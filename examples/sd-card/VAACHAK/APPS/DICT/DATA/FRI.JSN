{"FRIABIIITY":[{"def":"The quality of being friable; friableness.","pos":""}],"FRIAR":[{"def":"A brother or member of any religious order, but especially of one of the four mendicant orders, viz: (a) Minors, Gray Friars, or Franciscans.","pos":""},{"def":"A white or pale patch on a printed page.","pos":""}],"FRIARLY":[{"def":"Like a friar; inexperienced.","pos":""}],"FRIARY":[{"def":"Like a friar; pertaining to friars or to a convent.","pos":""}],"FRIATION":[{"def":"The act of breaking up or pulverizing.","pos":""}],"FRIBBLE":[{"def":"Frivolous; trifling; sily.","pos":""}],"FRIBBLER":[{"def":"A trifler; a fribble.","pos":""}],"FRIBBLING":[{"def":"Frivolous; trining; toolishly captious.","pos":""},{"def":"The pledge and tithing, afterwards called by the Normans frankpledge.","pos":""}],"FRICACE":[{"def":"A ragout or fricassee of veal; a fancy dish of veal or of boned turkey, served as an entrée, -- called also fricandel.","pos":""}],"FRICASSEE":[{"def":"A dish made of fowls, veal, or other meat of small animals cut into pieces, and stewed in a gravy.","pos":""}],"FRICATIVE":[{"def":"A fricative consonant letter or sound.","pos":""}],"FRICATRICE":[{"def":"A lewd woman; a harlot.","pos":""}],"FRICKLE":[{"def":"A bushel basket.","pos":""}],"FRICTION":[{"def":"The resistance which a body meets with from the surface on which it moves.","pos":""}],"FRICTIONAL":[{"def":"Relating to friction; moved by friction; produced by friction; as, frictional electricity.","pos":""}],"FRICTIONLESS":[{"def":"Having no friction.","pos":""}],"FRIDAY":[{"def":"The sixth day of the week, following Thursday and preceding Saturday.","pos":""}],"FRIDGE":[{"def":"To rub; to fray.","pos":""},{"def":"A seat in churches near the altar, to which offenders formerly fled for sanctuary.","pos":""}],"FRIEND":[{"def":"One who entertains for another suo Want gives to know the flatterer from the friend.","pos":""},{"def":"One not inimical or hostile; one not a foe or enemy; also, one of the same nation, party, kin, etc.","pos":""}],"FRIENDED":[{"def":"Having friends; [Obs.","pos":""},{"def":"Iuclined to love; well-disposed.","pos":""}],"FRIENDLESS":[{"def":"Destitute of friends; forsaken.","pos":""}],"FRIENDLILY":[{"def":"In a friendly manner.","pos":""}],"FRIENDLINESS":[{"def":"The condition or quality of being friendly.","pos":""}],"FRIENDLY":[{"def":"Having the temper and disposition of a friend; disposed to promote the good of another; kind; favorable.","pos":""},{"def":"Appropriate to, or implying, friendship; befitting friends; amicable.","pos":""}],"FRIENDSHIP":[{"def":"The state of being friends; friendly relation, or attachment, to a person, or between persons; affection arising from mutual esteem and good will; friendliness; amity; good will.","pos":""},{"def":"Kindly aid; help; assistance, [Obs.","pos":""}],"FRIESE":[{"def":"Same as Friesic, n.","pos":""}],"FRIESIC":[{"def":"Of or pertaining to Friesland, a province in the northern part of the Netherlands.","pos":""}],"FRIEZE":[{"def":"Cornice or frieze with bossy sculptures graven.","pos":""}],"FRIEZED":[{"def":"Gathered, or having the map gathered, into little tufts, knots, or protuberances.","pos":""}],"FRIEZER":[{"def":"One who, or that which, friezes or frizzes.","pos":""}],"FRIGATE":[{"def":"Originally, a vessel of the Mediterranean propelled by sails and by oars.","pos":""},{"def":"Any small vessel on the water.","pos":""}],"FRIGATE-BUILT":[{"def":"Built like a frigate with a raised quarter-deck and forecastle.","pos":""}],"FRIGATOON":[{"def":"A Venetian vessel, with a square stern, having only a mainmast, jigger mast, and bowsprit; also a sloop of war ship-rigged.","pos":""}],"FRIGEFACTION":[{"def":"The act of making cold.","pos":""}],"FRIGERATE":[{"def":"The wife of Odin and mother of the gods; the supreme goddess; the Juno of the Valhalla.","pos":""}],"FRIGHT":[{"def":"A state of terror excited by the sudden appearance of danger; sudden and violent fear, usually of short duration; a sudden alarm.","pos":""},{"def":"Anything strange, ugly or shocking, producing a feeling of alarm or aversion.","pos":""}],"FRIGHTEN":[{"def":"To disturb with fear; to throw into a state of alarm or fright; to affright; to terrify.","pos":""}],"FRIGHTFUL":[{"def":"Full of fright; affrighted; frightened.","pos":""},{"def":"Full of that which causes fright; exciting alarm; impressing terror; shocking; as, a frightful chasm, or tempest; a frightful appearance.","pos":""}],"FRIGHTFULLY":[{"def":"In a frightful manner; to a frightful dagree.","pos":""}],"FRIGHTFULNESS":[{"def":"The quality of being frightful.","pos":""}],"FRIGHTLESS":[{"def":"Free from fright; fearless.","pos":""}],"FRIGID":[{"def":"Cold; wanting heat or warmth; of low temperature; as, a frigid climate.","pos":""},{"def":"Wanting warmth, fervor, ardor, fire, vivacity, etc.","pos":""}],"FRIGIDARIUM":[{"def":"The cooling room of the Roman thermæ, furnished with a cold bath.","pos":""}],"FRIGIDITY":[{"def":"The condition or quality of being frigid; coldness; want of warmth.","pos":""},{"def":"Want of ardor, animation, vivacity, etc.","pos":""}],"FRIGIDLY":[{"def":"In a frigid manner; coldly; dully; without affection.","pos":""}],"FRIGIDNESS":[{"def":"The state of being frigid; want of heat, vigor, or affection; coldness; dullness.","pos":""},{"def":"Causing cold; producing or generating cold.","pos":""}],"FRILL":[{"def":"To wrinkle; -- said of the gelatin film.","pos":""}],"FRILLED":[{"def":"Furnished with a frill or frills.","pos":""}],"FRIM":[{"def":"Flourishing; thriving; fresh; in good case; vigorous.","pos":""}],"FRIMAIRE":[{"def":"The third month of the French republican calendar.","pos":""}],"FRINGE":[{"def":"One of a number of light or dark bands, produced by the interference of light; a diffraction band; -- called also interference fringe.","pos":""},{"def":"The peristome or fringelike appendage of the capsules of most mosses.","pos":""}],"FRINGE TREE":[{"def":"A small oleaceous tree (Chionanthus virginica), of the southern United States, having clusters of white flowers with slender petals.","pos":""}],"FRINGED":[{"def":"Furnished with a fringe.","pos":""}],"FRINGELESS":[{"def":"Having no fringe.","pos":""}],"FRINGENT":[{"def":"Encircling like a fringe; bordering.","pos":""}],"FRINGILLA":[{"def":"A genus of birds, with a short, conical, pointed bill.","pos":""}],"FRINGILLINE":[{"def":"Pertaining to the family Fringillidæ; characteristic of finches; sparrowlike.","pos":""}],"FRINGY":[{"def":"Aborned with fringes.","pos":""}],"FRIPPER":[{"def":"One who deals in frippery or in old clothes.","pos":""}],"FRIPPERY":[{"def":"Coast-off clothes.","pos":""},{"def":"Hence: Secondhand finery; cheap and tawdry decoration; affected elegance.","pos":""}],"FRISIAN":[{"def":"Of or pertaining to Friesland, a province of the Netherlands; Friesic.","pos":""}],"FRISK":[{"def":"Lively; brisk; frolicsome; frisky.","pos":""}],"FRISKAL":[{"def":"A leap or caper.","pos":""}],"FRISKER":[{"def":"One who frisks; one who leaps of dances in gayety; a wanton; an inconstant or unsettled person.","pos":""}],"FRISKET":[{"def":"The light frame which holds the sheet of paper to the tympan in printing.","pos":""}],"FRISKFUL":[{"def":"Brisk; lively; frolicsome.","pos":""}],"FRISKILY":[{"def":"In a frisky manner.","pos":""}],"FRISKINESS":[{"def":"State or quality of being frisky.","pos":""}],"FRISKY":[{"def":"Inclined to frisk; frolicsome; gay.","pos":""}],"FRISLET":[{"def":"[Fraise a kind of defense; also Friz.","pos":""}],"FRIST":[{"def":"To sell upon credit, as goods.","pos":""}],"FRISURE":[{"def":"The dressing of the hair by crisping or curling.","pos":""}],"FRIT":[{"def":"The material of which glass is made, after having been calcined or partly fused in a furnace, but before vitrification.","pos":""},{"def":"The material for glaze of pottery.","pos":""}],"FRITFLY":[{"def":"A small dipterous fly of the genus Oscinis, esp.","pos":""}],"FRITH":[{"def":"A narrow arm of the sea; an estuary; the opening of a river into the sea; as, the Frith of Forth.","pos":""}],"FRITILLARIA":[{"def":"A genus of liliaceous plants, of which the crown-imperial (Fritillaria imperialis) is one species, and the Guinea-hen flower (F.","pos":""}],"FRITILLARY":[{"def":"A plant with checkered petals, of the genus Fritillaria: the Guinea-hen flower.","pos":""},{"def":"One of several species of butterflies belonging to Argynnis and allied genera; -- so called because the coloring of their wings resembles that of the common Fritillaria.","pos":""}],"FRITINANCY":[{"def":"A chirping or creaking, as of a cricket.","pos":""}],"FRITTER":[{"def":"A small quantity of batter, fried in boiling lard or in a frying pan.","pos":""},{"def":"A fragment; a shred; a small piece.","pos":""}],"FRITTING":[{"def":"The formation of frit or slag by heat with but incipient fusion.","pos":""}],"FRIVOL":[{"def":"To act frivolously; to trifle.","pos":""}],"FRIVOLITY":[{"def":"The condition or quality of being frivolous; also, acts or habits of trifling; unbecoming levity of disposition.","pos":""}],"FRIVOLOUS":[{"def":"Of little weight or importance; not worth notice; slight; as, a frivolous argument.","pos":""},{"def":"Given to trifling; marked with unbecoming levity; silly; interested especially in trifling matters.","pos":""}],"FRIZ":[{"def":"To soften and make of even thickness by rubbing, as with pumice stone or a blunt instrument.","pos":""}],"FRIZEL":[{"def":"A movable furrowed piece of steel struck by the flint, to throw sparks into the pan, in an early form of flintlock.","pos":""}],"FRIZETTE":[{"def":"A curl of hair or silk; a pad of frizzed hair or silk worn by women under the hair to stuff it out.","pos":""}],"FRIZZLE":[{"def":"To curl or crisp, as hair; to friz; to crinkle.","pos":""}],"FRIZZLER":[{"def":"One who frizzles.","pos":""},{"def":"Curled or crisped; as, frizzly, hair.","pos":""}]}