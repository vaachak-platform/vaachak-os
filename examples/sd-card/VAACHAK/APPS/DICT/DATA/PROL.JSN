{"PROLAPSE":[{"def":"The falling down of a part through the orifice with which it is naturally connected, especially of the uterus or the rectum.","pos":""}],"PROLATE":[{"def":"Stretched out; extended; especially, elongated in the direction of a line joining the poles; as, a prolate spheroid; -- opposed to oblate.","pos":""}],"PROLATION":[{"def":"A mediæval method of determining of the proportionate duration of semibreves and minims.","pos":""}],"PROLATUM":[{"def":"A prolate spheroid.","pos":""}],"PROLEG":[{"def":"One of the fleshy legs found on the abdominal segments of the larvæ of Lepidoptera, sawflies, and some other insects.","pos":""}],"PROLEGATE":[{"def":"The deputy or substitute for a legate.","pos":""}],"PROLEGOMENARY":[{"def":"Of the nature of a prolegomenon; preliminary; introductory; prefatory.","pos":""}],"PROLEGOMENON":[{"def":"A preliminary remark or observation; an introductory discourse prefixed to a book or treatise.","pos":""}],"PROLEPSIS":[{"def":"An error in chronology, consisting in an event being dated before the actual time.","pos":""},{"def":"The application of an adjective to a noun in anticipation, or to denote the result, of the action of the verb; as, to strike one dumb.","pos":""}],"PROLEPTICALLY":[{"def":"In a proleptical manner.","pos":""}],"PROLEPTICS":[{"def":"The art and science of predicting in medicine.","pos":""}],"PROLETAIRE":[{"def":"One of the common people; a low person; also, the common people as a class or estate in a country.","pos":""}],"PROLETANEOUS":[{"def":"Having a numerous offspring.","pos":""}],"PROLETARIAN":[{"def":"Of or pertaining to the proletaries; belonging to the commonalty; hence, mean; vile; vulgar.","pos":""}],"PROLETARIAT":[{"def":"The indigent class in the State; the body of proletarians.","pos":""}],"PROLETARIATE":[{"def":"The lower classes; beggars.","pos":""}],"PROLETARY":[{"def":"A citizen of the lowest class, who served the state, not with property, but only by having children; hence, a common person.","pos":""}],"PROLICIDE":[{"def":"The crime of destroying one's offspring, either in the womb or after birth.","pos":""}],"PROLIFERATE":[{"def":"To produce or form cells; especially, to produce cells rapidly.","pos":""},{"def":"To produce zooids by budding.","pos":""}],"PROLIFERATION":[{"def":"The continuous development of cells in tissue formation; cell formation.","pos":""},{"def":"The production of numerous zooids by budding, especially when buds arise from other buds in succession.","pos":""}],"PROLIFEROUS":[{"def":"Bearing offspring; -- applied to a flower from within which another is produced, or to a branch or frond from which another rises, or to a plant which is reproduced by buds or gemmæ.","pos":""}],"PROLIFIC":[{"def":"Having the quality of generating; producing young or fruit; generative; fruitful; productive; -- applied to plants producing fruit, animals producing young, etc.","pos":""},{"def":"Serving to produce; fruitful of results; active; as, a prolific brain; a controversy prolific of evil.","pos":""}],"PROLIFICAL":[{"def":"Producing young or fruit abundantly; fruitful; prolific.","pos":""}],"PROLIFICATE":[{"def":"To make prolific; to fertilize; to impregnate.","pos":""}],"PROLIFICATION":[{"def":"Reproduction by the growth of a plant, or part of a plant, directly from an older one, or by gemmæ.","pos":""}],"PROLIFICNESS":[{"def":"The quality or state of being prolific; fruitfulness; prolificacy.","pos":""}],"PROLIX":[{"def":"Extending to a great length; unnecessarily long; minute in narration or argument; excessively particular in detail; -- rarely used except with reference to discourse written or spoken; as, a prolix oration; a prolix poem; a prolix sermon.","pos":""},{"def":"Indulging in protracted discourse; tedious; wearisome; -- applied to a speaker or writer.","pos":""}],"PROLIXIOUS":[{"def":"Dilatory; tedious; superfluous.","pos":""}],"PROLIXITY":[{"def":"The quality or state of being prolix; great length; minute detail; as, prolixity in discourses and writings.","pos":""}],"PROLIXLY":[{"def":"In a prolix manner.","pos":""}],"PROLL":[{"def":"To search or prowl after; to rob; to plunder.","pos":""}],"PROLOCUTOR":[{"def":"One who speaks for another.","pos":""},{"def":"The presiding officer of a convocation.","pos":""}],"PROLOCUTORSHIP":[{"def":"The office of a prolocutor.","pos":""}],"PROLOGIZE":[{"def":"To deliver a Prologue.","pos":""}],"PROLOGIZER":[{"def":"One who prologizes.","pos":""}],"PROLOGUE":[{"def":"The preface or introduction to a discourse, poem, or performance; as, the prologue of Chaucer's \"Canterbury Tales;\" esp.","pos":""},{"def":"One who delivers a prologue.","pos":""}],"PROLONG":[{"def":"To extend in space or length; as, to prolong a line.","pos":""},{"def":"To lengthen in time; to extend the duration of; to draw out; to continue; as, to prolong one's days.","pos":""}],"PROLONGABLE":[{"def":"Capable of being prolonged; as, life is prolongable by care.","pos":""}],"PROLONGATE":[{"def":"To prolong; to extend in space or in time.","pos":""}],"PROLONGATION":[{"def":"The act of lengthening in space or in time; extension; protraction.","pos":""},{"def":"That which forms an additional length.","pos":""}],"PROLONGE":[{"def":"A rope with a hook and a toggle, sometimes used to drag a gun carriage or to lash it to the limber, and for various other purposes.","pos":""}],"PROLONGER":[{"def":"One who, or that which, causes an extension in time or space.","pos":""}],"PROLUSION":[{"def":"A trial before the principal performance; a prelude; hence, an introductory essay or exercise.","pos":""}]}