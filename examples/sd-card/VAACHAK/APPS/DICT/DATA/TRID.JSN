{"TRIDACNA":[{"def":"A genus of very large marine bivalve shells found on the coral reefs of the Indian and Pacific Oceans.","pos":""},{"def":"Having three fingers or toes, or composed of three movable parts attached to a common base.","pos":""}],"TRIDE":[{"def":"Short and ready; fleet; as, a tride pace; -- a term used by sportsmen.","pos":""}],"TRIDECANE":[{"def":"A hydrocarbon, C13H28, of the methane series, which is a probable ingredient both of crude petroleum and of kerosene, and is produced artificially as a light colorless liquid.","pos":""}],"TRIDECATOIC":[{"def":"Of, pertaining to, or designating, that acid of the fatty acids heterologous with tridecane.","pos":""}],"TRIDECATYLENE":[{"def":"A hydrocarbon, C13H26, of the ethylene series, corresponding to tridecane, and obtained from Burmah petroleum as a light colorless liquid; -- called also tridecylene, and tridecene.","pos":""}],"TRIDENT":[{"def":"A kind of scepter or spear with three prongs, -- the common attribute of Neptune.","pos":""},{"def":"A three-pronged spear or goad, used for urging horses; also, the weapon used by one class of gladiators.","pos":""}],"TRIDENTED":[{"def":"Having three prongs; trident; tridentate; as, a tridented mace.","pos":""}],"TRIDENTIFEROUS":[{"def":"Bearing a trident.","pos":""}],"TRIDENTINE":[{"def":"Of or pertaining to Trent, or the general church council held in that city.","pos":""}],"TRIDIAPASON":[{"def":"A triple octave, or twenty-second.","pos":""}],"TRIDIMENSIONAL":[{"def":"Having three dimensions; extended in three different directions.","pos":""}],"TRIDUAN":[{"def":"Lasting three lays; also, happening every third day.","pos":""}],"TRIDYMITE":[{"def":"Pure silica, like quartz, but crystallizing in hexagonal tables.","pos":""}]}