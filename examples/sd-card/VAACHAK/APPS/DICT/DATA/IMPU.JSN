{"IMPUBERAL":[{"def":"Not having arrived at puberty; immature.","pos":""}],"IMPUBERTY":[{"def":"The condition of not having reached puberty, or the age of ability to reproduce one's species; want of age at which the marriage contract can be legally entered into.","pos":""}],"IMPUDENCE":[{"def":"The quality of being impudent; assurance, accompanied with a disregard of the presence or opinions of others; shamelessness; forwardness; want of modesty.","pos":""}],"IMPUDENCY":[{"def":"Audacious without impudency.","pos":""}],"IMPUDENT":[{"def":"Bold, with contempt or disregard; unblushingly forward; impertinent; wanting modesty; shameless; saucy.","pos":""}],"IMPUDENTLY":[{"def":"In an impudent manner; with unbecoming assurance; shamelessly.","pos":""}],"IMPUGN":[{"def":"To attack by words or arguments; to contradict; to assail; to call in question; to make insinuations against; to gainsay; to oppose.","pos":""}],"IMPUGNABLE":[{"def":"Capable of being impugned; that may be gainsaid.","pos":""}],"IMPUGNATION":[{"def":"Act of impugning; opposition; attack.","pos":""}],"IMPUGNER":[{"def":"One who impugns.","pos":""}],"IMPUGNMENT":[{"def":"The act of impugning, or the state of being impugned.","pos":""}],"IMPUISSANCE":[{"def":"Lack of power; inability.","pos":""}],"IMPUISSANT":[{"def":"Weak; impotent; feeble.","pos":""}],"IMPULSE":[{"def":"The action of a force during a very small interval of time; the effect of such action; as, the impulse of a sudden blow upon a hard elastic body.","pos":""}],"IMPULSION":[{"def":"The act of impelling or driving onward, or the state of being impelled; the sudden or momentary agency of a body in motion on another body; also, the impelling force, or impulse.","pos":""},{"def":"Influence acting unexpectedly or temporarily on the mind; sudden motive or influence; impulse.","pos":""}],"IMPULSIVE":[{"def":"Acting momentarily, or by impulse; not continuous; -- said of forces.","pos":""}],"IMPULSIVELY":[{"def":"In an impulsive manner.","pos":""}],"IMPULSIVENESS":[{"def":"The quality of being impulsive.","pos":""}],"IMPULSOR":[{"def":"One who, or that which, impels; an inciter.","pos":""}],"IMPUNCTATE":[{"def":"Not punctuate or dotted.","pos":""}],"IMPUNCTUALITY":[{"def":"Neglect of, or failure in, punctuality.","pos":""}],"IMPUNIBLY":[{"def":"Without punishment; with impunity.","pos":""}],"IMPUNITY":[{"def":"Exemption or freedom from punishment, harm, or loss.","pos":""}],"IMPURATION":[{"def":"Defilement; obscuration.","pos":""}],"IMPURE":[{"def":"Not purified according to the ceremonial law of Moses; unclean.","pos":""},{"def":"Not accurate; not idiomatic; as, impure Latin; an impure style.","pos":""}],"IMPURELY":[{"def":"In an impure manner.","pos":""}],"IMPURENESS":[{"def":"The quality or condition of being impure; impurity.","pos":""}],"IMPURITY":[{"def":"Want of ceremonial purity; defilement.","pos":""}],"IMPURPLE":[{"def":"To color or tinge with purple; to make red or reddish; to purple; as, a field impurpled with blood.","pos":""}],"IMPUTABILITY":[{"def":"The quality of being imputable; imputableness.","pos":""}],"IMPUTABLE":[{"def":"That may be imputed; capable of being imputed; chargeable; ascribable; attributable; referable.","pos":""},{"def":"Accusable; culpable.","pos":""}],"IMPUTABLENESS":[{"def":"Quality of being imputable.","pos":""}],"IMPUTATION":[{"def":"A setting of something to the account of; the attribution of personal guilt or personal righteousness of another; as, the imputation of the sin of Adam, or the righteousness of Christ.","pos":""}],"IMPUTATIVE":[{"def":"Transferred by imputation; that may be imputed.","pos":""}],"IMPUTE":[{"def":"To adjudge as one's own (the sin or righteousness) of another; as, the righteousness of Christ is imputed to us.","pos":""}],"IMPUTER":[{"def":"One who imputes.","pos":""}],"IMPUTRESCIBLE":[{"def":"Not putrescible.","pos":""}]}