{"MANU":[{"def":"One of a series of progenitors of human beings, and authors of human wisdom.","pos":""}],"MANUAL":[{"def":"Of or pertaining to the hand; done or made by the hand; as, manual labor; the king's sign manual.","pos":""}],"MANUBIAL":[{"def":"Belonging to spoils; taken in war.","pos":""}],"MANUBRIAL":[{"def":"Of or pertaining to a manubrium; shaped like a manubrium; handlelike.","pos":""}],"MANUBRIUM":[{"def":"A handlelike process or part; esp.","pos":""},{"def":"The proboscis of a jellyfish; -- called also hypostoma.","pos":""}],"MANUCODE":[{"def":"Any bird of the genus Manucodia, of Australia and New Guinea.","pos":""}],"MANUDUCENT":[{"def":"One who leads by the hand; a manuductor.","pos":""}],"MANUDUCTION":[{"def":"Guidance by the hand.","pos":""}],"MANUDUCTOR":[{"def":"A conductor; an officer in the ancient church who gave the signal for the choir to sing, and who beat time with the hand, and regulated the music.","pos":""}],"MANUFACTORY":[{"def":"A building or place where anything is manufactured; a factory.","pos":""}],"MANUFACTURAL":[{"def":"Of or pertaining to manufactures.","pos":""}],"MANUFACTURE":[{"def":"The operation of making wares or any products by hand, by machinery, or by other agency.","pos":""},{"def":"Anything made from raw materials by the hand, by machinery, or by art, as cloths, iron utensils, shoes, machinery, saddlery, etc.","pos":""}],"MANUFACTURER":[{"def":"One who manufactures.","pos":""}],"MANUFACTURING":[{"def":"Employed, or chiefly employed, in manufacture; as, a manufacturing community; a manufacturing town.","pos":""},{"def":"Pertaining to manufacture; as, manufacturing projects.","pos":""}],"MANUL":[{"def":"A wild cat (Felis manul), having long, soft, light-colored fur.","pos":""}],"MANUMISSION":[{"def":"The act of manumitting, or of liberating a slave from bondage.","pos":""}],"MANUMIT":[{"def":"To release from slavery; to liberate from personal bondage or servitude; to free, as a slave.","pos":""}],"MANUMOTIVE":[{"def":"Movable by hand.","pos":""}],"MANUMOTOR":[{"def":"A small wheel carriage, so constructed that a person sitting in it may move it.","pos":""}],"MANURABLE":[{"def":"Capable of cultivation.","pos":""},{"def":"Capable of receiving a fertilizing substance.","pos":""}],"MANURE":[{"def":"To cultivate by manual labor; to till; hence, to develop by culture.","pos":""},{"def":"To apply manure to; to enrich, as land, by the application of a fertilizing substance.","pos":""}],"MANURER":[{"def":"One who manures land.","pos":""}],"MANURIAL":[{"def":"Relating to manures.","pos":""}],"MANURING":[{"def":"The act of process of applying manure; also, the manure applied.","pos":""}],"MANUS":[{"def":"The distal segment of the fore limb, including the carpus and fore foot or hand.","pos":""}],"MANUSCRIPT":[{"def":"Written with or by the hand; not printed; as, a manuscript volume.","pos":""}]}