{"CAM":[{"def":"A ridge or mound of earth.","pos":""}],"CAMAIEU":[{"def":"Painting in shades of one color; monochrome.","pos":""}],"CAMAIL":[{"def":"A neck guard of chain mall, hanging from the bascinet or other headpiece.","pos":""},{"def":"Chamber; house; -- used in Ca\"ma*ra dos Pa\"res, and Ca\"ma*ra dos De`pu*ta\"dos.","pos":""}],"CAMARADERIE":[{"def":"Comradeship and loyalty.","pos":""}],"CAMARASAURUS":[{"def":"A genus of gigantic American Jurassic dinosaurs, having large cavities in the bodies of the dorsal vertebræ.","pos":""}],"CAMARILLA":[{"def":"The private audience chamber of a king.","pos":""},{"def":"A company of secret and irresponsible advisers, as of a king; a cabal or clique.","pos":""}],"CAMASS":[{"def":"A blue-flowered liliaceous plant (Camassia esculenta) of northwestern America, the bulbs of which are collected for food by the Indians.","pos":""}],"CAMBER":[{"def":"An upward convexity of a deck or other surface; as, she has a high camber (said of a vessel having an unusual convexity of deck).","pos":""},{"def":"An upward concavity in the under side of a beam, girder, or lintel; also, a slight upward concavity in a straight arch.","pos":""}],"CAMBERKEELED":[{"def":"Having the keel arched upwards, but not actually hogged; -- said of a ship.","pos":""}],"CAMBIAL":[{"def":"Belonging to exchanges in commerce; of exchange.","pos":""}],"CAMBIST":[{"def":"A banker; a money changer or broker; one who deals in bills of exchange, or who is skilled in the science of exchange.","pos":""}],"CAMBISTRY":[{"def":"The science of exchange, weight, measures, etc.","pos":""}],"CAMBIUM":[{"def":"A series of formative cells lying outside of the wood proper and inside of the inner bark.","pos":""},{"def":"A fancied nutritive juice, formerly supposed to orgiginate in the blood, to repair losses of the system, and to promote its increase.","pos":""}],"CAMBRASINE":[{"def":"A kind of linen cloth made in Egypt, and so named from its resemblance to cambric.","pos":""}],"CAMBRIA":[{"def":"The ancient Latin name of Wales.","pos":""}],"CAMBRIAN":[{"def":"Of or pertaining to Cambria or Wales.","pos":""},{"def":"Of or pertaining to the lowest subdivision of the rocks of the Silurian or Molluscan age; -- sometimes described as inferior to the Silurian.","pos":""}],"CAMBRIC":[{"def":"A fine, thin, and white fabric made of flax or linen.","pos":""},{"def":"A fabric made, in imitation of linen cambric, of fine, hardspun cotton, often with figures of various colors; -- also called cotton cambric, and cambric muslin.","pos":""}],"CAME":[{"def":"A slender rod of cast lead, with or without grooves, used, in casements and stained-glass windows, to hold together the panes or pieces of glass.","pos":""}],"CAMEL":[{"def":"A large ruminant used in Asia and Africa for carrying burdens and for riding.","pos":""},{"def":"A watertight structure (as a large box or boxes) used to assist a vessel in passing over a shoal or bar or in navigating shallow water.","pos":""}],"CAMELLIA":[{"def":"An Asiatic genus of small shrubs, often with shining leaves and showy flowers.","pos":""}],"CAMELOPARD":[{"def":"An African ruminant; the giraffe.","pos":""}],"CAMELRY":[{"def":"Troops that are mounted on camels.","pos":""}],"CAMELSHAIR":[{"def":"Of camel's hair.","pos":""},{"def":"A kind of soft, unpressed cream cheese made in the vicinity of Camembert, near Argentan, France; also, any cheese of the same type, wherever made.","pos":""}],"CAMEO":[{"def":"A carving in relief, esp.","pos":""}],"CAMERA":[{"def":"A chamber, or instrument having a chamber.","pos":""}],"CAMERA LUCIDA":[{"def":"An instrument which by means of a prism of a peculiar form, or an arrangement of mirrors, causes an apparent image of an external object or objects to appear as if projected upon a plane surface, as of paper or canvas, so that the outlines may conveniently traced.","pos":""}],"CAMERA OBSCURA":[{"def":"An apparatus in which the image of an external object or objects is, by means of lenses.","pos":""}],"CAMERADE":[{"def":"See Comrade, [Obs.","pos":""}],"CAMERALISTIC":[{"def":"Of or pertaining to finance and public revenue.","pos":""}],"CAMERALISTICS":[{"def":"The science of finance or public revenue.","pos":""}],"CAMERATE":[{"def":"To build in the form of a vault; to arch over.","pos":""},{"def":"To divide into chambers.","pos":""}],"CAMERATION":[{"def":"A vaulting or arching over.","pos":""}],"CAMERLINGO":[{"def":"The papal chamberlain; the cardinal who presides over the pope's household.","pos":""}],"CAMERONIAN":[{"def":"A follower of the Rev.","pos":""}],"CAMIS":[{"def":"A light, loose dress or robe.","pos":""}],"CAMISARD":[{"def":"One of the French Protestant insurgents who rebelled against Louis XIV, after the revocation of the edict of Nates; -- so called from the peasant's smock (camise) which they wore.","pos":""}],"CAMISATED":[{"def":"Dressed with a shirt over the other garments.","pos":""}],"CAMISOLE":[{"def":"A short dressing jacket for women.","pos":""},{"def":"A kind of straitjacket.","pos":""}],"CAMLET":[{"def":"A woven fabric originally made of camel's hair, now chiefly of goat's hair and silk, or of wool and cotton.","pos":""}],"CAMLETED":[{"def":"Wavy or undulating like camlet; veined.","pos":""}],"CAMMOCK":[{"def":"A plant having long hard, crooked roots, the Ononis spinosa; -- called also rest-harrow.","pos":""},{"def":"A genus of herbs (Anthemis) of the Composite family.","pos":""}],"CAMONFLET":[{"def":"A small mine, sometimes formed in the wall or side of an enemy's gallery, to blow in the earth and cut off the retreat of the miners.","pos":""}],"CAMORRA":[{"def":"A secret organization formed at Naples, Italy, early in the 19th century, and used partly for political ends and partly for practicing extortion, violence, etc.","pos":""},{"def":"Flat; depressed; crooked; -- said only of the nose.","pos":""}],"CAMOUSED":[{"def":"Depressed; flattened.","pos":""}],"CAMP":[{"def":"A mound of earth in which potatoes and other vegetables are stored for protection against frost; -- called also burrow and pie.","pos":""},{"def":"An ancient game of football, played in some parts of England.","pos":""}],"CAMPAGNA":[{"def":"An open level tract of country; especially \"Campagna di Roma.","pos":""}],"CAMPAGNOL":[{"def":"A mouse (Arvicala agrestis), called also meadow mouse, which often does great damage in fields and gardens, by feeding on roots and seeds.","pos":""}],"CAMPAIGN":[{"def":"A connected series of military operations forming a distinct stage in a war; the time during which an army keeps the field.","pos":""},{"def":"The period during which a blast furnace is continuously in operation.","pos":""}],"CAMPAIGNER":[{"def":"One who has served in an army in several campaigns; an old soldier; a veteran.","pos":""}],"CAMPANA":[{"def":"The pasque flower.","pos":""}],"CAMPANED":[{"def":"Furnished with, or bearing, campanes, or bells.","pos":""}],"CAMPANERO":[{"def":"The bellbird of South America.","pos":""}],"CAMPANILE":[{"def":"A bell tower, esp.","pos":""}],"CAMPANILIFORM":[{"def":"Bell-shaped; campanulate; campaniform.","pos":""}],"CAMPANOLOGIST":[{"def":"One skilled in campanology; a bell ringer.","pos":""}],"CAMPANOLOGY":[{"def":"The art of ringing bells, or a treatise on the art.","pos":""}],"CAMPANULA":[{"def":"A large genus of plants bearing bell-shaped flowers, often of great beauty; -- also called bellflower.","pos":""}],"CAMPANULACEOUS":[{"def":"Of pertaining to, or resembling, the family of plants (Camponulaceæ) of which Campanula is the type, and which includes the Canterbury bell, the harebell, and the Venus's looking-glass.","pos":""}],"CAMPANULARIAN":[{"def":"A hydroid of the family ampanularidæ, characterized by having the polyps or zooids inclosed in bell-shaped calicles or hydrothecæ.","pos":""}],"CAMPBELLITE":[{"def":"A member of the denomination called Christians or Disciples of Christ.","pos":""}],"CAMPER":[{"def":"One who lodges temporarily in a hut or camp.","pos":""},{"def":"Relating to an open fields; drowing in a field; growing in a field, or open ground.","pos":""}],"CAMPFIGHT":[{"def":"A duel; the decision of a case by a duel.","pos":""}],"CAMPHENE":[{"def":"One of a series of substances C10H16, resembling camphor, regarded as modified terpenes.","pos":""}],"CAMPHINE":[{"def":"Rectified oil of turpentine, used for burning in lamps, and as a common solvent in varnishes.","pos":""}],"CAMPHIRE":[{"def":"An old spelling of Camphor.","pos":""}],"CAMPHOR":[{"def":"A tough, white, aromatic resin, or gum, obtained from different species of the Laurus family, esp.","pos":""},{"def":"A gum resembing ordinary camphor, obtained from a tree (Dryobalanops camphora) growing in Sumatra and Borneo; -- called also Malay camphor, camphor of Borneo, or borneol.","pos":""}],"CAMPHORACEOUS":[{"def":"Of the nature of camphor; containing camphor.","pos":""}],"CAMPHORATE":[{"def":"To impregnate or treat with camphor.","pos":""}],"CAMPHORIC":[{"def":"Of, pertaining to, or derived from, camphor.","pos":""}],"CAMPHRETIC":[{"def":"Pertaining to, or derived from camphor.","pos":""}],"CAMPING":[{"def":"A game of football.","pos":""}],"CAMPION":[{"def":"A plant of the Pink family (Cucubalus bacciferus), bearing berries regarded as poisonous.","pos":""}],"CAMPUS":[{"def":"The principal grounds of a college or school, between the buildings or within the main inclosure; as, the college campus.","pos":""}],"CAMPYLOSPERMOUS":[{"def":"Having seeds grooved lengthwise on the inner face, as in sweet cicely.","pos":""}],"CAMPYLOTROPOUS":[{"def":"Having the ovules and seeds so curved, or bent down upon themselves, that the ends of the embryo are brought close together.","pos":""}]}