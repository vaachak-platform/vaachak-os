{"AE":[{"def":"A diphthong in the Latin language; used also by the Saxon writers.","pos":""}],"AECIDIUM":[{"def":"A form of fruit in the cycle of development of the Rusts or Brands, an order of fungi, formerly considered independent plants.","pos":""}],"AEDILE":[{"def":"A magistrate in ancient Rome, who had the superintendence of public buildings, highways, shows, etc.","pos":""}],"AEDILESHIP":[{"def":"The office of an ædile.","pos":""}],"AEGEAN":[{"def":"Of or pertaining to the sea, or arm of the Mediterranean sea, east of Greece.","pos":""}],"AEGICRANIA":[{"def":"Sculptured ornaments, used in classical architecture, representing rams' heads or skulls.","pos":""}],"AEGILOPS":[{"def":"An ulcer or fistula in the inner corner of the eye.","pos":""}],"AEGIS":[{"def":"A shield or protective armor; -- applied in mythology to the shield of Jupiter which he gave to Minerva.","pos":""}],"AEGOPHONY":[{"def":"Same as Egophony.","pos":""}],"AEGROTAT":[{"def":"A medical certificate that a student is ill.","pos":""}],"AENEID":[{"def":"The great epic poem of Virgil, of which the hero is Æneas.","pos":""}],"AENEOUS":[{"def":"Colored like bronze.","pos":""}],"AEOLIAN":[{"def":"Of or pertaining to Æolia or Æolis, in Asia Minor, colonized by the Greeks, or to its inhabitants; æolic; as, the Æolian dialect.","pos":""},{"def":"Pertaining to Æolus, the mythic god of the winds; pertaining to, or produced by, the wind; aërial.","pos":""}],"AEOLIC":[{"def":"Æolian, 1; as, the Æolic dialect; the Æolic mode.","pos":""},{"def":"An apparatus consisting chiefly of a closed vessel (as a globe or cylinder) with one or more projecting bent tubes, through which steam is made to pass from the vessel, causing it to revolve.","pos":""}],"AEOLOTROPIC":[{"def":"Exhibiting differences of quality or property in different directions; not isotropic.","pos":""}],"AEOLOTROPY":[{"def":"Difference of quality or property in different directions.","pos":""}],"AEOLUS":[{"def":"The god of the winds.","pos":""}],"AEON":[{"def":"A period of immeasurable duration; also, an emanation of the Deity.","pos":""}],"AEONIAN":[{"def":"Eternal; everlasting.","pos":""}],"AEPYORNIS":[{"def":"A gigantic bird found fossil in Madagascar.","pos":""}],"AERATE":[{"def":"To expose to the chemical action of air; to oxygenate (the blood) by respiration; to arterialize.","pos":""}],"AERATION":[{"def":"A change produced in the blood by exposure to the air in respiration; oxygenation of the blood in respiration; arterialization.","pos":""}],"AERATOR":[{"def":"That which supplies with air; esp.","pos":""},{"def":"A secondary respiratory tissue or modified periderm, found in many aquatic plants and distinguished by the large intercellular spaces.","pos":""}],"AERIAL":[{"def":"Of or pertaining to the air, or atmosphere; inhabiting or frequenting the air; produced by or found in the air; performed in the air; as, aërial regions or currents.","pos":""},{"def":"Consisting of air; resembling, or partaking of the nature of air.","pos":""}],"AERIAL SICKNESS":[{"def":"A sickness felt by aëronauts due to high speed of flights and rapidity in changing altitudes, combining some symptoms of mountain sickness and some of seasickness.","pos":""}],"AERIALITY":[{"def":"The state of being aërial; [R.","pos":""}],"AERIALLY":[{"def":"Like, or from, the air; in an aërial manner.","pos":""}],"AERIE":[{"def":"The nest of a bird of prey, as of an eagle or hawk; also a brood of such birds; eyrie.","pos":""}],"AERIFEROUS":[{"def":"Conveying or containing air; air-bearing; as, the windpipe is an aëriferous tube.","pos":""}],"AERIFICATION":[{"def":"The act of combining air with another substance, or the state of being filled with air.","pos":""},{"def":"The act of becoming aërified, or of changing from a solid or liquid form into an aëriform state; the state of being aëriform.","pos":""}],"AERIFORM":[{"def":"Having the form or nature of air, or of an elastic fluid; gaseous.","pos":""}],"AERIFY":[{"def":"To infuse air into; to combine air with.","pos":""},{"def":"To change into an aëriform state.","pos":""}],"AERO-":[{"def":"The combining form of the Greek word meaning air.","pos":""}],"AEROBIC":[{"def":"Growing or thriving only in the presence of oxygen; also, pertaining to, or induced by, aërobies; as, aërobic fermentation.","pos":""}],"AEROBIES":[{"def":"Microörganisms which live in contact with the air and need oxygen for their growth; as the microbacteria which form on the surface of putrefactive fluids.","pos":""}],"AEROBIOTIC":[{"def":"Related to, or of the nature of, aërobies; as, aërobiotic plants, which live only when supplied with free oxygen.","pos":""}],"AEROBOAT":[{"def":"A form of hydro-aëroplane; a flying boat.","pos":""}],"AEROBUS":[{"def":"An aëroplane or airship designed to carry passengers.","pos":""}],"AEROCLUB":[{"def":"A club or association of persons interested in aëronautics.","pos":""}],"AEROCURVE":[{"def":"A modification of the aëroplane, having curved surfaces, the advantages of which were first demonstrated by Lilienthal.","pos":""}],"AEROCYST":[{"def":"One of the air cells of algals.","pos":""}],"AERODONETICS":[{"def":"The science of gliding and soaring flight.","pos":""}],"AERODYNAMIC":[{"def":"Pertaining to the force of air in motion.","pos":""}],"AERODYNAMICS":[{"def":"The science which treats of the air and other gaseous bodies under the action of force, and of their mechanical effects.","pos":""}],"AEROFOIL":[{"def":"A plane or arched surface for sustaining bodies by its movement through the air; a spread wing, as of a bird.","pos":""}],"AEROGNOSY":[{"def":"The science which treats of the properties of the air, and of the part it plays in nature.","pos":""}],"AEROGRAPHER":[{"def":"One versed in aëography: an aërologist.","pos":""},{"def":"Pertaining to aërography; aërological.","pos":""}],"AEROGRAPHY":[{"def":"A description of the air or atmosphere; aërology.","pos":""}],"AEROGUN":[{"def":"A cannon capable of being trained at very high angles for use against aircraft.","pos":""}],"AEROHYDRODYNAMIC":[{"def":"Acting by the force of air and water; as, an aërohydrodynamic wheel.","pos":""}],"AEROLITE":[{"def":"A stone, or metallic mass, which has fallen to the earth from distant space; a meteorite; a meteoric stone.","pos":""}],"AEROLITHOLOGY":[{"def":"The science of aërolites.","pos":""}],"AEROLITIC":[{"def":"Of or pertaining to aërolites; meteoric; as, aërolitic iron.","pos":""},{"def":"Of or pertaining to aërology.","pos":""}],"AEROLOGIST":[{"def":"One versed in aërology.","pos":""}],"AEROLOGY":[{"def":"That department of physics which treats of the atmosphere.","pos":""}],"AEROMANCY":[{"def":"Divination from the state of the air or from atmospheric substances; also, forecasting changes in the weather.","pos":""}],"AEROMECHANIC":[{"def":"A mechanic or mechanician expert in the art and practice of aëronautics.","pos":""}],"AEROMECHANICS":[{"def":"The science of equilibrium and motion of air or an aëriform fluid, including aërodynamics and aërostatics.","pos":""}],"AEROMETER":[{"def":"An instrument for ascertaining the weight or density of air and gases.","pos":""}],"AEROMETRIC":[{"def":"Of or pertaining to aërometry; as, aërometric investigations.","pos":""}],"AEROMETRY":[{"def":"The science of measuring the air, including the doctrine of its pressure, elasticity, rarefaction, and condensation; pneumatics.","pos":""}],"AERONAT":[{"def":"A dirigible balloon.","pos":""}],"AERONAUT":[{"def":"An aërial navigator; a balloonist.","pos":""},{"def":"Pertaining to aëronautics, or aërial sailing.","pos":""}],"AERONAUTICS":[{"def":"The science or art of ascending and sailing in the air, as by means of a balloon; aërial navigation; ballooning.","pos":""}],"AERONEF":[{"def":"A power-driven, heavier-than-air flying machine.","pos":""},{"def":"Dread of a current of air.","pos":""}],"AEROPHYTE":[{"def":"A plant growing entirely in the air, and receiving its nourishment from it; an air plant or epiphyte.","pos":""}],"AEROPLANE":[{"def":"A flying machine, or a small plane for experiments on flying, which floats in the air only when propelled through it.","pos":""}],"AEROPLANIST":[{"def":"One who flies in an aëroplane.","pos":""}],"AEROSCOPE":[{"def":"An apparatus designed for collecting spores, germs, bacteria, etc.","pos":""}],"AEROSCOPY":[{"def":"The observation of the state and variations of the atmosphere.","pos":""}],"AEROSE":[{"def":"Of the nature of, or like, copper; brassy.","pos":""}],"AEROSIDERITE":[{"def":"A mass of meteoric iron.","pos":""}],"AEROSTAT":[{"def":"A balloonist; an aëronaut.","pos":""}],"AEROSTATICS":[{"def":"The science that treats of the equilibrium of elastic fluids, or that of bodies sustained in them.","pos":""}],"AEROSTATION":[{"def":"Aërial navigation; the art of raising and guiding balloons in the air.","pos":""},{"def":"The science of weighing air; aërostatics.","pos":""}],"AEROTAXIS":[{"def":"The positive or negative stimulus exerted by oxygen on aërobic and anaërobic bacteria.","pos":""}],"AEROTHERAPENTICS":[{"def":"Treatment of disease by the use of air or other gases.","pos":""}],"AEROYACHT":[{"def":"A form of hydro-aëroplane; a flying boat.","pos":""}],"AERUGINOUS":[{"def":"Of the nature or color of verdigris, or the rust of copper.","pos":""}],"AERUGO":[{"def":"The rust of any metal, esp.","pos":""}],"AERY":[{"def":"Aërial; ethereal; incorporeal; visionary.","pos":""}],"AESCULAPIAN":[{"def":"Pertaining to Æsculapius or to the healing art; medical; medicinal.","pos":""}],"AESCULAPIUS":[{"def":"The god of medicine.","pos":""}],"AESCULIN":[{"def":"Same as Esculin.","pos":""}],"AESIR":[{"def":"In the old Norse mythology, the gods Odin, Thor, Loki, Balder, Frigg, and the others.","pos":""},{"def":"Of or pertaining to Æsop, or in his manner.","pos":""}],"AESTHESIA":[{"def":"Perception by the senses; feeling; -- the opposite of anæsthesia.","pos":""},{"def":"An instrument to measure the degree of sensation, by determining at how short a distance two impressions upon the skin can be distinguished, and thus to determine whether the condition of tactile sensibility is normal or altered.","pos":""}],"AESTHESIS":[{"def":"Sensuous perception.","pos":""}],"AESTHESODIC":[{"def":"Conveying sensory or afferent impulses; -- said of nerves.","pos":""}],"AESTHETE":[{"def":"One who makes much or overmuch of æsthetics.","pos":""},{"def":"Of or Pertaining to æsthetics; versed in æsthetics; as, æsthetic studies, emotions, ideas, persons, etc.","pos":""}],"AESTHETICAN":[{"def":"One versed in æsthetics.","pos":""}],"AESTHETICISM":[{"def":"The doctrine of æsthetics; æsthetic principles; devotion to the beautiful in nature and art.","pos":""},{"def":"The theory or philosophy of taste; the science of the beautiful in nature and art; esp.","pos":""}],"AESTHO-PHYSIOLOGY":[{"def":"The science of sensation in relation to nervous action.","pos":""}],"AESTIVAL":[{"def":"Of or belonging to the summer; as, æstival diseases.","pos":""}],"AESTIVATE":[{"def":"To pass the summer in a state of torpor.","pos":""}],"AESTIVATION":[{"def":"The state of torpidity induced by the heat and dryness of summer, as in certain snails; -- opposed to hibernation.","pos":""},{"def":"The arrangement of the petals in a flower bud, as to folding, overlapping, etc.","pos":""}],"AESTUOUS":[{"def":"Glowing; agitated, as with heat.","pos":""}],"AETHEOGAMOUS":[{"def":"Propagated in an unusual way; cryptogamous.","pos":""}],"AETHIOPS MINERAL":[{"def":"Same as Ethiops mineral.","pos":""}],"AETHRIOSCOPE":[{"def":"An instrument consisting in part of a differential thermometer.","pos":""}],"AETIOLOGICAL":[{"def":"Pertaining to ætiology; assigning a cause.","pos":""}],"AETIOLOGY":[{"def":"The science, doctrine, or demonstration of causes; esp.","pos":""},{"def":"The assignment of a cause.","pos":""}]}