{"ISABELLA GRAPE":[{"def":"A favorite sweet American grape of a purple color.","pos":""}],"ISABELLA MOTH":[{"def":"A common American moth (Pyrrharctia isabella), of an isabella color.","pos":""}],"ISABELLINE":[{"def":"Of an isabel or isabella color.","pos":""},{"def":"Containing the same information, as isagelous sentences.","pos":""}],"ISAGOGE":[{"def":"An introduction.","pos":""},{"def":"Introductory; especially, introductory to the study of theology.","pos":""}],"ISAGOGICS":[{"def":"That part of theological science directly preliminary to actual exegesis, or interpretation of the Scriptures.","pos":""}],"ISAGON":[{"def":"A figure or polygon whose angles are equal.","pos":""}],"ISAPOSTOLIC":[{"def":"Having equal, or almost equal, authority with the apostles of their teachings.","pos":""},{"def":"Pertaining to, or derived from, isatin; as, isatic acid, which is also called trioxindol.","pos":""}],"ISATIDE":[{"def":"A white crystalline substance obtained by the partial reduction of isatin.","pos":""}],"ISATIN":[{"def":"An orange-red crystalline substance, C8H5NO2, obtained by the oxidation of indigo blue.","pos":""}],"ISATIS":[{"def":"A genus of herbs, some species of which, especially the Isatis tinctoria, yield a blue dye similar to indigo; woad.","pos":""}],"ISATOGEN":[{"def":"A complex nitrogenous radical, C8H4NO2, regarded as the essential residue of a series of compounds, related to isatin, which easily pass by reduction to indigo blue.","pos":""}],"ISATROPIC":[{"def":"Pertaining to, or designating, an acid obtained from atropine, and isomeric with cinnamic acid.","pos":""}]}