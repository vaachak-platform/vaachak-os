{"BUCCAL":[{"def":"Of or pertaining to the mouth or cheeks.","pos":""}],"BUCCAN":[{"def":"A wooden frame or grid for roasting, smoking, or drying meat over fire.","pos":""}],"BUCCANEER":[{"def":"A robber upon the sea; a pirate; -- a term applied especially to the piratical adventurers who made depredations on the Spaniards in America in the 17th and 18th centuries.","pos":""}],"BUCCANEERISH":[{"def":"Like a buccaneer; piratical.","pos":""}],"BUCCINAL":[{"def":"Shaped or sounding like a trumpet; trumpetlike.","pos":""}],"BUCCINATOR":[{"def":"A muscle of the cheek; -- so called from its use in blowing wind instruments.","pos":""}],"BUCCINOID":[{"def":"Resembling the genus Buccinum, or pertaining to the Buccinidæ, a family of marine univalve shells.","pos":""}],"BUCCINUM":[{"def":"A genus of large univalve mollusks abundant in the arctic seas.","pos":""}],"BUCENTAUR":[{"def":"The state barge of Venice, used by the doge in the ceremony of espousing the Adriatic.","pos":""}],"BUCEPHALUS":[{"def":"The celebrated war horse of Alexander the Great.","pos":""}],"BUCEROS":[{"def":"A genus of large perching birds; the hornbills.","pos":""}],"BUCHOLZITE":[{"def":"Same as Fibrolite.","pos":""}],"BUCHU":[{"def":"A South African shrub (Barosma) with small leaves that are dotted with oil dlands; also, the leaves themselves, which are used in medicine for diseases of the urinary organs, etc.","pos":""}],"BUCK":[{"def":"Lye or suds in which cloth is soaked in the operation of bleaching, or in which clothes are washed.","pos":""},{"def":"The cloth or clothes soaked or washed.","pos":""}],"BUCK BEAN":[{"def":"A plant (Menyanthes trifoliata) which grows in moist and boggy places, having racems of white or reddish flowers and intensely bitter leaves, sometimes used in medicine; marsh trefoil; -- called also bog bean.","pos":""}],"BUCK FEVER":[{"def":"Intense excitement at the sight of deer or other game, such as often unnerves a novice in hunting.","pos":""}],"BUCK'S-HORN":[{"def":"A plant with leaves branched somewhat like a buck's horn (Plantago Coronopus); also, Lobelia coronopifolia.","pos":""}],"BUCK-BASKET":[{"def":"A basket in which clothes are carried to the wash.","pos":""}],"BUCK-EYED":[{"def":"Having bad or speckled eyes.","pos":""}],"BUCKBOARD":[{"def":"A four-wheeled vehicle, having a long elastic board or frame resting on the bolsters or axletrees, and a seat or seats placed transversely upon it; -- called also buck wagon.","pos":""}],"BUCKER":[{"def":"One who bucks ore.","pos":""},{"def":"A broad-headed hammer used in bucking ore.","pos":""}],"BUCKET":[{"def":"One of the receptacles on the rim of a water wheel into which the water rushes, causing the wheel to revolve; also, a float of a paddle wheel.","pos":""}],"BUCKET SHOP":[{"def":"An office or a place where facilities are given for betting small sums on current prices of stocks, petroleum, etc.","pos":""}],"BUCKETY":[{"def":"Paste used by weavers to dress their webs.","pos":""}],"BUCKEYE":[{"def":"A name given to several American trees and shrubs of the same genus (Æsculus) as the horse chestnut.","pos":""}],"BUCKHOUND":[{"def":"A hound for hunting deer.","pos":""}],"BUCKIE":[{"def":"A large spiral marine shell, esp.","pos":""}],"BUCKING":[{"def":"The act or process of soaking or boiling cloth in an alkaline liquid in the operation of bleaching; also, the liquid used.","pos":""}],"BUCKISH":[{"def":"Dandified; foppish.","pos":""}],"BUCKLE":[{"def":"A device, usually of metal, consisting of a frame with one more movable tongues or catches, used for fastening things together, as parts of dress or harness, by means of a strap passing through the frame and pierced by the tongue.","pos":""},{"def":"A distortion bulge, bend, or kink, as in a saw blade or a plate of sheet metal.","pos":""}],"BUCKLER":[{"def":"A block of wood or plate of iron made to fit a hawse hole, or the circular opening in a half-port, to prevent water from entering when the vessel pitches.","pos":""}],"BUCKLER-HEADED":[{"def":"Having a head like a buckler.","pos":""}],"BUCKLING":[{"def":"Wavy; curling, as hair.","pos":""}],"BUCKRA":[{"def":"A white man; -- a term used by negroes of the African coast, West Indies, etc.","pos":""}],"BUCKRAM":[{"def":"A coarse cloth of linen or hemp, stiffened with size or glue, used in garments to keep them in the form intended, and for wrappers to cover merchandise.","pos":""}],"BUCKSHOT":[{"def":"A coarse leaden shot, larger than swan shot, used in hunting deer and large game.","pos":""}],"BUCKSKIN":[{"def":"Breeches made of buckskin.","pos":""}],"BUCKSTALL":[{"def":"A toil or net to take deer.","pos":""}],"BUCKTHORN":[{"def":"A genus (Rhamnus) of shrubs or trees.","pos":""}],"BUCKTOOTH":[{"def":"Any tooth that juts out.","pos":""}],"BUCKWHEAT":[{"def":"A plant (Fagopyrum esculentum) of the Polygonum family, the seed of which is used for food.","pos":""}],"BUCOLIC":[{"def":"Of or pertaining to the life and occupation of a shepherd; pastoral; rustic.","pos":""}],"BUCRANIUM":[{"def":"A sculptured ornament, representing an ox skull adorned with wreaths, etc.","pos":""}]}