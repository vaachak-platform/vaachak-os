{"TRIABLE":[{"def":"Liable to undergo a judicial examination; properly coming under the cognizance of a court; as, a cause may be triable before one court which is not triable in another.","pos":""}],"TRIABLENESS":[{"def":"Quality or state of being triable.","pos":""}],"TRIACID":[{"def":"Capable of neutralizing three molecules of a monobasic acid or the equivalent; having three hydrogen atoms which may be acid radicals; -- said of certain bases; thus, glycerin is a triacid base.","pos":""}],"TRIACONTAHEDRAL":[{"def":"Having thirty sides.","pos":""}],"TRIACONTER":[{"def":"A vessel with thirty banks of oars, or, as some say, thirty ranks of rowers.","pos":""}],"TRIAD":[{"def":"An element or radical whose valence is three.","pos":""}],"TRIADELPHOUS":[{"def":"Having stamens joined by filaments into three bundles.","pos":""}],"TRIADIC":[{"def":"Having the characteristics of a triad; as, boron is triadic.","pos":""}],"TRIAKISOCTAHEDRON":[{"def":"A trigonal trisoctahedron.","pos":""}],"TRIAL":[{"def":"The formal examination of the matter in issue in a cause before a competent tribunal; the mode of determining a question of fact in a court of law; the examination, in legal form, of the facts in issue in a cause pending before a competent tribunal, for the purpose of determining such issue.","pos":""}],"TRIAL BALANCE":[{"def":"The testing of a ledger to discover whether the debits and credits balance, by finding whether the sum of the personal credits increased by the difference between the debit and credit sums in the merchandise and other impersonal accounts equals the sum of personal debits.","pos":""}],"TRIALITY":[{"def":"Three united; state of being three.","pos":""}],"TRIALOGUE":[{"def":"A discourse or colloquy by three persons.","pos":""}],"TRIAMIDE":[{"def":"An amide containing three amido groups.","pos":""}],"TRIAMINE":[{"def":"An amine containing three amido groups.","pos":""}],"TRIANDER":[{"def":"Any one of the Triandria.","pos":""}],"TRIANDRIA":[{"def":"A Linnæan class of plants having three distinct and equal stamens.","pos":""},{"def":"Of or pertaining to the Triandria; having three distinct and equal stamens in the same flower.","pos":""}],"TRIANGLE":[{"def":"A figure bounded by three lines, and containing three angles.","pos":""},{"def":"An instrument of percussion, usually made of a rod of steel, bent into the form of a triangle, open at one angle, and sounded by being struck with a small metallic rod.","pos":""}],"TRIANGLED":[{"def":"Having three angles; triangular.","pos":""}],"TRIANGULAR":[{"def":"Oblong or elongated, and having three lateral angles; as, a triangular seed, leaf, or stem.","pos":""}],"TRIANGULARES":[{"def":"The triangular, or maioid, crabs.","pos":""}],"TRIANGULARITY":[{"def":"The quality or state of being triangular.","pos":""}],"TRIANGULARLY":[{"def":"In a triangular manner; in the form of a triangle.","pos":""}],"TRIANGULATE":[{"def":"To divide into triangles; specifically, to survey by means of a series of triangles properly laid down and measured.","pos":""},{"def":"To make triangular, or three-cornered.","pos":""}],"TRIARCHY":[{"def":"Government by three persons; a triumvirate; also, a country under three rulers.","pos":""}],"TRIARIAN":[{"def":"Occupying the third post or rank.","pos":""}],"TRIARTICULATE":[{"def":"Having three joints.","pos":""}],"TRIAS":[{"def":"The formation situated between the Permian and Lias, and so named by the Germans, because consisting of three series of strata, which are called in German the Bunter sandstein, Muschelkalk, and Keuper.","pos":""}],"TRIASSIC":[{"def":"Of the age of, or pertaining to, the Trias.","pos":""},{"def":"The Triassic formation.","pos":""}],"TRIATIC":[{"def":"A term used in the phrase triatic stay.","pos":""}]}