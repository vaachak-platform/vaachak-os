{"NUT":[{"def":"The fruit of certain trees and shrubs (as of the almond, walnut, hickory, beech, filbert, etc.","pos":""},{"def":"A projection on each side of the shank of an anchor, to secure the stock in place.","pos":""}],"NUT-BROWN":[{"def":"Brown as a nut long kept and dried.","pos":""}],"NUTANT":[{"def":"Nodding; having the top bent downward.","pos":""}],"NUTATION":[{"def":"A very small libratory motion of the earth's axis, by which its inclination to the plane of the ecliptic is constantly varying by a small amount.","pos":""}],"NUTCRACKER":[{"def":"An instrument for cracking nuts.","pos":""}],"NUTGALL":[{"def":"A more or less round gall resembling a nut, esp.","pos":""}],"NUTHATCH":[{"def":"Any one of several species of birds of the genus Sitta, as the European species (Sitta Europæa).","pos":""}],"NUTHOOK":[{"def":"A hook at the end of a pole to pull down boughs for gathering the nuts.","pos":""},{"def":"A thief who steals by means of a hook; also, a bailiff who hooks or seizes malefactors.","pos":""}],"NUTLET":[{"def":"A small nut; also, the stone of a drupe.","pos":""}],"NUTMEG":[{"def":"The kernel of the fruit of the nutmeg tree (Myristica fragrans), a native of the Molucca Islands, but cultivated elsewhere in the tropics.","pos":""}],"NUTMEGGED":[{"def":"Seasoned with nutmeg.","pos":""}],"NUTRIA":[{"def":"The fur of the coypu.","pos":""}],"NUTRICATION":[{"def":"The act or manner of feeding.","pos":""}],"NUTRIENT":[{"def":"Nutritious; nourishing; promoting growth.","pos":""},{"def":"Any substance which has nutritious qualities, i.","pos":""}],"NUTRIMENT":[{"def":"That which nourishes; anything which promotes growth and repairs the natural waste of animal or vegetable life; food; aliment.","pos":""},{"def":"That which promotes development or growth.","pos":""}],"NUTRITIAL":[{"def":"Pertaining to, or connected with, nutrition; nutritious.","pos":""}],"NUTRITION":[{"def":"In the broadest sense, a process or series of processes by which the living organism as a whole (or its component parts or organs) is maintained in its normal condition of life and growth.","pos":""},{"def":"In a more limited sense, the process by which the living tissues take up, from the blood, matters necessary either for their repair or for the performance of their healthy functions.","pos":""}],"NUTRITIONAL":[{"def":"Of or pertaining to nutrition; as, nutritional changes.","pos":""}],"NUTRITIOUS":[{"def":"Nourishing; promoting growth, or preventing decay; alimental.","pos":""}],"NUTRITIVE":[{"def":"Of or pertaining to nutrition; as, the nutritive functions; having the quality of nourishing; nutritious; nutrimental; alimental; as, nutritive food or berries.","pos":""}],"NUTRITURE":[{"def":"Nutrition; nourishment.","pos":""}],"NUTSHELL":[{"def":"A shell of the genus Nucula.","pos":""}],"NUTTER":[{"def":"A gatherer of nuts.","pos":""}],"NUTTING":[{"def":"The act of gathering nuts.","pos":""}],"NUTTY":[{"def":"Abounding in nuts.","pos":""},{"def":"Having a flavor like that of nuts; as, nutty wine.","pos":""}]}