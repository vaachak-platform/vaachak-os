{"RESUBJECTION":[{"def":"A second subjection.","pos":""}],"RESUBLIME":[{"def":"To sublime again.","pos":""}],"RESUDATION":[{"def":"Act of sweating again.","pos":""}],"RESULT":[{"def":"To leap back; to rebound.","pos":""},{"def":"To come out, or have an issue; to terminate; to have consequences; -- followed by in; as, this measure will result in good or in evil.","pos":""}],"RESULTANCE":[{"def":"The act of resulting; that which results; a result.","pos":""}],"RESULTANT":[{"def":"Resulting or issuing from a combination; existing or following as a result or consequence.","pos":""}],"RESULTFUL":[{"def":"HAving results or effects.","pos":""}],"RESULTLESS":[{"def":"Being without result; as, resultless investigations.","pos":""}],"RESUMABLE":[{"def":"Capable of, or admitting of, being resumed.","pos":""}],"RESUME":[{"def":"A summing up; a condensed statement; an abridgment or brief recapitulation.","pos":""}],"RESUMMON":[{"def":"To summon again.","pos":""}],"RESUMMONS":[{"def":"A second summons.","pos":""}],"RESUMPTION":[{"def":"The taking again into the king's hands of such lands or tenements as he had granted to any man on false suggestions or other error.","pos":""}],"RESUMPTIVE":[{"def":"Taking back; resuming, or tending toward resumption; as, resumptive measures.","pos":""}],"RESUPINATE":[{"def":"Inverted in position; appearing to be upside down or reversed, as the flowers of the orchis and the leaves of some plants.","pos":""}],"RESUPINATION":[{"def":"The state of luing on the back; the state of being resupinate, or reversed.","pos":""}],"RESUPINE":[{"def":"Lying on the back; supine; hence, careless.","pos":""}],"RESUPPLY":[{"def":"To supply again.","pos":""}],"RESURGENCE":[{"def":"The act of rising again; resurrection.","pos":""}],"RESURGENT":[{"def":"Rising again, as from the dead.","pos":""}],"RESURRECT":[{"def":"To take from the grave; to disinter.","pos":""},{"def":"To reanimate; to restore to life; to bring to view (that which was forgotten or lost).","pos":""}],"RESURRECTION":[{"def":"A rising again; the resumption of vigor.","pos":""},{"def":"Especially, the rising again from the dead; the resumption of life by the dead; as, the resurrection of Jesus Christ; the general resurrection of all the dead at the Day of Judgment.","pos":""}],"RESURRECTIONIST":[{"def":"One who steals bodies from the grave, as for dissection.","pos":""}],"RESURRECTIONIZE":[{"def":"To raise from the dead.","pos":""}],"RESURVEY":[{"def":"To survey again or anew; to review.","pos":""}],"RESUSCITABLE":[{"def":"Capable of resuscitation; as, resuscitable plants.","pos":""}],"RESUSCITANT":[{"def":"One who, or that which resuscitates.","pos":""}],"RESUSCITATE":[{"def":"Restored to life.","pos":""}],"RESUSCITATION":[{"def":"The act of resuscitating, or state of being resuscitated.","pos":""}],"RESUSCITATIVE":[{"def":"Tending to resuscitate; reviving; revivifying.","pos":""}],"RESUSCITATOR":[{"def":"One who, or that which, resuscitates.","pos":""}]}