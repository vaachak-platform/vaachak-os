{"LIKABLE":[{"def":"Such as can be liked; such as to attract liking; as, a likable person.","pos":""}],"LIKE":[{"def":"Having the same, or nearly the same, appearance, qualities, or characteristics; resembling; similar to; similar; alike; -- often with in and the particulars of the resemblance; as, they are like each other in features, complexion, and many traits of character.","pos":""},{"def":"Equal, or nearly equal; as, fields of like extent.","pos":""}],"LIKE-MINDED":[{"def":"Having a like disposition or purpose; of the same mind.","pos":""}],"LIKEABLE":[{"def":"Like\"a*ble (lik\"a*b'l), a.","pos":""}],"LIKELIHOOD":[{"def":"Appearance; show; sign; expression.","pos":""},{"def":"Likeness; resemblance.","pos":""}],"LIKELINESS":[{"def":"Likelihood; probability.","pos":""},{"def":"Suitableness; agreeableness.","pos":""}],"LIKELY":[{"def":"Worthy of belief; probable; credible; as, a likely story.","pos":""},{"def":"Having probability; having or giving reason to expect; -- followed by the infinitive; as, it is likely to rain.","pos":""}],"LIKEN":[{"def":"To allege, or think, to be like; to represent as like; to compare; as, to liken life to a pilgrimage.","pos":""},{"def":"To make or cause to be like.","pos":""}],"LIKENESS":[{"def":"See Lickerish, Lickerishness.","pos":""}],"LIKEWISE":[{"def":"In like manner; also; moreover; too.","pos":""}],"LIKIN":[{"def":"A Chinese provincial tax levied at many inland stations upon imports or articles in transit.","pos":""}],"LIKING":[{"def":"Looking; appearing; as, better or worse liking.","pos":""}]}