{"OLAY":[{"def":"Palm leaves, prepared for being written upon with a style pointed with steel.","pos":""}],"OLD":[{"def":"Not young; advanced far in years or life; having lived till toward the end of the ordinary term of living; as, an old man; an old age; an old horse; an old tree.","pos":""},{"def":"Not new or fresh; not recently made or produced; having existed for a long time; as, old wine; an old friendship.","pos":""}],"OLD DOMINION":[{"def":"Virginia; -- a name of uncertain origin, perh.","pos":""}],"OLD LANG SYNE":[{"def":"See Auld lang syne.","pos":""}],"OLD LINE STATE":[{"def":"Maryland; a nickname, alluding to the fact that its northern boundary in Mason and Dixon's line.","pos":""}],"OLD-FASHIONED":[{"def":"Formed according to old or obsolete fashion or pattern; adhering to old customs or ideas; as, an old-fashioned dress, girl.","pos":""}],"OLD-GENTLEMANLY":[{"def":"Pertaining to an old gentleman, or like one.","pos":""}],"OLD-MAIDISH":[{"def":"Like an old maid; prim; precise; particular.","pos":""}],"OLD-MAIDISM":[{"def":"The condition or characteristics of an old maid.","pos":""}],"OLD-WOMANISH":[{"def":"Like an old woman; anile.","pos":""}],"OLDEN":[{"def":"Old; ancient; as, the olden time.","pos":""}],"OLDNESS":[{"def":"The state or quality of being old; old age.","pos":""}],"OLEA":[{"def":"A genus of trees including the olive.","pos":""}],"OLEACEOUS":[{"def":"Of, pertaining to, or resembling, a natural order of plants (Oleaceæ), mostly trees and shrubs, of which the olive is the type.","pos":""}],"OLEAGINOUS":[{"def":"Having the nature or qualities of oil; oily; unctuous.","pos":""}],"OLEAGINOUSNESS":[{"def":"O`le*ag`i*nous*ness, n.","pos":""}],"OLEAMEN":[{"def":"A soft ointment prepared from oil.","pos":""}],"OLEANDER":[{"def":"A beautiful evergreen shrub of the Dogbane family, having clusters of fragrant red or white flowers.","pos":""}],"OLEANDRINE":[{"def":"One of several alkaloids found in the leaves of the oleander.","pos":""}],"OLEASTER":[{"def":"Trebizond dates, and are made into cakes by the Arabs.","pos":""}],"OLEATE":[{"def":"A salt of oleic acid.","pos":""}],"OLECRANAL":[{"def":"Of or pertaining to the olecranon.","pos":""}],"OLECRANON":[{"def":"The large process at the proximal end of the ulna which projects behind the articulation with the humerus and forms the bony prominence of the elbow.","pos":""}],"OLEFIANT":[{"def":"Forming or producing an oil; specifically, designating a colorless gaseous hydrocarbon called ethylene.","pos":""}],"OLEFINE":[{"def":"Olefiant gas, or ethylene; hence, by extension, any one of the series of unsaturated hydrocarbons of which ethylene is a type.","pos":""}],"OLEIC":[{"def":"Pertaining to, derived from, or contained in, oil; as, oleic acid, an acid of the acrylic acid series found combined with glyceryl in the form of olein in certain animal and vegetable fats and oils, such as sperm oil, olive oil, etc.","pos":""}],"OLEIFEROUS":[{"def":"Producing oil; as, oleiferous seeds.","pos":""}],"OLEIN":[{"def":"A fat, liquid at ordinary temperatures, but solidifying at temperatures below 0° C.","pos":""}],"OLEO OIL":[{"def":"An oil expressed from certain animal fats (esp.","pos":""}],"OLEOGRAPH":[{"def":"The form or figure assumed by a drop of oil when placed upon water or some other liquid with which it does not mix.","pos":""},{"def":"A picture produced in oils by a process analogous to that of lithographic printing.","pos":""}],"OLEOGRAPHY":[{"def":"Art or process of producing the pictures known as oleographs.","pos":""},{"def":"A process of identifying oils by their oleographs.","pos":""}],"OLEOMARGARINE":[{"def":"A liquid oil made from animal fats (esp.","pos":""},{"def":"An artificial butter made by churning this oil with more or less milk.","pos":""}],"OLEOMETER":[{"def":"An instrument for ascertaining the weight and purity of oil; an elaiometer.","pos":""}],"OLEONE":[{"def":"An oily liquid, obtained by distillation of calcium oleate, and probably consisting of the ketone of oleic acid.","pos":""}],"OLEORESIN":[{"def":"A natural mixture of a terebinthinate oil and a resin.","pos":""},{"def":"A liquid or semiliquid preparation extracted (as from capsicum, cubebs, or ginger) by means of ether, and consisting of fixed or volatile oil holding resin in solution.","pos":""}],"OLEOSITY":[{"def":"The state or quality of being oily or fat; fatness.","pos":""}],"OLERACEOUS":[{"def":"Pertaining to pot herbs; of the nature or having the qualities of herbs for cookery; esculent.","pos":""}],"OLF":[{"def":"The European bullfinch.","pos":""}],"OLFACTION":[{"def":"The sense by which the impressions made on the olfactory organs by the odorous particles in the atmosphere are perceived.","pos":""}],"OLFACTIVE":[{"def":"See Olfactory, a.","pos":""}],"OLFACTOR":[{"def":"A smelling organ; a nose.","pos":""}],"OLFACTORY":[{"def":"Of, pertaining to, or connected with, the sense of smell; as, the olfactory nerves; the olfactory cells.","pos":""}],"OLIBANUM":[{"def":"The fragrant gum resin of various species of Boswellia; Oriental frankincense.","pos":""}],"OLIBENE":[{"def":"A colorless mobile liquid of a pleasant aromatic odor obtained by the distillation of olibanum, or frankincense, and regarded as a terpene; -- called also conimene.","pos":""},{"def":"Having a strong, disagreeable smell; fetid.","pos":""}],"OLIFANT":[{"def":"An ancient horn, made of ivory.","pos":""}],"OLIGANDROUS":[{"def":"Having few stamens.","pos":""}],"OLIGANTHOUS":[{"def":"Having few flowers.","pos":""}],"OLIGARCH":[{"def":"A member of an oligarchy; one of the rulers in an oligarchical government.","pos":""}],"OLIGARCHAL":[{"def":"Of or pertaining to oligarchy, or government by a few.","pos":""}],"OLIGARCHIST":[{"def":"An advocate or supporter of oligarchy.","pos":""}],"OLIGARCHY":[{"def":"A form of government in which the supreme power is placed in the hands of a few persons; also, those who form the ruling few.","pos":""}],"OLIGIST":[{"def":"Hematite or specular iron ore; -- prob.","pos":""},{"def":"Of or pertaining to hematite.","pos":""}],"OLIGO-":[{"def":"A combining form from Gr.","pos":""}],"OLIGOCENE":[{"def":"Of, pertaining to, or designating, certain strata which occupy an intermediate position between the Eocene and Miocene periods.","pos":""},{"def":"The Oligocene period.","pos":""}],"OLIGOCHAETA":[{"def":"An order of Annelida which includes the earthworms and related species.","pos":""}],"OLIGOCHETE":[{"def":"Of or pertaining to the Oligochæta.","pos":""}],"OLIGOCLASE":[{"def":"A triclinic soda-lime feldspar.","pos":""}],"OLIGOMEROUS":[{"def":"Having few members in each set of organs; as, an oligomerous flower.","pos":""}],"OLIGOMYOLD":[{"def":"Having few or imperfect syringeal muscles; -- said of some passerine birds (Oligomyodi).","pos":""}],"OLIGOPETALOUS":[{"def":"Having few petals.","pos":""}],"OLIGOSEPALOUS":[{"def":"Having few sepals.","pos":""}],"OLIGOSIDERITE":[{"def":"A meteorite characterized by the presence of but a small amount of metallic iron.","pos":""}],"OLIGOSPERMOUS":[{"def":"Having few seeds.","pos":""}],"OLIGOTOKOUS":[{"def":"Producing few young.","pos":""}],"OLIO":[{"def":"A collection of miscellaneous pieces.","pos":""}],"OLITORY":[{"def":"Of or pertaining to, or produced in, a kitchen garden; used for kitchen purposes; as, olitory seeds.","pos":""}],"OLIVA":[{"def":"A genus of polished marine gastropod shells, chiefly tropical, and often beautifully colored.","pos":""}],"OLIVACEOUS":[{"def":"Resembling the olive; of the color of the olive; olive-green.","pos":""}],"OLIVASTER":[{"def":"Of the color of the olive; tawny.","pos":""}],"OLIVE":[{"def":"An olivary body.","pos":""},{"def":"A small slice of meat seasoned, rolled up, and cooked; as, olives of beef or veal.","pos":""}],"OLIVED":[{"def":"Decorated or furnished with olive trees.","pos":""}],"OLIVENITE":[{"def":"An olive-green mineral, a hydrous arseniate of copper; olive ore.","pos":""}],"OLIVER":[{"def":"A small tilt hammer, worked by the foot.","pos":""}],"OLIVERIAN":[{"def":"An adherent of Oliver Cromwell.","pos":""}],"OLIVIL":[{"def":"A white crystalline substance, obtained from an exudation from the olive, and having a bitter-sweet taste and acid proporties.","pos":""}],"OLIVIN":[{"def":"A complex bitter gum, found on the leaves of the olive tree; -- called also olivite.","pos":""}],"OLIVINE":[{"def":"A common name of the yellowish green mineral chrysolite, esp.","pos":""}],"OLLA":[{"def":"A pot or jar having a wide mouth; a cinerary urn, especially one of baked clay.","pos":""},{"def":"A dish of stewed meat; an olio; an olla-podrida.","pos":""}],"OLLA-PODRIDA":[{"def":"A favorite Spanish dish, consisting of a mixture of several kinds of meat chopped fine, and stewed with vegetables.","pos":""},{"def":"Any incongruous mixture or miscellaneous collection; an olio.","pos":""}],"OLOGY":[{"def":"A colloquial or humorous name for any science or branch of knowledge.","pos":""}],"OLPE":[{"def":"Originally, a leather flask or vessel for oils or liquids; afterward, an earthenware vase or pitcher without a spout.","pos":""}],"OLUSATRUM":[{"def":"An umbelliferous plant, the common Alexanders of Western Europe (Smyrnium Olusatrum).","pos":""}],"OLYMPIAD":[{"def":"A period of four years, by which the ancient Greeks reckoned time, being the interval from one celebration of the Olympic games to another, beginning with the victory of Coroebus in the foot race, which took place in the year 776 b.","pos":""},{"def":"Of or pertaining to Olympus, a mountain of Thessaly, fabled as the seat of the gods, or to Olympia, a small plain in Elis.","pos":""}],"OLYMPIANISM":[{"def":"Worship of the Olympian gods, esp.","pos":""},{"def":"A modified revival of the ancient Olympian games, consisting of international athletic games, races, etc.","pos":""}],"OLYMPIONIC":[{"def":"An ode in honor of a victor in the Olympic games.","pos":""}]}