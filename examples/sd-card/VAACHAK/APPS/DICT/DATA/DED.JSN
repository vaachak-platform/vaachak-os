{"DEDANS":[{"def":"A division, at one end of a tennis court, for spectators.","pos":""}],"DEDECORATE":[{"def":"To bring to shame; to disgrace.","pos":""}],"DEDECORATION":[{"def":"Disgrace; dishonor.","pos":""}],"DEDECOROUS":[{"def":"Disgraceful; unbecoming.","pos":""}],"DEDENTITION":[{"def":"The shedding of teeth.","pos":""}],"DEDICATE":[{"def":"Dedicated; set apart; devoted; consecrated.","pos":""}],"DEDICATEE":[{"def":"One to whom a thing is dedicated; -- correlative to dedicator.","pos":""}],"DEDICATION":[{"def":"The act of setting apart or consecrating to a divine Being, or to a sacred use, often with religious solemnities; solemn appropriation; as, the dedication of Solomon's temple.","pos":""},{"def":"A devoting or setting aside for any particular purpose; as, a dedication of lands to public use.","pos":""}],"DEDICATOR":[{"def":"One who dedicates; more especially, one who inscribes a book to the favor of a patron, or to one whom he desires to compliment.","pos":""}],"DEDICATORY":[{"def":"Constituting or serving as a dedication; complimental.","pos":""}],"DEDIMUS":[{"def":"A writ to commission private persons to do some act in place of a judge, as to examine a witness, etc.","pos":""}],"DEDITION":[{"def":"The act of yielding; surrender.","pos":""}],"DEDOLENT":[{"def":"Feeling no compunction; apathetic.","pos":""}],"DEDUCE":[{"def":"To take away; to deduct; to subtract; as, to deduce a part from the whole.","pos":""}],"DEDUCEMENT":[{"def":"Inference; deduction; thing deduced.","pos":""}],"DEDUCIBLE":[{"def":"Capable of being deduced or inferred; derivable by reasoning, as a result or consequence.","pos":""},{"def":"Capable of being brought down.","pos":""}],"DEDUCIBLENESS":[{"def":"The quality of being deducible; deducibility.","pos":""}],"DEDUCIVE":[{"def":"That deduces; inferential.","pos":""}],"DEDUCT":[{"def":"To lead forth or out.","pos":""},{"def":"To take away, separate, or remove, in numbering, estimating, or calculating; to subtract; -- often with from or out of.","pos":""}],"DEDUCTIBLE":[{"def":"Capable of being deducted, taken away, or withdrawn.","pos":""},{"def":"Deducible; consequential.","pos":""}],"DEDUCTION":[{"def":"Act or process of deducing or inferring.","pos":""},{"def":"Act of deducting or taking away; subtraction; as, the deduction of the subtrahend from the minuend.","pos":""}],"DEDUCTIVE":[{"def":"Of or pertaining to deduction; capable of being deduced from premises; deducible.","pos":""}],"DEDUCTIVELY":[{"def":"By deduction; by way of inference; by consequence.","pos":""}],"DEDUCTOR":[{"def":"The pilot whale or blackfish.","pos":""}],"DEDUIT":[{"def":"Delight; pleasure.","pos":""}],"DEDUPLICATION":[{"def":"The division of that which is morphologically one organ into two or more, as the division of an organ of a plant into a pair or cluster.","pos":""}]}