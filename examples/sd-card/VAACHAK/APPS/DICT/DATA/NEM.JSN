{"NEMALINE":[{"def":"Having the form of threads; fibrous.","pos":""}],"NEMALITE":[{"def":"A fibrous variety of brucite.","pos":""}],"NEMATELMIA":[{"def":"Same as Nemathelminthes.","pos":""}],"NEMATHECIUM":[{"def":"A peculiar kind of fructification on certain red algæ, consisting of an external mass of filaments at length separating into tetraspores.","pos":""},{"def":"An order of helminths, including the Nematoidea and Gordiacea; the roundworms.","pos":""}],"NEMATOBLAST":[{"def":"A spermatocyte or spermoblast.","pos":""}],"NEMATOCALYX":[{"def":"One of a peculiar kind of cups, or calicles, found upon hydroids of the family Plumularidæ.","pos":""}],"NEMATOCERA":[{"def":"A suborder of dipterous insects, having long antennæ, as the mosquito, gnat, and crane fly; -- called also Nemocera.","pos":""}],"NEMATOCYST":[{"def":"A lasso cell, or thread cell.","pos":""}],"NEMATODE":[{"def":"Same as Nematoid.","pos":""}],"NEMATOGENE":[{"def":"One of the dimorphic forms of the species of Dicyemata, which produced vermiform embryos; -- opposed to Ant: rhombogene.","pos":""}],"NEMATOGNATH":[{"def":"one of the Nematognathi.","pos":""}],"NEMATOGNATHI":[{"def":"An order of fishes having barbels on the jaws.","pos":""}],"NEMATOID":[{"def":"of or pertaining to the Nematoidea.","pos":""},{"def":"One of the Nematoidea.","pos":""}],"NEMATOIDEA":[{"def":"An order of worms, having a long, round, and generally smooth body; the roundworms.","pos":""}],"NEMATOPHORA":[{"def":"Same as Cælenterata.","pos":""}],"NEMEAN":[{"def":"Of or pertaining to Nemea, in Argolis, where the ancient Greeks celebrated games, and Hercules killed a lion.","pos":""}],"NEMERTEAN":[{"def":"Of or pertaining to the Nemertina.","pos":""},{"def":"One of the Nemertina.","pos":""}],"NEMERTES":[{"def":"A genus of nemertina.","pos":""}],"NEMERTINA":[{"def":"An order of helminths usually having a long, slender, smooth, often bright-colored body, covered with minute vibrating cilia; -- called also Nemertea, Nemertida, and Rhynchocæla.","pos":""}],"NEMESIS":[{"def":"The goddess of retribution or vengeance; hence, retributive justice personified; divine vengeance.","pos":""}],"NEMOPHILIST":[{"def":"One who is fond of forest or forest scenery; a haunter of the woods.","pos":""}],"NEMOPHILY":[{"def":"Fondness for forest scenery; love of the woods.","pos":""}],"NEMORAL":[{"def":"Of or pertaining to a wood or grove.","pos":""}],"NEMOROUS":[{"def":"Paradise itself was but a kind of nemorous temple.","pos":""}],"NEMPNE":[{"def":"To name or call.","pos":""}]}