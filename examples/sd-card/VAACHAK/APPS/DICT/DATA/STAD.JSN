{"STADDLE":[{"def":"Anything which serves for support; a staff; a prop; a crutch; a cane.","pos":""},{"def":"The frame of a stack of hay or grain.","pos":""}],"STADE":[{"def":"A landing place or wharf.","pos":""},{"def":"In a theodolite, etc.","pos":""}],"STADIMETER":[{"def":"A horizontal graduated bar mounted on a staff, used as a stadium, or telemeter, for measuring distances.","pos":""}],"STADIUM":[{"def":"A Greek measure of length, being the chief one used for itinerary distances, also adopted by the Romans for nautical and astronomical measurements.","pos":""},{"def":"Hence, a race course; especially, the Olympic course for foot races.","pos":""}],"STADTHOLDER":[{"def":"Formerly, the chief magistrate of the United Provinces of Holland; also, the governor or lieutenant governor of a province.","pos":""},{"def":"The office or position of a stadtholder.","pos":""}]}