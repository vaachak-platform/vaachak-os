{"LITTER":[{"def":"A bed or stretcher so arranged that a person, esp.","pos":""},{"def":"Straw, hay, etc.","pos":""}],"LITTERATEUR":[{"def":"One who occupies himself with literature; a literary man; a literatus.","pos":""}],"LITTERY":[{"def":"Covered or encumbered with litter; consisting of or constituting litter.","pos":""}],"LITTLE":[{"def":"Small in size or extent; not big; diminutive; -- opposed to big or large; as, a little body; a little animal; a little piece of ground; a little hill; a little distance; a little child.","pos":""},{"def":"Short in duration; brief; as, a little sleep.","pos":""}],"LITTLE-EASE":[{"def":"An old slang name for the pillory, stocks, etc.","pos":""}],"LITTLENESS":[{"def":"The state or quality of being little; as, littleness of size, thought, duration, power, etc.","pos":""}],"LITTORAL":[{"def":"Inhabiting the seashore, esp.","pos":""}],"LITTORINA":[{"def":"A genus of small pectinibranch mollusks, having thick spiral shells, abundant between tides on nearly all rocky seacoasts.","pos":""}],"LITTRESS":[{"def":"A smooth kind of cartridge paper used for making cards.","pos":""}]}