{"TROU-DE-LOUP":[{"def":"A pit in the form of an inverted cone or pyramid, constructed as an obstacle to the approach of an enemy, and having a pointed stake in the middle.","pos":""}],"TROUBADOUR":[{"def":"One of a school of poets who flourished from the eleventh to the thirteenth century, principally in Provence, in the south of France, and also in the north of Italy.","pos":""}],"TROUBLABLE":[{"def":"Causing trouble; troublesome.","pos":""}],"TROUBLE":[{"def":"To put into confused motion; to disturb; to agitate.","pos":""},{"def":"To disturb; to perplex; to afflict; to distress; to grieve; to fret; to annoy; to vex.","pos":""}],"TROUBLER":[{"def":"One who troubles or disturbs; one who afflicts or molests; a disturber; as, a troubler of the peace.","pos":""}],"TROUBLESOME":[{"def":"Giving trouble or anxiety; vexatious; burdensome; wearisome.","pos":""}],"TROUBLOUS":[{"def":"Full of trouble; causing trouble.","pos":""}],"TROUGH":[{"def":"A long, hollow vessel, generally for holding water or other liquid, especially one formed by excavating a log longitudinally on one side; a long tray; also, a wooden channel for conveying water, as to a mill wheel.","pos":""},{"def":"Any channel, receptacle, or depression, of a long and narrow shape; as, trough between two ridges, etc.","pos":""}],"TROUGH-SHELL":[{"def":"Any bivalve shell of the genus Mactra.","pos":""}],"TROUNCE":[{"def":"To punish or beat severely; to whip smartly; to flog; to castigate.","pos":""}],"TROUPE":[{"def":"A company or troop, especially the company pf performers in a play or an opera.","pos":""}],"TROUPIAL":[{"def":"Any one of numerous species of bright-colored American birds belonging to Icterus and allied genera, especially Icterus icterus, a native of the West Indies and South America.","pos":""}],"TROUSERING":[{"def":"Cloth or material for making trousers.","pos":""}],"TROUSERS":[{"def":"A garment worn by men and boys, extending from the waist to the knee or to the ankle, and covering each leg separately.","pos":""}],"TROUSSE":[{"def":"A case for small implements; as, a surgeon's trousse.","pos":""}],"TROUSSEAU":[{"def":"The collective lighter equipments or outfit of a bride, including clothes, jewelry, and the like; especially, that which is provided for her by her family.","pos":""}],"TROUT":[{"def":"Any one of numerous species of fishes belonging to Salmo, Salvelinus, and allied genera of the family Salmonidæ.","pos":""}],"TROUT-COLORED":[{"def":"White, with spots of black, bay, or sorrel; as, a trout-colored horse.","pos":""}],"TROUTBIRD":[{"def":"The American golden plover.","pos":""}],"TROUTLET":[{"def":"A little trout; a troutling.","pos":""}],"TROUTLING":[{"def":"A little trout; a troutlet.","pos":""},{"def":"One of a school of poets who flourished in Northern France from the eleventh to the fourteenth century.","pos":""}]}