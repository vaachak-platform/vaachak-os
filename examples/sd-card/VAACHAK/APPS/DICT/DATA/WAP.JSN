{"WAP":[{"def":"To beat; to whap.","pos":""}],"WAPACUT":[{"def":"The American hawk owl.","pos":""}],"WAPATOO":[{"def":"The edible tuber of a species of arrowhead (Sagittaria variabilis); -- so called by the Indians of Oregon.","pos":""}],"WAPED":[{"def":"Cast down; crushed by misery; dejected.","pos":""}],"WAPENTAKE":[{"def":"In some northern counties of England, a division, or district, answering to the hundred in other counties.","pos":""}],"WAPINSCHAW":[{"def":"An exhibition of arms.","pos":""}],"WAPITI":[{"def":"The American elk (Cervus Canadensis).","pos":""}],"WAPPENED":[{"def":"A word of doubtful meaning used once by Shakespeare.","pos":""}],"WAPPER":[{"def":"To cause to shake; to tremble; to move tremulously, as from weakness; to totter.","pos":""}],"WAPPET":[{"def":"A small yelping cur.","pos":""}]}