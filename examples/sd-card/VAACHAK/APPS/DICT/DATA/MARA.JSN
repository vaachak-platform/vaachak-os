{"MARA":[{"def":"The principal or ruling evil spirit.","pos":""}],"MARABOU":[{"def":"A large stork of the genus Leptoptilos (formerly Ciconia), esp.","pos":""}],"MARABOUT":[{"def":"A Mohammedan saint; especially, one who claims to work cures supernaturally.","pos":""}],"MARAI":[{"def":"A sacred inclosure or temple; -- so called by the islanders of the Pacific Ocean.","pos":""}],"MARANATHA":[{"def":"\"Our Lord cometh;\" -- an expression used by St.","pos":""}],"MARANTA":[{"def":"A genus of endogenous plants found in tropical America, and some species also in India.","pos":""}],"MARASCHINO":[{"def":"A liqueur distilled from fermented cherry juice, and flavored with the pit of a variety of cherry which grows in Dalmatia.","pos":""}],"MARASMUS":[{"def":"A wasting of flesh without fever or apparent disease; a kind of consumption; atrophy; phthisis.","pos":""},{"def":"A Sanskritic language of western India, prob.","pos":""}],"MARAUD":[{"def":"To rove in quest of plunder; to make an excursion for booty; to plunder.","pos":""}],"MARAUDER":[{"def":"A rover in quest of booty or plunder; a plunderer; one who pillages.","pos":""}],"MARAVEDI":[{"def":"A small copper coin of Spain, equal to three mils American money, less than a farthing sterling.","pos":""}]}