{"PATRIAL":[{"def":"Derived from the name of a country, and designating an inhabitant of the country; gentile; -- said of a noun.","pos":""}],"PATRIARCH":[{"def":"A dignitary superior to the order of archbishops; as, the patriarch of Constantinople, of Alexandria, or of Antioch.","pos":""}],"PATRIARCHAL":[{"def":"Having an organization of society and government in which the head of the family exercises authority over all its generations.","pos":""}],"PATRIARCHATE":[{"def":"A patriarchal form of government or society.","pos":""}],"PATRIARCHDOM":[{"def":"The office or jurisdiction of a patriarch; patriarchate.","pos":""}],"PATRIARCHISM":[{"def":"Government by a patriarch, or the head of a family.","pos":""}],"PATRIARCHY":[{"def":"The jurisdiction of a patriarch; patriarchship.","pos":""},{"def":"Government by a patriarch; patriarchism.","pos":""}],"PATRICIAN":[{"def":"Of or pertaining to the Roman patres (fathers) or senators, or patricians.","pos":""}],"PATRICIANISM":[{"def":"The rank or character of patricians.","pos":""}],"PATRICIATE":[{"def":"The patrician class; the aristocracy; also, the office of patriarch.","pos":""}],"PATRICIDAL":[{"def":"Of or pertaining to patricide; parricidal.","pos":""}],"PATRICIDE":[{"def":"The murderer of his father.","pos":""},{"def":"The crime of one who murders his father.","pos":""}],"PATRIMONIAL":[{"def":"Of or pertaining to a patrimony; inherited from ancestors; as, a patrimonial estate.","pos":""}],"PATRIMONIALLY":[{"def":"Pat`ri*mo\"ni*al*ly, adv.","pos":""}],"PATRIMONY":[{"def":"A right or estate inherited from one's father; or, in a larger sense, from any ancestor.","pos":""},{"def":"Formerly, a church estate or endowment.","pos":""}],"PATRIOT":[{"def":"One who loves his country, and zealously supports its authority and interests.","pos":""}],"PATRIOTIC":[{"def":"Inspired by patriotism; actuated by love of one's country; zealously and unselfishly devoted to the service of one's country; as, a patriotic statesman, vigilance.","pos":""}],"PATRIOTICAL":[{"def":"Patriotic; that pertains to a patriot.","pos":""}],"PATRIOTISM":[{"def":"Love of country; devotion to the welfare of one's country; the virtues and actions of a patriot; the passion which inspires one to serve one's country.","pos":""}],"PATRIOTS' DAY":[{"def":"A legal holiday in the States of Massachusetts and Maine, April 19, the anniversary of the battle of Lexington in 1775.","pos":""}],"PATRIPASSIAN":[{"def":"One of a body of believers in the early church who denied the independent preëxistent personality of Christ, and who, accordingly, held that the Father suffered in the Son; a monarchian.","pos":""}],"PATRIST":[{"def":"One versed in patristics.","pos":""},{"def":"Of or pertaining to the Fathers of the Christian church.","pos":""}],"PATRISTICS":[{"def":"That departnent of historical theology which treats of the lives and doctrines of the Fathers of the church.","pos":""}],"PATRIZATE":[{"def":"To imitate one's father.","pos":""}],"PATROCINATE":[{"def":"To support; to patronize.","pos":""}],"PATROCINATION":[{"def":"The act of patrocinating or patronizing.","pos":""}],"PATROCINY":[{"def":"See Patrocination.","pos":""}],"PATROL":[{"def":"To go the rounds along a chain of sentinels; to traverse a police district or beat.","pos":""}],"PATROLMAN":[{"def":"One who patrols; a watchman; especially, a policeman who patrols a particular precinct of a town or city.","pos":""}],"PATRON":[{"def":"One who has gift and disposition of a benefice.","pos":""}],"PATRONAGE":[{"def":"The right of presentation to church or ecclesiastical benefice; advowson.","pos":""}],"PATRONAL":[{"def":"Patron; protecting; favoring.","pos":""}],"PATRONATE":[{"def":"The right or duty of a patron; patronage.","pos":""}],"PATRONESS":[{"def":"A female patron or helper.","pos":""}],"PATRONIZATION":[{"def":"The act of patronizing; patronage; support.","pos":""}],"PATRONIZE":[{"def":"To act as patron toward; to support; to countenance; to favor; to aid.","pos":""},{"def":"To trade with customarily; to frequent as a customer.","pos":""}],"PATRONIZER":[{"def":"One who patronizes.","pos":""}],"PATRONIZING":[{"def":"Showing condescending favor; assuming the manner of airs of a superior toward another.","pos":""}],"PATRONLESS":[{"def":"Destitute of a patron.","pos":""}],"PATRONOMAYOLOGY":[{"def":"That branch of knowledge which deals with personal names and their origin; the study of patronymics.","pos":""}],"PATRONYMIC":[{"def":"Derived from ancestors; as, a patronymic denomination.","pos":""}],"PATRONYMICAL":[{"def":"Same as Patronymic.","pos":""}],"PATROON":[{"def":"One of the proprietors of certain tracts of land with manorial privileges and right of entail, under the old Dutch governments of New York and New Jersey.","pos":""}],"PATROONSHIP":[{"def":"The office of a patroon.","pos":""},{"def":"Narrow at the inner, and very broad at the other, end, or having its arms of that shape; -- said of a cross.","pos":""}]}