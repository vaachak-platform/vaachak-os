{"CHEEK":[{"def":"Those pieces of a machine, or of any timber, or stone work, which form corresponding sides, or which are similar and in pair; as, the cheeks (jaws) of a vise; the cheeks of a gun carriage, etc.","pos":""},{"def":"The branches of a bridle bit.","pos":""}],"CHEEKED":[{"def":"Having a cheek; -- used in composition.","pos":""}],"CHEEKY":[{"def":"a Brazen-faced; impudent; bold.","pos":""}],"CHEEP":[{"def":"To chirp, as a young bird.","pos":""}],"CHEER":[{"def":"The face; the countenance or its expression.","pos":""},{"def":"Feeling; spirit; state of mind or heart.","pos":""}],"CHEERER":[{"def":"One who cheers; one who, or that which, gladdens.","pos":""}],"CHEERFUL":[{"def":"Having or showing good spirits or joy; cheering; cheery; contented; happy; joyful; lively; animated; willing.","pos":""}],"CHEERFULLY":[{"def":"In a cheerful manner, gladly.","pos":""}],"CHEERFULNESS":[{"def":"Good spirits; a state of moderate joy or gayety; alacrity.","pos":""}],"CHEERILY":[{"def":"In a cheery manner.","pos":""}],"CHEERINESS":[{"def":"The state of being cheery.","pos":""}],"CHEERINGLY":[{"def":"In a manner to cheer or encourage.","pos":""}],"CHEERISNESS":[{"def":"There is no Christian duty that is not to be seasoned and set off with cheerishness.","pos":""}],"CHEERLESS":[{"def":"Without joy, gladness, or comfort.","pos":""}],"CHEERRY":[{"def":"Cheerful; lively; gay; bright; pleasant; as, a cheery person.","pos":""}],"CHEESE":[{"def":"The curd of milk, coagulated usually with rennet, separated from the whey, and pressed into a solid mass in a hoop or mold.","pos":""},{"def":"A mass of pomace, or ground apples, pressed togehter in the form of a cheese.","pos":""}],"CHEESE CLOTH":[{"def":"A thin, loosewoven cotton cloth, such as is used in pressing cheese curds.","pos":""}],"CHEESELEP":[{"def":"A bag in which rennet is kept.","pos":""}],"CHEESEMONGER":[{"def":"One who deals incheese.","pos":""}],"CHEESEPARING":[{"def":"A thin portion of the rind of a cheese.","pos":""},{"def":"Scrimping; mean; as, cheeseparing economy.","pos":""}],"CHEESINESS":[{"def":"The quality of being cheesy.","pos":""}],"CHEESY":[{"def":"Having the nature, qualities, taste, form, consistency, or appearance of cheese.","pos":""}],"CHEETAH":[{"def":"A species of leopard (Cynælurus jubatus) tamed and used for hunting in India.","pos":""}]}