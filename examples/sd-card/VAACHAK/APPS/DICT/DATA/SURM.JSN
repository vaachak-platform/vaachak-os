{"SURMARK":[{"def":"A mark made on the molds of a ship, when building, to show where the angles of the timbers are to be placed.","pos":""}],"SURMISABLE":[{"def":"Capable of being surmised; as, a surmisable result.","pos":""}],"SURMISE":[{"def":"A thought, imagination, or conjecture, which is based upon feeble or scanty evidence; suspicion; guess; as, the surmisses of jealousy or of envy.","pos":""},{"def":"Reflection; thought.","pos":""}],"SURMISER":[{"def":"One who surmises.","pos":""}],"SURMISING":[{"def":"from Surmise, v.","pos":""}],"SURMOUNT":[{"def":"To rise above; to be higher than; to overtop.","pos":""},{"def":"To conquer; to overcome; as, to surmount difficulties or obstacles.","pos":""}],"SURMOUNTABLE":[{"def":"Capable of being surmounted or overcome; superable.","pos":""}],"SURMOUNTED":[{"def":"Having its vertical height greater than the half span; -- said of an arch.","pos":""},{"def":"Partly covered by another charge; -- said of an ordinary or other bearing.","pos":""}],"SURMOUNTER":[{"def":"One who, or that which, surmounts.","pos":""}],"SURMULLET":[{"def":"Any one of various species of mullets of the family Millidæ, esp.","pos":""}],"SURMULOT":[{"def":"The brown, or Norway, rat.","pos":""}]}