{"SLEAVE":[{"def":"Sleep that knits up the ravell'd sleave of care.","pos":"verb"}],"SLEAVED":[{"def":"Raw; not spun or wrought; as, sleaved thread or silk.","pos":""}],"SLEAZINESS":[{"def":"Quality of being sleazy.","pos":""}],"SLEAZY":[{"def":"Wanting firmness of texture or substance; thin; flimsy; as, sleazy silk or muslin.","pos":""}],"SLED":[{"def":"A vehicle on runners, used for conveying loads over the snow or ice; -- in England called sledge.","pos":""},{"def":"A small, light vehicle with runners, used, mostly by young persons, for sliding on snow or ice.","pos":""}],"SLEDDING":[{"def":"The act of transporting or riding on a sled.","pos":""},{"def":"The state of the snow which admits of the running of sleds; as, the sledding is good.","pos":""}],"SLEDGE":[{"def":"A strong vehicle with low runners or low wheels; or one without wheels or runners, made of plank slightly turned up at one end, used for transporting loads upon the snow, ice, or bare ground; a sled.","pos":""},{"def":"A hurdle on which, formerly, traitors were drawn to the place of execution.","pos":""}],"SLEEK":[{"def":"Having an even, smooth surface; smooth; hence, glossy; as, sleek hair.","pos":""},{"def":"Not rough or harsh.","pos":""}],"SLEEKLY":[{"def":"In a sleek manner; smoothly.","pos":""}],"SLEEKNESS":[{"def":"The quality or state of being sleek; smoothness and glossiness of surface.","pos":""}],"SLEEKY":[{"def":"Of a sleek, or smooth, and glossy appearance.","pos":""},{"def":"Fawning and deceitful; sly.","pos":""}],"SLEEP":[{"def":"To take rest by a suspension of the voluntary exercise of the powers of the body and mind, and an apathy of the organs of sense; to slumber.","pos":""},{"def":"Figuratively: (a) To be careless, inattentive, or uncouncerned; not to be vigilant; to live thoughtlessly.","pos":""}],"SLEEP-AT-NOON":[{"def":"A plant (Tragopogon pratensis) which closes its flowers at midday; a kind of goat's beard.","pos":""}],"SLEEP-CHARGED":[{"def":"Heavy with sleep.","pos":""}],"SLEEPER":[{"def":"An animal that hibernates, as the bear.","pos":""}],"SLEEPFUL":[{"def":"Strongly inclined to sleep; very sleepy.","pos":""}],"SLEEPILY":[{"def":"In a sleepy manner; drowsily.","pos":""}],"SLEEPINESS":[{"def":"The quality or state of being sleepy.","pos":""}],"SLEEPISH":[{"def":"Disposed to sleep; sleepy; drowsy.","pos":""}],"SLEEPLESS":[{"def":"Having no sleep; wakeful.","pos":""},{"def":"Having no rest; perpetually agitated.","pos":""}],"SLEEPWAKER":[{"def":"On in a state of magnetic or mesmeric sleep.","pos":""}],"SLEEPWAKING":[{"def":"The state of one mesmerized, or in a partial and morbid sleep.","pos":""}],"SLEEPWALKER":[{"def":"One who walks in his sleep; a somnambulist.","pos":""}],"SLEEPWALKING":[{"def":"Walking in one's sleep.","pos":""}],"SLEEPY":[{"def":"Drowsy; inclined to, or overcome by, sleep.","pos":""},{"def":"Tending to induce sleep; soporiferous; somniferous; as, a sleepy drink or potion.","pos":""}],"SLEEPYHEAD":[{"def":"A sleepy person.","pos":""}],"SLEET":[{"def":"The part of a mortar extending from the chamber to the trunnions.","pos":""}],"SLEETCH":[{"def":"Mud or slime, such as that at the bottom of rivers.","pos":""}],"SLEETINESS":[{"def":"The state of being sleety.","pos":""}],"SLEETY":[{"def":"Of or pertaining to sleet; characterized by sleet; as, a sleety storm; sleety weather.","pos":""}],"SLEEVE":[{"def":"See Sleave, untwisted thread.","pos":""}],"SLEEVED":[{"def":"Having sleeves; furnished with sleeves; -- often in composition; as, long-sleeved.","pos":""}],"SLEEVEHAND":[{"def":"The part of a sleeve nearest the hand; a cuff or wristband.","pos":""}],"SLEEVELESS":[{"def":"Having no sleeves.","pos":""},{"def":"Wanting a cover, pretext, or palliation; unreasonable; profitless; bootless; useless.","pos":""}],"SLEID":[{"def":"To sley, or prepare for use in the weaver's sley, or slaie.","pos":""}],"SLEIGH":[{"def":"A vehicle moved on runners, and used for transporting persons or goods on snow or ice; -- in England commonly called a sledge.","pos":""}],"SLEIGHING":[{"def":"The act of riding in a sleigh.","pos":""},{"def":"The state of the snow or ice which admits of running sleighs.","pos":""}],"SLEIGHT":[{"def":"Cunning; craft; artful practice.","pos":""},{"def":"An artful trick; sly artifice; a feat so dexterous that the manner of performance escapes observation.","pos":""}],"SLEIGHTFUL":[{"def":"Cunning; dexterous.","pos":""}],"SLENDER":[{"def":"Uttered with a thin tone; -- the opposite of broad; as, the slender vowels long e and i.","pos":""}],"SLEPEZ":[{"def":"A burrowing rodent (Spalax typhlus), native of Russia and Asia Minor.","pos":""}],"SLEUTH":[{"def":"The track of man or beast as followed by the scent.","pos":""}],"SLEUTHHOUND":[{"def":"A hound that tracks animals by the scent; specifically, a bloodhound.","pos":""}],"SLEWTH":[{"def":"Sloth; idleness.","pos":""}],"SLEY":[{"def":"A weaver's reed.","pos":""},{"def":"A guideway in a knitting machine.","pos":""}]}