{"INVULGAR":[{"def":"To cause to become or appear vulgar.","pos":""}],"INVULNERABILITY":[{"def":"Quality or state of being invulnerable.","pos":""}],"INVULNERABLE":[{"def":"Incapable of being wounded, or of receiving injury.","pos":""},{"def":"Unanswerable; irrefutable; that can not be refuted or convinced; as, an invulnerable argument.","pos":""}],"INVULNERABLENESS":[{"def":"Invulnerability.","pos":""}]}