{"VEDA":[{"def":"The ancient sacred literature of the Hindoos; also, one of the four collections, called Rig-Veda, Yajur-Veda, Sama-Veda, and Atharva-Veda, constituting the most ancient portions of that literature.","pos":""}],"VEDANTA":[{"def":"A system of philosophy among the Hindoos, founded on scattered texts of the Vedas, and thence termed the \"Anta,\" or end or substance.","pos":""}],"VEDANTIC":[{"def":"Of or pertaining to the Vedas.","pos":""}],"VEDANTIST":[{"def":"One versed in the doctrines of the Vedantas.","pos":""}],"VEDETTE":[{"def":"A sentinel, usually on horseback, stationed on the outpost of an army, to watch an enemy and give notice of danger; a vidette.","pos":""}],"VEDRO":[{"def":"A Russian liquid measure, equal to 3.","pos":""}]}