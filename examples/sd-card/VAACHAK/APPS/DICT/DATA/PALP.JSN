{"PALP":[{"def":"To have a distinct touch or feeling of; to feel.","pos":""}],"PALPABILITY":[{"def":"The quality of being palpable, or perceptible by the touch.","pos":""}],"PALPABLE":[{"def":"Capable of being touched and felt; perceptible by the touch; as, a palpable form.","pos":""},{"def":"Easily perceptible; plain; distinct; obvious; readily perceived and detected; gross; as, palpable imposture; palpable absurdity; palpable errors.","pos":""}],"PALPATION":[{"def":"Examination of a patient by touch.","pos":""}],"PALPATOR":[{"def":"One of a family of clavicorn beetles, including those which have very long maxillary palpi.","pos":""}],"PALPEBRAL":[{"def":"Of or pertaining to the eyelids.","pos":""}],"PALPED":[{"def":"Having a palpus.","pos":""}],"PALPICORN":[{"def":"One of a group of aquatic beetles (Palpicornia) having short club-shaped antennæ, and long maxillary palpi.","pos":""}],"PALPIFER":[{"def":"Same as Palpiger.","pos":""}],"PALPIFORM":[{"def":"Having the form of a palpus.","pos":""}],"PALPIGER":[{"def":"That portion of the labium which bears the palpi in insects.","pos":""}],"PALPIGEROUS":[{"def":"Bearing a palpus.","pos":""}],"PALPITANT":[{"def":"Palpitating; throbbing; trembling.","pos":""}],"PALPITATE":[{"def":"To beat rapidly and more strongly than usual; to throb; to bound with emotion or exertion; to pulsate violently; to flutter; -- said specifically of the heart when its action is abnormal, as from excitement.","pos":""}],"PALPITATION":[{"def":"A rapid pulsation; a throbbing; esp.","pos":""}],"PALPLESS":[{"def":"Without a palpus.","pos":""}],"PALPOCIL":[{"def":"A minute soft filamentary process springing from the surface of certain hydroids and sponges.","pos":""}],"PALPUS":[{"def":"A feeler; especially, one of the jointed sense organs attached to the mouth organs of insects, arachnids, crustaceans, and annelids; as, the mandibular palpi, maxillary palpi, and labial palpi.","pos":""}]}