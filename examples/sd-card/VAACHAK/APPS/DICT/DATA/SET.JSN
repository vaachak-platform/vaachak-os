{"SET":[{"def":"To compose; to arrange in words, lines, etc.","pos":""}],"SET CHISEL":[{"def":"A kind of chisel or punch, variously shaped, with a broad flat end, used for stripping off rivet heads, etc.","pos":""}],"SET-FAIR":[{"def":"In plastering, a particularly good troweled surface.","pos":""}],"SET-OFF":[{"def":"A counterclaim; a cross debt or demand; a distinct claim filed or set up by the defendant against the plaintiff's demand.","pos":""},{"def":"Same as Offset, n.","pos":""}],"SET-STITCHED":[{"def":"Stitched according to a formal pattern.","pos":""}],"SET-TO":[{"def":"A contest in boxing, in an argument, or the like.","pos":""}],"SETA":[{"def":"Any slender, more or less rigid, bristlelike organ or part; as the hairs of a caterpillar, the slender spines of a crustacean, the hairlike processes of a protozoan, the bristles or stiff hairs on the leaves of some plants, or the pedicel of the capsule of a moss.","pos":""}],"SETACEOUS":[{"def":"Set with, or consisting of, bristles; bristly; as, a stiff, setaceous tail.","pos":""},{"def":"Bristelike in form or texture; as, a setaceous feather; a setaceous leaf.","pos":""}],"SETBACK":[{"def":"A backset; a countercurrent; an eddy.","pos":""},{"def":"A backset; a check; a repulse; a reverse; a relapse.","pos":""}],"SETBOLT":[{"def":"An iron pin, or bolt, for fitting planks closely together.","pos":""},{"def":"A bolt used for forcing another bolt out of its hole.","pos":""}],"SETDOWN":[{"def":"The humbling of a person by act or words, especially by a retort or a reproof; the retort or the reproof which has such effect.","pos":""}],"SETIFEROUS":[{"def":"Producing, or having one or more, bristles.","pos":""}],"SETIFORM":[{"def":"Having the form or structure of setæ.","pos":""}],"SETIGER":[{"def":"An annelid having setæ; a chætopod.","pos":""}],"SETIGEROUS":[{"def":"Covered with bristles; having or bearing a seta or setæ; setiferous; as, setigerous glands; a setigerous segment of an annelid; specifically (Bot.","pos":""}],"SETIPAROUS":[{"def":"Producing setæ; -- said of the organs from which the setæ of annelids arise.","pos":""}],"SETIREME":[{"def":"A swimming leg (of an insect) having a fringe of hairs on the margin.","pos":""}],"SETNESS":[{"def":"The quality or state of being set; formality; obstinacy.","pos":""}],"SETON":[{"def":"A few silk threads or horsehairs, or a strip of linen or the like, introduced beneath the skin by a knife or needle, so as to form an issue; also, the issue so formed.","pos":""},{"def":"Thickly set with bristles or bristly hairs.","pos":""}],"SETOUT":[{"def":"A display, as of plate, equipage, etc.","pos":""}],"SETTEE":[{"def":"A long seat with a back, -- made to accommodate several persons at once.","pos":""}],"SETTER":[{"def":"A hunting dog of a special breed originally derived from a cross between the spaniel and the pointer.","pos":""},{"def":"A shallow seggar for porcelain.","pos":""}],"SETTERWORT":[{"def":"The bear's-foot (Helleborus foetidus); -- so called because the root was used in settering, or inserting setons into the dewlaps of cattle.","pos":""}],"SETTING":[{"def":"The act of one who, or that which, sets; as, the setting of type, or of gems; the setting of the sun; the setting (hardening) of moist plaster of Paris; the setting (set) of a current.","pos":""},{"def":"The act of marking the position of game, as a setter does; also, hunting with a setter.","pos":""}],"SETTING-UP EXERCISE":[{"def":"Any one of a series of gymnastic exercises used, as in drilling recruits, for the purpose of giving an erect carriage, supple muscles, and an easy control of the limbs.","pos":""}],"SETTLE":[{"def":"A seat of any kind.","pos":""},{"def":"A bench; especially, a bench with a high back.","pos":""}],"SETTLEDNESS":[{"def":"The quality or state of being settled; confirmed state.","pos":""}],"SETTLEMENT":[{"def":"A disposition of property for the benefit of some person or persons, usually through the medium of trustees, and for the benefit of a wife, children, or other relatives; jointure granted to a wife, or the act of granting it.","pos":""},{"def":"Fractures or dislocations caused by settlement.","pos":""}],"SETTLER":[{"def":"One who settles, becomes fixed, established, etc.","pos":""},{"def":"Especially, one who establishes himself in a new region or a colony; a colonist; a planter; as, the first settlers of New England.","pos":""}],"SETTLING":[{"def":"That which settles at the bottom of a liquid; lees; dregs; sediment.","pos":""}],"SETULA":[{"def":"A small, short hair or bristle; a small seta.","pos":""}],"SETULOSE":[{"def":"Having small bristles or setæ.","pos":""}],"SETWALL":[{"def":"A plant formerly valued for its restorative qualities (Valeriana officinalis, or V.","pos":""}]}