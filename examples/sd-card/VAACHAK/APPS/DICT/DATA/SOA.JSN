{"SOAK":[{"def":"To cause or suffer to lie in a fluid till the substance has imbibed what it can contain; to macerate in water or other liquid; to steep, as for the purpose of softening or freshening; as, to soak cloth; to soak bread; to soak salt meat, salt fish, or the like.","pos":""},{"def":"To drench; to wet thoroughly.","pos":""}],"SOAKAGE":[{"def":"The act of soaking, or the state of being soaked; also, the quantity that enters or issues by soaking.","pos":""}],"SOAKER":[{"def":"One who, or that which, soaks.","pos":""}],"SOAKING":[{"def":"Wetting thoroughly; drenching; as, a soaking rain.","pos":""}],"SOAKY":[{"def":"Full of moisture; wet; soppy.","pos":""}],"SOAL":[{"def":"See Sole, the fish.","pos":""}],"SOAM":[{"def":"A chain by which a leading horse draws a plow.","pos":""}],"SOAP":[{"def":"A substance which dissolves in water, thus forming a lather, and is used as a cleansing agent.","pos":""}],"SOAPBERRY TREE":[{"def":"Any tree of the genus Sapindus, esp.","pos":""}],"SOAPFISH":[{"def":"Any serranoid fish of the genus Rhypticus; -- so called from the soapy feeling of its skin.","pos":""}],"SOAPINESS":[{"def":"Quality or state of being soapy.","pos":""}],"SOAPROOT":[{"def":"A perennial herb (Gypsophila Struthium) the root of which is used in Spain as a substitute for soap.","pos":""}],"SOAPSTONE":[{"def":"See Steatite, and Talc.","pos":""}],"SOAPSUDS":[{"def":"Suds made with soap.","pos":""}],"SOAPWORT":[{"def":"A common plant (Saponaria officinalis) of the Pink family; -- so called because its bruised leaves, when agitated in water, produce a lather like that from soap.","pos":""}],"SOAPY":[{"def":"Resembling soap; having the qualities of, or feeling like, soap; soft and smooth.","pos":""},{"def":"Smeared with soap; covered with soap.","pos":""}],"SOAR":[{"def":"To fly aloft, as a bird; to mount upward on wings, or as on wings.","pos":""}]}