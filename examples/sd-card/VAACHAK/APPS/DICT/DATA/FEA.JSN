{"FEAGUE":[{"def":"To beat or whip; to drive.","pos":""}],"FEAL":[{"def":"Faithful; loyal.","pos":""}],"FEALTY":[{"def":"Fidelity to one's lord; the feudal obligation by which the tenant or vassal was bound to be faithful to his lord; the special oath by which this obligation was assumed; fidelity to a superior power, or to a government; loyality.","pos":""},{"def":"Fidelity; constancy; faithfulness, as of a friend to a friend, or of a wife to her husband.","pos":""}],"FEAR":[{"def":"A variant of Fere, a mate, a companion.","pos":""}],"FEARFUL":[{"def":"Full of fera, apprehension, or alarm; afraid; frightened.","pos":""},{"def":"Indicating, or caused by, fear.","pos":""}],"FEARFULLY":[{"def":"In a fearful manner.","pos":""}],"FEARFULNESS":[{"def":"The state of being fearful.","pos":""}],"FEARNAUGHT":[{"def":"A fearless person.","pos":""},{"def":"A stout woolen cloth of great thickness; dreadnaught; also, a warm garment.","pos":""}],"FEARSOME":[{"def":"Frightful; causing fear [Scotch] \"This fearsome wind.","pos":""}],"FEASIBILITY":[{"def":"The quality of being feasible; practicability; also, that which is feasible; as, before we adopt a plan, let us consider its feasibility.","pos":""}],"FEASIBLE":[{"def":"Capable of being done, executed, or effected; practicable.","pos":""},{"def":"Fit to be used or tailed, as land.","pos":""}],"FEAST":[{"def":"A festival; a holiday; a solemn, or more commonly, a joyous, anniversary.","pos":""},{"def":"A festive or joyous meal; a grand, ceremonious, or sumptuous entertainment, of which many guests partake; a banquet characterized by tempting variety and abundance of food.","pos":""}],"FEASTER":[{"def":"One who fares deliciously.","pos":""},{"def":"One who entertains magnificently.","pos":""}],"FEASTFUL":[{"def":"Festive; festal; joyful; sumptuous; luxurious.","pos":""}],"FEAT":[{"def":"An act; a deed; an exploit.","pos":""},{"def":"A striking act of strength, skill, or cunning; a trick; as, feats of horsemanship, or of dexterity.","pos":""}],"FEAT-BODIED":[{"def":"Having a feat or trim body.","pos":""}],"FEATEOUS":[{"def":"Dexterous; neat.","pos":""}],"FEATHER":[{"def":"A longitudinal strip projecting as a fin from an object, to strengthen it, or to enter a channel in another object and thereby prevent displacement sidwise but permit motion lengthwise; a spline.","pos":""}],"FEATHER-BRAINED":[{"def":"Giddy; frivolous; feather-headed.","pos":""}],"FEATHER-EDGE":[{"def":"The thin, new growth around the edge of a shell, of an oyster.","pos":""}],"FEATHER-EDGED":[{"def":"Having a feather-edge; also, having one edge thinner than the other, as a board; -- in the United States, said only of stuff one edge of which is made as thin as practicable.","pos":""}],"FEATHER-FOIL":[{"def":"An aquatic plant (Hottonia palustris), having finely divided leaves.","pos":""}],"FEATHER-HEAD":[{"def":"A frivolous or featherbrained person.","pos":""}],"FEATHER-HEADED":[{"def":"Giddy; frivolous; foolish.","pos":""}],"FEATHER-HEELED":[{"def":"Light-heeled; gay; frisky; frolicsome.","pos":""}],"FEATHER-PATED":[{"def":"Feather-headed; frivolous.","pos":""}],"FEATHER-VEINED":[{"def":"Having the veins (of a leaf) diverging from the two sides of a midrib.","pos":""}],"FEATHERBONE":[{"def":"A substitute for whalebone, made from the quills of geese and turkeys.","pos":""}],"FEATHERED":[{"def":"Having a fringe of feathers, as the legs of certian birds; or of hairs, as the legs of a setter dog.","pos":""},{"def":"Having feathers; -- said of an arrow, when the feathers are of a tincture different from that of the shaft.","pos":""}],"FEATHERINESS":[{"def":"The state or condition of being feathery.","pos":""}],"FEATHERING":[{"def":"Same as Foliation.","pos":""}],"FEATHERLESS":[{"def":"Destitute of feathers.","pos":""}],"FEATHERNESS":[{"def":"The state or condition of being feathery.","pos":""}],"FEATHERSTITCH":[{"def":"A kind of embroidery stitch producing a branching zigzag line.","pos":""}],"FEATHERY":[{"def":"Pertaining to, or resembling, feathers; covered with, or as with, feathers; as, feathery spray or snow.","pos":""}],"FEATLY":[{"def":"Neatly; dexterously; nimbly.","pos":""}],"FEATNESS":[{"def":"Skill; adroitness.","pos":""}],"FEATURE":[{"def":"The make, form, or outward appearance of a person; the whole turn or style of the body; esp.","pos":""},{"def":"The make, cast, or appearance of the human face, and especially of any single part of the face; a lineament.","pos":""}],"FEATURED":[{"def":"Shaped; fashioned.","pos":""},{"def":"Having features; formed into features.","pos":""}],"FEATURELESS":[{"def":"Having no distinct or distinctive features.","pos":""}],"FEATURELY":[{"def":"Having features; showing marked peculiarities; handsome.","pos":""}],"FEAZE":[{"def":"To untwist; to unravel, as the end of a rope.","pos":""}],"FEAZINGS":[{"def":"The unlaid or ragged end of a rope.","pos":""}]}