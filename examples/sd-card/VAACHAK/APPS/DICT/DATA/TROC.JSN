{"TROCAR":[{"def":"A stylet, usually with a triangular point, used for exploring tissues or for inserting drainage tubes, as in dropsy.","pos":""}],"TROCHA":[{"def":"A line of fortifications, usually rough, constructed to prevent the passage of an enemy across a region.","pos":""}],"TROCHAIC":[{"def":"A trochaic verse or measure.","pos":""},{"def":"Of or pertaining to trochees; consisting of trochees; as, trochaic measure or verse.","pos":""}],"TROCHAL":[{"def":"Resembling a wheel.","pos":""}],"TROCHANTER":[{"def":"One of two processes near the head of the femur, the outer being called the great trochanter, and the inner the small trochanter.","pos":""},{"def":"The third joint of the leg of an insect, or the second when the trochantine is united with the coxa.","pos":""}],"TROCHANTERIC":[{"def":"Of or pertaining to one or both of the trochanters.","pos":""}],"TROCHANTINE":[{"def":"The second joint of the leg of an insect, -- often united with the coxa.","pos":""}],"TROCHE":[{"def":"A medicinal tablet or lozenge; strictly, one of circular form.","pos":""}],"TROCHEE":[{"def":"A foot of two syllables, the first long and the second short, as in the Latin word ante, or the first accented and the second unaccented, as in the English word motion; a choreus.","pos":""}],"TROCHIL":[{"def":"The crocodile bird.","pos":""}],"TROCHILI":[{"def":"A division of birds comprising the humming birds.","pos":""}],"TROCHILIC":[{"def":"OF or pertaining to rotary motion; having power to draw out or turn round.","pos":""}],"TROCHILICS":[{"def":"The science of rotary motion, or of wheel work.","pos":""}],"TROCHILIDIST":[{"def":"One who studies, or is versed in, the nature and habits of humming birds, or the Trochilidæ.","pos":""}],"TROCHILOS":[{"def":"The crocodile bird, or trochil.","pos":""}],"TROCHILUS":[{"def":"An annular molding whose section is concave, like the edge of a pulley; -- called also scotia.","pos":""}],"TROCHING":[{"def":"One of the small branches of a stag's antler.","pos":""}],"TROCHISCUS":[{"def":"A kind of tablet or lozenge; a troche.","pos":""}],"TROCHITE":[{"def":"A wheel-like joint of the stem of a fossil crinoid.","pos":""}],"TROCHLEA":[{"def":"A pulley, or a structure resembling a pulley; as, the trochlea, or pulleylike end, of the humerus, which articulates with the ulna; or the trochlea, or fibrous ring, in the upper part of the orbit, through which the superior oblique, or trochlear, muscle of the eye passes.","pos":""}],"TROCHLEAR":[{"def":"Shaped like, or resembling, a pulley; pertaining to, or connected with, a trochlea; as, a trochlear articular surface; the trochlear muscle of the eye.","pos":""}],"TROCHLEARY":[{"def":"Pertaining to, or connected with, a trochlea; trochlear; as, the trochleary, or trochlear, nerve.","pos":""}],"TROCHOID":[{"def":"The curve described by any point in a wheel rolling on a line; a cycloid; a roulette; in general, the curve described by any point fixedly connected with a moving curve while the moving curve rolls without slipping on a second fixed curve, the curves all being in one plane.","pos":""}],"TROCHOIDAL":[{"def":"Of or pertaining to a trochoid; having the properties of a trochoid.","pos":""},{"def":"See Trochoid, a.","pos":""}],"TROCHOMETER":[{"def":"A contrivance for computing the revolutions of a wheel; an odometer.","pos":""}],"TROCHOSPHERE":[{"def":"A young larval form of many annelids, mollusks, and bryozoans, in which a circle of cilia is developed around the anterior end.","pos":""}],"TROCHUS":[{"def":"Any one of numerous species of marine univalve shells belonging to Trochus and many allied genera of the family Trochidæ.","pos":""}],"TROCO":[{"def":"An old English game; -- called also lawn billiards.","pos":""}]}