{"SAND":[{"def":"Tracts of land consisting of sand, like the deserts of Arabia and Africa; also, extensive tracts of sand exposed by the ebb of the tide.","pos":""}],"SAND-BLIND":[{"def":"Having defective sight; dim-sighted; purblind.","pos":""}],"SAND-LOT":[{"def":"Kearney, who delivered many of his speeches in the open sand lots about San Francisco; as, the sand-lot constitution of California, framed in 1879, under the influence of sand-lot agitation.","pos":""}],"SANDAL":[{"def":"Sails of silk and ropes of sandal.","pos":""}],"SANDALED":[{"def":"Wearing sandals.","pos":""},{"def":"Made like a sandal.","pos":""}],"SANDALIFORM":[{"def":"Shaped like a sandal or slipper.","pos":""}],"SANDALWOOD":[{"def":"Realgar; red sulphide of arsenic.","pos":""},{"def":"A white or yellow resin obtained from a Barbary tree (Callitris quadrivalvis or Thuya articulata), and pulverized for pounce; -- probably so called from a resemblance to the mineral.","pos":""}],"SANDBAGGER":[{"def":"An assaulter whose weapon is a sand bag.","pos":""}],"SANDED":[{"def":"Covered or sprinkled with sand; sandy; barren.","pos":""},{"def":"Marked with small spots; variegated with spots; speckled; of a sandy color, as a hound.","pos":""}],"SANDEMANIAN":[{"def":"A follower of Robert Sandeman, a Scotch sectary of the eighteenth century.","pos":""}],"SANDEMANIANISM":[{"def":"The faith or system of the Sandemanians.","pos":""}],"SANDERLING":[{"def":"A small gray and brown sandpiper (Calidris arenaria) very common on sandy beaches in America, Europe, and Asia.","pos":""}],"SANDERS":[{"def":"An old name of sandalwood, now applied only to the red sandalwood.","pos":""}],"SANDERS-BLUE":[{"def":"See Saundersblue.","pos":""}],"SANDFISH":[{"def":"A small marine fish of the Pacific coast of North America (Trichodon trichodon) which buries itself in the sand.","pos":""}],"SANDGLASS":[{"def":"An instrument for measuring time by the running of sand.","pos":""}],"SANDHILLER":[{"def":"A nickname given to any \"poor white\" living in the pine woods which cover the sandy hills in Georgia and South Carolina.","pos":""}],"SANDINESS":[{"def":"The quality or state of being sandy, or of being of a sandy color.","pos":""}],"SANDISH":[{"def":"Approaching the nature of sand; loose; not compact.","pos":""}],"SANDIVER":[{"def":"A whitish substance which is cast up, as a scum, from the materials of glass in fusion, and, floating on the top, is skimmed off; -- called also glass gall.","pos":""}],"SANDIX":[{"def":"A kind of minium, or red lead, made by calcining carbonate of lead, but inferior to true minium.","pos":""}],"SANDMAN":[{"def":"A mythical person who makes children sleepy, so that they rub their eyes as if there were sand in them.","pos":""}],"SANDNECKER":[{"def":"A European flounder (Hippoglossoides limandoides); -- called also rough dab, long fluke, sand fluke, and sand sucker.","pos":""}],"SANDPAPER":[{"def":"Paper covered on one side with sand glued fast, -- used for smoothing and polishing.","pos":""}],"SANDPIPER":[{"def":"Any one of numerous species of small limicoline game birds belonging to Tringa, Actodromas, Ereunetes, and various allied genera of the family Tringid\\'91.","pos":""},{"def":"A small lamprey eel; the pride.","pos":""}],"SANDPIT":[{"def":"A pit or excavation from which sand is or has been taken.","pos":""}],"SANDRE":[{"def":"A Russian fish (Lucioperca sandre) which yields a valuable oil, called sandre oil, used in the preparation of caviare.","pos":""}],"SANDSTONE":[{"def":"A rock made of sand more or less firmly united.","pos":""}],"SANDWICH":[{"def":"Two pieces of bread and butter with a thin slice of meat, cheese, or the like, between them.","pos":""}],"SANDWORT":[{"def":"Any plant of the genus Arenaria, low, tufted herbs (order Caryophyllace\\'91.","pos":""}],"SANDY":[{"def":"Consisting of, abounding with, or resembling, sand; full of sand; covered or sprinkled with sand; as, a sandy desert, road, or soil.","pos":""},{"def":"Of the color of sand; of a light yellowish red color; as, sandy hair.","pos":""}]}