{"MYO-":[{"def":"A combining form of Gr.","pos":""}],"MYOCARDITIS":[{"def":"Inflammation of the myocardium.","pos":""}],"MYOCARDIUM":[{"def":"The main substance of the muscular wall of the heart inclosed between the epicardium and endocardium.","pos":""}],"MYOCHROME":[{"def":"A colored albuminous substance in the serum from red-colored muscles.","pos":""}],"MYODYNAMICS":[{"def":"The department of physiology which deals with the principles of muscular contraction; the exercise of muscular force or contraction.","pos":""}],"MYODYNAMIOMETER":[{"def":"A myodynamometer.","pos":""}],"MYODYNAMOMETER":[{"def":"An instrument for measuring the muscular strength of man or of other animals; a dynamometer.","pos":""}],"MYOEPITHELIAL":[{"def":"Derived from epithelial cells and destined to become a part of the muscular system; -- applied to structural elements in certain embryonic forms.","pos":""},{"def":"Having the characteristics of both muscle and epithelium; as, the myoepithelial cells of the hydra.","pos":""}],"MYOGALID":[{"def":"One of the Myogalodæ, a family of Insectivora, including the desman, and allied species.","pos":""}],"MYOGRAM":[{"def":"See Muscle curve, under Muscle.","pos":""}],"MYOGRAPH":[{"def":"An instrument for determining and recording the different phases, as the intensity, velocity, etc.","pos":""},{"def":"Of or pertaining to myography.","pos":""}],"MYOGRAPHY":[{"def":"The description of muscles, including the study of muscular contraction by the aid of registering apparatus, as by some form of myograph; myology.","pos":""}],"MYOHAEMATIN":[{"def":"A red-colored respiratory pigment found associated with hemoglobin in the muscle tissue of a large number of animals, both vertebrate and invertebrate.","pos":""}],"MYOID":[{"def":"Composed of, or resembling, muscular fiber.","pos":""}],"MYOLIN":[{"def":"The essential material of muscle fibers.","pos":""},{"def":"Of or pertaining to myology.","pos":""}],"MYOLOGIST":[{"def":"One skilled in myology.","pos":""}],"MYOLOGY":[{"def":"That part of anatomy which treats of muscles.","pos":""}],"MYOMA":[{"def":"A tumor consisting of muscular tissue.","pos":""}],"MYOMANCY":[{"def":"Divination by the movements of mice.","pos":""}],"MYOMORPH":[{"def":"One of the Myomorpha.","pos":""}],"MYOMORPHA":[{"def":"An extensive group of rodents which includes the rats, mice, jerboas, and many allied forms.","pos":""}],"MYOPATHIA":[{"def":"Any affection of the muscles or muscular system.","pos":""}],"MYOPATHIC":[{"def":"Of or pertaining to myopathia.","pos":""}],"MYOPATHY":[{"def":"Same as Myopathia.","pos":""}],"MYOPE":[{"def":"A person having myopy; a myops.","pos":""}],"MYOPHAN":[{"def":"A contractile striated layer found in the bodies and stems of certain Infusoria.","pos":""}],"MYOPIA":[{"def":"Nearsightedness; shortsightedness; a condition of the eye in which the rays from distant object are brought to a focus before they reach the retina, and hence form an indistinct image; while the rays from very near objects are normally converged so as to produce a distinct image.","pos":""}],"MYOPIC":[{"def":"Pertaining to, or affected with, or characterized by, myopia; nearsighted.","pos":""}],"MYOPSIS":[{"def":"The appearance of muscæ volitantes.","pos":""}],"MYOSIN":[{"def":"An albuminous body present in dead muscle, being formed in the process of coagulation which takes place in rigor mortis; the clot formed in the coagulation of muscle plasma.","pos":""}],"MYOSIS":[{"def":"Long-continued contraction of the pupil of the eye.","pos":""}],"MYOSITIS":[{"def":"Inflammation of the muscles.","pos":""}],"MYOSOTIS":[{"def":"A genus of plants.","pos":""}],"MYOTIC":[{"def":"Producing myosis, or contraction of the pupil of the eye, as opium, calabar bean, etc.","pos":""}],"MYOTOMIC":[{"def":"Of or pertaining to a myotome or myotomes.","pos":""}],"MYOTOMY":[{"def":"The dissection, or that part of anatomy which treats of the dissection, of muscles.","pos":""}]}