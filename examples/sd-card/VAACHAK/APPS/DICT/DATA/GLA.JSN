{"GLABELLA":[{"def":"The space between the eyebrows, also including the corresponding part of the frontal bone; the mesophryon.","pos":""}],"GLABELLUM":[{"def":"The median, convex lobe of the head of a trilobite.","pos":""}],"GLABRATE":[{"def":"Becoming smooth or glabrous from age.","pos":""},{"def":"To make smooth, plain, or bare.","pos":""}],"GLABRITY":[{"def":"Smoothness; baldness.","pos":""}],"GLABROUS":[{"def":"Smooth; having a surface without hairs or any unevenness.","pos":""}],"GLACE":[{"def":"Coated with icing; iced; glazed; -- said of fruits, sweetmeats, cake, etc.","pos":""}],"GLACIAL":[{"def":"Resembling ice; having the appearance and consistency of ice; - - said of certain solid compounds; as, glacial phosphoric or acetic acids.","pos":""}],"GLACIALIST":[{"def":"One who attributes the phenomena of the drift, in geology, to glaciers.","pos":""}],"GLACIATE":[{"def":"To produce glacial effects upon, as in the scoring of rocks, transportation of loose material, etc.","pos":""}],"GLACIATION":[{"def":"Act of freezing.","pos":""},{"def":"That which is formed by freezing; ice.","pos":""}],"GLACIER":[{"def":"An immense field or stream of ice, formed in the region of perpetual snow, and moving slowly down a mountain slope or valley, as in the Alps, or over an extended area, as in Greenland.","pos":""}],"GLACIOUS":[{"def":"Pertaining to, consisting of or resembling, ice; icy.","pos":""}],"GLACIS":[{"def":"A gentle slope, or a smooth, gently sloping bank; especially (Fort.","pos":""}],"GLAD":[{"def":"Pleased; joyous; happy; cheerful; gratified; -- opposed to sorry, sorrowful, or unhappy; -- said of persons, and often followed by of, at, that, or by the infinitive, and sometimes by with, introducing the cause or reason.","pos":""},{"def":"Wearing a gay or bright appearance; expressing or exciting joy; producing gladness; exhilarating.","pos":""}],"GLADDEN":[{"def":"To make glad; to cheer; to please; to gratify; to rejoice; to exhilarate.","pos":""}],"GLADDER":[{"def":"One who makes glad.","pos":""}],"GLADE":[{"def":"An open passage through a wood; a grassy open or cleared space in a forest.","pos":""}],"GLADEN":[{"def":"Sword grass; any plant with sword-shaped leaves, esp.","pos":""}],"GLADEYE":[{"def":"The European yellow-hammer.","pos":""}],"GLADFUL":[{"def":"Full of gladness; joyful; glad.","pos":""}],"GLADIATE":[{"def":"Sword-shaped; resembling a sword in form, as the leaf of the iris, or of the gladiolus.","pos":""}],"GLADIATOR":[{"def":"Of or pertaining to gladiators, or to contests or combatants in general.","pos":""}],"GLADIATORISM":[{"def":"The art or practice of a gladiator.","pos":""}],"GLADIATORSHIP":[{"def":"Conduct, state, or art, of a gladiator.","pos":""}],"GLADIATURE":[{"def":"Swordplay; fencing; gladiatorial contest.","pos":""}],"GLADIOLE":[{"def":"A lilylike plant, of the genus Gladiolus; -- called also corn flag.","pos":""}],"GLADIOLUS":[{"def":"A genus of plants having bulbous roots and gladiate leaves, and including many species, some of which are cultivated and valued for the beauty of their flowers; the corn flag; the sword lily.","pos":""},{"def":"The middle portion of the sternum in some animals; the mesosternum.","pos":""}],"GLADIUS":[{"def":"The internal shell, or pen, of cephalopods like the squids.","pos":""}],"GLADLY":[{"def":"Preferably; by choice.","pos":""},{"def":"With pleasure; joyfully; cheerfully; eagerly.","pos":""}],"GLADNESS":[{"def":"State or quality of being glad; pleasure; joyful satisfaction; cheerfulness.","pos":""}],"GLADSHIP":[{"def":"A state of gladness.","pos":""}],"GLADSOME":[{"def":"Pleased; joyful; cheerful.","pos":""},{"def":"Causing joy, pleasure, or cheerfulness; having the appearance of gayety; pleasing.","pos":""}],"GLADSTONE":[{"def":"A four-wheeled pleasure carriage with two inside seats, calash top, and seats for driver and footman.","pos":""}],"GLAIR":[{"def":"The white of egg.","pos":""},{"def":"Any viscous, transparent substance, resembling the white of an egg.","pos":""}],"GLAIREOUS":[{"def":"Glairy; covered with glair.","pos":""}],"GLAIRIN":[{"def":"A glairy viscous substance, which forms on the surface of certain mineral waters, or covers the sides of their inclosures; -- called also baregin.","pos":""}],"GLAIRY":[{"def":"Like glair, or partaking of its qualities; covered with glair; viscous and transparent; slimy.","pos":""}],"GLAIVE":[{"def":"A weapon formerly used, consisting of a large blade fixed on the end of a pole, whose edge was on the outside curve; also, a light lance with a long sharp-pointed head.","pos":""},{"def":"A sword; -- used poetically and loosely.","pos":""}],"GLAMA":[{"def":"A copious gummy secretion of the humor of the eyelids, in consequence of some disorder; blearedness; lippitude.","pos":""}],"GLAMOUR":[{"def":"A charm affecting the eye, making objects appear different from what they really are.","pos":""},{"def":"Witchcraft; magic; a spell.","pos":""}],"GLANCE":[{"def":"A name given to some sulphides, mostly dark-colored, which have a brilliant metallic luster, as the sulphide of copper, called copper glance.","pos":""}],"GLANCING":[{"def":"Shooting, as light.","pos":""},{"def":"Flying off (after striking) in an oblique direction; as, a glancing shot.","pos":""}],"GLANCINGLY":[{"def":"In a glancing manner; transiently; incidentally; indirectly.","pos":""}],"GLAND":[{"def":"The movable part of a stuffing box by which the packing is compressed; -- sometimes called a follower.","pos":""},{"def":"The crosspiece of a bayonet clutch.","pos":""}],"GLANDAGE":[{"def":"A feeding on nuts or mast.","pos":""}],"GLANDERED":[{"def":"Affected with glanders; as, a glandered horse.","pos":""}],"GLANDEROUS":[{"def":"Of or pertaining to glanders; of the nature of glanders.","pos":""}],"GLANDERS":[{"def":"A highly contagious and very destructive disease of horses, asses, mules, etc.","pos":""}],"GLANDIFEROUS":[{"def":"Bearing acorns or other nuts; as, glandiferous trees.","pos":""}],"GLANDIFORM":[{"def":"Having the form of a gland or nut; resembling a gland.","pos":""}],"GLANDULAR":[{"def":"Containing or supporting glands; consisting of glands; pertaining to glands.","pos":""}],"GLANDULATION":[{"def":"The situation and structure of the secretory vessels in plants.","pos":""}],"GLANDULE":[{"def":"A small gland or secreting vessel.","pos":""}],"GLANDULIFEROUS":[{"def":"Bearing glandules.","pos":""}],"GLANDULOSE":[{"def":"Same as Glandulous.","pos":""}],"GLANDULOSITY":[{"def":"Quality of being glandulous; a collection of glands.","pos":""}],"GLANDULOUS":[{"def":"Containing glands; consisting of glands; pertaining to glands; resembling glands.","pos":""}],"GLANS":[{"def":"The vascular body which forms the apex of the penis, and the extremity of the clitoris.","pos":""},{"def":"The acorn or mast of the oak and similar fruits.","pos":""}],"GLARE":[{"def":"To shine with a bright, dazzling light.","pos":""},{"def":"To look with fierce, piercing eyes; to stare earnestly, angrily, or fiercely.","pos":""}],"GLAREOUS":[{"def":"A dazzling luster or brilliancy.","pos":""}],"GLARING":[{"def":"Clear; notorious; open and bold; barefaced; as, a glaring crime.","pos":""}],"GLARY":[{"def":"Of a dazzling luster; glaring; bright; shining; smooth.","pos":""}],"GLASS":[{"def":"Any substance having a peculiar glassy appearance, and a conchoidal fracture, and usually produced by fusion.","pos":""}],"GLASS-CRAB":[{"def":"The larval state (Phyllosoma) of the genus Palinurus and allied genera.","pos":""}],"GLASS-FACED":[{"def":"Mirror-faced; reflecting the sentiments of another.","pos":""}],"GLASS-GAZING":[{"def":"Given to viewing one's self in a glass or mirror; finical.","pos":""}],"GLASS-ROPE":[{"def":"A remarkable vitreous sponge, of the genus Hyalonema, first brought from Japan.","pos":""}],"GLASS-SNAIL":[{"def":"A small, transparent, land snail, of the genus Vitrina.","pos":""}],"GLASS-SNAKE":[{"def":"A long, footless lizard (Ophiosaurus ventralis), of the Southern United States; -- so called from its fragility, the tail easily breaking into small pieces.","pos":""}],"GLASS-SPONGE":[{"def":"A siliceous sponge, of the genus Hyalonema, and allied genera; -- so called from their glassy fibers or spicules; -- called also vitreous sponge.","pos":""}],"GLASSEN":[{"def":"And pursues the dice with glassen eyes.","pos":""}],"GLASSEYE":[{"def":"A fish of the great lakes; the wall-eyed pike.","pos":""},{"def":"A species of blindness in horses in which the eye is bright and the pupil dilated; a sort of amaurosis.","pos":""}],"GLASSFUL":[{"def":"The contents of a glass; as much of anything as a glass will hold.","pos":""}],"GLASSHOUSE":[{"def":"A house where glass is made; a commercial house that deals in glassware.","pos":""}],"GLASSILY":[{"def":"So as to resemble glass.","pos":""}],"GLASSINESS":[{"def":"The quality of being glassy.","pos":""}],"GLASSITE":[{"def":"A member of a Scottish sect, founded in the 18th century by John Glass, a minister of the Established Church of Scotland, who taught that justifying faith is \"no more than a simple assent to the divine testimone passively recived by the understanding.","pos":""},{"def":"One who makes, or manufactures, glass.","pos":""}],"GLASSWARE":[{"def":"Ware, or articles collectively, made of glass.","pos":""}],"GLASSWORK":[{"def":"Manufacture of glass; articles or ornamentation made of glass.","pos":""}],"GLASSWORT":[{"def":"A seashore plant of the Spinach family (Salicornia herbacea), with succulent jointed stems; also, a prickly plant of the same family (Salsola Kali), both formerly burned for the sake of the ashes, which yield soda for making glass and soap.","pos":""}],"GLASSY":[{"def":"Made of glass; vitreous; as, a glassy substance.","pos":""},{"def":"Resembling glass in its properties, as in smoothness, brittleness, or transparency; as, a glassy stream; a glassy surface; the glassy deep.","pos":""}],"GLASTONBURY THORN":[{"def":"A variety of the common hawthorn.","pos":""}],"GLASYNGE":[{"def":"Glazing or glass.","pos":""}],"GLAUBERITE":[{"def":"A mineral, consisting of the sulphates of soda and lime.","pos":""},{"def":"Sulphate of soda, a well-known cathartic.","pos":""}],"GLAUCESCENT":[{"def":"Having a somewhat glaucous appearance or nature; becoming glaucous.","pos":""}],"GLAUCIC":[{"def":"Of or pertaining to the Glaucium or horned poppy; -- formerly applied to an acid derived from it, now known to be fumaric acid.","pos":""}],"GLAUCINE":[{"def":"Glaucous or glaucescent.","pos":""}],"GLAUCODOT":[{"def":"A metallic mineral having a grayish tin-white color, and containing cobalt and iron, with sulphur and arsenic.","pos":""}],"GLAUCOMA":[{"def":"Dimness or abolition of sight, with a diminution of transparency, a bluish or greenish tinge of the refracting media of the eye, and a hard inelastic condition of the eyeball, with marked increase of tension within the eyeball.","pos":""}],"GLAUCOMATOUS":[{"def":"Having the nature of glaucoma.","pos":""}],"GLAUCOMETER":[{"def":"See Gleucometer.","pos":""}],"GLAUCONITE":[{"def":"The green mineral characteristic of the greensand of the chalk and other formations.","pos":""}],"GLAUCOPHANE":[{"def":"A mineral of a dark bluish color, related to amphibole.","pos":""}],"GLAUCOSIS":[{"def":"Same as Glaucoma.","pos":""}],"GLAUCOUS":[{"def":"Covered with a fine bloom or fine white powder easily rubbed off, as that on a blue plum, or on a cabbage leaf.","pos":""}],"GLAUCUS":[{"def":"A genus of nudibranchiate mollusks, found in the warmer latitudes, swimming in the open sea.","pos":""}],"GLAUM":[{"def":"To grope with the hands, as in the dark.","pos":""}],"GLAVER":[{"def":"To prate; to jabber; to babble.","pos":""},{"def":"To flatter; to wheedle.","pos":""}],"GLAZE":[{"def":"To apply thinly a transparent or semitransparent color to (another color), to modify the effect.","pos":""}],"GLAZEN":[{"def":"Resembling glass; glasslike; glazed.","pos":""}],"GLAZER":[{"def":"One who applies glazing, as in pottery manufacture, etc.","pos":""},{"def":"A tool or machine used in glazing, polishing, smoothing, etc.","pos":""}],"GLAZIER":[{"def":"One whose business is to set glass.","pos":""}],"GLAZING":[{"def":"Transparent, or semitransparent, colors passed thinly over other colors, to modify the effect.","pos":""}],"GLAZY":[{"def":"Having a glazed appearance; -- said of the fractured surface of some kinds of pin iron.","pos":""}]}