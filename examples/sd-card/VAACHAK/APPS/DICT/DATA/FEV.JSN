{"FEVER":[{"def":"A diseased state of the system, marked by increased heat, acceleration of the pulse, and a general derangement of the functions, including usually, thirst and loss of appetite.","pos":""}],"FEVERFEW":[{"def":"A perennial plant (Pyrethrum, or Chrysanthemum, Parthenium) allied to camomile, having finely divided leaves and white blossoms; -- so named from its supposed febrifugal qualities.","pos":""}],"FEVERISH":[{"def":"Having a fever; suffering from, or affected with, a moderate degree of fever; showing increased heat and thirst; as, the patient is feverish.","pos":""},{"def":"Indicating, or pertaining to, fever; characteristic of a fever; as, feverish symptoms.","pos":""}],"FEVEROUS":[{"def":"Affected with fever or ague; feverish.","pos":""},{"def":"Pertaining to, or having the nature of, fever; as, a feverous pulse.","pos":""}],"FEVERWORT":[{"def":"See Fever root, under Fever.","pos":""}]}