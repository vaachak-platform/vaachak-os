{"PRUCE":[{"def":"Prussian leather.","pos":""}],"PRUDE":[{"def":"A woman of affected modesty, reserve, or coyness; one who is overscrupulous or sensitive; one who affects extraordinary prudence in conduct and speech.","pos":""}],"PRUDENCE":[{"def":"The quality or state of being prudent; wisdom in the way of caution and provision; discretion; carefulness; hence, also, economy; frugality.","pos":""}],"PRUDENT":[{"def":"Sagacious in adapting means to ends; circumspect in action, or in determining any line of conduct; practically wise; judicious; careful; discreet; sensible; -- opposed to rash; as, a prudent man; dictated or directed by prudence or wise forethought; evincing prudence; as, prudent behavior.","pos":""},{"def":"Frugal; economical; not extravagant; as, a prudent woman; prudent expenditure of money.","pos":""}],"PRUDENTIAL":[{"def":"Proceeding from, or dictated or characterized by, prudence; prudent; discreet; sometimes, selfish or pecuniary as distinguished from higher motives or influences; as, prudential motives.","pos":""},{"def":"Exercising prudence; discretionary; advisory; superintending or executive; as, a prudential committee.","pos":""}],"PRUDENTIALIST":[{"def":"One who is governed by, or acts from, prudential motives.","pos":""}],"PRUDENTIALITY":[{"def":"The quality or state of being prudential.","pos":""}],"PRUDENTIALLY":[{"def":"In a prudential manner; prudently.","pos":""}],"PRUDENTLY":[{"def":"In a prudent manner.","pos":""}],"PRUDERY":[{"def":"The quality or state of being prudish; excessive or affected scrupulousness in speech or conduct; stiffness; coyness.","pos":""}],"PRUDHOMME":[{"def":"A trustworthy citizen; a skilled workman.","pos":""}],"PRUDISH":[{"def":"Like a prude; very formal, precise, or reserved; affectedly severe in virtue; as, a prudish woman; prudish manners.","pos":""}],"PRUDISHLY":[{"def":"In a prudish manner.","pos":""}],"PRUINATE":[{"def":"Same as Pruinose.","pos":""}],"PRUINOSE":[{"def":"Frosty; covered with fine scales, hairs, dust, bloom, or the like, so as to give the appearance of frost.","pos":""}],"PRUINOUS":[{"def":"Frosty; pruinose.","pos":""}],"PRUNE":[{"def":"To lop or cut off the superfluous parts, branches, or shoots of; to clear of useless material; to shape or smooth by trimming; to trim: as, to prune trees; to prune an essay.","pos":""},{"def":"To cut off or cut out, as useless parts.","pos":""}],"PRUNELLA":[{"def":"A smooth woolen stuff, generally black, used for making shoes; a kind of lasting; -- formerly used also for clergymen's gowns.","pos":""}],"PRUNELLE":[{"def":"A kind of small and very acid French plum; -- applied especially to the stoned and dried fruit.","pos":""}],"PRUNELLO":[{"def":"A species of dried plum; prunelle.","pos":""}],"PRUNER":[{"def":"Any one of several species of beetles whose larvæ gnaw the branches of trees so as to cause them to fall, especially the American oak pruner (Asemum moestum), whose larva eats the pith of oak branches, and when mature gnaws a circular furrow on the inside nearly to the bark.","pos":""}],"PRUNING":[{"def":"That which is cast off by bird in pruning her feathers; leavings.","pos":""}],"PRUNUS":[{"def":"A genus of trees with perigynous rosaceous flowers, and a single two-ovuled carpel which usually becomes a drupe in ripening.","pos":""},{"def":"The quality or state of being prurient.","pos":""}],"PRURIENT":[{"def":"Uneasy with desire; itching; especially, having a lascivious curiosity or propensity; lustful.","pos":""}],"PRURIGINOUS":[{"def":"Tending to, or caused by, prurigo; affected by, or of the nature of, prurigo.","pos":""}],"PRURIGO":[{"def":"A papular disease of the skin, of which intense itching is the chief symptom, the eruption scarcely differing from the healthy cuticle in color.","pos":""}],"PRUSSIAN":[{"def":"Of or pertaining to Prussia.","pos":""},{"def":"A native or inhabitant of Prussia.","pos":""}],"PRUSSIATE":[{"def":"A salt of prussic acid; a cyanide.","pos":""}],"PRUSSIC":[{"def":"designating the acid now called hydrocyanic acid, but formerly called prussic acid, because Prussian blue is derived from it or its compounds.","pos":""}],"PRUTENIC":[{"def":"Prussian; -- applied to certain astronomical tables published in the sixteenth century, founded on the principles of Copernicus, a Prussian.","pos":""}]}