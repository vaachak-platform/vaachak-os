{"LOLIGO":[{"def":"A genus of cephalopods, including numerous species of squids, common on the coasts of America and Europe.","pos":""}],"LOLL":[{"def":"To act lazily or indolently; to recline; to lean; to throw one's self down; to lie at ease.","pos":""},{"def":"To hand extended from the mouth, as the tongue of an ox or a log when heated with labor or exertion.","pos":""}],"LOLLARD":[{"def":"The doctrines or principles of the Lollards.","pos":""}],"LOLLER":[{"def":"An idle vagabond.","pos":""}],"LOLLINGLY":[{"def":"In a lolling manner.","pos":""}],"LOLLIPOP":[{"def":"A kind of sugar confection which dissolves easily in the mouth.","pos":""}],"LOLLOP":[{"def":"To move heavily; to lounge or idle; to loll.","pos":""}]}