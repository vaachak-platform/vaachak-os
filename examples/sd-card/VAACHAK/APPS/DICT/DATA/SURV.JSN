{"SURVEILLANCE":[{"def":"Oversight; watch; inspection; supervision.","pos":""}],"SURVEILLANT":[{"def":"One who watches over another; an overseer; a spy; a supervisor.","pos":""}],"SURVENE":[{"def":"To supervene upon; to come as an addition to.","pos":""}],"SURVENUE":[{"def":"A sudden or unexpected coming or stepping on.","pos":""}],"SURVEY":[{"def":"To inspect, or take a view of; to view with attention, as from a high place; to overlook; as, to stand on a hill, and survey the surrounding country.","pos":""},{"def":"To view with a scrutinizing eye; to examine.","pos":""}],"SURVEYANCE":[{"def":"Survey; inspection.","pos":""}],"SURVEYING":[{"def":"That branch of applied mathematics which teaches the art of determining the area of any portion of the earth's surface, the length and directions of the bounding lines, the contour of the surface, etc.","pos":""}],"SURVEYOR":[{"def":"One placed to superintend others; an overseer; an inspector.","pos":""},{"def":"One who views and examines for the purpose of ascertaining the condition, quantity, or quality of anything; as, a surveyor of highways, ordnance, etc.","pos":""}],"SURVEYORSHIP":[{"def":"The office of a surveyor.","pos":""}],"SURVIEW":[{"def":"To survey; to make a survey of.","pos":""}],"SURVISE":[{"def":"To look over; to supervise.","pos":""}],"SURVIVAL":[{"def":"Any habit, usage, or belief, remaining from ancient times, the origin of which is often unknown, or imperfectly known.","pos":""}],"SURVIVE":[{"def":"To live beyond the life or existence of; to live longer than; to outlive; to outlast; as, to survive a person or an event.","pos":""}],"SURVIVER":[{"def":"One who survives; a survivor.","pos":""}],"SURVIVING":[{"def":"Remaining alive; yet living or existing; as, surviving friends; surviving customs.","pos":""}],"SURVIVOR":[{"def":"The longer liver of two joint tenants, or two persons having a joint interest in anything.","pos":""}],"SURVIVORSHIP":[{"def":"The right of a joint tenant, or other person who has a joint interest in an estate, to take the whole estate upon the death of other.","pos":""}]}