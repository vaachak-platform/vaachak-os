{"WOAD":[{"def":"An herbaceous cruciferous plant (Isatis tinctoria).","pos":""}],"WOAD-WAXEN":[{"def":"A leguminous plant (Genista tinctoria) of Europe and Russian Asia, and adventitious in America; -- called also greenwood, greenweed, dyer's greenweed, and whin, wood-wash, wood-wax, and wood- waxen.","pos":""}],"WOADED":[{"def":"Colored or stained with woad.","pos":""}]}