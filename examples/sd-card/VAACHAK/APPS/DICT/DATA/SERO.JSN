{"SEROLIN":[{"def":"SERON; SEROON Se*ron\", Se*roon\", n.","pos":""}],"SEROSITY":[{"def":"A thin watery animal fluid, as synovial fluid and pericardial fluid.","pos":""}],"SEROTINE":[{"def":"The European long-eared bat (Vesperugo serotinus).","pos":""}],"SEROTINOUS":[{"def":"Appearing or blossoming later in the season than is customary with allied species.","pos":""}],"SEROUS":[{"def":"SEROW; SURROW Ser\"ow, Sur\"row, n.","pos":""}]}