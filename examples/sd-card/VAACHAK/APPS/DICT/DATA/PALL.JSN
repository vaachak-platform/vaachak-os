{"PALL":[{"def":"Same as Pallium.","pos":""},{"def":"A figure resembling the Roman Catholic pallium, or pall, and having the form of the letter Y.","pos":""}],"PALL-MALL":[{"def":"A game formerly common in England, in which a wooden ball was driven with a mallet through an elevated hoop or ring of iron.","pos":""}],"PALLA":[{"def":"An oblong rectangular piece of cloth, worn by Roman ladies, and fastened with brooches.","pos":""}],"PALLADIAN":[{"def":"Of, pertaining to, or designating, a variety of the revived classic style of architecture, founded on the works of Andrea Palladio, an Italian architect of the 16th century.","pos":""}],"PALLADIC":[{"def":"Of, pertaining to, or derived from, palladium; -- used specifically to designate those compounds in which the element has a higher valence as contrasted with palladious compounds.","pos":""}],"PALLADIOUS":[{"def":"Of, pertaining to, or containing, palladium; -- used specifically to designate those compounds in which palladium has a lower valence as compared with palladic compounds.","pos":""}],"PALLADIUM":[{"def":"Any statue of the goddess Pallas; esp.","pos":""}],"PALLADIUMIZE":[{"def":"To cover or coat with palladium.","pos":""}],"PALLAH":[{"def":"A large South African antelope (Æpyceros melampus).","pos":""}],"PALLAS":[{"def":"Pallas Athene, the Grecian goddess of wisdom, called also Athene, and identified, at a later period, with the Roman Minerva.","pos":""}],"PALLBEARER":[{"def":"One of those who attend the coffin at a funeral; -- so called from the pall being formerly carried by them.","pos":""}],"PALLET":[{"def":"A small and mean bed; a bed of straw.","pos":""}],"PALLIAL":[{"def":"Of or pretaining to a mantle, especially to the mantle of mollusks; produced by the mantle; as, the pallial line, or impression, which marks the attachment of the mantle on the inner surface of a bivalve shell.","pos":""}],"PALLIAMENT":[{"def":"A dress; a robe.","pos":""}],"PALLIARD":[{"def":"A born beggar; a vagabond.","pos":""},{"def":"A lecher; a lewd person.","pos":""}],"PALLIATE":[{"def":"Covered with a mant [Obs.","pos":""},{"def":"Eased; mitigated; alleviated.","pos":""}],"PALLIATION":[{"def":"The act of palliating, or state of being palliated; extenuation; excuse; as, the palliation of faults, offenses, vices.","pos":""},{"def":"Mitigation; alleviation, as of a disease.","pos":""}],"PALLIATIVE":[{"def":"Serving to palliate; serving to extenuate or mitigate.","pos":""}],"PALLIATORY":[{"def":"Palliative; extenuating.","pos":""}],"PALLID":[{"def":"Deficient in color; pale; wan; as, a pallid countenance; pallid blue.","pos":""}],"PALLIDITY":[{"def":"Pallidness; paleness.","pos":""}],"PALLIDLY":[{"def":"In a pallid manner.","pos":""}],"PALLIDNESS":[{"def":"The quality or state of being pallid; paleness; pallor; wanness.","pos":""}],"PALLIOBRANCHIATA":[{"def":"Same as Brachiopoda.","pos":""}],"PALLIOBRANCHIATE":[{"def":"Having the pallium, or mantle, acting as a gill, as in brachiopods.","pos":""}],"PALLIUM":[{"def":"A large, square, woolen cloak which enveloped the whole person, worn by the Greeks and by certain Romans.","pos":""},{"def":"A band of white wool, worn on the shoulders, with four purple crosses worked on it; a pall.","pos":""}],"PALLONE":[{"def":"An Italian game, played with a large leather ball.","pos":""}],"PALLOR":[{"def":"Paleness; want of color; pallidity; as, pallor of the complexion.","pos":""}]}