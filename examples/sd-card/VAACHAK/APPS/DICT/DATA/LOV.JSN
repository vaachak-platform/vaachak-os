{"LOVABLE":[{"def":"Having qualities that excite, or are fitted to excite, love; worthy of love.","pos":""}],"LOVAGE":[{"def":"An umbelliferous plant (Levisticum officinale), sometimes used in medicine as an aromatic stimulant.","pos":""}],"LOVE":[{"def":"A climbing species of Clematis (C.","pos":""}],"LOVE-SICK":[{"def":"Languishing with love or amorous desire; as, a love-sick maid.","pos":""},{"def":"Originating in, or expressive of, languishing love.","pos":""}],"LOVE-SICKNESS":[{"def":"The state of being love-sick.","pos":""}],"LOVEE":[{"def":"One who is loved.","pos":""}],"LOVELESS":[{"def":"Void of love; void of tenderness or kindness.","pos":""},{"def":"Not attracting love; unattractive.","pos":""}],"LOVELILY":[{"def":"In manner to excite love; amiably.","pos":""}],"LOVELINESS":[{"def":"The state or quality of being lovely.","pos":""}],"LOVELOCK":[{"def":"A long lock of hair hanging prominently by itself; an earlock; -- worn by men of fashion in the reigns of Elizabeth and James I.","pos":""}],"LOVELORN":[{"def":"Forsaken by one's love.","pos":""}],"LOVELY":[{"def":"Having such an appearance as excites, or is fitted to excite, love; beautiful; charming; very pleasing in form, looks, tone, or manner.","pos":""},{"def":"Lovable; amiable; having qualities of any kind which excite, or are fitted to excite, love or friendship.","pos":""}],"LOVEMONGER":[{"def":"One who deals in affairs of love.","pos":""}],"LOVER":[{"def":"One who loves; one who is in love; -- usually limited, in the singular, to a person of the male sex.","pos":""},{"def":"A friend; one strongly attached to another; one who greatly desires the welfare of any person or thing; as, a lover of his country.","pos":""}],"LOVERWISE":[{"def":"As they sat down here loverwise.","pos":""}],"LOVING":[{"def":"Expressing love or kindness; as, loving words.","pos":""}],"LOVING CUP":[{"def":"A large ornamental drinking vessel having two or more handles, intended to pass from hand to hand, as at a banquet.","pos":""}],"LOVING-KINDNESS":[{"def":"Tender regard; mercy; favor.","pos":""}],"LOVINGLY":[{"def":"With love; affectionately.","pos":""}],"LOVINGNESS":[{"def":"Affection; kind regard.","pos":""}]}