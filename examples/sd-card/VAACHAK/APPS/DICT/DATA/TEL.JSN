{"TEL-EL-AMARNA":[{"def":"A station on the Nile, midway between Thebes and Memphis, forming the site of the capital of Amenophis IV.","pos":""}],"TELAMONES":[{"def":"Same as Atlantes.","pos":""}],"TELANGIECTASIS":[{"def":"Dilatation of the capillary vessels.","pos":""}],"TELANGIECTASY":[{"def":"Tel*an`gi*ec\"ta*sy, n.","pos":""}],"TELARLY":[{"def":"In a weblike manner.","pos":""}],"TELARY":[{"def":"Of or pertaining to a web; hence, spinning webs; retiary.","pos":""}],"TELAUTOGRAM":[{"def":"A message transmitted and recorded by a teleautograph.","pos":""}],"TELAUTOGRAPH":[{"def":"A facsimile telegraph for reproducing writing, pictures, maps, etc.","pos":""}],"TELE-ICONOGRAPH":[{"def":"An instrument essentially the same as the telemetrograph.","pos":""},{"def":"A form of facsimile telegraph.","pos":""}],"TELECHIROGRAPH":[{"def":"An instrument for telegraphically transmitting and receiving handwritten messages, as photographically by a beam of light from a mirror.","pos":""}],"TELEDU":[{"def":"An East Indian carnivore (Mydaus meliceps) allied to the badger, and noted for the very offensive odor that it emits, somewhat resembling that of a skunk.","pos":""}],"TELEGA":[{"def":"A rude four-wheeled, springless wagon, used among the Russians.","pos":""}],"TELEGONY":[{"def":"The supposed influence of a father upon offspring subsequent to his own, begotten of the same mother by another father.","pos":""}],"TELEGRAM":[{"def":"A message sent by telegraph; a telegraphic dispatch.","pos":""}],"TELEGRAMMIC":[{"def":"Pertaining to, or resembling, a telegram; laconic; concise; brief.","pos":""}],"TELEGRAPH":[{"def":"An apparatus, or a process, for communicating intelligence rapidly between distant points, especially by means of preconcerted visible or audible signals representing words or ideas, or by means of words and signs, transmitted by electrical action.","pos":""}],"TELEGRAPH PLANT":[{"def":"An East Indian tick trefoil (Meibomia gyrans), whose lateral leaflets jerk up and down like the arms of a semaphore, and also rotate on their axes.","pos":""}],"TELEGRAPHER":[{"def":"One who sends telegraphic messages; a telegraphic operator; a telegraphist.","pos":""}],"TELEGRAPHIC":[{"def":"Of or pertaining to the telegraph; made or communicated by a telegraph; as, telegraphic signals; telegraphic art; telegraphic intelligence.","pos":""}],"TELEGRAPHIST":[{"def":"One skilled in telegraphy; a telegrapher.","pos":""}],"TELEGRAPHONE":[{"def":"An instrument for recording and reproducing sound by local magnetization of a steel wire, disk, or ribbon, moved against the pole of a magnet connected electrically with a telephone receiver, or the like.","pos":""}],"TELEGRAPHOSCOPE":[{"def":"An instrument for telegraphically transmitting a picture and reproducing its image as a positive or negative.","pos":""}],"TELEGRAPHY":[{"def":"The science or art of constructing, or of communicating by means of, telegraphs; as, submarine telegraphy.","pos":""}],"TELEHYDROBAROMETER":[{"def":"An instrument for indicating the level of water in a distant tank or reservior.","pos":""}],"TELELECTRIC":[{"def":"Of or pertaining to transmission, as of music, to a distance by electricity.","pos":""}],"TELELECTROSCOPE":[{"def":"Any apparatus for making distant objects visible by the aid of electric transmission.","pos":""}],"TELEMECHANIC":[{"def":"Designating, or pert.","pos":""}],"TELEMETEOROGRAPH":[{"def":"Any apparatus recording meteorological phenomena at a distance from the measuring apparatus, as by electricity or by compressed air; esp.","pos":""}],"TELEMETER":[{"def":"An instrument used for measuring the distance of an object from an observer; as, a telescope with a micrometer for measuring the apparent diameter of an object whose real dimensions are known.","pos":""}],"TELEMETROGRAPH":[{"def":"A combination of the camera lucida and telescope for drawing and measuring distant objects.","pos":""}],"TELEMOTOR":[{"def":"A hydraulic device by which the movement of the wheel on the bridge operates the steering gear at the stern.","pos":""}],"TELENERGY":[{"def":"Display of force or energy at a distance, or without contact; - - applied to mediumistic phenomena.","pos":""}],"TELENGISCOPE":[{"def":"An instrument of such focal length that it may be used as an observing telescope for objects close at hand or as a long-focused microscope.","pos":""}],"TELEOCEPHIAL":[{"def":"An extensive order of bony fishes including most of the common market species, as bass, salmon, cod, perch, etc.","pos":""}],"TELEOLOGICAL":[{"def":"Of or pertaining to teleology, or the doctrine of design.","pos":""}],"TELEOLOGIST":[{"def":"One versed in teleology.","pos":""}],"TELEOLOGY":[{"def":"The doctrine of the final causes of things; specif.","pos":""},{"def":"the doctrine of design, which assumes that the phenomena of organic life, particularly those of evolution, are explicable only by purposive causes, and that they in no way admit of a mechanical explanation or one based entirely on biological science; the doctrine of adaptation to purpose.","pos":""}],"TELEOPHORE":[{"def":"Same as Gonotheca.","pos":""}],"TELEORGANIC":[{"def":"Vital; as, teleorganic functions.","pos":""}],"TELEOSAUR":[{"def":"Any one of several species of fossil suarians belonging to Teleosaurus and allied genera.","pos":""}],"TELEOSAURUS":[{"def":"A genus of extinct crocodilian reptiles of the Jurassic period, having a long and slender snout.","pos":""}],"TELEOST":[{"def":"One of the Teleosti.","pos":""}],"TELEOSTEAN":[{"def":"Of or pertaining to the teleosts.","pos":""},{"def":"A teleostean fish.","pos":""}],"TELEOSTEI":[{"def":"A subclass of fishes including all the ordinary bony fishes as distinguished from the ganoids.","pos":""}],"TELEOSTOMI":[{"def":"An extensive division of fishes including the ordinary fishes (Teleostei) and the ganoids.","pos":""}],"TELEOZOIC":[{"def":"Having tissued composed of cells.","pos":""}],"TELEPATHY":[{"def":"The sympathetic affection of one mind by the thoughts, feelings, or emotions of another at a distance, without communication through the ordinary channels of sensation.","pos":""}],"TELEPHEME":[{"def":"A message by a telephone.","pos":""}],"TELEPHONE":[{"def":"An instrument for reproducing sounds, especially articulate speech, at a distance.","pos":""}],"TELEPHONE EXCHANGE":[{"def":"A central office in which the wires of telephones may be connected to permit conversation.","pos":""}],"TELEPHONIC":[{"def":"Conveying sound to a great distance.","pos":""},{"def":"Of or pertaining to the telephone; by the telephone.","pos":""}],"TELEPHONICALLY":[{"def":"By telephonic means or processes; by the use of the telephone.","pos":""}],"TELEPHONY":[{"def":"The art or process of reproducing sounds at a distance, as with the telephone.","pos":""}],"TELEPHOTE":[{"def":"A telelectric apparatus for producing images of visible objects at a distance.","pos":""}],"TELEPHOTO":[{"def":"Telephotographic; specif.","pos":""}],"TELEPHOTOGRAPH":[{"def":"A photograph, image, or impression, reproduced by or taken with a telephotographic apparatus.","pos":""}],"TELEPHOTOGRAPHIC":[{"def":"Designating, or pertaining to, the process of telephotography.","pos":""}],"TELEPHOTOGRAPHY":[{"def":"The photography of distant objects in more enlarged form than is possible by the ordinary means, usually by a camera provided with a telephoto lens or mounted in place of the eyepiece of a telescope, so that the real or a magnified image falls on the sensitive plate.","pos":""},{"def":"Art or process of electrically transmitting and reproducing photographic or other pictures at a distance by methods similar to those used in electric telegraphy.","pos":""}],"TELEPOLARISCOPE":[{"def":"A polariscope arranged to be attached to a telescope.","pos":""}],"TELERYTHIN":[{"def":"A red crystalline compound related to, or produced from, erythrin.","pos":""}],"TELESCOPE":[{"def":"An optical instrument used in viewing distant objects, as the heavenly bodies.","pos":""}],"TELESCOPE BAG":[{"def":"An adjustable traveling bag consisting of two cases, the larger slipping over the other.","pos":""}],"TELESCOPIC SIGHT":[{"def":"A sight consisting of a small telescope, as on a compass or rifle.","pos":""}],"TELESCOPICALLY":[{"def":"In a telescopical manner; by or with the telescope.","pos":""}],"TELESCOPIST":[{"def":"One who uses a telescope.","pos":""}],"TELESCOPY":[{"def":"The art or practice of using or making telescopes.","pos":""}],"TELESEISM":[{"def":"A seismic movement or shock far from the recording instrument.","pos":""}],"TELESEME":[{"def":"A system of apparatus for electric signals providing for automatic transmission of a definite number of different signals or calls, as in connection with hotel annunciators.","pos":""}],"TELESM":[{"def":"A kind of amulet or magical charm.","pos":""},{"def":"Of or pertaining to telesms; magical.","pos":""}],"TELESPECTROSCOPE":[{"def":"A spectroscope arranged to be attached to a telescope for observation of distant objects, as the sun or stars.","pos":""}],"TELESTEREOGRAPH":[{"def":"An instrument for telegraphically reproducing a photograph.","pos":""}],"TELESTEREOSCOPE":[{"def":"A stereoscope adapted to view distant natural objects or landscapes; a telescopic stereoscope.","pos":""}],"TELESTIC":[{"def":"Tending or relating to a purpose or an end.","pos":""}],"TELESTICH":[{"def":"A poem in which the final letters of the lines, taken consequently, make a name.","pos":""}],"TELETHERMOGRAPH":[{"def":"Tel`e*ther\"mo*graph, n.","pos":""}],"TELETHERMOMETER":[{"def":"An apparatus for determining the temperature of a distant point, as by a thermoelectric circuit or otherwise.","pos":""}],"TELEUTOSPORE":[{"def":"The thick-celled winter or resting spore of the rusts (order Uredinales), produced in late summer.","pos":""}],"TELFORD":[{"def":"Designating, or pert.","pos":""}],"TELFORDIZE":[{"def":"To furnish (a road) with a telford pavement.","pos":""}],"TELHARMONIC":[{"def":"Of or pertaining to telharmonium.","pos":""},{"def":"An instrument for producing music (Tel*har\"mo*ny []), at a distant point or points by means of alternating currents of electricity controlled by an operator who plays on a keyboard.","pos":""}],"TELIC":[{"def":"Denoting the final end or purpose, as distinguished from ecbatic.","pos":""}],"TELL":[{"def":"To mention one by one, or piece by piece; to recount; to enumerate; to reckon; to number; to count; as, to tell money.","pos":""},{"def":"To utter or recite in detail; to give an account of; to narrate.","pos":""}],"TELLABLE":[{"def":"Capable of being told.","pos":""}],"TELLEN":[{"def":"Any species of Tellina.","pos":""}],"TELLER":[{"def":"One who tells, relates, or communicates; an informer, narrator, or describer.","pos":""},{"def":"One of four officers of the English Exchequer, formerly appointed to receive moneys due to the king and to pay moneys payable by the king.","pos":""}],"TELLERSHIP":[{"def":"The office or employment of a teller.","pos":""}],"TELLINA":[{"def":"A genus of marine bivalve mollusks having thin, delicate, and often handsomely colored shells.","pos":""}],"TELLING":[{"def":"Operating with great effect; effective; as, a telling speech.","pos":""}],"TELLTALE":[{"def":"Telling tales; babbling.","pos":""}],"TELLURAL":[{"def":"Of or pertaining to the earth.","pos":""}],"TELLURATE":[{"def":"A salt of telluric acid.","pos":""}],"TELLURETED":[{"def":"Combined or impregnated with tellurium; tellurized.","pos":""}],"TELLURHYDRIC":[{"def":"Of, pertaining to, or designating, hydrogen telluride, which is regarded as an acid, especially when in solution.","pos":""}],"TELLURIAN":[{"def":"Of or pertaining to the earth.","pos":""}],"TELLURIC":[{"def":"Of or pertaining to tellurium; derived from, or resembling, tellurium; specifically, designating those compounds in which the element has a higher valence as contrasted with tellurous compounds; as, telluric acid, which is analogous to sulphuric acid.","pos":""}],"TELLURIDE":[{"def":"A compound of tellurium with a more positive element or radical; -- formerly called telluret.","pos":""}],"TELLURISM":[{"def":"An hypothesis of animal magnetism propounded by Dr.","pos":""}],"TELLURITE":[{"def":"A salt of tellurous acid.","pos":""},{"def":"Oxide of tellurium.","pos":""}],"TELLURIUM":[{"def":"A rare nonmetallic element, analogous to sulphur and selenium, occasionally found native as a substance of a silver-white metallic luster, but usually combined with metals, as with gold and silver in the mineral sylvanite, with mercury in Coloradoite, etc.","pos":""}],"TELLURIZE":[{"def":"To impregnate with, or to subject to the action of, tellurium; -- chiefly used adjectively in the past participle; as, tellurized ores.","pos":""}],"TELLUROUS":[{"def":"Of or pertaining to tellurium; derived from, or containing, tellurium; specifically, designating those compounds in which the element has a lower valence as contrasted with telluric compounds; as, tellurous acid, which is analogous to sulphurous acid.","pos":""}],"TELODYNAMIC":[{"def":"Relating to a system for transmitting power to a distance by means of swiftly moving ropes or cables driving grooved pulleys of large diameter.","pos":""}],"TELOTROCHA":[{"def":"An annelid larva having telotrochal bands of cilia.","pos":""},{"def":"Having both a preoral and a posterior band of cilla; -- applied to the larvæ of certain annelids.","pos":""}],"TELOTYPE":[{"def":"An electric telegraph which prints the messages in letters and not in signs.","pos":""}],"TELPHER":[{"def":"A contrivance for the conveyance of vehicles or loads by means of electricity.","pos":""}],"TELPHERAGE":[{"def":"The conveyance of vehicles or loads by means of electricity.","pos":""}],"TELSON":[{"def":"The terminal joint or movable piece at the end of the abdomen of Crustacea and other articulates.","pos":""}],"TELUGU":[{"def":"A Darvidian language spoken in the northern parts of the Madras presidency.","pos":""},{"def":"One of the people speaking the Telugu language.","pos":""}]}