{"MOE":[{"def":"A wry face or mouth; a mow.","pos":""}],"MOEBLES":[{"def":"Movables; furniture; -- also used in the singular (moeble).","pos":""}],"MOELLINE":[{"def":"An unguent for the hair.","pos":""}],"MOESOGOTHIC":[{"def":"Belonging to the Moesogoths, a branch of the Goths who settled in Moesia.","pos":""}]}