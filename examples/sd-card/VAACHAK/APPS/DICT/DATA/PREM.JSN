{"PREMATURE":[{"def":"Mature or ripe before the proper time; as, the premature fruits of a hotbed.","pos":""},{"def":"Happening, arriving, existing, or performed before the proper or usual time; adopted too soon; too early; untimely; as, a premature fall of snow; a premature birth; a premature opinion; premature decay.","pos":""}],"PREMATURITY":[{"def":"The quality or state of being premature; early, or untimely, ripeness; as, the prematurity of genius.","pos":""}],"PREMAXILLA":[{"def":"A bone on either side of the middle line between the nose and mouth, forming the anterior part of each half of the upper jawbone; the intermaxilla.","pos":""}],"PREMAXILLARY":[{"def":"Situated in front of the maxillary bones; pertaining to the premaxillæ; intermaxillary.","pos":""}],"PREMEDITATE":[{"def":"To think on, and revolve in the mind, beforehand; to contrive and design previously; as, to premeditate robbery.","pos":""}],"PREMEDITATELY":[{"def":"With premeditation.","pos":""}],"PREMEDITATION":[{"def":"The act of meditating or contriving beforehand; previous deliberation; forethought.","pos":""}],"PREMERIT":[{"def":"To merit or deserve beforehand.","pos":""},{"def":"Serving to reward; rewarding.","pos":""}],"PREMIER":[{"def":"First; chief; principal; as, the premier place; premier minister.","pos":""},{"def":"Most ancient; -- said of the peer bearing the oldest title of his degree.","pos":""}],"PREMIERE":[{"def":"First; chief; as, a première danseuse.","pos":""}],"PREMIERSHIP":[{"def":"The office of the premier.","pos":""}],"PREMILLENNIAL":[{"def":", Previous to the millennium.","pos":""}],"PREMISE":[{"def":"Either of the first two propositions of a syllogism, from which the conclusion is drawn.","pos":""},{"def":"Matters previously stated or set forth; esp.","pos":""}],"PREMIUM":[{"def":"A reward or recompense; a prize to be won by being before another, or others, in a competition; reward or prize to be adjudged; a bounty; as, a premium for good behavior or scholarship, for discoveries, etc.","pos":""},{"def":"Something offered or given for the loan of money; bonus; -- sometimes synonymous with interest, but generally signifying a sum in addition to the capital.","pos":""}],"PREMOLAR":[{"def":"Situated in front of the molar teeth.","pos":""},{"def":"An anterior molar tooth which has replaced a deciduous molar.","pos":""}],"PREMONISH":[{"def":"To forewarn; to admonish beforehand.","pos":""}],"PREMONISHMENT":[{"def":"Previous warning or admonition; forewarning.","pos":""}],"PREMONITION":[{"def":"Previous warning, notice, or information; forewarning; as, a premonition of danger.","pos":""}],"PREMONITOR":[{"def":"One who, or that which, gives premonition.","pos":""}],"PREMONITORY":[{"def":"Giving previous warning or notice; as, premonitory symptoms of disease.","pos":""}],"PREMONSTRANT":[{"def":"A Premonstratensian.","pos":""}],"PREMONSTRATE":[{"def":"To show beforehand; to foreshow.","pos":""}],"PREMONSTRATENSIAN":[{"def":"One of a religious order of regular canons founded by St.","pos":""}],"PREMONSTRATION":[{"def":"A showing beforehand; foreshowing.","pos":""}],"PREMONSTRATOR":[{"def":"One who, or that which, premonstrates.","pos":""}],"PREMORSE":[{"def":"Terminated abruptly, or as it bitten off.","pos":""}],"PREMOSAIC":[{"def":"Relating to the time before Moses; as, premosaic history.","pos":""}],"PREMOTION":[{"def":"Previous motion or excitement to action.","pos":""}],"PREMUNITE":[{"def":"To fortify beforehand; to guard against objection.","pos":""}],"PREMUNITION":[{"def":"The act of fortifying or guarding against objections.","pos":""}],"PREMUNITORY":[{"def":"Of or pertaining to a premunire; as, a premunitory process.","pos":""}]}