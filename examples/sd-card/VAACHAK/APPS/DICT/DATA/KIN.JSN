{"KIN":[{"def":"A diminutive suffix; as, manikin; lambkin.","pos":""}],"KINAESTHESIS":[{"def":"The perception attendant upon the movements of the muscles.","pos":""},{"def":"Of, pertaining to, or involving, kinæsthesis.","pos":""}],"KINCOB":[{"def":"India silk brocaded with flowers in silver or gold.","pos":""},{"def":"Of the nature of kincob; brocaded.","pos":""}],"KIND":[{"def":"Characteristic of the species; belonging to one's nature; natural; native.","pos":""},{"def":"Having feelings befitting our common nature; congenial; sympathetic; as, a kind man; a kind heart.","pos":""}],"KIND-HEARTED":[{"def":"Having kindness of nature; sympathetic; characterized by a humane disposition; as, a kind-hearted landlord.","pos":""}],"KIND-HEARTEDNESS":[{"def":"The state or quality of being kind-hearted; benevolence.","pos":""}],"KINDERGARTNER":[{"def":"One who teaches in a kindergarten.","pos":""}],"KINDLE":[{"def":"To bring forth young.","pos":""}],"KINDLER":[{"def":"One who, or that which, kindles, stirs up, or sets on fire.","pos":""}],"KINDLESS":[{"def":"Destitute of kindness; unnatural.","pos":""}],"KINDLINESS":[{"def":"Natural inclination; natural course.","pos":""},{"def":"The quality or state of being kindly; benignity; benevolence; gentleness; tenderness; as, kindliness of disposition, of treatment, or of words.","pos":""}],"KINDLING":[{"def":"Materials, easily lighted, for starting a fire.","pos":""}],"KINDLY":[{"def":"According to the kind or nature; natural.","pos":""},{"def":"Humane; congenial; sympathetic; hence, disposed to do good to; benevolent; gracious; kind; helpful; as, kindly affections, words, acts, etc.","pos":""}],"KINDNESS":[{"def":"The state or quality of being kind, in any of its various senses; manifestation of kind feeling or disposition beneficence.","pos":""},{"def":"A kind act; an act of good will; as, to do a great kindness.","pos":""}],"KINDRED":[{"def":"Relationship by birth or marriage; consanguinity; affinity; kin.","pos":""},{"def":"Relatives by blood or marriage, more properly the former; relations; persons related to each other.","pos":""}],"KINE":[{"def":"Of or pertaining to kinematics.","pos":""}],"KINEMATICS":[{"def":"The science which treats of motions considered in themselves, or apart from their causes; the comparison and relation of motions.","pos":""}],"KINEPOX":[{"def":"See Kinetoscope.","pos":""}],"KINESIATRICS":[{"def":"A mode of treating disease by appropriate muscular movements; - - also termed kinesitherapy, kinesipathy, lingism, and the movement cure.","pos":""}],"KINESIPATHY":[{"def":"See Kinesiatrics.","pos":""}],"KINESITHERAPY":[{"def":"See Kinesiatrics.","pos":""}],"KINESODIC":[{"def":"Conveying motion; as; kinesodic substance; -- applied esp.","pos":""}],"KINETIC":[{"def":"Moving or causing motion; motory; active, as opposed to latent.","pos":""}],"KINETOGENESIS":[{"def":"An instrument for producing curves by the combination of circular movements; -- called also kinescope.","pos":""}],"KINETOPHONE":[{"def":"A machine combining a kinetoscope and a phonograph synchronized so as to reproduce a scene and its accompanying sounds.","pos":""}],"KINETOSCOPE":[{"def":"A machine, for the production of animated pictures, in which a film carrying successive instantaneous views of a moving scene travels uniformly through the field of a magnifying glass.","pos":""}],"KING":[{"def":"A Chinese musical instrument, consisting of resonant stones or metal plates, arranged according to their tones in a frame of wood, and struck with a hammer.","pos":""}],"KING CHARLES SPANIEL":[{"def":"A variety of small pet dogs, having, drooping ears, a high, dome-shaped forehead, pug nose, large, prominent eyes, and long, wavy hair.","pos":""}],"KING'S BENCH":[{"def":"Formerly, the highest court of common law in England; -- so called because the king used to sit there in person.","pos":""}],"KING-POST":[{"def":"A member of a common form of truss, as a roof truss.","pos":""}],"KINGBIRD":[{"def":"A small American bird (Tyrannus, or T.","pos":""}],"KINGBOLT":[{"def":"A vertical iron bolt, by which the forward axle and wheels of a vehicle or the trucks of a railroad car are connected with the other parts.","pos":""}],"KINGCRAFT":[{"def":"The craft of kings; the art of governing as a sovereign; royal policy.","pos":""}],"KINGCUP":[{"def":"The common buttercup.","pos":""}],"KINGDOM":[{"def":"The rank, quality, state, or attributes of a king; royal authority; sovereign power; rule; dominion; monarchy.","pos":""},{"def":"The territory or country subject to a king or queen; the dominion of a monarch; the sphere in which one is king or has control.","pos":""}],"KINGDOMED":[{"def":"Having a kingdom or the dignity of a king; like a kingdom.","pos":""}],"KINGFISHER":[{"def":"Any one of numerous species of birds constituting the family Alcedinidæ.","pos":""}],"KINGHOOD":[{"def":"The state of being a king; the attributes of a king; kingship.","pos":""}],"KINGLET":[{"def":"Any one of several species of small singing birds of the genus Regulus and family Sylviidæ.","pos":""}],"KINGLINESS":[{"def":"The state or quality of being kingly.","pos":""}],"KINGLING":[{"def":"Same as Kinglet, 1.","pos":""}],"KINGLY":[{"def":"Belonging to, suitable to, or becoming, a king; characteristic of, resembling, a king; directed or administered by a king; monarchical; royal; sovereign; regal; august; noble; grand.","pos":""}],"KINGSHIP":[{"def":"The state, office, or dignity of a king; royalty.","pos":""},{"def":"The black angel fish.","pos":""}],"KINGSTON METAL":[{"def":"King\"ston met\"al Defn: .","pos":""}],"KINGSTON VALVE":[{"def":"A conical valve, opening outward, to close the mouth of a pipe which passes through the side of a vessel below the water line.","pos":""}],"KINGTRUSS":[{"def":"A truss, framed with a king-post; -- used in roofs, bridges, etc.","pos":""}],"KINIT":[{"def":"A unit of force equal to the force which, acting for one second, will give a pound a velocity of one foot per second; -- proposed by J.","pos":""}],"KINK":[{"def":"A twist or loop in a rope or thread, caused by a spontaneous doubling or winding upon itself; a close loop or curl; a doubling in a cord.","pos":""},{"def":"An unreasonable notion; a crotchet; a whim; a caprice.","pos":""}],"KINKAJOU":[{"def":"A nocturnal carnivorous mammal (Cercoleptes caudivolvulus) of South America, about as large as a full-grown cat.","pos":""}],"KINKLE":[{"def":"Same as 3d Kink.","pos":""}],"KINKY":[{"def":"Full of kinks; liable to kink or curl; as, kinky hair.","pos":""},{"def":"Queer; eccentric; crotchety.","pos":""}],"KINNIKINIC":[{"def":"Prepared leaves or bark of certain plants; -- used by the Indians of the Northwest for smoking, either mixed with tobacco or as a substitute for it.","pos":""}],"KINO":[{"def":"The dark red dried juice of certain plants, used variously in tanning, in dyeing, and as an astringent in medicine.","pos":""}],"KINOLOGY":[{"def":"That branch of physics which treats of the laws of motion, or of moving bodies.","pos":""}],"KINSFOLK":[{"def":"Relatives; kindred; kin; persons of the same family or closely or closely related families.","pos":""}],"KINSHIP":[{"def":"Family relationship.","pos":""}],"KINSMAN":[{"def":"A man of the same race or family; one related by blood.","pos":""}],"KINSWOMAN":[{"def":"A female relative.","pos":""}]}