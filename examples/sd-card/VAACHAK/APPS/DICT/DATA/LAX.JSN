{"LAX":[{"def":"Not tense, firm, or rigid; loose; slack; as, a lax bandage; lax fiber.","pos":""},{"def":"Not strict or stringent; not exact; loose; weak; vague; equivocal.","pos":""}],"LAXATION":[{"def":"The act of loosening or slackening, or the state of being loosened or slackened.","pos":""}],"LAXATIVE":[{"def":"Having the effect of loosening or opening the intestines, and relieving from constipation; -- opposed to astringent.","pos":""},{"def":"A laxative medicine.","pos":""}],"LAXATIVENESS":[{"def":"The quality of being laxative.","pos":""}],"LAXATOR":[{"def":"That which loosens; -- esp.","pos":""}],"LAXIITY":[{"def":"The state or quality of being lax; want of tenseness, strictness, or exactness.","pos":""}],"LAXITY":[{"def":"The state or quality of being lax; want of tenseness, strictness, or exactness.","pos":""}],"LAXLY":[{"def":"In a lax manner.","pos":""}],"LAXNESS":[{"def":"The state of being lax; laxity.","pos":""}]}