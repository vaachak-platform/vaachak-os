{"CREPITANT":[{"def":"Having a crackling sound; crackling; rattling.","pos":""}],"CREPITATE":[{"def":"To make a series of small, sharp, rapidly repeated explosions or sounds, as salt in fire; to crackle; to snap.","pos":""}],"CREPITATION":[{"def":"The act of crepitating or crackling.","pos":""}],"CREPITUS":[{"def":"Crep\"i*tus (krp\"-ts), n.","pos":""}],"CREPON":[{"def":"A thin stuff made of the finest wool or silk, or of wool and silk.","pos":""}],"CREPT":[{"def":"Pertaining to twilight; glimmering; hence, imperfectly clear or luminous.","pos":""}]}