{"DWALE":[{"def":"The deadly nightshade (Atropa Belladonna), having stupefying qualities.","pos":""},{"def":"The tincture sable or black when blazoned according to the fantastic system in which plants are substituted for the tinctures.","pos":""}],"DWANG":[{"def":"A piece of wood set between two studs, posts, etc.","pos":""}],"DWARF":[{"def":"An animal or plant which is much below the ordinary size of its species or kind; especially, a diminutive human being.","pos":""}],"DWARFISH":[{"def":"Like a dwarf; below the common stature or size; very small; petty; as, a dwarfish animal, shrub.","pos":""}],"DWARFLING":[{"def":"A diminutive dwarf.","pos":""}],"DWARFY":[{"def":"Much undersized.","pos":""},{"def":"To be delirious.","pos":""}],"DWELL":[{"def":"To delay; to linger.","pos":""},{"def":"To abide; to remain; to continue.","pos":""}],"DWELLER":[{"def":"An inhabitant; a resident; as, a cave dweller.","pos":""}],"DWELLING":[{"def":"Habitation; place or house in which a person lives; abode; domicile.","pos":""}],"DWINDLE":[{"def":"To diminish; to become less; to shrink; to waste or consume away; to become degenerate; to fall away.","pos":""}],"DWINDLEMENT":[{"def":"The act or process of dwindling; a dwindling.","pos":""}],"DWINE":[{"def":"To waste away; to pine; to languish.","pos":""}]}