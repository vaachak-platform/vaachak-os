{"PIQUANCY":[{"def":"The quality or state of being piquant.","pos":""}],"PIQUANT":[{"def":"Stimulating to the taste; giving zest; tart; sharp; pungent; as, a piquant anecdote.","pos":""}],"PIQUANTLY":[{"def":"In a piquant manner.","pos":""}],"PIQUE":[{"def":"A cotton fabric, figured in the loom, -- used as a dress goods for women and children, and for vestings, etc.","pos":""}],"PIQUET":[{"def":"A game at cards played between two persons, with thirty-two cards, all the deuces, threes, fours, fives, and sixes, being set aside.","pos":""}]}