{"COULD":[{"def":"Was, should be, or would be, able, capable, or susceptible.","pos":""}],"COULEE":[{"def":"A stream; (Geol.","pos":""},{"def":"a stream of lava.","pos":""}],"COULEUR":[{"def":"Color; -- chiefly used in a few French phrases, as couler de rose, color of rose; and hence, adjectively, rose-colored; roseate.","pos":""},{"def":"A suit of cards, as hearts or clubs; --used in some French games.","pos":""}],"COULISSE":[{"def":"A piece of timber having a groove in which something glides.","pos":""},{"def":"One of the side scenes of the stage in a theater, or the space included between the side scenes.","pos":""}],"COULOIR":[{"def":"A dredging machine for excavating canals, etc.","pos":""}],"COULOMB":[{"def":"The standard unit of quantity in electrical measurements.","pos":""}],"COULOMB METER":[{"def":"Any instrument by which electricity can be measured in coulombs.","pos":""}],"COULOMB'S LAW":[{"def":"The law that the force exerted between two electric or magnetic charges is directly proportional to the product of the charges and inversely to the square of the distance between them.","pos":""}],"COULTERNEB":[{"def":"Coul\"ter*neb` (-nb`), n.","pos":""}],"COULURE":[{"def":"A disease affecting grapes, esp.","pos":""}]}