{"STAMEN":[{"def":"The male organ of flowers for secreting and furnishing the pollen or fecundating dust.","pos":""}],"STAMENED":[{"def":"Furnished with stamens.","pos":""}],"STAMIN":[{"def":"A kind of woolen cloth.","pos":""}],"STAMINA":[{"def":"The fixed, firm part of a body, which supports it or gives it strength and solidity; as, the bones are the stamina of animal bodies; the ligneous parts of trees are the stamina which constitute their strength.","pos":""},{"def":"Whatever constitutes the principal strength or support of anything; power of endurance; backbone; vigor; as, the stamina of a constitution or of life; the stamina of a State.","pos":""}],"STAMINAL":[{"def":"Of or pertaining to stamens or stamina; consisting in stamens.","pos":""}],"STAMINATE":[{"def":"To indue with stamina.","pos":""},{"def":"Of or pertaining to the stamens; possessing stamens; also, attached to the stamens; as, a stamineous nectary.","pos":""}],"STAMINIFEROUS":[{"def":"Bearing or having stamens.","pos":""}],"STAMINODIUM":[{"def":"An abortive stamen, or any organ modified from an abortive stamen.","pos":""}],"STAMMEL":[{"def":"A large, clumsy horse.","pos":""}],"STAMMER":[{"def":"To make involuntary stops in uttering syllables or words; to hesitate or falter in speaking; to speak with stops and diffivulty; to stutter.","pos":""}],"STAMMERER":[{"def":"One who stammers.","pos":""}],"STAMMERING":[{"def":"Apt to stammer; hesitating in speech; stuttering.","pos":""}],"STAMP":[{"def":"To strike beat, or press forcibly with the bottom of the foot, or by thrusting the foot downward.","pos":""},{"def":"To bring down (the foot) forcibly on the ground or floor; as, he stamped his foot with rage.","pos":""}],"STAMPEDE":[{"def":"A wild, headlong scamper, or running away, of a number of animals; usually caused by fright; hence, any sudden flight or dispersion, as of a crowd or an army in consequence of a panic.","pos":""}],"STAMPER":[{"def":"An instrument for pounding or stamping.","pos":""}],"STAMPING":[{"def":"Stamping machine, a machine for forming metallic articles or impressions by stamping.","pos":""}]}