{"AUGEAN":[{"def":"Of or pertaining to Augeus, king of Elis, whose stable contained 3000 oxen, and had not been cleaned for 30 years.","pos":""}],"AUGER":[{"def":"A carpenter's tool for boring holes larger than those bored by a gimlet.","pos":""},{"def":"An instrument for boring or perforating soils or rocks, for determining the quality of soils, or the nature of the rocks or strata upon which they lie, and for obtaining water.","pos":""}],"AUGET":[{"def":"A priming tube connecting the charge chamber with the gallery, or place where the slow match is applied.","pos":""},{"def":"Property; possession.","pos":""}],"AUGHT":[{"def":"Anything; any part.","pos":""}],"AUGITE":[{"def":"A variety of pyroxene, usually of a black or dark green color, occurring in igneous rocks, such as basalt; -- also used instead of the general term pyroxene.","pos":""}],"AUGITIC":[{"def":"Pertaining to, or like, augite; containing augite as a principal constituent; as, augitic rocks.","pos":""}],"AUGMENT":[{"def":"To add an augment to.","pos":""}],"AUGMENTABLE":[{"def":"Capable of augmentation.","pos":""}],"AUGMENTATION":[{"def":"A additional charge to a coat of arms, given as a mark of honor.","pos":""},{"def":"The stage of a disease in which the symptoms go on increasing.","pos":""}],"AUGMENTATIVE":[{"def":"Having the quality or power of augmenting; expressing augmentation.","pos":""}],"AUGMENTER":[{"def":"One who, or that which, augments or increases anything.","pos":""}],"AUGUR":[{"def":"An official diviner who foretold events by the singing, chattering, flight, and feeding of birds, or by signs or omens derived from celestial phenomena, certain appearances of quadrupeds, or unusual occurrences.","pos":""}],"AUGURAL":[{"def":"Of or pertaining to augurs or to augury; betokening; ominous; significant; as, an augural staff; augural books.","pos":""}],"AUGURATE":[{"def":"To make or take auguries; to augur; to predict.","pos":""}],"AUGURATION":[{"def":"The practice of augury.","pos":""}],"AUGURIAL":[{"def":"Relating to augurs or to augury.","pos":""}],"AUGUROUS":[{"def":"Full of augury; foreboding.","pos":""}],"AUGURSHIP":[{"def":"The office, or period of office, of an augur.","pos":""}],"AUGURY":[{"def":"The art or practice of foretelling events by observing the actions of birds, etc.","pos":""},{"def":"An omen; prediction; prognostication; indication of the future; presage.","pos":""}],"AUGUST":[{"def":"Of a quality inspiring mingled admiration and reverence; having an aspect of solemn dignity or grandeur; sublime; majestic; having exalted birth, character, state, or authority.","pos":""}],"AUGUSTAN":[{"def":"A member of one of the religious orders called after St.","pos":""}],"AUGUSTINIAN":[{"def":"Of or pertaining to St.","pos":""}],"AUGUSTLY":[{"def":"In an august manner.","pos":""}],"AUGUSTNESS":[{"def":"The quality of being august; dignity of mien; grandeur; magnificence.","pos":""}]}