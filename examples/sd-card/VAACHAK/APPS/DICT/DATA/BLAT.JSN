{"BLAT":[{"def":"To cry, as a calf or sheep; to bleat; to make a senseless noise; to talk inconsiderately.","pos":""}],"BLATANCY":[{"def":"Blatant quality.","pos":""}],"BLATANT":[{"def":"Bellowing, as a calf; bawling; brawling; clamoring; disagreeably clamorous; sounding loudly and harshly.","pos":""}],"BLATANTLY":[{"def":"In a blatant manner.","pos":""}],"BLATHER":[{"def":"To talk foolishly, or nonsensically.","pos":""}],"BLATHERSKITE":[{"def":"A blustering, talkative fellow.","pos":""}],"BLATTER":[{"def":"To prate; to babble; to rail; to make a senseless noise; to patter.","pos":""}],"BLATTERER":[{"def":"One who blatters; a babbler; a noisy, blustering boaster.","pos":""}],"BLATTERING":[{"def":"Senseless babble or boasting.","pos":""}],"BLATTEROON":[{"def":"A senseless babbler or boaster.","pos":""}]}