{"PREST":[{"def":"Ready; prompt; prepared.","pos":""},{"def":"Neat; tidy; proper.","pos":""}],"PRESTATION":[{"def":"A payment of money; a toll or duty; also, the rendering of a service.","pos":""}],"PRESTER":[{"def":"One of the veins of the neck when swollen with anger or other excitement.","pos":""}],"PRESTERNUM":[{"def":"The anterior segment of the sternum; the manubrium.","pos":""}],"PRESTIDIGITAL":[{"def":"Nimble-fingered; having fingers fit for prestidigitation, or juggling.","pos":""}],"PRESTIDIGITATION":[{"def":"Legerdemain; sleight of hand; juggling.","pos":""}],"PRESTIDIGITATOR":[{"def":"One skilled in legerdemain or sleight of hand; a juggler.","pos":""}],"PRESTIGE":[{"def":"Delusion; illusion; trick.","pos":""},{"def":"Weight or influence derived from past success; expectation of future achievements founded on those already accomplished; force or charm derived from acknowledged character or reputation.","pos":""}],"PRESTIGIATION":[{"def":"Legerdemain; prestidigitation.","pos":""}],"PRESTIGIATOR":[{"def":"A juggler; prestidigitator.","pos":""}],"PRESTIGIATORY":[{"def":"Consisting of impostures; juggling.","pos":""}],"PRESTIGIOUS":[{"def":"Practicing tricks; juggling.","pos":""}],"PRESTIMONY":[{"def":"A fund for the support of a priest, without the title of a benefice.","pos":""}],"PRESTISSIMO":[{"def":"Very quickly; with great rapidity.","pos":""}],"PRESTO":[{"def":"Quickly; rapidly; -- a direction for a quick, lively movement or performance; quicker than allegro, or any rate of time except prestissimo.","pos":""}],"PRESTRICTION":[{"def":"Obstruction, dimness, or defect of sight.","pos":""}]}