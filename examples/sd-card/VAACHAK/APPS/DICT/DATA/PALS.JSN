{"PALSGRAVE":[{"def":"A count or earl who presided in the domestic court, and had the superintendence, of a royal household in Germany.","pos":""}],"PALSGRAVINE":[{"def":"The consort or widow of a palsgrave.","pos":"noun"}],"PALSICAL":[{"def":"Affected with palsy; palsied; paralytic.","pos":""}],"PALSIED":[{"def":"Affected with palsy; paralyzed.","pos":""}],"PALSTAVE":[{"def":"A peculiar bronze adz, used in prehistoric Europe about the middle of the bronze age.","pos":""}],"PALSTER":[{"def":"A pilgrim's staff.","pos":""}],"PALSY":[{"def":"Paralysis, complete or partial.","pos":""}],"PALSYWORT":[{"def":"The cowslip (Primula veris); -- so called from its supposed remedial powers.","pos":""}]}