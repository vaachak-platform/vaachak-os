{"UNISEPTATE":[{"def":"Having but one septum, or partition; -- said of two-celled fruits, such as the silicles of cruciferous plants.","pos":""}],"UNISERIAL":[{"def":"Having only one row or series.","pos":""}],"UNISERIATE":[{"def":"Having one line or series; uniserial.","pos":""}],"UNISEXUAL":[{"def":"Having one sex only, as plants which have the male and female flowers on separate individuals, or animals in which the sexes are in separate individuals; dioecious; -- distinguished from bisexual, or hermaphrodite.","pos":""}],"UNISILICATE":[{"def":"A salt of orthosilicic acid, H4SiO4; -- so called because the ratio of the oxygen atoms united to the basic metals and silicon respectively is 1:1; for example, Mg2SiO4 or 2MgO.","pos":""}],"UNISON":[{"def":"Identity in pitch; coincidence of sounds proceeding from an equality in the number of vibrations made in a given time by two or more sonorous bodies.","pos":""}],"UNISONAL":[{"def":"Being in unison; unisonant.","pos":""}],"UNISONANCE":[{"def":"Accordance of sounds; unison.","pos":""}],"UNISONANT":[{"def":"Being in unison; having the same degree of gravity or acuteness; sounded alike in pitch.","pos":""}],"UNISONOUS":[{"def":"Being in unison; unisonant.","pos":""}]}