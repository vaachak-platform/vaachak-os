{"BABA":[{"def":"A kind of plum cake.","pos":""}],"BABBITT":[{"def":"To line with Babbitt metal.","pos":""}],"BABBITT METAL":[{"def":"A soft white alloy of variable composition (as a nine parts of tin to one of copper, or of fifty parts of tin to five of antimony and one of copper) used in bearings to diminish friction.","pos":""}],"BABBLE":[{"def":"To utter words indistinctly or unintelligibly; to utter inarticulate sounds; as a child babbles.","pos":""},{"def":"To talk incoherently; to utter unmeaning words.","pos":""}],"BABBLER":[{"def":"A name given to any one of family (Timalinæ) of thrushlike birds, having a chattering note.","pos":""}],"BABE":[{"def":"An infant; a young child of either sex; a baby.","pos":""},{"def":"A doll for children.","pos":""}],"BABEL":[{"def":"The city and tower in the land of Shinar, where the confusion of languages took place.","pos":""},{"def":"Hence: A place or scene of noise and confusion; a confused mixture of sounds, as of voices or languages.","pos":""}],"BABERY":[{"def":"Finery of a kind to please a child.","pos":""}],"BABILLARD":[{"def":"The lesser whitethroat of Europe; -- called also babbling warbler.","pos":""}],"BABINGTONITE":[{"def":"A mineral occurring in triclinic crystals approaching pyroxene in angle, and of a greenish black color.","pos":""},{"def":"A large hoglike quadruped (Sus, or Porcus, babirussa) of the East Indies, sometimes domesticated; the Indian hog.","pos":""}],"BABISH":[{"def":"Like a babe; a childish; babyish.","pos":""}],"BABISM":[{"def":"The doctrine of a modern religious sect, which originated in Persia in 1843, being a mixture of Mohammedan, Christian, Jewish and Parsee elements.","pos":""},{"def":"The doctrine of a modern religious pantheistical sect in Persia, which was founded, about 1844, by Mirza Ali Mohammed ibn Rabhik (1820 -- 1850), who assumed the title of Bab-ed-Din (Per.","pos":""}],"BABIST":[{"def":"A believer in Babism.","pos":""}],"BABLAH":[{"def":"The ring of the fruit of several East Indian species of acacia; neb-neb.","pos":""},{"def":"A Hindoo gentleman; native clerk who writes English; also, a Hindoo title answering to Mr.","pos":""}],"BABOON":[{"def":"One of the Old World Quadrumana, of the genera Cynocephalus and Papio; the dog-faced ape.","pos":""}],"BABOONERY":[{"def":"Baboonish behavior.","pos":""}],"BABOONISH":[{"def":"Any one of several species of Acacia, esp.","pos":""}],"BABY":[{"def":"An infant or young child of either sex; a babe.","pos":""}],"BABY FARM":[{"def":"A place where the nourishment and care of babies are offered for hire.","pos":""}],"BABY FARMER":[{"def":"One who keeps a baby farm.","pos":""}],"BABY FARMING":[{"def":"The business of keeping a baby farm.","pos":""}],"BABY JUMPER":[{"def":"A hoop suspended by an elastic strap, in which a young child may be held secure while amusing itself by jumping on the floor.","pos":""}],"BABYHOOD":[{"def":"The state or period of infancy.","pos":""}],"BABYHOUSE":[{"def":"A place for children's dolls and dolls' furniture.","pos":""}],"BABYISH":[{"def":"Like a baby; childish; puerile; simple.","pos":""}],"BABYISM":[{"def":"The state of being a baby.","pos":""},{"def":"A babyish manner of acting or speaking.","pos":""}],"BABYLONIAN":[{"def":"Of or pertaining to the real or to the mystical Babylon, or to the ancient kingdom of Babylonia; Chaldean.","pos":""}],"BABYLONISH":[{"def":"Of or pertaining to, or made in, Babylon or Babylonia.","pos":""},{"def":"Pertaining to the Babylon of Revelation xiv.","pos":""}],"BABYSHIP":[{"def":"The quality of being a baby; the personality of an infant.","pos":""}]}