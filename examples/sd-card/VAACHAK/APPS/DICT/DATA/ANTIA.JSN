{"ANTIAE":[{"def":"The two projecting feathered angles of the forehead of some birds; the frontal points.","pos":""}],"ANTIALBUMID":[{"def":"A body formed from albumin by pancreatic and gastric digestion.","pos":""}],"ANTIAPHRODISIAC":[{"def":"Same as Antaphrodisiac.","pos":""}],"ANTIAPOPLECTIC":[{"def":"Same as Antapoplectic.","pos":""}],"ANTIAR":[{"def":"A Virulent poison prepared in Java from the gum resin of one species of the upas tree (Antiaris toxicaria).","pos":""}],"ANTIARIN":[{"def":"A poisonous principle obtained from antiar.","pos":""}],"ANTIASTHMATIC":[{"def":"Same as Antasthmatic.","pos":""}],"ANTIATTRITION":[{"def":"Anything to prevent the effects of friction, esp.","pos":""}]}