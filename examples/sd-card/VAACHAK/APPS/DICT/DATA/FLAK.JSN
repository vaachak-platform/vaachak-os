{"FLAKE":[{"def":"A small stage hung over a vessel's side, for workmen to stand on in calking, etc.","pos":""}],"FLAKINESS":[{"def":"The state of being flaky.","pos":""}],"FLAKY":[{"def":"Consisting of flakes or of small, loose masses; lying, or cleaving off, in flakes or layers; flakelike.","pos":""}]}