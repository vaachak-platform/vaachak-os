{"CANKER":[{"def":"A disease incident to trees, causing the bark to rot and fall off.","pos":""},{"def":"An obstinate and often incurable disease of a horse's foot, characterized by separation of the horny portion and the development of fungoid growths; -- usually resulting from neglected thrush.","pos":""}],"CANKER BLOOM":[{"def":"The bloom or blossom of the wild rose or dog-rose.","pos":""}],"CANKER BLOSSOM":[{"def":"That which blasts a blossom as a canker does.","pos":""}],"CANKER FLY":[{"def":"A fly that preys on fruit.","pos":""}],"CANKER RASH":[{"def":"A form of scarlet fever characterized by ulcerated or putrid sore throat.","pos":""}],"CANKER-BIT":[{"def":"Eaten out by canker, or as by canker.","pos":""}],"CANKERED":[{"def":"Affected with canker; as, a cankered mouth.","pos":""},{"def":"Affected mentally or morally as with canker; sore, envenomed; malignant; fretful; ill-natured.","pos":""}],"CANKEREDLY":[{"def":"Fretfully; spitefully.","pos":""}],"CANKEROUS":[{"def":"Affecting like a canker.","pos":""}],"CANKERWORM":[{"def":"The larva of two species of geometrid moths which are very injurious to fruit and shade trees by eating, and often entirely destroying, the foliage.","pos":""}],"CANKERY":[{"def":"Like a canker; full of canker.","pos":""},{"def":"Surly; sore; malignant.","pos":""}]}