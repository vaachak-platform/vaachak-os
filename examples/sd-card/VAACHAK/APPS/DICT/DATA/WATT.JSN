{"WATT":[{"def":"A unit of power or activity equal to 107 C.","pos":""}],"WATTEAU":[{"def":"Having the appearance of that which is seen in pictures by Antoine Watteau, a French painter of the eighteenth century; --said esp.","pos":""}],"WATTEAU BACK":[{"def":"The back of a woman's gown in which one or more very broad folds are carried from the neck to the floor without being held in at the waist, while the front and sides of the gown are shaped to the person and have a belt or its equivalent.","pos":""}],"WATTLE":[{"def":"A twig or flexible rod; hence, a hurdle made of such rods.","pos":""},{"def":"A rod laid on a roof to support the thatch.","pos":""}],"WATTLEBIRD":[{"def":"Any one of several species of honey eaters belonging to Anthochæra and allied genera of the family Meliphagidæ.","pos":""},{"def":"The Australian brush turkey.","pos":""}],"WATTLED":[{"def":"Furnished with wattles, or pendent fleshy processes at the chin or throat.","pos":""}],"WATTLESS":[{"def":"Without any power (cf.","pos":""}],"WATTLING":[{"def":"The act or process of binding or platting with twigs; also, the network so formed.","pos":""}],"WATTMETER":[{"def":"An instrument for measuring power in watts, -- much used in measuring the energy of an electric current.","pos":""},{"def":"A large draught of any liquid.","pos":""}]}