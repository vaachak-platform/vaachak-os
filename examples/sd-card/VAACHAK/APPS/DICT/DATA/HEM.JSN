{"HEM":[{"def":"An onomatopoetic word used as an expression of hesitation, doubt, etc.","pos":""}],"HEMACHATE":[{"def":"A species of agate, sprinkled with spots of red jasper.","pos":""}],"HEMACHROME":[{"def":"Same as Hæmachrome.","pos":""}],"HEMACITE":[{"def":"A composition made from blood, mixed with mineral or vegetable substances, used for making buttons, door knobs, etc.","pos":""},{"def":"An instrument for measuring the velocity with which the blood moves in the arteries.","pos":""}],"HEMADYNAMICS":[{"def":"The principles of dynamics in their application to the blood; that part of science which treats of the motion of the blood.","pos":""}],"HEMADYNAMOMETER":[{"def":"An instrument by which the pressure of the blood in the arteries, or veins, is measured by the height to which it will raise a column of mercury; -- called also a hæmomanometer.","pos":""}],"HEMAL":[{"def":"Relating to the blood or blood vessels; pertaining to, situated in the region of, or on the side with, the heart and great blood vessels; -- opposed to neural.","pos":""}],"HEMAPHAEIN":[{"def":"Same as Hæmaphæin.","pos":""}],"HEMAPOPHYSIS":[{"def":"The second element in each half of a hemal arch, corresponding to the sternal part of a rib.","pos":""},{"def":"Same as Hemostatic.","pos":""}],"HEMASTATICS":[{"def":"Laws relating to the equilibrium of the blood in the blood vessels.","pos":""}],"HEMATACHOMETER":[{"def":"Same as Hæmatachometer.","pos":""}],"HEMATEIN":[{"def":"A reddish brown or violet crystalline substance, C16H12O6, got from hematoxylin by partial oxidation, and regarded as analogous to the phthaleins.","pos":""}],"HEMATEMESIS":[{"def":"A vomiting of blood.","pos":""}],"HEMATHERM":[{"def":"A warm-blooded animal.","pos":""}],"HEMATHERMAL":[{"def":"Warm-blooded; hematothermal.","pos":""}],"HEMATIC":[{"def":"Same as Hæmatic.","pos":""}],"HEMATIN":[{"def":"A bluish black, amorphous substance containing iron and obtained from blood.","pos":""}],"HEMATINIC":[{"def":"Any substance, such as an iron salt or organic compound containing iron, which when ingested tends to increase the hemoglobin contents of the blood.","pos":""}],"HEMATINOMETER":[{"def":"A form of hemoglobinometer.","pos":""}],"HEMATINOMETRIC":[{"def":"Relating to the measurement of the amount of hematin or hemoglobin contained in blood, or other fluids.","pos":""}],"HEMATINON":[{"def":"A red consisting of silica, borax, and soda, fused with oxide of copper and iron, and used in enamels, mosaics, etc.","pos":""}],"HEMATITE":[{"def":"An important ore of iron, the sesquioxide, so called because of the red color of the powder.","pos":""}],"HEMATITIC":[{"def":"Of or pertaining to hematite, or resembling it.","pos":""}],"HEMATOCELE":[{"def":"A tumor filled with blood.","pos":""}],"HEMATOCRYA":[{"def":"The cold-blooded vertebrates, that is, all but the mammals and birds; -- the antithesis to Hematotherma.","pos":""}],"HEMATOCRYSTALLIN":[{"def":"Hem`a*to*crys\"tal*lin, n.","pos":""}],"HEMATOID":[{"def":"Resembling blood.","pos":""}],"HEMATOIDIN":[{"def":"A crystalline or amorphous pigment, free from iron, formed from hematin in old blood stains, and in old hemorrhages in the body.","pos":""}],"HEMATOLOGY":[{"def":"The science which treats of the blood.","pos":""}],"HEMATOMA":[{"def":"A circumscribed swelling produced by an effusion of blood beneath the skin.","pos":""}],"HEMATOPHILIA":[{"def":"A condition characterized by a tendency to profuse and uncontrollable hemorrhage from the slightest wounds.","pos":""}],"HEMATOSIN":[{"def":"The hematin of blood.","pos":""}],"HEMATOTHERMA":[{"def":"The warm-blooded vertebrates, comprising the mammals and birds; -- the antithesis to hematocrya.","pos":""}],"HEMATURIA":[{"def":"Passage of urine mingled with blood.","pos":""}],"HEMAUTOGRAPHY":[{"def":"The obtaining of a curve similar to a pulse curve or sphygmogram by allowing the blood from a divided artery to strike against a piece of paper.","pos":""},{"def":"One of the partially thickened anterior wings of certain insects, as of many Hemiptera, the earwigs, etc.","pos":""}],"HEMERALOPIA":[{"def":"A disease of the eyes, in consequence of which a person can see clearly or without pain only by daylight or a strong artificial light; day sight.","pos":""}],"HEMEROBIAN":[{"def":"A neuropterous insect of the genus Hemerobius, and allied genera.","pos":""}],"HEMEROBID":[{"def":"Of relating to the hemerobians.","pos":""}],"HEMEROCALLIS":[{"def":"A genus of plants, some species of which are cultivated for their beautiful flowers; day lily.","pos":""}],"HEMI-":[{"def":"A prefix signifying half.","pos":""}],"HEMI-DEMI-SEMIQUAVER":[{"def":"A short note, equal to one fourth of a semiquaver, or the sixty-fourth part of a whole note.","pos":""}],"HEMIALBUMIN":[{"def":"Same as Hemialbumose.","pos":""}],"HEMIALBUMOSE":[{"def":"An albuminous substance formed in gastric digestion, and by the action of boiling dilute acids on albumin.","pos":""}],"HEMIANAESTHESIA":[{"def":"Anæsthesia upon one side of the body.","pos":""}],"HEMIBRANCHI":[{"def":"An order of fishes having an incomplete or reduced branchial apparatus.","pos":""}],"HEMICARDIA":[{"def":"A lateral half of the heart, either the right or left.","pos":""}],"HEMICARP":[{"def":"One portion of a fruit that spontaneously divides into halves.","pos":""}],"HEMICEREBRUM":[{"def":"A lateral half of the cerebrum.","pos":""}],"HEMICRANIA":[{"def":"A pain that affects only one side of the head.","pos":""}],"HEMICYCLE":[{"def":"A half circle; a semicircle.","pos":""},{"def":"A semicircular place, as a semicircular arena, or room, or part of a room.","pos":""}],"HEMIDACTYL":[{"def":"Any species of Old World geckoes of the genus Hemidactylus.","pos":""}],"HEMIDITONE":[{"def":"The lesser third.","pos":""}],"HEMIGAMOUS":[{"def":"Having one of the two florets in the same spikelet neuter, and the other unisexual, whether male or female; -- said of grasses.","pos":""}],"HEMIGLYPH":[{"def":"The half channel or groove in the edge of the triglyph in the Doric order.","pos":""}],"HEMIHEDRISM":[{"def":"The property of crystallizing hemihedrally.","pos":""}],"HEMIHEDRON":[{"def":"A solid hemihedrally derived.","pos":""}],"HEMIHOLOHEDRAL":[{"def":"Presenting hemihedral forms, in which half the sectants have the full number of planes.","pos":""}],"HEMIMELLITIC":[{"def":"Having half as many (three) carboxyl radicals as mellitic acid; -- said of an organic acid.","pos":""}],"HEMIMETABOLA":[{"def":"Those insects which have an incomplete metamorphosis.","pos":""}],"HEMIMETABOLIC":[{"def":"Having an incomplete metamorphosis, the larvæ differing from the adults chiefly in laking wings, as in the grasshoppers and cockroaches.","pos":""}],"HEMIMORPHIC":[{"def":"Having the two ends modified with unlike planes; -- said of a crystal.","pos":""}],"HEMIN":[{"def":"A substance, in the form of reddish brown, microscopic, prismatic crystals, formed from dried blood by the action of strong acetic acid and common salt; -- called also Teichmann's crystals.","pos":""}],"HEMINA":[{"def":"A measure of half a sextary.","pos":""},{"def":"A measure equal to about ten fluid ounces.","pos":""}],"HEMIONUS":[{"def":"A wild ass found in Thibet; the kiang.","pos":""},{"def":"A defect of vision in consequence of which a person sees but half of an object looked at.","pos":""}],"HEMIORTHOTYPE":[{"def":"Same as Monoclinic.","pos":""}],"HEMIPEPTONE":[{"def":"A product of the gastric and pancreatic digestion of albuminous matter.","pos":""}],"HEMIPLEGIA":[{"def":"A palsy that affects one side only of the body.","pos":"noun"}],"HEMIPODE":[{"def":"Any bird of the genus Turnix.","pos":""}],"HEMIPROTEIN":[{"def":"An insoluble, proteid substance, described by Schützenberger, formed when albumin is heated for some time with dilute sulphuric acid.","pos":""}],"HEMIPTER":[{"def":"One of the Hemiptera.","pos":""}],"HEMIPTERA":[{"def":"An order of hexapod insects having a jointed proboscis, including four sharp stylets (mandibles and maxillæ), for piercing.","pos":""},{"def":"Of or pertaining to the Hemiptera.","pos":""}],"HEMIPTERAN":[{"def":"One of the Hemiptera; an hemipter.","pos":""}],"HEMISECT":[{"def":"To divide along the mesial plane.","pos":""}],"HEMISECTION":[{"def":"A division along the mesial plane; also, one of the parts so divided.","pos":""}],"HEMISPHERE":[{"def":"Containing, or pertaining to, a hemisphere; as, a hemispheric figure or form; a hemispherical body.","pos":""}],"HEMISPHEROID":[{"def":"A half of a spheroid.","pos":""}],"HEMISPHEROIDAL":[{"def":"Resembling, or approximating to, a hemisphere in form.","pos":""}],"HEMISPHERULE":[{"def":"A half spherule.","pos":""}],"HEMISTICH":[{"def":"Half a poetic verse or line, or a verse or line not completed.","pos":""}],"HEMISTICHAL":[{"def":"Pertaining to, or written in, hemistichs; also, by, or according to, hemistichs; as, a hemistichal division of a verse.","pos":""}],"HEMISYSTOLE":[{"def":"Contraction of only one ventricle of the heart.","pos":""}],"HEMITONE":[{"def":"Having the raphe terminating about half way between the chalaza and the orifice; amphitropous; -- said of an ovule.","pos":""}],"HEMITROPE":[{"def":"Half turned round; half inverted; (Crystallog.","pos":""}],"HEMITROPY":[{"def":"Twin composition in crystals.","pos":""}],"HEMLOCK":[{"def":"The name of several poisonous umbelliferous herbs having finely cut leaves and small white flowers, as the Cicuta maculata, bulbifera, and virosa, and the Conium maculatum.","pos":""},{"def":"An evergreen tree common in North America (Abies, or Tsuga, Canadensis); hemlock spruce.","pos":""}],"HEMMEL":[{"def":"A shed or hovel for cattle.","pos":""}],"HEMMER":[{"def":"One who, or that which, hems with a needle.","pos":""}],"HEMO-":[{"def":"Same as Hæma-, Hæmo-.","pos":""}],"HEMOGLOBIN":[{"def":"The normal coloring matter of the red blood corpuscles of vertebrate animals.","pos":""}],"HEMOGLOBINOMETER":[{"def":"Same as Hæmochromometer.","pos":""}],"HEMOPHILIA":[{"def":"See Hematophilia.","pos":""}],"HEMOPTYSIS":[{"def":"The expectoration of blood, due usually to hemorrhage from the mucous membrane of the lungs.","pos":""}],"HEMORRHAGE":[{"def":"Any discharge of blood from the blood vessels.","pos":""}],"HEMORRHOIDAL":[{"def":"Of or pertaining to the rectum; rectal; as, the hemorrhoidal arteries, veins, and nerves.","pos":""}],"HEMORRHOIDS":[{"def":"Livid and painful swellings formed by the dilation of the blood vessels around the margin of, or within, the anus, from which blood or mucus is occasionally discharged; piles; emerods.","pos":""}],"HEMOSTATIC":[{"def":"Of or relating to stagnation of the blood.","pos":""}],"HEMOTHORAX":[{"def":"An effusion of blood into the cavity of the pleura.","pos":""}],"HEMP":[{"def":"A plant of the genus Cannabis (C.","pos":""}],"HEMPEN":[{"def":"Made of hemp; as, a hempen cord.","pos":""}],"HEMPY":[{"def":"Themselves; -- used reflexively.","pos":""}],"HEMSTITCH":[{"def":"To ornament at the head of a broad hem by drawing out a few parallel threads, and fastening the cross threads in successive small clusters; as, to hemstitch a handkerchief.","pos":""}],"HEMSTITCHED":[{"def":"Having a broad hem separated from the body of the article by a line of open work; as, a hemistitched handkerchief.","pos":""}],"HEMUSE":[{"def":"The roebuck in its third year.","pos":""}]}