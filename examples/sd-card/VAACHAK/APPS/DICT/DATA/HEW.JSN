{"HEW":[{"def":"To cut with an ax; to fell with a sharp instrument; -- often with down, or off.","pos":""},{"def":"To form or shape with a sharp instrument; to cut; hence, to form laboriously; -- often with out; as, to hew out a sepulcher.","pos":""}],"HEWE":[{"def":"A domestic servant; a retainer.","pos":""}],"HEWHOLE":[{"def":"The European green woodpecker.","pos":""}],"HEWN":[{"def":"A prefix or combining form, used to denote six, sixth, etc.","pos":""}]}