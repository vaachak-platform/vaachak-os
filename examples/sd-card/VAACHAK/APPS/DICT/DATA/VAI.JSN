{"VAIL":[{"def":"Avails; profit; return; proceeds.","pos":""},{"def":"An unexpected gain or acquisition; a casual advantage or benefit; a windfall.","pos":""}],"VAIMURE":[{"def":"An outer, or exterior.","pos":""}],"VAIN":[{"def":"Having no real substance, value, or importance; empty; void; worthless; unsatisfying.","pos":""},{"def":"Destitute of forge or efficacy; effecting no purpose; fruitless; ineffectual; as, vain toil; a vain attempt.","pos":""}],"VAINGLORIOUS":[{"def":"Feeling or indicating vainglory; elated by vanity; boastful.","pos":""}],"VAINGLORY":[{"def":"Excessive vanity excited by one's own performances; empty pride; undue elation of mind; vain show; boastfulness.","pos":""}],"VAINLY":[{"def":"In a vain manner; in vain.","pos":""}],"VAINNESS":[{"def":"The quality or state of being vain.","pos":""}],"VAIR":[{"def":"The skin of the squirrel, much used in the fourteenth century as fur for garments, and frequently mentioned by writers of that period in describing the costly dresses of kings, nobles, and prelates.","pos":""}],"VAIRY":[{"def":"Charged with vair; variegated with shield-shaped figures.","pos":""}],"VAISHNAVA":[{"def":"A worshiper of the god Vishnu in any of his incarnations.","pos":""}],"VAISHNAVISM":[{"def":"The worship of Vishnu.","pos":""}],"VAISYA":[{"def":"The third of the four great original castes among the Hindoos, now either extinct or partially represented by the mercantile class of Banyas.","pos":""}]}