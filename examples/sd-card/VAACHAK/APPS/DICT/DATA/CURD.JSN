{"CURD":[{"def":"The coagulated or thickened part of milk, as distingushed from the whey, or watery part.","pos":""},{"def":"The coagulated part of any liquid.","pos":""}],"CURDINESS":[{"def":"The state of being curdy.","pos":""}],"CURDLE":[{"def":"To change into curd; to coagulate; as, rennet causes milk to curdle.","pos":""},{"def":"To thicken; to congeal.","pos":""}],"CURDLESS":[{"def":"Destitute of curd.","pos":""}],"CURDY":[{"def":"Like curd; full of curd; coagulated.","pos":""}]}