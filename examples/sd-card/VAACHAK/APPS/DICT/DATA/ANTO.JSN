{"ANTONOMASTIC":[{"def":"Pertaining to, or characterized by, antonomasia.","pos":""}],"ANTONYM":[{"def":"A word of opposite meaning; a counterterm; -- used as a correlative of synonym.","pos":""}],"ANTORBITAL":[{"def":"Pertaining to, or situated in, the region of the front of the orbit.","pos":""},{"def":"The antorbital bone.","pos":""}],"ANTORGASTIC":[{"def":"See Antiorgastic.","pos":""}],"ANTOZONE":[{"def":"A compound formerly supposed to be modification of oxygen, but now known to be hydrogen dioxide; -- so called because apparently antagonistic to ozone, converting it into ordinary oxygen.","pos":""}]}