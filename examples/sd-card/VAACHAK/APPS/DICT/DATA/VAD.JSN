{"VADANTES":[{"def":"An extensive artificial group of birds including the wading, swimming, and cursorial birds.","pos":""}],"VADE":[{"def":"To fade; hence, to vanish.","pos":""}],"VADE MECUM":[{"def":"A book or other thing that a person carries with him as a constant companion; a manual; a handbook.","pos":""}],"VADIMONY":[{"def":"A bond or pledge for appearance before a judge on a certain day.","pos":""}],"VADIUM":[{"def":"Pledge; security; bail.","pos":""}]}