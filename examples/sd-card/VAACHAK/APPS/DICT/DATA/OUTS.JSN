{"OUTSAIL":[{"def":"To excel, or to leave behind, in sailing; to sail faster than.","pos":""}],"OUTSCENT":[{"def":"To exceed in odor.","pos":""}],"OUTSCOLD":[{"def":"To exceed in scolding.","pos":""}],"OUTSCORN":[{"def":"To confront, or subdue, with greater scorn.","pos":""}],"OUTSCOURING":[{"def":"That which is scoured out o Buckland.","pos":""}],"OUTSCOUT":[{"def":"To overpower by disdain; to outface.","pos":""}],"OUTSELL":[{"def":"To exceed in amount of sales; to sell more than.","pos":""},{"def":"To exceed in the price of selling; to fetch more than; to exceed in value.","pos":""}],"OUTSENTRY":[{"def":"A sentry who guards the entrance or approach to a place; an outguard.","pos":""}],"OUTSET":[{"def":"A setting out, starting, or beginning.","pos":""}],"OUTSETTLER":[{"def":"One who settles at a distance, or away, from others.","pos":""}],"OUTSHINE":[{"def":"To excel in splendor.","pos":""}],"OUTSHOOT":[{"def":"To exceed or excel in shooting; to shoot beyond.","pos":""}],"OUTSIDE":[{"def":"The external part of a thing; the part, end, or side which forms the surface; that which appears, or is manifest; that which is superficial; the exterior.","pos":""},{"def":"The part or space which lies without an inclosure; the outer side, as of a door, walk, or boundary.","pos":""}],"OUTSIDER":[{"def":"One not belonging to the concern, institution, party, etc.","pos":""},{"def":"A locksmith's pinchers for grasping the point of a key in the keyhole, to open a door from the outside when the key is inside.","pos":""}],"OUTSING":[{"def":"To surpass in singing.","pos":""}],"OUTSIT":[{"def":"To remain sitting, or in session, longer than, or beyond the time of; to outstay.","pos":""}],"OUTSKIRT":[{"def":"A part remote from the center; outer edge; border; -- usually in the plural; as, the outskirts of a town.","pos":""}],"OUTSLEEP":[{"def":"To exceed in sleeping.","pos":""}],"OUTSLIDE":[{"def":"To slide outward, onward, or forward; to advance by sliding.","pos":""}],"OUTSOAR":[{"def":"To soar beyond or above.","pos":""}],"OUTSOLE":[{"def":"The outside sole of a boot or shoe.","pos":""}],"OUTSOUND":[{"def":"To surpass in sounding.","pos":""}],"OUTSPAN":[{"def":"To unyoke or disengage, as oxen from a wagon.","pos":""}],"OUTSPARKLE":[{"def":"To exceed in sparkling.","pos":""}],"OUTSPEAK":[{"def":"To exceed in speaking.","pos":""},{"def":"To speak openly or boldly.","pos":""}],"OUTSPEED":[{"def":"To excel in speed.","pos":""}],"OUTSPEND":[{"def":"Outlay; expenditure.","pos":""}],"OUTSPIN":[{"def":"To spin out; to finish.","pos":""}],"OUTSPOKEN":[{"def":"Speaking, or spoken, freely, openly, or boldly; as, an outspoken man; an outspoken rebuke.","pos":""}],"OUTSPORT":[{"def":"To exceed in sporting.","pos":""}],"OUTSPREAD":[{"def":"To spread out; to expand; -- usually as a past part.","pos":""}],"OUTSPRING":[{"def":"To spring out; to issue.","pos":""}],"OUTSTAND":[{"def":"To stand out, or project, from a surface or mass; hence, to remain standing out.","pos":""}],"OUTSTANDING":[{"def":"That stands out; undischarged; uncollected; not paid; as, outstanding obligations.","pos":""}],"OUTSTARE":[{"def":"To excel or overcome in staring; to face down.","pos":""}],"OUTSTART":[{"def":"To start out or up.","pos":""}],"OUTSTAY":[{"def":"To stay beyond or longer than.","pos":""}],"OUTSTEP":[{"def":"To exceed in stepping.","pos":""}],"OUTSTORM":[{"def":"To exceed in storming.","pos":""}],"OUTSTREET":[{"def":"A street remote from the center of a town.","pos":""}],"OUTSTRIDE":[{"def":"To surpass in striding.","pos":""}],"OUTSTRIKE":[{"def":"To strike out; to strike faster than.","pos":""}],"OUTSTRIP":[{"def":"To go faster than; to outrun; to advance beyond; to leave behing.","pos":""}],"OUTSUFFER":[{"def":"To exceed in suffering.","pos":""}],"OUTSWEAR":[{"def":"To exceed in swearing.","pos":""}],"OUTSWEETEN":[{"def":"To surpass in sweetness.","pos":""}],"OUTSWELL":[{"def":"To exceed in swelling.","pos":""},{"def":"To swell beyond; to overflow.","pos":""}]}