{"FASCES":[{"def":"A bundle of rods, having among them an ax with the blade projecting, borne before the Roman magistrates as a badge of their authority.","pos":""}],"FASCET":[{"def":"A wire basket on the end of a rod to carry glass bottles, etc.","pos":""}],"FASCIA":[{"def":"A flat member of an order or building, like a flat band or broad fillet; especially, one of the three bands which make up the architrave, in the Ionic order.","pos":""},{"def":"The layer of loose tissue, often containing fat, immediately beneath the skin; the stronger layer of connective tissue covering and investing all muscles; an aponeurosis.","pos":""}],"FASCIAL":[{"def":"Relating to a fascia.","pos":""},{"def":"Broadly banded with color.","pos":""}],"FASCIATION":[{"def":"The act or manner of binding up; bandage; also, the condition of being fasciated.","pos":""}],"FASCICLE":[{"def":"A small bundle or collection; a compact cluster; as, a fascicle of fibers; a fascicle of flowers or roots.","pos":""}],"FASCICLED":[{"def":"Growing in a bundle, tuft, or close cluster; as, the fascicled leaves of the pine or larch; the fascicled roots of the dahlia; fascicled muscle fibers; fascicled tufts of hair.","pos":""}],"FASCICULAR":[{"def":"Pertaining to a fascicle; fascicled; as, a fascicular root.","pos":""}],"FASCICULARLY":[{"def":"In a fascicled manner.","pos":""},{"def":"Grouped in a fascicle; fascicled.","pos":""}],"FASCICULE":[{"def":"A small bunch or bundle; a fascicle; as, a fascicule of fibers, hairs, or spines.","pos":""}],"FASCICULUS":[{"def":"A little bundle; a fascicle.","pos":""},{"def":"A division of a book.","pos":""}],"FASCINATE":[{"def":"To influence in an uncontrollable manner; to operate on by some powerful or irresistible charm; to bewitch; to enchant.","pos":""},{"def":"To excite and allure irresistibly or powerfully; to charm; to captivate, as by physical or mental charms.","pos":""}],"FASCINATION":[{"def":"The act of fascinating, bewhiching, or enchanting; enchantment; witchcraft; the exercise of a powerful or irresistible influence on the affections or passions; unseen, inexplicable influence.","pos":""},{"def":"The state or condition of being fascinated.","pos":""}],"FASCINE":[{"def":"A cylindrical bundle of small sticks of wood, bound together, used in raising batteries, filling ditches, strengthening ramparts, and making parapets; also in revetments for river banks, and in mats for dams, jetties, etc.","pos":""}],"FASCINOUS":[{"def":"Caused or acting by witchcraft.","pos":""}],"FASCIOLA":[{"def":"A band of gray matter bordering the fimbria in the brain; the dentate convolution.","pos":""}],"FASCIOLE":[{"def":"A band of minute tubercles, bearing modified spines, on the shells of spatangoid sea urchins.","pos":""}],"FASH":[{"def":"To vex; to tease; to trouble.","pos":""}],"FASHION":[{"def":"The make or form of anything; the style, shape, appearance, or mode of structure; pattern, model; as, the fashion of the ark, of a coat, of a house, of an altar, etc.","pos":""},{"def":"The prevailing mode or style, especially of dress; custom or conventional usage in respect of dress, behavior, etiquette, etc.","pos":""}],"FASHION-MONGER":[{"def":"One who studies the fashions; a fop; a dandy.","pos":""}],"FASHION-MONGERING":[{"def":"Behaving like a fashion-monger.","pos":""}],"FASHIONABLE":[{"def":"Conforming to the fashion or established mode; according with the prevailing form or style; as, a fashionable dress.","pos":""},{"def":"Established or favored by custom or use; current; prevailing at a particular time; as, the fashionable philosophy; fashionable opinions.","pos":""}],"FASHIONABLENESS":[{"def":"State of being fashionable.","pos":""}],"FASHIONABLY":[{"def":"In a fashionable manner.","pos":""}],"FASHIONED":[{"def":"Having a certain style or fashion; as old-fashioned; new- fashioned.","pos":""}],"FASHIONER":[{"def":"One who fashions, forms, ar gives shape to anything.","pos":""}],"FASHIONIST":[{"def":"An obsequious follower of the modes and fashions.","pos":""}],"FASHIONLESS":[{"def":"Having no fashion.","pos":""}],"FASSAITE":[{"def":"A variety of pyroxene, from the valley of Fassa, in the Tyrol.","pos":""}],"FAST":[{"def":"To abstain from food; to omit to take nourishment in whole or in part; to go hungry.","pos":""},{"def":"To practice abstinence as a religious exercise or duty; to abstain from food voluntarily for a time, for the mortification of the body or appetites, or as a token of grief, or humiliation and penitence.","pos":""}],"FAST-HANDED":[{"def":"Close-handed; close-fisted; covetous; avaricious.","pos":""}],"FASTEN":[{"def":"To fix firmly; to make fast; to secure, as by a knot, lock, bolt, etc.","pos":""},{"def":"To cause to hold together or to something else; to attach or unite firmly; to cause to cleave to something , or to cleave together, by any means; as, to fasten boards together with nails or cords; to fasten anything in our thoughts.","pos":""}],"FASTENER":[{"def":"One who, or that which, makes fast or firm.","pos":""}],"FASTENING":[{"def":"Anything that binds and makes fast, as a lock, catch, bolt, bar, buckle, etc.","pos":""}],"FASTER":[{"def":"One who abstains from food.","pos":""}],"FASTI":[{"def":"The Roman calendar, which gave the days for festivals, courts, etc.","pos":"noun"},{"def":"Records or registers of important events.","pos":"noun"}],"FASTIDIOSITY":[{"def":"Fastidiousness; squeamishness.","pos":""}],"FASTIDIOUS":[{"def":"Difficult to please; delicate to fault; suited with difficulty; squeamish; as, a fastidious mind or ear; a fastidious appetite.","pos":""},{"def":"Clustered, parallel, and upright, as the branches of the Lombardy poplar; pointed.","pos":""}],"FASTISH":[{"def":"Rather fast; also, somewhat dissipated.","pos":""}],"FASTNESS":[{"def":"The state of being fast and firm; firmness; fixedness; security; faithfulness.","pos":""},{"def":"A fast place; a stronghold; a fortress or fort; a secure retreat; a castle; as, the enemy retired to their fastnesses in the mountains.","pos":""}],"FASTUOUS":[{"def":"Proud; haughty; disdainful.","pos":""}]}