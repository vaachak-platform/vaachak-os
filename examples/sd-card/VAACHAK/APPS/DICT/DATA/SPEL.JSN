{"SPELDING":[{"def":"A haddock or other small fish split open and dried in the sun; -- called also speldron.","pos":""}],"SPELK":[{"def":"A small stick or rod used as a spike in thatching; a splinter.","pos":""}],"SPELL":[{"def":"A spelk, or splinter.","pos":""}],"SPELLABLE":[{"def":"Capable of being spelt.","pos":""}],"SPELLBIND":[{"def":"To bind or hold by, or as if by, a spell or charm; to fascinate, esp.","pos":""}],"SPELLBOUND":[{"def":"Bound by, or as by, a spell.","pos":""}],"SPELLER":[{"def":"A spelling book.","pos":""}],"SPELLFUL":[{"def":"Abounding in spells, or charms.","pos":""}],"SPELLING":[{"def":"The act of one who spells; formation of words by letters; orthography.","pos":""}],"SPELLWORK":[{"def":"Power or effect of magic; that which is wrought by magic; enchantment.","pos":""}],"SPELT":[{"def":"A species of grain (Triticum Spelta) much cultivated for food in Germany and Switzerland; -- called also German wheat.","pos":""}],"SPELTER":[{"def":"Zinc; -- especially so called in commerce and arts.","pos":""}],"SPELUNC":[{"def":"A cavern; a cave.","pos":""}]}