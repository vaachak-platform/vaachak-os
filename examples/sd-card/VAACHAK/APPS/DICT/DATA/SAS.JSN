{"SASH":[{"def":"A scarf or band worn about the waist, over the shoulder, or otherwise; a belt; a girdle, -- worn by women and children as an ornament; also worn as a badge of distinction by military officers, members of societies, etc.","pos":""}],"SASHERY":[{"def":"A collection of sashes; ornamentation by means of sashes.","pos":""}],"SASHOON":[{"def":"A kind of pad worn on the leg under the boot.","pos":""}],"SASIN":[{"def":"The Indian antelope (Antilope bezoartica, or cervicapra), noted for its beauty and swiftness.","pos":""},{"def":"A large African antelope (Alcelaphus tunata), similar to the hartbeest, but having its horns regularly curved.","pos":""}],"SASSAFRAS":[{"def":"An American tree of the Laurel family (Sassafras officinale); also, the bark of the roots, which has an aromatic smell and taste.","pos":""}],"SASSANAGE":[{"def":"Stones left after sifting.","pos":""}],"SASSARARA":[{"def":"A word used to emphasize a statement.","pos":""}],"SASSE":[{"def":"A sluice or lock, as in a river, to make it more navigable.","pos":""}],"SASSENACH":[{"def":"A Saxon; an Englishman; a Lowlander.","pos":""},{"def":"Native boric acid, found in saline incrustations on the borders of hot springs near Sasso, in the territory of Florence.","pos":""}],"SASSY BARK":[{"def":"The bark of a West African leguminous tree (Erythrophlæum Guineense, used by the natives as an ordeal poison, and also medicinally; -- called also mancona bark.","pos":""}],"SASTRA":[{"def":"Same as Shaster.","pos":""}],"SASTRUGI":[{"def":"Incorrect, but common, var.","pos":""}]}