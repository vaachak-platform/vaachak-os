{"OVERMAGNIFY":[{"def":"To magnify too much.","pos":""}],"OVERMALAPERT":[{"def":"Excessively malapert or impudent.","pos":""}],"OVERMAN":[{"def":"One in authority over others; a chief; usually, an overseer or boss.","pos":""}],"OVERMANNER":[{"def":"In an excessive manner; excessively.","pos":""}],"OVERMARCH":[{"def":"To march too far, or too much; to exhaust by marching.","pos":""}],"OVERMAST":[{"def":"To furnish (a vessel) with too long or too heavy a mast or masts.","pos":""}],"OVERMASTER":[{"def":"To overpower; to subdue; to vanquish; to govern.","pos":""}],"OVERMATCH":[{"def":"To be more than equal to or a match for; hence, to vanquish.","pos":""},{"def":"To marry (one) to a superior.","pos":""}],"OVERMEASURE":[{"def":"To measure or estimate too largely.","pos":""}],"OVERMEDDLE":[{"def":"To meddle unduly.","pos":""}],"OVERMEDDLING":[{"def":"Excessive interference.","pos":""}],"OVERMELLOW":[{"def":"Too mellow; overripe.","pos":""}],"OVERMERIT":[{"def":"Excessive merit.","pos":""}],"OVERMIX":[{"def":"To mix with too much.","pos":""}],"OVERMODEST":[{"def":"Modest to excess; bashful.","pos":""}],"OVERMOIST":[{"def":"Excessively moist.","pos":""}],"OVERMOISTURE":[{"def":"Excess of moisture.","pos":""}],"OVERMORE":[{"def":"Beyond; moreover.","pos":""}],"OVERMORROW":[{"def":"The day after or following to-morrow.","pos":""}],"OVERMOST":[{"def":"Over the rest in authority; above all others; highest.","pos":""}],"OVERMOUNT":[{"def":"To mount over; to go higher than; to rise above.","pos":""}],"OVERMUCH":[{"def":"In too great a degree; too much.","pos":""}],"OVERMUCHNESS":[{"def":"The quality or state of being in excess; superabundance.","pos":""}],"OVERMULTIPLY":[{"def":"To multiply or increase too much; to repeat too often.","pos":""}]}