{"SERAC":[{"def":"A pinnacle of ice among the crevasses of a glacier; also, one of the blocks into which a glacier breaks on a steep grade.","pos":""}],"SERAGLIO":[{"def":"An inclosure; a place of separation.","pos":""},{"def":"The palace of the Grand Seignior, or Turkish sultan, at Constantinople, inhabited by the sultan himself, and all the officers and dependents of his court.","pos":""}],"SERAI":[{"def":"A palace; a seraglio; also, in the East, a place for the accommodation of travelers; a caravansary, or rest house.","pos":""}],"SERANG":[{"def":"The boatswain of a Lascar or East Ondian crew.","pos":""}],"SERAPE":[{"def":"A blanket or shawl worn as an outer garment by the Spanish Americans, as in Mexico.","pos":""}],"SERAPH":[{"def":"One of an order of celestial beings, each having three pairs of wings.","pos":""},{"def":"Of or pertaining to a seraph; becoming, or suitable to, a seraph; angelic; sublime; pure; refined.","pos":""}],"SERAPHICISM":[{"def":"The character, quality, or state of a seraph; seraphicalness.","pos":""}],"SERAPHIM":[{"def":"The Hebrew plural of Seraph.","pos":""}],"SERAPHINE":[{"def":"A wind instrument whose sounding parts are reeds, consisting of a thin tongue of brass playing freely through a slot in a plate.","pos":""}],"SERAPIS":[{"def":"An Egyptian deity, at first a symbol of the Nile, and so of fertility; later, one of the divinities of the lower world.","pos":""}],"SERASKIER":[{"def":"A general or commander of land forces in the Turkish empire; especially, the commander-in-chief of minister of war.","pos":""}],"SERASKIERATE":[{"def":"The office or authority of a seraskier.","pos":""}]}