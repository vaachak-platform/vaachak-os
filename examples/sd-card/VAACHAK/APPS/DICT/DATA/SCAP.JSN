{"SCAPE":[{"def":"A peduncle rising from the ground or from a subterranean stem, as in the stemless violets, the bloodroot, and the like.","pos":""},{"def":"The long basal joint of the antennæ of an insect.","pos":""}],"SCAPE-WHEEL":[{"def":"the wheel in an escapement (as of a clock or a watch) into the teeth of which the pallets play.","pos":""}],"SCAPEGALLOWS":[{"def":"One who has narrowly escaped the gallows for his crimes.","pos":""}],"SCAPEGOAT":[{"def":"A goat upon whose head were symbolically placed the sins of the people, after which he was suffered to escape into the wilderness.","pos":""}],"SCAPEGRACE":[{"def":"A graceless, unprincipled person; one who is wild and reckless.","pos":""}],"SCAPELESS":[{"def":"Destitute of a scape.","pos":""}],"SCAPEMENT":[{"def":"Same as Escapement, 3.","pos":""}],"SCAPHANDER":[{"def":"The case, or impermeable apparel, in which a diver can work while under water.","pos":""}],"SCAPHISM":[{"def":"An ancient mode of punishing criminals among the Persians, by confining the victim in a trough, with his head and limbs smeared with honey or the like, and exposed to the sun and to insects until he died.","pos":""}],"SCAPHITE":[{"def":"Any fossil cephalopod shell of the genus Scaphites, belonging to the Ammonite family and having a chambered boat-shaped shell.","pos":""}],"SCAPHOCEPHALIC":[{"def":"Of, pertaining to, or affected with, scaphocephaly.","pos":""}],"SCAPHOCEPHALY":[{"def":"A deformed condition of the skull, in which the vault is narrow, clongated, and more or less boat-shaped.","pos":""}],"SCAPHOCERITE":[{"def":"A flattened plate or scale attached to the second joint of the antennæ of many Crustacea.","pos":""}],"SCAPHOGNATHITE":[{"def":"A thin leafike appendage (the exopodite) of the second maxilla of decapod crustaceans.","pos":""}],"SCAPHOID":[{"def":"Resembling a boat in form; boat-shaped.","pos":""},{"def":"The scaphoid bone.","pos":""}],"SCAPHOLUNAR":[{"def":"Of or pertaining to the scaphoid and lunar bones of the carpus.","pos":""},{"def":"The scapholunar bone.","pos":""}],"SCAPHOPODA":[{"def":"A class of marine cephalate Mollusca having a tubular shell open at both ends, a pointed or spadelike foot for burrowing, and many long, slender, prehensile oral tentacles.","pos":""}],"SCAPIFORM":[{"def":"Resembling scape, or flower stm.","pos":""}],"SCAPOLITE":[{"def":"A grayish white mineral occuring in tetragonal crystals and in cleavable masses.","pos":""}],"SCAPULA":[{"def":"The principal bone of the shoulder girdle in mammals; the shoulder blade.","pos":""},{"def":"One of the plates from which the arms of a crinoid arise.","pos":""}],"SCAPULAR":[{"def":"Of or pertaining to the scapula or the shoulder Scapular arch (Anat.","pos":""}],"SCAPULARY":[{"def":"Same as Scapular, a.","pos":""}],"SCAPULET":[{"def":"A secondary mouth fold developed at the base of each of the armlike lobes of the manubrium of many rhizostome medusæ.","pos":""}],"SCAPULO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the scapula or the shoulder; as, the scapulo- clavicular articulation, the articulation between the scapula and clavicle.","pos":""}]}