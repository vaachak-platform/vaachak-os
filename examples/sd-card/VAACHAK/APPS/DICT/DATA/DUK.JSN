{"DUKE":[{"def":"A leader; a chief; a prince.","pos":""},{"def":"In England, one of the highest order of nobility after princes and princesses of the royal blood and the four archbishops of England and Ireland.","pos":""}],"DUKEDOM":[{"def":"The territory of a duke.","pos":""},{"def":"The title or dignity of a duke.","pos":""}],"DUKELING":[{"def":"A little or insignificant duke.","pos":""}],"DUKESHIP":[{"def":"The quality or condition of being a duke; also, the personality of a duke.","pos":""},{"def":"A Russian religious sect founded about the middle of the 18th century at Kharkov.","pos":""}]}