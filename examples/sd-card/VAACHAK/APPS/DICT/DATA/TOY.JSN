{"TOY":[{"def":"A headdress of linen or woolen, that hangs down over the shoulders, worn by old women of the lower classes; -- called also toy mutch.","pos":"verb"}],"TOYER":[{"def":"One who toys; one who is full of trifling tricks; a trifler.","pos":""}],"TOYFUL":[{"def":"Full of trifling play.","pos":""}],"TOYHOUSE":[{"def":"A house for children to play in or to play with; a playhouse.","pos":""}],"TOYINGLY":[{"def":"In a toying manner.","pos":""}],"TOYISH":[{"def":"Sportive; trifling; wanton.","pos":""},{"def":"Resembling a toy.","pos":""}],"TOYMAN":[{"def":"One who deals toys.","pos":""}],"TOYSHOP":[{"def":"A shop where toys are sold.","pos":""}],"TOYSOME":[{"def":"Disposed to toy; trifling; wanton.","pos":""}]}