{"RAN":[{"def":"Yarns coiled on a spun-yarn winch.","pos":""}],"RANA":[{"def":"A genus of anurous batrachians, including the common frogs.","pos":""}],"RANAL":[{"def":"Having a general affinity to ranunculaceous plants.","pos":""}],"RANCE":[{"def":"A prop or shore.","pos":""},{"def":"A round between the legs of a chair.","pos":""}],"RANCESCENT":[{"def":"Becoming rancid or sour.","pos":""}],"RANCH":[{"def":"To wrench; to tear; to sprain; to injure by violent straining or contortion.","pos":""}],"RANCHERIA":[{"def":"A dwelling place of a ranchero.","pos":""},{"def":"A small settlement or collection of ranchos, or rude huts, esp.","pos":""}],"RANCHERO":[{"def":"A herdsman; a peasant employed on a ranch or rancho.","pos":""},{"def":"The owner and occupant of a ranch or rancho.","pos":""}],"RANCHMAN":[{"def":"An owner or occupant of, or laborer on, a ranch; a herdsman.","pos":""}],"RANCHO":[{"def":"A rude hut, as of posts, covered with branches or thatch, where herdsmen or farm laborers may live or lodge at night.","pos":""},{"def":"A large grazing farm where horses and cattle are raised; -- distinguished from hacienda, a cultivated farm or plantation.","pos":""}],"RANCID":[{"def":"Having a rank smell or taste, from chemical change or decomposition; musty; as, rancid oil or butter.","pos":""}],"RANCIDITY":[{"def":"The quality or state of being rancid; a rancid scent or flavor, as of old oil.","pos":""}],"RANCIDLY":[{"def":"In a rancid manner.","pos":""}],"RANCIDNESS":[{"def":"The quality of being rancid.","pos":""}],"RANCOR":[{"def":"The deepest malignity or spite; deep-seated enmity or malice; inveterate hatred.","pos":""}],"RANCOROUS":[{"def":"Full of rancor; evincing, or caused by, rancor; deeply malignant; implacably spiteful or malicious; intensely virulent.","pos":""}],"RANCOROUSLY":[{"def":"In a rancorous manner.","pos":""}],"RAND":[{"def":"A border; edge; margin.","pos":""},{"def":"A long, fleshy piece, as of beef, cut from the flank or leg; a sort of steak.","pos":""}],"RANDALL GRASS":[{"def":"The meadow fescue (Festuca elatior).","pos":""}],"RANDAN":[{"def":"The product of a second sifting of meal; the finest part of the bran.","pos":""}],"RANDING":[{"def":"The act or process of making and applying rands for shoes.","pos":""},{"def":"A kind of basket work used in gabions.","pos":""}],"RANDOM":[{"def":"The direction of a rake-vein.","pos":""}],"RANDOMLY":[{"def":"In a random manner.","pos":""}],"RANDON":[{"def":"To go or stray at random.","pos":""}],"RANGE":[{"def":"To be native to, or to live in; to frequent.","pos":""}],"RANGER":[{"def":"One who ranges; a rover; sometimes, one who ranges for plunder; a roving robber.","pos":""},{"def":"That which separates or arranges; specifically, a sieve.","pos":""}],"RANGERSHIP":[{"def":"The office of the keeper of a forest or park.","pos":""}],"RANGLE":[{"def":"To range about in an irregular manner.","pos":""}],"RANGY":[{"def":"Inclined or able to range, or rove about, for considerable distances; apt or suited for much roving, --chiefly used of cattle.","pos":""}],"RANI":[{"def":"A queen or princess; the wife of a rajah.","pos":""}],"RANINE":[{"def":"Of or pertaining to the frogs and toads.","pos":""},{"def":"Pertaining to, or designating, a swelling under the tongue; also, pertaining to the region where the swelling occurs; -- applied especially to branches of the lingual artery and lingual vein.","pos":""}],"RANK":[{"def":"Luxuriant in growth; of vigorous growth; exuberant; grown to immoderate height; as, rank grass; rank weeds.","pos":""},{"def":"Raised to a high degree; violent; extreme; gross; utter; as, rank heresy.","pos":""}],"RANKER":[{"def":"One who ranks, or disposes in ranks; one who arranges.","pos":""}],"RANKLE":[{"def":"To become, or be, rank; to grow rank or strong; to be inflamed; to fester; -- used literally and figuratively.","pos":""},{"def":"To produce a festering or inflamed effect; to cause a sore; -- used literally and figuratively; as, a splinter rankles in the flesh; the words rankled in his bosom.","pos":""}],"RANKLY":[{"def":"With rank or vigorous growth; luxuriantly; hence, coarsely; grossly; as, weeds grow rankly.","pos":""}],"RANKNESS":[{"def":"The condition or quality of being rank.","pos":""}],"RANSACK":[{"def":"To search thoroughly; to search every place or part of; as, to ransack a house.","pos":""},{"def":"To plunder; to pillage completely.","pos":""}],"RANSOM":[{"def":"A sum paid for the pardon of some great offense and the discharge of the offender; also, a fine paid in lieu of corporal punishment.","pos":""}],"RANSOMABLE":[{"def":"Such as can be ransomed.","pos":""}],"RANSOMER":[{"def":"One who ransoms or redeems.","pos":""}],"RANSOMLESS":[{"def":"Incapable of being ransomed; without ransom.","pos":""}],"RANT":[{"def":"To rave in violent, high-sounding, or extravagant language, without dignity of thought; to be noisy, boisterous, and bombastic in talk or declamation; as, a ranting preacher.","pos":""}],"RANTER":[{"def":"A noisy talker; a raving declaimer.","pos":""}],"RANTERISM":[{"def":"The practice or tenets of the Ranters.","pos":""}],"RANTINGLY":[{"def":"In a ranting manner.","pos":""}],"RANTIPOLE":[{"def":"A wild, romping young person.","pos":""}],"RANTY":[{"def":"Wild; noisy; boisterous.","pos":""}],"RANULA":[{"def":"A cyst formed under the tongue by obstruction of the duct of the submaxillary gland.","pos":""}],"RANUNCULACEOUS":[{"def":"Of or pertaining to a natural order of plants (Ranunculaceæ), of which the buttercup is the type, and which includes also the virgin's bower, the monkshood, larkspur, anemone, meadow rue, and peony.","pos":""}],"RANUNCULUS":[{"def":"A genus of herbs, mostly with yellow flowers, including crowfoot, buttercups, and the cultivated ranunculi (R.","pos":""}],"RANZ DES VACHES":[{"def":"The name for numerous simple, but very irregular, melodies of the Swiss mountaineers, blown on a long tube called the Alpine horn, and sometimes sung.","pos":""}]}