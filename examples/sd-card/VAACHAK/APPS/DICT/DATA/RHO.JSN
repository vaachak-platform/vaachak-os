{"RHODAMMONIUM":[{"def":"Pertaining to, derived from, or containing, rhodium and ammonia; -- said of certain complex compounds.","pos":""}],"RHODANATE":[{"def":"A salt of rhodanic acid; a sulphocyanate.","pos":""}],"RHODANIC":[{"def":"Pertaining to, or designating, an acid (commonly called sulphocyanic acid) which frms a red color with ferric salts.","pos":""}],"RHODEORETIN":[{"def":"Same as Convolvuln.","pos":""}],"RHODIAN":[{"def":"Of or pertaining to Rhodes, an island of the Mediterranean.","pos":""},{"def":"A native or inhabitant of Rhodes.","pos":""}],"RHODIC":[{"def":"Of or pertaining to rhodium; containing rhodium.","pos":""}],"RHODIUM":[{"def":"A rare element of the light platinum group.","pos":""}],"RHODIZONIC":[{"def":"Pertaining to, or designating, a colorless crystalline substance (called rhodizonic acid, and carboxylic acid) obtained from potassium carboxide and from certain quinones.","pos":""}],"RHODOCHROSITE":[{"def":"Manganese carbonate, a rose-red mineral sometimes occuring crystallized, but generally massive with rhombohedral cleavage like calcite; -- called also dialogite.","pos":""}],"RHODOCRINITE":[{"def":"A rose encrinite.","pos":""}],"RHODODENDRON":[{"def":"A genus of shrubs or small trees, often having handsome evergreen leaves, and remarkable for the beauty of their flowers; rosebay.","pos":""}],"RHODOMONTADE":[{"def":"See Rodomontade.","pos":""}],"RHODOMONTADER":[{"def":"See Rodomontador.","pos":""}],"RHODONITE":[{"def":"Manganese spar, or silicate of manganese, a mineral occuring crystallised and in rose-red masses.","pos":""}],"RHODOPHANE":[{"def":"The red pigment contained in the inner segments of the cones of the retina in animals.","pos":""}],"RHODOPSIN":[{"def":"The visual purple.","pos":""}],"RHODOSPERM":[{"def":"Any seaweed with red spores.","pos":""}],"RHOMB":[{"def":"An equilateral parallelogram, or quadrilateral figure whose sides are equal and the opposite sides parallel.","pos":""}],"RHOMB SPAR":[{"def":"A variety of dolomite.","pos":""}],"RHOMBIC":[{"def":"Same as Orthorhombic.","pos":""}],"RHOMBOGANOID":[{"def":"A ganoid fish having rhombic enameled scales; one of the Rhomboganoidei.","pos":""}],"RHOMBOGANOIDEI":[{"def":"Same as Ginglymodi.","pos":"noun"}],"RHOMBOGENE":[{"def":"A dicyemid which produces infusorialike embryos; -- opposed to nematogene.","pos":""}],"RHOMBOHEDRAL":[{"def":"Related to the rhombohedron; presenting the form of a rhombohedron, or a form derivable from a rhombohedron; relating to a system of forms including the rhombohedron and scalenohedron.","pos":""}],"RHOMBOHEDRON":[{"def":"A solid contained by six rhomboids; a parallelopiped.","pos":""}],"RHOMBOID":[{"def":"An oblique-angled parallelogram like a rhomb, but having only the opposite sides equal, the length and with being different.","pos":""}],"RHOMBOID-OVATE":[{"def":"Between rhomboid and ovate, or oval, in shape.","pos":""}],"RHOMBOIDAL":[{"def":"Having, or approaching, the shape of a rhomboid.","pos":""}],"RHOMBUS":[{"def":"Same as Rhomb, 1.","pos":""}],"RHONCHIAL":[{"def":"Of or pertaining to a rhonchus; produced by rhonchi.","pos":""}],"RHONCHISONANT":[{"def":"Making a snorting noise; snorting.","pos":""}],"RHONCHUS":[{"def":"An adventitious whistling or snoring sound heard on auscultation of the chest when the air channels are partially obstructed.","pos":""}],"RHOPALIC":[{"def":"Applied to a line or verse in which each successive word has one more syllable than the preceding.","pos":""}],"RHOPALIUM":[{"def":"One of the marginal sensory bodies of medusæ belonging to the Discophora.","pos":""}],"RHOPALOCERA":[{"def":"A division of Lepidoptera including all the butterflies.","pos":""}],"RHOTACISM":[{"def":"An oversounding, or a misuse, of the letter r; specifically (Phylol.","pos":""}]}