{"SUBEDITOR":[{"def":"An assistant editor, as of a periodical or journal.","pos":""}],"SUBELONGATE":[{"def":"Not fully elongated; somewhat elongated.","pos":""}],"SUBENDOCARDIAL":[{"def":"Situated under the endocardium.","pos":""}],"SUBENDYMAL":[{"def":"Situated under the endyma.","pos":""}],"SUBEPIDERMAL":[{"def":"Situated immediately below the epidermis.","pos":""}],"SUBEPIGLOTTIC":[{"def":"Situated under the epiglottis.","pos":""}],"SUBEPITHELIAL":[{"def":"Situated under the epithelium.","pos":""}],"SUBERATE":[{"def":"A salt of suberic acid.","pos":""}],"SUBEREOUS":[{"def":"Of or pertaining to cork; of the nature of cork; suberose.","pos":""}],"SUBERIN":[{"def":"A material found in the cell walls of cork.","pos":""}],"SUBERITE":[{"def":"Any sponge of the genus Suberites and allied genera.","pos":""}],"SUBERIZATION":[{"def":"Conversion of the cell walls into cork tissue by development of suberin; -- commonly taking place in exposed tissues, as when a callus forms over a wound.","pos":""}],"SUBERIZE":[{"def":"To effect suberization of.","pos":""}],"SUBERONE":[{"def":"Having a corky texture.","pos":""}],"SUBESOPHAGEAL":[{"def":"Situated beneath the esophagus.","pos":""}]}