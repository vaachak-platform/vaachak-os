{"MOCCASIN":[{"def":"A poisonous snake of the Southern United States.","pos":""}],"MOCCASINED":[{"def":"Covered with, or wearing, a moccasin or moccasins.","pos":""}],"MOCHA":[{"def":"A seaport town of Arabia, on the Red Sea.","pos":""},{"def":"A variety of coffee brought from Mocha.","pos":""}],"MOCHE":[{"def":"A bale of raw silk.","pos":""}],"MOCHILA":[{"def":"A large leather flap which covers the saddletree.","pos":""}],"MOCK":[{"def":"To imitate; to mimic; esp.","pos":""},{"def":"To treat with scorn or contempt; to deride.","pos":""}],"MOCKABLE":[{"def":"Such as can be mocked.","pos":""}],"MOCKADO":[{"def":"A stuff made in imitation of velvet; -- probably the same as mock velvet.","pos":""}],"MOCKBIRD":[{"def":"The European sedge warbler (Acrocephalus phragmitis).","pos":""}],"MOCKER":[{"def":"One who, or that which, mocks; a scorner; a scoffer; a derider.","pos":""},{"def":"A deceiver; an impostor.","pos":""}],"MOCKERY":[{"def":"The act of mocking, deriding, and exposing to contempt, by mimicry, by insincere imitation, or by a false show of earnestness; a counterfeit appearance.","pos":""},{"def":"Insulting or contemptuous action or speech; contemptuous merriment; derision; ridicule.","pos":""}],"MOCKINGLY":[{"def":"By way of derision; in a contemptuous or mocking manner.","pos":""}],"MOCKINGSTOCK":[{"def":"A butt of sport; an object of derision.","pos":""}],"MOCKISH":[{"def":"Mock; counterfeit; sham.","pos":""}],"MOCO":[{"def":"A South American rodent (Cavia rupestris), allied to the Guinea pig, but larger; -- called also rock cavy.","pos":""}]}