{"IMPRACTICABILITY":[{"def":"The state or quality of being impracticable; infeasibility.","pos":""},{"def":"An impracticable thing.","pos":""}],"IMPRACTICABLE":[{"def":"Not practicable; incapable of being performed, or accomplished by the means employed, or at command; impossible; as, an impracticable undertaking.","pos":""},{"def":"Not to be overcome, presuaded, or controlled by any reasonable method; unmanageable; intractable; not capable of being easily dealt with; -- used in a general sense, as applied to a person or thing that is difficult to control or get along with.","pos":""}],"IMPRACTICABLENESS":[{"def":"The state or quality of being impracticable; impracticability.","pos":""}],"IMPRACTICABLY":[{"def":"In an impracticable manner.","pos":""}],"IMPRECATE":[{"def":"To call down by prayer, as something hurtful or calamitous.","pos":""},{"def":"To invoke evil upon; to curse; to swear at.","pos":""}],"IMPRECATION":[{"def":"The act of imprecating, or unvoking evil upon any one; a player that a curse or calamnity may fall on any one; a curse.","pos":""}],"IMPRECATORY":[{"def":"Of the nature of, or containing, imprecation; invokingevil; as, the imprecatory psalms.","pos":""}],"IMPRECISION":[{"def":"Want of precision.","pos":""}],"IMPREGN":[{"def":"To impregnate; to make fruitful.","pos":""}],"IMPREGNABILITY":[{"def":"The quality or state of being impregnable; invincibility.","pos":""}],"IMPREGNABLE":[{"def":"Not to be stormed, or taken by assault; incapable of being subdued; able to resist attack; unconquerable; as, an impregnable fortress; impregnable virtue.","pos":""}],"IMPREGNANT":[{"def":"That which impregnates.","pos":""}],"IMPREGNATE":[{"def":"To come into contact with (an ovum or egg) so as to cause impregnation; to fertilize; to fecundate.","pos":""}],"IMPREGNATION":[{"def":"The fusion of a female germ cell (ovum) with a male germ cell (in animals, a spermatozoön) to form a single new cell endowed with the power of developing into a new individual; fertilization; fecundation.","pos":""},{"def":"An ore deposit, with indefinite boundaries, consisting of rock impregnated with ore.","pos":""}],"IMPREJUDICATE":[{"def":"Not prejuged; unprejudiced; impartial.","pos":""}],"IMPREPARATION":[{"def":"Want of preparation.","pos":""}],"IMPRESA":[{"def":"A device on a shield or seal, or used as a bookplate or the like.","pos":""}],"IMPRESARIO":[{"def":"The projector, manager, or conductor, of an opera or concert company.","pos":""}],"IMPRESCRIPTIBILITY":[{"def":"The quality of being imprescriptible.","pos":""}],"IMPRESCRIPTIBLE":[{"def":"Not capable of being lost or impaired by neglect, by disuse, or by the claims of another founded on prescription.","pos":""},{"def":"Not derived from, or dependent on, external authority; self- evidencing; obvious.","pos":""}],"IMPRESCRIPTIBLY":[{"def":"In an imprescriptible manner; obviously.","pos":""}],"IMPRESE":[{"def":"An imprese, as the Italians call it, is a device in picture with his motto or word, borne by noble or learned personages.","pos":""}],"IMPRESS":[{"def":"To take by force for public service; as, to impress sailors or money.","pos":""}],"IMPRESSIBILITY":[{"def":"The quality of being impressible; susceptibility.","pos":""}],"IMPRESSIBLE":[{"def":"Capable of being impressed; susceptible; sensitive.","pos":""}],"IMPRESSION":[{"def":"The pressure of the type on the paper, or the result of such pressure, as regards its appearance; as, a heavy impression; a clear, or a poor, impression; also, a single copy as the result of printing, or the whole edition printed at a given time.","pos":""},{"def":"A print on paper from a wood block, metal plate, or the like.","pos":""}],"IMPRESSIONABILITY":[{"def":"The quality of being impressionable.","pos":""}],"IMPRESSIONABLE":[{"def":"Liable or subject to impression; capable of being molded; susceptible; impressible.","pos":""}],"IMPRESSIONABLENESS":[{"def":"The quality of being impressionable.","pos":""}],"IMPRESSIONISM":[{"def":"The theory or method of suggesting an effect or impression without elaboration of the details; -- a disignation of a recent fashion in painting and etching.","pos":""}],"IMPRESSIONIST":[{"def":"One who adheres to the theory or method of impressionism, so called.","pos":""}],"IMPRESSIONISTIC":[{"def":"Pertaining to, or characterized by, impressionism.","pos":""}],"IMPRESSIONLESS":[{"def":"Having the quality of not being impressed or affected; not susceptible.","pos":""}],"IMPRESSIVE":[{"def":"Making, or tending to make, an impression; having power to impress; adapted to excite attention and feeling, to touch the sensibilities, or affect the conscience; as, an impressive discourse; an impressive scene.","pos":""},{"def":"Capable of being impressed.","pos":""}],"IMPRESSMENT":[{"def":"The act of seizing for public use, or of impressing into public service; compulsion to serve; as, the impressment of provisions or of sailors.","pos":""}],"IMPRESSOR":[{"def":"One who, or that which, impresses.","pos":""}],"IMPRESSURE":[{"def":"Dent; impression.","pos":""}],"IMPREST":[{"def":"To advance on loan.","pos":""}],"IMPREVENTABILITY":[{"def":"The state or quality of being impreventable.","pos":""}],"IMPREVENTABLE":[{"def":"Not preventable; invitable.","pos":""}],"IMPRIMATUR":[{"def":"A license to print or publish a book, paper, etc.","pos":""}],"IMPRIMIS":[{"def":"In the first place; first in order.","pos":""}],"IMPRINT":[{"def":"To impress; to mark by pressure; to indent; to stamp.","pos":""},{"def":"To stamp or mark, as letters on paper, by means of type, plates, stamps, or the like; to print the mark (figures, letters, etc.","pos":""}],"IMPRISON":[{"def":"To put in prison or jail; To arrest and detain in custody; to confine.","pos":""},{"def":"To limit, restrain, or confine in any way.","pos":""}],"IMPRISONER":[{"def":"One who imprisons.","pos":""}],"IMPRISONMENT":[{"def":"The act of imprisoning, or the state of being imprisoned; confinement; restraint.","pos":""}],"IMPROBABILITY":[{"def":"The quality or state of being improbable; unlikelihood; also, that which is improbable; an improbable event or result.","pos":""}],"IMPROBABLE":[{"def":"Not probable; unlikely to be true; not to be expected under the circumstances or in the usual course of events; as, an improbable story or event.","pos":""}],"IMPROBATE":[{"def":"To disapprove of; to disallow.","pos":""}],"IMPROBATION":[{"def":"The act by which falsehood and forgery are proved; an action brought for the purpose of having some instrument declared false or forged.","pos":""},{"def":"Implying, or tending to, improbation.","pos":""}],"IMPROBITY":[{"def":"Lack of probity; want of integrity or rectitude; dishonesty.","pos":""},{"def":"Want of proficiency.","pos":""}],"IMPROGRESSIVE":[{"def":"Not progressive.","pos":""}],"IMPROMPTU":[{"def":"Offhand; without previous study; extemporaneous; extempore; as, an impromptu verse.","pos":""}],"IMPROPER":[{"def":"Not proper; not suitable; not fitted to the circumstances, design, or end; unfit; not becoming; incongruous; inappropriate; indecent; as, an improper medicine; improper thought, behavior, language, dress.","pos":""},{"def":"Not peculiar or appropriate to individuals; general; common.","pos":""}],"IMPROPERATION":[{"def":"The act of upbraiding or taunting; a reproach; a taunt.","pos":""}],"IMPROPERIA":[{"def":"A series of antiphons and responses, expressing the sorrowful remonstrance of our Lord with his people; -- sung on the morning of the Good Friday in place of the usual daily Mass of the Roman ritual.","pos":""}],"IMPROPERLY":[{"def":"In an improper manner; not properly; unsuitably; unbecomingly.","pos":""}],"IMPROPITIOUS":[{"def":"Unpropitious; unfavorable.","pos":""}],"IMPROPORTIONABLE":[{"def":"Not proportionable.","pos":""}],"IMPROPORTIONATE":[{"def":"Not proportionate.","pos":""}],"IMPROPRIATE":[{"def":"To place the profits of (ecclesiastical property) in the hands of a layman for care and disbursement.","pos":""}],"IMPROPRIATION":[{"def":"The act of impropriating; as, the impropriation of property or tithes; also, that which is impropriated.","pos":""}],"IMPROPRIATOR":[{"def":"One who impropriates; specifically, a layman in possession of church property.","pos":""}],"IMPROPRIATRIX":[{"def":"A female impropriator.","pos":""}],"IMPROPRIETY":[{"def":"The quality of being improper; unfitness or unsuitableness to character, time place, or circumstances; as, improperiety of behavior or manners.","pos":""},{"def":"That which is improper; an unsuitable or improper act, or an inaccurate use of language.","pos":""}],"IMPROSPERITY":[{"def":"Want of prosperity.","pos":""}],"IMPROVABILITY":[{"def":"The state or quality of being improvable; improvableness.","pos":""}],"IMPROVABLE":[{"def":"Capable of being improved; susceptible of improvement; admitting of being made better; capable of cultivation, or of being advanced in good qualities.","pos":""},{"def":"Capable of being used to advantage; profitable; serviceable; advantageous.","pos":""}],"IMPROVE":[{"def":"To disprove or make void; to refute.","pos":""},{"def":"To disapprove; to find fault with; to reprove; to censure; as, to improve negligence.","pos":""}],"IMPROVEMENT":[{"def":"Valuable additions or betterments, as buildings, clearings, drains, fences, etc.","pos":""},{"def":"A useful addition to, or modification of, a machine, manufacture, or composition.","pos":""}],"IMPROVER":[{"def":"One who, or that which, improves.","pos":""}],"IMPROVIDED":[{"def":"Unforeseen; unexpected; not provided against; unprepared.","pos":""}],"IMPROVIDENCE":[{"def":"The quality of being improvident; want of foresight or thrift.","pos":""}],"IMPROVIDENT":[{"def":"Not provident; wanting foresight or forethought; not foreseeing or providing for the future; negligent; thoughtless; as, an improvident man.","pos":""}],"IMPROVIDENTIALLY":[{"def":"Im*prov`i*den\"tial*ly, adv.","pos":""}],"IMPROVIDENTLY":[{"def":"In a improvident manner.","pos":""}],"IMPROVING":[{"def":"Tending to improve, beneficial; growing better.","pos":""}],"IMPROVISATE":[{"def":"Unpremeditated; impromptu; extempore.","pos":""}],"IMPROVISATION":[{"def":"The act or art of composing and rendering music, poetry, and the like, extemporaneously; as, improvisation on the organ.","pos":""},{"def":"That which is improvised; an impromptu.","pos":""}],"IMPROVISATIZE":[{"def":"Same as Improvisate.","pos":""}],"IMPROVISATOR":[{"def":"An improviser, or improvvisatore.","pos":""}],"IMPROVISATORE":[{"def":"See Improvvisatore.","pos":""},{"def":"Of or pertaining to improvisation or extemporaneous composition.","pos":""}],"IMPROVISATRICE":[{"def":"See Improvvisatrice.","pos":""}],"IMPROVISE":[{"def":"To compose, recite, or sing extemporaneously, especially in verse; to extemporize; also, to play upon an instrument, or to act, extemporaneously.","pos":""},{"def":"To bring about, arrange, or make, on a sudden, or without previous preparation.","pos":""}],"IMPROVISER":[{"def":"One who improvises.","pos":""}],"IMPROVISO":[{"def":"Not prepared or mediated beforehand; extemporaneous.","pos":""}],"IMPROVVISATORE":[{"def":"One who composes and sings or recites rhymes and short poems extemporaneously.","pos":""}],"IMPROVVISATRICE":[{"def":"A female improvvisatore.","pos":""}],"IMPRUDENCE":[{"def":"The quality or state of being imprudent; want to caution, circumspection, or a due regard to consequences; indiscretion; inconsideration; reshness; also, an imprudent act; as, he was guilty of an imprudence.","pos":""}],"IMPRUDENT":[{"def":"Not prudent; wanting in prudence or discretion; indiscreet; injudicious; not attentive to consequence; improper.","pos":""}]}