{"UNILABIATE":[{"def":"Having one lip only; as, a unilabiate corolla.","pos":""}],"UNILATERAL":[{"def":"Pertaining to one side; one-sided; as, a unilateral raceme, in which the flowers grow only on one side of a common axis, or are all turned to one side.","pos":""}],"UNILITERAL":[{"def":"Consisting of one letter only; as, a uniliteral word or sign.","pos":""}],"UNILOBAR":[{"def":"Consisting of a single lobe.","pos":""}],"UNILOCULAR":[{"def":"Having one cell or cavity only; as, a unilocular capsule or shell.","pos":""}]}