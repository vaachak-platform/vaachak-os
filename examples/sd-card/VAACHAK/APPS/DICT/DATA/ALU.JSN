{"ALUDEL":[{"def":"One of the pear-shaped pots open at both ends, and so formed as to be fitted together, the neck of one into the bottom of another in succession; -- used in the process of sublimation.","pos":""}],"ALULA":[{"def":"A false or bastard wing.","pos":""}],"ALULAR":[{"def":"Pertaining to the alula.","pos":""}],"ALUM":[{"def":"A double sulphate formed of aluminium and some other element (esp.","pos":""}],"ALUM ROOT":[{"def":"A North American herb (Heuchera Americana) of the Saxifrage family, whose root has astringent properties.","pos":""},{"def":"A variety of shale or clay slate, containing iron pyrites, the decomposition of which leads to the formation of alum, which often effloresces on the rock.","pos":""}],"ALUM STONE":[{"def":"A subsulphate of alumina and potash; alunite.","pos":""}],"ALUMINA":[{"def":"One of the earths, consisting of two parts of aluminium and three of oxygen, Al2O3.","pos":""}],"ALUMINATE":[{"def":"A compound formed from the hydrate of aluminium by the substitution of a metal for the hydrogen.","pos":""}],"ALUMINATED":[{"def":"Combined with alumina.","pos":""}],"ALUMINIC":[{"def":"Of or containing aluminium; as, aluminic phosphate.","pos":""}],"ALUMINIFEROUS":[{"def":"Containing alum.","pos":""}],"ALUMINIFORM":[{"def":"pertaining the form of alumina.","pos":""}],"ALUMINIUM":[{"def":"The metallic base of alumina.","pos":""}],"ALUMINIZE":[{"def":"To treat impregnate with alum; to alum.","pos":""}],"ALUMINOGRAPHY":[{"def":"Art or process of producing, and printing from, aluminium plates, after the manner of ordinary lithography.","pos":""}],"ALUMINOUS":[{"def":"Pertaining to or containing alum, or alumina; as, aluminous minerals, aluminous solution.","pos":""}],"ALUMISH":[{"def":"Somewhat like alum.","pos":""}],"ALUMNA":[{"def":"A female pupil; especially, a graduate of a school or college.","pos":""}],"ALUMNUS":[{"def":"A pupil; especially, a graduate of a college or other seminary of learning.","pos":""}],"ALUNOGEN":[{"def":"A white fibrous mineral frequently found on the walls of mines and quarries, chiefly hydrous sulphate of alumina; -- also called feather alum, and hair salt.","pos":""}],"ALURE":[{"def":"A walk or passage; -- applied to passages of various kinds.","pos":""}],"ALUTACEOUS":[{"def":"Of a pale brown color; leather-yellow.","pos":""}],"ALUTATION":[{"def":"The tanning or dressing of leather.","pos":""}]}