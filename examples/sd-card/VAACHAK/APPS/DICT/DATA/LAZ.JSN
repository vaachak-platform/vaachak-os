{"LAZAR":[{"def":"A person infected with a filthy or pestilential disease; a leper.","pos":""},{"def":"A public building, hospital, or pesthouse for the reception of diseased persons, particularly those affected with contagious diseases.","pos":""}],"LAZARET FEVER":[{"def":"One of the Congregation of the Priests of the Mission, a religious institute founded by Vincent de Paul in 1624, and popularly called Lazarists or Lazarites from the College of St.","pos":""}],"LAZE":[{"def":"To be lazy or idle.","pos":""}],"LAZILY":[{"def":"In a lazy manner.","pos":""}],"LAZINESS":[{"def":"The state or quality of being lazy.","pos":""}],"LAZULI":[{"def":"A mineral of a fine azure-blue color, usually in small rounded masses.","pos":"noun"}],"LAZULITE":[{"def":"A mineral of a light indigo-blue color, occurring in small masses, or in monoclinic crystals; blue spar.","pos":""}],"LAZY":[{"def":"Disinclined to action or exertion; averse to labor; idle; shirking work.","pos":""},{"def":"Inactive; slothful; slow; sluggish; as, a lazy stream.","pos":""}],"LAZYBACK":[{"def":"A support for the back, attached to the seat of a carriage.","pos":""}],"LAZZARONI":[{"def":"The homeless idlers of Naples who live by chance work or begging; -- so called from the Hospital of St.","pos":""}]}