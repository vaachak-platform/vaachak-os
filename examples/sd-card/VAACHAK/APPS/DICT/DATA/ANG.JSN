{"ANGARIATION":[{"def":"Exaction of forced service; compulsion.","pos":""},{"def":"Same as Angiology, Angiotomy, etc.","pos":""}],"ANGEL":[{"def":"An ancient gold coin of England, bearing the figure of the archangel Michael.","pos":""}],"ANGEL FISH":[{"def":"See under Angel.","pos":""}],"ANGELAGE":[{"def":"Existence or state of angels.","pos":""}],"ANGELET":[{"def":"A small gold coin formerly current in England; a half angel.","pos":""}],"ANGELHOOD":[{"def":"The state of being an angel; angelic nature.","pos":""},{"def":"Belonging to, or proceeding from, angels; resembling, characteristic of, or partaking of the nature of, an angel; heavenly; divine.","pos":""}],"ANGELIC":[{"def":"Of or derived from angelica; as, angelic acid; angelic ether.","pos":""}],"ANGELICA":[{"def":"An aromatic umbelliferous plant (Archangelica officinalis or Angelica archangelica) the leaf stalks of which are sometimes candied and used in confectionery, and the roots and seeds as an aromatic tonic.","pos":""},{"def":"The candied leaf stalks of angelica.","pos":""}],"ANGELICALNESS":[{"def":"The quality of being angelic; excellence more than human.","pos":""}],"ANGELIFY":[{"def":"To make like an angel; to angelize.","pos":""}],"ANGELIZE":[{"def":"To raise to the state of an angel; to render angelic.","pos":""}],"ANGELLIKE":[{"def":"Resembling an angel.","pos":""}],"ANGELOLATRY":[{"def":"Worship paid to angels.","pos":""}],"ANGELOLOGY":[{"def":"A discourse on angels, or a body of doctrines in regard to angels.","pos":""}],"ANGELOPHANY":[{"def":"The actual appearance of an angel to man.","pos":""}],"ANGELOT":[{"def":"A French gold coin of the reign of Louis XI.","pos":""},{"def":"An instrument of music, of the lute kind, now disused.","pos":""}],"ANGER":[{"def":"Trouble; vexation; also, physical pain or smart of a sore, etc.","pos":""},{"def":"A strong passion or emotion of displeasure or antagonism, excited by a real or supposed injury or insult to one's self or others, or by the intent to do such injury.","pos":""}],"ANGERLY":[{"def":"Why, how now, Hecate! you look angerly.","pos":""}],"ANGEVINE":[{"def":"Of or pertaining to Anjou in France.","pos":""}],"ANGIENCHYMA":[{"def":"Vascular tissue of plants, consisting of spiral vessels, dotted, barred, and pitted ducts, and laticiferous vessels.","pos":""}],"ANGINA":[{"def":"Any inflammatory affection of the throat or faces, as the quinsy, malignant sore throat, croup, etc.","pos":""},{"def":"Pertaining to angina or angina pectoris.","pos":""}],"ANGIO-":[{"def":"A prefix, or combining form, in numerous compounds, usually relating to seed or blood vessels, or to something contained in, or covered by, a vessel.","pos":""}],"ANGIOGRAPHY":[{"def":"A description of blood vessels and lymphatics.","pos":""}],"ANGIOLOGY":[{"def":"That part of anatomy which treats of blood vessels and lymphatics.","pos":""}],"ANGIOMA":[{"def":"A tumor composed chiefly of dilated blood vessels.","pos":""}],"ANGIOMONOSPERMOUS":[{"def":"Producing one seed only in a seed pod.","pos":""}],"ANGIONEUROSIS":[{"def":"Any disorder of the vasomotor system; neurosis of a blood vessel.","pos":""}],"ANGIOPATHY":[{"def":"Disease of the vessels, esp.","pos":""}],"ANGIOSCOPE":[{"def":"An instrument for examining the capillary vessels of animals and plants.","pos":""}],"ANGIOSPERM":[{"def":"A plant which has its seeds inclosed in a pericarp.","pos":""}],"ANGIOSPERMATOUS":[{"def":"Same as Angiospermous.","pos":""}],"ANGIOSPERMOUS":[{"def":"Having seeds inclosed in a pod or other pericarp.","pos":""}],"ANGIOSPOROUS":[{"def":"Having spores contained in cells or thecæ, as in the case of some fungi.","pos":""}],"ANGIOSTOMOUS":[{"def":"With a narrow mouth, as the shell of certain gastropods.","pos":""}],"ANGIOTOMY":[{"def":"Dissection of the blood vessels and lymphatics of the body.","pos":""}],"ANGLE":[{"def":"A name given to four of the twelve astrological \"houses.","pos":""},{"def":"A fishhook; tackle for catching fish, consisting of a line, hook, and bait, with or without a rod.","pos":""}],"ANGLE OF ENTRY":[{"def":"The angle between the tangent to the advancing edge (of an aërocurve) and the line of motion; -- contrasted with angle of trail, which is the angle between the tangent to the following edge and the line of motion.","pos":""}],"ANGLE OF INCIDENCE":[{"def":"The angle between the chord of an aërocurve and the relative direction of the undisturbed air current.","pos":""}],"ANGLED":[{"def":"Having an angle or angles; -- used in compounds; as, right- angled, many-angled, etc.","pos":""}],"ANGLEMETER":[{"def":"An instrument to measure angles, esp.","pos":""}],"ANGLER":[{"def":"A fish (Lophius piscatorius), of Europe and America, having a large, broad, and depressed head, with the mouth very large.","pos":""}],"ANGLES":[{"def":"An ancient Low German tribe, that settled in Britain, which came to be called Engla-land (Angleland or England).","pos":""}],"ANGLESITE":[{"def":"A native sulphate of lead.","pos":""}],"ANGLEWISE":[{"def":"In an angular manner; angularly.","pos":""}],"ANGLEWORM":[{"def":"A earthworm of the genus Lumbricus, frequently used by anglers for bait.","pos":""}],"ANGLIAN":[{"def":"Of or pertaining to the Angles.","pos":""},{"def":"One of the Angles.","pos":""}],"ANGLICAN":[{"def":"English; of or pertaining to England or the English nation; especially, pertaining to, or connected with, the established church of England; as, the Anglican church, doctrine, orders, ritual, etc.","pos":""},{"def":"Pertaining to, characteristic of, or held by, the high church party of the Church of England.","pos":""}],"ANGLICANISM":[{"def":"Strong partiality to the principles and rites of the Church of England.","pos":""},{"def":"The principles of the established church of England; also, in a restricted sense, the doctrines held by the high-church party.","pos":""}],"ANGLICE":[{"def":"In English; in the English manner; as, Livorno, Anglice Leghorn.","pos":""}],"ANGLICISM":[{"def":"An English idiom; a phrase or form language peculiar to the English.","pos":""},{"def":"The quality of being English; an English characteristic, custom, or method.","pos":""}],"ANGLICITY":[{"def":"The state or quality of being English.","pos":""}],"ANGLICIZATION":[{"def":"The act of anglicizing, or making English in character.","pos":""}],"ANGLICIZE":[{"def":"To make English; to English; to anglify; render conformable to the English idiom, or to English analogies.","pos":""}],"ANGLIFY":[{"def":"To convert into English; to anglicize.","pos":""}],"ANGLING":[{"def":"The act of one who angles; the art of fishing with rod and line.","pos":""}],"ANGLO-":[{"def":"A combining form meaning the same as English; or English and, or English conjoined with; as, Anglo-Turkish treaty, Anglo-German, Anglo-Irish.","pos":""}],"ANGLO-CATHOLIC":[{"def":"Of or pertaining to a church modeled on the English Reformation; Anglican; -- sometimes restricted to the ritualistic or High Church section of the Church of England.","pos":""}],"ANGLO-CATHOLICISM":[{"def":"The belief of those in the Church of England who accept many doctrines and practices which they maintain were those of the primitive, or true, Catholic Church, of which they consider the Church of England to be the lineal descendant.","pos":""}],"ANGLO-SAXON":[{"def":"The Teutonic people (Angles, Saxons, Jutes) of England, or the English people, collectively, before the Norman Conquest.","pos":""}],"ANGLO-SAXONDOM":[{"def":"The Anglo-Saxon domain (i.","pos":""}],"ANGLO-SAXONISM":[{"def":"A characteristic of the Anglo-Saxon race; especially, a word or an idiom of the Anglo-Saxon tongue.","pos":""},{"def":"The quality or sentiment of being Anglo-Saxon, or English in its ethnological sense.","pos":""}],"ANGLOMANIA":[{"def":"A mania for, or an inordinate attachment to, English customs, institutions, etc.","pos":""}],"ANGLOMANIAC":[{"def":"One affected with Anglomania.","pos":""}],"ANGLOPHOBIA":[{"def":"Intense dread of, or aversion to, England or the English.","pos":""}],"ANGOLA":[{"def":"A fabric made from the wool of the Angora goat.","pos":""}],"ANGOLA PEA":[{"def":"A tropical plant (Cajanus indicus) and its edible seed, a kind of pulse; -- so called from Angola in Western Africa.","pos":""}],"ANGOR":[{"def":"Great anxiety accompanied by painful constriction at the upper part of the belly, often with palpitation and oppression.","pos":""}],"ANGORA":[{"def":"A city of Asia Minor (or Anatolia) which has given its name to a goat, a cat, etc.","pos":""}],"ANGOSTURA BARK":[{"def":"An aromatic bark used as a tonic, obtained from a South American of the rue family (Galipea cusparia, or officinalis).","pos":""}],"ANGOUMOIS MOTH":[{"def":"A small moth (Gelechia cerealella) which is very destructive to wheat and other grain.","pos":""}],"ANGRILY":[{"def":"In an angry manner; under the influence of anger.","pos":""}],"ANGRINESS":[{"def":"The quality of being angry, or of being inclined to anger.","pos":""}],"ANGRY":[{"def":"Troublesome; vexatious; rigorous.","pos":""},{"def":"Inflamed and painful, as a sore.","pos":""}],"ANGUILLIFORM":[{"def":"Note: The \"Anguillæformes\" of Cuvier are fishes related to thee eel.","pos":""}],"ANGUINE":[{"def":"Of, pertaining to, or resembling, a snake or serpent.","pos":""}],"ANGUISH":[{"def":"Extreme pain, either of body or mind; excruciating distress.","pos":""}],"ANGULAR":[{"def":"Relating to an angle or to angles; having an angle or angles; forming an angle or corner; sharp-cornered; pointed; as, an angular figure.","pos":""},{"def":"Measured by an angle; as, angular distance.","pos":""}],"ANGULARITY":[{"def":"The quality or state of being angular; angularness.","pos":""}],"ANGULARLY":[{"def":"In an angular manner; with of at angles or corners.","pos":""}],"ANGULARNESS":[{"def":"The quality of being angular.","pos":""}],"ANGULATE":[{"def":"To make angular.","pos":""},{"def":"Having angles or corners; angled; as, angulate leaves.","pos":""}],"ANGULATION":[{"def":"A making angular; angular formation.","pos":""}],"ANGULO-DENTATE":[{"def":"Angularly toothed, as certain leaves.","pos":""}],"ANGULOMETER":[{"def":"An instrument for measuring external angles.","pos":""}],"ANGULOSITY":[{"def":"A state of being angulous or angular.","pos":""}],"ANGULOUS":[{"def":"Angular; having corners; hooked.","pos":""}],"ANGUSTATION":[{"def":"The act or making narrow; a straitening or contacting.","pos":""}],"ANGUSTICLAVE":[{"def":"A narrow stripe of purple worn by the equites on each side of the tunic as a sign of rank.","pos":""},{"def":"Having narrow leaves.","pos":""}],"ANGUSTURA BARK":[{"def":"See Angostura bark.","pos":""}],"ANGWANTIBO":[{"def":"A small lemuroid mammal (Arctocebus Calabarensis) of Africa.","pos":""}]}