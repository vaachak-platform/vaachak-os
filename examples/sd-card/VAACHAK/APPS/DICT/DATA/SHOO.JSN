{"SHOO":[{"def":"Begone; away; -- an expression used in frightening away animals, especially fowls.","pos":""}],"SHOOI":[{"def":"The Richardson's skua (Stercorarius parasiticus);- so called from its cry.","pos":""}],"SHOOK":[{"def":"To pack, as staves, in a shook.","pos":""}],"SHOON":[{"def":"They shook the snow from hats and shoon.","pos":""}],"SHOOT":[{"def":"An inclined plane, either artificial or natural, down which timber, coal, etc.","pos":""}],"SHOOTER":[{"def":"One who shoots, as an archer or a gunner.","pos":""},{"def":"That which shoots.","pos":""}],"SHOOTING":[{"def":"The act of one who, or that which, shoots; as, the shooting of an archery club; the shooting of rays of light.","pos":""},{"def":"A wounding or killing with a firearm; specifically (Sporting), the killing of game; as, a week of shooting.","pos":""}],"SHOOTY":[{"def":"Sprouting or coming up freely and regularly.","pos":""}]}