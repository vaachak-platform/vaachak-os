{"HAW":[{"def":"A hedge; an inclosed garden or yard.","pos":""},{"def":"The fruit of the hawthorn.","pos":""}],"HAWAIIAN":[{"def":"Belonging to Hawaii or the Sandwich Islands, or to the people of Hawaii.","pos":""},{"def":"A native of Hawaii.","pos":""}],"HAWEBAKE":[{"def":"Probably, the baked berry of the hawthorn tree, that is, coarse fare.","pos":""}],"HAWFINCH":[{"def":"The common European grosbeak (Coccothraustes vulgaris); -- called also cherry finch, and coble.","pos":""}],"HAWHAW":[{"def":"To laugh boisterously.","pos":""}],"HAWK":[{"def":"One of numerous species and genera of rapacious birds of the family Falconidæ.","pos":""}],"HAWK MOTH":[{"def":"Any moth of the family Sphingidæ, of which there are numerous genera and species.","pos":""}],"HAWK-EYED":[{"def":"Having a keen eye; sharpsighted; discerning.","pos":""}],"HAWKBILL":[{"def":"A sea turtle (Eretmochelys imbricata), which yields the best quality of tortoise shell; -- called also caret.","pos":""}],"HAWKBIT":[{"def":"The fall dandelion (Leontodon autumnale).","pos":""}],"HAWKED":[{"def":"Curved like a hawk's bill; crooked.","pos":""}],"HAWKER":[{"def":"One who sells wares by crying them in the street; hence, a peddler or a packman.","pos":""}],"HAWKEYE STATE":[{"def":"Iowa; -- a nickname of obscure origin.","pos":""}],"HAWM":[{"def":"See Haulm, straw.","pos":""}],"HAWSER":[{"def":"A large rope made of three strands each containing many yarns.","pos":""}],"HAWSER-LAID":[{"def":"Made in the manner of a hawser.","pos":""}],"HAWTHORN":[{"def":"A thorny shrub or tree (the Cratægus oxyacantha), having deeply lobed, shining leaves, small, roselike, fragrant flowers, and a fruit called haw.","pos":""}]}