{"UNRAVEL":[{"def":"To disentangle; to disengage or separate the threads of; as, to unravel a stocking.","pos":""},{"def":"Hence, to clear from complication or difficulty; to unfold; to solve; as, to unravel a plot.","pos":""}],"UNRAVELMENT":[{"def":"The act of unraveling, or the state of being unraveled.","pos":""}],"UNREAD":[{"def":"Not read or perused; as, an unread book.","pos":""},{"def":"Not versed in literature; illiterate.","pos":""}],"UNREADINESS":[{"def":"The quality or state of being unready.","pos":""}],"UNREADY":[{"def":"Not ready or prepared; not prompt; slow; awkward; clumsy.","pos":""},{"def":"Not dressed; undressed.","pos":""}],"UNREAL":[{"def":"Not real; unsubstantial; fanciful; ideal.","pos":""}],"UNREALITY":[{"def":"The quality or state of being unreal; want of reality.","pos":""}],"UNREALIZE":[{"def":"To make unreal; to idealize.","pos":""}],"UNREALLY":[{"def":"In an unreal manner; ideally.","pos":""}],"UNREASON":[{"def":"Want of reason; unreasonableness; absurdity.","pos":""}],"UNREASONABLE":[{"def":"Not reasonable; irrational; immoderate; exorbitant.","pos":""}],"UNREASONED":[{"def":"Not supported by reason; unreasonable.","pos":""}],"UNREAVE":[{"def":"To unwind; to disentangle; to loose.","pos":""}],"UNREAVED":[{"def":"Not torn, split, or parted; not torn to pieces.","pos":""}],"UNREBUKABLE":[{"def":"Not deserving rebuke or censure; blameless.","pos":""}],"UNREEVE":[{"def":"To withdraw, or take out, as a rope from a block, thimble, or the like.","pos":""}],"UNREFORMATION":[{"def":"Want of reformation; state of being unreformed.","pos":""}],"UNREGENERACY":[{"def":"The quality or state of being unregenerate.","pos":""},{"def":"Not regenerated; not renewed in heart; remaining or being at enmity with God.","pos":""}],"UNREGENERATION":[{"def":"Un`re*gen`er*a\"tion, n.","pos":""}],"UNREIN":[{"def":"To loosen the reins of; to remove restraint from.","pos":""}],"UNRELENTING":[{"def":"Not relenting; unyielding; rigid; hard; stern; cruel.","pos":""}],"UNRELIABLE":[{"def":"Not reliable; untrustworthy.","pos":""}],"UNREMEMBRANCE":[{"def":"Want of remembrance; forgetfulness.","pos":""}],"UNREMITTING":[{"def":"Not remitting; incessant; continued; persevering; as, unremitting exertions.","pos":""}],"UNREMORSELESS":[{"def":"Utterly remorseless.","pos":""}],"UNREPRIEVABLE":[{"def":"Not capable of being reprieved.","pos":""}],"UNREPROACHABLE":[{"def":"Not liable to be reproached; irreproachable.","pos":""}],"UNREPROVED":[{"def":"Not having incurred reproof, blameless.","pos":""}],"UNRESERVE":[{"def":"Absence of reverse; frankness; freedom of communication.","pos":""}],"UNRESERVED":[{"def":"Not reserved; not kept back; not withheld in part; unrestrained.","pos":""}],"UNRESISTANCE":[{"def":"Nonresistance; passive submission; irresistance.","pos":""}],"UNRESISTED":[{"def":"Not resisted; unopposed.","pos":""},{"def":"Resistless; as, unresisted fate.","pos":""}],"UNREST":[{"def":"Want of rest or repose; unquietness; sleeplessness; uneasiness; disquietude.","pos":""}],"UNRESTRAINT":[{"def":"Freedom from restraint; freedom; liberty; license.","pos":""}],"UNRESTY":[{"def":"Causing unrest; disquieting; as, unresty sorrows.","pos":""}],"UNREVENUED":[{"def":"Not furnished with a revenue.","pos":""}],"UNREVERENCE":[{"def":"Absence or lack of reverence; irreverence.","pos":""}],"UNREVEREND":[{"def":"Disrespectful; irreverent.","pos":""}],"UNREVERENTLY":[{"def":"Un*rev\"er*ent*ly, adv.","pos":""}],"UNRIDDLE":[{"def":"To read the riddle of; to solve or explain; as, to unriddle an enigma or a mystery.","pos":""}],"UNRIDDLER":[{"def":"One who unriddles.","pos":""}],"UNRIG":[{"def":"To strip of rigging; as, to unrig a ship.","pos":""}],"UNRIGHT":[{"def":"Not right; wrong.","pos":""}],"UNRIGHTEOUS":[{"def":"Not righteous; evil; wicked; sinful; as, an unrighteous man.","pos":""},{"def":"Contrary to law and equity; unjust; as, an unrighteous decree or sentence.","pos":""}],"UNRINGED":[{"def":"Not having a ring, as in the nose.","pos":""}],"UNRIOTED":[{"def":"Free from rioting.","pos":""}],"UNRIP":[{"def":"To rip; to cut open.","pos":""}],"UNRIPE":[{"def":"Not ripe; as, unripe fruit.","pos":""},{"def":"Developing too early; premature.","pos":""}],"UNRIPENESS":[{"def":"Quality or state of being unripe.","pos":""}],"UNRIVALED":[{"def":"Having no rival; without a competitor; peerless.","pos":""}],"UNRIVET":[{"def":"To take out, or loose, the rivets of; as, to unrivet boiler plates.","pos":""}],"UNROBE":[{"def":"To disrobe; to undress; to take off the robes.","pos":""}],"UNROLL":[{"def":"To open, as what is rolled or convolved; as, to unroll cloth; to unroll a banner.","pos":""},{"def":"To display; to reveal.","pos":""}],"UNROOF":[{"def":"To strip off the roof or covering of, as a house.","pos":""}],"UNROOFED":[{"def":"Stripped of a roof, or similar covering.","pos":""}],"UNROOST":[{"def":"To drive from the roost.","pos":""}],"UNROOT":[{"def":"To tear up by the roots; to eradicate; to uproot.","pos":""}],"UNRUDE":[{"def":"Not rude; polished.","pos":""},{"def":"Excessively rude.","pos":""}],"UNRUFFLE":[{"def":"To cease from being ruffled or agitated.","pos":""}],"UNRUFFLED":[{"def":"Not ruffled or agitated; smooth; calm; tranquil; quiet.","pos":""},{"def":"Not ruined or destroyed.","pos":""}],"UNRULED":[{"def":"Not governed or controlled.","pos":""},{"def":"Not ruled or marked with lines; as, unruled paper.","pos":""}],"UNRULINESS":[{"def":"Quality or state unruly.","pos":""}],"UNRULY":[{"def":"Not submissive to rule; disregarding restraint; disposed to violate; turbulent; ungovernable; refractory; as, an unruly boy; unruly boy; unruly conduct.","pos":""}]}