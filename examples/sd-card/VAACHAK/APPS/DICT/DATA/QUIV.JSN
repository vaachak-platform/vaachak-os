{"QUIVER":[{"def":"To shake or move with slight and tremulous motion; to tremble; to quake; to shudder; to shiver.","pos":""}],"QUIVERED":[{"def":"Furnished with, or carrying, a quiver.","pos":""},{"def":"Sheathed, as in a quiver.","pos":""}],"QUIVERINGLY":[{"def":"With quivering motion.","pos":""}]}