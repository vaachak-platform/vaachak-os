{"MIAMIS":[{"def":"A tribe of Indians that formerly occupied the country between the Wabash and Maumee rivers.","pos":""}],"MIARGYRITE":[{"def":"A mineral of an iron-black color, and very sectile, consisting principally of sulphur, antimony, and silver.","pos":""}],"MIAS":[{"def":"The orang-outang.","pos":""}],"MIASCITE":[{"def":"A granitoid rock containing feldspar, biotite, elæolite, and sodalite.","pos":""}],"MIASMA":[{"def":"Infectious particles or germs floating in the air; air made noxious by the presence of such particles or germs; noxious effluvia; malaria.","pos":""}],"MIASMAL":[{"def":"Containing miasma; miasmatic.","pos":""},{"def":"Containing, or relating to, miasma; caused by miasma; as, miasmatic diseases.","pos":""}],"MIASMATIST":[{"def":"One who has made a special study of miasma.","pos":""}],"MIASMOLOGY":[{"def":"That department of medical science which treats of miasma.","pos":""}],"MIAUL":[{"def":"To cry as a cat; to mew; to caterwaul.","pos":""}]}