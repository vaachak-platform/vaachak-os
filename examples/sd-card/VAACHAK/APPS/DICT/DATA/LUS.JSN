{"LUSCIOUS":[{"def":"Sweet; delicious; very grateful to the taste; toothsome; excessively sweet or rich.","pos":""},{"def":"Cloying; fulsome.","pos":""}],"LUSH":[{"def":"Full of juice or succulence.","pos":""}],"LUSHBURG":[{"def":"See Lussheburgh.","pos":""}],"LUSITANIAN":[{"def":"Pertaining to Lusitania, the ancient name of the region almost coinciding with Portugal.","pos":""},{"def":"One of the people of Lusitania.","pos":""}],"LUSK":[{"def":"A lazy fellow; a lubber.","pos":""}],"LUSKISH":[{"def":"Inclined to be lazy.","pos":""},{"def":"Used in play; sportive; playful.","pos":""}],"LUSSHEBURGH":[{"def":"A spurious coin of light weight imported into England from Luxemburg, or Lussheburgh, as it was formerly called.","pos":""}],"LUST":[{"def":"Inclination; desire.","pos":""}],"LUSTER":[{"def":"A period of five years; a lustrum.","pos":""}],"LUSTERING":[{"def":"Destitute of luster; dim; dull.","pos":""}],"LUSTFUL":[{"def":"Full of lust; excited by lust Spenser.","pos":""},{"def":"Exciting lust; characterized by lust or sensuality.","pos":""}],"LUSTIC":[{"def":"Lusty; vigorous.","pos":""}],"LUSTIHOOD":[{"def":"State of being lusty; vigor of body.","pos":""}],"LUSTILY":[{"def":"In a lusty or vigorous manner.","pos":""}],"LUSTINESS":[{"def":"State of being lusty; vigor; strength.","pos":""}],"LUSTLESS":[{"def":"Lacking vigor; weak; spiritless.","pos":""},{"def":"Free from sexual lust.","pos":""}],"LUSTRAL":[{"def":"Of or pertaining to, or used for, purification; as, lustral days; lustral water.","pos":""},{"def":"Of or pertaining to a lustrum.","pos":""}],"LUSTRATE":[{"def":"To make clear or pure by means of a propitiatory offering; to purify.","pos":""}],"LUSTRATION":[{"def":"A sacrifice, or ceremony, by which cities, fields, armies, or people, defiled by crimes, pestilence, or other cause of uncleanness, were purified.","pos":""}],"LUSTRICAL":[{"def":"Pertaining to, or used for, purification.","pos":""}],"LUSTRING":[{"def":"A kind of glossy silk fabric.","pos":""}],"LUSTROUS":[{"def":"Bright; shining; luminous.","pos":""}],"LUSTRUM":[{"def":"A lustration or purification, especially the purification of the whole Roman people, which was made by the censors once in five years.","pos":""}],"LUSTY":[{"def":"Exhibiting lust or vigor; stout; strong; vigorous; robust; healthful; able of body.","pos":""},{"def":"Beautiful; handsome; pleasant.","pos":""}],"LUSUS NATURAE":[{"def":"Sport or freak of nature; a deformed or unnatural production.","pos":""}]}