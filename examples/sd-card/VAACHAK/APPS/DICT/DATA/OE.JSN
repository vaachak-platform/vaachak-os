{"OE":[{"def":"a diphthong, employed in the Latin language, and thence in the English language, as the representative of the Greek diphthong oe.","pos":""}],"OECOID":[{"def":"The colorless porous framework, or stroma, of red blood corpuscles from which the zooid, or hemoglobin and other substances of the corpuscles, may be dissolved out.","pos":""}],"OECOLOGY":[{"def":"The various relations of animals and plants to one another and to the outer world.","pos":""}],"OEDEMA":[{"def":"A swelling from effusion of watery fluid in the cellular tissue beneath the skin or mucous membrance; dropsy of the subcutaneous cellular tissue.","pos":""}],"OEDEMATOUS":[{"def":"Pertaining to, or of the nature of, edema; affected with edema.","pos":""}],"OEIL-DE-BOEUF":[{"def":"A circular or oval window; -- generally used of architecture of the 17th and 18th centuries.","pos":""}],"OEIL-DE-PERDRIX":[{"def":"A glance of the eye; an amorous look.","pos":""}],"OELET":[{"def":"An eye, bud, or shoot, as of a plant; an oilet.","pos":""}],"OENANTHATE":[{"def":"A salt of the supposed oenanthic acid.","pos":""}],"OENANTHIC":[{"def":"Having, or imparting, the odor characteristic of the bouquet of wine; specifically used, formerly, to designate an acid whose ethereal salts were supposed to occasion the peculiar bouquet, or aroma, of old wine.","pos":""}],"OENANTHOL":[{"def":"An oily substance obtained by the distillation of castor oil, recognized as the aldehyde of oenanthylic acid, and hence called also oenanthaldehyde.","pos":""}],"OENANTHONE":[{"def":"The ketone of oenanthic acid.","pos":""}],"OENANTHYL":[{"def":"A hydrocarbon radical formerly supposed to exist in oenanthic acid, now known to be identical with heptyl.","pos":""}],"OENANTHYLATE":[{"def":"A salt of oenanthylic acid; as, potassium oenanthylate.","pos":""}],"OENANTHYLIC":[{"def":"Pertaining to, derived from, or containing, oenanthyl; specifically, designating an acid formerly supposed to be identical with the acid in oenanthic ether, but now known to be identical with heptoic acid.","pos":""}],"OENANTHYLIDENE":[{"def":"A colorless liquid hydrocarbon, having a garlic odor; heptine.","pos":""}],"OENANTHYLOUS":[{"def":"Of, pertaining to, or designating, an acid formerly supposed to be the acid of oenanthylic ether, but now known to be a mixture of higher acids, especially capric acid.","pos":""}],"OENOCYAN":[{"def":"The coloring matter of red wines.","pos":""}],"OENOLOGY":[{"def":"Knowledge of wine, scientific or practical.","pos":""}],"OENOMEL":[{"def":"Wine mixed with honey; mead, [R.","pos":""}],"OENOMETER":[{"def":"See Alcoholometer.","pos":""}],"OENOPHILIST":[{"def":"A lover of wine.","pos":""}],"OENOTHIONIC":[{"def":"Pertaining to an acid now called sulphovinic, or ethyl sulphuric, acid.","pos":""}],"OERSTED":[{"def":"Same as Esophagus, Esophageal, etc.","pos":""}],"OESTRIAN":[{"def":"Of or pertaining to the gadflies.","pos":""}],"OESTRUAL":[{"def":"Of or pertaining to sexual desire; -- mostly applied to brute animals; as, the oestrual period; oestrual influence.","pos":""}],"OESTRUATION":[{"def":"The state of being under oestrual influence, or of having sexual desire.","pos":""}],"OESTRUS":[{"def":"A genus of gadflies.","pos":""}]}