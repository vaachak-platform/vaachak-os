{"HARVEST":[{"def":"The gathering of a crop of any kind; the ingathering of the crops; also, the season of gathering grain and fruits, late summer or early autumn.","pos":""},{"def":"That which is reaped or ready to be reaped or gath Put ye in the sickle, for the harvest is ripe.","pos":""}],"HARVEST-HOME":[{"def":"The gathering and bringing home of the harvest; the time of harvest.","pos":""},{"def":"The song sung by reapers at the feast made at the close of the harvest; the feast itself.","pos":""}],"HARVESTER":[{"def":"A harvesting ant.","pos":""}],"HARVESTING":[{"def":", from Harvest, v.","pos":""}],"HARVESTLESS":[{"def":"Without harvest; lacking in crops; barren.","pos":""}],"HARVESTMAN":[{"def":"See Daddy longlegs, 1.","pos":""}],"HARVESTRY":[{"def":"The act of harvesting; also, that which is harvested.","pos":""}],"HARVEY PROCESS":[{"def":"A process of hardening the face of steel, as armor plates, invented by Hayward A.","pos":""}]}