{"OUTLABOR":[{"def":"To surpass in laboring.","pos":""}],"OUTLAND":[{"def":"Foreign; outlandish.","pos":""}],"OUTLANDISH":[{"def":"Foreign; not native.","pos":""},{"def":"Hence: Not according with usage; strange; rude; barbarous; uncouth; clownish; as, an outlandish dress, behavior, or speech.","pos":""}],"OUTLAST":[{"def":"To exceed in duration; to survive; to endure longer than.","pos":""}],"OUTLAUGH":[{"def":"To surpass or outdo in laughing.","pos":""},{"def":"To laugh (one) out of a purpose, principle, etc.","pos":""}],"OUTLAW":[{"def":"A person excluded from the benefit of the law, or deprived of its protection.","pos":""}],"OUTLAWRY":[{"def":"The act of outlawing; the putting a man out of the protection of law, or the process by which a man (as an absconding criminal) is deprived of that protection.","pos":""},{"def":"The state of being an outlaw.","pos":""}],"OUTLAY":[{"def":"To lay out; to spread out; to display.","pos":""}],"OUTLEAP":[{"def":"To surpass in leaping.","pos":""}],"OUTLEARN":[{"def":"To excel or surpass in learing.","pos":""},{"def":"To learn out [i.","pos":""}],"OUTLET":[{"def":"The place or opening by which anything is let out; a passage out; an exit; a vent.","pos":""}],"OUTLIE":[{"def":"To exceed in lying.","pos":""}],"OUTLIER":[{"def":"A part of a rock or stratum lying without, or beyond, the main body, from which it has been separated by denudation.","pos":""}],"OUTLIMB":[{"def":", An extreme member or part of a thing; a limb.","pos":""}],"OUTLINE":[{"def":"Painters, by their outlines, colors, lights, and shadows, represent the same in their pictures.","pos":""}],"OUTLINEAR":[{"def":"Of or pertaining to an outline; being in, or forming, an outline.","pos":""}],"OUTLIVE":[{"def":"To live beyond, or longer than; to survive.","pos":""}],"OUTLIVER":[{"def":"One who outlives.","pos":""}],"OUTLOOK":[{"def":"To face down; to outstare.","pos":""},{"def":"To inspect throughly; to select.","pos":""}],"OUTLOOSE":[{"def":"A loosing from; an escape; an outlet; an evasion.","pos":""}],"OUTLOPE":[{"def":"To excel in brightness or luster.","pos":""}],"OUTLYING":[{"def":"Lying or being at a distance from the central part, or the main body; being on, or beyond, the frontier; exterior; remote; detached.","pos":""},{"def":"To surpass, or get an advantage of, in maneuvering; to outgeneral.","pos":""}]}