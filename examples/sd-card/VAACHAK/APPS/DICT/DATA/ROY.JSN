{"ROYAL":[{"def":"Kingly; pertaining to the crown or the sovereign; suitable for a king or queen; regal; as, royal power or prerogative; royal domains; the royal family; royal state.","pos":""},{"def":"Noble; generous; magnificent; princely.","pos":""}],"ROYAL SPADE":[{"def":"A spade when spades are trumps under the condition that every trick over six taken by the successful bidder has a score value of 9; -- usually in pl.","pos":""}],"ROYALET":[{"def":"A petty or powerless king.","pos":""}],"ROYALISM":[{"def":"the principles or conduct of royalists.","pos":""}],"ROYALIST":[{"def":"An adherent of a king (as of Charles I.","pos":""}],"ROYALIZATION":[{"def":"The act of making loyal to a king.","pos":""}],"ROYALLY":[{"def":"In a royal or kingly manner; like a king; as becomes a king.","pos":""}],"ROYALTY":[{"def":"The state of being royal; the condition or quality of a royal person; kingship; kingly office; sovereignty.","pos":""},{"def":"The person of a king or sovereign; majesty; as, in the presence of royalty.","pos":""}],"ROYNE":[{"def":"To bite; to gnaw.","pos":""}],"ROYNISH":[{"def":"Mangy; scabby; hence, mean; paltry; troublesome.","pos":""},{"def":"same as Roister, Roisterer.","pos":""}],"ROYSTON CROW":[{"def":"See Hooded crow, under Hooded.","pos":""}],"ROYTISH":[{"def":"Wild; irregular.","pos":""}]}