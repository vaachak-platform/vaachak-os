{"DISCIDE":[{"def":"To divide; to cleave in two.","pos":""}],"DISCIFEROUS":[{"def":"Bearing the stamens on a discoid outgrowth of the receptacle; - - said of a subclass of plants.","pos":""}],"DISCINA":[{"def":"A genus of Branchiopoda, having a disklike shell, attached by one valve, which is perforated by the peduncle.","pos":""}],"DISCINCT":[{"def":"Ungirded; loosely dressed.","pos":""}],"DISCIND":[{"def":"To part; to divide.","pos":""}],"DISCIPLE":[{"def":"One who receives instruction from another; a scholar; a learner; especially, a follower who has learned to believe in the truth of the doctrine of his teacher; an adherent in doctrine; as, the disciples of Plato; the disciples of our Savior.","pos":""}],"DISCIPLESHIP":[{"def":"The state of being a disciple or follower in doctrines and precepts.","pos":""}],"DISCIPLESS":[{"def":"A female disciple.","pos":""}],"DISCIPLINABLE":[{"def":"Capable of being disciplined or improved by instruction and training.","pos":""},{"def":"Liable or deserving to be disciplined; subject to disciplinary punishment; as, a disciplinable offense.","pos":""}],"DISCIPLINABLENESS":[{"def":"The quality of being improvable by discipline.","pos":""}],"DISCIPLINAL":[{"def":"Relating to discipline.","pos":""}],"DISCIPLINARIAN":[{"def":"Pertaining to discipline.","pos":""}],"DISCIPLINARY":[{"def":"Pertaining to discipline; intended for discipline; corrective; belonging to a course of training.","pos":""}],"DISCIPLINE":[{"def":"The enforcement of methods of correction against one guilty of ecclesiastical offenses; reformatory or penal action toward a church member.","pos":""},{"def":"Self- inflicted and voluntary corporal punishment, as penance, or otherwise; specifically, a penitential scourge.","pos":""}],"DISCIPLINER":[{"def":"One who disciplines.","pos":""}]}