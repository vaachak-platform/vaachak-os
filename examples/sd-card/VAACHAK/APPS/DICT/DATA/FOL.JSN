{"FOLD":[{"def":"To lap or lay in plaits or folds; to lay one part over another part of; to double; as, to fold cloth; to fold a letter.","pos":""},{"def":"To double or lay together, as the arms or the hands; as, he folds his arms in despair.","pos":""}],"FOLDER":[{"def":"One who, or that which, folds; esp.","pos":""}],"FOLDING":[{"def":"The keepig of sheep in inclosures on arable land, etc.","pos":""}],"FOLIACEOUS":[{"def":"Belonging to, or having the texture or nature of, a leaf; having leaves intermixed with flowers; as, a foliaceous spike.","pos":""},{"def":"Consisting of leaves or thin laminæ; having the form of a leaf or plate; as, foliaceous spar.","pos":""}],"FOLIAGE":[{"def":"Leaves, collectively, as produced or arranged by nature; leafage; as, a tree or forest of beautiful foliage.","pos":""},{"def":"A cluster of leaves, flowers, and branches; especially, the representation of leaves, flowers, and branches, in architecture, intended to ornament and enrich capitals, friezes, pediments, etc.","pos":""}],"FOLIAGED":[{"def":"Furnished with foliage; leaved; as, the variously foliaged mulberry.","pos":""}],"FOLIAR":[{"def":"Consisting of, or pertaining to, leaves; as, foliar appendages.","pos":""}],"FOLIATE":[{"def":"Furnished with leaves; leafy; as, a foliate stalk.","pos":""}],"FOLIATED":[{"def":"Containing, or consisting of, foils; as, a foliated arch.","pos":""},{"def":"Characterized by being separable into thin plates or folia; as, graphite has a foliated structure.","pos":""}],"FOLIATION":[{"def":"The enrichment of an opening by means of foils, arranged in trefoils, quatrefoils, etc.","pos":""},{"def":"The property, possessed by some crystalline rocks, of dividing into plates or slabs, which is due to the cleavage structure of one of the constituents, as mica or hornblende.","pos":""}],"FOLIATURE":[{"def":"The state of being beaten into foil.","pos":""}],"FOLIER":[{"def":"Goldsmith's foil.","pos":""}],"FOLIFEROUS":[{"def":"Producing leaves.","pos":""}],"FOLIO":[{"def":"The page number.","pos":""},{"def":"A leaf containing a certain number of words, hence, a certain number of words in a writing, as in England, in law proceedings 72, and in chancery, 90; in New York, 100 words.","pos":""}],"FOLIOLATE":[{"def":"Of or pertaining to leaflets; -- used in composition; as, bi- foliolate.","pos":""}],"FOLIOLE":[{"def":"One of the distinct parts of a compound leaf; a leaflet.","pos":""}],"FOLIOMORT":[{"def":"See Feuillemort.","pos":""}],"FOLIOSE":[{"def":"Having many leaves; leafy.","pos":""}],"FOLIOSITY":[{"def":"The ponderousness or bulk of a folio; voluminousness.","pos":""}],"FOLIOUS":[{"def":"Like a leaf; thin; unsubstantial.","pos":""}],"FOLIUM":[{"def":"A curve of the third order, consisting of two infinite branches, which have a common asymptote.","pos":""},{"def":"In Anglo-Saxon times, the people of a group of townships or villages; a community; a tribe.","pos":""}],"FOLKETHING":[{"def":"The lower house of the Danish Rigsdag, or Parliament.","pos":""}],"FOLKLAND":[{"def":"Land held in villenage, being distributed among the folk, or people, at the pleasure of the lord of the manor, and resumed at his discretion.","pos":""}],"FOLKMOTE":[{"def":"An assembly of the people; esp.","pos":""},{"def":"a general assembly of the people to consider and order matters of the commonwealth; also, a local court.","pos":""}],"FOLKMOTER":[{"def":"One who takes part in a folkmote, or local court.","pos":""}],"FOLLICLE":[{"def":"A simple podlike pericarp which contains several seeds and opens along the inner or ventral suture, as in the peony, larkspur and milkweed.","pos":""}],"FOLLICULAR":[{"def":"Affecting the follicles; as, follicular pharyngitis.","pos":""}],"FOLLICULATED":[{"def":"Having follicles.","pos":""}],"FOLLICULOUS":[{"def":"Having or producing follicles.","pos":""}],"FOLLOW":[{"def":"To go or come after; to move behind in the same path or direction; hence, to go with (a leader, guide, etc.","pos":""},{"def":"To endeavor to overtake; to go in pursuit of; to chase; to pursue; to prosecute.","pos":""}],"FOLLOWER":[{"def":"The part of a machine that receives motion from another part.","pos":""}],"FOLLOWING":[{"def":"One's followers, adherents, or dependents, collectively.","pos":""},{"def":"Vocation; business; profession.","pos":""}],"FOLLOWING EDGE":[{"def":"See Advancing-edge, above.","pos":""}],"FOLLOWING SURFACE":[{"def":"See Advancing-surface, above.","pos":""}],"FOLLY":[{"def":"The state of being foolish; want of good sense; levity, weakness, or derangement of mind.","pos":""},{"def":"A foolish act; an inconsiderate or thoughtless procedure; weak or light-minded conduct; foolery.","pos":""}]}