{"MANDAMUS":[{"def":"A writ issued by a superior court and directed to some inferior tribunal, or to some corporation or person exercising authority, commanding the performance of some specified duty.","pos":""}],"MANDARIN":[{"def":"A small orange, with easily separable rind.","pos":""}],"MANDARINATE":[{"def":"The collective body of officials or persons of rank in China.","pos":""}],"MANDARINIC":[{"def":"Appropriate or peculiar to a mandarin.","pos":""}],"MANDARINING":[{"def":"The process of giving an orange color to goods formed of animal tissue, as silk or wool, not by coloring matter, but by producing a certain change in the fiber by the action of dilute nitric acid.","pos":""}],"MANDARINISM":[{"def":"A government mandarins; character or spirit of the mandarins.","pos":""}],"MANDATARY":[{"def":"One who undertakes to discharge a specific business commission; a mandatory.","pos":""}],"MANDATE":[{"def":"A rescript of the pope, commanding an ordinary collator to put the person therein named in possession of the first vacant benefice in his collation.","pos":""},{"def":"A contract by which one employs another to manage any business for him.","pos":""}],"MANDATOR":[{"def":"The person who employs another to perform a mandate.","pos":""}],"MANDATORY":[{"def":"Containing a command; preceptive; directory.","pos":""}],"MANDELATE":[{"def":"A salt of mandelic acid.","pos":""}],"MANDELIC":[{"def":"Pertaining to an acid first obtained from benzoic aldehyde (oil of better almonds), as a white crystalline substance; -- called also phenyl glycolic acid.","pos":""}],"MANDIBLE":[{"def":"The bone, or principal bone, of the lower jaw; the inferior maxilla; -- also applied to either the upper or the lower jaw in the beak of birds.","pos":""},{"def":"The anterior pair of mouth organs of insects, crustaceaus, and related animals, whether adapted for biting or not.","pos":""}],"MANDIBULAR":[{"def":"Of or pertaining to a mandible; like a mandible.","pos":""},{"def":"The principal mandibular bone; the mandible.","pos":""}],"MANDIBULATE":[{"def":"An insect having mandibles.","pos":""}],"MANDIBULIFORM":[{"def":"Having the form of a mandible; -- said especially of the maxillæ of an insect when hard and adapted for biting.","pos":""}],"MANDIBULOHYOID":[{"def":"Pertaining both to the mandibular and the hyoid arch, or situated between them.","pos":""}],"MANDIL":[{"def":"A loose outer garment worn the 16th and 17th centuries.","pos":""}],"MANDINGOS":[{"def":"MANDIOC; MANDIOCA Man\"di*oc, Man`di*o\"ca, n.","pos":""}],"MANDOLA":[{"def":"An instrument closely resembling the mandolin, but of larger size and tuned lower.","pos":""},{"def":"A small and beautifully shaped instrument resembling the lute.","pos":""}],"MANDORE":[{"def":"A kind of four-stringed lute.","pos":""}],"MANDRAGORA":[{"def":"A genus of plants; the mandrake.","pos":""}],"MANDRAGORITE":[{"def":"One who habitually intoxicates himself with a narcotic obtained from mandrake.","pos":""}],"MANDRAKE":[{"def":"A low plant (Mandragora officinarum) of the Nightshade family, having a fleshy root, often forked, and supposed to resemble a man.","pos":""},{"def":"The May apple (Podophyllum peltatum).","pos":""}],"MANDRILL":[{"def":"a large West African baboon (Cynocephalus, or Papio, mormon).","pos":""}],"MANDUCABLE":[{"def":"Such as can be chewed; fit to be eaten.","pos":""}],"MANDUCATE":[{"def":"To masticate; to chew; to eat.","pos":""}],"MANDUCATION":[{"def":"The act of chewing.","pos":""}],"MANDUCATORY":[{"def":"Pertaining to, or employed in, chewing.","pos":""}],"MANDUCUS":[{"def":"A grotesque mask, representing a person chewing or grimacing, worn in processions and by comic actors on the stage.","pos":""}]}