{"FIX":[{"def":"Fixed; solidified.","pos":""}],"FIXABLE":[{"def":"Capable of being fixed.","pos":""}],"FIXATION":[{"def":"The act of fixing, or the state of being fixed.","pos":""},{"def":"The act of uniting chemically with a solid substance or in a solid form; reduction to a non-volatile condition; -- said of gaseous elements.","pos":""}],"FIXATIVE":[{"def":"That which serves to set or fix colors or drawings, as a mordant.","pos":""}],"FIXED":[{"def":"Stable; non-volatile.","pos":""}],"FIXEDLY":[{"def":"In a fixed, stable, or constant manner.","pos":""}],"FIXEDNESS":[{"def":"The state or quality of being fixed; stability; steadfastness.","pos":""},{"def":"The quality of a body which resists evaporation or volatilization by heat; solidity; cohesion of parts; as, the fixedness of gold.","pos":""}],"FIXING":[{"def":"Arrangements; embellishments; trimmings; accompaniments.","pos":""}],"FIXITY":[{"def":"Fixedness; as, fixity of tenure; also, that which is fixed.","pos":""},{"def":"Coherence of parts.","pos":""}],"FIXTURE":[{"def":"Anything of an accessory character annexed to houses and lands, so as to constitute a part of them.","pos":""}],"FIXURE":[{"def":"Fixed position; stable condition; firmness.","pos":""}]}