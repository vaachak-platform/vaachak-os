{"PLEXIFORM":[{"def":"Like network; complicated.","pos":""}],"PLEXIMETER":[{"def":"A small, hard, elastic plate, as of ivory, bone, or rubber, placed in contact with body to receive the blow, in examination by mediate percussion.","pos":""}],"PLEXURE":[{"def":"The act or process of weaving together, or interweaving; that which is woven together.","pos":""}],"PLEXUS":[{"def":"A network of vessels, nerves, or fibers.","pos":""},{"def":"The system of equations required for the complete expression of the relations which exist between a set of quantities.","pos":""}]}