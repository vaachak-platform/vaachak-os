{"RUD":[{"def":"Ruddle; red ocher.","pos":""}],"RUDBECKIA":[{"def":"A genus of composite plants, the coneflowers, consisting of perennial herbs with showy pedunculate heads, having a hemispherical involucre, sterile ray flowers, and a conical chaffy receptacle.","pos":""}],"RUDD":[{"def":"A fresh-water European fish of the Carp family (Leuciscus erythrophthalmus).","pos":""}],"RUDDER":[{"def":"A riddle or sieve.","pos":""}],"RUDDERHEAD":[{"def":"The upper end of the rudderpost, to which the tiller is attashed.","pos":""}],"RUDDERHOLE":[{"def":"The hole in the deck through which the rudderpost passes.","pos":""}],"RUDDERLESS":[{"def":"Without a rudder.","pos":""}],"RUDDERPOST":[{"def":"The shank of a rudder, having the blade at one end and the attachments for operating it at the other.","pos":""}],"RUDDERSTOCK":[{"def":"The main part or blade of the rudder, which is connected by hinges, or the like, with the sternpost of a vessel.","pos":""}],"RUDDIED":[{"def":"Made ruddy or red.","pos":""}],"RUDDILY":[{"def":"In a ruddy manner.","pos":""}],"RUDDINESS":[{"def":"The quality or state of being ruddy; as, the ruddiness of the cheeks or the sky.","pos":""}],"RUDDLE":[{"def":"To raddle or twist.","pos":""}],"RUDDOCK":[{"def":"The European robin.","pos":""}],"RUDDY":[{"def":"Of a red color; red, or reddish; as, a ruddy sky; a ruddy flame.","pos":""},{"def":"Of a lively flesh color, or the color of the human skin in high health; as, ruddy cheeks or lips.","pos":""}],"RUDE":[{"def":"Characterized by roughness; umpolished; raw; lacking delicacy or refinement; coarse.","pos":""},{"def":"Hence, specifically: (a) Unformed by taste or skill; not nicely finished; not smoothed or polished; -- said especially of material things; as, rude workmanship.","pos":""}],"RUDERARY":[{"def":"Of or pertaining to rubbish.","pos":""}],"RUDESBY":[{"def":"An uncivil, turbulent fellow.","pos":""},{"def":"A German wine made near Rüdesheim, on the Rhine.","pos":""}],"RUDIMENT":[{"def":"An imperfect organ or part, or one which is never developed.","pos":""}],"RUDIMENTARY":[{"def":"Very imperfectly developed; in an early stage of development; embryonic.","pos":""}],"RUDISTES":[{"def":"An extinct order or suborder of bivalve mollusks characteristic of the Cretaceous period; -- called also Rudista.","pos":""}],"RUDITY":[{"def":"Rudeness; ignorance.","pos":""}],"RUDMASDAY":[{"def":"Either of the feasts of the Holy Cross, occuring on May 3 and September 14, annually.","pos":""}],"RUDOLPHINE":[{"def":"Pertaining to, or designating, a set of astronomical tables computed by Kepler, and founded on the observations of Tycho Brahe; - - so named from Rudolph II.","pos":""}]}