{"CALVARIA":[{"def":"The bones of the cranium; more especially, the bones of the domelike upper portion.","pos":""}],"CALVARY":[{"def":"A cross, set upon three steps; -- more properly called cross calvary.","pos":""}],"CALVE":[{"def":"To bring forth a calf.","pos":""},{"def":"To bring forth young; to produce offspring.","pos":""}],"CALVER":[{"def":"To cut in slices and pickle, as salmon.","pos":""},{"def":"To crimp; as, calvered salmon.","pos":""}],"CALVINISM":[{"def":"The theological tenets or doctrines of John Calvin (a French theologian and reformer of the 16th century) and his followers, or of the so-called calvinistic churches.","pos":""}],"CALVINIST":[{"def":"A follower of Calvin; a believer in Calvinism.","pos":""},{"def":"Of or pertaining to Calvin, or Calvinism; following Calvin; accepting or Teaching Calvinism.","pos":""}],"CALVINIZE":[{"def":"To convert to Calvinism.","pos":""}],"CALVISH":[{"def":"Like a calf; stupid.","pos":""}]}