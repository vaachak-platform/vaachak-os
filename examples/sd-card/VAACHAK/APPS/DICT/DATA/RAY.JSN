{"RAY":[{"def":"To mark, stain, or soil; to streak; to defile.","pos":""}],"RAY GRASS":[{"def":"A perennial European grass (Lolium perenne); -- called also rye grass, and red darnel.","pos":""}],"RAYAH":[{"def":"A person not a Mohammedan, who pays the capitation tax.","pos":""}],"RAYLESS":[{"def":"Destitute of rays; hence, dark; not illuminated; blind; as, a rayless sky; rayless eyes.","pos":""}],"RAYONNANT":[{"def":"Darting forth rays, as the sun when it shines out.","pos":""}]}