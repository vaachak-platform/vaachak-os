{"ARM":[{"def":"The limb of the human body which extends from the shoulder to the hand; also, the corresponding limb of a monkey.","pos":""},{"def":"Anything resembling an arm; as, (a) The fore limb of an animal, as of a bear.","pos":""}],"ARM-GRET":[{"def":"Great as a man's arm.","pos":""}],"ARMADA":[{"def":"A fleet of armed ships; a squadron.","pos":""}],"ARMADILLO":[{"def":"The body and head are incased in an armor composed of small bony plates.","pos":""}],"ARMAMENT":[{"def":"All the cannon and small arms collectively, with their equipments, belonging to a ship or a fortification.","pos":""}],"ARMAMENTARY":[{"def":"An armory; a magazine or arsenal.","pos":""}],"ARMATURE":[{"def":"A piece of soft iron used to connect the two poles of a magnet, or electro-magnet, in order to complete the circuit, or to receive and apply the magnetic force.","pos":""},{"def":"Iron bars or framing employed for the consolidation of a building, as in sustaining slender columns, holding up canopies, etc.","pos":""}],"ARMCHAIR":[{"def":"A chair with arms to support the elbows or forearms.","pos":""}],"ARMED":[{"def":"Having horns, beak, talons, etc; -- said of beasts and birds of prey.","pos":""}],"ARMENIAN":[{"def":"Of or pertaining to Armenia.","pos":""}],"ARMET":[{"def":"A kind of helmet worn in the 14th, 15th, and 16th centuries.","pos":""}],"ARMFUL":[{"def":"As much as the arm can hold.","pos":""}],"ARMGAUNT":[{"def":"With gaunt or slender legs.","pos":""}],"ARMHOLE":[{"def":"The cavity under the shoulder; the armpit.","pos":""},{"def":"A hole for the arm in a garment.","pos":""}],"ARMIFEROUS":[{"def":"Bearing arms or weapons.","pos":""}],"ARMIGER":[{"def":"Formerly, an armor bearer, as of a knight, an esquire who bore his shield and rendered other services.","pos":""}],"ARMIGEROUS":[{"def":"They belonged to the armigerous part of the population, and were entitled to write themselves Esquire.","pos":""}],"ARMIL":[{"def":"An ancient astronomical instrument.","pos":""}],"ARMILLA":[{"def":"A ring of hair or feathers on the legs.","pos":""}],"ARMILLARY":[{"def":"Pertaining to, or resembling, a bracelet or ring; consisting of rings or circles.","pos":""}],"ARMING":[{"def":"A piece of tallow placed in a cavity at the lower end of a sounding lead, to bring up the sand, shells, etc.","pos":""},{"def":"Red dress cloths formerly hung fore and aft outside of a ship's upper works on holidays.","pos":""}],"ARMINIAN":[{"def":"Of or pertaining to Arminius of his followers, or to their doctrines.","pos":""}],"ARMINIANISM":[{"def":"The religious doctrines or tenets of the Arminians.","pos":""}],"ARMIPOTENT":[{"def":"Powerful in arms; mighty in battle.","pos":""},{"def":"Rustling in arms; resounding with arms.","pos":""}],"ARMISTICE":[{"def":"A cessation of arms for a short time, by convention; a temporary suspension of hostilities by agreement; a truce.","pos":""}],"ARMLESS":[{"def":"Without any arm or branch.","pos":""},{"def":"Destitute of arms or weapons.","pos":""}],"ARMLET":[{"def":"A small arm; as, an armlet of the sea.","pos":""},{"def":"An arm ring; a bracelet for the upper arm.","pos":""}],"ARMOR":[{"def":"Defensive arms for the body; any clothing or covering worn to protect one's person in battle.","pos":""},{"def":"Steel or iron covering, whether of ships or forts, protecting them from the fire of artillery.","pos":""}],"ARMOR-BEARER":[{"def":"One who carries the armor or arms of another; an armiger.","pos":""}],"ARMOR-PLATED":[{"def":"Covered with defensive plates of metal, as a ship of war; steel-clad.","pos":""}],"ARMORED":[{"def":"Clad with armor.","pos":""}],"ARMORED CRUISER":[{"def":"A man-of-war carrying a large coal supply, and more or less protected from the enemy's shot by iron or steel armor.","pos":""}],"ARMORER":[{"def":"One who makes or repairs armor or arms.","pos":""},{"def":"Formerly, one who had care of the arms and armor of a knight, and who dressed him in armor.","pos":""}],"ARMORIAL":[{"def":"Belonging to armor, or to the heraldic arms or escutcheon of a family.","pos":""},{"def":"Of or pertaining to the northwestern part of France (formerly called Armorica, now Bretagne or Brittany), or to its people.","pos":""}],"ARMORICAN":[{"def":"A native of Armorica.","pos":""}],"ARMORIST":[{"def":"One skilled in coat armor or heraldry.","pos":""}],"ARMORY":[{"def":"A thick plain silk, generally black, and used for clerical.","pos":""}],"ARMPIT":[{"def":"The hollow beneath the junction of the arm and shoulder; the axilla.","pos":""}],"ARMRACK":[{"def":"A frame, generally vertical, for holding small arms.","pos":""}],"ARMS":[{"def":"Anything which a man takes in his hand in anger, to strike or assault another with; an aggressive weapon.","pos":""},{"def":"The ensigns armorial of a family, consisting of figures and colors borne in shields, banners, etc.","pos":""}],"ARMURE":[{"def":"A variety of twilled fabric ribbed on the surface.","pos":""}],"ARMY":[{"def":"A collection or body of men armed for war, esp.","pos":""},{"def":"A body of persons organized for the advancement of a cause; as, the Blue Ribbon Army.","pos":""}],"ARMY ORGANIZATION":[{"def":"The system by which a country raises, classifies, arranges, and equips its armed land forces.","pos":""}],"ARMY WORM":[{"def":"The wild buffalo of India (Bos, or Bubalus, arni), larger than the domestic buffalo and having enormous horns.","pos":""}]}