{"OUSEL":[{"def":"One of several species of European thrushes, especially the blackbird (Merula merula, or Turdus merula), and the mountain or ring ousel (Turdus torquatus).","pos":""}],"OUST":[{"def":"To take away; to remove.","pos":""},{"def":"To eject; to turn out.","pos":""}],"OUSTER":[{"def":"A putting out of possession; dispossession; ejection; disseizin.","pos":""}]}