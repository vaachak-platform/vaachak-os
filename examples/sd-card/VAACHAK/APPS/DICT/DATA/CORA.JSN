{"CORA":[{"def":"The Arabian gazelle (Gazella Arabica), found from persia to North Africa.","pos":""}],"CORACLE":[{"def":"A boat made by covering a wicker frame with leather or oilcloth.","pos":""}],"CORACOID":[{"def":"Pertaining to a bone of the shoulder girdle in most birds, reptiles, and amphibians, which is reduced to a process of the scapula in most mammals.","pos":""}],"CORAGE":[{"def":"See Courage [Obs.","pos":""}],"CORAH":[{"def":"Plain; undyed; -- applied to Indian silk.","pos":""}],"CORAL":[{"def":"The hard parts or skeleton of various Anthozoa, and of a few Hydrozoa.","pos":""}],"CORAL FISH":[{"def":"Any bright-colored fish of the genera Chætodon, Pomacentrus, Apogon, and related genera, which live among reef corals.","pos":""}],"CORAL-RAG":[{"def":"Same as Corallian.","pos":""}],"CORALED":[{"def":"Having coral; covered with coral.","pos":""}],"CORALLACEOUS":[{"def":"Like coral, or partaking of its qualities.","pos":""}],"CORALLIAN":[{"def":"A deposit of coralliferous limestone forming a portion of the middle division of the oölite; -- called also coral-rag.","pos":""}],"CORALLIFEROUS":[{"def":"Containing or producing coral.","pos":""}],"CORALLIFORM":[{"def":"resembling coral in form.","pos":""}],"CORALLIGENA":[{"def":"Same as Anthozoa.","pos":""}],"CORALLIGENOUS":[{"def":"producing coral; coraligerous; coralliferous.","pos":""}],"CORALLIGEROUS":[{"def":"Producing coral; coraliferous.","pos":""}],"CORALLIN":[{"def":"A yellow coal-tar dyestuff which probably consists chiefly of rosolic acid.","pos":""}],"CORALLINE":[{"def":"Composed of corallines; as, coralline limestone.","pos":""}],"CORALLINITE":[{"def":"A fossil coralline.","pos":""}],"CORALLITE":[{"def":"A mineral substance or petrifaction, in the form of coral.","pos":""},{"def":"One of the individual members of a compound coral; or that part formed by a single coral animal.","pos":""}],"CORALLOID":[{"def":"Having the form of coral; branching like coral.","pos":""}],"CORALLOIDAL":[{"def":"resembling coral; coralloid.","pos":""}],"CORALLUM":[{"def":"The coral or skeleton of a zoöphyte, whether calcareous of horny, simple or compound.","pos":""}],"CORALWORT":[{"def":"A cruciferous herb of certain species of Dentaria; -- called also toothwort, tooth violet, or pepper root.","pos":""}],"CORANACH":[{"def":"A lamentation for the dead; a dirge.","pos":""},{"def":"A sprightly but somewhat stately dance, now out of fashion.","pos":""}]}