{"CONFAB":[{"def":"Familiar talk or conversation.","pos":""}],"CONFABULATE":[{"def":"To talk familiarly together; to chat; to prattle.","pos":""}],"CONFABULATION":[{"def":"Familiar talk; easy, unrestrained, unceremonious conversation.","pos":""}],"CONFABULATORY":[{"def":"Of the nature of familiar talk; in the form of a dialogue.","pos":""}],"CONFALON":[{"def":"One of a fraternity of seculars, also called Penitents.","pos":""}],"CONFARREATION":[{"def":"A form of marriage among the Romans, in which an offering of bread was made, in presence of the high priest and at least ten witnesses.","pos":""}],"CONFATED":[{"def":"Fated or decreed with something else.","pos":""}]}