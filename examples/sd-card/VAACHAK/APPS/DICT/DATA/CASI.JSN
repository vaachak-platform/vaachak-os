{"CASING":[{"def":"The act or process of inclosing in, or covering with, a case or thin substance, as plaster, boards, etc.","pos":""},{"def":"An outside covering, for protection or ornament, or to precent the radiation of heat.","pos":""}],"CASINGS":[{"def":"Dried dung of cattle used as fuel.","pos":""}],"CASINO":[{"def":"A small country house.","pos":""},{"def":"A building or room used for meetings, or public amusements, for dancing, gaming, etc.","pos":""}]}