{"HARRAGE":[{"def":"To harass; to plunder from.","pos":""}],"HARRIDAN":[{"def":"A worn-out strumpet; a vixenish woman; a hag.","pos":""}],"HARRIER":[{"def":"One of a small breed of hounds, used for hunting hares.","pos":""}],"HARROW":[{"def":"An obstacle formed by turning an ordinary harrow upside down, the frame being buried.","pos":""}],"HARROWER":[{"def":"One who harrows.","pos":""}],"HARRY":[{"def":"To strip; to lay waste; as, the Northmen came several times and harried the land.","pos":""},{"def":"To agitate; to worry; to harrow; to harass.","pos":""}]}