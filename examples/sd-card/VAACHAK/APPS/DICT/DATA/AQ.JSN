{"AQUA":[{"def":"Water; -- a word much used in pharmacy and the old chemistry, in various signification, determined by the word or words annexed.","pos":""}],"AQUAMARINE":[{"def":"A transparent, pale green variety of beryl, used as a gem.","pos":""}],"AQUAPUNCTURE":[{"def":"The introduction of water subcutaneously for the relief of pain.","pos":""}],"AQUARELLE":[{"def":"A design or painting in thin transparent water colors; also, the mode of painting in such colors.","pos":""}],"AQUARELLIST":[{"def":"A painter in thin transparent water colors.","pos":""},{"def":"Of or pertaining to an aquarium.","pos":""}],"AQUARIAN":[{"def":"One of a sect of Christian in the primitive church who used water instead of wine in the Lord's Supper.","pos":""}],"AQUARIUM":[{"def":"An artificial pond, or a globe or tank (usually with glass sides), in which living specimens of aquatic animals or plants are kept.","pos":""}],"AQUATIC":[{"def":"Pertaining to water growing in water; living in, swimming in, or frequenting the margins of waters; as, aquatic plants and fowls.","pos":""}],"AQUATILE":[{"def":"Inhabiting the water.","pos":""},{"def":"A kind of etching in which spaces are bitten by the use of aqua fortis, by which an effect is produced resembling a drawing in water colors or India ink; also, the engraving produced by this method.","pos":""}],"AQUEDUCT":[{"def":"A canal or passage; as, the aqueduct of Sylvius, a channel connecting the third and fourth ventricles of the brain.","pos":""}],"AQUEOUS":[{"def":"Partaking of the nature of water, or abounding with it; watery.","pos":""},{"def":"Made from, or by means of, water.","pos":""}],"AQUIFEROUS":[{"def":"Consisting or conveying water or a watery fluid; as, aquiferous vessels; the aquiferous system.","pos":""}],"AQUIFORM":[{"def":"Having the form of water.","pos":""}],"AQUILA":[{"def":"A genus of eagles.","pos":""},{"def":"A northern constellation southerly from Lyra and Cygnus and preceding the Dolphin; the Eagle.","pos":""}],"AQUILATED":[{"def":"Adorned with eagles' heads.","pos":""}],"AQUILINE":[{"def":"Belonging to or like an eagle.","pos":""},{"def":"Curving; hooked; prominent, like the beak of an eagle; -- applied particularly to the nose Terribly arched and aquiline his nose.","pos":""}],"AQUIPAROUS":[{"def":"Secreting water; -- applied to certain glands.","pos":""}],"AQUITANIAN":[{"def":"Of or pertaining to Aquitania, now called Gascony.","pos":""}],"AQUOSE":[{"def":"Watery; aqueous.","pos":""}],"AQUOSITY":[{"def":"The condition of being wet or watery; wateriness.","pos":""}]}