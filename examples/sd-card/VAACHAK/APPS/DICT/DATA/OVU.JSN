{"OVULAR":[{"def":"Relating or belonging to an ovule; as, an ovular growth.","pos":""}],"OVULARY":[{"def":"Pertaining to ovules.","pos":""}],"OVULATE":[{"def":"Containing an ovule or ovules.","pos":""}],"OVULATION":[{"def":"The formation of ova or eggs in the ovary, and the discharge of the same.","pos":""}],"OVULIFEROUS":[{"def":"Producing ovules.","pos":""}],"OVUM":[{"def":"A more or less spherical and transparent mass of granular protoplasm, which by a process of multiplication and growth develops into a mass of cells, constituting a new individual like the parent; an egg, spore, germ, or germ cell.","pos":""},{"def":"One of the series of egg-shaped ornaments into which the ovolo is often carved.","pos":""}]}