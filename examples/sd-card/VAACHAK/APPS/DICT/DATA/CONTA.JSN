{"CONTABESCENT":[{"def":"Wasting away gradually.","pos":""}],"CONTACT":[{"def":"The property of two curves, or surfaces, which meet, and at the point of meeting have a common direction.","pos":""},{"def":"The plane between two adjacent bodies of dissimilar rock.","pos":""}],"CONTACTION":[{"def":"Act of touching.","pos":""}],"CONTAGION":[{"def":"The transmission of a disease from one person to another, by direct or indirect contact.","pos":""}],"CONTAGIONED":[{"def":"Affected by contagion.","pos":""}],"CONTAGIONIST":[{"def":"One who believes in the contagious character of certain diseases, as of yellow fever.","pos":""}],"CONTAGIOUS":[{"def":"Communicable by contact, by a virus, or by a bodily exhalation; catching; as, a contagious disease.","pos":""}],"CONTAGIOUS DISEASE":[{"def":"A disease communicable by contact with a patient suffering from it, or with some secretion of, or object touched by, such a patient.","pos":""}],"CONTAGIOUSLY":[{"def":"In a contagious manner.","pos":""}],"CONTAGIOUSNESS":[{"def":"Quality of being contagious.","pos":""}],"CONTAGIUM":[{"def":"Contagion; contagious matter.","pos":""}],"CONTAIN":[{"def":"To hold within fixed limits; to comprise; to include; to inclose; to hold.","pos":""},{"def":"To have capacity for; to be able to hold; to hold; to be equivalent to; as, a bushel contains four pecks.","pos":""}],"CONTAINABLE":[{"def":"Capable of being contained or comprised.","pos":""}],"CONTAINER":[{"def":"One who, or that which, contains.","pos":""}],"CONTAINMENT":[{"def":"That which is contained; the extent; the substance.","pos":""}],"CONTAMINABLE":[{"def":"Capable of being contaminated.","pos":""}],"CONTAMINATE":[{"def":"To soil, stain, or corrupt by contact; to tarnish; to sully; to taint; to pollute; to defile.","pos":""}],"CONTAMINATION":[{"def":"The act or process of contaminating; pollution; defilement; taint; also, that which contaminates.","pos":""}],"CONTAMITIVE":[{"def":"Tending or liable to contaminate.","pos":""}],"CONTANGO":[{"def":"The premium or interest paid by the buyer to the seller, to be allowed to defer paying for the stock purchased until the next fortnightly settlement day.","pos":""},{"def":"The postponement of payment by the buyer of stock on the payment of a premium to the seller.","pos":""}]}