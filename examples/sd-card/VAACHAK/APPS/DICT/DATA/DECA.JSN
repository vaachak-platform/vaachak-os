{"DECA-":[{"def":"A prefix, from Gr.","pos":""}],"DECACERATA":[{"def":"The division of Cephalopoda which includes the squids, cuttlefishes, and others having ten arms or tentacles; -- called also Decapoda.","pos":""}],"DECACUMINATED":[{"def":"Having the point or top cut off.","pos":""}],"DECAD":[{"def":"Averill was a decad and a half his elder.","pos":""}],"DECADAL":[{"def":"Pertaining to ten; consisting of tens.","pos":""}],"DECADE":[{"def":"A group or division of ten; esp.","pos":""},{"def":"A falling away; decay; deterioration; declension.","pos":""}],"DECADENT":[{"def":"Decaying; deteriorating.","pos":""}],"DECADIST":[{"def":"A writer of a book divided into decades; as, Livy was a decadist.","pos":""}],"DECAGON":[{"def":"A plane figure having ten sides and ten angles; any figure having ten angles.","pos":""}],"DECAGONAL":[{"def":"Pertaining to a decagon; having ten sides.","pos":""},{"def":"A weight of the metric system; ten grams, equal to about 154.","pos":""}],"DECAGYNIA":[{"def":"A Linnæan order of plants characterized by having ten styles.","pos":""},{"def":"Belonging to the Decagynia; having ten styles.","pos":""}],"DECAHEDRAL":[{"def":"Having ten sides.","pos":""}],"DECAHEDRON":[{"def":"A solid figure or body inclosed by ten plane surfaces.","pos":""}],"DECALCIFICATION":[{"def":"The removal of calcareous matter.","pos":""}],"DECALCIFY":[{"def":"To deprive of calcareous matter; thus, to decalcify bones is to remove the stony part, and leave only the gelatin.","pos":""},{"def":"The art or process of transferring pictures and designs to china, glass, marble, etc.","pos":""}],"DECALOGIST":[{"def":"One who explains the decalogue.","pos":""}],"DECALOGUE":[{"def":"The Ten Commandments or precepts given by God to Moses on Mount Sinai, and originally written on two tables of stone.","pos":""}],"DECAMERON":[{"def":"A celebrated collection of tales, supposed to be related in ten days; -- written in the 14th century, by Boccaccio, an Italian.","pos":""},{"def":"A measure of length in the metric system; ten meters, equal to about 393.","pos":""}],"DECAMP":[{"def":"To break up a camp; to move away from a camping ground, usually by night or secretly.","pos":""},{"def":"Hence, to depart suddenly; to run away; -- generally used disparagingly.","pos":""}],"DECAMPMENT":[{"def":"Departure from a camp; a marching off.","pos":""}],"DECANAL":[{"def":"Pertaining to a dean or deanery.","pos":""}],"DECANDRIA":[{"def":"A Linnæan class of plants characterized by having ten stamens.","pos":""},{"def":"Belonging to the Decandria; having ten stamens.","pos":""}],"DECANE":[{"def":"A liquid hydrocarbon, C10H22, of the paraffin series, including several isomeric modifications.","pos":""}],"DECANGULAR":[{"def":"Having ten angles.","pos":""}],"DECANI":[{"def":"Used of the side of the choir on which the dean's stall is placed; decanal; -- correlative to cantoris; as, the decanal, or decani, side.","pos":""}],"DECANT":[{"def":"To pour off gently, as liquor, so as not to disturb the sediment; or to pour from one vessel into another; as, to decant wine.","pos":""}],"DECANTATION":[{"def":"The act of pouring off a clear liquor gently from its lees or sediment, or from one vessel into another.","pos":""}],"DECANTER":[{"def":"A vessel used to decant liquors, or for receiving decanted liquors; a kind of glass bottle used for holding wine or other liquors, from which drinking glasses are filled.","pos":""},{"def":"One who decants liquors.","pos":""}],"DECAPHYLLOUS":[{"def":"Having ten leaves.","pos":""}],"DECAPITATE":[{"def":"To cut off the head of; to behead.","pos":""},{"def":"To remove summarily from office.","pos":""}],"DECAPITATION":[{"def":"The act of beheading; beheading.","pos":""}],"DECAPOD":[{"def":"A crustacean with ten feet or legs, as a crab; one of the Decapoda.","pos":""}],"DECAPODA":[{"def":"The order of Crustacea which includes the shrimps, lobsters, crabs, etc.","pos":""},{"def":"A division of the dibranchiate cephalopods including the cuttlefishes and squids.","pos":""}],"DECARBONATE":[{"def":"To deprive of carbonic acid.","pos":""}],"DECARBONIZATION":[{"def":"The action or process of depriving a substance of carbon.","pos":""}],"DECARBONIZE":[{"def":"To deprive of carbon; as, to decarbonize steel; to decarbonize the blood.","pos":""}],"DECARBONIZER":[{"def":"He who, or that which, decarbonizes a substance.","pos":""}],"DECARBURIZATION":[{"def":"The act, process, or result of decarburizing.","pos":""}],"DECARBURIZE":[{"def":"To deprive of carbon; to remove the carbon from.","pos":""}],"DECARD":[{"def":"You have cast those by, decarded them.","pos":""}],"DECARDINALIZE":[{"def":"To depose from the rank of cardinal.","pos":""}],"DECASTERE":[{"def":"A measure of capacity, equal to ten steres, or ten cubic meters.","pos":""}],"DECASTICH":[{"def":"A poem consisting of ten lines.","pos":""}],"DECASTYLE":[{"def":"Having ten columns in front; -- said of a portico, temple, etc.","pos":""},{"def":"A portico having ten pillars or columns in front.","pos":""}],"DECASYLLABIC":[{"def":"Having, or consisting of, ten syllables.","pos":""}],"DECATHLON":[{"def":"In the modern Olympic Games, a composite contest consisting of a 100-meter run, a broad jump, putting the shot, a running high-jump, a 400-meter run, throwing the discus, a 100-meter hurdle race, pole vaulting, throwing the javelin, and a 1500-meter run.","pos":""}],"DECATOIC":[{"def":"Pertaining to, or derived from, decane.","pos":""}],"DECAY":[{"def":"To pass gradually from a sound, prosperous, or perfect state, to one of imperfection, adversity, or dissolution; to waste away; to decline; to fail; to become weak, corrupt, or disintegrated; to rot; to perish; as, a tree decays; fortunes decay; hopes decay.","pos":""}],"DECAYED":[{"def":"Fallen, as to physical or social condition; affected with decay; rotten; as, decayed vegetation or vegetables; a decayed fortune or gentleman.","pos":""}],"DECAYER":[{"def":"A causer of decay.","pos":""}]}