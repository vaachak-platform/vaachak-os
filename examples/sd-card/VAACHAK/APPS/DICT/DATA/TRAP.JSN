{"TRAP":[{"def":"To dress with ornaments; to adorn; -- said especially of horses.","pos":""}],"TRAP SHOOTING":[{"def":"Shooting at pigeons liberated, or glass balls or clay pigeons sprung into the air, from a trap.","pos":""}],"TRAPAN":[{"def":"A snare; a stratagem; a trepan.","pos":""}],"TRAPANNER":[{"def":"One who trapans, or insnares.","pos":""}],"TRAPBALL":[{"def":"An old game of ball played with a trap.","pos":""}],"TRAPDOOR":[{"def":"A lifting or sliding door covering an opening in a roof or floor.","pos":""},{"def":"A door in a level for regulating the ventilating current; -- called also weather door.","pos":""}],"TRAPE":[{"def":"To walk or run about in an idle or slatternly manner; to traipse.","pos":""}],"TRAPES":[{"def":"A slattern; an idle, sluttish, or untidy woman.","pos":""}],"TRAPEZATE":[{"def":"Having the form of a trapezium; trapeziform.","pos":""}],"TRAPEZE":[{"def":"A swinging horizontal bar, suspended at each end by a rope; -- used by gymnasts.","pos":""}],"TRAPEZIFORM":[{"def":"Having the form of a trapezium; trapezoid.","pos":""}],"TRAPEZIUM":[{"def":"A plane figure bounded by four right lines, of which no two are parallel.","pos":""}],"TRAPEZOHEDRAL":[{"def":"Of, pertaining to, or resembling, a trapezohedron.","pos":""}],"TRAPEZOID":[{"def":"A plane four-sided figure, having two sides parallel to each other.","pos":""},{"def":"A bone of the carpus at the base of the second metacarpal, or index finger.","pos":""}],"TRAPEZOIDAL":[{"def":"Having the form of a trapezoid; trapezoid.","pos":""}],"TRAPHOLE":[{"def":"See Trou-de-loup.","pos":""}],"TRAPPEAN":[{"def":"Of or pertaining to trap; being of the nature of trap.","pos":""}],"TRAPPER":[{"def":"A boy who opens and shuts a trapdoor in a gallery or level.","pos":""}],"TRAPPINGS":[{"def":"That which serves to trap or adorn; ornaments; dress; superficial decorations.","pos":""},{"def":"Specifically, ornaments to be put on horses.","pos":""}],"TRAPPIST":[{"def":"A monk belonging to a branch of the Cistercian Order, which was established by Armand de Rancé in 1660 at the monastery of La Trappe in Normandy.","pos":""}],"TRAPPOUS":[{"def":"Of or performance to trap; resembling trap, or partaking of its form or qualities; trappy.","pos":""}],"TRAPPURES":[{"def":"Trappings for a horse.","pos":""}],"TRAPPY":[{"def":"Same as Trappous.","pos":""}],"TRAPS":[{"def":"Small or portable articles for dress, furniture, or use; goods; luggage; things.","pos":""}],"TRAPSTICK":[{"def":"A stick used in playing the game of trapball; hence, fig.","pos":""}]}