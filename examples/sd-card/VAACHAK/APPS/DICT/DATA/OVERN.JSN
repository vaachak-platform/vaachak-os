{"OVERNAME":[{"def":"To name over or in a series; to recount.","pos":""}],"OVERNEAT":[{"def":"Excessively neat.","pos":""}],"OVERNICE":[{"def":"Excessively nice; fastidious.","pos":""}],"OVERNIGHT":[{"def":"The fore part of the night last past; the previous evening.","pos":""}],"OVERNOISE":[{"def":"To overpower by noise.","pos":""}],"OVERNUMEROUS":[{"def":"Excessively numerous; too many.","pos":""}]}