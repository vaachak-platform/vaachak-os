{"NEW":[{"def":"Having existed, or having been made, but a short time; having originated or occured lately; having recently come into existence, or into one's possession; not early or long in being; of late origin; recent; fresh; modern; -- opposed to old, as, a new coat; a new house; a new book; a new fashion.","pos":""},{"def":"Not before seen or known, although existing before; lately manifested; recently discovered; as, a new metal; a new planet; new scenes.","pos":""}],"NEW THOUGHT":[{"def":"Any form of belief in mental healing other than (1) Christian Science and (2) hypnotism or psychotherapy.","pos":""}],"NEW YEAR'S DAY":[{"def":"the first day of a calendar year; the first day of January.","pos":""}],"NEW ZEALAND":[{"def":"A group of islands in the South Pacific Ocean.","pos":""}],"NEW-YEAR":[{"def":"Of or pertaining to, or suitable for, the commencement of the year; as, New-year gifts or odes.","pos":""}],"NEWCOMER":[{"def":"One who has lately come.","pos":""}],"NEWEL":[{"def":"A novelty; a new thing.","pos":""}],"NEWFANGLE":[{"def":"Eager for novelties; desirous of changing.","pos":""}],"NEWFANGLED":[{"def":"Newmade; formed with the affectation of novelty.","pos":""},{"def":"Disposed to change; inclined to novelties; given to new theories or fashions.","pos":""}],"NEWFANGLEDNESS":[{"def":"Affectation of, or fondness for, novelty; vain or affected fashion or form.","pos":""}],"NEWFANGLENESS":[{"def":"Proud newfangleness in their apparel.","pos":""}],"NEWFANGLIST":[{"def":"One who is eager for novelties or desirous of change.","pos":""}],"NEWFANGLY":[{"def":"In a newfangled manner; with eagerness for novelty.","pos":""}],"NEWFASHIONED":[{"def":"Made in a new form, or lately come into fashion.","pos":""}],"NEWFOUNDLAND":[{"def":"An island on the coast of British North America, famed for the fishing grounds in its vicinity.","pos":""},{"def":"A Newfoundland dog.","pos":""}],"NEWISH":[{"def":"Somewhat new; nearly new.","pos":""}],"NEWLY":[{"def":"Lately; recently.","pos":""},{"def":"Anew; afresh; freshly.","pos":""}],"NEWMARKET":[{"def":"A long, closely fitting cloak.","pos":""}],"NEWNESS":[{"def":"The quality or state of being new; as, the newness of a system; the newness of a scene; newness of life.","pos":""}],"NEWS":[{"def":"A report of recent occurences; information of something that has lately taken place, or of something before unknown; fresh tindings; recent intelligence.","pos":""},{"def":"Something strange or newly happened.","pos":""}],"NEWS-LETTER":[{"def":"A circular letter, written or printed for the purpose of disseminating news.","pos":""}],"NEWS-VNDER":[{"def":"A seller of newspapers.","pos":""}],"NEWS-WRITER":[{"def":"One who gathered news for, and wrote, news-letters.","pos":""}],"NEWSBOY":[{"def":"A boy who distributes or sells newspaper.","pos":""}],"NEWSMAN":[{"def":"One who brings news.","pos":""},{"def":"A man who distributes or sells newspapers.","pos":""}],"NEWSMONGER":[{"def":"One who deals in news; one who is active in hearing and telling news.","pos":""}],"NEWSPAPER":[{"def":"A sheet of paper printed and distributed, at stated intervals, for conveying intelligence of passing events, advocating opinions, etc.","pos":""}],"NEWSROOM":[{"def":"A room where news is collected and disseminated, or periodicals sold; a reading room supplied with newspapers, magazines, etc.","pos":""}],"NEWSY":[{"def":"Full of news; abounding in information as to current events.","pos":""}],"NEWT":[{"def":"Any one of several species of small aquatic salamanders.","pos":""}],"NEWTONIAN":[{"def":"Of or pertaining to Sir Isaac Newton, or his discoveries.","pos":""}]}