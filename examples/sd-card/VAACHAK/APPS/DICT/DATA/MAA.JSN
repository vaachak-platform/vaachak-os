{"MAA":[{"def":"The common European gull (Larus canus); -- called also mar.","pos":""}],"MAARA SHELL":[{"def":"A large, pearly, spiral, marine shell (Turbo margaritaceus), from the Pacific Islands.","pos":""}],"MAASHA":[{"def":"An East Indian coin, of about one tenth of the weight of a rupee.","pos":""}],"MAAT":[{"def":"Dejected; sorrowful; downcast.","pos":""}]}