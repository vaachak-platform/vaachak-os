{"FOSSA":[{"def":"A pit, groove, cavity, or depression, of greater or less depth; as, the temporal fossa on the side of the skull; the nasal fossæ containing the nostrils in most birds.","pos":""}],"FOSSANE":[{"def":"A species of civet (Viverra fossa) resembling the genet.","pos":""}],"FOSSE":[{"def":"A ditch or moat.","pos":""}],"FOSSETTE":[{"def":"A small, deep-centered ulcer of the transparent cornea.","pos":""}],"FOSSEWAY":[{"def":"One of the great military roads constructed by the Romans in England and other parts of Europe; -- so called from the fosse or ditch on each side for keeping it dry.","pos":""}],"FOSSICK":[{"def":"To search for gold by picking at stone or earth or among roots in isolated spots, picking over abandoned workings, etc.","pos":""}],"FOSSIL":[{"def":"Like or pertaining to fossils; contained in rocks.","pos":""}],"FOSSILIFEROUS":[{"def":"Containing or composed of fossils.","pos":""}],"FOSSILIFICATION":[{"def":"The process of becoming fossil.","pos":""}],"FOSSILISM":[{"def":"The science or state of fossils.","pos":""},{"def":"The state of being extremely antiquated in views and opinions.","pos":""}],"FOSSILIST":[{"def":"One who is versed in the science of fossils; a paleontologist.","pos":""}],"FOSSILIZATION":[{"def":"The process of converting, or of being converted, into a fossil.","pos":""}],"FOSSILIZE":[{"def":"To convert into a fossil; to petrify; as, to fossilize bones or wood.","pos":""},{"def":"To cause to become antiquated, rigid, or fixed, as by fossilization; to mummify; to deaden.","pos":""}],"FOSSILIZED":[{"def":"Converted into a fossil; antiquated; firmly fixed in views or opinions.","pos":""}],"FOSSORES":[{"def":"A group of hymenopterous insects including the sand wasps.","pos":""}],"FOSSORIAL":[{"def":"Fitted for digging, adapted for burrowing or digging; as, a fossorial foot; a fossorial animal.","pos":""}],"FOSSORIOUS":[{"def":"Adapted for digging; -- said of the legs of certain insects.","pos":""}],"FOSSULATE":[{"def":"Having, or surrounded by, long, narrow depressions or furrows.","pos":""}],"FOSTER":[{"def":"To feed; to nourish; to support; to bring up.","pos":""},{"def":"To cherish; to promote the growth of; to encourage; to sustain and promote; as, to foster genius.","pos":""}],"FOSTERAGE":[{"def":"The care of a foster child; the charge of nursing.","pos":""}],"FOSTERER":[{"def":"One who, or that which, fosters.","pos":""}],"FOSTERMENT":[{"def":"Food; nourishment.","pos":""}],"FOSTRESS":[{"def":"A woman who feeds and cherishes; a nurse.","pos":""}]}