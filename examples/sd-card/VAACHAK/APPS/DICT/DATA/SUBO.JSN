{"SUBOBSCURELY":[{"def":"Somewhat obscurely or darkly.","pos":""}],"SUBOBTUSE":[{"def":"Partially obtuse.","pos":""}],"SUBOCCIPITAL":[{"def":"Situated under, or posterior to, the occiput; as, the suboccipital, or first cervical, nerve.","pos":""},{"def":"Containing one part of eight; having the ratio of one to eight.","pos":""}],"SUBOCULAR":[{"def":"Situated under, or on the ventral side of, the eye.","pos":""}],"SUBOFFICER":[{"def":"An under or subordinate officer.","pos":""}],"SUBOPERCULAR":[{"def":"Situated below the operculum; pertaining to the suboperculum.","pos":""},{"def":"The suboperculum.","pos":""}],"SUBOPERCULUM":[{"def":"The lower opercular bone in fishes.","pos":""},{"def":"Almost orbiculate or orbicular.","pos":""}],"SUBORDER":[{"def":"A division of an order; a group of genera of a little lower rank than an order and of greater importance than a tribe or family; as, cichoraceous plants form a suborder of Compositæ.","pos":""}],"SUBORDINACY":[{"def":"The quality or state of being subordinate, or subject to control; subordination, as, to bring the imagination to act in subordinacy to reason.","pos":""},{"def":"Subordinacy; subordination.","pos":""}],"SUBORDINARY":[{"def":"One of several heraldic bearings somewhat less common than an ordinary.","pos":""}],"SUBORDINATE":[{"def":"Placed in a lower order, class, or rank; holding a lower or inferior position.","pos":""},{"def":"Inferior in order, nature, dignity, power, importance, or the like.","pos":""}],"SUBORDINATION":[{"def":"The act of subordinating, placing in a lower order, or subjecting.","pos":""},{"def":"The quality or state of being subordinate or inferior to an other; inferiority of rank or dignity; subjection.","pos":""}],"SUBORDINATIVE":[{"def":"Tending to subordinate; expressing subordination; used to introduce a subordinate sentence; as, a subordinative conjunction.","pos":""}],"SUBORN":[{"def":"To procure or cause to take a false oath amounting to perjury, such oath being actually taken.","pos":""}],"SUBORNATION":[{"def":"The act of suborning; the crime of procuring a person to take such a false oath as constitutes perjury.","pos":""}],"SUBORNER":[{"def":"One who suborns or procures another to take, a false oath; one who procures another to do a bad action.","pos":""}],"SUBOVAL":[{"def":"Somewhat oval; nearly oval.","pos":""}],"SUBOVATE":[{"def":"Nearly in the form of an egg, or of the section of an egg, but having the inferior extremity broadest; nearly ovate.","pos":""}],"SUBOXIDE":[{"def":"An oxide containing a relatively small amount of oxygen, and less than the normal proportion; as, potassium suboxide, K4O.","pos":""}]}