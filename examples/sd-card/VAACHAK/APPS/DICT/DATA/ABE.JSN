{"ABEAM":[{"def":"On the beam, that is, on a line which forms a right angle with the ship's keel; opposite to the center of the ship's side.","pos":""}],"ABEAR":[{"def":"To bear; to behave.","pos":"verb"},{"def":"To put up with; to endure.","pos":"verb"}],"ABECEDARIAN":[{"def":"Pertaining to, or formed by, the letters of the alphabet; alphabetic; hence, rudimentary.","pos":""}],"ABECEDARY":[{"def":"A primer; the first principle or rudiment of anything.","pos":""}],"ABED":[{"def":"In bed, or on the bed.","pos":""},{"def":"To childbed (in the phrase \"brought abed,\" that is, delivered of a child).","pos":""}],"ABELE":[{"def":"The white polar (Populus alba).","pos":""},{"def":"One of a sect in Africa (4th century), mentioned by St.","pos":""}],"ABELMOSK":[{"def":"An evergreen shrub (Hibiscus -- formerly Abelmoschus- moschatus), of the East and West Indies and Northern Africa, whose musky seeds are used in perfumery and to flavor coffee; -- sometimes called musk mallow.","pos":""}],"ABER-DE-VINE":[{"def":"The European siskin (Carduelis spinus), a small green and yellow finch, related to the goldfinch.","pos":""}],"ABERR":[{"def":"To wander; to stray.","pos":"verb"},{"def":"State of being aberrant; a wandering from the right way; deviation from truth, rectitude, etc.","pos":"verb"}],"ABERRANT":[{"def":"Deviating from the ordinary or natural type; exceptional; abnormal.","pos":""}],"ABERRATE":[{"def":"To go astray; to diverge.","pos":"verb"}],"ABERRATION":[{"def":"The act of wandering; deviation, especially from truth or moral rectitude, from the natural state, or from a type.","pos":""},{"def":"A partial alienation of reason.","pos":""}],"ABERRATIONAL":[{"def":"Characterized by aberration.","pos":""}],"ABERUNCATOR":[{"def":"A weeding machine.","pos":""}],"ABET":[{"def":"To contribute, as an assistant or instigator, to the commission of an offense.","pos":"verb"}],"ABETMENT":[{"def":"The act of abetting; as, an abetment of treason, crime, etc.","pos":""}],"ABETTAL":[{"def":"One who abets; an instigator of an offense or an offender.","pos":""}],"ABEVACUATION":[{"def":"A partial evacuation.","pos":""}],"ABEYANCE":[{"def":"Expectancy; condition of being undetermined.","pos":""}],"ABEYANT":[{"def":"Being in a state of abeyance.","pos":""}]}