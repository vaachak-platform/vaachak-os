{"TOP":[{"def":"A plug, or conical block of wood, with longitudital grooves on its surface, in which the strands of the rope slide in the process of twisting.","pos":""}],"TOP FERMENTATION":[{"def":"An alcoholic fermentation during which the yeast cells are carried to the top of the fermening liquid.","pos":""}],"TOP OUT":[{"def":"To top off; to finish by putting on a cap of top (uppermost) course (called a top`ping-out\" course).","pos":""}],"TOP RAKE":[{"def":"The angle that the front edge of the point of a tool is set back from the normal to the surface being cut.","pos":""}],"TOP-ARMOR":[{"def":"A top railing supported by stanchions and equipped with netting.","pos":""}],"TOP-BLOCK":[{"def":"A large ironbound block strapped with a hook, and, when used, hung to an eyebolt in the cap, -- used in swaying and lowering the topmast.","pos":""}],"TOP-BOOTS":[{"def":"High boots, having generally a band of some kind of light- colored leather around the upper part of the leg; riding boots.","pos":""}],"TOP-CHAIN":[{"def":"A chain for slinging the lower yards, in time of action, to prevent their falling, if the ropes by which they are hung are shot away.","pos":""}],"TOP-CLOTH":[{"def":"A piece of canvas used to cover the hammocks which are lashed to the top in action to protect the topmen.","pos":""}],"TOP-DRAIN":[{"def":"To drain the surface of, as land; as, to top-drain a field or farm.","pos":""}],"TOP-DRAINING":[{"def":"The act or practice of drining the surface of land.","pos":""}],"TOP-DRESS":[{"def":"To apply a surface dressing of manureto,as land.","pos":""}],"TOP-DRESSING":[{"def":"The act of applying a dressing of manure to the surface of land; also, manure so applied.","pos":""}],"TOP-HAMPER":[{"def":"The upper rigging, spars, etc.","pos":""}],"TOP-HEAVY":[{"def":"Having the top or upper part too heavy for the lower part.","pos":""}],"TOP-LIGHT":[{"def":"A lantern or light on the top of a vessel.","pos":""}],"TOP-PROUD":[{"def":"Proud to the highest degree.","pos":""}],"TOP-ROPE":[{"def":"A rope used for hoisting and lowering a topmast, and for other purposes.","pos":""}],"TOP-SHAPED":[{"def":"Having the shape of a top; (Bot.","pos":""}],"TOP-SHELL":[{"def":"Any one of numerous species of marine top_shaped shells of the genus Thochus, or family Trochidæ.","pos":""}],"TOP-TACKLE":[{"def":"A tackle used in hoisting and lowering the topmast.","pos":""}],"TOP-TIMBERS":[{"def":"The highest timbers on the side of a vessel, being those above the futtocks.","pos":""}],"TOP-TOOL":[{"def":"A tool applied to the top of the work, in distinction from a tool inserted in the anvil and on which the work is placed.","pos":""}],"TOPARCH":[{"def":"The ruler or principal man in a place or country; the governor of a toparchy.","pos":""}],"TOPARCHY":[{"def":"A small state, consisting of a few cities or towns; a petty country governed by a toparch; as, Judea was formerly divided into ten toparchies.","pos":""}],"TOPAU":[{"def":"The rhinocerous bird (a).","pos":""}],"TOPAZ":[{"def":"A mineral occurring in rhombic prisms, generally yellowish and pellucid, also colorless, and of greenesh, bluish, or brownish shades.","pos":""},{"def":"Either one of two species of large, brilliantly colored humming birds of the Topaza, of South America and the West Indies.","pos":""}],"TOPAZOLITE":[{"def":"A topaz-yellow variety of garnet.","pos":""}],"TOPCOAT":[{"def":"An outer coat; an overcoat.","pos":""}],"TOPE":[{"def":"A moundlike Buddhist sepulcher, or memorial monument.","pos":""}],"TOPEK":[{"def":"An ESkimo house made of material other than snow, esp.","pos":""}],"TOPER":[{"def":"One who topes, or drinks frequently or to excess; a drunkard; a sot.","pos":""}],"TOPET":[{"def":"The European crested titmouse.","pos":""}],"TOPFUL":[{"def":"Full to the top, ore brim; brimfull.","pos":""}],"TOPGALLANT":[{"def":"Situated above the topmast and below the royal mast; designatb, or pertaining to, the third spars in order from the deck; as, the topgallant mast, yards, braces, and the like.","pos":""}],"TOPH":[{"def":"kind of sandstone.","pos":""}],"TOPHACEOUS":[{"def":"Gritty; sandy; rough; stony.","pos":""}],"TOPHET":[{"def":"A place lying east or southeast of Jerusalem, in the valley of Hinnom.","pos":""}],"TOPHUS":[{"def":"One of the mineral concretions about the joints, and in other situations, occurring chiefly in gouty persons.","pos":""},{"def":"Calcareous tufa.","pos":""}],"TOPI":[{"def":"An antelope (Damaliscus corrigum jimela) having a glossy purplish brown coat.","pos":""}],"TOPIARIAN":[{"def":"Of or pertaining to the ornamental cutting and trimming of trees, hedges, etc.","pos":""}],"TOPIARY":[{"def":"Of or pertaining to ornamental gardening; produced by cutting, trimming, etc.","pos":""}],"TOPIC":[{"def":"A treatise on forms of argument; a system or scheme of forms or commonplaces of argument or oratory; as, the Topics of Aristotle.","pos":""},{"def":"An external local application or remedy, as a plaster, a blister, etc.","pos":""}],"TOPICAL":[{"def":"Pertaining to, or consisting of, a topic or topics; according to topics.","pos":""}],"TOPICALLY":[{"def":"In a topical manner; with application to, or limitation of, a particular place or topic.","pos":""}],"TOPKNOT":[{"def":"A small Europen flounder (Rhoumbus punctatus).","pos":""}],"TOPLESS":[{"def":"Having no top, or no visble fop; hence, fig.","pos":""}],"TOPMAN":[{"def":"A man stationed in the top.","pos":""}],"TOPMAST":[{"def":"The second mast, or that which is next above the lower mast, and below the topgallant mast.","pos":""}],"TOPMOST":[{"def":"Highest; uppermost; as, the topmost cliff; the topmost branch of a tree.","pos":""}],"TOPOGRAPHER":[{"def":"One who is skilled in the science of topography; one who describes a particular place, town, city, or tract of land.","pos":""},{"def":"Of or pertaining to topography; descriptive of a place.","pos":""}],"TOPOGRAPHY":[{"def":"The description of a particular place, town, manor, parish, or tract of land; especially, the exact and scientific delineation and description in minute detail of any place or region.","pos":""}],"TOPOLOGY":[{"def":"The art of, or method for, assisting the memory by associating the thing or subject to be remembered with some place.","pos":""}],"TOPONOMY":[{"def":"The designation of position and direction.","pos":""}],"TOPONYM":[{"def":"A name of a place; more broadly, a name, as in the binomial name of a plant, based on, or derived from, a place name, or based on the location of the thing named.","pos":""}],"TOPONYMY":[{"def":"A system of toponyms; the use of toponyms.","pos":""}],"TOPOPHONE":[{"def":"A double ear trumpet for estimating the direction from which sounds proceed, esp.","pos":""}],"TOPPER":[{"def":"One that tops, in any sense of the verb; specif.","pos":""}],"TOPPIECE":[{"def":"A small wig for the top of the head; a toupee.","pos":""}],"TOPPING":[{"def":"Rising above; surpassing.","pos":""},{"def":"Hence, assuming superiority; proud.","pos":""}],"TOPPINGLY":[{"def":"In a topping or proud manner.","pos":""}],"TOPPLE":[{"def":"To fall forward; to pitch or tumble down.","pos":""}],"TOPS-AND-BOTTOMS":[{"def":"Small rolls of dough, baked, cut in halves, and then browned in an oven, -- used as food for infants.","pos":""}],"TOPSAIL":[{"def":"In a square-rigged vessel, the sail next above the lowermost sail on a mast.","pos":""}],"TOPSMAN":[{"def":"The chief drover of those who drive a herd of cattle.","pos":""},{"def":"The uppermost sawyer in a saw pit; a topman.","pos":""}],"TOPSOIL":[{"def":"The upper layer of soil; surface soil.","pos":""}],"TOPSOILING":[{"def":"The act or art of taking off the top soil of land before an excavation or embankment is begun.","pos":""}],"TOPSTONE":[{"def":"A stone that is placed on the top, or which forms the top.","pos":""}],"TOPSY-TURVY":[{"def":"In an inverted posture; with the top or head downward; upside down; as, to turn a carriage topsy-turvy.","pos":""}]}