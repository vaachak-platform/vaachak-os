{"INEFFABILITY":[{"def":"The quality or state of being ineffable; ineffableness; unspeakableness.","pos":""}],"INEFFABLE":[{"def":"Incapable of being expresses in words; unspeakable; unutterable; indescribable; as, the ineffable joys of heaven.","pos":""}],"INEFFABLENESS":[{"def":"The quality or state of being ineffable or unutterable; unspeakableness.","pos":""}],"INEFFABLY":[{"def":"In a manner not to be expressed in words; unspeakably.","pos":""}],"INEFFACEABLE":[{"def":"Incapable of being effaced; indelible; ineradicable.","pos":""}],"INEFFACEABLY":[{"def":"So as not to be effaceable.","pos":""}],"INEFFECTIBLE":[{"def":"Ineffectual; impracticable.","pos":""}],"INEFFECTIVE":[{"def":"Not effective; ineffectual; futile; inefficient; useless; as, an ineffective appeal.","pos":""}],"INEFFECTIVELY":[{"def":"In an ineffective manner; without effect; inefficiently; ineffectually.","pos":""}],"INEFFECTIVENESS":[{"def":"Quality of being ineffective.","pos":""}],"INEFFECTUAL":[{"def":"Not producing the proper effect; without effect; inefficient; weak; useless; futile; unavailing; as, an ineffectual attempt; an ineffectual expedient.","pos":""}],"INEFFECTUALITY":[{"def":"Ineffectualness.","pos":""}],"INEFFECTUALLY":[{"def":"Without effect; in vain.","pos":""}],"INEFFECTUALNESS":[{"def":"Want of effect, or of power to produce it; inefficacy.","pos":""}],"INEFFERVESCENCE":[{"def":"Want of effervescence.","pos":""}],"INEFFERVESCENT":[{"def":"Not effervescing, or not susceptible of effervescence; quiescent.","pos":""}],"INEFFERVESCIBILITY":[{"def":"The quality of being ineffervescible.","pos":""}],"INEFFERVESCIBLE":[{"def":"Not capable or susceptible of effervescence.","pos":""}],"INEFFICACIOUS":[{"def":"Not efficacious; not having power to produce the effect desired; inadequate; incompetent; inefficient; impotent.","pos":""}],"INEFFICACIOUSLY":[{"def":"without efficacy or effect.","pos":""}],"INEFFICACIOUSNESS":[{"def":"Want of effect, or of power to produce the effect; inefficacy.","pos":""}],"INEFFICACY":[{"def":"Want of power to produce the desired or proper effect; inefficiency; ineffectualness; futility; uselessness; fruitlessness; as, the inefficacy of medicines or means.","pos":""}],"INEFFICIENCY":[{"def":"The quality of being inefficient; want of power or energy sufficient; want of power or energy sufficient for the desired effect; inefficacy; incapacity; as, he was discharged from his position for inefficiency.","pos":""}],"INEFFICIENT":[{"def":"Not efficient; not producing the effect intended or desired; inefficacious; as, inefficient means or measures.","pos":""},{"def":"Incapable of, or indisposed to, effective action; habitually slack or remiss; effecting little or nothing; as, inefficient workmen; an inefficient administrator.","pos":""}],"INEFFICIENTLY":[{"def":"In an inefficient manner.","pos":""}]}