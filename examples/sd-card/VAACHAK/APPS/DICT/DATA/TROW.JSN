{"TROW":[{"def":"A boat with an open well amidships.","pos":""}],"TROWEL":[{"def":"A tool used for smoothing a mold.","pos":""}],"TROWELED":[{"def":"Formed with a trowel; smoothed with a trowel; as, troweled stucco, that is, stucco laid on and ready for the reception of paint.","pos":""}],"TROWELFUL":[{"def":"As much as a trowel will hold; enough to fill a trowel.","pos":""}],"TROWSED":[{"def":"Wearing trousers.","pos":""}],"TROWSERS":[{"def":"Same as Trousers.","pos":""}]}