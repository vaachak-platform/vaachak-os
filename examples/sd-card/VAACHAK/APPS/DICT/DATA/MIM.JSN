{"MIME":[{"def":"A kind of drama in which real persons and events were generally represented in a ridiculous manner.","pos":""},{"def":"An actor in such representations.","pos":""}],"MIMEOGRAPH":[{"def":"An autographic stencil copying device invented by Edison.","pos":""}],"MIMESIS":[{"def":"Imitation; mimicry.","pos":""}],"MIMETENE":[{"def":"Characterized by mimicry; -- applied to animals and plants; as, mimetic species; mimetic organisms.","pos":""}],"MIMETISM":[{"def":"Same as Mimicry.","pos":""}],"MIMETITE":[{"def":"A mineral occurring in pale yellow or brownish hexagonal crystals.","pos":""},{"def":"Imitative; characterized by resemblance to other forms; -- applied to crystals which by twinning resemble simple forms of a higher grade of symmetry.","pos":""}],"MIMIC":[{"def":"One who imitates or mimics, especially one who does so for sport; a copyist; a buffoon.","pos":""}],"MIMICALLY":[{"def":"In an imitative manner.","pos":""}],"MIMICKER":[{"def":"An animal which imitates something else, in form or habits.","pos":""}],"MIMICRY":[{"def":"Protective resemblance; the resemblance which certain animals and plants exhibit to other animals and plants or to the natural objects among which they live, -- a characteristic which serves as their chief means of protection against enemies; imitation; mimesis; mimetism.","pos":""}],"MIMOGRAPHER":[{"def":"A writer of mimes.","pos":""}],"MIMOSA":[{"def":"A genus of leguminous plants, containing many species, and including the sensitive plants (Mimosa sensitiva, and M.","pos":""}],"MIMOTANNIC":[{"def":"Pertaining to, or designating, a variety of tannin or tannic acid found in Acacia, Mimosa, etc.","pos":""}]}