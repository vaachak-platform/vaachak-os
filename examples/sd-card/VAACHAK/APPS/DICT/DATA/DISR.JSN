{"DISRANK":[{"def":"To degrade from rank.","pos":""},{"def":"To throw out of rank or into confusion.","pos":""}],"DISRATE":[{"def":"To reduce to a lower rating or rank; to degrade.","pos":""}],"DISRAY":[{"def":"Dis*ray\", variant Defn: of Disarray.","pos":""}],"DISREALIZE":[{"def":"To divest of reality; to make uncertain.","pos":""}],"DISREGARD":[{"def":"Not to regard; to pay no heed to; to omit to take notice of; to neglect to observe; to slight as unworthy of regard or notice; as, to disregard the admonitions of conscience.","pos":""}],"DISREGARDER":[{"def":"One who disregards.","pos":""}],"DISREGARDFUL":[{"def":"Neglect; negligent; heedless; regardless.","pos":""}],"DISREGARDFULLY":[{"def":"Negligently; heedlessly.","pos":""}],"DISRELISH":[{"def":"Want of relish; dislike (of the palate or of the mind); distaste; a slight degree of disgust; as, a disrelish for some kinds of food.","pos":""},{"def":"Absence of relishing or palatable quality; bad taste; nauseousness.","pos":""}],"DISREMEMBER":[{"def":"To fail to remember; to forget.","pos":""}],"DISREPAIR":[{"def":"A state of being in bad condition, and wanting repair.","pos":""}],"DISREPUTABILITY":[{"def":"The state of being disreputable.","pos":""}],"DISREPUTABLE":[{"def":"Not reputable; of bad repute; not in esteem; dishonorable; disgracing the reputation; tending to bring into disesteem; as, it is disreputable to associate familiarly with the mean, the lewd, and the profane.","pos":""}],"DISREPUTABLY":[{"def":"In a disreputable manner.","pos":""}],"DISREPUTATION":[{"def":"Loss or want of reputation or good name; dishonor; disrepute; disesteem.","pos":""}],"DISREPUTE":[{"def":"Loss or want of reputation; ill character; disesteem; discredit.","pos":""}],"DISRESPECT":[{"def":"Want of respect or reverence; disesteem; incivility; discourtesy.","pos":""}],"DISRESPECTABILITY":[{"def":"Want of respectability.","pos":""}],"DISRESPECTABLE":[{"def":"Not respectable; disreputable.","pos":""}],"DISRESPECTER":[{"def":"One who disrespects.","pos":""}],"DISRESPECTFUL":[{"def":"Wanting in respect; manifesting disesteem or lack of respect; uncivil; as, disrespectful behavior.","pos":""}],"DISRESPECTIVE":[{"def":"Showing want of respect; disrespectful.","pos":""}],"DISREVERENCE":[{"def":"To treat irreverently or with disrespect.","pos":""}],"DISROBE":[{"def":"To divest of a robe; to undress; figuratively, to strip of covering; to divest of that which clothes or decorates; as, autumn disrobes the fields of verdure.","pos":""}],"DISROBER":[{"def":"One who, or that which, disrobes.","pos":""}],"DISROOT":[{"def":"To tear up the roots of, or by the roots; hence, to tear from a foundation; to uproot.","pos":""}],"DISRUDDER":[{"def":"To deprive of the rudder, as a ship.","pos":""}],"DISRULILY":[{"def":"In a disorderly manner.","pos":""}],"DISRULY":[{"def":"Unruly; disorderly.","pos":""}],"DISRUPT":[{"def":"Rent off; torn asunder; severed; disrupted.","pos":""}],"DISRUPTION":[{"def":"The act or rending asunder, or the state of being rent asunder or broken in pieces; breach; rent; dilaceration; rupture; as, the disruption of rocks in an earthquake; disruption of a state.","pos":""}],"DISRUPTIVE":[{"def":"Causing, or tending to cause, disruption; caused by disruption; breaking through; bursting; as, the disruptive discharge of an electrical battery.","pos":""}]}