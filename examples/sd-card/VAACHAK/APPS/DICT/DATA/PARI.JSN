{"PARI-":[{"def":"A combining form signifying equal; as, paridigitate, paripinnate.","pos":""}],"PARIAH":[{"def":"One of an aboriginal people of Southern India, regarded by the four castes of the Hindoos as of very low grade.","pos":""},{"def":"An outcast; one despised by society.","pos":""}],"PARIAL":[{"def":"See Pair royal, under Pair, n.","pos":""}],"PARIAN":[{"def":"Of or pertaining to Paros, an island in the Ægean Sea noted for its excellent statuary marble; as, Parian marble.","pos":""}],"PARIDIGITATA":[{"def":"Same as Artiodactyla.","pos":""}],"PARIDIGITATE":[{"def":"Having an evennumber of digits on the hands or the feet.","pos":""}],"PARIES":[{"def":"The triangular middle part of each segment of the shell of a barnacle.","pos":""}],"PARIETAL":[{"def":"Attached to the main wall of the ovary, and not to the axis; -- said of a placenta.","pos":""}],"PARIETARY":[{"def":"See Parietal, 2.","pos":""}],"PARIETES":[{"def":"The walls of a cavity or an organ; as, the abdominal parietes; the parietes of the cranium.","pos":""},{"def":"The sides of an ovary or of a capsule.","pos":""}],"PARIETIC":[{"def":"Pertaining to, or designating, an acid found in the lichen Parmelia parietina, and called also chrysophanic acid.","pos":""}],"PARIETINE":[{"def":"A piece of a fallen wall; a ruin.","pos":""}],"PARIETO-":[{"def":"A combining form used to indicate connection with, or relation to, the parietal bones or the parietal segment of the skull; as, the parieto-mastoid suture.","pos":""}],"PARIGENIN":[{"def":"A curdy white substance, obtained by the decomposition of parillin.","pos":""}],"PARILLIN":[{"def":"A glucoside resembling saponin, found in the root of sarsaparilla, smilax, etc.","pos":""}],"PARING":[{"def":"The act of cutting off the surface or extremites of anything.","pos":""},{"def":"That which is pared off.","pos":""}],"PARIPINNATE":[{"def":"Pinnate with an equal number of leaflets on each side; having no odd leaflet at the end.","pos":""}],"PARIS":[{"def":"A plant common in Europe (Paris quadrifolia); herb Paris; truelove.","pos":""}],"PARISH":[{"def":"An ecclesiastical society, usually not bounded by territorial limits, but composed of those persons who choose to unite under the charge of a particular priest, clergyman, or minister; also, loosely, the territory in which the members of a congregation live.","pos":""},{"def":"In Louisiana, a civil division corresponding to a county in other States.","pos":""}],"PARISHIONAL":[{"def":"Of or pertaining to a parish; parochial.","pos":""}],"PARISHIONER":[{"def":"One who belongs to, or is connected with, a parish.","pos":""}],"PARISIAN":[{"def":"A native or inhabitant of Paris, the capital of France.","pos":""}],"PARISIENNE":[{"def":"A female native or resident of Paris.","pos":""}],"PARISOLOGY":[{"def":"The use of equivocal or ambiguous words.","pos":""},{"def":"Having the same number of syllables in all its inflections.","pos":""}],"PARITY":[{"def":"The quality or condition of being equal or equivalent; A like state or degree; equality; close correspondence; analogy; as, parity of reasoning.","pos":""}]}