{"MEED":[{"def":"That which is bestowed or rendered in consideration of merit; reward; recompense.","pos":""},{"def":"Merit or desert; worth.","pos":""}],"MEEDFUL":[{"def":"Worthy of meed, reward, or recompense; meritorious.","pos":""}],"MEEDFULLY":[{"def":"According to merit; suitably.","pos":""}],"MEEK":[{"def":"To make meek; to nurture in gentleness and humility.","pos":""}],"MEEKLY":[{"def":"In a meek manner.","pos":""}],"MEEKNESS":[{"def":"The quality or state of being meek.","pos":""}],"MEER":[{"def":"Simple; unmixed.","pos":""}],"MEERKAT":[{"def":"A South African carnivore (Cynictis penicillata), allied to the ichneumons.","pos":""}],"MEERSCHAUM":[{"def":"A fine white claylike mineral, soft, and light enough when in dry masses to float in water.","pos":""}],"MEET":[{"def":"To join, or come in contact with; esp.","pos":""},{"def":"To come in collision with; to confront in conflict; to encounter hostilely; as, they met the enemy and defeated them; the ship met opposing winds and currents.","pos":""}],"MEETH":[{"def":"Meeth Defn: , Mead.","pos":""}],"MEETING":[{"def":"A coming together; an assembling; as, the meeting of Congress.","pos":""},{"def":"A junction, crossing, or union; as, the meeting of the roads or of two rivers.","pos":""}],"MEETINGHOUSE":[{"def":"A house used as a place of worship; a church; -- in England, applied only to a house so used by Dissenters.","pos":""}],"MEETLY":[{"def":"Fitly; suitably; properly.","pos":""}],"MEETNESS":[{"def":"Fitness; suitableness; propriety.","pos":""},{"def":"Combining forms signifying: (a) Great, extended, powerful; as, megascope, megacosm.","pos":""}]}