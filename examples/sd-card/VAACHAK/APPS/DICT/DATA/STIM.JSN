{"STIME":[{"def":"A slight gleam or glimmer; a glimpse.","pos":""}],"STIMULANT":[{"def":"Produced increased vital action in the organism, or in any of its parts.","pos":""}],"STIMULATE":[{"def":"To excite; to irritate; especially, to excite the activity of (a nerve or an irritable muscle), as by electricity.","pos":""}],"STIMULATION":[{"def":"The act of stimulating, or the state of being stimulated.","pos":""}],"STIMULATIVE":[{"def":"Having the quality of stimulating.","pos":""},{"def":"That which stimulates.","pos":""}],"STIMULATOR":[{"def":"One who stimulates.","pos":""}],"STIMULATRESS":[{"def":"A woman who stimulates.","pos":""}],"STIMULUS":[{"def":"A goad; hence, something that rouses the mind or spirits; an incentive; as, the hope of gain is a powerful stimulus to labor and action.","pos":""},{"def":"That which excites or produces a temporary increase of vital action, either in the whole organism or in any of its parts; especially (Physiol.","pos":""}]}