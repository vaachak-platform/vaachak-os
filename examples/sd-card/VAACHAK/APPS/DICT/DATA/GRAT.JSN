{"GRATE":[{"def":"Serving to gratify; agreeable.","pos":""}],"GRATED":[{"def":"Furnished with a grate or grating; as, grated windows.","pos":""}],"GRATEFUL":[{"def":"Having a due sense of benefits received; kindly disposed toward one from whom a favor has been received; willing to acknowledge and repay, or give thanks for, benefits; as, a grateful heart.","pos":""},{"def":"Affording pleasure; pleasing to the senses; gratifying; delicious; as, a grateful present; food grateful to the palate; grateful sleep.","pos":""}],"GRATER":[{"def":"One who, or that which, grates; especially, an instrument or utensil with a rough, indented surface, for rubbing off small particles of any substance; as a grater for nutmegs.","pos":""}],"GRATICULATION":[{"def":"The division of a design or draught into squares, in order the more easily to reproduce it in larger or smaller dimensions.","pos":""}],"GRATICULE":[{"def":"A design or draught which has been divided into squares, in order to reproduce it in other dimensions.","pos":""}],"GRATIFICATION":[{"def":"The act of gratifying, or pleasing, either the mind, the taste, or the appetite; as, the gratification of the palate, of the appetites, of the senses, of the desires, of the heart.","pos":""},{"def":"That which affords pleasure; satisfaction; enjoyment; fruition: delight.","pos":""}],"GRATIFIED":[{"def":"Pleased; indulged according to desire.","pos":""}],"GRATIFIER":[{"def":"One who gratifies or pleases.","pos":""}],"GRATIFY":[{"def":"To please; to give pleasure to; to satisfy; to soothe; to indulge; as, to gratify the taste, the appetite, the senses, the desires, the mind, etc.","pos":""},{"def":"To requite; to recompense.","pos":""}],"GRATIN":[{"def":"The brown crust formed upon a gratinated dish; also, dish itself, as crusts bread, game, or poultry.","pos":""}],"GRATINATE":[{"def":"To cook, as macaroni, in a savory juice or sauce until juice is absorbed and a crisp surface forms.","pos":"verb"}],"GRATING":[{"def":"A partition, covering, or frame of parallel or cross bars; a latticework resembling a window grate; as, the grating of a prison or convent.","pos":""}],"GRATIOLIN":[{"def":"One of the essential principles of the hedge hyssop (Gratiola officinalis).","pos":""}],"GRATIS":[{"def":"For nothing; without fee or recompense; freely; gratuitously.","pos":""}],"GRATITUDE":[{"def":"The state of being grateful; warm and friendly feeling toward a benefactor; kindness awakened by a favor received; thankfulness.","pos":""}],"GRATUITOUS":[{"def":"Given without an equivalent or recompense; conferred without valuable consideration; granted without pay, or without claim or merit; not required by justice.","pos":""},{"def":"Not called for by the circumstances; without reason, cause, or proof; adopted or asserted without any good ground; as, a gratuitous assumption.","pos":""}],"GRATUITY":[{"def":"Something given freely or without recompense; a free gift; a present.","pos":""},{"def":"Something voluntarily given in return for a favor or service, as a recompense or acknowledgment.","pos":""}],"GRATULATE":[{"def":"To salute with declaration of joy; to congratulate.","pos":""}],"GRATULATION":[{"def":"The act of gratulating or felicitating; congratulation.","pos":""}],"GRATULATORY":[{"def":"Expressing gratulation or joy; congratulatory.","pos":""}]}