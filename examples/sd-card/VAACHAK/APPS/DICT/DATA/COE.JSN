{"COEDUCATION":[{"def":"An educating together, as of persons of different sexes or races.","pos":""}],"COEFFICIENCY":[{"def":"Joint efficiency; coöperation.","pos":""}],"COEFFICIENT":[{"def":"Coöperating; acting together to produce an effect.","pos":""}],"COEHORN":[{"def":"A small bronze mortar mounted on a wooden block with handles, and light enough to be carried short distances by two men.","pos":""}],"COELACANTH":[{"def":"Having hollow spines, as some ganoid fishes.","pos":""}],"COELECTRON":[{"def":"A comprehensive group of Invertebrata, mostly marine, comprising the Anthozoa, Hydrozoa, and Ctenophora.","pos":""}],"COELENTERATE":[{"def":"Belonging to the Coelentra.","pos":""},{"def":"One of the Coelentera.","pos":""}],"COELIA":[{"def":"Relating to the abdomen, or to the cavity of the abdomen.","pos":""}],"COELODONT":[{"def":"Having hollow teeth; -- said of a group lizards.","pos":""},{"def":"One of a group of lizards having hollow teeth.","pos":""}],"COELOSPERMOUS":[{"def":"Hollow-seeded; having the ventral face of the seedlike carpels incurved at the ends, as in coriander seed.","pos":""}],"COELUM":[{"def":"See Body cavity, under Body.","pos":""}],"COEMPTION":[{"def":"The act of buying the whole quantity of any commodity.","pos":""}],"COENDOO":[{"def":"The Brazilian porcupine (Cercolades, or Sphingurus, prehensiles), remarkable for its prehensile tail.","pos":""},{"def":"The common tissue which unites the polyps or zooids of a compound anthozoan or coral.","pos":""}],"COENESTHESIS":[{"def":"Common sensation or general sensibility, as distinguished from the special sensations which are located in, or ascribed to, separate organs, as the eye and ear.","pos":""}],"COENOBITE":[{"def":"Coen\"o*bite ( or ), n.","pos":""}],"COENOECIUM":[{"def":"The common tissue which unites the various zooids of a bryozoan.","pos":""}],"COENOGAMY":[{"def":"The state of a community which permits promiscuous sexual intercourse among its members; -- as in certain primitive tribes or communistic societies.","pos":""}],"COENOSARC":[{"def":"The common soft tissue which unites the polyps of a compound hydroid.","pos":""}],"COENURUS":[{"def":"The larval stage of a tapeworm (Tænia coenurus) which forms bladderlike sacs in the brain of sheep, causing the fatal disease known as water brain, vertigo, staggers or gid.","pos":""}],"COEQUAL":[{"def":"Being on an equality in rank or power.","pos":""},{"def":"One who is on an equality with another.","pos":""}],"COEQUALITY":[{"def":"The state of being on an equality, as in rank or power.","pos":""}],"COEQUALLY":[{"def":"With coequality.","pos":""}],"COERCE":[{"def":"To restrain by force, especially by law or authority; to repress; to curb.","pos":""},{"def":"To compel or constrain to any action; as, to coerce a man to vote for a certain candidate.","pos":""}],"COERCIBLE":[{"def":"Capable of being coerced.","pos":""}],"COERCION":[{"def":"The application to another of either physical or moral force.","pos":""}],"COERCIVE":[{"def":"Serving or intended to coerce; having power to constrain.","pos":""}],"COERULIGNONE":[{"def":"A bluish violet, crystalline substance obtained in the purification of crude wood vinegar.","pos":""}],"COESSENTIAL":[{"def":"Partaking of the same essence.","pos":""}],"COESSENTIALITY":[{"def":"Participation of the same essence.","pos":""}],"COESTABLISHMENT":[{"def":"Joint establishment.","pos":""}],"COETANEAN":[{"def":"A personcoetaneous with another; a contemporary.","pos":""}],"COETANEOUS":[{"def":"Of the same age; beginning to exist at the same time; contemporaneous.","pos":""}],"COETERNAL":[{"def":"Equally eternal.","pos":""}],"COETERNITY":[{"def":"Existence from eternity equally with another eternal being; equal eternity.","pos":""}],"COEVAL":[{"def":"Of the same age; existing during the same period of time, especially time long and remote; -- usually followed by with.","pos":""}],"COEXECUTOR":[{"def":"A joint executor.","pos":""}],"COEXECUTRIX":[{"def":"A joint executrix.","pos":""}],"COEXIST":[{"def":"To exist at the same time; -- sometimes followed by with.","pos":""}],"COEXISTENCE":[{"def":"Existence at the same time with another; -- contemporary existence.","pos":""}],"COEXISTENT":[{"def":"Existing at the same time with another.","pos":""},{"def":"That which coexists with another.","pos":""}],"COEXTEND":[{"def":"To extend through the same space or time with another; to extend to the same degree.","pos":""}],"COEXTENSION":[{"def":"The act of extending equally, or the state of being equally extended.","pos":""}],"COEXTENSIVE":[{"def":"Equally extensive; having as, consciousness and knowledge are coextensive.","pos":""}]}