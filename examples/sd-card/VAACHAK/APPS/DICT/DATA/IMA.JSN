{"IMAGE":[{"def":"A picture, example, or illustration, often taken from sensible objects, and used to illustrate a subject; usually, an extended metaphor.","pos":""}],"IMAGEABLE":[{"def":"That may be imaged.","pos":""}],"IMAGELESS":[{"def":"Having no image.","pos":""}],"IMAGER":[{"def":"One who images or forms likenesses; a sculptor.","pos":""}],"IMAGERY":[{"def":"The work of one who makes images or visible representation of objects; imitation work; images in general, or in mass.","pos":""}],"IMAGINABILITY":[{"def":"Capacity for imagination.","pos":""}],"IMAGINABLE":[{"def":"Capable of being imagined; conceivable.","pos":""}],"IMAGINAL":[{"def":"Of or pertaining to an imago.","pos":""}],"IMAGINANT":[{"def":"Imagining; conceiving.","pos":""}],"IMAGINARILY":[{"def":"In a imaginary manner; in imagination.","pos":""}],"IMAGINARINESS":[{"def":"The state or quality of being imaginary; unreality.","pos":""}],"IMAGINARY":[{"def":"Existing only in imagination or fancy; not real; fancied; visionary; ideal.","pos":""}],"IMAGINATION":[{"def":"The imagine-making power of the mind; the power to create or reproduce ideally an object of sense previously perceived; the power to call up mental imagines.","pos":""},{"def":"The representative power; the power to reconstruct or recombine the materials furnished by direct apprehension; the complex faculty usually termed the plastic or creative power; the fancy.","pos":""}],"IMAGINATIONAL":[{"def":"Pertaining to, involving, or caused by, imagination.","pos":""}],"IMAGINATIONALISM":[{"def":"Im*ag`i*na\"tion*al*ism, n.","pos":""}],"IMAGINATIVE":[{"def":"Proceeding from, and characterized by, the imagination, generally in the highest sense of the word.","pos":""},{"def":"Given to imagining; full of images, fancies, etc.","pos":""}],"IMAGINE":[{"def":"To form in the mind a notion or idea of; to form a mental image of; to conceive; to produce by the imagination.","pos":""},{"def":"To contrive in purpose; to scheme; to devise; to compass; to purpose.","pos":""}],"IMAGINER":[{"def":"One who forms ideas or conceptions; one who contrives.","pos":""}],"IMAGO":[{"def":"The final adult, and usually winged, state of an insect.","pos":""}],"IMARET":[{"def":"A lodging house for Mohammedan pilgrims.","pos":""}]}