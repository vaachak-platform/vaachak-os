{"THERAPEUTAE":[{"def":"A name given to certain ascetics said to have anciently dwelt in the neighborhood of Alexandria.","pos":""},{"def":"Of or pertaining to the healing art; concerned in discovering and applying remedies for diseases; curative.","pos":""}],"THERAPEUTIC":[{"def":"One of the Therapeutæ.","pos":""}],"THERAPEUTICS":[{"def":"That part of medical science which treats of the discovery and application of remedies for diseases.","pos":""}],"THERAPEUTIST":[{"def":"One versed in therapeutics, or the discovery and application of remedies.","pos":""}],"THERE":[{"def":"In or at that place.","pos":""},{"def":"In that matter, relation, etc.","pos":""}],"THERE-ANENT":[{"def":"Concerning that.","pos":""}],"THEREAFTER":[{"def":"After that; afterward.","pos":""},{"def":"According to that; accordingly.","pos":""}],"THEREAGAIN":[{"def":"In opposition; against one's course.","pos":""}],"THEREAT":[{"def":"Before that time; beforehand.","pos":""}],"THEREBY":[{"def":"By that; by that means; in consequence of that.","pos":""},{"def":"Annexed to that.","pos":""}],"THEREFOR":[{"def":"For that, or this; for it.","pos":""}],"THEREFORE":[{"def":"For that or this reason, referring to something previously stated; for that.","pos":""},{"def":"Consequently; by consequence.","pos":""}],"THEREFROM":[{"def":"From this or that.","pos":""}],"THEREIN":[{"def":"In that or this place, time, or thing; in that particular or respect.","pos":""}],"THEREINTO":[{"def":"Into that or this, or into that place.","pos":""}],"THEREOF":[{"def":"Of that or this.","pos":""}],"THEREON":[{"def":"On that or this.","pos":""}],"THEREOUT":[{"def":"Out of that or this.","pos":""},{"def":"On the outside; out of doors.","pos":""}],"THERETO":[{"def":"To that or this.","pos":""},{"def":"Besides; moreover.","pos":""}],"THERETOFORE":[{"def":"Up to that time; before then; -- correlative with heretofore.","pos":""}],"THEREUNDER":[{"def":"Under that or this.","pos":""}],"THEREUNTO":[{"def":"Unto that or this; thereto; besides.","pos":""}],"THEREUPON":[{"def":"Upon that or this; thereon.","pos":""},{"def":"On account, or in consequence, of that; therefore.","pos":""}],"THEREWHILE":[{"def":"At that time; at the same time.","pos":""}],"THEREWITH":[{"def":"With that or this.","pos":""},{"def":"In addition; besides; moreover.","pos":""}],"THEREWITHAL":[{"def":"Over and above; besides; moreover.","pos":""},{"def":"With that or this; therewith; at the same time.","pos":""}],"THERF":[{"def":"Not fermented; unleavened; -- said of bread, loaves, etc.","pos":""},{"def":"An ancient composition esteemed efficacious against the effects of poison; especially, a certain compound of sixty-four drugs, prepared, pulverized, and reduced by means of honey to an electuary; -- called also theriaca Andromachi, and Venice treacle.","pos":""}],"THERIODONT":[{"def":"One of the Theriodontia.","pos":""}],"THERIODONTA":[{"def":"Same as Theriodontia.","pos":""}],"THERIODONTIA":[{"def":"An extinct order of reptiles found in the Permian and Triassic formations in South Africa.","pos":""}],"THERMAE":[{"def":"Springs or baths of warm or hot water.","pos":""}],"THERMAL":[{"def":"Of or pertaining to heat; warm; hot; as, the thermal unit; thermal waters.","pos":""}],"THERMALLY":[{"def":"In a thermal manner.","pos":""}],"THERMANTIDOTE":[{"def":"A device for circulating and cooling the air, consisting essentially of a kind of roasting fan fitted in a window and incased in wet tatties.","pos":""}],"THERMETOGRAPH":[{"def":"A self-registering thermometer, especially one that registers the maximum and minimum during long periods.","pos":""}],"THERMIC":[{"def":"Of or pertaining to heat; due to heat; thermal; as, thermic lines.","pos":""}],"THERMIDOR":[{"def":"The eleventh month of the French republican calendar, -- commencing July 19, and ending August 17.","pos":""}],"THERMIFUGINE":[{"def":"An artificial alkaloid of complex composition, resembling thalline and used as an antipyretic, -- whence its name.","pos":""}],"THERMO-":[{"def":"A combining form from Gr.","pos":""},{"def":"Loss of power to distinguish heat or cold by touch.","pos":""}],"THERMOBAROGRAPH":[{"def":"An instrument for recording simultaneously the pressure and temperature of a gas; a combined thermograph and barograph.","pos":""}],"THERMOBAROMETER":[{"def":"An instrument for determining altitudes by the boiling point of water.","pos":""}],"THERMOBATTERY":[{"def":"A thermoelectric battery; a thermopile.","pos":""}],"THERMOCAUTERY":[{"def":"Cautery by the application of heat.","pos":""},{"def":"Of or pertaining to thermochemistry; obtained by, or employed in, thermochemistry.","pos":""}],"THERMOCHEMISTRY":[{"def":"That branch of chemical science which includes the investigation of the various relations existing between chemical action and that manifestation of force termed heat, or the determination of the heat evolved by, or employed in, chemical actions.","pos":""}],"THERMOCHROSY":[{"def":"The property possessed by heat of being composed, like light, of rays of different degrees of refrangibility, which are unequal in rate or degree of transmission through diathermic substances.","pos":""}],"THERMOCOUPLE":[{"def":"A thermoelectric couple.","pos":""}],"THERMOCURRENT":[{"def":"A current, as of electricity, developed, or set in motion, by the action of heat.","pos":""}],"THERMODIN":[{"def":"A white crystalline substance derived from urethane, used in medicine as an antipyretic, etc.","pos":""}],"THERMODYNAMIC":[{"def":"Relating to thermodynamics; caused or operated by force due to the application of heat.","pos":""}],"THERMODYNAMICS":[{"def":"The science which treats of the mechanical action or relations of heat.","pos":""}],"THERMOELECTRIC":[{"def":"Pertaining to thermoelectricity; as, thermoelectric currents.","pos":""},{"def":"A union of two conductors, as bars or wires of dissimilar metals joined at their extremities, for producing a thermoelectric current.","pos":""}],"THERMOELECTRICITY":[{"def":"Electricity developed in the action of heat.","pos":""}],"THERMOELECTROMETER":[{"def":"An instrument for measuring the strength of an electric current in the heat which it produces, or for determining the heat developed by such a current.","pos":""}],"THERMOGEN":[{"def":"Caloric; heat; regarded as a material but imponderable substance.","pos":""}],"THERMOGENIC":[{"def":"Relating to heat, or to the production of heat; producing heat; thermogenous; as, the thermogenic tissues.","pos":""}],"THERMOGENOUS":[{"def":"Producing heat; thermogenic.","pos":""}],"THERMOGRAM":[{"def":"The trace or record made by means of a thermograph.","pos":""}],"THERMOGRAPH":[{"def":"An instrument for automatically recording indications of the variation of temperature.","pos":""}],"THERMOGRAPHY":[{"def":"Any process of writing involving the use of heat.","pos":""}],"THERMOJUNCTION":[{"def":"A junction of two dissimilar conductors used to produce a thermoelectric current, as in one form of pyrometer; a thermocouple.","pos":""}],"THERMOLOGY":[{"def":"A discourse on, or an account of, heat.","pos":""}],"THERMOLUMINESCENCE":[{"def":"Luminescence exhibited by a substance on being moderately heated.","pos":""}],"THERMOLYSIS":[{"def":"The resolution of a compound into parts by heat; dissociation by heat.","pos":""}],"THERMOLYTIC":[{"def":"Of or pertaining to thermolysis.","pos":""}],"THERMOLYZE":[{"def":"To subject to thermolysis; to dissociate by heat.","pos":""}],"THERMOMAGNETISM":[{"def":"Magnetism as affected or caused by the action of heat; the relation of heat to magnetism.","pos":""}],"THERMOMETER":[{"def":"An instrument for measuring temperature, founded on the principle that changes of temperature in bodies are accompained by proportional changes in their volumes or dimensions.","pos":""}],"THERMOMETRICALLY":[{"def":"In a thermometrical manner; by means of a thermometer.","pos":""}],"THERMOMETROGRAPH":[{"def":"An instrument for recording graphically the variations of temperature, or the indications of a thermometer.","pos":""}],"THERMOMETRY":[{"def":"The estimation of temperature by the use of a thermometric apparatus.","pos":""}],"THERMOMOTOR":[{"def":"A heat engine; a hot-air engine.","pos":""}],"THERMOMULTIPLIER":[{"def":"Same as Thermopile.","pos":""}],"THERMONEUROSIS":[{"def":"Ther`mo*neu*ro\"sis, n.","pos":""}],"THERMONEUTRALITY":[{"def":"Neutrality as regards heat effects.","pos":""}],"THERMOPHILIC":[{"def":"Heat-loving; -- applied esp.","pos":""}],"THERMOPHONE":[{"def":"A portable form of telethermometer, using a telephone in connection with a differential thermometer.","pos":""},{"def":"A telephone involving heat effects, as changes in temperature (hence in length) due to pulsations of the line current in a fine wire connected with the receiver diaphragm.","pos":""}],"THERMOPHORE":[{"def":"An apparatus for conveying heat, as a case containing material which retains its heat for a considerable period.","pos":""}],"THERMOPILE":[{"def":"An instrument of extreme sensibility, used to determine slight differences and degrees of heat.","pos":""}],"THERMOREGULATOR":[{"def":"A device for the automatic regulation of temperature; a thermostat.","pos":""}],"THERMOSCOPE":[{"def":"An instrument for indicating changes of temperature without indicating the degree of heat by which it is affected; especially, an instrument contrived by Count Rumford which, as modified by Professor Leslie, was afterward called the differential thermometer.","pos":""}],"THERMOSCOPIC":[{"def":"Of or pertaining to the thermoscope; made by means of the thermoscope; as, thermoscopic observations.","pos":""}],"THERMOSIPHON":[{"def":"An arrangement of siphon tubes for assisting circulation in a liquid.","pos":""}],"THERMOSTABLE":[{"def":"Capable of being heated to or somewhat above 55º C.","pos":""}],"THERMOSTAT":[{"def":"A self-acting apparatus for regulating temperature by the unequal expansion of different metals, liquids, or gases by heat, as in opening or closing the damper of a stove, or the like, as the heat becomes greater or less than is desired.","pos":""}],"THERMOSTATIC":[{"def":"Of or pertaining to the thermostat; made or effected by means of the thermostat.","pos":""}],"THERMOSYSTALTIC":[{"def":"Influenced in its contraction by heat or cold; -- said of a muscle.","pos":""}],"THERMOTACTIC":[{"def":"Of or retaining to thermotaxis.","pos":""}],"THERMOTANK":[{"def":"A tank containing pipes through which circulates steam, water, air, or the like, for heating or cooling; -- used in some heating and ventilation systems.","pos":""}],"THERMOTAXIC":[{"def":"Pertaining to, or connected with, the regulation of temperature in the animal body; as, the thermotaxic nervous system.","pos":""}],"THERMOTENSILE":[{"def":"Pertaining to the variation of tensile strength with the temperature.","pos":""}],"THERMOTENSION":[{"def":"A process of increasing the strength of wrought iron by heating it to a determinate temperature, and giving to it, while in that state, a mechanical strain or tension in the direction in which the strength is afterward to be exerted.","pos":""}],"THERMOTHERAPY":[{"def":"Treatment of disease by heat, esp.","pos":""},{"def":"Of or pertaining to heat; produced by heat; as, thermotical phenomena.","pos":""}],"THERMOTICS":[{"def":"The science of heat.","pos":""}],"THERMOTONUS":[{"def":"A condition of tonicity with respect to temperature.","pos":""}],"THERMOTROPIC":[{"def":"Manifesting thermotropism.","pos":""}],"THERMOTROPISM":[{"def":"The phenomenon of turning towards a source of warmth, seen in the growing parts of some plants.","pos":""}],"THERMOTYPE":[{"def":"A picture (as of a slice of wood) obtained by first wetting the object slightly with hydrochloric or dilute sulphuric acid, then taking an impression with a press, and next strongly heating this impression.","pos":""}],"THERMOTYPY":[{"def":"The art or process of obtaining thermotypes.","pos":""}],"THERMOVOLTAIC":[{"def":"Of or relating to heat and electricity; especially, relating to thermal effects produced by voltaic action.","pos":""}],"THEROID":[{"def":"Resembling a beast in nature or habit; marked by animal characteristics; as, theroid idiocy.","pos":""}],"THEROMORPHA":[{"def":"See Theriodonta.","pos":""}],"THEROPODA":[{"def":"An order of carnivorous dinosaurs in which the feet are less birdlike, and hence more like those of an ordinary quadruped, than in the Ornithopoda.","pos":""}]}