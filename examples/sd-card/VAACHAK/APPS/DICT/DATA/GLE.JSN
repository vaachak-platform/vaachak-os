{"GLEAM":[{"def":"To disgorge filth, as a hawk.","pos":""}],"GLEAMY":[{"def":"Darting beams of light; casting light in rays; flashing; coruscating.","pos":""}],"GLEAN":[{"def":"To gather after a reaper; to collect in scattered or fragmentary parcels, as the grain left by a reaper, or grapes left after the gathering.","pos":""},{"def":"To gather from (a field or vineyard) what is left.","pos":""}],"GLEANER":[{"def":"One who gathers after reapers.","pos":""},{"def":"One who gathers slowly with labor.","pos":""}],"GLEANING":[{"def":"The act of gathering after reapers; that which is collected by gleaning.","pos":""}],"GLEBA":[{"def":"The chambered sporogenous tissue forming the central mass of the sporophore in puff balls, stinkhorns, etc.","pos":""}],"GLEBE":[{"def":"The land belonging, or yielding revenue, to a parish church or ecclesiastical benefice.","pos":""}],"GLEBELESS":[{"def":"Having no glebe.","pos":""}],"GLEBOSITY":[{"def":"The quality of being glebous.","pos":""},{"def":"Pertaining to the glebe; turfy; cloddy; fertile; fruitful.","pos":""}],"GLEDE":[{"def":"The common European kite (Milvus ictinus).","pos":""}],"GLEE":[{"def":"An unaccompanied part song for three or more solo voices.","pos":""}],"GLEE CLUB":[{"def":"A club or company organized for singing glees, and (by extension) part songs, ballads, etc.","pos":""}],"GLEED":[{"def":"A live or glowing coal; a glede.","pos":""}],"GLEEFUL":[{"def":"Merry; gay; joyous.","pos":""}],"GLEEK":[{"def":"An enticing look or glance.","pos":""}],"GLEEMAN":[{"def":"A name anciently given to an itinerant minstrel or musician.","pos":""}],"GLEEN":[{"def":"To glisten; to gleam.","pos":""}],"GLEESOME":[{"def":"Merry; joyous; gleeful.","pos":""}],"GLEET":[{"def":"A transparent mucous discharge from the membrane of the urethra, commonly an effect of gonorrhea.","pos":""}],"GLEETY":[{"def":"Ichorous; thin; limpid.","pos":""}],"GLEG":[{"def":"Quick of perception; alert; sharp.","pos":""}],"GLEN":[{"def":"A secluded and narrow valley; a dale; a depression between hills.","pos":""},{"def":"A kind of Highland Scotch cap for men, with straight sides and a hollow top sloping to the back, where it is parted and held together by ribbons or strings.","pos":""}],"GLENOID":[{"def":"Having the form of a smooth and shallow depression; sockas, the glenoid cavity, or fossa, of the scapula, in which the head of the humerus articulates.","pos":""}],"GLEUCOMETER":[{"def":"An instrument for measuring the specific gravity and ascertaining the quantity of sugar contained in must.","pos":""}],"GLEY":[{"def":"To squint; to look obliquely; to overlook things.","pos":""}]}