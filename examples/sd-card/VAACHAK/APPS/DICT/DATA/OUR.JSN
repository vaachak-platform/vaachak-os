{"OUR":[{"def":"Of or pertaining to us; belonging to us; as, our country; our rights; our troops; our endeavors.","pos":""}],"OURANG":[{"def":"The orang-outang.","pos":""}],"OURANG-OUTANG":[{"def":"See Orang-outang.","pos":""}],"OURANOGRAPHIST":[{"def":"See Uranographist.","pos":""}],"OURANOGRAPHY":[{"def":"See Uranography.","pos":""}],"OUREBI":[{"def":"A small, graceful, and swift African antelope, allied to the klipspringer.","pos":""}],"OURS":[{"def":"See Note under Our.","pos":""}],"OURSELVES":[{"def":"A suffix denoting that the element indicated by the name bearing it, has a valence lower than that denoted by the termination -ic; as, nitrous, sulphurous, etc.","pos":""}]}