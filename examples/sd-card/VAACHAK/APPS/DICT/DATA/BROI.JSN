{"BROIDER":[{"def":"They shall make a broidered coat.","pos":""}],"BROIDERER":[{"def":"One who embroiders.","pos":""}],"BROIDERY":[{"def":"The golden broidery tender Milkah wove.","pos":""}],"BROIL":[{"def":"A tumult; a noisy quarrel; a disturbance; a brawl; contention; discord, either between individuals or in the state.","pos":""}],"BROILER":[{"def":"One who excites broils; one who engages in or promotes noisy quarrels.","pos":""}],"BROILING":[{"def":"Excessively hot; as, a broiling sun.","pos":""},{"def":"The act of causing anything to broil.","pos":""}]}