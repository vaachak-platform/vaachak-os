{"IZARD":[{"def":"A variety of the chamois found in the Pyrenees.","pos":""},{"def":"A verb suffix signifying to make, to do, to practice; as apologize, baptize, theorize, tyrannize.","pos":""}],"IZEDI":[{"def":"One of an Oriental religious sect which worships Satan or the Devil.","pos":""}],"IZEDISM":[{"def":"The religion of the Izedis.","pos":""}],"IZZARD":[{"def":"The letter z; -- formerly so called.","pos":""}]}