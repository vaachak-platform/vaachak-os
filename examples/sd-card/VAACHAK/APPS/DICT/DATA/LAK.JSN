{"LAKE":[{"def":"A pigment formed by combining some coloring matter, usually by precipitation, with a metallic oxide or earth, esp.","pos":""}],"LAKE-DWELLER":[{"def":"See Lake dwellers, under Lake.","pos":""}],"LAKEWEED":[{"def":"The water pepper (Polygonum Hydropiper), an aquatic plant of Europe and North America.","pos":""}],"LAKH":[{"def":"Same as Lac, one hundred thousand.","pos":""}],"LAKY":[{"def":"Pertaining to a lake.","pos":""}]}