{"SCOAT":[{"def":"To prop; to scotch.","pos":""}],"SCOBIFORM":[{"def":"Having the form of, or resembling, sawdust or raspings.","pos":""}],"SCOBS":[{"def":"Raspings of ivory, hartshorn, metals, or other hard substance.","pos":""},{"def":"The dross of metals.","pos":""}],"SCOFF":[{"def":"Derision; ridicule; mockery; derisive or mocking expression of scorn, contempt, or reproach.","pos":""},{"def":"An object of scorn, mockery, or derision.","pos":""}],"SCOFFERY":[{"def":"The act of scoffing; scoffing conduct; mockery.","pos":""}],"SCOFFINGLY":[{"def":"In a scoffing manner.","pos":""}],"SCOKE":[{"def":"Poke (Phytolacca decandra).","pos":""}],"SCOLD":[{"def":"To find fault or rail with rude clamor; to brawl; to utter harsh, rude, boisterous rebuke; to chide sharply or coarsely; -- often with at; as, to scold at a servant.","pos":""}],"SCOLDING":[{"def":"Scold\"ing, Defn: a.","pos":""}],"SCOLDINGLY":[{"def":"In a scolding manner.","pos":""}],"SCOLECIDA":[{"def":"Same as Helminthes.","pos":""}],"SCOLECITE":[{"def":"A zeolitic mineral occuring in delicate radiating groups of white crystals.","pos":""}],"SCOLECOMORPHA":[{"def":"Same as Scolecida.","pos":""}],"SCOLEY":[{"def":"To go to school; to study.","pos":""}],"SCOLIOSIS":[{"def":"A lateral curvature of the spine.","pos":""}],"SCOLITHUS":[{"def":"A tubular structure found in Potsdam sandstone, and believed to be the fossil burrow of a marine worm.","pos":""}],"SCOLOPACINE":[{"def":"Of or pertaining to the Scolopacidæ, or Snipe family.","pos":""}],"SCOLOPENDRA":[{"def":"A genus of venomous myriapods including the centipeds.","pos":""}],"SCOLOPENDRINE":[{"def":"Like or pertaining to the Scolopendra.","pos":""}],"SCOLYTID":[{"def":"Any one of numerous species of small bark-boring beetles of the genus Scolytus and allied genera.","pos":""}],"SCOMBER":[{"def":"A genus of acanthopterygious fishes which includes the common mackerel.","pos":""}],"SCOMBEROID":[{"def":"Same as Scombroid.","pos":""}],"SCOMBRIFORMES":[{"def":"A division of fishes including the mackerels, tunnies, and allied fishes.","pos":""}],"SCOMBROID":[{"def":"Like or pertaining to the Mackerel family.","pos":""},{"def":"Any fish of the family Scombridæ, of which the mackerel (Scomber) is the type.","pos":""}],"SCOMFISH":[{"def":"To suffocate or stifle; to smother.","pos":""}],"SCOMM":[{"def":"A flout; a jeer; a gibe; a taunt.","pos":""}],"SCONCE":[{"def":"A protection for a light; a lantern or cased support for a candle; hence, a fixed hanging or projecting candlestick.","pos":""}],"SCONE":[{"def":"A cake, thinner than a bannock, made of wheat or barley or oat meal.","pos":""}],"SCOOP":[{"def":"A spoon-shaped instrument, used in extracting certain substances or foreign bodies.","pos":""}],"SCOOPER":[{"def":"The avocet; -- so called because it scoops up the mud to obtain food.","pos":""}],"SCOOT":[{"def":"To walk fast; to go quickly; to run hastily away.","pos":""}],"SCOPARIN":[{"def":"A yellow gelatinous or crystalline substance found in broom (Cytisus scoparius) accompanying sparteïne.","pos":""}],"SCOPATE":[{"def":"Having the surface closely covered with hairs, like a brush.","pos":""},{"def":"A combining form usually signifying an instrument for viewing (with the eye) or observing (in any way); as in microscope, telescope, altoscope, anemoscope.","pos":""}],"SCOPE":[{"def":"That at which one aims; the thing or end to which the mind directs its view; that which is purposed to be reached or accomplished; hence, ultimate design, aim, or purpose; intention; drift; object.","pos":""},{"def":"Room or opportunity for free outlook or aim; space for action; amplitude of opportunity; free course or vent; liberty; range of view; intent, or action.","pos":""}],"SCOPELOID":[{"def":"Like or pertaining to fishes of the genus Scopelus, or family Scopelodæ, which includes many small oceanic fishes, most of which are phosphorescent.","pos":""},{"def":"Any fish of the family Scopelidæ.","pos":""}],"SCOPIFEROUS":[{"def":"Bearing a tuft of brushlike hairs.","pos":""}],"SCOPIFORM":[{"def":"Having the form of a broom or besom.","pos":""}],"SCOPIPED":[{"def":"Same as Scopuliped.","pos":""}],"SCOPPET":[{"def":"To lade or dip out.","pos":""}],"SCOPS OWL":[{"def":"Any one of numerous species of small owls of the genus Scops having ear tufts like those of the horned owls, especially the European scops owl (Scops giu), and the American screech owl.","pos":""},{"def":"Jesting; jeering; scoffing.","pos":""}],"SCOPULIPED":[{"def":"Any species of bee which has on the hind legs a brush of hairs used for collecting pollen, as the hive bees and bumblebees.","pos":""}],"SCOPULOUS":[{"def":"Full of rocks; rocky.","pos":""}],"SCORBUTE":[{"def":"Of or pertaining to scurvy; of the nature of, or resembling, scurvy; diseased with scurvy; as, a scorbutic person; scorbutic complaints or symptoms.","pos":""}],"SCORCH":[{"def":"To burn superficially; to parch, or shrivel, the surface of, by heat; to subject to so much heat as changes color and texture without consuming; as, to scorch linen.","pos":""},{"def":"To affect painfully with heat, or as with heat; to dry up with heat; to affect as by heat.","pos":""}],"SCORCHING":[{"def":"Burning; parching or shriveling with heat.","pos":""}],"SCORE":[{"def":"The original and entire draught, or its transcript, of a composition, with the parts for all the different instruments or voices written on staves one above another, so that they can be read at a glance; -- so called from the bar, which, in its early use, was drawn through all the parts.","pos":""}],"SCORER":[{"def":"One who, or that which, scores.","pos":""}],"SCORIA":[{"def":"The recrement of metals in fusion, or the slag rejected after the eduction of metallic ores; dross.","pos":""},{"def":"Cellular slaggy lava; volcanic cinders.","pos":""}],"SCORIACEOUS":[{"def":"Of or pertaining to scoria; like scoria or the recrement of metals; partaking of the nature of scoria.","pos":""}],"SCORIE":[{"def":"The young of any gull.","pos":""}],"SCORIFICATION":[{"def":"The act, process, or result of scorifying, or reducing to a slag; hence, the separation from earthy matter by means of a slag; as, the scorification of ores.","pos":""}],"SCORIFIER":[{"def":"One who, or that which, scorifies; specifically, a small flat bowl-shaped cup used in the first heating in assaying, to remove the earth and gangue, and to concentrate the gold and silver in a lead button.","pos":""}],"SCORIFORM":[{"def":"In the form of scoria.","pos":""}],"SCORIFY":[{"def":"To reduce to scoria or slag; specifically, in assaying, to fuse so as to separate the gangue and earthy material, with borax, lead, soda, etc.","pos":""}],"SCORN":[{"def":"Extreme and lofty contempt; haughty disregard; that disdain which aprings from the opinion of the utter meanness and unworthiness of an object.","pos":""},{"def":"An act or expression of extreme contempt.","pos":""}],"SCORNER":[{"def":"One who scorns; a despiser; a contemner; specifically, a scoffer at religion.","pos":""}],"SCORNFUL":[{"def":"Full of scorn or contempt; contemptuous; disdainful.","pos":""},{"def":"Treated with scorn; exciting scorn.","pos":""}],"SCORNY":[{"def":"Deserving scorn; paltry.","pos":""}],"SCORODITE":[{"def":"A leek-green or brownish mineral occurring in orthorhombic crystals.","pos":""}],"SCORPAENOID":[{"def":"Of or pertaining to the family Scorpænidæ, which includes the scorpene, the rosefish, the California rockfishes, and many other food fishes.","pos":""}],"SCORPENE":[{"def":"A marine food fish of the genus Scorpæna, as the European hogfish (S.","pos":""}],"SCORPER":[{"def":"Same as Scauper.","pos":""}],"SCORPIO":[{"def":"It is drawn on the celestial globe in the figure of a scorpion.","pos":""}],"SCORPIODEA":[{"def":"Same as Scorpiones.","pos":""}],"SCORPION":[{"def":"Any one of numerous species of pulmonate arachnids of the order scorpiones, having a suctorial mouth, large claw-bearing palpi, and a caudal sting.","pos":""},{"def":"The pine or gray lizard (Sceloporus undulatus).","pos":""}],"SCORPIONES":[{"def":"A division of arachnids comprising the scorpions.","pos":""}],"SCORPIONIDEA":[{"def":"Same as Scorpiones.","pos":""}],"SCORPIONWORT":[{"def":"A leguminous plant (Ornithopus scorpides) of Southern Europe, having curved pods.","pos":""}],"SCORSE":[{"def":"Barter; exchange; trade.","pos":""}],"SCORTATORY":[{"def":"Pertaining to lewdness or fornication; lewd.","pos":""}],"SCOT":[{"def":"A name for a horse.","pos":""}],"SCOT-FREE":[{"def":"Free from payment of scot; untaxed; hence, unhurt; clear; safe.","pos":""}],"SCOTCH":[{"def":"Of or pertaining to Scotland, its language, or its inhabitants; Scottish.","pos":""}],"SCOTCH RITE":[{"def":"The ceremonial observed by one of the Masonic systems, called in full the Ancient and Accepted Scotch Rite; also, the system itself, which confers thirty-three degrees, of which the first three are nearly identical with those of the York rite.","pos":""}],"SCOTCH TERRIER":[{"def":"One of a breed of small terriers with long, rough hair.","pos":""}],"SCOTCHING":[{"def":"Dressing stone with a pick or pointed instrument.","pos":""}],"SCOTCHMAN":[{"def":"A piece of wood or stiff hide placed over shrouds and other rigging to prevent chafe by the running gear.","pos":""}],"SCOTER":[{"def":"Any one of several species of northern sea ducks of the genus Oidemia.","pos":""}],"SCOTH":[{"def":"To clothe or cover up.","pos":""}],"SCOTIA":[{"def":"A concave molding used especially in classical architecture.","pos":""}],"SCOTIST":[{"def":"A follower of (Joannes) Duns Scotus, the Franciscan scholastic (d.","pos":""}],"SCOTOGRAPH":[{"def":"An instrument for writing in the dark, or without seeing.","pos":""}],"SCOTOMY":[{"def":"Obscuration of the field of vision due to the appearance of a dark spot before the eye.","pos":""}],"SCOTOSCOPE":[{"def":"An instrument that discloses objects in the dark or in a faint light.","pos":""}],"SCOTS":[{"def":"Of or pertaining to the Scotch; Scotch; Scottish; as, Scots law; a pound Scots (1s.","pos":""}],"SCOTTERING":[{"def":"The burning of a wad of pease straw at the end of harvest.","pos":""}],"SCOTTICISM":[{"def":"An idiom, or mode of expression, peculiar to Scotland or Scotchmen.","pos":""}],"SCOTTICIZE":[{"def":"To cause to become like the Scotch; to make Scottish.","pos":""}],"SCOTTISH":[{"def":"Of or pertaining to the inhabitants of Scotland, their country, or their language; as, Scottish industry or economy; a Scottish chief; a Scottish dialect.","pos":""}],"SCOTTISH TERRIER":[{"def":"Same as Scotch terrier.","pos":""}],"SCOUNDREL":[{"def":"A mean, worthless fellow; a rascal; a villain; a man without honor or virtue.","pos":""}],"SCOUNDRELDOM":[{"def":"The domain or sphere of scoundrels; scoundrels, collectively; the state, ideas, or practices of scoundrels.","pos":""}],"SCOUNDRELISM":[{"def":"The practices or conduct of a scoundrel; baseness; rascality.","pos":""}],"SCOUR":[{"def":"To pass swiftly over; to brush along; to traverse or search thoroughly; as, to scour the coast.","pos":""}],"SCOURAGE":[{"def":"Refuse water after scouring.","pos":""}],"SCOURER":[{"def":"One who, or that which, scours.","pos":""},{"def":"A rover or footpad; a prowling robber.","pos":""}],"SCOURGE":[{"def":"A lash; a strap or cord; especially, a lash used to inflict pain or punishment; an instrument of punishment or discipline; a whip.","pos":""},{"def":"Hence, a means of inflicting punishment, vengeance, or suffering; an infliction of affliction; a punishment.","pos":""}],"SCOURGER":[{"def":"One who scourges or punishes; one who afflicts severely.","pos":""}],"SCOUSE":[{"def":"A sailor's dish.","pos":""}],"SCOUT":[{"def":"A swift sailing boat.","pos":""}],"SCOVEL":[{"def":"A mop for sweeping ovens; a malkin.","pos":""}],"SCOW":[{"def":"A large flat-bottomed boat, having broad, square ends.","pos":""}],"SCOWL":[{"def":"To wrinkle the brows, as in frowning or displeasure; to put on a frowning look; to look sour, sullen, severe, or angry.","pos":""},{"def":"Hence, to look gloomy, dark, or threatening; to lower.","pos":""}],"SCOWLINGLY":[{"def":"In a scowling manner.","pos":""}]}