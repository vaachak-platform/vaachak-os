{"TRANSMISSIBLE":[{"def":"Capable of being transmitted from one to another; capable of being passed through any body or substance.","pos":""}],"TRANSMISSION":[{"def":"The right possessed by an heir or legatee of transmitting to his successor or successors any inheritance, legacy, right, or privilege, to which he is entitled, even if he should die without enjoying or exercising it.","pos":""}],"TRANSMISSION DYNAMOMETER":[{"def":"A dynamometer in which power is measured, without being absorbed or used up, during transmission.","pos":""}],"TRANSMISSIONIST":[{"def":"An adherent of a theory, the transmission theory, that the brain serves to \"transmit,\" rather than to originate, conclusions, and hence that consciousness may exist independently of the brain.","pos":""}],"TRANSMISSIVE":[{"def":"Capable of being transmitted; derived, or handed down, from one to another.","pos":""}],"TRANSMIT":[{"def":"To cause to pass over or through; to communicate by sending; to send from one person or place to another; to pass on or down as by inheritance; as, to transmit a memorial; to transmit dispatches; to transmit money, or bills of exchange, from one country to another.","pos":""},{"def":"To suffer to pass through; as, glass transmits light; metals transmit, or conduct, electricity.","pos":""}],"TRANSMITTER":[{"def":"One who, or that which, transmits; specifically, that portion of a telegraphic or telephonic instrument by means of which a message is sent; -- opposed to receiver.","pos":""}],"TRANSMITTIBLE":[{"def":"Capable of being transmitted; transmissible.","pos":""}],"TRANSMOGRIFICATION":[{"def":"The act of transmogrifying, or the state of being transmogrified; transformation.","pos":""}],"TRANSMOGRIFY":[{"def":"To change into a different shape; to transform.","pos":""}],"TRANSMOVE":[{"def":"To move or change from one state into another; to transform.","pos":""}],"TRANSMUTABILITY":[{"def":"The quality of being transmutable.","pos":""}],"TRANSMUTABLE":[{"def":"Capable of being transmuted or changed into a different substance, or into into something of a different form a nature; transformable.","pos":""}],"TRANSMUTATION":[{"def":"The change or reduction of one figure or body into another of the same area or solidity, but of a different form, as of a triangle into a square.","pos":""},{"def":"The change of one species into another, which is assumed to take place in any development theory of life; transformism.","pos":""}],"TRANSMUTATIONIST":[{"def":"One who believes in the transmutation of metals or of species.","pos":""}],"TRANSMUTE":[{"def":"To change from one nature, form, or substance, into another; to transform.","pos":""}],"TRANSMUTER":[{"def":"One who transmutes.","pos":""}],"TRANSMUTUAL":[{"def":"Reciprocal; commutual.","pos":""}],"TRANSNATATION":[{"def":"The act of swimming across, as a river.","pos":""}],"TRANSNATURE":[{"def":"To transfer or transform the nature of.","pos":""}],"TRANSOM":[{"def":"A horizontal crossbar in a window, over a door, or between a door and a window above it.","pos":""},{"def":"One of the principal transverse timbers of the stern, bolted to the sternpost and giving shape to the stern structure; -- called also transsummer.","pos":""}],"TRANSPADANE":[{"def":"Lying or being on the further side of the river Po with reference to Rome, that is, on the north side; -- opposed to cispadane.","pos":""}],"TRANSPALATINE":[{"def":"Situated beyond or outside the palatine bone; -- said of a bone in the skull of some reptiles.","pos":""}],"TRANSPARE":[{"def":"To be, or cause to be, transparent; to appear, or cause to appear, or be seen, through something.","pos":""}],"TRANSPARENCE":[{"def":"The quality or state of being transparent; transparency.","pos":""}],"TRANSPARENCY":[{"def":"The quality or condition of being transparent; transparence.","pos":""},{"def":"That which is transparent; especially, a picture painted on thin cloth or glass, or impressed on porcelain, or the like, to be viewed by natural or artificial light, which shines through it.","pos":""}],"TRANSPARENT":[{"def":"Having the property of transmitting rays of light, so that bodies can be distinctly seen through; pervious to light; diaphanous; pellucid; as, transparent glass; a transparent diamond; -- opposed to Ant: opaque.","pos":""},{"def":"Admitting the passage of light; open; porous; as, a transparent veil.","pos":""}],"TRANSPASS":[{"def":"To pass over; as, Alexander transpassed the river.","pos":""}],"TRANSPASSABLE":[{"def":"Capable of being transpassed, or crossed over.","pos":""}],"TRANSPATRONIZE":[{"def":"To transfer the patronage of.","pos":""}],"TRANSPECIATE":[{"def":"To change from one species to another; to transform.","pos":""}],"TRANSPICUOUS":[{"def":"Transparent; pervious to the sight.","pos":""}],"TRANSPIERCE":[{"def":"To pierce through; to penetrate; to permeate; to pass through.","pos":""}],"TRANSPIRABLE":[{"def":"Capable of being transpired, or of transpiring.","pos":""}],"TRANSPIRATION":[{"def":"The act or process of transpiring or excreting in the form of vapor; exhalation, as through the skin or other membranes of the body; as, pulmonary transpiration, or the excretion of aqueous vapor from the lungs.","pos":""},{"def":"The evaporation of water, or exhalation of aqueous vapor, from cells and masses of tissue.","pos":""}],"TRANSPIRATORY":[{"def":"Of or relating to transpiration.","pos":""}],"TRANSPIRE":[{"def":"To pass off in the form of vapor or insensible perspiration; to exhale.","pos":""},{"def":"To evaporate from living cells.","pos":""}],"TRANSPLACE":[{"def":"To remove across some space; to put in an opposite or another place.","pos":""}],"TRANSPLANT":[{"def":"To remove, and plant in another place; as, to transplant trees.","pos":""},{"def":"To remove, and settle or establish for residence in another place; as, to transplant inhabitants.","pos":""}],"TRANSPLANTATION":[{"def":"The removal of tissues from a healthy part, and the insertion of them in another place where there is a lesion; as, the transplantation of tissues in autoplasty.","pos":""},{"def":"The removal of a bodily organ or of tissues from one person, and the insertion of them into another person to replace a damaged organ or tissue; as, the transplantation of a heart, kidney, or liver.","pos":""}],"TRANSPLANTER":[{"def":"One who transplants; also, a machine for transplanting trees.","pos":""}],"TRANSPLENDENCY":[{"def":"Quality or state of being transplendent.","pos":""}],"TRANSPLENDENT":[{"def":"Resplendent in the highest degree.","pos":""}],"TRANSPORT":[{"def":"To carry or bear from one place to another; to remove; to convey; as, to transport goods; to transport troops.","pos":""},{"def":"To carry, or cause to be carried, into banishment, as a criminal; to banish.","pos":""}],"TRANSPORTABILITY":[{"def":"The quality or state of being transportable.","pos":""}],"TRANSPORTABLE":[{"def":"Capable of being transported.","pos":""},{"def":"Incurring, or subject to, the punishment of transportation; as, a transportable offense.","pos":""}],"TRANSPORTAL":[{"def":"Transportation; the act of removing from one locality to another.","pos":""}],"TRANSPORTANT":[{"def":"Transporting; as, transportant love.","pos":""}],"TRANSPORTATION":[{"def":"The act of transporting, or the state of being transported; carriage from one place to another; removal; conveyance.","pos":""},{"def":"Transport; ecstasy.","pos":""}],"TRANSPORTED":[{"def":"Conveyed from one place to another; figuratively, carried away with passion or pleasure; entranced.","pos":""}],"TRANSPORTER":[{"def":"One who transports.","pos":""}],"TRANSPORTING":[{"def":"That transports; fig.","pos":""}],"TRANSPORTINGLY":[{"def":"So as to transport.","pos":""}],"TRANSPORTMENT":[{"def":"The act of transporting, or the state of being transported; transportation.","pos":""}],"TRANSPOSABLE":[{"def":"That may transposed; as, a transposable phrase.","pos":""}],"TRANSPOSAL":[{"def":"The act of transposing, or the state of being transposed; transposition.","pos":""}],"TRANSPOSE":[{"def":"To bring, as any term of an equation, from one side over to the other, without destroying the equation; thus, if a + b = c, and we make a = c - b, then b is said to be transposed.","pos":""},{"def":"To change the natural order of, as words.","pos":""}],"TRANSPOSER":[{"def":"One who transposes.","pos":""}],"TRANSPOSITION":[{"def":"The act of transposing, or the state of being transposed.","pos":""},{"def":"The bringing of any term of an equation from one side over to the other without destroying the equation.","pos":""}],"TRANSPOSITIONAL":[{"def":"Of or pertaining to transposition; involving transposition.","pos":""}],"TRANSPOSITIVE":[{"def":"Made by transposing; consisting in transposition; transposable.","pos":""}],"TRANSPRINT":[{"def":"To transfer to the wrong place in printing; to print out of place.","pos":""}],"TRANSPROSE":[{"def":"To change from prose into verse; to versify; also, to change from verse into prose.","pos":""}],"TRANSSHAPE":[{"def":"To change into another shape or form; to transform.","pos":""}],"TRANSSHIP":[{"def":"To transfer from one ship or conveyance to another.","pos":""}],"TRANSSHIPMENT":[{"def":"The act of transshipping, or transferring, as goods, from one ship or conveyance to another.","pos":""}],"TRANSUBSTANTIATE":[{"def":"To change, as the sacramental elements, bread and wine, into the flesh and blood of Christ.","pos":""}],"TRANSUBSTANTIATION":[{"def":"The doctrine held by Roman Catholics, that the bread and wine in the Mass is converted into the body and blood of Christ; -- distinguished from consubstantiation, and impanation.","pos":""}],"TRANSUBSTANTIATOR":[{"def":"One who maintains the doctrine of transubstantiation.","pos":""}],"TRANSUDATION":[{"def":"Same as Exosmose.","pos":""}],"TRANSUDATORY":[{"def":"Of or pertaining to transudation; passing by transudation.","pos":""}],"TRANSUDE":[{"def":"To pass, as perspirable matter does, through the pores or interstices of textures; as, liquor may transude through leather or wood.","pos":""}],"TRANSUME":[{"def":"To change; to convert.","pos":""}],"TRANSUMPT":[{"def":"A copy or exemplification of a record.","pos":""}],"TRANSUMPTION":[{"def":"Act of taking from one place to another.","pos":""}],"TRANSUMPTIVE":[{"def":"Taking from one to another; metaphorical.","pos":""}],"TRANSVASATE":[{"def":"To pour out of one vessel into another.","pos":""}],"TRANSVASATION":[{"def":"The act or process of pouring out of one vessel into another.","pos":""}],"TRANSVECTION":[{"def":"The act of conveying or carrying over.","pos":""}],"TRANSVERBERATE":[{"def":"To beat or strike through.","pos":""}],"TRANSVERSAL":[{"def":"Running or lying across; transverse; as, a transversal line.","pos":""}],"TRANSVERSE":[{"def":"Lying or being across, or in a crosswise direction; athwart; -- often opposed to Ant: longitudinal.","pos":""}],"TRANSVERSELY":[{"def":"In a transverse manner.","pos":""}],"TRANSVERSION":[{"def":"The act of changing from prose into verse, or from verse into prose.","pos":""}],"TRANSVERT":[{"def":"To cause to turn across; to transverse.","pos":""}],"TRANSVERTIBLE":[{"def":"Capable of being transverted.","pos":""}],"TRANSVOLATION":[{"def":"The act of flying beyond or across.","pos":""}]}