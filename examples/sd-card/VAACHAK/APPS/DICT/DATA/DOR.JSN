{"DOR":[{"def":"A large European scaraboid beetle (Geotrupes stercorarius), which makes a droning noise while flying.","pos":""}],"DORADO":[{"def":"A southern constellation, within which is the south pole of the ecliptic; -- called also sometimes Xiphias, or the Swordfish.","pos":""},{"def":"A large, oceanic fish of the genus Coryphæna.","pos":""}],"DOREE":[{"def":"A European marine fish (Zeus faber), of a yellow color.","pos":""}],"DORHAWK":[{"def":"The European goatsucker; -- so called because it eats the dor beetle.","pos":""}],"DORIAN":[{"def":"Same as Doric, 3.","pos":""}],"DORIC":[{"def":"Belonging to, or resembling, the oldest and simplest of the three orders of architecture used by the Greeks, but ranked as second of the five orders adopted by the Romans.","pos":""},{"def":"Of or relating to one of the ancient Greek musical modes or keys.","pos":""}],"DORICISM":[{"def":"A Doric phrase or idiom.","pos":""}],"DORIS":[{"def":"A genus of nudibranchiate mollusks having a wreath of branchiæ on the back.","pos":""}],"DORISM":[{"def":"A Doric phrase or idiom.","pos":""}],"DORKING FOWL":[{"def":"One of a breed of large-bodied domestic fowls, having five toes, or the hind toe double.","pos":""}],"DORMANCY":[{"def":"The state of being dormant; quiescence; abeyance.","pos":""}],"DORMANT":[{"def":"In a sleeping posture; as, a lion dormant; -- distinguished from couchant.","pos":""}],"DORMITIVE":[{"def":"Causing sleep; as, the dormitive properties of opium.","pos":""},{"def":"A medicine to promote sleep; a soporific; an opiate.","pos":""}],"DORMITORY":[{"def":"A sleeping room, or a building containing a series of sleeping rooms; a sleeping apartment capable of containing many beds; esp.","pos":""}],"DORMOUSE":[{"def":"A small European rodent of the genus Myoxus, of several species.","pos":""}],"DORMY":[{"def":"Up, or ahead, as many holes as remain to be played; -- said of a player or side.","pos":""}],"DORN":[{"def":"A British ray; the thornback.","pos":""},{"def":"A coarse sort of damask, originally made at Tournay (in Flemish, Doornick), Belgium, and used for hangings, carpets, etc.","pos":""}],"DORR":[{"def":"The dorbeetle; also, a drone or an idler.","pos":""}],"DORSAD":[{"def":"Toward the dorsum or back; on the dorsal side; dorsally.","pos":""}],"DORSAL":[{"def":"Pertaining to, or situated near, the back, or dorsum, of an animal or of one of its parts; notal; tergal; neural; as, the dorsal fin of a fish; the dorsal artery of the tongue; -- opposed to ventral.","pos":""}],"DORSALE":[{"def":"Same as Dorsal, n.","pos":""}],"DORSALLY":[{"def":"On, or toward, the dorsum, or back; on the dorsal side of; dorsad.","pos":""}],"DORSE":[{"def":"Same as dorsal, n.","pos":""},{"def":"The back of a book.","pos":""}],"DORSEL":[{"def":"Same as Dorsal, n.","pos":""}],"DORSIBRANCHIATA":[{"def":"A division of chætopod annelids in which the branchiæ are along the back, on each side, or on the parapodia.","pos":""}],"DORSIBRANCHIATE":[{"def":"Having branchiæ along the back; belonging to the Dorsibranchiata.","pos":""},{"def":"One of the Dorsibranchiata.","pos":""}],"DORSIFEROUS":[{"def":"Bearing, or producing, on the back; -- applied to ferns which produce seeds on the back of the leaf, and to certain Batrachia, the ova of which become attached to the skin of the back of the parent, where they develop; dorsiparous.","pos":""}],"DORSIPAROUS":[{"def":"Same as Dorsiferous.","pos":""}],"DORSIVENTRAL":[{"def":"Having distinct upper and lower surfaces, as most common leaves.","pos":""},{"def":"See Dorsoventral.","pos":""}],"DORSOVENTRAL":[{"def":"From the dorsal to the ventral side of an animal; as, the dorsoventral axis.","pos":""}],"DORSUM":[{"def":"The back or dorsal region of an animal; the upper side of an appendage or part; as, the dorsum of the tongue.","pos":""}],"DORY":[{"def":"A European fish.","pos":""},{"def":"The American wall-eyed perch; -- called also doré.","pos":""}],"DORYPHORA":[{"def":"A genus of plant-eating beetles, including the potato beetle.","pos":""}],"DORYPHOROS":[{"def":"A spear bearer; a statue of a man holding a spear or in the attitude of a spear bearer.","pos":""}]}