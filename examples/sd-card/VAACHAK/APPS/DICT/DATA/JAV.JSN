{"JAVA":[{"def":"One of the islands of the Malay Archipelago belonging to the Netherlands.","pos":""},{"def":"Java coffee, a kind of coffee brought from Java.","pos":""}],"JAVANESE":[{"def":"Of or pertaining to Java, or to the people of Java.","pos":""},{"def":"A native or natives of Java.","pos":""}],"JAVELIN":[{"def":"A sort of light spear, to be thrown or cast by thew hand; anciently, a weapon of war used by horsemen and foot soldiers; now used chiefly in hunting the wild boar and other fierce game.","pos":""}],"JAVELINIER":[{"def":"A soldier armed with a javelin.","pos":""}]}