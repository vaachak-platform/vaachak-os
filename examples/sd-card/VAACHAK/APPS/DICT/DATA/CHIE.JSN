{"CHIEF":[{"def":"The upper third part of the field.","pos":""}],"CHIEF BARON":[{"def":"The presiding judge of the court of exchequer.","pos":""}],"CHIEF HARE":[{"def":"A small rodent (Lagamys princeps) inhabiting the summits of the Rocky Mountains; -- also called crying hare, calling hare, cony, American pika, and little chief hare.","pos":""}],"CHIEF JUSTICE":[{"def":"The presiding justice, or principal judge, of a court.","pos":""}],"CHIEF-JUSTICESHIP":[{"def":"The office of chief justice.","pos":""}],"CHIEFAGE":[{"def":"A tribute by the head; a capitation tax.","pos":""}],"CHIEFEST":[{"def":"First or foremost; chief; principal.","pos":""}],"CHIEFLESS":[{"def":"Without a chief or leader.","pos":""}],"CHIEFLY":[{"def":"In the first place; principally; preëminently; above; especially.","pos":""},{"def":"For the most part; mostly.","pos":""}],"CHIEFRIE":[{"def":"A small rent paid to the lord paramount.","pos":""}],"CHIEFTAIN":[{"def":"A captain, leader, or commander; a chief; the head of a troop, army, or clan.","pos":""},{"def":"The rank, dignity, or office of a chieftain.","pos":""}],"CHIERTE":[{"def":"Love; tender regard.","pos":""}],"CHIEVANCE":[{"def":"An unlawful bargain; traffic in which money is exported as discount.","pos":""}]}