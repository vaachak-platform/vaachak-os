{"ASEMIA":[{"def":"Loss of power to express, or to understand, symbols or signs of thought.","pos":""}],"ASEPSIS":[{"def":"State of being aseptic; the methods or processes of asepticizing.","pos":""}],"ASEPTIC":[{"def":"Not liable to putrefaction; nonputrescent.","pos":""},{"def":"An aseptic substance.","pos":""}],"ASEXUAL":[{"def":"Having no distinct; without sexual action; as, asexual reproduction.","pos":""}],"ASEXUALIZATION":[{"def":"The act or process of sterilizing an animal or human being, as by vasectomy.","pos":""}],"ASEXUALLY":[{"def":"In an asexual manner; without sexual agency.","pos":""}]}