{"MISLACTATION":[{"def":"Defective flow or vitiated condition of the milk.","pos":""}],"MISLAY":[{"def":"To lay in a wrong place; to ascribe to a wrong source.","pos":""},{"def":"To lay in a place not recollected; to lose.","pos":""}],"MISLAYER":[{"def":"One who mislays.","pos":""}],"MISLE":[{"def":"To rain in very fine drops, like a thick mist; to mizzle.","pos":""}],"MISLEAD":[{"def":"To lead into a wrong way or path; to lead astray; to guide into error; to cause to mistake; to deceive.","pos":""}],"MISLEADER":[{"def":"One who leads into error.","pos":""}],"MISLEADING":[{"def":"Leading astray; delusive.","pos":""}],"MISLEARN":[{"def":"To learn wrongly.","pos":""}],"MISLIGHT":[{"def":"To deceive or lead astray with a false light.","pos":""}],"MISLIKE":[{"def":"To dislike; to disapprove of; to have aversion to; as, to mislike a man.","pos":""}],"MISLIKER":[{"def":"One who dislikes.","pos":""}],"MISLIKING":[{"def":"Dislike; aversion.","pos":""}],"MISLUCK":[{"def":"Ill luck; misfortune.","pos":""}],"MISLY":[{"def":"Raining in very small drops.","pos":""}]}