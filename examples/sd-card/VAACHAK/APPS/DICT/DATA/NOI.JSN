{"NOIL":[{"def":"A short or waste piece or knot of wool separated from the longer staple by combing; also, a similar piece or shred of waste silk.","pos":""}],"NOILS":[{"def":"Waste and knots of wool removed by the comb; combings.","pos":""}],"NOIOUS":[{"def":"Annoying; troublesome.","pos":""}],"NOISE":[{"def":"Sound of any kind.","pos":""},{"def":"Especially, loud, confused, or senseless sound; clamor; din.","pos":""}],"NOISEFUL":[{"def":"Loud; clamorous.","pos":""}],"NOISELESS":[{"def":"Making, or causing, no noise or bustle; without noise; silent; as, the noiseless foot of time.","pos":""}],"NOISETTE":[{"def":"A hybrid rose produced in 1817, by a French gardener, Noisette, of Charleston, South Carolina, from the China rose and the musk rose.","pos":""}],"NOISILY":[{"def":"In a noisy manner.","pos":""}],"NOISINESS":[{"def":"The state or quality of being noisy.","pos":""}],"NOISOME":[{"def":"Noxious to health; hurtful; mischievous; unwholesome; insalubrious; destructive; as, noisome effluvia.","pos":""},{"def":"Offensive to the smell or other senses; disgusting; fetid.","pos":""}],"NOISY":[{"def":"Making a noise, esp.","pos":""}]}