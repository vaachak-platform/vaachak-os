{"SEMISAVAGE":[{"def":"One who is half savage.","pos":""}],"SEMISEXTILE":[{"def":"An aspect of the planets when they are distant from each other the twelfth part of a circle, or thirty degrees.","pos":""}],"SEMISOLID":[{"def":"Partially solid.","pos":""}],"SEMISOUN":[{"def":"A half sound; a low tone.","pos":""},{"def":"Having the figure of a half sphere.","pos":""}],"SEMISPHEROIDAL":[{"def":"Formed like a half spheroid.","pos":""}]}