{"HYBLAEAN":[{"def":"Pertaining to Hybla, an ancient town of Sicily, famous for its bees.","pos":""}],"HYBODONT":[{"def":"Of, pertaining to, or resembling, an extinct genus of sharks (Hybodus), especially in the form of the teeth, which consist of a principal median cone with smaller lateral ones.","pos":""}],"HYBODUS":[{"def":"An extinct genus of sharks having conical, compressed teeth.","pos":""}],"HYBRID":[{"def":"The offspring of the union of two distinct species; an animal or plant produced from the mixture of two species.","pos":""}],"HYBRIDISM":[{"def":"The state or quality of being hybrid.","pos":""}],"HYBRIDIST":[{"def":"One who hybridizes.","pos":""}],"HYBRIDIZABLE":[{"def":"Capable of forming a hybrid, or of being subjected to a hybridizing process; capable of producing a hybrid by union with another species or stock.","pos":""}],"HYBRIDIZATION":[{"def":"The act of hybridizing, or the state of being hybridized.","pos":""}],"HYBRIDIZE":[{"def":"To render hybrid; to produce by mixture of stocks.","pos":""}],"HYBRIDIZER":[{"def":"One who hybridizes.","pos":""}]}