{"QUAT":[{"def":"To satiate; to satisfy.","pos":""}],"QUATER-COUSIN":[{"def":"A cousin within the first four degrees of kindred.","pos":""}],"QUATERNARY":[{"def":"Later than, or subsequent to, the Tertiary; Post-tertiary; as, the Quaternary age, or Age of man.","pos":""}],"QUATERNATE":[{"def":"Composed of, or arranged in, sets of four; quaternary; as, quaternate leaves.","pos":""}],"QUATERNION":[{"def":"The quotient of two vectors, or of two directed right lines in space, considered as depending on four geometrical elements, and as expressible by an algebraic symbol of quadrinomial form.","pos":""}],"QUATERNITY":[{"def":"The number four.","pos":""},{"def":"The union of four in one, as of four persons; -- analogous to the theological term trinity.","pos":""}],"QUATERON":[{"def":"See 2d Quarteron.","pos":""}],"QUATORZAIN":[{"def":"A poem of fourteen lines; a sonnet.","pos":""}],"QUATORZE":[{"def":"The four aces, kings, queens, knaves, or tens, in the game of piquet; -- so called because quatorze counts as fourteen points.","pos":""}],"QUATRAIN":[{"def":"A stanza of four lines rhyming alternately.","pos":""}],"QUATRE":[{"def":"Same as Quarterfoil.","pos":""}],"QUATTROCENTO":[{"def":"The fifteenth century, when applied to Italian art or literature; as, the sculpture of the quattrocento; quattrocento style.","pos":""}],"QUATUOR":[{"def":"A quartet; -- applied chiefly to instrumental compositions.","pos":""}]}