{"STING":[{"def":"Any sharp organ of offense and defense, especially when connected with a poison gland, and adapted to inflict a wound by piercing; as the caudal sting of a scorpion.","pos":""},{"def":"A sharp-pointed hollow hair seated on a gland which secrets an acrid fluid, as in nettles.","pos":""}],"STINGBULL":[{"def":"The European greater weever fish (Trachinus draco), which is capable of inflicting severe wounds with the spinous rays of its dorsal fin.","pos":""}],"STINGER":[{"def":"One who, or that which, stings.","pos":""}],"STINGILY":[{"def":"In a stingy manner.","pos":""}],"STINGINESS":[{"def":"The quality or state of being stingy.","pos":""}],"STINGING":[{"def":"Piercing, or capable of piercing, with a sting; inflicting acute pain as if with a sting, goad, or pointed weapon; pungent; biting; as, stinging cold; a stinging rebuke.","pos":""}],"STINGLESS":[{"def":"Having no sting.","pos":""}],"STINGO":[{"def":"Old beer; sharp or strong liquor.","pos":""},{"def":"Any one of numerous rays of the family Dasyatidæ, syn.","pos":""}],"STINGY":[{"def":"Stinging; able to sting.","pos":""}],"STINK":[{"def":"To emit a strong, offensive smell; to send out a disgusting odor.","pos":""}],"STINKARD":[{"def":"The teledu of the East Indies.","pos":""}],"STINKBALL":[{"def":"A composition of substances which in combustion emit a suffocating odor; -- used formerly in naval warfare.","pos":""}],"STINKER":[{"def":"Any one of the several species of large antarctic petrels which feed on blubber and carrion and have an offensive odor, as the giant fulmar.","pos":""}],"STINKHORN":[{"def":"A kind of fungus of the genus Phallus, which emits a fetid odor.","pos":""}],"STINKINGLY":[{"def":"In a stinking manner; with an offensive smell.","pos":""}],"STINKPOT":[{"def":"The musk turtle, or musk tortoise.","pos":""}],"STINKSTONE":[{"def":"One of the varieties of calcite, barite, and feldspar, which emit a fetid odor on being struck; -- called also swinestone.","pos":""}],"STINKWOOD":[{"def":"A name given to several kinds of wood with an unpleasant smell, as that of the Foetidia Mauritiana of the Mauritius, and that of the South African Ocotea bullata.","pos":""}],"STINT":[{"def":"To restrain within certain limits; to bound; to confine; to restrain; to restrict to a scant allowance.","pos":""},{"def":"To put an end to; to stop.","pos":""}],"STINTANCE":[{"def":"Restraint; stoppage.","pos":""}],"STINTEDNESS":[{"def":"The state of being stinted.","pos":""}],"STINTER":[{"def":"One who, or that which, stints.","pos":""}],"STINTLESS":[{"def":"Without stint or restraint.","pos":""}]}