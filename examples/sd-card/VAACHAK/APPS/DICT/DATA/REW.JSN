{"REWARD":[{"def":"To give in return, whether good or evil; -- commonly in a good sense; to requite; to recompense; to repay; to compensate.","pos":""}],"REWARDABLE":[{"def":"Worthy of reward.","pos":""}],"REWARDER":[{"def":"One who rewards.","pos":""}],"REWARDFUL":[{"def":"Yielding reward.","pos":""}],"REWARDLESS":[{"def":"Having, or affording, no reward.","pos":""}],"REWEL BONE":[{"def":"An obsolete phrase of disputed meaning, -- perhaps, smooth or polished bone.","pos":""}],"REWIN":[{"def":"To win again, or win back.","pos":""}],"REWORD":[{"def":"To repeat in the same words; to reëcho.","pos":""},{"def":"To alter the wording of; to restate in other words; as, to reword an idea or a passage.","pos":""}]}