{"INEQUAL":[{"def":"Unequal; uneven; various.","pos":""}],"INEQUALITY":[{"def":"An expression consisting of two unequal quantities, with the sign of inequality (> or <) between them; as, the inequality 2 < 3, or 4 > 1.","pos":""},{"def":"An irregularity, or a deviation, in the motion of a planet or satellite from its uniform mean motion; the amount of such deviation.","pos":""}],"INEQUIDISTANT":[{"def":"Not equally distant; not equidistant.","pos":""}],"INEQUILATERAL":[{"def":"Having the two ends unequal, as in the clam, quahaug, and most lamellibranch shells.","pos":""}],"INEQUILOBATE":[{"def":"Unequally lobed; cut into lobes of different shapes or sizes.","pos":""}],"INEQUITABLE":[{"def":"Not equitable; not just.","pos":""}],"INEQUITATE":[{"def":"To ride over or through.","pos":""}],"INEQUITY":[{"def":"Want of equity; injustice; wrong.","pos":""},{"def":"Having unequal valves, as the shell of an oyster.","pos":""}]}