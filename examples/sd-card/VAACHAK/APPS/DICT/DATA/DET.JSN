{"DETACH":[{"def":"To part; to separate or disunite; to disengage; -- the opposite of attach; as, to detach the coats of a bulbous root from each other; to detach a man from a leader or from a party.","pos":""},{"def":"To separate for a special object or use; -- used especially in military language; as, to detach a ship from a fleet, or a company from a regiment.","pos":""}],"DETACHABLE":[{"def":"That can be detached.","pos":""}],"DETACHED":[{"def":"Separate; unconnected, or imperfectly connected; as, detached parcels.","pos":""}],"DETACHMENT":[{"def":"The act of detaching or separating, or the state of being detached.","pos":""},{"def":"That which is detached; especially, a body of troops or part of a fleet sent from the main body on special service.","pos":""}],"DETAIL":[{"def":"The selection for a particular service of a person or a body of men; hence, the person or the body of men so selected.","pos":""}],"DETAILER":[{"def":"One who details.","pos":""}],"DETAIN":[{"def":"To keep back or from; to withhold.","pos":""},{"def":"To restrain from proceeding; to stay or stop; to delay; as, we were detained by an accident.","pos":""}],"DETAINER":[{"def":"One who detains.","pos":""}],"DETECT":[{"def":"Capable of being detected or found out; as, parties not detectable.","pos":""}],"DETECTER":[{"def":"One who, or that which, detects or brings to light; one who finds out what another attempts to conceal; a detector.","pos":""}],"DETECTION":[{"def":"The act of detecting; the laying open what was concealed or hidden; discovery; as, the detection of a thief; the detection of fraud, forgery, or a plot.","pos":""}],"DETECTIVE":[{"def":"Fitted for, or skilled in, detecting; employed in detecting crime or criminals; as, a detective officer.","pos":""}],"DETECTOR":[{"def":"One who, or that which, detects; a detecter.","pos":""}],"DETECTOR BAR":[{"def":"A bar, connected with a switch, longer than the distance between any two consecutive wheels of a train (45 to 50 feet), laid inside a rail and operated by the wheels so that the switch cannot be thrown until all the train is past the switch.","pos":""}],"DETENEBRATE":[{"def":"To remove darkness from.","pos":""}],"DETENT":[{"def":"That which locks or unlocks a movement; a catch, pawl, or dog; especially, in clockwork, the catch which locks and unlocks the wheelwork in striking.","pos":""}],"DETENTION":[{"def":"The act of detaining or keeping back; a withholding.","pos":""},{"def":"The state of being detained (stopped or hindered); delay from necessity.","pos":""}],"DETER":[{"def":"To prevent by fear; hence, to hinder or prevent from action by fear of consequences, or difficulty, risk, etc.","pos":""}],"DETERGE":[{"def":"To cleanse; to purge away, as foul or offending matter from the body, or from an ulcer.","pos":""}],"DETERGENCY":[{"def":"A cleansing quality or power.","pos":""}],"DETERGENT":[{"def":"Cleansing; purging.","pos":""},{"def":"A substance which cleanses the skin, as water or soap; a medicine to cleanse wounds, ulcers, etc.","pos":""}],"DETERIORATE":[{"def":"To make worse; to make inferior in quality or value; to impair; as, to deteriorate the mind.","pos":""}],"DETERIORATION":[{"def":"The process of growing worse, or the state of having grown worse.","pos":""}],"DETERIORITY":[{"def":"Worse state or quality; inferiority.","pos":""}],"DETERMENT":[{"def":"The act of deterring; also, that which deters.","pos":""}],"DETERMINABILITY":[{"def":"The quality of being determinable; determinableness.","pos":""}],"DETERMINABLE":[{"def":"Capable of being determined, definitely ascertained, decided upon, or brought to a conclusion.","pos":""}],"DETERMINABLENESS":[{"def":"Capability of being determined; determinability.","pos":""}],"DETERMINACY":[{"def":"Determinateness.","pos":""}],"DETERMINANT":[{"def":"Serving to determine or limit; determinative.","pos":""}],"DETERMINATE":[{"def":"Having defined limits; not uncertain or arbitrary; fixed; established; definite.","pos":""},{"def":"Conclusive; decisive; positive.","pos":""}],"DETERMINATELY":[{"def":"In a determinate manner; definitely; ascertainably.","pos":""},{"def":"Resolutely; unchangeably.","pos":""}],"DETERMINATENESS":[{"def":"State of being determinate.","pos":""}],"DETERMINATION":[{"def":"A flow, rush, or tendency to a particular part; as, a determination of blood to the head.","pos":""},{"def":"The act, process, or result of any accurate measurement, as of length, volume, weight, intensify, etc.","pos":""}],"DETERMINATIVE":[{"def":"Having power to determine; limiting; shaping; directing; conclusive.","pos":""}],"DETERMINATOR":[{"def":"One who determines.","pos":""}],"DETERMINE":[{"def":"To define or limit by adding a differentia.","pos":""},{"def":"To ascertain the presence, quantity, or amount of; as, to determine the parallax; to determine the salt in sea water.","pos":""}],"DETERMINED":[{"def":"Decided; resolute.","pos":""}],"DETERMINEDLY":[{"def":"In a determined manner; with determination.","pos":""}],"DETERMINER":[{"def":"One who, or that which, determines or decides.","pos":""}],"DETERMINISM":[{"def":"The doctrine that the will is not free, but is inevitably and invincibly determined by motives.","pos":""}],"DETERMINIST":[{"def":"One who believes in determinism.","pos":""}],"DETERRATION":[{"def":"The uncovering of anything buried or covered with earth; a taking out of the earth or ground.","pos":""}],"DETERRENCE":[{"def":"That which deters; a deterrent; a hindrance.","pos":""}],"DETERRENT":[{"def":"Serving to deter.","pos":""}],"DETERSION":[{"def":"The act of deterging or cleansing, as a sore.","pos":""}],"DETERSIVE":[{"def":"Cleansing; detergent.","pos":""},{"def":"A cleansing agent; a detergent.","pos":""}],"DETERSIVELY":[{"def":"In a way to cleanse.","pos":""}],"DETERSIVENESS":[{"def":"The quality of cleansing.","pos":""}],"DETEST":[{"def":"To witness against; to denounce; to condemn.","pos":""},{"def":"To hate intensely; to abhor; to abominate; to loathe; as, we detest what is contemptible or evil.","pos":""}],"DETESTABILITY":[{"def":"Capacity of being odious.","pos":""}],"DETESTABLE":[{"def":"Worthy of being detested; abominable; extremely hateful; very odious; deserving abhorrence; as, detestable vices.","pos":""}],"DETESTABLENESS":[{"def":"The quality or state of being detestable.","pos":""}],"DETESTABLY":[{"def":"In a detestable manner.","pos":""}],"DETESTATION":[{"def":"The act of detesting; extreme hatred or dislike; abhorrence; loathing.","pos":""}],"DETHRONE":[{"def":"To remove or drive from a throne; to depose; to divest of supreme authority and dignity.","pos":""}],"DETHRONEMENT":[{"def":"Deposal from a throne; deposition from regal power.","pos":""}],"DETHRONER":[{"def":"One who dethrones.","pos":""}],"DETHRONIZATION":[{"def":"De*thron`i*za\"tion, n.","pos":""}],"DETHRONIZE":[{"def":"To dethrone or unthrone.","pos":""}],"DETINUE":[{"def":"A person or thing detained; (Law) Defn: a form of action for the recovery of a personal chattel wrongfully detained.","pos":""}],"DETONATE":[{"def":"To explode with a sudden report; as, niter detonates with sulphur.","pos":""}],"DETONATION":[{"def":"An explosion or sudden report made by the instantaneous decomposition or combustion of unstable substances' as, the detonation of gun cotton.","pos":""}],"DETONATOR":[{"def":"One who, or that which, detonates.","pos":""}],"DETONIZATION":[{"def":"The act of detonizing; detonation.","pos":""}],"DETONIZE":[{"def":"To explode, or cause to explode; to burn with an explosion; to detonate.","pos":""}],"DETORSION":[{"def":"Same as Detortion.","pos":""}],"DETORT":[{"def":"To turn form the original or plain meaning; to pervert; to wrest.","pos":""}],"DETORTION":[{"def":"The act of detorting, or the state of being detorted; a twisting or warping.","pos":""}],"DETOUR":[{"def":"A turning; a circuitous route; a deviation from a direct course; as, the detours of the Mississippi.","pos":""}],"DETRACT":[{"def":"To take away; to withdraw.","pos":""},{"def":"To take credit or reputation from; to defame.","pos":""}],"DETRACTER":[{"def":"One who detracts; a detractor.","pos":""}],"DETRACTINGLY":[{"def":"In a detracting manner.","pos":""}],"DETRACTION":[{"def":"A taking away or withdrawing.","pos":""},{"def":"The act of taking away from the reputation or good name of another; a lessening or cheapening in the estimation of others; the act of depreciating another, from envy or malice; calumny.","pos":""}],"DETRACTIOUS":[{"def":"Containing detraction; detractory.","pos":""}],"DETRACTIVE":[{"def":"Tending to detractor draw.","pos":""},{"def":"Tending to lower in estimation; depreciative.","pos":""}],"DETRACTIVENESS":[{"def":"The quality of being detractive.","pos":""}],"DETRACTOR":[{"def":"One who detracts; a derogator; a defamer.","pos":""}],"DETRACTORY":[{"def":"Defamatory by denial of desert; derogatory; calumnious.","pos":""}],"DETRACTRESS":[{"def":"A female detractor.","pos":""}],"DETRAIN":[{"def":"To alight, or to cause to alight, from a railway train.","pos":""}],"DETRECT":[{"def":"To refuse; to decline.","pos":""}],"DETRIMENT":[{"def":"That which injures or causes damage; mischief; harm; diminution; loss; damage; -- used very generically; as, detriments to property, religion, morals, etc.","pos":""},{"def":"A charge made to students and barristers for incidental repairs of the rooms they occupy.","pos":""}],"DETRIMENTAL":[{"def":"Causing detriment; injurious; hurtful.","pos":""}],"DETRIMENTALNESS":[{"def":"The quality of being detrimental; injuriousness.","pos":""}],"DETRITAL":[{"def":"Pertaining to, or composed of, detritus.","pos":""}],"DETRITION":[{"def":"A wearing off or away.","pos":""}],"DETRITUS":[{"def":"A mass of substances worn off from solid bodies by attrition, and reduced to small portions; as, diluvial detritus.","pos":""}],"DETRUDE":[{"def":"To thrust down or out; to push down with force.","pos":""}],"DETRUNCATE":[{"def":"To shorten by cutting; to cut off; to lop off.","pos":""}],"DETRUNCATION":[{"def":"The act of lopping or cutting off, as the head from the body.","pos":""}],"DETRUSION":[{"def":"The act of thrusting or driving down or outward; outward thrust.","pos":""}],"DETUMESCENCE":[{"def":"Diminution of swelling; subsidence of anything swollen.","pos":""}],"DETUR":[{"def":"A present of books given to a meritorious undergraduate student as a prize.","pos":""}],"DETURBATE":[{"def":"To evict; to remove.","pos":""}],"DETURBATION":[{"def":"The act of deturbating.","pos":""}],"DETURPATE":[{"def":"To defile; to disfigure.","pos":""}]}