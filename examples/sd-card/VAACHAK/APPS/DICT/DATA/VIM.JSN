{"VIM":[{"def":"Power; force; energy; spirit; activity; vigor.","pos":""}],"VIMEN":[{"def":"A long, slender, flexible shoot or branch.","pos":""}],"VIMINAL":[{"def":"Of or pertaining to twigs; consisting of twigs; producing twigs.","pos":""}],"VIMINEOUS":[{"def":"Producing long, slender twigs or shoots.","pos":""}]}