{"ECCALEOBION":[{"def":"A contrivance for hatching eggs by artificial heat.","pos":""}],"ECCE HOMO":[{"def":"A picture which represents the Savior as given up to the people by Pilate, and wearing a crown of thorns.","pos":""}],"ECCENTRIC":[{"def":"Pertaining to an eccentric; as, the eccentric rod in a steam engine.","pos":""}],"ECCENTRICALLY":[{"def":"In an eccentric manner.","pos":""}],"ECCENTRICITY":[{"def":"The ratio of the distance between the center and the focus of an ellipse or hyperbola to its semi-transverse axis.","pos":""},{"def":"The ratio of the distance of the center of the orbit of a heavenly body from the center of the body round which it revolves to the semi-transverse axis of the orbit.","pos":""}],"ECCHYMOSE":[{"def":"To discolor by the production of an ecchymosis, or effusion of blood, beneath the skin; -- chiefly used in the passive form; as, the parts were much ecchymosed.","pos":""}],"ECCHYMOSIS":[{"def":"A livid or black and blue spot, produced by the extravasation or effusion of blood into the areolar tissue from a contusion.","pos":""}],"ECCHYMOTIC":[{"def":"Pertaining to ecchymosis.","pos":""}],"ECCLE":[{"def":"The European green woodpecker; -- also called ecall, eaquall, yaffle.","pos":""}],"ECCLESIA":[{"def":"The public legislative assembly of the Athenians.","pos":""},{"def":"A church, either as a body or as a building.","pos":""}],"ECCLESIARCH":[{"def":"An official of the Eastern Church, resembling a sacrist in the Western Church.","pos":""}],"ECCLESIAST":[{"def":"An ecclesiastic.","pos":""},{"def":"The Apocryphal book of Ecclesiasticus.","pos":""}],"ECCLESIASTES":[{"def":"One of the canonical books of the Old Testament.","pos":""}],"ECCLESIASTIC":[{"def":"Of or pertaining to the church.","pos":""}],"ECCLESIASTICAL":[{"def":"Of or pertaining to the church; relating to the organization or government of the church; not secular; as, ecclesiastical affairs or history; ecclesiastical courts.","pos":""}],"ECCLESIASTICALLY":[{"def":"In an ecclesiastical manner; according ecclesiastical rules.","pos":""}],"ECCLESIASTICISM":[{"def":"Strong attachment to ecclesiastical usages, forms, etc.","pos":""}],"ECCLESIASTICUS":[{"def":"A book of the Apocrypha.","pos":""}],"ECCLESIOLOGICAL":[{"def":"Belonging to ecclesiology.","pos":""}],"ECCLESIOLOGIST":[{"def":"One versed in ecclesiology.","pos":""}],"ECCLESIOLOGY":[{"def":"The science or theory of church building and decoration.","pos":""}],"ECCRITIC":[{"def":"A remedy which promotes discharges, as an emetic, or a cathartic.","pos":""}]}