{"LOW":[{"def":"Low, obs Defn: , strong imp.","pos":""}],"LOW-CHURCH":[{"def":"Not placing a high estimate on ecclesiastical organizations or forms; -- applied especially to Episcopalians, and opposed to high- church.","pos":""}],"LOW-CHURCHISM":[{"def":"The principles of the low-church party.","pos":""}],"LOW-CHURCHMAN":[{"def":"One who holds low-church principles.","pos":""}],"LOW-CHURCHMANSHIP":[{"def":"The state of being a low-churchman.","pos":""}],"LOW-LIVED":[{"def":"Characteristic of, or like, one bred in a low and vulgar condition of life; mean dishonorable; contemptible; as, low-lived dishonesty.","pos":""}],"LOW-MINDED":[{"def":"Inclined in mind to low or unworthy things; showing a base mind.","pos":""}],"LOW-MINDEDNESS":[{"def":"The quality of being lowminded; meanness; baseness.","pos":""}],"LOW-NECKED":[{"def":"Cut low in the neck; decollete; -- said of a woman's dress.","pos":""}],"LOW-PRESSURE":[{"def":"Having, employing, or exerting, a low degree of pressure.","pos":""}],"LOW-SPIRITED":[{"def":"Deficient in animation and courage; dejected; depressed; not sprightly.","pos":""}],"LOW-STUDDED":[{"def":"Furnished or built with short studs; as, a low-studded house or room.","pos":""}],"LOW-THOUGHTED":[{"def":"Having one's thoughts directed toward mean or insignificant subjects.","pos":""}],"LOWBELL":[{"def":"A bell used in fowling at night, to frighten birds, and, with a sudden light, to make them fly into a net.","pos":""},{"def":"A bell to be hung on the neck of a sheep.","pos":""}],"LOWBORN":[{"def":"Born in a low condition or rank; -- opposed to highborn.","pos":""}],"LOWBOY":[{"def":"A chest of drawers not more than four feet high; -- applied commonly to the lower half of a tallboy from which the upper half has been removed.","pos":""}],"LOWBRED":[{"def":"Bred, or like one bred, in a low condition of life; characteristic or indicative of such breeding; rude; impolite; vulgar; as, a lowbred fellow; a lowbred remark.","pos":""}],"LOWER":[{"def":"To let descend by its own weight, as something suspended; to let down; as, to lower a bucket into a well; to lower a sail or a boat; sometimes, to pull down; as, to lower a flag.","pos":""},{"def":"To reduce the height of; as, to lower a fence or wall; to lower a chimney or turret.","pos":""}],"LOWER-CASE":[{"def":"Pertaining to, or kept in, the lower case; -- used to denote the small letters, in distinction from capitals and small capitals.","pos":""}],"LOWERING":[{"def":"Dark and threatening; gloomy; sullen; as, lowering clouds or sky.","pos":""}],"LOWERINGLY":[{"def":"In a lowering manner; with cloudiness or threatening gloom.","pos":""}],"LOWERY":[{"def":"Cloudy; gloomy; lowering; as, a lowery sky; lowery weather.","pos":""}],"LOWING":[{"def":"The calling sound made by cows and other bovine animals.","pos":""}],"LOWLAND":[{"def":"Land which is low with respect to the neighboring country; a low or level country; -- opposed to highland.","pos":""}],"LOWLANDER":[{"def":"A native or inhabitant of the Lowlands, especially of the Lowlands of Scotland, as distinguished from Highlander.","pos":""}],"LOWLILY":[{"def":"In a lowly place or manner; humbly.","pos":""}],"LOWLINESS":[{"def":"The state or quality of being lowly; humility; humbleness of mind.","pos":""},{"def":"Low condition, especially as to manner of life.","pos":""}],"LOWLY":[{"def":"Not high; not elevated in place; low.","pos":""},{"def":"Low in rank or social importance.","pos":""}],"LOWNESS":[{"def":"The state or quality of being low.","pos":""}],"LOWRY":[{"def":"An open box car used on railroads.","pos":""}]}