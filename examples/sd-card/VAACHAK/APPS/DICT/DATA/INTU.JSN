{"INTUBATION":[{"def":"The introduction of a tube into an organ to keep it open, as into the larynx in croup.","pos":""}],"INTUITION":[{"def":"A looking after; a regard to.","pos":""},{"def":"Direct apprehension or cognition; immediate knowledge, as in perception or consciousness; -- distinguished from \"mediate\" knowledge, as in reasoning; as, the mind knows by intuition that black is not white, that a circle is not a square, that three are more than two, etc.","pos":""}],"INTUITIONAL":[{"def":"Pertaining to, or derived from, intuition; characterized by intuition; perceived by intuition; intuitive.","pos":""}],"INTUITIONALISM":[{"def":"The doctrine that the perception or recognition of primary truth is intuitive, or direct and immediate; -- opposed to sensationalism, and experientialism.","pos":""}],"INTUITIONALIST":[{"def":"One who holds the doctrine of intuitionalism.","pos":""}],"INTUITIONISM":[{"def":"Same as Intuitionalism.","pos":""}],"INTUITIONIST":[{"def":"Same as Intuitionalist.","pos":""}],"INTUITIVE":[{"def":"Seeing clearly; as, an intuitive view; intuitive vision.","pos":""},{"def":"Knowing, or perceiving, by intuition; capable of knowing without deduction or reasoning.","pos":""}],"INTUITIVELY":[{"def":"In an intuitive manner.","pos":""}],"INTUITIVISM":[{"def":"The doctrine that the ideas of right and wrong are intuitive.","pos":""}],"INTUMESCE":[{"def":"To enlarge or expand with heat; to swell; specifically, to swell up or bubble up under the action of heat, as before the blowpipe.","pos":""}],"INTUMESCENCE":[{"def":"The act or process of swelling or enlarging; also, the state of being swollen; expansion; tumidity; especially, the swelling up of bodies under the action of heat.","pos":""},{"def":"Anything swollen or enlarged, as a tumor.","pos":""}],"INTUMESCENT":[{"def":"Swelling up; expanding.","pos":""}],"INTURBIDATE":[{"def":"To render turbid; to darken; to confuse.","pos":""}],"INTURGESCENCE":[{"def":"A swelling; the act of swelling, or state of being swelled.","pos":""}],"INTUSE":[{"def":"A bruise; a contusion.","pos":""}],"INTUSSUSCEPTED":[{"def":"Received into some other thing or part, as a sword into a sheath; invaginated.","pos":""}],"INTUSSUSCEPTION":[{"def":"The abnormal reception or slipping of a part of a tube, by inversion and descent, within a contiguous part of it; specifically, the reception or slipping of the upper part of the small intestine into the lower; introsusception; invagination.","pos":""},{"def":"The interposition of new particles of formative material among those already existing, as in a cell wall, or in a starch grain.","pos":""}]}