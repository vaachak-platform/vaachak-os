{"SIZABLE":[{"def":"Of considerable size or bulk.","pos":""},{"def":"Being of reasonable or suitable size; as, sizable timber; sizable bulk.","pos":""}],"SIZAR":[{"def":"One of a body of students in the universities of Cambridge (Eng.","pos":""}],"SIZARSHIP":[{"def":"The position or standing of a sizar.","pos":""}],"SIZE":[{"def":"A thin, weak glue used in various trades, as in painting, bookbinding, paper making, etc.","pos":""},{"def":"Any viscous substance, as gilder's varnish.","pos":""}],"SIZED":[{"def":"Adjusted according to size.","pos":""},{"def":"Having a particular size or magnitude; -- chiefly used in compounds; as, large-sized; common-sized.","pos":""}],"SIZEL":[{"def":"Same as Scissel, 2.","pos":""}],"SIZINESS":[{"def":"The quality or state of being sizy; viscousness.","pos":""}],"SIZING":[{"def":"Act of covering or treating with size.","pos":""},{"def":"A weak glue used in various trades; size.","pos":""}],"SIZY":[{"def":"Sizelike; viscous; glutinous; as, sizy blood.","pos":""}],"SIZZLE":[{"def":"To make a hissing sound; to fry, or to dry and shrivel up, with a hissing sound.","pos":""}]}