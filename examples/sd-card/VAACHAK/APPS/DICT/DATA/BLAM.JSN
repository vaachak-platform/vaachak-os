{"BLAMABLE":[{"def":"Deserving of censure; faulty; culpable; reprehensible; censurable; blameworthy.","pos":""}],"BLAME":[{"def":"To censure; to express disapprobation of; to find fault with; to reproach.","pos":""},{"def":"To bring reproach upon; to blemish.","pos":""}],"BLAMEFUL":[{"def":"Faulty; meriting blame.","pos":""},{"def":"Attributing blame or fault; implying or conveying censure; faultfinding; censorious.","pos":""}],"BLAMELESS":[{"def":"Free from blame; without fault; innocent; guiltless; -- sometimes followed by of.","pos":""}],"BLAMELESSLY":[{"def":"In a blameless manner.","pos":""}],"BLAMELESSNESS":[{"def":"The quality or state of being blameless; innocence.","pos":""}],"BLAMEWORTHY":[{"def":"Deserving blame; culpable; reprehensible.","pos":""}]}