{"BRASH":[{"def":"Hasty in temper; impetuous.","pos":""}],"BRASHY":[{"def":"An artificer who works in brass.","pos":""},{"def":"A pan for holding burning coals.","pos":""}],"BRASQUE":[{"def":"A paste made by mixing powdered charcoal, coal, or coke with clay, molasses, tar, or other suitable substance.","pos":""}],"BRASS":[{"def":"A journal bearing, so called because frequently made of brass.","pos":""},{"def":"Utensils, ornaments, or other articles of brass.","pos":""}],"BRASSAGE":[{"def":"A sum formerly levied to pay the expense of coinage; -- now called seigniorage.","pos":""}],"BRASSART":[{"def":"Armor for the arm; -- generally used for the whole arm from the shoulder to the wrist, and consisting, in the 15th and 16th centuries, of many parts.","pos":""}],"BRASSE":[{"def":"A spotted European fish of the genus Lucioperca, resembling a perch.","pos":""}],"BRASSICA":[{"def":"A genus of plants embracing several species ad varieties differing much in appearance and qualities: such as the common cabbage (B.","pos":""}],"BRASSICACEOUS":[{"def":"Related to, or resembling, the cabbage, or plants of the Cabbage family.","pos":""}],"BRASSIERE":[{"def":"A form of woman's underwaist stiffened with whalebones, or the like, and worn to support the breasts.","pos":""}],"BRASSINESS":[{"def":"The state, conditions, or quality of being brassy.","pos":""}],"BRASSY":[{"def":"Of or pertaining to brass; having the nature, appearance, or hardness, of brass.","pos":""},{"def":"Impudent; impudently bold.","pos":""}],"BRAST":[{"def":"And both his yën braste out of his face.","pos":""}]}