{"BOG":[{"def":"A quagmire filled with decayed moss and other vegetable matter; wet spongy ground where a heavy body is apt to sink; a marsh; a morass.","pos":""},{"def":"A little elevated spot or clump of earth, roots, and grass, in a marsh or swamp.","pos":""}],"BOGBERRY":[{"def":"The small cranberry (Vaccinium oxycoccus), which grows in boggy places.","pos":""}],"BOGEY":[{"def":"A goblin; a bugbear.","pos":""}],"BOGGLE":[{"def":"To stop or hesitate as if suddenly frightened, or in doubt, or impeded by unforeseen difficulties; to take alarm; to exhibit hesitancy and indecision.","pos":""},{"def":"To do anything awkwardly or unskillfully.","pos":""}],"BOGGLER":[{"def":"One who boggles.","pos":""}],"BOGGLISH":[{"def":"Doubtful; skittish.","pos":""}],"BOGGY":[{"def":"Consisting of, or containing, a bog or bogs; of the nature of a bog; swampy; as, boggy land.","pos":""}],"BOGIE":[{"def":"A four-wheeled truck, having a certain amount of play around a vertical axis, used to support in part a locomotive on a railway track.","pos":""}],"BOGIE ENGINE":[{"def":"A switching engine the running gear and driving gear of which are on a bogie, or truck.","pos":""}],"BOGLE":[{"def":"A goblin; a specter; a frightful phantom; a bogy; a bugbear.","pos":""}],"BOGSUCKER":[{"def":"The American woodcock; -- so called from its feeding among the bogs.","pos":""}],"BOGTROTTER":[{"def":"One who lives in a boggy country; -- applied in derision to the lowest class of Irish.","pos":""}],"BOGTROTTING":[{"def":"Living among bogs.","pos":""}],"BOGUE":[{"def":"To fall off from the wind; to edge away to leeward; -- said only of inferior craft.","pos":""}],"BOGUS":[{"def":"Spurious; fictitious; sham; -- a cant term originally applied to counterfeit coin, and hence denoting anything counterfeit.","pos":""}],"BOGWOOD":[{"def":"The wood of trees, esp.","pos":""}],"BOGY":[{"def":"A specter; a hobgoblin; a bugbear.","pos":""}]}