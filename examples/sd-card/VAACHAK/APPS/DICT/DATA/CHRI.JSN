{"CHRISM":[{"def":"Olive oil mixed with balm and spices, consecrated by the bishop on Maundy Thursday, and used in the administration of baptism, confirmation, ordination, etc.","pos":""},{"def":"The same as Chrisom.","pos":""}],"CHRISMAL":[{"def":"Of or pertaining to or used in chrism.","pos":""}],"CHRISMATION":[{"def":"The act of applying the chrism, or consecrated oil.","pos":""}],"CHRISMATORY":[{"def":"A cruet or vessel in which chrism is kept.","pos":""}],"CHRISOM":[{"def":"A white cloth, anointed with chrism, or a white mantle thrown over a child when baptized or christened.","pos":""},{"def":"A child which died within a month after its baptism; -- so called from the chrisom cloth which was used as a shroud for it.","pos":""}],"CHRIST":[{"def":"The Anointed; an appellation given to Jesus, the Savior.","pos":""}],"CHRIST'S-THORN":[{"def":"One of several prickly or thorny shrubs found in Palestine, especially the Paliurus aculeatus, Zizyphus Spina-Christi, and Z.","pos":""}],"CHRISTCROSS":[{"def":"The mark of the cross, as cut, painted, written, or stamped on certain objects, -- sometimes as the sign of 12 o'clock on a dial.","pos":""},{"def":"The beginning and the ending.","pos":""}],"CHRISTCROSS-ROW":[{"def":"The alphabet; -- formerly so called, either from the cross usually set before it, or from a superstitious custom, sometimes practiced, of writing it in the form of a cross, by way of a charm.","pos":""}],"CHRISTEN":[{"def":"To baptize and give a Christian name to.","pos":""},{"def":"To give a name; to denominate.","pos":""}],"CHRISTENDOM":[{"def":"The profession of faith in Christ by baptism; hence, the Christian religion, or the adoption of it.","pos":""},{"def":"The name received at baptism; or, more generally, any name or appelation.","pos":""}],"CHRISTIAN":[{"def":"One who believes, or professes or is assumed to believe, in Jesus Christ, and the truth as taught by Him; especially, one whose inward and outward life is conformed to the doctrines of Christ.","pos":""},{"def":"One born in a Christian country or of Christian parents, and who has not definitely becomes an adherent of an opposing system.","pos":""}],"CHRISTIAN ERA":[{"def":"The era in use in all Christian countries, which was intended to commence with the birth of Christ.","pos":""}],"CHRISTIAN SCIENCE":[{"def":"A system of healing disease of mind and body which teaches that all cause and effect is mental, and that sin, sickness, and death will be destroyed by a full understanding of the Divine Principle of Jesus' teaching and healing.","pos":""}],"CHRISTIAN SCIENTIST":[{"def":"A believer in Christian Science; one who practices its teachings.","pos":""}],"CHRISTIAN SENECA":[{"def":"Joseph Hall (1574 -- 1656), Bishop of Norwich, a divine eminent as a moralist.","pos":""}],"CHRISTIAN SOCIALISM":[{"def":"Any theory or system that aims to combine the teachings of Christ with the teachings of socialism in their applications to life; Christianized socialism; esp.","pos":""}],"CHRISTIANISM":[{"def":"The Christian religion.","pos":""},{"def":"The Christian world; Christendom.","pos":""}],"CHRISTIANITE":[{"def":"Frederic, of Denmark; in sense (b) after Christian VII.","pos":""}],"CHRISTIANITY":[{"def":"The religion of Christians; the system of doctrines and precepts taught by Christ.","pos":""},{"def":"Practical conformity of one's inward and outward life to the spirit of the Christian religion 3.","pos":""}],"CHRISTIANIZATION":[{"def":"The act or process of converting or being converted to a true Christianity.","pos":""}],"CHRISTIANIZE":[{"def":"To make Christian; to convert to Christianity; as, to Christianize pagans.","pos":""},{"def":"To imbue with or adapt to Christian principles.","pos":""}],"CHRISTIANLIKE":[{"def":"Becoming to a Christian.","pos":""}],"CHRISTIANLY":[{"def":"In a manner becoming the principles of the Christian religion.","pos":""}],"CHRISTIANNESS":[{"def":"Consonance with the doctrines of Christianity.","pos":""}],"CHRISTLESS":[{"def":"Without faith in Christ; unchristian.","pos":""}],"CHRISTLIKE":[{"def":"Resembling Christ in character, actions, etc.","pos":""}],"CHRISTMAS":[{"def":"An annual church festival (December 25) and in some States a legal holiday, in memory of the birth of Christ, often celebrated by a particular church service, and also by special gifts, greetings, and hospitality.","pos":""}],"CHRISTMASTIDE":[{"def":"The season of Christmas.","pos":""}],"CHRISTOCENTRIC":[{"def":"Making Christ the center, about whom all things are grouped, as in religion or history; tending toward Christ, as the central object of thought or emotion.","pos":""}],"CHRISTOLOGY":[{"def":"A treatise on Christ; that department of theology which treats of the personality, attributes, or life of Christ.","pos":""}],"CHRISTOPHANY":[{"def":"An appearance of Christ, as to his disciples after the crucifixion.","pos":""}]}