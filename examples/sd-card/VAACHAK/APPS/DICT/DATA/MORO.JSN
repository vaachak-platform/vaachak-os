{"MORO":[{"def":"A small abscess or tumor having a resemblance to a mulberry.","pos":""}],"MOROCCAN":[{"def":"Of or pertaining to Morocco, or its inhabitants.","pos":""}],"MOROCCO":[{"def":"A fine kind of leather, prepared commonly from goatskin (though an inferior kind is made of sheepskin), and tanned with sumac and dyed of various colors; -- said to have been first made by the Moors.","pos":""}],"MOROLOGY":[{"def":"Foolish talk; nonsense; folly.","pos":""}],"MORON":[{"def":"A person whose intellectual development proceeds normally up to about the eighth year of age and is then arrested so that there is little or no further development.","pos":""}],"MORONE":[{"def":"Maroon; the color of an unripe black mulberry.","pos":""}],"MOROS":[{"def":"The Mohammedan tribes of the southern Philippine Islands, said to have formerly migrated from Borneo.","pos":""}],"MOROSAURUS":[{"def":"An extinct genus of large herbivorous dinosaurs, found in Jurassic strata in America.","pos":""}],"MOROSE":[{"def":"Of a sour temper; sullen and austere; ill-humored; severe.","pos":""},{"def":"Lascivious; brooding over evil thoughts.","pos":""}],"MOROSELY":[{"def":"Sourly; with sullen austerity.","pos":""}],"MOROSENESS":[{"def":"Sourness of temper; sulenness.","pos":""}],"MOROSIS":[{"def":"Idiocy; fatuity; stupidity.","pos":""}],"MOROSOPH":[{"def":"A philosophical or learned fool.","pos":""}],"MOROXITE":[{"def":"A variety of apatite of a greenish blue color.","pos":""}],"MOROXYLIC":[{"def":"Of, pertaining to, or derived from, the mulberry; moric.","pos":""}]}