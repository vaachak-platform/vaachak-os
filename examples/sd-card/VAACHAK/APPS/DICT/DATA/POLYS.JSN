{"POLYSCHEMATIST":[{"def":"Having, or existing in, many different forms or fashions; multiform.","pos":""}],"POLYSCOPE":[{"def":"A glass which makes a single object appear as many; a multiplying glass.","pos":""},{"def":"An apparatus for affording a view of the different cavities of the body.","pos":""}],"POLYSEPALOUS":[{"def":"Having the sepals separate from each other.","pos":""}],"POLYSILICIC":[{"def":"Of or pertaining to compounds formed by the condensation of two or more molecules of silicic acid.","pos":""}],"POLYSPAST":[{"def":"A machine consisting of many pulleys; specifically, an apparatus formerly used for reducing luxations.","pos":""}],"POLYSPERMOUS":[{"def":"Containing many seeds; as, a polyspermous capsule or berry.","pos":""}],"POLYSPERMY":[{"def":"Fullness of sperm, or seed; the passage of more than one spermatozoön into the vitellus in the impregnation of the ovum.","pos":""}],"POLYSPOROUS":[{"def":"Containing many spores.","pos":""}],"POLYSTOMATA":[{"def":"A division of trematode worms having more two suckers.","pos":""}],"POLYSTOME":[{"def":"Having many mouths.","pos":""}],"POLYSTYLE":[{"def":"Having many columns; -- said of a building, especially of an interior part or court; as, a polystyle hall.","pos":""},{"def":"A polystyle hall or edifice.","pos":""}],"POLYSULPHIDE":[{"def":"A sulphide having more than one atom of sulphur in the molecule; -- contrasted with monosulphide.","pos":""}],"POLYSULPHURET":[{"def":"Pertaining to a polysyllable; containing, or characterized by, polysyllables; consisting of more than three syllables.","pos":""}],"POLYSYLLABICISM":[{"def":"Pol`y*syl*lab\"i*cism, n.","pos":""}],"POLYSYLLABICITY":[{"def":"Pol`y*syl`la*bic\"i*ty, n.","pos":""}],"POLYSYLLABISM":[{"def":"The quality or state of being polysyllabic.","pos":""}],"POLYSYLLABLE":[{"def":"A word of many syllables, or consisting of more syllables than three; -- words of less than four syllables being called monosyllables, dissyllables, and trisyllables.","pos":""}],"POLYSYNDETIC":[{"def":"Characterized by polysyndeton, or the multiplication of conjunctions.","pos":""}],"POLYSYNDETON":[{"def":"A figure by which the conjunction is often repeated, as in the sentence, \"We have ships and men and money and stores.","pos":""}],"POLYSYNTHESIS":[{"def":"The formation of a word by the combination of several simple words, as in the aboriginal languages of America; agglutination.","pos":""}],"POLYSYNTHETIC":[{"def":"Characterized by polysynthesis; agglutinative.","pos":""}],"POLYSYNTHETICISM":[{"def":"Pol`y*syn*thet\"i*cism, n.","pos":""}]}