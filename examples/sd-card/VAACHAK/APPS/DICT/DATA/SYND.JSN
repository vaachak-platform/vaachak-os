{"SYNDACTYLE":[{"def":"Any bird having syndactilous feet.","pos":""}],"SYNDACTYLOUS":[{"def":"Having the toes firmly united together for some distance, and without an intermediate web, as the kingfishers; gressorial.","pos":""}],"SYNDESMOGRAPHY":[{"def":"A description of the ligaments; syndesmology.","pos":""}],"SYNDESMOLOGY":[{"def":"That part of anatomy which treats of ligaments.","pos":""}],"SYNDESMOSIS":[{"def":"An articulation formed by means of ligaments.","pos":""},{"def":"Connecting; conjunctive; as, syndetic words or connectives; syndetic references in a dictionary.","pos":""}],"SYNDIC":[{"def":"An agent of a corporation, or of any body of men engaged in a business enterprise; an advocate or patron; an assignee.","pos":""}],"SYNDICAL":[{"def":"Consisting of, or pert.","pos":""},{"def":"Of or pertaining to, or of the nature of, syndicalism.","pos":""}],"SYNDICALIST":[{"def":"One who advocates or practices syndicalism.","pos":""}],"SYNDICATE":[{"def":"The office or jurisdiction of a syndic; a council, or body of syndics.","pos":""}],"SYNDICATION":[{"def":"Act or process of syndicating or forming a syndicate.","pos":""}],"SYNDROME":[{"def":"A group of symptoms occurring together that are characteristic and indicative of some underlying cause, such as a disease.","pos":""}],"SYNDYASMIAN":[{"def":"Pertaining to the state of pairing together sexually; -- said of animals during periods of procreation and while rearing their offspring.","pos":""}]}