{"ATE":[{"def":"the preterit of Eat.","pos":""}],"ATECHNIC":[{"def":"Without technical or artistic knowledge.","pos":""}],"ATELES":[{"def":"A genus of American monkeys with prehensile tails, and having the thumb wanting or rudimentary.","pos":""},{"def":"A sauce (such as egg and bread crumbs) used for covering bits of meat, small birds, or fish, strung on skewers for frying.","pos":""}],"ATELIER":[{"def":"A workshop; a studio.","pos":""}],"ATELLAN":[{"def":"Of or pertaining to Atella, in ancient Italy; as, Atellan plays; farcical; ribald.","pos":""},{"def":"A farcical drama performed at Atella.","pos":""}]}