{"OYER":[{"def":"A hearing or an inspection, as of a deed, bond, etc.","pos":""}],"OYEZ":[{"def":"Hear; attend; -- a term used by criers of courts to secure silence before making a proclamation.","pos":""}],"OYSTER":[{"def":"Any marine bivalve mollusk of the genus Ostrea.","pos":""}],"OYSTER-GREEN":[{"def":"A green membranous seaweed (Ulva) often found growing on oysters but common on stones, piles, etc.","pos":""}],"OYSTERING":[{"def":"Gathering, or dredging for, oysters.","pos":""}]}