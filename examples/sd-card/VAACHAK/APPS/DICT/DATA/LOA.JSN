{"LOACH":[{"def":"Any one of several small, fresh-water, cyprinoid fishes of the genera Cobitis, Nemachilus, and allied genera, having six or more barbules around the mouth.","pos":""}],"LOAD":[{"def":"The work done by a steam engine or other prime mover when working.","pos":""}],"LOADER":[{"def":"One who, or that which, loads; a mechanical contrivance for loading, as a gun.","pos":""}],"LOADING":[{"def":"Pilotage; skill of a pilot or loadsman.","pos":""}],"LOAF":[{"def":"Any thick lump, mass, or cake; especially, a large regularly shaped or molded mass, as of bread, sugar, or cake.","pos":""}],"LOAFER":[{"def":"One who loafs; a lazy lounger.","pos":""}],"LOAM":[{"def":"A mixture of sand, clay, and other materials, used in making molds for large castings, often without a pattern.","pos":""}],"LOAMY":[{"def":"Consisting of loam; partaking of the nature of loam; resembling loam.","pos":""}],"LOAN":[{"def":"The act of lending; a lending; permission to use; as, the loan of a book, money, services.","pos":""},{"def":"That which one lends or borrows, esp.","pos":""}],"LOANABLE":[{"def":"Such as can be lent; available for lending; as, loanable funds; -- used mostly in financial business and writings.","pos":""},{"def":"An open space between cultivated fields through which cattle are driven, and where the cows are sometimes milked; also, a lane.","pos":""}],"LOANMONGER":[{"def":"A dealer in, or negotiator of, loans.","pos":""}],"LOATH":[{"def":"Hateful; odious; disliked.","pos":""},{"def":"Filled with disgust or aversion; averse; unwilling; reluctant; as, loath to part.","pos":""}],"LOATHE":[{"def":"To feel extreme disgust at, or aversion for.","pos":""},{"def":"To dislike greatly; to abhor; to hate.","pos":""}],"LOATHER":[{"def":"One who loathes.","pos":""}],"LOATHFUL":[{"def":"Full of loathing; hating; abhorring.","pos":""},{"def":"Causing a feeling of loathing; disgusting.","pos":""}],"LOATHING":[{"def":"Extreme disgust; a feeling of aversion, nausea, abhorrence, or detestation.","pos":""}],"LOATHLY":[{"def":"Unwillingly; reluctantly.","pos":""}],"LOATHNESS":[{"def":"Unwillingness; reluctance.","pos":""}],"LOATHSOME":[{"def":"Fitted to cause loathing; exciting disgust; disgusting.","pos":""}]}