{"EUTAXY":[{"def":"Good or established order or arrangement.","pos":""}],"EUTECTIC":[{"def":"Of maximum fusibility; -- said of an alloy or mixture which has the lowest melting point which it is possible to obtain by the combination of the given components.","pos":""}],"EUTERPE":[{"def":"The Muse who presided over music.","pos":""},{"def":"A genus of palms, some species of which are elegant trees.","pos":""}],"EUTERPEAN":[{"def":"Of or pertaining to Euterpe or to music.","pos":""}],"EUTEXIA":[{"def":"The principle or process of forming from given components the eutectic alloy, or alloy of maximum fusibility.","pos":""}],"EUTHANASIA":[{"def":"An easy death; a mode of dying to be desired.","pos":""}],"EUTHANASY":[{"def":"Same as Euthanasia.","pos":""}],"EUTHIOCHROIC":[{"def":"Pertaining to, or denoting, an acid so called.","pos":""}],"EUTHYNEURA":[{"def":"A large division of gastropod molluske, including the Pulmonifera and Opisthobranchiata.","pos":""}],"EUTROPHY":[{"def":"Healthy nutrition; soundless as regards the nutritive functions.","pos":""}],"EUTYCHIAN":[{"def":"A follower of Eutyches [5th century], who held that the divine and the human in the person of Christ were blended together as to constitute but one nature; a monophysite; -- opposed to Nestorian.","pos":""}],"EUTYCHIANISM":[{"def":"The doctrine of Eutyches and his followers.","pos":""}]}