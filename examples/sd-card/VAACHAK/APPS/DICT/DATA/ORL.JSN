{"ORLE":[{"def":"A bearing, in the form of a fillet, round the shield, within, but at some distance from, the border.","pos":""},{"def":"The wreath, or chaplet, surmounting or encircling the helmet of a knight and bearing the crest.","pos":""}],"ORLEANS":[{"def":"A cloth made of worsted and cotton, -- used for wearing apparel.","pos":""},{"def":"A variety of the plum.","pos":""}],"ORLO":[{"def":"A wind instrument of music in use among the Spaniards.","pos":""}],"ORLOP":[{"def":"The lowest deck of a vessel, esp.","pos":""},{"def":"The supreme deity, the principle of good, creator of the world, and guardian of mankind.","pos":""}]}