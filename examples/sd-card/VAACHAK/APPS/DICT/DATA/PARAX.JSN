{"PARAXANTHIN":[{"def":"A crystalline substance closely related to xanthin, present in small quantity in urine.","pos":""}],"PARAXIAL":[{"def":"On either side of the axis of the skeleton.","pos":""}],"PARAXYLENE":[{"def":"A hydrocarbon of the aromatic series obtained as a colorless liquid by the distillation of camphor with zinc chloride.","pos":""}]}