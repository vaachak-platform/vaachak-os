{"BEE":[{"def":"An insect of the order Hymenoptera, and family Apidæ (the honeybees), or family Andrenidæ (the solitary bees.","pos":""},{"def":"Pieces of hard wood bolted to the sides of the bowsprit, to reeve the fore-topmast stays through; -- called also bee blocks.","pos":""}],"BEE LINE":[{"def":"The shortest line from one place to another, like that of a bee to its hive when loaded with honey; an air line.","pos":""}],"BEEBREAD":[{"def":"A brown, bitter substance found in some of the cells of honeycomb.","pos":""}],"BEECH":[{"def":"A tree of the genus Fagus.","pos":""}],"BEECHEN":[{"def":"Consisting, or made, of the wood or bark of the beech; belonging to the beech.","pos":""}],"BEECHNUT":[{"def":"The nut of the beech tree.","pos":""}],"BEECHY":[{"def":"Of or relating to beeches.","pos":""}],"BEEF":[{"def":"An animal of the genus Bos, especially the common species, B.","pos":""},{"def":"The flesh of an ox, or cow, or of any adult bovine animal, when slaughtered for food.","pos":""}],"BEEFEATER":[{"def":"An African bird of the genus Buphaga, which feeds on the larvæ of botflies hatched under the skin of oxen, antelopes, etc.","pos":""}],"BEEFSTEAK":[{"def":"A steak of beef; a slice of beef broiled or suitable for broiling.","pos":""}],"BEEFWOOD":[{"def":"An Australian tree (Casuarina), and its red wood, used for cabinetwork; also, the trees Stenocarpus salignus of New South Wales, and Banksia compar of Queensland.","pos":""}],"BEEFY":[{"def":"Having much beef; of the nature of beef; resembling beef; fleshy.","pos":""}],"BEEHIVE":[{"def":"A hive for a swarm of bees.","pos":""}],"BEEHOUSE":[{"def":"A house for bees; an apiary.","pos":""}],"BEELZEBUB":[{"def":"The title of a heathen deity to whom the Jews ascribed the sovereignty of the evil spirits; hence, the Devil or a devil.","pos":""}],"BEEMASTER":[{"def":"One who keeps bees.","pos":""}],"BEEN":[{"def":"The past participle of Be.","pos":""}],"BEER":[{"def":"A fermented liquor made from any malted grain, but commonly from barley malt, with hops or some other substance to impart a bitter flavor.","pos":""},{"def":"A fermented extract of the roots and other parts of various plants, as spruce, ginger, sassafras, etc.","pos":""}],"BEERHOUSE":[{"def":"A house where malt liquors are sold; an alehouse.","pos":""}],"BEERINESS":[{"def":"Beery condition.","pos":""}],"BEERY":[{"def":"Of or resembling beer; affected by beer; maudlin.","pos":""}],"BEESTINGS":[{"def":"Same as Biestings.","pos":""}],"BEESWAX":[{"def":"The wax secreted by bees, and of which their cells are constructed.","pos":""}],"BEESWING":[{"def":"The second crust formed in port and some other wines after long keeping.","pos":""}],"BEET":[{"def":"A biennial plant of the genus Beta, which produces an edible root the first year and seed the second year.","pos":""}],"BEET RADISH":[{"def":"Same as Beetrave.","pos":""}],"BEETLE":[{"def":"A heavy mallet, used to drive wedges, beat pavements, etc.","pos":""},{"def":"A machine in which fabrics are subjected to a hammering process while passing over rollers, as in cotton mills; -- called also beetling machine.","pos":""}],"BEETLE BROW":[{"def":"An overhanging brow.","pos":""}],"BEETLE-BROWED":[{"def":"Having prominent, overhanging brows; hence, lowering or sullen.","pos":""}],"BEETLEHEAD":[{"def":"The black-bellied plover, or bullhead (Squatarola helvetica).","pos":""}],"BEETLESTOCK":[{"def":"The handle of a beetle.","pos":""}],"BEETRAVE":[{"def":"The common beet (Beta vulgaris).","pos":""}],"BEEVE":[{"def":"A beef; a beef creature.","pos":""}],"BEEVES":[{"def":"; plural of Beef, the animal.","pos":""}]}