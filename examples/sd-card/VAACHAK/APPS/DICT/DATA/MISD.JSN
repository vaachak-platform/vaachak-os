{"MISDATE":[{"def":"To date erroneously.","pos":""}],"MISDEAL":[{"def":"To deal or distribute wrongly, as cards; to make a wrong distribution.","pos":""}],"MISDEED":[{"def":"An evil deed; a wicked action.","pos":""}],"MISDEMEAN":[{"def":"To behave ill; -- with a reflexive pronoun; as, to misdemean one's self.","pos":""}],"MISDEMEANANT":[{"def":"One guilty of a misdemeanor.","pos":""}],"MISDEMEANOR":[{"def":"A crime less than a felony.","pos":""}],"MISDEPART":[{"def":"To distribute wrongly.","pos":""}],"MISDERIVE":[{"def":"To turn or divert improperly; to misdirect.","pos":""},{"def":"To derive erroneously.","pos":""}],"MISDESCRIBE":[{"def":"To describe wrongly.","pos":""}],"MISDEVOTION":[{"def":"Mistaken devotion.","pos":""}],"MISDIET":[{"def":"To diet improperly.","pos":""}],"MISDIGHT":[{"def":"Arrayed, prepared, or furnished, unsuitably.","pos":""}],"MISDIRECT":[{"def":"To give a wrong direction to; as, to misdirect a passenger, or a letter; to misdirect one's energies.","pos":""}],"MISDIRECTION":[{"def":"An error of a judge in charging the jury on a matter of law.","pos":""}],"MISDISPOSITION":[{"def":"Erroneous disposal or application.","pos":""}],"MISDISTINGUISH":[{"def":"To make wrong distinctions in or concerning.","pos":""}],"MISDIVIDE":[{"def":"To divide wrongly.","pos":""}],"MISDO":[{"def":"To do wrong to; to illtreat.","pos":""}],"MISDOING":[{"def":"A wrong done; a fault or crime; an offense; as, it was my misdoing.","pos":""}],"MISDOUBT":[{"def":"To be suspicious of; to have suspicion.","pos":""}],"MISDOUBTFUL":[{"def":"Misgiving; hesitating.","pos":""}]}