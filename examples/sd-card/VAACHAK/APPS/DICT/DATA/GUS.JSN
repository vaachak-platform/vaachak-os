{"GUSH":[{"def":"To issue with violence and rapidity, as a fluid; to rush forth as a fluid from confinement; to flow copiously.","pos":""},{"def":"To make a sentimental or untimely exhibition of affection; to display enthusiasm in a silly, demonstrative manner.","pos":""}],"GUSHING":[{"def":"Rushing forth with violence, as a fluid; flowing copiously; as, gushing waters.","pos":""},{"def":"Emitting copiously, as tears or words; weakly and unreservedly demonstrative in matters of affection; sentimental.","pos":""}],"GUSHINGLY":[{"def":"In a gushing manner; copiously.","pos":""},{"def":"Weakly; sentimentally; effusively.","pos":""}],"GUSSET":[{"def":"An abatement or mark of dishonor in a coat of arms, resembling a gusset.","pos":""}],"GUST":[{"def":"A sudden squall; a violent blast of wind; a sudden and brief rushing or driving of the wind.","pos":""},{"def":"A sudden violent burst of passion.","pos":""}],"GUSTABLE":[{"def":"Capable of being tasted; tastable.","pos":""},{"def":"Pleasant to the taste; toothsome; savory.","pos":""}],"GUSTARD":[{"def":"The great bustard.","pos":""}],"GUSTATION":[{"def":"The act of tasting.","pos":""}],"GUSTATORY":[{"def":"Pertaining to, or subservient to, the sense of taste; as, the gustatory nerve which supplies the front of the tongue.","pos":""}],"GUSTFUL":[{"def":"Tasteful; well-tasted.","pos":""}],"GUSTLESS":[{"def":"Tasteless; insipid.","pos":""}],"GUSTO":[{"def":"Nice or keen appreciation or enjoyment; relish; taste; fancy.","pos":""}],"GUSTOSO":[{"def":"Tasteful; in a tasteful, agreeable manner.","pos":""}],"GUSTY":[{"def":"Subject to, or characterized by, gusts or squalls; windy; stormy; tempestuous.","pos":""}]}