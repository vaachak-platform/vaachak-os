{"SHY":[{"def":"Easily frightened; timid; as, a shy bird.","pos":""},{"def":"Reserved; coy; disinclined to familiar approach.","pos":""}],"SHYLY":[{"def":"In a shy or timid manner; not familiarly; with reserve.","pos":""}],"SHYNESS":[{"def":"The quality or state of being shy.","pos":""}],"SHYSTER":[{"def":"A trickish knave; one who carries on any business, especially legal business, in a mean and dishonest way.","pos":""}]}