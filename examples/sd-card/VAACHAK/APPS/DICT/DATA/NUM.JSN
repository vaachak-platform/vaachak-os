{"NUMB":[{"def":"Enfeebled in, or destitute of, the power of sensation and motion; rendered torpid; benumbed; insensible; as, the fingers or limbs are numb with cold.","pos":""},{"def":"Producing numbness; benumbing; as, the numb, cold night.","pos":""}],"NUMBER":[{"def":"The measure of the relation between quantities or things of the same kind; that abstract species of quantity which is capable of being expressed by figures; numerical value.","pos":""}],"NUMBERER":[{"def":"One who numbers.","pos":""}],"NUMBERLESS":[{"def":"Innumerable; countless.","pos":""}],"NUMBFISH":[{"def":"The torpedo, which numbs by the electric shocks which it gives.","pos":""}],"NUMBNESS":[{"def":"The condition of being numb; that state of a living body in which it loses, wholly or in part, the power of feeling or motion.","pos":""}],"NUMERABLE":[{"def":"Capable of being numbered or counted.","pos":""}],"NUMERAL":[{"def":"Of or pertaining to number; consisting of number or numerals.","pos":""},{"def":"Expressing number; representing number; as, numeral letters or characters, as X or 10 for ten.","pos":""}],"NUMERALLY":[{"def":"According to number; in number; numerically.","pos":""}],"NUMERARY":[{"def":"Belonging to a certain number; counting as one of a collection or body.","pos":""}],"NUMERATE":[{"def":"To divide off and read according to the rules of numeration; as, to numerate a row of figures.","pos":""}],"NUMERATION":[{"def":"The act or art of numbering.","pos":""},{"def":"The act or art of reading numbers when expressed by means of numerals.","pos":""}],"NUMERATIVE":[{"def":"Of or pertaining to numeration; as, a numerative system.","pos":""}],"NUMERATOR":[{"def":"The term in a fraction which indicates the number of fractional units that are taken.","pos":""}],"NUMERIC":[{"def":"Any number, proper or improper fraction, or incommensurable ratio.","pos":""}],"NUMERICALLY":[{"def":"In a numerical manner; in numbers; with respect to number, or sameness in number; as, a thing is numerically the same, or numerically different.","pos":""}],"NUMERIST":[{"def":"One who deals in numbers.","pos":""}],"NUMERO":[{"def":"Number; -- often abbrev.","pos":""}],"NUMEROSITY":[{"def":"The state of being numerous; numerousness.","pos":""},{"def":"Rhythm; harmony; flow.","pos":""}],"NUMEROUS":[{"def":"Consisting of a great number of units or individual objects; being many; as, a numerous army.","pos":""},{"def":"Consisting of poetic numbers; rhythmical; measured and counted; melodious; musical.","pos":""}],"NUMIDIAN":[{"def":"Of or pertaining to ancient Numidia in Northern Africa.","pos":""},{"def":"Of or pertaining to coins; relating to the science of coins or medals.","pos":""}],"NUMISMATICS":[{"def":"The science of coins and medals.","pos":""}],"NUMISMATIST":[{"def":"One skilled in numismatics; a numismatologist.","pos":""}],"NUMISMATOGRAPHY":[{"def":"A treatise on, or description of, coins and medals.","pos":""}],"NUMISMATOLOGIST":[{"def":"One versed in numismatology.","pos":""}],"NUMISMATOLOGY":[{"def":"The science which treats of coins and medals, in their relation to history; numismatics.","pos":""}],"NUMMARY":[{"def":"Of or relating to coins or money.","pos":""},{"def":"Having the appearance or form of a coin.","pos":""}],"NUMMULATION":[{"def":"The arrangement of the red blood corpuscles in rouleaux, like piles of coins, as when a drop of human blood is examined under the microscope.","pos":""}],"NUMMULITE":[{"def":"A fossil of the genus Nummulites and allied genera.","pos":""}],"NUMMULITES":[{"def":"A genus of extinct Tertiary Foraminifera, having a thin, flat, round shell, containing a large number of small chambers arranged spirally.","pos":""}],"NUMMULITIC":[{"def":"Of, like, composed of, containing, nummulites; as, nummulitic beds.","pos":""}],"NUMPS":[{"def":"A dolt; a blockhead.","pos":""}],"NUMSKULL":[{"def":"A dunce; a dolt; a stupid fellow.","pos":""}],"NUMSKULLED":[{"def":"Stupid; doltish.","pos":""}]}