{"MONODACTYLOUS":[{"def":"Having but one finger or claw.","pos":""},{"def":"One of the Monodelphia.","pos":""}],"MONODELPHIA":[{"def":"The group that includes all ordinary or placental mammals; the Placentalia.","pos":""},{"def":"Of or pertaining to the Monodelphia.","pos":""}],"MONODIST":[{"def":"A writer of a monody.","pos":""},{"def":"A drama acted, or intended to be acted, by a single person.","pos":""}],"MONODRAMATIC":[{"def":"Pertaining to a monodrama.","pos":""}],"MONODY":[{"def":"A species of poem of a mournful character, in which a single mourner expresses lamentation; a song for one voice.","pos":""}],"MONODYNAMIC":[{"def":"Possessing but one capacity or power.","pos":""}],"MONODYNAMISM":[{"def":"The theory that the various forms of activity in nature are manifestations of the same force.","pos":""}]}