{"MIGHT":[{"def":"Force or power of any kind, whether of body or mind; energy or intensity of purpose, feeling, or action; means or resources to effect an object; strength; force; power; ability; capacity.","pos":""}],"MIGHTILY":[{"def":"In a mighty manner; with might; with great earnestness; vigorously; powerfully.","pos":""},{"def":"To a great degree; very much.","pos":""}],"MIGHTINESS":[{"def":"The quality of being mighty; possession of might; power; greatness; high dignity.","pos":""},{"def":"Highness; excellency; -- with a possessive pronoun, a title of dignity; as, their high mightinesses.","pos":""}],"MIGHTY":[{"def":"Possessing might; having great power or authority.","pos":""},{"def":"Accomplished by might; hence, extraordinary; wonderful.","pos":""}],"MIGNIARDISE":[{"def":"Delicate fondling.","pos":""}],"MIGNONETTE":[{"def":"A plant (Reseda odorata) having greenish flowers with orange- colored stamens, and exhaling a delicious fragrance.","pos":""}],"MIGRANT":[{"def":"A migratory bird or other animal.","pos":""}],"MIGRATE":[{"def":"To remove from one country or region to another, with a view to residence; to change one's place of residence; to remove; as, the Moors who migrated from Africa into Spain; to migrate to the West.","pos":""},{"def":"To pass periodically from one region or climate to another for feeding or breeding; -- said of certain birds, fishes, and quadrupeds.","pos":""}],"MIGRATION":[{"def":"The act of migrating.","pos":""}],"MIGRATORY":[{"def":"Removing regularly or occasionally from one region or climate to another; as, migratory birds.","pos":""},{"def":"Hence, roving; wandering; nomad; as, migratory habits; a migratory life.","pos":""}]}