{"HAP":[{"def":"To clothe; to wrap.","pos":""}],"HAPHAZARD":[{"def":"Extra hazard; chance; accident; random.","pos":""}],"HAPHTARAH":[{"def":"One of the lessons from the Nebiim (or Prophets) read in the Jewish synagogue on Sabbaths, feast days, fasts, and the ninth of Ab, at the end of the service, after the parashoth, or lessons from the Law.","pos":""}],"HAPLESS":[{"def":"Without hap or luck; luckless; unfortunate; unlucky; unhappy; as, hapless youth; hapless maid.","pos":""}],"HAPLESSLY":[{"def":"In a hapless, unlucky manner.","pos":""}],"HAPLOMI":[{"def":"An order of freshwater fishes, including the true pikes, cyprinodonts, and blindfishes.","pos":""}],"HAPLOSTEMONOUS":[{"def":"Having but one series of stamens, and that equal in number to the proper number of petals; isostemonous.","pos":""}],"HAPLY":[{"def":"By hap, chance, luck, or accident; perhaps; it may be.","pos":""}],"HAPPED":[{"def":"Wrapped; covered; cloaked.","pos":""}],"HAPPEN":[{"def":"To come by chance; to come without previous expectation; to fall out.","pos":""},{"def":"To take place; to occur.","pos":""}],"HAPPILY":[{"def":"By chance; peradventure; haply.","pos":""},{"def":"By good fortune; fortunately; luckily.","pos":""}],"HAPPINESS":[{"def":"Good luck; good fortune; prosperity.","pos":""},{"def":"An agreeable feeling or condition of the soul arising from good fortune or propitious happening of any kind; the possession of those circumstances or that state of being which is attended enjoyment; the state of being happy; contentment; joyful satisfaction; felicity; blessedness.","pos":""}],"HAPPY":[{"def":"Favored by hap, luck, or fortune; lucky; fortunate; successful; prosperous; satisfying desire; as, a happy expedient; a happy effort; a happy venture; a happy omen.","pos":""},{"def":"Experiencing the effect of favorable fortune; having the feeling arising from the consciousness of well-being or of enjoyment; enjoying good of any kind, as peace, tranquillity, comfort; contented; joyous; as, happy hours, happy thoughts.","pos":""}],"HAPUKU":[{"def":"A large and valuable food fish (Polyprion prognathus) of New Zealand.","pos":""}]}