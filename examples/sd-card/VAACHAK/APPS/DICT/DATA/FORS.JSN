{"FORSAKE":[{"def":"To quit or leave entirely; to desert; to abandon; to depart or withdraw from; to leave; as, false friends and flatterers forsake us in adversity.","pos":""},{"def":"To renounce; to reject; to refuse.","pos":""}],"FORSAKER":[{"def":"One who forsakes or deserts.","pos":""}],"FORSAY":[{"def":"To forbid; to renounce; to forsake; to deny.","pos":""}],"FORSHAPE":[{"def":"To render misshapen.","pos":"verb"}],"FORSLACK":[{"def":"To neglect by idleness; to delay or to waste by sloth.","pos":""}],"FORSLOUTHE":[{"def":"To lose by sloth or negligence.","pos":""}],"FORSLOW":[{"def":"To delay; to hinder; to neglect; to put off.","pos":""}],"FORSLUGGE":[{"def":"To lsoe by idleness or slotch.","pos":""}],"FORSOOTH":[{"def":"In truth; in fact; certainly; very well; -- formerly used as an expression of deference or respect, especially to woman; now used ironically or contemptuously.","pos":""}],"FORSPEAK":[{"def":"To forbid; to prohibit.","pos":""}],"FORSPENT":[{"def":"Wasted in strength; tired; exhausted.","pos":""}],"FORSWAT":[{"def":"Spent with heat; covered with sweat.","pos":""}],"FORSWEAR":[{"def":"To reject or renounce upon oath; hence, to renounce earnestly, determinedly, or with protestations.","pos":""},{"def":"To deny upon oath.","pos":""}],"FORSWEARER":[{"def":"One who rejects of renounces upon oath; one who swears a false oath.","pos":""}],"FORSWONK":[{"def":"Overlabored; exhausted; worn out.","pos":""}],"FORSWORE":[{"def":"For*swore\", Defn: imp.","pos":""}],"FORSWORN":[{"def":"For*sworn\", Defn: p.","pos":""}],"FORSWORNNESS":[{"def":"State of being forsworn.","pos":""}],"FORSYTHIA":[{"def":"A shrub of the Olive family, with yellow blossoms.","pos":""}]}