{"IRON":[{"def":"The most common and most useful metallic element, being of almost universal occurrence, usually in the form of an oxide (as hematite, magnetite, etc.","pos":""},{"def":"Fetters; chains; handcuffs; manacles.","pos":""}],"IRON WORKS":[{"def":"I\"ron works` Defn: .","pos":""}],"IRON-CASED":[{"def":"Cased or covered with iron, as a vessel; ironclad.","pos":""}],"IRON-FISTED":[{"def":"Closefisted; stingy; mean.","pos":""}],"IRON-GRAY":[{"def":"Of a gray color, somewhat resembling that of iron freshly broken.","pos":""},{"def":"An iron-gray color; also, a horse of this color.","pos":""}],"IRON-HEARTED":[{"def":"Hard-hearted; unfeeling; cruel; as, an iron-hearted master.","pos":""}],"IRON-SICK":[{"def":"Having the ironwork loose or corroded; -- said of a ship when her bolts and nails are so eaten with rust that she has become leaky.","pos":""}],"IRON-SIDED":[{"def":"Having iron sides, or very firm sides.","pos":""}],"IRONBARK TREE":[{"def":"The Australian Eucalyptus Sideroxylon, used largely by carpenters and shipbuilders; -- called also ironwood.","pos":""}],"IRONBOUND":[{"def":"Bound as with iron; rugged; as, an ironbound coast.","pos":""},{"def":"Rigid; unyielding; as, ironbound traditions.","pos":""}],"IRONCLAD":[{"def":"Clad in iron; protected or covered with iron, as a vessel for naval warfare.","pos":""},{"def":"Rigorous; severe; exacting; as, an ironclad oath or pledge.","pos":""}],"IRONER":[{"def":"One who, or that which, irons.","pos":""}],"IRONHEADS":[{"def":"A European composite herb (Centaurea nigra); -- so called from the resemblance of its knobbed head to an iron ball fixed on a long handle.","pos":""}],"IRONICAL":[{"def":"Pertaining to irony; containing, expressing, or characterized by, irony; as, an ironical remark.","pos":""},{"def":"Addicted to the use of irony; given to irony.","pos":""}],"IRONING":[{"def":"The act or process of smoothing, as clothes, with hot flatirons.","pos":""},{"def":"The clothes ironed.","pos":""}],"IRONISH":[{"def":"Resembling iron, as in taste.","pos":""}],"IRONIST":[{"def":"One who uses irony.","pos":""}],"IRONMASTER":[{"def":"A manufacturer of iron, or large dealer therein.","pos":""}],"IRONMONGER":[{"def":"A dealer in iron or hardware.","pos":""}],"IRONMONGERY":[{"def":"Hardware; a general name for all articles made of iron.","pos":""}],"IRONSIDES":[{"def":"A cuirassier or cuirassiers; also, hardy veteran soldiers; -- applied specifically to Cromwell's cavalry.","pos":""}],"IRONSMITH":[{"def":"An East Indian barbet (Megalaima faber), inhabiting the Island of Hainan.","pos":""}],"IRONSTONE":[{"def":"A hard, earthy ore of iron.","pos":""}],"IRONWARE":[{"def":"Articles made of iron, as household utensils, tools, and the like.","pos":""}],"IRONWEED":[{"def":"A tall weed with purplish flowers (Vernonia Noveboracensis).","pos":""}],"IRONWOOD":[{"def":"A tree unusually hard, strong, or heavy wood.","pos":""}],"IRONWORK":[{"def":"Anything made of iron; -- a general name of such parts or pieces of a building, vessel, carriage, etc.","pos":""}],"IRONWORT":[{"def":"An herb of the Mint family (Sideritis), supposed to heal sword cuts; also, a species of Galeopsis.","pos":""}],"IRONY":[{"def":"Made or consisting of iron; partaking of iron; iron; as, irony chains; irony particles.","pos":""},{"def":"Resembling iron taste, hardness, or other physical property.","pos":""}],"IROQUOIAN":[{"def":"Of, pertaining to, or designating, one of the principal linguistic stocks of the North American Indians.","pos":""},{"def":"An Indian of an Iroquoian tribe.","pos":""}],"IROQUOIS":[{"def":"A powerful and warlike confederacy of Indian tribes, formerly inhabiting Central New York and constituting most of the Five Nations.","pos":""}],"IROUS":[{"def":"Irascible; passionate.","pos":""},{"def":"A fantastic grimace or contortion of the body.","pos":""}]}