{"MAXILLA":[{"def":"One of the lower or outer jaws of arthropods.","pos":""},{"def":"Pertaining to either the upper or the lower jaw, but now usually applied to the upper jaw only.","pos":""}],"MAXILLIFORM":[{"def":"Having the form, or structure, of a maxilla.","pos":""}],"MAXILLIPED":[{"def":"One of the mouth appendages of Crustacea, situated next behind the maxillæ.","pos":""}],"MAXILLO-MANDIBULAR":[{"def":"Pertaining to the maxilla and mandible; as, the maxillo- mandibular nerve.","pos":""}],"MAXILLO-PALATINE":[{"def":"Pertaining to the maxillary and palatine regions of the skull; as, the maxillo-palatine process of the maxilla.","pos":""}],"MAXILLOTURBINAL":[{"def":"Pertaining to the maxillary and turbinal regions of the skull.","pos":""},{"def":"The maxillo-turbinal, or inferior turbinate, bone.","pos":""}],"MAXIM":[{"def":"The longest note formerly used, equal to two longs, or four breves; a large.","pos":""}],"MAXIM GUN":[{"def":"A kind of machine gun; -- named after its inventor, Hiram S.","pos":""}],"MAXIMILIAN":[{"def":"A gold coin of Bavaria, of the value of about 13s.","pos":""}],"MAXIMIZATION":[{"def":"The act or process of increasing to the highest degree.","pos":""}],"MAXIMIZE":[{"def":"To increase to the highest degree.","pos":""}],"MAXIMUM":[{"def":"The greatest quantity or value attainable in a given case; or, the greatest value attained by a quantity which first increases and then begins to decrease; the highest point or degree; -- opposed to Ant: minimum.","pos":""}]}