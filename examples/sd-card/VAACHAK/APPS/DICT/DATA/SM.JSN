{"SMACK":[{"def":"A small sailing vessel, commonly rigged as a sloop, used chiefly in the coasting and fishing trade.","pos":""}],"SMACKING":[{"def":"A sharp, quick noise; a smack.","pos":""}],"SMALL":[{"def":"Having little size, compared with other things of the same kind; little in quantity or degree; diminutive; not large or extended in dimension; not great; not much; inconsiderable; as, a small man; a small river.","pos":""},{"def":"Being of slight consequence; feeble in influence or importance; unimportant; trivial; insignificant; as, a small fault; a small business.","pos":""}],"SMALLAGE":[{"def":"A biennial umbelliferous plant (Apium graveolens) native of the seacoats of Europe and Asia.","pos":""}],"SMALLCLOTHES":[{"def":"A man's garment for the hips and thighs; breeches.","pos":""}],"SMALLNESS":[{"def":"The quality or state of being small.","pos":""}],"SMALLPOX":[{"def":"A contagious, constitutional, febrile disease characterized by a peculiar eruption; variola.","pos":""}],"SMALLSWORD":[{"def":"A light sword used for thrusting only; especially, the sword worn by civilians of rank in the eighteenth century.","pos":""}],"SMALLY":[{"def":"In a small quantity or degree; with minuteness.","pos":""}],"SMALT":[{"def":"A deep blue pigment or coloring material used in various arts.","pos":""}],"SMALT-BLUE":[{"def":"Deep blue, like smalt.","pos":""},{"def":"A tin-white or gray mineral of metallic luster.","pos":""}],"SMARAGDINE":[{"def":"Of or pertaining to emerald; resembling emerald; of an emerald green.","pos":""}],"SMARAGDITE":[{"def":"A green foliated kind of amphibole, observed in eclogite and some varietis of gabbro.","pos":""}],"SMART":[{"def":"To feel a lively, pungent local pain; -- said of some part of the body as the seat of irritation; as, my finger smarts; these wounds smart.","pos":""},{"def":"To feel a pungent pain of mind; to feel sharp pain or grief; to suffer; to feel the sting of evil.","pos":""}],"SMARTEN":[{"def":"To make smart or spruce; -- usually with up.","pos":""}],"SMARTLY":[{"def":"In a smart manner.","pos":""}],"SMARTNESS":[{"def":"The quality or state of being smart.","pos":""}],"SMARTWEED":[{"def":"An acrid plant of the genus Polygonum (P.","pos":""}],"SMASH":[{"def":"To break in pieces by violence; to dash to pieces; to crush.","pos":""}],"SMASHER":[{"def":"One who, or that which, smashes or breaks things to pieces.","pos":""},{"def":"Anything very large or extraordinary.","pos":""}],"SMATCH":[{"def":"Taste; tincture; smack.","pos":""}],"SMATTER":[{"def":"To talk superficially or ignorantly; to babble; to chatter.","pos":""},{"def":"To have a slight taste, or a slight, superficial knowledge, of anything; to smack.","pos":""}],"SMATTERER":[{"def":"One who has only a slight, superficial knowledge; a sciolist.","pos":""}],"SMATTERING":[{"def":"A slight, superficial knowledge of something; sciolism.","pos":""}],"SMEAR":[{"def":"To overspread with anything unctuous, viscous, or adhesive; to daub; as, to smear anything with oil.","pos":""},{"def":"To soil in any way; to contaminate; to pollute; to stain morally; as, to be smeared with infamy.","pos":""}],"SMEAR DAB":[{"def":"The sand fluke (b).","pos":""}],"SMEARED":[{"def":"Having the color mark ings ill defined, as if rubbed; as, the smeared dagger moth (Apatela oblinita).","pos":""}],"SMEARY":[{"def":"Tending to smear or soil; adhesive; viscous.","pos":""}],"SMECTITE":[{"def":"A hydrous silicate of alumina, of a greenish color, which, in certain states of humidity, appears transparent and almost gelatinous.","pos":""}],"SMEETH":[{"def":"To smoke; to blacken with smoke; to rub with soot.","pos":""}],"SMEGMA":[{"def":"The matter secreted by any of the sebaceous glands.","pos":""}],"SMEGMATIC":[{"def":"Being of the nature of soap; soapy; cleansing; detersive.","pos":""}],"SMEIR":[{"def":"A salt glaze on pottery, made by adding common salt to an earthenware glaze.","pos":""}],"SMELL":[{"def":"To perceive by the olfactory nerves, or organs of smell; to have a sensation of, excited through the nasal organs when affected by the appropriate materials or qualities; to obtain the scent of; as, to smell a rose; to smell perfumes.","pos":""},{"def":"To detect or perceive, as if by the sense of smell; to scent out; -- often with out.","pos":""}],"SMELL-FEAST":[{"def":"One who is apt to find and frequent good tables; a parasite; a sponger.","pos":""},{"def":"A feast at which the guests are supposed to feed upon the odors only of the viands.","pos":""}],"SMELL-LESS":[{"def":"Destitute of smell; having no odor.","pos":""}],"SMELLER":[{"def":"One who smells, or perceives by the sense of smell; one who gives out smell.","pos":""}],"SMELLING":[{"def":"The act of one who smells.","pos":""},{"def":"The sense by which odors are perceived; the sense of smell.","pos":""}],"SMELLING SALTS":[{"def":"An aromatic preparation of carbonate of ammonia and, often, some scent, to avoid or relieve faintness, headache, or the like.","pos":""}],"SMELT":[{"def":"Any one of numerous species of small silvery salmonoid fishes of the genus Osmerus and allied genera, which ascend rivers to spawn, and sometimes become landlocked in lakes.","pos":""}],"SMELTER":[{"def":"One who, or that which, smelts.","pos":""}],"SMELTERY":[{"def":"A house or place for smelting.","pos":""}],"SMELTIE":[{"def":"A fish, the bib.","pos":""}],"SMELTING":[{"def":"Smelt\"ing, Defn: a.","pos":""}],"SMERK":[{"def":"Smart; jaunty; spruce.","pos":""}],"SMICKER":[{"def":"To look amorously or wantonly; to smirk.","pos":""}],"SMICKERING":[{"def":"Amorous glance or inclination.","pos":""}],"SMICKET":[{"def":"A woman's under-garment; a smock.","pos":""}],"SMICKLY":[{"def":"Smugly; finically.","pos":""}],"SMIFT":[{"def":"A match for firing a charge of powder, as in blasting; a fuse.","pos":""}],"SMILE":[{"def":"To express amusement, pleasure, moderate joy, or love and kindness, by the features of the face; to laugh silently.","pos":""},{"def":"To express slight contempt by a look implying sarcasm or pity; to sneer.","pos":""}],"SMILELESS":[{"def":"Not having a smile.","pos":""}],"SMILET":[{"def":"Those happy smilets That played on her ripe lip.","pos":""}],"SMILINGLY":[{"def":"In a smiling manner.","pos":""}],"SMILINGNESS":[{"def":"Quality or state of being smiling.","pos":""}],"SMILODON":[{"def":"An extinct genus of saber-toothed tigers.","pos":""}],"SMINTHURID":[{"def":"Any one of numerous small species of springtails, of the family Sminthurid, -- usually found on flowers.","pos":""}],"SMIRCH":[{"def":"To smear with something which stains, or makes dirty; to smutch; to begrime; to soil; to sully.","pos":""}],"SMIRK":[{"def":"To smile in an affected or conceited manner; to smile with affected complaisance; to simper.","pos":""}],"SMIRKINGLY":[{"def":"With smirking; with a smirk.","pos":""}],"SMIRKY":[{"def":"Smirk; smirking.","pos":""}],"SMIT":[{"def":"Smit, rare Defn: imp.","pos":""}],"SMITE":[{"def":"To strike; to inflict a blow upon with the hand, or with any instrument held in the hand, or with a missile thrown by the hand; as, to smite with the fist, with a rod, sword, spear, or stone.","pos":""},{"def":"To cause to strike; to use as an instrument in striking or hurling.","pos":""}],"SMITER":[{"def":"I give my back to the smiters.","pos":""}],"SMITH":[{"def":"One who forgess with the hammer; one who works in metals; as, a blacksmith, goldsmith, silversmith, and the like.","pos":""},{"def":"One who makes or effects anything.","pos":""}],"SMITHCRAFT":[{"def":"The art or occupation of a smith; smithing.","pos":""}],"SMITHER":[{"def":"Fragments; atoms; finders.","pos":""}],"SMITHEREENS":[{"def":"Fragments; atoms; smithers.","pos":""}],"SMITHERY":[{"def":"The workshop of a smith; a smithy or stithy.","pos":""},{"def":"Work done by a smith; smithing.","pos":""}],"SMITHING":[{"def":"The act or art of working or forging metals, as iron, into any desired shape.","pos":""}],"SMITHSONIAN":[{"def":"Of or pertaining to the Englishman J.","pos":""},{"def":"The Smithsonian Institution.","pos":""}],"SMITHSONITE":[{"def":"Native zinc carbonate.","pos":""}],"SMITHY":[{"def":"The workshop of a smith, esp.","pos":""}],"SMITT":[{"def":"Fine clay or ocher made up into balls, used for marking sheep.","pos":""}],"SMITTLE":[{"def":"Infectious; catching.","pos":""}],"SMOCK":[{"def":"A woman's under-garment; a shift; a chemise.","pos":""},{"def":"A blouse; a smoock frock.","pos":""}],"SMOCK FROCK":[{"def":"A coarse frock, or shirt, worn over the other dress, as by farm laborers.","pos":""}],"SMOCK-FACED":[{"def":"Having a feminine countenance or complexion; smooth-faced; girlish.","pos":""}],"SMOCKLESS":[{"def":"Wanting a smock.","pos":""}],"SMOKABLE":[{"def":"Capable of being smoked; suitable or ready to be smoked; as, smokable tobacco.","pos":""}],"SMOKE":[{"def":"The visible exhalation, vapor, or substance that escapes, or expelled, from a burning body, especially from burning vegetable matter, as wood, coal, peat, or the like.","pos":""},{"def":"That which resembles smoke; a vapor; a mist.","pos":""}],"SMOKE BALL":[{"def":"Same as Puffball.","pos":""}],"SMOKE-DRY":[{"def":"To dry by or in smoke.","pos":""}],"SMOKEHOUSE":[{"def":"A building where meat or fish is cured by subjecting it to a dense smoke.","pos":""}],"SMOKEJACK":[{"def":"A contrivance for turning a spit by means of a fly or wheel moved by the current of ascending air in a chimney.","pos":""}],"SMOKELESS":[{"def":"Making or having no smoke.","pos":""}],"SMOKELESS POWDER":[{"def":"A high-explosive gunpowder whose explosion produces little, if any, smoke.","pos":""}],"SMOKER":[{"def":"One who dries or preserves by smoke.","pos":""},{"def":"One who smokes tobacco or the like.","pos":""}],"SMOKILY":[{"def":"In a smoky manner.","pos":""}],"SMOKINESS":[{"def":"The quality or state of being smoky.","pos":""}],"SMOKY":[{"def":"To smother; to suffocate; to choke.","pos":""}],"SMOLT":[{"def":"A young salmon two or three years old, when it has acquired its silvery color.","pos":""}],"SMOOR":[{"def":"To suffocate or smother.","pos":""}],"SMOOTH":[{"def":"Causing no resistance to a body sliding along its surface; frictionless.","pos":""}],"SMOOTH-CHINNED":[{"def":"Having a smooth chin; beardless.","pos":""}],"SMOOTH-SPOKEN":[{"def":"Speaking smoothly; plausible; flattering; smooth-tongued.","pos":""}],"SMOOTH-TONGUED":[{"def":"Having a smooth tongue; plausible; flattering.","pos":""}],"SMOOTHBORE":[{"def":"Having a bore of perfectly smooth surface; -- distinguished from rifled.","pos":""},{"def":"A smoothbore firearm.","pos":""}],"SMOOTHER":[{"def":"One who, or that which, smooths.","pos":""}],"SMOOTHLY":[{"def":"In a smooth manner.","pos":""}],"SMOOTHNESS":[{"def":"Quality or state of being smooth.","pos":""}],"SMORE":[{"def":"Growing gradually fainter and softer; dying away; morendo.","pos":""}],"SMOTHER":[{"def":"To destroy the life of by suffocation; to deprive of the air necessary for life; to cover up closely so as to prevent breathing; to suffocate; as, to smother a child.","pos":""},{"def":"To affect as by suffocation; to stife; to deprive of air by a thick covering, as of ashes, of smoke, or the like; as, to smother a fire.","pos":""}],"SMOTHERED MATE":[{"def":"Checkmate given when movement of the king is completely obstructed by his own men.","pos":""}],"SMOTHERINESS":[{"def":"The quality or state of being smothery.","pos":""}],"SMOTHERINGLY":[{"def":"In a smothering manner.","pos":""}],"SMOTHERY":[{"def":"Tending to smother; stifling.","pos":""}],"SMOUCH":[{"def":"To kiss closely.","pos":""}],"SMUDGE":[{"def":"A suffocating smoke.","pos":""},{"def":"A heap of damp combustibles partially ignited and burning slowly, placed on the windward side of a house, tent, or the like, in order, by the thick smoke, to keep off mosquitoes or other insects.","pos":""}],"SMUDGINESS":[{"def":"The quality or state of being smudged, soiled, or blurred.","pos":""}],"SMUG":[{"def":"Studiously neat or nice, especially in dress; spruce; affectedly precise; smooth and prim.","pos":""}],"SMUGGLE":[{"def":"To import or export secretly, contrary to the law; to import or export without paying the duties imposed by law; as, to smuggle lace.","pos":""}],"SMUGGLER":[{"def":"One who smuggles.","pos":""},{"def":"A vessel employed in smuggling.","pos":""}],"SMUGLY":[{"def":"In a smug manner.","pos":""}],"SMUGNESS":[{"def":"The quality or state of being smug.","pos":""}],"SMUT":[{"def":"Bad, soft coal, containing much earthy matter, found in the immediate locality of faults.","pos":""},{"def":"An affection of cereal grains producing a swelling which is at length resolved into a powdery sooty mass.","pos":""}],"SMUTCH":[{"def":"A stain; a dirty spot.","pos":""}],"SMUTTY":[{"def":"Soiled with smut; smutted.","pos":""},{"def":"Tainted with mildew; as, smutty corn.","pos":""}],"SMYRNIOT":[{"def":"Of or pertaining to Smyrna.","pos":""},{"def":"A native or inhabitant of Smyrna.","pos":""}]}