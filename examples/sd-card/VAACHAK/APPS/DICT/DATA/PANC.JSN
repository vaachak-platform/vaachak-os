{"PANCAKE":[{"def":"A thin cake of batter fried in a pan or on a griddle; a griddlecake; a flapjack.","pos":""}],"PANCARTE":[{"def":"A royal charter confirming to a subject all his possessions.","pos":""}],"PANCHWAY":[{"def":"A Bengalese four-oared boat for passengers.","pos":""}],"PANCRATIAN":[{"def":"Pancratic; athletic.","pos":""}],"PANCRATIAST":[{"def":"One who engaged in the contests of the pancratium.","pos":""}],"PANCRATIASTIC":[{"def":"Of or pertaining to the pancratium.","pos":""}],"PANCRATIC":[{"def":"Having all or many degrees of power; having a great range of power; -- said of an eyepiece made adjustable so as to give a varying magnifying power.","pos":""},{"def":"Of or pertaining to the pancratium; athletic.","pos":""}],"PANCRATIST":[{"def":"An athlete; a gymnast.","pos":""}],"PANCRATIUM":[{"def":"An athletic contest involving both boxing and wrestling.","pos":""},{"def":"A genus of Old World amaryllideous bulbous plants, having a funnel-shaped perianth with six narrow spreading lobes.","pos":""}],"PANCREAS":[{"def":"The sweetbread, a gland connected with the intestine of nearly all vertebrates.","pos":""}],"PANCREATIC":[{"def":"Of or pertaining to the pancreas; as, the pancreatic secretion, digestion, ferments.","pos":""}],"PANCREATIN":[{"def":"One of the digestive ferments of the pancreatic juice; also, a preparation containing such a ferment, made from the pancreas of animals, and used in medicine as an aid to digestion.","pos":""}]}