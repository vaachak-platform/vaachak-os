{"RACA":[{"def":"A term of reproach used by the Jews of our Savior's time, meaning \"worthless.","pos":""}],"RACAHOUT":[{"def":"A preparation from acorns used by the Arabs as a substitute for chocolate, and also as a beverage for invalids.","pos":""}],"RACCOON":[{"def":"A North American nocturnal carnivore (Procyon lotor) allied to the bears, but much smaller, and having a long, full tail, banded with black and gray.","pos":""}],"RACE":[{"def":"A game, match, etc.","pos":""}],"RACE SUICIDE":[{"def":"The voluntary failure of the members of a race or people to have a number of children sufficient to keep the birth rate equal to the death rate.","pos":""},{"def":"A dog that pursued his prey by scent, as distinguished from the greyhound.","pos":""}],"RACEABOUT":[{"def":"A small sloop-rigged racing yacht carrying about six hundred square feet of sail, distinguished from a knockabout by having a short bowsprit.","pos":""}],"RACEMATE":[{"def":"A salt of racemic acid.","pos":""}],"RACEMATION":[{"def":"A cluster or bunch, as of grapes.","pos":""},{"def":"Cultivation or gathering of clusters of grapes.","pos":""}],"RACEME":[{"def":"A flower cluster with an elongated axis and many one-flowered lateral pedicels, as in the currant and chokecherry.","pos":""}],"RACEMED":[{"def":"Arranged in a raceme, or in racemes.","pos":""}],"RACEMIC":[{"def":"Pertaining to, or designating, an acid found in many kinds of grapes.","pos":""}],"RACEMIFEROUS":[{"def":"Bearing racemes, as the currant.","pos":""}],"RACEMIFORM":[{"def":"Having the form of a raceme.","pos":""}],"RACEMOSE":[{"def":"Resembling a raceme; growing in the form of a raceme; as, (Bot.","pos":""}],"RACEMULE":[{"def":"A little raceme.","pos":""}],"RACEMULOSE":[{"def":"Growing in very small racemes.","pos":""}],"RACER":[{"def":"The common American black snake.","pos":""},{"def":"One of the circular iron or steel rails on which the chassis of a heavy gun is turned.","pos":""}],"RACHIALGIA":[{"def":"A painful affection of the spine; especially, Pott's disease; also, formerly, lead colic.","pos":""}],"RACHIDIAN":[{"def":"Of or pertaining to the rachis; spinal; vertebral.","pos":""}],"RACHILLA":[{"def":"Same as Rhachilla.","pos":""}],"RACHIODONT":[{"def":"Same as Rhachiodont.","pos":""}],"RACHIS":[{"def":"The spine; the vertebral column.","pos":""},{"def":"Same as Rhachis.","pos":""}],"RACHITIC":[{"def":"Of or pertaining to rachitis; affected by rachitis; rickety.","pos":""}],"RACHITIS":[{"def":"Literally, inflammation of the spine, but commonly applied to the rickets.","pos":""},{"def":"A disease which produces abortion in the fruit or seeds.","pos":""}],"RACHITOME":[{"def":"A dissecting instrument for opening the spinal canal.","pos":""}],"RACIAL":[{"def":"Of or pertaining to a race or family of men; as, the racial complexion.","pos":""}],"RACILY":[{"def":"In a racy manner.","pos":""}],"RACINESS":[{"def":"The quality of being racy; peculiar and piquant flavor.","pos":""}],"RACK":[{"def":"The neck and spine of a fore quarter of veal or mutton.","pos":""}],"RACK-RENT":[{"def":"A rent of the full annual value of the tenement, or near it; an excessive or unreasonably high rent.","pos":""}],"RACK-RENTER":[{"def":"One who is subjected to playing rack-rent.","pos":""},{"def":"One who exacts rack-rent.","pos":""}],"RACKABONES":[{"def":"A very lean animal, esp.","pos":""}],"RACKAROCK":[{"def":"A Sprengel explosive consisting of potassium chlorate and mono- nitrobenzene.","pos":""}],"RACKER":[{"def":"A horse that has a racking gait.","pos":""}],"RACKET":[{"def":"A thin strip of wood, having the ends brought together, forming a somewhat elliptical hoop, across which a network of catgut or cord is stretched.","pos":""},{"def":"A variety of the game of tennis played with peculiar long-handled rackets; -- chiefly in the plural.","pos":""}],"RACKET-TAIL":[{"def":"Any one of several species of humming birds of the genus Steganura, having two of the tail feathers very long and racket- shaped.","pos":""}],"RACKET-TAILED":[{"def":"Having long and spatulate, or racket-shaped, tail feathers.","pos":""}],"RACKETER":[{"def":"One who makes, or engages in, a racket.","pos":""}],"RACKETT":[{"def":"An old wind instrument of the double bassoon kind, having ventages but not keys.","pos":""}],"RACKETY":[{"def":"Making a tumultuous noise.","pos":""}],"RACKING":[{"def":"Spun yarn used in racking ropes.","pos":""}],"RACKTAIL":[{"def":"An arm attached to a swinging notched arc or rack, to let off the striking mechanism of a repeating clock.","pos":""}],"RACKWORK":[{"def":"Any mechanism having a rack, as a rack and pinion.","pos":""}],"RACONTEUR":[{"def":"A relater; a storyteller.","pos":""}],"RACOVIAN":[{"def":"One of a sect of Socinians or Unitarians in Poland.","pos":""}],"RACY":[{"def":"Having a strong flavor indicating origin; of distinct characteristic taste; tasting of the soil; hence, fresh; rich.","pos":""},{"def":"Hence: Exciting to the mental taste by a strong or distinctive character of thought or language; peculiar and piquant; fresh and lively.","pos":""}]}