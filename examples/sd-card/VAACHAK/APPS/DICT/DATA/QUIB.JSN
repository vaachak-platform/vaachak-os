{"QUIBBLE":[{"def":"A shift or turn from the point in question; a trifling or evasive distinction; an evasion; a cavil.","pos":""},{"def":"A pun; a low conceit.","pos":""}],"QUIBBLER":[{"def":"One who quibbles; a caviler; also, a punster.","pos":""}],"QUIBBLINGLY":[{"def":"Triflingly; evasively.","pos":""}]}