{"POLYP":[{"def":"Same as Anthozoa.","pos":""}],"POLYPAROUS":[{"def":"Producing or bearing a great number; bringing forth many.","pos":""}],"POLYPARY":[{"def":"Same as Polypidom.","pos":""}],"POLYPEAN":[{"def":"Of or pertaining to a polyp, or polyps.","pos":""}],"POLYPERYTHRIN":[{"def":"A coloring matter found in many simple Anthozoa and some hydroids.","pos":""}],"POLYPETALOUS":[{"def":"Consisting of, or having, several or many separate petals; as, a polypetalous corolla, flower, or plant.","pos":""}],"POLYPHAGOUS":[{"def":"Eating, or subsisting on, many kinds of food; as, polyphagous animals.","pos":""}],"POLYPHAGY":[{"def":"The practice or faculty of subsisting on many kinds of food.","pos":""}],"POLYPHASE":[{"def":"Having or producing two or more phases; multiphase; as, a polyphase machine, a machine producing two or more pressure waves of electro-motive force, differing in phase; a polyphase current.","pos":""}],"POLYPHASER":[{"def":"A machine generating more than one pressure wave; a multiphaser.","pos":""}],"POLYPHEMUS":[{"def":"A very large American moth (Telea polyphemus) belonging to the Silkworm family (Bombycidæ).","pos":""}],"POLYPHONE":[{"def":"A character or vocal sign representing more than one sound, as read, which is pronounced red or rèd.","pos":""}],"POLYPHONIC":[{"def":"Consisting of several tone series, or melodic parts, progressing simultaneously according to the laws of counterpoint; contrapuntal; as, a polyphonic composition; -- opposed to homophonic, or monodic.","pos":""}],"POLYPHONIST":[{"def":"A master of polyphony; a contrapuntist.","pos":""}],"POLYPHONOUS":[{"def":"Same as Polyphonic.","pos":""}],"POLYPHONY":[{"def":"Composition in mutually related, equally important parts which share the melody among them; contrapuntal composition; -- opposed to homophony, in which the melody is given to one part only, the others filling out the harmony.","pos":""}],"POLYPHORE":[{"def":"A receptacle which bears many ovaries.","pos":""},{"def":"Pertaining to or designating arc lamps so constructed that more than one can be used on a single circuit.","pos":""}],"POLYPHYLETIC":[{"def":"Pertaining to, or characterized by, descent from more than one root form, or from many different root forms; polygenetic; -- opposed to Ant: monophyletic.","pos":""}],"POLYPHYLLOUS":[{"def":"Many-leaved; as, a polyphyllous calyx or perianth.","pos":""}],"POLYPIDE":[{"def":"One of the ordinary zooids of the Bryozoa.","pos":""}],"POLYPIDOM":[{"def":"A coral, or corallum; also, one of the coral-like structure made by bryozoans and hydroids.","pos":""}],"POLYPIFEROUS":[{"def":"Bearing polyps, or polypites.","pos":""}],"POLYPIPAROUS":[{"def":"Producing polyps.","pos":""}],"POLYPLACOPHORA":[{"def":"Pol`y*pla*coph\"o*ra, n.","pos":""}],"POLYPLASTIC":[{"def":"Assuming, or having the power of assuming, many forms; as, a polyplastic element which does not preserve its original shape.","pos":""}],"POLYPODE":[{"def":"A plant of the genus Polypodium; polypody.","pos":""}],"POLYPODIUM":[{"def":"A genus of plants of the order Filices or ferns.","pos":""}],"POLYPODY":[{"def":"Any plant of the genus Polypodium.","pos":""}],"POLYPOID":[{"def":"Like a polyp; having the nature of a polyp, but lacking the tentacles or other parts.","pos":""},{"def":"Resembling a polypus in appearance; having a character like that of a polypus.","pos":""}],"POLYPOMEDUSAE":[{"def":"Same as Hydrozoa.","pos":""}],"POLYPOROUS":[{"def":"Having many pores.","pos":""}],"POLYPORUS":[{"def":"A genus of fungi having the under surface full of minute pores; also, any fungus of this genus.","pos":""}],"POLYPOUS":[{"def":"Of the nature of a polypus; having many feet or roots, like the polypus; affected with polypus.","pos":""},{"def":"Overbusy; officious.","pos":""}],"POLYPRAGMATY":[{"def":"The state of being overbusy.","pos":""}],"POLYPROTODONTA":[{"def":"A division of marsupials in which there are more fore incisor teeth in each jaw.","pos":""}],"POLYPTEROIDEI":[{"def":"A suborder of existing ganoid fishes having numerous fins along the back.","pos":""}],"POLYPTERUS":[{"def":"An African genus of ganoid fishes including the bichir.","pos":""}],"POLYPTOTON":[{"def":"A figure by which a word is repeated in different forms, cases, numbers, genders, etc.","pos":""}],"POLYPUS":[{"def":"A tumor, usually with a narrow base, somewhat resembling a pear, -- found in the nose, uterus, etc.","pos":""}]}