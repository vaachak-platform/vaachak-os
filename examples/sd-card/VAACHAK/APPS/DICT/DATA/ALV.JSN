{"ALVEARY":[{"def":"The hollow of the external ear.","pos":""}],"ALVEATED":[{"def":"Formed or vaulted like a beehive.","pos":""}],"ALVEOLAR":[{"def":"Of, pertaining to, or resembling, alveoli or little cells, sacs, or sockets.","pos":""}],"ALVEOLATE":[{"def":"Deeply pitted, like a honeycomb.","pos":""}],"ALVEOLE":[{"def":"Same as Alveolus.","pos":""}],"ALVEOLIFORM":[{"def":"Having the form of alveoli, or little sockets, cells, or cavities.","pos":""}],"ALVEOLUS":[{"def":"A small cavity in a coral, shell, or fossil 3.","pos":""},{"def":"A small depression, sac, or vesicle, as the socket of a tooth, the air cells of the lungs, the ultimate saccules of glands, etc.","pos":""}],"ALVEUS":[{"def":"The channel of a river.","pos":""}],"ALVINE":[{"def":"Of, from, in, or pertaining to, the belly or the intestines; as, alvine discharges; alvine concretions.","pos":""}]}