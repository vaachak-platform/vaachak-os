{"ALLIABLE":[{"def":"Able to enter into alliance.","pos":""}],"ALLIACEOUS":[{"def":"Of or pertaining to the genus Allium, or garlic, onions, leeks, etc.","pos":""}],"ALLIANCE":[{"def":"The state of being allied; the act of allying or uniting; a union or connection of interests between families, states, parties, etc.","pos":""},{"def":"Any union resembling that of families or states; union by relationship in qualities; affinity.","pos":""}],"ALLIANT":[{"def":"An ally; a confederate.","pos":""},{"def":"The European shad (Clupea vulgaris); allice shad.","pos":""}],"ALLICIENCY":[{"def":"Attractive power; attractiveness.","pos":""}],"ALLICIENT":[{"def":"That attracts; attracting.","pos":""}],"ALLIED":[{"def":"United; joined; leagued; akin; related.","pos":""}],"ALLIGATE":[{"def":"To tie; to unite by some tie.","pos":""}],"ALLIGATION":[{"def":"A rule relating to the solution of questions concerning the compounding or mixing of different ingredients, or ingredients of different qualities or values.","pos":""}],"ALLIGATOR":[{"def":"A large carnivorous reptile of the Crocodile family, peculiar to America.","pos":""},{"def":"Any machine with strong jaws, one of which opens like the movable jaw of an alligator; as, (a) (Metal Working) Defn: a form of squeezer for the puddle ball; (b) (Mining) a rock breaker; (c) (Printing) a kind of job press, called also alligator press.","pos":""}],"ALLIGATOR WRENCH":[{"def":"A kind of pipe wrench having a flaring jaw with teeth on one side.","pos":""}],"ALLINEATE":[{"def":"Alignment; position in a straight line, as of two planets with the sun.","pos":""}],"ALLISION":[{"def":"The act of dashing against, or striking upon.","pos":""}],"ALLITERAL":[{"def":"Pertaining to, or characterized by alliteration.","pos":""}],"ALLITERATE":[{"def":"To employ or place so as to make alliteration.","pos":""}],"ALLITERATION":[{"def":"The repetition of the same letter at the beginning of two or more words immediately succeeding each other, or at short intervals; as in the following lines: - Behemoth, biggest born of earth, upheaved His vastness.","pos":""}],"ALLITERATIVE":[{"def":"Pertaining to, or characterized by, alliteration; as, alliterative poetry.","pos":""}],"ALLITERATOR":[{"def":"One who alliterates.","pos":""}],"ALLIUM":[{"def":"A genus of plants, including the onion, garlic, leek, chive, etc.","pos":""}]}