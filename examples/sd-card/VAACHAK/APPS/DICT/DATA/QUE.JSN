{"QUE":[{"def":"A half farthing.","pos":""}],"QUEACH":[{"def":"A thick, bushy plot; a thicket.","pos":""}],"QUEACHY":[{"def":"Yielding or trembling under the feet, as moist or boggy ground; shaking; moving.","pos":""},{"def":"Like a queach; thick; bushy.","pos":""}],"QUEAN":[{"def":"A woman; a young or unmarried woman; a girl.","pos":""},{"def":"A low woman; a wench; a slut.","pos":""}],"QUEASILY":[{"def":"In a queasy manner.","pos":""}],"QUEASINESS":[{"def":"The state of being queasy; nausea; qualmishness; squeamishness.","pos":""}],"QUEASY":[{"def":"Sick at the stomach; affected with nausea; inclined to vomit; qualmish.","pos":""},{"def":"Fastidious; squeamish; delicate; easily disturbed; unsettled; ticklish.","pos":""}],"QUEBEC GROUP":[{"def":"The middle of the three groups into which the rocks of the Canadian period have been divided in the American Lower Silurian system.","pos":""}],"QUEBRACHO":[{"def":"Lorentzii) whose bark is said to have similar properties.","pos":""}],"QUEBRITH":[{"def":"A word occurring in a corrupt passage of Bacon's Essays, and probably meaning, to stir, to move.","pos":""}],"QUEEN":[{"def":"The most powerful, and except the king the most important, piece in a set of chessmen.","pos":""},{"def":"A male homosexual, esp.","pos":""}],"QUEEN OLIVE":[{"def":"Properly, a kind of superior olive grown in the region of Seville, Spain.","pos":""}],"QUEEN TRUSS":[{"def":"A truss framed with queen-posts; a queen-post truss.","pos":""}],"QUEEN-POST":[{"def":"One of two suspending posts in a roof truss, or other framed truss of similar form.","pos":""}],"QUEENCRAFT":[{"def":"Craft or skill in policy on the part of a queen.","pos":""}],"QUEENDOM":[{"def":"The dominion, condition, or character of a queen.","pos":""}],"QUEENFISH":[{"def":"A California sciænoid food fish (Seriphys politus).","pos":""}],"QUEENHOOD":[{"def":"The state, personality, or character of a queen; queenliness.","pos":""}],"QUEENING":[{"def":"Any one of several kinds of apples, as summer queening, scarlet queening, and early queening.","pos":""}],"QUEENLINESS":[{"def":"The quality of being queenly; the; characteristic of a queen; stateliness; eminence among women in attractions or power.","pos":""}],"QUEENLY":[{"def":"Like, becoming, or suitable to, a queen.","pos":""}],"QUEENSHIP":[{"def":"The state, rank, or dignity of a queen.","pos":""}],"QUEENSLAND NUT":[{"def":"The nut of an Australian tree (Macadamia ternifolia).","pos":""}],"QUEER":[{"def":"At variance with what is usual or normal; differing in some odd way from what is ordinary; odd; singular; strange; whimsical; as, a queer story or act.","pos":""},{"def":"Mysterious; suspicious; questionable; as, a queer transaction.","pos":""}],"QUEERISH":[{"def":"Rather queer; somewhat singular.","pos":""}],"QUEERLY":[{"def":"In a queer or odd manner.","pos":""}],"QUEERNESS":[{"def":"The quality or state of being queer.","pos":""}],"QUEEST":[{"def":"The European ringdove (Columba palumbus); the cushat.","pos":""}],"QUEGH":[{"def":"A drinking vessel.","pos":""}],"QUELL":[{"def":"To be subdued or abated; to yield; to abate.","pos":""}],"QUELLER":[{"def":"A killer; as, Jack the Giant Queller.","pos":""},{"def":"One who quells; one who overpowers or subdues.","pos":""}],"QUELLIO":[{"def":"A ruff for the neck.","pos":""}],"QUELQUECHOSE":[{"def":"A trifle; a kickshaw.","pos":""}],"QUEMEFUL":[{"def":"Kindly; merciful.","pos":""}],"QUENCH":[{"def":"To extinguish; to overwhelm; to make an end of; -- said of flame and fire, of things burning, and figuratively of sensations and emotions; as, to quench flame; to quench a candle; to quench thirst, love, hate, etc.","pos":""},{"def":"To cool suddenly, as heated steel, in tempering.","pos":""}],"QUENCHABLE":[{"def":"Capable of being quenched.","pos":""}],"QUENCHER":[{"def":"One who, or that which, quenches.","pos":""}],"QUENCHLESS":[{"def":"Incapable of being quenched; inextinguishable; as, quenchless fire or fury.","pos":""}],"QUENELLE":[{"def":"A kind of delicate forcemeat, commonly poached and used as a dish by itself or for garnishing.","pos":""}],"QUENOUILLE TRAINING":[{"def":"A method of training trees or shrubs in the shape of a cone or distaff by tying down the branches and pruning.","pos":""}],"QUERCITANNIC":[{"def":"Pertaining to, or designating, a tannic acid found in oak bark and extracted as a yellowish brown amorphous substance.","pos":""}],"QUERCITE":[{"def":"A white crystalline substance, C6H7(OH)5, found in acorns, the fruit of the oak (Quercus).","pos":""}],"QUERCITIN":[{"def":"A yellow crystalline substance, occurring quite widely distributed in the vegetable kingdom, as is apple-tree bark, horse- chestnut leaves, etc.","pos":""}],"QUERCITRIN":[{"def":"A glucoside extracted from the bark of the oak (Quercus) as a bitter citron-yellow crystalline substance, used as a pigment and called quercitron.","pos":""}],"QUERCITRON":[{"def":"The yellow inner bark of the Quercus tinctoria, the American black oak, yellow oak, dyer's oak, or quercitron oak, a large forest tree growing from Maine to eastern Texas.","pos":""},{"def":"Quercitrin, used as a pigment.","pos":""}],"QUERCUS":[{"def":"A genus of trees constituted by the oak.","pos":""}],"QUERELE":[{"def":"A complaint to a court.","pos":""}],"QUERENT":[{"def":"A complainant; a plaintiff.","pos":""}],"QUERIMONIOUS":[{"def":"Complaining; querulous; apt to complain.","pos":""}],"QUERIMONY":[{"def":"A complaint or complaining.","pos":""}],"QUERIST":[{"def":"One who inquires, or asks questions.","pos":""}],"QUERKEN":[{"def":"To stifle or choke.","pos":""}],"QUERL":[{"def":"To twirl; to turn or wind round; to coil; as, to querl a cord, thread, or rope.","pos":""}],"QUERN":[{"def":"A mill for grinding grain, the upper stone of which was turned by hand; -- used before the invention of windmills and watermills.","pos":""}],"QUERPO":[{"def":"The inner or body garments taken together.","pos":""}],"QUERRY":[{"def":"A groom; an equerry.","pos":""}],"QUERULOUS":[{"def":"Given to quarreling; quarrelsome.","pos":""},{"def":"Apt to find fault; habitually complaining; disposed to murmur; as, a querulous man or people.","pos":""}],"QUERY":[{"def":"A question; an inquiry to be answered or solved.","pos":""},{"def":"A question in the mind; a doubt; as, I have a query about his sincerity.","pos":""}],"QUESAL":[{"def":"The long-tailed, or resplendent, trogon (Pharomachus mocinno, formerly Trogon resplendens), native of Southern Mexico and Central America.","pos":""}],"QUEST":[{"def":"The act of seeking, or looking after anything; attempt to find or obtain; search; pursuit; as, to rove in quest of game, of a lost child, of property, etc.","pos":""},{"def":"Request; desire; solicitation.","pos":""}],"QUESTANT":[{"def":"One who undertakes a quest; a seeker.","pos":""}],"QUESTER":[{"def":"One who seeks; a seeker.","pos":""}],"QUESTION":[{"def":"The act of asking; interrogation; inquiry; as, to examine by question and answer.","pos":""},{"def":"Discussion; debate; hence, objection; dispute; doubt; as, the story is true beyond question; he obeyed without question.","pos":""}],"QUESTIONABILITY":[{"def":"The state or condition of being questionable.","pos":""}],"QUESTIONABLE":[{"def":"Admitting of being questioned; inviting, or seeming to invite, inquiry.","pos":""},{"def":"Liable to question; subject to be doubted or called in question; problematical; doubtful; suspicious.","pos":""}],"QUESTIONABLENESS":[{"def":"The quality or state of being questionable, doubtful, or suspicious.","pos":""}],"QUESTIONABLY":[{"def":"In a questionable manner.","pos":""}],"QUESTIONARY":[{"def":"Inquiring; asking questions; testing.","pos":""}],"QUESTIONER":[{"def":"One who asks questions; an inquirer.","pos":""}],"QUESTIONIST":[{"def":"A candidate for honors or degrees who is near the time of his examination.","pos":""}],"QUESTIONLESS":[{"def":"Unquestioning; incurious.","pos":""}],"QUESTIONNAIRE":[{"def":"= Questionary, above.","pos":""}],"QUESTMAN":[{"def":"One legally empowered to make quest of certain matters, esp.","pos":""}],"QUESTMONGER":[{"def":"One who lays informations, and encourages petty lawsuits.","pos":""}],"QUESTOR":[{"def":"An officer who had the management of the public treasure; a receiver of taxes, tribute, etc.","pos":""}],"QUESTORSHIP":[{"def":"The office, or the term of office, of a questor.","pos":""}],"QUESTRIST":[{"def":"A seeker; a pursuer.","pos":""}],"QUESTUARY":[{"def":"Studious of profit.","pos":""}],"QUET":[{"def":"The common guillemot.","pos":""}],"QUEUE":[{"def":"To fasten, as hair, in a queue.","pos":""}]}