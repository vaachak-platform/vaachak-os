{"REDDE":[{"def":"Red\"de (-de), Defn: obs.","pos":""}],"REDDEN":[{"def":"To make red or somewhat red; to give a red color to.","pos":""}],"REDDENDUM":[{"def":"A clause in a deed by which some new thing is reserved out of what had been granted before; the clause by which rent is reserved in a lease.","pos":""}],"REDDISH":[{"def":"Somewhat red; moderately red.","pos":""}],"REDDITION":[{"def":"Restoration: restitution: surrender.","pos":"noun"},{"def":"Explanation; representation.","pos":"noun"}],"REDDITIVE":[{"def":"Answering to an interrogative or inquiry; conveying a reply; as, redditive words.","pos":""}],"REDDLE":[{"def":"The lowest grade of flour in milling.","pos":""}],"REDDOUR":[{"def":"Rigor; violence.","pos":""}]}