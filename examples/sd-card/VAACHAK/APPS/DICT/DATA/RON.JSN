{"RONCADOR":[{"def":"Any one of several species of California sciænoid food fishes, especially Roncador Stearnsi, which is an excellent market fish, and the red roncador (Corvina, or Johnius, saturna).","pos":""}],"RONCHIL":[{"def":"An American marine food fish (Bathymaster signatus) of the North Pacific coast, allied to the tilefish.","pos":""}],"RONDACHE":[{"def":"A circular shield carried by foot soldiers.","pos":""}],"RONDE":[{"def":"A kind of script in which the heavy strokes are nearly upright, giving the characters when taken together a round look.","pos":""}],"RONDEAU":[{"def":"A species of lyric poetry so composed as to contain a refrain or repetition which recurs according to a fixed law, and a limited number of rhymes recurring also by rule.","pos":""}],"RONDEL":[{"def":"A small round tower erected at the foot of a bastion.","pos":""}],"RONDELETIA":[{"def":"A tropical genus of rubiaceous shrubs which often have brilliant flowers.","pos":""}],"RONDLE":[{"def":"A round mass, plate, or disk; especially (Metal.","pos":""}],"RONDO":[{"def":"A composition, vocal or instrumental, commonly of a lively, cheerful character, in which the first strain recurs after each of the other strains.","pos":""}],"RONDURE":[{"def":"A round; a circle.","pos":""},{"def":"Roundness; plumpness.","pos":""}],"RONG":[{"def":"Rung (of a ladder).","pos":""}],"RONGEUR":[{"def":"An instrument for removing small rough portions of bone.","pos":""}],"RONIN":[{"def":"In Japan, under the feudal system, a samurai who had renounced his clan or who had been discharged or ostracized and had become a wanderer without a lord; an outcast; an outlaw.","pos":""},{"def":"A mangy or scabby creature.","pos":""}],"RONTGEN":[{"def":"Of or pertaining to the German physicist Wilhelm Konrad Röntgen, or the rays discovered by him; as, Röntgen apparatus.","pos":""}],"RONTGEN RAY":[{"def":"Any of the rays produced when cathode rays strike upon surface of a solid (as the wall of the vacuum tube).","pos":""}],"RONTGENIZE":[{"def":"To render (air or other gas) conducting by the passage of Röntgen rays.","pos":""}]}