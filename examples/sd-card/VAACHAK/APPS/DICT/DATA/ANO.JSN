{"ANOA":[{"def":"A small wild ox of Celebes (Anoa depressicornis), allied to the buffalo, but having long nearly straight horns.","pos":""}],"ANODE":[{"def":"The positive pole of an electric battery, or more strictly the electrode by which the current enters the electrolyte on its way to the other pole; -- opposed to cathode.","pos":""}],"ANODON":[{"def":"A genus of fresh-water bivalves, having to teeth at the hinge.","pos":""}],"ANODYNE":[{"def":"Serving to assuage pain; soothing.","pos":""}],"ANOETIC":[{"def":"Presentation considered as having an existence relatively independent of thought, may be called sentience, or anoetic consciousness.","pos":""}],"ANOIL":[{"def":"The anoint with oil.","pos":""}],"ANOINT":[{"def":"To smear or rub over with oil or an unctuous substance; also, to spread over, as oil.","pos":""},{"def":"To apply oil to or to pour oil upon, etc.","pos":""}],"ANOINTER":[{"def":"One who anoints.","pos":""}],"ANOINTMENT":[{"def":"The act of anointing, or state of being anointed; also, an ointment.","pos":""}],"ANOLIS":[{"def":"A genus of lizards which belong to the family Iguanidæ.","pos":""}],"ANOMAL":[{"def":"Anything anomalous.","pos":""},{"def":"Having anomalous feet.","pos":""}],"ANOMALIPED":[{"def":"One of a group of perching birds, having the middle toe more or less united to the outer and inner ones.","pos":""}],"ANOMALISM":[{"def":"An anomaly; a deviation from rule.","pos":""},{"def":"Pertaining to the anomaly, or angular distance of a planet from its perihelion.","pos":""}],"ANOMALISTICALLY":[{"def":"With irregularity.","pos":""}],"ANOMALOFLOROUS":[{"def":"Having anomalous flowers.","pos":""}],"ANOMALOUS":[{"def":"Deviating from a general rule, method, or analogy; abnormal; irregular; as, an anomalous proceeding.","pos":""}],"ANOMALOUSLY":[{"def":"In an anomalous manner.","pos":""}],"ANOMALOUSNESS":[{"def":"Quality of being anomalous.","pos":""}],"ANOMALY":[{"def":"Any deviation from the essential characteristics of a specific type.","pos":""}],"ANOMIA":[{"def":"A genus of bivalve shells, allied to the oyster, so called from their unequal valves, of which the lower is perforated for attachment.","pos":""}],"ANOMOPHYLLOUS":[{"def":"Having leaves irregularly placed.","pos":""},{"def":"A group of decapod Crustacea, of which the hermit crab in an example.","pos":""}],"ANOMURAN":[{"def":"One of the Anomura.","pos":""}],"ANOMY":[{"def":"Disregard or violation of law.","pos":""}],"ANON":[{"def":"Straightway; at once.","pos":""},{"def":"Soon; in a little while.","pos":""}],"ANONA":[{"def":"A genus of tropical or subtropical plants of the natural order Anonaceæ, including the soursop.","pos":""}],"ANONACEOUS":[{"def":"Pertaining to the order of plants including the soursop, custard apple, etc.","pos":""}],"ANONYM":[{"def":"One who is anonymous; also sometimes used for \"pseudonym.","pos":""},{"def":"A notion which has no name, or which can not be expressed by a single English word.","pos":""}],"ANONYMITY":[{"def":"The quality or state of being anonymous; anonymousness; also, that which anonymous.","pos":""}],"ANONYMOUS":[{"def":"Nameless; of unknown name; also, of unknown /or unavowed authorship; as, an anonymous benefactor; an anonymous pamphlet or letter.","pos":""}],"ANONYMOUSLY":[{"def":"In an anonymous manner; without a name.","pos":""}],"ANONYMOUSNESS":[{"def":"The state or quality of being anonymous.","pos":""}],"ANOPHELES":[{"def":"A genus of mosquitoes which are secondary hosts of the malaria parasites, and whose bite is the usual, if not the only, means of infecting human beings with malaria.","pos":""}],"ANOPHYTE":[{"def":"A moss or mosslike plant which cellular stems, having usually an upward growth and distinct leaves.","pos":""}],"ANOPLA":[{"def":"One of the two orders of Nemerteans.","pos":""},{"def":"A genus of extinct quadrupeds of the order Ungulata, whose were first found in the gypsum quarries near Paris; characterized by the shortness and feebleness of their canine teeth (whence the name).","pos":""}],"ANOPLURA":[{"def":"A group of insects which includes the lice.","pos":""},{"def":"Want or defect of sight; blindness.","pos":""}],"ANORMAL":[{"def":"Not according to rule; abnormal.","pos":""}],"ANORN":[{"def":"The form a-ourne was corrupted into anourne.","pos":""}],"ANORTHIC":[{"def":"Having unequal oblique axes; as, anorthic crystals.","pos":""}],"ANORTHITE":[{"def":"A mineral of the feldspar family, commonly occurring in small glassy crystals, also a constituent of some igneous rocks.","pos":""}],"ANORTHOCLASE":[{"def":"A feldspar closely related to orthoclase, but triclinic.","pos":""}],"ANORTHOPIA":[{"def":"Distorted vision, in which straight lines appear bent.","pos":""}],"ANORTHOSCOPE":[{"def":"An optical toy for producing amusing figures or pictures by means of two revolving disks, on one of which distorted figures are painted.","pos":""}],"ANORTHOSITE":[{"def":"A granular igneous rock composed almost exclusively of a soda- lime feldspar, usually labradorite.","pos":""}],"ANOSMIA":[{"def":"Loss of the sense of smell.","pos":""}],"ANOTHER":[{"def":"One more, in addition to a former number; a second or additional one, similar in likeness or in effect.","pos":""},{"def":"Not the same; different.","pos":""}],"ANOTHER-GAINES":[{"def":"Of another kind.","pos":""}],"ANOTHER-GATES":[{"def":"Of another sort.","pos":""}],"ANOTHER-GUESS":[{"def":"Of another sort.","pos":""}],"ANOUROUS":[{"def":"An abnormal condition due to deficient aëration of the blood, as in balloon sickness, mountain sickness.","pos":""}]}