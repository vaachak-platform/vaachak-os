{"TEND":[{"def":"To make a tender of; to offer or tender.","pos":""}],"TENDANCE":[{"def":"The act of attending or waiting; attendance.","pos":""},{"def":"Persons in attendance; attendants.","pos":""}],"TENDENCY":[{"def":"Direction or course toward any place, object, effect, or result; drift; causal or efficient influence to bring about an effect or result.","pos":""}],"TENDER":[{"def":"A vessel employed to attend other vessels, to supply them with provisions and other stores, to convey intelligence, or the like.","pos":""}],"TENDER-HEARTED":[{"def":"Having great sensibility; susceptible of impressions or influence; affectionate; pitying; sensitive.","pos":""}],"TENDER-HEFTED":[{"def":"Having great tenderness; easily moved.","pos":""}],"TENDERFOOT":[{"def":"A delicate person; one not inured to the hardship and rudeness of pioneer life.","pos":""}],"TENDERLING":[{"def":"One of the first antlers of a deer.","pos":""}],"TENDERLOIN":[{"def":"A strip of tender flesh on either side of the vertebral column under the short ribs, in the hind quarter of beef and pork.","pos":""}],"TENDERLY":[{"def":"In a tender manner; with tenderness; mildly; gently; softly; in a manner not to injure or give pain; with pity or affection; kindly.","pos":""}],"TENDERNESS":[{"def":"The quality or state of being tender (in any sense of the adjective).","pos":""}],"TENDINOUS":[{"def":"Pertaining to a tendon; of the nature of tendon.","pos":""},{"def":"Full of tendons; sinewy; as, nervous and tendinous parts of the body.","pos":""}],"TENDMENT":[{"def":"Attendance; care.","pos":""}],"TENDON":[{"def":"A tough insensible cord, bundle, or band of fibrous connective tissue uniting a muscle with some other part; a sinew.","pos":""}],"TENDOSYNOVITIS":[{"def":"See Tenosynovitis.","pos":""}],"TENDRAC":[{"def":"Any one of several species of small insectivores of the family Centetidæ, belonging to Ericulus, Echinope, and related genera, native of Madagascar.","pos":""}],"TENDRE":[{"def":"Tender feeling or fondness; affection.","pos":""}],"TENDRESSE":[{"def":"Tender feeling; fondness.","pos":""}],"TENDRIL":[{"def":"A slender, leafless portion of a plant by which it becomes attached to a supporting body, after which the tendril usually contracts by coiling spirally.","pos":""}],"TENDRY":[{"def":"A tender; an offer.","pos":""}]}