{"AMPELITE":[{"def":"An earth abounding in pyrites, used by the ancients to kill insects, etc.","pos":""}],"AMPELOPSIS":[{"def":"A genus formerly including the Virginia creeper.","pos":""}],"AMPERAGE":[{"def":"The strength of a current of electricity carried by a conductor or generated by a machine, measured in ampères.","pos":""},{"def":"The unit of electric current; -- defined by the International Electrical Congress in 1893 and by U.","pos":""}],"AMPERE FOOT":[{"def":"A unit, employed in calculating fall of pressure in distributing mains, equivalent to a current of one ampère flowing through one foot of conductor.","pos":""},{"def":"The quantity of electricity delivered in one hour by a current whose average strength is one ampère.","pos":""}],"AMPERE TURN":[{"def":"A unit equal to the product of one complete convolution (of a coiled conductor) into one ampère of current; thus, a conductor having five convolutions and carrying a current of half an ampère is said to have 2½ ampère turns.","pos":""}],"AMPERSAND":[{"def":"A word used to describe the character Halliwell.","pos":""}],"AMPHI-":[{"def":"A prefix in words of Greek origin, signifying both, of both kinds, on both sides, about, around.","pos":""}],"AMPHIARTHRODIAL":[{"def":"Characterized by amphiarthrosis.","pos":""}],"AMPHIARTHROSIS":[{"def":"A form of articulation in which the bones are connected by intervening substance admitting slight motion; symphysis.","pos":""}],"AMPHIASTER":[{"def":"The achromatic figure, formed in mitotic cell-division, consisting of two asters connected by a spindle-shaped bundle of rodlike fibers diverging from each aster, and called the spindle.","pos":""}],"AMPHIBIA":[{"def":"One of the classes of vertebrates.","pos":""}],"AMPHIBIAL":[{"def":"Am*phib\"i*al (-al), a.","pos":""}],"AMPHIBIAN":[{"def":"Of or pertaining to the Amphibia; as, amphibian reptiles.","pos":""}],"AMPHIBIOLOGICAL":[{"def":"Pertaining to amphibiology.","pos":""}],"AMPHIBIOLOGY":[{"def":"A treatise on amphibious animals; the department of natural history which treats of the Amphibia.","pos":""}],"AMPHIBIOTICA":[{"def":"A division of insects having aquatic larvæ.","pos":""}],"AMPHIBIOUS":[{"def":"Having the ability to live both on land and in water, as frogs, crocodiles, beavers, and some plants.","pos":""},{"def":"Pertaining to, adapted for, or connected with, both land and water.","pos":""}],"AMPHIBIOUSLY":[{"def":"Like an amphibious being.","pos":""}],"AMPHIBLASTIC":[{"def":"Segmenting unequally; -- said of telolecithal ova with complete segmentation.","pos":""}],"AMPHIBOLE":[{"def":"A common mineral embracing many varieties varying in color and in composition.","pos":""}],"AMPHIBOLIC":[{"def":"Of or pertaining to amphiboly; ambiguous; equivocal.","pos":""},{"def":"Of or resembling the mineral amphibole.","pos":""}],"AMPHIBOLOGICAL":[{"def":"Of doubtful meaning; ambiguous.","pos":""}],"AMPHIBOLOGY":[{"def":"A phrase, discourse, or proposition, susceptible of two interpretations; and hence, of uncertain meaning.","pos":""}],"AMPHIBOLOUS":[{"def":"Capable of two meanings.","pos":""}],"AMPHIBOLY":[{"def":"Ambiguous discourse; amphibology.","pos":""}],"AMPHIBRACH":[{"def":"A foot of three syllables, the middle one long, the first and last short (as, h.","pos":""},{"def":"Producing fruit of two kinds, either as to form or time of ripening.","pos":""}],"AMPHICHROIC":[{"def":"Exhibiting or producing two colors, as substances which in the color test may change red litmus to blue and blue litmus to red.","pos":""},{"def":"Having both ends concave; biconcave; -- said of vertebræ.","pos":""}],"AMPHICOME":[{"def":"A kind of figured stone, rugged and beset with eminences, anciently used in divination.","pos":""}],"AMPHICTYONIC":[{"def":"Of or pertaining to the Amphictyons or their League or Council; as, an Amphictyonic town or state; the Amphictyonic body.","pos":""}],"AMPHICTYONS":[{"def":"Deputies from the confederated states of ancient Greece to a congress or council.","pos":""}],"AMPHICTYONY":[{"def":"A league of states of ancient Greece; esp.","pos":""}],"AMPHID":[{"def":"A salt of the class formed by the combination of an acid and a base, or by the union of two oxides, two sulphides, selenides, or tellurides, as distinguished from a haloid compound.","pos":""}],"AMPHIDISC":[{"def":"A peculiar small siliceous spicule having a denticulated wheel at each end; -- found in freshwater sponges.","pos":""}],"AMPHIDROMICAL":[{"def":"Pertaining to an Attic festival at the naming of a child; -- so called because the friends of the parents carried the child around the hearth and then named it.","pos":""}],"AMPHIGAMOUS":[{"def":"Having a structure entirely cellular, and no distinct sexual organs; -- a term applied by De Candolle to the lowest order of plants.","pos":""}],"AMPHIGEAN":[{"def":"Extending over all the zones, from the tropics to the polar zones inclusive.","pos":""}],"AMPHIGEN":[{"def":"An element that in combination produces amphid salt; -- applied by Berzelius to oxygen, sulphur, selenium, and tellurium.","pos":""}],"AMPHIGENESIS":[{"def":"Sexual generation; amphigony.","pos":""}],"AMPHIGENOUS":[{"def":"Increasing in size by growth on all sides, as the lichens.","pos":""}],"AMPHIGONIC":[{"def":"Pertaining to amphigony; sexual; as, amphigonic propagation.","pos":""}],"AMPHIGONOUS":[{"def":"Relating to both parents.","pos":""}],"AMPHIGONY":[{"def":"Sexual propagation.","pos":""}],"AMPHIGORIC":[{"def":"Nonsensical; absurd; pertaining to an amphigory.","pos":""}],"AMPHIGORY":[{"def":"A nonsense verse; a rigmarole, with apparent meaning, which on further attention proves to be meaningless.","pos":""},{"def":"Ambiguity of speech; equivocation.","pos":""}],"AMPHIMACER":[{"def":"A foot of three syllables, the middle one short and the others long, as in cast.","pos":""}],"AMPHINEURA":[{"def":"A division of Mollusca remarkable for the bilateral symmetry of the organs and the arrangement of the nerves.","pos":""}],"AMPHIOXUS":[{"def":"A fishlike creature (Amphioxus lanceolatus), two or three inches long, found in temperature seas; -- also called the lancelet.","pos":""}],"AMPHIPNEUST":[{"def":"One of a tribe of Amphibia, which have both lungs and gills at the same time, as the proteus and siren.","pos":""}],"AMPHIPOD":[{"def":"One of the Amphipoda.","pos":""},{"def":"Of or pertaining to the Amphipoda.","pos":""}],"AMPHIPODA":[{"def":"A numerous group of fourteen -- footed Crustacea, inhabiting both fresh and salt water.","pos":""}],"AMPHIPODOUS":[{"def":"Of or pertaining to the Amphipoda.","pos":""}],"AMPHIPROSTYLE":[{"def":"Doubly prostyle; having columns at each end, but not at the sides.","pos":""},{"def":"An amphiprostyle temple or edifice.","pos":""}],"AMPHIRHINA":[{"def":"A name applied to the elasmobranch fishes, because the nasal sac is double.","pos":""}],"AMPHISBAENA":[{"def":"A genus of harmless lizards, serpentlike in form, without legs, and with both ends so much alike that they appear to have a head at each, and ability to move either way.","pos":""}],"AMPHISBAENOID":[{"def":"Like or pertaining to the lizards of the genus Amphisbæna.","pos":""},{"def":"The inhabitants of the tropic, whose shadows in one part of the year are cast to the north, and in the other to the south, according as the sun is south or north of their zenith.","pos":""}],"AMPHISTOMOUS":[{"def":"Having a sucker at each extremity, as certain entozoa, by means of which they adhere.","pos":""}],"AMPHISTYLIC":[{"def":"Having the mandibular arch articulated with the hyoid arch and the cranium, as in the cestraciont sharks; -- said of a skull.","pos":""}],"AMPHITHEATRAL":[{"def":"Amphitheatrical; resembling an amphitheater.","pos":""},{"def":"Of, pertaining to, exhibited in, or resembling, an amphitheater.","pos":""}],"AMPHITHEATRICALLY":[{"def":"In the form or manner of an amphitheater.","pos":""}],"AMPHITROCHA":[{"def":"A kind of annelid larva having both a dorsal and a ventral circle of special cilia.","pos":""},{"def":"Having the ovule inverted, but with the attachment near the middle of one side; half anatropous.","pos":""}],"AMPHIUMA":[{"def":"A genus of amphibians, inhabiting the Southern United States, having a serpentlike form, but with four minute limbs and two persistent gill openings; the Congo snake.","pos":""}],"AMPHOPEPTONE":[{"def":"A product of gastric digestion, a mixture of hemipeptone and antipeptone.","pos":""}],"AMPHORA":[{"def":"Among the ancients, a two-handled vessel, tapering at the bottom, used for holding wine, oil, etc.","pos":""}],"AMPHORAL":[{"def":"Pertaining to, or resembling, an amphora.","pos":""}],"AMPHORIC":[{"def":"Produced by, or indicating, a cavity in the lungs, not filled, and giving a sound like that produced by blowing into an empty decanter; as, amphoric respiration or resonance.","pos":""}],"AMPHOTERIC":[{"def":"Partly one and partly the other; neither acid nor alkaline; neutral.","pos":""}],"AMPLE":[{"def":"Large; great in size, extent, capacity, or bulk; spacious; roomy; widely extended.","pos":""}],"AMPLECTANT":[{"def":"Clasping a support; as, amplectant tendrils.","pos":""}],"AMPLENESS":[{"def":"The state or quality of being ample; largeness; fullness; completeness.","pos":""}],"AMPLEXATION":[{"def":"An humble amplexation of those sacred feet.","pos":""}],"AMPLEXICAUL":[{"def":"Clasping or embracing a stem, as the base of some leaves.","pos":""}],"AMPLIATE":[{"def":"To maintain and ampliate the external possessions of your empire.","pos":""}],"AMPLIATION":[{"def":"A postponement of the decision of a cause, for further consideration or re-argument.","pos":""}],"AMPLIATIVE":[{"def":"Enlarging a conception by adding to that which is already known or received.","pos":""}],"AMPLIFICATION":[{"def":"The enlarging of a simple statement by particularity of description, the use of epithets, etc.","pos":""}],"AMPLIFICATORY":[{"def":"Serving to amplify or enlarge; amplificative.","pos":""}],"AMPLIFIER":[{"def":"One who or that which amplifies.","pos":""}],"AMPLIFY":[{"def":"To enlarge by addition or discussion; to treat copiously by adding particulars, illustrations, etc.","pos":""}],"AMPLITUDE":[{"def":"The horizontal line which measures the distance to which a projectile is thrown; the range.","pos":""},{"def":"The extent of a movement measured from the starting point or position of equilibrium; -- applied especially to vibratory movements.","pos":""}],"AMPLY":[{"def":"In an ample manner.","pos":""}],"AMPUL":[{"def":"Same as Ampulla, 2.","pos":""}],"AMPULLA":[{"def":"A narrow-necked vessel having two handles and bellying out like a jug.","pos":""},{"def":"Any membranous bag shaped like a leathern bottle, as the dilated end of a vessel or duct; especially the dilations of the semicircular canals of the ear.","pos":""}],"AMPULLACEOUS":[{"def":"Like a bottle or inflated bladder; bottle-shaped; swelling.","pos":""},{"def":"Resembling an ampulla.","pos":""}],"AMPULLIFORM":[{"def":"Flask-shaped; dilated.","pos":""}],"AMPUTATE":[{"def":"To cut off (a limb or projecting part (of the body).","pos":""}],"AMPUTATION":[{"def":"The act amputating; esp.","pos":""}],"AMPUTATOR":[{"def":"One who amputates.","pos":""}],"AMPYX":[{"def":"A woman's headband (sometimes of metal), for binding the front hair.","pos":""}]}