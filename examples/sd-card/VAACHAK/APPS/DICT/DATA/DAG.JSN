{"DAG":[{"def":"The unbrunched antler of a young deer.","pos":""}],"DAG-TAILED":[{"def":"Daggle-tailed; having the tail clogged with daglocks.","pos":""},{"def":"Pertaining to Daguerre, or to his invention of the daguerreotype.","pos":""}],"DAGGER":[{"def":"A mark of reference in the form of a dagger [|].","pos":""}],"DAGGES":[{"def":"An ornamental cutting of the edges of garments, introduced about a.","pos":""}],"DAGGLE":[{"def":"To trail, so as to wet or befoul; to make wet and limp; to moisten.","pos":""}],"DAGGLE-TAIL":[{"def":"A slovenly woman; a slattern; a draggle-tail.","pos":""}],"DAGLOCK":[{"def":"A dirty or clotted lock of wool on a sheep; a taglock.","pos":""}],"DAGO":[{"def":"A nickname given to a person of Spanish (or, by extension, Portuguese or Italian) descent.","pos":""}],"DAGOBA":[{"def":"A dome-shaped structure built over relics of Buddha or some Buddhist saint.","pos":""}],"DAGON":[{"def":"The national god of the Philistines, represented with the face and hands and upper part of a man, and the tail of a fish.","pos":""}],"DAGSWAIN":[{"def":"Acoarse woolen fabric made of daglocks, or the refuse of wool.","pos":""}],"DAGUERREOTYPE":[{"def":"An early variety of photograph, produced on a silver plate, or copper plate covered with silver, and rendered sensitive by the action of iodine, or iodine and bromine, on which, after exposure in the camera, the latent image is developed by the vapor of mercury.","pos":""},{"def":"The process of taking such pictures.","pos":""}],"DAGUERREOTYPY":[{"def":"The art or process of producing pictures by method of Daguerre.","pos":""}]}