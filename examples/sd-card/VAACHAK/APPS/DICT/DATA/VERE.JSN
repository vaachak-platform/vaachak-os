{"VERECUND":[{"def":"Rashful; modest.","pos":""}],"VERECUNDITY":[{"def":"The quality or state of being verecund; modesty.","pos":""}],"VEREIN":[{"def":"A union, association, or society; -- used in names of German organizations.","pos":""}],"VERETILLUM":[{"def":"Any one of numerous species of club-shaped, compound Alcyonaria belonging to Veretillum and allied genera, of the tribe Pennatulacea.","pos":""}]}