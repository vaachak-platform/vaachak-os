{"PRIM":[{"def":"Formal; precise; affectedly neat or nice; as, prim regularity; a prim person.","pos":""}],"PRIMA DONNA":[{"def":"The first or chief female singer in an opera.","pos":""}],"PRIMA FACIE":[{"def":"At first view; on the first appearance.","pos":""}],"PRIMACY":[{"def":"The state or condition of being prime or first, as in time, place, rank, etc.","pos":""},{"def":"The office, rank, or character of a primate; the chief ecclesiastical station or dignity in a national church; the office or dignity of an archbishop; as, the primacy of England.","pos":""}],"PRIMAGE":[{"def":"A charge in addition to the freight; originally, a gratuity to the captain for his particular care of the goods (sometimes called hat money), but now belonging to the owners or freighters of the vessel, unless by special agreement the whole or part is assigned to the captain.","pos":""}],"PRIMAL":[{"def":"First; primary; original; chief.","pos":""}],"PRIMALITY":[{"def":"The quality or state of being primal.","pos":""}],"PRIMARILY":[{"def":"In a primary manner; in the first place; in the first place; in the first intention; originally.","pos":""}],"PRIMARINESS":[{"def":"The quality or state of being primary, or first in time, in act, or in intention.","pos":""}],"PRIMARY":[{"def":"Earliest formed; fundamental.","pos":""},{"def":"Illustrating, possessing, or characterized by, some quality or property in the first degree; having undergone the first stage of substitution or replacement.","pos":""}],"PRIMATE":[{"def":"One of the Primates.","pos":""}],"PRIMATES":[{"def":"The highest order of mammals.","pos":""}],"PRIMATESHIP":[{"def":"The office, dignity, or position of a primate; primacy.","pos":""}],"PRIMATICAL":[{"def":"Of or pertaining to a primate.","pos":""}],"PRIME":[{"def":"First in order of time; original; primeval; primitive; primary.","pos":""},{"def":"First in rank, degree, dignity, authority, or importance; as, prime minister.","pos":""}],"PRIMELY":[{"def":"At first; primarily.","pos":""},{"def":"In a prime manner; excellently.","pos":""}],"PRIMENESS":[{"def":"The quality or state of being first.","pos":""},{"def":"The quality or state of being prime, or excellent.","pos":""}],"PRIMER":[{"def":"One who, or that which, primes; specifically, an instrument or device for priming; esp.","pos":""}],"PRIMERO":[{"def":"A game at cards, now unknown.","pos":""}],"PRIMEVAL":[{"def":"Belonging to the first ages; pristine; original; primitive; primary; as, the primeval innocence of man.","pos":""}],"PRIMEVALLY":[{"def":"In a primeval manner; in or from the earliest times; originally.","pos":""}],"PRIMIGENIAL":[{"def":"First born, or first of all; original; primary.","pos":""},{"def":"First formed or generated; original; primigenial.","pos":""}],"PRIMINE":[{"def":"The outermost of the two integuments of an ovule.","pos":""}],"PRIMING":[{"def":"The first coating of color, size, or the like, laid on canvas, or on a building, or other surface.","pos":""},{"def":"The carrying over of water, with the steam, from the boiler, as into the cylinder.","pos":""}],"PRIMIPARA":[{"def":"A woman who bears a child for the first time.","pos":""}],"PRIMIPAROUS":[{"def":"Belonging to a first birth; bearing young for the first time.","pos":""}],"PRIMIPILAR":[{"def":"Of or pertaining to the captain of the vanguard of a Roman army.","pos":""}],"PRIMITIA":[{"def":"The first fruit; the first year's whole profit of an ecclesiastical preferment.","pos":""}],"PRIMITIAL":[{"def":"Being of the first production; primitive; original.","pos":""}],"PRIMITIVE":[{"def":"Of or pertaining to the beginning or origin, or to early times; original; primordial; primeval; first; as, primitive innocence; the primitive church.","pos":""},{"def":"Of or pertaining to a former time; old-fashioned; characterized by simplicity; as, a primitive style of dress.","pos":""}],"PRIMITIVELY":[{"def":"Originally; at first.","pos":""},{"def":"Primarily; not derivatively.","pos":""}],"PRIMITIVENESS":[{"def":"The quality or state of being primitive; conformity to primitive style or practice.","pos":""}],"PRIMITY":[{"def":"Quality of being first; primitiveness.","pos":""}],"PRIMLY":[{"def":"In a prim or precise manner.","pos":""}],"PRIMNESS":[{"def":"The quality or state of being prim; affected formality or niceness; preciseness; stiffness.","pos":""}],"PRIMOGENIAL":[{"def":"First born, made, or generated; original; primary; elemental; as, primogenial light.","pos":""}],"PRIMOGENITIVE":[{"def":"Of or pertaining to primogeniture.","pos":""}],"PRIMOGENITOR":[{"def":"The first ancestor; a forefather.","pos":""}],"PRIMOGENITURE":[{"def":"The exclusive right of inheritance which belongs to the eldest son.","pos":""}],"PRIMOGENITURESHIP":[{"def":"The state or privileges of the firstborn.","pos":""}],"PRIMORDIAL":[{"def":"Of or pertaining to the lowest beds of the Silurian age, corresponding to the Acadian and Potsdam periods in American geology.","pos":""},{"def":"Originally or earliest formed in the growth of an individual or organ; as, a primordial leaf; a primordial cell.","pos":""}],"PRIMORDIALISM":[{"def":"Devotion to, or persistence in, conditions of the primordial state.","pos":""}],"PRIMORDIALLY":[{"def":"At the beginning; under the first order of things; originally.","pos":""}],"PRIMORDIAN":[{"def":"A name given to several kinds of plums; as, red primordian, amber primordian, etc.","pos":""}],"PRIMP":[{"def":"To be formal or affected in dress or manners; -- often with up.","pos":""}],"PRIMROSE":[{"def":"Of or pertaining to the primrose; of the color of a primrose; - - hence, flowery; gay.","pos":""}],"PRIMROSE LEAGUE":[{"def":"A league of both sexes among the Conservatives, founded in 1883.","pos":""}],"PRIMULA":[{"def":"The genus of plants including the primrose (Primula vera).","pos":""}],"PRIMULACEOUS":[{"def":"Of or pertaining to an order of herbaceous plants (Primulaceæ), of which the primrose is the type, and the pimpernel, the cyclamen, and the water violet are other examples.","pos":""}],"PRIMUM MOBILE":[{"def":"In the Ptolemaic system, the outermost of the revolving concentric spheres constituting the universe, the motion of which was supposed to carry with it all the inclosed spheres with their planets in a daily revolution from east to west.","pos":""}],"PRIMUS":[{"def":"One of the bishops of the Episcopal Church of Scotland, who presides at the meetings of the bishops, and has certain privileges but no metropolitan authority.","pos":""}],"PRIMY":[{"def":"Being in its prime.","pos":""}]}