{"ORN":[{"def":"To ornament; to adorn.","pos":""}],"ORNAMENT":[{"def":"That which embellishes or adorns; that which adds grace or beauty; embellishment; decoration; adornment.","pos":""}],"ORNAMENTAL":[{"def":"Serving to ornament; characterized by ornament; beautifying; embellishing.","pos":""}],"ORNAMENTALLY":[{"def":"By way of ornament.","pos":""}],"ORNAMENTATION":[{"def":"The act or art of ornamenting, or the state of being ornamented.","pos":""},{"def":"That which ornaments; ornament.","pos":""}],"ORNAMENTER":[{"def":"One who ornaments; a decorator.","pos":""}],"ORNATE":[{"def":"Adorned; decorated; beautiful.","pos":""},{"def":"Finely finished, as a style of composition.","pos":""}],"ORNATELY":[{"def":"In an ornate manner.","pos":""}],"ORNATENESS":[{"def":"The quality of being ornate.","pos":""}],"ORNATURE":[{"def":"Decoration; ornamentation.","pos":""}],"ORNITHIC":[{"def":"Of or pertaining to birds; as, ornithic fossils.","pos":""}],"ORNITHICHNITE":[{"def":"The footmark of a bird occurring in strata of stone.","pos":""}],"ORNITHICHNOLOGY":[{"def":"The branch of science which treats of ornithichnites.","pos":""}],"ORNITHO-":[{"def":"A combining form fr.","pos":""}],"ORNITHODELPHIA":[{"def":"Same as Monotremata.","pos":""}],"ORNITHOIDICHNITE":[{"def":"A fossil track resembling that of a bird.","pos":""}],"ORNITHOLITE":[{"def":"Of or pertaining to ornithology.","pos":""}],"ORNITHOLOGIST":[{"def":"One skilled in ornithology; a student of ornithology; one who describes birds.","pos":""}],"ORNITHOLOGY":[{"def":"That branch of zoölogy which treats of the natural history of birds and their classification.","pos":""},{"def":"A treatise or book on this science.","pos":""}],"ORNITHOMANCY":[{"def":"Divination by means of birds, their flight, etc.","pos":""}],"ORNITHON":[{"def":"An aviary; a poultry house.","pos":""}],"ORNITHOPAPPI":[{"def":"An extinct order of birds.","pos":""}],"ORNITHOPODA":[{"def":"An order of herbivorous dinosaurs with birdlike characteristics in the skeleton, esp.","pos":""}],"ORNITHORHYNCHUS":[{"def":"See Duck mole, under Duck.","pos":""}],"ORNITHOSAURIA":[{"def":"An order of extinct flying reptiles; -- called also Pterosauria.","pos":""}],"ORNITHOSCELIDA":[{"def":"A group of extinct Reptilia, intermediate in structure (especially with regard to the pelvis) between reptiles and birds.","pos":""}],"ORNITHOSCOPY":[{"def":"Observation of birds and their habits.","pos":""}],"ORNITHOTOMICAL":[{"def":"Of or pertaining to ornithotomy.","pos":""}],"ORNITHOTOMIST":[{"def":"One who is skilled in ornithotomy.","pos":""}],"ORNITHOTOMY":[{"def":"The anatomy or dissection of birds.","pos":""}]}