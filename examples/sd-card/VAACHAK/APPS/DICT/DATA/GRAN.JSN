{"GRANADILLA":[{"def":"The fruit of certain species of passion flower (esp.","pos":""}],"GRANARY":[{"def":"A storehouse or repository for grain, esp.","pos":""}],"GRANATIN":[{"def":"Mannite; -- so called because found in the pomegranate.","pos":""}],"GRAND":[{"def":"Of large size or extent; great; extensive; hence, relatively great; greatest; chief; principal; as, a grand mountain; a grand army; a grand mistake.","pos":""},{"def":"Great in size, and fine or imposing in appearance or impression; illustrious, dignifled, or noble (said of persons); majestic, splendid, magnificent, or sublime (said of things); as, a grand monarch; a grand lord; a grand general; a grand view; a grand conception.","pos":""}],"GRAND-DUCAL":[{"def":"Of or pertaining to a grand duke.","pos":""}],"GRANDAM":[{"def":"An old woman; specifically, a grandmother.","pos":""}],"GRANDAUNT":[{"def":"The aunt of one's father or mother.","pos":""}],"GRANDCHILD":[{"def":"A son's or daughter's child; a child in the second degree of descent.","pos":""}],"GRANDDAUGHTER":[{"def":"The daughter of one's son or daughter.","pos":""}],"GRANDEE":[{"def":"A man of elevated rank or station; a nobleman.","pos":""}],"GRANDEESHIP":[{"def":"The rank or estate of a grandee; lordship.","pos":""}],"GRANDEUR":[{"def":"The state or quality of being grand; vastness; greatness; splendor; magnificence; stateliness; sublimity; dignity; elevation of thought or expression; nobility of action.","pos":""}],"GRANDEVITY":[{"def":"Great age; long life.","pos":""}],"GRANDEVOUS":[{"def":"Of great age; aged; longlived.","pos":""}],"GRANDFATHER":[{"def":"A father's or mother's father; an ancestor in the next degree above the father or mother in lineal ascent.","pos":""}],"GRANDFATHERLY":[{"def":"Like a grandfather in age or manner; kind; benignant; indulgent.","pos":""}],"GRANDILOQUENCE":[{"def":"The use of lofty words or phrases; bombast; -- usually in a bad sense.","pos":""}],"GRANDILOQUENT":[{"def":"Speaking in a lofty style; pompous; bombastic.","pos":""}],"GRANDINOUS":[{"def":"Consisting of hail; abounding in hail.","pos":""}],"GRANDIOSE":[{"def":"Impressive or elevating in effect; vimposing; splendid; striking; -- in a good sense.","pos":""},{"def":"Characterized by affectation of grandeur or splendor; flaunting; turgid; bombastic; -- in a bad sense; as, a grandiose style.","pos":""}],"GRANDLY":[{"def":"In a grand manner.","pos":""}],"GRANDMOTHER":[{"def":"The mother of one's father or mother.","pos":""}],"GRANDMOTHERLY":[{"def":"Like a grandmother in age or manner; kind; indulgent.","pos":""}],"GRANDNEPHEW":[{"def":"The grandson of one's brother or sister.","pos":""}],"GRANDNIECE":[{"def":"The granddaughter of one's brother or sister.","pos":""}],"GRANDSIRE":[{"def":"Specifically, a grandfather; more generally, any ancestor.","pos":""}],"GRANDSON":[{"def":"A son's or daughter's son.","pos":""}],"GRANDUNCLE":[{"def":"father's or mother's uncle.","pos":""}],"GRANGE":[{"def":"A building for storing grain; a granary.","pos":""},{"def":"A farmhouse, with the barns and other buildings for farming purposes.","pos":""}],"GRANGER":[{"def":"A member of a grange.","pos":""}],"GRANGERISM":[{"def":"The practice of illustrating a particular book by engravings collected from other books.","pos":""}],"GRANGERITE":[{"def":"One who collects illustrations from various books for the decoration of one book.","pos":""}],"GRANGERIZE":[{"def":"To collect (illustrations from books) for decoration of other books.","pos":""},{"def":"Certain railroads whose traffic largely consists in carrying the produce of farmers or grangers; -- specifically applied to the Chicago & Alton; Chicago, Burlington & Quincey; Chicago, Rock Island & Pacific; Chicago, Milwaukee & St.","pos":""}],"GRANIFEROUS":[{"def":"Bearing grain, or seeds like grain.","pos":""}],"GRANIFORM":[{"def":"Formed like of corn.","pos":""}],"GRANILLA":[{"def":"Small grains or dust of cochineal or the coccus insect.","pos":""}],"GRANITE":[{"def":"A crystalline, granular rock, consisting of quartz, feldspar, and mica, and usually of a whitish, grayish, or flesh-red color.","pos":""}],"GRANITE STATE":[{"def":"New Hampshire; -- a nickname alluding to its mountains, which are chiefly of granite.","pos":""}],"GRANITIC":[{"def":"Like granite in composition, color, etc.","pos":""},{"def":"Consisting of granite; as, granitic mountains.","pos":""}],"GRANITIFICATION":[{"def":"The act or the process of forming into granite.","pos":""}],"GRANITIFORM":[{"def":"Resembling granite in structure or shape.","pos":""}],"GRANITOID":[{"def":"Resembling granite in granular appearance; as, granitoid gneiss; a granitoid pavement.","pos":""}],"GRANIVOROUS":[{"def":"Eating grain; feeding or subsisting on seeds; as, granivorous birds.","pos":""}],"GRANNY":[{"def":"A grandmother; a grandam; familiarly, an old woman.","pos":""}],"GRANOLITHIC":[{"def":"A kind of hard artificial stone, used for pavements.","pos":""}],"GRANT":[{"def":"To give over; to make conveyance of; to give the possession or title of; to convey; -- usually in answer to petition.","pos":""},{"def":"To bestow or confer, with or without compensation, particularly in answer to prayer or request; to give.","pos":""}],"GRANTABLE":[{"def":"Capable of being granted.","pos":""}],"GRANTEE":[{"def":"The person to whom a grant or conveyance is made.","pos":""}],"GRANTOR":[{"def":"The person by whom a grant or conveyance is made.","pos":""}],"GRANULAR":[{"def":"Consisting of, or resembling, grains; as, a granular substance.","pos":""}],"GRANULARLY":[{"def":"In a granular form.","pos":""}],"GRANULATE":[{"def":"To form into grains or small masses; as, to granulate powder, sugar, or metal.","pos":""},{"def":"To raise in granules or small asperities; to make rough on the surface.","pos":""}],"GRANULATION":[{"def":"The act or process of forming or crystallizing into grains; as, the granulation of powder and sugar.","pos":""},{"def":"The state of being granulated.","pos":""}],"GRANULE":[{"def":"A little grain a small particle; a pellet.","pos":""}],"GRANULIFEROUS":[{"def":"Full of granulations.","pos":""}],"GRANULIFORM":[{"def":"Having a granular structure; granular; as, granuliform limestone.","pos":""}],"GRANULITE":[{"def":"A whitish, granular rock, consisting of feldspar and quartz intimately mixed; -- sometimes called whitestone, and leptynite.","pos":""}],"GRANULOSE":[{"def":"The main constituent of the starch grain or granule, in distinction from the framework of cellulose.","pos":""}],"GRANULOUS":[{"def":"Full of grains; abounding with granular substances; granular.","pos":""}]}