{"HECATOMB":[{"def":"A sacrifice of a hundred oxen or cattle at the same time; hence, the sacrifice or slaughter of any large number of victims.","pos":""}],"HECATOMPEDON":[{"def":"A name given to the old Parthenon at Athens, because measuring 100 Greek feet, probably in the width across the stylobate.","pos":""}],"HECDECANE":[{"def":"A white, semisolid, spermaceti-like hydrocarbon, C16H34, of the paraffin series, found dissolved as an important ingredient of kerosene, and so called because each molecule has sixteen atoms of carbon; -- called also hexadecane.","pos":""}],"HECK":[{"def":"An apparatus for separating the threads of warps into sets, as they are wound upon the reel from the bobbins, in a warping machine.","pos":""}],"HECKERISM":[{"def":"Catholicism as promoting human aspirations after liberty and truth, and as the religion best suited to the character and institutions of the American people.","pos":""}],"HECKIMAL":[{"def":"The European blue titmouse (Parus coeruleus).","pos":""}],"HECTARE":[{"def":"A measure of area, or superficies, containing a hundred ares, or 10,000 square meters, and equivalent to 2.","pos":""}],"HECTIC":[{"def":"Habitual; constitutional; pertaining especially to slow waste of animal tissue, as in consumption; as, a hectic type in disease; a hectic flush.","pos":""},{"def":"In a hectic condition; having hectic fever; consumptive; as, a hectic patient.","pos":""}],"HECTOCOTYLIZED":[{"def":"Changed into a hectocotylus; having a hectocotylis.","pos":""}],"HECTOCOTYLUS":[{"def":"One of the arms of the male of most kinds of cephalopods, which is specially modified in various ways to effect the fertilization of the eggs.","pos":""}],"HECTOGRAM":[{"def":"A measure of weight, containing a hundred grams, or about 3.","pos":""}],"HECTOGRAMME":[{"def":"The same as Hectogram.","pos":""}],"HECTOGRAPH":[{"def":"A contrivance for multiple copying, by means of a surface of gelatin softened with glycerin.","pos":""},{"def":"A measure of liquids, containing a hundred liters; equal to a tenth of a cubic meter, nearly 26 HECTOMETER; HECTOMETRE Hec\"to*me`ter, Hec\"to*me`tre, n.","pos":""}],"HECTOR":[{"def":"A bully; a blustering, turbulent, insolent, fellow; one who vexes or provokes.","pos":""}],"HECTORISM":[{"def":"The disposition or the practice of a hector; a bullying.","pos":""}],"HECTORLY":[{"def":"Resembling a hector; blustering; insolent; taunting.","pos":""}],"HECTOSTERE":[{"def":"A measure of solidity, containing one hundred cubic meters, and equivalent to 3531.","pos":""}]}