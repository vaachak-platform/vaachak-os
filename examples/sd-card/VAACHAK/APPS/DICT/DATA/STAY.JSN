{"STAY":[{"def":"A large, strong rope, employed to support a mast, by being extended from the head of one mast down to some other, or to some part of the vessel.","pos":""}],"STAYED":[{"def":"Staid; fixed; settled; sober; -- now written staid.","pos":""}],"STAYEDNESS":[{"def":"Solidity; weight.","pos":""}],"STAYER":[{"def":"One who upholds or supports that which props; one who, or that which, stays, stops, or restrains; also, colloquially, a horse, man, etc.","pos":""}],"STAYLACE":[{"def":"A lace for fastening stays.","pos":""}],"STAYLESS":[{"def":"Without stop or delay.","pos":""}],"STAYMAKER":[{"def":"One whose occupation is to make stays.","pos":""}],"STAYNIL":[{"def":"The European starling.","pos":""}],"STAYSAIL":[{"def":"Any sail extended on a stay.","pos":""}],"STAYSHIP":[{"def":"A remora, -- fabled to stop ships by attaching itself to them.","pos":""}]}