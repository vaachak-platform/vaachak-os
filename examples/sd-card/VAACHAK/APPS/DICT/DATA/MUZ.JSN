{"MUZARAB":[{"def":"One of a denomination of Christians formerly living under the government of the Moors in Spain, and having a liturgy and ritual of their own.","pos":""}],"MUZARABIC":[{"def":"Of or pertaining to Muzarabs; as, the Muzarabic liturgy.","pos":""}],"MUZZINESS":[{"def":"The state or quality of being muzzy.","pos":""}],"MUZZLE":[{"def":"The projecting mouth and nose of a quadruped, as of a horse; a snout.","pos":""},{"def":"The mouth of a thing; the end for entrance or discharge; as, the muzzle of a gun.","pos":""}],"MUZZLE-LOADER":[{"def":"A firearm which receives its charge through the muzzle, as distinguished from one which is loaded at the breech.","pos":""}],"MUZZLE-LOADING":[{"def":"Receiving its charge through the muzzle; as, a muzzle-loading rifle.","pos":""}],"MUZZY":[{"def":"Absent-minded; dazed; muddled; stupid.","pos":""}]}