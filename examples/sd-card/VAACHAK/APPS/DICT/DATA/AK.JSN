{"AKIMBO":[{"def":"With a crook or bend; with the hand on the hip and elbow turned outward.","pos":""}],"AKIN":[{"def":"Of the same kin; related by blood; -- used of persons; as, the two families are near akin.","pos":""},{"def":"Allied by nature; partaking of the same properties; of the same kind.","pos":""}],"AKINESIA":[{"def":"Paralysis of the motor nerves; loss of movement.","pos":""}],"AKINESIC":[{"def":"Pertaining to akinesia.","pos":""}],"AKNOW":[{"def":"Earlier form of Acknow.","pos":""}]}