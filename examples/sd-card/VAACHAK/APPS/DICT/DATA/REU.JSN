{"REUNION":[{"def":"A second union; union formed anew after separation, secession, or discord; as, a reunion of parts or particles of matter; a reunion of parties or sects.","pos":""},{"def":"An assembling of persons who have been separated, as of a family, or the members of a disbanded regiment; an assembly so composed.","pos":""}],"REUNITE":[{"def":"To unite again; to join after separation or variance.","pos":""}],"REUNITEDLY":[{"def":"In a reunited manner.","pos":""}],"REUNITION":[{"def":"A second uniting.","pos":""}]}