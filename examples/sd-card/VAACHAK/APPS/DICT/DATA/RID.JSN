{"RID":[{"def":"He rid to the end of the village, where he alighted.","pos":""}],"RIDABLE":[{"def":"Suitable for riding; as, a ridable horse; a ridable road.","pos":""}],"RIDDANCE":[{"def":"The act of ridding or freeing; deliverance; a cleaning up or out.","pos":""},{"def":"The state of being rid or free; freedom; escape.","pos":""}],"RIDDER":[{"def":"One who, or that which, rids.","pos":""}],"RIDDLE":[{"def":"A sieve with coarse meshes, usually of wire, for separating coarser materials from finer, as chaff from grain, cinders from ashes, or gravel from sand.","pos":""},{"def":"A board having a row of pins, set zigzag, between which wire is drawn to straighten it.","pos":""}],"RIDDLER":[{"def":"One who riddles (grain, sand, etc.","pos":""}],"RIDDLING":[{"def":"Speaking in a riddle or riddles; containing a riddle.","pos":""}],"RIDE":[{"def":"To be carried on the back of an animal, as a horse.","pos":""},{"def":"To be borne in a carriage; as, to ride in a coach, in a car, and the like.","pos":""}],"RIDEAU":[{"def":"A small mound of earth; ground slightly elevated; a small ridge.","pos":""}],"RIDER":[{"def":"A problem of more than usual difficulty added to another on an examination paper.","pos":""},{"def":"A Dutch gold coin having the figure of a man on horseback stamped upon it.","pos":""}],"RIDERLESS":[{"def":"Having no rider; as, a riderless horse.","pos":""}],"RIDGE":[{"def":"The intersection of two surface forming a salient angle, especially the angle at the top between the opposite slopes or sides of a roof or a vault.","pos":""},{"def":"The highest portion of the glacis proceeding from the salient angle of the covered way.","pos":""}],"RIDGEBAND":[{"def":"The part of a harness which passes over the saddle, and supports the shafts of a cart; -- called also ridgerope, and ridger.","pos":""}],"RIDGEL":[{"def":"Same as Ridgelling.","pos":""}],"RIDGELING":[{"def":"A half-castrated male animal.","pos":""}],"RIDGEPOLE":[{"def":"The timber forming the ridge of a roof, into which the rafters are secured.","pos":""}],"RIDGEROPE":[{"def":"See Life line (a), under Life.","pos":""}],"RIDGINGLY":[{"def":"So as to form ridges.","pos":""}],"RIDGY":[{"def":"Having a ridge or ridges; rising in a ridge.","pos":""}],"RIDICULE":[{"def":"An object of sport or laughter; a laughingstock; a laughing matter.","pos":""},{"def":"Remarks concerning a subject or a person designed to excite laughter with a degree of contempt; wit of that species which provokes contemptuous laughter; disparagement by making a person an object of laughter; banter; -- a term lighter than derision.","pos":""}],"RIDICULER":[{"def":"One who ridicules.","pos":""}],"RIDICULIZE":[{"def":"To make ridiculous; to ridicule.","pos":""}],"RIDICULOSITY":[{"def":"The quality or state of being ridiculous; ridiculousness; also, something ridiculous.","pos":""}],"RIDICULOUS":[{"def":"Fitted to excite ridicule; absurd and laughable; unworthy of serious consideration; as, a ridiculous dress or behavior.","pos":""},{"def":"Involving or expressing ridicule.","pos":""}],"RIDING":[{"def":"One of the three jurisdictions into which the county of York, in England, is divided; -- formerly under the government of reeve.","pos":""}],"RIDOTTO":[{"def":"A favorite Italian public entertainment, consisting of music and dancing, -- held generally on fast eves.","pos":""}]}