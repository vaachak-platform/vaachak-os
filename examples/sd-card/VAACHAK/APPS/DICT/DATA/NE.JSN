{"NE":[{"def":"He never yet no villany ne said.","pos":""}],"NE EXEAT":[{"def":"A writ to restrain a person from leaving the country, or the jurisdiction of the court.","pos":""}],"NE PLUS ULTRA":[{"def":"The uttermost point to which one can go or attain; hence, the summit of achievement; the highest point or degree; the acme.","pos":""},{"def":"A prohibition against proceeding further; an insuperable obstacle or limiting condition.","pos":""}],"NE TEMERE":[{"def":"Roman Catholic, if not contracted before a duty qualified priest (or the bishop of the diocese) and at least two witnesses.","pos":""}],"NE'ER":[{"def":"a contraction of Never.","pos":""}],"NE'ER-DO-WELL":[{"def":"A person who never does, or fares, well; a good for nothing.","pos":""}]}