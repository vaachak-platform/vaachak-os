{"BULAU":[{"def":"An East Indian insectivorous mammal (Gymnura Rafflesii), somewhat like a rat in appearance, but allied to the hedgehog.","pos":""}],"BULB":[{"def":"A spheroidal body growing from a plant either above or below the ground (usually below), which is strictly a bud, consisting of a cluster of partially developed leaves, and producing, as it grows, a stem above, and roots below, as in the onion, tulip, etc.","pos":""},{"def":"A name given to some parts that resemble in shape certain bulbous roots; as, the bulb of the aorta.","pos":""}],"BULBAR":[{"def":"Of or pertaining to bulb; especially, in medicine, pertaining to the bulb of the spinal cord, or medulla oblongata; as, bulbar paralysis.","pos":""}],"BULBED":[{"def":"Having a bulb; round-headed.","pos":""}],"BULBEL":[{"def":"A separable bulb formed on some flowering plants.","pos":""}],"BULBIFEROUS":[{"def":"Producing bulbs.","pos":""}],"BULBIL":[{"def":"A small or secondary bulb; hence, now almost exclusively: An aërial bulb or deciduous bud, produced in the leaf axils, as in the tiger lily, or relpacing the flowers, as in some onions, and capable, when separated, of propagating the plant; -- called also bulblet and brood bud.","pos":""}],"BULBLET":[{"def":"A small bulb, either produced on a larger bulb, or on some aërial part of a plant, as in the axils of leaves in the tiger lily, or replacing the flowers in some kinds of onion.","pos":""}],"BULBOUS":[{"def":"Having or containing bulbs, or a bulb; growing from bulbs; bulblike in shape or structure.","pos":""}],"BULBUL":[{"def":"The Persian nightingale (Pycnonotus jocosus).","pos":""}],"BULBULE":[{"def":"A small bulb; a bulblet.","pos":""}],"BULGE":[{"def":"The bilge of a vessel.","pos":""}],"BULGER":[{"def":"A driver or a brassy with a convex face.","pos":""}],"BULGY":[{"def":"Bulged; bulging; bending, or tending to bend, outward.","pos":""},{"def":"A disease in which there is a perpetual and insatiable appetite for food; a diseased and voracious appetite.","pos":""}],"BULIMUS":[{"def":"A genus of land snails having an elongated spiral shell, often of large size.","pos":""}],"BULK":[{"def":"The cargo of a vessel when stowed.","pos":""}],"BULKER":[{"def":"A person employed to ascertain the bulk or size of goods, in order to fix the amount of freight or dues payable on them.","pos":""}],"BULKHEAD":[{"def":"A partition in a vessel, to separate apartments on the same deck.","pos":""}],"BULKINESS":[{"def":"Greatness in bulk; size.","pos":""}],"BULKY":[{"def":"Of great bulk or dimensions; of great size; large; thick; massive; as, bulky volumes.","pos":""}],"BULL":[{"def":"The male of any species of cattle (Bovidæ); hence, the male of any large quadruped, as the elephant; also, the male of the whale.","pos":""},{"def":"One who operates in expectation of a rise in the price of stocks, or in order to effect such a rise.","pos":""}],"BULL BRIER":[{"def":"A species of Smilax (S.","pos":""}],"BULL MOOSE":[{"def":"Roosevelt on a certain occasion that he felt \"like a bull moose.","pos":""}],"BULL TERRIER":[{"def":"A breed of dogs obtained by crossing the bulldog and the terrier.","pos":""}],"BULL TROUT":[{"def":"Varden trout and red-spotted trout.","pos":""}],"BULL'S-EYE":[{"def":"A small circular or oval wooden block without sheaves, having a groove around it and a hole through it, used for connecting rigging.","pos":""},{"def":"Aldebaran, a bright star in the eye of Taurus or the Bull.","pos":""}],"BULL'S-NOSE":[{"def":"An external angle when obtuse or rounded.","pos":""}],"BULL-NECKED":[{"def":"Having a short and thick neck like that of a bull.","pos":""}],"BULL-ROARER":[{"def":"A contrivance consisting of a slat of wood tied to the end of a thong or string, with which the slat is whirled so as to cause an intermittent roaring noise.","pos":""}],"BULLA":[{"def":"A bleb; a vesicle, or an elevation of the cuticle, containing a transparent watery fluid.","pos":""},{"def":"The ovoid prominence below the opening of the ear in the skulls of many animals; as, the tympanic or auditory bulla.","pos":""}],"BULLANTIC":[{"def":"Pertaining to, or used in, papal bulls.","pos":""}],"BULLARY":[{"def":"A collection of papal bulls.","pos":""}],"BULLATE":[{"def":"Appearing as if blistered; inflated; puckered.","pos":""}],"BULLBEGGAR":[{"def":"Something used or suggested to produce terror, as in children or persons of weak mind; a bugbear.","pos":""}],"BULLCOMBER":[{"def":"A scaraboid beetle; esp.","pos":""}],"BULLDOG":[{"def":"A variety of dog, of remarkable ferocity, courage, and tenacity of grip; -- so named, probably, from being formerly employed in baiting bulls.","pos":""},{"def":"A refractory material used as a furnace lining, obtained by calcining the cinder or slag from the puddling furnace of a rolling mill.","pos":""}],"BULLDOZE":[{"def":"To intimidate; to restrain or coerce by intimidation or violence; -- used originally of the intimidation of negro voters, in Louisiana.","pos":""}],"BULLDOZER":[{"def":"One who bulldozes.","pos":""}],"BULLEN-NAIL":[{"def":"A nail with a round head and short shank, tinned and lacquered.","pos":""}],"BULLET":[{"def":"A missile, usually of lead, and round or elongated in form, to be discharged from a rifle, musket, pistol, or other small firearm.","pos":""}],"BULLET-PROOF":[{"def":"Capable of resisting the force of a bullet.","pos":""}],"BULLETIN":[{"def":"A brief statement of facts respecting some passing event, as military operations or the health of some distinguished personage, issued by authority for the information of the public.","pos":""},{"def":"Any public notice or announcement, especially of news recently received.","pos":""}],"BULLFACED":[{"def":"Having a large face.","pos":""}],"BULLFEAST":[{"def":"A barbarous sport, of great antiquity, in which men torment, and fight with, a bull or bulls in an arena, for public amusement, -- still popular in Spain.","pos":""}],"BULLFINCH":[{"def":"A bird of the genus Pyrrhula and other related genera, especially the P.","pos":""},{"def":"A kind of fungus.","pos":""}],"BULLFROG":[{"def":"A very large species of frog (Rana Catesbiana), found in North America; -- so named from its loud bellowing in spring.","pos":""}],"BULLHEAD":[{"def":"A small black water insect.","pos":""}],"BULLHEADED":[{"def":"Having a head like that of a bull.","pos":""}],"BULLION":[{"def":"Uncoined gold or silver in the mass.","pos":""},{"def":"Base or uncurrent coin.","pos":""}],"BULLIONIST":[{"def":"An advocate for a metallic currency, or a paper currency always convertible into gold.","pos":""}],"BULLIRAG":[{"def":"To intimidate by bullying; to rally contemptuously; to badger.","pos":""}],"BULLISH":[{"def":"Partaking of the nature of a bull, or a blunder.","pos":""}],"BULLIST":[{"def":"A writer or drawer up of papal bulls.","pos":""}],"BULLITION":[{"def":"The action of boiling; boiling.","pos":""}],"BULLOCK":[{"def":"A young bull, or any male of the ox kind.","pos":""},{"def":"An ox, steer, or stag.","pos":""}],"BULLOCK'S-EYE":[{"def":"See Bull's-eye, 3.","pos":""}],"BULLON":[{"def":"A West Indian fish (Scarus Croicensis).","pos":""}],"BULLPOUT":[{"def":"See Bullhead, 1 (b).","pos":""}],"BULLWORT":[{"def":"See Bishop's-weed.","pos":""}],"BULLY":[{"def":"A noisy, blustering fellow, more insolent than courageous; one who is threatening and quarrelsome; an insolent, tyrannical fellow.","pos":""},{"def":"A brisk, dashing fellow.","pos":""}],"BULLY TREE":[{"def":"The name of several West Indian trees of the order Sapotaceæ, as Dipholis nigra and species of Sapota and Mimusops.","pos":""}],"BULLYRAG":[{"def":"Same as Bullirag.","pos":""}],"BULRUSH":[{"def":"A kind of large rush, growing in wet land or in water.","pos":""}],"BULSE":[{"def":"A purse or bag in which to carry or measure diamonds, etc.","pos":""}],"BULTEL":[{"def":"A bolter or bolting cloth; also, bran.","pos":""}],"BULWARK":[{"def":"A rampart; a fortification; a bastion or outwork.","pos":""},{"def":"The sides of a ship above the upper deck.","pos":""}]}