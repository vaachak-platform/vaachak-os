{"OVERVALUATION":[{"def":"Excessive valuation; overestimate.","pos":""}],"OVERVALUE":[{"def":"To value excessively; to rate at too high a price.","pos":""},{"def":"To exceed in value.","pos":""}],"OVERVEIL":[{"def":"To veil or cover.","pos":""}],"OVERVIEW":[{"def":"An inspection or overlooking.","pos":""}],"OVERVOTE":[{"def":"To outvote; to outnumber in votes given.","pos":""}]}