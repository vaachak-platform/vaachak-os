{"LILAC":[{"def":"A shrub of the genus Syringa.","pos":""}],"LILIAL":[{"def":"Having a general resemblance to lilies or to liliaceous plants.","pos":""}],"LILIED":[{"def":"Covered with, or having many, lilies.","pos":""}],"LILLIPUTIAN":[{"def":"A person or thing of very small size.","pos":""}],"LILLY-PILLY":[{"def":"An Australian myrtaceous tree (Eugenia Smithii), having smooth ovate leaves, and panicles of small white flowers.","pos":""}],"LILT":[{"def":"To do anything with animation and quickness, as to skip, fly, or hop.","pos":""},{"def":"To sing cheerfully.","pos":""}],"LILY":[{"def":"A plant and flower of the genus Lilium, endogenous bulbous plants, having a regular perianth of six colored pieces, six stamens, and a superior three-celled ovary.","pos":""},{"def":"A name given to handsome flowering plants of several genera, having some resemblance in color or form to a true lily, as Pancratium, Crinum, Amaryllis, Nerine, etc.","pos":""}],"LILY-HANDED":[{"def":"Having white, delicate hands.","pos":""}],"LILY-LIVERED":[{"def":"White-livered; cowardly.","pos":""}],"LILYWORT":[{"def":"Any plant of the Lily family or order.","pos":""}]}