{"EPIDEICTIC":[{"def":"Serving to show forth, explain, or exhibit; -- applied by the Greeks to a kind of oratory, which, by full amplification, seeks to persuade.","pos":""},{"def":"Common to, or affecting at the same time, a large number in a community; -- applied to a disease which, spreading widely, attacks many persons at the same time; as, an epidemic disease; an epidemic catarrh, fever, etc.","pos":""}],"EPIDEMIC":[{"def":"An epidemic disease.","pos":""}],"EPIDEMICALLY":[{"def":"In an epidemic manner.","pos":""}],"EPIDEMIOGRAPHY":[{"def":"A treatise upon, or history of, epidemic diseases.","pos":""}],"EPIDEMIOLOGICAL":[{"def":"Connected with, or pertaining to, epidemiology.","pos":""}],"EPIDEMIOLOGIST":[{"def":"A person skilled in epidemiology.","pos":""}],"EPIDEMIOLOGY":[{"def":"That branch of science which treats of epidemics.","pos":""}],"EPIDEMY":[{"def":"An epidemic disease.","pos":""}],"EPIDERMAL":[{"def":"Of or pertaining to the epidermis; epidermic; cuticular.","pos":""}],"EPIDERMIC":[{"def":"Epidermal; connected with the skin or the bark.","pos":""}],"EPIDERMIS":[{"def":"The outer, nonsensitive layer of the skin; cuticle; scarfskin.","pos":""},{"def":"The outermost layer of the cells, which covers both surfaces of leaves, and also the surface of stems, when they are first formed.","pos":""}],"EPIDERMOID":[{"def":"Like epidermis; pertaining to the epidermis.","pos":""}],"EPIDERMOSE":[{"def":"Serving to explain; demonstrative.","pos":""}],"EPIDIDYMIS":[{"def":"An oblong vermiform mass on the dorsal side of the testicle, composed of numerous convolutions of the excretory duct of that organ.","pos":""}],"EPIDIDYMITIS":[{"def":"Inflammation of the epididymis, one of the common results of gonorrhea.","pos":""}],"EPIDOTE":[{"def":"A mineral, commonly of a yellowish green (pistachio) color, occurring granular, massive, columnar, and in monoclinic crystals.","pos":""}],"EPIDOTIC":[{"def":"Related to, resembling, or containing epidote; as, an epidotic granite.","pos":""}]}