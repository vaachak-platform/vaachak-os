{"URE":[{"def":"Use; practice; exercise.","pos":""}],"UREA":[{"def":"A very soluble crystalline body which is the chief constituent of the urine in mammals and some other animals.","pos":""}],"UREAL":[{"def":"Of or pertaining to urea; containing, or consisting of, urea; as, ureal deposits.","pos":""}],"UREAMETER":[{"def":"An apparatus for the determination of the amount of urea in urine, in which the nitrogen evolved by the action of certain reagents, on a given volume of urine, is collected and measured, and the urea calculated accordingly.","pos":""}],"URECHITIN":[{"def":"A glucoside extracted from the leaves of a certain plant (Urechitis suberecta) as a bitter white crystalline substance.","pos":""}],"URECHITOXIN":[{"def":"A poisonous glucoside found accompanying urechitin, and extracted as a bitter white crystalline substance.","pos":""}],"UREDO":[{"def":"One of the stages in the life history of certain rusts (Uredinales), regarded at one time as a distinct genus.","pos":""}],"UREDOSPORE":[{"def":"The thin-walled summer spore which is produced during the so- called Uredo stage of certain rusts.","pos":""}],"UREIDE":[{"def":"Any one of the many complex derivatives of urea; thus, hydantoin, and, in an extended dense, guanidine, caffeine, et.","pos":""},{"def":"A suffix with the same meaning as -ide.","pos":""}],"URETER":[{"def":"The duct which conveys the urine from the kidney to the bladder or cloaca.","pos":""}],"URETERITIS":[{"def":"Inflammation of the ureter.","pos":""}],"URETHANE":[{"def":"A white crystalline substance, NH2.","pos":""}],"URETHRA":[{"def":"The canal by which the urine is conducted from the bladder and discharged.","pos":""}],"URETHRAL":[{"def":"Of or pertaining to the urethra.","pos":""}],"URETHRITIS":[{"def":"Inflammation of the urethra.","pos":""}],"URETHROPLASTY":[{"def":"An operation for the repair of an injury or a defect in the walls of the urethra.","pos":""}],"URETHROSCOPE":[{"def":"An instrument for viewing the interior of the urethra.","pos":""}],"URETHROSCOPY":[{"def":"Examination of the urethra by means of the urethroscope.","pos":""}],"URETHROTOME":[{"def":"An instrument for cutting a urethral stricture.","pos":""}],"URETHROTOMY":[{"def":"An incision of the urethra, esp.","pos":""}],"URETIC":[{"def":"Of or pertaining to the urine; diuretic; urinary; as, uretic medicine.","pos":""}]}