{"SEA":[{"def":"A great brazen laver in the temple at Jerusalem; -- so called from its size.","pos":""}],"SEA ACORN":[{"def":"An acorn barnacle (Balanus).","pos":""}],"SEA ANCHOR":[{"def":"See Drag sail, under 4th Drag.","pos":""}],"SEA ANEMONE":[{"def":"Any one of numerous species of soft-bodied Anthozoa, belonging to the order Actrinaria; an actinian.","pos":""}],"SEA APPLE":[{"def":"The fruit of a West Indian palm (Manicaria Plukenetii), often found floating in the sea.","pos":""}],"SEA ARROW":[{"def":"A squid of the genus Ommastrephes.","pos":""}],"SEA BANK":[{"def":"A bank or mole to defend against the sea.","pos":""}],"SEA BASS":[{"def":"Centropristis, atrarius) which abounds on the Atlantic coast of the United States.","pos":""}],"SEA BAT":[{"def":"See Batfish (a).","pos":""}],"SEA BEAN":[{"def":"Same as Florida bean.","pos":""}],"SEA BEAST":[{"def":"Any large marine mammal, as a seal, walrus, or cetacean.","pos":""}],"SEA BIRD":[{"def":"Any swimming bird frequenting the sea; a sea fowl.","pos":""}],"SEA BLITE":[{"def":"A plant (Suæda maritima) of the Goosefoot family, growing in salt marches.","pos":""}],"SEA BOW":[{"def":"See Marine rainbow, under Rainbow.","pos":""}],"SEA BOY":[{"def":"A boy employed on shipboard.","pos":""}],"SEA BREACH":[{"def":"A breaking or overflow of a bank or a dike by the sea.","pos":""}],"SEA BREAM":[{"def":"Any one of several species of sparoid fishes, especially the common European species (Pagellus centrodontus), the Spanish (P.","pos":""}],"SEA BRIEF":[{"def":"Same as Sea letter.","pos":""}],"SEA CABBAGE":[{"def":"See Sea kale, under Kale.","pos":""}],"SEA CALF":[{"def":"The common seal.","pos":""}],"SEA CANARY":[{"def":"The beluga, or white whale.","pos":""}],"SEA CAPTAIN":[{"def":"The captain of a vessel that sails upon the sea.","pos":""}],"SEA CARD":[{"def":"Mariner's card, or compass.","pos":""}],"SEA CHART":[{"def":"A chart or map on which the lines of the shore, islands, shoals, harbors, etc.","pos":""}],"SEA CHICKWEED":[{"def":"A fleshy plant (Arenaria peploides) growing in large tufts in the sands of the northern Atlantic seacoast; -- called also sea sandwort, and sea purslane.","pos":""}],"SEA CLAM":[{"def":"Any one of the large bivalve mollusks found on the open seacoast, especially those of the family Mactridæ, as the common American species.","pos":""}],"SEA COAL":[{"def":"Coal brought by sea; -- a name by which mineral coal was formerly designated in the south of England, in distinction from charcoal, which was brought by land.","pos":""}],"SEA COB":[{"def":"The black-backed gull.","pos":""}],"SEA COCK":[{"def":"In a steamship, a cock or valve close to the vessel's side, for closing a pipe which communicates with the sea.","pos":""}],"SEA COCOA":[{"def":"A magnificent palm (Lodoicea Sechellarum) found only in the Seychelles Islands.","pos":""}],"SEA COLANDER":[{"def":"A large blackfish seaweed (Agarum Turneri), the frond of which is punctured with many little holes.","pos":""}],"SEA COMPASS":[{"def":"The mariner's compass.","pos":""}],"SEA CORN":[{"def":"A yellow cylindrical mass of egg capsule of certain species of whelks (Buccinum), which resembles an ear of maize.","pos":""}],"SEA COW":[{"def":"Any crustacean of the genus Palinurus and allied genera, as the European spiny lobster (P.","pos":""}],"SEA CUCUMBER":[{"def":"Any large holothurian, especially one of those belonging to the genus Pentacta, or Cucumaria, as the common American and European species.","pos":""}],"SEA DACE":[{"def":"The European sea perch.","pos":""}],"SEA DAFFODIL":[{"def":"A European amarylidaceous plant (Pancratium maritimum).","pos":""}],"SEA DEVIL":[{"def":"Cepholoptera, some of which become more than twenty feet across and weigh several tons.","pos":""}],"SEA DOG":[{"def":"An old sailor; a salt.","pos":""}],"SEA DOVE":[{"def":"The little auk, or rotche.","pos":""}],"SEA DUCK":[{"def":"Any one of numerous species of ducks which frequent the seacoasts and feed mainly on fishes and mollusks.","pos":""}],"SEA EAGLE":[{"def":"Any one of several species of fish-eating eagles of the genus Haliæetus and allied genera, as the North Pacific sea eagle.","pos":""}],"SEA ELEPHANT":[{"def":"A very large seal (Macrorhinus proboscideus) of the Antarctic seas, much hunted for its oil.","pos":""}],"SEA FAN":[{"def":"Any gorgonian which branches in a fanlike form, especially Gorgonia flabellum of Florida and the West Indies.","pos":""}],"SEA FEATHER":[{"def":"Any gorgonian which branches in a plumelike form.","pos":""}],"SEA FERN":[{"def":"Any gorgonian which branches like a fern.","pos":""}],"SEA FIGHT":[{"def":"An engagement between ships at sea; a naval battle.","pos":""}],"SEA FIR":[{"def":"A sertularian hydroid, especially Sertularia abietina, which branches like a miniature fir tree.","pos":""}],"SEA FLOWER":[{"def":"A sea anemone, or any related anthozoan.","pos":""}],"SEA FOAM":[{"def":"Meerschaum; -- called also sea froth.","pos":""}],"SEA FOWL":[{"def":"Any bird which habitually frequents the sea, as an auk, gannet, gull, tern, or petrel; also, all such birds, collectively.","pos":""}],"SEA FOX":[{"def":"The thrasher shark.","pos":""}],"SEA FROTH":[{"def":"See Sea foam, 2.","pos":""},{"def":"A long, rolling swell of the sea.","pos":""}],"SEA GAUGE":[{"def":"See under Gauge, n.","pos":""},{"def":"Any small holothurian resembling in form a gherkin.","pos":""}],"SEA GINGER":[{"def":"A hydroid coral of the genus Millepora, especially M.","pos":""}],"SEA GIRDLES":[{"def":"A kind of kelp (Laminaria digitata) with palmately cleft fronds; -- called also sea wand, seaware, and tangle.","pos":""}],"SEA GOD":[{"def":"A marine deity; a fabulous being supposed to live in, or have dominion over, the sea, or some particular sea or part of the sea, as Neptune.","pos":""}],"SEA GODDESS":[{"def":"A goddess supposed to live in or reign over the sea, or some part of the sea.","pos":""}],"SEA GOWN":[{"def":"A gown or frock with short sleeves, formerly worn by mariners.","pos":""}],"SEA GRAPE":[{"def":"The clusters of gelatinous egg capsules of a squid (Loligo).","pos":""}],"SEA GREEN":[{"def":"The green color of sea water.","pos":""}],"SEA GUDGEON":[{"def":"The European black goby (Gobius niger).","pos":""}],"SEA GULL":[{"def":"Any gull living on the seacoast.","pos":""}],"SEA HARE":[{"def":"Any tectibranchiate mollusk of the genus Aplysia.","pos":""}],"SEA HEATH":[{"def":"A low perennial plant (Frankenia lævis) resembling heath, growing along the seashore in Europe.","pos":""}],"SEA HEN":[{"def":"the common guillemot; -- applied also to various other sea birds.","pos":""}],"SEA HOLLY":[{"def":"An evergeen seashore plant (Eryngium maritimum).","pos":""}],"SEA HOLM":[{"def":"A small uninhabited island.","pos":""}],"SEA HORSE":[{"def":"A fabulous creature, half horse and half fish, represented in classic mythology as driven by sea dogs or ridden by the Nereids.","pos":""}],"SEA JELLY":[{"def":"A medusa, or jellyfish.","pos":""}],"SEA KING":[{"def":"One of the leaders among the Norsemen who passed their lives in roving the seas in search of plunder and adventures; a Norse pirate chief.","pos":""}],"SEA LACES":[{"def":"A kind of seaweed (Chorda Filum) having blackish cordlike fronds, often many feet long.","pos":""}],"SEA LAMPREY":[{"def":"The common lamprey.","pos":""}],"SEA LANGUAGE":[{"def":"The peculiar language or phraseology of seamen; sailor's cant.","pos":""}],"SEA LAVENDER":[{"def":"See Marsh rosemary, under Marsh.","pos":""}],"SEA LAWYER":[{"def":"The gray snapper.","pos":""}],"SEA LEGS":[{"def":"Legs able to maintain their possessor upright in stormy weather at sea, that is, ability stand or walk steadily on deck when a vessel is rolling or pitching in a rough sea.","pos":""}],"SEA LEMON":[{"def":"Any one of several species of nudibranchiate mollusks of the genus Doris and allied genera, having a smooth, thick, convex yellow body.","pos":""}],"SEA LEOPARD":[{"def":"Any one of several species of spotted seals, especially Ogmorhinus leptonyx, and Leptonychotes Weddelli, of the Antarctic Ocean.","pos":""}],"SEA LETTER":[{"def":"The customary certificate of national character which neutral merchant vessels are bound to carry in time of war; a passport for a vessel and cargo.","pos":""}],"SEA LETTUCE":[{"def":"The green papery fronds of several seaweeds of the genus Ulva, sometimes used as food.","pos":""}],"SEA LEVEL":[{"def":"The level of the surface of the sea; any surface on the same level with the sea.","pos":""}],"SEA LOACH":[{"def":"The three-bearded rockling.","pos":""}],"SEA LOUSE":[{"def":"Any one of numerous species of isopod crustaceans of Cymothoa, Livoneca, and allied genera, mostly parasites on fishes.","pos":""}],"SEA MARGE":[{"def":"Land which borders on the sea; the seashore.","pos":""}],"SEA MAT":[{"def":"Any bryozoan of the genus Flustra or allied genera which form frondlike corals.","pos":""}],"SEA MEW":[{"def":"A gull; the mew.","pos":""}],"SEA MILE":[{"def":"A geographical mile.","pos":""}],"SEA MILKWORT":[{"def":"A low, fleshy perennial herb (Glaux maritima) found along northern seashores.","pos":""}],"SEA MONK":[{"def":"See Monk seal, under Monk.","pos":""}],"SEA MONSTER":[{"def":"Any large sea animal.","pos":""}],"SEA MOSS":[{"def":"Any branched marine bryozoan resembling moss.","pos":""}],"SEA MUD":[{"def":"A rich slimy deposit in salt marshes and along the seashore, sometimes used as a manure; -- called also sea ooze.","pos":""}],"SEA NEEDLE":[{"def":"See Garfish (a).","pos":""}],"SEA NETTLE":[{"def":"A jellyfish, or medusa.","pos":""}],"SEA ONION":[{"def":"The officinal squill.","pos":""}],"SEA OOZE":[{"def":"Same as Sea mud.","pos":""}],"SEA ORANGE":[{"def":"A large American holothurian (Lophothuria Fabricii) having a bright orange convex body covered with finely granulated scales.","pos":""}],"SEA OTTER":[{"def":"An aquatic carnivore (Enhydris lutris, or marina) found in the North Pacific Ocean.","pos":""}],"SEA PARROT":[{"def":"Sea\" par\"rot (se\" par\"rut).","pos":""}],"SEA PARTRIDGE":[{"def":"The gilthead (Crenilabrus melops), a fish of the British coasts.","pos":""}],"SEA PASS":[{"def":"A document carried by neutral merchant vessels in time of war, to show their nationality; a sea letter or passport.","pos":""}],"SEA PEACH":[{"def":"A beautiful American ascidian (Cynthia, or Halocynthia, pyriformis) having the size, form, velvety surface, and color of a ripe peach.","pos":""}],"SEA PEAR":[{"def":"A pedunculated ascidian of the genus Boltonia.","pos":""}],"SEA PHEASANT":[{"def":"The pintail duck.","pos":""}],"SEA PIE":[{"def":"The oyster catcher, a limicoline bird of the genus Hæmatopus.","pos":""}],"SEA PIET":[{"def":"See 1st Sea pie.","pos":""}],"SEA PIGEON":[{"def":"The common guillemot.","pos":""}],"SEA PLOVER":[{"def":"the black-bellied plover.","pos":""}],"SEA POOL":[{"def":"A pool of salt water.","pos":""}],"SEA PORCUPINE":[{"def":"Any fish of the genus Diodon, and allied genera, whose body is covered with spines.","pos":""}],"SEA PORK":[{"def":"An American compound ascidian (Amoræcium stellatum) which forms large whitish masses resembling salt pork.","pos":""}],"SEA PORT":[{"def":"A port on the seashore, or one accessible for seagoing vessels.","pos":""}],"SEA PUDDING":[{"def":"Any large holothurian.","pos":""}],"SEA PURSE":[{"def":"The horny egg case of a skate, and of certain sharks.","pos":""}],"SEA PURSLANE":[{"def":"See under Purslane.","pos":""}],"SEA PYE":[{"def":"See 1st Sea pie.","pos":""}],"SEA PYOT":[{"def":"See 1st Sea pie.","pos":""}],"SEA REED":[{"def":"The sea-sand reed.","pos":""}],"SEA RISK":[{"def":"Risk of injury, destruction, or loss by the sea, or while at sea.","pos":""}],"SEA ROBBER":[{"def":"A pirate; a sea rover.","pos":""}],"SEA ROBIN":[{"def":"See under Robin, and Illustration in Appendix.","pos":""}],"SEA ROCKET":[{"def":"See under Rocket.","pos":""}],"SEA ROOM":[{"def":"Room or space at sea for a vessel to maneuver, drive, or scud, without peril of running ashore or aground.","pos":""}],"SEA ROVER":[{"def":"One that cruises or roves the sea for plunder; a sea robber; a pirate; also, a piratical vessel.","pos":""}],"SEA SALT":[{"def":"Common salt, obtained from sea water by evaporation.","pos":""}],"SEA SANDPIPER":[{"def":"The purple sandpiper.","pos":""}],"SEA SANDWORT":[{"def":"See Sea chickweed.","pos":""}],"SEA SAURIAN":[{"def":"Any marine saurian; esp.","pos":""}],"SEA SCURF":[{"def":"Any bryozoan which forms rounded or irregular patches of coral on stones, seaweeds, etc.","pos":""}],"SEA SERPENT":[{"def":"Any marine snake.","pos":""},{"def":"A large marine animal of unknown nature, often reported to have been seen at sea, but never yet captured.","pos":""}],"SEA SLATER":[{"def":"Any isopod crustacean of the genus Ligia.","pos":""}],"SEA SNAKE":[{"def":"Any one of many species of venomous aquatic snakes of the family Hydrophidæ, having a flattened tail and living entirely in the sea, especially in the warmer parts of the Indian and Pacific Oceans.","pos":""}],"SEA STAR":[{"def":"A starfish, or brittle star.","pos":""}],"SEA SWALLOW":[{"def":"See Cornish chough, under Chough.","pos":""}],"SEA TANG":[{"def":"A kind of seaweed; tang; tangle.","pos":""}],"SEA TERM":[{"def":"A term used specifically by seamen; a nautical word or phrase.","pos":""}],"SEA THONGS":[{"def":"A kind of blackish seaweed (Himanthalia lorea) found on the northern coasts of the Atlantic.","pos":""}],"SEA TRUMPET":[{"def":"A great blackish seaweed of the Southern Ocean, having a hollow and expanding stem and a pinnate frond, sometimes twenty feet long.","pos":""},{"def":"Any large marine univalve shell of the genus Triton.","pos":""}],"SEA TURN":[{"def":"A breeze, gale, or mist from the sea.","pos":""}],"SEA URCHIN":[{"def":"Any one of numerous species of echinoderms of the order Echinoidea.","pos":""}],"SEA WALL":[{"def":"A wall, or embankment, to resist encroachments of the sea.","pos":""}],"SEA WHIP":[{"def":"A gorgonian having a simple stem.","pos":""}],"SEA WILLOW":[{"def":"A gorgonian coral with long flexible branches.","pos":""}],"SEA WING":[{"def":"A wing shell (Avicula).","pos":""}],"SEA WOODCOCK":[{"def":"The bar-tailed godwit.","pos":""}],"SEA WORMWOOD":[{"def":"A European species of wormwood (Artemisia maritima) growing by the sea.","pos":""}]}