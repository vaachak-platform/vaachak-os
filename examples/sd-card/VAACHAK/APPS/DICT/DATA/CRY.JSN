{"CRY":[{"def":"To make a loud call or cry; to call or exclaim vehemently or earnestly; to shout; to vociferate; to proclaim; to pray; to implore.","pos":""},{"def":"Clapping their hands, and crying with loud voice.","pos":""}],"CRYER":[{"def":"The female of the hawk; a falcon-gentil.","pos":""}],"CRYING":[{"def":"Calling for notice; compelling attention; notorious; heinous; as, a crying evil.","pos":""}],"CRYOHYDRATE":[{"def":"A substance, as salt, ammonium chloride, etc.","pos":""}],"CRYOLITE":[{"def":"A fluoride of sodium and aluminum, found in Greenland, in white cleavable masses; -- used as a source of soda and alumina.","pos":""}],"CRYOMETER":[{"def":"A thermometer for the measurement of low temperatures, esp.","pos":""}],"CRYOPHORUS":[{"def":"An instrument used to illustrate the freezing of water by its own evaporation.","pos":""}],"CRYPT":[{"def":"A simple gland, glandular cavity, or tube; a follicle; as, the cryps of Lieberk.","pos":""}],"CRYPTAL":[{"def":"Of or pertaining to crypts.","pos":""},{"def":"Hidden; secret; occult.","pos":""}],"CRYPTICALLY":[{"def":"Secretly; occultly.","pos":""}],"CRYPTIDINE":[{"def":"One of the quinoline bases, obtained from coal tar as an oily liquid, C11H11N; also, any one of several substances metameric with, and resembling, cryptidine proper.","pos":""}],"CRYPTOBRANCHIATA":[{"def":"Cryp`to*bran`chi*a\"ta (krp`t-bra`k-\"t), n.","pos":""}],"CRYPTOBRANCHIATE":[{"def":"Having concealed or rudimentary gills.","pos":""}],"CRYPTOCRYSTALLINE":[{"def":"Indistinctly crystalline; -- applied to rocks and minerals, whose state of aggregation is so fine that no distinct particles are visible, even under the microscope.","pos":""}],"CRYPTOGAM":[{"def":"A plant belonging to the Cryptogamia.","pos":""}],"CRYPTOGAMIA":[{"def":"The series or division of flowerless plants, or those never having true stamens and pistils, but propagated by spores of various kinds.","pos":""},{"def":"Of or pertaining to the series Cryptogamia, or to plants of that series.","pos":""}],"CRYPTOGAMIST":[{"def":"One skilled in cryptogamic botany.","pos":""}],"CRYPTOGRAM":[{"def":"A cipher writing.","pos":""}],"CRYPTOGRAPH":[{"def":"Cipher; something written in cipher.","pos":""}],"CRYPTOGRAPHAL":[{"def":"Pertaining to cryptography; cryptographical.","pos":""}],"CRYPTOGRAPHER":[{"def":"One who writes in cipher, or secret characters.","pos":""},{"def":"Relating to cryptography; written in secret characters or in cipher, or with sympathetic ink.","pos":""}],"CRYPTOGRAPHIST":[{"def":"Same as Cryptographer.","pos":""}],"CRYPTOGRAPHY":[{"def":"The act or art of writing in secret characters; also, secret characters, or cipher.","pos":""}],"CRYPTOLOGY":[{"def":"Secret or enigmatical language.","pos":""}],"CRYPTONYM":[{"def":"A secret name; a name by which a person is known only to the initiated.","pos":""}],"CRYPTOPINE":[{"def":"A colorless crystalline alkaloid obtained in small quantities from opium.","pos":""}],"CRYPTURI":[{"def":"An order of flying, dromTinamou.","pos":""}],"CRYSTAL":[{"def":"The regular form which a substance tends to assume in solidifying, through the inherent power of cohesive attraction.","pos":""}],"CRYSTALLIN":[{"def":"Crys\"tal*lin (-ln), n.","pos":""}],"CRYSTALLINE":[{"def":"Consisting, or made, of crystal.","pos":""},{"def":"Formed by crystallization; like crystal in texture.","pos":""}],"CRYSTALLITE":[{"def":"A minute mineral form like those common in glassy volcanic rocks and some slags, not having a definite crystalline outline and not referable to any mineral species, but marking the first step in the crystallization process.","pos":""}],"CRYSTALLIZABLE":[{"def":"Capable of being crystallized; that may be formed into crystals.","pos":""}],"CRYSTALLIZATION":[{"def":"The act or process by which a substance in solidifying assumes the form and sructure of a crystal, or becomes crystallized.","pos":""}],"CRYSTALLIZE":[{"def":"To cause to form crystals, or to assume the crystalline form.","pos":""}],"CRYSTALLOGENY":[{"def":"The science which pertains to the production of crystals.","pos":""}],"CRYSTALLOGRAPHER":[{"def":"One who describes crystals, or the manner of their formation; one versed in crystallography.","pos":""},{"def":"Pertaining to crystallography.","pos":""}],"CRYSTALLOGRAPHICALLY":[{"def":"In the manner of crystallography.","pos":""}],"CRYSTALLOGRAPHY":[{"def":"The doctrine or science of crystallization, teaching the system of forms among crystals, their structure, and their methods of formation.","pos":""},{"def":"A discourse or treatise on crystallization.","pos":""}],"CRYSTALLOID":[{"def":"Crystal-like; transparent like crystal.","pos":""}],"CRYSTALLOMANCY":[{"def":"Divination by means of a crystal or other transparent body, especially a beryl.","pos":""}],"CRYSTALLOMETRY":[{"def":"The art of measuring crystals.","pos":""}],"CRYSTALLURGY":[{"def":"Crys\"tal*lur`gy (-lr`j), n.","pos":""}]}