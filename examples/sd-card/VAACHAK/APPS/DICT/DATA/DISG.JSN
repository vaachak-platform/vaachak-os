{"DISGAGE":[{"def":"To free from a gage or pledge; to disengage.","pos":""}],"DISGALLANT":[{"def":"To deprive of gallantry.","pos":""}],"DISGARLAND":[{"def":"To strip of a garland.","pos":""}],"DISGARNISH":[{"def":"To divest of garniture; to disfurnish; to dismantle.","pos":""}],"DISGARRISON":[{"def":"To deprive of a garrison.","pos":""}],"DISGAVEL":[{"def":"To deprive of that principal quality of gavelkind tenure by which lands descend equally among all the sons of the tenant; -- said of lands.","pos":""}],"DISGLORIFY":[{"def":"To deprive of glory; to treat with indignity.","pos":""}],"DISGLORY":[{"def":"To the disglory of God's name.","pos":""}],"DISGORGE":[{"def":"To eject or discharge by the throat and mouth; to vomit; to pour forth or throw out with violence, as if from the mouth; to discharge violently or in great quantities from a confined place.","pos":""},{"def":"To give up unwillingly as what one has wrongfully seized and appropriated; to make restitution of; to surrender; as, he was compelled to disgorge his ill-gotten gains.","pos":""}],"DISGORGEMENT":[{"def":"The act of disgorging; a vomiting; that which is disgorged.","pos":""}],"DISGOSPEL":[{"def":"To be inconsistent with, or act contrary to, the precepts of the gospel; to pervert the gospel.","pos":""}],"DISGRACE":[{"def":"The condition of being out of favor; loss of favor, regard, or respect.","pos":""},{"def":"The state of being dishonored, or covered with shame; dishonor; shame; ignominy.","pos":""}],"DISGRACEFUL":[{"def":"Bringing disgrace; causing shame; shameful; dishonorable; unbecoming; as, profaneness is disgraceful to a man.","pos":""}],"DISGRACER":[{"def":"One who disgraces.","pos":""}],"DISGRACIOUS":[{"def":"Wanting grace; unpleasing; disagreeable.","pos":""}],"DISGRADATION":[{"def":"Degradation; a stripping of titles and honors.","pos":""}],"DISGRADUATE":[{"def":"To degrade; to reduce in rank.","pos":""}],"DISGREGATE":[{"def":"To disperse; to scatter; -- opposite of congregate.","pos":""}],"DISGREGATION":[{"def":"The process of separation, or the condition of being separate, as of the molecules of a body.","pos":""}],"DISGRUNTLE":[{"def":"To dissatisfy; to disaffect; to anger.","pos":""}],"DISGUISE":[{"def":"To change the guise or appearance of; especially, to conceal by an unusual dress, or one intended to mislead or deceive.","pos":""},{"def":"To hide by a counterfeit appearance; to cloak by a false show; to mask; as, to disguise anger; to disguise one's sentiments, character, or intentions.","pos":""}],"DISGUISEDNESS":[{"def":"The state of being disguised.","pos":""}],"DISGUISER":[{"def":"One who, or that which, disguises.","pos":""},{"def":"One who wears a disguise; an actor in a masquerade; a masker.","pos":""}],"DISGUISING":[{"def":"A masque or masquerade.","pos":""}],"DISGUST":[{"def":"To provoke disgust or strong distaste in; to cause (any one) loathing, as of the stomach; to excite aversion in; to offend the moral taste of; -- often with at, with, or by.","pos":""}],"DISGUSTFUL":[{"def":"Provoking disgust; offensive to the taste; exciting aversion; disgusting.","pos":""}],"DISGUSTFULNESS":[{"def":"The state of being disgustful.","pos":""}],"DISGUSTING":[{"def":"That causes disgust; sickening; offensive; revolting.","pos":""}]}