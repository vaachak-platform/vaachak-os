{"TRAWL":[{"def":"To take fish, or other marine animals, with a trawl.","pos":""}],"TRAWLBOAT":[{"def":"A boat used in fishing with trawls or trawlnets.","pos":""}],"TRAWLER":[{"def":"One who, or that which, trawls.","pos":""},{"def":"A fishing vessel which trails a net behind it.","pos":""}],"TRAWLERMAN":[{"def":"A fisherman who used unlawful arts and engines to catch fish.","pos":""}],"TRAWLNET":[{"def":"Same as Trawl, n.","pos":""}],"TRAWLWARP":[{"def":"A rope passing through a block, used in managing or dragging a trawlnet.","pos":""}]}