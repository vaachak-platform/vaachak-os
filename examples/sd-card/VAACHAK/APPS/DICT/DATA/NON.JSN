{"NON ASSUMPSIT":[{"def":"The general plea or denial in an action of assumpsit.","pos":""}],"NON EST FACTUM":[{"def":"The plea of the general issue in an action of debt on bond.","pos":""}],"NON EST INVENTUS":[{"def":"The return of a sheriff on a writ, when the defendant is not found in his county.","pos":""}],"NON LIQUET":[{"def":"It is not clear; -- a verdict given by a jury when a matter is to be deferred to another day of trial.","pos":""}],"NON OBSTANTE":[{"def":"A clause in old English statutes and letters patent, importing a license from the crown to do a thing notwithstanding any statute to the contrary.","pos":""}],"NON PROSEQUITUR":[{"def":"A judgment entered against the plaintiff in a suit where he does not appear to prosecute.","pos":""}],"NON SEQUITUR":[{"def":"An inference which does not follow from the premises.","pos":""}],"NON-":[{"def":"A prefix used in the sense of not; un-; in-; as in nonattention, or non-attention, nonconformity, nonmetallic, nonsuit.","pos":""}],"NON-EGO":[{"def":"The union of being and relation as distinguished from, and contrasted with, the ego.","pos":""}],"NON-EPISCOPAL":[{"def":"Not Episcopal; not pertaining to the Episcopal church or system.","pos":""}],"NON-FEASANCE":[{"def":"An omission or neglect to do something, esp.","pos":""}],"NON-PROS":[{"def":"To decline or fail to prosecute; to allow to be dropped (said of a suit); to enter judgment against (a plaintiff who fails to prosecute); as, the plaintiff was non-prossed.","pos":""}]}