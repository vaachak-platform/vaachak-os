{"INTRA-":[{"def":"A prefix signifying in, within, interior; as, intraocular, within the eyeball; intramarginal.","pos":""}],"INTRAAXILLARY":[{"def":"Situated below the point where a leaf joins the stem.","pos":""}],"INTRACELLULAR":[{"def":"Within a cell; as, the intracellular movements seen in the pigment cells, the salivary cells, and in the protoplasm of some vegetable cells.","pos":""}],"INTRACOLIC":[{"def":"Within the colon; as, the intracolic valve.","pos":""}],"INTRACRANIAL":[{"def":"Within the cranium or skull.","pos":""}],"INTRACTABILITY":[{"def":"The quality of being intractable; intractableness.","pos":""}],"INTRACTABLE":[{"def":"Not tractable; not easily governed, managed, or directed; indisposed to be taught, disciplined, or tamed; violent; stubborn; obstinate; refractory; as, an intractable child.","pos":""}],"INTRACTILE":[{"def":"Not tractile; incapable of being drawn out or extended.","pos":""}],"INTRADOS":[{"def":"The interior curve of an arch; esp.","pos":""}],"INTRAFOLIACEOUS":[{"def":"Growing immediately above, or in front of, a leaf; as, intrafoliaceous stipules.","pos":""}],"INTRAFUSION":[{"def":"The act of pouring into a vessel; specif.","pos":""}],"INTRALOBULAR":[{"def":"Within lobules; as, the intralobular branches of the hepatic veins.","pos":""}],"INTRAMARGINAL":[{"def":"Situated within the margin.","pos":""}],"INTRAMERCURIAL":[{"def":"Between the planet Mercury and the sun; -- as, the hypothetical Vulcan is intramercurial.","pos":""}],"INTRAMOLECULAR":[{"def":"Between molecules; situated, or acting, between the molecules of bodies.","pos":""}],"INTRAMUNDANE":[{"def":"Being within the material world; -- opposed to extramundane.","pos":""}],"INTRAMURAL":[{"def":"Being within the substance of the walls of an organ; as, intramural pregnancy.","pos":""}],"INTRANQUILLITY":[{"def":"Unquietness; restlessness.","pos":""}],"INTRANSCALENT":[{"def":"Impervious to heat; adiathermic.","pos":""}],"INTRANSGRESSIBLE":[{"def":"Incapable of being transgressed; not to be passes over or crossed.","pos":""}],"INTRANSIENT":[{"def":"Not transient; remaining; permanent.","pos":""}],"INTRANSIGENT":[{"def":"Refusing compromise; uncompromising; irreconcilable.","pos":""}],"INTRANSIGENTES":[{"def":"The extreme radicals; the party of the irreconcilables.","pos":""}],"INTRANSITIVE":[{"def":"Not transitive; not passing over tas, an intransitive verb, e.","pos":""}],"INTRANSITIVELY":[{"def":"Without an object following; in the manner of an intransitive verb.","pos":""}],"INTRANSMISSIBLE":[{"def":"Not capable of being transmitted.","pos":""}],"INTRANSMUTABILITY":[{"def":"The quality of being intransmutable.","pos":""}],"INTRANSMUTABLE":[{"def":"Not capable of being transmuted or changed into another substance.","pos":""}],"INTRANT":[{"def":"Entering; penetrating.","pos":""}],"INTRANUCLEAR":[{"def":"Within the nucleus of a cell; as.","pos":""}],"INTRAPARIETAL":[{"def":"Situated or occurring within an inclosure; shut off from public sight; private; secluded; retired.","pos":""}],"INTRAPETIOLAR":[{"def":"In`tra*pet\"i*o*lar, a.","pos":""}],"INTRATERRITORIAL":[{"def":"Within the territory or a territory.","pos":""}],"INTRATROPICAL":[{"def":"Within the tropics.","pos":""}],"INTRAUTERINE":[{"def":"Within the uterus or womb; as, intrauterine hemorrhage.","pos":""}],"INTRAVENOUS":[{"def":"Within the veins.","pos":""}],"INTRAVENTRICULAR":[{"def":"Within or between ventricles.","pos":""}],"INTREASURE":[{"def":"To lay up, as in a treasury; to hoard.","pos":""}],"INTREATABLE":[{"def":"Not to be entreated; inexorable.","pos":""}],"INTREATFUL":[{"def":"Full of entreaty.","pos":""}],"INTRENCH":[{"def":"To cut in; to furrow; to make trenches in or upon.","pos":""},{"def":"To surround with a trench or with intrenchments, as in fortification; to fortify with a ditch and parapet; as, the army intrenched their camp, or intrenched itself.","pos":""}],"INTRENCHANT":[{"def":"Not to be gashed or marked with furrows.","pos":""}],"INTRENCHMENT":[{"def":"Any defensive work consisting of at least a trench or ditch and a parapet made from the earth thrown up in making such a ditch.","pos":""}],"INTREPID":[{"def":"Not trembling or shaking with fear; fearless; bold; brave; undaunted; courageous; as, an intrepid soldier; intrepid spirit.","pos":""}],"INTREPIDITY":[{"def":"The quality or state of being intrepid; fearless bravery; courage; resoluteness; valor.","pos":""}],"INTREPIDLY":[{"def":"In an intrepid manner; courageously; resolutely.","pos":""}],"INTRICACY":[{"def":"The state or quality of being intricate or entangled; perplexity; involution; complication; complexity; that which is intricate or involved; as, the intricacy of a knot; the intricacy of accounts; the intricacy of a cause in controversy; the intricacy of a plot.","pos":""}],"INTRICATE":[{"def":"Entangled; involved; perplexed; complicated; difficult to understand, follow, arrange, or adjust; as, intricate machinery, labyrinths, accounts, plots, etc.","pos":""}],"INTRICATELY":[{"def":"In an intricate manner.","pos":""}],"INTRICATENESS":[{"def":"The state or quality of being intricate; intricacy.","pos":""}],"INTRIGANTE":[{"def":"A female intriguer.","pos":""}],"INTRIGUE":[{"def":"To form a plot or scheme; to contrive to accomplish a purpose by secret artifice.","pos":""},{"def":"To carry on a secret and illicit love or amour.","pos":""}],"INTRIGUER":[{"def":"One who intrigues.","pos":""}],"INTRIGUERY":[{"def":"Arts or practice of intrigue.","pos":""}],"INTRIGUINGLY":[{"def":"By means of, or in the manner of, intrigue.","pos":""}],"INTRINSE":[{"def":"Tightly drawn; or (perhaps) intricate.","pos":""}],"INTRINSIC":[{"def":"Included wholly within an organ or limb, as certain groups of muscles; -- opposed to extrinsic.","pos":""}],"INTRINSICAL":[{"def":"Intimate; closely familiar.","pos":""}],"INTRINSICALITY":[{"def":"In*trin`si*cal\"i*ty, n.","pos":""}],"INTRINSICALLY":[{"def":"Internally; A lie is a thing absolutely and intrinsically evil.","pos":""}],"INTRINSICALNESS":[{"def":"The quality of being intrinsical; intrinsicality.","pos":""}],"INTRO-":[{"def":"A prefix signifying within, into, in, inward; as, introduce, introreception, introthoracic.","pos":""}],"INTROCESSION":[{"def":"A depression, or inward sinking of parts.","pos":""}],"INTRODUCE":[{"def":"To lead or bring in; to conduct or usher in; as, to introduce a person into a drawing-room.","pos":""},{"def":"To put (something into a place); to insert; as, to introduce the finger, or a probe.","pos":""}],"INTRODUCER":[{"def":"One who, or that which, introduces.","pos":""}],"INTRODUCTION":[{"def":"The act of introducing, or bringing to notice.","pos":""},{"def":"The act of formally making persons known to each other; a presentation or making known of one person to another by name; as, the introduction of one stranger to another.","pos":""}],"INTRODUCTIVE":[{"def":"Serving to introduce; introductory.","pos":""}],"INTRODUCTORILY":[{"def":"By way of introduction.","pos":""}],"INTRODUCTORY":[{"def":"Serving to introduce something else; leading to the main subject or business; preliminary; prefatory; as, introductory proceedings; an introductory discourse.","pos":""}],"INTRODUCTRESS":[{"def":"A female introducer.","pos":""}],"INTROFLEXED":[{"def":"Flexed or bent inward.","pos":""}],"INTROGRESSION":[{"def":"The act of going in; entrance.","pos":""}],"INTROIT":[{"def":"An anthem or psalm sung before the Communion service.","pos":""}],"INTROMISSION":[{"def":"An intermeddling with the affairs of another, either on legal grounds or without authority.","pos":""}],"INTROMIT":[{"def":"To send in or put in; to insert or introduce.","pos":""},{"def":"To allow to pass in; to admit.","pos":""}],"INTROMITTENT":[{"def":"Used in copulation; -- said of the external reproductive organs of the males of many animals, and sometimes of those of the females.","pos":""}],"INTROMITTER":[{"def":"One who intromits.","pos":""}],"INTROPRESSION":[{"def":"Pressure acting within.","pos":""}],"INTRORECEPTION":[{"def":"The act of admitting into or within.","pos":""}],"INTRORSE":[{"def":"Turning or facing inward, or toward the axis of the part to which it belongs.","pos":""}],"INTROSPECT":[{"def":"To look into or within; to view the inside of.","pos":""}],"INTROSPECTION":[{"def":"A view of the inside or interior; a looking inward; specifically, the act or process of self-examination, or inspection of one's own thoughts and feelings; the cognition which the mind has of its own acts and states; self-consciousness; reflection.","pos":""}],"INTROSPECTIONIST":[{"def":"One given to the introspective method of examining the phenomena of the soul.","pos":""}],"INTROSPECTIVE":[{"def":"Inspecting within; seeing inwardly; capable of, or exercising, inspection; self-conscious.","pos":""},{"def":"Involving the act or results of conscious knowledge of physical phenomena; -- contrasted with associational.","pos":""}],"INTROSUME":[{"def":"To draw in; to swallow.","pos":""}],"INTROSUSCEPTION":[{"def":"Same as Intussusception.","pos":""}],"INTROVENIENT":[{"def":"Coming in together; entering; commingling.","pos":""}],"INTROVERSION":[{"def":"The act of introverting, or the state of being introverted; the act of turning the mind inward.","pos":""}],"INTROVERT":[{"def":"To turn or bend inward.","pos":""},{"def":"To look within; to introspect.","pos":""}],"INTRUDE":[{"def":"To thrust one's self in; to come or go in without invitation, permission, or welcome; to encroach; to trespass; as, to intrude on families at unseasonable hours; to intrude on the lands of another.","pos":""}],"INTRUDED":[{"def":"Same as Intrusive.","pos":""}],"INTRUDER":[{"def":"One who intrudes; one who thrusts himself in, or enters without right, or without leave or welcome; a trespasser.","pos":""}],"INTRUDRESS":[{"def":"A female intruder.","pos":""}],"INTRUNK":[{"def":"To inclose as in a trunk; to incase.","pos":""}],"INTRUSION":[{"def":"The penetrating of one rock, while in a plastic or metal state, into the cavities of another.","pos":""},{"def":"The entry of a stranger, after a particular estate or freehold is determined, before the person who holds in remainder or reversion has taken possession.","pos":""}],"INTRUSIONAL":[{"def":"Of or pertaining to intrusion.","pos":""}],"INTRUSIONIST":[{"def":"One who intrudes; especially, one who favors the appointment of a clergyman to a parish, by a patron, against the wishes of the parishioners.","pos":""}],"INTRUSIVE":[{"def":"Apt to intrude; characterized by intrusion; entering without right or welcome.","pos":""}],"INTRUST":[{"def":"To deliver (something) to another in trust; to deliver to (another) something in trust; to commit or surrender (something) to another with a certain confidence regarding his care, use, or disposal of it; as, to intrust a servant with one's money or intrust money or goods to a servant.","pos":""}]}