{"SUTILE":[{"def":"Done by stitching.","pos":""}],"SUTLER":[{"def":"A person who follows an army, and sells to the troops provisions, liquors, and the like.","pos":""}],"SUTLERSHIP":[{"def":"The condition or occupation of a sutler.","pos":""}],"SUTLING":[{"def":"Belonging to sutlers; engaged in the occupation of a sutler.","pos":""}],"SUTOR":[{"def":"A kind of sirup made by the Indians of Arizona from the fruit of some cactaceous plant (probably the Cereus giganteus).","pos":""}],"SUTRA":[{"def":"A body of Hindoo literature containing aphorisms on grammar, meter, law, and philosophy, and forming a connecting link between the Vedic and later Sanscrit literature.","pos":""}],"SUTTEE":[{"def":"A Hindoo widow who immolates herself, or is immolated, on the funeral pile of her husband; -- so called because this act of self- immolation is regarded as envincing excellence of wifely character.","pos":""},{"def":"The act of burning a widow on the funeral pile of her husband.","pos":""}],"SUTTEEISM":[{"def":"The practice of self-immolation of widows in Hindostan.","pos":""}],"SUTTLE":[{"def":"The weight when the tare has been deducted, and tret is yet to be allowed.","pos":""}],"SUTURAL":[{"def":"Taking place at a suture; as, a sutural de.","pos":""}],"SUTURALLY":[{"def":"In a sutural manner.","pos":""}],"SUTURATED":[{"def":"Sewed or knit together; united by a suture; stitched.","pos":""}],"SUTURE":[{"def":"The line of union, or seam, in an immovable articulation, like those between the bones of the skull; also, such an articulation itself; synarthrosis.","pos":""}],"SUTURED":[{"def":"Having a suture or sutures; knit or united together.","pos":""}]}