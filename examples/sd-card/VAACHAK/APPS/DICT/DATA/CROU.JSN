{"CROUCH":[{"def":"To bend down; to stoop low; to lie close to the ground with the logs bent, as an animal when waiting for prey, or in fear.","pos":""},{"def":"To bend servilely; to stoop meanly; to fawn; to cringe.","pos":""}],"CROUCHED":[{"def":"Marked with the sign of the cross.","pos":""}],"CROUD":[{"def":"See Crowd, a violin.","pos":""}],"CROUP":[{"def":"The hinder part or buttocks of certain quadrupeds, especially of a horse; hence, the place behind the saddle.","pos":""}],"CROUPADE":[{"def":"A leap in which the horse pulls up his hind legs toward his belly.","pos":""}],"CROUPIER":[{"def":"One who presides at a gaming table and collects the stakes.","pos":""},{"def":"One who, at a public dinner party, sits at the lower end of the table as assistant chairman.","pos":""}],"CROUPOUS":[{"def":"Relating to or resembling croup; especially, attended with the formation of a deposit or membrance like that found in membranous croup; as, croupous laryngitis.","pos":""}],"CROUPY":[{"def":"Of or pertaining to croup; resembling or indicating croup; as, a croupy cough.","pos":""}],"CROUSE":[{"def":"Brisk; lively; bold; self-complacent.","pos":""}],"CROUSTADE":[{"def":"Bread baked in a mold, and scooped out, to serve minces upon.","pos":""}],"CROUTON":[{"def":"Bread cut in various forms, and fried lightly in butter or oil, to garnish hashes, etc.","pos":""}]}