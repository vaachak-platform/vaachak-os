{"ENTICE":[{"def":"To draw on, by exciting hope or desire; to allure; to attract; as, the bait enticed the fishes.","pos":""}],"ENTICEABLE":[{"def":"Capable of being enticed.","pos":""}],"ENTICEMENT":[{"def":"The act or practice of alluring or tempting; as, the enticements of evil companions.","pos":""},{"def":"That which entices, or incites to evil; means of allurement; alluring object; as, an enticement to sin.","pos":""}],"ENTICER":[{"def":"One who entices; one who incites or allures to evil.","pos":""}],"ENTICING":[{"def":"That entices; alluring.","pos":""}],"ENTICINGLY":[{"def":"In an enticing manner; charmingly.","pos":""}],"ENTIRE":[{"def":"Complete in all parts; undivided; undiminished; whole; full and perfect; not deficient; as, the entire control of a business; entire confidence, ignorance.","pos":""},{"def":"Without mixture or alloy of anything; unqualified; morally whole; pure; faithful.","pos":""}],"ENTIRE-WHEAT":[{"def":"Designating, made of, or relating to, flour including a considerable part of the bran.","pos":""}],"ENTIRELY":[{"def":"In an entire manner; wholly; completely; fully; as, the trace is entirely lost.","pos":""},{"def":"Without alloy or mixture; truly; sincerely.","pos":""}],"ENTIRENESS":[{"def":"The state or condition of being entire; completeness; fullness; totality; as, the entireness of an arch or a bridge.","pos":""},{"def":"Integrity; wholeness of heart; honesty.","pos":""}],"ENTIRETY":[{"def":"The state of being entire; completeness; as, entirely of interest.","pos":""},{"def":"That which is entire; the whole.","pos":""}],"ENTITATIVE":[{"def":"Considered as pure entity; abstracted from all circumstances.","pos":""}],"ENTITLE":[{"def":"To give a title to; to affix to as a name or appellation; hence, also, to dignify by an honorary designation; to denominate; to call; as, to entitle a book \"Commentaries;\" to entitle a man \"Honorable.","pos":""},{"def":"To give a claim to; to qualify for, with a direct object of the person, and a remote object of the thing; to furnish with grounds for seeking or claiming with success; as, an officer's talents entitle him to command.","pos":""}],"ENTITY":[{"def":"A real being, whether in thought (as an ideal conception) or in fact; being; essence; existence.","pos":""}]}