{"UNCREATE":[{"def":"To deprive of existence; to annihilate.","pos":""}],"UNCREATED":[{"def":"Deprived of existence; annihilated.","pos":""},{"def":"Not yet created; as, misery uncreated.","pos":""}],"UNCREATEDNESS":[{"def":"The quality or state of being uncreated.","pos":""}],"UNCREDIT":[{"def":"To cause to be disbelieved; to discredit.","pos":""}],"UNCROWN":[{"def":"To deprive of a crown; to take the crown from; hence, to discrown; to dethrone.","pos":""}],"UNCRUDDED":[{"def":"Not cruddled, or curdled.","pos":""}]}