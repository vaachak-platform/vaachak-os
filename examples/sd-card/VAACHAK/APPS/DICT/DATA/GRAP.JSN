{"GRAPE":[{"def":"A well-known edible berry growing in pendent clusters or bunches on the grapevine.","pos":""},{"def":"The plant which bears this fruit; the grapevine.","pos":""}],"GRAPELESS":[{"def":"Wanting grapes or the flavor of grapes.","pos":""}],"GRAPERY":[{"def":"A building or inclosure used for the cultivation of grapes.","pos":""}],"GRAPESHOT":[{"def":"A cluster, usually nine in number, of small iron balls, put together by means of cast-iron circular plates at top and bottom, with two rings, and a central connecting rod, in order to be used as a charge for a cannon.","pos":""}],"GRAPESTONE":[{"def":"A seed of the grape.","pos":""}],"GRAPEVINE":[{"def":"A vine or climbing shrub, of the genus Vitis, having small green flowers and lobed leaves, and bearing the fruit called grapes.","pos":""},{"def":"A suffix signifying something written, a writing; also, a writer; as autograph, crystograph, telegraph, photograph.","pos":""}],"GRAPHICALLY":[{"def":"In a graphic manner; vividly.","pos":""},{"def":"The quality or state of being graphic.","pos":""}],"GRAPHICS":[{"def":"The art or the science of drawing; esp.","pos":""}],"GRAPHISCOPE":[{"def":"See Graphoscope.","pos":""}],"GRAPHITE":[{"def":"Native carbon in hexagonal crystals, also foliated or granular massive, of black color and metallic luster, and so soft as to leave a trace on paper.","pos":""}],"GRAPHITIC":[{"def":"Pertaining to, containing, derived from, or resembling, graphite.","pos":""},{"def":"Resembling graphite or plumbago.","pos":""}],"GRAPHOLITE":[{"def":"Any species of slate suitable to be written on.","pos":""}],"GRAPHOLOGY":[{"def":"The art of judging of a person's character, disposition, and aptitude from his handwriting.","pos":""}],"GRAPHOPHONE":[{"def":"A kind of photograph.","pos":""}],"GRAPHOSCOPE":[{"def":"An optical instrument for magnifying engravings, photographs, etc.","pos":""}],"GRAPHOTYPE":[{"def":"A process for producing a design upon a surface in relief so that it can be printed from.","pos":""},{"def":"A suffix denoting the art of writing or describing; also, the writing or description itself; a treatise; as, calligraphy, biography, geography.","pos":""}],"GRAPNEL":[{"def":"A small anchor, with four or five flukes or claws, used to hold boats or small vessels; hence, any instrument designed to grapple or hold; a grappling iron; a grab; -- written also grapline, and crapnel.","pos":""}],"GRAPPLE":[{"def":"To seize; to lay fast hold of; to attack at close quarters: as, to grapple an antagonist.","pos":""},{"def":"To fasten, as with a grapple; to fix; to join indissolubly.","pos":""}],"GRAPPLEMENT":[{"def":"A grappling; close fight or embrace.","pos":""}],"GRAPPLING":[{"def":"A laying fast ho1d of; also, that by which anything is seized and held, a grapnel.","pos":""},{"def":"A grapple; a struggle.","pos":""}],"GRAPSOID":[{"def":"Pertaining to the genus Grapsus or the family Grapsidæ.","pos":""},{"def":"A grapsoid crab.","pos":""}],"GRAPTOLITE":[{"def":"One of numerous species of slender and delicate fossils, of the genus Graptolites and allied genera, found in the Silurian rocks.","pos":""}],"GRAPTOLITIC":[{"def":"Of or pertaining to graptolites; containing graptolites; as, a graptolitic slate.","pos":""}],"GRAPY":[{"def":"Composed of, or resembling, grapes.","pos":""}]}