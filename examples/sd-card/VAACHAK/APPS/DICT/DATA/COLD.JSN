{"COLD":[{"def":"Having a bluish effect.","pos":""}],"COLD WAVE":[{"def":"In the terminology of the United States Weather Bureau, an unusual fall in temperature, to or below the freezing point, exceeding 16º in twenty-four hours or 20º in thirty-six hours, independent of the diurnal range.","pos":""}],"COLD-BLOODED":[{"def":"Having cold blood; -- said of fish or animals whose blood is but little warmer than the water or air about them.","pos":""},{"def":"Deficient in sensibility or feeling; hard-hearted.","pos":""}],"COLD-HEARTED":[{"def":"Wanting passion or feeling; indifferent.","pos":""}],"COLD-SHORT":[{"def":"Brittle when cold; as, cold-short iron.","pos":""}],"COLD-SHUT":[{"def":"Closed while too cold to become thoroughly welded; -- said of a forging or casting.","pos":""},{"def":"An imperfection caused by such insufficient welding.","pos":""}],"COLDFINCH":[{"def":"A British wagtail.","pos":""}],"COLDISH":[{"def":"Somewhat cold; cool; chilly.","pos":""}],"COLDLY":[{"def":"In a cold manner; without warmth, animation, or feeling; with indifference; calmly.","pos":""}],"COLDNESS":[{"def":"The state or quality of being cold.","pos":""}]}