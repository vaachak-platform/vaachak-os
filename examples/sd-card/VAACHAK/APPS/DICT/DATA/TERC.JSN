{"TERCELET":[{"def":"A male hawk or eagle; a tiercelet.","pos":""}],"TERCELLENE":[{"def":"A small male hawk.","pos":""}],"TERCENTENARY":[{"def":"Including, or relating to, an interval of three hundred years.","pos":""},{"def":"The three hundredth anniversary of any event; also, a celebration of such an anniversary.","pos":""}],"TERCET":[{"def":"A triplet; a group of three lines.","pos":""}],"TERCINE":[{"def":"A cellular layer derived from the nucleus of an ovule and surrounding the embryo sac.","pos":""}]}