{"RINCON":[{"def":"An interior corner; a nook; hence, an angular recess or hollow bend in a mountain, river, cliff, or the like.","pos":""}],"RIND":[{"def":"The external covering or coat, as of flesh, fruit, trees, etc.","pos":""}],"RINDERPEST":[{"def":"A highly contagious distemper or murrain, affecting neat cattle, and less commonly sheep and goats; -- called also cattle plague, Russian cattle plague, and steppe murrain.","pos":""}],"RINDLE":[{"def":"A small water course or gutter.","pos":""}],"RINDLESS":[{"def":"Destitute of a rind.","pos":""}],"RINDY":[{"def":"Having a rind or skin.","pos":""}],"RINED":[{"def":"Having a rind [Obs.","pos":""}],"RINFORZANDO":[{"def":"Increasing; strengthening; -- a direction indicating a sudden increase of force (abbreviated rf.","pos":""}],"RING":[{"def":"To cause to sound, especially by striking, as a metallic body; as, to ring a bell.","pos":""},{"def":"To make (a sound), as by ringing a bell; to sound.","pos":""}],"RING ARMATURE":[{"def":"An armature for a dynamo or motor having the conductors wound on a ring.","pos":""}],"RING WINDING":[{"def":"Armature winding in which the wire is wound round the outer and inner surfaces alternately of an annular or cylindrical core.","pos":""}],"RING-NECKED":[{"def":"Having a well defined ring of color around the neck.","pos":""}],"RING-STREAKED":[{"def":"Having circular streaks or lines on the body; as, ring-streaked goats.","pos":""}],"RING-TAILED":[{"def":"Having the tail crossed by conspicuous bands of color.","pos":""}],"RINGBILL":[{"def":"The ring-necked scaup duck; -- called also ring-billed blackhead.","pos":""}],"RINGBIRD":[{"def":"The reed bunting.","pos":""}],"RINGBOLT":[{"def":"An eyebolt having a ring through the eye.","pos":""}],"RINGBONE":[{"def":"A morbid growth or deposit of bony matter between or on the small pastern and the great pastern bones.","pos":""}],"RINGDOVE":[{"def":"A European wild pigeon (Columba palumbus) having a white crescent on each side of the neck, whence the name.","pos":""}],"RINGED":[{"def":"Encircled or marked with, or as with, a ring or rings.","pos":""},{"def":"Wearning a wedding ring; hence, lawfully wedded.","pos":""}],"RINGENT":[{"def":"Having the lips widely separated and gaping like an open mouth; as a ringent bilabiate corolla.","pos":""}],"RINGER":[{"def":"One who, or that which, rings; especially, one who rings chimes on bells.","pos":""}],"RINGHEAD":[{"def":"An instrument used for stretching woolen cloth.","pos":""}],"RINGING":[{"def":"Ring\"ing, Defn: a & n.","pos":""}],"RINGINGLY":[{"def":"In a ringing manner.","pos":""}],"RINGLEADER":[{"def":"The leader of a circle of dancers; hence, the leader of a number of persons acting together; the leader of a herd of animals.","pos":""},{"def":"Opprobriously, a leader of a body of men engaged in the violation of law or in an illegal enterprise, as rioters, mutineers, or the like.","pos":""}],"RINGLESTONE":[{"def":"The ringed dotterel, or ring plover.","pos":""}],"RINGLET":[{"def":"A small ring; a small circle; specifically, a fairy ring.","pos":""},{"def":"A curl; especially, a curl of hair.","pos":""}],"RINGMAN":[{"def":"The ring finger.","pos":""}],"RINGMASTER":[{"def":"One in charge of the performances (as of horses) within the ring in a circus.","pos":""}],"RINGNECK":[{"def":"Any one of several species of small plovers of the genus Ægialitis, having a ring around the neck.","pos":""},{"def":"The ring-necked duck.","pos":""}],"RINGSTRAKED":[{"def":"Cattle ringstraked, speckled, and spotted.","pos":""}],"RINGTAIL":[{"def":"A bird having a distinct band of color across the tail, as the hen harrier.","pos":""},{"def":"A light sail set abaft and beyong the leech of a boom-and-gaff sail; -- called also ringsail.","pos":""}],"RINGTOSS":[{"def":"A game in which the object is to toss a ring so that it will catch upon an upright stick.","pos":""}],"RINGWORM":[{"def":"A contagious affection of the skin due to the presence of a vegetable parasite, and forming ring-shaped discolored patches covered with vesicles or powdery scales.","pos":""}],"RINK":[{"def":"The smooth and level extent of ice marked off for the game of curling.","pos":""},{"def":"An artificial sheet of ice, generally under cover, used for skating; also, a floor prepared for skating on with roller skates, or a building with such a floor.","pos":""}],"RINKER":[{"def":"One who skates at a rink.","pos":""}],"RINKING":[{"def":"Skating in a rink.","pos":""}],"RINSE":[{"def":"To wash lightly; to cleanse with a second or repeated application of water after washing.","pos":""},{"def":"To cleancse by the introduction of water; -- applied especially to hollow vessels; as, to rinse a bottle.","pos":""}],"RINSER":[{"def":"One who, or that which, rinses.","pos":""}]}