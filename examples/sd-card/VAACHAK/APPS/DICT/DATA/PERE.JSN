{"PEREGRINATE":[{"def":"To travel from place to place, or from one country to another; hence, to sojourn in foreign countries.","pos":""}],"PEREGRINATION":[{"def":"A traveling from one country to another; a wandering; sojourn in foreign countries.","pos":""}],"PEREGRINATOR":[{"def":"One who peregrinates; one who travels about.","pos":""}],"PEREGRINE":[{"def":"Foreign; not native; extrinsic or from without; exotic.","pos":""}],"PEREGRINITY":[{"def":"Foreignness; strangeness.","pos":""},{"def":"Travel; wandering.","pos":""}],"PEREMPT":[{"def":"To destroy; to defeat.","pos":""}],"PEREMPTION":[{"def":"A quashing; a defeating.","pos":""}],"PEREMPTORILY":[{"def":"In a peremptory manner; absolutely; positively.","pos":""}],"PEREMPTORINESS":[{"def":"The quality of being peremptory; positiveness.","pos":""}],"PEREMPTORY":[{"def":"Precluding debate or expostulation; not admitting of question or appeal; positive; absolute; decisive; conclusive; final.","pos":""},{"def":"Positive in opinion or judgment; decided; dictatorial; dogmatical.","pos":""}],"PERENNIAL":[{"def":"Continuing more than two years; as, a perennial steam, or root, or plant.","pos":""}],"PERENNIALLY":[{"def":"In a perennial manner.","pos":""}],"PERENNIBRANCHIATA":[{"def":"Those Batrachia which retain their gills through life, as the menobranchus.","pos":""}],"PERENNIBRANCHIATE":[{"def":"Having branchæ, or gills, through life; -- said especially of certain Amphibia, like the menobranchus.","pos":""},{"def":"Belonging to the Perennibranchiata.","pos":""}],"PERENNITY":[{"def":"The quality of being perennial.","pos":""}],"PERERRATION":[{"def":"A wandering, or rambling, through various places.","pos":""}]}