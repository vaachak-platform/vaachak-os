{"BIVALENCY":[{"def":"The quality of being bivalent.","pos":""}],"BIVALENT":[{"def":"Equivalent in combining or displacing power to two atoms of hydrogen; dyad.","pos":""}],"BIVALVE":[{"def":"A mollusk having a shell consisting of two lateral plates or valves joined together by an elastic ligament at the hinge, which is usually strengthened by prominences called teeth.","pos":""},{"def":"A pericarp in which the seed case opens or splits into two parts or valves.","pos":""}],"BIVALVED":[{"def":"Having two valves, as the oyster and some seed pods; bivalve.","pos":""}],"BIVALVULAR":[{"def":"Having two valves.","pos":""}],"BIVAULTED":[{"def":"Having two vaults or arches.","pos":""}],"BIVIAL":[{"def":"Of or relating to the bivium.","pos":""}],"BIVIOUS":[{"def":"Having, or leading, two ways.","pos":""}],"BIVIUM":[{"def":"One side of an echinoderm, including a pair of ambulacra, in distinction from the opposite side (trivium), which includes three ambulacra.","pos":""}]}