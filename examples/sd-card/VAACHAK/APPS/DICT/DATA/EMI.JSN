{"EMICANT":[{"def":"Beaming forth; flashing.","pos":""}],"EMICATION":[{"def":"A flying off in small particles, as heated iron or fermenting liquors; a sparkling; scintillation.","pos":""}],"EMICTION":[{"def":"The voiding of urine.","pos":""},{"def":"What is voided by the urinary passages; urine.","pos":""}],"EMIGRANT":[{"def":"Removing from one country to another; emigrating; as, an emigrant company or nation.","pos":""},{"def":"Pertaining to an emigrant; used for emigrants; as, an emigrant ship or hospital.","pos":""}],"EMIGRATE":[{"def":"To remove from one country or State to another, for the purpose of residence; to migrate from home.","pos":""}],"EMIGRATION":[{"def":"The act of emigrating; removal from one country or state to another, for the purpose of residence, as from Europe to America, or, in America, from the Atlantic States to the Western.","pos":""},{"def":"A body emigrants; emigrants collectively; as, the German emigration.","pos":""}],"EMIGRATIONAL":[{"def":"Relating to emigration.","pos":""}],"EMIGRATIONIST":[{"def":"An advocate or promoter of emigration.","pos":""}],"EMIGRATOR":[{"def":"One who emigrates; am emigrant.","pos":""}],"EMIGRE":[{"def":"One of the natives of France who were opposed to the first Revolution, and who left their country in consequence.","pos":""}],"EMINENCE":[{"def":"That which is eminent or lofty; a high ground or place; a height.","pos":""},{"def":"An elevated condition among men; a place or station above men in general, either in rank, office, or celebrity; social or moral loftiness; high rank; distinction; preferment.","pos":""}],"EMINENCY":[{"def":"State of being eminent; eminence.","pos":""}],"EMINENT":[{"def":"High; lofty; towering; prominent.","pos":""},{"def":"Being, metaphorically, above others, whether by birth, high station, merit, or virtue; high in public estimation; distinguished; conspicuous; as, an eminent station; an eminent historian, statements, statesman, or saint.","pos":""}],"EMINENTLY":[{"def":"In an eminent manner; in a high degree; conspicuously; as, to be eminently learned.","pos":""},{"def":"An Arabian military commander, independent chieftain, or ruler of a province; also, an honorary title given to the descendants of Mohammed, in the line of his daughter Fatima; among the Turks, likewise, a title of dignity, given to certain high officials.","pos":""}],"EMISSARY":[{"def":"An agent employed to advance, in a covert manner, the interests of his employers; one sent out by any power that is at war with another, to create dissatisfaction among the people of the latter.","pos":""}],"EMISSARYSHIP":[{"def":"The office of an emissary.","pos":""}],"EMISSION":[{"def":"The act of sending or throwing out; the act of sending forth or putting into circulation; issue; as, the emission of light from the sun; the emission of heat from a fire; the emission of bank notes.","pos":""},{"def":"That which is sent out, issued, or put in circulation at one time; issue; as, the emission was mostly blood.","pos":""}],"EMISSITIOUS":[{"def":"Looking, or narrowly examining; prying.","pos":""}],"EMISSIVE":[{"def":"Sending out; emitting; as, emissive powers.","pos":""}],"EMISSIVITY":[{"def":"Tendency to emission; comparative facility of emission, or rate at which emission takes place, as of heat from the surface of a heated body.","pos":""}],"EMISSORY":[{"def":"Same as Emissary, a.","pos":""}],"EMIT":[{"def":"To send forth; to throw or give out; to cause to issue; to give vent to; to eject; to discharge; as, fire emits heat and smoke; boiling water emits steam; the sun emits light.","pos":""},{"def":"To issue forth, as an order or decree; to print and send into circulation, as notes or bills of credit.","pos":""}],"EMITTENT":[{"def":"Sending forth; emissive.","pos":""}]}