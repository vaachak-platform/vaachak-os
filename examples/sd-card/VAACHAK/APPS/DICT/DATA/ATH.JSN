{"ATHALAMOUS":[{"def":"Not furnished with shields or beds for the spores, as the thallus of certain lichens.","pos":""}],"ATHAMAUNT":[{"def":"The quality of being deathless; immortality.","pos":""}],"ATHANASIAN":[{"def":"Of or pertaining to Athanasius, bishop of Alexandria in the 4th century.","pos":""}],"ATHANOR":[{"def":"A digesting furnace, formerly used by alchemists.","pos":""}],"ATHECATA":[{"def":"A division of Hydroidea in which the zooids are naked, or not inclosed in a capsule.","pos":""}],"ATHEISM":[{"def":"The disbelief or denial of the existence of a God, or supreme intelligent Being.","pos":""}],"ATHEIST":[{"def":"One who disbelieves or denies the existence of a God, or supreme intelligent Being.","pos":""},{"def":"A godless person.","pos":""}],"ATHEIZE":[{"def":"To render atheistic or godless.","pos":""}],"ATHELING":[{"def":"An Anglo-Saxon prince or nobleman; esp.","pos":""},{"def":"A temple of Athene, at Athens, in which scholars and poets were accustomed to read their works and instruct students.","pos":""}],"ATHENIAN":[{"def":"Of or pertaining to Athens, the metropolis of Greece.","pos":""}],"ATHEOLOGICAL":[{"def":"Opposed to theology; atheistic.","pos":""}],"ATHEOLOGY":[{"def":"Antagonism to theology.","pos":""}],"ATHEOUS":[{"def":"Atheistic; impious.","pos":""},{"def":"Without God, neither accepting nor denying him.","pos":""}],"ATHERINE":[{"def":"A small marine fish of the family Atherinidæ, having a silvery stripe along the sides.","pos":""}],"ATHERMANCY":[{"def":"Inability to transmit radiant; impermeability to heat.","pos":""}],"ATHERMANOUS":[{"def":"Not transmitting heat; -- opposed to diathermanous.","pos":""}],"ATHEROID":[{"def":"Shaped like an ear of grain.","pos":""}],"ATHEROMATOUS":[{"def":"Of, pertaining to, or having the nature of, atheroma.","pos":""}],"ATHETIZE":[{"def":"To set aside or reject as spurious, as by marking with an obelus.","pos":""}],"ATHETOSIS":[{"def":"A variety of chorea, marked by peculiar tremors of the fingers and toes.","pos":""}],"ATHINK":[{"def":"To repent; to displease; to disgust.","pos":""}],"ATHIRST":[{"def":"Wanting drink; thirsty.","pos":""},{"def":"Having a keen appetite or desire; eager; longing.","pos":""}],"ATHLETE":[{"def":"One who contended for a prize in the public games of ancient Greece or Rome.","pos":""}],"ATHLETIC":[{"def":"Of or pertaining to athletes or to the exercises practiced by them; as, athletic games or sports.","pos":""},{"def":"Befitting an athlete; strong; muscular; robust; vigorous; as, athletic Celts.","pos":""}],"ATHLETICISM":[{"def":"The practice of engaging in athletic games; athletism.","pos":""}],"ATHLETICS":[{"def":"The art of training by athletic exercises; the games and sports of athletes.","pos":""}],"ATHLETISM":[{"def":"The state or practice of an athlete; the characteristics of an athlete.","pos":""}],"ATHREPSIA":[{"def":"Profound debility of children due to lack of food and to unhygienic surroundings.","pos":""}],"ATHWART":[{"def":"Across the direction or course of; as, a fleet standing athwart our course.","pos":""}]}