{"RAZE":[{"def":"A Shakespearean word (used once) supposed to mean the same as race, a root.","pos":""}],"RAZED":[{"def":"Slashed or striped in patterns.","pos":""}],"RAZEE":[{"def":"An armed ship having her upper deck cut away, and thus reduced to the next inferior rate, as a seventy-four cut down to a frigate.","pos":""}],"RAZOR":[{"def":"A task of a wild boar.","pos":""}],"RAZOR-BACKED":[{"def":"Having a sharp, lean, or thin back; as, a razor-backed hog, perch, etc.","pos":""}],"RAZORABLE":[{"def":"Ready for the razor; fit to be shaved.","pos":""}],"RAZURE":[{"def":"The act of erasing or effacing, or the state of being effaced; obliteration.","pos":""},{"def":"An erasure; a change made by erasing.","pos":""}]}