{"ANAPEST":[{"def":"A metrical foot consisting of three syllables, the first two short, or unaccented, the last long, or accented; the reverse of the dactyl.","pos":""}],"ANAPESTIC":[{"def":"Pertaining to an anapest; consisting of an anapests; as, an anapestic meter, foot, verse.","pos":""},{"def":"Anapestic measure or verse.","pos":""}],"ANAPHORA":[{"def":"A repetition of a word or of words at the beginning of two or more successive clauses.","pos":""}],"ANAPHRODISIA":[{"def":"Absence of sexual appetite.","pos":""}],"ANAPHRODISIAC":[{"def":"Same as Antaphrodisiac.","pos":""}],"ANAPHRODITIC":[{"def":"Produced without concourse of sexes.","pos":""}],"ANAPLASTIC":[{"def":"Of or pertaining to anaplasty.","pos":""}],"ANAPLASTY":[{"def":"The art of operation of restoring lost parts or the normal shape by the use of healthy tissue.","pos":""}],"ANAPLEROTIC":[{"def":"Filling up; promoting granulation of wounds or ulcers.","pos":""},{"def":"A remedy which promotes such granulation.","pos":""}],"ANAPNOGRAPH":[{"def":"A form of spirometer.","pos":""}],"ANAPNOIC":[{"def":"Relating to respiration.","pos":""}],"ANAPODEICTIC":[{"def":"Not apodeictic; undemonstrable.","pos":""}],"ANAPOPHYSIS":[{"def":"An accessory process in many lumbar vertebræ.","pos":""}],"ANAPTOTIC":[{"def":"Having lost, or tending to lose, inflections by phonetic decay; as, anaptotic languages.","pos":""}],"ANAPTYCHUS":[{"def":"One of a pair of shelly plates found in some cephalopods, as the ammonites.","pos":""}]}