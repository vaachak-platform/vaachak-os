{"PIC":[{"def":"A Turkish cloth measure, varying from 18 to 28 inches.","pos":""}],"PICA":[{"def":"The genus that includes the magpies.","pos":""},{"def":"A vitiated appetite that craves what is unfit for food, as chalk, ashes, coal, etc.","pos":""}],"PICADOR":[{"def":"A horseman armed with a lance, who in a bullfight receives the first attack of the bull, and excites him by picking him without attempting to kill him.","pos":""}],"PICAMAR":[{"def":"An oily liquid hydrocarbon extracted from the creosote of beechwood tar.","pos":""}],"PICARD":[{"def":"One of a sect of Adamites in the fifteenth century; -- so called from one Picard of Flanders.","pos":""}],"PICARESQUE":[{"def":"Applied to that class of literature in which the principal personage is the Spanish picaro, meaning a rascal, a knave, a rogue, an adventurer.","pos":""}],"PICARIAE":[{"def":"An extensive division of birds which includes the woodpeckers, toucans, trogons, hornbills, kingfishers, motmots, rollers, and goatsuckers.","pos":""}],"PICARIAN":[{"def":"Of or pertaining to Picariæ.","pos":""},{"def":"One of the Picariæ.","pos":""}],"PICAROON":[{"def":"One who plunders; especially, a plunderer of wrecks; a pirate; a corsair; a marauder; a sharper.","pos":""}],"PICAYUNE":[{"def":"A small coin of the value of six and a quarter cents.","pos":""}],"PICAYUNISH":[{"def":"Petty; paltry; mean; as, a picayunish business.","pos":""},{"def":"A high, stiff collar for the neck; also, a hem or band about the skirt of a garment, -- worn by men in the 17th century.","pos":""}],"PICCAGE":[{"def":"Money paid at fairs for leave to break ground for booths.","pos":""}],"PICCALILLI":[{"def":"A pickle of various vegetables with pungent species, -- originally made in the East Indies.","pos":""}],"PICCOLO":[{"def":"A small, shrill flute, the pitch of which is an octave higher than the ordinary flute; an octave flute.","pos":""},{"def":"A small upright piano.","pos":""}],"PICE":[{"def":"A small copper coin of the East Indies, worth less than a cent.","pos":""}],"PICEA":[{"def":"A genus of coniferous trees of the northen hemisphere, including the Norway spruce and the American black and white spruces.","pos":""}],"PICEOUS":[{"def":"Of or pertaining to pitch; resembling pitch in color or quality; pitchy.","pos":""}],"PICHEY":[{"def":"A Brazilian armadillo (Dasypus minutus); the little armadillo.","pos":""}],"PICHICIAGO":[{"def":"A small, burrowing, South American edentate (Chlamyphorus truncatus), allied to the armadillos.","pos":""}],"PICHURIM BEAN":[{"def":"The seed of a Brazilian lauraceous tree (Nectandra Puchury) of a taste and smell between those of nutmeg and of sassafras, -- sometimes used medicinally.","pos":""}],"PICI":[{"def":"A division of birds including the woodpeckers and wrynecks.","pos":""}],"PICIFORM":[{"def":"Of or pertaining to Piciformes.","pos":""}],"PICIFORMES":[{"def":"A group of birds including the woodpeckers, toucans, barbets, colies, kingfishes, hornbills, and some other related groups.","pos":""}],"PICINE":[{"def":"Of or pertaining to the woodpeckers (Pici), or to the Piciformes.","pos":""}],"PICK":[{"def":"To throw; to pitch.","pos":""},{"def":"To peck at, as a bird with its beak; to strike at with anything pointed; to act upon with a pointed instrument; to pierce; to prick, as with a pin.","pos":""}],"PICK-FAULT":[{"def":"One who seeks out faults.","pos":""}],"PICK-ME-UP":[{"def":"A stimulant, restorative, or tonic; a bracer.","pos":""}],"PICKABACK":[{"def":"On the back or shoulders; as, to ride pickback.","pos":""}],"PICKANINNY":[{"def":"A small child; especially, a negro or mulatto infant.","pos":""}],"PICKAPACK":[{"def":"A pick with a point at one end, a transverse edge or blade at the other, and a handle inserted at the middle; a hammer with a flattened end for driving wedges and a pointed end for piercing as it strikes.","pos":""}],"PICKED":[{"def":"Having a pike or spine on the back; -- said of certain fishes.","pos":""}],"PICKEDNESS":[{"def":"The state of being sharpened; pointedness.","pos":""},{"def":"Fineness; spruceness; smartness.","pos":""}],"PICKEER":[{"def":"To make a raid for booty; to maraud; also, to skirmish in advance of an army.","pos":""}],"PICKEERER":[{"def":"One who pickeers.","pos":""}],"PICKER":[{"def":"A machine for picking fibrous materials to pieces so as to loosen and separate the fiber.","pos":""},{"def":"The piece in a loom which strikes the end of the shuttle, and impels it through the warp.","pos":""}],"PICKEREL":[{"def":"A young or small pike.","pos":""}],"PICKERING":[{"def":"The sauger of the St.","pos":""}],"PICKET":[{"def":"A detached body of troops serving to guard an army from surprise, and to oppose reconnoitering parties of the enemy; -- called also outlying picket.","pos":""}],"PICKING":[{"def":"The pulverized shells of oysters used in making walks.","pos":""},{"def":"Rough sorting of ore.","pos":""}],"PICKLE":[{"def":"A bath of dilute sulphuric or nitric acid, etc.","pos":""}],"PICKLE-HERRING":[{"def":"A herring preserved in brine; a pickled herring.","pos":""},{"def":"A merry-andrew; a buffoon.","pos":""}],"PICKLED":[{"def":"Preserved in a pickle.","pos":""}],"PICKLER":[{"def":"One who makes pickles.","pos":""}],"PICKLOCK":[{"def":"An instrument for picking locks.","pos":""},{"def":"One who picks locks; a thief.","pos":""}],"PICKMIRE":[{"def":"The pewit, or black-headed gull.","pos":""}],"PICKPENNY":[{"def":"A miser; also, a sharper.","pos":""}],"PICKPOCKET":[{"def":"One who steals purses or other articles from pockets.","pos":""}],"PICKPURSE":[{"def":"One who steals purses, or money from purses.","pos":""}],"PICKTHANK":[{"def":"One who strives to put another under obligation; an officious person; hence, a flatterer.","pos":""}],"PICKTOOTH":[{"def":"Act of picking up, as, in various games, the fielding or hitting of a ball just after it strikes the ground.","pos":""},{"def":"That which picks up; specif.","pos":""}],"PICNIC":[{"def":"Formerly, an entertainment at which each person contributed some dish to a common table; now, an excursion or pleasure party in which the members partake of a collation or repast (usually in the open air, and from food carried by themselves).","pos":""}],"PICNICKER":[{"def":"One who takes part in a picnic.","pos":""}],"PICOID":[{"def":"Like or pertaining to the Pici.","pos":""}],"PICOLINE":[{"def":"Any one of three isometric bases (C6H7N) related to pyridine, and obtained from bone oil, acrolein ammonia, and coal-tar naphtha, as colorless mobile liquids of strong odor; -- called also methyl pyridine.","pos":""}],"PICOT":[{"def":"One of many small loops, as of thread, forming an ornamental border, as on a ribbon.","pos":""},{"def":"A variety of carnation having petals of a light color variously dotted and spotted at the edges.","pos":""}],"PICRA":[{"def":"The powder of aloes with canella, formerly officinal, employed as a cathartic.","pos":""}],"PICRATE":[{"def":"A salt of picric acid.","pos":""}],"PICRIC":[{"def":"Pertaining to, or designating, a strong organic acid (called picric acid), intensely bitter.","pos":""}],"PICRITE":[{"def":"A dark green igneous rock, consisting largely of chrysolite, with hornblende, augite, biotite, etc.","pos":""}],"PICROLITE":[{"def":"A fibrous variety of serpentine.","pos":""}],"PICROMEL":[{"def":"A colorless viscous substance having a bitter-sweet taste.","pos":""}],"PICROTOXIN":[{"def":"A bitter white crystalline substance found in the cocculus indicus.","pos":""}],"PICRYL":[{"def":"The hypothetical radical of picric acid, analogous to phenyl.","pos":""}],"PICTISH":[{"def":"Of or pertaining to Picts; resembling the Picts.","pos":""}],"PICTOGRAPH":[{"def":"A picture or hieroglyph representing and expressing an idea.","pos":""}],"PICTORIAL":[{"def":"Of or pertaining to pictures; illustrated by pictures; forming pictures; representing with the clearness of a picture; as, a pictorial dictionary; a pictorial imagination.","pos":""}],"PICTS":[{"def":"A race of people of uncertain origin, who inhabited Scotland in early times.","pos":""}],"PICTURA":[{"def":"Pattern of coloration.","pos":""}],"PICTURABLE":[{"def":"Capable of being pictured, or represented by a picture.","pos":""}],"PICTURE":[{"def":"The art of painting; representation by painting.","pos":""},{"def":"A representation of anything (as a person, a landscape, a building) upon canvas, paper, or other surface, produced by means of painting, drawing, engraving, photography, etc.","pos":""}],"PICTURED":[{"def":"Furnished with pictures; represented by a picture or pictures; as, a pictured scene.","pos":""}],"PICTURER":[{"def":"One who makes pictures; a painter.","pos":""}],"PICTURESQUE":[{"def":"What is picturesque as placed in relation to the beautiful and the sublime It is .","pos":""}],"PICTURESQUISH":[{"def":"Somewhat picturesque.","pos":""}],"PICTURIZE":[{"def":"To adorn with pictures.","pos":""}],"PICUL":[{"def":"A commercial weight varying in different countries and for different commodities.","pos":""}],"PICULET":[{"def":"Any species of very small woodpeckers of the genus Picumnus and allied genera.","pos":""}],"PICUS":[{"def":"A genus of woodpeckers, including some of the common American and European species.","pos":""}]}