{"HABEAS CORPUS":[{"def":"A writ having for its object to bring a party before a court or judge; especially, one to inquire into the cause of a person's imprisonment or detention by another, with the view to protect the right to personal liberty; also, one to bring a prisoner into court to testify in a pending trial.","pos":""}],"HABENDUM":[{"def":"That part of a deed which follows the part called the premises, and determines the extent of the interest or estate granted; -- so called because it begins with the word Habendum.","pos":""}],"HABERDASH":[{"def":"To deal in small wares.","pos":""}],"HABERDASHER":[{"def":"A dealer in small wares, as tapes, pins, needles, and thread; also, a hatter.","pos":""},{"def":"A dealer in drapery goods of various descriptions, as laces, silks, trimmings, etc.","pos":""}],"HABERDASHERY":[{"def":"The goods and wares sold by a haberdasher; also (Fig.","pos":""}],"HABERDINE":[{"def":"A cod salted and dried.","pos":""}],"HABERGEON":[{"def":"Properly, a short hauberk, but often used loosely for the hauberk.","pos":""}],"HABILATORY":[{"def":"Of or pertaining to clothing; wearing clothes.","pos":""}],"HABILE":[{"def":"Fit; qualified; also, apt.","pos":""}],"HABILIMENT":[{"def":"Dress, in general.","pos":""}],"HABILITATE":[{"def":"Qualified or entitled.","pos":""}],"HABILITATION":[{"def":"Equipment; qualification.","pos":""}],"HABILITY":[{"def":"Ability; aptitude.","pos":""}],"HABIT":[{"def":"The general appearance and manner of life of a living organism.","pos":""}],"HABITABLE":[{"def":"Capable of being inhabited; that may be inhabited or dwelt in; as, the habitable world.","pos":""}],"HABITAN":[{"def":"Same as Habitant, 2.","pos":""}],"HABITANCE":[{"def":"Dwelling; abode; residence.","pos":""}],"HABITANCY":[{"def":"Same as Inhabitancy.","pos":""}],"HABITANT":[{"def":"An inhabitant or resident; -- a name applied to and denoting farmers of French descent or origin in Canada, especially in the Province of Quebec; -- usually in plural.","pos":"verb"}],"HABITAT":[{"def":"The natural abode, locality or region of an animal or plant.","pos":""}],"HABITATION":[{"def":"The act of inhabiting; state of inhabiting or dwelling, or of being inhabited; occupancy.","pos":""},{"def":"Place of abode; settled dwelling; residence; house.","pos":""}],"HABITATOR":[{"def":"A dweller; an inhabitant.","pos":""}],"HABITED":[{"def":"Clothed; arrayed; dressed; as, he was habited like a shepherd.","pos":""},{"def":"Fixed by habit; accustomed.","pos":""}],"HABITUAL":[{"def":"Formed or acquired by habit or use.","pos":""},{"def":"According to habit; established by habit; customary; constant; as, the habiual practice of sin.","pos":""}],"HABITUATE":[{"def":"To make accustomed; to accustom; to familiarize.","pos":""},{"def":"To settle as an inhabitant.","pos":""}],"HABITUATION":[{"def":"The act of habituating, or accustoming; the state of being habituated.","pos":""}],"HABITUDE":[{"def":"Habitual attitude; usual or accustomed state with reference to something else; established or usual relations.","pos":""},{"def":"Habitual association, intercourse, or familiarity.","pos":""}],"HABITUE":[{"def":"One who habitually frequents a place; as, an habitué of a theater.","pos":""}],"HABITUS":[{"def":"Habitude; mode of life; general appearance.","pos":""}]}