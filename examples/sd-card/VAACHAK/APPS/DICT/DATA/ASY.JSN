{"ASYLUM":[{"def":"A sanctuary or place of refuge and protection, where criminals and debtors found shelter, and from which they could not be forcibly taken without sacrilege.","pos":""},{"def":"Any place of retreat and security.","pos":""}],"ASYMMETRAL":[{"def":"Incommensurable; also, unsymmetrical.","pos":""}],"ASYMMETRY":[{"def":"Incommensurability.","pos":""}],"ASYMPTOTE":[{"def":"A line which approaches nearer to some curve than assignable distance, but, though infinitely extended, would never meet it.","pos":""}],"ASYNARTETE":[{"def":"Disconnected; not fitted or adjusted.","pos":""}],"ASYNCHRONOUS":[{"def":"Not simultaneous; not concurrent in time; --opposed to synchronous.","pos":""}],"ASYNDETIC":[{"def":"Characterized by the use of asyndeton; not connected by conjunctions.","pos":""}],"ASYNDETON":[{"def":"A figure which omits the connective; as, I came, I saw, I conquered.","pos":""}],"ASYSTOLE":[{"def":"A weakening or cessation of the contractile power of the heart.","pos":""}],"ASYSTOLISM":[{"def":"The state or symptoms characteristic of asystole.","pos":""}]}