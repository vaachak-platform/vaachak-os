{"ON":[{"def":"The general signification of on is situation, motion, or condition with respect to contact or support beneath; as: -- 1.","pos":""}],"ON DIT":[{"def":"They say, or it is said.","pos":""},{"def":"A flying report; rumor; as, it is a mere on dit.","pos":""}],"ON-LOOKING":[{"def":"Looking on or forward.","pos":""}],"ONAGER":[{"def":"A military engine acting like a sling, which threw stones from a bag or wooden bucket, and was operated by machinery.","pos":""},{"def":"A wild ass, especially the koulan.","pos":""}],"ONAGGA":[{"def":"Pertaining to, or resembling, a natural order of plants (Onagraceæ or Onagrarieæ), which includes the fuchsia, the willow- herb (Epilobium), and the evening primrose ().","pos":""}],"ONANISM":[{"def":"Self-pollution; masturbation.","pos":""}],"ONAPPO":[{"def":"A nocturnal South American monkey (Callithrix discolor), noted for its agility; -- called also ventriloquist monkey.","pos":""}],"ONCE":[{"def":"By limitation to the number one; for one time; not twice nor any number of times more than one.","pos":""},{"def":"At some one period of time; -- used indefinitely.","pos":""}],"ONCIDIUM":[{"def":"A genus of tropical orchidaceous plants, the flower of one species of which (O.","pos":""}],"ONCOGRAPH":[{"def":"An instrument for registering the changes observable with an oncometer.","pos":""}],"ONCOMETER":[{"def":"An instrument for measuring the variations in size of the internal organs of the body, as the kidney, spleen, etc.","pos":""}],"ONCOTOMY":[{"def":"The opening of an abscess, or the removal of a tumor, with a cutting instrument.","pos":""}],"ONDE":[{"def":"Hatred; fury; envy.","pos":""}],"ONDOGRAM":[{"def":"The record of an ondograph.","pos":""}],"ONDOGRAPH":[{"def":"An instrument for autographically recording the wave forms of varying currents, esp.","pos":""}],"ONDOMETER":[{"def":"An electric wave meter.","pos":""}],"ONDOYANT":[{"def":"Wavy; having the surface marked by waves or slightly depressed furrows; as, ondoyant glass.","pos":""},{"def":"A suffix indicating that the substance, in the name of which it appears, is a ketone; as, acetone.","pos":""}],"ONE":[{"def":"Being a single unit, or entire being or thing, and no more; not multifold; single; individual.","pos":""},{"def":"Denoting a person or thing conceived or spoken of indefinitely; a certain.","pos":""}],"ONE-HAND":[{"def":"Employing one hand; as, the one-hand alphabet.","pos":""}],"ONE-HORSE":[{"def":"Drawn by one horse; having but a single horse; as, a one-horse carriage.","pos":""},{"def":"Second-rate; inferior; small.","pos":""}],"ONE-SIDED":[{"def":"Growing on one side of a stem; as, one-sided flowers.","pos":""}],"ONEIDAS":[{"def":"A tribe of Indians formerly inhabiting the region near Oneida Lake in the State of New York, and forming part of the Five Nations.","pos":""}],"ONEIROCRITIC":[{"def":"An interpreter of dreams.","pos":""},{"def":"Of or pertaining to the interpretation of dreams.","pos":""}],"ONEIROMANCY":[{"def":"Divination by means of dreams.","pos":""}],"ONEIROSCOPIST":[{"def":"One who interprets dreams.","pos":""}],"ONEIROSCOPY":[{"def":"The interpretation of dreams.","pos":""}],"ONELINESS":[{"def":"The state of being one or single.","pos":""}],"ONEMENT":[{"def":"The state of being at one or reconciled.","pos":""}],"ONENESS":[{"def":"The state of being one; singleness in number; individuality; unity.","pos":""}],"ONERARY":[{"def":"Fitted for, or carrying, a burden.","pos":""}],"ONERATE":[{"def":"To load; to burden.","pos":""}],"ONERATION":[{"def":"The act of loading.","pos":""}],"ONEROUS":[{"def":"Burdensome; oppressive.","pos":""}],"ONEROUSLY":[{"def":"In an onerous manner.","pos":""}],"ONESELF":[{"def":"A reflexive form of the indefinite pronoun one.","pos":""}],"ONGOING":[{"def":"The act of going forward; progress; (pl.","pos":""}],"ONION":[{"def":"A liliaceous plant of the genus Allium (A.","pos":""}],"ONIONSKIN":[{"def":"A kind of thin translucent paper with a glossy finish.","pos":""}],"ONIROCRITIC":[{"def":"See Oneirocritic.","pos":""}],"ONLINESS":[{"def":"The state of being alone.","pos":""}],"ONLOFT":[{"def":"Aloft; above ground.","pos":""}],"ONLY":[{"def":"One alone; single; as, the only man present; his only occupation.","pos":""},{"def":"Alone in its class; by itself; not associated with others of the same class or kind; as, an only child.","pos":""}],"ONOCERIN":[{"def":"A white crystalline waxy substance extracted from the root of the leguminous plant Ononis spinosa.","pos":""}],"ONOLOGY":[{"def":"Foolish discourse.","pos":""}],"ONOMANCY":[{"def":"Divination by the letters of a name; nomancy.","pos":""},{"def":"Of or pertaining to onomancy.","pos":""}],"ONOMASTIC":[{"def":"Applied to a signature when the body of the instrument is in another's handwriting.","pos":""}],"ONOMASTICON":[{"def":"A collection of names and terms; a dictionary; specif.","pos":""}],"ONOMATECHNY":[{"def":"Prognostication by the letters of a name.","pos":""}],"ONOMATOLOGIST":[{"def":"One versed in the history of names.","pos":""}],"ONOMATOLOGY":[{"def":"The science of names or of their classification.","pos":""}],"ONOMATOPE":[{"def":"An imitative word; an onomatopoetic word.","pos":""}],"ONOMATOPOEIA":[{"def":"The formation of words in imitation of sounds; a figure of speech in which the sound of a word is imitative of the sound of the thing which the word represents; as, the buzz of bees; the hiss of a goose; the crackle of fire.","pos":""}],"ONOMATOPOETIC":[{"def":"Of or pertaining to onomatopoeia; characterized by onomatopoeia; imitative; as, an onomatopoetic writer or word.","pos":""}],"ONONDAGAS":[{"def":"A tribe of Indians formerly inhabiting what is now a part of the State of New York.","pos":""}],"ONRUSH":[{"def":"A rushing onward.","pos":""}],"ONSET":[{"def":"A rushing or setting upon; an attack; an assault; a storming; especially, the assault of an army.","pos":""},{"def":"A setting about; a beginning.","pos":""}],"ONSLAUGHT":[{"def":"An attack; an onset; esp.","pos":""},{"def":"A bloody fray or battle.","pos":""}],"ONSTEAD":[{"def":"A single farmhouse; a steading.","pos":""}],"ONTO":[{"def":"On the top of; upon; on.","pos":""},{"def":"The history of the individual development of an organism; the history of the evolution of the germ; the development of an individual organism, -- in distinction from phylogeny, or evolution of the tribe.","pos":""}],"ONTOGENETIC":[{"def":"Of or pertaining to ontogenesis; as, ontogenetic phenomena.","pos":""}],"ONTOLOGICAL":[{"def":"Of or pertaining to ontology.","pos":""}],"ONTOLOGICALLY":[{"def":"In an ontological manner.","pos":""}],"ONTOLOGIST":[{"def":"One who is versed in or treats of ontology.","pos":""}],"ONTOLOGY":[{"def":"That department of the science of metaphysics which investigates and explains the nature and essential properties and relations of all beings, as such, or the principles and causes of being.","pos":""}],"ONUS":[{"def":"A burden; an obligation.","pos":""}],"ONWARD":[{"def":"Moving in a forward direction; tending toward a contemplated or desirable end; forward; as, an onward course, progress, etc.","pos":""},{"def":"Advanced in a forward direction or toward an end.","pos":""}],"ONWARDNESS":[{"def":"Progress; advancement.","pos":""}],"ONYCHA":[{"def":"An ingredient of the Mosaic incense, probably the operculum of some kind of strombus.","pos":""},{"def":"The precious stone called onyx.","pos":""}],"ONYCHOMANCY":[{"def":"Divination by the nails.","pos":""}],"ONYX":[{"def":"Chalcedony in parallel layers of different shades of color.","pos":""}]}