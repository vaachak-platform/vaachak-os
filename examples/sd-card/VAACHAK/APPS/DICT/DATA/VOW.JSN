{"VOW":[{"def":"A solemn promise made to God, or to some deity; an act by which one consecrates or devotes himself, absolutely or conditionally, wholly or in part, for a longer or shorter time, to some act, service, or condition; a devotion of one's possessions; as, a baptismal vow; a vow of poverty.","pos":""},{"def":"Specifically, a promise of fidelity; a pledge of love or affection; as, the marriage vow.","pos":""}],"VOW-FELLOW":[{"def":"One bound by the same vow as another.","pos":""}],"VOWEL":[{"def":"Pronunciation, §§ 5, 146-149.","pos":""}],"VOWELED":[{"def":"Furnished with vowels.","pos":""}],"VOWELISH":[{"def":"Of the nature of a vowel.","pos":""}],"VOWELISM":[{"def":"The use of vowels.","pos":""}],"VOWELIZE":[{"def":"To give the quality, sound, or office of a vowel to.","pos":""}],"VOWER":[{"def":"One who makes a vow.","pos":""}]}