{"KOALA":[{"def":"A tailless marsupial (Phascolarctos cinereus), found in Australia.","pos":""},{"def":"Any one of several species of African antelopes of the genus Kobus, esp.","pos":""}],"KOBELLITE":[{"def":"A blackish gray mineral, a sulphide of antimony, bismuth, and lead.","pos":""}],"KOBOLD":[{"def":"A kind of domestic spirit in German mythology, corresponding to the Scottish brownie and the English Robin Goodfellow.","pos":""}],"KODAK":[{"def":"A kind of portable camera.","pos":""}],"KOEL":[{"def":"Any one of several species of cuckoos of the genus Eudynamys, found in India, the East Indies, and Australia.","pos":""}],"KOFF":[{"def":"A two-masted Dutch vessel.","pos":""}],"KOFTGARI":[{"def":"Ornamental work produced by inlaying steel with gold, -- a variety of damascening much used in the arts of India.","pos":""},{"def":"A famous diamond, surrendered to the British crown on the annexation of the Punjab.","pos":""}],"KOHL":[{"def":"A mixture of soot and other ingredients, used by Egyptian and other Eastern women to darken the edges of the eyelids.","pos":""}],"KOHL-RABI":[{"def":"A variety of cabbage, in which the edible part is a large, turnip-shaped swelling of the stem, above the surface of the ground.","pos":""}],"KOKLASS":[{"def":"Any pheasant of the genus Pucrasia.","pos":""}],"KOKOON":[{"def":"Same as Cola, Cola nut.","pos":""}],"KOLARIAN":[{"def":"An individual of one of the races of aboriginal inhabitants which survive in Hindostan.","pos":""},{"def":"Of or pertaining to the Kolarians.","pos":""}],"KOLINSKY":[{"def":"Among furriers, any of several Asiatic minks; esp.","pos":""},{"def":"Designating, or pert.","pos":""}],"KOMENIC":[{"def":"Of or pertaining to, or designating, an acid derived from meconic acid.","pos":""}],"KOMTOK":[{"def":"An African freshwater fish (Protopterus annectens), belonging to the Dipnoi.","pos":""}],"KON":[{"def":"Ye konnen thereon as much as any man.","pos":""}],"KONSEAL":[{"def":"A form of capsule for inclosing a dose of medicine that is offensive, caustic, or the like.","pos":""}],"KONZE":[{"def":"A large African antelope (Alcelaphus Lichtensteini), allied to the hartbeest, but having shorter and flatter horns, and lacking a black patch on the face.","pos":""}],"KOODOO":[{"def":"A large South African antelope (Strepsiceros kudu).","pos":""}],"KOOKOOM":[{"def":"The oryx or gemsbok.","pos":""}],"KOOLOKAMBA":[{"def":"A west African anthropoid ape (Troglodytes koolokamba, or T.","pos":""}],"KOORILIAN":[{"def":"Same as Kurilian.","pos":""}],"KOPECK":[{"def":"A small Russian coin.","pos":""}],"KOPJE":[{"def":"A hillock; a small kop.","pos":""}],"KORAN":[{"def":"The Scriptures of the Mohammedans, containing the professed revelations to Mohammed; -- called also Alcoran.","pos":""}],"KORRIGUM":[{"def":"A West African antelope (Damalis Senegalensis), allied to the sassaby.","pos":""}],"KOSHER":[{"def":"Ceremonially clean, according to Jewish law; --applied to food, esp.","pos":""}],"KOTOW":[{"def":"The prostration made by mandarins and others to their superiors, either as homage or worship, by knocking the forehead on the ground.","pos":""}],"KOULAN":[{"def":"A wild horse (Equus, or Asinus, onager) inhabiting the plants of Central Asia; -- called also gour, khur, and onager.","pos":""}],"KOUMISS":[{"def":"An intoxicating fermented or distilled liquor originally made by the Tartars from mare's or camel's milk.","pos":""}],"KOUSSO":[{"def":"An Abyssinian rosaceous tree (Brayera anthelmintica), the flowers of which are used as a vermifuge.","pos":""}],"KOWTOW":[{"def":"The same as Kotow.","pos":""}]}