{"CANDELABRUM":[{"def":"A large candlestick, having several branches.","pos":""}],"CANDENT":[{"def":"Heated to whiteness; glowing with heat.","pos":""}],"CANDEROS":[{"def":"An East Indian resin, of a pellucid white color, from which small ornaments and toys are sometimes made.","pos":""}],"CANDESCENCE":[{"def":"See Inclandescence.","pos":""}],"CANDESCENT":[{"def":"Glowing; luminous; incandescent.","pos":""}],"CANDID":[{"def":"Free from undue bias; disposed to think and judge according to truth and justice, or without partiality or prejudice; fair; just; impartial; as, a candid opinion.","pos":""}],"CANDIDACY":[{"def":"The position of a candidate; state of being a candidate; candidateship.","pos":""}],"CANDIDATE":[{"def":"One who offers himself, or is put forward by others, as a suitable person or an aspirant or contestant for an office, privilege, or honor; as, a candidate for the office of governor; a candidate for holy orders; a candidate for scholastic honors.","pos":""}],"CANDIDATING":[{"def":"The taking of the position of a candidate; specifically, the preaching of a clergyman with a view to settlement.","pos":""}],"CANDIDLY":[{"def":"In a candid manner.","pos":""}],"CANDIDNESS":[{"def":"The quality of being candid.","pos":""}],"CANDIED":[{"def":"Preserved in or with sugar; incrusted with a candylike substance; as, candied fruits.","pos":""},{"def":"Covered or incrusted with that which resembles sugar or candy.","pos":""}],"CANDIFY":[{"def":"To make or become white, or candied.","pos":""}],"CANDIOT":[{"def":"Of or pertaining to Candia; Cretary.","pos":""}],"CANDITE":[{"def":"A variety of spinel, of a dark color, found at Candy, in Ceylon.","pos":""}],"CANDLE":[{"def":"A slender, cylindrical body of tallow, containing a wick composed of loosely twisted linen of cotton threads, and used to furnish light.","pos":""},{"def":"That which gives light; a luminary.","pos":""}],"CANDLE COAL":[{"def":"See Cannel coal.","pos":""}],"CANDLE FOOT":[{"def":"The illumination produced by a British standard candle at a distance of one foot; --used as a unit of illumination.","pos":""}],"CANDLE METER":[{"def":"The illumination given by a standard candle at a distance of one meter; -- used as a unit of illumination, except in Great Britain.","pos":""}],"CANDLE POWER":[{"def":"Illuminating power, as of a lamp, or gas flame, reckoned in terms of the light of a standard candle.","pos":""}],"CANDLEBERRY TREE":[{"def":"A shrub (the Myrica cerifera, or wax-bearing myrtle), common in North America, the little nuts of which are covered with a greenish white wax, which was formerly, used for hardening candles; -- also called bayberry tree, bayberry, or candleberry.","pos":""}],"CANDLEBOMB":[{"def":"A small glass bubble, filled with water, which, if placed in the flame of a candle, bursts by expansion of steam.","pos":""},{"def":"A pasteboard shell used in signaling.","pos":""}],"CANDLEHOLDER":[{"def":"One who, or that which, holds a candle; also, one who assists another, but is otherwise not of importance.","pos":""}],"CANDLELIGHT":[{"def":"The light of a candle.","pos":""}],"CANDLEMAS":[{"def":"The second day of February, on which is celebrated the feast of the Purification of the Virgin Mary; -- so called because the candles for the altar or other sacred uses are blessed on that day.","pos":""}],"CANDLENUT":[{"def":"The fruit of a euphorbiaceous tree or shrub (Aleurites moluccana), native of some of the Pacific islands.","pos":""},{"def":"The tree itself.","pos":""}],"CANDLESTICK":[{"def":"An instrument or utensil for supporting a candle.","pos":""}],"CANDLEWASTER":[{"def":"One who consumes candles by being up late for study or dissipation.","pos":""}],"CANDOCK":[{"def":"A plant or weed that grows in rivers; a species of of Equisetum; also, the yellow frog lily (Nuphar luteum).","pos":""}],"CANDOR":[{"def":"Whiteness; brightness; (as applied to moral conditions) usullied purity; innocence.","pos":""},{"def":"A disposition to treat subjects with fairness; freedom from prejudice or disguise; frankness; sincerity.","pos":""}],"CANDROY":[{"def":"A machine for spreading out cotton cloths to prepare them for printing.","pos":""}],"CANDY":[{"def":"To conserve or boil in sugar; as, to candy fruits; to candy ginger.","pos":""},{"def":"To make sugar crystals of or in; to form into a mass resembling candy; as, to candy sirup.","pos":""}],"CANDYTUFT":[{"def":"An annual plant of the genus Iberis, cultivated in gardens.","pos":""}]}