{"PLESH":[{"def":"A pool; a plash.","pos":""}],"PLESIMORPHISM":[{"def":"The property possessed by some substances of crystallizing in closely similar forms while unlike in chemical composition.","pos":""}],"PLESIOMORPHOUS":[{"def":"Nearly alike in form.","pos":""}],"PLESIOSAUR":[{"def":"One of the Plesiosauria.","pos":""}],"PLESIOSAURIA":[{"def":"An extinct order of Mesozoic marine reptiles including the genera Plesiosaurus, and allied forms; -- called also Sauropterygia.","pos":""}],"PLESIOSAURIAN":[{"def":"Ple`si*o*sau\"ri*an, n.","pos":""}],"PLESIOSAURUS":[{"def":"A genus of large extinct marine reptiles, having a very long neck, a small head, and paddles for swimming.","pos":""}]}