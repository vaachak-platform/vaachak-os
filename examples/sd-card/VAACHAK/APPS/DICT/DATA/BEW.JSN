{"BEWAIL":[{"def":"To express deep sorrow for, as by wailing; to lament; to wail over.","pos":""}],"BEWAILABLE":[{"def":"Such as may, or ought to, be bewailed; lamentable.","pos":""}],"BEWAILER":[{"def":"One who bewails or laments.","pos":""}],"BEWAILING":[{"def":"Wailing over; lamenting.","pos":""}],"BEWAILMENT":[{"def":"The act of bewailing.","pos":""}],"BEWAKE":[{"def":"To keep watch over; to keep awake.","pos":""}],"BEWARE":[{"def":"To be on one's guard; to be cautious; to take care; -- commonly followed by of or lest before the thing that is to be avoided.","pos":""},{"def":"To have a special regard; to heed.","pos":""}],"BEWASH":[{"def":"To drench or souse with water.","pos":""}],"BEWEEP":[{"def":"To weep over; to deplore; to bedew with tears.","pos":""}],"BEWET":[{"def":"To wet or moisten.","pos":""}],"BEWHORE":[{"def":"To corrupt with regard to chastity; to make a whore of.","pos":""},{"def":"To pronounce or characterize as a whore.","pos":""}],"BEWIG":[{"def":"To cover (the head) with a wig.","pos":""}],"BEWILDER":[{"def":"To lead into perplexity or confusion, as for want of a plain path; to perplex with mazes; or in general, to perplex or confuse greatly.","pos":""}],"BEWILDERED":[{"def":"Greatly perplexed; as, a bewildered mind.","pos":""}],"BEWILDEREDNESS":[{"def":"The state of being bewildered; bewilderment.","pos":""}],"BEWILDERING":[{"def":"Causing bewilderment or great perplexity; as, bewildering difficulties.","pos":""}],"BEWILDERMENT":[{"def":"The state of being bewildered.","pos":""},{"def":"A bewildering tangle or confusion.","pos":""}],"BEWIT":[{"def":"A double slip of leather by which bells are fastened to a hawk's legs.","pos":""}],"BEWITCH":[{"def":"To gain an ascendency over by charms or incantations; to affect (esp.","pos":""},{"def":"To charm; to fascinate; to please to such a degree as to take away the power of resistance; to enchant.","pos":""}],"BEWITCHEDNESS":[{"def":"The state of being bewitched.","pos":""}],"BEWITCHER":[{"def":"One who bewitches.","pos":""}],"BEWITCHERY":[{"def":"The power of bewitching or fascinating; bewitchment; charm; fascination.","pos":""}],"BEWITCHING":[{"def":"Having power to bewitch or fascinate; enchanting; captivating; charming.","pos":""}],"BEWITCHMENT":[{"def":"The act of bewitching, or the state of being bewitched.","pos":""},{"def":"The power of bewitching or charming.","pos":""}],"BEWONDER":[{"def":"To fill with wonder.","pos":""},{"def":"To wonder at; to admire.","pos":""}],"BEWRAP":[{"def":"To wrap up; to cover.","pos":""}],"BEWRAY":[{"def":"To expose; to reveal; to disclose; to betray.","pos":""}],"BEWRAYER":[{"def":"One who, or that which, bewrays; a revealer.","pos":""}],"BEWREKE":[{"def":"To wreak; to avenge.","pos":""}]}