{"SHOCK":[{"def":"A lot consisting of sixty pieces; -- a term applied in some Baltic ports to loose goods.","pos":""}],"SHOCK-HEADED":[{"def":"Having a thick and bushy head of hair.","pos":""}],"SHOCKDOG":[{"def":"See 7th Shock, 1.","pos":""}],"SHOCKING":[{"def":"Causing to shake or tremble, as by a blow; especially, causing to recoil with horror or disgust; extremely offensive or disgusting.","pos":""}]}