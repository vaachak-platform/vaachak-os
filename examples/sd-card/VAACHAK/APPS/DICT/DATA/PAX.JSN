{"PAX":[{"def":"The kiss of peace; also, the embrace in the sanctuary now substituted for it at High Mass in Roman Catholic churches.","pos":""},{"def":"A tablet or board, on which is a representation of Christ, of the Virgin Mary, or of some saint and which, in the Mass, was kissed by the priest and then by the people, in mediæval times; an osculatory.","pos":""}],"PAXILLOSE":[{"def":"Resembling a little stake.","pos":""}],"PAXILLUS":[{"def":"One of a peculiar kind of spines covering the surface of certain starfishes.","pos":""}],"PAXWAX":[{"def":"The strong ligament of the back of the neck in quadrupeds.","pos":""}]}