{"ASA":[{"def":"An ancient name of a gum.","pos":""},{"def":"The fetid gum resin or inspissated juice of a large umbelliferous plant (Ferula asafoetida) of Persia and the East India.","pos":""}],"ASAPHUS":[{"def":"A genus of trilobites found in the Lower Silurian formation.","pos":""}],"ASARABACCA":[{"def":"An acrid herbaceous plant (Asarum Europæum), the leaves and roots of which are emetic and cathartic.","pos":""}],"ASARONE":[{"def":"A crystallized substance, resembling camphor, obtained from the Asarum Europæum; -- called also camphor of asarum.","pos":""}]}