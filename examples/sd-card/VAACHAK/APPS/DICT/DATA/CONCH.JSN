{"CONCH":[{"def":"A name applied to various marine univalve shells; esp.","pos":""}],"CONCHA":[{"def":"The plain semidome of an apse; sometimes used for the entire apse.","pos":""},{"def":"The external ear; esp.","pos":""}],"CONCHAL":[{"def":"Pertaining to the concha, or external ear; as, the conchal cartilage.","pos":""}],"CONCHIFER":[{"def":"One of the Conchifera.","pos":""}],"CONCHIFERA":[{"def":"That class of Mollusca which includes the bivalve shells; the Lamellibranchiata.","pos":""}],"CONCHIFEROUS":[{"def":"Producing or having shells.","pos":""}],"CONCHIFORM":[{"def":"Shaped like one half of a bivalve shell; shell-shaped.","pos":""}],"CONCHININE":[{"def":"Con\"chi*nine ( or ), n.","pos":""}],"CONCHITE":[{"def":"A fossil or petrified conch or shell.","pos":""}],"CONCHITIC":[{"def":"Composed of shells; containing many shells.","pos":""}],"CONCHO-SPIRAL":[{"def":"A kind of spiral curve found in certain univalve shells.","pos":""},{"def":"Of or pertaining to shells; resembling a shell; as, conchyliaceous impressions.","pos":""}],"CONCHOID":[{"def":"A curve, of the fourth degree, first made use of by the Greek geometer, Nicomedes, who invented it for the purpose of trisecting an angle and duplicating the cube.","pos":""}],"CONCHOIDAL":[{"def":"Having elevations or depressions in form like one half of a bivalve shell; -- applied principally to a surface produced by fracture.","pos":""}],"CONCHOLOGICAL":[{"def":"Pertaining to, or connected with, conchology.","pos":""}],"CONCHOLOGIST":[{"def":"One who studies, or is versed in, conchology.","pos":""}],"CONCHOLOGY":[{"def":"The science of Mollusca, and of the shells which they form; malacology.","pos":""}],"CONCHOMETER":[{"def":"An instrument for measuring shells, or the angle of their spire.","pos":""}],"CONCHOMETRY":[{"def":"The art of measuring shells or their curves; conchyliometry.","pos":""}],"CONCHYLIOMETRY":[{"def":"Same as Conchometry.","pos":""}]}