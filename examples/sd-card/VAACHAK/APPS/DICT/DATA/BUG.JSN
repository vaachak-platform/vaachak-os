{"BUG":[{"def":"A general name applied to various insects belonging to the Hemiptera; as, the squash bug; the chinch bug, etc.","pos":""},{"def":"An insect of the genus Cimex, especially the bedbug (C.","pos":""}],"BUGBANE":[{"def":"A perennial white-flowered herb of the order Ranunculaceæ and genus Cimiciguga; bugwort.","pos":""}],"BUGBEAR":[{"def":"Same as Bugaboo.","pos":""},{"def":"Causing needless fright.","pos":""}],"BUGGER":[{"def":"One guilty of buggery or unnatural vice; a sodomite.","pos":""},{"def":"A wretch; -- sometimes used humorously or in playful disparagement.","pos":""}],"BUGGERY":[{"def":"Unnatural sexual intercourse; sodomy.","pos":""}],"BUGGINESS":[{"def":"The state of being infested with bugs.","pos":""}],"BUGGY":[{"def":"Infested or abounding with bugs.","pos":""}],"BUGLE":[{"def":"A sort of wild ox; a buffalo.","pos":""}],"BUGLE HORN":[{"def":"A drinking vessel made of horn.","pos":""}],"BUGLED":[{"def":"Ornamented with bugles.","pos":""}],"BUGLER":[{"def":"One who plays on a bugle.","pos":""}],"BUGLEWEED":[{"def":"A plant of the Mint family and genus Lycopus; esp.","pos":""}],"BUGLOSS":[{"def":"A plant of the genus Anchusa, and especially the A.","pos":""}],"BUGWORT":[{"def":"Decorative woodwork in which tortoise shell, yellow metal, white metal, etc.","pos":""}]}