{"APHAERESIS":[{"def":"Same as Apheresis.","pos":""}],"APHAKIA":[{"def":"An anomalous state of refraction caused by the absence of the crystalline lens, as after operations for cataract.","pos":""}],"APHAKIAL":[{"def":"Pertaining to aphakia; as, aphakial eyes.","pos":""}],"APHANIPTERA":[{"def":"A group of wingless insects, of which the flea in the type.","pos":""}],"APHANIPTEROUS":[{"def":"Of or pertaining to the Aphaniptera.","pos":""}],"APHANITIC":[{"def":"Resembling aphanite; having a very fine-grained structure.","pos":""},{"def":"Loss of the power of speech, or of the appropriate use of words, the vocal organs remaining intact, and the intelligence being preserved.","pos":""}],"APHASIC":[{"def":"Pertaining to, or affected by, aphasia; speechless.","pos":""}],"APHELION":[{"def":"That point of a planet's or comet's orbit which is most distant from the sun, the opposite point being the perihelion.","pos":""}],"APHELIOTROPIC":[{"def":"Turning away from the sun; -- said of leaves, etc.","pos":""}],"APHELIOTROPISM":[{"def":"The habit of bending from the sunlight; -- said of certain plants.","pos":""}],"APHEMIA":[{"def":"Loss of the power of speaking, while retaining the power of writing; -- a disorder of cerebral origin.","pos":""}],"APHERESIS":[{"def":"The dropping of a letter or syllable from the beginning of a word; e.","pos":""},{"def":"An operation by which any part is separated from the rest.","pos":""}],"APHESIS":[{"def":"The loss of a short unaccented vowel at the beginning of a word; -- the result of a phonetic process; as, squire for esquire.","pos":""}],"APHETIC":[{"def":"Shortened by dropping a letter or a syllable from the beginning of a word; as, an aphetic word or form.","pos":""}],"APHETISM":[{"def":"An aphetized form of a word.","pos":""}],"APHETIZE":[{"def":"To shorten by aphesis.","pos":""}],"APHID":[{"def":"One of the genus Aphis; an aphidian.","pos":""}],"APHIDIAN":[{"def":"Of or pertaining to the family Aphidæ.","pos":""},{"def":"One of the aphides; an aphid.","pos":""}],"APHIDIVOROUS":[{"def":"Devouring aphides; aphidophagous.","pos":""}],"APHIDOPHAGOUS":[{"def":"Feeding upon aphides, or plant lice, as do beetles of the family Coccinellidæ.","pos":""}],"APHILANTHROPY":[{"def":"Want of love to mankind; -- the opposite of philanthropy.","pos":""}],"APHIS":[{"def":"A genus of insects belonging to the order Hemiptera and family Aphidæ, including numerous species known as plant lice and green flies.","pos":""}],"APHIS LION":[{"def":"The larva of the lacewinged flies (Chrysopa), which feeds voraciously upon aphids.","pos":""}],"APHLOGISTIC":[{"def":"Flameless; as, an aphlogistic lamp, in which a coil of wire is kept in a state of continued ignition by alcohol, without flame.","pos":""},{"def":"Loss of voice or vocal utterance.","pos":""}],"APHORISM":[{"def":"A comprehensive maxim or principle expressed in a few words; a sharply defined sentence relating to abstract truth rather than to practical matters.","pos":""},{"def":"Pertaining to aphorisms, or having the form of an aphorism.","pos":""}],"APHORISMER":[{"def":"A dealer in aphorisms.","pos":""}],"APHORIST":[{"def":"A writer or utterer of aphorisms.","pos":""},{"def":"In the form of, or of the nature of, an aphorism; in the form of short, unconnected sentences; as, an aphoristic style.","pos":""}],"APHORISTICALLY":[{"def":"In the form or manner of aphorisms; pithily.","pos":""}],"APHORIZE":[{"def":"To make aphorisms.","pos":""}],"APHOTIC":[{"def":"A*pho\"tic (a*fo\"tik), a.","pos":""}],"APHOTIC REGION":[{"def":"A depth of water so great that only those organisms can exist that do not assimilate.","pos":""}],"APHRITE":[{"def":"See under Calcite.","pos":""},{"def":"Exciting venereal desire; provocative to venery.","pos":""}],"APHRODISIAC":[{"def":"That which (as a drug, or some kinds of food) excites to venery.","pos":""}],"APHRODISIAN":[{"def":"Pertaining to Aphrodite or Venus.","pos":""}],"APHRODITE":[{"def":"The Greek goddess of love, corresponding to the Venus of the Romans.","pos":""},{"def":"A large marine annelid, covered with long, lustrous, golden, hairlike setæ; the sea mouse.","pos":""}],"APHTHAE":[{"def":"Roundish pearl-colored specks or flakes in the mouth, on the lips, etc.","pos":""}],"APHTHOID":[{"def":"Of the nature of aphthæ; resembling thrush.","pos":""}],"APHTHONG":[{"def":"A letter, or a combination of letters, employed in spelling a word, but in the pronunciation having no sound.","pos":""}],"APHTHOUS":[{"def":"Pertaining to, or caused by, aphthæ; characterized by aphtæ; as, aphthous ulcers; aphthous fever.","pos":""}],"APHYLLOUS":[{"def":"Destitute of leaves, as the broom rape, certain euphorbiaceous plants, etc.","pos":""}]}