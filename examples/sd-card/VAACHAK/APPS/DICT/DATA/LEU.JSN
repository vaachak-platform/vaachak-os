{"LEUCADENDRON":[{"def":"A genus of evergreen shrubs from the Cape of Good Hope, having handsome foliage.","pos":""}],"LEUCANILINE":[{"def":"A colorless, crystalline, organic base, obtained from rosaniline by reduction, and also from other sources.","pos":""}],"LEUCHAEMIA":[{"def":"See Leucocythæmia.","pos":""},{"def":"Pertaining to, or designating, an acid obtained from leucin, and called also oxycaproic acid.","pos":""}],"LEUCIN":[{"def":"A white, crystalline, nitrogenous substance formed in the decomposition of albuminous matter by pancreatic digestion, by the action of boiling dilute sulphuric acid, and by putrefaction.","pos":""}],"LEUCITE":[{"def":"A mineral having a glassy fracture, occurring in translucent trapezohedral crystals.","pos":""}],"LEUCITIC":[{"def":"Containing leucite; as, leucitic rocks.","pos":""}],"LEUCITOID":[{"def":"The trapezohedron or tetragonal trisoctahedron; -- so called as being the form of the mineral leucite.","pos":""},{"def":"A combining form signifying white, colorless; specif.","pos":""}],"LEUCOCYTE":[{"def":"A colorless corpuscle, as one of the white blood corpuscles, or those found in lymph, marrow of hone, connective tissue, etc.","pos":""},{"def":"A disease in which the white corpuscles of the blood are largely increased in number, and there is enlargement of the spleen, or the lymphatic glands; leuchæmia.","pos":""}],"LEUCOCYTOGENESIS":[{"def":"The formation of leucocytes.","pos":""}],"LEUCOETHIOPIC":[{"def":"White and black; -- said of a white animal of a black species, or the albino of the negro race.","pos":""}],"LEUCOLINE":[{"def":"A nitrogenous organic base from coal tar, and identical with quinoline.","pos":""}],"LEUCOMA":[{"def":"A white opacity in the cornea of the eye; -- called also albugo.","pos":""}],"LEUCOMAINE":[{"def":"An animal base or alkaloid, appearing in the tissue during life; hence, a vital alkaloid, as distinguished from a ptomaine or cadaveric poison.","pos":""}],"LEUCONIC":[{"def":"Pertaining to, or designating, a complex organic acid, obtained as a yellowish white gum by the oxidation of croconic acid.","pos":""}],"LEUCOPATHY":[{"def":"The state of an albino, or of a white child of black parents.","pos":""}],"LEUCOPHANE":[{"def":"A mineral of a greenish yellow color; it is a silicate of glucina, lime, and soda with fluorine.","pos":""}],"LEUCOPHLEGMACY":[{"def":"A dropsical habit of body, or the commencement of anasarca; paleness, with viscid juices and cold sweats.","pos":""}],"LEUCOPHLEGMATIC":[{"def":"Having a dropsical habit of body, with a white bloated skin.","pos":""}],"LEUCOPHYLL":[{"def":"A colorless substance isomeric with chlorophyll, contained in parts of plants capable of becoming green.","pos":""}],"LEUCOPHYLLOUS":[{"def":"Having white or silvery foliage.","pos":""},{"def":"One of certain very minute whitish or colorless granules occurring in the protoplasm of plants and supposed to be the nuclei around which starch granules will form.","pos":""}],"LEUCOPYRITE":[{"def":"A mineral of a color between white and steel-gray, with a metallic luster, and consisting chiefly of arsenic and iron.","pos":""}],"LEUCORRHOEA":[{"def":"A discharge of a white, yellowish, or greenish, viscid mucus, resulting from inflammation or irritation of the membrane lining the genital organs of the female; the whites.","pos":""}],"LEUCORYX":[{"def":"A large antelope of North Africa (Oryx leucoryx), allied to the gemsbok.","pos":""}],"LEUCOSCOPE":[{"def":"An instrument, devised by Professor Helmholtz, for testing the color perception of the eye, or for comparing different lights, as to their constituent color or their relative whiteness.","pos":""}],"LEUCOSOID":[{"def":"Like or pertaining to the Leucosoidea, a tribe of marine crabs including the box crab or Calappa.","pos":""}],"LEUCOSPHERE":[{"def":"The inner corona.","pos":""}],"LEUCOTURIC":[{"def":"Pertaining to, or designating, a nitrogenous organic substance of the uric acid group, called leucoturic acid or oxalantin.","pos":""}],"LEUCOUS":[{"def":"White; -- applied to albinos, from the whiteness of their skin and hair.","pos":""}],"LEUCOXENE":[{"def":"A nearly opaque white mineral, in part identical with titanite, observed in some igneous rocks as the result of the alteration of titanic iron.","pos":""}],"LEUKAEMIA":[{"def":"LEUKE; LEUKENESS Leuke, a.","pos":""}],"LEUKOPLAST":[{"def":"Leu\"ko*plast (lu\"ko*plast), n.","pos":""}]}