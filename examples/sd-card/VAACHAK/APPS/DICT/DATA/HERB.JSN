{"HERB":[{"def":"A plant whose stem does not become woody and permanent, but dies, at least down to the ground, after flowering.","pos":""}],"HERB-WOMAN":[{"def":"A woman that sells herbs.","pos":""}],"HERBACEOUS":[{"def":"Of or pertaining to herbs; having the nature, texture, or characteristics, of an herb; as, herbaceous plants; an herbaceous stem.","pos":""}],"HERBAGE":[{"def":"The liberty or right of pasture in the forest or in the grounds of another man.","pos":""}],"HERBAGED":[{"def":"Covered with grass.","pos":""}],"HERBAL":[{"def":"Of or pertaining to herbs.","pos":""}],"HERBALISM":[{"def":"The knowledge of herbs.","pos":""}],"HERBALIST":[{"def":"One skilled in the knowledge of plants; a collector of, or dealer in, herbs, especially medicinal herbs.","pos":""}],"HERBARIUM":[{"def":"A collection of dried specimens of plants, systematically arranged.","pos":""},{"def":"A book or case for preserving dried plants.","pos":""}],"HERBARY":[{"def":"A garden of herbs; a cottage garden.","pos":""}],"HERBER":[{"def":"A garden; a pleasure garden.","pos":""}],"HERBERGAGE":[{"def":"Harborage; lodging; shelter; harbor.","pos":""}],"HERBERGEOUR":[{"def":"HERBERGH; HERBERWE Her\"bergh, Her\"ber*we (, n.","pos":""}],"HERBESCENT":[{"def":"Growing into herbs.","pos":""}],"HERBID":[{"def":"Covered with herbs.","pos":""}],"HERBIFEROUS":[{"def":"Bearing herbs or vegetation.","pos":""}],"HERBIVORA":[{"def":"An extensive division of Mammalia.","pos":""}],"HERBIVORE":[{"def":"One of the Herbivora.","pos":""}],"HERBIVOROUS":[{"def":"Eating plants; of or pertaining to the Herbivora.","pos":""}],"HERBLESS":[{"def":"Destitute of herbs or of vegetation.","pos":""}],"HERBORIZATION":[{"def":"The act of herborizing.","pos":""},{"def":"The figure of plants in minerals or fossils.","pos":""}],"HERBORIZE":[{"def":"To search for plants, or new species of plants, with a view to classifying them.","pos":""}],"HERBOROUGH":[{"def":"Abounding with herbs.","pos":""}],"HERBY":[{"def":"Having the nature of, pertaining to, or covered with, herbs or herbage.","pos":""}]}