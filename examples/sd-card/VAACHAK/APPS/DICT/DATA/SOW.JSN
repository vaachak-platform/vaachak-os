{"SOW":[{"def":"The female of swine, or of the hog kind.","pos":""}],"SOWAR":[{"def":"In India, a mounted soldier.","pos":""}],"SOWBANE":[{"def":"The red goosefoot (Chenopodium rubrum), -- said to be fatal to swine.","pos":""}],"SOWENS":[{"def":"A nutritious article of food, much used in Scotland, made from the husk of the oat by a process not unlike that by which common starch is made; -- called flummery in England.","pos":""}],"SOWER":[{"def":"One who, or that which, sows.","pos":""}],"SOWINS":[{"def":"To pull by the ears; to drag about.","pos":""}]}