{"BOHEA":[{"def":"Bohea tea, an inferior kind of black tea.","pos":""}],"BOHEMIA":[{"def":"A country of central Europe.","pos":""}],"BOHEMIAN":[{"def":"Of or pertaining to Bohemia, or to the language of its ancient inhabitants or their descendants.","pos":""},{"def":"Of or pertaining to a social gypsy or \"Bohemian\" (see Bohemian, n.","pos":""}],"BOHEMIANISM":[{"def":"The characteristic conduct or methods of a Bohemian.","pos":""}]}