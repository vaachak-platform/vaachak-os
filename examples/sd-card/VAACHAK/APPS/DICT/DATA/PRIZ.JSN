{"PRIZE":[{"def":"That which is taken from another; something captured; a thing seized by force, stratagem, or superior power.","pos":""},{"def":"Hence, specifically; (a) (Law) Anything captured by a belligerent using the rights of war; esp.","pos":""}],"PRIZEMAN":[{"def":"The winner of a prize.","pos":""}],"PRIZER":[{"def":"One who estimates or sets the value of a thing; an appraiser.","pos":""}],"PRIZING":[{"def":"The application of a lever to move any weighty body, as a cask, anchor, cannon, car, etc.","pos":""}]}