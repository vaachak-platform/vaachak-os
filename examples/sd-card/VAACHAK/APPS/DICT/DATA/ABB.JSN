{"ABB":[{"def":"Among weaves, yarn for the warp.","pos":""}],"ABBA":[{"def":"Father; religious superior; -- in the Syriac, Coptic, and Ethiopic churches, a title given to the bishops, and by the bishops to the patriarch.","pos":""}],"ABBACY":[{"def":"The dignity, estate, or jurisdiction of an abbot.","pos":""}],"ABBATIAL":[{"def":"Belonging to an abbey; as, abbatial rights.","pos":""}],"ABBE":[{"def":"The French word answering to the English abbot, the head of an abbey; but commonly a title of respect given in France to every one vested with the ecclesiastical habit or dress.","pos":"noun"}],"ABBESS":[{"def":"A female superior or governess of a nunnery, or convent of nuns, having the same authority over the nuns which the abbots have over the monks.","pos":""}],"ABBEY":[{"def":"A monastery or society of persons of either sex, secluded from the world and devoted to religion and celibacy; also, the monastic building or buildings.","pos":""},{"def":"The church of a monastery.","pos":""}],"ABBOT":[{"def":"The superior or head of an abbey.","pos":""},{"def":"One of a class of bishops whose sees were formerly abbeys.","pos":""}],"ABBOTSHIP":[{"def":"The state or office of an abbot.","pos":""}],"ABBREVIATE":[{"def":"To reduce to lower terms, as a fraction.","pos":"verb"}],"ABBREVIATED":[{"def":"Shortened; relatively short; abbreviate.","pos":""}],"ABBREVIATION":[{"def":"One dash, or more, through the stem of a note, dividing it respectively into quavers, semiquavers, or demi-semiquavers.","pos":""}],"ABBREVIATOR":[{"def":"One who abbreviates or shortens.","pos":""},{"def":"One of a college of seventy-two officers of the papal court whose duty is to make a short minute of a decision on a petition, or reply of the pope to a letter, and afterwards expand the minute into official form.","pos":""}],"ABBREVIATORY":[{"def":"Serving or tending to abbreviate; shortening; abridging.","pos":""}],"ABBREVIATURE":[{"def":"An abbreviation; an abbreviated state or form.","pos":""},{"def":"An abridgment; a compendium or abstract.","pos":""}]}