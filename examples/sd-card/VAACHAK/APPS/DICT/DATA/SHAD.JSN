{"SHAD":[{"def":"Any one of several species of food fishes of the Herring family.","pos":""}],"SHAD-WAITER":[{"def":"A lake whitefish; the roundfish.","pos":""}],"SHADD":[{"def":"Rounded stones containing tin ore, lying at the surface of the ground, and indicating a vein.","pos":""}],"SHADDE":[{"def":"Shad\"de, Defn: obs.","pos":""}],"SHADDOCK":[{"def":"A tree (Citrus decumana) and its fruit, which is a large species of orange; -- called also forbidden fruit, and pompelmous.","pos":""}],"SHADE":[{"def":"The darker portion of a picture; a less illuminated part.","pos":""}],"SHADEFUL":[{"def":"Full of shade; shady.","pos":""}],"SHADELESS":[{"def":"Being without shade; not shaded.","pos":""}],"SHADER":[{"def":"One who, or that which, shades.","pos":""}],"SHADILY":[{"def":"In a shady manner.","pos":""}],"SHADINESS":[{"def":"Shad\"i*ness Defn: , n.","pos":""}],"SHADING":[{"def":"Act or process of making a shade.","pos":""},{"def":"That filling up which represents the effect of more or less darkness, expressing rotundity, projection, etc.","pos":""}],"SHADOOF":[{"def":"A machine, resembling a well sweep, used in Egypt for raising water from the Nile for irrigation.","pos":""}],"SHADOW":[{"def":"Shade within defined limits; obscurity or deprivation of light, apparent on a surface, and representing the form of the body which intercepts the rays of light; as, the shadow of a man, of a tree, or of a tower.","pos":""},{"def":"Darkness; shade; obscurity.","pos":""}],"SHADOWINESS":[{"def":"The quality or state of being shadowy.","pos":""}],"SHADOWING":[{"def":"Shade, or gradation of light and color; shading.","pos":""},{"def":"A faint representation; an adumbration.","pos":""}],"SHADOWLESS":[{"def":"Having no shadow.","pos":""}],"SHADOWY":[{"def":"Full of shade or shadows; causing shade or shadow.","pos":""},{"def":"Hence, dark; obscure; gloomy; dim.","pos":""}],"SHADRACH":[{"def":"A mass of iron on which the operation of smelting has failed of its intended effect; -- so called from Shadrach, one of the three Hebrews who came forth unharmed from the fiery furnace of Nebuchadnezzar.","pos":""}],"SHADY":[{"def":"Abounding in shade or shades; overspread with shade; causing shade.","pos":""},{"def":"Sheltered from the glare of light or sultry heat.","pos":""}]}