{"CHORAGIC":[{"def":"Of or pertaining to a choragus.","pos":""}],"CHORAGUS":[{"def":"A chorus leader; esp.","pos":""}],"CHORAL":[{"def":"Of or pertaining to a choir or chorus; singing, sung, or adapted to be sung, in chorus or harmony.","pos":""}],"CHORALIST":[{"def":"A singer or composer of chorals.","pos":""}],"CHORALLY":[{"def":"In the manner of a chorus; adapted to be sung by a choir; in harmony.","pos":""}],"CHORD":[{"def":"A combination of tones simultaneously performed, producing more or less perfect harmony, as, the common chord.","pos":""},{"def":"A right line uniting the extremities of the arc of a circle or curve.","pos":""}],"CHORDAL":[{"def":"Of or pertaining to a chord.","pos":""}],"CHORDATA":[{"def":"A comprehensive division of animals including all Vertebrata together with the Tunicata, or all those having a dorsal nervous cord.","pos":""}],"CHORDEE":[{"def":"A painful erection of the penis, usually with downward curvature, occurring in gonorrhea.","pos":""}],"CHORE":[{"def":"A small job; in the pl.","pos":""}],"CHOREE":[{"def":"Pertaining to choregraphy.","pos":""}],"CHOREGRAPHY":[{"def":"The art of representing dancing by signs, as music is represented by notes.","pos":""}],"CHOREIC":[{"def":"Of the nature of, or pertaining to, chorea; convulsive.","pos":""}],"CHOREPISCOPAL":[{"def":"Pertaining to a chorepiscopus or his change or authority.","pos":""}],"CHOREPISCOPUS":[{"def":"A \"country\" or suffragan bishop, appointed in the ancient church by a diocesan bishop to exercise episcopal jurisdiction in a rural district.","pos":""}],"CHORIAMB":[{"def":"Same as Choriambus.","pos":""}],"CHORIAMBIC":[{"def":"Pertaining to a choriamb.","pos":""}],"CHORIAMBUS":[{"def":"A foot consisting of four syllables, of which the first and last are long, and the other short (- ~ ~ -); that is, a choreus, or trochee, and an iambus united.","pos":""}],"CHORIC":[{"def":"Of or pertaining to a chorus.","pos":""}],"CHORION":[{"def":"The outer membrane of seeds of plants.","pos":""}],"CHORISIS":[{"def":"The separation of a leaf or floral organ into two more parts.","pos":""}],"CHORIST":[{"def":"A singer in a choir; a chorister.","pos":""}],"CHORISTER":[{"def":"One of a choir; a singer in a chorus.","pos":""},{"def":"One who leads a choir in church music.","pos":""}],"CHOROGRAPH":[{"def":"An instrument for constructing triangles in marine surveying, etc.","pos":""}],"CHOROGRAPHER":[{"def":"One who describes or makes a map of a district or region.","pos":""},{"def":"A geographical antiquary; one who investigates the locality of ancient places.","pos":""}],"CHOROGRAPHICAL":[{"def":"Pertaining to chorography.","pos":""}],"CHOROGRAPHY":[{"def":"the mapping or description of a region or district.","pos":""}],"CHOROID":[{"def":"resembling the chorion; as, the choroid plexuses of the ventricles of the brain, and the choroid coat of the eyeball.","pos":""},{"def":"The choroid coat of the eye.","pos":""}],"CHOROIDAL":[{"def":"Pertaining to the choroid coat.","pos":""}],"CHOROLOGY":[{"def":"The science which treats of the laws of distribution of living organisms over the earth's surface as to latitude, altitude, locality, etc.","pos":""}],"CHOROMETRY":[{"def":"The art of surveying a region or district.","pos":""}],"CHORTLE":[{"def":"A word coined by Lewis Carroll (Charles L.","pos":""}],"CHORUS":[{"def":"A band of singers and dancers.","pos":""},{"def":"A company of persons supposed to behold what passed in the acts of a tragedy, and to sing the sentiments which the events suggested in couplets or verses between the acts; also, that which was thus sung by the chorus.","pos":""}]}