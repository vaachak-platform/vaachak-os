{"OUTMANTLE":[{"def":"To excel in mantling; hence, to excel in splendor, as of dress.","pos":""}],"OUTMARCH":[{"def":"To surpass in marching; to march faster than, or so as to leave behind.","pos":""}],"OUTMEASURE":[{"def":"To exceed in measure or extent; to measure more than.","pos":""}],"OUTMOST":[{"def":"Farthest from the middle or interior; farthest outward; outermost.","pos":""}]}