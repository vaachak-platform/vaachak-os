{"AX":[{"def":"To ask; to inquire or inquire of.","pos":""}],"AXAL":[{"def":"AXE; AXEMAN Axe, Axe\"man, etc.","pos":""}],"AXIAL":[{"def":"Belonging to the axis of the body; as, the axial skeleton; or to the axis of any appendage or organ; as, the axial bones.","pos":""}],"AXIALLY":[{"def":"In relation to, or in a line with, an axis; in the axial (magnetic) line.","pos":""}],"AXIL":[{"def":"The angle or point of divergence between the upper side of a branch, leaf, or petiole, and the stem or branch from which it springs.","pos":""}],"AXILE":[{"def":"Situated in the axis of anything; as an embryo which lies in the axis of a seed.","pos":""}],"AXILLA":[{"def":"The armpit, or the cavity beneath the junction of the arm and shoulder.","pos":""}],"AXILLAR":[{"def":"Feathers connecting the under surface of the wing and the body, and concealed by the closed wing.","pos":""}],"AXILLARY":[{"def":"Of or pertaining to the axilla or armpit; as, axillary gland, artery, nerve.","pos":""},{"def":"Situated in, or rising from, an axil; of or pertaining to an axil.","pos":""}],"AXINITE":[{"def":"A borosilicate of alumina, iron, and lime, commonly found in glassy, brown crystals with acute edges.","pos":""}],"AXINOMANCY":[{"def":"A species of divination, by means of an ax or hatchet.","pos":""}],"AXIOM":[{"def":"A self-evident and necessary truth, or a proposition whose truth is so evident as first sight that no reasoning or demonstration can make it plainer; a proposition which it is necessary to take for granted; as, \"The whole is greater than a part;\" \"A thing can not, at the same time, be and not be.","pos":""},{"def":"Of or pertaining to an axiom; having the nature of an axiom; self-evident; characterized by axioms.","pos":""}],"AXIOMATICALLY":[{"def":"By the use of axioms; in the form of an axiom.","pos":""}],"AXIS":[{"def":"The spotted deer (Cervus axis or Axis maculata) of India, where it is called hog deer and parrah (Moorish name).","pos":""}],"AXLE":[{"def":"The pin or spindle on which a wheel revolves, or which revolves with a wheel.","pos":""},{"def":"A transverse bar or shaft connecting the opposite wheels of a car or carriage; an axletree.","pos":""}],"AXLE BOX":[{"def":"A bushing in the hub of a wheel, through which the axle passes.","pos":""},{"def":"The journal box of a rotating axle, especially a railway axle.","pos":""}],"AXLE GUARD":[{"def":"The part of the framing of a railway car or truck, by which an axle box is held laterally, and in which it may move vertically; -- also called a jaw in the United States, and a housing in England.","pos":""}],"AXLED":[{"def":"Having an axle; -- used in composition.","pos":""}],"AXLETREE":[{"def":"A bar or beam of wood or iron, connecting the opposite wheels of a carriage, on the ends of which the wheels revolve.","pos":""},{"def":"A spindle or axle of a wheel.","pos":""}],"AXMAN":[{"def":"One who wields an ax.","pos":""}],"AXMINSTER":[{"def":"An Axminster carpet, an imitation Turkey carpet, noted for its thick and soft pile; -- so called from Axminster, Eng.","pos":""}],"AXOLOTL":[{"def":"An amphibian of the salamander tribe found in the elevated lakes of Mexico; the siredon.","pos":""}],"AXSTONE":[{"def":"A variety of jade.","pos":""}],"AXTREE":[{"def":"Axle or axletree.","pos":""}],"AXUNGE":[{"def":"Fat; grease; esp.","pos":""}]}