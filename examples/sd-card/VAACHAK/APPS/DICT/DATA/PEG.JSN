{"PEG":[{"def":"A small, pointed piece of wood, used in fastening boards together, in attaching the soles of boots or shoes, etc.","pos":""},{"def":"A wooden pin, or nail, on which to hang things, as coats, etc.","pos":""}],"PEGADOR":[{"def":"A species of remora (Echeneis naucrates).","pos":""}],"PEGASEAN":[{"def":"Of or pertaining to Pegasus, or, figuratively, to poetry.","pos":""}],"PEGASOID":[{"def":"Like or pertaining to Pegasus.","pos":""}],"PEGASUS":[{"def":"A winged horse fabled to have sprung from the body of Medusa when she was slain.","pos":""},{"def":"A northen constellation near the vernal equinoctial point.","pos":""}],"PEGGER":[{"def":"One who fastens with pegs.","pos":""}],"PEGGING":[{"def":"The act or process of fastening with pegs.","pos":""}],"PEGM":[{"def":"A sort of moving machine employed in the old pageants.","pos":""}],"PEGMATITIC":[{"def":"Of, pertaining to, or resembling, pegmatite; as, the pegmatic structure of certain rocks resembling graphic granite.","pos":""}],"PEGMATOID":[{"def":"Resembling pegmatite; pegmatic.","pos":""}],"PEGOMANCY":[{"def":"Divination by fountains.","pos":""}],"PEGROOTS":[{"def":"Same as Setterwort.","pos":""}]}