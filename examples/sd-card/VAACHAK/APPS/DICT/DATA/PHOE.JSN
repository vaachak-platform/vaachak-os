{"PHOEBE":[{"def":"The pewee, or pewit.","pos":""}],"PHOEBUS":[{"def":"Apollo; the sun god.","pos":""}],"PHOENICIAN":[{"def":"Of or pertaining to Phoenica.","pos":""},{"def":"A native or inhabitant of Phoenica.","pos":""}],"PHOENICOPTERUS":[{"def":"A genus of birds which includes the flamingoes.","pos":""}],"PHOENIX":[{"def":"A genus of palms including the date tree.","pos":""}]}