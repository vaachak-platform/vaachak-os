{"SEMIDEISTICAL":[{"def":"Half deisticsl; bordering on deism.","pos":""}],"SEMIDEMIQUAVER":[{"def":"A demisemiquaver; a thirty-second note.","pos":""}],"SEMIDETACHED":[{"def":"Half detached; partly distinct or separate.","pos":""}],"SEMIDIAMETER":[{"def":"Half of a diameter; a right line, or the length of a right line, drawn from the center of a circle, a sphere, or other curved figure, to its circumference or periphery; a radius.","pos":""}],"SEMIDIAPASON":[{"def":"An imperfect octave.","pos":""}],"SEMIDIAPENTE":[{"def":"An imperfect or diminished fifth.","pos":""}],"SEMIDIAPHANEITY":[{"def":"Half or imperfect transparency; translucency.","pos":""}],"SEMIDIAPHANOUS":[{"def":"Half or imperfectly transparent; translucent.","pos":""}],"SEMIDIATESSARON":[{"def":"An imperfect or diminished fourth.","pos":""}],"SEMIDITONE":[{"def":"A lesser third, having its terms as 6 to 5; a hemiditone.","pos":""}],"SEMIDIURNAL":[{"def":"Pertaining to, or accomplished in, half a day, or twelve hours; occurring twice every day.","pos":""},{"def":"Pertaining to, or traversed in, six hours, or in half the time between the rising and setting of a heavenly body; as, a semidiurnal arc.","pos":""}],"SEMIDOME":[{"def":"A roof or ceiling covering a semicircular room or recess, or one of nearly that shape, as the apse of a church, a niche, or the like.","pos":""}],"SEMIDOUBLE":[{"def":"An office or feast celebrated with less solemnity than the double ones.","pos":""}]}