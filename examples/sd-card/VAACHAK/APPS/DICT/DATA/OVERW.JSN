{"OVERWALK":[{"def":"To walk over or upon.","pos":""}],"OVERWARY":[{"def":"Too wary; too cautious.","pos":""}],"OVERWASTED":[{"def":"Wasted or worn out; [Obs.","pos":""}],"OVERWATCH":[{"def":"To watch too much.","pos":""},{"def":"To weary or exhaust by watching.","pos":""}],"OVERWAX":[{"def":"To wax or grow too rapindly or too much.","pos":""}],"OVERWEAK":[{"def":"Too weak; too feeble.","pos":""}],"OVERWEAR":[{"def":"To wear too much; to wear out.","pos":""}],"OVERWEARY":[{"def":"To weary too much; to tire out.","pos":""}],"OVERWEATHER":[{"def":"To expose too long to the influence of the weather.","pos":""}],"OVERWEEN":[{"def":"To think too highly or arrogantly; to regard one's own thinking or conclusions too highly; hence, to egotistic, arrogant, or rash, in opinion; to think conceitedly; to presume.","pos":""}],"OVERWEENER":[{"def":"One who overweens.","pos":""}],"OVERWEENING":[{"def":"Unduly confident; arrogant; presumptuous; conceited.","pos":""}],"OVERWEIGH":[{"def":"To exceed in weight; to overbalance; to weigh down.","pos":""}],"OVERWEIGHT":[{"def":"Weight over and above what is required by law or custom.","pos":""},{"def":"Superabundance of weight; preponderance.","pos":""}],"OVERWET":[{"def":"Excessive wetness.","pos":""}],"OVERWHELM":[{"def":"To cover over completely, as by a great wave; to overflow and bury beneath; to ingulf; hence, figuratively, to immerse and bear down; to overpower; to crush; to bury; to oppress, etc.","pos":""},{"def":"To project or impend over threateningly.","pos":""}],"OVERWHELMING":[{"def":"Overpowering; irresistible.","pos":""}],"OVERWIND":[{"def":"To wind too tightly, as a spring, or too far, as a hoisting rope on a drum.","pos":""}],"OVERWISE":[{"def":"Too wise; affectedly wise.","pos":""}],"OVERWORD":[{"def":"To say in too many words; to express verbosely.","pos":""}],"OVERWORK":[{"def":"To work beyond the strength; to cause to labor too much or too long; to tire excessively; as, to overwork a horse.","pos":""},{"def":"To fill too full of work; to crowd with labor.","pos":""}],"OVERWORN":[{"def":"Worn out or subdued by toil; worn out so as to be trite.","pos":""}],"OVERWREST":[{"def":"To wrest or force from the natural or proper position.","pos":""}],"OVERWRESTLE":[{"def":"To subdue by wrestling.","pos":""}],"OVERWROUGHT":[{"def":"Wrought upon excessively; overworked; overexcited.","pos":""}]}