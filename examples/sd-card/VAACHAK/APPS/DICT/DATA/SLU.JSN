{"SLUB":[{"def":"A roll of wool slightly twisted; a rove; -- called also slubbing.","pos":""}],"SLUBBER":[{"def":"To do lazily, imperfectly, or coarsely.","pos":""},{"def":"To daub; to stain; to cover carelessly.","pos":""}],"SLUBBERDEGULLION":[{"def":"A mean, dirty wretch.","pos":""}],"SLUBBERINGLY":[{"def":"In a slovenly, or hurried and imperfect, manner.","pos":""}],"SLUDGE":[{"def":"Mud; mire; soft mud; slush.","pos":""},{"def":"Small floating pieces of ice, or masses of saturated snow.","pos":""}],"SLUDGE ACID":[{"def":"Impure dark-colored sulphuric acid that has been used in the refining of petroleum.","pos":""}],"SLUDGER":[{"def":"A bucket for removing mud from a bored hole; a sand pump.","pos":""}],"SLUE":[{"def":"To turn about a fixed point, usually the center or axis, as a spar or piece of timber; to turn; -- used also of any heavy body.","pos":""}],"SLUG":[{"def":"Any one of numerous species of terrestrial pulmonate mollusks belonging to Limax and several related genera, in which the shell is either small and concealed in the mantle, or altogether wanting.","pos":""},{"def":"Any smooth, soft larva of a sawfly or moth which creeps like a mollusk; as, the pear slug; rose slug.","pos":""}],"SLUG-HORN":[{"def":"An erroneous form of the Scotch word slughorne, or sloggorne, meaning slogan.","pos":""}],"SLUGABED":[{"def":"One who indulges in lying abed; a sluggard.","pos":""}],"SLUGGARD":[{"def":"A person habitually lazy, idle, and inactive; a drone.","pos":""}],"SLUGGARDY":[{"def":"The state of being a sluggard; sluggishness; sloth.","pos":""}],"SLUGGER":[{"def":"One who strikes heavy blows; hence, a boxer; a prize fighter.","pos":""}],"SLUGGISH":[{"def":"Habitually idle and lazy; slothful; dull; inactive; as, a sluggish man.","pos":""},{"def":"Slow; having little motion; as, a sluggish stream.","pos":""}],"SLUGS":[{"def":"Half-roasted ore.","pos":""}],"SLUGWORM":[{"def":"Any caterpillar which has the general appearance of a slug, as do those of certain moths belonging to Limacodes and allied genera, and those of certain sawflies.","pos":""}],"SLUICE":[{"def":"A long box or trough through which water flows, -- used for washing auriferous earth.","pos":""}],"SLUICEWAY":[{"def":"An artificial channel into which water is let by a sluice; specifically, a trough constructed over the bed of a stream, so that logs, lumber, or rubbish can be floated down to some convenient place of delivery.","pos":""}],"SLUICY":[{"def":"Falling copiously or in streams, as from a sluice.","pos":""}],"SLUM":[{"def":"A foul back street of a city, especially one filled with a poor, dirty, degraded, and often vicious population; any low neighborhood or dark retreat; -- usually in the plural; as, Westminster slums are haunts for theives.","pos":""}],"SLUMBER":[{"def":"To sleep; especially, to sleep lightly; to doze.","pos":""},{"def":"To be in a state of negligence, sloth, supineness, or inactivity.","pos":""}],"SLUMBERER":[{"def":"One who slumbers; a sleeper.","pos":""}],"SLUMBERINGLY":[{"def":"In a slumbering manner.","pos":""}],"SLUMBERLESS":[{"def":"Without slumber; sleepless.","pos":""}],"SLUMBEROUS":[{"def":"Inviting slumber; soporiferous.","pos":""},{"def":"Being in the repose of slumber; sleepy; drowsy.","pos":""}],"SLUMGUM":[{"def":"The impure residue, consisting of cocoons, propolis, etc.","pos":""}],"SLUMP":[{"def":"The gross amount; the mass; the lump.","pos":"verb"}],"SLUMPY":[{"def":"Easily broken through; boggy; marshy; swampy.","pos":""}],"SLUR":[{"def":"To sing or perform in a smooth, gliding style; to connect smoothly in performing, as several notes or tones.","pos":""},{"def":"To blur or double, as an impression from type; to mackle.","pos":""}],"SLURRED":[{"def":"Marked with a slur; performed in a smooth, gliding style, like notes marked with a slur.","pos":""}],"SLUSH":[{"def":"A mixture of white lead and lime, with which the bright parts of machines, such as the connecting rods of steamboats, are painted to be preserved from oxidation.","pos":""}],"SLUSHY":[{"def":"Abounding in slush; characterized by soft mud or half-melted snow; as, the streets are slushy; the snow is slushy.","pos":""}],"SLUT":[{"def":"An untidy woman; a slattern.","pos":""},{"def":"A servant girl; a drudge.","pos":""}],"SLUTTERY":[{"def":"The qualities and practices of a slut; sluttishness; slatternlines.","pos":""}],"SLUTTISH":[{"def":"Like a slut; untidy; indecently negligent of cleanliness; disorderly; as, a sluttish woman.","pos":""}]}