{"WAY":[{"def":"The timbers on which a ship is launched.","pos":""},{"def":"The longitudinal guides, or guiding surfaces, on the bed of a planer, lathe, or the like, along which a table or carriage moves.","pos":""}],"WAY SHAFT":[{"def":"An interior shaft, usually one connecting two levels.","pos":""}],"WAY-GOING":[{"def":"Going away; departing; of or pertaining to one who goes away.","pos":""}],"WAY-GOOSE":[{"def":"See Wayz-goose, n.","pos":""}],"WAY-WISE":[{"def":"Skillful in finding the way; well acquainted with the way or route; wise from having traveled.","pos":""}],"WAYBILL":[{"def":"A list of passengers in a public vehicle, or of the baggage or gods transported by a common carrier on a land route.","pos":""}],"WAYBREAD":[{"def":"The common dooryard plantain (Plantago major).","pos":""}],"WAYBUNG":[{"def":"An Australian insessorial bird (Corcorax melanorhamphus) noted for the curious actions of the male during the breeding season.","pos":""}],"WAYED":[{"def":"Used to the way; broken.","pos":""}],"WAYFARE":[{"def":"To journey; to travel; to go to and fro.","pos":""}],"WAYFARER":[{"def":"One who travels; a traveler; a passenger.","pos":""}],"WAYFARING":[{"def":"Traveling; passing; being on a journey.","pos":""}],"WAYGATE":[{"def":"The tailrace of a mill.","pos":""}],"WAYLAY":[{"def":"To lie in wait for; to meet or encounter in the way; especially, to watch for the passing of, with a view to seize, rob, or slay; to beset in ambush.","pos":""}],"WAYLAYER":[{"def":"One who waylays another.","pos":""}],"WAYLESS":[{"def":"Having no road or path; pathless.","pos":""}],"WAYMAKER":[{"def":"One who makes a way; a precursor.","pos":""}],"WAYMARK":[{"def":"A mark to guide in traveling.","pos":""}],"WAYMENT":[{"def":"To lament; to grieve; to wail.","pos":""}],"WAYSIDE":[{"def":"The side of the way; the edge or border of a road or path.","pos":""}],"WAYWARD":[{"def":"Taking one's own way; disobedient; froward; perverse; willful.","pos":""}],"WAYWISER":[{"def":"An instrument for measuring the distance which one has traveled on the road; an odometer, pedometer, or perambulator.","pos":""}],"WAYWODE":[{"def":"Originally, the title of a military commander in various Slavonic countries; afterwards applied to governors of towns or provinces.","pos":""}],"WAYWODESHIP":[{"def":"The office, province, or jurisdiction of a waywode.","pos":""}],"WAYWORN":[{"def":"Wearied by traveling.","pos":""}],"WAYZ-GOOSE":[{"def":"A stubble goose.","pos":""},{"def":"An annual feast of the persons employed in a printing office.","pos":""}]}