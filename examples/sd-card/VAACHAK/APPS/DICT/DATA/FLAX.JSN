{"FLAX":[{"def":"A plant of the genus Linum, esp.","pos":""}],"FLAX-PLANT":[{"def":"A plant in new Zealand (Phormium tenax), allied to the lilies and aloes.","pos":""}],"FLAXEN":[{"def":"Made of flax; resembling flax or its fibers; of the color of flax; of a light soft straw color; fair and flowing, like flax or tow; as, flaxen thread; flaxen hair.","pos":""}],"FLAXSEED":[{"def":"The seed of the flax; linseed.","pos":""}],"FLAXY":[{"def":"Like flax; flaxen.","pos":""}]}