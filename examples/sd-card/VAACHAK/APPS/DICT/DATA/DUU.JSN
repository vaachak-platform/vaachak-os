{"DUUMVIR":[{"def":"One of two Roman officers or magistrates united in the same public functions.","pos":""}],"DUUMVIRAL":[{"def":"Of or belonging to the duumviri or the duumvirate.","pos":""}],"DUUMVIRATE":[{"def":"The union of two men in the same office; or the office, dignity, or government of two men thus associated, as in ancient Rome.","pos":""}]}