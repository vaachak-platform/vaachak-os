{"RIVAGE":[{"def":"A duty paid to the crown for the passage of vessels on certain rivers.","pos":""}],"RIVAL":[{"def":"A person having a common right or privilege with another; a partner.","pos":""},{"def":"One who is in pursuit of the same object as another; one striving to reach or obtain something which another is attempting to obtain, and which one only can posses; a competitor; as, rivals in love; rivals for a crown.","pos":""}],"RIVALITY":[{"def":"Rivalry; competition.","pos":""},{"def":"Equality, as of right or rank.","pos":""}],"RIVALRY":[{"def":"The act of rivaling, or the state of being a rival; a competition.","pos":""}],"RIVE":[{"def":"To rend asunder by force; to split; to cleave; as, to rive timber for rails or shingles.","pos":""}],"RIVEL":[{"def":"To contract into wrinkles; to shrivel; to shrink; as, riveled fruit; riveled flowers.","pos":""}],"RIVER":[{"def":"One who rives or splits.","pos":""}],"RIVERED":[{"def":"Supplied with rivers; as, a well rivered country.","pos":""}],"RIVERHOOD":[{"def":"The quality or state of being a river.","pos":""}],"RIVERSIDE":[{"def":"The side or bank of a river.","pos":""}],"RIVERY":[{"def":"Having rivers; as, a rivery country.","pos":""}],"RIVET":[{"def":"A metallic pin with a head, used for uniting two plates or pieces of material together, by passing it through them and then beating or pressing down the point so that it shall spread out and form a second head; a pin or bolt headed or clinched at both ends.","pos":""}],"RIVETING":[{"def":"The act of joining with rivets; the act of spreading out and clinching the end, as of a rivet, by beating or pressing.","pos":""},{"def":"The whole set of rivets, collectively.","pos":""}],"RIVIERE":[{"def":"A necklace of diamonds or other precious stones, esp.","pos":""}],"RIVOSE":[{"def":"Marked with sinuate and irregular furrows.","pos":""}],"RIVULET":[{"def":"A small stream or brook; a streamlet.","pos":""}]}