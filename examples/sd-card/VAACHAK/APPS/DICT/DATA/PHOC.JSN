{"PHOCA":[{"def":"A genus of seals.","pos":""}],"PHOCACEAN":[{"def":"Any species of Phoca; a seal.","pos":""}],"PHOCAL":[{"def":"Pertaining to seals.","pos":""}],"PHOCENIC":[{"def":"Of or pertaining to dolphin oil or porpoise oil; -- said of an acid (called also delphinic acid) subsequently found to be identical with valeric acid.","pos":""}],"PHOCINE":[{"def":"Of or pertaining to the seal tribe; phocal.","pos":""}],"PHOCODONT":[{"def":"One of the Phocodontia.","pos":""}],"PHOCODONTIA":[{"def":"A group of extinct carnivorous whales.","pos":""}]}