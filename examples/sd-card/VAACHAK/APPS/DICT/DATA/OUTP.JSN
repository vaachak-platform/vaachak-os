{"OUTPACE":[{"def":"To outgo; to move faster than; to leave behind.","pos":""}],"OUTPARAMOUR":[{"def":"To exceed in the number of mistresses.","pos":""}],"OUTPARISH":[{"def":"A parish lying without the walls of, or in a remote part of, a town.","pos":""}],"OUTPART":[{"def":"An outlying part.","pos":""}],"OUTPASS":[{"def":"To pass beyond; to exceed in progress.","pos":""}],"OUTPASSION":[{"def":"To exceed in passion.","pos":""}],"OUTPENSION":[{"def":"To grant an outpension to.","pos":""}],"OUTPLAY":[{"def":"To excel or defeat in a game; to play better than; as, to be outplayed in tennis or ball.","pos":""}],"OUTPORT":[{"def":"A harbor or port at some distance from the chief town or seat of trade.","pos":""}],"OUTPOUR":[{"def":"A flowing out; a free discharge.","pos":""}],"OUTPOWER":[{"def":"To excel in power; to overpover.","pos":""}],"OUTPRAY":[{"def":"To exceed or excel in prayer.","pos":""}],"OUTPREACH":[{"def":"To surpass in preaching.","pos":""}],"OUTPRIZE":[{"def":"To prize beyong value, or in excess; to exceed in value.","pos":""}],"OUTPUT":[{"def":"That which is thrown out as products of the metabolic activity of the body; the egesta other than the fæces.","pos":""}]}