{"LOB":[{"def":"A dull, heavy person.","pos":""},{"def":"Something thick and heavy.","pos":""}],"LOBAR":[{"def":"Of or pertaining to a lobe; characterized by, or like, a lobe or lobes.","pos":""},{"def":"Consisting of, or having, lobes; lobed; as, a lobate leaf.","pos":""}],"LOBATELY":[{"def":"As a lobe; so as to make a lobe; in a lobate manner.","pos":""}],"LOBBISH":[{"def":"Like a lob; consisting of lobs.","pos":""}],"LOBBY":[{"def":"A passage or hall of communication, especially when large enough to serve also as a waiting room.","pos":""},{"def":"An apartment or passageway in the fore part of an old-fashioned cabin under the quarter-deck.","pos":""}],"LOBBYIST":[{"def":"A member of the lobby; a person who solicits members of a legislature for the purpose of influencing legislation.","pos":""}],"LOBCOCK":[{"def":"A dull, sluggish person; a lubber; a lob.","pos":""}],"LOBE":[{"def":"Any projection or division, especially one of a somewhat rounded form; as: (a) (Bot.","pos":""},{"def":"A membranous flap on the sides of the toes of certain birds, as the coot.","pos":""}],"LOBED":[{"def":"Having lobes; lobate.","pos":""}],"LOBEFOOT":[{"def":"A bird having lobate toes; esp.","pos":""}],"LOBELET":[{"def":"A small lobe; a lobule.","pos":""}],"LOBELIA":[{"def":"A genus of plants, including a great number of species.","pos":""}],"LOBELIACEOUS":[{"def":"Of or pertaining to a natural order of plants of which the genus Lobelia is the type.","pos":""}],"LOBELIN":[{"def":"A yellowish green resin from Lobelia, used as an emetic and diaphoretic.","pos":""}],"LOBELINE":[{"def":"A poisonous narcotic alkaloid extracted from the leaves of Indian tobacco (Lobelia inflata) as a yellow oil, having a tobaccolike taste and odor.","pos":""}],"LOBIPED":[{"def":"Having lobate toes, as a coot.","pos":""}],"LOBLOLLY":[{"def":"Gruel; porridge; -- so called among seamen.","pos":""}],"LOBOSA":[{"def":"An order of Rhizopoda, in which the pseudopodia are thick and irregular in form, as in the Amoeba.","pos":""}],"LOBSCOUSE":[{"def":"A combination of meat with vegetables, bread, etc.","pos":""}],"LOBSTER":[{"def":"Any large macrurous crustacean used as food, esp.","pos":""}],"LOBULAR":[{"def":"Like a lobule; pertaining to a lobule or lobules.","pos":""},{"def":"Made up of, or divided into, lobules; as, a lobulated gland.","pos":""}],"LOBULE":[{"def":"A small lobe; a subdivision of a lobe.","pos":""}],"LOBULETTE":[{"def":"A little lobule, or subdivision of a lobule.","pos":""}]}