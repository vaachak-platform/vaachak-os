{"INSUAVITY":[{"def":"Want of suavity; unpleasantness.","pos":""}],"INSUBJECTION":[{"def":"Want of subjection or obedience; a state of disobedience, as to government.","pos":""}],"INSUBMERGIBLE":[{"def":"Not capable of being submerged; buoyant.","pos":""}],"INSUBMISSION":[{"def":"Want of submission; disobedience; noncompliance.","pos":""}],"INSUBORDINATION":[{"def":"The quality of being insubordinate; disobedience to lawful authority.","pos":""}],"INSUBSTANTIAL":[{"def":"Unsubstantial; not real or strong.","pos":""}],"INSUBSTANTIALITY":[{"def":"Unsubstantiality; unreality.","pos":""}],"INSUCCATION":[{"def":"The act of soaking or moistening; maceration; solution in the juice of herbs.","pos":""}],"INSUCCESS":[{"def":"Want of success.","pos":""}],"INSUETUDE":[{"def":"The state or quality of being unaccustomed; absence of use or habit.","pos":""}],"INSUFFERABLE":[{"def":"Incapable of being suffered, borne, or endured; insupportable; unendurable; intolerable; as, insufferable heat, cold, or pain; insufferable wrongs.","pos":""},{"def":"Offensive beyond endurance; detestable.","pos":""}],"INSUFFERABLY":[{"def":"In a manner or to a degree beyond endurance; intolerably; as, a blaze insufferably bright; a person insufferably proud.","pos":""}],"INSUFFICIENCY":[{"def":"The quality or state of being insufficient; want of sufficiency; deficiency; inadequateness; as, the insufficiency of provisions, of an excuse, etc.","pos":""},{"def":"Want of power or skill; inability; incapacity; incompetency; as, the insufficiency of a man for an office.","pos":""}],"INSUFFICIENT":[{"def":"Not sufficient; not enough; inadequate to any need, use, or purpose; as, the provisions are insufficient in quantity, and defective in quality.","pos":""},{"def":"Wanting in strength, power, ability, capacity, or skill; incompetent; incapable; unfit; as, a person insufficient to discharge the duties of an office.","pos":""}],"INSUFFICIENTLY":[{"def":"In an insufficient manner or degree; unadequately.","pos":""}],"INSUFFLATE":[{"def":"To blow upon; to breath upon or into; to use insufflation upon.","pos":""}],"INSUFFLATION":[{"def":"The act of breathing on or into anything; especially: (a) (R.","pos":""}],"INSULAR":[{"def":"Of or pertaining to an island; of the nature, or possessing the characteristics, of an island; as, an insular climate, fauna, etc.","pos":""},{"def":"Of or pertaining to the people of an island; narrow; circumscribed; illiberal; contracted; as, insular habits, opinions, or prejudices.","pos":""}],"INSULARITY":[{"def":"The state or quality of being an island or consisting of islands; insulation.","pos":""},{"def":"Narrowness or illiberality of opinion; prejudice; exclusiveness; as, the insularity of the Chinese or of the aristocracy.","pos":""}],"INSULARLY":[{"def":"In an insular manner.","pos":""}],"INSULATE":[{"def":"To prevent the transfer o Insulating stool (Elec.","pos":""}],"INSULATED":[{"def":"Separated from other bodies by means of nonconductors of heat or electricity.","pos":""},{"def":"Situated at so great a distance as to be beyond the effect of gravitation; -- said of stars supposed to be so far apart that the affect of their mutual attraction is insensible.","pos":""}],"INSULATION":[{"def":"The act of separating a body from others by nonconductors, so as to prevent the transfer of electricity or of heat; also, the state of a body so separated.","pos":""}],"INSULATOR":[{"def":"The substance or body that insulates; a nonconductor.","pos":""}],"INSULITE":[{"def":"An insulating material, usually some variety of compressed cellulose, made of sawdust, paper pulp, cotton waste, etc.","pos":""}],"INSULOUS":[{"def":"Abounding in islands.","pos":""}],"INSULSE":[{"def":"Insipid; dull; stupid.","pos":""}],"INSULSITY":[{"def":"Insipidity; stupidity; dullness.","pos":""}],"INSULT":[{"def":"The act of leaping on; onset; attack.","pos":""},{"def":"Gross abuse offered to another, either by word or act; an act or speech of insolence or contempt; an affront; an indignity.","pos":""}],"INSULTABLE":[{"def":"Capable of being insulted or affronted.","pos":""}],"INSULTATION":[{"def":"The act of insulting; abusive or insolent treatment; insult.","pos":""}],"INSULTER":[{"def":"One who insults.","pos":""}],"INSULTING":[{"def":"Containing, or characterized by, insult or abuse; tending to insult or affront; as, insulting language, treatment, etc.","pos":""}],"INSULTMENT":[{"def":"Insolent treatment; insult.","pos":""}],"INSUME":[{"def":"To take in; to absorb.","pos":""}],"INSUPERABILITY":[{"def":"The quality or state of being insuperable; insuperableness.","pos":""}],"INSUPERABLE":[{"def":"Incapable of being passed over or surmounted; insurmountable; as, insuperable difficulties.","pos":""}],"INSUPPORTABLE":[{"def":"Incapable of being supported or borne; unendurable; insufferable; intolerable; as, insupportable burdens; insupportable pain.","pos":""}],"INSUPPOSABLE":[{"def":"Incapable of being supposed; not supposable; inconceivable.","pos":""}],"INSUPPRESSIBLE":[{"def":"That can not be suppressed or concealed; irrepressible.","pos":""}],"INSURABLE":[{"def":"Capable of being insured against loss, damage, death, etc.","pos":""}],"INSURANCE":[{"def":"The act of insuring, or assuring, against loss or damage by a contingent event; a contract whereby, for a stipulated consideration, called premium, one party undertakes to indemnify or guarantee another against loss by certain specified risks.","pos":""},{"def":"Note: The person who undertakes to pay in case of loss is termed the insurer; the danger against which he undertakes, the risk; the person protected, the insured; the sum which he pays for the protection, the premium; and the contract itself, when reduced to form, the policy.","pos":""}],"INSURANCER":[{"def":"One who effects insurance; an insurer; an underwriter.","pos":""}],"INSURANT":[{"def":"The person insured.","pos":""}],"INSURE":[{"def":"To make sure or secure; as, to insure safety to any one.","pos":""}],"INSURER":[{"def":"One who, or that which, insures; the person or company that contracts to indemnify losses for a premium; an underwriter.","pos":""},{"def":"A state of insurrection; an uprising; an insurrection.","pos":""}],"INSURGENT":[{"def":"Rising in opposition to civil or political authority, or against an established government; insubordinate; rebellious.","pos":""}],"INSURMOUNTABILITY":[{"def":"The state or quality of being insurmountable.","pos":""}],"INSURMOUNTABLE":[{"def":"Incapable of being passed over, surmounted, or overcome; insuperable; as, insurmountable difficulty or obstacle.","pos":""}],"INSURMOUNTABLENESS":[{"def":"The state or quality of being insurmountable; insurmountability.","pos":""}],"INSURMOUNTABLY":[{"def":"In a manner or to a degree not to be overcome.","pos":""}],"INSURRECTION":[{"def":"A rising against civil or political authority, or the established government; open and active opposition to the execution of law in a city or state.","pos":""},{"def":"A rising in mass to oppose an enemy.","pos":""}],"INSURRECTIONAL":[{"def":"Pertaining to insurrection; consisting in insurrection.","pos":""}],"INSURRECTIONARY":[{"def":"Pertaining to, or characterized by, insurrection; rebellious; seditious.","pos":""}],"INSURRECTIONIST":[{"def":"One who favors, or takes part in, insurrection; an insurgent.","pos":""}],"INSUSCEPTIBILITY":[{"def":"Want of susceptibility, or of capacity to feel or perceive.","pos":""}],"INSUSCEPTIBLE":[{"def":"Not susceptible; not capable of being moved, affected, or impressed; that can not feel, receive, or admit; as, a limb insusceptible of pain; a heart insusceptible of pity; a mind insusceptible to flattery.","pos":""}],"INSUSCEPTIVE":[{"def":"Not susceptive or susceptible.","pos":""}],"INSUSURRATION":[{"def":"The act of whispering into something.","pos":""}]}