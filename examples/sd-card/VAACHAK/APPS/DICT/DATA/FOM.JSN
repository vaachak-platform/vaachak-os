{"FOMALHAUT":[{"def":"A star of the first magnitude, in the constellation Piscis Australis, or Southern Fish.","pos":""}],"FOMENT":[{"def":"To apply a warm lotion to; to bathe with a cloth or sponge wet with warm water or medicated liquid.","pos":""},{"def":"To cherish with heat; to foster.","pos":""}],"FOMENTATION":[{"def":"Excitation; instigation; encouragement.","pos":""}],"FOMENTER":[{"def":"One who foments; one who encourages or instigates; as, a fomenter of sedition.","pos":""}],"FOMES":[{"def":"Any substance supposed to be capable of absorbing, retaining, and transporting contagious or infectious germs; as, woolen clothes are said to be active fomites.","pos":""}]}