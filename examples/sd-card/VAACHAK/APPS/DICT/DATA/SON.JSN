{"SON":[{"def":"Jesus Christ, the Savior; -- called the Son of God, and the Son of man.","pos":""}],"SON-IN-LAW":[{"def":"The husband of one's daughter; a man in his relationship to his wife's parents.","pos":""}],"SONANCE":[{"def":"A sound; a tune; as, to sound the tucket sonance.","pos":""},{"def":"The quality or state of being sonant.","pos":""}],"SONANT":[{"def":"Uttered, as an element of speech, with tone or proper vocal sound, as distinguished from mere breath sound; intonated; voiced; tonic; the opposite of nonvocal, or surd; -- sid of the vowels, semivowels, liquids, and nasals, and particularly of the consonants b, d, g hard, v, etc.","pos":""},{"def":"A sonant letter.","pos":""}],"SONATA":[{"def":"An extended composition for one or two instruments, consisting usually of three or four movements; as, Beethoven's sonatas for the piano, for the violin and piano, etc.","pos":""}],"SONATINA":[{"def":"A short and simple sonata.","pos":""},{"def":"Lucky; fortunate; thriving; plump.","pos":""}],"SONDERCLASS":[{"def":"A special class of small yachts developed in Germany under the patronage of Emperor William and Prince Henry of Prussia, and so called because these yachts do not conform to the restrictions for the regular classes established by the rules of the International Yacht Racing Union.","pos":""}],"SONG":[{"def":"That which is sung or uttered with musical modulations of the voice, whether of a human being or of a bird, insect, etc.","pos":""},{"def":"A lyrical poem adapted to vocal music; a ballad.","pos":""}],"SONGCRAFT":[{"def":"The art of making songs or verse; metrical composition; versification.","pos":""}],"SONGFUL":[{"def":"Disposed to sing; full of song.","pos":""}],"SONGISH":[{"def":"Consisting of songs.","pos":""}],"SONGLESS":[{"def":"Destitute of the power of song; without song; as, songless birds; songless woods.","pos":""}],"SONGSTER":[{"def":"One who sings; one skilled in singing; -- not often applied to human beings.","pos":""}],"SONGSTRESS":[{"def":"A woman who sings; a female singing bird.","pos":""}],"SONIFER":[{"def":"A kind of ear trumpet for the deaf, or the partially deaf.","pos":""}],"SONIFEROUS":[{"def":"Sounding; producing sound; conveying sound.","pos":""}],"SONIFICATION":[{"def":"The act of producing sound, as the stridulation of insects.","pos":""}],"SONLESS":[{"def":"Being without a son.","pos":""}],"SONNET":[{"def":"A short poem, -- usually amatory.","pos":""},{"def":"A poem of fourteen lines, -- two stanzas, called the octave, being of four verses each, and two stanzas, called the sestet, of three verses each, the rhymes being adjusted by a particular rule.","pos":""}],"SONNETEER":[{"def":"A composer of sonnets, or small poems; a small poet; -- usually in contempt.","pos":""}],"SONNETER":[{"def":"A composer of sonnets.","pos":""}],"SONNETIST":[{"def":"A sonneter, or sonneteer.","pos":""}],"SONNETIZE":[{"def":"To compose sonnets.","pos":""}],"SONNISH":[{"def":"Like the sun; sunny; golden.","pos":""}],"SONOMETER":[{"def":"An instrument for exhibiting the transverse vibrations of cords, and ascertaining the relations between musical notes.","pos":""}],"SONORAN":[{"def":"Pertaining to or designating the arid division of the Austral zone, including the warmer parts of the western United States and central Mexico.","pos":""}],"SONORIFIC":[{"def":"Producing sound; as, the sonorific quality of a body.","pos":""}],"SONORITY":[{"def":"The quality or state of being sonorous; sonorousness.","pos":""}],"SONOROUS":[{"def":"Sonant; vibrant; hence, of sounds produced in a cavity, deep- toned; as, sonorous rhonchi.","pos":""}],"SONSHIP":[{"def":"The state of being a son, or of bearing the relation of a son; filiation.","pos":""}],"SONTAG":[{"def":"A knitted worsted jacket, worn over the waist of a woman's dress.","pos":""}],"SONTIES":[{"def":"Probably from \"saintes\" saints, or from sanctities; -- used as an oath.","pos":""}]}