{"CHUB":[{"def":"A species to fresh-water fish of the Cyprinidæ or Carp family.","pos":""}],"CHUB-FACED":[{"def":"Having a plump, short face.","pos":""}],"CHUBBEDNESS":[{"def":"The state of being chubby.","pos":""}],"CHUBBY":[{"def":"Like a chub; plump, short, and thick.","pos":""}],"CHUCK":[{"def":"To make a noise resembling that of a hen when she calls her chickens; to cluck.","pos":""},{"def":"To chuckle; to laugh.","pos":""}],"CHUCK-WILL'S-WIDOW":[{"def":"A species of goatsucker (Antrostomus Carolinensis), of the southern United States; -- so called from its note.","pos":""}],"CHUCKLE":[{"def":"To call, as a hen her chickens; to cluck.","pos":""},{"def":"To fondle; to cocker.","pos":""}],"CHUCKLEHEAD":[{"def":"A person with a large head; a numskull; a dunce.","pos":""}],"CHUCKLEHEADED":[{"def":"Having a large head; thickheaded; dull; stupid.","pos":""}],"CHUD":[{"def":"To champ; to bite.","pos":""}],"CHUFA":[{"def":"A sedgelike plant (Cyperus esculentus) producing edible tubers, native about the Mediterranean, now cultivated in many regions; the earth almond.","pos":""}],"CHUFF":[{"def":"A coarse or stupid fellow.","pos":""}],"CHUFFILY":[{"def":"Clownishly; surlily.","pos":""}],"CHUFFINESS":[{"def":"The quality of being chuffy.","pos":""}],"CHUFFY":[{"def":"Fat or puffed out in the cheeks.","pos":""},{"def":"Rough; clownish; surly.","pos":""}],"CHULAN":[{"def":"The fragrant flowers of the Chloranthus inconspicuus, used in China for perfuming tea.","pos":""}],"CHUM":[{"def":"A roommate, especially in a college or university; an old and intimate friend.","pos":""}],"CHUMP":[{"def":"A short, thick, heavy piece of wood.","pos":""}],"CHUNAM":[{"def":"Quicklime; also, plaster or mortar.","pos":""}],"CHUNK":[{"def":"A short, thick piece of anything.","pos":""}],"CHUNKY":[{"def":"Short and thick.","pos":""}],"CHUPATTY":[{"def":"A kind of griddlecake of unleavened bread, used among the natives of India.","pos":""},{"def":"A messenger or servant wearing an official badge.","pos":""}],"CHURCH":[{"def":"A building set apart for Christian worship.","pos":""},{"def":"A Jewish or heathen temple.","pos":""}],"CHURCH MODES":[{"def":"The modes or scales used in ancient church music.","pos":""}],"CHURCH-ALE":[{"def":"A church or parish festival (as in commemoration of the dedication of a church), at which much ale was used.","pos":""}],"CHURCH-BENCH":[{"def":"A seat in the porch of a church.","pos":""}],"CHURCHDOM":[{"def":"The institution, government, or authority of a church.","pos":""}],"CHURCHGOER":[{"def":"One who attends church.","pos":""}],"CHURCHGOING":[{"def":"Habitually attending church.","pos":""},{"def":"Summoning to church.","pos":""}],"CHURCHISM":[{"def":"Strict adherence to the forms or principles of some church organization; sectarianism.","pos":""}],"CHURCHLESS":[{"def":"Without a church.","pos":""}],"CHURCHLIKE":[{"def":"Befitting a church or a churchman; becoming to a clergyman.","pos":""}],"CHURCHLINESS":[{"def":"Regard for the church.","pos":""}],"CHURCHLY":[{"def":"Pertaining to, or suitable for, the church; ecclesiastical.","pos":""}],"CHURCHMAN":[{"def":"An ecclesiastic or clergyman.","pos":""},{"def":"An Episcopalian, or a member of the Established Church of England.","pos":""}],"CHURCHMANLY":[{"def":"Pertaining to, or becoming, a churchman.","pos":""}],"CHURCHMANSHIP":[{"def":"The state or quality of being a churchman; attachment to the church.","pos":""}],"CHURCHSHIP":[{"def":"State of being a church.","pos":""}],"CHURCHWARDEN":[{"def":"One of the officers (usually two) in an Episcopal church, whose duties vary in different dioceses, but always include the provision of what is necessary for the communion service.","pos":""},{"def":"A clay tobacco pipe, with a long tube.","pos":""}],"CHURCHWARDENSHIP":[{"def":"The office of a churchwarden.","pos":""}],"CHURCHY":[{"def":"Relating to a church; unduly fond of church forms.","pos":""}],"CHURCHYARD":[{"def":"The ground adjoining a church, in which the dead are buried; a cemetery.","pos":""}],"CHURL":[{"def":"A rustic; a countryman or laborer.","pos":""},{"def":"A rough, surly, ill-bred man; a boor.","pos":""}],"CHURLISH":[{"def":"Like a churl; rude; cross-grained; ungracious; surly; illiberal; niggardly.","pos":""},{"def":"Wanting pliancy; unmanageable; unyielding; not easily wrought; as, a churlish soil; the churlish and intractable nature of some minerals.","pos":""}],"CHURLISHLY":[{"def":"In a churlish manner.","pos":""}],"CHURLISHNESS":[{"def":"Rudeness of manners or temper; lack of kindness or courtesy.","pos":""}],"CHURLY":[{"def":"Rude; churlish; violent.","pos":""},{"def":"Clamor, or confused noise; buzzing.","pos":""}],"CHURN":[{"def":"A vessel in which milk or cream is stirred, beaten, or otherwise agitated (as by a plunging or revolving dasher) in order to separete the oily globules from the other parts, and obtain butter.","pos":""}],"CHURNING":[{"def":"The act of one who churns.","pos":""},{"def":"The quantity of butter made at one operation.","pos":""}],"CHURR":[{"def":"A vibrant or whirring noise such as that made by some insects, as the cockchafer, or by some birds, as the nightjar, the partridge, etc.","pos":""}],"CHURRUS":[{"def":"A powerfully narcotic and intoxicating gum resin which exudes from the flower heads, seeds, etc.","pos":""}],"CHURRWORM":[{"def":"An insect that turns about nimbly; the mole cricket; -- called also fan cricket.","pos":""}],"CHUTE":[{"def":"A warm or spicy condiment or pickle made in India, compounded of various vegetable substances, sweets, acids, etc.","pos":""}]}