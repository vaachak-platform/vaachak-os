{"COLOBOMA":[{"def":"A defect or malformation; esp.","pos":""}],"COLOCOLO":[{"def":"A South American wild cat (Felis colocolo), of the size of the ocelot.","pos":""}],"COLOCYNTH":[{"def":"The light spongy pulp of the fruit of the bitter cucumber (Citrullus, or Cucumis, colocynthis), an Asiatic plant allied to the watermelon; coloquintida.","pos":""}],"COLOCYNTHIN":[{"def":"The active medicinal principle of colocynth; a bitter, yellow, crystalline substance, regarded as a glucoside.","pos":""}],"COLOGNE":[{"def":"A perfumed liquid, composed of alcohol and certain aromatic oils, used in the toilet; -- called also cologne water and eau de cologne.","pos":""}],"COLOGNE EARTH":[{"def":"An earth of a deep brown color, containing more vegetable than mineral matter; an earthy variety of lignite, or brown coal.","pos":""}],"COLOMBIER":[{"def":"A large size of paper for drawings.","pos":""}],"COLON":[{"def":"That part of the large intestines which extends from the cæcum to the rectum.","pos":""},{"def":"A point or character, formed thus [:], used to separate parts of a sentence that are complete in themselves and nearly independent, often taking the place of a conjunction.","pos":""}],"COLONEL":[{"def":"The chief officer of a regiment; an officer ranking next above a lieutenant colonel and next below a brigadier general.","pos":""}],"COLONELCY":[{"def":"The office, rank, or commission of a colonel.","pos":""}],"COLONIAL":[{"def":"Of or pertaining to a colony; as, colonial rights, traffic, wars.","pos":""}],"COLONIALISM":[{"def":"The state or quality of, or the relationship involved in, being colonial.","pos":""},{"def":"A custom, idea, feature of government, or the like, characteristic of a colony.","pos":""}],"COLONICAL":[{"def":"Of or pertaining to husbandmen.","pos":""}],"COLONIST":[{"def":"A member or inhabitant of a colony.","pos":""}],"COLONIZATION":[{"def":"Tha act of colonizing, or the state of being colonized; the formation of a colony or colonies.","pos":""}],"COLONIZATIONIST":[{"def":"A friend to colonization, esp.","pos":""}],"COLONIZE":[{"def":"To plant or establish a colony or colonies in; to people with colonists; to migrate to and settle in.","pos":""}],"COLONIZER":[{"def":"One who promotes or establishes a colony; a colonist.","pos":""}],"COLONNADE":[{"def":"A series or range of columns placed at regular intervals with all the adjuncts, as entablature, stylobate, roof, etc.","pos":""}],"COLONY":[{"def":"A number of animals or plants living or growing together, beyond their usual range.","pos":""}],"COLOPHANY":[{"def":"Col\"o*pha`ny ( or ), n.","pos":""}],"COLOPHENE":[{"def":"A colorless, oily liquid, formerly obtained by distillation of colophony.","pos":""}],"COLOPHON":[{"def":"An inscription, monogram, or cipher, containing the place and date of publication, printer's name, etc.","pos":""}],"COLOPHONITE":[{"def":"A coarsely granular variety of garnet.","pos":""}],"COLOPHONY":[{"def":"Col\"o*pho`ny ( or ; 277), n.","pos":""}],"COLOR":[{"def":"An apparent right; as where the defendant in trespass gave to the plaintiff an appearance of title, by stating his title specially, thus removing the cause from the jury to the court.","pos":""}],"COLOR SERGEANT":[{"def":"See under Sergeant.","pos":""}],"COLOR-BLIND":[{"def":"Affected with color blindness.","pos":""}],"COLORABLE":[{"def":"Specious; plausible; having an appearance of right or justice.","pos":""}],"COLORADO BEETLE":[{"def":"A yellowish beetle (Doryphora decemlineata), with ten longitudinal, black, dorsal stripes.","pos":""}],"COLORADO GROUP":[{"def":"A subdivision of the cretaceous formation of western North America, especially developed in Colorado and the upper Missouri region.","pos":""}],"COLORADOITE":[{"def":"Mercury telluride, an iron-black metallic mineral, found in Colorado.","pos":""}],"COLORATION":[{"def":"The act or art of coloring; the state of being colored.","pos":""}],"COLORATURE":[{"def":"Vocal music colored, as it were, by florid ornaments, runs, or rapid passages.","pos":""}],"COLORED":[{"def":"Of some other color than white; specifically applied to negroes or persons having negro blood; as, a colored man; the colored people.","pos":""},{"def":"Of some other color than green.","pos":""}],"COLORIFIC":[{"def":"Capable of communicating color or tint to other bodies.","pos":""}],"COLORIMETER":[{"def":"An instrument for measuring the depth of the color of anything, especially of a liquid, by comparison with a standard liquid.","pos":""}],"COLORIMETRY":[{"def":"The quantitative determination of the depth of color of a substance.","pos":""}],"COLORING":[{"def":"The act of applying color to; also, that which produces color.","pos":""},{"def":"Change of appearance as by addition of color; appearance; show; disguise; misrepresentation.","pos":""}],"COLORIST":[{"def":"One who colors; an artist who excels in the use of colors; one to whom coloring is of prime importance.","pos":""}],"COLORLESS":[{"def":"Without color; not distinguished by any hue; transparent; as, colorless water.","pos":""},{"def":"Free from any manifestation of partial or peculiar sentiment or feeling; not disclosing likes, dislikes, prejudice, etc.","pos":""}],"COLORMAN":[{"def":"A vender of paints, etc.","pos":""}],"COLOSSAL":[{"def":"Of a size larger than heroic.","pos":""}],"COLOSSEUM":[{"def":"The amphitheater of Vespasian in Rome.","pos":""}],"COLOSSUS":[{"def":"A statue of gigantic size.","pos":""},{"def":"Any man or beast of gigantic size.","pos":""}]}