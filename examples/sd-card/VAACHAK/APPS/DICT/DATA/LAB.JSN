{"LAB":[{"def":"To prate; to gossip; to babble; to blab.","pos":""}],"LABADIST":[{"def":"A follower of Jean de Labadie, a religious teacher of the 17th century, who left the Roman Catholic Church and taught a kind of mysticism, and the obligation of community of property among Christians.","pos":""}],"LABARRAQUE'S SOLUTION":[{"def":"An aqueous solution of hypochlorite of sodium, extensively used as a disinfectant.","pos":""}],"LABARUM":[{"def":"The standard adopted by the Emperor Constantine after his conversion to Christianity.","pos":""}],"LABEFACTION":[{"def":"The act of labefying or making weak; the state of being weakened; decay; ruin.","pos":""}],"LABEFY":[{"def":"To weaken or impair.","pos":""}],"LABEL":[{"def":"A barrulet, or, rarely, a bendlet, with pendants, or points, usually three, especially used as a mark of cadency to distinguish an eldest or only son while his father is still living.","pos":""},{"def":"The name now generally given to the projecting molding by the sides, and over the tops, of openings in mediæval architecture.","pos":""}],"LABELLUM":[{"def":"The lower or apparently anterior petal of an orchidaceous flower, often of a very curious shape.","pos":""},{"def":"A small appendage beneath the upper lip or labrum of certain insects.","pos":""}],"LABENT":[{"def":"Slipping; sliding; gliding.","pos":""}],"LABIAL":[{"def":"Furnished with lips; as, a labial organ pipe.","pos":""},{"def":"Of or pertaining to the labium; as, the labial palpi of insects.","pos":""}],"LABIALISM":[{"def":"The quality of being labial; as, the labialism of an articulation; conversion into a labial, as of a sound which is different in another language.","pos":""}],"LABIALIZATION":[{"def":"The modification of an articulation by contraction of the lip opening.","pos":""}],"LABIALIZE":[{"def":"To modify by contraction of the lip opening.","pos":""}],"LABIALLY":[{"def":"In a labial manner; with, or by means of, the lips.","pos":""}],"LABIATE":[{"def":"A plant of the order Labiatæ.","pos":""}],"LABIATED":[{"def":"Same as Labiate, a.","pos":""},{"def":"Having labiate flowers, as the snapdragon.","pos":""}],"LABIDOMETER":[{"def":"A forceps with a measuring attachment for ascertaining the size of the fetal head.","pos":""}],"LABILE":[{"def":"Liable to slip, err, fall, or apostatize.","pos":""}],"LABILITY":[{"def":"Liability to lapse, err, or apostatize.","pos":""}],"LABIMETER":[{"def":"See Labidometer.","pos":""}],"LABIODENTAL":[{"def":"Formed or pronounced by the cooperation of the lips and teeth, as f and v.","pos":""},{"def":"A labiodental sound or letter.","pos":""}],"LABIONASAL":[{"def":"Formed by the lips and the nose.","pos":""},{"def":"A labionasal sound or letter.","pos":""}],"LABIOPLASTY":[{"def":"A plastic operation for making a new lip, or for replacing a lost tissue of a lip.","pos":""}],"LABIOSE":[{"def":"Having the appearance of being labiate; -- said of certain polypetalous corollas.","pos":""}],"LABIPALPUS":[{"def":"One of the labial palpi of an insect.","pos":""}],"LABIUM":[{"def":"The folds of integument at the opening of the vulva.","pos":""}],"LABLAB":[{"def":"an East Indian name for several twining leguminous plants related to the bean, but commonly applied to the hyacinth bean (Delichos Lablab).","pos":""}],"LABOR":[{"def":"The pitching or tossing of a vessel which results in the straining of timbers and rigging.","pos":""},{"def":"A measure of land in Mexico and Texas, equivalent to an area of 177 Bartlett.","pos":""}],"LABOR DAY":[{"def":"In most of the States and Territories of the United States, a day, usually the first Monday of September, set aside as a legal holiday, in honor of, or in the interest of, workingmen as a class.","pos":""}],"LABOR-SAVING":[{"def":"Saving labor; adapted to supersede or diminish the labor of men; as, laborsaving machinery.","pos":""}],"LABORATORY":[{"def":"The workroom of a chemist; also, a place devoted to experiments in any branch of natural science; as, a chemical, physical, or biological laboratory.","pos":""}],"LABORED":[{"def":"Bearing marks of labor and effort; elaborately wrought; not easy or natural; as, labored poetry; a labored style.","pos":""}],"LABOREDLY":[{"def":"In a labored manner; with labor.","pos":""}],"LABORER":[{"def":"One who labors in a toilsome occupation; a person who does work that requires strength rather than skill, as distinguished from that of an artisan.","pos":""}],"LABORING":[{"def":"That labors; performing labor; esp.","pos":""},{"def":"Suffering pain or grief.","pos":""}],"LABORIOUS":[{"def":"Requiring labor, perseverance, or sacrifices; toilsome; tiresome.","pos":""},{"def":"Devoted to labor; diligent; industrious; as, a laborious mechanic.","pos":""}],"LABORLESS":[{"def":"Not involving labor; not laborious; easy.","pos":""}],"LABORSOME":[{"def":"Likely or inclined to roll or pitch, as a ship in a heavy sea; having a tendency to labor.","pos":""}],"LABRADOR":[{"def":"A region of British America on the Atlantic coast, north of Newfoundland.","pos":""}],"LABRADORITE":[{"def":"A kind of feldspar commonly showing a beautiful play of colors, and hence much used for ornamental purposes.","pos":""}],"LABRET":[{"def":"A piece of wood, shell, stone, or other substance, worn in a perforation of the lip or cheek by many savages.","pos":""}],"LABROID":[{"def":"Like the genus Labrus; belonging to the family Labridæ, an extensive family of marine fishes, often brilliantly colored, which are very abundant in the Indian and Pacific Oceans.","pos":""}],"LABROSE":[{"def":"Having thick lips.","pos":""}],"LABRUM":[{"def":"A lip or edge, as of a basin.","pos":""}],"LABRUS":[{"def":"A genus of marine fishes, including the wrasses of Europe.","pos":""}],"LABURNIC":[{"def":"Of, pertaining to, or derived from, the laburnum.","pos":""}],"LABURNINE":[{"def":"A poisonous alkaloid found in the unripe seeds of the laburnum.","pos":""}],"LABURNUM":[{"def":"A small leguminous tree (Cytisus Laburnum), native of the Alps.","pos":""}],"LABYRINTH":[{"def":"The internal ear.","pos":""},{"def":"A series of canals through which a stream of water is directed for suspending, carrying off, and depositing at different distances, the ground ore of a metal.","pos":""}],"LABYRINTHAL":[{"def":"Pertaining to, or resembling, a labyrinth; intricate; labyrinthian.","pos":""}],"LABYRINTHIAN":[{"def":"Intricately winding; like a labyrinth; perplexed; labyrinthal.","pos":""}],"LABYRINTHIBRANCH":[{"def":"Of or pertaining to the Labyrinthici.","pos":""},{"def":"One of the Labyrinthici.","pos":""}],"LABYRINTHICI":[{"def":"An order of teleostean fishes, including the Anabas, or climbing perch, and other allied fishes.","pos":""}],"LABYRINTHIFORM":[{"def":"Having the form of a labyrinth; intricate.","pos":""}],"LABYRINTHINE":[{"def":"Pertaining to, or like, a labyrinth; labyrinthal.","pos":""}],"LABYRINTHODON":[{"def":"A genus of very large fossil amphibians, of the Triassic period, having bony plates on the under side of the body.","pos":""}],"LABYRINTHODONT":[{"def":"Of or pertaining to the Labyrinthodonta.","pos":""},{"def":"One of the Labyrinthodonta.","pos":""}],"LABYRINTHODONTA":[{"def":"An extinct order of Amphibia, including the typical genus Labyrinthodon, and many other allied forms, from the Carboniferous, Permian, and Triassic formations.","pos":""},{"def":"One hundred thousand; also, a vaguely great number; as, a lac of rupees.","pos":""}]}