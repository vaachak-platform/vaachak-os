{"CLAY":[{"def":"Earth in general, as representing the elementary particles of the human body; hence, the human body as formed from such particles.","pos":""}],"CLAYES":[{"def":"Wattles, or hurdles, made with stakes interwoven with osiers, to cover lodgments.","pos":""}],"CLAYEY":[{"def":"Consisting of clay; abounding with clay; partaking of clay; like clay.","pos":""}],"CLAYISH":[{"def":"Partaking of the nature of clay, or containing particles of it.","pos":""}],"CLAYMORE":[{"def":"A large two-handed sword used formerly by the Scottish Highlanders.","pos":""}],"CLAYTONIA":[{"def":"An American genus of perennial herbs with delicate blossoms; -- sometimes called spring beauty.","pos":""}]}