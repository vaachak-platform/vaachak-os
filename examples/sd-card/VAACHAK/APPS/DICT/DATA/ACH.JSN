{"ACHARNEMENT":[{"def":"Savage fierceness; ferocity.","pos":""}],"ACHATE":[{"def":"Purchase; bargaining.","pos":""}],"ACHATINA":[{"def":"A genus of land snails, often large, common in the warm parts of America and Africa.","pos":""}],"ACHATOUR":[{"def":"Purveyor; acater.","pos":""}],"ACHE":[{"def":"Continued pain, as distinguished from sudden twinges, or spasmodic pain.","pos":""}],"ACHEAN":[{"def":"See Achæan, Achaian.","pos":""},{"def":"A small, dry, indehiscent fruit, containing a single seed, as in the buttercup; -- called a naked seed by the earlier botanists.","pos":""}],"ACHENIAL":[{"def":"Pertaining to an achene.","pos":""}],"ACHERON":[{"def":"A river in the Nether World or infernal regions; also, the infernal regions themselves.","pos":""}],"ACHERONTIC":[{"def":"Of or pertaining to Acheron; infernal; hence, dismal, gloomy; moribund.","pos":""}],"ACHIEVABLE":[{"def":"Capable of being achieved.","pos":""}],"ACHIEVE":[{"def":"To carry on to a final close; to bring out into a perfected state; to accomplish; to perform; -- as, to achieve a feat, an exploit, an enterprise.","pos":""},{"def":"To obtain, or gain, as the result of exertion; to succeed in gaining; to win.","pos":""}],"ACHIEVEMENT":[{"def":"An escutcheon or ensign armorial; now generally applied to the funeral shield commonly called hatchment.","pos":""}],"ACHIEVER":[{"def":"One who achieves; a winner.","pos":""}],"ACHILLEAN":[{"def":"Resembling Achilles, the hero of the Iliad; invincible.","pos":""}],"ACHILLES' TENDON":[{"def":"The strong tendon formed of the united tendons of the large muscles in the calf of the leg, an inserted into the bone of the heel; -- so called from the mythological account of Achilles being held by the heel when dipped in the River Styx.","pos":""}],"ACHING":[{"def":"That aches; continuously painful.","pos":""}],"ACHIOTE":[{"def":"Seeds of the annotto tree; also, the coloring matter, annotto.","pos":""}],"ACHLAMYDATE":[{"def":"Not possessing a mantle; -- said of certain gastropods.","pos":""}],"ACHLAMYDEOUS":[{"def":"Naked; having no floral envelope, neither calyx nor corolla.","pos":""}],"ACHOLIA":[{"def":"Deficiency or want of bile.","pos":""}],"ACHROMATIC":[{"def":"Free from color; transmitting light without decomposing it into its primary colors.","pos":""},{"def":"Uncolored; not absorbing color from a fluid; -- said of tissue.","pos":""}],"ACHROMATICALLY":[{"def":"In an achromatic manner.","pos":""}],"ACHROMATICITY":[{"def":"Ach`ro*ma*tic\"i*ty, n.","pos":""}],"ACHROMATIN":[{"def":"Tissue which is not stained by fluid dyes.","pos":""}],"ACHROMATISM":[{"def":"The state or quality of being achromatic; as, the achromatism of a lens; achromaticity.","pos":""}],"ACHROMATIZATION":[{"def":"The act or process of achromatizing.","pos":""}],"ACHROMATIZE":[{"def":"To deprive of color; to make achromatic.","pos":""}],"ACHROMATOPSY":[{"def":"Color blindness; inability to distinguish colors; Daltonism.","pos":""}],"ACHROMATOUS":[{"def":"Lacking, or deficient in, color; as, achromatous blood.","pos":""}],"ACHROMIC":[{"def":"Free from color; colorless; as, in Physiol.","pos":""}],"ACHRONIC":[{"def":"Dextrin not colorable by iodine.","pos":""}],"ACHROOUS":[{"def":"Colorless; achromatic.","pos":""}]}