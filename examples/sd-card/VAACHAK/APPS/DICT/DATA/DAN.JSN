{"DAN":[{"def":"A title of honor equivalent to master, or sir.","pos":""}],"DANAIDE":[{"def":"A water wheel having a vertical axis, and an inner and outer tapering shell, between which are vanes or floats attached usually to both shells, but sometimes only to one.","pos":""}],"DANAITE":[{"def":"A cobaltiferous variety of arsenopyrite.","pos":""}],"DANALITE":[{"def":"A mineral occuring in octahedral crystals, also massive, of a reddish color.","pos":""}],"DANBURITE":[{"def":"A borosilicate of lime, first found at Danbury, Conn.","pos":""}],"DANCE":[{"def":"To move with measured steps, or to a musical accompaniment; to go through, either alone or in company with others, with a regulated succession of movements, (commonly) to the sound of music; to trip or leap rhytmically.","pos":""},{"def":"To move nimbly or merrily; to express pleasure by motion; to caper; to frisk; to skip about.","pos":""}],"DANCER":[{"def":"One who dances or who practices dancing.","pos":""}],"DANCERESS":[{"def":"A female dancer.","pos":""}],"DANCETTE":[{"def":"Deeply indented; having large teeth; thus, a fess dancetté has only three teeth in the whole width of the escutcheon.","pos":""}],"DANCY":[{"def":"Same as Dancetté.","pos":""}],"DANDELION":[{"def":"A well-known plant of the genus Taraxacum (T.","pos":""}],"DANDER":[{"def":"Dandruff or scurf on the head.","pos":""},{"def":"Anger or vexation; rage [Low] Halliwell.","pos":""}],"DANDI":[{"def":"A boatman; an oarsman.","pos":""}],"DANDIE":[{"def":"One of a breed of small terriers; -- called also Dandie Dinmont.","pos":""},{"def":"In Scott's \"Guy Mannering\", a Border farmer of eccentric but fine character, who owns two terriers claimed to be the progenitors of the Dandie Dinmont terriers.","pos":""}],"DANDIFIED":[{"def":"Made up like a dandy; having the dress or manners of a dandy; buckish.","pos":""}],"DANDIFY":[{"def":"To cause to resemble a dandy; to make dandyish.","pos":""}],"DANDIPRAT":[{"def":"A little fellow; -- in sport or contempt.","pos":""}],"DANDLE":[{"def":"To move up and down on one's knee or in one's arms, in affectionate play, as an infant.","pos":""},{"def":"To treat with fondness, as if a child; to fondle; to toy with; to pet.","pos":""}],"DANDLER":[{"def":"One who dandles or fondles.","pos":""}],"DANDRUFF":[{"def":"A scurf which forms on the head, and comes off in small or particles.","pos":""}],"DANDY":[{"def":"To make, or to act, like a dandy; to dandify.","pos":""}],"DANDYISM":[{"def":"The manners and dress of a dandy; foppishness.","pos":""}],"DANDYLING":[{"def":"A little or insignificant dandy; a contemptible fop.","pos":""}],"DANE":[{"def":"A native, or a naturalized inhabitant, of Denmark.","pos":""},{"def":"An annual tax formerly laid on the English nation to buy off the ravages of Danish invaders, or to maintain forces to oppose them.","pos":""}],"DANEWORT":[{"def":"A fetid European species of elder (Sambucus Ebulus); dwarf elder; wallwort; elderwort; -- called also Daneweed, Dane's weed, and Dane's-blood.","pos":""}],"DANG":[{"def":"Till she, o'ercome with anguish, shame, and rage, Danged down to hell her loathsome carriage.","pos":""}],"DANGER":[{"def":"Authority; jurisdiction; control.","pos":""},{"def":"Power to harm; subjection or liability to penalty.","pos":""}],"DANGERFUL":[{"def":"Full of danger; dangerous.","pos":""}],"DANGERLESS":[{"def":"Free from danger.","pos":""}],"DANGEROUS":[{"def":"Attended or beset with danger; full of risk; perilous; hazardous; unsafe.","pos":""},{"def":"Causing danger; ready to do harm or injury.","pos":""}],"DANGLE":[{"def":"To hang loosely, or with a swinging or jerking motion.","pos":""}],"DANGLEBERRY":[{"def":"A dark blue, edible berry with a white bloom, and its shrub (Gaylussacia frondosa) closely allied to the common huckleberry.","pos":""}],"DANGLER":[{"def":"One who dangles about or after others, especially after women; a trifler.","pos":""}],"DANIEL":[{"def":"A Hebrew prophet distinguished for sagacity and ripeness of judgment in youth; hence, a sagacious and upright judge.","pos":""}],"DANISH":[{"def":"Belonging to the Danes, or to their language or country.","pos":""},{"def":"The language of the Danes.","pos":""}],"DANITE":[{"def":"One of a secret association of Mormons, bound by an oath to obey the heads of the church in all things.","pos":""}],"DANK":[{"def":"Damp; moist; humid; wet.","pos":""}],"DANKISH":[{"def":"In a dark and dankish vault at home.","pos":""}],"DANNEBROG":[{"def":"The ancient battle standard of Denmark, bearing figures of cross and crown.","pos":""}],"DANSEUSE":[{"def":"a professional female dancer; a woman who dances at a public exhibition as in a ballet.","pos":""}],"DANSKER":[{"def":"Inquire me first what Danskers are in Paris.","pos":""}],"DANTEAN":[{"def":"Relatingto, emanating from or resembling, the poet Dante or his writings.","pos":""}],"DANTESQUE":[{"def":"Dantelike; Dantean.","pos":""}],"DANUBIAN":[{"def":"Pertainingto, or bordering on, the river Danube.","pos":""}]}