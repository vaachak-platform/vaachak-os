{"SAD":[{"def":"Sated; satisfied; weary; tired.","pos":""},{"def":"Heavy; weighty; ponderous; close; hard.","pos":""}],"SADDA":[{"def":"A work in the Persian tongue, being a summary of the Zend- Avesta, or sacred books.","pos":""}],"SADDEN":[{"def":"Marl is binding, and saddening of land is the great prejudice it doth to clay lands.","pos":""}],"SADDLE":[{"def":"A block of wood, usually fastened to some spar, and shaped to receive the end of another spar.","pos":""},{"def":"A part, as a flange, which is hollowed out to fit upon a convex surface and serve as a means of attachment or support.","pos":""}],"SADDLE-BACKED":[{"def":"Having the outline of the upper part concave like the seat of a saddle.","pos":""},{"def":"Having a low back and high neck, as a horse.","pos":""}],"SADDLE-SHAPED":[{"def":"Shaped like a saddle.","pos":""}],"SADDLEBACK":[{"def":"Same as Saddle-backed.","pos":""}],"SADDLEBAGS":[{"def":"Bags, usually of leather, united by straps or a band, formerly much used by horseback riders to carry small articles, one bag hanging on each side.","pos":""}],"SADDLEBOW":[{"def":"The bow or arch in the front part of a saddle, or the pieces which form the front.","pos":""}],"SADDLECLOTH":[{"def":"A cloth under a saddle, and extending out behind; a housing.","pos":""}],"SADDLED":[{"def":"Having a broad patch of color across the back, like a saddle; saddle-backed.","pos":""}],"SADDLER":[{"def":"One who makes saddles.","pos":""}],"SADDLERY":[{"def":"The materials for making saddles and harnesses; the articles usually offered for sale in a saddler's shop.","pos":""},{"def":"The trade or employment of a saddler.","pos":""}],"SADDLETREE":[{"def":"The frame of a saddle.","pos":""}],"SADDUCAIC":[{"def":"Pertaining to, or like, the Sadducees; as, Sadducaic reasonings.","pos":""}],"SADDUCEE":[{"def":"One of a sect among the ancient Jews, who denied the resurrection, a future state, and the existence of angels.","pos":""},{"def":"The tenets of the Sadducees.","pos":""}],"SADDUCIZE":[{"def":"To adopt the principles of the Sadducees.","pos":""}],"SADH":[{"def":"A member of a monotheistic sect of Hindoos.","pos":""}],"SADIRON":[{"def":"An iron for smoothing clothes; a flatiron.","pos":""}],"SADLY":[{"def":"Wearily; heavily; firmly.","pos":""},{"def":"Seriously; soberly; gravely.","pos":""}],"SADNESS":[{"def":"Heaviness; firmness.","pos":""},{"def":"Seriousness; gravity; discretion.","pos":""}],"SADR":[{"def":"A plant of the genus Ziziphus (Z.","pos":""}]}