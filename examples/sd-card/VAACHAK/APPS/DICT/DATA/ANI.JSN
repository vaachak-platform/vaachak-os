{"ANIGH":[{"def":"In the night time; at night.","pos":""}],"ANIL":[{"def":"A West Indian plant (Indigofera anil), one of the original sources of indigo; also, the indigo dye.","pos":""}],"ANILE":[{"def":"Old-womanish; imbecile.","pos":""}],"ANILIC":[{"def":"Pertaining to, or obtained from, anil; indigotic; -- applied to an acid formed by the action of nitric acid on indigo.","pos":""}],"ANILIDE":[{"def":"One of a class of compounds which may be regarded as amides in which more or less of the hydrogen has been replaced by phenyl.","pos":""}],"ANILINE":[{"def":"An organic base belonging to the phenylamines.","pos":""}],"ANILINISM":[{"def":"A disease due to inhaling the poisonous fumes present in the manufacture of aniline.","pos":""}],"ANILITY":[{"def":"The state of being and old woman; old-womanishness; dotage.","pos":""}],"ANIMADVERSAL":[{"def":"The faculty of perceiving; a percipient.","pos":""}],"ANIMADVERSION":[{"def":"The act or power of perceiving or taking notice; direct or simple perception.","pos":""},{"def":"Monition; warning.","pos":""}],"ANIMADVERSIVE":[{"def":"Having the power of perceiving; percipient.","pos":""}],"ANIMADVERT":[{"def":"To take notice; to observe; -- commonly followed by that.","pos":""},{"def":"To consider or remark by way of criticism or censure; to express censure; -- with on or upon.","pos":""}],"ANIMADVERTER":[{"def":"One who animadverts; a censurer; also [Obs.","pos":""}],"ANIMAL":[{"def":"One of the lower animals; a brute or beast, as distinguished from man; as, men and animals.","pos":""}],"ANIMALCULE":[{"def":"An animal, invisible, or nearly so, to the naked eye.","pos":""}],"ANIMALCULISM":[{"def":"The theory which seeks to explain certain physiological and pathological by means of animalcules.","pos":""}],"ANIMALCULIST":[{"def":"One versed in the knowledge of animalcules.","pos":""},{"def":"A believer in the theory of animalculism.","pos":""}],"ANIMALCULUM":[{"def":"Note: Animalculæ, as if from a Latin singular animalcula, is a barbarism.","pos":""}],"ANIMALISM":[{"def":"The state, activity, or enjoyment of animals; mere animal life without intellectual or moral qualities; sensuality.","pos":""}],"ANIMALITY":[{"def":"Animal existence or nature.","pos":""}],"ANIMALIZATION":[{"def":"The act of animalizing; the giving of animal life, or endowing with animal properties.","pos":""},{"def":"Conversion into animal matter by the process of assimilation.","pos":""}],"ANIMALIZE":[{"def":"To endow with the properties of an animal; to represent in animal form.","pos":""},{"def":"To convert into animal matter by the processes of assimilation.","pos":""}],"ANIMASTIC":[{"def":"Pertaining to mind or spirit; spiritual.","pos":""}],"ANIMATE":[{"def":"To give natural life to; to make alive; to quicken; as, the soul animates the body.","pos":""},{"def":"To give powers to, or to heighten the powers or effect of; as, to animate a lyre.","pos":""}],"ANIMATED":[{"def":"Endowed with life; full of life or spirit; indicating animation; lively; vigorous.","pos":""}],"ANIMATER":[{"def":"One who animates.","pos":""}],"ANIMATING":[{"def":"Causing animation; life-giving; inspiriting; rousing.","pos":""}],"ANIMATION":[{"def":"The act of animating, or giving life or spirit; the state of being animate or alive.","pos":""},{"def":"The state of being lively, brisk, or full of spirit and vigor; vivacity; spiritedness; as, he recited the story with great animation.","pos":""}],"ANIMATIVE":[{"def":"Having the power of giving life or spirit.","pos":""}],"ANIMATOR":[{"def":"One who, or that which, animates; an animater.","pos":""}],"ANIME":[{"def":"Of a different tincture from the animal itself; -- said of the eyes of a rapacious animal.","pos":""}],"ANIMISM":[{"def":"The doctrine, taught by Stahl, that the soul is the proper principle of life and development in the body.","pos":""},{"def":"The belief that inanimate objects and the phenomena of nature are endowed with personal life or a living soul; also, in an extended sense, the belief in the existence of soul or spirit apart from matter.","pos":""}],"ANIMIST":[{"def":"One who maintains the doctrine of animism.","pos":""}],"ANIMISTIC":[{"def":"Of or pertaining to animism.","pos":""},{"def":"Full of spirit; hot; vehement; resolute.","pos":""}],"ANIMOSENESS":[{"def":"Vehemence of temper.","pos":""}],"ANIMOSITY":[{"def":"Mere spiritedness or courage.","pos":""},{"def":"Violent hatred leading to active opposition; active enmity; energetic dislike.","pos":""}],"ANIMUS":[{"def":"Animating spirit; intention; temper.","pos":""}],"ANION":[{"def":"An electro-negative element, or the element which, in electro- chemical decompositions, is evolved at the anode; -- opposed to cation.","pos":""}],"ANISE":[{"def":"An umbelliferous plant (Pimpinella anisum) growing naturally in Egypt, and cultivated in Spain, Malta, etc.","pos":""}],"ANISEED":[{"def":"The seed of the anise; also, a cordial prepared from it.","pos":""}],"ANISETTE":[{"def":"A French cordial or liqueur flavored with anise seeds.","pos":""}],"ANISIC":[{"def":"Of or derived from anise; as, anisic acid; anisic alcohol.","pos":""}],"ANISOCORIA":[{"def":"Inequality of the pupils of the eye.","pos":""}],"ANISODACTYLOUS":[{"def":"Characterized by unequal toes, three turned forward and one backward, as in most passerine birds.","pos":""}],"ANISOL":[{"def":"Methyl phenyl ether, C6H5OCH3, got by distilling anisic acid or by the action of methide on potassium phenolate.","pos":""}],"ANISOMERIC":[{"def":"Not isomeric; not made of the same components in the same proportions.","pos":""}],"ANISOMEROUS":[{"def":"Having the number of floral organs unequal, as four petals and six stamens.","pos":""}],"ANISOMETRIC":[{"def":"Not isometric; having unsymmetrical parts; -- said of crystals with three unequal axes.","pos":""}],"ANISOMETROPIA":[{"def":"Unequal refractive power in the two eyes.","pos":""}],"ANISOPETALOUS":[{"def":"Having unequal petals.","pos":""}],"ANISOPHYLLOUS":[{"def":"Having unequal leaves.","pos":""}],"ANISOPLEURA":[{"def":"A primary division of gastropods, including those having spiral shells.","pos":""}],"ANISOPODA":[{"def":"A division of Crustacea, which, in some its characteristics, is intermediate between Amphipoda and Isopoda.","pos":""}],"ANISOSPORE":[{"def":"A sexual spore in which the sexes differ in size; -- opposed to isospore.","pos":""}],"ANISOSTEMONOUS":[{"def":"Having unequal stamens; having stamens different in number from the petals.","pos":""}],"ANISOSTHENIC":[{"def":"Of unequal strength.","pos":""},{"def":"Not isotropic; having different properties in different directions; thus, crystals of the isometric system are optically isotropic, but all other crystals are anisotropic.","pos":""}],"ANITO":[{"def":"In Guam and the Philippines, an idol, fetich, or spirit.","pos":""}]}