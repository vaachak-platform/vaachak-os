{"UNSYMMETRICAL":[{"def":"Not symmetrical; being without symmetry, as the parts of a flower when similar parts are of different size and shape, or when the parts of successive circles differ in number.","pos":""},{"def":"Being without symmetry of chemical structure or relation; as, an unsymmetrical carbon atom.","pos":""}],"UNSYMMETRICALLY":[{"def":"Not symmetrically.","pos":""}],"UNSYMPATHY":[{"def":"Absence or lack of sympathy.","pos":""}]}