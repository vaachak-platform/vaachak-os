{"WATER":[{"def":"A solution in water of a gaseous or readily volatile substance; as, ammonia water.","pos":""}],"WATER AGRIMONY":[{"def":"A kind of bur marigold (Bidens tripartita) found in wet places in Europe.","pos":""}],"WATER ALOE":[{"def":"See Water soldier.","pos":""}],"WATER ARUM":[{"def":"An aroid herb (Calla palustris) having a white spathe.","pos":""}],"WATER BACK":[{"def":"See under 1st Back.","pos":""}],"WATER BAILIFF":[{"def":"An officer of the customs, whose duty it is to search vessels.","pos":""}],"WATER BALLAST":[{"def":"Water confined in specially constructed compartments in a vessel's hold, to serve as ballast.","pos":""}],"WATER BAROMETER":[{"def":"A barometer in which the changes of atmospheric pressure are indicated by the motion of a column of water instead of mercury.","pos":""}],"WATER BATH":[{"def":"A device for regulating the temperature of anything subjected to heat, by surrounding the vessel containing it with another vessel containing water which can be kept at a desired temperature; also, a vessel designed for this purpose.","pos":""}],"WATER BATTERY":[{"def":"A voltaic battery in which the exciting fluid is water.","pos":""},{"def":"A battery nearly on a level with the water.","pos":""}],"WATER BEAR":[{"def":"Any species of Tardigrada, 2.","pos":""}],"WATER BED":[{"def":"A kind of mattress made of, or covered with, waterproof fabric and filled with water.","pos":""}],"WATER BEECH":[{"def":"The American hornbeam.","pos":""}],"WATER BEETLE":[{"def":"Any one of numerous species of aquatic beetles belonging to Dytiscus and allied genera of the family Dytiscidæ, and to various genera of the family Hydrophilidæ.","pos":""}],"WATER BIRD":[{"def":"Any aquatic bird; a water fowl.","pos":""}],"WATER BLACKBIRD":[{"def":"The European water ousel, or dipper.","pos":""}],"WATER BRAIN":[{"def":"A disease of sheep; gid.","pos":""}],"WATER BRASH":[{"def":"See under Brash.","pos":""}],"WATER BREATHER":[{"def":"Any arthropod that breathes by means of gills.","pos":""}],"WATER BRIDGE":[{"def":"See Water table.","pos":""}],"WATER BUCK":[{"def":"A large, heavy antelope (Kobus ellipsiprymnus) native of Central Africa.","pos":""}],"WATER BUFFALO":[{"def":"The European buffalo.","pos":""}],"WATER BUTT":[{"def":"A large, open-headed cask, set up on end, to contain water.","pos":""}],"WATER CALTROP":[{"def":"The water chestnut.","pos":""}],"WATER CAN":[{"def":"Any one of several species of Nuphar; the yellow frog lily; -- so called from the shape of the seed vessel.","pos":""}],"WATER CARRIAGE":[{"def":"Transportation or conveyance by water; means of transporting by water.","pos":""},{"def":"A vessel or boat.","pos":""}],"WATER CART":[{"def":"A cart carrying water; esp.","pos":""}],"WATER CELERY":[{"def":"A very acrid herb (Ranunculus sceleratus) growing in ditches and wet places; -- called also cursed crowfoot.","pos":""}],"WATER CELL":[{"def":"A cell containing water; specifically (Zoöl.","pos":""}],"WATER CEMENT":[{"def":"Hydraulic cement.","pos":""}],"WATER CHESTNUT":[{"def":"The fruit of Trapa natans and Trapa bicornis, Old World water plants bearing edible nutlike fruits armed with several hard and sharp points; also, the plant itself; -- called also water caltrop.","pos":""}],"WATER CHEVROTAIN":[{"def":"A large West African chevrotain (Hyæmoschus aquaticus).","pos":""}],"WATER CHICKEN":[{"def":"The common American gallinule.","pos":""}],"WATER CHICKWEED":[{"def":"A small annual plant (Montia fontana) growing in wet places in southern regions.","pos":""}],"WATER CHINQUAPIN":[{"def":"The American lotus, and its edible seeds, which somewhat resemble chinquapins.","pos":""}],"WATER CLOCK":[{"def":"An instrument or machine serving to measure time by the fall, or flow, of a certain quantity of water; a clepsydra.","pos":""}],"WATER COCK":[{"def":"A large gallinule (Gallicrex cristatus) native of Australia, India, and the East Indies.","pos":""}],"WATER COLOR":[{"def":"A color ground with water and gum or other glutinous medium; a color the vehicle of which is water; -- so called in distinction from oil color.","pos":""},{"def":"A picture painted with such colors.","pos":""}],"WATER COURSE":[{"def":"A running stream of water having a bed and banks; the easement one may have in the flowing of such a stream in its accustomed course.","pos":""}],"WATER CRAFT":[{"def":"Any vessel or boat plying on water; vessels and boats, collectively.","pos":""}],"WATER CRANE":[{"def":"A goose-neck apparatus for supplying water from an elevated tank, as to the tender of a locomotive.","pos":""}],"WATER CRESS":[{"def":"A perennial cruciferous herb (Nasturtium officinale) growing usually in clear running or spring water.","pos":""}],"WATER CROWFOOT":[{"def":"An aquatic kind of buttercup (Ranunculus aquatilis), used as food for cattle in parts of England.","pos":""}],"WATER CURE":[{"def":"A hydropathic institution.","pos":""}],"WATER DECK":[{"def":"A covering of painting canvas for the equipments of a dragoon's horse.","pos":""}],"WATER DEERLET":[{"def":"See Water chevrotain.","pos":""}],"WATER DEVIL":[{"def":"The rapacious larva of a large water beetle (Hydrophilus piceus), and of other similar species.","pos":""}],"WATER DOCK":[{"def":"A tall, coarse dock growing in wet places.","pos":""}],"WATER DOG":[{"def":"A dog accustomed to the water, or trained to retrieve waterfowl.","pos":""},{"def":"The menobranchus.","pos":""}],"WATER DRAIN":[{"def":"A drain or channel for draining off water.","pos":""}],"WATER DRAINAGE":[{"def":"The draining off of water.","pos":""}],"WATER DRESSING":[{"def":"The treatment of wounds or ulcers by the application of water; also, a dressing saturated with water only, for application to a wound or an ulcer.","pos":""}],"WATER DROPWORT":[{"def":"A European poisonous umbelliferous plant (Enanthe fistulosa) with large hollow stems and finely divided leaves.","pos":""}],"WATER ELDER":[{"def":"The guelder-rose.","pos":""}],"WATER ELEPHANT":[{"def":"The hippopotamus.","pos":""}],"WATER ENGINE":[{"def":"An engine to raise water; or an engine moved by water; also, an engine or machine for extinguishing fires; a fire engine.","pos":""}],"WATER FLAG":[{"def":"A European species of Iris (Iris Pseudacorus) having bright yellow flowers.","pos":""}],"WATER FLANNEL":[{"def":"A floating mass formed in pools by the entangled filaments of a European fresh-water alga (Cladophora crispata).","pos":""}],"WATER FLEA":[{"def":"Any one of numerous species of small aquatic Entomostraca belonging to the genera Cyclops, Daphnia, etc; -- so called because they swim with sudden leaps, or starts.","pos":""}],"WATER FLOUNDER":[{"def":"The windowpane (Pleuronectes maculatus).","pos":""}],"WATER FOX":[{"def":"The carp; -- so called on account of its cunning.","pos":""}],"WATER FRAME":[{"def":"A name given to the first power spinning machine, because driven by water power.","pos":""}],"WATER FURROW":[{"def":"A deep furrow for conducting water from the ground, and keeping the surface soil dry.","pos":""}],"WATER GAGE":[{"def":"See Water gauge.","pos":""}],"WATER GALL":[{"def":"A cavity made in the earth by a torrent of water; a washout.","pos":""},{"def":"A watery appearance in the sky, accompanying the rainbow; a secondary or broken rainbow.","pos":""}],"WATER GANG":[{"def":"A passage for water, such as was usually made in a sea wall, to drain water out of marshes.","pos":""}],"WATER GATE":[{"def":"A gate, or valve, by which a flow of water is permitted, prevented, or regulated.","pos":""}],"WATER GAUGE":[{"def":"A wall or bank to hold water back.","pos":""},{"def":"An instrument for measuring or ascertaining the depth or quantity of water, or for indicating the height of its surface, as in the boiler of a steam engine.","pos":""}],"WATER GAVEL":[{"def":"A gavel or rent paid for a privilege, as of fishing, in some river or water.","pos":""}],"WATER GERMANDER":[{"def":"A labiate plant (Teucrium Scordium) found in marshy places in Europe.","pos":""}],"WATER GILDING":[{"def":"The act, or the process, of gilding metallic surfaces by covering them with a thin coating of amalgam of gold, and then volatilizing the mercury by heat; -- called also wash gilding.","pos":""}],"WATER GLASS":[{"def":"See Soluble glass, under Glass.","pos":""}],"WATER GOD":[{"def":"A fabulous deity supposed to dwell in, and preside over, some body of water.","pos":""}],"WATER GRASS":[{"def":"The water cress.","pos":""},{"def":"One of various horsetails.","pos":""}],"WATER GRUEL":[{"def":"A liquid food composed of water and a small portion of meal, or other farinaceous substance, boiled and seasoned.","pos":""}],"WATER HAMMER":[{"def":"A vessel partly filled with water, exhausted of air, and hermetically sealed.","pos":""},{"def":"A concussion, or blow, made by water in striking, as against the sides of a pipe or vessel containing it.","pos":""}],"WATER HARE":[{"def":"A small American hare or rabbit (Lepus aquaticus) found on or near the southern coasts of the United States; -- called also water rabbit, and swamp hare.","pos":""}],"WATER HEN":[{"def":"The common American coot.","pos":""}],"WATER HYACINTH":[{"def":"Either of several tropical aquatic plants of the genus Eichhornia, related to the pickerel weed.","pos":""}],"WATER ICE":[{"def":"Water flavored, sweetened, and frozen, to be eaten as a confection.","pos":""}],"WATER INCH":[{"def":"Same as Inch of water, under Water.","pos":""}],"WATER JACKET":[{"def":"A chamber surrounding a vessel or tube in which water may be circulated, thereby regulating the temperature or supply of heat to the vessel.","pos":""}],"WATER JOINT":[{"def":"A joint in a stone pavement where the stones are left slightly higher than elsewhere, the rest of the surface being sunken or dished.","pos":""}],"WATER JUNKET":[{"def":"The common sandpiper.","pos":""}],"WATER LAVEROCK":[{"def":"The common sandpiper.","pos":""}],"WATER LEMON":[{"def":"The edible fruit of two species of passion flower (Passiflora laurifolia, and P.","pos":""}],"WATER LETTUCE":[{"def":"A plant (Pistia stratiotes) which floats on tropical waters, and forms a rosette of spongy, wedge-shaped leaves.","pos":""}],"WATER LEVEL":[{"def":"The level formed by the surface of still water.","pos":""},{"def":"A kind of leveling instrument.","pos":""}],"WATER LILY":[{"def":"A blossom or plant of any species of the genus Nymphæa, distinguished for its large floating leaves and beautiful flowers.","pos":""}],"WATER LINE":[{"def":"Any one of certain lines of a vessel, model, or plan, parallel with the surface of the water at various heights from the keel.","pos":""},{"def":"Any one of several lines marked upon the outside of a vessel, corresponding with the surface of the water when she is afloat on an even keel.","pos":""}],"WATER LIZARD":[{"def":"Any aquatic lizard of the genus Varanus, as the monitor of the Nile.","pos":""}],"WATER LOCUST":[{"def":"A thorny leguminous tree (Gleditschia monosperma) which grows in the swamps of the Mississippi valley.","pos":""}],"WATER MEADOW":[{"def":"A meadow, or piece of low, flat land, capable of being kept in a state of fertility by being overflowed with water from some adjoining river or stream.","pos":""}],"WATER MEASURE":[{"def":"A measure formerly used for articles brought by water, as coals, oysters, etc.","pos":""}],"WATER MEASURER":[{"def":"Any one of numerous species of water; the skater.","pos":""}],"WATER METER":[{"def":"A contrivance for measuring a supply of water delivered or received for any purpose, as from a street main.","pos":""}],"WATER MILFOIL":[{"def":"Any plant of the genus Myriophyllum, aquatic herbs with whorled leaves, the submersed ones pinnately parted into capillary divisions.","pos":""}],"WATER MILL":[{"def":"A mill whose machinery is moved by water; -- distinguished from a windmill, and a steam mill.","pos":""}],"WATER MINT":[{"def":"A kind of mint (Mentha aquatica) growing in wet places, and sometimes having a perfume resembling bergamot.","pos":""}],"WATER MITE":[{"def":"Any of numerous species of aquatic mites belonging to Hydrachna and allied genera of the family Hydrachnidæ, usually having the legs fringed and adapted for swimming.","pos":""}],"WATER MOCCASIN":[{"def":"A venomous North American snake (Ancistrodon piscivorus) allied to the rattlesnake but destitute of a rattle.","pos":""}],"WATER MONITOR":[{"def":"A very large lizard (Varanaus salvator) native of India.","pos":""}],"WATER MONKEY":[{"def":"A jar or bottle, as of porous earthenware, in which water is cooled by evaporation.","pos":""}],"WATER MOTOR":[{"def":"A water wheel; especially, a small water wheel driven by water from a street main.","pos":""}],"WATER MOUSE":[{"def":"Any one of several species of mice belonging to the genus Hydromys, native of Australia and Tasmania.","pos":""}],"WATER MURRAIN":[{"def":"A kind of murrain affecting cattle.","pos":""}],"WATER NEWT":[{"def":"Any one of numerous species of aquatic salamanders; a triton.","pos":""}],"WATER NYMPH":[{"def":"A goddess of any stream or other body of water, whether one of the Naiads, Nereids, or Oceanides.","pos":""},{"def":"A water lily (Nymphæa).","pos":""}],"WATER OPOSSUM":[{"def":"See Yapock, and the Note under Opossum.","pos":""}],"WATER ORDEAL":[{"def":"Same as Ordeal by water.","pos":""},{"def":"Any one of several species of small insessorial birds of the genus Cinclus (or Hydrobates), especially the European water ousel (C.","pos":""}],"WATER PARSNIP":[{"def":"Any plant of the aquatic umbelliferous genus Sium, poisonous herbs with pinnate or dissected leaves and small white flowers.","pos":""}],"WATER PARTING":[{"def":"A summit from the opposite sides of which rain waters flow to different streams; a line separating the drainage districts of two streams or coasts; a divide.","pos":""}],"WATER PENNYWORT":[{"def":"Marsh pennywort.","pos":""}],"WATER PIET":[{"def":"The water ousel.","pos":""}],"WATER PIMPERNEL":[{"def":"A small white-flowered shrub; brookweed.","pos":""}],"WATER PIPE":[{"def":"A pipe for conveying water.","pos":""}],"WATER PITCHER":[{"def":"One of a family of plants having pitcher-shaped leaves.","pos":""}],"WATER PLANT":[{"def":"A plant that grows in water; an aquatic plant.","pos":""}],"WATER PLANTAIN":[{"def":"A kind of plant with acrid leaves.","pos":""}]}