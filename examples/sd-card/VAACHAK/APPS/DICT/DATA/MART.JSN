{"MART":[{"def":"Where has commerce such a mart .","pos":""}],"MARTAGON":[{"def":"A lily (Lilium Martagon) with purplish red flowers, found in Europe and Asia.","pos":""}],"MARTEL":[{"def":"To make a blow with, or as with, a hammer.","pos":""}],"MARTEL DE FER":[{"def":"A weapon resembling a hammer, often having one side of the head pointed; -- used by horsemen in the Middle Ages to break armor.","pos":""}],"MARTELINE":[{"def":"A small hammer used by marble workers and sculptors.","pos":""}],"MARTELLO TOWER":[{"def":"A building of masonry, generally circular, usually erected on the seacoast, with a gun on the summit mounted on a traversing platform, so as to be fired in any direction.","pos":""}],"MARTEN":[{"def":"Any one of several fur-bearing carnivores of the genus Mustela, closely allied to the sable.","pos":""}],"MARTIAL":[{"def":"Pertaining to, or containing, iron; chalybeate; as, martial preparations.","pos":""}],"MARTIALISM":[{"def":"The quality of being warlike; exercises suitable for war.","pos":""}],"MARTIALIZE":[{"def":"To render warlike; as, to martialize a people.","pos":""}],"MARTIALLY":[{"def":"In a martial manner.","pos":""}],"MARTIALNESS":[{"def":"The quality of being martial.","pos":""}],"MARTIAN":[{"def":"Of or pertaining to Mars, the Roman god of war, or to the planet bearing his name; martial.","pos":""}],"MARTIN":[{"def":"A perforated stone-faced runner for grinding.","pos":""}],"MARTINET":[{"def":"In military language, a strict disciplinarian; in general, one who lays stress on a rigid adherence to the details of discipline, or to forms and fixed methods.","pos":""}],"MARTINETA":[{"def":"A species of tinamou (Calopezus elegans), having a long slender crest.","pos":""}],"MARTINETISM":[{"def":"The principles or practices of a martinet; rigid adherence to discipline, etc.","pos":""},{"def":"A lower stay of rope or chain for the jib boom or flying jib boom, fastened to, or reeved through, the dolphin striker.","pos":""}],"MARTINMAS":[{"def":"The feast of St.","pos":""}],"MARTITE":[{"def":"Iron sesquioxide in isometric form, probably a pseudomorph after magnetite.","pos":""}],"MARTLET":[{"def":"The European house martin.","pos":""},{"def":"A bird without beak or feet; -- generally assumed to represent a martin.","pos":""}],"MARTYR":[{"def":"One who, by his death, bears witness to the truth of the gospel; one who is put to death for his religion; as, Stephen was the first Christian martyr.","pos":""},{"def":"Hence, one who sacrifices his life, his station, or what is of great value to him, for the sake of principle, or to sustain a cause.","pos":""}],"MARTYRDOM":[{"def":"The condition of a martyr; the death of a martyr; the suffering of death on account of adherence to the Christian faith, or to any cause.","pos":""},{"def":"Affliction; torment; torture.","pos":""}],"MARTYRIZATION":[{"def":"Act of martyrizing, or state of being martyrized; torture.","pos":""}],"MARTYRIZE":[{"def":"To make a martyr of.","pos":""}],"MARTYRLY":[{"def":"In the manner of a martyr.","pos":""}],"MARTYROLOGE":[{"def":"Pertaining to martyrology or martyrs; registering, or registered in, a catalogue of martyrs.","pos":""}],"MARTYROLOGIST":[{"def":"A writer of martyrology; an historian of martyrs.","pos":""}],"MARTYROLOGY":[{"def":"A history or account of martyrs; a register of martyrs.","pos":""}]}