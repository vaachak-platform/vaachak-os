{"QUAGGA":[{"def":"A South African wild ass (Equus, or Hippotigris, quagga).","pos":""}],"QUAGGY":[{"def":"Of the nature of a quagmire; yielding or trembling under the foot, as soft, wet earth; spongy; boggy.","pos":""}],"QUAGMIRE":[{"def":"Soft, wet, miry land, which shakes or yields under the feet.","pos":""},{"def":"An American market clam (Venus mercenaria).","pos":""}]}