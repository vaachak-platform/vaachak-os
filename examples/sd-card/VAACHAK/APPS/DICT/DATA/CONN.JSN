{"CONN":[{"def":"See Con, to direct a ship.","pos":""}],"CONNASCENT":[{"def":"Born together; produced at the same time.","pos":""}],"CONNATE":[{"def":"Congenitally united; growing from one base, or united at their bases; united into one body; as, connate leaves or athers.","pos":""}],"CONNATE-PERFOLIATE":[{"def":"Connate or coalescent at the base so as to produce a broad foliaceous body through the center of which the stem passes; -- applied to leaves, as the leaves of the boneset.","pos":""}],"CONNATION":[{"def":"Connection by birth; natural union.","pos":""}],"CONNATURAL":[{"def":"Connected by nature; united in nature; inborn; inherent; natural.","pos":""},{"def":"Partaking of the same nature.","pos":""}],"CONNATURALITY":[{"def":"Participation of the same nature; natural union or connection.","pos":""}],"CONNATURALIZE":[{"def":"To bring to the same nature as something else; to adapt.","pos":""}],"CONNATURALLY":[{"def":"By the act of nature; originally; from birth.","pos":""}],"CONNATURALNESS":[{"def":"Participation of the same nature; natural union.","pos":""}],"CONNATURE":[{"def":"Participation in a common nature or character.","pos":""}],"CONNECT":[{"def":"To join, or fasten together, as by something intervening; to associate; to combine; to unite or link together; to establish a bond or relation between.","pos":""},{"def":"To associate (a person or thing, or one's self) with another person, thing, business, or affair.","pos":""}],"CONNECTEDLY":[{"def":"In a connected manner.","pos":""}],"CONNECTION":[{"def":"The act of connecting, or the state of being connected; junction; union; alliance; relationship.","pos":""},{"def":"That which connects or joins together; bond; tie.","pos":""}],"CONNECTIVE":[{"def":"Connecting, or adapted to connect; involving connection.","pos":""}],"CONNECTIVELY":[{"def":"In connjunction; jointly.","pos":""}],"CONNECTOR":[{"def":"One who, or that which, connects; as: (a) A flexible tube for connecting the ends of glass tubes in pneumatic experiments.","pos":""}],"CONNER":[{"def":"A marine European fish (Crenilabrus melops); also, the related American cunner.","pos":""}],"CONNING TOWER":[{"def":"The shotproof pilot house of a war vessel.","pos":""}],"CONNIVANCE":[{"def":"Corrupt or guilty assent to wrongdoing, not involving actual participation in, but knowledge of, and failure to prevent or oppose it.","pos":""}],"CONNIVE":[{"def":"To open and close the eyes rapidly; to wink.","pos":""},{"def":"To close the eyes upon a fault; to wink (at); to fail or forbear by intention to discover an act; to permit a proceeding, as if not aware of it; -- usually followed by at.","pos":""}],"CONNIVENT":[{"def":"Brought close together; arched inward so that the points meet; converging; in close contact; as, the connivent petals of a flower, wings of an insect, or folds of membrane in the human system, etc.","pos":""}],"CONNIVER":[{"def":"One who connives.","pos":""}],"CONNOISSEUR":[{"def":"One well versed in any subject; a skillful or knowing person; a critical judge of any art, particulary of one of the fine arts.","pos":""}],"CONNOISSEURSHIP":[{"def":"State of being a connoisseur.","pos":""}],"CONNOTATE":[{"def":"To connote; to suggest or designate (something) as additional; to include; to imply.","pos":""}],"CONNOTATION":[{"def":"The act of connoting; a making known or designating something additional; implication of something more than is asserted.","pos":""}],"CONNOTATIVE":[{"def":"Implying an attribute.","pos":""}],"CONNOTATIVELY":[{"def":"In a connotative manner; expressing connotation.","pos":""}],"CONNOTE":[{"def":"To imply as an attribute.","pos":""}],"CONNUBIAL":[{"def":"Of or pertaining to marriage, or the marriage state; conjugal; nuptial.","pos":""}],"CONNUBIALITY":[{"def":"The quality of being connubial; something characteristics of the conjugal state; an expression of connubial tenderness.","pos":""}],"CONNUMERATION":[{"def":"A reckoning together.","pos":""}],"CONNUTRITIOUS":[{"def":"Nutritious by force of habit; -- said of certain kinds of food.","pos":""}],"CONNY":[{"def":"Brave; fine; canny.","pos":""}]}