{"CYPERACEOUS":[{"def":"Of, pertaining to, or resembling, a large family of plants of which the sedge is the type.","pos":""}],"CYPERUS":[{"def":"A large genus of plants belonging to the Sedge family, and including the species called galingale, several bulrushes, and the Egyptian papyrus.","pos":""}],"CYPHONAUTES":[{"def":"The free-swimming, bivalve larva of certain Bryozoa.","pos":""}],"CYPHONISM":[{"def":"A punishment sometimes used by the ancients, consisting in the besmearing of the criminal with honey, and exposing him to insects.","pos":""}],"CYPRAEA":[{"def":"A genus of mollusks, including the cowries.","pos":""}],"CYPRES":[{"def":"A rule for construing written instruments so as to conform as nearly to the intention of the parties as is consistent with law.","pos":""}],"CYPRESS":[{"def":"A coniferous tree of the genus Cupressus.","pos":""}],"CYPRIAN":[{"def":"Belonging to Cyprus.","pos":""},{"def":"Of, pertaining, or conducing to, lewdness.","pos":""}],"CYPRINE":[{"def":"Of or pertaining to the cypress.","pos":""}],"CYPRINODONT":[{"def":"One of the Cyprinodontidae, a family of fishes including the killifishes or minnows.","pos":""}],"CYPRINOID":[{"def":"Like the carp (Cyprinus).","pos":""},{"def":"One of the Cyprinidae, or Carp family, as the goldfish, barbel, etc.","pos":""}],"CYPRIOT":[{"def":"A native or inhabitant of Cyprus.","pos":""}],"CYPRIPEDIUM":[{"def":"A genus of orchidaceous plants including the lady's slipper.","pos":""}],"CYPRIS":[{"def":"A genus of small, bivalve, freshwater Crustacea, belonging to the Ostracoda; also, a member of this genus.","pos":""}],"CYPRUS":[{"def":"A thin, transparent stuff, the same as, or corresponding to, crape.","pos":""}],"CYPRUSLAWN":[{"def":"Cy\"prus*lawn` (-ln`), n.","pos":""}],"CYPSELA":[{"def":"A one-seeded, one-called, indehiscent fruit; an achene with the calyx tube adherent.","pos":""}],"CYPSELIFORM":[{"def":"Like or belonging to the swifts (Cypselidæ.","pos":""}]}