{"REVACCINATE":[{"def":"To vaccinate a second time or again.","pos":""}],"REVALESCENCE":[{"def":"The act of growing well; the state of being revalescent.","pos":""}],"REVALESCENT":[{"def":"Growing well; recovering strength.","pos":""}],"REVALUATION":[{"def":"A second or new valuation.","pos":""}],"REVAMP":[{"def":"To vamp again; hence, topatch up; to reconstruct.","pos":""}]}