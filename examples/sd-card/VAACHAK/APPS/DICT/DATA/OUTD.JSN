{"OUTDARE":[{"def":"To surpass in daring; to overcome by courage; to brave.","pos":""}],"OUTDATED":[{"def":"Being out of date; antiquated.","pos":""}],"OUTDAZZLE":[{"def":"To surpass in dazzing.","pos":""}],"OUTDO":[{"def":"To go beyond in performance; to excel; to surpass.","pos":""}],"OUTDOOR":[{"def":"Being, or done, in the open air; being or done outside of certain buildings, as poorhouses, hospitals, etc.","pos":""}],"OUTDOORS":[{"def":"Abread; out of the house; out of doors.","pos":""}],"OUTDRAW":[{"def":"To draw out; to extract.","pos":""}],"OUTDREAM":[{"def":"To pass, or escape, while dreaming.","pos":""}],"OUTDRINK":[{"def":"To exceed in drinking.","pos":""}],"OUTDWELL":[{"def":"To dwell or stay beyond.","pos":""}],"OUTDWELLER":[{"def":"One who holds land in a parish, but lives elsewhere.","pos":""}]}