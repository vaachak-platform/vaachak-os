{"TUP":[{"def":"To butt, as a ram does.","pos":""},{"def":"To cover; -- said of a ram.","pos":""}],"TUPAI":[{"def":"Any one of the tupaiids.","pos":""}],"TUPAIID":[{"def":"Any one of several species of East Indian and Asiatic insectivores of the family Tupaiidæ, somewhat resembling squirrels in size and arboreal habits.","pos":""}],"TUPELO":[{"def":"A North American tree (Nyssa multiflora) of the Dogwood family, having brilliant, glossy foliage and acid red berries.","pos":""}],"TUPI":[{"def":"An Indian of the tribe from which the Tupian stock takes its name, dwelling, at the advent of the Portuguese, about the mouth of the Amazon.","pos":""}],"TUPIAN":[{"def":"Designating, or pert.","pos":""}],"TUPMAN":[{"def":"A man who breeds, or deals in tups.","pos":""}]}