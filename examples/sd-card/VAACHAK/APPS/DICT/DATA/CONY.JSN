{"CONY":[{"def":"Note: The cony of Scripture is thought to be Hyrax Syriacus, called also daman, and cherogril.","pos":""}],"CONY-CATCH":[{"def":"To deceive; to cheat; to trick.","pos":""}],"CONY-CATCHER":[{"def":"A cheat; a sharper; a deceiver.","pos":""}],"CONYLENE":[{"def":"An oily substance, C8H14, obtained from several derivatives of conine.","pos":""}],"CONYRINE":[{"def":"A blue, fluorescent, oily base (regarded as a derivative of pyridine), obtained from conine.","pos":""}]}