{"BUB":[{"def":"Strong malt liquor.","pos":""}],"BUBALE":[{"def":"A large antelope (Alcelaphus bubalis) of Egypt and the Desert of Sahara, supposed by some to be the fallow deer of the Bible.","pos":""}],"BUBALINE":[{"def":"Resembling a buffalo.","pos":""}],"BUBBLE":[{"def":"A thin film of liquid inflated with air or gas; as, a soap bubble; bubbles on the surface of a river.","pos":""},{"def":"A small quantity of air or gas within a liquid body; as, bubbles rising in champagne or aërated waters.","pos":""}],"BUBBLE SHELL":[{"def":"A marine univalve shell of the genus Bulla and allied genera, belonging to the Tectibranchiata.","pos":""}],"BUBBLER":[{"def":"To cheat; to deceive.","pos":""}],"BUBBLING JOCK":[{"def":"The male wild turkey, the gobbler; -- so called in allusion to its notes.","pos":""}],"BUBBLY":[{"def":"Abounding in bubbles; bubbling.","pos":""}],"BUBBY":[{"def":"A woman's breast.","pos":""}],"BUBO":[{"def":"An inflammation, with enlargement, of a limphatic gland, esp.","pos":""}],"BUBONIC":[{"def":"Of or pertaining to a bubo or buboes; characterized by buboes.","pos":""}],"BUBONOCELE":[{"def":"An inguinal hernia; esp.","pos":""}]}