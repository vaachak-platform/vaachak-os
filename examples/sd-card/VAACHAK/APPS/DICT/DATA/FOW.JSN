{"FOWL":[{"def":"Any domesticated bird used as food, as a hen, turkey, duck; in a more restricted sense, the common domestic cock or hen (Gallus domesticus).","pos":""}],"FOWLER":[{"def":"A sportsman who pursues wild fowl, or takes or kills for food.","pos":""}],"FOWLER'S SOLUTION":[{"def":"Fow\"ler's so*lu\"tion Defn: .","pos":""}],"FOWLERITE":[{"def":"A variety of rhodonite, from Franklin Furnace, New Jersey, containing some zinc.","pos":""}]}