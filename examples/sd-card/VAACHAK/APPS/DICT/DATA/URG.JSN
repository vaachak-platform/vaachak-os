{"URGE":[{"def":"To press; to push; to drive; to impel; to force onward.","pos":""},{"def":"To press the mind or will of; to ply with motives, arguments, persuasion, or importunity.","pos":""}],"URGENCY":[{"def":"The quality or condition of being urgent; insistence; pressure; as, the urgency of a demand or an occasion.","pos":""}],"URGENT":[{"def":"Urging; pressing; besetting; plying, with importunity; calling for immediate attention; instantly important.","pos":""}],"URGENTLY":[{"def":"In an urgent manner.","pos":""}]}