{"EPHEMERA":[{"def":"A fever of one day's continuance only.","pos":""},{"def":"A genus of insects including the day flies, or ephemeral flies.","pos":""}],"EPHEMERAL":[{"def":"Beginning and ending in a day; existing only, or no longer than, a day; diurnal; as, an ephemeral flower.","pos":""},{"def":"Short-lived; existing or continuing for a short time only.","pos":""}],"EPHEMERAN":[{"def":"One of the ephemeral flies.","pos":""}],"EPHEMERIS":[{"def":"A collective name for reviews, magazines, and all kinds of periodical literature.","pos":""}],"EPHEMERIST":[{"def":"One who studies the daily motions and positions of the planets.","pos":""},{"def":"One who keeps an ephemeris; a journalist.","pos":""}],"EPHEMERON":[{"def":"One of the ephemeral flies.","pos":""}],"EPHESIAN":[{"def":"Of or pertaining to Ephesus, an ancient city of Ionia, in Asia Minor.","pos":""}],"EPHIPPIAL":[{"def":"Saddle-shaped; occupying an ephippium.","pos":""}],"EPHIPPIUM":[{"def":"A depression in the sphenoid bone; the pituitary fossa.","pos":""},{"def":"A saddle-shaped cavity to contain the winter eggs, situated on the back of Cladocera.","pos":""}],"EPHOD":[{"def":"A part of the sacerdotal habit among Jews, being a covering for the back and breast, held together on the shoulders by two clasps or brooches of onyx stones set in gold, and fastened by a girdle of the same stuff as the ephod.","pos":""}],"EPHOR":[{"def":"A magistrate; one of a body of five magistrates chosen by the people of ancient Sparta.","pos":""}],"EPHORAL":[{"def":"Pertaining to an ephor.","pos":""}],"EPHORALTY":[{"def":"The office of an ephor, or the body of ephors.","pos":""}],"EPHRAIM":[{"def":"A hunter's name for the grizzly bear.","pos":""}],"EPHYRA":[{"def":"A stage in the development of discophorous medusæ, when they first begin to swim about after being detached from the strobila.","pos":""}]}