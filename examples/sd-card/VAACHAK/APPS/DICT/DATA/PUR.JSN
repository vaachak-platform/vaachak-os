{"PUR":[{"def":"To utter a low, murmuring, continued sound, as a cat does when pleased.","pos":""}],"PURANA":[{"def":"One of a class of sacred Hindoo poetical works in the Sanskrit language which treat of the creation, destruction, and renovation of worlds, the genealogy and achievements of gods and heroes, the reigns of the Manus, and the transactions of their descendants.","pos":""}],"PURANIC":[{"def":"Pertaining to the Puranas.","pos":""}],"PURBECK BEDS":[{"def":"The strata of the Purbeck stone, or Purbeck limestone, belonging to the Oölitic group.","pos":""}],"PURBECK STONE":[{"def":"A limestone from the Isle of Purbeck in England.","pos":""}],"PURBLIND":[{"def":"Nearsighted, or dim-sighted; seeing obscurely; as, a purblind eye; a purblind mole.","pos":""}],"PURCHASABLE":[{"def":"Capable of being bought, purchased, or obtained for a consideration; hence, venal; corrupt.","pos":""}],"PURCHASE":[{"def":"To pursue and obtain; to acquire by seeking; to gain, obtain, or acquire.","pos":""},{"def":"To obtain by paying money or its equivalent; to buy for a price; as, to purchase land, or a house.","pos":""}],"PURCHASER":[{"def":"One who acquires an estate in lands by his own act or agreement, or who takes or obtains an estate by any means other than by descent or inheritance.","pos":""}],"PURDAH":[{"def":"A curtain or screen; also, a cotton fabric in blue and white stripes, used for curtains.","pos":""}],"PURE":[{"def":"Ritually clean; fitted for holy services.","pos":""},{"def":"Of a single, simple sound or tone; -- said of some vowels and the unaspirated consonants.","pos":""}],"PURED":[{"def":"Purified; refined.","pos":""}],"PUREE":[{"def":"A dish made by boiling any article of food to a pulp and rubbing it through a sieve; as, a purée of fish, or of potatoes; especially, a soup the thickening of which is so treated.","pos":""}],"PURELY":[{"def":"In a pure manner (in any sense of the adjective).","pos":""},{"def":"Nicely; prettily.","pos":""}],"PURENESS":[{"def":"The state of being pure (in any sense of the adjective).","pos":""}],"PURFILE":[{"def":"A sort of ancient trimming of tinsel and thread for women's gowns; -- called also bobbinwork.","pos":""}],"PURFLE":[{"def":"To ornament with a bordure of emines, furs, and the like; also, with gold studs or mountings.","pos":""},{"def":"A border of any heraldic fur.","pos":""}],"PURFLED":[{"def":"Ornamented; decorated; esp.","pos":""}],"PURFLING":[{"def":"Ornamentation on the border of a thing; specifically, the inlaid border of a musical instrument, as a violin.","pos":""}],"PURGAMENT":[{"def":"A cathartic; a purgative.","pos":""}],"PURGATION":[{"def":"The clearing of one's self from a crime of which one was publicly suspected and accused.","pos":""}],"PURGATIVE":[{"def":"Having the power or quality of purging; cathartic.","pos":""},{"def":"A purging medicine; a cathartic.","pos":""}],"PURGATIVELY":[{"def":"In a purgative manner.","pos":""},{"def":"Of or pertaining to purgatory; expiatory.","pos":""}],"PURGATORIAN":[{"def":"One who holds to the doctrine of purgatory.","pos":""}],"PURGATORY":[{"def":"Tending to cleanse; cleansing; expiatory.","pos":""}],"PURGE":[{"def":"To operate on as, or by means of, a cathartic medicine, or in a similar manner.","pos":""},{"def":"To clear from accusation, or the charge of a crime or misdemeanor, as by oath or in ordeal.","pos":""}],"PURGER":[{"def":"One who, or that which, purges or cleanses; especially, a cathartic medicine.","pos":""}],"PURGERY":[{"def":"The part of a sugarhouse where the molasses is drained off from the sugar.","pos":""}],"PURGING":[{"def":"That purges; cleansing.","pos":""}],"PURIFICATION":[{"def":"The act of purifying; the act or operation of separating and removing from anything that which is impure or noxious, or heterogeneous or foreign to it; as, the purification of liquors, or of metals.","pos":""},{"def":"The act or operation of cleansing ceremonially, by removing any pollution or defilement.","pos":""}],"PURIFICATIVE":[{"def":"Having power to purify; tending to cleanse.","pos":""}],"PURIFICATOR":[{"def":"One who, or that which, purifies; a purifier.","pos":""}],"PURIFICATORY":[{"def":"Serving or tending to purify; purificative.","pos":""}],"PURIFIER":[{"def":"One who, or that which, purifies or cleanses; a cleanser; a refiner.","pos":""}],"PURIFORM":[{"def":"In the form of pus.","pos":""}],"PURIFY":[{"def":"To make pure or clear from material defilement, admixture, or imperfection; to free from extraneous or noxious matter; as, to purify liquors or metals; to purify the blood; to purify the air.","pos":""},{"def":"Hence, in figurative uses: (a) To free from guilt or moral defilement; as, to purify the heart.","pos":""}],"PURIM":[{"def":"A Jewish festival, called also the Feast of Lots, instituted to commemorate the deliverance of the Jews from the machinations of Haman.","pos":""}],"PURISM":[{"def":"Rigid purity; the quality of being affectedly pure or nice, especially in the choice of language; over-solicitude as to purity.","pos":""}],"PURIST":[{"def":"Of or pertaining to purists or purism.","pos":""}],"PURITAN":[{"def":"One who, in the time of Queen Elizabeth and the first two Stuarts, opposed traditional and formal usages, and advocated simpler forms of faith and worship than those established by law; -- originally, a term of reproach.","pos":""}],"PURITANICALLY":[{"def":"In a puritanical manner.","pos":""}],"PURITANISM":[{"def":"The doctrines, notions, or practice of Puritans.","pos":""}],"PURITANIZE":[{"def":"To agree with, or teach, the doctrines of Puritans; to conform to the practice of Puritans.","pos":""}],"PURITY":[{"def":"The condition of being pure.","pos":""}],"PURKINJE'S CELLS":[{"def":"Large ganglion cells forming a layer near the surface of the cerebellum.","pos":""}],"PURL":[{"def":"To decorate with fringe or embroidery.","pos":""}],"PURLIEU":[{"def":"In root construction, a horizontal member supported on the principals and supporting the common rafters.","pos":""}],"PURLING":[{"def":"The motion of a small stream running among obstructions; also, the murmur it makes in so doing.","pos":""}],"PURLOIN":[{"def":"To take or carry away for one's self; hence, to steal; to take by theft; to filch.","pos":""}],"PURLOINER":[{"def":"One who purloins.","pos":""}],"PURPARTY":[{"def":"A share, part, or portion of an estate allotted to a coparcener.","pos":""}],"PURPLE":[{"def":"Any species of large butterflies, usually marked with purple or blue, of the genus Basilarchia (formerly Limenitis) as, the banded purple (B.","pos":""},{"def":"Any shell of the genus Purpura.","pos":""}],"PURPLEHEART":[{"def":"A strong, durable, and elastic wood of a purplish color, obtained from several tropical American leguminous trees of the genus Copaifera (C.","pos":""}],"PURPLEWOOD":[{"def":"Same as Purpleheart.","pos":""}],"PURPLISH":[{"def":"Somewhat purple.","pos":""}],"PURPORT":[{"def":"Design or tendency; meaning; import; tenor.","pos":""},{"def":"Disguise; covering.","pos":""}],"PURPORTLESS":[{"def":"Without purport or meaning.","pos":""}],"PURPOSE":[{"def":"That which a person sets before himself as an object to be reached or accomplished; the end or aim to which the view is directed in any plan, measure, or exertion; view; aim; design; intention; plan.","pos":""},{"def":"Proposal to another; discourse.","pos":""}],"PURPOSEDLY":[{"def":"In a purposed manner; according to purpose or design; purposely.","pos":""}],"PURPOSEFUL":[{"def":"Important; material.","pos":""}],"PURPOSELESS":[{"def":"Having no purpose or result; objectless.","pos":""}],"PURPOSELY":[{"def":"With purpose or design; intentionally; with predetermination; designedly.","pos":""}],"PURPOSER":[{"def":"One who brings forward or proposes anything; a proposer.","pos":""},{"def":"One who forms a purpose; one who intends.","pos":""}],"PURPOSIVE":[{"def":"Having or indicating purpose or design.","pos":""}],"PURPRESTURE":[{"def":"Wrongful encroachment upon another's property; esp.","pos":""}],"PURPRISE":[{"def":"A close or inclosure; the compass of a manor.","pos":""}],"PURPURA":[{"def":"A disease characterized by livid spots on the skin from extravasated blood, with loss of muscular strength, pain in the limbs, and mental dejection; the purples.","pos":""},{"def":"A genus of marine gastropods, usually having a rough and thick shell.","pos":""}],"PURPURATE":[{"def":"Of or pertaining to purpura.","pos":""}],"PURPURE":[{"def":"Purple, -- represented in engraving by diagonal lines declining from the right top to the left base of the escutcheon (or from sinister chief to dexter base).","pos":""}],"PURPUREAL":[{"def":"Of a purple color; purple.","pos":""}],"PURPUREO-":[{"def":"A combining form signifying of a purple or purple-red color.","pos":""}],"PURPURIC":[{"def":"Of or pertaining to purpura.","pos":""},{"def":"Pertaining to or designating, a nitrogenous acid contained in uric acid.","pos":""}],"PURPURIN":[{"def":"A dyestuff resembling alizarin, found in madder root, and extracted as an orange or red crystalline substance.","pos":""}],"PURPURIPAROUS":[{"def":"Producing, or connected with, a purple-colored secretion; as, the purpuriparous gland of certain gastropods.","pos":""}],"PURPUROGENOUS":[{"def":"Having the power to produce a purple color; as, the purpurogenous membrane, or choroidal epithelium, of the eye.","pos":""}],"PURR":[{"def":"To murmur as a cat.","pos":""}],"PURREE":[{"def":"A yellow coloring matter.","pos":""}],"PURROCK":[{"def":"See Puddock, and Parrock.","pos":""}],"PURSE":[{"def":"A small bag or pouch, the opening of which is made to draw together closely, used to carry money in; by extension, any receptacle for money carried on the person; a wallet; a pocketbook; a portemonnaie.","pos":""},{"def":"Hence, a treasury; finances; as, the public purse.","pos":""}],"PURSE-PROUD":[{"def":"Affected with purse pride; puffed up with the possession of riches.","pos":""}],"PURSEFUL":[{"def":"All that is, or can be, contained in a purse; enough to fill a purse.","pos":""}],"PURSER":[{"def":"A commissioned officer in the navy who had charge of the provisions, clothing, and public moneys on shipboard; -- now called paymaster.","pos":""}],"PURSERSHIP":[{"def":"The office of purser.","pos":""}],"PURSET":[{"def":"A purse or purse net.","pos":""}],"PURSINESS":[{"def":"State of being pursy.","pos":""}],"PURSLAIN":[{"def":"Same as Purslane.","pos":""}],"PURSLANE":[{"def":"An annual plant (Portulaca oleracea), with fleshy, succulent, obovate leaves, sometimes used as a pot herb and for salads, garnishing, and pickling.","pos":""}],"PURSUABLE":[{"def":"Capable of being, or fit to be, pursued, followed, or prosecuted.","pos":""}],"PURSUAL":[{"def":"The act of pursuit.","pos":""}],"PURSUANCE":[{"def":"The act of pursuing or prosecuting; a following out or after.","pos":""},{"def":"The state of being pursuant; consequence.","pos":""}],"PURSUANT":[{"def":"Acting in consequence or in prosecution (of anything); hence, agreeable; conformable; following; according; -- with to or of.","pos":""},{"def":"Agreeably; conformably.","pos":""}],"PURSUE":[{"def":"To follow with a view to overtake; to follow eagerly, or with haste; to chase; as, to pursue a hare.","pos":""},{"def":"To seek; to use or adopt measures to obtain; as, to pursue a remedy at law.","pos":""}],"PURSUER":[{"def":"A plaintiff; a prosecutor.","pos":""}],"PURSUIT":[{"def":"The act of following or going after; esp.","pos":""},{"def":"A following with a view to reach, accomplish, or obtain; endeavor to attain to or gain; as, the pursuit of knowledge; the pursuit of happiness or pleasure.","pos":""}],"PURSUIVANT":[{"def":"A functionary of lower rank than a herald, but discharging similar duties; -- called also pursuivant at arms; an attendant of the heralds.","pos":""}],"PURSY":[{"def":"Fat and short-breathed; fat, short, and thick; swelled with pampering; as, pursy insolence.","pos":""}],"PURTENANCE":[{"def":"That which pertains or belongs to something; esp.","pos":""},{"def":"The quality or state of being purulent; the generation of pus; also, the pus itself.","pos":""}],"PURULENT":[{"def":"Consisting of pus, or matter; partaking of the nature of pus; attended with suppuration; as, purulent inflammation.","pos":""}],"PURULENTLY":[{"def":"In a purulent manner.","pos":""}],"PURVEY":[{"def":"To furnish or provide, as with a convenience, provisions, or the like.","pos":""},{"def":"To procure; to get.","pos":""}],"PURVEYANCE":[{"def":"A providing necessaries for the sovereign by buying them at an appraised value in preference to all others, and oven without the owner's consent.","pos":""}],"PURVEYOR":[{"def":"One who provides victuals, or whose business is to make provision for the table; a victualer; a caterer.","pos":""},{"def":"An officer who formerly provided, or exacted provision, for the king's household.","pos":""}],"PURVIEW":[{"def":"The limit or scope of a statute; the whole extent of its intention or provisions.","pos":""}]}