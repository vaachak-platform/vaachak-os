{"THEN":[{"def":"At that time (referring to a time specified, either past or future).","pos":""},{"def":"Soon afterward, or immediately; next; afterward.","pos":""}],"THENADAYS":[{"def":"At that time; then; in those days; -- correlative to nowadays.","pos":""},{"def":"Of or pertaining to the thenar; corresponding to thenar; palmar.","pos":""}],"THENARDITE":[{"def":"Anhydrous sodium sulphate, a mineral of a white or brown color and vitreous luster.","pos":""}],"THENCE":[{"def":"From that place.","pos":""},{"def":"From that time; thenceforth; thereafter.","pos":""}],"THENCEFORTH":[{"def":"From that time; thereafter.","pos":""}],"THENCEFORWARD":[{"def":"From that time onward; thenceforth.","pos":""}],"THENCEFROM":[{"def":"From that place.","pos":""}]}