{"ESCALADE":[{"def":"A furious attack made by troops on a fortified place, in which ladders are used to pass a ditch or mount a rampart.","pos":""}],"ESCALATOR":[{"def":"A stairway or incline arranged like an endless belt so that the steps or treads ascend or descend continuously, and one stepping upon it is carried up or down; -- a trade term.","pos":""}],"ESCALOP":[{"def":"A bivalve shell of the genus Pecten.","pos":""}],"ESCALOPED":[{"def":"Covered with a pattern resembling a series of escalop shells, each of which issues from between two others.","pos":""}],"ESCAMBIO":[{"def":"A license formerly required for the making over a bill of exchange to another over sea.","pos":""}],"ESCAPADE":[{"def":"The fling of a horse, or ordinary kicking back of his heels; a gambol.","pos":""},{"def":"Act by which one breaks loose from the rules of propriety or good sense; a freak; a prank.","pos":""}],"ESCAPE":[{"def":"To flee from and avoid; to be saved or exempt from; to shun; to obtain security from; as, to escape danger.","pos":""},{"def":"To avoid the notice of; to pass unobserved by; to evade; as, the fact escaped our attention.","pos":""}],"ESCAPEMENT":[{"def":"The act of escaping; escape.","pos":""},{"def":"Way of escape; vent.","pos":""}],"ESCAPER":[{"def":"One who escapes.","pos":""}],"ESCARBUNCLE":[{"def":"See Carbuncle, 3.","pos":""}],"ESCARGATOIRE":[{"def":"A nursery of snails.","pos":""}],"ESCARP":[{"def":"The side of the ditch next the parapet; -- same as scarp, and opposed to counterscarp.","pos":""}],"ESCARPMENT":[{"def":"A steep descent or declivity; steep face or edge of a ridge; ground about a fortified place, cut away nearly vertically to prevent hostile approach.","pos":""},{"def":"A suffix signifying beginning, beginning to be; as, adolescent, effervescent, etc.","pos":""}],"ESCHAR":[{"def":"A dry slough, crust, or scab, which separates from the healthy part of the body, as that produced by a burn, or the application of caustics.","pos":""}],"ESCHARA":[{"def":"A genus of Bryozoa which produce delicate corals, often incrusting like lichens, but sometimes branched.","pos":""}],"ESCHARINE":[{"def":"Like, or pertaining to, the genus Eschara, or family Escharidæ.","pos":""}],"ESCHAROTIC":[{"def":"Serving or tending to form an eschar;; producing a scar; caustic.","pos":""}],"ESCHATOLOGICAL":[{"def":"Pertaining to the last or final things.","pos":""}],"ESCHATOLOGY":[{"def":"The doctrine of the last or final things, as death, judgment, and the events therewith connected.","pos":""}],"ESCHEAT":[{"def":"Lands which fall to the lord or the State by escheat.","pos":""},{"def":"That which falls to one; a reversion or return To make me great by others' loss is bad escheat.","pos":""}],"ESCHEATABLE":[{"def":"Liable to escheat.","pos":""}],"ESCHEATAGE":[{"def":"The right of succeeding to an escheat.","pos":""}],"ESCHEATOR":[{"def":"An officer whose duty it is to observe what escheats have taken place, and to take charge of them.","pos":""}],"ESCHEVIN":[{"def":"The alderman or chief officer of an ancient guild.","pos":""}],"ESCHEW":[{"def":"To shun; to avoid, as something wrong, or from a feeling of distaste; to keep one's self clear of.","pos":""},{"def":"To escape from; to avoid.","pos":""}],"ESCHEWER":[{"def":"One who eschews.","pos":""}],"ESCHEWMENT":[{"def":"The act of eschewing.","pos":""}],"ESCHSCHOLTZIA":[{"def":"A genus of papaveraceous plants, found in California and upon the west coast of North America, some species of which produce beautiful yellow, orange, rose-colored, or white flowers; the California poppy.","pos":""}],"ESCHYNITE":[{"def":"A rare mineral, containing chiefly niobium, titanium, thorium, and cerium.","pos":""}],"ESCOCHEON":[{"def":"A kind of firearm; a carbine.","pos":""}],"ESCORT":[{"def":"Protection, care, or safeguard on a journey or excursion; as, to travel under the escort of a friend.","pos":""}],"ESCOT":[{"def":"See Scot, a tax.","pos":""}],"ESCRIBED":[{"def":"Drawn outside of; -- used to designate a circle that touches one of the sides of a given triangle, and also the other two sides produced.","pos":""}],"ESCRITOIRE":[{"def":"A piece of furniture used as a writing table, commonly with drawers, pigeonholes, and the like; a secretary or writing desk.","pos":""}],"ESCRITORIAL":[{"def":"Of or pertaining to an escritoire.","pos":""}],"ESCROD":[{"def":"See Scrod, a young cod.","pos":""}],"ESCROW":[{"def":"A deed, bond, or other written engagement, delivered to a third person, to be held by him till some act is done or some condition is performed, and then to be by him delivered to the grantee.","pos":""}],"ESCUAGE":[{"def":"Service of the shield, a species of knight service by which a tenant was bound to follow his lord to war, at his own charge.","pos":""}],"ESCULAPIUS":[{"def":"Same as Æsculapius.","pos":""}],"ESCULENT":[{"def":"Suitable to be used by man for food; eatable; edible; as, esculent plants; esculent fish.","pos":""}],"ESCULIC":[{"def":"Pertaining to, or obtained from, the horse-chestnut; as, esculic acid.","pos":""}],"ESCULIN":[{"def":"A glucoside obtained from the Æsculus hippocastanum, or horse- chestnut, and characterized by its fine blue fluorescent solutions.","pos":""}],"ESCURIAL":[{"def":"A palace and mausoleum of the kinds of Spain, being a vast and wonderful structure about twenty-five miles northwest of Madrid.","pos":""}],"ESCUTCHEON":[{"def":"The surface, usually a shield, upon which bearings are marshaled and displayed.","pos":""},{"def":"That part of a vessel's stern on which her name is written.","pos":""}],"ESCUTCHEONED":[{"def":"Having an escutcheon; furnished with a coat of arms or ensign.","pos":""}]}