{"CHENG":[{"def":"A chinese reed instrument, with tubes, blown by the mouth.","pos":""}],"CHENILLE":[{"def":"Tufted cord, of silk or worsted, for the trimimg of ladies' dresses, for embroidery and fringes, and for the weft of chenille rugs.","pos":""}],"CHENOMORPHAE":[{"def":"An order of birds, including the swans, ducks, geese, flamingoes and screamers.","pos":""}]}