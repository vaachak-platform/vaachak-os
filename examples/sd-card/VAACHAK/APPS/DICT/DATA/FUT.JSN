{"FUTCHEL":[{"def":"The jaws between which the hinder end of a carriage tongue is inserted.","pos":""},{"def":"The Runic alphabet; -- so called from the six letters f, u, þ (th), o (or a), r, c (=k).","pos":""}],"FUTILE":[{"def":"Talkative; loquacious; tattling.","pos":""},{"def":"Of no importance; answering no useful end; useless; vain; worthless.","pos":""}],"FUTILELY":[{"def":"In a futile manner.","pos":""}],"FUTILITY":[{"def":"The quality of being talkative; talkativeness; loquaciousness; loquacity.","pos":""},{"def":"The quality of producing no valuable effect, or of coming to nothing; uselessness.","pos":""}],"FUTILOUS":[{"def":"Futile; trifling.","pos":""}],"FUTTOCK":[{"def":"One of the crooked timbers which are scarfed together to form the lower part of the compound rib of a vessel; one of the crooked transverse timbers passing across and over the keel.","pos":""}],"FUTURABLE":[{"def":"Capable of being future; possible to occur.","pos":""}],"FUTURE":[{"def":"That is to be or come hereafter; that will exist at any time after the present; as, the next moment is future, to the present.","pos":""}],"FUTURELESS":[{"def":"Without prospect of betterment in the future.","pos":""}],"FUTURELY":[{"def":"In time to come.","pos":""}],"FUTURISM":[{"def":"A movement or phase of post-impressionism (which see, below).","pos":""}],"FUTURIST":[{"def":"One who believes or maintains that the fulfillment of the prophecies of the Bible is to be in the future.","pos":""}],"FUTURITIAL":[{"def":"Relating to what is to come; pertaining to futurity; future.","pos":""}],"FUTURITION":[{"def":"The state of being future; futurity.","pos":""}],"FUTURITY":[{"def":"State of being that is yet to come; future state.","pos":""},{"def":"Future time; time to come; the future.","pos":""}]}