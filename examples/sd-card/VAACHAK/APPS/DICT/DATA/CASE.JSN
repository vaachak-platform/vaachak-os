{"CASE":[{"def":"A shallow tray divided into compartments or \"boxes\" for holding type.","pos":""},{"def":"A small fissure which admits water to the workings.","pos":""}],"CASE KNIFE":[{"def":"A knife carried in a sheath or case.","pos":""},{"def":"A large table knife; -- so called from being formerly kept in a case.","pos":""}],"CASE SHOT":[{"def":"A collection of small projectiles, inclosed in a case or canister.","pos":""}],"CASE SYSTEM":[{"def":"The system of teaching law in which the instruction is primarily a historical and inductive study of leading or selected cases, with or without the use of textbooks for reference and collateral reading.","pos":""}],"CASEATION":[{"def":"A degeneration of animal tissue into a cheesy or curdy mass.","pos":""}],"CASEHARDEN":[{"def":"To subject to a process which converts the surface of iron into steel.","pos":""},{"def":"To render insensible to good influences.","pos":""}],"CASEHARDENED":[{"def":"Having the surface hardened, as iron tools.","pos":""},{"def":"Hardened against, or insusceptible to, good influences; rendered callous by persistence in wrongdoing or resistance of good influences; -- said of persons.","pos":""}],"CASEHARDENING":[{"def":"The act or process of converting the surface of iron into steel.","pos":""}],"CASEIC":[{"def":"OF or pertaining to cheese; as, caseic acid.","pos":""}],"CASEIN":[{"def":"A proteid substance present in both the animal and the vegetable kingdom.","pos":""}],"CASEMATE":[{"def":"A bombproof chamber, usually of masonry, in which cannon may be placed, to be fired through embrasures; or one capable of being used as a magazine, or for quartering troops.","pos":""},{"def":"A hollow molding, chiefly in cornices.","pos":""}],"CASEMATED":[{"def":"Furnished with, protected by, or built like, a casemate.","pos":""}],"CASEMENT":[{"def":"A window sash opening on hinges affixed to the upright side of the frame into which it is fitted.","pos":""}],"CASEMENTED":[{"def":"Having a casement or casements.","pos":""}],"CASEOSE":[{"def":"A soluble product (proteose) formed in the gastric and pancreatic digestion of casein and caseinogen.","pos":""}],"CASEOUS":[{"def":"Of, pertaining to, or resembling, cheese; having the qualities of cheese; cheesy.","pos":""}],"CASERN":[{"def":"A lodging for soldiers in garrison towns, usually near the rampart; barracks.","pos":""}],"CASEWORM":[{"def":"A worm or grub that makes for itself a case.","pos":""}]}