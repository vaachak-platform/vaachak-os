{"CHOICE":[{"def":"Act of choosing; the voluntary act of selecting or separating from two or more things that which is preferred; the determination of the mind in preferring one thing to another; election.","pos":""},{"def":"The power or opportunity of choosing; option.","pos":""}],"CHOICEFUL":[{"def":"Making choices; fickle.","pos":""}],"CHOICELY":[{"def":"With care in choosing; with nice regard to preference.","pos":""},{"def":"In a preferable or excellent manner; excellently; eminently.","pos":""}],"CHOICENESS":[{"def":"The quality of being of particular value or worth; nicely; excellence.","pos":""}],"CHOIR":[{"def":"A band or organized company of singers, especially in church service.","pos":""},{"def":"That part of a church appropriated to the singers.","pos":""}]}