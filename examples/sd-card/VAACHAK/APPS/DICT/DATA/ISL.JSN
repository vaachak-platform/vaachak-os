{"ISLAM":[{"def":"The religion of the Mohammedans; Mohammedanism; Islamism.","pos":""},{"def":"The whole body of Mohammedans, or the countries which they occupy.","pos":""}],"ISLAMISM":[{"def":"The faith, doctrines, or religious system of the Mohammedans; Mohammedanism; Islam.","pos":""}],"ISLAMITIC":[{"def":"Of or pertaining to Islam; Mohammedan.","pos":""}],"ISLAMIZE":[{"def":"To conform, or cause to conform, to the religion of Islam.","pos":""}],"ISLAND":[{"def":"A tract of land surrounded by water, and smaller than a continent.","pos":""},{"def":"Anything regarded as resembling an island; as, an island of ice.","pos":""}],"ISLANDER":[{"def":"An inhabitant of an island.","pos":""}],"ISLANDY":[{"def":"Of or pertaining to islands; full of islands.","pos":""}],"ISLE":[{"def":"A spot within another of a different color, as upon the wings of some insects.","pos":""}],"ISLET":[{"def":"A little island.","pos":""},{"def":"A suffix indicating an act, a process, the result of an act or a process, a state; also, a characteristic (as a theory, doctrine, idiom, etc.","pos":""}]}