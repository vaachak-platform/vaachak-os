{"POLYOMMATOUS":[{"def":"Having many eyes.","pos":""}],"POLYONOMOUS":[{"def":"Having many names or titles; polyonymous.","pos":""}],"POLYONOMY":[{"def":"The use of a variety of names for the same object.","pos":""}],"POLYONYM":[{"def":"An object which has a variety of names.","pos":""},{"def":"A polynomial name or term.","pos":""}],"POLYONYMOUS":[{"def":"A glass through which objects appear multiplied, but diminished in size.","pos":""}],"POLYORAMA":[{"def":"A view of many objects; also, a sort of panorama with dissolving views.","pos":""}]}