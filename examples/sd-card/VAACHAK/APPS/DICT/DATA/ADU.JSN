{"ADULARIA":[{"def":"A transparent or translucent variety of common feldspar, or orthoclase, which often shows pearly opalescent reflections; -- called by lapidaries moonstone.","pos":""}],"ADULATE":[{"def":"To flatter in a servile way.","pos":""}],"ADULATION":[{"def":"Servile flattery; praise in excess, or beyond what is merited.","pos":""}],"ADULATOR":[{"def":"A servile or hypocritical flatterer.","pos":""}],"ADULATORY":[{"def":"Containing excessive praise or compliment; servilely praising; flattering; as, an adulatory address.","pos":""}],"ADULATRESS":[{"def":"A woman who flatters with servility.","pos":""}],"ADULT":[{"def":"Having arrived at maturity, or to full size and strength; matured; as, an adult person or plant; an adult ape; an adult age.","pos":""}],"ADULTER":[{"def":"To commit adultery; to pollute.","pos":""}],"ADULTERANT":[{"def":"That which is used to adulterate anything.","pos":""}],"ADULTERATE":[{"def":"To defile by adultery.","pos":""},{"def":"To corrupt, debase, or make impure by an admixture of a foreign or a baser substance; as, to adulterate food, drink, drugs, coin, etc.","pos":""}],"ADULTERATION":[{"def":"The act of adulterating; corruption, or debasement (esp.","pos":""},{"def":"An adulterated state or product.","pos":""}],"ADULTERATOR":[{"def":"One who adulterates or corrupts.","pos":""}],"ADULTERER":[{"def":"A man who violates his religious covenant.","pos":""}],"ADULTERESS":[{"def":"A woman who violates her religious engagements.","pos":""}],"ADULTERINE":[{"def":"Proceeding from adulterous intercourse.","pos":""}],"ADULTERIZE":[{"def":"To commit adultery.","pos":""}],"ADULTEROUS":[{"def":"Guilty of, or given to, adultery; pertaining to adultery; illicit.","pos":""},{"def":"Characterized by adulteration; spurious.","pos":""}],"ADULTEROUSLY":[{"def":"In an adulterous manner.","pos":""}],"ADULTERY":[{"def":"The fine and penalty imposed for the offense of adultery.","pos":""},{"def":"The intrusion of a person into a bishopric during the life of the bishop.","pos":""}],"ADULTNESS":[{"def":"The state of being adult.","pos":""}],"ADUMBRANT":[{"def":"Giving a faint shadow, or slight resemblance; shadowing forth.","pos":""}],"ADUMBRATE":[{"def":"To give a faint shadow or slight representation of; to outline; to shadow forth.","pos":""},{"def":"To overshadow; to shade.","pos":""}],"ADUMBRATION":[{"def":"The shadow or outlines of a figure.","pos":""}],"ADUMBRATIVE":[{"def":"Faintly representing; typical.","pos":""}],"ADUNATION":[{"def":"A uniting; union.","pos":""},{"def":"Hooked; as, a parrot has an adunc bill.","pos":""}],"ADUNCITY":[{"def":"Curvature inwards; hookedness.","pos":""}],"ADUNCOUS":[{"def":"Curved inwards; hooked.","pos":""}],"ADUROL":[{"def":"Either of two compounds, a chlorine derivative and bromine derivative, of hydroquinone, used as developers.","pos":""}],"ADUST":[{"def":"Having much heat in the constitution and little serum in the blood.","pos":""}],"ADUSTIBLE":[{"def":"That may be burnt.","pos":""}],"ADUSTION":[{"def":"The act of burning, or heating to dryness; the state of being thus heated or dried.","pos":""}]}