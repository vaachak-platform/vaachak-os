{"INEXACT":[{"def":"Not exact; not precisely correct or true; inaccurate.","pos":""}],"INEXACTITUDE":[{"def":"Inexactness; uncertainty; as, geographical inexactitude.","pos":""}],"INEXACTLY":[{"def":"In a manner not exact or precise; inaccurately.","pos":""}],"INEXACTNESS":[{"def":"Incorrectness; want of exactness.","pos":""}],"INEXCITABILITY":[{"def":"The quality of being inexcitable; insusceptibility to excitement.","pos":""}],"INEXCITABLE":[{"def":"Not susceptible of excitement; dull; lifeless; torpid.","pos":""}],"INEXCUSABLE":[{"def":"Not excusable; not admitting excuse or justification; as, inexcusable folly.","pos":""}],"INEXCUSABLENESS":[{"def":"The quality of being inexcusable; enormity forgiveness.","pos":""}],"INEXCUSABLY":[{"def":"With a degree of guilt or folly beyond excuse or justification.","pos":""}],"INEXECRABLE":[{"def":"That can not be execrated enough.","pos":""}],"INEXECUTABLE":[{"def":"Incapable of being executed or performed; impracticable; infeasible.","pos":""}],"INEXECUTION":[{"def":"Neglect of execution; nonperformance; as, the inexecution of a treaty.","pos":""}],"INEXERTION":[{"def":"Want of exertion; want of effort; defect of action; indolence; laziness.","pos":""}],"INEXHALABLE":[{"def":"Incapable of being exhaled.","pos":""}],"INEXHAUSTED":[{"def":"Not exhausted; not emptied; not spent; not having lost all strength or resources; unexhausted.","pos":""}],"INEXHAUSTEDLY":[{"def":"Without exhaustion.","pos":""}],"INEXHAUSTIBILITY":[{"def":"The state or quality of being inexhaustible; abundance.","pos":""}],"INEXHAUSTIBLE":[{"def":"Incapable of being exhausted, emptied, or used up; unfailing; not to be wasted or spent; as, inexhaustible stores of provisions; an inexhaustible stock of elegant words.","pos":""}],"INEXIST":[{"def":"To exist within; to dwell within.","pos":""}],"INEXISTANT":[{"def":"Inexistent; not existing.","pos":""}],"INEXISTENCE":[{"def":"Want of being or existence.","pos":""}],"INEXISTENT":[{"def":"Not having being; not existing.","pos":""}],"INEXORABILITY":[{"def":"The quality of being inexorable, or unyielding to entreaty.","pos":""}],"INEXORABLE":[{"def":"Not to be persuaded or moved by entreaty or prayer; firm; determined; unyielding; unchangeable; inflexible; relentless; as, an inexorable prince or tyrant; an inexorable judge.","pos":""}],"INEXORABLENESS":[{"def":"The quality or state of being inexorable.","pos":""}],"INEXORABLY":[{"def":"In an inexorable manner; inflexibly.","pos":""}],"INEXPANSIBLE":[{"def":"Incapable of expansion, enlargement, or extension.","pos":""}],"INEXPECTABLE":[{"def":"Not to be expected or anticipated.","pos":""}],"INEXPECTATION":[{"def":"Absence of expectation.","pos":""}],"INEXPECTEDLY":[{"def":"In`ex*pect\"ed*ly, adv.","pos":""}],"INEXPECTEDNESS":[{"def":"The quality or state of being inexpedient; want of fitness; unsuitableness to the end or object; impropriety; as, the inexpedience of some measures.","pos":""}],"INEXPEDIENT":[{"def":"Not expedient; not tending to promote a purpose; not tending to the end desired; inadvisable; unfit; improper; unsuitable to time and place; as, what is expedient at one time may be inexpedient at another.","pos":""}],"INEXPEDIENTLY":[{"def":"In`ex*pe\"di*ent*ly, adv.","pos":""}],"INEXPENSIVE":[{"def":"Not expensive; cheap.","pos":""}],"INEXPERIENCE":[{"def":"Absence or want of experience; lack of personal and experimental knowledge; as, the inexperience of youth.","pos":""}],"INEXPERIENCED":[{"def":"Not having experience unskilled.","pos":""}],"INEXPERT":[{"def":"Destitute of experience or of much experience.","pos":""},{"def":"Not expert; not skilled; destitute of knowledge or dexterity derived from practice.","pos":""}],"INEXPERTNESS":[{"def":"Want of expertness or skill.","pos":""}],"INEXPIABLE":[{"def":"Admitting of no expiation, atonement, or satisfaction; as, an inexpiable crime or offense.","pos":""},{"def":"Incapable of being mollified or appeased; relentless; implacable.","pos":""}],"INEXPIABLENESS":[{"def":"Quality of being inexpiable.","pos":""}],"INEXPIABLY":[{"def":"In an inexpiable manner of degree; to a degree that admits of no atonement.","pos":""}],"INEXPIATE":[{"def":"Not appeased or placated.","pos":""}],"INEXPLAINABLE":[{"def":"Incapable of being explained; inexplicable.","pos":""}],"INEXPLICABILITY":[{"def":"The quality or state of being inexplicable.","pos":""}],"INEXPLICABLE":[{"def":"Not explicable; not explainable; incapable of being explained, interpreted, or accounted for; as, an inexplicable mystery.","pos":""}],"INEXPLICABLENESS":[{"def":"A state of being inexplicable; inexplicability.","pos":""}],"INEXPLICABLY":[{"def":"In an inexplicable manner.","pos":""}],"INEXPLICIT":[{"def":"Not explicit; not clearly stated; indefinite; vague.","pos":""}],"INEXPLORABLE":[{"def":"Incapable of being explored, searched out, or discovered.","pos":""}],"INEXPOSURE":[{"def":"A state of not being exposed.","pos":""}],"INEXPRESSIBLE":[{"def":"Not capable of expression or utterance in language; ineffable; unspeakable; indescribable; unutterable; as, inexpressible grief or pleasure.","pos":""}],"INEXPRESSIBLES":[{"def":"Breeches; trousers.","pos":""}],"INEXPRESSIBLY":[{"def":"In an inexpressible manner or degree; unspeakably; unutterably.","pos":""}],"INEXPRESSIVE":[{"def":"Without expression or meaning; not expressive; dull; unintelligent; as, an inexpressive countenance.","pos":""}],"INEXPRESSIVENESS":[{"def":"The state or quality of being inexpressive.","pos":""}],"INEXPUGNABLE":[{"def":"Incapable of being subdued by force; impregnable; unconquerable.","pos":""}],"INEXPUGNABLY":[{"def":"So as to be inexpugnable; in an inexpugnable manner.","pos":""}],"INEXSUPERABLE":[{"def":"Not capable of being passed over; insuperable; insurmountable.","pos":""}],"INEXTENSIBLE":[{"def":"Not capable of being extended; not elastic; as, inextensible fibers.","pos":""}],"INEXTENSION":[{"def":"Want of extension; unextended state.","pos":""}],"INEXTERMINABLE":[{"def":"Incapable of extermination.","pos":""}],"INEXTINCT":[{"def":"Not quenched; not extinct.","pos":""}],"INEXTINGUIBLE":[{"def":"Inextinguishable.","pos":""}],"INEXTINGUISHABLE":[{"def":"Not capable of being extinguished; extinguishable; unquenchable; as, inextinguishable flame, light, thirst, desire, feuds.","pos":""}],"INEXTINGUISHABLY":[{"def":"So as not to be extinguished; in an inextinguishable manner.","pos":""}],"INEXTIRPABLE":[{"def":"Not capable of being extirpated or rooted out; ineradicable.","pos":""}],"INEXTRICABLE":[{"def":"Incapable of being extricated, untied, or disentangled; hopelessly intricate, confused, or obscure; as, an inextricable knot or difficulty; inextricable confusion.","pos":""}],"INEXTRICABLENESS":[{"def":"The state of being inextricable.","pos":""}],"INEXTRICABLY":[{"def":"In an inextricable manner.","pos":""}]}