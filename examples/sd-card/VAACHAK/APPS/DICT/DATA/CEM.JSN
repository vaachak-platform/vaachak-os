{"CEMBALO":[{"def":"An old mname for the harpsichord.","pos":""}],"CEMENT":[{"def":"The layer of bone investing the root and neck of a tooth; -- called also cementum.","pos":""}],"CEMENT STEEL":[{"def":"Steel produced by cementation; blister steel.","pos":""}],"CEMENTAL":[{"def":"Of or pertaining to cement, as of a tooth; as, cemental tubes.","pos":""}],"CEMENTATION":[{"def":"The act or process of cementing.","pos":""}],"CEMENTATORY":[{"def":"Having the quality of cementating or uniting firmly.","pos":""}],"CEMENTER":[{"def":"A person or thing that cements.","pos":""}],"CEMENTITIOUS":[{"def":"Of the nature of cement.","pos":""}],"CEMETERIAL":[{"def":"Of or pertaining to a cemetery.","pos":""}],"CEMETERY":[{"def":"A place or ground set apart for the burial of the dead; a graveyard; a churchyard; a necropolis.","pos":""}]}