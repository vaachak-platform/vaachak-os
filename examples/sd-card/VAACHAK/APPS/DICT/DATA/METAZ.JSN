{"METAZOA":[{"def":"Those animals in which the protoplasmic mass, constituting the egg, is converted into a multitude of cells, which are metamorphosed into the tissues of the body.","pos":""}],"METAZOAN":[{"def":"One of the Metazoa.","pos":""}],"METAZOIC":[{"def":"Of or pertaining to the Metazoa.","pos":""},{"def":"One of the Metazoa.","pos":""}]}