{"ALP":[{"def":"A very high mountain.","pos":""}],"ALPACA":[{"def":"An animal of Peru (Lama paco), having long, fine, wooly hair, supposed by some to be a domesticated variety of the llama.","pos":""}],"ALPEN":[{"def":"Of or pertaining to the Alps.","pos":""}],"ALPENGLOW":[{"def":"A reddish glow seen near sunset or sunrise on the summits of mountains; specif.","pos":""},{"def":"A curved wooden horn about three feet long, with a cupped mouthpiece and a bell, used by the Swiss to sound the ranz des vaches and other melodies.","pos":""}],"ALPENSTOCK":[{"def":"A long staff, pointed with iron, used in climbing the Alps.","pos":""}],"ALPESTRINE":[{"def":"Pertaining to the Alps, or other high mountains; as, Alpestrine diseases, etc.","pos":""}],"ALPHA":[{"def":"The first letter in the Greek alphabet, answering to A, and hence used to denote the beginning.","pos":""}],"ALPHA PAPER":[{"def":"A sensitized paper for obtaining positives by artificial light.","pos":""}],"ALPHA RAYS":[{"def":"Rays of relatively low penetrating power emitted by radium and other radioactive substances, and shown to consist of positively charged particles (perhaps particles of helium) having enormous velocities but small masses.","pos":""}],"ALPHABET":[{"def":"The letters of a language arranged in the customary order; the series of letters or signs which form the elements of written language.","pos":""},{"def":"The simplest rudiments; elements.","pos":""}],"ALPHABETARIAN":[{"def":"A learner of the alphabet; an abecedarian.","pos":""}],"ALPHABETICALLY":[{"def":"In an alphabetic manner; in the customary order of the letters.","pos":""}],"ALPHABETICS":[{"def":"The science of representing spoken sounds by letters.","pos":""}],"ALPHABETISM":[{"def":"The expression of spoken sounds by an alphabet.","pos":""}],"ALPHABETIZE":[{"def":"To arrange alphabetically; as, to alphabetize a list of words.","pos":""},{"def":"To furnish with an alphabet.","pos":""}],"ALPHOL":[{"def":"A crystalline derivative of salicylic acid, used as an antiseptic and antirheumatic.","pos":""}],"ALPHONSINE":[{"def":"Of or relating to Alphonso X.","pos":""}],"ALPIGENE":[{"def":"Growing in Alpine regions.","pos":""}],"ALPINE":[{"def":"Of or pertaining to the Alps, or to any lofty mountain; as, Alpine snows; Alpine plants.","pos":""},{"def":"Like the Alps; lofty.","pos":""}],"ALPINIST":[{"def":"A climber of the Alps.","pos":""},{"def":"The seed of canary grass (Phalaris Canariensis), used for feeding cage birds.","pos":""}]}