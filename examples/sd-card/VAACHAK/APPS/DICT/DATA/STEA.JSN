{"STEAD":[{"def":"Place, or spot, in general.","pos":""},{"def":"Place or room which another had, has, or might have.","pos":""}],"STEADFAST":[{"def":"Firmly fixed or established; fast fixed; firm.","pos":""},{"def":"Not fickle or wavering; constant; firm; resolute; unswerving; steady.","pos":""}],"STEADFASTLY":[{"def":"In a steadfast manner; firmly.","pos":""}],"STEADFASTNESS":[{"def":"The quality or state of being steadfast; firmness; fixedness; constancy.","pos":""}],"STEADILY":[{"def":"In a steady manner.","pos":""}],"STEADINESS":[{"def":"The quality or state of being steady.","pos":""}],"STEADING":[{"def":"The brans, stables, cattle-yards, etc.","pos":""}],"STEADY":[{"def":"Firm in standing or position; not tottering or shaking; fixed; firm.","pos":""},{"def":"Constant in feeling, purpose, or pursuit; not fickle, changeable, or wavering; not easily moved or persuaded to alter a purpose; resolute; as, a man steady in his principles, in his purpose, or in the pursuit of an object.","pos":""}],"STEAK":[{"def":"A slice of beef, broiled, or cut for broiling; -- also extended to the meat of other large animals; as, venison steak; bear steak; pork steak; turtle steak.","pos":""}],"STEAL":[{"def":"A handle; a stale, or stele.","pos":""}],"STEALER":[{"def":"The endmost plank of a strake which stops short of the stem or stern.","pos":""}],"STEALING":[{"def":"The act of taking feloniously the personal property of another without his consent and knowledge; theft; larceny.","pos":""},{"def":"That which is stolen; stolen property; -- chiefly used in the plural.","pos":""}],"STEALINGLY":[{"def":"By stealing, or as by stealing, furtively, or by an invisible motion.","pos":""}],"STEALTH":[{"def":"The act of stealing; theft.","pos":""},{"def":"The thing stolen; stolen property.","pos":""}],"STEALTHFUL":[{"def":"Given to stealth; stealthy.","pos":""}],"STEALTHILY":[{"def":"In a stealthy manner.","pos":""}],"STEALTHINESS":[{"def":"The state, quality, or character of being stealthy; stealth.","pos":""}],"STEALTHY":[{"def":"Done by stealth; accomplished clandestinely; unperceived; secret; furtive; sly.","pos":""}],"STEAM":[{"def":"The elastic, aëriform fluid into which water is converted when heated to the boiling points; water in the state of vapor.","pos":""},{"def":"The mist formed by condensed vapor; visible vapor; -- so called in popular usage.","pos":""}],"STEAM ENGINE":[{"def":"An engine moved by steam.","pos":""}],"STEAMBOAT":[{"def":"A boat or vessel propelled by steam power; -- generally used of river or coasting craft, as distinguished from ocean steamers.","pos":""}],"STEAMBOATING":[{"def":"The shearing of a pile of books which are as yet uncovered, or out of boards.","pos":""}],"STEAMER":[{"def":"The steamer duck.","pos":""}],"STEAMINESS":[{"def":"The quality or condition of being steamy; vaporousness; mistness.","pos":""}],"STEAMSHIP":[{"def":"A ship or seagoing vessel propelled by the power of steam; a steamer.","pos":""}],"STEAMY":[{"def":"Consisting of, or resembling, steam; full of steam; vaporous; misty.","pos":""}],"STEAPSIN":[{"def":"An unorganized ferment or enzyme present in pancreatic juice.","pos":""}],"STEARATE":[{"def":"A salt of stearic acid; as, ordinary soap consists largely of sodium or potassium stearates.","pos":""}],"STEARIC":[{"def":"Pertaining to, or obtained from, stearin or tallow; resembling tallow.","pos":""}],"STEARIN":[{"def":"One of the constituents of animal fats and also of some vegetable fats, as the butter of cacao.","pos":""}],"STEAROLIC":[{"def":"Of, pertaining to, or designating, an acid of the acetylene series, isologous with stearis acid, and obtained, as a white crystalline substance, from oleïc acid.","pos":""}],"STEARONE":[{"def":"The ketone of stearic acid, obtained as a white crystalline substance, (C17H35)2.","pos":""}],"STEAROPTENE":[{"def":"The more solid ingredient of certain volatile oils; -- contrasted with elæoptene.","pos":""}],"STEARYL":[{"def":"The hypothetical radical characteristic of stearic acid.","pos":""}],"STEATITE":[{"def":"A massive variety of talc, of a grayish green or brown color.","pos":""}],"STEATITIC":[{"def":"Pertaining to, or of the nature of, steatite; containing or resembling steatite.","pos":""}],"STEATOMA":[{"def":"A cyst containing matter like suet.","pos":""}],"STEATOMATOUS":[{"def":"Of the nature of steatoma.","pos":""}],"STEATOPYGA":[{"def":"A remarkable accretion of fat upon the buttocks of Africans of certain tribes, especially of Hottentot women.","pos":""}],"STEATOPYGOUS":[{"def":"Having fat buttocks.","pos":""},{"def":"See Stead, Steadfast, etc.","pos":""}]}