{"NONUNIFORMIST":[{"def":"One who believes that past changes in the structure of the earth have proceeded from cataclysms or causes more violent than are now operating; -- called also nonuniformitarian.","pos":""}],"NONUNION":[{"def":"Not belonging to, or affiliated with, a trades union; as, a nonunoin carpenter.","pos":""},{"def":"Not recognizing or favoring trades unions or trades-unionists; as, a nonunion contractor.","pos":""}],"NONUNIONIST":[{"def":"One who does not belong, or refuses to belong, to a trades union.","pos":""}],"NONUSANCE":[{"def":"Neglect of using; failure to use.","pos":""}],"NONUSER":[{"def":"Neglect or omission to use an easement or franchise or to assert a right.","pos":""}]}