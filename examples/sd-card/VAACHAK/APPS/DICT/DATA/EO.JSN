{"EOCENE":[{"def":"Pertaining to the first in time of the three subdivisions into which the Tertiary formation is divided by geologists, and alluding to the approximation in its life to that of the present era; as, Eocene deposits.","pos":""},{"def":"The Eocene formation.","pos":""}],"EOLIAN":[{"def":"Formed, or deposited, by the action of wind, as dunes.","pos":""}],"EOLIPILE":[{"def":"Same as Æolipile.","pos":""}],"EOLIS":[{"def":"A genus of nudibranch mollusks having clusters of branchial papillæ along the back.","pos":""},{"def":"One of the embodiments of the divine attributes of the Eternal Being.","pos":""}],"EOPHYTE":[{"def":"A fossil plant which is found in the lowest beds of the Silurian age.","pos":""}],"EOPHYTIC":[{"def":"Of or pertaining to eophytes.","pos":""}],"EOS":[{"def":"Aurora, the goddess of morn.","pos":""}],"EOSAURUS":[{"def":"An extinct marine reptile from the coal measures of Nova Scotia; -- so named because supposed to be of the earliest known reptiles.","pos":""}],"EOSIN":[{"def":"A yellow or brownish red dyestuff obtained by the action of bromine on fluoresceïn, and named from the fine rose-red which it imparts to silk.","pos":""}],"EOSPHORITE":[{"def":"A hydrous phosphate of alumina and manganese.","pos":""}],"EOZOIC":[{"def":"Of or pertaining to rocks or strata older than the Paleozoic, in many of which the eozoön has been found.","pos":""},{"def":"A peculiar structure found in the Archæan limestones of Canada and other regions.","pos":""}]}