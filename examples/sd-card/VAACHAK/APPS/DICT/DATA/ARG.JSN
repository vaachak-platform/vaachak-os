{"ARGAL":[{"def":"A ludicrous corruption of the Latin word ergo, therefore.","pos":""},{"def":"A species of wild sheep (Ovis ammon, or O.","pos":""}],"ARGALA":[{"def":"The adjutant bird.","pos":""}],"ARGAND LAMP":[{"def":"A lamp with a circular hollow wick and glass chimney which allow a current of air both inside and outside of the flame.","pos":""}],"ARGAS":[{"def":"A genus of venomous ticks which attack men and animals.","pos":""}],"ARGEAN":[{"def":"Pertaining to the ship Argo.","pos":""}],"ARGENT":[{"def":"Whiteness; anything that is white.","pos":""},{"def":"The white color in coats of arms, intended to represent silver, or, figuratively, purity, innocence, beauty, or gentleness; -- represented in engraving by a plain white surface.","pos":""}],"ARGENTAL":[{"def":"Of or pertaining to silver; resembling, containing, or combined with, silver.","pos":""}],"ARGENTALIUM":[{"def":"A (patented) alloy of aluminium and silver, with a density of about 2.","pos":""},{"def":"A solution of silver phosphate in an aqueous solution of ethylene diamine, used as an antiseptic astringent and as a disinfectant.","pos":""}],"ARGENTAN":[{"def":"An alloy of nicked with copper and zinc; German silver.","pos":""}],"ARGENTATION":[{"def":"A coating or overlaying with silver.","pos":""}],"ARGENTIC":[{"def":"Pertaining to, derived from, or containing, silver; -- said of certain compounds of silver in which this metal has its lowest proportion; as, argentic chloride.","pos":""}],"ARGENTIFEROUS":[{"def":"Producing or containing silver; as, argentiferous lead ore or veins.","pos":""}],"ARGENTINE":[{"def":"Pertaining to, or resembling, silver; made of, or sounding like, silver; silvery.","pos":""},{"def":"Of or pertaining to the Argentine Republic in South America.","pos":""}],"ARGENTITE":[{"def":"Sulphide of silver; -- also called vitreous silver, or silver glance.","pos":""}],"ARGENTOUS":[{"def":"Of, pertaining to, or containing, silver; -- said of certain silver compounds in which silver has a higher proportion than in argentic compounds; as, argentous chloride.","pos":""}],"ARGENTRY":[{"def":"Silver plate or vessels.","pos":""}],"ARGIL":[{"def":"Clay, or potter's earth; sometimes pure clay, or alumina.","pos":""}],"ARGILLACEOUS":[{"def":"Of the nature of clay; consisting of, or containing, argil or clay; clayey.","pos":""}],"ARGILLIFEROUS":[{"def":"Producing clay; -- applied to such earths as abound with argil.","pos":""}],"ARGILLITE":[{"def":"Argillaceous schist or slate; clay slate.","pos":""}],"ARGILLO-AREENACEOUS":[{"def":"Consisting of, or containing, clay and sand, as a soil.","pos":""}],"ARGILLO-CALCAREOUS":[{"def":"Consisting of, or containing, clay and calcareous earth.","pos":""}],"ARGILLO-FERRUGINOUS":[{"def":"Containing clay and iron.","pos":""}],"ARGILLOUS":[{"def":"Argillaceous; clayey.","pos":""}],"ARGIVE":[{"def":"Of or performance to Argos, the capital of Argolis in Greece.","pos":""},{"def":"A native of Argos.","pos":""}],"ARGO":[{"def":"The name of the ship which carried Jason and his fifty-four companions to Colchis, in quest of the Golden Fleece.","pos":""},{"def":"A large constellation in the southern hemisphere, called also Argo Navis.","pos":""}],"ARGOAN":[{"def":"Pertaining to the ship Argo.","pos":""}],"ARGOL":[{"def":"Crude tartar; an acidulous salt from which cream of tartar is prepared.","pos":""}],"ARGOLIC":[{"def":"Pertaining to Argolis, a district in the Peloponnesus.","pos":""}],"ARGON":[{"def":"A substance regarded as an element, contained in the atmosphere and remarkable for its chemical inertness.","pos":""}],"ARGONAUT":[{"def":"A cephalopod of the genus Argonauta.","pos":""}],"ARGONAUTA":[{"def":"A genus of Cephalopoda.","pos":""}],"ARGONAUTIC":[{"def":"Of or pertaining to the Argonauts.","pos":""}],"ARGOSY":[{"def":"A large ship, esp.","pos":""}],"ARGOT":[{"def":"A secret language or conventional slang peculiar to thieves, tramps, and vagabonds; flash.","pos":""}],"ARGUABLE":[{"def":"Capable of being argued; admitting of debate.","pos":""}],"ARGUE":[{"def":"To invent and offer reasons to support or overthrow a proposition, opinion, or measure; to use arguments; to reason.","pos":""},{"def":"To contend in argument; to dispute; to reason; -- followed by with; as, you may argue with your friend without convincing him.","pos":""}],"ARGUER":[{"def":"One who argues; a reasoner; a disputant.","pos":""}],"ARGUFY":[{"def":"To argue pertinaciously.","pos":""}],"ARGULUS":[{"def":"A genus of copepod Crustacea, parasitic of fishes; a fish louse.","pos":""}],"ARGUMENT":[{"def":"The quantity on which another quantity in a table depends; as, the altitude is the argument of the refraction.","pos":""},{"def":"The independent variable upon whose value that of a function depends.","pos":""}],"ARGUMENTABLE":[{"def":"Admitting of argument.","pos":""}],"ARGUMENTAL":[{"def":"Of, pertaining to, or containing, argument; argumentative.","pos":""}],"ARGUMENTATION":[{"def":"The act of forming reasons, making inductions, drawing conclusions, and applying them to the case in discussion; the operation of inferring propositions, not known or admitted as true, from facts or principles known, admitted, or proved to be true.","pos":""},{"def":"Debate; discussion.","pos":""}],"ARGUMENTATIVE":[{"def":"Consisting of, or characterized by, argument; containing a process of reasoning; as, an argumentative discourse.","pos":""},{"def":"Adductive as proof; indicative; as, the adaptation of things to their uses is argumentative of infinite wisdom in the Creator.","pos":""}],"ARGUMENTIZE":[{"def":"To argue or discuss.","pos":""}],"ARGUS":[{"def":"A fabulous being of antiquity, said to have had a hundred eyes, who has placed by Juno to guard Io.","pos":""},{"def":"A genus of East Indian pheasants.","pos":""}],"ARGUS SHELL":[{"def":"A species of shell (Cypræa argus), beautifully variegated with spots resembling those in a peacock's tail.","pos":""}],"ARGUS-EYED":[{"def":"Extremely observant; watchful; sharp-sighted.","pos":""}],"ARGUTATION":[{"def":"Caviling; subtle disputation.","pos":""}],"ARGUTE":[{"def":"Sagacious; acute; subtle; shrewd.","pos":""}],"ARGUTELY":[{"def":"In a subtle; shrewdly.","pos":""}],"ARGUTENESS":[{"def":"See Arrhizal, Arrhizous, Arrhythmic, Arrhythmous.","pos":""}]}