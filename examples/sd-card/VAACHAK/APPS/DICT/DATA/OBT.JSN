{"OBTAIN":[{"def":"To hold; to keep; to possess.","pos":""},{"def":"To get hold of by effort; to gain possession of; to procure; to acquire, in any way.","pos":""}],"OBTAINABLE":[{"def":"Capable of being obtained.","pos":""}],"OBTAINER":[{"def":"One who obtains.","pos":""}],"OBTAINMENT":[{"def":"The act or process of obtaining; attainment.","pos":""}],"OBTECTED":[{"def":"Covered with a hard chitinous case, as the pupa of certain files.","pos":""}],"OBTEMPER":[{"def":"To obey (a judgment or decree).","pos":""}],"OBTEND":[{"def":"To oppose; to hold out in opposition.","pos":""},{"def":"To offer as the reason of anything; to pretend.","pos":""}],"OBTENEBRATION":[{"def":"The act of darkening; the state of being darkened; darkness.","pos":""}],"OBTENSION":[{"def":"The act of obtending.","pos":""}],"OBTEST":[{"def":"To call to witness; to invoke as a witness.","pos":""},{"def":"To beseech; to supplicate; to beg for.","pos":""}],"OBTESTATION":[{"def":"The act of obtesting; supplication; protestation.","pos":""}],"OBTRECTATION":[{"def":"Slander; detraction; calumny.","pos":""}],"OBTRUDE":[{"def":"To thrust impertinently; to present without warrant or solicitation; as, to obtrude one's self upon a company.","pos":""},{"def":"To offer with unreasonable importunity; to urge unduly or against the will.","pos":""}],"OBTRUDER":[{"def":"One who obtrudes.","pos":""}],"OBTRUNCATE":[{"def":"To deprive of a limb; to lop.","pos":""}],"OBTRUNCATION":[{"def":"The act of lopping or cutting off.","pos":""}],"OBTRUSION":[{"def":"The act of obtruding; a thrusting upon others by force or unsolicited; as, the obtrusion of crude opinions on the world.","pos":""},{"def":"That which is obtruded.","pos":""}],"OBTRUSIONIST":[{"def":"One who practices or excuses obtrusion.","pos":""}],"OBTRUSIVE":[{"def":"Disposed to obtrude; inclined to intrude or thrust one's self or one's opinions upon others, or to enter uninvited; forward; pushing; intrusive.","pos":""}],"OBTUND":[{"def":"To reduce the edge, pungency, or violent action of; to dull; to blunt; to deaden; to quell; as, to obtund the acrimony of the gall.","pos":""}],"OBTUNDENT":[{"def":"A substance which sheathes a part, or blunts irritation, usually some bland, oily, or mucilaginous matter; -- nearly the same as demulcent.","pos":""}],"OBTUNDER":[{"def":"That which obtunds or blunts; especially, that which blunts sensibility.","pos":""}],"OBTURATE":[{"def":"To stop or close, as an opening; specif.","pos":""},{"def":"to stop (a gun breech) so as to prevent the escape of gas in firing.","pos":""}],"OBTURATION":[{"def":"The act of stopping up, or closing, an opening.","pos":""}],"OBTURATOR":[{"def":"An apparatus designed to close an unnatural opening, as a fissure of the palate.","pos":""}],"OBTUSANGULAR":[{"def":"See Obstuseangular.","pos":""}],"OBTUSE":[{"def":"Having an obtuse angle; as, an obtuse-angled triangle.","pos":""}],"OBTUSELY":[{"def":"In an obtuse manner.","pos":""}],"OBTUSENESS":[{"def":"State or quality of being obtuse.","pos":""}],"OBTUSION":[{"def":"The act or process of making obtuse or blunt.","pos":""},{"def":"The state of being dulled or blunted; as, the obtusion of the senses.","pos":""}]}