{"HOLARCTIC":[{"def":"designating a realm or region including the northern parts of the Old and the New World.","pos":""}],"HOLASPIDEAN":[{"def":"Having a single series of large scutes on the posterior side of the tarsus; -- said of certain birds.","pos":""}],"HOLCAD":[{"def":"A large ship of burden, in ancient Greece.","pos":""}],"HOLD":[{"def":"The whole interior portion of a vessel below the lower deck, in which the cargo is stowed.","pos":""}],"HOLDBACK":[{"def":"Check; hindrance; restraint; obstacle.","pos":""},{"def":"The projection or loop on the thill of a vehicle.","pos":""}],"HOLDER":[{"def":"One who is employed in the hold of a vessel.","pos":""}],"HOLDER-FORTH":[{"def":"One who speaks in public; an haranguer; a preacher.","pos":""}],"HOLDFAST":[{"def":"A conical or branching body, by which a seaweed is attached to its support, and differing from a root in that it is not specially absorbent of moisture.","pos":""}],"HOLDING":[{"def":"The act or state of sustaining, grasping, or retaining.","pos":""},{"def":"A tenure; a farm or other estate held of another.","pos":""}],"HOLE":[{"def":"A hollow place or cavity; an excavation; a pit; an opening in or through a solid body, a fabric, etc.","pos":""},{"def":"An excavation in the ground, made by an animal to live in, or a natural cavity inhabited by an animal; hence, a low, narrow, or dark lodging or place; a mean habitation.","pos":""}],"HOLE IN THE AIR":[{"def":"= Air hole, above.","pos":""}],"HOLETHNIC":[{"def":"Of or pertaining to a holethnos or parent race.","pos":""}],"HOLETHNOS":[{"def":"A parent stock or race of people, not yet divided into separate branches or tribes.","pos":""}],"HOLIDAY":[{"def":"A day fixed by law for suspension of business; a legal holiday.","pos":""}],"HOLILY":[{"def":"Piously; with sanctity; in a holy manner.","pos":""},{"def":"Sacredly; inviolably.","pos":""}],"HOLINESS":[{"def":"The state or quality of being holy; perfect moral integrity or purity; freedom from sin; sanctity; innocence.","pos":""},{"def":"The state of being hallowed, or consecrated to God or to his worship; sacredness.","pos":""}],"HOLING":[{"def":"Undercutting in a bed of coal, in order to bring down the upper mass.","pos":""}],"HOLLAND":[{"def":"A kind of linen first manufactured in Holland; a linen fabric used for window shades, children's garments, etc.","pos":""},{"def":"A sauce consisting essentially of a seasoned emulsion of butter and yolk of eggs with a little lemon juice or vinegar.","pos":""}],"HOLLANDER":[{"def":"A native or one of the people of Holland; a Dutchman.","pos":""},{"def":"A very hard, semi-glazed, green or dark brown brick, which will not absorb water; -- called also, Dutch clinker.","pos":""}],"HOLLANDISH":[{"def":"Relating to Holland; Dutch.","pos":""}],"HOLLANDS":[{"def":"Gin made in Holland.","pos":""}],"HOLLO":[{"def":"Ho there; stop; attend; hence, a loud cry or a call to attract attention; a halloo.","pos":""}],"HOLLOW":[{"def":"Having an empty space or cavity, natural or artificial, within a solid substance; not solid; excavated in the interior; as, a hollow tree; a hollow sphere.","pos":""},{"def":"Depressed; concave; gaunt; sunken.","pos":""}],"HOLLOW-HEARTED":[{"def":"Insincere; deceitful; not sound and true; having a cavity or decayed spot within.","pos":""}],"HOLLOW-HORNED":[{"def":"Having permanent horns with a bony core, as cattle.","pos":""}],"HOLLOWLY":[{"def":"Insincerely; deceitfully.","pos":""}],"HOLLOWNESS":[{"def":"State of being hollow.","pos":""},{"def":"Insincerity; unsoundness; treachery.","pos":""}],"HOLLUSCHICKIE":[{"def":"A young male fur seal, esp.","pos":""}],"HOLLY":[{"def":"A tree or shrub of the genus Ilex.","pos":""}],"HOLLYHOCK":[{"def":"A species of Althæa (A.","pos":""}],"HOLM":[{"def":"A common evergreen oak, of Europe (Quercus Ilex); -- called also ilex, and holly.","pos":""}],"HOLMIA":[{"def":"An oxide of holmium.","pos":""}],"HOLMIUM":[{"def":"A rare element said to be contained in gadolinite.","pos":""}],"HOLMOS":[{"def":"A name given to a vase having a rounded body; esp.","pos":""}],"HOLO-":[{"def":"A combining form fr.","pos":""}],"HOLOBLAST":[{"def":"an ovum composed entirely of germinal matter.","pos":""}],"HOLOBLASTIC":[{"def":"Undergoing complete segmentation; composed entirely of germinal matter, the whole of the yolk undergoing fission; -- opposed to meroblastic.","pos":""}],"HOLOCAUST":[{"def":"A burnt sacrifice; an offering, the whole of which was consumed by fire, among the Jews and some pagan nations.","pos":""},{"def":"Sacrifice or loss of many lives, as by the burning of a theater or a ship.","pos":""}],"HOLOCEPHALI":[{"def":"An order of elasmobranch fishes, including, among living species, only the chimæras; -- called also Holocephala.","pos":""}],"HOLOCRYPTIC":[{"def":"Wholly or completely concealing; incapable of being deciphered.","pos":""}],"HOLOCRYSTALLINE":[{"def":"Completely crystalline; -- said of a rock like granite, all the constituents of which are crystalline.","pos":""}],"HOLOGRAPH":[{"def":"A document, as a letter, deed, or will, wholly in the handwriting of the person from whom it proceeds and whose act it purports to be.","pos":""}],"HOLOGRAPHIC":[{"def":"Of the nature of a holograph; pertaining to holographs.","pos":""}],"HOLOHEDRAL":[{"def":"Having all the planes required by complete symmetry, -- in opposition to hemihedral.","pos":""}],"HOLOHEMIHEDRAL":[{"def":"Presenting hemihedral forms, in which all the sectants have halt the whole number of planes.","pos":""}],"HOLOMETABOLA":[{"def":"Those insects which have a complete metamorphosis; metabola.","pos":""}],"HOLOMETABOLIC":[{"def":"Having a complete metamorphosis;-said of certain insects, as the butterflies and bees.","pos":""}],"HOLOMETER":[{"def":"An instrument for making of angular measurements.","pos":""}],"HOLOPHANEROUS":[{"def":"Same as Holometabolic.","pos":""}],"HOLOPHOTAL":[{"def":"Causing no loss of light; -- applied to reflectors which throw back the rays of light without perceptible loss.","pos":""}],"HOLOPHOTE":[{"def":"A lamp with lenses or reflectors to collect the rays of light and throw them in a given direction; -- used in lighthouses.","pos":""}],"HOLOPHRASTIC":[{"def":"Expressing a phrase or sentence in a single word, -- as is the case in the aboriginal languages of America.","pos":""}],"HOLOPHYTIC":[{"def":"Wholly or distinctively vegetable.","pos":""}],"HOLORHINAL":[{"def":"Having the nasal bones contiguous.","pos":""}],"HOLOSIDERITE":[{"def":"Meteoric iron; a meteorite consisting of metallic iron without stony matter.","pos":""}],"HOLOSTEAN":[{"def":"Pertaining to the Holostei.","pos":""}],"HOLOSTEI":[{"def":"An extensive division of ganoids, including the gar pike, bowfin, etc.","pos":""}],"HOLOSTERIC":[{"def":"Wholly solid; -- said of a barometer constructed of solid materials to show the variations of atmospheric pressure without the use of liquids, as the aneroid.","pos":""}],"HOLOSTOMATA":[{"def":"An artificial division of gastropods, including those that have an entire aperture.","pos":""}],"HOLOSTOMATE":[{"def":"Same as Holostomatous.","pos":""}],"HOLOSTOMATOUS":[{"def":"Having an entire aperture; -- said of many univalve shells.","pos":""}],"HOLOSTOME":[{"def":"One of the Holostomata.","pos":""}],"HOLOSTRACA":[{"def":"A division of phyllopod Crustacea, including those that are entirely covered by a bivalve shell.","pos":""}],"HOLOTHURIAN":[{"def":"One of the Holothurioidea.","pos":""}],"HOLOTHURIOIDEA":[{"def":"One of the classes of echinoderms.","pos":""}],"HOLOTRICHA":[{"def":"A group of ciliated Infusoria, having cilia all over the body.","pos":""}],"HOLOUR":[{"def":"HOLP; HOLPEN Holp, Hol\"pen, Defn: imp.","pos":""}],"HOLSTEIN":[{"def":"One of a breed of cattle, originally from Schleswig-Holstein, valued for the large amount of milk produced by the cows.","pos":""}],"HOLSTER":[{"def":"A leather case for a pistol, carried by a horseman at the bow of his saddle.","pos":""}],"HOLSTERED":[{"def":"Bearing holsters.","pos":""}],"HOLT":[{"def":"Holt, Defn: 3d pers.","pos":""}],"HOLY":[{"def":"Set apart to the service or worship of God; hallowed; sacred; reserved from profane or common use; holy vessels; a holy priesthood.","pos":""},{"def":"Spiritually whole or sound; of unimpaired innocence and virtue; free from sinful affections; pure in heart; godly; pious; irreproachable; guiltless; acceptable to God.","pos":""}],"HOLY CROSS":[{"def":"The cross as the symbol of Christ's crucifixion.","pos":""}],"HOLYDAY":[{"def":"A religious festival.","pos":""},{"def":"A secular festival; a holiday.","pos":""}],"HOLYSTONE":[{"def":"A stone used by seamen for scrubbing the decks of ships.","pos":""}]}