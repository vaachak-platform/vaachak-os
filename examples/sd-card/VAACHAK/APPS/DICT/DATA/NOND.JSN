{"NONDA":[{"def":"The edible plumlike fruit of the Australian tree, Parinarium Nonda.","pos":""}],"NONDECANE":[{"def":"A hydrocarbon of the paraffin series, a white waxy substance, C19H40; -- so called from the number of carbon atoms in the molecule.","pos":""}],"NONDECIDUATE":[{"def":"Characterized by the absence of a decidua; indeciduate.","pos":""}],"NONDELIVERY":[{"def":"A neglect or failure of delivery; omission of delivery.","pos":""}],"NONDEPOSITION":[{"def":"A failure to deposit or throw down.","pos":""}],"NONDESCRIPT":[{"def":"Not hitherto described; novel; hence, odd; abnormal; unclassifiable.","pos":""}],"NONDEVELOPMENT":[{"def":"Failure or lack of development.","pos":""}],"NONDISCOVERY":[{"def":"Want or failure of discovery.","pos":""}],"NONDO":[{"def":"A coarse umbelliferous plant (Ligusticum actæifolium) with a large aromatic root.","pos":""}]}