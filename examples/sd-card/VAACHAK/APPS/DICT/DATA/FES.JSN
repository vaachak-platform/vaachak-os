{"FESCENNINE":[{"def":"Pertaining to, or resembling, the Fescennines.","pos":""},{"def":"A style of low, scurrilous, obscene poetry originating in fescennia.","pos":""}],"FESCUE":[{"def":"A grass of the genus Festuca.","pos":""}],"FESELS":[{"def":"A band drawn horizontally across the center of an escutcheon, and containing in breadth the third part of it; one of the nine honorable ordinaries.","pos":""}],"FESSWISE":[{"def":"In the manner of fess.","pos":""}],"FEST":[{"def":"FEST; FESTE Fest, Fes\"te, n.","pos":""}],"FESTAL":[{"def":"Of or pertaining to a holiday or a feast; joyous; festive.","pos":""}],"FESTALLY":[{"def":"Joyously; festively; mirthfully.","pos":""}],"FESTER":[{"def":"To generate pus; to become imflamed and suppurate; as, a sore or a wound festers.","pos":""},{"def":"To be inflamed; to grow virulent, or malignant; to grow in intensity; to rankle.","pos":""}],"FESTEYE":[{"def":"To feast; to entertain.","pos":""}],"FESTI-VAL":[{"def":"A time of feasting or celebration; an anniversary day of joy, civil or religious.","pos":""}],"FESTIVAL":[{"def":"Pertaining to a fest; festive; festal; appropriate to a festival; joyous; mirthful.","pos":""}],"FESTIVE":[{"def":"Pertaining to, or becoming, a feast; festal; joyous; gay; mirthful; sportive.","pos":""}],"FESTIVITY":[{"def":"The condition of being festive; social joy or exhilaration of spirits at an entertaintment; joyfulness; gayety.","pos":""},{"def":"A festival; a festive celebration.","pos":""}],"FESTIVOUS":[{"def":"Pertaining to a feast; festive.","pos":""}],"FESTLICH":[{"def":"Festive; fond of festive occasions.","pos":""}],"FESTOON":[{"def":"A carved ornament consisting of flowers, and leaves, intermixed or twisted together, wound with a ribbon, and hanging or depending in a natural curve.","pos":""}],"FESTOONY":[{"def":"Pertaining to, consisting of, or resembling, festoons.","pos":""}],"FESTUCINE":[{"def":"Of a straw color; greenish yellow.","pos":""}],"FESTUCOUS":[{"def":"Formed or consisting of straw.","pos":""}],"FESTUE":[{"def":"A straw; a fescue.","pos":""}]}