{"PLIABILITY":[{"def":"The quality or state of being pliable; flexibility; as, pliability of disposition.","pos":""}],"PLIABLE":[{"def":"Capable of being plied, turned, or bent; easy to be bent; flexible; pliant; supple; limber; yielding; as, willow is a pliable plant.","pos":""},{"def":"Flexible in disposition; readily yielding to influence, arguments, persuasion, or discipline; easy to be persuaded; -- sometimes in a bad sense; as, a pliable youth.","pos":""}],"PLIANCY":[{"def":"The quality or state of being pliant in sense; as, the pliancy of a rod.","pos":""}],"PLIANT":[{"def":"Capable of plying or bending; readily yielding to force or pressure without breaking; flexible; pliable; lithe; limber; plastic; as, a pliant thread; pliant wax.","pos":""},{"def":"Favorable to pliancy.","pos":""}],"PLICA":[{"def":"A disease of the hair (Plica polonica), in which it becomes twisted and matted together.","pos":""},{"def":"A diseased state in plants in which there is an excessive development of small entangled twigs, instead of ordinary branches.","pos":""}],"PLICATION":[{"def":"A folding or fold; a plait.","pos":""}],"PLICATURE":[{"def":"A fold; a doubling; a plication.","pos":""}],"PLICIDENTINE":[{"def":"A form of dentine which shows sinuous lines of structure in a transverse section of the tooth.","pos":""}],"PLIERS":[{"def":"A kind of small pinchers with long jaws, -- used for bending or cutting metal rods or wire, for handling small objects such as the parts of a watch, etc.","pos":""}],"PLIFORM":[{"def":"In the form of a ply, fold, or doubling.","pos":""}],"PLIGHT":[{"def":"To weave; to braid; to fold; to plait.","pos":""}],"PLIGHTER":[{"def":"One who, or that which, plights.","pos":""}],"PLIM":[{"def":"To swell, as grain or wood with water.","pos":""}],"PLIMSOLL'S MARK":[{"def":"A mark conspicuously painted on the port side of all British sea-going merchant vessels, to indicate the limit of submergence allowed by law; -- so called from Samuel Plimsoll, by whose efforts the act of Parliament to prevent overloading was procured.","pos":""}],"PLIOCENE":[{"def":"Of, pertaining to, or characterizing, the most recent division of the Tertiary age.","pos":""}],"PLIOHIPPUS":[{"def":"An extinct genus of horses from the Pliocene deposits.","pos":""}],"PLIOSAURUS":[{"def":"An extinct genus of marine reptiles allied to Plesiosaurus, but having a much shorter neck.","pos":""}],"PLITT":[{"def":"An instrument of punishment or torture resembling the knout, used in Russia.","pos":""}]}