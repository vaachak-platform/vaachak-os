{"ERA":[{"def":"A fixed point of time, usually an epoch, from which a series of years is reckoned.","pos":""},{"def":"A period of time reckoned from some particular date or epoch; a succession of years dating from some important event; as, the era of Alexander; the era of Christ, or the Christian era (see under Christian).","pos":""}],"ERADIATE":[{"def":"To shoot forth, as rays of light; to beam; to radiate.","pos":""}],"ERADIATION":[{"def":"Emission of radiance.","pos":""}],"ERADICABLE":[{"def":"Capable of being eradicated.","pos":""}],"ERADICATE":[{"def":"To pluck up by the roots; to root up; as, an oak tree eradicated.","pos":""},{"def":"To root out; to destroy utterly; to extirpate; as, to eradicate diseases, or errors.","pos":""}],"ERADICATION":[{"def":"The act of plucking up by the roots; a rooting out; extirpation; utter destruction.","pos":""},{"def":"The state of being plucked up by the roots.","pos":""}],"ERADICATIVE":[{"def":"Tending or serving to eradicate; curing or destroying thoroughly, as a disease or any evil.","pos":""}],"ERASABLE":[{"def":"Capable of being erased.","pos":""}],"ERASE":[{"def":"To rub or scrape out, as letters or characters written, engraved, or painted; to efface; to expunge; to cross out; as, to erase a word or a name.","pos":""}],"ERASED":[{"def":"Represented with jagged and uneven edges, as is torn off; -- used esp.","pos":""}],"ERASEMENT":[{"def":"The act of erasing; a rubbing out; expunction; obliteration.","pos":""}],"ERASER":[{"def":"One who, or that which, erases; esp.","pos":""}],"ERASION":[{"def":"The act of erasing; a rubbing out; obliteration.","pos":""}],"ERASTIAN":[{"def":"One of the followers of Thomas Erastus, a German physician and theologian of the 16th century.","pos":""}],"ERASTIANISM":[{"def":"The principles of the Erastains.","pos":""}],"ERASURE":[{"def":"The act of erasing; a scratching out; obliteration.","pos":""}],"ERATIVE":[{"def":"Pertaining to the Muse Erato who presided over amatory poetry.","pos":""}],"ERATO":[{"def":"The Muse who presided over lyric and amatory poetry.","pos":""}]}