{"ABDAL":[{"def":"A religious devotee or dervish in Persia.","pos":""}],"ABDERIAN":[{"def":"Given to laughter; inclined to foolish or incessant merriment.","pos":""}],"ABDERITE":[{"def":"An inhabitant of Abdera, in Thrace.","pos":""}],"ABDEST":[{"def":"Purification by washing the hands before prayer; -- a Mohammedan rite.","pos":""}],"ABDICABLE":[{"def":"Capable of being abdicated.","pos":""}],"ABDICANT":[{"def":"Abdicating; renouncing; -- followed by of.","pos":""}],"ABDICATE":[{"def":"To disclaim and expel from the family, as a father his child; to disown; to disinherit.","pos":"verb"}],"ABDICATION":[{"def":"The act of abdicating; the renunciation of a high office, dignity, or trust, by its holder; commonly the voluntary renunciation of sovereign power; as, abdication of the throne, government, power, authority.","pos":""}],"ABDICATIVE":[{"def":"Causing, or implying, abdication.","pos":""}],"ABDICATOR":[{"def":"One who abdicates.","pos":""}],"ABDITIVE":[{"def":"Having the quality of hiding.","pos":""}],"ABDITORY":[{"def":"A place for hiding or preserving articles of value.","pos":""}],"ABDOMEN":[{"def":"The belly, or that part of the body between the thorax and the pelvis.","pos":""},{"def":"The posterior section of the body, behind the thorax, in insects, crustaceans, and other Arthropoda.","pos":""}],"ABDOMINAL":[{"def":"Having abdominal fins; belonging to the Abdominales; as, abdominal fishes.","pos":""}],"ABDOMINALES":[{"def":"A group including the greater part of fresh-water fishes, and many marine ones, having the ventral fins under the abdomen behind the pectorals.","pos":""}],"ABDOMINALIA":[{"def":"A group of cirripeds having abdominal appendages.","pos":""}],"ABDOMINOSCOPY":[{"def":"Examination of the abdomen to detect abdominal disease.","pos":""}],"ABDOMINOTHORACIC":[{"def":"Relating to the abdomen and the thorax, or chest.","pos":""}],"ABDOMINOUS":[{"def":"Having a protuberant belly; pot-bellied.","pos":""}],"ABDUCE":[{"def":"To draw or conduct away; to withdraw; to draw to a different part.","pos":"verb"}],"ABDUCT":[{"def":"To take away surreptitiously by force; to carry away (a human being) wrongfully and usually by violence; to kidnap.","pos":"verb"},{"def":"To draw away, as a limb or other part, from its ordinary position.","pos":"verb"}],"ABDUCTION":[{"def":"The movement which separates a limb or other part from the axis, or middle line, of the body.","pos":""},{"def":"The wrongful, and usually the forcible, carrying off of a human being; as, the abduction of a child, the abduction of an heiress.","pos":""}],"ABDUCTOR":[{"def":"A muscle which serves to draw a part out, or form the median line of the body; as, the abductor oculi, which draws the eye outward.","pos":""}]}