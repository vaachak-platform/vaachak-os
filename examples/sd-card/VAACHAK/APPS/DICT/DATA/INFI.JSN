{"INFIBULATION":[{"def":"The act of clasping, or fastening, as with a buckle or padlock.","pos":""},{"def":"The act of attaching a ring, clasp, or frame, to the genital organs in such a manner as to prevent copulation.","pos":""}],"INFIDEL":[{"def":"Not holding the faith; -- applied esp.","pos":""}],"INFIDELITY":[{"def":"Want of faith or belief in some religious system; especially, a want of faith in, or disbelief of, the inspiration of the Scriptures, of the divine origin of Christianity.","pos":""},{"def":"Unfaithfulness to the marriage vow or contract; violation of the marriage covenant by adultery.","pos":""}],"INFIELD":[{"def":"To inclose, as a field.","pos":""}],"INFILE":[{"def":"To arrange in a file or rank; to place in order.","pos":""}],"INFILM":[{"def":"To cover with a film; to coat thinly; as, to infilm one metal with another in the process of gilding; to infilm the glass of a mirror.","pos":""}],"INFILTER":[{"def":"To filter or sift in.","pos":""}],"INFILTRATE":[{"def":"To enter by penetrating the pores or interstices of a substance; to filter into or through something.","pos":""}],"INFILTRATION":[{"def":"The act or process of infiltrating, as if water into a porous substance, or of a fluid into the cells of an organ or part of the body.","pos":""},{"def":"The substance which has entered the pores or cavities of a body.","pos":""}],"INFILTRATIVE":[{"def":"Of or pertaining to infiltration.","pos":""}],"INFINITE":[{"def":"Greater than any assignable quantity of the same kind; -- said of certain quantities.","pos":""},{"def":"Capable of endless repetition; -- said of certain forms of the canon, called also perpetual fugues, so constructed that their ends lead to their beginnings, and the performance may be incessantly repeated.","pos":""}],"INFINITELY":[{"def":"Without bounds or limits; beyond or below assignable limits; as, an infinitely large or infinitely small quantity.","pos":""},{"def":"Very; exceedingly; vastly; highly; extremely.","pos":""}],"INFINITENESS":[{"def":"The state or quality of being infinite; infinity; greatness; immensity.","pos":""}],"INFINITESIMAL":[{"def":"Infinitely or indefinitely small; less than any assignable quantity or value; very small.","pos":""}],"INFINITESIMALLY":[{"def":"By infinitesimals; in infinitely small quantities; in an infinitesimal degree.","pos":""}],"INFINITIVAL":[{"def":"Pertaining to the infinite mood.","pos":""}],"INFINITIVE":[{"def":"Unlimited; not bounded or restricted; undefined.","pos":""}],"INFINITO":[{"def":"Infinite; perpetual, as a canon whose end leads back to the beginning.","pos":""}],"INFINITUDE":[{"def":"The quality or state of being infinite, or without limits; infiniteness.","pos":""},{"def":"Infinite extent; unlimited space; immensity; infinity.","pos":""}],"INFINITUPLE":[{"def":"Multipied an infinite number of times.","pos":""}],"INFINITY":[{"def":"A quantity greater than any assignable quantity of the same kind.","pos":""},{"def":"That part of a line, or of a plane, or of space, which is infinitely distant.","pos":""}],"INFIRM":[{"def":"Not firm or sound; weak; feeble; as, an infirm body; an infirm constitution.","pos":""},{"def":"Weak of mind or will; irresolute; vacillating.","pos":""}],"INFIRMARIAN":[{"def":"A person dwelling in, or having charge of, an infirmary, esp.","pos":""}],"INFIRMARY":[{"def":"A hospital, or place where the infirm or sick are lodged and nursed gratuitously, or where out-patients are treated.","pos":""}],"INFIRMATIVE":[{"def":"Weakening; annulling, or tending to make void.","pos":""}],"INFIRMITY":[{"def":"The state of being infirm; feebleness; an imperfection or weakness; esp.","pos":""},{"def":"A personal frailty or failing; foible; eccentricity; a weakness or defect.","pos":""}],"INFIRMLY":[{"def":"In an infirm manner.","pos":""}],"INFIRMNESS":[{"def":"Infirmity; feebleness.","pos":""}],"INFIX":[{"def":"To set; to fasten or fix by piercing or thrusting in; as, to infix a sting, spear, or dart.","pos":""},{"def":"To implant or fix; to instill; to inculcate, as principles, thoughts, or instructions; as, to infix good principles in the mind, or ideas in the memory.","pos":""}]}