{"GELABLE":[{"def":"Capable of being congealed; capable of being converted into jelly.","pos":""}],"GELADA":[{"def":"A baboon (Gelada Ruppelli) of Abyssinia, remarkable for the length of the hair on the neck and shoulders of the adult male.","pos":""}],"GELASTIC":[{"def":"Pertaining to laughter; used in laughing.","pos":""}],"GELATIFICATION":[{"def":"The formation of gelatin.","pos":""}],"GELATIGENOUS":[{"def":"Producing, or yielding, gelatin; gelatiniferous; as, the gelatigeneous tissues.","pos":""},{"def":", Gel\"a*tine (, n.","pos":""}],"GELATINATE":[{"def":"To convert into gelatin, or into a substance resembling jelly.","pos":""}],"GELATINATION":[{"def":"The act of process of converting into gelatin, or a substance like jelly.","pos":""}],"GELATINE":[{"def":"Same as Gelatin.","pos":""}],"GELATINIFEROUS":[{"def":"Yielding gelatin on boiling with water; capable of gelatination.","pos":""}],"GELATINIFORM":[{"def":"Having the form of gelatin.","pos":""}],"GELATINIZATION":[{"def":"Same as Gelatination.","pos":""}],"GELATINIZE":[{"def":"To coat, or otherwise treat, with gelatin.","pos":""}],"GELATINOUS":[{"def":"Of the nature and consistence of gelatin or the jelly; resembling jelly; viscous.","pos":""}],"GELATION":[{"def":"The process of becoming solid by cooling; a cooling and solidifying.","pos":""}],"GELD":[{"def":"Money; tribute; compensation; ransom.","pos":""}],"GELDABLE":[{"def":"Capable of being gelded.","pos":""}],"GELDER":[{"def":"One who gelds or castrates.","pos":""}],"GELDER-ROSE":[{"def":"Same as Guelder-rose.","pos":""}],"GELDING":[{"def":"A castrated animal; -- usually applied to a horse, but formerly used also of the human male.","pos":""}],"GELID":[{"def":"Cold; very cold; frozen.","pos":""}],"GELIDITY":[{"def":"The state of being gelid.","pos":""}],"GELIDLY":[{"def":"In a gelid manner; coldly.","pos":""}],"GELIDNESS":[{"def":"The state of being gelid; gelidity.","pos":""}],"GELOSCOPY":[{"def":"Divination by means of laughter.","pos":""}],"GELOSE":[{"def":"An amorphous, gummy carbohydrate, found in Gelidium, agar-agar, and other seaweeds.","pos":""}],"GELSEMINE":[{"def":"An alkaloid obtained from the yellow jasmine (Gelsemium sempervirens), as a bitter white semicrystalline substance; -- called also gelsemia.","pos":""}],"GELSEMINIC":[{"def":"Pertaining to, or derived from, the yellow jasmine (Gelsemium sempervirens); as, gelseminic acid, a white crystalline substance resembling esculin.","pos":""}],"GELSEMIUM":[{"def":"A genus of climbing plants.","pos":""},{"def":"The root of the yellow jasmine, used in malarial fevers, etc.","pos":""}],"GELT":[{"def":"All these the king granted unto them .","pos":""}]}