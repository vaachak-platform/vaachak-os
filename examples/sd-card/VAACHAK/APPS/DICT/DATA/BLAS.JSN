{"BLASE":[{"def":"Having the sensibilities deadened by excess or frequency of enjoyment; sated or surfeited with pleasure; used up.","pos":""}],"BLASPHEME":[{"def":"To speak of, or address, with impious irreverence; to revile impiously (anything sacred); as, to blaspheme the Holy Spirit.","pos":""},{"def":"Figuratively, of persons and things not religiously sacred, but held in high honor: To calumniate; to revile; to abuse.","pos":""}],"BLASPHEMER":[{"def":"One who blasphemes.","pos":""}],"BLASPHEMOUS":[{"def":"Speaking or writing blasphemy; uttering or exhibiting anything impiously irreverent; profane; as, a blasphemous person; containing blasphemy; as, a blasphemous book; a blasphemous caricature.","pos":""}],"BLASPHEMOUSLY":[{"def":"In a blasphemous manner.","pos":""}],"BLASPHEMY":[{"def":"A suffix or terminal formative, used principally in biological terms, and signifying growth, formation; as, bioblast, epiblast, mesoblast, etc.","pos":""}],"BLAST":[{"def":"A violent gust of wind.","pos":""},{"def":"A forcible stream of air from an orifice, as from a bellows, the mouth, etc.","pos":""}],"BLAST LAMP":[{"def":"A lamp provided with some arrangement for intensifying combustion by means of a blast.","pos":""}],"BLAST PIPE":[{"def":"The exhaust pipe of a steam engine, or any pipe delivering steam or air, when so constructed as to cause a blast.","pos":""}],"BLASTED":[{"def":"Blighted; withered.","pos":""},{"def":"Confounded; accursed; detestable.","pos":""}],"BLASTEMA":[{"def":"The structureless, protoplasmic tissue of the embryo; the primitive basis of an organ yet unformed, from which it grows.","pos":""}],"BLASTEMAL":[{"def":"Relating to the blastema; rudimentary.","pos":""}],"BLASTEMATIC":[{"def":"Connected with, or proceeding from, the blastema; blastemal.","pos":""}],"BLASTER":[{"def":"One who, or that which, blasts or destroys.","pos":""}],"BLASTIDE":[{"def":"A small, clear space in the segments of the ovum, the precursor of the nucleus.","pos":""}],"BLASTING":[{"def":"A blast; destruction by a blast, or by some pernicious cause.","pos":""},{"def":"The act or process of one who, or that which, blasts; the business of one who blasts.","pos":""}],"BLASTMENT":[{"def":"A sudden stroke or injury produced by some destructive cause.","pos":""}],"BLASTOCARPOUS":[{"def":"Germinating inside the pericarp, as the mangrove.","pos":""}],"BLASTOCOELE":[{"def":"The cavity of the blastosphere, or segmentation cavity.","pos":""}],"BLASTOCYST":[{"def":"The germinal vesicle.","pos":""}],"BLASTODERM":[{"def":"The germinal membrane in an ovum, from which the embryo is developed.","pos":""},{"def":"Of or pertaining to the blastoderm.","pos":""}],"BLASTOGENESIS":[{"def":"Multiplication or increase by gemmation or budding.","pos":""}],"BLASTOID":[{"def":"One of the Blastoidea.","pos":""}],"BLASTOIDEA":[{"def":"One of the divisions of Crinoidea found fossil in paleozoic rocks; pentremites.","pos":""}],"BLASTOMERE":[{"def":"One of the segments first formed by the division of the ovum.","pos":""},{"def":"Relating to the blastophore.","pos":""}],"BLASTOPHORE":[{"def":"That portion of the spermatospore which is not converted into spermatoblasts, but carries them.","pos":""}],"BLASTOPORE":[{"def":"The pore or opening leading into the cavity of invagination, or archenteron.","pos":""}],"BLASTOSPHERE":[{"def":"The hollow globe or sphere formed by the arrangement of the blastomeres on the periphery of an impregnated ovum.","pos":""}],"BLASTOSTYLE":[{"def":"In certain hydroids, an imperfect zooid, whose special function is to produce medusoid buds.","pos":""}],"BLASTULA":[{"def":"That stage in the development of the ovum in which the outer cells of the morula become more defined and form the blastoderm.","pos":""}],"BLASTULE":[{"def":"Same as Blastula.","pos":""}],"BLASTY":[{"def":"Affected by blasts; gusty.","pos":""},{"def":"Causing blast or injury.","pos":""}]}