{"BIPALMATE":[{"def":"Palmately branched, with the branches again palmated.","pos":""}],"BIPARIETAL":[{"def":"Of or pertaining to the diameter of the cranium, from one parietal fossa to the other.","pos":""}],"BIPAROUS":[{"def":"Bringing forth two at a birth.","pos":""}],"BIPARTIBLE":[{"def":"Capable of being divided into two parts.","pos":""}],"BIPARTIENT":[{"def":"Dividing into two parts.","pos":""},{"def":"A number that divides another into two equal parts without a remainder.","pos":""}],"BIPARTILE":[{"def":"Divisible into two parts.","pos":""}],"BIPARTITE":[{"def":"Being in two parts; having two correspondent parts, as a legal contract or writing, one for each party; shared by two; as, a bipartite treaty.","pos":""},{"def":"Divided into two parts almost to the base, as a leaf; consisting of two parts or subdivisions.","pos":""}],"BIPARTITION":[{"def":"The act of dividing into two parts, or of making two correspondent parts, or the state of being so divided.","pos":""},{"def":"Having two margins toothed like a comb.","pos":""}],"BIPED":[{"def":"A two-footed animal, as man.","pos":""}],"BIPEDAL":[{"def":"Having two feet; biped.","pos":""},{"def":"Pertaining to a biped.","pos":""}],"BIPELTATE":[{"def":"Having a shell or covering like a double shield.","pos":""},{"def":"Having two wings.","pos":""}],"BIPENNIS":[{"def":"An ax with an edge or blade on each side of the handle.","pos":""}],"BIPETALOUS":[{"def":"Having two petals.","pos":""}],"BIPINNARIA":[{"def":"The larva of certain starfishes as developed in the free- swimming stage.","pos":""}],"BIPINNATIFID":[{"def":"Doubly pinnatifid.","pos":""}],"BIPLANE":[{"def":"An aëroplane with two main supporting surfaces one above the other.","pos":""}],"BIPLICATE":[{"def":"Twice folded together.","pos":""}],"BIPLICITY":[{"def":"The state of being twice folded; reduplication.","pos":""}],"BIPOLAR":[{"def":"Doubly polar; having two poles; as, a bipolar cell or corpuscle.","pos":""}],"BIPOLARITY":[{"def":"Bipolar quality.","pos":""},{"def":"Relating to books printed at Deuxponts, or Bipontium (Zweibrücken), in Bavaria.","pos":""}],"BIPRISM":[{"def":"A prism whose refracting angle is very nearly 180 degrees.","pos":""}],"BIPUNCTATE":[{"def":"Having two punctures, or spots.","pos":""}],"BIPUNCTUAL":[{"def":"Having two points.","pos":""}],"BIPUPILLATE":[{"def":"Having an eyelike spot on the wing, with two dots within it of a different color, as in some butterflies.","pos":""}],"BIPYRAMIDAL":[{"def":"Consisting of two pyramids placed base to base; having a pyramid at each of the extremities of a prism, as in quartz crystals.","pos":""}]}