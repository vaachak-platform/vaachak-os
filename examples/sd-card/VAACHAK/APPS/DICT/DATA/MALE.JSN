{"MALE":[{"def":"Evil; wicked; bad.","pos":""}],"MALE-SPIRITED":[{"def":"Having the spirit of a male; vigorous; courageous.","pos":""}],"MALEADMINISTRATION":[{"def":"Maladministration.","pos":""}],"MALEATE":[{"def":"A salt of maleic acid.","pos":""}],"MALEBRANCHISM":[{"def":"The philosophical system of Malebranche, an eminent French metaphysician.","pos":""}],"MALECONFORMATION":[{"def":"Malconformation.","pos":""}],"MALEDICENT":[{"def":"Speaking reproachfully; slanderous.","pos":""}],"MALEDICT":[{"def":"Accursed; abominable.","pos":""}],"MALEDICTION":[{"def":"A proclaiming of evil against some one; a cursing; imprecation; a curse or execration; -- opposed to benediction.","pos":""}],"MALEFACTION":[{"def":"A crime; an offense; an evil deed.","pos":""}],"MALEFACTOR":[{"def":"An evil doer; one who commits a crime; one subject to public prosecution and punishment; a criminal.","pos":""},{"def":"One who does wrong by injuring another, although not a criminal.","pos":""}],"MALEFACTRESS":[{"def":"A female malefactor.","pos":""}],"MALEFEASANCE":[{"def":"See Malfeasance.","pos":""}],"MALEFIC":[{"def":"Doing mischief; causing harm or evil; nefarious; hurtful.","pos":""}],"MALEFICE":[{"def":"An evil deed; artifice; enchantment.","pos":""}],"MALEFICENCE":[{"def":"Evil doing, esp.","pos":""}],"MALEFICENT":[{"def":"Doing evil to others; harmful; mischievous.","pos":""}],"MALEFICIATE":[{"def":"To bewitch; to harm.","pos":""}],"MALEFICIATION":[{"def":"Mal`e*fi`ci*a\"tion, n.","pos":""}],"MALEFICIENCE":[{"def":"The doing of evil, harm, or mischief.","pos":""}],"MALEFICIENT":[{"def":"Doing evil, harm, or mischief.","pos":""}],"MALEFORMATION":[{"def":"See Malformation.","pos":""}],"MALEIC":[{"def":"Pertaining to, or designating, an acid of the ethylene series, metameric with fumaric acid and obtained by heating malic acid.","pos":""}],"MALENGINE":[{"def":"Evil machination; guile; deceit.","pos":""}],"MALEO":[{"def":"A bird of Celebes (megacephalon maleo), allied to the brush turkey.","pos":""}],"MALEPRACTICE":[{"def":"See Malpractice.","pos":""}],"MALET":[{"def":"A little bag or budget.","pos":""}],"MALEVOLENCE":[{"def":"The quality or state of being malevolent; evil disposition toward another; inclination to injure others; ill will.","pos":""}],"MALEVOLENT":[{"def":"Wishing evil; disposed to injure others; rejoicing in another's misfortune.","pos":""}],"MALEVOLENTLY":[{"def":"In a malevolent manner.","pos":""}],"MALEYL":[{"def":"A hypothetical radical derived from maleic acid.","pos":""}]}