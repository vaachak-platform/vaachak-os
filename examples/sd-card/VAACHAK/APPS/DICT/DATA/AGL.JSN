{"AGLEAM":[{"def":"Gleaming; as, faces agleam.","pos":""},{"def":"A round white staylace.","pos":""}],"AGLIMMER":[{"def":"In a glimmering state.","pos":""}],"AGLITTER":[{"def":"Clittering; in a glitter.","pos":""}],"AGLOSSAL":[{"def":"Without tongue; tongueless.","pos":""}],"AGLOW":[{"def":"In a glow; glowing; as, cheeks aglow; the landscape all aglow.","pos":""}],"AGLUTITION":[{"def":"Inability to swallow.","pos":""}]}