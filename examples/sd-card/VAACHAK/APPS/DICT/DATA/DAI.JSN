{"DAILINESS":[{"def":"Daily occurence.","pos":""}],"DAILY":[{"def":"Happening, or belonging to, each successive day; diurnal; as, daily labor; a daily bulletin.","pos":""}],"DAIMIO":[{"def":"The title of the feudal nobles of Japan.","pos":""}],"DAINT":[{"def":"Something of exquisite taste; a dainty.","pos":""}],"DAINTIFY":[{"def":"To render dainty, delicate, or fastidious.","pos":""}],"DAINTILY":[{"def":"In a dainty manner; nicely; scrupulously; fastidiously; deliciously; prettily.","pos":""}],"DAINTINESS":[{"def":"The quality of being dainty; nicety; niceness; elegance; delicacy; deliciousness; fastidiousness; squeamishness.","pos":""}],"DAINTY":[{"def":"Value; estimation; the gratification or pleasure taken in anything.","pos":""},{"def":"That which is delicious or delicate; a delicacy.","pos":""}],"DAIRA":[{"def":"Any of several valuable estates of the Egyptian khedive or his family.","pos":""}],"DAIRY":[{"def":"The place, room, or house where milk is kept, and converted into butter or cheese.","pos":""},{"def":"That department of farming which is concerned in the production of milk, and its conversion into butter and cheese.","pos":""}],"DAIRYING":[{"def":"The business of conducting a dairy.","pos":""}],"DAIRYMAID":[{"def":"A female servant whose business is the care of the dairy.","pos":""}],"DAIRYMAN":[{"def":"A man who keeps or takes care of a dairy.","pos":""}],"DAIRYWOMAN":[{"def":"A woman who attends to a dairy.","pos":""}],"DAIS":[{"def":"The high or principal table, at the end of a hall, at which the chief guests were seated; also, the chief seat at the high table.","pos":""},{"def":"A platform slightly raised above the floor of a hall or large room, giving distinction to the table and seats placed upon it for the chief guests.","pos":""}],"DAISIED":[{"def":"Full of daisies; adorned with daisies.","pos":""}],"DAISY":[{"def":"The common English and classical daisy is B.","pos":""}]}