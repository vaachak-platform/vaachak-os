{"SUBGELATINOUS":[{"def":"Imperfectly or partially gelatinous.","pos":""}],"SUBGENERIC":[{"def":"Of or pertaining to a subgenus.","pos":""}],"SUBGENUS":[{"def":"A subdivision of a genus, comprising one or more species which differ from other species of the genus in some important character or characters; as, the azaleas now constitute a subgenus of Rhododendron.","pos":""}],"SUBGLACIAL":[{"def":"Pertaining or belonging to the under side of a glacier; being beneath a glacier; as, subglacial streams.","pos":""}],"SUBGLOBOSE":[{"def":"Not quite globose.","pos":""}],"SUBGLOBULAR":[{"def":"Nearly globular.","pos":""}],"SUBGLOSSAL":[{"def":"Situated under the tongue; sublingual.","pos":""}],"SUBGLOTTIC":[{"def":"Situated below the glottis; -- applied to that part of the cavity of the larynx below the true vocal cords.","pos":""}],"SUBGLUMACEOUS":[{"def":"Somewhat glumaceous.","pos":""}],"SUBGOVERNOR":[{"def":"A subordinate or assistant governor.","pos":""}],"SUBGRANULAR":[{"def":"Somewhat granular.","pos":""}],"SUBGROUP":[{"def":"A subdivision of a group, as of animals.","pos":""}]}