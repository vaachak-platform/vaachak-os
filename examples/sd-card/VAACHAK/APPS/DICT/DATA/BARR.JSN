{"BARRACAN":[{"def":"A thick, strong stuff, somewhat like camlet; -- still used for outer garments in the Levant.","pos":""}],"BARRACK":[{"def":"A building for soldiers, especially when in garrison.","pos":""}],"BARRACLADE":[{"def":"A home-made woolen blanket without nap.","pos":""}],"BARRACOON":[{"def":"A slave warehouse, or an inclosure where slaves are quartered temporarily.","pos":""},{"def":"A voracious pikelike, marine fish, of the genus Sphyræna, sometimes used as food.","pos":""}],"BARRAGE":[{"def":"An artificial bar or obstruction placed in a river or water course to increase the depth of water; as, the barrages of the Nile.","pos":""}],"BARRANCA":[{"def":"A ravine caused by heavy rains or a watercourse.","pos":""}],"BARRAS":[{"def":"A resin, called also galipot.","pos":""}],"BARRATOR":[{"def":"One guilty of barratry.","pos":""}],"BARRATROUS":[{"def":"Tainter with, or constituting, barratry.","pos":""}],"BARRATRY":[{"def":"The practice of exciting and encouraging lawsuits and quarrels.","pos":""},{"def":"A fraudulent breach of duty or willful act of known illegality on the part of a master of a ship, in his character of master, or of the mariners, to the injury of the owner of the ship or cargo, and without his consent.","pos":""}],"BARRED OWL":[{"def":"A large American owl (Syrnium nebulosum); -- so called from the transverse bars of a dark brown color on the breast.","pos":""}],"BARREL":[{"def":"The hollow basal part of a feather.","pos":"noun"}],"BARREL PROCESS":[{"def":"A process of extracting gold or silver by treating the ore in a revolving barrel, or drum, with mercury, chlorine, cyanide solution, or other reagent.","pos":""}],"BARREN":[{"def":"Incapable of producing offspring; producing no young; sterile; -- She was barren of children.","pos":""},{"def":"Not producing vegetation, or useful vegetation; \"Barren mountain tracts.","pos":""}],"BARRENLY":[{"def":"Unfruitfully; unproductively.","pos":""}],"BARRENNESS":[{"def":"The condition of being barren; sterility; unproductiveness.","pos":""}],"BARRENWORT":[{"def":"An herbaceous plant of the Barberry family (Epimedium alpinum), having leaves that are bitter and said to be sudorific.","pos":""}],"BARRET":[{"def":"A kind of cap formerly worn by soldiers; -- called also barret cap.","pos":""}],"BARRETTER":[{"def":"A thermal cymoscope which operates by increased resistance when subjected to the influence of electric waves.","pos":""}],"BARRICADE":[{"def":"A fortification, made in haste, of trees, earth, palisades, wagons, or anything that will obstruct the progress or attack of an enemy.","pos":""}],"BARRICADER":[{"def":"One who constructs barricades.","pos":""}],"BARRIER":[{"def":"A carpentry obstruction, stockade, or other obstacle made in a passage in order to stop an enemy.","pos":""},{"def":"A fence or railing to mark the limits of a place, or to keep back a crowd.","pos":""}],"BARRIGUDO":[{"def":"A large, dark-colored, South American monkey, of the genus Lagothrix, having a long prehensile tail.","pos":""}],"BARRINGOUT":[{"def":"The act of closing the doors of a schoolroom against a schoolmaster; -- a boyish mode of rebellion in schools.","pos":""}],"BARRIO":[{"def":"In Spain and countries colonized by Spain, a village, ward, or district outside a town or city to whose jurisdiction it belongs.","pos":""}],"BARRISTER":[{"def":"Counselor at law; a counsel admitted to plead at the bar, and undertake the public trial of causes, as distinguished from an attorney or solicitor.","pos":""}],"BARROOM":[{"def":"A room containing a bar or counter at which liquors are sold.","pos":""}],"BARROW":[{"def":"A wicker case, in which salt is put to drain.","pos":""}],"BARROWIST":[{"def":"A follower of Henry Barrowe, one of the founders of Independency or Congregationalism in England.","pos":""}],"BARRULET":[{"def":"A diminutive of the bar, having one fourth its width.","pos":""}],"BARRULY":[{"def":"Traversed by barrulets or small bars; -- said of the field.","pos":""}],"BARRY":[{"def":", Divided into bars; -- said of the field.","pos":""}]}