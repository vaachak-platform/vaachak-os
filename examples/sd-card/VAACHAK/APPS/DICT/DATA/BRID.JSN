{"BRIDAL":[{"def":"Of or pertaining to a bride, or to wedding; nuptial; as, bridal ornaments; a bridal outfit; a bridal chamber.","pos":""}],"BRIDALTY":[{"def":"Celebration of the nuptial feast.","pos":""}],"BRIDE":[{"def":"A woman newly married, or about to be married.","pos":""}],"BRIDE-ALE":[{"def":"A rustic wedding feast; a bridal.","pos":""}],"BRIDEBED":[{"def":"The marriage bed.","pos":""}],"BRIDECAKE":[{"def":"Rich or highly ornamented cake, to be distributed to the guests at a wedding, or sent to friends after the wedding.","pos":""}],"BRIDECHAMBER":[{"def":"The nuptial appartment.","pos":""}],"BRIDEGROOM":[{"def":"A man newly married, or just about to be married.","pos":""}],"BRIDEKNOT":[{"def":"A knot of ribbons worn by a guest at a wedding; a wedding favor.","pos":""},{"def":"See Bridesmaid, Bridesman.","pos":""}],"BRIDESMAID":[{"def":"A female friend who attends on a bride at her wedding.","pos":""}],"BRIDESMAN":[{"def":"A male friend who attends upon a bridegroom and bride at their marriage; the \"best man.","pos":""}],"BRIDESTAKE":[{"def":"A stake or post set in the ground, for guests at a wedding to dance round.","pos":""}],"BRIDEWELL":[{"def":"A house of correction for the confinement of disorderly persons; -- so called from a hospital built in 1553 near St.","pos":""}],"BRIDGE":[{"def":"The small arch or bar at right angles to the strings of a violin, guitar, etc.","pos":""},{"def":"A device to measure the resistance of a wire or other conductor forming part of an electric circuit.","pos":""}],"BRIDGE-WARD":[{"def":"A bridge keeper; a warden or a guard for a bridge.","pos":""},{"def":"The principal ward of a key.","pos":""}],"BRIDGEBOARD":[{"def":"A notched board to which the treads and risers of the steps of wooden stairs are fastened.","pos":""}],"BRIDGEHEAD":[{"def":"A fortification commanding the extremity of a bridge nearest the enemy, to insure the preservation and usefulness of the bridge, and prevent the enemy from crossing; a tête-de-pont.","pos":""},{"def":"The system of bracing used between floor or other timbers to distribute the weight.","pos":""}],"BRIDGELESS":[{"def":"Having no bridge; not bridged.","pos":""}],"BRIDGEPOT":[{"def":"The adjustable socket, or step, of a millstone spindle.","pos":""}],"BRIDGETREE":[{"def":"The beam which supports the spindle socket of the runner in a grinding mill.","pos":""}],"BRIDGEY":[{"def":"Full of bridges.","pos":""}],"BRIDLE":[{"def":"The piece in the interior of a gun lock, which holds in place the timbler, sear, etc.","pos":""}],"BRIDLE IRON":[{"def":"A strong flat bar of iron, so bent as to support, as in a stirrup, one end of a floor timber, etc.","pos":""}],"BRIDLER":[{"def":"One who bridles; one who restrains and governs, as with a bridle.","pos":""}],"BRIDOON":[{"def":"The snaffle and rein of a military bridle, which acts independently of the bit, at the pleasure of the rider.","pos":""}]}