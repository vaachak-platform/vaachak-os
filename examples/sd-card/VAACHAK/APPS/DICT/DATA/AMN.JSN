{"AMNESIA":[{"def":"Forgetfulness; also, a defect of speech, from cerebral disease, in which the patient substitutes wrong words or names in the place of those he wishes to employ.","pos":""}],"AMNESIC":[{"def":"Of or pertaining to amnesia.","pos":""}],"AMNESTIC":[{"def":"Causing loss of memory.","pos":""}],"AMNESTY":[{"def":"Forgetfulness; cessation of remembrance of wrong; oblivion.","pos":""},{"def":"An act of the sovereign power granting oblivion, or a general pardon, for a past offense, as to subjects concerned in an insurrection.","pos":""}],"AMNICOLIST":[{"def":"One who lives near a river.","pos":""}],"AMNIGENOUS":[{"def":"Born or bred in, of, or near a river.","pos":""}],"AMNION":[{"def":"A thin membrane surrounding the embryos of mammals, birds, and reptiles.","pos":""}],"AMNIOTA":[{"def":"That group of vertebrates which develops in its embryonic life the envelope called the amnion.","pos":""}],"AMNIOTIC":[{"def":"Of or pertaining to the amnion; characterized by an amnion; as, the amniotic fluid; the amniotic sac.","pos":""}]}