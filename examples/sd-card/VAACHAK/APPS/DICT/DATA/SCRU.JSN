{"SCRUB":[{"def":"To rub hard; to wash with rubbing; usually, to rub with a wet brush, or with something coarse or rough, for the purpose of cleaning or brightening; as, to scrub a floor, a doorplate.","pos":""}],"SCRUBBED":[{"def":"Dwarfed or stunted; scrubby.","pos":""}],"SCRUBBER":[{"def":"One who, or that which, scrubs; esp.","pos":""}],"SCRUBBOARD":[{"def":"A baseboard; a mopboard.","pos":""}],"SCRUBBY":[{"def":"Of the nature of scrub; small and mean; stunted in growth; as, a scrubby cur.","pos":""}],"SCRUBSTONE":[{"def":"A species of calciferous sandstone.","pos":""}],"SCRUFF":[{"def":"The nape of the neck; the loose outside skin, as of the back of the neck.","pos":""}],"SCRUMPTIOUS":[{"def":"Nice; particular; fastidious; excellent; fine.","pos":""}],"SCRUNCH":[{"def":"To scranch; to crunch.","pos":""}],"SCRUPLE":[{"def":"A weight of twenty grains; the third part of a dram.","pos":""},{"def":"Hence, a very small quantity; a particle.","pos":""}],"SCRUPLER":[{"def":"One who scruples.","pos":""}],"SCRUPULIZE":[{"def":"To perplex with scruples; to regard with scruples.","pos":""}],"SCRUPULOSITY":[{"def":"The quality or state of being scruppulous; doubt; doubtfulness respecting decision or action; caution or tenderness from the far of doing wrong or ofending; nice regard to exactness and propierty; precision.","pos":""}],"SCRUPULOUS":[{"def":"Full ofscrupules; inclined to scruple; nicely doubtful; hesitating to determine or to act, from a fear of offending or of doing wrong.","pos":""},{"def":"Careful; cautious; exact; nice; as, scrupulous abstinence from labor; scrupulous performance of duties.","pos":""}],"SCRUTABLE":[{"def":"Discoverable by scrutiny, inquiry, or critical examination.","pos":""}],"SCRUTATION":[{"def":"Search; scrutiny.","pos":""}],"SCRUTATOR":[{"def":"One who scrutinizes; a close examiner or inquirer.","pos":""}],"SCRUTIN DE LISTE":[{"def":"Voting for a group of candidates for the same kind of office on one ticket or ballot, containing a list of them; -- the method, used in France, as from June, 1885, to Feb.","pos":""}],"SCRUTINEER":[{"def":"A scrutinizer; specifically, an examiner of votes, as at an election.","pos":""}],"SCRUTINIZE":[{"def":"To examine closely; to inspect or observe with critical attention; to regard narrowly; as, to scrutinize the measures of administration; to scrutinize the conduct or motives of individuals.","pos":""}],"SCRUTINIZER":[{"def":"One who scrutinizes.","pos":""}],"SCRUTINOUS":[{"def":"Closely examining, or inquiring; careful; sctrict.","pos":""}],"SCRUTINY":[{"def":"An examination of catechumens, in the last week of Lent, who were to receive baptism on Easter Day.","pos":""},{"def":"A ticket, or little paper billet, on which a vote is written.","pos":""}],"SCRUTOIRE":[{"def":"A escritoire; a writing desk.","pos":""}],"SCRUZE":[{"def":"To squeeze, compress, crush, or bruise.","pos":""}]}