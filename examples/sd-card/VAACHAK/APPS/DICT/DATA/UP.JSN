{"UP":[{"def":"Aloft; on high; in a direction contrary to that of gravity; toward or in a higher place or position; above; -- the opposite of Ant: down.","pos":""}],"UP-LINE":[{"def":"A line or track leading from the provinces toward the metropolis or a principal terminus; the track upon which up-trains run.","pos":""}],"UP-OVER":[{"def":"Designating a method of shaft excavation by drifting to a point below, and then raising instead of sinking.","pos":""}],"UP-TO-DATE":[{"def":"Extending to the present time; having style, manners, knowledge, or other qualities that are abreast of the times.","pos":""}],"UP-TRAIN":[{"def":"A train going in the direction of the metropolis or the main terminus.","pos":""},{"def":"A train going in the direction conventionally called up.","pos":""}],"UP-WIND":[{"def":"Against the wind.","pos":""}],"UPAS":[{"def":"A tree (Antiaris toxicaria) of the Breadfruit family, common in the forests of Java and the neighboring islands.","pos":""}],"UPBAR":[{"def":"To fasten with a bar.","pos":""},{"def":"To remove the bar or bards of, as a gate; to under.","pos":""}],"UPBEAR":[{"def":"To bear up; to raise aloft; to support in an elevated situation; to sustain.","pos":""}],"UPBLOW":[{"def":"To blow up; as, the wind upblows from the sea.","pos":""}],"UPBRAID":[{"def":"To charge with something wrong or disgraceful; to reproach; to cast something in the teeth of; -- followed by with or for, and formerly of, before the thing imputed.","pos":""},{"def":"To reprove severely; to rebuke; to chide.","pos":""}],"UPBREAK":[{"def":"To break upwards; to force away or passage to the surface.","pos":""}],"UPBREATHE":[{"def":"To breathe up or out; to exhale.","pos":""}],"UPBREED":[{"def":"To rear, or bring up; to nurse.","pos":""}],"UPBROUGHT":[{"def":"Brought up; educated.","pos":""}],"UPBUOYANCE":[{"def":"The act of buoying up; uplifting.","pos":""}],"UPBURST":[{"def":"The act of bursting upwards; a breaking through to the surface; an upbreak or uprush; as, an upburst of molten matter.","pos":""}],"UPCAST":[{"def":"Cast up; thrown upward; as, with upcast eyes.","pos":""}],"UPCAUGHT":[{"def":"Seized or caught up.","pos":""}],"UPCLIMB":[{"def":"To climb up; to ascend.","pos":""}],"UPCOIL":[{"def":"To coil up; to make into a coil, or to be made into a coil.","pos":""}],"UPCOUNTRY":[{"def":"In an upcountry direction; as, to live upcountry.","pos":""}],"UPDIVE":[{"def":"To spring upward; to rise.","pos":""}],"UPEND":[{"def":"To end up; to set on end, as a cask.","pos":""}],"UPFLOW":[{"def":"To flow or stream up.","pos":""}],"UPFLUNG":[{"def":"Flung or thrown up.","pos":""}],"UPGATHER":[{"def":"To gather up; to contract; to draw together.","pos":""}],"UPGIVE":[{"def":"To give up or out.","pos":""}],"UPGROWTH":[{"def":"The process or result of growing up; progress; development.","pos":""}],"UPGUSH":[{"def":"A gushing upward.","pos":""}],"UPHAND":[{"def":"Lifted by the hand, or by both hands; as, the uphand sledge.","pos":""}],"UPHASP":[{"def":"To hasp or faster up; to close; as, sleep uphasps the eyes.","pos":""}],"UPHEAPED":[{"def":"Piled up; accumulated.","pos":""}],"UPHEAVAL":[{"def":"The act of upheaving, or the state of being upheaved; esp.","pos":""}],"UPHEAVE":[{"def":"To heave or lift up from beneath; to raise.","pos":""}],"UPHELD":[{"def":"Up*held\", Defn: imp.","pos":""}],"UPHER":[{"def":"A fir pole of from four to seven inches diameter, and twenty to forty feet long, sometimes roughly hewn, used for scaffoldings, and sometimes for slight and common roofs, for which use it is split.","pos":""}],"UPHILL":[{"def":"Upwards on, or as on, a hillside; as, to walk uphill.","pos":""}],"UPHILT":[{"def":"To thrust in up to the hilt; as, to uphilt one's sword into an enemy.","pos":""}],"UPHOLD":[{"def":"To hold up; to lift on high; to elevate.","pos":""},{"def":"To keep erect; to support; to sustain; to keep from falling; to maintain.","pos":""}],"UPHOLDER":[{"def":"A broker or auctioneer; a tradesman.","pos":""},{"def":"An undertaker, or provider for funerals.","pos":""}],"UPHOLSTER":[{"def":"To furnish (rooms, carriages, bedsteads, chairs, etc.","pos":""}],"UPHOLSTERER":[{"def":"One who provides hangings, coverings, cushions, curtains, and the like; one who upholsters.","pos":""}],"UPHOLSTERY":[{"def":"The articles or goods supplied by upholsterers; the business or work of an upholsterer.","pos":""}],"UPHROE":[{"def":"Same as Euphroe.","pos":""}],"UPKEEP":[{"def":"The act of keeping up, or maintaining; maintenance.","pos":""}],"UPLAND":[{"def":"High land; ground elevated above the meadows and intervals which lie on the banks of rivers, near the sea, or between hills; land which is generally dry; -- opposed to lowland, meadow, marsh, swamp, interval, and the like.","pos":""},{"def":"The country, as distinguished from the neighborhood of towns.","pos":""}],"UPLANDER":[{"def":"The upland sandpiper.","pos":""}],"UPLANDISH":[{"def":"Of or pertaining to uplands; dwelling on high lands.","pos":""}],"UPLEAN":[{"def":"To lean or incline upon anything.","pos":""}],"UPLIFT":[{"def":"To lift or raise aloft; to raise; to elevate; as, to uplift the arm; to uplift a rock.","pos":""}],"UPLOOK":[{"def":"To look or gaze up.","pos":""}],"UPMOST":[{"def":"Highest; topmost; uppermost.","pos":""}],"UPOKORORO":[{"def":"An edible fresh-water New Zealand fish (Prototroctes oxyrhynchus) of the family Haplochitonidæ.","pos":""}],"UPON":[{"def":"On; -- used in all the senses of that word, with which it is interchangeable.","pos":""}],"UPPENT":[{"def":"A Pent up; confined.","pos":""}],"UPPER":[{"def":"Being further up, literally or figuratively; higher in place, position, rank, dignity, or the like; superior; as, the upper lip; the upper side of a thing; the upper house of a legislature.","pos":""}],"UPPERMOST":[{"def":"Highest in place, position, rank, power, or the like; upmost; supreme.","pos":""}],"UPPERTENDOM":[{"def":"The highest class in society; the upper ten.","pos":""}],"UPPILE":[{"def":"To pile, or heap, up.","pos":""}],"UPPISH":[{"def":"Proud; arrogant; assuming; putting on airs of superiority.","pos":""}],"UPPLUCK":[{"def":"To pull or pluck up.","pos":""}],"UPPRICKED":[{"def":"Upraised; erect; -- said of the ears of an animal.","pos":""}],"UPRAISE":[{"def":"To raise; to lift up.","pos":""}],"UPREAR":[{"def":"To raise; to erect.","pos":""}],"UPRIDGED":[{"def":"Raised up in a ridge or ridges; as, a billow upridged.","pos":""}],"UPRIGHT":[{"def":"In an erect position or posture; perpendicular; vertical, or nearly vertical; pointing upward; as, an upright tree.","pos":""},{"def":"Morally erect; having rectitude; honest; just; as, a man upright in all his ways.","pos":""}],"UPRIGHTEOUSLY":[{"def":"In an upright or just manner.","pos":""}],"UPRIGHTLY":[{"def":"In an upright manner.","pos":""}],"UPRIGHTNESS":[{"def":"the quality or state of being upright.","pos":""}],"UPRISE":[{"def":"To rise; to get up; to appear from below the horizon.","pos":""},{"def":"To have an upward direction or inclination.","pos":""}],"UPRISING":[{"def":"Act of rising; also, a steep place; an ascent.","pos":""},{"def":"An insurrection; a popular revolt.","pos":""}],"UPRIST":[{"def":"Nor dim nor red, like God's own head The glorious sun uprist.","pos":""}],"UPROAR":[{"def":"Great tumult; violent disturbance and noise; noisy confusion; bustle and clamor.","pos":""}],"UPROARIOUS":[{"def":"Making, or accompanied by, uproar, or noise and tumult; as, uproarious merriment.","pos":""}],"UPROOT":[{"def":"To root up; to tear up by the roots, or as if by the roots; to remove utterly; to eradicate; to extirpate.","pos":""}],"UPROUSE":[{"def":"To rouse up; to rouse from sleep; to awake; to arouse.","pos":""}],"UPRUN":[{"def":"To run up; to ascend.","pos":""}],"UPRUSH":[{"def":"Act of rushing upward; an upbreak or upburst; as, an uprush of lava.","pos":""}],"UPSEEK":[{"def":"To seek or strain upward.","pos":""}],"UPSEND":[{"def":"To send, cast, or throw up.","pos":""}],"UPSET":[{"def":"To set up; to put upright.","pos":""},{"def":"To overturn, overthrow, or overset; as, to upset a carriage; to upset an argument.","pos":""}],"UPSETTING":[{"def":"Conceited; assuming; as, an upsetting fellow.","pos":""}],"UPSETTING THERMOMETER":[{"def":"A thermometer by merely inverting which the temperature may be registered.","pos":""}],"UPSHOOT":[{"def":"To shoot upward.","pos":""}],"UPSHOT":[{"def":"Final issue; conclusion; the sum and substance; the end; the result; the consummation.","pos":""}],"UPSIDE":[{"def":"The upper side; the part that is uppermost.","pos":""}],"UPSILON":[{"def":"The 20th letter (U, u) of the Greek alphabet, a vowel having originally the sound of oo as in room, becoming before the 4th century b.","pos":""}],"UPSITTING":[{"def":"A sitting up of a woman after her confinement, to receive and entertain her friends.","pos":""}],"UPSOAR":[{"def":"To soar or mount up.","pos":""}],"UPSODOWN":[{"def":"In man's sin is every manner order or ordinance turned upsodown.","pos":""}],"UPSPEAR":[{"def":"To grow or shoot up like a spear; as, upspearing grass.","pos":""}],"UPSPRING":[{"def":"A spring or leap into the air.","pos":""}],"UPSPURNER":[{"def":"A spurner or contemner; a despiser; a scoffer.","pos":""}],"UPSTAIRS":[{"def":"Up the stairs; in or toward an upper story.","pos":""}],"UPSTAND":[{"def":"To stand up; to be erected; to rise.","pos":""}],"UPSTARE":[{"def":"To stare or stand upward; hence, to be uplifted or conspicuous.","pos":""}],"UPSTART":[{"def":"To start or spring up suddenly.","pos":""}],"UPSTAY":[{"def":"To sustain; to support.","pos":""}],"UPSTIR":[{"def":"Insurrection; commotion; disturbance.","pos":""}],"UPSTREAM":[{"def":"Toward the higher part of a stream; against the current.","pos":""}],"UPSTREET":[{"def":"Toward the higher part of a street; as, to walk upstreet.","pos":""}],"UPSTROKE":[{"def":"An upward stroke, especially the stroke, or line, made by a writing instrument when moving upward, or from the body of the writer, or a line corresponding to the part of a letter thus made.","pos":""}],"UPSUN":[{"def":"The time during which the sun is up, or above the horizon; the time between sunrise and sunset.","pos":""}],"UPSWARM":[{"def":"To rise, or cause to rise, in a swarm or swarms.","pos":""}],"UPSWAY":[{"def":"To sway or swing aloft; as, to upsway a club.","pos":""}],"UPSWELL":[{"def":"To swell or rise up.","pos":""}],"UPSYTURVY":[{"def":"Upside down; topsy-turvy.","pos":""}],"UPTAILS ALL":[{"def":"An old game at cards.","pos":""},{"def":"Revelers; roysterers.","pos":""}],"UPTAKE":[{"def":"To take into the hand; to take up; to help.","pos":""}],"UPTHUNDER":[{"def":"To send up a noise like thunder.","pos":""}],"UPTILL":[{"def":"She, poor bird, as all forlorn, Leaned her breast uptill a thorn.","pos":""}],"UPTOWN":[{"def":"To or in the upper part of a town; as, to go uptown.","pos":""}],"UPTRACE":[{"def":"To trace up or out.","pos":""}],"UPTRAIN":[{"def":"To train up; to educate.","pos":""}],"UPTURN":[{"def":"To turn up; to direct upward; to throw up; as, to upturn the ground in plowing.","pos":""}],"UPUPA":[{"def":"A genus of birds which includes the common hoopoe.","pos":""}],"UPWAFT":[{"def":"In a direction from lower to higher; toward a higher place; in a course toward the source or origin; -- opposed to downward; as, to tend or roll upward.","pos":""},{"def":"In the upper parts; above.","pos":""}],"UPWARD":[{"def":"Directed toward a higher place; as, with upward eye; with upward course.","pos":""}],"UPWHIRL":[{"def":"To rise upward in a whirl; to raise upward with a whirling motion.","pos":""}],"UPWREATH":[{"def":"To rise with a curling motion; to curl upward, as smoke.","pos":""}]}