{"SOOCHONG":[{"def":"Same as Souchong.","pos":""}],"SOODRA":[{"def":"Same as Sufi, Sufism.","pos":""}],"SOON":[{"def":"In a short time; shortly after any time specified or supposed; as, soon after sunrise.","pos":""},{"def":"Without the usual delay; before any time supposed; early.","pos":""}],"SOONER STATE":[{"def":"Oklahoma; -- a nickname.","pos":""}],"SOORMA":[{"def":"A preparation of antimony with which Mohammedan men anoint their eyelids.","pos":""}],"SOOSOO":[{"def":"A kind of dolphin (Platanista Gangeticus) native of the river Ganges; the Gangetic dolphin.","pos":""}],"SOOT":[{"def":"To cover or dress with soot; to smut with, or as with, soot; as, to soot land.","pos":""}],"SOOTERKIN":[{"def":"A kind of false birth, fabled to be produced by Dutch women from sitting over their stoves; also, an abortion, in a figurative sense; an abortive scheme.","pos":""}],"SOOTH":[{"def":"True; faithful; trustworthy.","pos":""},{"def":"Pleasing; delightful; sweet.","pos":""}],"SOOTHE":[{"def":"To assent to as true.","pos":""},{"def":"To assent to; to comply with; to gratify; to humor by compliance; to please with blandishments or soft words; to flatter.","pos":""}],"SOOTHER":[{"def":"One who, or that which, soothes.","pos":""}],"SOOTHFAST":[{"def":"Firmly fixed in, or founded upon, the thruth; true; genuine; real; also, truthful; faithful.","pos":""}],"SOOTHINGLY":[{"def":"In a soothing manner.","pos":""}],"SOOTHLY":[{"def":"In truth; truly; really; verily.","pos":""}],"SOOTHSAY":[{"def":"To foretell; to predict.","pos":""}],"SOOTHSAYER":[{"def":"One who foretells events by the art of soothsaying; a prognosticator.","pos":""}],"SOOTHSAYING":[{"def":"A true saying; truth.","pos":""},{"def":"The act of one who soothsays; the foretelling of events; the art or practice of making predictions.","pos":""}],"SOOTINESS":[{"def":"The quality or state of being sooty; fuliginousness.","pos":""}],"SOOTY":[{"def":"Of or pertaining to soot; producing soot; soiled by soot.","pos":""},{"def":"Having a dark brown or black color like soot; fuliginous; dusky; dark.","pos":""}]}