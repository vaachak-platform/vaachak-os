{"COMIC":[{"def":"Relating to comedy, as distinct from tragedy.","pos":""},{"def":"Causing mirth; ludicrous.","pos":""}],"COMICAL":[{"def":"Relating to comedy.","pos":""},{"def":"Exciting mirth; droll; laughable; as, a comical story.","pos":""}],"COMICALITY":[{"def":"The quality of being comical; something comical.","pos":""}],"COMICRY":[{"def":"The power of exciting mirth; comicalness.","pos":""}],"COMING":[{"def":"Approaching; of the future, especially the near future; the next; as, the coming week or year; the coming exhibition.","pos":""},{"def":"Ready to come; complaisant; fond.","pos":""}],"COMITIA":[{"def":"A public assembly of the Roman people for electing officers or passing laws.","pos":""}],"COMITIAL":[{"def":"Relating to the comitia, or popular assembles of the Romans for electing officers and passing laws.","pos":""}],"COMITIVA":[{"def":"A body of followers; -- applied to the lawless or brigand bands in Italy and Sicily.","pos":""}],"COMITY":[{"def":"Mildness and suavity of manners; courtesy between equals; friendly equals; friendly civility; as, comity of manners; the comity of States.","pos":""}]}