{"MULADA":[{"def":"A drove of mules.","pos":""}],"MULATTO":[{"def":"The offspring of a negress by a white man, or of a white woman by a negro, -- usually of a brownish yellow complexion.","pos":""}],"MULATTRESS":[{"def":"A female mulatto.","pos":""}],"MULBERRY":[{"def":"The berry or fruit of any tree of the genus Morus; also, the tree itself.","pos":""}],"MULBERRY-FACED":[{"def":"Having a face of a mulberry color, or blotched as if with mulberry stains.","pos":""}],"MULCH":[{"def":"Half-rotten straw, or any like substance strewn on the ground, as over the roots of plants, to protect from heat, drought, etc.","pos":""}],"MULCT":[{"def":"A fine or penalty, esp.","pos":""},{"def":"A blemish or defect.","pos":""}],"MULE":[{"def":"A hybrid animal; specifically, one generated between an ass and a mare, sometimes a horse and a she-ass.","pos":""},{"def":"A plant or vegetable produced by impregnating the pistil of one species with the pollen or fecundating dust of another; -- called also hybrid.","pos":""}],"MULE KILLER":[{"def":"Any of several arthropods erroneously supposed to kill live stock, in the southern United States, by stinging or by being swallowed; as: (a) A whip scorpion.","pos":""}],"MULETEER":[{"def":"One who drives mules.","pos":""}],"MULEWORT":[{"def":"A fern of the genus Hemionitis.","pos":""}],"MULEY":[{"def":"A stiff, long saw, guided at the ends but not stretched in a gate.","pos":""}],"MULIEBRITY":[{"def":"The state of being a woman or of possessing full womanly powers; womanhood; -- correlate of virility.","pos":""},{"def":"Hence: Effeminancy; softness.","pos":""}],"MULIERLY":[{"def":"In the manner or condition of a mulier; in wedlock; legitimately.","pos":""}],"MULIEROSITY":[{"def":"A fondness for women.","pos":""}],"MULIERTY":[{"def":"Condition of being a mulier; position of one born in lawful wedlock.","pos":""}],"MULISH":[{"def":"Like a mule; sullen; stubborn.","pos":""}],"MULL":[{"def":"A thin, soft kind of muslin.","pos":""}],"MULLAGATAWNY":[{"def":"An East Indian curry soup.","pos":""}],"MULLAR":[{"def":"A die, cut in intaglio, for stamping an ornament in relief, as upon metal.","pos":""}],"MULLEIN":[{"def":"Any plant of the genus Verbascum.","pos":""}],"MULLER":[{"def":"One who, or that which, mulls.","pos":""},{"def":"A vessel in which wine, etc.","pos":""}],"MULLET":[{"def":"Any one of numerous fishes of the genus Mugil; -- called also gray mullets.","pos":""},{"def":"Any species of the genus Mullus, or family Mullidæ; called also red mullet, and surmullet, esp.","pos":""}],"MULLIGATAWNY":[{"def":"See Mullagatawny.","pos":""}],"MULLIGRUBS":[{"def":"A griping of the intestines; colic.","pos":""},{"def":"Hence, sullenness; the sulks.","pos":""}],"MULLINGONG":[{"def":"See Duck mole, under Duck.","pos":""}],"MULLION":[{"def":"To furnish with mullions; to divide by mullions.","pos":""}],"MULLOCK":[{"def":"Rubbish; refuse; dirt.","pos":""}],"MULLOID":[{"def":"Like or pertaining to the genus Mullus, which includes the surmullet, or red mullet.","pos":""}],"MULMUL":[{"def":"A fine, soft muslin; mull.","pos":""}],"MULSE":[{"def":"Wine boiled and mingled with honey.","pos":""}],"MULTANGULAR":[{"def":"Having many angles.","pos":""}],"MULTANIMOUS":[{"def":"Many-minded; many-sided.","pos":""}],"MULTARTICULATE":[{"def":"Having many articulations or joints.","pos":""}],"MULTEITY":[{"def":"A prefix signifying much or many; several; more than one; as, multiaxial, multocular.","pos":""}],"MULTIAXIAL":[{"def":"Having more than one axis; developing in more than a single line or plain; -- opposed to Ant: monoaxial.","pos":""}],"MULTICAPSULAR":[{"def":"Having many, or several, capsules.","pos":""}],"MULTICAVOUS":[{"def":"Having many cavities.","pos":""}],"MULTICELLULAR":[{"def":"Consisting of, or having, many cells or more than one cell.","pos":""}],"MULTICENTRAL":[{"def":"Having many, or several, centers; as, a multicentral cell.","pos":""}],"MULTICIPITAL":[{"def":"Having many heads or many stems from one crown or root.","pos":""}],"MULTICOLOR":[{"def":"Having many, or several, colors.","pos":""}],"MULTICOSTATE":[{"def":"Having numerous ribs, or costæ, as the leaf of a plant, or as certain shells and corals.","pos":""}],"MULTICUSPID":[{"def":"Multicuspidate; -- said of teeth.","pos":""}],"MULTICUSPIDATE":[{"def":"Having many cusps or points.","pos":""}],"MULTIDENTATE":[{"def":"Having many teeth, or toothlike processes.","pos":""}],"MULTIDIGITATE":[{"def":"Having many fingers, or fingerlike processes.","pos":""}],"MULTIFACED":[{"def":"Having many faces.","pos":""}],"MULTIFARIOUS":[{"def":"Having parts, as leaves, arranged in many vertical rows.","pos":""}],"MULTIFARIOUSLY":[{"def":"With great multiplicity and diversity; with variety of modes and relations.","pos":""}],"MULTIFARIOUSNESS":[{"def":"The fault of improperly uniting in one bill distinct and independent matters, and thereby confounding them.","pos":""}],"MULTIFEROUS":[{"def":"Bearing or producing much or many.","pos":""}],"MULTIFID":[{"def":"Having many segments; cleft into several parts by linear sinuses; as, a multifid leaf or corolla.","pos":""}],"MULTIFLOROUS":[{"def":"Having many flowers.","pos":""}],"MULTIFLUE":[{"def":"Having many flues; as, a multiflue boiler.","pos":""}],"MULTIFOIL":[{"def":"An ornamental foliation consisting of more than five divisions or foils.","pos":""}],"MULTIFOLD":[{"def":"Many times doubled; manifold; numerous.","pos":""}],"MULTIFORM":[{"def":"Having many forms, shapes, or appearances.","pos":""}],"MULTIFORMITY":[{"def":"The quality of being multiform; diversity of forms; variety of appearances in the same thing.","pos":""}],"MULTIGENEROUS":[{"def":"Having many kinds.","pos":""}],"MULTIGRANULATE":[{"def":"Having, or consisting of, many grains.","pos":""}],"MULTIGRAPH":[{"def":"A combined rotary type-setting and printing machine for office use.","pos":""}],"MULTIJUGATE":[{"def":"Having many pairs of leaflets.","pos":""}],"MULTIJUGOUS":[{"def":"Same as Multijugate.","pos":""}],"MULTILATERAL":[{"def":"Having many sides; many-sided.","pos":""}],"MULTILINEAL":[{"def":"Having many lines.","pos":""}],"MULTILOBAR":[{"def":"Consisting of, or having, many lobes.","pos":""}],"MULTILOCULAR":[{"def":"Having many or several cells or compartments; as, a multilocular shell or capsule.","pos":""}],"MULTILOQUENCE":[{"def":"Quality of being multiloquent; use of many words; talkativeness.","pos":""},{"def":"Speaking much; very talkative; loquacious.","pos":""}],"MULTILOQUY":[{"def":"Excess of words or talk.","pos":""}],"MULTINODATE":[{"def":"Having many knots or nodes.","pos":""}],"MULTINODOUS":[{"def":"Same as Multinodate.","pos":""}],"MULTINOMIAL":[{"def":"Same as Polynomial.","pos":""},{"def":"Having many names or terms.","pos":""}],"MULTINUCLEAR":[{"def":"Containing many nuclei; as, multinuclear cells.","pos":""}],"MULTIPAROUS":[{"def":"Producing many, or more than one, at a birth.","pos":""}],"MULTIPARTITE":[{"def":"Divided into many parts; having several parts.","pos":""}],"MULTIPED":[{"def":"An insect having many feet, as a myriapod.","pos":""}],"MULTIPHASE":[{"def":"Having many phases; specif.","pos":""},{"def":"pertaining to, or designating, a generator producing, or any system conveying or utilizing, two or more waves of pressure, or electromotive force, not in phase with each other; polyphase.","pos":""}],"MULTIPLANE":[{"def":"Having several or many planes or plane surfaces; as, a multiplane kite.","pos":""}],"MULTIPLE":[{"def":"Containing more than once, or more than one; consisting of more than one; manifold; repeated many times; having several, or many, parts.","pos":""}],"MULTIPLEX":[{"def":"Manifold; multiple.","pos":""}],"MULTIPLIABLE":[{"def":"Capable of being multiplied.","pos":""}],"MULTIPLICABLE":[{"def":"Capable of being multiplied; multipliable.","pos":""}],"MULTIPLICAND":[{"def":"The number which is to be multiplied by another number called the multiplier.","pos":""}],"MULTIPLICATE":[{"def":"Consisting of many, or of more than one; multiple; multifold.","pos":""}],"MULTIPLICATION":[{"def":"The process of repeating, or adding to itself, any given number or quantity a certain number of times; commonly, the process of ascertaining by a briefer computation the result of such repeated additions; also, the rule by which the operation is performed; -- the reverse of division.","pos":""},{"def":"An increase above the normal number of parts, especially of petals; augmentation.","pos":""}],"MULTIPLICATIVE":[{"def":"Tending to multiply; having the power to multiply, or incease numbers.","pos":""}],"MULTIPLICATIVELY":[{"def":"So as to multiply.","pos":""}],"MULTIPLICATOR":[{"def":"The number by which another number is multiplied; a multiplier.","pos":""}],"MULTIPLICITY":[{"def":"The quality of being multiple, manifold, or various; a state of being many; a multitude; as, a multiplicity of thoughts or objects.","pos":""}],"MULTIPLIER":[{"def":"The number by which another number is multiplied.","pos":""},{"def":"An instrument for multiplying or increasing by repetition or accumulation the intensity of a force or action, as heat or electricity.","pos":""}],"MULTIPLY":[{"def":"To add (any given number or quantity) to itself a certain number of times; to find the product of by multiplication; thus 7 multiplied by 8 produces the number 56; to multiply two numbers.","pos":""}],"MULTIPOLAR":[{"def":"Having many poles; -- applied especially to those ganglionic nerve cells which have several radiating processes.","pos":""}],"MULTIPOTENT":[{"def":"Having manifold power, or power to do many things.","pos":""}],"MULTIPRESENCE":[{"def":"The state or power of being multipresent.","pos":""}],"MULTIPRESENT":[{"def":"Being, or having the power to be, present in two or more places at once.","pos":""}],"MULTIRADIATE":[{"def":"Having many rays.","pos":""}],"MULTIRAMIFIED":[{"def":"Divided into many branches.","pos":""}],"MULTIRAMOSE":[{"def":"Having many branches.","pos":""}],"MULTISCIOUS":[{"def":"Having much or varied knowledge.","pos":""}],"MULTISECT":[{"def":"Divided into many similar segments; -- said of an insect or myriapod.","pos":""}],"MULTISEPTATE":[{"def":"Divided into many chambers by partitions, as the pith of the pokeweed.","pos":""}],"MULTISERIAL":[{"def":"Arranged in many rows, or series, as the scales of a pine cone, or the leaves of the houseleek.","pos":""}],"MULTISILIQUOUS":[{"def":"Having many pods or seed vessels.","pos":""}],"MULTISONOUS":[{"def":"Having many sounds, or sounding much.","pos":""}],"MULTISPIRAL":[{"def":"Having numerous spiral coils round a center or nucleus; -- said of the opercula of certain shells.","pos":""}],"MULTISTRIATE":[{"def":"Having many streaks.","pos":""}],"MULTISULCATE":[{"def":"Having many furrows.","pos":""}],"MULTISYLLABLE":[{"def":"A word of many syllables; a polysyllable.","pos":""}],"MULTITITULAR":[{"def":"Having many titles.","pos":""}],"MULTITUBULAR":[{"def":"Having many tubes; as, a multitubular boiler.","pos":""}],"MULTITUDE":[{"def":"A great number of persons collected together; a numerous collection of persons; a crowd; an assembly.","pos":""},{"def":"A great number of persons or things, regarded collectively; as, the book will be read by a multitude of people; the multitude of stars; a multitude of cares.","pos":""}],"MULTITUDINARY":[{"def":"Mul`ti*tu\"di*na*ry, a.","pos":""}],"MULTITUDINOUS":[{"def":"Consisting of a multitude; manifold in number or condition; as, multitudinous waves.","pos":""},{"def":"Of or pertaining to a multitude.","pos":""}],"MULTIVALENCE":[{"def":"Quality, state, or degree, of a multivalent element, atom, or radical.","pos":""}],"MULTIVALVE":[{"def":"Any mollusk which has a shell composed of more than two pieces.","pos":""},{"def":"Many-valved; having more than two valves; -- said of certain shells, as the chitons.","pos":""}],"MULTIVERSANT":[{"def":"Turning into many shapes; assuming many forms; protean.","pos":""}],"MULTIVIOUS":[{"def":"Having many ways or roads; by many ways.","pos":""}],"MULTIVOCAL":[{"def":"Signifying many different things; of manifold meaning; equivocal.","pos":""},{"def":"A multivocal word.","pos":""}],"MULTOCULAR":[{"def":"Having many eyes, or more than two.","pos":""}],"MULTUM":[{"def":"An extract of quassia licorice, fraudulently used by brewers in order to economize malt and hops.","pos":""}],"MULTUNGULATE":[{"def":"Having many hoofs.","pos":""}],"MULTURE":[{"def":"The toll for grinding grain.","pos":""}]}