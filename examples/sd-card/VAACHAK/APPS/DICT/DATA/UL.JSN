{"ULARBURONG":[{"def":"A large East Indian nocturnal tree snake (Dipsas dendrophila).","pos":""}],"ULCER":[{"def":"A solution of continuity in any of the soft parts of the body, discharging purulent matter, found on a surface, especially one of the natural surfaces of the body, and originating generally in a constitutional disorder; a sore discharging pus.","pos":""}],"ULCERABLE":[{"def":"Capable of ulcerating.","pos":""}],"ULCERATE":[{"def":"To be formed into an ulcer; to become ulcerous.","pos":""}],"ULCERATED":[{"def":"Affected with, or as with, an ulcer or ulcers; as, an ulcerated sore throat.","pos":""}],"ULCERATION":[{"def":"The process of forming an ulcer, or of becoming ulcerous; the state of being ulcerated; also, an ulcer.","pos":""}],"ULCERATIVE":[{"def":"Of or pertaining to ulcers; as, an ulcerative process.","pos":""}],"ULCERED":[{"def":"Ulcerous; ulcerated.","pos":""}],"ULCEROUS":[{"def":"Having the nature or character of an ulcer; discharging purulent or other matter.","pos":""},{"def":"Affected with an ulcer or ulcers; ulcerated.","pos":""}],"ULE":[{"def":"A Mexican and Central American tree (Castilloa elastica and C.","pos":""}],"ULEMA":[{"def":"A college or corporation in Turkey composed of the hierarchy, namely, the imams, or ministers of religion, the muftis, or doctors of law, and the cadis, or administrators of justice.","pos":""}],"ULEXITE":[{"def":"A mineral occurring in white rounded crystalline masses.","pos":""},{"def":"Muddy; oozy; slimy; also, growing in muddy places.","pos":""}],"ULLAGE":[{"def":"The amount which a vessel, as a cask, of liquor lacks of being full; wantage; deficiency.","pos":""}],"ULLET":[{"def":"A European owl (Syrnium aluco) of a tawny color; -- called also uluia.","pos":""}],"ULLMANNITE":[{"def":"A brittle mineral of a steel-gray color and metallic luster, containing antimony, arsenic, sulphur, and nickel.","pos":""}],"ULMACEOUS":[{"def":"Of or pertaining to a suborder of urticaceous plants, of which the elm is the type.","pos":""}],"ULMATE":[{"def":"A salt of ulmic acid.","pos":""}],"ULMIC":[{"def":"Pertaining to ulmin; designating an acid obtained from ulmin.","pos":""}],"ULMIN":[{"def":"A brown amorphous substance found in decaying vegetation.","pos":""}],"ULMUS":[{"def":"A genus of trees including the elm.","pos":""}],"ULNA":[{"def":"The postaxial bone of the forearm, or branchium, corresponding to the fibula of the hind limb.","pos":""},{"def":"An ell; also, a yard.","pos":""}],"ULNAGE":[{"def":"Measurement by the ell; alnage.","pos":""}],"ULNAR":[{"def":"Of or pertaining to the ulna, or the elbow; as, the ulnar nerve.","pos":""}],"ULNARE":[{"def":"One of the bones or cartilages of the carpus, which articulates with the ulna and corresponds to the cuneiform in man.","pos":""}],"ULODENDRON":[{"def":"A genus of fossil trees.","pos":""}],"ULOID":[{"def":"Resembling a scar; scarlike.","pos":""}],"ULONATA":[{"def":"A division of insects nearly equivalent to the true Orthoptera.","pos":""}],"ULOTRICHAN":[{"def":"Of or pertaining to the Ulotrichi.","pos":""},{"def":"One of the Ulotrichi.","pos":""}],"ULOTRICHI":[{"def":"The division of mankind which embraces the races having woolly or crispy hair.","pos":""}],"ULOTRICHOUS":[{"def":"Having woolly or crispy hair; -- opposed to leiotrichous.","pos":""}],"ULSTER":[{"def":"A long, loose overcoat, worn by men and women, originally made of frieze from Ulster, Ireland.","pos":""}],"ULTERIOR":[{"def":"Situated beyond, or on the farther side; thither; -- correlative with hither.","pos":""},{"def":"Further; remoter; more distant; succeeding; as, ulterior demands or propositions; ulterior views; what ulterior measures will be adopted is uncertain.","pos":""}],"ULTERIORLY":[{"def":"More distantly or remotely.","pos":""}],"ULTIMA":[{"def":"Most remote; furthest; final; last.","pos":""}],"ULTIMATE":[{"def":"Farthest; most remote in space or time; extreme; last; final.","pos":""},{"def":"Last in a train of progression or consequences; tended toward by all that precedes; arrived at, as the last result; final.","pos":""}],"ULTIMATELY":[{"def":"As a final consequence; at last; in the end; as, afflictions often tend to correct immoral habits, and ultimately prove blessings.","pos":""}],"ULTIMATION":[{"def":"State of being ultimate; that which is ultimate, or final; ultimatum.","pos":""}],"ULTIMATUM":[{"def":"A final proposition, concession, or condition; especially, the final propositions, conditions, or terms, offered by either of the parties in a diplomatic negotiation; the most favorable terms a negotiator can offer, the rejection of which usually puts an end to the hesitation.","pos":""}],"ULTIME":[{"def":"Ultimate; final.","pos":""}],"ULTIMITY":[{"def":"The last stage or consequence; finality.","pos":""}],"ULTIMO":[{"def":"In the month immediately preceding the present; as, on the 1st ultimo; -- usually abbreviated to ult.","pos":""}],"ULTION":[{"def":"The act of taking vengeance; revenge.","pos":""}],"ULTRA":[{"def":"Going beyond others, or beyond due limit; extreme; fanatical; uncompromising; as, an ultra reformer; ultra measures.","pos":""}],"ULTRA VIRES":[{"def":"Beyond power; transcending authority; -- a phrase used frequently in relation to acts or enactments by corporations in excess of their chartered or statutory rights.","pos":""}],"ULTRA-":[{"def":"A prefix from the Latin ultra beyond (see Ulterior), having in composition the signification beyond, on the other side, chiefly when joined with words expressing relations of place; as, ultramarine, ultramontane, ultramundane, ultratropical, etc.","pos":""}],"ULTRAGASEOUS":[{"def":"Having the properties exhibited by gases under very low pressures (one millionth of an atmosphere or less).","pos":""}],"ULTRAISM":[{"def":"The principles of those who advocate extreme measures, as radical reform, and the like.","pos":""}],"ULTRAIST":[{"def":"One who pushes a principle or measure to extremes; an extremist; a radical; an ultra.","pos":""}],"ULTRAMARINE":[{"def":"Situated or being beyond the sea.","pos":""}],"ULTRAMONTANE":[{"def":"Being beyond the mountains; specifically, being beyond the Alps, in respect to the one who speaks.","pos":""}],"ULTRAMONTANISM":[{"def":"Ul`tra*mon\"ta*nism, n.","pos":""}],"ULTRAMONTANIST":[{"def":"One who upholds ultramontanism.","pos":""}],"ULTRAMUNDANE":[{"def":"Being beyond the world, or beyond the limits of our system.","pos":""}],"ULTRARED":[{"def":"Situated beyond or below the red rays; as, the ultrated rays of the spectrum, which are less refrangible than the red.","pos":""}],"ULTRATROPICAL":[{"def":"Situated beyond, or outside of, the tropics; extratropical; also, having an excessively tropical temperature; warmer than the tropics.","pos":""}],"ULTRAVIOLET":[{"def":"Lying outside the visible spectrum at its violet end; -- said of rays more refrangible than the extreme violet rays of the spectrum.","pos":""}],"ULTRAZODIACAL":[{"def":"Outside the zodiac; being in that part of the heavens that is more than eight degrees from the ecliptic; as, ultrazodiacal planets, that is, those planets which in part of their orbits go beyond the zodiac.","pos":""}],"ULTRONEOUS":[{"def":"Spontaneous; voluntary.","pos":""}],"ULULA":[{"def":"A genus of owls including the great gray owl (Ulula cinerea) of Arctic America, and other similar species.","pos":""}],"ULULANT":[{"def":"Howling; wailing.","pos":""}],"ULULATE":[{"def":"To howl, as a dog or a wolf; to wail; as, ululating jackals.","pos":""}],"ULULATION":[{"def":"A howling, as of a dog or wolf; a wailing.","pos":""}],"ULVA":[{"def":"A genus of thin papery bright green seaweeds including the kinds called sea lettuce.","pos":""}]}