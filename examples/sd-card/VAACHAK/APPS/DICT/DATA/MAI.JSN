{"MAIAN":[{"def":"Any spider crab of the genus Maia, or family Maiadæ.","pos":""}],"MAID":[{"def":"The female of a ray or skate, esp.","pos":""}],"MAID'S HAIR":[{"def":"The yellow bedstraw (Galium verum).","pos":""}],"MAIDAN":[{"def":"In various parts of Asia, an open space, as for military exercises, or for a market place; an open grassy tract; an esplanade.","pos":""}],"MAIDEN":[{"def":"An unmarried woman; a girl or woman who has not experienced sexual intercourse; a virgin; a maid.","pos":""},{"def":"A female servant.","pos":""}],"MAIDENHAIR":[{"def":"A fern of the genus Adiantum (A.","pos":""}],"MAIDENHEAD":[{"def":"The state of being a maiden; maidenhood; virginity.","pos":""},{"def":"The state of being unused or uncontaminated; freshness; purity.","pos":""}],"MAIDENHOOD":[{"def":"The state of being a maid or a virgin; virginity.","pos":""},{"def":"Newness; freshness; uncontaminated state.","pos":""}],"MAIDENLIKE":[{"def":"Like a maiden; modest; coy.","pos":""}],"MAIDENLINESS":[{"def":"The quality of being maidenly; the behavior that becomes a maid; modesty; gentleness.","pos":""}],"MAIDENLY":[{"def":"Like a maid; suiting a maid; maiden-like; gentle, modest, reserved.","pos":""}],"MAIDMARIAN":[{"def":"The lady of the May games; one of the characters in a morris dance; a May queen.","pos":""},{"def":"A kind of dance.","pos":""}],"MAIDPALE":[{"def":"Pale, like a sick girl.","pos":""}],"MAIDSERVANT":[{"def":"A female servant.","pos":""}],"MAIEUTICS":[{"def":"The art of giving birth (i.","pos":""}],"MAIGRE":[{"def":"Belonging to a fast day or fast; as, a maigre day.","pos":""}],"MAIHEM":[{"def":"See Maim, and Mayhem.","pos":""}],"MAIKEL":[{"def":"A South American carnivore of the genus Conepatus, allied to the skunk, but larger, and having a longer snout.","pos":""}],"MAIKONG":[{"def":"A South American wild dog (Canis cancrivorus); the crab-eating dog.","pos":""}],"MAIL":[{"def":"A small piece of money; especially, an English silver half-penny of the time of Henry V.","pos":""}],"MAILABLE":[{"def":"Admissible lawfully into the mail.","pos":""}],"MAILCLAD":[{"def":"Protected by a coat of mail; clad in armor.","pos":""}],"MAILED":[{"def":"Protected by an external coat, or covering, of scales or plates.","pos":""}],"MAIM":[{"def":"To deprive of the use of a limb, so as to render a person on fighting less able either to defend himself or to annoy his adversary.","pos":""},{"def":"To mutilate; to cripple; to injure; to disable; to impair.","pos":""}],"MAIMEDLY":[{"def":"In a maimed manner.","pos":""}],"MAIMEDNESS":[{"def":"State of being maimed.","pos":""}],"MAIN":[{"def":"A hand or match at dice.","pos":""},{"def":"A stake played for at dice.","pos":""}],"MAIN YARD":[{"def":"The yard on which the mainsail is extended, supported by the mainmast.","pos":""}],"MAIN-GAUCHE":[{"def":"The dagger held in the left hand, while the rapier is held in the right; -- used to parry thrusts of the adversary's rapier.","pos":""}],"MAIN-HAMPER":[{"def":"A hamper to be carried in the hand; a hand basket used in carrying grapes to the press.","pos":""}],"MAINE":[{"def":"One of the New England States.","pos":""}],"MAINLAND":[{"def":"The continent; the principal land; -- opposed to island, or peninsula.","pos":""}],"MAINLY":[{"def":"Very strongly; mightily; to a great degree.","pos":""}],"MAINMAST":[{"def":"The principal mast in a ship or other vessel.","pos":""}],"MAINOR":[{"def":"A thing stolen found on the person of the thief.","pos":""}],"MAINPERNABLE":[{"def":"Capable of being admitted to give surety by mainpernors; able to be mainprised.","pos":""}],"MAINPERNOR":[{"def":"A surety, under the old writ of mainprise, for a prisoner's appearance in court at a day.","pos":""}],"MAINPRISE":[{"def":"To suffer to go at large, on his finding sureties, or mainpernors, for his appearance at a day; -- said of a prisoner.","pos":""}],"MAINS":[{"def":"The farm attached to a mansion house.","pos":""}],"MAINSAIL":[{"def":"The principal sail in a ship or other vessel.","pos":""}],"MAINSHEET":[{"def":"One of the ropes by which the mainsail is hauled aft and trimmed.","pos":""}],"MAINSPRING":[{"def":"The principal or most important spring in a piece of mechanism, especially the moving spring of a watch or clock or the spring in a gunlock which impels the hammer.","pos":""}],"MAINSTAY":[{"def":"The stay extending from the foot of the foremast to the maintop.","pos":""}],"MAINSWEAR":[{"def":"To swear falsely.","pos":""}],"MAINTAIN":[{"def":"To keep possession of; to hold and defend; not to surrender or relinquish.","pos":""}],"MAINTAINABLE":[{"def":"That maybe maintained.","pos":""}],"MAINTAINER":[{"def":"One who maintains.","pos":""}],"MAINTAINOR":[{"def":"One who, not being interested, maintains a cause depending between others, by furnishing money, etc.","pos":""}],"MAINTENANCE":[{"def":"An officious or unlawful intermeddling in a cause depending between others, by assisting either party with money or means to carry it on.","pos":""}],"MAINTOP":[{"def":"The platform about the head of the mainmast in square-rigged vessels.","pos":""}],"MAIOID":[{"def":"Of or pertaining to the genus Maia, or family Maiadeæ.","pos":""}],"MAISTER":[{"def":"Principal; chief.","pos":""},{"def":"Mastery; superiority; art.","pos":""}],"MAIZE":[{"def":"A large species of American grass of the genus Zea (Z.","pos":""}]}