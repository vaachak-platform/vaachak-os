{"TRAVAIL":[{"def":"Labor with pain; severe toil or exertion.","pos":""},{"def":"Parturition; labor; as, an easy travail.","pos":""}],"TRAVAILOUS":[{"def":"Causing travail; laborious.","pos":""}],"TRAVE":[{"def":"A crossbeam; a lay of joists.","pos":""}],"TRAVEL":[{"def":"To labor; to travail.","pos":""},{"def":"To go or march on foot; to walk; as, to travel over the city, or through the streets.","pos":""}],"TRAVEL-TAINTED":[{"def":"Harassed; fatigued with travel.","pos":""}],"TRAVELED":[{"def":"Having made journeys; having gained knowledge or experience by traveling; hence, knowing; experienced.","pos":""}],"TRAVELER":[{"def":"A traveling crane.","pos":""},{"def":"The metal loop which travels around the ring surrounding the bobbin, in a ring spinner.","pos":""}],"TRAVERS":[{"def":"Across; athwart.","pos":""}],"TRAVERSABLE":[{"def":"Capable of being traversed, or passed over; as, a traversable region.","pos":""},{"def":"Deniable; specifically (Law), liable to legal objection; as, a traversable presentment.","pos":""}],"TRAVERSE":[{"def":"Lying across; being in a direction across something else; as, paths cut with traverse trenches.","pos":""}],"TRAVERSE DRILL":[{"def":"A machine tool for drilling slots, in which the work or tool has a lateral motion back and forth; also, a drilling machine in which the spindle holder can be adjusted laterally.","pos":""}],"TRAVERSER":[{"def":"One who traverses, or denies.","pos":""},{"def":"A traverse table.","pos":""}],"TRAVERSING":[{"def":"Adjustable laterally; having a lateral motion, or a swinging motion; adapted for giving lateral motion.","pos":""}],"TRAVERTINE":[{"def":"A white concretionary form of calcium carbonate, usually hard and semicrystalline.","pos":""}],"TRAVESTY":[{"def":"Disguised by dress so as to be ridiculous; travestied; -- applied to a book or shorter composition.","pos":""}],"TRAVOIS":[{"def":"A primitive vehicle, common among the North American Indians, usually two trailing poles serving as shafts and bearing a platform or net for a load.","pos":""}]}