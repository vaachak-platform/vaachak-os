{"GUM":[{"def":"The dense tissues which invest the teeth, and cover the adjacent parts of the jaws.","pos":""}],"GUMBO":[{"def":"A soup thickened with the mucilaginous pods of the okra; okra soup.","pos":""},{"def":"The okra plant or its pods.","pos":""}],"GUMBOIL":[{"def":"A small suppurting inflamed spot on the gum.","pos":""}],"GUMMA":[{"def":"A kind of soft tumor, usually of syphilitic origin.","pos":""}],"GUMMATOUS":[{"def":"Belonging to, or resembling, gumma.","pos":""}],"GUMMER":[{"def":"A punch-cutting tool, or machine for deepening and enlarging the spaces between the teeth of a worn saw.","pos":""}],"GUMMIFEROUS":[{"def":"Producing gum; gum-bearing.","pos":""}],"GUMMINESS":[{"def":"The state or quality of being gummy; viscousness.","pos":""}],"GUMMITE":[{"def":"A yellow amorphous mineral, essentially a hydrated oxide of uranium derived from the alteration of uraninite.","pos":""}],"GUMMOSITY":[{"def":"Gumminess; a viscous or adhesive quality or nature.","pos":""}],"GUMMOUS":[{"def":"Of or pertaining to a gumma.","pos":""}],"GUMMY":[{"def":"Consisting of gum; viscous; adhesive; producing or containing gum; covered with gum or a substance resembling gum.","pos":""}],"GUMP":[{"def":"A dolt; a dunce.","pos":""}],"GUMPTION":[{"def":"Capacity; shrewdness; common sense.","pos":""}]}