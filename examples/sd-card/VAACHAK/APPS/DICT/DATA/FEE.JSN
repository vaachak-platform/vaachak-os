{"FEE":[{"def":"A right to the use of a superior's land, as a stipend for services to be performed; also, the land so held; a fief.","pos":""},{"def":"An estate of inheritance supposed to be held either mediately or immediately from the sovereign, and absolutely vested in the owner.","pos":""}],"FEE-FAW-FUM":[{"def":"A nonsensical exclamation attributed to giants and ogres; hence, any expression calculated to impose upon the timid and ignorant.","pos":""}],"FEEBLE":[{"def":"Deficient in physical strenght; weak; infirm; debilitated.","pos":""},{"def":"Wanting force, vigor, or efficiency in action or expression; not full, loud, bright, strong, rapid, etc.","pos":""}],"FEEBLE-MINDED":[{"def":"Weak in intellectual power; wanting firmness or constancy; irresolute; vacilating; imbecile.","pos":""}],"FEEBLENESS":[{"def":"The quality or condition of being feeble; debility; infirmity.","pos":""}],"FEEBLY":[{"def":"In a feeble manner.","pos":""}],"FEED":[{"def":"To give food to; to supply with nourishment; to satisfy the physical huger of.","pos":""},{"def":"To satisfy; grafity or minister to, as any sense, talent, taste, or desire.","pos":""}],"FEEDER":[{"def":"An auxiliary part of a machine which supplies or leads along the material operated upon.","pos":""},{"def":"A device for supplying steam boilers with water as needed.","pos":""}],"FEEDING":[{"def":"That which is eaten; food.","pos":""},{"def":"That which furnishes or affords food, especially for animals; pasture land.","pos":""}],"FEEL":[{"def":"To perceive by the touch; to take cognizance of by means of the nerves of sensation distributed all over the body, especially by those of the skin; to have sensation excited by contact of (a thing) with the body or limbs.","pos":""},{"def":"To touch; to handle; to examine by touching; as, feel this piece of silk; hence, to make trial of; to test; often with out.","pos":""}],"FEELER":[{"def":"One of the sense organs or certain animals (as insects), which are used in testing objects by touch and in searching for food; an antenna; a palp.","pos":""}],"FEELING":[{"def":"Possessing great sensibility; easily affected or moved; as, a feeling heart.","pos":""},{"def":"Expressive of great sensibility; attended by, or evincing, sensibility; as, he made a feeling representation of his wrongs.","pos":""}],"FEELINGLY":[{"def":"In a feeling manner; pathetically; sympathetically.","pos":""}],"FEERE":[{"def":"A consort, husband or wife; a companion; a fere.","pos":""}],"FEESE":[{"def":"the short run before a leap.","pos":""}],"FEET":[{"def":"Fact; performance.","pos":""}],"FEETLESS":[{"def":"Destitute of feet; as, feetless birds.","pos":""}],"FEEZE":[{"def":"To turn, as a screw.","pos":"verb"},{"def":"To beat; to chastise; to humble; to worry.","pos":"verb"}]}