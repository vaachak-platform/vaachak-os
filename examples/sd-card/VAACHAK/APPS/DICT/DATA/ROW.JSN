{"ROW":[{"def":"Rough; stern; angry.","pos":""}],"ROWABLE":[{"def":"That may be rowed, or rowed upon.","pos":""}],"ROWAN TREE":[{"def":"A european tree (Pyrus aucuparia) related to the apple, but with pinnate leaves and flat corymbs of small white flowers followed by little bright red berries.","pos":""}],"ROWBOAT":[{"def":"A boat designed to be propelled by oars instead of sails.","pos":""}],"ROWDY":[{"def":"One who engages in rows, or noisy quarrels; a ruffianly fellow.","pos":""}],"ROWDYISH":[{"def":"Resembling a rowdy in temper or conduct; characteristic of a rowdy.","pos":""}],"ROWDYISM":[{"def":"the conduct of a rowdy.","pos":""}],"ROWED":[{"def":"Formed into a row, or rows; having a row, or rows; as, a twelve-rowed ear of corn.","pos":""}],"ROWEL":[{"def":"A roll of hair, silk, etc.","pos":""}],"ROWEN":[{"def":"A stubble field left unplowed till late in the autumn, that it may be cropped by cattle.","pos":""},{"def":"The second growth of grass in a season; aftermath.","pos":""}],"ROWER":[{"def":"One who rows with an oar.","pos":""}],"ROWLOCK":[{"def":"A contrivance or arrangement serving as a fulcrum for an oar in rowing.","pos":""}],"ROWPORT":[{"def":"An opening in the side of small vessels of war, near the surface of the water, to facilitate rowing in calm weather.","pos":""}]}