{"GROAN":[{"def":"To give forth a low, moaning sound in breathing; to utter a groan, as in pain, in sorrow, or in derision; to moan.","pos":""},{"def":"To strive after earnestly, as with groans.","pos":""}],"GROAT":[{"def":"An old English silver coin, equal to four pence.","pos":""},{"def":"Any small sum of money.","pos":""}],"GROATS":[{"def":"Dried grain, as oats or wheat, hulled and broken or crushed; in high milling, cracked fragments of wheat larger than grits.","pos":""}],"GROBIAN":[{"def":"A rude or clownish person; boor; lout.","pos":""}],"GROCER":[{"def":"A trader who deals in tea, sugar, spices, coffee, fruits, and various other commodities.","pos":""}],"GROCERY":[{"def":"The commodities sold by grocers, as tea, coffee, spices, etc.","pos":""},{"def":"A retail grocer's shop or store.","pos":""}],"GROG":[{"def":"A mixture of spirit and water not sweetened; hence, any intoxicating liquor.","pos":""}],"GROGGINESS":[{"def":"Tenderness or stiffness in the foot of a horse, which causes him to move in a hobbling manner.","pos":""}],"GROGGY":[{"def":"Moving in a hobbling manner, owing to ten der feet; -- said of a horse.","pos":""},{"def":"A coarse stuff made of silk and mohair, or of coarse silk.","pos":""}],"GROGSHOP":[{"def":"A shop or room where strong liquors are sold and drunk; a dramshop.","pos":""}],"GROIN":[{"def":"The snout of a swine.","pos":""}],"GROINED":[{"def":"Built with groins; as, a groined ceiling; a groined vault.","pos":""}],"GROLIER":[{"def":"The name by which Jean Grolier de Servier (1479-1565), a French bibliophile, is commonly known; -- used in naming a certain style of binding, a design, etc.","pos":""}],"GROMET":[{"def":"Same as Grommet.","pos":""}],"GROMMET":[{"def":"A ring of rope used as a wad to hold a cannon ball in place.","pos":""}],"GROMWELL":[{"def":"A plant of the genus Lithospermum (L.","pos":""}],"GRONTE":[{"def":"Gron\"te, Defn: obs.","pos":""}],"GROOM":[{"def":"A boy or young man; a waiter; a servant; especially, a man or boy who has charge of horses, or the stable.","pos":""},{"def":"One of several officers of the English royal household, chiefly in the lord chamberlain's department; as, the groom of the chamber; the groom of the stole.","pos":""}],"GROOMER":[{"def":"One who, or that which, grooms horses; especially, a brush rotated by a flexible or jointed revolving shaft, for cleaning horses.","pos":""}],"GROOMSMAN":[{"def":"A male attendant of a bridegroom at his wedding; -- the correlative of bridesmaid.","pos":""}],"GROOVE":[{"def":"A shaft or excavation.","pos":""}],"GROOVER":[{"def":"One who or that which grooves.","pos":""}],"GROOVING":[{"def":"The act of forming a groove or grooves; a groove, or collection of grooves.","pos":""}],"GROPE":[{"def":"To feel with or use the hands; to handle.","pos":""},{"def":"To search or attempt to find something in the dark, or, as a blind person, by feeling; to move about hesitatingly, as in darkness or obscurity; to feel one's way, as with the hands, when one can not see.","pos":""}],"GROPER":[{"def":"One who gropes; one who feels his way in the dark, or searches by feeling.","pos":""}],"GROPING-LY":[{"def":"In a groping manner.","pos":""}],"GROS":[{"def":"A heavy silk with a dull finish; as, gros de Naples; gros de Tours.","pos":""}],"GROSBEAK":[{"def":"One of various species of finches having a large, stout beak.","pos":""}],"GROSCHEN":[{"def":"A small silver coin and money of account of Germany, worth about two cents.","pos":""}],"GROSGRAIN":[{"def":"Of a coarse texture; -- applied to silk with a heavy thread running crosswise.","pos":""}],"GROSS":[{"def":"Great; large; bulky; fat; of huge size; excessively large.","pos":""},{"def":"Coarse; rough; not fine or delicate.","pos":""}],"GROSS-HEADED":[{"def":"Thick-skulled; stupid.","pos":""}],"GROSSIFICATION":[{"def":"The swelling of the ovary of plants after fertilization.","pos":""}],"GROSSLY":[{"def":"In a gross manner; greatly; coarsely; without delicacy; shamefully; disgracefully.","pos":""}],"GROSSNESS":[{"def":"The state or quality of being gross; thickness; corpulence; coarseness; shamefulness.","pos":""}],"GROSSULAR":[{"def":"Pertaining too, or resembling, a gooseberry; as, grossular garnet.","pos":""}],"GROSSULARIA":[{"def":"Same as Grossular.","pos":""}],"GROSSULIN":[{"def":"A vegetable jelly, resembling pectin, found in gooseberries (Ribes Grossularia) and other fruits.","pos":""}],"GROT":[{"def":"GROT; GROTE Grot, Grote (, n.","pos":""}],"GROTESQUE":[{"def":"Like the figures found in ancient grottoes; grottolike; wildly or strangely formed; whimsical; extravagant; of irregular forms and proportions; fantastic; ludicrous; antic.","pos":""}],"GROTESQUELY":[{"def":"In a grotesque manner.","pos":""}],"GROTESQUENESS":[{"def":"Quality of being grotesque.","pos":""}],"GROTESQUERY":[{"def":"Grotesque action, speech, or manners; grotesque doings.","pos":""}],"GROTTO":[{"def":"A natural covered opening in the earth; a cave; also, an artificial recess, cave, or cavernlike apartment.","pos":""}],"GROTTO-WORK":[{"def":"Artificial and ornamental rockwork in imitation of a grotto.","pos":""}],"GROUND":[{"def":"A floor or pavement supposed to rest upon the earth.","pos":""},{"def":"A gummy composition spread over the surface of a metal to be etched, to prevent the acid from eating except where an opening is made by the needle.","pos":""}],"GROUNDAGE":[{"def":"A local tax paid by a ship for the ground or space it occupies while in port.","pos":""}],"GROUNDEDLY":[{"def":"In a grounded or firmly established manner.","pos":""}],"GROUNDING":[{"def":"The act, method, or process of laying a groundwork or foundation; hence, elementary instruction; the act or process of applying a ground, as of color, to wall paper, cotton cloth, etc.","pos":""}],"GROUNDLESS":[{"def":"Without ground or foundation; wanting cause or reason for support; not authorized; false; as, groundless fear; a groundless report or assertion.","pos":""}],"GROUNDLING":[{"def":"A fish that keeps at the bottom of the water, as the loach.","pos":""}],"GROUNDLY":[{"def":"Solidly; deeply; thoroughly.","pos":""}],"GROUNDSEL":[{"def":"An annual composite plant (Senecio vulgaris) one of the most common, and widely distributed weeds on the globe.","pos":""}],"GROUNDWORK":[{"def":"That which forms the foundation or support of anything; the basis; the essential or fundamental part; first principle.","pos":""}],"GROUP":[{"def":"A variously limited assemblage of animals or planta, having some resemblance, or common characteristics in form or structure.","pos":""},{"def":"A number of eighth, sixteenth, etc.","pos":""}],"GROUPER":[{"def":"Epinephelus, of the family Serranidæ, as the red grouper, or brown snapper (E.","pos":""}],"GROUPING":[{"def":"The disposal or relative arrangement of figures or objects, as in, drawing, painting, and sculpture, or in ornamental design.","pos":""}],"GROUSE":[{"def":") Any of the numerous species of gallinaceous birds of the family Tetraonidæ, and subfamily Tetraoninæ, inhabiting Europe, Asia, and North America.","pos":""}],"GROUSER":[{"def":"(Dredging, Pile Driving, etc.","pos":""}],"GROUT":[{"def":"Lees; dregs; grounds.","pos":""}],"GROUTING":[{"def":"The process of filling in or finishing with grout; also, the grout thus filled in.","pos":""}],"GROUTNOL":[{"def":"Same as Growthead.","pos":""}],"GROUTY":[{"def":"Cross; sulky; sullen.","pos":""}],"GROVE":[{"def":"The original sense seems to have been a lane cut through trees.","pos":""}],"GROVEL":[{"def":"To creep on the earth, or with the face to the ground; to lie prone, or move uneasily with the body prostrate on the earth; to lie fiat on one's belly, expressive of abjectness; to crawl.","pos":""},{"def":"To tend toward, or delight in, what is sensual or base; to be low, abject, or mean.","pos":""}],"GROVELER":[{"def":"One who grovels; an abject wretch.","pos":""}],"GROVELING":[{"def":"Lying prone; low; debased.","pos":""}],"GROVY":[{"def":"Pertaining to, or resembling, a grove; situated in, or frequenting, groves.","pos":""}],"GROW":[{"def":"To increase in size by a natural and organic process; to increase in bulk by the gradual assimilation of new matter into the living organism; -- said of animals and vegetables and their organs.","pos":""},{"def":"To increase in any way; to become larger and stronger; to be augmented; to advance; to extend; to wax; to accrue.","pos":""}],"GROWABLE":[{"def":"Capable of growth.","pos":""}],"GROWAN":[{"def":"A decomposed granite, forming a mass of gravel, as in tin lodes in Cornwall.","pos":""}],"GROWER":[{"def":"One who grows or produces; as, a grower of corn; also, that which grows or increases; as, a vine may be a rank or a slow grower.","pos":""}],"GROWL":[{"def":"To utter a deep guttural sound, sa an angry dog; to give forth an angry, grumbling sound.","pos":""}],"GROWLER":[{"def":"The large-mouthed black bass.","pos":""}],"GROWLINGLY":[{"def":"In a growling manner.","pos":""}],"GROWSE":[{"def":"To shiver; to have chills.","pos":""}],"GROWTH":[{"def":"The process of growing; the gradual increase of an animal or a vegetable body; the development from a seed, germ, or root, to full size or maturity; increase in size, number, frequency, strength, etc.","pos":""},{"def":"That which has grown or is growing; anything produced; product; consequence; effect; result.","pos":""}],"GROWTHEAD":[{"def":"A lazy person; a blockhead.","pos":""}],"GROWTHFUL":[{"def":"Having capacity of growth.","pos":""}],"GROZING IRON":[{"def":"A tool for smoothing the solder joints of lead pipe.","pos":""}]}