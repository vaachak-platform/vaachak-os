{"ANKER":[{"def":"A liquid measure in various countries of Europe.","pos":""}],"ANKERITE":[{"def":"A mineral closely related to dolomite, but containing iron.","pos":""}],"ANKH":[{"def":"A tau cross with a loop at the top, used as an attribute or sacred emblem, symbolizing generation or enduring life.","pos":""}],"ANKLE":[{"def":"The joint which connects the foot with the leg; the tarsus.","pos":""}],"ANKLED":[{"def":"Having ankles; -- used in composition; as, well-ankled.","pos":""}],"ANKLET":[{"def":"An ornament or a fetter for the ankle; an ankle ring.","pos":""}],"ANKUS":[{"def":"An elephant goad with a sharp spike and hook, resembling a short-handled boat hook.","pos":""}],"ANKYLOSE":[{"def":"Same as Anchylose.","pos":""}],"ANKYLOSIS":[{"def":"Same as Anchylosis.","pos":""}],"ANKYLOSTOMIASIS":[{"def":"A disease due to the presence of the parasites Agchylostoma duodenale, Uncinaria (subgenus Necator) americana, or allied nematodes, in the small intestine.","pos":""}]}