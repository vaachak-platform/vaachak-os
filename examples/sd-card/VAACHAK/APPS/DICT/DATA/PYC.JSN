{"PYCNASPIDEAN":[{"def":"Having the posterior side of the tarsus covered with small irregular scales; -- said of certain birds.","pos":""}],"PYCNIDIUM":[{"def":"In certain fungi, a flask-shaped cavity from the surface of the inner walls of which spores are produced.","pos":""}],"PYCNITE":[{"def":"A massive subcolumnar variety of topaz.","pos":""}],"PYCNODONT":[{"def":"Any fossil fish belonging to the Pycnodontini.","pos":""}],"PYCNODONTINI":[{"def":"An extinct order of ganoid fishes.","pos":""}],"PYCNOGONID":[{"def":"One of the Pycnogonida.","pos":""}],"PYCNOGONIDA":[{"def":"A class of marine arthropods in which the body is small and thin, and the eight legs usually very long; -- called also Pantopoda.","pos":""}],"PYCNOMETER":[{"def":"A specific gravity bottle; a standard flask for measuring and comparing the densities of liquids.","pos":""}],"PYCNOSTYLE":[{"def":"See under Intercolumniation.","pos":""},{"def":"A pycnostyle colonnade.","pos":""}]}