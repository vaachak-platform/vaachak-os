{"PROCACIOUS":[{"def":"Pert; petulant; forward; saucy.","pos":""}],"PROCACITY":[{"def":"Forwardness; pertness; petulance.","pos":""}],"PROCAMBIUM":[{"def":"The young tissue of a fibrovascular bundle before its component cells have begun to be differentiated.","pos":""}],"PROCATARCTIC":[{"def":"Beginning; predisposing; exciting; initial.","pos":""}],"PROCATARXIS":[{"def":"The kindling of a disease into action; also, the procatarctic cause.","pos":""}],"PROCEDURE":[{"def":"The act or manner of proceeding or moving forward; progress; process; operation; conduct.","pos":""},{"def":"A step taken; an act performed; a proceeding; the steps taken in an action or other legal proceeding.","pos":""}],"PROCEED":[{"def":"To begin and carry on a legal process.","pos":""}],"PROCEEDER":[{"def":"One who proceeds.","pos":""}],"PROCEEDING":[{"def":"The course of procedure in the prosecution of an action at law.","pos":""}],"PROCEEDS":[{"def":"That which comes forth or results; effect; yield; issue; product; sum accruing from a sale, etc.","pos":""}],"PROCELEUSMATIC":[{"def":"Consisting of four short syllables; composed of feet of four short syllables each.","pos":""}],"PROCELLARIAN":[{"def":"One of a family of oceanic birds (Procellaridæ) including the petrels, fulmars, and shearwaters.","pos":""}],"PROCEPHALIC":[{"def":"Pertaining to, or forming, the front of the head.","pos":""}],"PROCERE":[{"def":"Of high stature; tall.","pos":""}],"PROCEREBRUM":[{"def":"The prosencephalon.","pos":""}],"PROCERES":[{"def":"An order of large birds; the Ratitæ; -- called also Proceri.","pos":""}],"PROCERITE":[{"def":"The segment next to the flagellum of the antennæ of Crustacea.","pos":""}],"PROCERITY":[{"def":"Height of stature; tallness.","pos":""}],"PROCES VERBAL":[{"def":"An authentic minute of an official act, or statement of facts.","pos":""}],"PROCESS":[{"def":"Any marked prominence or projecting part, especially of a bone; anapophysis.","pos":""},{"def":"The whole course of proceedings in a cause real or personal, civil or criminal, from the beginning to the end of the suit; strictly, the means used for bringing the defendant into court to answer to the action; -- a generic term for writs of the class called judicial.","pos":""}],"PROCESSION":[{"def":"An orderly and ceremonial progress of persons, either from the sacristy to the choir, or from the choir around the church, within or without.","pos":""},{"def":"An old term for litanies which were said in procession and not kneeling.","pos":""}],"PROCESSIONAL":[{"def":"Of or pertaining to a procession; consisting in a procession.","pos":""}],"PROCESSIONALIST":[{"def":"One who goes or marches in a procession.","pos":""}],"PROCESSIONARY":[{"def":"Pertaining to a procession; consisting in processions; as, processionary service.","pos":""}],"PROCESSIONER":[{"def":"One who takes part in a procession.","pos":""},{"def":"A manual of processions; a processional.","pos":""}],"PROCESSIONING":[{"def":"A proceeding prescribed by statute for ascertaining and fixing the boundaries of land.","pos":""}],"PROCESSIVE":[{"def":"Proceeding; advancing.","pos":""}],"PROCHORDAL":[{"def":"Situated in front of the notochord; -- applied especially to parts of the cartilaginous rudiments in the base of the skull.","pos":""}],"PROCHRONISM":[{"def":"The dating of an event before the time it happened; an antedating; -- opposed to Ant: metachronism.","pos":""}],"PROCHRONIZE":[{"def":"A falling down; a prolapsus.","pos":""}],"PROCIDUOUS":[{"def":"Falling from its proper place.","pos":""}],"PROCINCT":[{"def":"A state of complete readiness for action.","pos":""}],"PROCLAIM":[{"def":"To make known by public announcement; to give wide publicity to; to publish abroad; to promulgate; to declare; as, to proclaim war or peace.","pos":""},{"def":"To outlaw by public proclamation.","pos":""}],"PROCLAIMER":[{"def":"One who proclaims.","pos":""}],"PROCLAMATION":[{"def":"The act of proclaiming; official or general notice; publication.","pos":""},{"def":"That which is proclaimed, publicly announced, or officially declared; a published ordinance; as, the proclamation of a king; a Thanksgiving proclamation.","pos":""}],"PROCLITIC":[{"def":"Leaning forward; -- said of certain monosyllabic words which are so closely attached to the following word as not to have a separate accent.","pos":""}],"PROCLIVE":[{"def":"Having a tendency by nature; prone; proclivous.","pos":""}],"PROCLIVITY":[{"def":"Inclination; propensity; proneness; tendency.","pos":""},{"def":"Readiness; facility; aptitude.","pos":""}],"PROCLIVOUS":[{"def":"Having the incisor teeth directed forward.","pos":""}],"PROCOELE":[{"def":"A lateral cavity of the prosencephalon; a lateral ventricle of the brain.","pos":""}],"PROCOELIA":[{"def":"Same as Procoele.","pos":""}],"PROCOELIAN":[{"def":"Concave in front; as, procoelian vertebræ, which have the anterior end of the centra concave and the posterior convex.","pos":""}],"PROCOELOUS":[{"def":"Same as Procoelian.","pos":""}],"PROCONSUL":[{"def":"An officer who discharged the duties of a consul without being himself consul; a governor of, or a military commander in, a province.","pos":""}],"PROCONSULATE":[{"def":"The office jurisdiction of a proconsul, or the term of his office.","pos":""}],"PROCRASTINATE":[{"def":"To put off till to-morrow, or from day to day; to defer; to postpone; to delay; as, to procrastinate repentance.","pos":""}],"PROCRASTINATION":[{"def":"The act or habit of procrastinating, or putting off to a future time; delay; dilatoriness.","pos":""}],"PROCRASTINATOR":[{"def":"One who procrastinates, or defers the performance of anything.","pos":""}],"PROCRASTINATORY":[{"def":"Of or pertaining to procrastination; dilatory.","pos":""}],"PROCRASTINE":[{"def":"To procrastinate.","pos":""}],"PROCREANT":[{"def":"Generating; producing; productive; fruitful; assisting in procreation.","pos":""}],"PROCREATE":[{"def":"To generate and produce; to beget; to engender.","pos":""}],"PROCREATION":[{"def":"The act of begetting; generation and production of young.","pos":""}],"PROCREATIVE":[{"def":"Having the power to beget; generative.","pos":""}],"PROCREATIVENESS":[{"def":"The power of generating.","pos":""}],"PROCREATOR":[{"def":"One who begets; a father or sire; a generator.","pos":""}],"PROCRIS":[{"def":"Any species of small moths of the genus Procris.","pos":""}],"PROCRUSTEAN":[{"def":"Of or pertaining to Procrustes, or the mode of torture practiced by him; producing conformity by violent means; as, the Procrustean treatment; a Procrustean limit.","pos":""}],"PROCRUSTEANIZE":[{"def":"To stretch or contract according to some rule or standard.","pos":""}],"PROCRUSTES":[{"def":"A celebrated legendary highwayman of Attica, who tied his victims upon an iron bed, and, as the case required, either stretched or cut of their legs to adapt them to its length; -- whence the metaphorical phrase, the bed of Procrustes.","pos":""}],"PROCRUSTESIAN":[{"def":"See Procrustean.","pos":""}],"PROCTITIS":[{"def":"Inflammation of the rectum.","pos":""}],"PROCTOCELE":[{"def":"Inversion and prolapse of the mucous coat of the rectum, from relaxation of the sphincter, with more or less swelling; prolapsus ani.","pos":""}],"PROCTOR":[{"def":"One who is employed to manage to affairs of another.","pos":""}],"PROCTORAGE":[{"def":"Management by a proctor, or as by a proctor; hence, control; superintendence; -- in contempt.","pos":""}],"PROCTORIAL":[{"def":"Of or pertaining to a proctor, esp.","pos":""}],"PROCTORSHIP":[{"def":"The office or dignity of a proctor; also, the term of his office.","pos":""}],"PROCTOTOMY":[{"def":"An incision into the rectum, as for the division of a stricture.","pos":""}],"PROCUMBENT":[{"def":"Lying on the ground, but without putting forth roots; trailing; prostrate; as, a procumbent stem.","pos":""}],"PROCURABLE":[{"def":"Capable of being procured; obtainable.","pos":""}],"PROCURACY":[{"def":"The office or act of a proctor or procurator; management for another.","pos":""},{"def":"Authority to act for another; a proxy.","pos":""}],"PROCURATION":[{"def":"A sum of money paid formerly to the bishop or archdeacon, now to the ecclesiastical commissioners, by an incumbent, as a commutation for entertainment at the time of visitation; -- called also proxy.","pos":""}],"PROCURATOR":[{"def":"One who manages another's affairs, either generally or in a special matter; an agent; a proctor.","pos":""},{"def":"A governor of a province under the emperors; also, one who had charge of the imperial revenues in a province; as, the procurator of Judea.","pos":""}],"PROCURATORIAL":[{"def":"Of or pertaining to a procurator, or proctor; made by a proctor.","pos":""}],"PROCURATORSHIP":[{"def":"The office or term of a procurator.","pos":""}],"PROCURATORY":[{"def":"Tending to, or authorizing, procuration.","pos":""}],"PROCURE":[{"def":"To bring into possession; to cause to accrue to, or to come into possession of; to acquire or provide for one's self or for another; to gain; to get; to obtain by any means, as by purchase or loan.","pos":""},{"def":"To contrive; to bring about; to effect; to cause.","pos":""}],"PROCUREMENT":[{"def":"The act of procuring or obtaining; obtainment; attainment.","pos":""},{"def":"Efficient contrivance; management; agency.","pos":""}],"PROCURER":[{"def":"One who procures, or obtains; one who, or that which, brings on, or causes to be done, esp.","pos":""},{"def":"One who procures the gratification of lust for another; a pimp; a pander.","pos":""}],"PROCURESS":[{"def":"A female procurer, or pander.","pos":""}],"PROCYON":[{"def":"a star of the first magnitude in the constellation Canis Minor, or the Little Dog.","pos":""},{"def":"A genus of mammals including the raccoon.","pos":""}]}