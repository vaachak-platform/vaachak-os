{"MARS":[{"def":"The god of war and husbandry.","pos":""},{"def":"One of the planets of the solar system, the fourth in order from the sun, or the next beyond the earth, having a diameter of about 4,200 miles, a period of 687 days, and a mean distance of 141,000,000 miles.","pos":""}],"MARSALA":[{"def":"A kind of wine exported from Marsala in Sicily.","pos":""}],"MARSDENIA":[{"def":"A genus of plants of the Milkweed family, mostly woody climbers with fragrant flowers, several species of which furnish valuable fiber, and one species (Marsdenia tinctoria) affords indigo.","pos":""},{"def":"Of or pertaining to Marseilles, in France, or to its inhabitants.","pos":""}],"MARSEILLES":[{"def":"A general term for certain kinds of fabrics, which are formed of two series of threads interlacing each other, thus forming double cloth, quilted in the loom; -- so named because first made in Marseilles, France.","pos":""}],"MARSH":[{"def":"A tract of soft wet land, commonly covered partially or wholly with water; a fen; a swamp; a morass.","pos":""}],"MARSH MARIGOLD":[{"def":"Marsh mar\"i*gold Defn: .","pos":""}],"MARSHAL":[{"def":"Originally, an officer who had the care of horses; a groom.","pos":""},{"def":"An officer of high rank, charged with the arrangement of ceremonies, the conduct of operations, or the like; as, specifically: (a) One who goes before a prince to declare his coming and provide entertainment; a harbinger; a pursuivant.","pos":""}],"MARSHALER":[{"def":"One who marshals.","pos":""}],"MARSHALING":[{"def":"The arrangement of an escutcheon to exhibit the alliances of the owner.","pos":""}],"MARSHALSEA":[{"def":"The court or seat of a marshal; hence, the prison in Southwark, belonging to the marshal of the king's household.","pos":""}],"MARSHALSHIP":[{"def":"The office of a marshal.","pos":""}],"MARSHINESS":[{"def":"The state or condition of being marshy.","pos":""}],"MARSHY":[{"def":"Resembling a marsh; wet; boggy; fenny.","pos":""},{"def":"Pertaining to, or produced in, marshes; as, a marshy weed.","pos":""}],"MARSIPOBRANCH":[{"def":"One of the Marsipobranchia.","pos":""}],"MARSIPOBRANCHIA":[{"def":"A class of Vertebrata, lower than fishes, characterized by their purselike gill cavities, cartilaginous skeletons, absence of limbs, and a suckerlike mouth destitute of jaws.","pos":""}],"MARSUPIAL":[{"def":"Having a pouch for carrying the immature young; of or pertaining to the Marsupialia.","pos":""},{"def":"Of or pertaining to a marsupium; as, the marsupial bones.","pos":""}],"MARSUPIALIA":[{"def":"A subclass of Mammalia, including nearly all the mammals of Australia and the adjacent islands, together with the opossums of America.","pos":""},{"def":"One of the Marsupialia.","pos":""}],"MARSUPIATE":[{"def":"Related to or resembling the marsupials; furnished with a pouch for the young, as the marsupials, and also some fishes and Crustacea.","pos":""}],"MARSUPION":[{"def":"Same as Marsupium.","pos":""}],"MARSUPITE":[{"def":"A fossil crinoid of the genus Marsupites, resembling a purse in form.","pos":""}]}