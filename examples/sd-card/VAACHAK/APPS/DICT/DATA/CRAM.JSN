{"CRAM":[{"def":"To press, force, or drive, particularly in filling, or in thrustung one thing into another; to stuff; to crowd; to fill to superfluity; as, to cram anything into a basket; to cram a room with people.","pos":""},{"def":"To fill with food to satiety; to stuff.","pos":""}],"CRAMBO":[{"def":"A game in which one person gives a word, to which another finds a rhyme.","pos":""},{"def":"A werd rhyming with another word.","pos":""}],"CRAMMER":[{"def":"One who crams; esp.","pos":""}],"CRAMP":[{"def":"A device, usually of iron bent at the ends, used to hold together blocks of stone, timbers, etc.","pos":""},{"def":"A rectangular frame, with a tightening screw, used for compressing the jionts of framework, etc.","pos":""}],"CRAMPET":[{"def":"A cramp iron or cramp ring; a chape, as of a scabbard.","pos":""}],"CRAMPFISH":[{"def":"The torpedo, or electric ray, the touch of which gives an electric shock.","pos":""}],"CRAMPONEE":[{"def":"Having a cramp or square piece at the end; -- said of a cross so furnished.","pos":""}],"CRAMPOONS":[{"def":"A clutch formed of hooked pieces of iron, like double calipers, for raising stones, lumber, blocks of ice, etc.","pos":""},{"def":"Iron insruments with sharp points, worn on the shoes to assist in gaining or keeping a foothold.","pos":""}],"CRAMPY":[{"def":"A measure for fresh herrings, -- as many as will fill a barrel.","pos":""}]}