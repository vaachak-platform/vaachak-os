{"FLIBBERTIGIBBET":[{"def":"Flib\"ber*ti*gib`bet, n.","pos":""}],"FLIBUSTIER":[{"def":"A buccaneer; an American pirate.","pos":""}],"FLICK":[{"def":"To whip lightly or with a quick jerk; to flap; as, to flick a horse; to flick the dirt from boots.","pos":""}],"FLICKER":[{"def":"To flutter; to flap the wings without flying.","pos":""},{"def":"To waver unsteadily, like a flame in a current of air, or when about to expire; as, the flickering light.","pos":""}],"FLICKERINGLY":[{"def":"In a flickering manner.","pos":""}],"FLICKERMOUSE":[{"def":"See Flittermouse.","pos":""}],"FLIDGE":[{"def":"Fledged; fledge.","pos":""}],"FLIER":[{"def":"One who flies or flees; a runaway; a fugitive.","pos":""}],"FLIGHT":[{"def":"The act or flying; a passing through the air by the help of wings; volitation; mode or style of flying.","pos":""},{"def":"The act of fleeing; the act of running away, to escape or expected evil; hasty departure.","pos":""}],"FLIGHT-SHOT":[{"def":"The distance to which an arrow or flight may be shot; bowshot, -- about the fifth of a mile.","pos":""}],"FLIGHTED":[{"def":"Feathered; -- said of arrows.","pos":""}],"FLIGHTER":[{"def":"A horizontal vane revolving over the surface of wort in a cooler, to produce a circular current in the liquor.","pos":""}],"FLIGHTILY":[{"def":"In a flighty manner.","pos":""}],"FLIGHTINESS":[{"def":"The state or quality of being flighty.","pos":""}],"FLIGHTY":[{"def":"Fleeting; swift; transient.","pos":""},{"def":"Indulging in flights, or wild and unrestrained sallies, of imagination, humor, caprice, etc.","pos":""}],"FLIMFLAM":[{"def":"A freak; a trick; a lie.","pos":""}],"FLIMSILY":[{"def":"In a flimsy manner.","pos":""}],"FLIMSINESS":[{"def":"The state or quality of being flimsy.","pos":""}],"FLIMSY":[{"def":"Weak; feeble; limp; slight; vain; without strength or solidity; of loose and unsubstantial structure; without reason or plausibility; as, a flimsy argument, excuse, objection.","pos":""}],"FLINCH":[{"def":"To let the foot slip from a ball, when attempting to give a tight croquet.","pos":""}],"FLINCHER":[{"def":"One who flinches or fails.","pos":""}],"FLINCHINGLY":[{"def":"In a flinching manner.","pos":""}],"FLINDERMOUSE":[{"def":"A bat; a flittermouse.","pos":"noun"}],"FLINDERS":[{"def":"Small pieces or splinters; fragments.","pos":""}],"FLING":[{"def":"To cast, send, to throw from the hand; to hurl; to dart; to emit with violence as if thrown from the hand; as, to fing a stone into the pond.","pos":""},{"def":"To shed forth; to emit; to scatter.","pos":""}],"FLINGDUST":[{"def":"One who kicks up the dust; a streetwalker; a low manner.","pos":""}],"FLINGER":[{"def":"One who flings; one who jeers.","pos":""}],"FLINT":[{"def":"A massive, somewhat impure variety of quartz, in color usually of a gray to brown or nearly black, breaking with a conchoidal fracture and sharp edge.","pos":""}],"FLINT GLASS":[{"def":"A soft, heavy, brilliant glass, consisting essentially of a silicate of lead and potassium.","pos":""}],"FLINTINESS":[{"def":"The state or quality of being flinty; hardness; cruelty.","pos":""}],"FLINTLOCK":[{"def":"A lock for a gun or pistol, having a flint fixed in the hammer, which on stricking the steel ignites the priming.","pos":""},{"def":"A hand firearm fitted with a flintlock; esp.","pos":""}],"FLINTWARE":[{"def":"A superior kind of earthenware into whose composition flint enters largely.","pos":""}],"FLINTWOOD":[{"def":"An Australian name for the very hard wood of the Eucalyptus piluralis.","pos":""}],"FLINTY":[{"def":"Consisting of, composed of, abounding in, or resembling, flint; as, a flinty rock; flinty ground; a flinty heart.","pos":""}],"FLIP":[{"def":"A mixture of beer, spirit, etc.","pos":""}],"FLIP-FLAP":[{"def":"The repeated stroke of something long and loose.","pos":""}],"FLIPE":[{"def":"To turn inside out, or with the leg part back over the foot, as a stocking in pulling off or for putting on.","pos":""}],"FLIPPANCY":[{"def":"The state or quality of being flippant.","pos":"noun"}],"FLIPPANT":[{"def":"Of smooth, fluent, and rapid speech; speaking with ease and rapidity; having a voluble tongue; talkative.","pos":""},{"def":"Speaking fluently and confidently, without knowledge or consideration; empty; trifling; inconsederate; pert; petulant.","pos":""}],"FLIPPANTLY":[{"def":"In a flippant manner.","pos":""}],"FLIPPANTNESS":[{"def":"State or quality of being flippant.","pos":""}],"FLIPPER":[{"def":"A broad flat limb used for swimming, as those of seals, sea turtles, whales, etc.","pos":""}],"FLIRT":[{"def":"To throw with a jerk or quick effort; to fling suddenly; as, they flirt water in each other's faces; he flirted a glove, or a handkerchief.","pos":""},{"def":"To toss or throw about; to move playfully to and fro; as, to flirt a fan.","pos":""}],"FLIRT-GILL":[{"def":"A woman of light behavior; a gill-flirt.","pos":""}],"FLIRTATION":[{"def":"Playing at courtship; coquerty.","pos":""}],"FLIRTIGIG":[{"def":"A wanton, pert girl.","pos":""}],"FLIRTINGLY":[{"def":"In a flirting manner.","pos":""}],"FLISK":[{"def":"To frisk; to skip; to caper.","pos":""}],"FLIT":[{"def":"To move with celerity through the air; to fly away with a rapid motion; to dart along; to fleet; as, a bird flits away; a cloud flits along.","pos":""},{"def":"To flutter; to rove on the wing.","pos":""}],"FLITCH":[{"def":"The side of a hog salted and cured; a side of bacon.","pos":""},{"def":"One of several planks, smaller timbers, or iron plates, which are secured together, side by side, to make a large girder or built beam.","pos":""}],"FLITE":[{"def":"To scold; to quarrel.","pos":""},{"def":"Strife; dispute; abusive or upbraiding talk, as in fliting; wrangling.","pos":""}],"FLITTER":[{"def":"To flutter; to move quickly; as, to flitter the cards.","pos":""}],"FLITTERMOUSE":[{"def":"A bat; -- called also flickermouse, flindermouse, and flintymouse.","pos":"verb"}],"FLITTERN":[{"def":"A term applied to the bark obtained from young oak trees.","pos":""}],"FLITTINESS":[{"def":"Unsteadiness; levity; lightness.","pos":""}],"FLITTING":[{"def":"Contention; strife; scolding; specif.","pos":""}],"FLITTINGLY":[{"def":"In a flitting manner.","pos":""}],"FLITTY":[{"def":"Unstable; fluttering.","pos":""}],"FLIX":[{"def":"The flux; dysentery.","pos":""}]}