{"ELEUSINIAN":[{"def":"Pertaining to Eleusis, in Greece, or to secret rites in honor of Ceres, there celebrated; as, Eleusinian mysteries or festivals.","pos":""}],"ELEUTHERO-PETALOUS":[{"def":"Having the petals free, that is, entirely separate from each other; -- said of both plant and flower.","pos":""}],"ELEUTHEROMANIA":[{"def":"A mania or frantic zeal for freedom.","pos":""}],"ELEUTHEROMANIAC":[{"def":"Mad for freedom.","pos":""}]}