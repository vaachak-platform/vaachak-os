{"ACCLAIM":[{"def":"To declare by acclamations.","pos":""}],"ACCLAIMER":[{"def":"One who acclaims.","pos":""}],"ACCLAMATION":[{"def":"A representation, in sculpture or on medals, of people expressing joy.","pos":""}],"ACCLAMATORY":[{"def":"Pertaining to, or expressing approval by, acclamation.","pos":""}],"ACCLIMATABLE":[{"def":"Capable of being acclimated.","pos":""}],"ACCLIMATATION":[{"def":"Acclimatization.","pos":""}],"ACCLIMATE":[{"def":"To habituate to a climate not native; to acclimatize.","pos":""}],"ACCLIMATION":[{"def":"The process of becoming, or the state of being, acclimated, or habituated to a new climate; acclimatization.","pos":""}],"ACCLIMATIZABLE":[{"def":"Capable of being acclimatized.","pos":""}],"ACCLIMATIZATION":[{"def":"The act of acclimatizing; the process of inuring to a new climate, or the state of being so inured.","pos":""}],"ACCLIMATIZE":[{"def":"To inure or habituate to a climate different from that which is natural; to adapt to the peculiarities of a foreign or strange climate; said of man, the inferior animals, or plants.","pos":""}],"ACCLIMATURE":[{"def":"The act of acclimating, or the state of being acclimated.","pos":""}],"ACCLIVITY":[{"def":"A slope or inclination of the earth, as the side of a hill, considered as ascending, in opposition to declivity, or descending; an upward slope; ascent.","pos":""}],"ACCLIVOUS":[{"def":"Sloping upward; rising as a hillside; -- opposed to declivous.","pos":""}],"ACCLOY":[{"def":"To fill to satiety; to stuff full; to clog; to overload; to burden.","pos":""}]}