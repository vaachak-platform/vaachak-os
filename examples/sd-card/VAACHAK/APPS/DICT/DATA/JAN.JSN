{"JAN":[{"def":"One of intermediate order between angels and men.","pos":""}],"JANE":[{"def":"A coin of Genoa; any small coin.","pos":""},{"def":"A kind of twilled cotton cloth.","pos":""}],"JANE-OF-APES":[{"def":"A silly, pert girl; -- corresponding to jackanapes.","pos":""}],"JANGLE":[{"def":"To sound harshly or discordantly, as bells out of tune.","pos":""},{"def":"To talk idly; to prate; to babble; to chatter; to gossip.","pos":""}],"JANGLER":[{"def":"An idle talker; a babbler; a prater.","pos":""},{"def":"A wrangling, noisy fellow.","pos":""}],"JANGLERESS":[{"def":"A female prater or babbler.","pos":""}],"JANGLING":[{"def":"Producing discordant sounds.","pos":""}],"JANITOR":[{"def":"A door-keeper; a porter; one who has the care of a public building, or a building occupied for offices, suites of rooms, etc.","pos":""},{"def":"A female janitor.","pos":""}],"JANIZARIAN":[{"def":"Of or pertaining to the janizaries, or their government.","pos":""}],"JANIZARY":[{"def":"A soldier of a privileged military class, which formed the nucleus of the Turkish infantry, but was suppressed in 1826.","pos":""}],"JANKER":[{"def":"A long pole on two wheels, used in hauling logs.","pos":""}],"JANSENISM":[{"def":"The doctrine of Jansen regarding free will and divine grace.","pos":""}],"JANSENIST":[{"def":"A follower of Cornelius Jansen, a Roman Catholic bishop of Ypres, in Flanders, in the 17th century, who taught certain doctrines denying free will and the possibility of resisting divine grace.","pos":""}],"JANTU":[{"def":"A machine of great antiquity, used in Bengal for raising water to irrigate land.","pos":""}],"JANUARY":[{"def":"The first month of the year, containing thirty-one days.","pos":""}],"JANUS":[{"def":"A Latin deity represented with two faces looking in opposite directions.","pos":""}],"JANUS-FACED":[{"def":"Double-faced; deceitful.","pos":""}]}