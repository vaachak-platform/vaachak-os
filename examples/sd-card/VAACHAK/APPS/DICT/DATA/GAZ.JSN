{"GAZE":[{"def":"To fixx the eyes in a steady and earnest look; to look with eagerness or curiosity, as in admiration, astonishment, or with studious attention.","pos":""}],"GAZEEBO":[{"def":"A summerhouse so situated as to command an extensive prospect.","pos":""}],"GAZEHOUND":[{"def":"A hound that pursues by the sight rather than by the scent.","pos":""}],"GAZEL":[{"def":"The black currant; also, the wild plum.","pos":""}],"GAZELLE":[{"def":"One of several small, swift, elegantly formed species of antelope, of the genus Gazella, esp.","pos":""}],"GAZET":[{"def":"A Venetian coin, worth about three English farthings, or one and a half cents.","pos":""}],"GAZETTE":[{"def":"A newspaper; a printed sheet published periodically; esp.","pos":""}],"GAZETTEER":[{"def":"A writer of news, or an officer appointed to publish news by authority.","pos":""},{"def":"A newspaper; a gazette.","pos":""}],"GAZINGSTOCK":[{"def":"A person or thing gazed at with scorn or abhorrence; an object of curiosity or contempt.","pos":""}],"GAZOGENE":[{"def":"A portable apparatus for making soda water or aërated liquids on a small scale.","pos":""}],"GAZON":[{"def":"One of the pieces of sod used to line or cover parapets and the faces of earthworks.","pos":""}]}