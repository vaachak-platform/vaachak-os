{"ARBITER":[{"def":"A person appointed, or chosen, by parties to determine a controversy between them.","pos":""},{"def":"Any person who has the power of judging and determining, or ordaining, without control; one whose power of deciding and governing is not limited.","pos":""}],"ARBITRABLE":[{"def":"Capable of being decided by arbitration; determinable.","pos":""}],"ARBITRAGE":[{"def":"A traffic in bills of exchange (see Arbitration of Exchange); also, a traffic in stocks which bear differing values at the same time in different markets.","pos":""}],"ARBITRAL":[{"def":"Of or relating to an arbiter or an arbitration.","pos":""}],"ARBITRAMENT":[{"def":"Determination; decision; arbitration.","pos":""},{"def":"The award of arbitrators.","pos":""}],"ARBITRARILY":[{"def":"In an arbitrary manner; by will only; despotically; absolutely.","pos":""}],"ARBITRARINESS":[{"def":"The quality of being arbitrary; despoticalness; tyranny.","pos":""}],"ARBITRARIOUS":[{"def":"Arbitrary; despotic.","pos":""}],"ARBITRARY":[{"def":"Depending on will or discretion; not governed by any fixed rules; as, an arbitrary decision; an arbitrary punishment.","pos":""},{"def":"Exercised according to one's own will or caprice, and therefore conveying a notion of a tendency to abuse the possession of power.","pos":""}],"ARBITRATE":[{"def":"To hear and decide, as arbitrators; as, to choose to arbitrate a disputed case.","pos":""},{"def":"To decide, or determine generally.","pos":""}],"ARBITRATION":[{"def":"The hearing and determination of a cause between parties in controversy, by a person or persons chosen by the parties.","pos":""}],"ARBITRATOR":[{"def":"A person, or one of two or more persons, chosen by parties who have a controversy, to determine their differences.","pos":""},{"def":"One who has the power of deciding or prescribing without control; a ruler; a governor.","pos":""}],"ARBITRATRIX":[{"def":"A female who arbitrates or judges.","pos":""}],"ARBITRESS":[{"def":"A female arbiter; an arbitratrix.","pos":""}],"ARBOR":[{"def":"A kind of latticework formed of, or covered with, vines, branches of trees, or other plants, for shade; a bower.","pos":""}],"ARBOR DIANAE":[{"def":"A precipitation of silver, in a beautiful arborescent form.","pos":""}],"ARBOR VINE":[{"def":"A species of bindweed.","pos":""}],"ARBOR VITAE":[{"def":"An evergreen tree of the cypress tribe, genus Thuja.","pos":""},{"def":"The treelike disposition of the gray and white nerve tissues in the cerebellum, as seen in a vertical section.","pos":""}],"ARBORARY":[{"def":"Of or pertaining to trees; arboreal.","pos":""}],"ARBORATOR":[{"def":"One who plants or who prunes trees.","pos":""}],"ARBOREAL":[{"def":"Of or pertaining to a tree, or to trees; of nature of trees.","pos":""},{"def":"Attached to, found in or upon, or frequenting, woods or trees; as, arboreal animals.","pos":""}],"ARBORED":[{"def":"Furnished with an arbor; lined with trees.","pos":""}],"ARBOREOUS":[{"def":"Having the form, constitution, or habits, of a proper tree, in distinction from a shrub.","pos":""},{"def":"Pertaining to, or growing on, trees; as, arboreous moss.","pos":""}],"ARBORESCENCE":[{"def":"The state of being arborescent; the resemblance to a tree in minerals, or crystallizations, or groups of crystals in that form; as, the arborescence produced by precipitating silver.","pos":""}],"ARBORESCENT":[{"def":"Resembling a tree; becoming woody in stalk; dendritic; having crystallizations disposed like the branches and twigs of a tree.","pos":""}],"ARBORET":[{"def":"A small tree or shrub.","pos":""}],"ARBORETUM":[{"def":"A place in which a collection of rare trees and shrubs is cultivated for scientific or educational purposes.","pos":""}],"ARBORICAL":[{"def":"Relating to trees.","pos":""}],"ARBORICOLE":[{"def":"Tree-inhabiting; -- said of certain birds.","pos":""}],"ARBORICULTURAL":[{"def":"Pertaining to arboriculture.","pos":""}],"ARBORICULTURE":[{"def":"The cultivation of trees and shrubs, chiefly for timber or for ornamental purposes.","pos":""}],"ARBORICULTURIST":[{"def":"One who cultivates trees.","pos":""}],"ARBORIFORM":[{"def":"Treelike in shape.","pos":""}],"ARBORIST":[{"def":"One who makes trees his study, or who is versed in the knowledge of trees.","pos":""}],"ARBORIZATION":[{"def":"The appearance or figure of a tree or plant, as in minerals or fossils; a dendrite.","pos":""}],"ARBORIZED":[{"def":"Having a treelike appearance.","pos":""}],"ARBOROUS":[{"def":"Formed by trees.","pos":""}],"ARBUSCLE":[{"def":"A dwarf tree, one in size between a shrub and a tree; a treelike shrub.","pos":""}],"ARBUSCULAR":[{"def":"Of or pertaining to a dwarf tree; shrublike.","pos":""}],"ARBUSTIVE":[{"def":"Containing copses of trees or shrubs; covered with shrubs.","pos":""},{"def":"The strawberry tree, a genus of evergreen shrubs, of the Heath family.","pos":""}]}