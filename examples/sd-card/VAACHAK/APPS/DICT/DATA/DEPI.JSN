{"DEPICT":[{"def":"To form a colored likeness of; to represent by a picture; to paint; to portray.","pos":""},{"def":"To represent in words; to describe vividly.","pos":""}],"DEPICTION":[{"def":"A painting or depicting; a representation.","pos":""}],"DEPICTURE":[{"def":"To make a picture of; to paint; to picture; to depict.","pos":""}],"DEPILATE":[{"def":"To strip of hair; to husk.","pos":""}],"DEPILATION":[{"def":"Act of pulling out or removing the hair; unhairing.","pos":""}],"DEPILATORY":[{"def":"Having the quality or power of removing hair.","pos":""},{"def":"An application used to take off hair.","pos":""}]}