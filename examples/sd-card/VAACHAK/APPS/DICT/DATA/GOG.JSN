{"GOG":[{"def":"Haste; ardent desire to go.","pos":""}],"GOGGLE":[{"def":"To roll the eyes; to stare.","pos":""}],"GOGGLE-EYED":[{"def":"Having prominent and distorted or rolling eyes.","pos":""}],"GOGGLED":[{"def":"Prominent; staring, as the eye.","pos":""}],"GOGGLER":[{"def":"A carangoid oceanic fish (Trachurops crumenophthalmus), having very large and prominent eyes; -- called also goggle-eye, big-eyed scad, and cicharra.","pos":""}]}