{"CRACK":[{"def":"To break or burst, with or without entire separation of the parts; as, to crack glass; to crack nuts.","pos":""},{"def":"To rend with grief or pain; to affect deeply with sorrow; hence, to disorder; to distract; to craze.","pos":""}],"CRACK-BRAINED":[{"def":"Having an impaired intellect; whimsical; crazy.","pos":""}],"CRACKAJACK":[{"def":"An individual of marked ability or excellence, esp.","pos":""},{"def":"A preparation of popped corn, candied and pressed into small cakes.","pos":""}],"CRACKED":[{"def":"Coarsely ground or broken; as, cracked wheat.","pos":""}],"CRACKER":[{"def":"The pintail duck.","pos":""},{"def":"A pair of fluted rolls for grinding caoutchouc.","pos":""}],"CRACKER STATE":[{"def":"Georgia; -- a nickname.","pos":""}],"CRACKLE":[{"def":"To make slight cracks; to make small, sharp, sudden noises, rapidly or frequently repeated; to crepitate; as, burning thorns crackle.","pos":""}],"CRACKLED":[{"def":"Covered with minute cracks in the glaze; -- said of some kinds of porcelain and fine earthenware.","pos":""}],"CRACKLEWARE":[{"def":"Crac\"kle*ware` (-wr`), n.","pos":""}],"CRACKLING":[{"def":"Food for dogs, made from the refuse of tallow melting.","pos":""},{"def":"A kind of gambling game consisting in pitching coins to or towards the ceiling of a room so that they shall fall as near as possible to a certain crack in the floor.","pos":""}],"CRACKNEL":[{"def":"A hard brittle cake or biscuit.","pos":""}],"CRACKSMAN":[{"def":"Cracks\"man (krks\"man), n.","pos":""}],"CRACOVIAN":[{"def":"Of or pertaining to Cracow in Poland.","pos":""}],"CRACOVIENNE":[{"def":"A lively Polish dance, in 2-4 time.","pos":""}],"CRACOWES":[{"def":"Long-toed boots or shoes formerly worn in many parts of Europe; -- so called from Cracow, in Poland, where they were first worn in the fourteenth century.","pos":""}]}