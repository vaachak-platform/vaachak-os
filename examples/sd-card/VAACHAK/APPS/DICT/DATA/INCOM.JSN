{"INCOMBINE":[{"def":"To be incapable of combining; to disagree; to differ.","pos":""}],"INCOMBUSTIBILITY":[{"def":"The quality of being incombustible.","pos":""}],"INCOMBUSTIBLE":[{"def":"Not combustible; not capable of being burned, decomposed, or consumed by fire; uninflammable; as, asbestus is an incombustible substance; carbon dioxide is an incombustible gas.","pos":""}],"INCOME":[{"def":"That which is taken into the body as food; the ingesta; -- sometimes restricted to the nutritive, or digestible, portion of the food.","pos":""}],"INCOMER":[{"def":"One who comes in.","pos":""},{"def":"One who succeeds another, as a tenant of land, houses, etc.","pos":""}],"INCOMING":[{"def":"Coming in; accruing.","pos":""},{"def":"Coming in, succeeding, or following, as occupant or possessor; as, in incoming tenant.","pos":""}],"INCOMITY":[{"def":"Want of comity; incivility; rudeness.","pos":""}],"INCOMMENSURABILITY":[{"def":"The quality or state of being incommensurable.","pos":""}],"INCOMMENSURABLE":[{"def":"In`com*men\"su*ra*ble, a.","pos":""}],"INCOMMENSURATE":[{"def":"Not commensurate; not admitting of a common measure; incommensurable.","pos":""},{"def":"Not of equal of sufficient measure or extent; not adequate; as, our means are incommensurate to our wants.","pos":""}],"INCOMMISCIBLE":[{"def":"Not commiscible; not mixable.","pos":""}],"INCOMMIXTURE":[{"def":"A state of being unmixed; separateness.","pos":""}],"INCOMMODATION":[{"def":"The state of being incommoded; inconvenience.","pos":""}],"INCOMMODE":[{"def":"To give inconvenience or trouble to; to disturb or molest; to discommode; to worry; to put out; as, we are incommoded by want of room.","pos":""}],"INCOMMODEMENT":[{"def":"The act of incommoded.","pos":""}],"INCOMMODIOUS":[{"def":"Tending to incommode; not commodious; not affording ease or advantage; unsuitable; giving trouble; inconvenient; annoying; as, an incommodious seat; an incommodious arrangement.","pos":""}],"INCOMMODITY":[{"def":"Inconvenience; trouble; annoyance; disadvantage; encumbrance.","pos":""}],"INCOMMUNICABILITY":[{"def":"The quality or state of being incommunicable, or incapable of being imparted.","pos":""}],"INCOMMUNICABLE":[{"def":"Not communicable; incapable of being communicated, shared, told, or imparted, to others.","pos":""}],"INCOMMUNICATED":[{"def":"Not communicated or imparted.","pos":""}],"INCOMMUNICATING":[{"def":"Having no communion or intercourse with each other.","pos":""}],"INCOMMUNICATIVE":[{"def":"Not communicative; not free or apt to impart to others in conversation; reserved; silent; as, the messenger was incommunicative; hence, not disposed to hold fellowship or intercourse with others; exclusive.","pos":""}],"INCOMMUTABILITY":[{"def":"The quality or state of being incommutable.","pos":""}],"INCOMMUTABLE":[{"def":"Not commutable; not capable of being exchanged with, or substituted for, another.","pos":""},{"def":"Not compact; not having the parts firmly united; not solid; incoherent; loose; discrete.","pos":""}],"INCOMPARABLE":[{"def":"Not comparable; admitting of no comparison with others; unapproachably eminent; without a peer or equal; matchless; peerless; transcendent.","pos":""}],"INCOMPARED":[{"def":"Peerless; incomparable.","pos":""}],"INCOMPASSION":[{"def":"Want of compassion or pity.","pos":""}],"INCOMPASSIONATE":[{"def":"Not compassionate; void of pity or of tenderness; remorseless.","pos":""}],"INCOMPATIBILITY":[{"def":"The quality or state of being incompatible; inconsistency; irreconcilableness.","pos":""}],"INCOMPATIBLE":[{"def":"Incapable of being together without mutual reaction or decomposition, as certain medicines.","pos":""}],"INCOMPATIBLENESS":[{"def":"The quality or state of being incompatible; incompatibility.","pos":""}],"INCOMPATIBLY":[{"def":"In an incompatible manner; inconsistently; incongruously.","pos":""},{"def":"Want of competency or legal fitness; incapacity; disqualification, as of a person to be heard as a witness, or to act as a juror, or of a judge to try a cause.","pos":""}],"INCOMPETENT":[{"def":"Wanting the legal or constitutional qualifications; inadmissible; as, a person professedly wanting in religious belief is an incompetent witness in a court of law or equity; incompetent evidence.","pos":""}],"INCOMPETENTLY":[{"def":"In an competent manner; inadequately; unsuitably.","pos":""}],"INCOMPETIBILITY":[{"def":"See Incompatibility.","pos":""}],"INCOMPETIBLE":[{"def":"See Incompatible.","pos":""}],"INCOMPLETE":[{"def":"Wanting any of the usual floral organs; -- said of a flower.","pos":""}],"INCOMPLETELY":[{"def":"In an incomplete manner.","pos":""}],"INCOMPLETENESS":[{"def":"The state of being incomplete; imperfectness; defectiveness.","pos":""}],"INCOMPLETION":[{"def":"Want of completion; incompleteness.","pos":""}],"INCOMPLEX":[{"def":"Not complex; uncompounded; simple.","pos":""}],"INCOMPLIABLE":[{"def":"Not compliable; not conformable.","pos":""}],"INCOMPLIANCE":[{"def":"The quality or state of being incompliant; unyielding temper; obstinacy.","pos":""},{"def":"Refusal or failure to comply.","pos":""}],"INCOMPLIANT":[{"def":"Not compliant; unyielding to request, solicitation, or command; stubborn.","pos":""}],"INCOMPOSED":[{"def":"Disordered; disturbed.","pos":""}],"INCOMPOSITE":[{"def":"Not composite; uncompounded; simple.","pos":""}],"INCOMPOSSIBLE":[{"def":"Not capable of joint existence; incompatible; inconsistent.","pos":""}],"INCOMPREHENSE":[{"def":"Incomprehensible.","pos":""}],"INCOMPREHENSIBILITY":[{"def":"The quality of being incomprehensible, or beyond the reach of human intellect; incomprehensibleness; inconceivability; inexplicability.","pos":""}],"INCOMPREHENSIBLE":[{"def":"Not capable of being contained within limits.","pos":""},{"def":"Not capable of being comprehended or understood; beyond the reach of the human intellect; inconceivable.","pos":""}],"INCOMPREHENSION":[{"def":"Want of comprehension or understanding.","pos":""}],"INCOMPREHENSIVE":[{"def":"Not comprehensive; not capable of including or of understanding; not extensive; limited.","pos":""}],"INCOMPRESSIBILITY":[{"def":"The quality of being incompressible, or incapable of reduction in volume by pressure; -- formerly supposed to be a property of liquids.","pos":""}],"INCOMPRESSIBLE":[{"def":"Not compressible; incapable of being reduced by force or pressure into a smaller compass or volume; resisting compression; as, many liquids and solids appear to be almost incompressible.","pos":""}]}