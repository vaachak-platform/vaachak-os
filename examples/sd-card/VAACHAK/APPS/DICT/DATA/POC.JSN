{"POCAN":[{"def":"The poke (Phytolacca decandra); -- called also pocan bush.","pos":""}],"POCK":[{"def":"A pustule raised on the surface of the body in variolous and vaccine diseases.","pos":""}],"POCK-BROKEN":[{"def":"Broken out, or marked, with smallpox; pock-fretten.","pos":""}],"POCK-PITTED":[{"def":"Pockmarked; pitted.","pos":""}],"POCK-PUDDING":[{"def":"A bag pudding; a name of reproach or ridicule formerly applied by the Scotch to the English.","pos":""}],"POCKET":[{"def":"A hole or space covered by a movable piece of board, as in a floor, boxing, partitions, or the like.","pos":""},{"def":"A strip of canvas, sewn upon a sail so that a batten or a light spar can placed in the interspace.","pos":""}],"POCKET VETO":[{"def":"The retention by the President of the United States of a bill unsigned so that it does not become a law, in virtue of the following constitutional provision (Const.","pos":""}],"POCKETBOOK":[{"def":"A small book or case for carrying papers, money, etc.","pos":""}],"POCKETFUL":[{"def":"As much as a pocket will hold; enough to fill a pocket; as, pocketfuls of chestnuts.","pos":""}],"POCKETKNIFE":[{"def":"A knife with one or more blades, which fold into the handle so as to admit of being carried in the pocket.","pos":""}],"POCKINESS":[{"def":"The state of being pocky.","pos":""}],"POCKMARK":[{"def":"A mark or pit made by smallpox.","pos":""}],"POCKMARKED":[{"def":"Marked by smallpox; pitted.","pos":""}],"POCKY":[{"def":"Full of pocks; affected with smallpox or other eruptive disease.","pos":""}],"POCO":[{"def":"A little; -- used chiefly in phrases indicating the time or movement; as, poco più allegro, a little faster; poco largo, rather slow.","pos":""}],"POCOCURANTE":[{"def":"A careless person; a trifler.","pos":""}],"POCOCURANTISM":[{"def":"Carelessness; apathy; indifference.","pos":""}],"POCOSON":[{"def":"Low, wooded grounds or swamps in Eastern Maryland and Virginia.","pos":""}],"POCULIFORM":[{"def":"Having the shape of a goblet or drinking cup.","pos":""},{"def":"A combining form or suffix from Gr.","pos":""}]}