{"MONOPATHY":[{"def":"Suffering or sensibility in a single organ or function.","pos":""}],"MONOPERSONAL":[{"def":"Having but one person, or form of existence.","pos":""}],"MONOPETALOUS":[{"def":"Having only one petal, or the corolla in one piece, or composed of petals cohering so as to form a tube or bowl; gamopetalous.","pos":""}],"MONOPHANOUS":[{"def":"Having one the same appearance; having a mutual resemblance.","pos":""}],"MONOPHONIC":[{"def":"Single-voiced; having but one part; as, a monophonic composition; -- opposed to Ant: polyphonic.","pos":""}],"MONOPHTHONG":[{"def":"A single uncompounded vowel sound.","pos":""},{"def":"A combination of two written vowels pronounced as one; a digraph.","pos":""}],"MONOPHTHONGAL":[{"def":"Consisting of, or pertaining to, a monophthong.","pos":""}],"MONOPHYLETIC":[{"def":"Of or pertaining to a single family or stock, or to development from a single common parent form; -- opposed to polyphyletic; as, monophyletic origin.","pos":""}],"MONOPHYLLOUS":[{"def":"One-leaved; composed of a single leaf; as, a monophyllous involucre or calyx.","pos":""}],"MONOPHYODONT":[{"def":"Having but one set of teeth; -- opposed to diphyodont.","pos":""}],"MONOPHYSITE":[{"def":"One of a sect, in the ancient church, who maintained that the human and divine in Jesus Christ constituted but one composite nature.","pos":""}],"MONOPHYSITICAL":[{"def":"Of or pertaining to Monophysites, or their doctrines.","pos":""}],"MONOPLAST":[{"def":"A monoplastic element.","pos":""}],"MONOPLASTIC":[{"def":"That has one form, or retains its primary form, as, a monoplastic element.","pos":""}],"MONOPLEGIA":[{"def":"Paralysis affecting a single limb.","pos":""}],"MONOPNEUMONA":[{"def":"A suborder of Dipnoi, including the Ceratodus.","pos":""}],"MONOPODE":[{"def":"One of a fabulous tribe or race of Ethiopians having but one leg and foot.","pos":""}],"MONOPODIAL":[{"def":"Having a monopodium or a single and continuous axis, as a birchen twig or a cornstalk.","pos":""}],"MONOPODIUM":[{"def":"A single and continuous vegetable axis; -- opposed to sympodium.","pos":""}],"MONOPODY":[{"def":"A measure of but a single foot.","pos":""}],"MONOPOLIST":[{"def":"One who monopolizes; one who has a monopoly; one who favors monopoly.","pos":""}],"MONOPOLISTIC":[{"def":"Of or pertaining to a monopolist.","pos":""}],"MONOPOLIZE":[{"def":"To acquire a monopoly of; to have or get the exclusive privilege or means of dealing in, or the exclusive possession of; to engross the whole of; as, to monopolize the coffee trade; to monopolize land.","pos":""}],"MONOPOLIZER":[{"def":"One who monopolizes.","pos":""}],"MONOPOLY":[{"def":"Exclusive possession; as, a monopoly of land.","pos":""}],"MONOPOLYLOGUE":[{"def":"An exhibition in which an actor sustains many characters.","pos":""}],"MONOPSYCHISM":[{"def":"The doctrine that there is but one immortal soul or intellect with which all men are endowed.","pos":""}],"MONOPTERAL":[{"def":"Round and without a cella; consisting of a single ring of columns supporting a roof; -- said esp.","pos":""}],"MONOPTERON":[{"def":"A circular temple consisting of a roof supported on columns, without a cella.","pos":""}],"MONOPTOTE":[{"def":"A noun having only one case.","pos":""},{"def":"A noun having only one ending for the oblique cases.","pos":""}],"MONOPYRENOUS":[{"def":"Having but a single stone or kernel.","pos":""}]}