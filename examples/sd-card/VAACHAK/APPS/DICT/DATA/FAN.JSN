{"FAN":[{"def":"An instrument used for producing artificial currents of air, by the wafting or revolving motion of a broad surface; as: (a) An instrument for cooling the person, made of feathers, paper, silk, etc.","pos":""},{"def":"That which produces effects analogous to those of a fan, as in exciting a flame, etc.","pos":""}],"FAN PALM":[{"def":"Any palm tree having fan-shaped or radiate leaves; as the Chamærops humilis of Southern Europe; the species of Sabal and Thrinax in the West Indies, Florida, etc.","pos":""}],"FAN-NERVED":[{"def":"Having the nerves or veins arranged in a radiating manner; -- said of certain leaves, and of the winfs of some insects.","pos":""}],"FAN-TAILED":[{"def":"Having an expanded, or fan-shaped, tail; as, the fan-tailed pigeon.","pos":""}],"FAN-TAN":[{"def":"A Chinese gambling game in which coins or other small objects are placed upon a table, usually under a cup, and the players bet as to what remainder will be left when the sum of the counters is divided by four.","pos":""},{"def":"A game with playing cards in which the cards are played in sequences upon the table, the one who first gets rid of his cards being the winner.","pos":""}],"FANAL":[{"def":"A lighthouse, or the apparatus placed in it for giving light.","pos":""}],"FANATIC":[{"def":"Pertaining to, or indicating, fanaticism; extravagant in opinions; ultra; unreasonable; excessively enthusiastic, especially on religious subjects; as, fanatic zeal; fanatic notions.","pos":""}],"FANATICAL":[{"def":"Characteristic of, or relating to, fanaticism; fanatic.","pos":""}],"FANATICISM":[{"def":"Excessive enthusiasm, unreasoning zeal, or wild and extravagant notions, on any subject, especially religion; religious frenzy.","pos":""}],"FANATICIZE":[{"def":"To cause to become a fanatic.","pos":""}],"FANCIED":[{"def":"Formed or conceived by the fancy; unreal; as, a fancied wrong.","pos":""}],"FANCIER":[{"def":"One who is governed by fancy.","pos":""},{"def":"One who fancies or has a special liking for, or interest in, a particular object or class or objects; hence, one who breeds and keeps for sale birds and animals; as, bird fancier, dog fancier, etc.","pos":""}],"FANCIFUL":[{"def":"Full of fancy; guided by fancy, rather than by reason and experience; whimsical; as, a fanciful man forms visionary projects.","pos":""},{"def":"Conceived in the fancy; not consistent with facts or reason; abounding in ideal qualities or figures; as, a fanciful scheme; a fanciful theory.","pos":""}],"FANCILESS":[{"def":"Having no fancy; without ideas or imagination.","pos":""}],"FANCY":[{"def":"An image or representation of anything formed in the mind; conception; thought; idea; conceit.","pos":""}],"FANCY-FREE":[{"def":"Free from the power of love.","pos":""}],"FANCYMONGER":[{"def":"A lovemonger; a whimsical lover.","pos":""}],"FANCYWORK":[{"def":"Ornamental work with a needle or hook, as embroidery, crocheting, netting, etc.","pos":""}],"FANDANGO":[{"def":"A lively dance, in 3-8 or 6-8 time, much practiced in Spain and Spanish America.","pos":""},{"def":"A ball or general dance, as in Mexico.","pos":""}],"FANE":[{"def":"A temple; a place consecrated to religion; a church.","pos":""}],"FANEGA":[{"def":"A dry measure in Spain and Spanish America, varying from 1 De Colange.","pos":""}],"FANFARE":[{"def":"A flourish of trumpets, as in coming into the lists, etc.","pos":""}],"FANFARON":[{"def":"A bully; a hector; a swaggerer; an empty boaster.","pos":""}],"FANFARONADE":[{"def":"A swaggering; vain boasting; ostentation; a bluster.","pos":""}],"FANG":[{"def":"To catch; to seize, as with the teeth; to lay hold of; to gripe; to clutch.","pos":""},{"def":"To enable to catch or tear; to furnish with fangs.","pos":""}],"FANGED":[{"def":"Having fangs or tusks; as, a fanged adder.","pos":""}],"FANGLE":[{"def":"Something new-fashioned; a foolish innovation; a gewgaw; a trifling ornament.","pos":""}],"FANGLED":[{"def":"New made; hence, gaudy; showy; vainly decorated.","pos":""}],"FANGLENESS":[{"def":"Quality of being fangled.","pos":""}],"FANGLESS":[{"def":"Destitute of fangs or tusks.","pos":""}],"FANGOT":[{"def":"A quantity of wares, as raw silk, etc.","pos":""}],"FANION":[{"def":"A small flag sometimes carried at the head of the baggage of a brigade.","pos":""}],"FANLIKE":[{"def":"Resembling a fan; -- specifically (Bot.","pos":""}],"FANNER":[{"def":"A fan wheel; a fan blower.","pos":""}],"FANON":[{"def":"A term applied to various articles, as: (a) A peculiar striped scarf worn by the pope at mass, and by eastern bishops.","pos":""}],"FANTASIA":[{"def":"A continuous composition, not divided into what are called movements, or governed by the ordinary rules of musical design, but in which the author's fancy roves unrestricted by set form.","pos":""}],"FANTASIED":[{"def":"Filled with fancies or imaginations.","pos":""}],"FANTASM":[{"def":"Same as Phantasm.","pos":""}],"FANTAST":[{"def":"One whose manners or ideas are fantastic.","pos":""}],"FANTASTIC":[{"def":"Existing only in imagination; fanciful; imaginary; not real; chimerical.","pos":""},{"def":"Having the nature of a phantom; unreal.","pos":""}],"FANTASTIC-ALNESS":[{"def":"The quality of being fantastic.","pos":""}],"FANTASTICAL":[{"def":"Fanciful; unreal; whimsical; capricious; fantastic.","pos":""}],"FANTASTICALITY":[{"def":"Fan*tas`ti*cal\"i*ty, n.","pos":""}],"FANTASTICALLY":[{"def":"In a fantastic manner.","pos":""}],"FANTASTICISM":[{"def":"The quality of being fantastical; fancifulness; whimsicality.","pos":""}],"FANTASTICNESS":[{"def":"Fantasticalness.","pos":""}],"FANTASY":[{"def":"Fancy; imagination; especially, a whimsical or fanciful conception; a vagary of the imagination; whim; caprice; humor.","pos":""},{"def":"Fantastic designs.","pos":""}],"FANTOCCINI":[{"def":"Puppets caused to perform evolutions or dramatic scenes by means of machinery; also, the representations in which they are used.","pos":""},{"def":"State of worry or excitement; fidget; fuss; also, indisposition; pet; sulks.","pos":""}]}