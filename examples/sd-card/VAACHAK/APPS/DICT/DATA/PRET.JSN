{"PRETEMPORAL":[{"def":"Situated in front of the temporal bone.","pos":""},{"def":"See Pretense, Pretenseful, Pretenseless.","pos":""}],"PRETEND":[{"def":"To lay a claim to; to allege a title to; to claim.","pos":""},{"def":"To hold before, or put forward, as a cloak or disguise for something else; to exhibit as a veil for something hidden.","pos":""}],"PRETENDANT":[{"def":"A pretender; a claimant.","pos":""}],"PRETENDED":[{"def":"Making a false appearance; unreal; false; as, pretended friend.","pos":""}],"PRETENDENCE":[{"def":"The act of pretending; pretense.","pos":""}],"PRETENDER":[{"def":"The pretender (Eng.","pos":""}],"PRETENDERSHIP":[{"def":"The character, right, or claim of a pretender.","pos":""}],"PRETENDINGLY":[{"def":"As by right or title; arrogantly; presumptuously.","pos":""}],"PRETENSED":[{"def":"Pretended; feigned.","pos":""}],"PRETENSEFUL":[{"def":"Abounding in pretenses.","pos":""}],"PRETENSELESS":[{"def":"Not having or making pretenses.","pos":""}],"PRETENSION":[{"def":"The act of pretending, or laying claim; the act of asserting right or title.","pos":""},{"def":"A claim made, whether true or false; a right alleged or assumed; a holding out the appearance of possessing a certain character; as, pretensions to scholarship.","pos":""}],"PRETENTATIVE":[{"def":"Fitted for trial beforehand; experimental.","pos":""}],"PRETENTIOUS":[{"def":"Full of pretension; disposed to lay claim to more than is one's; presuming; assuming.","pos":""}],"PRETER-":[{"def":"A prefix signifying past, by, beyond, more than; as, preter- mission, a permitting to go by; preternatural, beyond or more than is natural.","pos":""}],"PRETERHUMAN":[{"def":"More than human.","pos":""}],"PRETERIENT":[{"def":"Passed through; antecedent; previous; as, preterient states.","pos":""}],"PRETERIMPERFECT":[{"def":"Old name of the tense also called imperfect.","pos":""}],"PRETERIST":[{"def":"One who believes the prophecies of the Apocalypse to have been already fulfilled.","pos":""}],"PRETERIT":[{"def":"Past; -- applied to a tense which expresses an action or state as past.","pos":""}],"PRETERITE":[{"def":"Same as Preterit.","pos":""}],"PRETERITENESS":[{"def":"Same as Preteritness.","pos":""}],"PRETERITION":[{"def":"A figure by which, in pretending to pass over anything, a summary mention of it is made; as, \"I will not say, he is valiant, he is learned, he is just.","pos":""},{"def":"The omission by a testator of some one of his heirs who is entitled to a portion.","pos":""}],"PRETERITIVE":[{"def":"Used only or chiefly in the preterit or past tenses, as certain verbs.","pos":""}],"PRETERITNESS":[{"def":"The quality or state of being past.","pos":""}],"PRETERLAPSED":[{"def":"Past; as, preterlapsed ages.","pos":""}],"PRETERLEGAL":[{"def":"Exceeding the limits of law.","pos":""}],"PRETERMISSION":[{"def":"See Preterition.","pos":""}],"PRETERMIT":[{"def":"To pass by; to omit; to disregard.","pos":""}],"PRETERNATURAL":[{"def":"This vile and preternatural temper of mind.","pos":""}],"PRETERNATURALISM":[{"def":"The state of being preternatural; a preternatural condition.","pos":""}],"PRETERNATURALITY":[{"def":"Preternaturalness.","pos":""}],"PRETERNATURALLY":[{"def":"In a preternatural manner or degree.","pos":""}],"PRETERNATURALNESS":[{"def":"The quality or state of being preternatural.","pos":""}],"PRETERPERFECT":[{"def":"Old name of the tense also called preterit.","pos":""}],"PRETERPLUPERFECT":[{"def":"Old name of the tense also called pluperfect.","pos":""}],"PRETERTIARY":[{"def":"Earlier than Tertiary.","pos":""}],"PRETERVECTION":[{"def":"The act of carrying past or beyond.","pos":""}],"PRETEX":[{"def":"To frame; to devise; to disguise or excuse; hence, to pretend; to declare falsely.","pos":""}],"PRETEXT":[{"def":"Ostensible reason or motive assigned or assumed as a color or cover for the real reason or motive; pretense; disguise.","pos":""}],"PRETIBIAL":[{"def":"Situated in front of the tibia.","pos":""}],"PRETOR":[{"def":"A civil officer or magistrate among the ancient Romans.","pos":""}],"PRETORIAN":[{"def":"Of or pertaining to a pretor or magistrate; judicial; exercised by, or belonging to, a pretor; as, pretorian power or authority.","pos":""}],"PRETORIUM":[{"def":"The general's tent in a Roman camp; hence, a council of war, because held in the general's tent.","pos":""},{"def":"The official residence of a governor of a province; hence, a place; a splendid country seat.","pos":""}],"PRETORSHIP":[{"def":"The office or dignity of a pretor.","pos":""}],"PRETORTURE":[{"def":"To torture beforehand.","pos":""}],"PRETTILY":[{"def":"In a pretty manner.","pos":""}],"PRETTINESS":[{"def":"The quality or state of being pretty; -- used sometimes in a disparaging sense.","pos":""}],"PRETTY":[{"def":"Moderately large; considerable; as, he had saved a pretty fortune.","pos":""}],"PRETTY-SPOKEN":[{"def":"Spoken or speaking prettily.","pos":""}],"PRETTYISH":[{"def":"Somewhat pretty.","pos":""}],"PRETTYISM":[{"def":"Affectation of a pretty style, manner, etc.","pos":""}],"PRETYPIFY":[{"def":"To prefigure; to exhibit previously in a type.","pos":""}],"PRETZEL":[{"def":"A kind of German biscuit or cake in the form of a twisted ring, salted on the outside.","pos":""}]}