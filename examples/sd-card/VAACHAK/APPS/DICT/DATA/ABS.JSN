{"ABSCESS":[{"def":"A collection of pus or purulent matter in any tissue or organ of the body, the result of a morbid process.","pos":""}],"ABSCESSION":[{"def":"A separating; removal; also, an abscess.","pos":""}],"ABSCISSA":[{"def":"One of the elements of reference by which a point, as of a curve, is referred to a system of fixed rectilineal coördinate axes.","pos":""}],"ABSCISSION":[{"def":"A figure of speech employed when a speaker having begun to say a thing stops abruptly: thus, \"He is a man of so much honor and candor, and of such generosity -- but I need say no more.","pos":""}],"ABSCOND":[{"def":"To hide, withdraw, or be concealed.","pos":""},{"def":"To depart clandestinely; to steal off and secrete one's self; -- used especially of persons who withdraw to avoid a legal process; as, an absconding debtor.","pos":""}],"ABSCONDENCE":[{"def":"Fugitive concealment; secret retirement; hiding.","pos":""}],"ABSCONDER":[{"def":"One who absconds.","pos":""}],"ABSENCE":[{"def":"A state of being absent or withdrawn from a place or from companionship; -- opposed to presence.","pos":""},{"def":"Want; destitution; withdrawal.","pos":""}],"ABSENT":[{"def":"Being away from a place; withdrawn from a place; not present.","pos":""},{"def":"Not existing; lacking; as, the part was rudimental or absent.","pos":""}],"ABSENT-MINDED":[{"def":"Absent in mind; abstracted; preoccupied.","pos":""}],"ABSENTANEOUS":[{"def":"Pertaining to absence.","pos":""}],"ABSENTATION":[{"def":"The act of absenting one's self.","pos":""}],"ABSENTEE":[{"def":"One who absents himself from his country, office, post, or duty; especially, a landholder who lives in another country or district than that where his estate is situated; as, an Irish absentee.","pos":""}],"ABSENTEEISM":[{"def":"The state or practice of an absentee; esp.","pos":""}],"ABSENTER":[{"def":"One who absents one's self.","pos":""}],"ABSENTLY":[{"def":"In an absent or abstracted manner.","pos":""}],"ABSENTMENT":[{"def":"The state of being absent; withdrawal.","pos":""}],"ABSENTNESS":[{"def":"The quality of being absent-minded.","pos":""}],"ABSEY-BOOK":[{"def":"An A-B-C book; a primer.","pos":""}],"ABSINTHATE":[{"def":"A combination of absinthic acid with a base or positive radical.","pos":""}],"ABSINTHIAL":[{"def":"Of or pertaining to wormwood; absinthian.","pos":""}],"ABSINTHIAN":[{"def":"Of the nature of wormwood.","pos":""}],"ABSINTHIATE":[{"def":"To impregnate with wormwood.","pos":""}],"ABSINTHIATED":[{"def":"Impregnated with wormwood; as, absinthiated wine.","pos":""}],"ABSINTHIC":[{"def":"Relating to the common wormwood or to an acid obtained from it.","pos":""}],"ABSINTHIN":[{"def":"The bitter principle of wormwood (Artemisia absinthium).","pos":""}],"ABSINTHISM":[{"def":"The condition of being poisoned by the excessive use of absinth.","pos":""}],"ABSINTHIUM":[{"def":"The common wormwood (Artemisia absinthium), an intensely bitter plant, used as a tonic and for making the oil of wormwood.","pos":""}],"ABSIST":[{"def":"To stand apart from; top leave off; to desist.","pos":""}],"ABSISTENCE":[{"def":"A standing aloof.","pos":""}],"ABSOLUTE":[{"def":"Pure; unmixed; as, absolute alcohol.","pos":""},{"def":"Not immediately dependent on the other parts of the sentence in government; as, the case absolute.","pos":""}],"ABSOLUTELY":[{"def":"In an absolute, independent, or unconditional manner; wholly; positively.","pos":""}],"ABSOLUTENESS":[{"def":"The quality of being absolute; independence of everything extraneous; unlimitedness; absolute power; independent reality; positiveness.","pos":""}],"ABSOLUTION":[{"def":"An acquittal, or sentence of a judge declaring and accused person innocent.","pos":""},{"def":"The exercise of priestly jurisdiction in the sacrament of penance, by which Catholics believe the sins of the truly penitent are forgiven.","pos":""}],"ABSOLUTISM":[{"def":"Doctrine of absolute decrees.","pos":""}],"ABSOLUTIST":[{"def":"One who believes that it is possible to realize a cognition or concept of the absolute.","pos":""}],"ABSOLUTISTIC":[{"def":"Pertaining to absolutism; absolutist.","pos":""}],"ABSOLUTORY":[{"def":"Serving to absolve; absolving.","pos":""}],"ABSOLVABLE":[{"def":"That may be absolved.","pos":""}],"ABSOLVATORY":[{"def":"Conferring absolution; absolutory.","pos":""}],"ABSOLVE":[{"def":"To free from a penalty; to pardon; to remit (a sin); -- said of the sin or guilt.","pos":""}],"ABSOLVER":[{"def":"One who absolves.","pos":""}],"ABSONANT":[{"def":"Discordant; contrary; -- opposed to consonant.","pos":""}],"ABSONOUS":[{"def":"Discordant; inharmonious; incongruous.","pos":""}],"ABSORB":[{"def":"To swallow up; to engulf; to overwhelm; to cause to disappear as if by swallowing up; to use up; to include.","pos":""},{"def":"To suck up; to drink in; to imbibe; as a sponge or as the lacteals of the body.","pos":""}],"ABSORBABILITY":[{"def":"The state or quality of being absorbable.","pos":""}],"ABSORBABLE":[{"def":"Capable of being absorbed or swallowed up.","pos":""}],"ABSORBEDLY":[{"def":"In a manner as if wholly engrossed or engaged.","pos":""}],"ABSORBENT":[{"def":"Absorbing; swallowing; absorptive.","pos":""}],"ABSORBER":[{"def":"One who, or that which, absorbs.","pos":""}],"ABSORBING":[{"def":"Swallowing, engrossing; as, an absorbing pursuit.","pos":""}],"ABSORPTION":[{"def":"An imbibing or reception by molecular or chemical action; as, the absorption of light, heat, electricity, etc.","pos":""},{"def":"In living organisms, the process by which the materials of growth and nutrition are absorbed and conveyed to the tissues and organs.","pos":""}],"ABSORPTIVE":[{"def":"Having power, capacity, or tendency to absorb or imbibe.","pos":""}],"ABSORPTIVENESS":[{"def":"The quality of being absorptive; absorptive power.","pos":""}],"ABSQUATULATE":[{"def":"To take one's self off; to decamp.","pos":""}],"ABSQUE HOC":[{"def":"Abs\"que hoc Defn: .","pos":""}],"ABSTAIN":[{"def":"To hold one's self aloof; to forbear or refrain voluntarily, and especially from an indulgence of the passions or appetites; -- with from.","pos":""}],"ABSTAINER":[{"def":"One who abstains; esp.","pos":""}],"ABSTEMIOUS":[{"def":"Abstaining from wine.","pos":""},{"def":"Sparing in diet; refraining from a free use of food and strong drinks; temperate; abstinent; sparing in the indulgence of the appetite or passions.","pos":""}],"ABSTEMIOUSNESS":[{"def":"The quality of being abstemious, temperate, or sparing in the use of food and strong drinks.","pos":""}],"ABSTENTION":[{"def":"The act of abstaining; a holding aloof.","pos":""}],"ABSTENTIOUS":[{"def":"Characterized by abstinence; self-restraining.","pos":""}],"ABSTERGE":[{"def":"To make clean by wiping; to wipe away; to cleanse; hence, to purge.","pos":""}],"ABSTERGENT":[{"def":"Serving to cleanse, detergent.","pos":""}],"ABSTERSE":[{"def":"To absterge; to cleanse; to purge away.","pos":""}],"ABSTERSION":[{"def":"Act of wiping clean; a cleansing; a purging.","pos":""}],"ABSTERSIVE":[{"def":"Cleansing; purging.","pos":""}],"ABSTERSIVENESS":[{"def":"The quality of being abstersive.","pos":""}],"ABSTINENCE":[{"def":"The act or practice of abstaining; voluntary forbearance of any action, especially the refraining from an indulgence of appetite, or from customary gratifications of animal or sensual propensities.","pos":""},{"def":"The practice of self-denial by depriving one's self of certain kinds of food or drink, especially of meat.","pos":""}],"ABSTINENT":[{"def":"Refraining from indulgence, especially from the indulgence of appetite; abstemious; continent; temperate.","pos":""}],"ABSTINENTLY":[{"def":"With abstinence.","pos":""}],"ABSTRACT":[{"def":"Withdraw; separate.","pos":""},{"def":"Considered apart from any application to a particular object; separated from matter; exiting in the mind only; as, abstract truth, abstract numbers.","pos":""}],"ABSTRACTED":[{"def":"Separated or disconnected; withdrawn; removed; apart.","pos":""},{"def":"Separated from matter; abstract; ideal.","pos":""}],"ABSTRACTEDLY":[{"def":"In an abstracted manner; separately; with absence of mind.","pos":""}],"ABSTRACTEDNESS":[{"def":"The state of being abstracted; abstract character.","pos":""}],"ABSTRACTER":[{"def":"One who abstracts, or makes an abstract.","pos":""}],"ABSTRACTION":[{"def":"The act process of leaving out of consideration one or more properties of a complex object so as to attend to others; analysis.","pos":""},{"def":"A separation of volatile parts by the act of distillation.","pos":""}],"ABSTRACTIONAL":[{"def":"Pertaining to abstraction.","pos":""}],"ABSTRACTITIOUS":[{"def":"Obtained from plants by distillation.","pos":""}],"ABSTRACTIVE":[{"def":"Having the power of abstracting; of an abstracting nature.","pos":""}],"ABSTRACTIVELY":[{"def":"In a abstract manner; separately; in or by itself.","pos":""}],"ABSTRACTIVENESS":[{"def":"The quality of being abstractive; abstractive property.","pos":""}],"ABSTRACTLY":[{"def":"In an abstract state or manner; separately; absolutely; by itself; as, matter abstractly considered.","pos":""}],"ABSTRACTNESS":[{"def":"The quality of being abstract.","pos":""}],"ABSTRUSE":[{"def":"Concealed or hidden out of the way.","pos":""},{"def":"Remote from apprehension; difficult to be comprehended or understood; recondite; as, abstruse learning.","pos":""}],"ABSTRUSELY":[{"def":"In an abstruse manner.","pos":""}],"ABSTRUSENESS":[{"def":"The quality of being abstruse; difficulty of apprehension.","pos":""}],"ABSTRUSION":[{"def":"The act of thrusting away.","pos":""}],"ABSTRUSITY":[{"def":"Abstruseness; that which is abstruse.","pos":""}],"ABSUME":[{"def":"To consume gradually; to waste away.","pos":""}],"ABSUMPTION":[{"def":"Act of wasting away; a consuming; extinction.","pos":""}],"ABSURD":[{"def":"Contrary to reason or propriety; obviously and fiatly opposed to manifest truth; inconsistent with the plain dictates of common sense; logically contradictory; nonsensical; ridiculous; as, an absurd person, an absurd opinion; an absurd dream.","pos":""}],"ABSURDITY":[{"def":"The quality of being absurd or inconsistent with obvious truth, reason, or sound judgment.","pos":""},{"def":"That which is absurd; an absurd action; a logical contradiction.","pos":""}],"ABSURDLY":[{"def":"In an absurd manner.","pos":""}]}