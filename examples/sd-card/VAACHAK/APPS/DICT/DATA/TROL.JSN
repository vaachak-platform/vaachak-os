{"TROLL":[{"def":"A supernatural being, often represented as of diminutive size, but sometimes as a giant, and fabled to inhabit caves, hills, and like places; a witch.","pos":""}],"TROLLER":[{"def":"TROLLEY; TROLLY Trol\"ley, Trol\"ly, n.","pos":""}],"TROLLEY CAR":[{"def":"A motor car to which the current is conveyed by means of a trolley.","pos":""}],"TROLLEY WIRE":[{"def":"A heavy conducting wire on which the trolley car runs and from which it receives the current.","pos":""}],"TROLLMYDAMES":[{"def":"The game of nineholes.","pos":""}],"TROLLOP":[{"def":"A stroller; a loiterer; esp.","pos":""}],"TROLLOPEE":[{"def":"A kind of loose dress for women.","pos":""}]}