{"PEE":[{"def":"Bill of an anchor.","pos":""}],"PEEK":[{"def":"To look slyly, or with the eyes half closed, or through a crevice; to peep.","pos":""}],"PEEKABOO":[{"def":"A child's game; bopeep.","pos":""}],"PEEL":[{"def":"A small tower, fort, or castle; a keep.","pos":""}],"PEELE":[{"def":"A graceful and swift South African antelope (Pelea capreola).","pos":""}],"PEELER":[{"def":"One who peels or strips.","pos":""}],"PEEN":[{"def":"To draw, bend, or straighten, as metal, by blows with the peen of a hammer or sledge.","pos":""}],"PEEP":[{"def":"To cry, as a chicken hatching or newly hatched; to chirp; to cheep.","pos":""},{"def":"To begin to appear; to look forth from concealment; to make the first appearance.","pos":""}],"PEEP SIGHT":[{"def":"An adjustable piece, pierced with a small hole to peep through in aiming, attached to a rifle or other firearm near the breech; -- distinguished from an open sight.","pos":""}],"PEEPER":[{"def":"A chicken just breaking the shell; a young bird.","pos":""},{"def":"One who peeps; a prying person; a spy.","pos":""}],"PEEPHOLE":[{"def":"A hole, or crevice, through which one may peep without being discovered.","pos":""}],"PEEPUL TREE":[{"def":"A sacred tree (Ficus religiosa) of the Buddhists, a kind of fig tree which attains great size and venerable age.","pos":""}],"PEER":[{"def":"To look narrowly or curiously or intently; to peep; as, the peering day.","pos":""}],"PEERAGE":[{"def":"The rank or dignity of a peer.","pos":""},{"def":"The body of peers; the nobility, collectively.","pos":""}],"PEERDOM":[{"def":"Peerage; also, a lordship.","pos":""}],"PEERESS":[{"def":"The wife of a peer; a woman ennobled in her own right, or by right of marriage.","pos":""},{"def":"Inquisitive; suspicious; sharp.","pos":""}],"PEERLESS":[{"def":"Having no peer or equal; matchless; superlative.","pos":""}],"PEERWEET":[{"def":"Same as Pewit (a & b).","pos":""}],"PEEVISH":[{"def":"Habitually fretful; easily vexed or fretted; hard to please; apt to complain; querulous; petulant.","pos":""},{"def":"Expressing fretfulness and discontent, or unjustifiable dissatisfaction; as, a peevish answer.","pos":""}],"PEEVISHLY":[{"def":"In a peevish manner.","pos":""}],"PEEVISHNESS":[{"def":"The quality of being peevish; disposition to murmur; sourness of temper.","pos":""}]}