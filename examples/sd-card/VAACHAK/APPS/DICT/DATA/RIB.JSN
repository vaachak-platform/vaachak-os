{"RIB":[{"def":"One of the curved bones attached to the vertebral column and supporting the lateral walls of the thorax.","pos":""},{"def":"A ridge, fin, or wing, as on a plate, cylinder, beam, etc.","pos":""}],"RIBALD":[{"def":"A low, vulgar, brutal, foul-mouthed wretch; a lewd fellow.","pos":""}],"RIBALDROUS":[{"def":"Of a ribald quality.","pos":""}],"RIBALDRY":[{"def":"The talk of a ribald; low, vulgar language; indecency; obscenity; lewdness; -- now chiefly applied to indecent language, but formerly, as by Chaucer, also to indecent acts or conduct.","pos":""}],"RIBAUDEQUIN":[{"def":"Filthy; obscene; ribald.","pos":""}],"RIBBAND":[{"def":"A long, narrow strip of timber bent and bolted longitudinally to the ribs of a vessel, to hold them in position, and give rigidity to the framework.","pos":""}],"RIBBED":[{"def":"Intercalated with slate; -- said of a seam of coal.","pos":""}],"RIBBING":[{"def":"An assemblage or arrangement of ribs, as the timberwork for the support of an arch or coved ceiling, the veins in the leaves of some plants, ridges in the fabric of cloth, or the like.","pos":""}],"RIBBON":[{"def":"Same as Rib-band.","pos":""}],"RIBBONISM":[{"def":"The principles and practices of the Ribbonmen.","pos":""}],"RIBBONMAN":[{"def":"A member of the Ribbon Society.","pos":""}],"RIBBONWOOD":[{"def":"A malvaceous tree (Hoheria populnea) of New Zealand, the bark of which is used for cordage.","pos":""}],"RIBES":[{"def":"A genus of shrubs including gooseberries and currants of many kinds.","pos":"noun"}],"RIBIBE":[{"def":"A sort of stringed instrument; a rebec.","pos":""},{"def":"An old woman; -- in contempt.","pos":""}],"RIBIBLE":[{"def":"A small threestringed viol; a rebec.","pos":""}],"RIBROAST":[{"def":"To beat soundly.","pos":""}],"RIBWORT":[{"def":"A species of plantain (Plantago lanceolata) with long, narrow, ribbed leaves; -- called also rib grass, ripple grass, ribwort plantain.","pos":""},{"def":"A suffix signifying dominion, jurisdiction; as, bishopric, the district over which a bishop exercises authority.","pos":""}]}