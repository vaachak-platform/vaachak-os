{"UVA":[{"def":"A small pulpy or juicy fruit containing several seeds and having a thin skin, as a grape.","pos":""}],"UVATE":[{"def":"A conserve made of grapes.","pos":""}],"UVEA":[{"def":"The posterior pigmented layer of the iris; -- sometimes applied to the whole iris together with the choroid coat.","pos":""}],"UVEOUS":[{"def":"Resembling a grape.","pos":""}],"UVIC":[{"def":"Pertaining to, or obtained from, grapes; specifically, designating an organic acid, C7H8O3 (also called pyrotritartaric acid), obtained as a white crystalline substance by the decomposition of tartaric and pyrotartaric acids.","pos":""}],"UVITIC":[{"def":"Pertaining to, or designating, an acid, CH3C6H3(CO2H)2, obtained as a white crystalline substance by the partial oxidation of mesitylene; -- called also mesitic acid.","pos":""}],"UVITONIC":[{"def":"Pertaining to, or designating, an acid which is obtained as a white crystalline substance by the action of ammonia on pyrotartaric acid.","pos":""}],"UVULA":[{"def":"The pendent fleshy lobe in the middle of the posterior border of the soft palate.","pos":""}],"UVULAR":[{"def":"Of or pertaining to a uvula.","pos":""}],"UVULATOME":[{"def":"An instrument for removing the uvula.","pos":""}],"UVULATOMY":[{"def":"The operation of removing the uvula.","pos":""}],"UVULITIS":[{"def":"Inflammation of the uvula.","pos":""}]}