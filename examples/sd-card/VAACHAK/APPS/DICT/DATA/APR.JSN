{"APRICATE":[{"def":"To bask in the sun.","pos":""}],"APRICATION":[{"def":"Basking in the sun.","pos":""}],"APRICOT":[{"def":"A fruit allied to the plum, of an orange color, oval shape, and delicious taste; also, the tree (Prunus Armeniaca of Linnæus) which bears this fruit.","pos":""}],"APRIL":[{"def":"The fourth month of the year.","pos":""}],"APRIORISM":[{"def":"An a priori principle.","pos":""}],"APRIORITY":[{"def":"The quality of being innate in the mind, or prior to experience; a priori reasoning.","pos":""}],"APROCTA":[{"def":"A group of Turbellaria in which there is no anal aperture.","pos":""}],"APROCTOUS":[{"def":"Without an anal office.","pos":""}],"APRON":[{"def":"An article of dress, of cloth, leather, or other stuff, worn on the fore part of the body, to keep the clothes clean, to defend them from injury, or as a covering.","pos":""},{"def":"Something which by its shape or use suggests an apron; as, (a) The fat skin covering the belly of a goose or duck.","pos":""}],"APRON MAN":[{"def":"A man who wears an apron; a laboring man; a mechanic.","pos":""}],"APRON STRING":[{"def":"The string of an apron.","pos":""}],"APRONED":[{"def":"Wearing an apron.","pos":""}],"APRONFUL":[{"def":"The quality an apron can hold.","pos":""}],"APRONLESS":[{"def":"Without an apron.","pos":""}],"APROPOS":[{"def":"Opportunely or opportune; seasonably or seasonable.","pos":""},{"def":"By the way; to the purpose; suitably to the place or subject; -- a word used to introduce an incidental observation, suited to the occasion, though not strictly belonging to the narration.","pos":""}]}