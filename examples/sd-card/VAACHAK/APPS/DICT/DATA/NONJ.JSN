{"NONJOINDER":[{"def":"The omission of some person who ought to have been made a plaintiff or defendant in a suit, or of some cause of action which ought to be joined.","pos":""}],"NONJURING":[{"def":"Not swearing allegiance; -- applied to the party in Great Britain that would not swear allegiance to William and Mary, or their successors.","pos":""}],"NONJUROR":[{"def":"One of those adherents of James II.","pos":""}],"NONJURORISM":[{"def":"The doctrines, or action, of the Nonjurors.","pos":""}]}