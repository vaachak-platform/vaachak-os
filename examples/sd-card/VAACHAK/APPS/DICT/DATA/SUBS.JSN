{"SUBSACRAL":[{"def":"Situated under, or on the ventral side of, the sacrum.","pos":""}],"SUBSALINE":[{"def":"Moderately saline or salt.","pos":""}],"SUBSANNATION":[{"def":"Derision; mockery.","pos":""},{"def":"Situated beneath the scapula; infrascapular; as, the subscapular muscle.","pos":""}],"SUBSCRIBABLE":[{"def":"Capable of being subscribed.","pos":""}],"SUBSCRIBE":[{"def":"To write underneath, as one's name; to sign (one's name) to a document.","pos":""},{"def":"To sign with one's own hand; to give consent to, as something written, or to bind one's self to the terms of, by writing one's name beneath; as, parties subscribe a covenant or contract; a man subscribes a bond.","pos":""}],"SUBSCRIBER":[{"def":"One who subscribes; one who contributes to an undertaking by subscribing.","pos":""},{"def":"One who enters his name for a paper, book, map, or the like.","pos":""}],"SUBSCRIPT":[{"def":"Written below or underneath; as, iota subscript.","pos":""}],"SUBSCRIPTION":[{"def":"The acceptance of articles, or other tests tending to promote uniformity; esp.","pos":""},{"def":"That part of a prescription which contains the direction to the apothecary.","pos":""}],"SUBSCRIPTIVE":[{"def":"Of or pertaining to a subscription, or signature.","pos":""}],"SUBSECUTE":[{"def":"To follow closely, or so as to overtake; to pursue.","pos":""}],"SUBSECUTIVE":[{"def":"Following in a train or succession.","pos":""}],"SUBSELLIUM":[{"def":"One of the stalls of the lower range where there are two ranges.","pos":""}],"SUBSEMITONE":[{"def":"The sensible or leading note, or sharp seventh, of any key; subtonic.","pos":""}],"SUBSENSIBLE":[{"def":"Deeper than the reach of the senses.","pos":""}],"SUBSEPTUPLE":[{"def":"Having the ratio of one to seven.","pos":""},{"def":"The act or state of following; -- opposed to precedence.","pos":""}],"SUBSEQUENT":[{"def":"Following in time; coming or being after something else at any time, indefinitely; as, subsequent events; subsequent ages or years; a period long subsequent to the foundation of Rome.","pos":""},{"def":"Following in order of place; succeeding; as, a subsequent clause in a treaty.","pos":""}],"SUBSEQUENTLY":[{"def":"At a later time; afterwards.","pos":""}],"SUBSEROUS":[{"def":"Situated under a serous membrane.","pos":""}],"SUBSERVE":[{"def":"To serve in subordination or instrumentally; to be subservient to; to help forward; to promote.","pos":""}],"SUBSERVIENT":[{"def":"Fitted or disposed to subserve; useful in an inferior capacity; serving to promote some end; subordinate; hence, servile, truckling.","pos":""}],"SUBSERVIENTLY":[{"def":"In a subservient manner.","pos":""}],"SUBSESQUI-":[{"def":"A prefix (also used adjectively) denoting the combination of constituents (especially electro-negative and electro-positive bodies) in the proportion of two to three; as, a subsesqui acetate, i.","pos":""}],"SUBSEXTUPLE":[{"def":"Having the ratio of one to six; as, a subsextuple proportion.","pos":""}],"SUBSIDE":[{"def":"The act or process of subsiding.","pos":""}],"SUBSIDIARILY":[{"def":"In a subsidiary manner; so as to assist.","pos":""}],"SUBSIDIARY":[{"def":"Furnishing aid; assisting; auxiliary; helping; tributary; especially, aiding in an inferior position or capacity; as, a subsidiary stream.","pos":""},{"def":"Of or pertaining to a subsidy; constituting a subsidy; being a part of, or of the nature of, a subsidy; as, subsidiary payments to an ally.","pos":""}],"SUBSIDIZE":[{"def":"To furnish with a subsidy; to purchase the assistance of by the payment of a subsidy; to aid or promote, as a private enterprise, with public money; as, to subsidize a steamship line.","pos":""}],"SUBSIDY":[{"def":"Support; aid; coöperation; esp.","pos":""},{"def":"Specifically: A sum of money paid by one sovereign or nation to another to purchase the coöperation or the neutrality of such sovereign or nation in war.","pos":""}],"SUBSIGN":[{"def":"To sign beneath; to subscribe.","pos":""}],"SUBSIGNATION":[{"def":"The act of writing the name under something, as for attestation.","pos":""}],"SUBSILICATE":[{"def":"A basic silicate.","pos":""}],"SUBSIST":[{"def":"To be; to have existence; to inhere.","pos":""},{"def":"To continue; to retain a certain state.","pos":""}],"SUBSISTENCE":[{"def":"Same as Hypostasis, 2.","pos":""}],"SUBSISTENCE DEPARTMENT":[{"def":"A staff department of the United States army charged, under the supervision of the Chief of Staff, with the purchasing and issuing to the army of such supplies as make up the ration.","pos":""}],"SUBSISTENT":[{"def":"Having real being; as, a subsistent spirit.","pos":""},{"def":"Inherent; as, qualities subsistent in matter.","pos":""}],"SUBSIZAR":[{"def":"An under sizar; a student of lower rank than a sizar.","pos":""}],"SUBSOIL":[{"def":"The bed, or stratum, of earth which lies immediately beneath the surface soil.","pos":""}],"SUBSOLARY":[{"def":"Being under the sun; hence, terrestrial; earthly; mundane.","pos":""}],"SUBSPECIES":[{"def":"A group somewhat lessdistinct than speciesusually are, but based on characters more important than those which characterize ordinary varieties; often, a geographical variety or race.","pos":""}],"SUBSPHENOIDAL":[{"def":"Situated under, or on the ventral side of, the body of the sphenoid bone.","pos":""}],"SUBSPHERICAL":[{"def":"Nearly spherical; having a figure resembling that of a sphere.","pos":""}],"SUBSTANCE":[{"def":"Same as Hypostasis, 2.","pos":""}],"SUBSTANCELESS":[{"def":"Having no substance; unsubstantial.","pos":""}],"SUBSTANT":[{"def":"Substantial; firm.","pos":""}],"SUBSTANTIAL":[{"def":"Belonging to substance; actually existing; real; as, substantial life.","pos":""},{"def":"Not seeming or imaginary; not illusive; real; solid; true; veritable.","pos":""}],"SUBSTANTIALITY":[{"def":"The quality or state of being substantial; corporiety; materiality.","pos":""}],"SUBSTANTIALIZE":[{"def":"To make substantial.","pos":""}],"SUBSTANTIALLY":[{"def":"In a substantial manner; in substance; essentially.","pos":""}],"SUBSTANTIALNESS":[{"def":"The quality or state of being substantial; as, the substantialness of a wall or column.","pos":""}],"SUBSTANTIALS":[{"def":"Essential parts.","pos":""}],"SUBSTANTIATE":[{"def":"To make to exist; to make real.","pos":""},{"def":"To establish the existence or truth of by proof or competent evidence; to verify; as, to substantiate a charge or allegation; to substantiate a declaration.","pos":""}],"SUBSTANTIATION":[{"def":"The act of substantiating or proving; evidence; proof.","pos":""}],"SUBSTANTIVAL":[{"def":"Of or pertaining to a substantive; of the nature of substantive.","pos":""}],"SUBSTANTIVE":[{"def":"Betokening or expressing existence; as, the substantive verb, that is, the verb to be.","pos":""},{"def":"Depending on itself; independent.","pos":""}],"SUBSTANTIVELY":[{"def":"As a substantive, name, or noun; as, an adjective may be used substantively.","pos":""}],"SUBSTANTIVENESS":[{"def":"The quality or state of being substantive.","pos":""}],"SUBSTANTIVIZE":[{"def":"To convert into a substantive; as, to substantivize an adjective.","pos":""}],"SUBSTITUENT":[{"def":"Any atom, group, or radical substituted for another, or entering a molecule in place of some other part which is removed.","pos":""}],"SUBSTITUTE":[{"def":"One who, or that which, is substituted or put in the place of another; one who acts for another; that which stands in lieu of something else; specifically (Mil.","pos":""},{"def":"a person who enlists for military service in the place of a conscript or drafted man.","pos":""}],"SUBSTITUTED":[{"def":"Containing substitutions or replacements; having been subjected to the process of substitution, or having some of its parts replaced; as, alcohol is a substituted water; methyl amine is a substituted ammonia.","pos":""}],"SUBSTITUTION":[{"def":"The designation of a person in a will to take a devise or legacy, either on failure of a former devisee or legatee by incapacity or unwillingness to accept, or after him.","pos":""},{"def":"The doctrine that Christ suffered vicariously, being substituted for the sinner, and that his sufferings were expiatory.","pos":""}],"SUBSTITUTIONAL":[{"def":"Of or pertaining to substitution; standing in the place of another; substituted.","pos":""}],"SUBSTITUTIONARY":[{"def":"Of or pertaining to substitution; substitutional.","pos":""}],"SUBSTITUTIVE":[{"def":"Tending to afford or furnish a substitute; making substitution; capable of being substituted.","pos":""}],"SUBSTRACT":[{"def":"To subtract; to withdraw.","pos":""}],"SUBSTRACTION":[{"def":"See Subtraction, 3.","pos":""}],"SUBSTRACTOR":[{"def":"One who subtracts.","pos":""},{"def":"A detractor; a slanderer.","pos":""}],"SUBSTRATE":[{"def":"Having very slight furrows.","pos":""}],"SUBSTRATUM":[{"def":"The permanent subject of qualities or cause of phenomena; substance.","pos":""}],"SUBSTRUCT":[{"def":"To build beneath something; to lay as the foundation.","pos":""}],"SUBSTRUCTION":[{"def":"Underbuilding; the foundation, or any preliminary structure intended to raise the lower floor or basement of a building above the natural level of the ground.","pos":""}],"SUBSTRUCTURE":[{"def":"Same as Substruction.","pos":""}],"SUBSTYLAR":[{"def":"Pertaining to the substyle.","pos":""}],"SUBSTYLE":[{"def":"A right line on which the style, or gnomon, of a dial is erected; being the common section of the face of the dial and a plane perpendicular to it passing through the style.","pos":""}],"SUBSULPHATE":[{"def":"A sulphate with an excess of the base.","pos":""}],"SUBSULPHIDE":[{"def":"A nonacid compound consisting of one equivalent of sulphur and more than one equivalent of some other body, as a metal.","pos":""}],"SUBSULTORY":[{"def":"Bounding; leaping; moving by sudden leaps or starts.","pos":""}],"SUBSULTUS":[{"def":"A starting, twitching, or convulsive motion.","pos":""}],"SUBSUMABLE":[{"def":"Capable of being subsumed.","pos":""}],"SUBSUME":[{"def":"To take up into or under, as individual under species, species under genus, or particular under universal; to place (any one cognition) under another as belonging to it; to include under something else.","pos":""}],"SUBSUMPTION":[{"def":"The act of subsuming, or of including under another.","pos":""},{"def":"That which is subsumed, as the minor clause or premise of a syllogism.","pos":""}],"SUBSUMPTIVE":[{"def":"Relating to, or containing, a subsumption.","pos":""}]}