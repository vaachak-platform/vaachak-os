{"FIACRE":[{"def":"A kind of French hackney coach.","pos":""}],"FIANCE":[{"def":"To betroth; to affiance.","pos":""}],"FIANCEE":[{"def":"A betrothed woman.","pos":""}],"FIANTS":[{"def":"The dung of the fox, wolf, boar, or badger.","pos":""}],"FIAR":[{"def":"One in whom the property of an estate is vested, subject to the estate of a life renter.","pos":""},{"def":"The price of grain, as legally fixed, in the counties of Scotland, for the current year.","pos":""}],"FIASCO":[{"def":"A complete or ridiculous failure, esp.","pos":""}],"FIAT":[{"def":"An authoritative command or order to do something; an effectual decree.","pos":""}],"FIAUNT":[{"def":"Commission; fiat; order; decree.","pos":""}]}