{"HIBERNACLE":[{"def":"That which serves for protection or shelter in winter; winter quarters; as, the hibernacle of an animal or a plant.","pos":""}],"HIBERNACULUM":[{"def":"A winter bud, in which the rudimentary foliage or flower, as of most trees and shrubs in the temperate zone, is protected by closely overlapping scales.","pos":""},{"def":"A little case in which certain insects pass the winter.","pos":""}],"HIBERNAL":[{"def":"Belonging or relating to winter; wintry; winterish.","pos":""}],"HIBERNATE":[{"def":"To winter; to pass the season of winter in close quarters, in a torpid or lethargic state, as certain mammals, reptiles, and insects.","pos":""}],"HIBERNATION":[{"def":"The act or state of hibernating.","pos":""}],"HIBERNIAN":[{"def":"Of or pertaining to Hibernia, now Ireland; Irish.","pos":""},{"def":"A native or an inhabitant of Ireland.","pos":""}],"HIBERNO-CELTIC":[{"def":"The native language of the Irish; that branch of the Celtic languages spoken by the natives of Ireland.","pos":""}],"HIBISCUS":[{"def":"A genus of plants (herbs, shrubs, or trees), some species of which have large, showy flowers.","pos":""}]}