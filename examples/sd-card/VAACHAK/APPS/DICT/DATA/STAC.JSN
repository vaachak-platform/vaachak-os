{"STACCATO":[{"def":"Disconnected; separated; distinct; -- a direction to perform the notes of a passage in a short, distinct, and pointed manner.","pos":""}],"STACK":[{"def":"A large pile of hay, grain, straw, or the like, usually of a nearly conical form, but sometimes rectangular or oblong, contracted at the top to a point or ridge, and sometimes covered with thatch.","pos":""},{"def":"A pile of poles or wood, indefinite in quantity.","pos":""}],"STACK-GUARD":[{"def":"A covering or protection, as a canvas, for a stack.","pos":""}],"STACKAGE":[{"def":"Hay, gray, or the like, in stacks; things stacked.","pos":""},{"def":"A tax on things stacked.","pos":""}],"STACKSTAND":[{"def":"A staging for supporting a stack of hay or grain; a rickstand.","pos":""}],"STACKYARD":[{"def":"A yard or inclosure for stacks of hay or grain.","pos":""}],"STACTE":[{"def":"One of the sweet spices used by the ancient Jews in the preparation of incense.","pos":""}]}