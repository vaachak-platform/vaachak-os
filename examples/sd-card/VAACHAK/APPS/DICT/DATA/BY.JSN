{"BY":[{"def":"In the neighborhood of; near or next to; not far from; close to; along with; as, come and sit by me.","pos":""},{"def":"On; along; in traversing.","pos":""}],"BY-BIDDER":[{"def":"One who bids at an auction in behalf of the auctioneer or owner, for the purpose of running up the price of articles.","pos":""}],"BY-BLOW":[{"def":"A side or incidental blow; an accidental blow.","pos":""},{"def":"An illegitimate child; a bastard.","pos":""}],"BY-CORNER":[{"def":"A private corner.","pos":""}],"BY-DEPENDENCE":[{"def":"An appendage; that which depends on something else, or is distinct from the main dependence; an accessory.","pos":""}],"BY-DRINKING":[{"def":"A drinking between meals.","pos":""}],"BY-ELECTION":[{"def":"An election held by itself, not at the time of a general election.","pos":""}],"BY-END":[{"def":"Private end or interest; secret purpose; selfish advantage.","pos":""}],"BY-INTEREST":[{"def":"Self-interest; private advantage.","pos":""}],"BY-LANE":[{"def":"A private lane, or one opening out of the usual road.","pos":""}],"BY-LAW":[{"def":"A local or subordinate law; a private law or regulation made by a corporation for its own government.","pos":""},{"def":"A law that is less important than a general law or constitutional provision, and subsidiary to it; a rule relating to a matter of detail; as, civic societies often adopt a constitution and by-laws for the government of their members.","pos":""}],"BY-PASS":[{"def":"A by-passage, for a pipe, or other channel, to divert circulation from the usual course.","pos":""}],"BY-PASSAGE":[{"def":"A passage different from the usual one; a byway.","pos":""}],"BY-PLACE":[{"def":"A retired or private place.","pos":""}],"BY-PRODUCT":[{"def":"A secondary or additional product; something produced, as in the course of a manufacture, in addition to the principal product.","pos":""}],"BY-RESPECT":[{"def":"Private end or view; by-interest.","pos":""}],"BY-ROOM":[{"def":"A private room or apartment.","pos":""}],"BY-SPEECH":[{"def":"An incidental or casual speech, not directly relating to the point.","pos":""}],"BY-STREET":[{"def":"A separate, private, or obscure street; an out of the way or cross street.","pos":""}],"BY-STROKE":[{"def":"An accidental or a slyly given stroke.","pos":""}],"BY-TURNING":[{"def":"An obscure road; a way turning from the main road.","pos":""}],"BY-VIEW":[{"def":"A private or selfish view; self-interested aim or purpose.","pos":""}],"BY-WALK":[{"def":"secluded or private walk.","pos":""}],"BY-WASH":[{"def":"The outlet from a dam or reservoir; also, a cut to divert the flow of water.","pos":""}],"BY-WIPE":[{"def":"A secret or side stroke, as of raillery or sarcasm.","pos":""}],"BYARD":[{"def":"A piece of leather crossing the breast, used by the men who drag sledges in coal mines.","pos":""}],"BYE":[{"def":"A run made upon a missed ball; as, to steal a bye.","pos":""}],"BYGONE":[{"def":"Something gone by or past; a past event.","pos":""}],"BYNAME":[{"def":"To give a nickname to.","pos":""}],"BYPATH":[{"def":"A private path; an obscure way; indirect means.","pos":""}],"BYPLAY":[{"def":"Action carried on aside, and commonly in dumb show, while the main action proceeds.","pos":""}],"BYROAD":[{"def":"A private or obscure road.","pos":""}],"BYRONIC":[{"def":"Pertaining to, or in the style of, Lord Byron.","pos":""}],"BYSMOTTERED":[{"def":"Bespotted with mud or dirt.","pos":""}],"BYSSACEOUS":[{"def":"Byssuslike; consisting of fine fibers or threads, as some very delicate filamentous algæ.","pos":""}],"BYSSIFEROUS":[{"def":"Bearing a byssus or tuft.","pos":""}],"BYSSINE":[{"def":"Made of silk; having a silky or flaxlike appearance.","pos":""}],"BYSSOLITE":[{"def":"An olive-green fibrous variety of hornblende.","pos":""}],"BYSSUS":[{"def":"A tuft of long, tough filaments which are formed in a groove of the foot, and issue from between the valves of certain bivalve mollusks, as the Pinna and Mytilus, by which they attach themselves to rocks, etc.","pos":""},{"def":"An obsolete name for certain fungi composed of slender threads.","pos":""}],"BYSTANDER":[{"def":"One who stands near; a spectator; one who has no concern with the business transacting.","pos":""}],"BYWAY":[{"def":"A secluded, private, or obscure way; a path or road aside from the main one.","pos":""}],"BYWORD":[{"def":"A common saying; a proverb; a saying that has a general currency.","pos":""},{"def":"The object of a contemptuous saying.","pos":""}],"BYWORK":[{"def":"Work aside from regular work; subordinate or secondary business.","pos":"noun"},{"def":"A gold coin, so called from being coined at Byzantium.","pos":"noun"}],"BYZANTINE":[{"def":"Of or pertaining to Byzantium.","pos":""},{"def":"A native or inhabitant of Byzantium, now Constantinople; sometimes, applied to an inhabitant of the modern city of Constantinople.","pos":""}]}