{"EWE":[{"def":"The female of the sheep, and of sheeplike animals.","pos":""}],"EWE-NECKED":[{"def":"Having a neck like a ewe; -- said of horses in which the arch of the neck is deficent, being somewhat hollowed out.","pos":""}],"EWER":[{"def":"A kind of widemouthed pitcher or jug; esp.","pos":""},{"def":"An office or place of household service where the ewers were formerly kept.","pos":""}]}