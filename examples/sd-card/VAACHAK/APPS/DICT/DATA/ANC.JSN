{"ANCE":[{"def":"A suffix signifying action; also, quality or state; as, assistance, resistance, appearance, elegance.","pos":""},{"def":"A suffix signifying action; also, quality or state; as, assistance, resistance, appearance, elegance.","pos":""}],"ANCESTOR":[{"def":"An earlier type; a progenitor; as, this fossil animal is regarded as the ancestor of the horse.","pos":""},{"def":"One from whom an estate has descended; -- the correlative of heir.","pos":""}],"ANCESTORIALLY":[{"def":"With regard to ancestors.","pos":""}],"ANCESTRAL":[{"def":"Of, pertaining to, derived from, or possessed by, an ancestor or ancestors; as, an ancestral estate.","pos":""}],"ANCESTRESS":[{"def":"A female ancestor.","pos":""}],"ANCESTRY":[{"def":"Condition as to ancestors; ancestral lineage; hence, birth or honorable descent.","pos":""},{"def":"A series of ancestors or progenitors; lineage, or those who compose the line of natural descent.","pos":""}],"ANCHOR":[{"def":"An emblem of hope.","pos":""},{"def":"One of the anchor-shaped spicules of certain sponges; also, one of the calcareous spinules of certain Holothurians, as in species of Synapta.","pos":""}],"ANCHOR LIGHT":[{"def":"The lantern shown at night by a vessel at anchor.","pos":""}],"ANCHOR SHOT":[{"def":"A shot made with the object balls in an anchor space.","pos":""}],"ANCHOR SPACE":[{"def":"In the balk-line game, any of eight spaces, 7 inches by 3½, lying along a cushion and bisected transversely by a balk line.","pos":""}],"ANCHOR WATCH":[{"def":"A detail of one or more men who keep watch on deck at night when a vessel is at anchor.","pos":""}],"ANCHOR-HOLD":[{"def":"The hold or grip of an anchor, or that to which it holds.","pos":""},{"def":"Hence: Firm hold: security.","pos":""}],"ANCHORABLE":[{"def":"Fit for anchorage.","pos":""}],"ANCHORAGE":[{"def":"The act of anchoring, or the condition of lying at anchor.","pos":""},{"def":"A place suitable for anchoring or where ships anchor; a hold for an anchor.","pos":""}],"ANCHORED":[{"def":"Having the extremities turned back, like the flukes of an anchor; as, an anchored cross.","pos":""}],"ANCHORESS":[{"def":"A female anchoret.","pos":""},{"def":"One who renounces the world and secludes himself, usually for religious reasons; a hermit; a recluse.","pos":""}],"ANCHORETISM":[{"def":"The practice or mode of life of an anchoret.","pos":""}],"ANCHORITE":[{"def":"Same as Anchoret.","pos":""}],"ANCHORLESS":[{"def":"Without an anchor or stay.","pos":""}],"ANCHOVY":[{"def":"A small fish, about three inches in length, of the Herring family (Engraulis encrasicholus), caught in vast numbers in the Mediterranean, and pickled for exportation.","pos":""}],"ANCHOVY PEAR":[{"def":"A West Indian fruit like the mango in taste, sometimes pickled; also, the tree (Grias cauliflora) bearing this fruit.","pos":""}],"ANCHUSIN":[{"def":"A resinoid coloring matter obtained from alkanet root.","pos":""}],"ANCHYLOSE":[{"def":"To affect or be affected with anchylosis; to unite or consolidate so as to make a stiff joint; to grow together into one.","pos":""},{"def":"Stiffness or fixation of a joint; formation of a stiff joint.","pos":""}],"ANCHYLOTIC":[{"def":"Of or pertaining to anchylosis.","pos":""}],"ANCIENT":[{"def":"Old; that happened or existed in former times, usually at a great distance of time; belonging to times long past; specifically applied to the times before the fall of the Roman empire; -- opposed to modern; as, ancient authors, literature, history; ancient days.","pos":""},{"def":"Old; that has been of long duration; of long standing; of great age; as, an ancient forest; an ancient castle.","pos":""}],"ANCIENTLY":[{"def":"In ancient times.","pos":""},{"def":"In an ancient manner.","pos":""}],"ANCIENTNESS":[{"def":"The quality of being ancient; antiquity; existence from old times.","pos":""}],"ANCIENTRY":[{"def":"Antiquity; what is ancient.","pos":""},{"def":"Old age; also, old people.","pos":""}],"ANCILE":[{"def":"The sacred shield of the Romans, said to have-fallen from heaven in the reign of Numa.","pos":""}],"ANCILLARY":[{"def":"Subservient or subordinate, like a handmaid; auxiliary.","pos":""}],"ANCILLARY ADMINISTRATION":[{"def":"An administration subordinate to, and in aid of, the primary or principal administration of an estate.","pos":""}],"ANCILLE":[{"def":"A maidservant; a handmaid.","pos":""},{"def":"Two-edged instead of round; -- said of certain flattened stems, as those of blue grass, and rarely also of leaves.","pos":""}],"ANCOME":[{"def":"A small ulcerous swelling, coming suddenly; also, a whitlow.","pos":""}],"ANCON":[{"def":"The olecranon, or the elbow.","pos":""},{"def":"Of or pertaining to the ancon or elbow.","pos":""}],"ANCONEUS":[{"def":"A muscle of the elbow and forearm.","pos":""}],"ANCONOID":[{"def":"Elbowlike; anconal.","pos":""}],"ANCONY":[{"def":"A piece of malleable iron, wrought into the shape of a bar in the middle, but unwrought at the ends.","pos":""},{"def":"A suffix expressing more strongly than -ance the idea of quality or state; as, constancy, buoyancy, infancy.","pos":""}]}