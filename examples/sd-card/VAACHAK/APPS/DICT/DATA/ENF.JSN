{"ENFACE":[{"def":"To write or print on the face of (a draft, bill, etc.","pos":""},{"def":"To write or print (a memorandum, direction, or the like) on the face of a draft, bill, etc.","pos":""}],"ENFAMISH":[{"def":"To famish; to starve.","pos":""}],"ENFECT":[{"def":"Contaminated with illegality.","pos":""}],"ENFEEBLE":[{"def":"To make feeble; to deprive of strength; to reduce the strength or force of; to weaken; to debilitate.","pos":""}],"ENFEEBLEMENT":[{"def":"The act of weakening; enervation; weakness.","pos":""}],"ENFEEBLER":[{"def":"One who, or that which, weakens or makes feeble.","pos":""}],"ENFELONED":[{"def":"Rendered fierce or frantic.","pos":""}],"ENFEOFF":[{"def":"To give a feud, or right in land, to; to invest with a fief or fee; to invest (any one) with a freehold estate by the process of feoffment.","pos":""}],"ENFETTER":[{"def":"To bind in fetters; to enchain.","pos":""}],"ENFEVER":[{"def":"To excite fever in.","pos":""}],"ENFILADE":[{"def":"A firing in the direction of the length of a trench, or a line of parapet or troops, etc.","pos":""}],"ENFILED":[{"def":"Having some object, as the head of a man or beast, impaled upon it; as, a sword which is said to be \"enfiled of\" the thing which it pierces.","pos":""}],"ENFLESH":[{"def":"To clothe with flesh.","pos":""}],"ENFLEURAGE":[{"def":"A process of extracting perfumes by exposing absorbents, as fixed oils or fats, to the exhalations of the flowers.","pos":""}],"ENFLOWER":[{"def":"To cover or deck with flowers.","pos":""}],"ENFOLDMENT":[{"def":"The act of infolding.","pos":""}],"ENFORCE":[{"def":"To put force upon; to force; to constrain; to compel; as, to enforce obedience to commands.","pos":""},{"def":"To make or gain by force; to obtain by force; as, to enforce a passage.","pos":""}],"ENFORCEABLE":[{"def":"Capable of being enforced.","pos":""}],"ENFORCED":[{"def":"Compelled; forced; not voluntary.","pos":""}],"ENFORCEMENT":[{"def":"The act of enforcing; compulsion.","pos":""},{"def":"A giving force to; a putting in execution.","pos":""}],"ENFORCER":[{"def":"One who enforces.","pos":""}],"ENFORCIBLE":[{"def":"That may be enforced.","pos":""}],"ENFORCIVE":[{"def":"Serving to enforce or constrain; compulsive.","pos":""}],"ENFOREST":[{"def":"To turn into a forest.","pos":""}],"ENFORM":[{"def":"To form; to fashion.","pos":""}],"ENFOULDRED":[{"def":"Mixed with, or emitting, lightning.","pos":""}],"ENFRAME":[{"def":"To inclose, as in a frame.","pos":""}],"ENFRANCHISE":[{"def":"To set free; to liberate from slavery, prison, or any binding power.","pos":""},{"def":"To endow with a franchise; to incorporate into a body politic and thus to invest with civil and political privileges; to admit to the privileges of a freeman.","pos":""}],"ENFRANCHISEMENT":[{"def":"Releasing from slavery or custody.","pos":""},{"def":"Admission to the freedom of a corporation or body politic; investiture with the privileges of free citizens.","pos":""}],"ENFRANCHISER":[{"def":"One who enfranchises.","pos":""}],"ENFREEZE":[{"def":"To freeze; to congeal.","pos":""}],"ENFROWARD":[{"def":"To make froward, perverse, or ungovernable.","pos":""}]}