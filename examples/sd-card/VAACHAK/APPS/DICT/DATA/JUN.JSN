{"JUNCO":[{"def":"Any bird of the genus Junco, which includes several species of North American finches; -- called also snowbird, or blue snowbird.","pos":""}],"JUNCOUS":[{"def":"Full of rushes: resembling rushes; juncaceous.","pos":""}],"JUNCTION":[{"def":"The act of joining, or the state of being joined; union; combination; coalition; as, the junction of two armies or detachments; the junction of paths.","pos":""},{"def":"The place or point of union, meeting, or junction; specifically, the place where two or more lines of railway meet or cross.","pos":""}],"JUNCTION BOX":[{"def":"A box through which the main conductors of a system of electric distribution pass, and where connection is made with branch circuits.","pos":""}],"JUNCTURE":[{"def":"A joining; a union; an alliance.","pos":""},{"def":"The line or point at which two bodies are joined; a joint; an articulation; a seam; as, the junctures of a vessel or of the bones.","pos":""}],"JUNE":[{"def":"The sixth month of the year, containing thirty days.","pos":""}],"JUNEATING":[{"def":"A kind of early apple.","pos":""}],"JUNGERMANNIA":[{"def":"A genus of hepatic mosses, now much circumscribed, but formerly comprising most plants of the order, which is sometimes therefore called Jungermanniaceæ.","pos":""}],"JUNGLE":[{"def":"A dense growth of brushwood, grasses, reeds, vines, etc.","pos":""}],"JUNGLY":[{"def":"Consisting of jungles; abounding with jungles; of the nature of a jungle.","pos":""}],"JUNIOR":[{"def":"Less advanced in age than another; younger.","pos":""},{"def":"Lower in standing or in rank; later in office; as, a junior partner; junior counsel; junior captain.","pos":""}],"JUNIORITY":[{"def":"The state or quality of being junior.","pos":""}],"JUNIPER":[{"def":"Any evergreen shrub or tree, of the genus Juniperus and order Coniferæ.","pos":""}],"JUNIPERIN":[{"def":"A yellow amorphous substance extracted from juniper berries.","pos":""}],"JUNIPERITE":[{"def":"One of the fossil Coniferæ, evidently allied to the juniper.","pos":""}],"JUNK":[{"def":"A fragment of any solid substance; a thick piece.","pos":""}],"JUNKER":[{"def":"A young German noble or squire; esp.","pos":""}],"JUNKERISM":[{"def":"The principles of the aristocratic party in Prussia.","pos":""}],"JUNKET":[{"def":"A cheese cake; a sweetmeat; any delicate food.","pos":""},{"def":"A feast; an entertainment.","pos":""}],"JUNKETING":[{"def":"A feast or entertainment; a revel.","pos":""}],"JUNO":[{"def":"The sister and wife of Jupiter, the queen of heaven, and the goddess who presided over marriage.","pos":""},{"def":"One of the early discovered asteroids.","pos":""}],"JUNTA":[{"def":"A council; a convention; a tribunal; an assembly; esp.","pos":""}],"JUNTO":[{"def":"A secret council to deliberate on affairs of government or politics; a number of men combined for party intrigue; a faction; a cabal; as, a junto of ministers; a junto of politicians.","pos":""}]}