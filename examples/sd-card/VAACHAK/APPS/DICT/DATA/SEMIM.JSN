{"SEMIMETAL":[{"def":"An element possessing metallic properties in an inferior degree and not malleable, as arsenic, antimony, bismuth, molybdenum, uranium, etc.","pos":""}],"SEMIMETALLIC":[{"def":"Of or pertaining to a semimetal; possessing metallic properties in an inferior degree; resembling metal.","pos":""}],"SEMIMONTHLY":[{"def":"Coming or made twice in a month; as, semimonthly magazine; a semimonthly payment.","pos":""},{"def":"Something done or made every half month; esp.","pos":""}],"SEMIMUTE":[{"def":"Having the faculty of speech but imperfectly developed or partially lost.","pos":""}]}