{"SEVEN":[{"def":"One more than six; six and one added; as, seven days make one week.","pos":""}],"SEVEN-THIRTIES":[{"def":"A name given to three several issues of United States Treasury notes, made during the Civil War, in denominations of $50 and over, bearing interest at the rate of seven and three tenths (thirty hundredths) per cent annually.","pos":""}],"SEVEN-UP":[{"def":"The game of cards called also all fours, and old sledge.","pos":""}],"SEVENFOLD":[{"def":"Repeated seven times; having seven thicknesses; increased to seven times the size or amount.","pos":""}],"SEVENNIGHT":[{"def":"A week; any period of seven consecutive days and nights.","pos":""}],"SEVENSCORE":[{"def":"Seven times twenty, that is, a hundred and forty.","pos":""}],"SEVENTEEN":[{"def":"One more than sixteen; ten and seven added; as, seventeen years.","pos":""}],"SEVENTEENTH":[{"def":"Next in order after the sixteenth; coming after sixteen others.","pos":""},{"def":"Constituting or being one of seventeen equal parts into which anything is divided.","pos":""}],"SEVENTH":[{"def":"Next in order after the sixth;; coming after six others.","pos":""},{"def":"Constituting or being one of seven equal parts into which anything is divided; as, the seventh part.","pos":""}],"SEVENTHLY":[{"def":"In the seventh place.","pos":""}],"SEVENTIETH":[{"def":"Next in order after the sixty-ninth; as, a man in the seventieth year of his age.","pos":""},{"def":"Constituting or being one of seventy equal parts.","pos":""}],"SEVENTY":[{"def":"Seven times ten; one more than sixty-nine.","pos":""}],"SEVENTY-FOUR":[{"def":"A naval vessel carrying seventy-four guns.","pos":""}],"SEVER":[{"def":"To disunite; to disconnect; to terminate; as, to sever an estate in joint tenancy.","pos":""}],"SEVERABLE":[{"def":"Capable of being severed.","pos":""}],"SEVERAL":[{"def":"Separate; distinct; particular; single.","pos":""},{"def":"Diverse; different; various.","pos":""}],"SEVERALITY":[{"def":"Each particular taken singly; distinction.","pos":""}],"SEVERALLY":[{"def":"Separately; distinctly; apart from others; individually.","pos":""}],"SEVERALTY":[{"def":"A state of separation from the rest, or from all others; a holding by individual right.","pos":""}],"SEVERANCE":[{"def":"The act of dividing; the singling or severing of two or more that join, or are joined, in one writ; the putting in several or separate pleas or answers by two or more disjointly; the destruction of the unity of interest in a joint estate.","pos":""}],"SEVERE":[{"def":"Serious in feeeling or manner; sedate; grave; austere; not light, lively, or cheerful.","pos":""},{"def":"Very strict in judgment, discipline, or government; harsh; not mild or indulgent; rigorous; as, severe criticism; severe punishment.","pos":""}],"SEVERITY":[{"def":"The quality or state of being severe.","pos":""}],"SEVERY":[{"def":"A bay or compartment of a vaulted ceiling.","pos":""}],"SEVOCATION":[{"def":"A calling aside.","pos":""}],"SEVRES BLUE":[{"def":"A very light blue.","pos":""}],"SEVRES WARE":[{"def":"Porcelain manufactured at Sèvres, France, ecpecially in the national factory situated there.","pos":""}]}