{"LION":[{"def":"A large carnivorous feline mammal (Felis leo), found in Southern Asia and in most parts of Africa, distinct varieties occurring in the different countries.","pos":""},{"def":"A sign and a constellation; Leo.","pos":""}],"LION'S EAR":[{"def":"A name given in Western South America to certain plants with shaggy tomentose leaves, as species of Culcitium, and Espeletia.","pos":""}],"LION'S LEAF":[{"def":"A South European plant of the genus Leontice (L.","pos":""}],"LION'S TAIL":[{"def":"A genus of labiate plants (Leonurus); -- so called from a fancied resemblance of its flower spikes to the tuft of a lion's tail.","pos":""}],"LION-HEART":[{"def":"A very brave person.","pos":""}],"LION-HEARTED":[{"def":"Very brave; brave and magnanimous.","pos":""}],"LIONCED":[{"def":"Adorned with lions heads; having arms terminating in lions' heads; -- said of a cross.","pos":""}],"LIONCEL":[{"def":"A small lion, especially one of several borne in the same coat of arms.","pos":""}],"LIONEL":[{"def":"The whelp of a lioness; a young lion.","pos":""}],"LIONET":[{"def":"A young or small lion.","pos":""}],"LIONHOOD":[{"def":"State of being a lion.","pos":""}],"LIONISM":[{"def":"An attracting of attention, as a lion; also, the treating or regarding as a lion.","pos":""}],"LIONIZE":[{"def":"To treat or regard as a lion or object of great interest.","pos":""},{"def":"To show the lions or objects of interest to; to conduct about among objects of interest.","pos":""}],"LIONLIKE":[{"def":"Like a lion; brave as a lion.","pos":""}],"LIONLY":[{"def":"Like a lion; fierce.","pos":""}],"LIONSHIP":[{"def":"The state of being a lion.","pos":""}]}