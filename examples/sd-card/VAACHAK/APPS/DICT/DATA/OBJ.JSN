{"OBJECT":[{"def":"To set before or against; to bring into opposition; to oppose.","pos":""},{"def":"To offer in opposition as a criminal charge or by way of accusation or reproach; to adduce as an objection or adverse reason.","pos":""}],"OBJECTABLE":[{"def":"Such as can be presented in opposition; that may be put forward as an objection.","pos":""}],"OBJECTIFY":[{"def":"To cause to become an object; to cause to assume the character of an object; to render objective.","pos":""}],"OBJECTION":[{"def":"The act of objecting; as, to prevent agreement, or action, by objection.","pos":""},{"def":"That which is, or may be, presented in opposition; an adverse reason or argument; a reason for objecting; obstacle; impediment; as, I have no objection to going; unreasonable objections.","pos":""}],"OBJECTIONABLE":[{"def":"Liable to objection; likely to be objected to or disapproved of; offensive; as, objectionable words.","pos":""}],"OBJECTIST":[{"def":"One who adheres to, or is skilled in, the objective philosophy.","pos":""}],"OBJECTIVATION":[{"def":"Converting into an object.","pos":""}],"OBJECTIVE":[{"def":"Of or pertaining to an object; contained in, or having the nature or position of, an object; outward; external; extrinsic; -- an epithet applied to whatever ir exterior to the mind, or which is simply an object of thought or feeling, and opposed to subjective.","pos":""},{"def":"Pertaining to, or designating, the case which follows a transitive verb or a preposition, being that case in which the direct object of the verb is placed.","pos":""}],"OBJECTIVELY":[{"def":"In the manner or state of an object; as, a determinate idea objectively in the mind.","pos":""}],"OBJECTIVENESS":[{"def":"Is there such a motion or objectiveness of external bodies, which produceth light Sir M.","pos":""}],"OBJECTIVITY":[{"def":"The state, quality, or relation of being objective; character of the object or of the objective.","pos":""}],"OBJECTIZE":[{"def":"To make an object of; to regard as an object; to place in the position of an object.","pos":""}],"OBJECTLESS":[{"def":"Having no object; purposeless.","pos":""}],"OBJECTOR":[{"def":"One who objects; one who offers objections to a proposition or measure.","pos":""}],"OBJICIENT":[{"def":"One who makes objection; an objector.","pos":""}],"OBJURATION":[{"def":"A binding by oath.","pos":""}],"OBJURGATE":[{"def":"To chide; to reprove.","pos":""}],"OBJURGATION":[{"def":"The act of objurgating; reproof.","pos":""}],"OBJURGATORY":[{"def":"Designed to objurgate or chide; containing or expressing reproof; culpatory.","pos":""}]}