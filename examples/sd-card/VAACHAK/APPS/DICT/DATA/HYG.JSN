{"HYGEIA":[{"def":"The goddess of health, daughter of Esculapius.","pos":""}],"HYGEIAN":[{"def":"Relating to Hygeia, the goddess of health; of or pertaining to health, or its preservation.","pos":""}],"HYGEIST":[{"def":"One skilled in hygiena; a hygienist.","pos":""}],"HYGIENE":[{"def":"That department of sanitary science which treats of the preservation of health, esp.","pos":""}],"HYGIENIC":[{"def":"Of or pertaining to health or hygiene; sanitary.","pos":""}],"HYGIENICS":[{"def":"The science of health; hygiene.","pos":""}],"HYGIENIST":[{"def":"One versed in hygiene.","pos":""}],"HYGIOLOGY":[{"def":"A treatise on, or the science of, the preservation of health.","pos":""}],"HYGRINE":[{"def":"An alkaloid associated with cocaine in coca leaves (Erythroxylon coca), and extracted as a thick, yellow oil, having a pungent taste and odor.","pos":""}],"HYGRODEIK":[{"def":"A form of hygrometer having wet and dry bulb thermometers, with an adjustable index showing directly the percentage of moisture in the air, etc.","pos":""}],"HYGROGRAPH":[{"def":"An instrument for recording automatically the variations of the humidity of the atmosphere.","pos":""}],"HYGROLOGY":[{"def":"The science which treats of the fluids of the body.","pos":""}],"HYGROMETER":[{"def":"An instrument for measuring the degree of moisture of the atmosphere.","pos":""}],"HYGROMETRY":[{"def":"That branch of physics which relates to the determination of the humidity of bodies, particularly of the atmosphere, with the theory and use of the instruments constructed for this purpose.","pos":""}],"HYGROPHANOUS":[{"def":"Having such a structure as to be diaphanous when moist, and opaque when dry.","pos":""}],"HYGROPHTHALMIC":[{"def":"Serving to moisten the eye; -- sometimes applied to the lachrymal ducts.","pos":""}],"HYGROPLASM":[{"def":"The fluid portion of the cell protoplasm, in opposition to stereoplasm, the solid or insoluble portion.","pos":""}],"HYGROSCOPE":[{"def":"An instrument which shows whether there is more or less moisture in the atmosphere, without indicating its amount.","pos":""}],"HYGROSCOPIC":[{"def":"Of or pertaining to, or indicated by, the hygroscope; not readily manifest to the senses, but capable of detection by the hygroscope; as, glass is often covered with a film of hygroscopic moisture.","pos":""},{"def":"Having the property of readily inbibing moisture from the atmosphere, or of the becoming coated with a thin film of moisture, as glass, etc.","pos":""}],"HYGROSCOPICITY":[{"def":"The property possessed by vegetable tissues of absorbing or discharging moisture according to circumstances.","pos":""}],"HYGROSTATICS":[{"def":"The science or art of comparing or measuring degrees of moisture.","pos":""}]}