{"VAN":[{"def":"The front of an army; the first line or leading column; also, the front line or foremost division of a fleet, either in sailing or in battle.","pos":""}],"VAN'T HOFF'S LAW":[{"def":"The generalization that: when a system is in equilibrium, of the two opposed interactions the endothermic is promoted by raising the temperature, the exothermic by lowering it.","pos":""}],"VAN-COURIER":[{"def":"One sent in advance; an avant-courier; a precursor.","pos":""}],"VANADATE":[{"def":"A salt of vanadic acid.","pos":""}],"VANADIC":[{"def":"Pertaining to, or obtained from, vanadium; containing vanadium; specifically distinguished those compounds in which vanadium has a relatively higher valence as contrasted with the vanadious compounds; as, vanadic oxide.","pos":""}],"VANADINITE":[{"def":"A mineral occurring in yellowish, and ruby-red hexagonal crystals.","pos":""}],"VANADIOUS":[{"def":"Pertaining to, or containing, vanadium; specifically, designating those compounds in which vanadium has a lower valence as contrasted with the vanadic compounds; as, vanadious acid.","pos":""}],"VANADITE":[{"def":"A salt of vanadious acid, analogous to a nitrite or a phosphite.","pos":""}],"VANADIUM":[{"def":"A rare element of the nitrogen-phosphorus group, found combined, in vanadates, in certain minerals, and reduced as an infusible, grayish-white metallic powder.","pos":""}],"VANADIUM BRONZE":[{"def":"A yellow pigment consisting of a compound of vanadium.","pos":""}],"VANADOUS":[{"def":"Of or pertaining to vanadium; obtained from vanadium; -- said of an acid containing one equivalent of vanadium and two of oxygen.","pos":""}],"VANADYL":[{"def":"The hypothetical radical VO, regarded as a characterized residue of certain vanadium compounds.","pos":""}],"VANDAL":[{"def":"One of a Teutonic race, formerly dwelling on the south shore of the Baltic, the most barbarous and fierce of the northern nations that plundered Rome in the 5th century, notorious for destroying the monuments of art and literature.","pos":""},{"def":"Of or pertaining to the Vandals; resembling the Vandals in barbarism and destructiveness.","pos":""}],"VANDALISM":[{"def":"The spirit or conduct of the Vandals; ferocious cruelty; hostility to the arts and literature, or willful destruction or defacement of their monuments.","pos":""}],"VANDYKE":[{"def":"Of or pertaining to the style of Vandyke the painter; used or represented by Vandyke.","pos":""}],"VANDYKE BEARD":[{"def":"A trim, pointed beard, such as those often seen in pictures by Vandyke.","pos":""}],"VANE":[{"def":"The rhachis and web of a feather taken together.","pos":""}],"VANESSA":[{"def":"Any one of numerous species of handsomely colored butterflies belonging to Vanessa and allied genera.","pos":""}],"VANFESS":[{"def":"A ditch on the outside of the counterscarp, usually full of water.","pos":""}],"VANG":[{"def":"A rope to steady the peak of a gaff.","pos":""}],"VANGLO":[{"def":"Benne (Sesamum orientale); also, its seeds; -- so called in the West Indies.","pos":""}],"VANGUARD":[{"def":"The troops who march in front of an army; the advance guard; the van.","pos":""}],"VANILLA":[{"def":"A genus of climbing orchidaceous plants natives of tropical America.","pos":""}],"VANILLATE":[{"def":"A salt of vanillic acid.","pos":""}],"VANILLIC":[{"def":"Pertaining to, or derived from, vanilla or vanillin; resembling vanillin; specifically, designating an alcohol and an acid respectively, vanillin being the intermediate aldehyde.","pos":""}],"VANILLIN":[{"def":"A white crystalline aldehyde having a burning taste and characteristic odor of vanilla.","pos":""}],"VANILLOES":[{"def":"An inferior kind of vanilla, the pods of Vanilla Pompona.","pos":""}],"VANILLYL":[{"def":"The hypothetical radical characteristic of vanillic alcohol.","pos":""}],"VANILOQUENCE":[{"def":"Vain or foolish talk.","pos":""}],"VANISH":[{"def":"To pass from a visible to an invisible state; to go out of sight; to disappear; to fade; as, vapor vanishes from the sight by being dissipated; a ship vanishes from the sight of spectators on land.","pos":""},{"def":"To be annihilated or lost; to pass away.","pos":""}],"VANISHING":[{"def":"Van\"ish*ing, Defn: a.","pos":""}],"VANITY":[{"def":"The quality or state of being vain; want of substance to satisfy desire; emptiness; unsubstantialness; unrealness; falsity.","pos":""},{"def":"An inflation of mind upon slight grounds; empty pride inspired by an overweening conceit of one's personal attainments or decorations; an excessive desire for notice or approval; pride; ostentation; conceit.","pos":""}],"VANITY BOX":[{"def":"A small box, usually jeweled or of precious metal and worn on a chain, containing a mirror, powder puff, and other small toilet articles for a woman.","pos":""}],"VANJAS":[{"def":"The Australian pied crow shrike (Strepera graculina).","pos":""}],"VANNER":[{"def":"A machine for concentrating ore.","pos":""}],"VANNING":[{"def":"A process by which ores are washed on a shovel, or in a vanner.","pos":""}],"VANQUISH":[{"def":"To conquer, overcome, or subdue in battle, as an enemy.","pos":""},{"def":"Hence, to defeat in any contest; to get the better of; to put down; to refute.","pos":""}],"VANQUISHABLE":[{"def":"That may be vanquished.","pos":""}],"VANQUISHER":[{"def":"One who, or that which, vanquishes.","pos":""}],"VANQUISHMENT":[{"def":"The act of vanquishing, or the state of being vanquished.","pos":""}],"VANSIRE":[{"def":"An ichneumon (Herpestes galera) native of Southern Africa and Madagascar.","pos":""}],"VANT-COURIER":[{"def":"An avant-courier.","pos":""}],"VANTAGE":[{"def":"The first point after deuce.","pos":""}],"VANTAGE GAME":[{"def":"The first game after the set is deuce.","pos":""}],"VANTAGE POINT":[{"def":"A point giving advantage; vantage ground.","pos":""},{"def":"Armor for the arm; vambrace.","pos":""}],"VANWARD":[{"def":"Being on, or towards, the van, or front.","pos":""}]}