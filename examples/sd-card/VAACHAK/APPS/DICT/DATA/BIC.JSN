{"BICALCARATE":[{"def":"Having two spurs, as the wing or leg of a bird.","pos":""},{"def":"Having two callosities or hard spots.","pos":""}],"BICAMERAL":[{"def":"Consisting of, or including, two chambers, or legislative branches.","pos":""}],"BICAPSULAR":[{"def":"Having two capsules; as, a bicapsular pericarp.","pos":""}],"BICARBONATE":[{"def":"A carbonate in which but half the hydrogen of the acid is replaced by a positive element or radical, thus making the proportion of the acid to the positive or basic portion twice what it is in the normal carbonates; an acid carbonate; -- sometimes called supercarbonate.","pos":""},{"def":"Containing two atoms or equivalents of carbon in the molecule.","pos":""}],"BICARINATE":[{"def":"Having two keel-like projections, as the upper palea of grasses.","pos":""}],"BICAUDAL":[{"def":"Having, or terminating in, two tails.","pos":""}],"BICAUDATE":[{"def":"Two-tailed; bicaudal.","pos":""}],"BICCHED":[{"def":"Pecked; pitted; notched.","pos":""},{"def":"A pale blue pigment, prepared from the native blue carbonate of copper, or from smalt; -- called also blue bice.","pos":""}],"BICENTENARY":[{"def":"Of or pertaining to two hundred, esp.","pos":""},{"def":"The two hundredth anniversary, or its celebration.","pos":""}],"BICENTENNIAL":[{"def":"Consisting of two hundred years.","pos":""},{"def":"Occurring every two hundred years.","pos":""}],"BICEPHALOUS":[{"def":"Having two heads.","pos":""}],"BICEPS":[{"def":"A muscle having two heads or origins; -- applied particularly to a flexor in the arm, and to another in the thigh.","pos":""}],"BICHIR":[{"def":"A remarkable ganoid fish (Polypterus bichir) found in the Nile and other African rivers.","pos":""}],"BICHLORIDE":[{"def":"A compound consisting of two atoms of chlorine with one or more atoms of another element; -- called also dichloride.","pos":""}],"BICHROMATE":[{"def":"A salt containing two parts of chromic acid to one of the other ingredients; as, potassium bichromate; -- called also dichromate.","pos":""}],"BICHROMATIZE":[{"def":"To combine or treat with a bichromate, esp.","pos":""}],"BICIPITAL":[{"def":"Dividing into two parts at one extremity; having two heads or two supports; as, a bicipital tree.","pos":""}],"BICIPITOUS":[{"def":"Having two heads; bicipital.","pos":""}],"BICKER":[{"def":"A small wooden vessel made of staves and hoops, like a tub.","pos":""}],"BICKERER":[{"def":"One who bickers.","pos":""}],"BICKERING":[{"def":"Altercation; wrangling.","pos":""}],"BICKERN":[{"def":"An anvil ending in a beak or point (orig.","pos":""},{"def":"A fuse used in blasting, consisting of a long cylinder of explosive material inclosed in a varnished wrapping of rope or hose.","pos":""}],"BICOLLIGATE":[{"def":"Having the anterior toes connected by a basal web.","pos":""}],"BICONCAVE":[{"def":"Concave on both sides; as, biconcave vertebræ.","pos":""}],"BICONJUGATE":[{"def":"Twice paired, as when a petiole forks twice.","pos":""}],"BICONVEX":[{"def":"Convex on both sides; as, a biconvex lens.","pos":""},{"def":"Having two horns; two-horned; crescentlike.","pos":""}],"BICORPORAL":[{"def":"Having two bodies.","pos":""}],"BICORPORATE":[{"def":"Double-bodied, as a lion having one head and two bodies.","pos":""}],"BICOSTATE":[{"def":"Having two principal ribs running longitudinally, as a leaf.","pos":""}],"BICRENATE":[{"def":"Twice crenated, as in the case of leaves whose crenatures are themselves crenate.","pos":""}],"BICRESCENTIC":[{"def":"Having the form of a double crescent.","pos":""}],"BICRURAL":[{"def":"Having two legs.","pos":""},{"def":"Having two points or prominences; ending in two points; -- said of teeth, leaves, fruit, etc.","pos":""}],"BICUSPID":[{"def":"One of the two double-pointed teeth which intervene between the canines (cuspids) and the molars, on each side of each jaw.","pos":""}],"BICYCLE":[{"def":"A light vehicle having two wheels one behind the other.","pos":""}],"BICYCLER":[{"def":"One who rides a bicycle.","pos":""}],"BICYCLIC":[{"def":"Relating to bicycles.","pos":""}],"BICYCLING":[{"def":"The use of a bicycle; the act or practice of riding a bicycle.","pos":""}],"BICYCLISM":[{"def":"The art of riding a bicycle.","pos":""}],"BICYCULAR":[{"def":"Relating to bicycling.","pos":""}]}