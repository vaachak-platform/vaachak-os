{"CONSIDER":[{"def":"To fix the mind on, with a view to a careful examination; to thank on with care; to ponder; to study; to meditate on.","pos":""},{"def":"To look at attentively; to observe; to examine.","pos":""}],"CONSIDERABLE":[{"def":"Worthy of consideration, borne in mind, or attended to.","pos":""},{"def":"Of some distinction; noteworthy; influential; respectable; -- said of persons.","pos":""}],"CONSIDERABLENESS":[{"def":"Worthiness of consideration; dignity; value; size; amount.","pos":""}],"CONSIDERABLY":[{"def":"In a manner or to a degree not trifling or unimportant; greatly; much.","pos":""}],"CONSIDERANCE":[{"def":"Act of considering; consideration.","pos":""}],"CONSIDERATE":[{"def":"Given to consideration or to sober reflection; regardful of consequences or circumstances; circumspect; careful; esp.","pos":""},{"def":"Having respect to; regardful.","pos":""}],"CONSIDERATION":[{"def":"The cause which moves a contracting party to enter into an agreement; the material cause of a contract; the price of a stripulation; compensation; equivalent.","pos":""}],"CONSIDERATIVE":[{"def":"Considerate; careful; thoughtful.","pos":""}],"CONSIDERATOR":[{"def":"One who considers.","pos":""}],"CONSIDERER":[{"def":"One who considers; a man of reflection; a thinker.","pos":""}],"CONSIDERINGLY":[{"def":"With consideration or deliberation.","pos":""}],"CONSIGN":[{"def":"To send or address (by bill of lading or otherwise) to an agent or correspondent in another place, to be cared for or sold, or for the use of such correspondent; as, to cosign a cargo or a ship; to set apart.","pos":""}],"CONSIGNATION":[{"def":"The act of consigning; the act of delivering or committing to another person, place, or state.","pos":""},{"def":"The act of ratifying or establishing, as if signing; confirmation; ratuficator.","pos":""}],"CONSIGNATORY":[{"def":"One of several that jointly sign a written instrument, as a treaty.","pos":""}],"CONSIGNATURE":[{"def":"Joint signature.","pos":""}],"CONSIGNEE":[{"def":"The person to whom goods or other things are consigned; a factor; -- correlative to consignor.","pos":""}],"CONSIGNER":[{"def":"One who consigns.","pos":""}],"CONSIGNIFICANT":[{"def":"Having joint or equal signification; synonymous.","pos":""}],"CONSIGNIFICATION":[{"def":"Joint signification.","pos":""}],"CONSIGNIFICATIVE":[{"def":"Consignificant; jointly significate.","pos":""}],"CONSIGNIFY":[{"def":"To signify or denote in combination with something else.","pos":""}],"CONSIGNMENT":[{"def":"The act of consigning or sending property to an agent or correspondent in another place, as for care, sale, etc.","pos":""},{"def":"That which is consigned; the goods or commodities sent or addressed to a consignee at one time or by one conveyance.","pos":""}],"CONSIGNOR":[{"def":"One who consigns something to another; -- opposed to consignee.","pos":""}],"CONSILIENCE":[{"def":"Act of concurring; coincidence; concurrence.","pos":""},{"def":"Common resemblance.","pos":""}],"CONSIST":[{"def":"To stand firm; to be in a fixed or permanent state, as a body composed of parts in union or connection; to hold together; to be; to exist; to subsist; to be supported and maintained.","pos":""},{"def":"To be composed or made up; -- followed by of.","pos":""}],"CONSISTENT":[{"def":"Possessing firmness or fixedness; firm; hard; solid.","pos":""},{"def":"Having agreement with itself or with something else; having harmony among its parts; possesing unity; accordant; harmonious; congruous; compatible; uniform; not contradictory.","pos":""}],"CONSISTENTLY":[{"def":"In a consistent manner.","pos":""}],"CONSISTORIAL":[{"def":"Of or pertaining to a consistory.","pos":""}],"CONSISTORIAN":[{"def":"Pertaining to a Presbyterian consistory; -- a contemptuous term of 17th century controversy.","pos":""}],"CONSISTORY":[{"def":"The spiritual court of a diocesan bishop held before his chancellor or commissioner in his cathedral church or elsewhere.","pos":""},{"def":"An assembly of prelates; a session of the college of cardinals at Rome.","pos":""}]}