{"CONFOCAL":[{"def":"Having the same foci; as, confocal quadrics.","pos":""}],"CONFORM":[{"def":"Of the same form; similar in import; conformable.","pos":""}],"CONFORMABILITY":[{"def":"The state of being conformable.","pos":""}],"CONFORMABLE":[{"def":"Corresponding in form, character, opinions, etc.","pos":""},{"def":"Disposed to compliance or obedience; ready to follow directions; submissive; compliant.","pos":""}],"CONFORMABLENESS":[{"def":"The quality of being conformable; conformability.","pos":""}],"CONFORMABLY":[{"def":"With conformity or in conformity; suitably; agreeably.","pos":""}],"CONFORMATE":[{"def":"Having the same form.","pos":""}],"CONFORMATION":[{"def":"The act of conforming; the act of producing conformity.","pos":""},{"def":"The state of being conformed; agreement; hence; structure, as depending on the arrangement of parts; form; arrangement.","pos":""}],"CONFORMATOR":[{"def":"An apparatus for taking the conformation of anything, as of the head for fitting a hat, or, in craniometry, finding the largest horizontal area of the head.","pos":""}],"CONFORMER":[{"def":"One who conforms; one who complies with established forms or doctrines.","pos":""}],"CONFORMIST":[{"def":"One who conforms or complies; esp.","pos":""}],"CONFORMITY":[{"def":"Correspondence in form, manner, or character; resemblance; agreement; congruity; -- followed by to, with, or between.","pos":""}],"CONFORTATION":[{"def":"The act of strengthening.","pos":""}],"CONFOUND":[{"def":"To mingle and blend, so that different elements can not be distinguished; to confuse.","pos":""},{"def":"To mistake for another; to identify falsely.","pos":""}],"CONFOUNDED":[{"def":"Confused; perplexed.","pos":""},{"def":"Excessive; extreme; abominable.","pos":""}],"CONFOUNDEDLY":[{"def":"Extremely; odiously; detestably.","pos":""}],"CONFOUNDEDNESS":[{"def":"The state of being confounded.","pos":""}],"CONFOUNDER":[{"def":"One who confounds.","pos":""}]}