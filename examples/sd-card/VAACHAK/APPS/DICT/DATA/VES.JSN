{"VESBIUM":[{"def":"A rare metallic element of which little is known.","pos":""}],"VESE":[{"def":"Onset; rush; violent draught or wind.","pos":""}],"VESICA":[{"def":"A glory, or aureole, of oval shape, or composed of two arcs of circles usually represented as surrounding a divine personage.","pos":""}],"VESICAL":[{"def":"Of or pertaining to the bladder.","pos":""}],"VESICATE":[{"def":"To raise little bladders or blisters upon; to inflame and separate the cuticle of; to blister.","pos":""}],"VESICATION":[{"def":"The process of vesicating, or of raising blisters.","pos":""}],"VESICATORY":[{"def":"Tending, or having power, to raise a blister.","pos":""},{"def":"A blistering application or plaster; a vesicant; an epispastic.","pos":""}],"VESICLE":[{"def":"A bladderlike vessel; a membranous cavity; a cyst; a cell.","pos":""},{"def":"A small bladderlike body in the substance of vegetable, or upon the surface of a leaf.","pos":""}],"VESICO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the bla; as in vesicoprostatic, vesicovaginal.","pos":""}],"VESICOPROSTATIC":[{"def":"Of a pertaining to the bladder and the prostrate gland.","pos":""}],"VESICOUTERINE":[{"def":"Of or pertaining to the bladder and the uterus.","pos":""}],"VESICOVAGINAL":[{"def":"Of or pertaining to the bladder and the vagina.","pos":""}],"VESICULAR":[{"def":"Of or pertaining to vesicles; esp.","pos":""},{"def":"Containing, or composed of, vesicles or vesiclelike structures; covered with vesicles or bladders; vesiculate; as, vesicular coral; vesicular lava; a vesicular leaf.","pos":""}],"VESICULARIA":[{"def":"Any one of numerous species of marine Bryozoa belonging to Vesicularia and allied genera.","pos":""}],"VESICULATA":[{"def":"The campanularian medusæ.","pos":""}],"VESICULATE":[{"def":"Bladdery; full of, or covered with, bladders; vesicular.","pos":""}],"VESICULATION":[{"def":"The state of containing vesicles, or the process by which vesicles are formed.","pos":""}],"VESICULITIS":[{"def":"Inflammation of a vesicle.","pos":""},{"def":"Bladdery; vesicular; vesiculate; composed of vesicles; covered with vesicles; as, a vesiculose shell.","pos":""}],"VESPA":[{"def":"A genus of Hymenoptera including the common wasps and hornets.","pos":""}],"VESPER":[{"def":"The evening star; Hesper; Venus, when seen after sunset; hence, the evening.","pos":""}],"VESPERAL":[{"def":"Vesper; evening.","pos":""}],"VESPERTILIO":[{"def":"A genus of bats including some of the common small insectivorous species of North America and Europe.","pos":""}],"VESPERTILIONES":[{"def":"A tribe of bats including the common insectivorous bats of America and Europe, belonging to Vespertilio and allied genera.","pos":""}],"VESPERTILIONINE":[{"def":"Of or pertaining to the Vespertiliones.","pos":""}],"VESPERTINE":[{"def":"Blossoming in the evening.","pos":""}],"VESPIARY":[{"def":"A nest, or habitation, of insects of the wasp kind.","pos":""}],"VESPILLO":[{"def":"One who carried out the dead bodies of the poor at night for burial.","pos":""}],"VESSEL":[{"def":"Any tube or canal in which the blood or other fluids are contained, secreted, or circulated, as the arteries, veins, lymphatics, etc.","pos":""},{"def":"A continuous tube formed from superposed large cylindrical or prismatic cells (tracheæ), which have lost their intervening partitions, and are usually marked with dots, pits, rings, or spirals by internal deposition of secondary membranes; a duct.","pos":""}],"VESSELFUL":[{"def":"As much as a vessel will hold; enough to fill a vessel.","pos":""},{"def":"A kind of worsted; also, a worsted cloth.","pos":""}],"VEST":[{"def":"An article of clothing covering the person; an outer garment; a vestment; a dress; a vesture; a robe.","pos":""},{"def":"Any outer covering; array; garb.","pos":""}],"VESTA":[{"def":"One of the great divinities of the ancient Romans, identical with the Greek Hestia.","pos":""},{"def":"An asteroid, or minor planet, discovered by Olbers in 1807.","pos":""}],"VESTAL":[{"def":"Of or pertaining to Vesta, the virgin goddess of the hearth; hence, pure; chaste.","pos":""}],"VESTALES":[{"def":"A group of butterflies including those known as virgins, or gossamer-winged butterflies.","pos":""}],"VESTED":[{"def":"Not in a state of contingency or suspension; fixed; as, vested rights; vested interests.","pos":""}],"VESTED SCHOOL":[{"def":"In Ireland, a national school which has been built by the aid of grants from the board of Commissioners of National Education and is secured for educational purposes by leases to the commissioners themselves, or to the commissioners and the trustees.","pos":""}],"VESTIARIAN":[{"def":"Of or pertaining to a vestiary or vestments.","pos":""}],"VESTIARY":[{"def":"A wardrobe; a robing room; a vestry.","pos":""}],"VESTIBULAR":[{"def":"Of or pertaining to a vestibule; like a vestibule.","pos":""}],"VESTIBULE":[{"def":"The porch or entrance into a house; a hall or antechamber next the entrance; a lobby; a porch; a hall.","pos":""}],"VESTIBULED TRAIN":[{"def":"Same as Vestibule train, under Vestibule.","pos":""}],"VESTIBULUM":[{"def":"A cavity into which, in certain bryozoans, the esophagus and anus open.","pos":""}],"VESTIGE":[{"def":"The mark of the foot left on the earth; a track or footstep; a trace; a sign; hence, a faint mark or visible sign left by something which is lost, or has perished, or is no longer present; remains; as, the vestiges of ancient magnificence in Palmyra; vestiges of former population.","pos":""}],"VESTIGIAL":[{"def":"Of or pertaining to a vestige or remnant; like a vestige.","pos":""}],"VESTING":[{"def":"Cloth for vests; a vest pattern.","pos":""}],"VESTLET":[{"def":"Any one of several species of actinians belonging to the genus Cerianthus.","pos":""}],"VESTMENT":[{"def":"A covering or garment; some part of clothing or dress; specifically (Eccl.","pos":""}],"VESTRY":[{"def":"A parochial assembly; an assembly of persons who manage parochial affairs; -- so called because usually held in a vestry.","pos":""},{"def":"A body, composed of wardens and vestrymen, chosen annually by a parish to manage its temporal concerns.","pos":""}],"VESTRYMAN":[{"def":"A member of a vestry; especially (Prot.","pos":""}],"VESTURE":[{"def":"A garment or garments; a robe; clothing; dress; apparel; vestment; covering; envelope.","pos":""}],"VESTURED":[{"def":"Covered with vesture or garments; clothed; enveloped.","pos":""}],"VESUVIAN":[{"def":"Of or pertaining to Vesuvius, a volcano near Naples.","pos":""}],"VESUVIANITE":[{"def":"A mineral occurring in tetragonal crystals, and also massive, of a brown to green color, rarely sulphur yellow and blue.","pos":""}],"VESUVINE":[{"def":"A trade name for a brown dyestuff obtained from certain basic azo compounds of benzene; -- called also Bismarck brown, Manchester brown, etc.","pos":""}]}