{"HEBDOMAD":[{"def":"A week; a period of seven days.","pos":""},{"def":"Consisting of seven days, or occurring at intervals of seven days; weekly.","pos":""}],"HEBDOMADALLY":[{"def":"In periods of seven days; weekly.","pos":""}],"HEBDOMADARY":[{"def":"A member of a chapter or convent, whose week it is to officiate in the choir, and perform other services, which, on extraordinary occasions, are performed by the superiors.","pos":""}],"HEBDOMATICAL":[{"def":"Weekly; hebdomadal.","pos":""}],"HEBE":[{"def":"The goddess of youth, daughter of Jupiter and Juno.","pos":""},{"def":"An African ape; the hamadryas.","pos":""}],"HEBETATE":[{"def":"To render obtuse; to dull; to blunt; to stupefy; as, to hebetate the intellectual faculties.","pos":""}],"HEBETATION":[{"def":"The act of making blunt, dull, or stupid.","pos":""},{"def":"The state of being blunted or dulled.","pos":""}],"HEBETUDE":[{"def":"Dullness; stupidity.","pos":""}],"HEBRAIC":[{"def":"Of or pertaining to the Hebrews, or to the language of the Hebrews.","pos":""}],"HEBRAICALLY":[{"def":"After the manner of the Hebrews or of the Hebrew language.","pos":""}],"HEBRAISM":[{"def":"A Hebrew idiom or custom; a peculiar expression or manner of speaking in the Hebrew language.","pos":""},{"def":"The type of character of the Hebrews.","pos":""}],"HEBRAIST":[{"def":"One versed in the Hebrew language and learning.","pos":""}],"HEBRAISTIC":[{"def":"Pertaining to, or resembling, the Hebrew language or idiom.","pos":""}],"HEBRAISTICALLY":[{"def":"In a Hebraistic sense or form.","pos":""}],"HEBRAIZE":[{"def":"To convert into the Hebrew idiom; to make Hebrew or Hebraistic.","pos":""}],"HEBREW":[{"def":"An appellative of Abraham or of one of his descendants, esp.","pos":""},{"def":"The language of the Hebrews; -- one of the Semitic family of languages.","pos":""}],"HEBREW CALENDAR":[{"def":"= Jewish calendar.","pos":""}],"HEBREWESS":[{"def":"An Israelitish woman.","pos":""}],"HEBRICIAN":[{"def":"Of or pertaining to the islands called Hebrides, west of Scotland.","pos":""}]}