{"LEPADITE":[{"def":"Same as Lepadoid.","pos":""}],"LEPADOID":[{"def":"A stalked barnacle of the genus Lepas, or family Lepadidæ; a goose barnacle.","pos":""}],"LEPAL":[{"def":"A sterile transformed stamen.","pos":""}],"LEPAS":[{"def":"Any one of various species of Lepas, a genus of pedunculated barnacles found attached to floating timber, bottoms of ships, Gulf weed, etc.","pos":""}],"LEPER":[{"def":"A person affected with leprosy.","pos":""}],"LEPERED":[{"def":"Affected or tainted with leprosy.","pos":""}],"LEPERIZE":[{"def":"To affect with leprosy.","pos":""}],"LEPEROUS":[{"def":"Leprous; infectious; corrupting; poisonous.","pos":""}],"LEPID":[{"def":"Pleasant; jocose.","pos":""}],"LEPIDINE":[{"def":"An organic base, C9H6.","pos":"noun"}],"LEPIDODENDRID":[{"def":"One of an extinct family of trees allied to the modern club mosses, and including Lepidodendron and its allies.","pos":""}],"LEPIDODENDROID":[{"def":"Allied to, or resembling, Lepidodendron.","pos":""},{"def":"A lepidodendrid.","pos":""}],"LEPIDODENDRON":[{"def":"A genus of fossil trees of the Devonian and Carboniferous ages, having the exterior marked with scars, mostly in quincunx order, produced by the separation of the leafstalks.","pos":""}],"LEPIDOGANOID":[{"def":"Any one of a division (Lepidoganoidei) of ganoid fishes, including those that have scales forming a coat of mail.","pos":""}],"LEPIDOLITE":[{"def":"A species of mica, of a lilac or rose-violet color, containing lithia.","pos":""}],"LEPIDOMELANE":[{"def":"An iron-potash mica, of a raven-black color, usually found in granitic rocks in small six-sided tables, or as an aggregation of minute opaque scales.","pos":""}],"LEPIDOPTER":[{"def":"One of the Lepidoptera.","pos":""}],"LEPIDOPTERA":[{"def":"An order of insects, which includes the butterflies and moths.","pos":""},{"def":"Of or pertaining to the Lepidoptera.","pos":""}],"LEPIDOPTERIST":[{"def":"One who studies the Lepidoptera.","pos":""}],"LEPIDOSAURIA":[{"def":"A division of reptiles, including the serpents and lizards; the Plagiotremata.","pos":""}],"LEPIDOSIREN":[{"def":"An eel-shaped ganoid fish of the order Dipnoi, having both gills and lungs.","pos":""},{"def":"Having a coat of scurfy scales, as the leaves of the oleaster.","pos":""}],"LEPISMA":[{"def":"A genus of wingless thysanurous insects having an elongated flattened body, covered with shining scales and terminated by seven unequal bristles.","pos":""}],"LEPISMOID":[{"def":"Like or pertaining to the Lepisma.","pos":""}],"LEPORINE":[{"def":"Of or pertaining to a hare; like or characteristic of, a hare.","pos":""}],"LEPRA":[{"def":"Note: The term lepra was formerly given to various skin diseases, the leprosy of modern authors being Lepra Arabum.","pos":""}],"LEPROSE":[{"def":"Covered with thin, scurfy scales.","pos":""}],"LEPROSITY":[{"def":"The state or quality of being leprous or scaly; also, a scale.","pos":""}],"LEPROSY":[{"def":"A cutaneous disease which first appears as blebs or as reddish, shining, slightly prominent spots, with spreading edges.","pos":""}],"LEPROUS":[{"def":"Infected with leprosy; pertaining to or resembling leprosy.","pos":""}],"LEPTIFORM":[{"def":"Having a form somewhat like leptus; -- said of active insect larvæ having three pairs of legs.","pos":""}],"LEPTOCARDIA":[{"def":"The lowest class of Vertebrata, including only the Amphioxus.","pos":""}],"LEPTOCARDIAN":[{"def":"Of or pertaining to the Leptocardia.","pos":""},{"def":"One of the Leptocardia.","pos":""}],"LEPTODACTYL":[{"def":"A bird or other animal having slender toes.","pos":""}],"LEPTODACTYLOUS":[{"def":", Having slender toes.","pos":""}],"LEPTOLOGY":[{"def":"A minute and tedious discourse on trifling things.","pos":""}],"LEPTOMENINGITIS":[{"def":"Inflammation of the pia mater or of the arachnoid membrane.","pos":""}],"LEPTORHINE":[{"def":"Having the nose narrow; -- said esp.","pos":""}],"LEPTOSTRACA":[{"def":"An order of Crustacea, including Nebalia and allied forms.","pos":""}],"LEPTOTHRIX":[{"def":"A genus of bacteria, characterized by having their filaments very long, slender, and indistinctly articulated.","pos":""}],"LEPTUS":[{"def":"The six-legged young, or larva, of certain mites; -- sometimes used as a generic name.","pos":""}]}