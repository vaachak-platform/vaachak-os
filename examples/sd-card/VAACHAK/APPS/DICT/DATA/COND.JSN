{"COND":[{"def":"To con, as a ship.","pos":""}],"CONDEMN":[{"def":"To doom to be taken for public use, under the right of eminent domain.","pos":""}],"CONDEMNABLE":[{"def":"Worthy of condemnation; blamable; culpable.","pos":""}],"CONDEMNATION":[{"def":"The act of condemning or pronouncing to be wrong; censure; blame; disapprobation.","pos":""},{"def":"The act of judicially condemning, or adjudging guilty, unfit for use, or forfeited; the act of dooming to punishment or forfeiture.","pos":""}],"CONDEMNATORY":[{"def":"Condemning; containing or imposing condemnation or censure; as, a condemnatory sentence or decree.","pos":""}],"CONDEMNED":[{"def":"Pronounced to be wrong, guilty, worthless, or forfeited; adjudged or sentenced to punishment, destruction, or confiscation.","pos":""},{"def":"Used for condemned persons.","pos":""}],"CONDEMNER":[{"def":"One who condemns or censures.","pos":""}],"CONDENSABILITY":[{"def":"Capability of being condensed.","pos":""}],"CONDENSABLE":[{"def":"Capable of being condensed; as, vapor is condensable.","pos":""}],"CONDENSATE":[{"def":"Made dense; condensed.","pos":""}],"CONDENSATION":[{"def":"The act or process of reducing, by depression of temperature or increase of pressure, etc.","pos":""},{"def":"A rearrangement or concentration of the different constituents of one or more substances into a distinct and definite compound of greater complexity and molecular weight, often resulting in an increase of density, as the condensation of oxygen into ozone, or of acetone into mesitylene.","pos":""}],"CONDENSATIVE":[{"def":"Having the property of condensing.","pos":""}],"CONDENSE":[{"def":"To reduce into another and denser form, as by cold or pressure; as, to condense gas into a liquid form, or steam into water.","pos":""}],"CONDENSER":[{"def":"An apparatus for receiving and condensing the volatile products of distillation to a liquid or solid form, by cooling.","pos":""},{"def":"An apparatus, separate from the cylinder, in which the exhaust steam is condensed by the action of cold water or air.","pos":""}],"CONDENSIBLE":[{"def":"Capable of being condensed; as, a gas condensible to a liquid by cold.","pos":""}],"CONDER":[{"def":"One who watches shoals of fish; a balker.","pos":""}],"CONDESCEND":[{"def":"To stoop or descend; to let one's self down; to submit; to waive the privilege of rank or dignity; to accommodate one's self to an inferior.","pos":""}],"CONDESCENDINGLY":[{"def":"In a condescending manner.","pos":""}],"CONDESCENSION":[{"def":"The act of condescending; voluntary descent from one's rank or dignity in intercourse with an inferior; courtesy toward inferiors.","pos":""}],"CONDESCENT":[{"def":"An act of condescension.","pos":""}],"CONDIGN":[{"def":"Worthy; suitable; deserving; fit.","pos":""},{"def":"Deserved; adequate; suitable to the fault or crime.","pos":""}],"CONDIGNITY":[{"def":"Merit, acguired by works, which can claim reward on the score of general benevolence.","pos":""}],"CONDIGNLY":[{"def":"According to merit.","pos":""}],"CONDIGNNESS":[{"def":"Agreeableness to deserts; suitableness.","pos":""}],"CONDIMENT":[{"def":"Something used to give relish to food, and to gratify the taste; a pungment and appetizing substance, as pepper or mustard; seasoning.","pos":""}],"CONDISCIPLE":[{"def":"A schoolfellow; a fellow-student.","pos":""}],"CONDITE":[{"def":"Preserved; pickled.","pos":""}],"CONDITION":[{"def":"A clause in a contract, or agreement, which has for its object to suspend, to defeat, or in some way to modify, the principal obligation; or, in case of a will, to suspend, revoke, or modify a devise or bequest.","pos":""}],"CONDITIONAL":[{"def":"Expressing a condition or supposition; as, a conditional word, mode, or tense.","pos":""}],"CONDITIONALITY":[{"def":"The quality of being conditional, or limited; limitation by certain terms.","pos":""}],"CONDITIONALLY":[{"def":"In a conditional manner; subject to a condition or conditions; not absolutely or positively.","pos":""}],"CONDITIONATE":[{"def":"Barak's answer is faithful, though conditionate.","pos":""}],"CONDITIONED":[{"def":"Surrounded; circumstanced; in a certain state or condition, as of property or health; as, a well conditioned man.","pos":""},{"def":"Having, or known under or by, conditions or relations; not independent; not absolute.","pos":""}],"CONDITORY":[{"def":"A repository for holding things; a hinding place.","pos":""}],"CONDOG":[{"def":"To concur; to agree.","pos":""}],"CONDOLATORY":[{"def":"Expressing condolence.","pos":""}],"CONDOLE":[{"def":"To express sympathetic sorrow; to grieve in sympathy; -- followed by with.","pos":""}],"CONDOLEMENT":[{"def":"Sorrow; mourning; lamentation.","pos":""}],"CONDOLENCE":[{"def":"Expression of sympathy with another in sorrow or grief.","pos":""}],"CONDOLER":[{"def":"One who condoles.","pos":""}],"CONDONATION":[{"def":"Forgiveness, either express or implied, by a husband of his wife or by a wife of her husband, for a breach of marital duty, as adultery, with an implied condition that the offense shall not be repeated.","pos":""}],"CONDONE":[{"def":"To pardon; to overlook the offense of; esp.","pos":""}],"CONDOR":[{"def":"A very large bird of the Vulture family (Sarcorhamphus gryphus), found in the most elevated parts of the Andes.","pos":""}],"CONDOTTIERE":[{"def":"A military adventurer of the fourteenth and fifteenth centuries, who sold his services, and those of his followers, to any party in any contest.","pos":""}],"CONDUCE":[{"def":"To lead or tend, esp.","pos":""}],"CONDUCENT":[{"def":"Conducive; tending.","pos":""}],"CONDUCIBILITY":[{"def":"The state or quality of being conducible; conducibleness.","pos":""}],"CONDUCIBLE":[{"def":"Conducive; tending; contributing.","pos":""}],"CONDUCIBLENESS":[{"def":"Quality of being conducible.","pos":""}],"CONDUCIBLY":[{"def":"In a manner to promote.","pos":""}],"CONDUCIVE":[{"def":"Loading or tending; helpful; contributive; tending to promote.","pos":""}],"CONDUCIVENESS":[{"def":"The quality of conducing.","pos":""}],"CONDUCT":[{"def":"The act or method of conducting; guidance; management.","pos":""},{"def":"Skillful guidance or management; generalship.","pos":""}],"CONDUCTANCE":[{"def":"Conducting power; -- the reciprocal of resistance.","pos":""}],"CONDUCTIBILITY":[{"def":"Capability of being conducted; as, the conductibility of heat or electricity.","pos":""},{"def":"Conductivity; capacity for receiving and transmitting.","pos":""}],"CONDUCTIBLE":[{"def":"Capable of being conducted.","pos":""}],"CONDUCTION":[{"def":"Transmission through, or by means of, a conductor; also, conductivity.","pos":""}],"CONDUCTIVE":[{"def":"Having the quality or power of conducting; as, the conductive tissue of a pistil.","pos":""}],"CONDUCTIVITY":[{"def":"The quality or power of conducting, or of receiving and transmitting, as, the conductivity of a nerve.","pos":""}],"CONDUCTOR":[{"def":"The leader or director of an orchestra or chorus.","pos":""},{"def":"A substance or body capable of being a medium for the transmission of certain forces, esp.","pos":""}],"CONDUCTORY":[{"def":"Having the property of conducting.","pos":""}],"CONDUCTRESS":[{"def":"A woman who leads or directs; a directress.","pos":""}],"CONDUIT":[{"def":"A system of electric traction, esp.","pos":""}],"CONDUPLICATE":[{"def":"Folded lengthwise along the midrib, the upper face being within; -- said of leaves or petals in vernation or æstivation.","pos":""}],"CONDUPLICATION":[{"def":"A doubling together or folding; a duplication.","pos":""}],"CONDURRITE":[{"def":"A variety of the mineral domeykite, or copper arsenide, from the Condurra mine in Cornwall, England.","pos":""}],"CONDYLAR":[{"def":"Of or pertaining to a condyle.","pos":""}],"CONDYLE":[{"def":"A bony prominence; particularly, an eminence at the end of a bone bearing a rounded articular surface; -- sometimes applied also to a concave articular surface.","pos":""}],"CONDYLOID":[{"def":"Shaped like or pertaining to a condyle.","pos":""},{"def":"A wartlike new growth on the outer skin or adjoining mucous membrance.","pos":""}]}