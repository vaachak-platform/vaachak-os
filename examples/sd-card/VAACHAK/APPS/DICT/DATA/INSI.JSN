{"INSICCATION":[{"def":"The act or process of drying in.","pos":""}],"INSIDE":[{"def":"Within the sides of; in the interior; contained within; as, inside a house, book, bottle, etc.","pos":""}],"INSIDIATE":[{"def":"To lie in ambush for.","pos":""}],"INSIDIATOR":[{"def":"One who lies in ambush.","pos":""}],"INSIDIOUS":[{"def":"Lying in wait; watching an opportunity to insnare or entrap; deceitful; sly; treacherous; -- said of persons; as, the insidious foe.","pos":""},{"def":"Intended to entrap; characterized by treachery and deceit; as, insidious arts.","pos":""}],"INSIGHT":[{"def":"A sight or view of the interior of anything; a deep inspection or view; introspection; -- frequently used with into.","pos":""},{"def":"Power of acute observation and deduction; penetration; discernment; perception.","pos":""}],"INSIGNIA":[{"def":"Distinguishing marks of authority, office, or honor; badges; tokens; decorations; as, the insignia of royalty or of an order.","pos":""},{"def":"Typical and characteristic marks or signs, by which anything is known or distinguished; as, the insignia of a trade.","pos":""}],"INSIGNIFICANCE":[{"def":"The condition or quality of being insignificant; want of significance, sense, or meaning; as, the insignificance of words or phrases.","pos":""},{"def":"Want of force or effect; unimportance; pettiness; inefficacy; as, the insignificance of human art.","pos":""}],"INSIGNIFICANCY":[{"def":"In`sig*nif\"i*can*cy, n.","pos":""}],"INSIGNIFICANT":[{"def":"Not significant; void of signification, sense, or import; meaningless; as, insignificant words.","pos":""},{"def":"Having no weight or effect; answering no purpose; unimportant; valueless; futile.","pos":""}],"INSIGNIFICANTLY":[{"def":"without significance, importance, or effect; to no purpose.","pos":""}],"INSIGNIFICATIVE":[{"def":"Not expressing meaning; not significant.","pos":""}],"INSIGNMENT":[{"def":"A token, mark, or explanation.","pos":""}],"INSINCERE":[{"def":"Not being in truth what one appears to be; not sincere; dissembling; hypocritical; disingenuous; deceitful; false; -- said of persons; also of speech, thought; etc.","pos":""},{"def":"Disappointing; imperfect; unsound.","pos":""}],"INSINCERELY":[{"def":"Without sincerity.","pos":""}],"INSINCERITY":[{"def":"The quality of being insincere; want of sincerity, or of being in reality what one appears to be; dissimulation; hypocritical; deceitfulness; hollowness; untrustworthiness; as, the insincerity of a professed friend; the insincerity of professions of regard.","pos":""}],"INSINEW":[{"def":"To strengthen, as with sinews; to invigorate.","pos":""}],"INSINUANT":[{"def":"Insinuating; insinuative.","pos":""}],"INSINUATE":[{"def":"To introduce gently or slowly, as by a winding or narrow passage, or a gentle, persistent movement.","pos":""},{"def":"To introduce artfully; to infuse gently; to instill.","pos":""}],"INSINUATING":[{"def":"Winding, creeping, or flowing in, quietly or stealthily; suggesting; winning favor and confidence insensibly.","pos":""}],"INSINUATINGLY":[{"def":"In*sin\"u*a`ting*ly, adv.","pos":""}],"INSINUATION":[{"def":"The act or process of insinuating; a creeping, winding, or flowing in.","pos":""},{"def":"The act of gaining favor, affection, or influence, by gentle or artful means; -- formerly used in a good sense, as of friendly influence or interposition.","pos":""}],"INSINUATIVE":[{"def":"Stealing on or into the confidence or affections; having power to gain favor.","pos":""},{"def":"Using insinuations; giving hints; insinuating; as, insinuative remark.","pos":""}],"INSINUATOR":[{"def":"One who, or that which, insinuates.","pos":""}],"INSIPID":[{"def":"The quality or state of being insipid; vapidity.","pos":""}],"INSIPIDLY":[{"def":"In an insipid manner; without taste, life, or spirit; flatly.","pos":""}],"INSIPIENCE":[{"def":"Want of intelligence; stupidity; folly.","pos":""}],"INSIPIENT":[{"def":"Wanting wisdom; stupid; foolish.","pos":""},{"def":"An insipient person.","pos":""}],"INSIST":[{"def":"To stand or rest; to find support; -- with in, on, or upon.","pos":""},{"def":"To take a stand and refuse to give way; to hold to something firmly or determinedly; to be persistent, urgent, or pressing; to persist in demanding; -- followed by on, upon, or that; as, he insisted on these conditions; he insisted on going at once; he insists that he must have money.","pos":""}],"INSISTENCE":[{"def":"The quality of insisting, or being urgent or pressing; the act of dwelling upon as of special importance; persistence; urgency.","pos":""}],"INSISTENT":[{"def":"Standing or resting on something; as, an insistent wall.","pos":""},{"def":"Insisting; persistent; persevering.","pos":""}],"INSISTENTLY":[{"def":"In an insistent manner.","pos":""}],"INSISTURE":[{"def":"A dwelling or standing on something; fixedness; persistence.","pos":""}],"INSITIENCY":[{"def":"Freedom from thirst.","pos":""}],"INSITION":[{"def":"The insertion of a scion in a stock; ingraftment.","pos":""}]}