{"EVACUANT":[{"def":"Emptying; evacuative; purgative; cathartic.","pos":""},{"def":"A purgative or cathartic.","pos":""}],"EVACUATE":[{"def":"To make empty; to empty out; to remove the contents of; as, to evacuate a vessel or dish.","pos":""}],"EVACUATION":[{"def":"The act of emptying, clearing of the contents, or discharging.","pos":""},{"def":"That which is evacuated or discharged; especially, a discharge by stool or other natural means.","pos":""}],"EVACUATIVE":[{"def":"Serving of tending to evacuate; cathartic; purgative.","pos":""}],"EVACUATOR":[{"def":"One who evacuates; a nullifier.","pos":""}],"EVADE":[{"def":"To get away from by artifice; to avoid by dexterity, subterfuge, address, or ingenuity; to elude; to escape from cleverly; as, to evade a blow, a pursuer, a punishment; to evade the force of an argument.","pos":""}],"EVADIBLE":[{"def":"Capable of being evaded.","pos":""}],"EVAGATION":[{"def":"A wandering about; excursion; a roving.","pos":""}],"EVAGINATE":[{"def":"Protruded, or grown out, as an evagination; turned inside out; unsheathed; evaginated; as, an evaginate membrane.","pos":""}],"EVAGINATION":[{"def":"The act of unsheathing.","pos":""}],"EVAL":[{"def":"Relating to time or duration.","pos":""}],"EVALUATE":[{"def":"To fix the value of; to rate; to appraise.","pos":""}],"EVALUATION":[{"def":"Valuation; appraisement.","pos":""}],"EVANESCE":[{"def":"To vanish away; to because dissipated and disappear, like vapor.","pos":""}],"EVANESCENCE":[{"def":"The act or state of vanishing away; disappearance; as, the evanescence of vapor, of a dream, of earthly plants or hopes.","pos":""}],"EVANESCENT":[{"def":"Liable to vanish or pass away like vapor; vanishing; fleeting; as, evanescent joys.","pos":""},{"def":"Vanishing from notice; imperceptible.","pos":""}],"EVANESCENTLY":[{"def":"; imperceptibly.","pos":""}],"EVANGEL":[{"def":"Good news; announcement of glad tidings; especially, the gospel, or a gospel.","pos":""}],"EVANGELIAN":[{"def":"Rendering thanks for favors.","pos":""}],"EVANGELIC":[{"def":"Belonging to, or contained in, the gospel; evangelical.","pos":""}],"EVANGELICAL":[{"def":"Contained in, or relating to, the four Gospels; as, the evangelical history.","pos":""},{"def":"Belonging to, agreeable or consonant to, or contained in, the gospel, or the truth taught in the New Testament; as, evangelical religion.","pos":""}],"EVANGELICALISM":[{"def":"Adherence to evangelical doctrines; evangelism.","pos":""}],"EVANGELICALLY":[{"def":"In an evangelical manner.","pos":""}],"EVANGELICALNESS":[{"def":"State of being evangelical.","pos":""}],"EVANGELICISM":[{"def":"Evangelical principles; evangelism.","pos":""}],"EVANGELISM":[{"def":"The preaching or promulgation of the gospel.","pos":""}],"EVANGELIST":[{"def":"A bringer of the glad tidings of Church and his doctrines.","pos":""}],"EVANGELISTARY":[{"def":"A selection of passages from the Gospels, as a lesson in divine service.","pos":""}],"EVANGELISTIC":[{"def":"Pertaining to the four evangelists; designed or fitted to evangelize; evangelical; as, evangelistic efforts.","pos":""}],"EVANGELIZATION":[{"def":"The act of evangelizing; the state of being evangelized.","pos":""}],"EVANGELIZE":[{"def":"To instruct in the gospel; to preach the gospel to; to convert to Christianity; as, to evangelize the world.","pos":""}],"EVANGELY":[{"def":"The sacred pledge of Christ's evangely.","pos":""}],"EVANGILE":[{"def":"Good tidings; evangel.","pos":""}],"EVANID":[{"def":"Liable to vanish or disappear; faint; weak; evanescent; as, evanid color.","pos":""}],"EVANISH":[{"def":"Or like the rainbow's lovely form, Evanishing amid the storm.","pos":""}],"EVANISHMENT":[{"def":"A vanishing; disappearance.","pos":""}],"EVAPORABLE":[{"def":"Capable of being converted into vapor, or dissipated by evaporation.","pos":""}],"EVAPORATE":[{"def":"To pass off in vapor, as a fluid; to escape and be dissipated, either in visible vapor, or in practice too minute to be visible.","pos":""},{"def":"To escape or pass off without effect; to be dissipated; to be wasted, as, the spirit of writer often evaporates in the process of translation.","pos":""}],"EVAPORATION":[{"def":"See Vaporization.","pos":""}],"EVAPORATIVE":[{"def":"Pertaining to, or producing, evaporation; as, the evaporative process.","pos":""}],"EVAPORATOR":[{"def":"An apparatus for condensing vegetable juices, or for drying fruit by heat.","pos":""}],"EVAPOROMETER":[{"def":"An instrument for ascertaining the quantity of a fluid evaporated in a given time; an atmometer.","pos":""}],"EVASIBLE":[{"def":"That may be evaded.","pos":""}],"EVASION":[{"def":"The act of eluding or avoiding, particularly the pressure of an argument, accusation, charge, or interrogation; artful means of eluding.","pos":""}],"EVASIVE":[{"def":"Tending to evade, or marked by evasion; elusive; shuffling; avoiding by artifice.","pos":""}]}