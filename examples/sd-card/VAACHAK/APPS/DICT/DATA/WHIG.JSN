{"WHIG":[{"def":"Acidulated whey, sometimes mixed with buttermilk and sweet herbs, used as a cooling beverage.","pos":""}],"WHIGGAMORE":[{"def":"A Whig; -- a cant term applied in contempt to Scotch Presbyterians.","pos":""}],"WHIGGARCHY":[{"def":"Government by Whigs.","pos":""}],"WHIGGERY":[{"def":"The principles or practices of the Whigs; Whiggism.","pos":""}],"WHIGGISH":[{"def":"Of or pertaining to Whigs; partaking of, or characterized by, the principles of Whigs.","pos":""}],"WHIGGISHLY":[{"def":"In a Whiggish manner.","pos":""}],"WHIGGISM":[{"def":"The principles of the Whigs.","pos":""}],"WHIGLING":[{"def":"A petty or inferior Whig; -- used in contempt.","pos":""}]}