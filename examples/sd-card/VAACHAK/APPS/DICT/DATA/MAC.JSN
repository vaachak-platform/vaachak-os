{"MAC":[{"def":"A prefix, in names of Scotch origin, signifying son.","pos":""}],"MACACO":[{"def":"Any one of several species of lemurs, as the ruffed lemur (Lemur macaco), and the ring-tailed lemur (L.","pos":""}],"MACACUS":[{"def":"A genus of monkeys, found in Asia and the East Indies.","pos":""}],"MACADAM ROAD":[{"def":"A macadamized road.","pos":""}],"MACADAMIZATION":[{"def":"The process or act of macadamizing.","pos":""}],"MACADAMIZE":[{"def":"To cover, as a road, or street, with small, broken stones, so as to form a smooth, hard, convex surface.","pos":""}],"MACAQUE":[{"def":"Any one of several species of short-tailed monkeys of the genus Macacus; as, M.","pos":""}],"MACARANGA GUM":[{"def":"A gum of a crimson color, obtained from a tree (Macaranga Indica) that grows in the East Indies.","pos":""}],"MACARIZE":[{"def":"To congratulate.","pos":""}],"MACARONI":[{"def":"Long slender tubes made of a paste chiefly of wheat flour, and used as an article of food; Italian or Genoese paste.","pos":""},{"def":"A medley; something droll or extravagant.","pos":""}],"MACARONIC":[{"def":"A heap of thing confusedly mixed together; a jumble.","pos":""},{"def":"A kind of burlesque composition, in which the vernacular words of one or more modern languages are intermixed with genuine Latin words, and with hybrid formed by adding Latin terminations to other roots.","pos":""}],"MACAROON":[{"def":"A small cake, composed chiefly of the white of eggs, almonds, and sugar.","pos":""},{"def":"A finical fellow, or macaroni.","pos":""}],"MACARTNEY":[{"def":"A fire-backed pheasant.","pos":""}],"MACASSAR OIL":[{"def":"A kind of oil formerly used in dressing the hair; -- so called because originally obtained from Macassar, a district of the Island of Celebes.","pos":""}],"MACAUCO":[{"def":"Any one of several species of small lemurs, as Lemur murinus, which resembles a rat in size.","pos":""}],"MACAVAHU":[{"def":"A small Brazilian monkey (Callithrix torquatus), -- called also collared teetee.","pos":""}],"MACAW":[{"def":"Any parrot of the genus Sittace, or Macrocercus.","pos":""}],"MACCABEAN":[{"def":"Of or pertaining to Judas Maccabeus or to the Maccabees; as, the Maccabean princes; Maccabean times.","pos":""}],"MACCABEES":[{"def":"A kind of snuff.","pos":""}],"MACCO":[{"def":"A gambling game in vogue in the eighteenth century.","pos":""}],"MACE":[{"def":"A money of account in China equal to one tenth of a tael; also, a weight of 57.","pos":""}],"MACEDOINE":[{"def":"A kind of mixed dish, as of cooked vegetables with white sauce, sweet jelly with whole fruit, etc.","pos":""}],"MACEDONIAN":[{"def":"Belonging, or relating, to Macedonia.","pos":""},{"def":"A native or inhabitant of Macedonia.","pos":""}],"MACEDONIANISM":[{"def":"The doctrines of Macedonius.","pos":""}],"MACER":[{"def":"A mace bearer; an officer of a court.","pos":""}],"MACERATE":[{"def":"To make lean; to cause to waste away.","pos":""},{"def":"To subdue the appetites of by poor and scanty diet; to mortify.","pos":""}],"MACERATER":[{"def":"One who, or that which, macerates; an apparatus for converting paper or fibrous matter into pulp.","pos":""}],"MACERATION":[{"def":"The act or process of macerating.","pos":""},{"def":"A genus of extinct mammals allied to the cats, and having in the upper jaw canine teeth of remarkable size and strength; -- hence called saber-toothed tigers.","pos":""}],"MACHETE":[{"def":"A large heavy knife resembling a broadsword, often two or three feet in length, -- used by the inhabitants of Spanish America as a hatchet to cut their way through thickets, and for various other purposes.","pos":""}],"MACHIAVELIAN":[{"def":"Of or pertaining to Machiavel, or to his supposed principles; politically cunning; characterized by duplicity or bad faith; crafty.","pos":""}],"MACHICOLATED":[{"def":"Having machicolations.","pos":""}],"MACHICOLATION":[{"def":"An opening between the corbels which support a projecting parapet, or in the floor of a gallery or the roof of a portal, shooting or dropping missiles upen assailants attacking the base of the walls.","pos":""}],"MACHICOULIS":[{"def":"Same as Machicolation.","pos":""}],"MACHINAL":[{"def":"Of or pertaining to machines.","pos":""}],"MACHINATE":[{"def":"To plan; to contrive; esp.","pos":""}],"MACHINATION":[{"def":"The act of machinating.","pos":""},{"def":"That which is devised; a device; a hostile or treacherous scheme; an artful design or plot.","pos":""}],"MACHINATOR":[{"def":"One who machinates, or forms a scheme with evil designs; a plotter or artful schemer.","pos":""}],"MACHINE":[{"def":"In general, any combination of bodies so connected that their relative motions are constrained, and by means of which force and motion may be transmitted and modified, as a screw and its nut, or a lever arranged to turn about a fulcrum or a pulley about its pivot, etc.","pos":""},{"def":"Any mechanical contrivance, as the wooden horse with which the Greeks entered Troy; a coach; a bicycle.","pos":""}],"MACHINER":[{"def":"One who or operates a machine; a machinist.","pos":""}],"MACHINERY":[{"def":"Machines, in general, or collectively.","pos":""},{"def":"The working parts of a machine, engine, or instrument; as, the machinery of a watch.","pos":""}],"MACHINING":[{"def":"Of or pertaining to the machinery of a poem; acting or used as a machine.","pos":""}],"MACHINIST":[{"def":"A constrictor of machines and engines; one versed in the principles of machines.","pos":""},{"def":"One skilled in the use of machine tools.","pos":""}],"MACHO":[{"def":"The striped mullet of California (Mugil cephalus, or Mexicanus).","pos":""}],"MACINTOSH":[{"def":"Same as Mackintosh.","pos":""}],"MACKEREL":[{"def":"A pimp; also, a bawd.","pos":""}],"MACKINAW BOAT":[{"def":"A flat-bottomed boat with a pointed prow and square stern, using oars or sails or both, used esp.","pos":""}],"MACKINAW COAT":[{"def":"A short, heavy, double-breasted plaid coat, the design of which is large and striking.","pos":""}],"MACKINTOSH":[{"def":"A waterproof outer garment; -- so called from the name of the inventor.","pos":""}],"MACKLE":[{"def":"To blur, or be blurred, in printing, as if there were a double impression.","pos":""}],"MACLUREA":[{"def":"A genus of spiral gastropod shells, often of large size, characteristic of the lower Silurian rocks.","pos":""}],"MACLURIN":[{"def":"See Morintannic.","pos":""}],"MACRAME LACE":[{"def":"A coarse lace made of twine, used especially in decorating furniture.","pos":""},{"def":"Having a large brain.","pos":""}],"MACRO-":[{"def":"A combining form signifying long, large, great; as macrodiagonal, macrospore.","pos":""}],"MACRO-CHEMISTRY":[{"def":"The science which treats of the chemical properties, actions or relations of substances in quantity; -- distinguished from micro- chemistry.","pos":""}],"MACROBIOTICS":[{"def":"The art of prolonging life.","pos":""}],"MACROCEPHALOUS":[{"def":"Having the cotyledons of a dicotyledonous embryo confluent, and forming a large mass compared with the rest of the body.","pos":""}],"MACROCHIRES":[{"def":"A division of birds including the swifts and humming birds.","pos":""}],"MACROCOSM":[{"def":"The great world; that part of the universe which is exterior to man; -- contrasted with microcosm, or man.","pos":""}],"MACROCOSMIC":[{"def":"Of or pertaining to the macrocosm.","pos":""}],"MACROCYSTIS":[{"def":"An immensely long blackish seaweed of the Pacific (Macrocystis pyrifera), having numerous almond-shaped air vessels.","pos":""}],"MACRODACTYL":[{"def":"One of a group of wading birds (Macrodactyli) having very long toes.","pos":""},{"def":"Having long toes.","pos":""}],"MACRODIAGONAL":[{"def":"The longer of two diagonals, as of a rhombic prism.","pos":""}],"MACRODOME":[{"def":"A dome parallel to the longer lateral axis of an orthorhombic crystal.","pos":""}],"MACRODONT":[{"def":"Having large teeth.","pos":""},{"def":"A macrodont animal.","pos":""}],"MACROGLOSSIA":[{"def":"Enlargement or hypertrophy of the tongue.","pos":""}],"MACROGRAPH":[{"def":"A picture of an object as seen by the naked eye (that is, unmagnified); as, a macrograph of a metallic fracture.","pos":""}],"MACROGRAPHY":[{"def":"Examination or study with the naked eye, as distinguished from micrography.","pos":""}],"MACROLOGY":[{"def":"Long and tedious talk without much substance; superfluity of words.","pos":""}],"MACROMETER":[{"def":"An instrument for determining the size or distance of inaccessible objects by means of two reflectors on a common sextant.","pos":""}],"MACRON":[{"def":"A short, straight, horizontal mark [-], placed over vowels to denote that they are to be pronounced with a long sound; as, a, in dame; e, in seam, etc.","pos":""}],"MACROPETALOUS":[{"def":"Having long or large petals.","pos":""}],"MACROPHYLLOUS":[{"def":"Having long or large leaves.","pos":""}],"MACROPINACOID":[{"def":"One of the two planes of an orthorhombic crystal which are parallel to the vertical and longer lateral (macrodiagonal) axes.","pos":""}],"MACROPOD":[{"def":"Any one of a group of maioid crabs remarkable for the length of their legs; -- called also spider crab.","pos":""}],"MACROPODAL":[{"def":"Having long or large feet, or a long stem.","pos":""}],"MACROPODOUS":[{"def":"Having long legs or feet.","pos":""}],"MACROPRISM":[{"def":"A prism of an orthorhombic crystal between the macropinacoid and the unit prism; the corresponding pyramids are called macropyramids.","pos":""}],"MACROPTERES":[{"def":"A division of birds; the Longipennes.","pos":""}],"MACROPTEROUS":[{"def":"Having long wings.","pos":""}],"MACROPUS":[{"def":"genus of marsupials including the common kangaroo.","pos":""}],"MACROPYRAMID":[{"def":"Visible to the unassisted eye; -- as opposed to microscopic.","pos":""}],"MACROSPORANGIUM":[{"def":"A sporangium or conceptacle containing only large spores; -- opposed to microsporangium.","pos":""}],"MACROSPORE":[{"def":"One of the specially large spores of certain flowerless plants, as Selaginella, etc.","pos":""}],"MACROSPORIC":[{"def":"Of or pertaining to macrospores.","pos":""}],"MACROTOUS":[{"def":"Same as Macrura, Macrural, etc.","pos":""}],"MACRURA":[{"def":"A subdivision of decapod Crustacea, having the abdomen largely developed.","pos":""}],"MACRURAL":[{"def":"Same as Macrurous.","pos":""}],"MACRURAN":[{"def":"One of the Macrura.","pos":""}],"MACRUROID":[{"def":"Like or pertaining to the Macrura.","pos":""}],"MACRUROUS":[{"def":"Of or pertaining to the Macrura; having a long tail.","pos":""}],"MACTATION":[{"def":"The act of killing a victim for sacrifice.","pos":""}],"MACTRA":[{"def":"Any marine bivalve shell of the genus Mactra, and allied genera.","pos":""}],"MACULA":[{"def":"A rather large spot or blotch of color.","pos":""}],"MACULATE":[{"def":"To spot; to stain; to blur.","pos":""}],"MACULATED":[{"def":"Having spots or blotches; maculate.","pos":""}],"MACULATION":[{"def":"The act of spotting; a spot; a blemish.","pos":""}],"MACULATORY":[{"def":"Causing a spot or stain.","pos":""}],"MACULATURE":[{"def":", Blotting paper.","pos":""}],"MACULE":[{"def":"A blur, or an appearance of a double impression, as when the paper slips a little; a mackle.","pos":""}],"MACULOSE":[{"def":"Of or pertaining to spots upon a surface; spotted; maculate.","pos":""}]}