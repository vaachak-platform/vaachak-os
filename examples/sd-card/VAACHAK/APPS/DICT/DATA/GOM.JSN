{"GOMAN":[{"def":"A husband; a master of a family.","pos":""},{"def":"One of the followers of Francis Gomar or Gomarus, a Dutch disciple of Calvin in the 17th century, who strongly opposed the Arminians.","pos":""}],"GOME":[{"def":"The black grease on the axle of a cart or wagon wheel; -- called also gorm.","pos":""}],"GOMER":[{"def":"A Hebrew measure.","pos":""}],"GOMPHIASIS":[{"def":"A disease of the teeth, which causes them to loosen and fall out of their sockets.","pos":""}],"GOMPHOSIS":[{"def":"A form of union or immovable articulation where a hard part is received into the cavity of a bone, as the teeth into the jaws.","pos":""}],"GOMUTI":[{"def":"A black, fibrous substance resembling horsehair, obtained from the leafstalks of two kinds of palms, Metroxylon Sagu, and Arenga saccharifera, of the Indian islands.","pos":""}]}