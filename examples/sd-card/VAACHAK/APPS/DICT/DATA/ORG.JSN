{"ORGAN":[{"def":"A natural part or structure in an animal or a plant, capable of performing some special action (termed its function), which is essential to the life or well-being of the whole; as, the heart, lungs, etc.","pos":""},{"def":"A wind instrument containing numerous pipes of various dimensions and kinds, which are filled with wind from a bellows, and played upon by means of keys similar to those of a piano, and sometimes by foot keys or pedals; -- formerly used in the plural, each pipe being considired an organ.","pos":""}],"ORGANIC":[{"def":"Of or pertaining to an organ or its functions, or to objects composed of organs; consisting of organs, or containing them; as, the organic structure of animals and plants; exhibiting characters peculiar to living organisms; as, organic bodies, organic life, organic remains.","pos":""}],"ORGANICAL":[{"def":"The organical structure of human bodies, whereby they live and move.","pos":""}],"ORGANICALLY":[{"def":"In an organic manner; by means of organs or with reference to organic functions; hence, fundamentally.","pos":""}],"ORGANICALNESS":[{"def":"The quality or state of being organic.","pos":""}],"ORGANICISM":[{"def":"The doctrine of the localization of disease, or which refers it always to a material lesion of an organ.","pos":""}],"ORGANIFIC":[{"def":"Making an organic or organized structure; producing an organism; acting through, or resulting from, organs.","pos":""}],"ORGANISM":[{"def":"An organized being; a living body, either vegetable or animal, compozed of different organs or parts with functions which are separate, but mutually dependent, and essential to the life of the individual.","pos":""}],"ORGANIST":[{"def":"One who plays on the organ.","pos":""},{"def":"One of the priests who organized or sung in parts.","pos":""}],"ORGANISTA":[{"def":"Any one of several South American wrens, noted for the sweetness of their song.","pos":""}],"ORGANIZABILITY":[{"def":"Quality of being organizable; capability of being organized.","pos":""}],"ORGANIZABLE":[{"def":"Capable of being organized; esp.","pos":""}],"ORGANIZATION":[{"def":"The act of organizing; the act of arranging in a systematic way for use or action; as, the organization of an army, or of a deliberative body.","pos":""},{"def":"The state of being organized; also, the relations included in such a state or condition.","pos":""}],"ORGANIZE":[{"def":"To furnish with organs; to give an organic structure to; to endow with capacity for the functions of life; as, an organized being; organized matter; -- in this sense used chiefly in the past participle.","pos":""},{"def":"To sing in parts; as, to organize an anthem.","pos":""}],"ORGANIZER":[{"def":"One who organizes.","pos":""}],"ORGANLING":[{"def":"A large kind of sea fish; the orgeis.","pos":""}],"ORGANO-":[{"def":"A combining form denoting relation to, or connection with, an organ or organs.","pos":""}],"ORGANOGEN":[{"def":"A name given to any one of the four elements, carbon, hydrogen, oxygen, and nitrogen, which are especially characteristic ingredients of organic compounds; also, by extension, to other elements sometimes found in the same connection; as sulphur, phosphorus, etc.","pos":""}],"ORGANOGENESIS":[{"def":"The origin and development of organs in animals and plants.","pos":""},{"def":"The germ history of the organs and systems of organs, -- a branch of morphogeny.","pos":""}],"ORGANOGENIC":[{"def":"Of or pertaining to organogenesis.","pos":""}],"ORGANOGENY":[{"def":"Of or pertaining to organography.","pos":""}],"ORGANOGRAPHIST":[{"def":"One versed in organography.","pos":""}],"ORGANOGRAPHY":[{"def":"A description of the organs of animals or plants.","pos":""}],"ORGANOLEPTIC":[{"def":"Making an impression upon an organ; plastic; -- said of the effect or impression produced by any substance on the organs of touch, taste, or smell, and also on the organism as a whole.","pos":""}],"ORGANOLOGICAL":[{"def":"Of or relating to organology.","pos":""}],"ORGANOLOGY":[{"def":"The science of organs or of anything considered as an organic structure.","pos":""},{"def":"That branch of biology which treats, in particular, of the organs of animals and plants.","pos":""}],"ORGANOMETALLIC":[{"def":"An organ or instrument; hence, a method by which philosophical or scientific investigation may be conducted; -- a term adopted from the Aristotelian writers by Lord Bacon, as the title (\"Novum Organon\") of part of his treatise on philosophical method.","pos":""}],"ORGANONYMY":[{"def":"The designation or nomenclature of organs.","pos":""}],"ORGANOPHYLY":[{"def":"The tribal history of organs, -- a branch of morphophyly.","pos":""}],"ORGANOPLASTIC":[{"def":"Having the property of producing the tissues or organs of animals and plants; as, the organoplastic cells.","pos":""}],"ORGANOTROPHIC":[{"def":"Relating to the creation, organization, and nutrition of living organs or parts.","pos":""}],"ORGANULE":[{"def":"One of the essential cells or elements of an organ.","pos":""}],"ORGANZINE":[{"def":"A kind of double thrown silk of very fine texture, that is, silk twisted like a rope with different strands, so as to increase its strength.","pos":""}],"ORGASM":[{"def":"Eager or immoderate excitement or action; the state of turgescence of any organ; erethism; esp.","pos":""}],"ORGEAT":[{"def":"A sirup in which, formerly, a decoction of barley entered, but which is now prepared with an emulsion of almonds, -- used to flavor beverages or edibles.","pos":""}],"ORGIASTIC":[{"def":"Pertaining to, or of the nature of, orgies.","pos":""}],"ORGIES":[{"def":"A sacrifice accompanied by certain ceremonies in honor of some pagan deity; especially, the ceremonies observed by the Greeks and Romans in the worship of Dionysus, or Bacchus, which were characterized by wild and dissolute revelry.","pos":""},{"def":"Drunken revelry; a carouse.","pos":""}],"ORGY":[{"def":"A frantic revel; drunken revelry.","pos":""}],"ORGYIA":[{"def":"A genus of bombycid moths whose caterpillars (esp.","pos":""}]}