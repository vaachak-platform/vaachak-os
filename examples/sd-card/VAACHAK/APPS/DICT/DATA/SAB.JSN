{"SABADILLA":[{"def":"A Mexican liliaceous plant (Schænocaulon officinale); also, its seeds, which contain the alkaloid veratrine.","pos":""}],"SABAEAN":[{"def":"Same as Sabianism.","pos":""}],"SABAEANISM":[{"def":"Same as Sabianism.","pos":""}],"SABAL":[{"def":"A genus of palm trees including the palmetto of the Southern United States.","pos":""}],"SABAOTH":[{"def":"Incorrectly, the Sabbath.","pos":""}],"SABBAT":[{"def":"In mediæval demonology, the nocturnal assembly in which demons and sorcerers were thought to celebrate their orgies.","pos":""}],"SABBATARIAN":[{"def":"One who regards and keeps the seventh day of the week as holy, aggreeably to the letter of the fourth commandment in the Decalogue.","pos":""},{"def":"A strict observer of the Sabbath.","pos":""}],"SABBATARIANISM":[{"def":"The tenets of Sabbatarians.","pos":""}],"SABBATH":[{"def":"The seventh year, observed among the Israelites as one of rest and festival.","pos":""}],"SABBATHLESS":[{"def":"Without Sabbath, or intermission of labor; hence, without respite or rest.","pos":""},{"def":"Of or pertaining to the Sabbath; resembling the Sabbath; enjoying or bringing an intermission of labor.","pos":""}],"SABBATISM":[{"def":"Intermission of labor, as upon the Sabbath; rest.","pos":""}],"SABBATON":[{"def":"A round-toed, armed covering for the feet, worn during a part of the sixteenth century in both military and civil dress.","pos":""}],"SABEISM":[{"def":"Same as Sabianism.","pos":""}],"SABELLA":[{"def":"A genus of tubiculous annelids having a circle of plumose gills around head.","pos":""}],"SABELLIAN":[{"def":"Pertaining to the doctrines or tenets of Sabellius.","pos":""}],"SABELLIANISM":[{"def":"The doctrines or tenets of Sabellius.","pos":""}],"SABELLOID":[{"def":"Like, or related to, the genus Sabella.","pos":""},{"def":"A sword with a broad and heavy blade, thick at the back, and usually more or less curved like a scimiter; a cavalry sword.","pos":""}],"SABIAN":[{"def":"Of or pertaining to Saba in Arabia, celebrated for producing aromatic plants.","pos":""},{"def":"Relating to the religion of Saba, or to the worship of the heavenly bodies.","pos":""}],"SABIANISM":[{"def":"The doctrine of the Sabians; the Sabian religion; that species of idolatry which consists in worshiping the sun, moon, and stars; heliolatry.","pos":""}],"SABICU":[{"def":"The very hard wood of a leguminous West Indian tree (Lysilona Sabicu), valued for shipbuilding.","pos":""}],"SABINE":[{"def":"Of or pertaining to the ancient Sabines, a people of Italy.","pos":""},{"def":"One of the Sabine people.","pos":""}],"SABLE":[{"def":"A carnivorous animal of the Weasel family (Mustela zibellina) native of the northern latitudes of Europe, Asia, and America, -- noted for its fine, soft, and valuable fur.","pos":""},{"def":"The tincture black; -- represented by vertical and horizontal lines each other.","pos":""}],"SABOT":[{"def":"A thick, circular disk of wood, to which the cartridge bag and projectile are attached, in fixed ammunition for cannon; also, a piece of soft metal attached to a projectile to take the groove of the rifling.","pos":""}],"SABOTIERE":[{"def":"A kind of freezer for ices.","pos":""}],"SABRETASCHE":[{"def":"A leather case or pocket worn by cavalry at the left side, suspended from the sword belt.","pos":""}],"SABRINA WORK":[{"def":"A variety of appliqué work for quilts, table covers, etc.","pos":""}],"SABULOSE":[{"def":"Growing in sandy places.","pos":""}],"SABULOSITY":[{"def":"The quality of being sabulous; sandiness; grittiness.","pos":""}]}