{"REI":[{"def":"A portuguese money of account, in value about one tenth of a cent.","pos":""}],"REICHSRATH":[{"def":"The parliament of Austria (exclusive of Hungary, which has its own diet, or parliament).","pos":""}],"REICHSSTAND":[{"def":"A free city of the former German empire.","pos":""}],"REICHSTAG":[{"def":"The Diet, or House of Representatives, of the German empire, which is composed of members elected for a term of three years by the direct vote of the people.","pos":""}],"REIGLE":[{"def":"A hollow cut or channel for quiding anything; as, the reigle of a side post for a flood gate.","pos":""}],"REIGLEMENT":[{"def":"Rule; regulation.","pos":""}],"REIGN":[{"def":"Royal authority; supreme power; sovereignty; rule; dominion.","pos":""},{"def":"The territory or sphere which is reigned over; kingdom; empire; realm; dominion.","pos":""}],"REILLUME":[{"def":"To light again; to cause to shine anew; to relume; to reillumine.","pos":""}],"REILLUMINATE":[{"def":"To enlighten again; to reillumine.","pos":""}],"REILLUMINATION":[{"def":"The act or process of enlightening again.","pos":""}],"REILLUMINE":[{"def":"To illumine again or anew; to reillume.","pos":""}],"REIM":[{"def":"A strip of oxhide, deprived of hair, and rendered pliable, -- used for twisting into ropes, etc.","pos":""}],"REIMBARK":[{"def":"Re`im*bark\" (r`m*brk\"), v.","pos":""}],"REIMBODY":[{"def":"To imbody again.","pos":""}],"REIMBURSABLE":[{"def":"Capable of being repaid; repayable.","pos":""}],"REIMBURSE":[{"def":"To replace in a treasury or purse, as an equivalent for what has been taken, lost, or expended; to refund; to pay back; to restore; as, to reimburse the expenses of a war.","pos":""},{"def":"To make restoration or payment of an equivalent to (a person); to pay back to; to indemnify; -- often reflexive; as, to reimburse one's self by successful speculation.","pos":""}],"REIMBURSEMENT":[{"def":"The act reimbursing.","pos":""}],"REIMBURSER":[{"def":"One who reimburses.","pos":""}],"REIMPLANT":[{"def":"To implant again.","pos":""}],"REIMPORT":[{"def":"To import again; to import what has been exported; to bring back.","pos":""}],"REIMPORTATION":[{"def":"The act of reimporting; also, that which is reimported.","pos":""}],"REIMPORTUNE":[{"def":"To importune again.","pos":""}],"REIMPOSE":[{"def":"Re`im*pose\" (r`m*pz), v.","pos":""}],"REIMPREGNATE":[{"def":"To impregnate again or anew.","pos":""}],"REIMPRESS":[{"def":"To impress anew.","pos":""}],"REIMPRESSION":[{"def":"A second or repeated impression; a reprint.","pos":""}],"REIMPRINT":[{"def":"To imprint again.","pos":""}],"REIMPRISON":[{"def":"To imprison again.","pos":""}],"REIMPRISONMENT":[{"def":"The act of reimprisoning, or the state of being reimprisoned.","pos":""}],"REIN":[{"def":"The strap of a bridle, fastened to the curb or snaffle on each side, by which the rider or driver governs the horse.","pos":""},{"def":"Hence, an instrument or means of curbing, restraining, or governing; government; restraint.","pos":""}],"REINAUGURATE":[{"def":"To inaugurate anew.","pos":""}],"REINCIT":[{"def":"To incite again.","pos":""}],"REINCORPORATE":[{"def":"To incorporate again.","pos":""}],"REINCREASE":[{"def":"To increase again.","pos":""}],"REINDEER":[{"def":"Any ruminant of the genus Rangifer, of the Deer family, found in the colder parts of both the Eastern and Western hemispheres, and having long irregularly branched antlers, with the brow tines palmate.","pos":""}],"REINDUCE":[{"def":"To induce again.","pos":""}],"REINETTE":[{"def":"A name given to many different kinds of apples, mostly of French origin.","pos":""}],"REINFECT":[{"def":"To infect again.","pos":""}],"REINFECTIOUS":[{"def":"Capable of reinfecting.","pos":""}],"REINFORCE":[{"def":"See Reënforce, v.","pos":""}],"REINFORCEMENT":[{"def":"See Reënforcement.","pos":""}],"REINFUND":[{"def":"To flow in anew.","pos":""}],"REINGRATIATE":[{"def":"To ingratiate again or anew.","pos":""}],"REINHABIT":[{"def":"To inhabit again.","pos":""}],"REINLESS":[{"def":"Not having, or not governed by, reins; hence, not checked or restrained.","pos":""}],"REINS":[{"def":"The kidneys; also, the region of the kidneys; the loins.","pos":""},{"def":"The inward impulses; the affections and passions; -- so called because formerly supposed to have their seat in the part of the body where the kidneys are.","pos":""}],"REINSERT":[{"def":"To insert again.","pos":""}],"REINSERTION":[{"def":"The act of reinserting.","pos":""}],"REINSPECT":[{"def":"To inspect again.","pos":""}],"REINSPECTION":[{"def":"The act of reinspecting.","pos":""}],"REINSPIRE":[{"def":"To inspire anew.","pos":""}],"REINSPIRIT":[{"def":"To give fresh spirit to.","pos":""}],"REINSTALL":[{"def":"To install again.","pos":""}],"REINSTALLMENT":[{"def":"A renewed installment.","pos":""}],"REINSTATE":[{"def":"To place again in possession, or in a former state; to restore to a state from which one had been removed; to instate again; as, to reinstate a king in the possession of the kingdom.","pos":""}],"REINSTATEMENT":[{"def":"Re`in*state\"ment (-ment), n.","pos":""}],"REINSTATION":[{"def":"Re`in*sta\"tion (-st\"shn), n.","pos":""}],"REINSTRUCT":[{"def":"To instruct anew.","pos":""}],"REINSURANCE":[{"def":"Insurance a second time or again; renewed insurance.","pos":""},{"def":"A contract by which an insurer is insured wholly or in part against the risk he has incurred in insuring somebody else.","pos":""}],"REINSURE":[{"def":"To insure again after a former insuranse has ceased; to renew insurance on.","pos":""},{"def":"To insure, as life or property, in favor of one who has taken an inssurance risk upon it.","pos":""}],"REINSURER":[{"def":"One who gives reinsurance.","pos":""}],"REINTEGRATE":[{"def":"To renew with regard to any state or quality; to restore; to bring again together into a whole, as the parts off anything; to reas, to reintegrate a nation.","pos":""}],"REINTEGRATION":[{"def":"A renewing, or making whole again.","pos":""}],"REINTER":[{"def":"Re`in*ter\" (r`n*tr\"), v.","pos":""}],"REINTERROGATE":[{"def":"To interrogate again; to question repeatedly.","pos":""}],"REINTHRONE":[{"def":"Re`in*throne\" (-thrn\"), v.","pos":""}],"REINTHRONIZE":[{"def":"To enthrone again.","pos":""}],"REINTRODUCE":[{"def":"To introduce again.","pos":""}],"REINVEST":[{"def":"To invest again or anew.","pos":""}],"REINVESTIGATE":[{"def":"To investigate again.","pos":""}],"REINVESTMENT":[{"def":"The act of investing anew; a second or repeated investment.","pos":""}],"REINVIGORATE":[{"def":"To invigorate anew.","pos":""}],"REINVOLVE":[{"def":"To involve anew.","pos":""}],"REIS":[{"def":"The word is used as a Portuguese designation of money of account, one hundred reis being about equal in value to eleven cents.","pos":""}],"REIS EFFENDI":[{"def":"A title formerly given to one of the chief Turkish officers of state.","pos":""}],"REISSNER'S MEMBRANE":[{"def":"The thin membrane which separates the canal of the cochlea from the vestibular scala in the internal ear.","pos":""}],"REISSUABLE":[{"def":"Capable of being reissued.","pos":""}],"REISSUE":[{"def":"To issue a second time.","pos":""}],"REITER":[{"def":"A German cavalry soldier of the fourteenth and fifteenth centuries.","pos":""}],"REITERANT":[{"def":"Re*it\"er*ant (r-t\"r-ant), a.","pos":""}],"REITERATE":[{"def":"To repeat again and again; to say or do repeatedly; sometimes, to repeat.","pos":""}],"REITERATEDLY":[{"def":"Re*it\"er*a`ted*ly (-`td-l), adv.","pos":""}],"REITERATION":[{"def":"The act of reiterating; that which is reiterated.","pos":""}],"REITERATIVE":[{"def":"A word expressing repeated or reiterated action.","pos":""}]}