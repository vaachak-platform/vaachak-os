{"SUBREADER":[{"def":"An under reader in the inns of court, who reads the texts of law the reader is to discourse upon.","pos":""}],"SUBRECTOR":[{"def":"An assistant restor.","pos":""}],"SUBRELIGION":[{"def":"A secondary religion; a belief or principle held in a quasi religious veneration.","pos":""}],"SUBREPTION":[{"def":"The act of obtaining a favor by surprise, or by unfair representation through suppression or fraudulent concealment of facts.","pos":""}],"SUBRIGID":[{"def":"Somewhat rigid or stiff.","pos":""}],"SUBRIGUOUS":[{"def":"Watered or wet beneath; well-watered.","pos":""}],"SUBROGATE":[{"def":"To put in the place of another; to substitute.","pos":""}],"SUBROGATION":[{"def":"The act of subrogating.","pos":""},{"def":"The substitution of one person in the place of another as a creditor, the new creditor succeeding to the rights of the former; the mode by which a third person who pays a creditor succeeds to his rights against the debtor.","pos":""}],"SUBROTUND":[{"def":"Somewhat rotund.","pos":""}]}