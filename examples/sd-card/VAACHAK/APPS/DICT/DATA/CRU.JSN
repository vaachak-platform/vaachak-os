{"CRUCIAL":[{"def":"Having the form of a cross; appertaining to a cross; cruciform; intersecting; as, crucial ligaments; a crucial incision.","pos":""},{"def":"Severe; trying or searching, as if bringing to the cross; decisive; as, a crucial test.","pos":""}],"CRUCIAN CARP":[{"def":"A kind of European carp (Carasius vulgaris), inferior to the common carp; -- called also German carp.","pos":""}],"CRUCIATE":[{"def":"Having the leaves or petals arranged in the form of a cross; cruciform.","pos":""}],"CRUCIATION":[{"def":"The act of torturing; torture; torment.","pos":""}],"CRUCIBLE":[{"def":"A vessel or melting pot, composed of some very refractory substance, as clay, graphite, platinum, and used for melting and calcining substances which require a strong degree of heat, as metals, ores, etc.","pos":""},{"def":"A hollow place at the bottom of a furnace, to receive the melted metal.","pos":""}],"CRUCIBLE STEEL":[{"def":"Cast steel made by fusing in crucibles crude or scrap steel, wrought iron, and other ingredients and fluxes.","pos":""}],"CRUCIFER":[{"def":"Any plant of the order Cruciferæ.","pos":""}],"CRUCIFEROUS":[{"def":"Of, pertaining to, or resembling, a family of plants which have four petals arranged like the arms of a cross, as the mustard, radish, turnip, etc.","pos":""}],"CRUCIFIER":[{"def":"One who crucifies; one who subjects himself or another to a painful trial.","pos":""}],"CRUCIFIX":[{"def":"A representation in art of the figure of Christ upon the cross; esp.","pos":""},{"def":"The cross or religion of Christ.","pos":""}],"CRUCIFIXION":[{"def":"The act of nailing or fastening a person to a cross, for the purpose of putting him to death; the use of the cross as a method of capital punishment.","pos":""},{"def":"The state of one who is nailed or fastened to a cross; death upon a cross.","pos":""}],"CRUCIFORM":[{"def":"Cross-shaped; (Bot.","pos":""}],"CRUCIFY":[{"def":"To fasten to a cross; to put to death by nailing the hands and feet to a cross or gibbet.","pos":""},{"def":"To destroy the power or ruling influence of; to subdue completely; to mortify.","pos":""}],"CRUCIGEROUS":[{"def":"Bearing the cross; marked with the figure of a cross.","pos":""}],"CRUDDLE":[{"def":"See how thy blood cruddles at this.","pos":""}],"CRUDE":[{"def":"Harsh and offensive, as a color; tawdry or in bad taste, as a combination of colors, or any design or work of art.","pos":""}],"CRUDELY":[{"def":"In a crude, immature manner.","pos":""}],"CRUDENESS":[{"def":"A crude, undigested, or unprepared state; rawness; unripeness; immatureness; unfitness for a destined use or purpose; as, the crudeness of iron ore; crudeness of theories or plans.","pos":""}],"CRUDITY":[{"def":"The condition of being crude; rawness.","pos":""},{"def":"That which is in a crude or undigested state; hence, superficial, undigested views, not reduced to order or form.","pos":""}],"CRUDY":[{"def":"His cruel wounds with crudy blood congealed.","pos":""}],"CRUEL":[{"def":"Disposed to give pain to others; willing or pleased to hurt, torment, or afflict; destitute of sympathetic kindness and pity; savage; inhuman; hard-hearted; merciless.","pos":""},{"def":"Causing, or fitted to cause, pain, grief, or misery.","pos":""}],"CRUELLY":[{"def":"In a cruel manner.","pos":""}],"CRUELS":[{"def":"Glandular scrofulous swellings in the neck.","pos":""}],"CRUELTY":[{"def":"The attribute or quality of being cruel; a disposition to give unnecessary pain or suffering to others; inhumanity; barbarity.","pos":""},{"def":"A cruel and barbarous deed; inhuman treatment; the act of willfully causing unnecessary pain.","pos":""}],"CRUENTATE":[{"def":"Smeared with blood.","pos":""}],"CRUENTOUS":[{"def":"Bloody; cruentate.","pos":""}],"CRUET":[{"def":"A vessel used to hold wine, oil, or water for the service of the altar.","pos":""}],"CRUISE":[{"def":"See Cruse, a small bottle.","pos":""}],"CRUISER":[{"def":"One who, or a vessel that, cruises; -- usually an armed vessel.","pos":""}],"CRUIVE":[{"def":"A kind of weir or dam for trapping salmon; also, a hovel.","pos":""}],"CRULLER":[{"def":"A kind of sweet cake cut in strips and curled or twisted, and fried crisp in boiling fat.","pos":""}],"CRUMB":[{"def":"A small fragment or piece; especially, a small piece of bread or other food, broken or cut off.","pos":""}],"CRUMBCLOTH":[{"def":"A cloth to be laid under a dining table to receive falling fragments, and keep the carpet or floor clean.","pos":""}],"CRUMBLE":[{"def":"To break into small pieces; to cause to fall in pieces.","pos":""}],"CRUMBLY":[{"def":"EAsily crumbled; friable; brittle.","pos":""}],"CRUMENAL":[{"def":"Cru\"me*nal (kr\"m-nal), n.","pos":""}],"CRUMMABLE":[{"def":"Capable of being crumbed or broken into small pieces.","pos":""}],"CRUMMY":[{"def":"Full of crumb or crumbs.","pos":""},{"def":"Soft, as the crumb of bread is; not crusty.","pos":""}],"CRUMP":[{"def":"Hard or crusty; dry baked; as, a crump loaf.","pos":""}],"CRUMPET":[{"def":"A kind of large.","pos":""}],"CRUMPLE":[{"def":"To draw or press into wrinkles or folds to crush together; to rumple; as, to crumple paper.","pos":""}],"CRUNCH":[{"def":"To chew with force and noise; to craunch.","pos":""},{"def":"To grind or press with violence and noise.","pos":""}],"CRUNODAL":[{"def":"Possessing, or characterized by, a crunode; -- used of curves.","pos":""}],"CRUNODE":[{"def":"A point where one branch of a curve crosses another branch.","pos":""}],"CRUOR":[{"def":"The coloring matter of the blood; the clotted portion of coagulated blood, containing the coloring matter; gore.","pos":""}],"CRUORIN":[{"def":"The coloring matter of the blood in the living animal; hæmoglobin.","pos":""}],"CRUP":[{"def":"Short; brittle; as, crup cake.","pos":""}],"CRUPPER":[{"def":"The buttocks or rump of a horse.","pos":""},{"def":"A leather loop, passing under a horse's tail, and buckled to the saddle to keep it from slipping forwards.","pos":""}],"CRURAL":[{"def":"Of or pertaining to the thigh or leg, or to any of the parts called crura; as, the crural arteries; crural arch; crural canal; crural ring.","pos":""}],"CRUSADE":[{"def":"Any one of the military expeditions undertaken by Christian powers, in the 11th, 12th, and 13th centuries, for the recovery of the Holy Land from the Mohammedans.","pos":""},{"def":"Any enterprise undertaken with zeal and enthusiasm; as, a crusade against intemperance.","pos":""}],"CRUSADER":[{"def":"One engaged in a crusade; as, the crusaders of the Middle Ages.","pos":""}],"CRUSADING":[{"def":"Of or pertaining to a crusade; as, a crusading spirit.","pos":""}],"CRUSADO":[{"def":"An old Portuguese coin, worth about seventy cents.","pos":""}],"CRUSE":[{"def":"A bottle for holding water, oil, honey, etc.","pos":""}],"CRUSET":[{"def":"A goldsmith's crucible or melting pot.","pos":""}],"CRUSH":[{"def":"To press or bruise between two hard bodies; to squeeze, so as to destroy the natural shape or integrity of the parts, or to force together into a mass; as, to crush grapes.","pos":""},{"def":"To reduce to fine particles by pounding or grinding; to comminute; as, to crush quartz.","pos":""}],"CRUSHER":[{"def":"One who, or that which, crushes.","pos":""}],"CRUSHING":[{"def":"That crushes; overwhelming.","pos":""}],"CRUST":[{"def":"The exterior portion of the earth, formerly universally supposed to inclose a molten interior.","pos":""},{"def":"The shell of crabs, lobsters, etc.","pos":""}],"CRUSTA":[{"def":"A crust or shell.","pos":""},{"def":"A gem engraved, or a plate embossed in low relief, for inlaying a vase or other object.","pos":""}],"CRUSTACEA":[{"def":"One of the classes of the arthropods, including lobsters and crabs; -- so called from the crustlike shell with which they are covered.","pos":""}],"CRUSTACEAN":[{"def":"Of or pertaining to the Crustacea; crustaceous.","pos":""},{"def":"An animal belonging to the class Crustacea.","pos":""}],"CRUSTACEOLOGICAL":[{"def":"Pertaining to crustaceology.","pos":""}],"CRUSTACEOLOGIST":[{"def":"One versed in crustaceology; a crustalogist.","pos":""}],"CRUSTACEOLOGY":[{"def":"That branch of Zoölogy which treats of the Crustacea; malacostracology; carcinology.","pos":""}],"CRUSTACEOUS":[{"def":"Belonging to the Crustacea; crustacean.","pos":""}],"CRUSTACEOUSNESS":[{"def":"The state or quality of being crustaceous or having a crustlike shell.","pos":""}],"CRUSTAL":[{"def":"Relating to a crust.","pos":""}],"CRUSTALOGICAL":[{"def":"Pertaining to crustalogy.","pos":""}],"CRUSTALOGIST":[{"def":"One versed in crustalogy.","pos":""}],"CRUSTALOGY":[{"def":"Crus*tal\"o*gy (krs-tl\"-j), n.","pos":""}],"CRUSTATED":[{"def":"Covered with a crust; as, crustated basalt.","pos":""}],"CRUSTATION":[{"def":"An adherent crust; an incrustation.","pos":""}],"CRUSTED":[{"def":"Incrusted; covered with, or containing, crust; as, old, crusted port wine.","pos":""}],"CRUSTIFIC":[{"def":"Producing or forming a crust or skin.","pos":""}],"CRUSTILY":[{"def":"In a crusty or surly manner; morosely.","pos":""}],"CRUSTINESS":[{"def":"The state or quality of having crust or being like crust; hardness.","pos":""},{"def":"The quality of being crusty or surly.","pos":""}],"CRUSTY":[{"def":"Having a hard exterior, or a short, rough manner, though kind at heart; snappish; peevish; surly.","pos":""}],"CRUT":[{"def":"The rough, shaggy part of oak bark.","pos":""}],"CRUTCH":[{"def":"A staff with a crosspiece at the head, to be placed under the arm or shoulder, to support the lame or infirm in walking.","pos":""},{"def":"A form of pommel for a woman's saddle, consisting of a forked rest to hold the leg of the rider.","pos":""}],"CRUTCHED":[{"def":"Marked with the sign of the cross; crouched.","pos":""}],"CRUX":[{"def":"Anything that is very puzzling or difficult to explain.","pos":""}],"CRUX ANSATA":[{"def":"A cross in the shape of the ankh.","pos":""}],"CRUZADO":[{"def":"Cru*za\"do (kr-z\"d), n.","pos":""}]}