{"CURIA":[{"def":"The court of a sovereign or of a feudal lord; also; his residence or his household.","pos":""},{"def":"Any court of justice.","pos":""}],"CURIAL":[{"def":"Of or pertaining to the papal curia; as, the curial etiquette of the Vatican.","pos":""},{"def":"A member of a curia, esp.","pos":""}],"CURIALISM":[{"def":"The wiew or doctrins of the ultramontane party in the Latin Church.","pos":""}],"CURIALIST":[{"def":"One who belongs to the ultramontane party in the Latin Church.","pos":""}],"CURIALISTIC":[{"def":"Pertaining to a court.","pos":""},{"def":"Relating or belonging to the ultramonate party in the Latin Church.","pos":""}],"CURIALITY":[{"def":"The privileges, prerogatives, or retinue of a court.","pos":""}],"CURING":[{"def":"Cur\"ing (kr\"ng), Defn: p.","pos":""}],"CURIO":[{"def":"Any curiosity or article of virtu.","pos":""}],"CURIOLOGIC":[{"def":"Pertaining to a rude kind of hieroglyphics, in which a thing is represented by its picture instead of by a symbol.","pos":""}],"CURIOSITY":[{"def":"The state or quality or being curious; nicety; accuracy; exactness; elaboration.","pos":""},{"def":"Disposition to inquire, investigate, or seek after knowledge; a desire to gratify the mind with new information or objects of interest; inquisitiveness.","pos":""}],"CURIOSO":[{"def":"Cu`ri*o\"so (k`r-\"z or k`r-\"s), n.","pos":""}],"CURIOUS":[{"def":"Difficult to please or satisfy; solicitous to be correct; careful; scrupulous; nice; exact.","pos":""},{"def":"Exhibiting care or nicety; artfully constructed; elaborate; wrought with elegance or skill.","pos":""}],"CURIOUSLY":[{"def":"In a curious manner.","pos":""}],"CURIOUSNESS":[{"def":"Carefulness; painstaking.","pos":""},{"def":"The state of being curious; exactness of workmanship; ingenuity of contrivance.","pos":""}]}