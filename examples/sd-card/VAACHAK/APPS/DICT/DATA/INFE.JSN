{"INFEASIBILITY":[{"def":"The state of being infeasible; impracticability.","pos":""}],"INFEASIBLE":[{"def":"Not capable of being done or accomplished; impracticable.","pos":""}],"INFEASIBLENESS":[{"def":"The state of quality of being infeasible; infeasibility.","pos":""}],"INFECT":[{"def":"To contaminate with illegality or to expo Syn.","pos":""}],"INFECTER":[{"def":"One who, or that which, infects.","pos":""}],"INFECTIBLE":[{"def":"Capable of being infected.","pos":""}],"INFECTION":[{"def":"Contamination by illegality, as in cases of contraband goods; implication.","pos":""}],"INFECTIOUS":[{"def":"Contaminating with illegality; exposing to seizure and forfeiture.","pos":""}],"INFECTIOUS DISEASE":[{"def":"In*fec\"tious dis*ease\".","pos":""}],"INFECTIOUSLY":[{"def":"In an infectious manner.","pos":""}],"INFECTIOUSNESS":[{"def":"The quality of being infectious.","pos":""}],"INFECUND":[{"def":"Unfruitful; not producing young; barren; infertile.","pos":""}],"INFECUNDITY":[{"def":"Want of fecundity or fruitfulness; barrenness; sterility; unproductiveness.","pos":""}],"INFECUNDOUS":[{"def":"Infertile; barren; unprofitable; unproductive.","pos":""}],"INFELICITOUS":[{"def":"Not felicitous; unhappy; unfortunate; not fortunate or appropriate in application; not well said, expressed, or done; as, an infelicitous condition; an infelicitous remark; an infelicitous description; infelicitous words.","pos":""}],"INFELICITY":[{"def":"The state or quality of being infelicitous; unhappiness; misery; wretchedness; misfortune; want of suitableness or appropriateness.","pos":""},{"def":"That (as an act, word, expression, etc.","pos":""}],"INFELONIOUS":[{"def":"Not felonious, malignant, or criminal.","pos":""}],"INFELT":[{"def":"Felt inwardly; heartfelt.","pos":""}],"INFEODATION":[{"def":"See Infeudation.","pos":""}],"INFEOFFMENT":[{"def":"See Enfeoffment.","pos":""}],"INFER":[{"def":"To bring on; to induce; to occasion.","pos":""},{"def":"To offer, as violence.","pos":""}],"INFERABLE":[{"def":"Capable of being inferred or deduced from premises.","pos":""}],"INFERENCE":[{"def":"The act or process of inferring by deduction or induction.","pos":""},{"def":"That which inferred; a truth or proposition drawn from another which is admitted or supposed to be true; a conclusion; a deduction.","pos":""}],"INFERENTIAL":[{"def":"Deduced or deducible by inference.","pos":""}],"INFERENTIALLY":[{"def":"By way of inference.","pos":""}],"INFERIAE":[{"def":"Sacrifices offered to the souls of deceased heroes or friends.","pos":""}],"INFERIOR":[{"def":"Junior or subordinate in rank; as, an inferior officer.","pos":""}],"INFERIORITY":[{"def":"The state of being inferior; a lower state or condition; as, inferiority of rank, of talents, of age, of worth.","pos":""}],"INFERIORLY":[{"def":"In an inferior manner, or on the inferior part.","pos":""}],"INFERNAL":[{"def":"Of or pertaining to or suitable for the lower regions, inhabited, according to the ancients, by the dead; pertaining to Pluto's realm of the dead, the Tartarus of the ancients.","pos":""},{"def":"Of or pertaining to, resembling, or inhabiting, hell; suitable for hell, or to the character of the inhabitants of hell; hellish; diabolical; as, infernal spirits, or conduct.","pos":""}],"INFERNALLY":[{"def":"In an infernal manner; diabolically.","pos":""}],"INFERNO":[{"def":"The infernal regions; hell.","pos":""}],"INFEROBRANCHIAN":[{"def":"One of the Inferobranchiata.","pos":""}],"INFEROBRANCHIATA":[{"def":"A suborder of marine gastropod mollusks, in which the gills are between the foot and the mantle.","pos":""}],"INFEROBRANCHIATE":[{"def":"Having the gills on the sides of the body, under the margin of the mantle; belonging to the Inferobranchiata.","pos":""}],"INFERTILE":[{"def":"Not fertile; not productive; barren; sterile; as, an infertile soil.","pos":""}],"INFERTILELY":[{"def":"In an infertile manner.","pos":""}],"INFERTILITY":[{"def":"The state or quality of being infertile; unproductiveness; barrenness.","pos":""}],"INFEST":[{"def":"Mischievous; hurtful; harassing.","pos":""}],"INFESTATION":[{"def":"The act of infesting or state of being infested; molestation; vexation; annoyance.","pos":""}],"INFESTER":[{"def":"One who, or that which, infests.","pos":""}],"INFESTIVE":[{"def":"Having no mirth; not festive or merry; dull; cheerless; gloomy; forlorn.","pos":""}],"INFESTIVITY":[{"def":"Want of festivity, cheerfulness, or mirth; dullness; cheerlessness.","pos":""}],"INFESTUOUS":[{"def":"Mischievous; harmful; dangerous.","pos":""}],"INFEUDATION":[{"def":"The act of putting one in possession of an estate in fee.","pos":""}]}