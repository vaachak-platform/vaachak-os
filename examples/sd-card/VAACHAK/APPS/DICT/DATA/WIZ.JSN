{"WIZARD":[{"def":"A wise man; a sage.","pos":""},{"def":"One devoted to the black art; a magician; a conjurer; a sorcerer; an enchanter.","pos":""}],"WIZARDLY":[{"def":"Resembling or becoming a wizard; wizardlike; weird.","pos":""}],"WIZARDRY":[{"def":"The character or practices o \"He acquired a reputation bordering on wizardry.","pos":""}],"WIZEN":[{"def":"To wither; to dry.","pos":""}],"WIZEN-FACED":[{"def":"Having a shriveled, thin, withered face.","pos":""}],"WIZENED":[{"def":"Dried; shriveled; withered; shrunken; weazen; as, a wizened old man.","pos":""}]}