{"STERCOBILIN":[{"def":"A coloring matter found in the fæces, a product of the alteration of the bile pigments in the intestinal canal, -- identical with hydrobilirubin.","pos":""}],"STERCOLIN":[{"def":"Same as Serolin (b).","pos":""}],"STERCORACEOUS":[{"def":"Of or pertaining to dung; partaking of the nature of, or containing, dung.","pos":""}],"STERCORANISM":[{"def":"The doctrine or belief of the Stercoranists.","pos":""}],"STERCORANIST":[{"def":"A nickname formerly given to those who held, or were alleged to hold, that the consecrated elements in the eucharist undergo the process of digestion in the body of the recipient.","pos":""}],"STERCORARY":[{"def":"A place, properly secured from the weather, for containing dung.","pos":""}],"STERCORATE":[{"def":"Excrement; dung.","pos":""}],"STERCORATION":[{"def":"Manuring with dung.","pos":""}],"STERCORIANISM":[{"def":"The doctrine or belief of the Stercoranists.","pos":""}],"STERCORIN":[{"def":"Same as Serolin (b).","pos":""}],"STERCORY":[{"def":"Excrement; dung.","pos":""}],"STERCULIACEOUS":[{"def":"Of or pertaining to a natural order (Sterculiaceæ) of polypetalous exogenous plants, mostly tropical.","pos":""}],"STERE":[{"def":"A unit of cubic measure in the metric system, being a cubic meter, or kiloliter, and equal to 35.","pos":""}],"STERELMINTHA":[{"def":"Same as Platyelminthes.","pos":""}],"STEREO-":[{"def":"A combining form meaning solid, hard, firm, as in stereo- chemistry, stereography.","pos":""}],"STEREO-CHEMISTRY":[{"def":"Chemistry considered with reference to the space relations of atoms.","pos":""}],"STEREOBATE":[{"def":"The lower part or basement of a building or pedestal; -- used loosely for several different forms of basement.","pos":""},{"def":"Pertaining to, or illustrating, the hypothetical space relations of atoms in the molecule; as, a stereo-chemic formula.","pos":""}],"STEREOCHROME":[{"def":"Stereochromic picture.","pos":""}],"STEREOCHROMIC":[{"def":"Pertaining to the art of stereochromy; produced by stereochromy.","pos":""}],"STEREOCHROMY":[{"def":"A style of painting on plastered walls or stone, in which the colors are rendered permanent by sprinklings of water, in which is mixed a proportion of soluble glass (a silicate of soda).","pos":""}],"STEREOELECTRIC":[{"def":"Of or pertaining to the generation of electricity by means of solid bodies alone; as, a stereoelectric current is one obtained by means of solids, without any liquid.","pos":""}],"STEREOGRAM":[{"def":"A diagram or picture which represents objects in such a way as to give the impression of relief or solidity; also, a stereograph.","pos":""}],"STEREOGRAPH":[{"def":"Any picture, or pair of pictures, prepared for exhibition in the stereoscope.","pos":""},{"def":"Made or done according to the rules of stereography; delineated on a plane; as, a stereographic chart of the earth.","pos":""}],"STEREOGRAPHICALLY":[{"def":"In a stereographical manner; by delineation on a plane.","pos":""}],"STEREOGRAPHY":[{"def":"The art of delineating the forms of solid bodies on a plane; a branch of solid geometry which shows the construction of all solids which are regularly defined.","pos":""}],"STEREOMETER":[{"def":"Of or pertaining to stereometry; performed or obtained by stereometry.","pos":""}],"STEREOMETRY":[{"def":"The art of measuring and computing the cubical contents of bodies and figures; -- distinguished from planimetry.","pos":""}],"STEREOMONOSCOPE":[{"def":"An instrument with two lenses, by which an image of a single picture projected upon a screen of ground glass is made to present an appearance of relief, and may be viewed by several persons at once.","pos":""}],"STEREOPLASM":[{"def":"The solid or insoluble portion of the cell protoplasm.","pos":""}],"STEREOSCOPE":[{"def":"An optical instrument for giving to pictures the appearance of solid forms, as seen in nature.","pos":""},{"def":"Of or pertaining to the stereoscope; characteristic of, or adapted to, the stereoscope; as, a stereoscopic effect; the stereoscopic function of the eyeglasses; stereoscopic views.","pos":""}],"STEREOSCOPIST":[{"def":"One skilled in the use or construction of stereoscopes.","pos":""}],"STEREOSCOPY":[{"def":"The art or science of using the stereoscope, or of constructing the instrument or the views used with it.","pos":""}],"STEREOSTATIC":[{"def":"Of or pertaining to stereotomy; performed by stereotomy.","pos":""}],"STEREOTOMY":[{"def":"The science or art of cutting solids into certain figures or sections, as arches, and the like; especially, the art of stonecutting.","pos":""}],"STEREOTYPE":[{"def":"A plate forming an exact faximile of a page of type or of an engraving, used in printing books, etc.","pos":""},{"def":"The art or process of making such plates, or of executing work by means of them.","pos":""}],"STEREOTYPED":[{"def":"Formed into, or printed from, stereotype plates.","pos":""}],"STEREOTYPER":[{"def":"One who stereotypes; one who makes stereotype plates, or works in a stereotype foundry.","pos":""}],"STEREOTYPERY":[{"def":"The art, process, or employment of making stereotype plates.","pos":""},{"def":"A place where stereotype plates are made; a stereotype foundry.","pos":""}],"STEREOTYPIC":[{"def":"Of or pertaining to stereotype, or stereotype plates.","pos":""}],"STEREOTYPOGRAPHER":[{"def":"A stereotype printer.","pos":""}],"STEREOTYPOGRAPHY":[{"def":"The act or art of printing from stereotype plates.","pos":""}],"STEREOTYPY":[{"def":"The art or process of making stereotype plates.","pos":""}],"STERHYDRAULIC":[{"def":"Pertaining to, or designating, a kind of hydraulic press; resembling such a press in action or principle.","pos":""}],"STERILE":[{"def":"Producing little or no crop; barren; unfruitful; unproductive; not fertile; as, sterile land; a sterile desert; a sterile year.","pos":""}],"STERILITY":[{"def":"Quality of being sterile; infecundity; also, the state of being free from germs or spores.","pos":""}],"STERILIZATION":[{"def":"The act or process of sterilizing, or rendering sterile; also, the state of being sterile.","pos":""}],"STERILIZE":[{"def":"To make sterile or unproductive; to impoverish, as land; to exhaust of fertility.","pos":""}],"STERILIZER":[{"def":"One that sterilizes anything; specif.","pos":""}],"STERLET":[{"def":"A small sturgeon (Acipenser ruthenus) found in the Caspian Sea and its rivers, and highly esteemed for its flavor.","pos":""}],"STERLING":[{"def":"Same as Starling, 3.","pos":""}],"STERN":[{"def":"Having a certain hardness or severity of nature, manner, or aspect; hard; severe; rigid; rigorous; austere; fixed; unchanging; unrelenting; hence, serious; resolute; harsh; as, a sternresolve; a stern necessity; a stern heart; a stern gaze; a stern decree.","pos":""}],"STERN-WHEEL":[{"def":"Having a paddle wheel at the stern; as, a stern-wheel steamer.","pos":""}],"STERN-WHEELER":[{"def":"A steamboat having a stern wheel instead of side wheels.","pos":""}],"STERNAL":[{"def":"Of or pertaining to the sternum; in the region of the sternum.","pos":""}],"STERNBERGITE":[{"def":"A sulphide of silver and iron, occurring in soft flexible laminæ varying in color from brown to black.","pos":""}],"STERNEBRA":[{"def":"One of the segments of the sternum.","pos":""}],"STERNED":[{"def":"Having a stern of a particular shape; -- used in composition; as, square-sterned.","pos":""}],"STERNFOREMOST":[{"def":"With the stern, instead of the bow, in advance; hence, figuratively, in an awkward, blundering manner.","pos":""}],"STERNITE":[{"def":"The sternum of an arthropod somite.","pos":""}],"STERNLY":[{"def":"In a stern manner.","pos":""}],"STERNMOST":[{"def":"Farthest in the rear; farthest astern; as, the sternmost ship in a convoy.","pos":""}],"STERNNESS":[{"def":"The quality or state of being stern.","pos":""}],"STERNO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the sternum; as, sternocostal, sternoscapular.","pos":""}],"STERNOCORACOID":[{"def":"Of or pertaining to the sternum and the coracoid.","pos":""}],"STERNOCOSTAL":[{"def":"Of or pertaining to the sternum and the ribs; as, the sternocostal cartilages.","pos":""}],"STERNOHYOID":[{"def":"Of or pertaining to the sternum and the hyoid bone or cartilage.","pos":""}],"STERNOMASTOID":[{"def":"Of or pertaining to the sternum and the mastoid process.","pos":""}],"STERNOTHYROID":[{"def":"Of or pertaining to the sternum and the thyroid cartilage.","pos":""}],"STERNPOST":[{"def":"A straight piece of timber, or an iron bar or beam, erected on the extremity of the keel to support the rudder, and receive the ends of the planks or plates of the vessel.","pos":""}],"STERNSON":[{"def":"The end of a ship's keelson, to which the sternpost is bolted; -- called also stern knee.","pos":""}],"STERNUM":[{"def":"A plate of cartilage, or a series of bony or cartilaginous plates or segments, in the median line of the pectoral skeleton of most vertebrates above fishes; the breastbone.","pos":""},{"def":"The ventral part of any one of the somites of an arthropod.","pos":""}],"STERNUTATION":[{"def":"The act of sneezing.","pos":""}],"STERNUTATIVE":[{"def":"Having the quality of provoking to sneeze.","pos":""}],"STERNUTATORY":[{"def":"A sternutatory substance or medicine.","pos":""}],"STERNWAY":[{"def":"The movement of a ship backward, or with her stern foremost.","pos":""}],"STERQUILINOUS":[{"def":"Pertaining to a dunghill; hence, mean; dirty; paltry.","pos":""}],"STERRINK":[{"def":"The crab-eating seal (Lobodon carcinophaga) of the Antarctic Ocean.","pos":""}],"STERROMETAL":[{"def":"Any alloy of copper, zinc, tin, and iron, of which cannon are sometimes made.","pos":""}],"STERTOROUS":[{"def":"Characterized by a deep snoring, which accompaines inspiration in some diseases, especially apoplexy; hence, hoarsely breathing; snoring.","pos":""}],"STERVE":[{"def":"To die, or cause to die; to perish.","pos":""}]}