{"DOLABRA":[{"def":"A rude ancient ax or hatchet, seen in museums.","pos":""}],"DOLABRIFORM":[{"def":"Shaped like the head of an ax or hatchet, as some leaves, and also certain organs of some shellfish.","pos":""},{"def":"Softly; sweetly; with soft, smooth, and delicate execution.","pos":""}],"DOLDRUMS":[{"def":"A part of the ocean near the equator, abounding in calms, squalls, and light, baffling winds, which sometimes prevent all progress for weeks; -- so called by sailors.","pos":""}],"DOLE":[{"def":"grief; sorrow; lamentation.","pos":""}],"DOLEFUL":[{"def":"Full of dole or grief; expressing or exciting sorrow; sorrowful; sad; dismal.","pos":""}],"DOLERITE":[{"def":"A dark-colored, basic, igneous rock, composed essentially of pyroxene and a triclinic feldspar with magnetic iron.","pos":""}],"DOLERITIC":[{"def":"Of the nature of dolerite; as, much lava is doleritic lava.","pos":""}],"DOLESOME":[{"def":"Doleful; dismal; gloomy; sorrowful.","pos":""}],"DOLF":[{"def":"Having the cranium, or skull, long to its breadth; long-headed; -- opposed to brachycephalic.","pos":""}],"DOLIOFORM":[{"def":"Barrel-shaped, or like a cask in form.","pos":""}],"DOLIOLUM":[{"def":"A genus of freeswimming oceanic tunicates, allied to Salpa, and having alternate generations.","pos":""}],"DOLIUM":[{"def":"A genus of large univalve mollusks, including the partridge shell and tun shells.","pos":""}],"DOLL":[{"def":"A child's puppet; a toy baby for a little girl.","pos":""}],"DOLLAR":[{"def":"A coin of the same general weight and value, though differing slightly in different countries, current in Mexico, Canada, parts of South America, also in Spain, and several other European countries.","pos":""},{"def":"The value of a dollar; the unit commonly employed in the United States in reckoning money values.","pos":""}],"DOLLARDEE":[{"def":"A species of sunfish (Lepomis pallidus), common in the United States; -- called also blue sunfish, and copper-nosed bream.","pos":""}],"DOLLY":[{"def":"A contrivance, turning on a vertical axis by a handle or winch, and giving a circular motion to the ore to be washed; a stirrer.","pos":""},{"def":"A tool with an indented head for shaping the head of a rivet.","pos":""}],"DOLLY VARDEN":[{"def":"A character in Dickens's novel \"Barnaby Rudge,\" a beautiful, lively, and coquettish girl who wore a cherry-colored mantle and cherry-colored ribbons.","pos":""},{"def":"A style of light, bright-figured dress goods for women; also, a style of dress.","pos":""}],"DOLMAN":[{"def":"A long robe or outer garment, with long sleeves, worn by the Turks.","pos":""},{"def":"A cloak of a peculiar fashion worn by women.","pos":""}],"DOLOMITE":[{"def":"A mineral consisting of the carbonate of lime and magnesia in varying proportions.","pos":""}],"DOLOMITIC":[{"def":"Pertaining to dolomite.","pos":""}],"DOLOMIZE":[{"def":"To convert into dolomite.","pos":""}],"DOLOR":[{"def":"Pain; grief; distress; anguish.","pos":""}],"DOLORIFEROUS":[{"def":"Causing pain or grief.","pos":""}],"DOLOROSO":[{"def":"Plaintive; pathetic; -- used adverbially as a musical direction.","pos":""}],"DOLOROUS":[{"def":"Full of grief; sad; sorrowful; doleful; dismal; as, a dolorous object; dolorous discourses.","pos":""},{"def":"Occasioning pain or grief; painful.","pos":""}],"DOLPHIN":[{"def":"A mass of iron or lead hung from the yardarm, in readiness to be dropped on the deck of an enemy's vessel.","pos":""},{"def":"In old ordnance, one of the handles above the trunnions by which the gun was lifted.","pos":""}],"DOLPHINET":[{"def":"A female dolphin.","pos":""}],"DOLT":[{"def":"A heavy, stupid fellow; a blockhead; a numskull; an ignoramus; a dunce; a dullard.","pos":""}],"DOLTISH":[{"def":"Doltlike; dull in intellect; stupid; blockish; as, a doltish clown.","pos":""}],"DOLUS":[{"def":"Evil intent, embracing both malice and fraud.","pos":""}],"DOLVEN":[{"def":"A suffix denoting: (a) Jurisdiction or property and jurisdiction, dominion, as in kingdom earldom.","pos":""}]}