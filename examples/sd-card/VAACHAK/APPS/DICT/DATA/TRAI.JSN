{"TRAIL":[{"def":"To carry, as a firearm, with the breech near the ground and the upper part inclined forward, the piece being held by the right hand near the middle.","pos":""}],"TRAIL ROPE":[{"def":"Same as Guide rope, above.","pos":""}],"TRAILER":[{"def":"One who, or that which, trails.","pos":""},{"def":"A part of an object which extends some distance beyond the main body of the object; as, the trailer of a plant.","pos":""}],"TRAILING":[{"def":"Trail\"ing, Defn: a.","pos":""}],"TRAILING EDGE":[{"def":"A following edge.","pos":""}],"TRAIN":[{"def":"To lead or direct, and form to a wall or espalier; to form to a proper shape, by bending, lopping, or pruning; as, to train young trees.","pos":""},{"def":"To trace, as a lode or any mineral appearance, to its head.","pos":""}],"TRAIN DISPATCHER":[{"def":"An official who gives the orders on a railroad as to the running of trains and their right of way.","pos":""}],"TRAIN OIL":[{"def":"Oil procured from the blubber or fat of whales, by boiling.","pos":""}],"TRAINABLE":[{"def":"Capable of being trained or educated; as, boys trainable to virtue.","pos":""}],"TRAINBAND":[{"def":"A band or company of an organized military force instituted by James I.","pos":""}],"TRAINBEARER":[{"def":"One who holds up a train, as of a robe.","pos":""}],"TRAINER":[{"def":"One who trains; an instructor; especially, one who trains or prepares men, horses, etc.","pos":""},{"def":"A militiaman when called out for exercise or discipline.","pos":""}],"TRAINING":[{"def":"The act of one who trains; the act or process of exercising, disciplining, etc.","pos":""}],"TRAINY":[{"def":"Belonging to train oil.","pos":""}],"TRAIPSE":[{"def":"To walk or run about in a slatternly, careless, or thoughtless manner.","pos":""}],"TRAIT":[{"def":"A stroke; a touch.","pos":""},{"def":"A distinguishing or marked feature; a peculiarity; as, a trait of character.","pos":""}],"TRAITEUR":[{"def":"The keeper of an eating house, or restaurant; a restaurateur.","pos":""}],"TRAITOR":[{"def":"Hence, one who betrays any confidence or trust; a betrayer.","pos":""}],"TRAITORLY":[{"def":"Like a traitor; treacherous; traitorous.","pos":""}],"TRAITOROUS":[{"def":"Guilty of treason; treacherous; perfidious; faithless; as, a traitorous officer or subject.","pos":""},{"def":"Consisting in treason; partaking of treason; implying breach of allegiance; as, a traitorous scheme.","pos":""}],"TRAITRESS":[{"def":"A woman who betrays her country or any trust; a traitoress.","pos":""}]}