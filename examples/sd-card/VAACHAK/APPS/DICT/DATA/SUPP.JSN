{"SUPPAGE":[{"def":"What may be supped; pottage.","pos":""}],"SUPPALPATION":[{"def":"The act of enticing by soft words; enticement.","pos":""}],"SUPPARASITATION":[{"def":"The act of flattering to gain favor; servile approbation.","pos":""}],"SUPPARASITE":[{"def":"To flatter; to cajole; to act the parasite.","pos":""}],"SUPPEDANEOUS":[{"def":"Being under the feet.","pos":""}],"SUPPEDITATE":[{"def":"To supply; to furnish.","pos":""}],"SUPPEDITATION":[{"def":"Supply; aid afforded.","pos":""}],"SUPPER":[{"def":"A meal taken at the close of the day; the evening meal.","pos":""}],"SUPPERLESS":[{"def":"Having no supper; deprived of supper; as, to go supperless to bed.","pos":""}],"SUPPING":[{"def":"The act of one who sups; the act of taking supper.","pos":""},{"def":"That which is supped; broth.","pos":""}],"SUPPLANT":[{"def":"To remove or displace by stratagem; to displace and take the place of; to supersede; as, a rival supplants another in the favor of a mistress or a prince.","pos":""}],"SUPPLANTATION":[{"def":"The act of supplanting or displacing.","pos":""}],"SUPPLANTER":[{"def":"One who supplants.","pos":""}],"SUPPLE":[{"def":"Pliant; flexible; easily bent; as, supple joints; supple fingers.","pos":""},{"def":"Yielding compliant; not obstinate; submissive to guidance; as, a supple horse.","pos":""}],"SUPPLE-CHAPPED":[{"def":"Having a limber tongue.","pos":""}],"SUPPLE-JACK":[{"def":"States, having a tough and pliable stem.","pos":""}],"SUPPLELY":[{"def":"In a supple manner; softly; pliantly; mildly.","pos":""}],"SUPPLEMENT":[{"def":"The number of degrees which, if added to a specified arc, make it 180°; the quantity by which an arc or an angle falls short of 180 degrees, or an arc falls short of a semicircle.","pos":""}],"SUPPLEMENTATION":[{"def":"The act of supplementing.","pos":""}],"SUPPLENESS":[{"def":"The quality or state of being supple; flexibility; pliableness; pliancy.","pos":""},{"def":"Supplying deficiencies; supplementary; as, a suppletory oath.","pos":""}],"SUPPLETORY":[{"def":"That which is to supply what is wanted.","pos":""}],"SUPPLIAL":[{"def":"The act of supplying; a supply.","pos":""}],"SUPPLIANCE":[{"def":"That which supplies a want; assistance; a gratification; satisfaction.","pos":""}],"SUPPLIANT":[{"def":"Asking earnestly and submissively; entreating; beseeching; supplicating.","pos":""},{"def":"Manifesting entreaty; expressive of supplication.","pos":""}],"SUPPLICANT":[{"def":"Entreating; asking submissively.","pos":""}],"SUPPLICAT":[{"def":"A petition; esp.","pos":""}],"SUPPLICATE":[{"def":"To entreat for; to seek by earnest prayer; to ask for earnestly and humbly; as, to supplicate blessings on Christian efforts to spread the gospel.","pos":""},{"def":"To address in prayer; to entreat as a supplicant; as, to supplicate the Deity.","pos":""}],"SUPPLICATINGLY":[{"def":"In a supplicating manner.","pos":""}],"SUPPLICATION":[{"def":"A religious solemnity observed in consequence of some military success, and also, in times of distress and danger, to avert the anger of the gods.","pos":""}],"SUPPLICATOR":[{"def":"One who supplicates; a supplicant.","pos":""}],"SUPPLICATORY":[{"def":"Containing supplication; humble; earnest.","pos":""}],"SUPPLIER":[{"def":"One who supplies.","pos":""}],"SUPPLY":[{"def":"To serve instead of; to take the place of.","pos":""}],"SUPPLYANT":[{"def":"Supplying or aiding; auxiliary; suppletory.","pos":""}],"SUPPLYMENT":[{"def":"A supplying or furnishing; supply.","pos":""}],"SUPPORT":[{"def":"To bear by being under; to keep from falling; to uphold; to sustain, in a literal or physical sense; to prop up; to bear the weight of; as, a pillar supports a structure; an abutment supports an arch; the trunk of a tree supports the branches.","pos":""},{"def":"To endure without being overcome, exhausted, or changed in character; to sustain; as, to support pain, distress, or misfortunes.","pos":""}],"SUPPORTABLE":[{"def":"Capable of being supported, maintained, or endured; endurable.","pos":""}],"SUPPORTATION":[{"def":"Maintenance; support.","pos":""}],"SUPPORTER":[{"def":"A knee placed under the cathead.","pos":""},{"def":"A figure, sometimes of a man, but commonly of some animal, placed on either side of an escutcheon, and exterior to it.","pos":""}],"SUPPORTFUL":[{"def":"Abounding with support.","pos":""}],"SUPPORTLESS":[{"def":"Having no support.","pos":""}],"SUPPORTRESS":[{"def":"A female supporter.","pos":""}],"SUPPOSABLE":[{"def":"Capable of being supposed, or imagined to exist; as, that is not a supposable case.","pos":""}],"SUPPOSAL":[{"def":"The act of supposing; also, that which is supposed; supposition; opinion.","pos":""}],"SUPPOSE":[{"def":"To imagine; to believe; to receive as true.","pos":""}],"SUPPOSEER":[{"def":"One who supposes.","pos":""}],"SUPPOSITION":[{"def":"The act of supposing, laying down, imagining, or considering as true or existing, what is known not to be true, or what is not proved.","pos":""},{"def":"That which is supposed; hypothesis; conjecture; surmise; opinion or belief without sufficient evidence.","pos":""}],"SUPPOSITIONAL":[{"def":"Resting on supposition; hypothetical; conjectural; supposed.","pos":""}],"SUPPOSITITIOUS":[{"def":"Fraudulently substituted for something else; not being what is purports to be; not genuine; spurious; counterfeit; as, a supposititious child; a supposititious writing.","pos":""},{"def":"Suppositional; hypothetical.","pos":""}],"SUPPOSITIVE":[{"def":"Including or implying supposition, or hypothesis; supposed.","pos":""}],"SUPPOSITOR":[{"def":"An apparatus for the introduction of suppositories into the rectum.","pos":""}],"SUPPOSITORY":[{"def":"A pill or bolus for introduction into the rectum; esp.","pos":""}],"SUPPOSURE":[{"def":"Supposition; hypothesis; conjecture.","pos":""}],"SUPPRESS":[{"def":"To overpower and crush; to subdue; to put down; to quell.","pos":""},{"def":"To keep in; to restrain from utterance or vent; as, to suppress the voice; to suppress a smile.","pos":""}],"SUPPRESSIBLE":[{"def":"That may be suppressed.","pos":""}],"SUPPRESSION":[{"def":"Complete stoppage of a natural secretion or excretion; as, suppression of urine; -- used in contradiction to retention, which signifies that the secretion or excretion is retained without expulsion.","pos":""},{"def":"Omission; as, the suppression of a word.","pos":""}],"SUPPRESSIVE":[{"def":"Tending to suppress; subduing; concealing.","pos":""}],"SUPPRESSOR":[{"def":"One who suppresses.","pos":""}],"SUPPURATE":[{"def":"To generate pus; as, a boil or abscess suppurates.","pos":""}],"SUPPURATION":[{"def":"The act or process of suppurating.","pos":""},{"def":"The matter produced by suppuration; pus.","pos":""}],"SUPPURATIVE":[{"def":"Tending to suppurate; promoting suppuration.","pos":""}],"SUPPUTATION":[{"def":"Reckoning; account.","pos":""}],"SUPPUTE":[{"def":"To reckon; to compute; to suppose; to impute.","pos":""}]}