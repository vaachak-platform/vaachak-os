{"PRITCH":[{"def":"A sharp-pointed instrument; also, an eelspear.","pos":""}],"PRITCHEL":[{"def":"A tool employed by blacksmiths for punching or enlarging the nail holes in a horseshoe.","pos":""}],"PRITHEE":[{"def":"A corruption of pray thee; as, I prithee; generally used without I.","pos":""}],"PRITTLE-PRATTLE":[{"def":"Empty talk; trifling loquacity; prattle; -- used in contempt or ridicule.","pos":""}]}