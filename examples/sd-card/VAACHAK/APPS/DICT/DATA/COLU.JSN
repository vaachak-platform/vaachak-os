{"COLUBER":[{"def":"A genus of harmless serpents.","pos":""}],"COLUBRINE":[{"def":"like or related to snakes of the genus Coluber.","pos":""}],"COLUGO":[{"def":"A peculiar East Indian mammal (Galleopithecus volans), having along the sides, connecting the fore and hind limbs, a parachutelike membrane, by means of which it is able to make long leaps, like the flying squirrel; -- called also flying lemur.","pos":""}],"COLUMBAE":[{"def":"An order of birds, including the pigeons.","pos":""}],"COLUMBARY":[{"def":"A dovecote; a pigeon house.","pos":""}],"COLUMBATE":[{"def":"A salt of columbic acid; a niobate.","pos":""}],"COLUMBATZ FLY":[{"def":"See Buffalo fly, under Buffalo.","pos":""}],"COLUMBELLA":[{"def":"A genus of univale shells, abundant in tropical seas.","pos":""}],"COLUMBIA":[{"def":"America; the United States; -- a poetical appellation given in honor of Columbus, the discoverer.","pos":""}],"COLUMBIAD":[{"def":"A form of seacoast cannon; a long, chambered gun designed for throwing shot or shells with heavy charges of powder, at high angles of elevation.","pos":""}],"COLUMBIAN":[{"def":"Of or pertaining to the United States, or to America.","pos":""}],"COLUMBIC":[{"def":"Pertaining to, or containing, columbium or niobium; niobic.","pos":""}],"COLUMBIFEROUS":[{"def":"Producing or containing columbium.","pos":""}],"COLUMBIN":[{"def":"A white, crystalline, bitter substance.","pos":""}],"COLUMBINE":[{"def":"Of or pertaining to a dove; dovelike; dove-colored.","pos":""}],"COLUMBITE":[{"def":"A mineral of a black color, submetallic luster, and high specific specific gravity.","pos":""}],"COLUMBIUM":[{"def":"A rare element of the vanadium group, first found in a variety of the mineral columbite occurring in Connecticut, probably at Haddam.","pos":""}],"COLUMBUS DAY":[{"def":"The 12th day of October, on which day in 1492 Christopher Columbus discovered America, landing on one of the Bahama Islands (probably the one now commonly called Watling Island), and naming it \"San Salvador\"; -- called also Discovery Day.","pos":""}],"COLUMELLA":[{"def":"A term applied to various columnlike parts; as, the columnella, or epipterygoid bone, in the skull of many lizards; the columella of the ear, the bony or cartilaginous rod connecting the tympanic membrane with the internal ear.","pos":""}],"COLUMELLIFORM":[{"def":"Shaped like a little column, or columella.","pos":""}],"COLUMN":[{"def":"A kind of pillar; a cylindrical or polygonal support for a roof, ceiling, statue, etc.","pos":""},{"def":"A number of ships so arranged as to follow one another in single or double file or in squadrons; -- in distinction from \"line\", where they are side by side.","pos":""}],"COLUMNAR":[{"def":"Formed in columns; having the form of a column or columns; like the shaft of a column.","pos":""}],"COLUMNARITY":[{"def":"The state or quality of being columnar.","pos":""}],"COLUMNATED":[{"def":"Having columns; as, columnated temples.","pos":""}],"COLUMNED":[{"def":"Troas and Ilion's columned citadel.","pos":""}],"COLUMNIATION":[{"def":"The employment or arrangement of columns in a structure.","pos":""}],"COLURE":[{"def":"One of two great circles intersecting at right angles in the poles of the equator.","pos":""}]}