{"MUM":[{"def":"Silent; not speaking.","pos":""}],"MUM-CHANCE":[{"def":"A game of hazard played with cards in silence.","pos":""},{"def":"A silent, stupid person.","pos":""}],"MUMBLE":[{"def":"To speak with the lips partly closed, so as to render the sounds inarticulate and imperfect; to utter words in a grumbling indistinct manner, indicating discontent or displeasure; to mutter.","pos":""},{"def":"To chew something gently with closed lips.","pos":""}],"MUMBLER":[{"def":"One who mumbles.","pos":""}],"MUMBLING":[{"def":"Low; indistinct; inarticulate.","pos":""}],"MUMBO JUMBO":[{"def":"An object of superstitious homage and fear.","pos":""}],"MUMM":[{"def":"To sport or make diversion in a mask or disguise; to mask.","pos":""}],"MUMMER":[{"def":"One who mumms, or makes diversion in disguise; a masker; a buffon.","pos":""}],"MUMMERY":[{"def":"Masking; frolic in disguise; buffoonery.","pos":""},{"def":"Farcical show; hypocritical disguise and parade or ceremonies.","pos":""}],"MUMMICHOG":[{"def":"Any one of several species of small American cyprinodont fishes of the genus Fundulus, and of allied genera; the killifishes; -- called also minnow.","pos":""}],"MUMMIFICATION":[{"def":"The act of making a mummy.","pos":""}],"MUMMIFIED":[{"def":"Converted into a mummy or a mummylike substance; having the appearance of a mummy; withered.","pos":""}],"MUMMIFORM":[{"def":"Having some resemblance to a mummy; -- in zoölogy, said of the pupæ of certain insects.","pos":""}],"MUMMIFY":[{"def":"To embalm and dry as a mummy; to make into, or like, a mummy.","pos":""}],"MUMMY":[{"def":"A sort of wax used in grafting, etc.","pos":""}],"MUMP":[{"def":"To move the lips with the mouth closed; to mumble, as in sulkiness.","pos":""},{"def":"To talk imperfectly, brokenly, or feebly; to chatter unintelligibly.","pos":""}],"MUMPER":[{"def":"A beggar; a begging impostor.","pos":""}],"MUMPS":[{"def":"Sullenness; silent displeasure; the sulks.","pos":""},{"def":"A specific infectious febrile disorder characterized by a nonsuppurative inflammation of the parotid glands; epidemic or infectious parotitis.","pos":""}]}