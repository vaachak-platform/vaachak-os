{"IRRADIANT":[{"def":"Irradiating or illuminating; as, the irradiant moon.","pos":""}],"IRRADIATE":[{"def":"To throw rays of light upon; to illuminate; to brighten; to adorn with luster.","pos":""},{"def":"To enlighten intellectually; to illuminate; as, to irradiate the mind.","pos":""}],"IRRADIATION":[{"def":"The apparent enlargement of a bright object seen upon a dark ground, due to the fact that the portions of the retina around the image are stimulated by the intense light; as when a dark spot on a white ground appears smaller, or a white spot on a dark ground larger, than it really is, esp.","pos":""}],"IRRATIONAL":[{"def":"Not capable of being exactly expressed by an integral number, or by a vulgar fraction; surd; -- said especially of roots.","pos":""}],"IRRATIONALITY":[{"def":"The quality or state of being irrational.","pos":""}],"IRRATIONALLY":[{"def":"In an irrational manner.","pos":""}],"IRRATIONALNESS":[{"def":"Ir*ra\"tion*al*ness, n.","pos":""}]}