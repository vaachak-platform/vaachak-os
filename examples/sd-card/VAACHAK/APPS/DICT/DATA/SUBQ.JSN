{"SUBQUADRATE":[{"def":"Nearly or approximately square; almost square.","pos":""}],"SUBQUADRUPLE":[{"def":"Containing one part of four; in the ratio of one to four; as, subquadruple proportion.","pos":""}],"SUBQUINQUEFID":[{"def":"Almost quinquefid; nearly quinquefid.","pos":""}],"SUBQUINTUPLE":[{"def":"Having the ratio of one to five; as, subquintuple proportion.","pos":""}]}