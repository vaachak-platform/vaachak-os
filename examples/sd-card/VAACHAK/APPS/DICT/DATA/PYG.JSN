{"PYGAL":[{"def":"Situated in the region of the rump, or posterior end of the backbone; -- applied especially to the posterior median plates in the carapace of chelonians.","pos":""},{"def":"A quadruped, probably the addax, an antelope having a white rump.","pos":""}],"PYGIDIUM":[{"def":"The caudal plate of trilobites, crustacean, and certain insects.","pos":""},{"def":"Of or pertaining to a pygmy; resembling a pygmy or dwarf; dwarfish; very small.","pos":""}],"PYGMY":[{"def":"One of a fabulous race of dwarfs who waged war with the cranes, and were destroyed.","pos":""}],"PYGOBRANCHIA":[{"def":"A division of opisthobranchiate mollusks having the branchiæ in a wreath or group around the anal opening, as in the genus Doris.","pos":""}],"PYGOPOD":[{"def":"One of the Pygopodes.","pos":""},{"def":"Any species of serpentiform lizards of the family Pygopodidæ, which have rudimentary hind legs near the anal cleft, but lack fore legs.","pos":""}],"PYGOPODES":[{"def":"A division of swimming birds which includes the grebes, divers, auks, etc.","pos":""}],"PYGOPODOUS":[{"def":"Of or pertaining to the Pygopodes.","pos":""}],"PYGOSTYLE":[{"def":"The plate of bone which forms the posterior end of the vertebral column in most birds; the plowshare bone; the vomer.","pos":""}]}