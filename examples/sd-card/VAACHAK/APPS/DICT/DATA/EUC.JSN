{"EUCAIRITE":[{"def":"A metallic mineral, a selenide of copper and silver; -- so called by Berzelius on account of its being found soon after the discovery of the metal selenium.","pos":""}],"EUCALYN":[{"def":"An unfermentable sugar, obtained as an uncrystallizable sirup by the decomposition of melitose; also obtained from a Tasmanian eucalyptus, -- whence its name.","pos":""}],"EUCALYPTOL":[{"def":"A volatile, terpenelike oil extracted from the eucalyptus, and consisting largely of cymene.","pos":""}],"EUCALYPTUS":[{"def":"A myrtaceous genus of trees, mostly Australian.","pos":""}],"EUCHARIS":[{"def":"A genus of South American amaryllidaceous plants with large and beautiful white blossoms.","pos":""}],"EUCHARIST":[{"def":"The sacrament of the Lord's Supper; the solemn act of ceremony of commemorating the death of Christ, in the use of bread and wine, as the appointed emblems; the communion.","pos":""}],"EUCHITE":[{"def":"One who resolves religion into prayer.","pos":""}],"EUCHLORIC":[{"def":"Relating to, or consisting of, euchlorine; as, euchloric .","pos":""}],"EUCHLORINE":[{"def":"A yellow or greenish yellow gas, first prepared by Davy, evolved from potassium chlorate and hydrochloric acid.","pos":""},{"def":"A formulary of prayers; the book of offices in the Greek Church, containing the liturgy, sacraments, and forms of prayers.","pos":""}],"EUCHRE":[{"def":"A game at cards, that may be played by two, three, or four persons, the highest card (except when an extra card called the Joker is used) being the knave of the same suit as the trump, and called right bower, the lowest card used being the seven, or frequently, in two-handed euchre, the nine spot.","pos":""}],"EUCHROIC":[{"def":"Having a fine color.","pos":""}],"EUCHROITE":[{"def":"A mineral occurring in transparent emerald green crystals.","pos":""}],"EUCHRONE":[{"def":"A substance obtained from euchroic acid.","pos":""}],"EUCHYMY":[{"def":"A good state of he blood and other fluids of the body.","pos":""}],"EUCLASE":[{"def":"A brittle gem occurring in light green, transparent crystals, affording a brilliant clinodiagonal cleavage.","pos":""}],"EUCLIDIAN":[{"def":"Related to Euclid, or to the geometry of Euclid.","pos":""}],"EUCOPEPODA":[{"def":"A group which includes the typical copepods and the lerneans.","pos":""}],"EUCRASY":[{"def":"Such a due mixture of qualities in bodies as constitutes health or soundness.","pos":""}],"EUCTICAL":[{"def":"Expecting a wish; supplicatory.","pos":""}]}