{"UNDER":[{"def":"Below or lower, in place or position, with the idea of being covered; lower than; beneath; -- opposed to over; as, he stood under a tree; the carriage is under cover; a cellar extends under the whole house.","pos":""}],"UNDER-AGE":[{"def":"Not having arrived at adult age, or at years of discretion; hence, raw; green; immature; boyish; childish.","pos":""}],"UNDER-ARM":[{"def":"Done (as bowling) with the arm not raised above the elbow, that is, not swung far out from the body; underhand.","pos":""}],"UNDER-GARMENT":[{"def":"A garment worn below another.","pos":""}],"UNDERACT":[{"def":"To perform inefficiently, as a play; to act feebly.","pos":""}],"UNDERACTION":[{"def":"Subordinate action; a minor action incidental or subsidiary to the main story; an episode.","pos":""}],"UNDERACTOR":[{"def":"A subordinate actor.","pos":""}],"UNDERAGENT":[{"def":"A subordinate agent.","pos":""}],"UNDERAID":[{"def":"To aid clandestinely.","pos":""}],"UNDERBACK":[{"def":"A vessel which receives the wort as it flows from the mashing tub.","pos":""}],"UNDERBEAR":[{"def":"To support; to endure.","pos":""},{"def":"To line; to guard; to face; as, cloth of gold underborne with blue tinsel.","pos":""}],"UNDERBEARER":[{"def":"One who supports or sustains; especially, at a funeral, one of those who bear the copse, as distinguished from a bearer, or pallbearer, who helps to hold up the pall.","pos":""}],"UNDERBID":[{"def":"To bid less than, as when a contract or service is offered to the lowest bidder; to offer to contract, sell, or do for a less price than.","pos":""}],"UNDERBIND":[{"def":"To bind beneath.","pos":""}],"UNDERBOARD":[{"def":"Under the board, or table; hence, secretly; unfairly; underhand.","pos":""}],"UNDERBRACE":[{"def":"To brace, fasten, or bind underneath or below.","pos":""}],"UNDERBRANCH":[{"def":"A twig or branchlet.","pos":""}],"UNDERBRED":[{"def":"Not thoroughly bred; ill-bred; as, an underbred fellow.","pos":""}],"UNDERBRUSH":[{"def":"Shrubs, small trees, and the like, in a wood or forest, growing beneath large trees; undergrowth.","pos":""}],"UNDERBUILDER":[{"def":"A subordinate or assistant builder.","pos":""}],"UNDERBUILDING":[{"def":"Same as Substruction.","pos":""}],"UNDERBUY":[{"def":"To buy at less than the real value or worth; to buy cheaper than.","pos":""}],"UNDERCAST":[{"def":"To cast under or beneath.","pos":""}],"UNDERCHAMBERLAIN":[{"def":"A deputy chamberlain of the exchequer.","pos":""}],"UNDERCHANTER":[{"def":"Same as Subchanter.","pos":""}],"UNDERCHAPS":[{"def":"The lower chaps or jaw.","pos":""}],"UNDERCHARGE":[{"def":"To charge below or under; to charge less than is usual or suitable fro; as, to undercharge goods or services.","pos":""},{"def":"To put too small a charge into; as, to undercharge a gun.","pos":""}],"UNDERCLAY":[{"def":"A stratum of clay lying beneath a coal bed, often containing the roots of coal plants, especially the Stigmaria.","pos":""}],"UNDERCLIFF":[{"def":"A subordinate cliff on a shore, consisting of material that has fallen from the higher cliff above.","pos":""}],"UNDERCLOTHES":[{"def":"Clothes worn under others, especially those worn next the skin for warmth.","pos":""}],"UNDERCLOTHING":[{"def":"Same as Underclothes.","pos":""}],"UNDERCOAT":[{"def":"A coat worn under another; a light coat, as distinguished from an overcoat, or a greatcoat.","pos":""},{"def":"A growth of short hair or fur partially concealed by a longer growth; as, a dog's undercoat.","pos":""}],"UNDERCONDUCT":[{"def":"A lower conduit; a subterranean conduit.","pos":""}],"UNDERCONSUMPTION":[{"def":"Consumption of less than is produced; consumption of less than the usual amount.","pos":""}],"UNDERCRAFT":[{"def":"A sly trick or device; as, an undercraft of authors.","pos":""}],"UNDERCREEP":[{"def":"To creep secretly or privily.","pos":""}],"UNDERCREST":[{"def":"To support as a crest; to bear.","pos":""}],"UNDERCROFT":[{"def":"A subterranean room of any kind; esp.","pos":""}],"UNDERCURRENT":[{"def":"A current below the surface of water, sometimes flowing in a contrary direction to that on the surface.","pos":""},{"def":"Hence, figuratively, a tendency of feeling, opinion, or the like, in a direction contrary to what is publicly shown; an unseen influence or tendency; as, a strong undercurrent of sentiment in favor of a prisoner.","pos":""}],"UNDERCUT":[{"def":"The lower or under side of a sirloin of beef; the fillet.","pos":""}],"UNDERDEALING":[{"def":"Crafty, unfair, or underhand dealing; unfair practice; trickery.","pos":""}],"UNDERDIG":[{"def":"To dig under or beneath; to undermine.","pos":""}],"UNDERDITCH":[{"def":"To dig an underground ditches in, so as to drain the surface; to underdrain; as, to underditch a field or a farm.","pos":""}],"UNDERDO":[{"def":"To do less than is requisite or proper; -- opposed to overdo.","pos":""}],"UNDERDOER":[{"def":"One who underdoes; a shirk.","pos":""}],"UNDERDOSE":[{"def":"A dose which is less than required; a small or insufficient dose.","pos":""}],"UNDERDRAIN":[{"def":"An underground drain or trench with openings through which the water may percolate from the soil or ground above.","pos":""}],"UNDERDRESSED":[{"def":"Not dresses enough.","pos":""}],"UNDERESTIMATE":[{"def":"The act of underestimating; too low an estimate.","pos":""}],"UNDERFACTION":[{"def":"A subordinate party or faction.","pos":""}],"UNDERFACULTY":[{"def":"An inferior or subordinate faculty.","pos":""}],"UNDERFARMER":[{"def":"An assistant farmer.","pos":""}],"UNDERFEED":[{"def":"To feed with too little food; to supply with an insufficient quantity of food.","pos":""}],"UNDERFELLOW":[{"def":"An underling [R.","pos":""}],"UNDERFILLING":[{"def":"The filling below or beneath; the under part of a building.","pos":""}],"UNDERFOLLOW":[{"def":"To follow closely or immediately after.","pos":""}],"UNDERFONG":[{"def":"To undertake; to take in hand; to receive.","pos":""},{"def":"To insnare; to circumvent.","pos":""}],"UNDERFOOT":[{"def":"Under the feet; underneath; below.","pos":""}],"UNDERFRINGE":[{"def":"A lower fringe; a fringe underneath something.","pos":""}],"UNDERFURNISH":[{"def":"To supply with less than enough; to furnish insufficiently.","pos":""}],"UNDERFURROW":[{"def":"To cover as under a furrow; to plow in; as, to underfurrow seed or manure.","pos":""}],"UNDERGET":[{"def":"To get under or beneath; also, to understand.","pos":""}],"UNDERGIRD":[{"def":"To blind below; to gird round the bottom.","pos":""}],"UNDERGLAZE":[{"def":"Applied under the glaze, that is, before the glaze, that is, before the glaze is put on; fitted to be so applied; -- said of colors in porcelain painting.","pos":""}],"UNDERGO":[{"def":"To go or move below or under.","pos":""},{"def":"To be subjected to; to bear up against; to pass through; to endure; to suffer; to sustain; as, to undergo toil and fatigue; to undergo pain, grief, or anxiety; to undergothe operation of amputation; food in the stomach undergoes the process of digestion.","pos":""}],"UNDERGORE":[{"def":"To gore underneath.","pos":""}],"UNDERGOWN":[{"def":"A gown worn under another, or under some other article of dress.","pos":""}],"UNDERGRADUATE":[{"def":"A member of a university or a college who has not taken his first degree; a student in any school who has not completed his course.","pos":""}],"UNDERGRADUATESHIP":[{"def":"The position or condition of an undergraduate.","pos":""}],"UNDERGROAN":[{"def":"To groan beneath.","pos":""}],"UNDERGROUND":[{"def":"The place or space beneath the surface of the ground; subterranean space.","pos":""}],"UNDERGROUND INSURANCE":[{"def":"Wildcat insurance.","pos":""}],"UNDERGROVE":[{"def":"A grove of shrubs or low trees under taller ones.","pos":""}],"UNDERGROW":[{"def":"To grow to an inferior, or less than the usual, size or height.","pos":""}],"UNDERGROWN":[{"def":"Of small stature; not grown to a full height or size.","pos":""}],"UNDERGROWTH":[{"def":"That which grows under trees; specifically, shrubs or small trees growing among large trees.","pos":""}],"UNDERHAND":[{"def":"Done, as pitching, with the hand lower than the shoulder, or, as bowling, with the hand lower than elbow.","pos":""}],"UNDERHANDED":[{"def":"Underhand; clandestine.","pos":""},{"def":"Insufficiently provided with hands or workers; short-handed; sparsely populated.","pos":""}],"UNDERHANDEDLY":[{"def":"In an underhand manner.","pos":""}],"UNDERHANG":[{"def":"To hang under or down; to suspend.","pos":""}],"UNDERHANGMAN":[{"def":"An assistant or deputy hangman.","pos":""}],"UNDERHEAD":[{"def":"A blockhead, or stupid person; a dunderhead.","pos":""}],"UNDERHEAVE":[{"def":"To heave or lift from below.","pos":""}],"UNDERHEW":[{"def":"To hew less than is usual or proper; specifically, to hew, as a piece of timber which should be square, in such a manner that it appears to contain a greater number of cubic feet than it really does contain.","pos":""}],"UNDERHONEST":[{"def":"Not entirely honest.","pos":""}],"UNDERHUNG":[{"def":"Resting on a track at the bottom, instead of being suspended; - - said of a sliding door.","pos":""}],"UNDERJOIN":[{"def":"To join below or beneath; to subjoin.","pos":""}],"UNDERKEEP":[{"def":"To keep under, or in subjection; to suppress.","pos":""}],"UNDERKEEPER":[{"def":"A subordinate keeper or guardian.","pos":""}],"UNDERKIND":[{"def":"An inferior kind.","pos":""}],"UNDERKINGDOM":[{"def":"A subordinate or dependent kingdom.","pos":""}],"UNDERLABORER":[{"def":"An assistant or subordinate laborer.","pos":""}],"UNDERLAID":[{"def":"Laid or placed underneath; also, having something laid or lying underneath.","pos":""}],"UNDERLAY":[{"def":"To lay beneath; to put under.","pos":""},{"def":"To raise or support by something laid under; as, to underlay a cut, plate, or the like, for printing.","pos":""}],"UNDERLAYER":[{"def":"A perpendicular shaft sunk to cut the lode at any required depth.","pos":""}],"UNDERLEAF":[{"def":"A prolific sort of apple, good for cider.","pos":""}],"UNDERLEASE":[{"def":"A lease granted by a tenant or lessee; especially, a lease granted by one who is himself a lessee for years, for any fewer or less number of years than he himself holds; a sublease.","pos":""}],"UNDERLET":[{"def":"To let below the value.","pos":""},{"def":"To let or lease at second hand; to sublet.","pos":""}],"UNDERLETTER":[{"def":"A tenant or lessee who grants a lease to another.","pos":""}],"UNDERLIE":[{"def":"To lie under; to rest beneath; to be situated under; as, a stratum of clay underlies the surface gravel.","pos":""},{"def":"To be at the basis of; to form the foundation of; to support; as, a doctrine underlying a theory.","pos":""}],"UNDERLINE":[{"def":"To mark a line below, as words; to underscore.","pos":""},{"def":"To influence secretly.","pos":""}],"UNDERLING":[{"def":"An inferior person or agent; a subordinate; hence, a mean, sorry fellow.","pos":""}],"UNDERLOAD STARTER":[{"def":"A motor starter provided with an underload switch.","pos":""}],"UNDERLOAD SWITCH":[{"def":"A switch which opens a circuit when the current falls below a certain predetermined value, used to protect certain types of motors from running at excessive speed upon decrease of load.","pos":""}],"UNDERLOCK":[{"def":"A lock of wool hanging under the belly of a sheep.","pos":""}],"UNDERLOCKER":[{"def":"A person who inspects a mine daily; -- called also underviewer.","pos":""}],"UNDERLYING":[{"def":"Lying under or beneath; hence, fundamental; as, the underlying strata of a locality; underlying principles.","pos":""}],"UNDERMANNED":[{"def":"Insufficiently furnished with men; short-handed.","pos":""}],"UNDERMASTED":[{"def":"Having masts smaller than the usual dimension; -- said of vessels.","pos":""}],"UNDERMASTER":[{"def":"A master subordinate to the principal master; an assistant master.","pos":""}],"UNDERMATCH":[{"def":"One who is not a match for another.","pos":""}],"UNDERMEAL":[{"def":"The inferior, or after, part of the day; the afternoon.","pos":""},{"def":"Hence, something occurring or done in the afternoon; esp.","pos":""}],"UNDERMINE":[{"def":"To excavate the earth beneath, or the part of, especially for the purpose of causing to fall or be overthrown; to form a mine under; to sap; as, to undermine a wall.","pos":""}],"UNDERMINER":[{"def":"One who undermines.","pos":""}],"UNDERMINISTER":[{"def":"To serve, or minister to, in a subordinate relation.","pos":""}],"UNDERMINISTRY":[{"def":"A subordinate or inferior ministry.","pos":""}],"UNDERMIRTH":[{"def":"Suppressed or concealed mirth.","pos":""}],"UNDERMOST":[{"def":"Lowest, as in place, rank, or condition.","pos":""}],"UNDERN":[{"def":"The time between; the time between sunrise and noon; specifically, the third hour of the day, or nine o'clock in the morning, according to ancient reckoning; hence, mealtime, because formerly the principal meal was eaten at that hour; also, later, the afternoon; the time between dinner and supper.","pos":""}],"UNDERNEATH":[{"def":"Beneath; below; in a lower place; under; as, a channel underneath the soil.","pos":""}],"UNDERNICENESS":[{"def":"A want of niceness; indelicacy; impropriety.","pos":""}],"UNDERNIME":[{"def":"To receive; to perceive.","pos":""},{"def":"To reprove; to reprehend.","pos":""}],"UNDEROFFICER":[{"def":"A subordinate officer.","pos":""}],"UNDERPART":[{"def":"A subordinate part.","pos":""}],"UNDERPAY":[{"def":"To pay inadequately.","pos":""}],"UNDERPEOPLED":[{"def":"Not fully peopled.","pos":""}],"UNDERPIGHT":[{"def":"Un`der*pight\", Defn: imp.","pos":""}],"UNDERPIN":[{"def":"To lay stones, masonry, etc.","pos":""},{"def":"To support by some solid foundation; to place something underneath for support.","pos":""}],"UNDERPINNING":[{"def":"The act of one who underpins; the act of supporting by stones, masonry, or the like.","pos":""}],"UNDERPITCH":[{"def":"To fill underneath; to stuff.","pos":""}],"UNDERPLANT":[{"def":"To plant under; specif.","pos":""},{"def":"to plant (young trees) under an existing stand.","pos":""}],"UNDERPLAY":[{"def":"To play a low card when holding a high one, in the hope of a future advantage.","pos":""}],"UNDERPLOT":[{"def":"A series of events in a play, proceeding collaterally with the main story, and subservient to it.","pos":""},{"def":"A clandestine scheme; a trick.","pos":""}],"UNDERPOISE":[{"def":"To weigh, estimate, or rate below desert; to undervalue.","pos":""}]}