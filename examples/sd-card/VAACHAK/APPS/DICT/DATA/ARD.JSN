{"ARDASSINE":[{"def":"A very fine sort of Persian silk.","pos":""}],"ARDENCY":[{"def":"Warmth of passion or affection; ardor; vehemence; eagerness; as, the ardency of love or zeal.","pos":""}],"ARDENT":[{"def":"Hot or burning; causing a sensation of burning; fiery; as, ardent spirits, that is, distilled liquors; an ardent fever.","pos":""},{"def":"Having the appearance or quality of fire; fierce; glowing; shining; as, ardent eyes.","pos":""}],"ARDENTLY":[{"def":"In an ardent manner; eagerly; with warmth; affectionately; passionately.","pos":""}],"ARDOIS SYSTEM":[{"def":"A widely used system of electric night signals in which a series of double electric lamps (white and red) is arranged vertically on a mast, and operated from a keyboard below.","pos":""}],"ARDOR":[{"def":"Bright and effulgent spirits; seraphim.","pos":""}],"ARDUOUS":[{"def":"Steep and lofty, in a literal sense; hard to climb.","pos":""},{"def":"Attended with great labor, like the ascending of acclivities; difficult; laborious; as, an arduous employment, task, or enterprise.","pos":""}],"ARDUOUSLY":[{"def":"In an arduous manner; with difficulty or laboriousness.","pos":""}],"ARDUOUSNESS":[{"def":"The quality of being arduous; difficulty of execution.","pos":""}],"ARDUROUS":[{"def":"Burning; ardent.","pos":""}]}