{"SNEAD":[{"def":"A line or cord; a string.","pos":""}],"SNEAK":[{"def":"To creep or steal (away or about) privately; to come or go meanly, as a person afraid or ashamed to be seen; as, to sneak away from company.","pos":""},{"def":"To act in a stealthy and cowardly manner; to behave with meanness and servility; to crouch.","pos":""}],"SNEAK CURRENT":[{"def":"A current which, though too feeble to blow the usual fuse or to injure at once telegraph or telephone instruments, will in time burn them out.","pos":""}],"SNEAK-CUP":[{"def":"One who sneaks from his cups; one who balks his glass.","pos":""}],"SNEAKER":[{"def":"A vessel of drink.","pos":""}],"SNEAKINESS":[{"def":"The quality of being sneaky.","pos":""}],"SNEAKING":[{"def":"Marked by cowardly concealment; deficient in openness and courage; underhand; mean; crouching.","pos":""}],"SNEAKSBY":[{"def":"A paltry fellow; a sneak.","pos":""}],"SNEAKY":[{"def":"Like a sneak; sneaking.","pos":""}],"SNEAP":[{"def":"To check; to reprimand; to rebuke; to chide.","pos":""},{"def":"To nip; to blast; to blight.","pos":""}],"SNEB":[{"def":"To reprimand; to sneap.","pos":""}],"SNECK":[{"def":"To fasten by a hatch; to latch, as a door.","pos":""}],"SNECKET":[{"def":"A door latch, or sneck.","pos":""}],"SNED":[{"def":"To lop; to snathe.","pos":""}],"SNEER":[{"def":"To show contempt by turning up the nose, or by a particular facial expression.","pos":""},{"def":"To inssinuate contempt by a covert expression; to speak derisively.","pos":""}],"SNEERFUL":[{"def":"Given to sneering.","pos":""}],"SNEERINGLY":[{"def":"In a sneering manner.","pos":""}],"SNEEZE":[{"def":"To emit air, chiefly through the nose, audibly and violently, by a kind of involuntary convulsive force, occasioned by irritation of the inner membrane of the nose.","pos":""}],"SNEEZEWEED":[{"def":"A yellow-flowered composite plant (Helenium autumnale) the odor of which is said to cause sneezing.","pos":""}],"SNEEZEWOOD":[{"def":"The wood of a South African tree.","pos":""}],"SNEEZEWORT":[{"def":"A European herbaceous plant (Achillea Ptarmica) allied to the yarrow, having a strong, pungent smell.","pos":""}],"SNEEZING":[{"def":"The act of violently forcing air out through the nasal passages while the cavity of the mouth is shut off from the pharynx by the approximation of the soft palate and the base of the tongue.","pos":""}],"SNELL":[{"def":"Active; brisk; nimble; quick; sharp.","pos":""}],"SNET":[{"def":"The fat of a deer.","pos":""}],"SNEW":[{"def":"To snow; to abound.","pos":""}]}