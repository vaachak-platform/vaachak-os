{"LOFT":[{"def":"That which is lifted up; an elevation.","pos":""}],"LOFTER":[{"def":"An iron club used in lofting the ball; -- called also lofting iron.","pos":""}],"LOFTILY":[{"def":"In a lofty manner or position; haughtily.","pos":""}],"LOFTINESS":[{"def":"The state or quality of being lofty.","pos":""}],"LOFTY":[{"def":"Lifted high up; having great height; towering; high.","pos":""}]}