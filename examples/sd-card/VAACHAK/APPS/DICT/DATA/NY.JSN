{"NYCTALOPIA":[{"def":"Note: Some writers (as Quain) use the word in the opposite sense, night blindness.","pos":""}],"NYCTALOPS":[{"def":"One afflicted with nyctalopia.","pos":""}],"NYCTALOPY":[{"def":"Same as Nyctalopia.","pos":""}],"NYCTHEMERON":[{"def":"The natural day and night, or space of twenty-four hours.","pos":""}],"NYCTIBUNE":[{"def":"A South American bird of the genus Nyctibius, allied to the goatsuckers.","pos":""}],"NYCTITROPIC":[{"def":"Turning or bending at night into special positions.","pos":""}],"NYCTITROPISM":[{"def":"The tendency of certain plant organs, as leaves, to assume special \"sleeping\" positions or make curvatures under the influence of darkness.","pos":""}],"NYCTOPHILE":[{"def":"Any Australian bat of the genus Nyctophilus, having a very simple nasal appendage.","pos":""}],"NYE":[{"def":"A brood or flock of pheasants.","pos":""}],"NYENTEK":[{"def":"A carnivorous mannual (Helictis moscatus, or H.","pos":""},{"def":"A large Asiatic antelope (Boselaphus, or Portax, tragocamelus), found in Northern India.","pos":""}],"NYMPH":[{"def":"A goddess of the mountains, forests, meadows, or waters.","pos":""},{"def":"The pupa of an insect; a chrysalis.","pos":""}],"NYMPHA":[{"def":"Same as Nymph, 3.","pos":""},{"def":"Two folds of mucous membrane, within the labia, at the opening of the vulva.","pos":""}],"NYMPHAEA":[{"def":"A genus of aquatic plants having showy flowers (white, blue, pink, or yellow, often fragrant), including the white water lily and the Egyptia lotus.","pos":""}],"NYMPHAL":[{"def":"Of or pertaining to a nymph or nymphs; nymphean.","pos":""}],"NYMPHALES":[{"def":"An extensive family of butterflies including the nymphs, the satyrs, the monarchs, the heliconias, and others; -- called also brush-footed butterflies.","pos":""}],"NYMPHEAN":[{"def":"Of, pertaining to, or appropriate to, nymphs; inhabited by nymphs; as, a nymphean cave.","pos":""}],"NYMPHET":[{"def":"A little or young nymph.","pos":""},{"def":"Of or pertaining to nymphs.","pos":""}],"NYMPHIPAROUS":[{"def":"Producing pupas or nymphs.","pos":""}],"NYMPHISH":[{"def":"Relating to nymphs; ladylike.","pos":""},{"def":"Resembling, or characteristic of, a nymph.","pos":""}],"NYMPHOLEPSY":[{"def":"A species of demoniac enthusiasm or possession coming upon one who had accidentally looked upon a nymph; ecstasy.","pos":""}],"NYMPHOLEPTIC":[{"def":"Under the influence of nympholepsy; ecstatic; frenzied.","pos":""}],"NYMPHOMANIA":[{"def":"Morbid and uncontrollable sexual desire in women, constituting a true disease.","pos":""}],"NYMPHOMANY":[{"def":"Same as Nymphomania.","pos":""}],"NYMPHOTOMY":[{"def":"Excision of the nymphæ.","pos":""}],"NYSTAGMUS":[{"def":"A rapid involuntary oscillation of the eyeballs.","pos":""}],"NYULA":[{"def":"A species of ichneumon (Herpestes nyula).","pos":""}]}