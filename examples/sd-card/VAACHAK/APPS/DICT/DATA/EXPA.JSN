{"EXPAND":[{"def":"To state in enlarged form; to develop; as, to expand an equation.","pos":""}],"EXPANDER":[{"def":"Anything which causes expansion esp.","pos":""}],"EXPANDING":[{"def":"That expands, or may be expanded; extending; spreading; enlarging.","pos":""}],"EXPANSE":[{"def":"That which is expanded or spread out; a wide extent of space or body; especially, the arch of the sky.","pos":""}],"EXPANSIBILITY":[{"def":"The capacity of being expanded; as, the expansibility of air.","pos":""}],"EXPANSIBLE":[{"def":"Capable of being expanded or spread out widely.","pos":""}],"EXPANSILE":[{"def":"Ether and alcohol are more expansile than water.","pos":""}],"EXPANSION":[{"def":"Enlargement or extension of business transaction; esp.","pos":""},{"def":"The developed result of an indicated operation; as, the expansion of (a + b)2 is a2 + 2ab + b2.","pos":""}],"EXPANSIVE":[{"def":"Having a capacity or tendency to expand or dilate; diffusive; of much expanse; wide-extending; as, the expansive force of heat; the expansive quality of air.","pos":""}],"EXPANSURE":[{"def":"Ex*pan\"sure (shur; 135), n.","pos":""}],"EXPATIATE":[{"def":"To range at large, or without restraint.","pos":""},{"def":"To enlarge in discourse or writing; to be copious in argument or discussion; to descant.","pos":""}],"EXPATIATION":[{"def":"Act of expatiating.","pos":""}],"EXPATIATORY":[{"def":"Expansive; diffusive.","pos":""}],"EXPATRIATE":[{"def":"To banish; to drive or force (a person) from his own country; to make an exile of.","pos":""},{"def":"Reflexively, as To expatriate one's self: To withdraw from one's native country; to renounce the rights and liabilities of citizenship where one is born, and become a citizen of another country.","pos":""}],"EXPATRIATION":[{"def":"The act of banishing, or the state of banishment; especially, the forsaking of one's own country with a renunciation of allegiance.","pos":""}]}