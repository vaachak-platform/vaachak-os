{"EY":[{"def":"Ey, Defn: an interj.","pos":""}],"EYALET":[{"def":"Formerly, one of the administrative divisions or provinces of the Ottoman Empire; -- now called a vilayet.","pos":""}],"EYAS":[{"def":"A nesting or unfledged Lird; in falconry, a young hawk from the nest, not able to pr Shak J.","pos":""}],"EYASMUSKET":[{"def":"An unfledged or young male sparrow hawk.","pos":""}],"EYE":[{"def":"A brood; as, an eye of pheasants.","pos":""}],"EYE OPENER":[{"def":"That which makes the eyes open, as startling news or occurrence, or (U.","pos":""}],"EYE-MINDED":[{"def":"Having one's mental imagery prevailingly of the visual type; having one's thoughts and memories mainly in the form of visual images.","pos":""}],"EYEBALL":[{"def":"The ball or globe of the eye.","pos":""}],"EYEBAR":[{"def":"A bar with an eye at one or both ends.","pos":""}],"EYEBEAM":[{"def":"A glance of the eye.","pos":""}],"EYEBOLT":[{"def":"A bolt which a looped head, or an opening in the head.","pos":""}],"EYEBRIGHT":[{"def":"A small annual plant (Euphrasia officinalis), formerly much used as a remedy for diseases of the eye.","pos":""}],"EYEBROW":[{"def":"The brow or hairy arch above the eye.","pos":""}],"EYECUP":[{"def":"A small oval porcelain or glass cup, having a rim curved to fit the orbit of the eye.","pos":""}],"EYED":[{"def":"Heaving (such or so many) eyes; -- used in composition; as sharp-eyed; dull-eyed; sad-eyed; ox-eyed Juno; myriad-eyed.","pos":""}],"EYEFLAP":[{"def":"A blinder on a horse's bridle.","pos":""}],"EYEFUL":[{"def":"Filling or satisfying the eye; visible; remarkable.","pos":""}],"EYEGLANCE":[{"def":"A glance of eye.","pos":""}],"EYEGLASS":[{"def":"A lens of glass to assist the sight.","pos":""},{"def":"Eyepiece of a telescope, microscope, etc.","pos":""}],"EYEHOLE":[{"def":"A circular opening to recive a hook, cord, ring, or rope; an eyelet.","pos":""}],"EYELASH":[{"def":"The fringe of hair that edges the eyelid; -- usually in the pl.","pos":""},{"def":"A hair of the fringe on the edge of the eyelid.","pos":""}],"EYELESS":[{"def":"Without eyes; blind.","pos":""}],"EYELET":[{"def":"A small hole or perforation to receive a cord or fastener, as in garments, sails, etc.","pos":""},{"def":"A metal ring or grommet, or short metallic tube, the ends of which can be bent outward and over to fasten it in place; -- used to line an eyelet hole.","pos":""}],"EYELETEER":[{"def":"A small, sharp-pointed instrument used in piercing eyelet holes; a stiletto.","pos":""}],"EYELID":[{"def":"The cover of the eye; that portion of movable skin with which an animal covers or uncovers the eyeball at pleasure.","pos":""}],"EYEPIECE":[{"def":"The lens, or combination of lenses, at the eye end of a telescope or other optical instrument, through which the image formed by the mirror or object glass is viewed.","pos":""}],"EYER":[{"def":"One who eyes another.","pos":""}],"EYEREACH":[{"def":"The range or reach of the eye; eyeshot.","pos":""},{"def":"An object of interest to the eye; one wirehaired with the eyes.","pos":""}],"EYESALVE":[{"def":"Ointment for the eye.","pos":""}],"EYESERVANT":[{"def":"A servant who attends faithfully to his duty only when watched.","pos":""}],"EYESERVICE":[{"def":"Service performed only under inspection, or the eye of an employer.","pos":""}],"EYESHOT":[{"def":"Range, reach, or glance of the eye; view; sight; as, to be out of eyeshot.","pos":""}],"EYESIGHT":[{"def":"Sight of the eye; the sense of seeing; view; observation.","pos":""}],"EYESORE":[{"def":"Something offensive to the eye or sight; a blemish.","pos":""},{"def":"A splice formed by bending a rope's and back, and fastening it into the rope, forming a loop or eye.","pos":""}],"EYESTALK":[{"def":"One of the movable peduncles which, in the decapod Crustacea, bear the eyes at the tip.","pos":""}],"EYESTONE":[{"def":"A small, lenticular, calcareous body, esp.","pos":""}],"EYESTRING":[{"def":"The tendon by which the eye is moved.","pos":""}],"EYETOOTH":[{"def":"A canine tooth of the upper jaw.","pos":""}],"EYEWATER":[{"def":"A wash or lotion for application to the eyes.","pos":""}],"EYEWINK":[{"def":"A wink; a token.","pos":""}],"EYEWITNESS":[{"def":"One who sees a thing done; one who has ocular view anything.","pos":""}],"EYLIAD":[{"def":"Plural of eye; obsolete, or used only in poetry.","pos":""}],"EYOT":[{"def":"A little island in a river or lake.","pos":""}],"EYRA":[{"def":"A wild cat (Felis eyra) ranging from southern Brazil to Texas.","pos":""}],"EYRE":[{"def":"A journey in circuit of certain judges called justices in eyre (or in itinere).","pos":""}],"EYREN":[{"def":"The nest of a bird of prey or other large bird that builds in a lofty place; aerie.","pos":""}],"EYSELL":[{"def":"F is the sixth letter of the English alphabet, and a nonvocal consonant.","pos":""}]}