{"HERCOGAMOUS":[{"def":"Not capable of self-fertilization; -- said of hermaphrodite flowers in which some structural obstacle forbids autogamy.","pos":""}],"HERCULEAN":[{"def":"Requiring the strength of Hercules; hence, very great, difficult, or dangerous; as, an Herculean task.","pos":""},{"def":"Having extraordinary strength or size; as, Herculean limbs.","pos":""}],"HERCULES":[{"def":"A hero, fabled to have been the son of Jupiter and Alcmena, and celebrated for great strength, esp.","pos":""},{"def":"A constellation in the northern hemisphere, near Lyra.","pos":""}],"HERCYNIAN":[{"def":"Of or pertaining to an extensive forest in Germany, of which there are still portions in Swabia and the Hartz mountains.","pos":""}]}