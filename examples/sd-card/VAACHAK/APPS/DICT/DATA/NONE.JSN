{"NONE":[{"def":"No one; not one; not anything; -- frequently used also partitively, or as a plural, not any.","pos":""},{"def":"No; not any; -- used adjectively before a vowel, in old style; as, thou shalt have none assurance of thy life.","pos":""}],"NONEFFECTIVE":[{"def":"Not fit or available for duty.","pos":""}],"NONELASTIC":[{"def":"Not having elasticity.","pos":""}],"NONELECT":[{"def":"A person or persons not elected, or chosen, to salvation.","pos":""}],"NONELECTION":[{"def":"Failure of election.","pos":""},{"def":"Not electric; conducting electricity.","pos":""}],"NONELECTRIC":[{"def":"A substance that is not an electric; that which transmits electricity, as a metal.","pos":""},{"def":"Having no emphasis; unemphatic.","pos":""}],"NONENTITY":[{"def":"Nonexistence; the negation of being.","pos":""},{"def":"A thing not existing.","pos":""}],"NONES":[{"def":"The fifth day of the months January, February, April, June, August, September, November, and December, and the seventh day of March, May, July, and October.","pos":""},{"def":"The canonical office, being a part of the Breviary, recited at noon (formerly at the ninth hour, 3 P.","pos":""}],"NONESSENTIAL":[{"def":"A thing not essential.","pos":""}],"NONESUCH":[{"def":"A person or thing of a sort that there is no other such; something extraordinary; a thing that has not its equal.","pos":""},{"def":"A composition for nine instruments, rarely for nine voices.","pos":""}],"NONEXECUTION":[{"def":"Neglect or failure of execution; nonperformance.","pos":""}],"NONEXISTENCE":[{"def":"Absence of existence; the negation of being; nonentity.","pos":""},{"def":"A thing that has no existence.","pos":""}],"NONEXISTENT":[{"def":"Not having existence.","pos":""}],"NONEXPORTATION":[{"def":"A failure of exportation; a not exporting of commodities.","pos":""}],"NONEXTENSILE":[{"def":"Not extensile; incapable of being stretched.","pos":""}]}