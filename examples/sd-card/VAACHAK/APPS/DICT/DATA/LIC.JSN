{"LICENSABLE":[{"def":"That can be licensed.","pos":""}],"LICENSE":[{"def":"The document granting such permission.","pos":""}],"LICENSED":[{"def":"Having a license; permitted or authorized by license; as, a licensed victualer; a licensed traffic.","pos":""}],"LICENSEE":[{"def":"The person to whom a license is given.","pos":""}],"LICENSER":[{"def":"One who gives a license; as, a licenser of the press.","pos":""}],"LICENTIATE":[{"def":"One who has a license to exercise a profession; as, a licentiate in medicine or theology.","pos":""},{"def":"A friar authorized to receive confessions and grant absolution in all places, independently of the local clergy.","pos":""}],"LICENTIOUS":[{"def":"Characterized by license; passing due bounds; excessive; abusive of freedom; wantonly offensive; as, a licentious press.","pos":""},{"def":"Unrestrained by law or morality; lawless; immoral; dissolute; lewd; lascivious; as, a licentious man; a licentious life.","pos":""}],"LICH":[{"def":"A dead body; a corpse.","pos":""}],"LICHEN":[{"def":"One of a class of cellular, flowerless plants, (technically called Lichenes), having no distinction of leaf and stem, usually of scaly, expanded, frond-like forms, but sometimes erect or pendulous and variously branched.","pos":""},{"def":"A name given to several varieties of skin disease, esp.","pos":""}],"LICHENED":[{"def":"Belonging to, or covered with, lichens.","pos":""}],"LICHENIC":[{"def":"Of, pertaining to, or obtained from, lichens.","pos":""}],"LICHENIFORM":[{"def":"Having the form of a lichen.","pos":""}],"LICHENIN":[{"def":"A substance isomeric with starch, extracted from several species of moss and lichen, esp.","pos":""},{"def":"Of or pertaining to lichenography.","pos":""}],"LICHENOGRAPHIST":[{"def":"One who describes lichens; one versed in lichenography.","pos":""}],"LICHENOGRAPHY":[{"def":"A description of lichens; the science which illustrates the natural history of lichens.","pos":""}],"LICHENOLOGIST":[{"def":"One versed in lichenology.","pos":""}],"LICHENOLOGY":[{"def":"The science which treats of lichens.","pos":""}],"LICHENOUS":[{"def":"Of, pertaining to, or resembling, lichens; abounding in lichens; covered with lichens.","pos":""}],"LICHWORT":[{"def":"An herb, the wall pellitory.","pos":""}],"LICITATION":[{"def":"The act of offering for sale to the highest bidder.","pos":""}],"LICK":[{"def":"To draw or pass the tongue over; as, a dog licks his master's hand.","pos":""},{"def":"To lap; to take in with the tongue; as, a dog or cat licks milk.","pos":""}],"LICK-SPITTLE":[{"def":"An abject flatterer or parasite.","pos":""}],"LICKER":[{"def":"One who, or that which, licks.","pos":""}],"LICKERISH":[{"def":"Eager; craving; urged by desire; eager to taste or enjoy; greedy.","pos":""},{"def":"Tempting the appetite; dainty.","pos":""}],"LICKEROUS":[{"def":"Lickerish; eager; lustful.","pos":""}],"LICKING":[{"def":"A lapping with the tongue.","pos":""},{"def":"A flogging or castigation.","pos":""}],"LICKPENNY":[{"def":"A devourer or absorber of money.","pos":""}],"LICORICE":[{"def":"A plant of the genus Glycyrrhiza (G.","pos":""}],"LICTOR":[{"def":"An officer who bore an ax and fasces or rods, as ensigns of his office.","pos":""}]}