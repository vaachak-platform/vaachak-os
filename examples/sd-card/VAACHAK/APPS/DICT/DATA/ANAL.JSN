{"ANAL":[{"def":"Pertaining to, or situated near, the anus; as, the anal fin or glands.","pos":""}],"ANALCIME":[{"def":"A white or flesh-red mineral, of the zeolite, occurring in isometric crystals.","pos":""}],"ANALECTIC":[{"def":"Relating to analects; made up of selections; as, an analectic magazine.","pos":""},{"def":"A collection of literary fragments.","pos":""}],"ANALEMMA":[{"def":"An orthographic projection of the sphere on the plane of the meridian, the eye being supposed at an infinite distance, and in the east or west point of the horizon.","pos":""}],"ANALEPTIC":[{"def":"Restorative; giving strength after disease.","pos":""}],"ANALGESIA":[{"def":"Absence of sensibility to pain.","pos":""}],"ANALLAGMATIC":[{"def":"Not changed in form by inversion.","pos":""}],"ANALLANTOIC":[{"def":"Without, or not developing, an allantois.","pos":""}],"ANALLANTOIDEA":[{"def":"The division of Vertebrata in which no allantois is developed.","pos":""}],"ANALOGIC":[{"def":"Of or belonging to analogy.","pos":""}],"ANALOGICAL":[{"def":"Founded on, or of the nature of, analogy; expressing or implying analogy.","pos":""},{"def":"Having analogy; analogous.","pos":""}],"ANALOGICALLY":[{"def":"In an analogical sense; in accordance with analogy; by way of similitude.","pos":""}],"ANALOGICALNESS":[{"def":"Quality of being analogical.","pos":""}],"ANALOGISM":[{"def":"an argument from the cause to the effect; an a priori argument.","pos":""}],"ANALOGIST":[{"def":"One who reasons from analogy, or represent, by analogy.","pos":""}],"ANALOGIZE":[{"def":"To employ, or reason by, analogy.","pos":""}],"ANALOGOUS":[{"def":"Having analogy; corresponding to something else; bearing some resemblance or proportion; -- often followed by to.","pos":""}],"ANALOGUE":[{"def":"A word in one language corresponding with one in another; an analogous term; as, the Latin \"pater\" is the analogue of the English \"father.","pos":""}],"ANALOGY":[{"def":"A relation or correspondence in function, between organs or parts which are decidedly different.","pos":""},{"def":"Proportion; equality of ratios.","pos":""}],"ANALYSIS":[{"def":"The separation of a compound substance, by chemical processes, into its constituents, with a view to ascertain either (a) what elements it contains, or (b) how much of each element is present.","pos":""},{"def":"The tracing of things to their source, and the resolving of knowledge into its original principles.","pos":""}],"ANALYST":[{"def":"One who analyzes; formerly, one skilled in algebraical geometry; now commonly, one skilled in chemical analysis.","pos":""},{"def":"Of or pertaining to analysis; resolving into elements or constituent parts; as, an analytical experiment; analytic reasoning; -- opposed to synthetic.","pos":""}],"ANALYTICALLY":[{"def":"In an analytical manner.","pos":""}],"ANALYTICS":[{"def":"The science of analysis.","pos":""}],"ANALYZABLE":[{"def":"That may be analyzed.","pos":""}],"ANALYZATION":[{"def":"The act of analyzing, or separating into constituent parts; analysis.","pos":""}],"ANALYZE":[{"def":"No one, I presume, can analyze the sensations of pleasure or pain.","pos":""}],"ANALYZER":[{"def":"The part of a polariscope which receives the light after polarization, and exhibits its properties.","pos":""}]}