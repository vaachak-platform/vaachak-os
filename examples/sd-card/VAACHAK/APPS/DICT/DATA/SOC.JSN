{"SOC":[{"def":"An exclusive privilege formerly claimed by millers of grrinding all the corn used within the manor or township which the mill stands.","pos":""}],"SOCAGE":[{"def":"A tenure of lands and tenements by a certain or determinate service; a tenure distinct from chivalry or knight's service, in which the obligations were uncertain.","pos":"noun"}],"SOCAGER":[{"def":"A tennant by socage; a socman.","pos":""}],"SOCIABILITY":[{"def":"The quality of being sociable; sociableness.","pos":"noun"}],"SOCIABLE":[{"def":"Capable of being, or fit to be, united in one body or company; associable.","pos":""},{"def":"Inclined to, or adapted for, society; ready to unite with others; fond of companions; social.","pos":""}],"SOCIABLENESS":[{"def":"The quality of being sociable.","pos":""}],"SOCIABLY":[{"def":"In a sociable manner.","pos":""}],"SOCIAL":[{"def":"Naturally growing in groups or masses; -- said of many individual plants of the same species.","pos":""}],"SOCIALISM":[{"def":"A theory or system of social reform which contemplates a complete reconstruction of society, with a more just and equitable distribution of property and labor.","pos":""}],"SOCIALIST":[{"def":"One who advocates or practices the doctrines of socialism.","pos":""},{"def":"Pertaining to, or of the nature of, socialism.","pos":""}],"SOCIALITY":[{"def":"The quality of being social; socialness.","pos":""}],"SOCIALIZE":[{"def":"To render social.","pos":""},{"def":"To subject to, or regulate by, socialism.","pos":""}],"SOCIALLY":[{"def":"In a social manner; sociably.","pos":""}],"SOCIALNESS":[{"def":"The quality or state of being social.","pos":""}],"SOCIETARIAN":[{"def":"Of or pertaining to society; social.","pos":""}],"SOCIETY":[{"def":"The relationship of men to one another when associated in any way; companionship; fellowship; company.","pos":""},{"def":"Connection; participation; partnership.","pos":""}],"SOCINIAN":[{"def":"Of or pertaining to Socinus, or the Socinians.","pos":""}],"SOCINIANISM":[{"def":"The tenets or doctrines of Faustus Socinus, an Italian theologian of the sixteenth century, who denied the Trinity, the deity of Christ, the personality of the Devil, the native and total depravity of man, the vicarious atonement, and the eternity of future punishment.","pos":""}],"SOCINIANIZE":[{"def":"To cause to conform to Socinianism; to regulate by, or imbue with, the principles of Socinianism.","pos":""},{"def":"Of or pertaining to sociology, or social science.","pos":""}],"SOCIOLOGIST":[{"def":"One who treats of, or devotes himself to, the study of sociology.","pos":""}],"SOCIOLOGY":[{"def":"That branch of philosophy which treats of the constitution, phenomena, and development of human society; social science.","pos":""}],"SOCK":[{"def":"The shoe worn by actors of comedy in ancient Greece and Rome, -- used as a sumbol of comedy, of the comic drams, as distinguished from tragedy, which is symbolized by the buskin.","pos":""},{"def":"A knit or woven covering for the foot and lower leg; a stocking with a short leg.","pos":""}],"SOCKDOLAGER":[{"def":"A combination of two hooks which close upon each other, by means of a spring, as soon as the fish bites.","pos":""}],"SOCKET":[{"def":"An opening into which anything is fitted; any hollow thing or place which receives and holds something else; as, the sockets of the teeth.","pos":""},{"def":"Especially, the hollow tube or place in which a candle is fixed in the candlestick.","pos":""}],"SOCKETED":[{"def":"Having a socket.","pos":""}],"SOCKLESS":[{"def":"Destitute of socks or shoes.","pos":""}],"SOCMAN":[{"def":"One who holds lands or tenements by socage; a socager.","pos":""}],"SOCMANRY":[{"def":"Tenure by socage.","pos":""}],"SOCOME":[{"def":"A custom of tenants to grind corn at the lord's mill.","pos":""}],"SOCOTRINE":[{"def":"Of or pertaining to Socotra, an island in the Indian Ocean, on the east coast of Africa.","pos":""},{"def":"A native or inhabitant of Socotra.","pos":""}],"SOCRATICALLY":[{"def":"In the Socratic method.","pos":""}],"SOCRATISM":[{"def":"The philosophy or the method of Socrates.","pos":""}],"SOCRATIST":[{"def":"A disciple or follower of Socrates.","pos":""}]}