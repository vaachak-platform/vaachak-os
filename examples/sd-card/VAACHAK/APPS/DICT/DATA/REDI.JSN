{"REDIA":[{"def":"A kind of larva, or nurse, which is prroduced within the sporocyst of certain trematodes by asexual generation.","pos":""}],"REDIENT":[{"def":"Re\"di*ent (r\"d-ent), a.","pos":""}],"REDIF":[{"def":"A reserve force in the Turkish army, or a soldier of the reserve.","pos":""}],"REDIGEST":[{"def":"To digest, or reduce to form, a second time.","pos":""}],"REDIMINISH":[{"def":"To diminish again.","pos":""}],"REDINGOTE":[{"def":"A long plain double-breasted outside coat for women.","pos":""}],"REDINTEGRATE":[{"def":"Restored to wholeness or a perfect state; renewed.","pos":""}],"REDINTEGRATION":[{"def":"Restoration of a mixed body or matter to its former nature and state.","pos":""},{"def":"The law that objects which have been previously combined as part of a single mental state tend to recall or suggest one another; -- adopted by many philosophers to explain the phenomena of the association of ideas.","pos":""}],"REDIRECT":[{"def":"Applied to the examination of a witness, by the party calling him, after the cross-examination.","pos":""}],"REDISBURSE":[{"def":"To disburse anew; to give, or pay, back.","pos":""}],"REDISCOVER":[{"def":"To discover again.","pos":""}],"REDISPOSE":[{"def":"To dispose anew or again; to readjust; to rearrange.","pos":""}],"REDISSEIZE":[{"def":"To disseize anew, or a second time.","pos":""}],"REDISSEIZIN":[{"def":"A disseizin by one who once before was adjudged to have dassezed the same person of the same lands, etc.","pos":""}],"REDISSEIZOR":[{"def":"One who redisseizes.","pos":""}],"REDISSOLVE":[{"def":"To dissolve again.","pos":""}],"REDISTILL":[{"def":"To distill again.","pos":""}],"REDISTRAINER":[{"def":"One who distrains again.","pos":""}],"REDISTRIBUTE":[{"def":"To distribute again.","pos":""}],"REDISTRICT":[{"def":"To divide into new districts.","pos":""}],"REDITION":[{"def":"Act of returning; return.","pos":""}],"REDIVIDE":[{"def":"Re`di*vide\" (r`d*vd\"), v.","pos":""}],"REDIVIVUS":[{"def":"Living again; revived; restored.","pos":""}]}