{"QUID":[{"def":"A portion suitable to be chewed; a cud; as, a quid of tobacco.","pos":""}],"QUIDAM":[{"def":"Somebody; one unknown.","pos":""}],"QUIDDANY":[{"def":"A confection of quinces, in consistency between a sirup and marmalade.","pos":""}],"QUIDDATIVE":[{"def":"Constituting, or containing, the essence of a thing; quidditative.","pos":""}],"QUIDDIT":[{"def":"A subtilty; an equivocation.","pos":""}],"QUIDDITY":[{"def":"The essence, nature, or distinctive peculiarity, of a thing; that which answers the question, Quid est or, What is it \" The degree of nullity and quiddity.","pos":""},{"def":"A trifling nicety; a cavil; a quibble.","pos":""}],"QUIDDLE":[{"def":"To spend time in trifling employments, or to attend to useful subjects in an indifferent or superficial manner; to dawdle.","pos":""},{"def":"One who wastes his energy about trifles.","pos":""}],"QUIDNUNC":[{"def":"One who is curious to know everything that passes; one who knows, or pretends to know, all that is going on.","pos":""}]}