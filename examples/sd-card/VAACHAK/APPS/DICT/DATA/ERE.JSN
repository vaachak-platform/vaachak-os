{"ERE":[{"def":"Before; sooner than.","pos":""}],"EREBUS":[{"def":"A place of nether darkness, being the gloomy space through which the souls passed to Hades.","pos":""},{"def":"The son of Chaos and brother of Nox, who dwelt in Erebus.","pos":""}],"ERECT":[{"def":"Standing upright, with reference to the earth's surface, or to the surface to which it is attached.","pos":""},{"def":"Elevated, as the tips of wings, heads of serpents, etc.","pos":""}],"ERECTABLE":[{"def":"Capable of being erected; as, an erectable feather.","pos":""}],"ERECTER":[{"def":"An erector; one who raises or builds.","pos":""}],"ERECTILE":[{"def":"Capable of being erected; susceptible of being erected of dilated.","pos":""}],"ERECTILITY":[{"def":"The quality or state of being erectile.","pos":""}],"ERECTION":[{"def":"The state of a part which, from having been soft, has become hard and swollen by the accumulation of blood in the erectile tissue.","pos":""}],"ERECTIVE":[{"def":"Making erect or upright; raising; tending to erect.","pos":""}],"ERECTLY":[{"def":"In an erect manner or posture.","pos":""}],"ERECTNESS":[{"def":"Uprightness of posture or form.","pos":""}],"ERECTO-PATENT":[{"def":"Having a position intermediate between erect and patent, or spreading.","pos":""},{"def":"Standing partially spread and erect; -- said of the wings of certain insects.","pos":""}],"ERECTOR":[{"def":"A muscle which raises any part.","pos":""},{"def":"An attachment to a microscope, telescope, or other optical instrument, for making the image erect instead of inverted.","pos":""}],"ERELONG":[{"def":"Before the ere long.","pos":""}],"EREMACAUSIS":[{"def":"A gradual oxidation from exposure to air and moisture, as in the decay of old trees or of dead animals.","pos":""}],"EREMITE":[{"def":"Of or pertaining to an eremite; hermitical; living in solitude.","pos":""}],"EREMITISM":[{"def":"The state of a hermit; a living in seclusion from social life.","pos":""}],"EREPTATION":[{"def":"A creeping forth.","pos":""}],"EREPTION":[{"def":"A snatching away.","pos":""}],"ERETHISM":[{"def":"A morbid degree of excitement or irritation in an organ.","pos":""}],"ERETHISTIC":[{"def":"Relating to erethism.","pos":""},{"def":"Some time ago; a little while before; heretofore.","pos":""}]}