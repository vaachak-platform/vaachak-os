{"PEROFSKITE":[{"def":"A titanate of lime occurring in octahedral or cubic crystals.","pos":""}],"PERONATE":[{"def":"A term applied to the stipes or stalks of certain fungi which are covered with a woolly substance which at length becomes powdery.","pos":""}],"PERONEAL":[{"def":"Of or pertaining to the fibula; in the region of the fibula.","pos":""}],"PERORATE":[{"def":"To make a peroration; to harangue.","pos":""}],"PERORATION":[{"def":"The concluding part of an oration; especially, a final summing up and enforcement of an argument.","pos":""}],"PEROXIDATION":[{"def":"Act, process, or result of peroxidizing; oxidation to a peroxide.","pos":""}],"PEROXIDE":[{"def":"An oxide containing more oxygen than some other oxide of the same element.","pos":""}],"PEROXIDIZE":[{"def":"To oxidize to the utmost degree, so as to form a peroxide.","pos":""}]}