{"PEND":[{"def":"Oil cake; penock.","pos":""}],"PENDANT":[{"def":"A hanging ornament on roofs, ceilings, etc.","pos":""},{"def":"One of a pair; a counterpart; as, one vase is the pendant to the other vase.","pos":""}],"PENDENCE":[{"def":"Slope; inclination.","pos":""}],"PENDENCY":[{"def":"The quality or state of being pendent or suspended.","pos":""},{"def":"The quality or state of being undecided, or in continuance; suspense; as, the pendency of a suit.","pos":""}],"PENDENT":[{"def":"Supported from above; suspended; depending; pendulous; hanging; as, a pendent leaf.","pos":""},{"def":"Jutting over; projecting; overhanging.","pos":""}],"PENDENTLY":[{"def":"In a pendent manner.","pos":""}],"PENDICE":[{"def":"A sloping roof; a lean-to; a penthouse.","pos":""}],"PENDICLE":[{"def":"An appendage; something dependent on another; an appurtenance; a pendant.","pos":""}],"PENDICLER":[{"def":"An inferior tenant; one who rents a pendicle or croft.","pos":""}],"PENDING":[{"def":"Not yet decided; in continuance; in suspense; as, a pending suit.","pos":""}],"PENDRAGON":[{"def":"A chief leader or a king; a head; a dictator; -- a title assumed by the ancient British chiefs when called to lead other chiefs.","pos":""}],"PENDULATE":[{"def":"To swing as a pendulum.","pos":""}],"PENDULINE":[{"def":"A European titmouse (Parus, or Ægithalus, pendulinus).","pos":""}],"PENDULOSITY":[{"def":"The state or quality of being pendulous.","pos":""}],"PENDULOUS":[{"def":"Inclined or hanging downwards, as a flower on a recurved stalk, or an ovule which hangs from the upper part of the ovary.","pos":""}],"PENDULOUSLY":[{"def":"In a pendulous manner.","pos":""}],"PENDULOUSNESS":[{"def":"The quality or state of being pendulous; the state of hanging loosely; pendulosity.","pos":""}],"PENDULUM":[{"def":"A body so suspended from a fixed point as to swing freely to and fro by the alternate action of gravity and momentum.","pos":""}]}