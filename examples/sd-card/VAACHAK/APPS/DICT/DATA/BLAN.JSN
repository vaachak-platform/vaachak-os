{"BLANC":[{"def":"A white cosmetic.","pos":""},{"def":"A white sauce of fat, broth, and vegetables, used esp.","pos":""}],"BLANCARD":[{"def":"A kind of linen cloth made in Normandy, the thread of which is partly blanches before it is woven.","pos":""}],"BLANCH":[{"def":"To bleach by excluding the light, as the stalks or leaves of plants, by earthing them up or tying them together.","pos":""}],"BLANCH HOLDING":[{"def":"A mode of tenure by the payment of a small duty in white rent (silver) or otherwise.","pos":""}],"BLANCHARD LATHE":[{"def":"A kind of wood-turning lathe for making noncircular and irregular forms, as felloes, gun stocks, lasts, spokes, etc.","pos":""}],"BLANCHER":[{"def":"One who, or that which, blanches or whitens; esp.","pos":""}],"BLANCHIMETER":[{"def":"An instrument for measuring the bleaching power of chloride of lime and potash; a chlorometer.","pos":""}],"BLANCMANGE":[{"def":"A preparation for desserts, etc.","pos":""}],"BLANCMANGER":[{"def":"A sort of fricassee with white sauce, variously made of capon, fish, etc.","pos":""}],"BLAND":[{"def":"Mild; soft; gentle; smooth and soothing in manner; suave; as, a bland temper; bland persuasion; a bland sycophant.","pos":""},{"def":"Having soft and soothing qualities; not drastic or irritating; not stimulating; as, a bland oil; a bland diet.","pos":""}],"BLANDILOQUENCE":[{"def":"Mild, flattering speech.","pos":""},{"def":"Fair-spoken; flattering.","pos":""}],"BLANDISE":[{"def":"To blandish any one.","pos":""}],"BLANDISH":[{"def":"To flatter with kind words or affectionate actions; to caress; to cajole.","pos":""},{"def":"To make agreeable and enticing.","pos":""}],"BLANDISHER":[{"def":"One who uses blandishments.","pos":""}],"BLANDISHMENT":[{"def":"The act of blandishing; a word or act expressive of affection or kindness, and tending to win the heart; soft words and artful caresses; cajolery; allurement.","pos":""}],"BLANDLY":[{"def":"In a bland manner; mildly; suavely.","pos":""}],"BLANDNESS":[{"def":"The state or quality of being bland.","pos":""}],"BLANK":[{"def":"Of a white or pale color; without color.","pos":""},{"def":"Free from writing, printing, or marks; having an empty space to be filled in with some special writing; -- said of checks, official documents, etc.","pos":""}],"BLANKET":[{"def":"A piece of rubber, felt, or woolen cloth, used in the tympan to make it soft and elastic.","pos":""}],"BLANKET CLAUSE":[{"def":"A clause, as in a blanket mortgage or policy, that includes a group or class of things, rather than a number mentioned individually and having the burden, loss, or the like, apportioned among them.","pos":""}],"BLANKET STITCH":[{"def":"A buttonhole stitch worked wide apart on the edge of material, as blankets, too thick to hem.","pos":""}],"BLANKETING":[{"def":"One that covers a group or class of things or properties instead of one or more things mentioned individually, as where a mortgage secures various debts as a group, or subjects a group or class of different pieces of property to one general lien.","pos":""}],"BLANKLY":[{"def":"In a blank manner; without expression; vacuously; as, to stare blankly.","pos":""},{"def":"Directly; flatly; point blank.","pos":""}],"BLANKNESS":[{"def":"The state of being blank.","pos":""}],"BLANQUETTE":[{"def":"A white fricassee.","pos":""}],"BLANQUILLO":[{"def":"A large fish of Florida and the W.","pos":""}]}