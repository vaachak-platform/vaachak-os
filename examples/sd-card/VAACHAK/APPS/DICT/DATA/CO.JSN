{"CO-":[{"def":"A form of the prefix com-, signifying with, together, in conjunction, joint.","pos":""}],"CO-ASSESSOR":[{"def":"A joint assessor.","pos":""}],"CO-LEGATEE":[{"def":"A joint legatee.","pos":""}],"CO-LESSEE":[{"def":"A partner in a lease taen.","pos":""}],"CO-LESSOR":[{"def":"A partner in giving a lease.","pos":""}],"CO-MEDDLE":[{"def":"To mix; to mingle, to temper.","pos":""}],"CO-REGENT":[{"def":"A joint regent or ruler.","pos":""}],"CO-RELATION":[{"def":"Corresponding relation.","pos":""}],"CO-RELIGIONIST":[{"def":"One of the same religion with another.","pos":""}],"CO-RESPONDENT":[{"def":"One who is called upon to answer a summons or other proceeding jointly with another.","pos":""}],"CO-SUFFERER":[{"def":"One who suffers with another.","pos":""}],"CO-UNE":[{"def":"To combine or unite.","pos":""}],"CO-UNITE":[{"def":"Co`-u*nite\" (k`-nt\"), v.","pos":""}]}