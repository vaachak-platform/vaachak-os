{"DOP":[{"def":"A dip; a low courtesy.","pos":""}],"DOPE":[{"def":"Any thick liquid or pasty preparation, as of opium for medicinal purposes, of grease for a lubricant, etc.","pos":""},{"def":"Any preparation, as of opium, used to stupefy or, in the case of a race horse, to stimulate.","pos":""}],"DOPE-BOOK":[{"def":"A chart of previous performances, etc.","pos":""}],"DOPEY":[{"def":"Affected by \"dope\"; esp.","pos":""}],"DOPPELGANGER":[{"def":"A spiritual or ghostly double or counterpart; esp.","pos":""}],"DOPPER":[{"def":"An Anabaptist or Baptist.","pos":""}],"DOPPLERITE":[{"def":"A brownish black native hydrocarbon occurring in elastic or jellylike masses.","pos":""}]}