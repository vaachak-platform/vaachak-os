{"UNBACKED":[{"def":"Never mounted by a rider; unbroken.","pos":""},{"def":"Not supported or encouraged; not countenanced; unaided.","pos":""}],"UNBAG":[{"def":"To pour, or take, or let go, out of a bag or bags.","pos":""}],"UNBALANCED":[{"def":"Not adjusted; not settled; not brought to an equality of debt and credit; as, an unbalanced account; unbalanced books.","pos":""}],"UNBALLAST":[{"def":"To free from ballast; to discharge ballast from.","pos":""}],"UNBALLASTED":[{"def":"Freed from ballast; having discharged ballast.","pos":""},{"def":"Not furnished with ballast; not kept steady by ballast; unsteady; as, unballasted vessels; unballasted wits.","pos":""}],"UNBANED":[{"def":"Wanting a band or string; unfastened.","pos":""}],"UNBANK":[{"def":"To remove a bank from; to open by, or as if by, the removal of a bank.","pos":""}],"UNBAR":[{"def":"To remove a bar or bars from; to unbolt; to open; as, to unbar a gate.","pos":""}],"UNBARBED":[{"def":"Destitute of bards, or of reversed points, hairs, or plumes; as, an unbarded feather.","pos":""}],"UNBARK":[{"def":"To deprive of the bark; to decorticate; to strip; as, to unbark a tree.","pos":""}],"UNBARREL":[{"def":"To remove or release from a barrel or barrels.","pos":""}],"UNBARRICADE":[{"def":"To unbolt; to unbar; to open.","pos":""}],"UNBARRICADOED":[{"def":"Not obstructed by barricades; open; as, unbarricadoed streets.","pos":""}],"UNBASHFUL":[{"def":"Not bashful or modest; bold; impudent; shameless.","pos":""}],"UNBAY":[{"def":"To free from the restraint of anything that surrounds or incloses; to let loose; to open.","pos":""}],"UNBE":[{"def":"To cause not to be; to cause to be another.","pos":""}],"UNBEAR":[{"def":"To remove or loose the bearing rein of (a horse).","pos":""}],"UNBEAT":[{"def":"To deliver from the form or nature of a beast.","pos":""}],"UNBECOMING":[{"def":"Not becoming; unsuitable; unfit; indecorous; improper.","pos":""}],"UNBED":[{"def":"To raise or rouse from bed.","pos":""}],"UNBEDINNED":[{"def":"Not filled with din.","pos":""}],"UNBEFOOL":[{"def":"To deliver from the state of a fool; to awaken the mind of; to undeceive.","pos":""}],"UNBEGET":[{"def":"To deprive of existence.","pos":""}],"UNBEGILT":[{"def":"Not gilded; hence, not rewarded with gold.","pos":""},{"def":"Not begot; not yet generated; also, having never been generated; self-existent; eternal.","pos":""}],"UNBEGUILE":[{"def":"To set free from the influence of guile; to undeceive.","pos":""}],"UNBEGUN":[{"def":"Not yet begun; also, existing without a beginning.","pos":""}],"UNBEHOVELY":[{"def":"Not behooving or becoming; unseemly.","pos":""}],"UNBEKNOWN":[{"def":"Not known; unknown.","pos":""}],"UNBELIEF":[{"def":"The withholding of belief; doubt; incredulity; skepticism.","pos":""},{"def":"Disbelief; especially, disbelief of divine revelation, or in a divine providence or scheme of redemption.","pos":""}],"UNBELIEVED":[{"def":"Not believed; disbelieved.","pos":""}],"UNBELIEVER":[{"def":"One who does not believe; an incredulous person; a doubter; a skeptic.","pos":""},{"def":"A disbeliever; especially, one who does not believe that the Bible is a divine revelation, and holds that Christ was neither a divine nor a supernatural person; an infidel; a freethinker.","pos":""}],"UNBELIEVING":[{"def":"Not believing; incredulous; doubting; distrusting; skeptical.","pos":""},{"def":"Believing the thing alleged no to be true; disbelieving; especially, believing that Bible is not a divine revelation, or that Christ was not a divine or a supernatural person.","pos":""}],"UNBELT":[{"def":"To remove or loose the belt of; to ungird.","pos":""}],"UNBEND":[{"def":"To free from flexure; to make, or allow to become, straight; to loosen; as, to unbend a bow.","pos":""},{"def":"A remit from a strain or from exertion; to set at ease for a time; to relax; as, to unbend the mind from study or care.","pos":""}],"UNBENDING":[{"def":"Not bending; not suffering flexure; not yielding to pressure; stiff; -- applied to material things.","pos":""},{"def":"Unyielding in will; not subject to persuasion or influence; inflexible; resolute; -- applied to persons.","pos":""}],"UNBENEVOLENCE":[{"def":"Absence or want of benevolence; ill will.","pos":""}],"UNBENIGN":[{"def":"Not benign; malignant.","pos":""}],"UNBENUMB":[{"def":"To relieve of numbness; to restore sensation to.","pos":""}],"UNBEREFT":[{"def":"Not bereft; not taken away.","pos":""}],"UNBESEEM":[{"def":"To be unbecoming or unsuitable to; to misbecome.","pos":""}],"UNBESEEMING":[{"def":"Unbecoming; not befitting.","pos":""}],"UNBESPEAK":[{"def":"To unsay; hence, to annul or cancel.","pos":""}],"UNBETHINK":[{"def":"To change the mind of (one's self).","pos":""}],"UNBEWITCH":[{"def":"To free from a spell; to disenchant.","pos":""}],"UNBIAS":[{"def":"To free from bias or prejudice.","pos":""}],"UNBIASED":[{"def":"Free from bias or prejudice; unprejudiced; impartial.","pos":""}],"UNBIND":[{"def":"To remove a band from; to set free from shackles or fastenings; to unite; to unfasten; to loose; as, unbind your fillets; to unbind a prisoner's arms; to unbind a load.","pos":""}],"UNBISHOP":[{"def":"To deprive, as a city, of a bishop; to deprive, as a clergyman, of episcopal dignity or rights.","pos":""}],"UNBIT":[{"def":"To remove the turns of (a rope or cable) from the bits; as, to unbit a cable.","pos":""}],"UNBLEMISHED":[{"def":"Not blemished; pure; spotless; as, an unblemished reputation or life.","pos":""}],"UNBLESS":[{"def":"To deprive of blessings; to make wretched.","pos":""},{"def":"Not blest; excluded from benediction; hence, accursed; wretched.","pos":""}],"UNBLIND":[{"def":"To free from blindness; to give or restore sight to; to open the eyes of.","pos":""}],"UNBLINDFOLD":[{"def":"To free from that which blindfolds.","pos":""}],"UNBLUSHING":[{"def":"Not blushing; shameless.","pos":""}],"UNBODY":[{"def":"To free from the body; to disembody.","pos":""}],"UNBOLT":[{"def":"To remove a bolt from; to unfasten; to unbar; to open.","pos":""}],"UNBONE":[{"def":"To deprive of bones, as meat; to bone.","pos":""},{"def":"To twist about, as if boneless.","pos":""}],"UNBONNET":[{"def":"To take a bonnet from; to take off one's bonnet; to uncover; as, to unbonnet one's head.","pos":""}],"UNBOOKED":[{"def":"Not written in a book; unrecorded.","pos":""}],"UNBOOT":[{"def":"To take off the boots from.","pos":""}],"UNBORN":[{"def":"Not born; no yet brought into life; being still to appear; future.","pos":""}],"UNBORROWED":[{"def":"Not borrowed; being one's own; native; original.","pos":""}],"UNBOSOM":[{"def":"To disclose freely; to reveal in confidence, as secrets; to confess; -- often used reflexively; as, to unbosom one's self.","pos":""}],"UNBOSOMER":[{"def":"One who unbosoms, or discloses.","pos":""}],"UNBOTTOMED":[{"def":"Deprived of a bottom.","pos":""},{"def":"Having no bottom; bottomless.","pos":""}],"UNBOUND":[{"def":"Un*bound\", Defn: imp.","pos":""}],"UNBOUNDED":[{"def":"Having no bound or limit; as, unbounded space; an, unbounded ambition.","pos":""}],"UNBOWED":[{"def":"Not bent or arched; not bowed down.","pos":""}],"UNBOWEL":[{"def":"To deprive of the entrails; to disembowel.","pos":""}],"UNBOX":[{"def":"To remove from a box or boxes.","pos":""}],"UNBOY":[{"def":"To divest of the traits of a boy.","pos":""}],"UNBRACE":[{"def":"To free from tension; to relax; to loose; as, to unbrace a drum; to unbrace the nerves.","pos":""}],"UNBRAID":[{"def":"To separate the strands of; to undo, as a braid; to unravel; to disentangle.","pos":""}],"UNBREAST":[{"def":"To disclose, or lay open; to unbosom.","pos":""}],"UNBREATHED":[{"def":"Not exercised; unpracticed.","pos":""}],"UNBRED":[{"def":"Not begotten; unborn.","pos":""},{"def":"Not taught or trained; -- with to.","pos":""}],"UNBREECH":[{"def":"To free the breech of, as a cannon, from its fastenings or coverings.","pos":""}],"UNBREWED":[{"def":"Not made by brewing; unmixed; pure; genuine.","pos":""}],"UNBRIDLE":[{"def":"To free from the bridle; to set loose.","pos":""}],"UNBRIDLED":[{"def":"Loosed from the bridle, or as from the bridle; hence, unrestrained; licentious; violent; as, unbridled passions.","pos":""}],"UNBROKEN":[{"def":"Not broken; continuous; unsubdued; as, an unbroken colt.","pos":""}],"UNBUCKLE":[{"def":"To loose the buckles of; to unfasten; as, to unbuckle a shoe.","pos":""}],"UNBUILD":[{"def":"To demolish; to raze.","pos":""}],"UNBUNDLE":[{"def":"To release, as from a bundle; to disclose.","pos":""}],"UNBUNG":[{"def":"To remove the bung from; as, to unbung a cask.","pos":""}],"UNBURDEN":[{"def":"To relieve from a burden.","pos":""},{"def":"To throw off, as a burden; to unload.","pos":""}],"UNBURIABLE":[{"def":"Not ready or not proper to be buried.","pos":""}],"UNBURROW":[{"def":"To force from a burrow; to unearth.","pos":""}],"UNBURTHEN":[{"def":"To unburden; to unload.","pos":""}],"UNBURY":[{"def":"To disinter; to exhume; fig.","pos":""}],"UNBUSIED":[{"def":"Not required to work; unemployed; not busy.","pos":""}],"UNBUTTON":[{"def":"To loose the buttons of; to unfasten.","pos":""}]}