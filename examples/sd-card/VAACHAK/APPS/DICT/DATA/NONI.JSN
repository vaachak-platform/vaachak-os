{"NONILLION":[{"def":"According to the French and American notation, a thousand octillions, or a unit with thirty ciphers annexed; according to the English notation, a million octillions, or a unit with fifty-four ciphers annexed.","pos":""}],"NONIMPORTATION":[{"def":"Want or failure of importation; a not importing of commodities.","pos":""}],"NONIMPORTING":[{"def":"Not importing; not bringing from foreign countries.","pos":""}],"NONINFLECTIONAL":[{"def":"Not admitting of, or characterized by, inflection.","pos":""}],"NONINHABITANT":[{"def":"One who is not an inhabitant; a stranger; a foreigner; a nonresident.","pos":""}],"NONINTERVENTION":[{"def":"The state or habit of not intervening or interfering; as, the nonintervention of one state in the affairs of another.","pos":""}]}