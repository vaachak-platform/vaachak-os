{"MUG":[{"def":"A kind of earthen or metal drinking cup, with a handle, -- usually cylindrical and without a lip.","pos":""},{"def":"The face or mouth.","pos":""}],"MUGGARD":[{"def":"Sullen; displeased.","pos":""},{"def":"The common crocodile (Crocodilus palustris) of India, the East Indies, etc.","pos":""}],"MUGGET":[{"def":"The small entrails of a calf or a hog.","pos":""}],"MUGGINESS":[{"def":"The condition or quality of being muggy.","pos":""}],"MUGGINS":[{"def":"A game of dominoes in which the object is to make the sum of the two ends of the line some multiple of five.","pos":""},{"def":"A game at cards which depends upon building in suits or matching exposed cards, the object being to get rid of one's cards.","pos":""}],"MUGGLETONIAN":[{"def":"One of an extinct sect, named after Ludovic Muggleton, an English journeyman tailor, who (about 1657) claimed to be inspired.","pos":""}],"MUGGY":[{"def":"Moist; damp; moldy; as, muggy straw.","pos":""},{"def":"Warm, damp, and close; as, muggy air, weather.","pos":""}],"MUGHOUSE":[{"def":"An alehouse; a pothouse.","pos":""}],"MUGIENT":[{"def":"Lowing; bellowing.","pos":""}],"MUGIL":[{"def":"A genus of fishes including the gray mullets.","pos":""}],"MUGILOID":[{"def":"Like or pertaining to the genus Mugil, or family Mugilidæ.","pos":""}],"MUGWEED":[{"def":"A slender European weed (Galium Cruciata); -- called also crossweed.","pos":""}],"MUGWORT":[{"def":"A somewhat aromatic composite weed (Artemisia vulgaris), at one time used medicinally; -- called also motherwort.","pos":""}],"MUGWUMP":[{"def":"A bolter from the Republican party in the national election of 1884; an Independent.","pos":""},{"def":"The acts and views of the mugwumps.","pos":""}]}