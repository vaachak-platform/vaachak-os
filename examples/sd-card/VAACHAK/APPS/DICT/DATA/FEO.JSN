{"FEODALITY":[{"def":"Feudal tenure; the feudal system.","pos":""}],"FEODARY":[{"def":"An ancient officer of the court of wards.","pos":""}],"FEOFF":[{"def":"To invest with a fee or feud; to give or grant a corporeal hereditament to; to enfeoff.","pos":""}],"FEOFFEE":[{"def":"The person to whom a feoffment is made; the person enfeoffed.","pos":""}],"FEOFFMENT":[{"def":"One who enfeoffs or grants a fee.","pos":""}]}