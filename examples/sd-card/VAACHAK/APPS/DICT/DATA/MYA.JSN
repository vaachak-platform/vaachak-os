{"MYA":[{"def":"A genus of bivalve mollusks, including the common long, or soft-shelled, clam.","pos":""}],"MYALGIA":[{"def":"Pain in the muscles; muscular rheumatism or neuralgia.","pos":""}],"MYALL WOOD":[{"def":"A durable, fragrant, and dark-colored Australian wood, used by the natives for spears.","pos":""}],"MYARIA":[{"def":"A division of bivalve mollusks of which the common clam (Mya) is the type.","pos":""}]}