{"FLAVANILINE":[{"def":"A yellow, crystalline, organic dyestuff, C16H14N2, of artifical production.","pos":""}],"FLAVESCENT":[{"def":"Turning yellow; yellowish.","pos":""}],"FLAVICOMOUS":[{"def":"Having yellow hair.","pos":""}],"FLAVIN":[{"def":"A yellow, vegetable dyestuff, resembling quercitron.","pos":""}],"FLAVINE":[{"def":"A yellow, crystalline, organic base, C13H12N2O, obtained artificially.","pos":""}],"FLAVOL":[{"def":"A yellow, crystalline substance, obtained from anthraquinone, and regarded as a hydroxyl derivative of it.","pos":""}],"FLAVOR":[{"def":"That quality of anything which affects the smell; odor; fragrances; as, the flavor of a rose.","pos":""},{"def":"That quality of anything which affects the taste; that quality which gratifies the palate; relish; zest; savor; as, the flavor of food or drink.","pos":""}],"FLAVORED":[{"def":"Having a distinct flavor; as, high-flavored wine.","pos":""}],"FLAVORLESS":[{"def":"Without flavor; tasteless.","pos":""}],"FLAVOROUS":[{"def":"Imparting flavor; pleasant to the taste or smell; sapid.","pos":""}]}