{"INCONCEALABLE":[{"def":"Not concealable.","pos":""}],"INCONCEIVABILITY":[{"def":"The quality of being inconceivable; inconceivableness.","pos":""}],"INCONCEIVABLE":[{"def":"Not conceivable; incapable of being conceived by the mind; not explicable by the human intellect, or by any known principles or agencies; incomprehensible; as, it is inconceivable to us how the will acts in producing muscular motion.","pos":""}],"INCONCERNING":[{"def":"Unimportant; trifling.","pos":""}],"INCONCINNE":[{"def":"Dissimilar; incongruous; unsuitable.","pos":""}],"INCONCINNITY":[{"def":"Want of concinnity or congruousness; unsuitableness.","pos":""}],"INCONCINNOUS":[{"def":"Not concinnous; unsuitable; discordant.","pos":""}],"INCONCLUDENT":[{"def":"Not inferring a conclusion or consequence; not conclusive.","pos":""}],"INCONCLUDING":[{"def":"Inferring no consequence.","pos":""}],"INCONCLUSIVE":[{"def":"Not conclusive; leading to no conclusion; not closing or settling a point in debate, or a doubtful question; as, evidence is inconclusive when it does not exhibit the truth of a disputed case in such a manner as to satisfy the mind, and put an end to debate or doubt.","pos":""}],"INCONCOCTED":[{"def":"Imperfectly digested, matured, or ripened.","pos":""}],"INCONCOCTION":[{"def":"The state of being undigested; unripeness; immaturity.","pos":""}],"INCONCURRING":[{"def":"Not concurring; disagreeing.","pos":""}],"INCONCUSSIBLE":[{"def":"Not concussible; that cannot be shaken.","pos":""},{"def":"The quality or state of being incondensable.","pos":""}],"INCONDITE":[{"def":"Badly put together; inartificial; rude; unpolished; irregular.","pos":""}],"INCONDITIONATE":[{"def":"Not conditioned; not limited; absolute.","pos":""}],"INCONFORMITY":[{"def":"Want of conformity; nonconformity.","pos":""}],"INCONFUSED":[{"def":"Not confused; distinct.","pos":""}],"INCONFUSION":[{"def":"Freedom from confusion; distinctness.","pos":""}],"INCONGEALABLE":[{"def":"Not congealable; incapable of being congealed.","pos":""}],"INCONGENIAL":[{"def":"Not congenial; uncongenial.","pos":""}],"INCONGRUENCE":[{"def":"Want of congruence; incongruity.","pos":""}],"INCONGRUITY":[{"def":"The quality or state of being incongruous; want of congruity; unsuitableness; inconsistency; impropriety.","pos":""},{"def":"Disagreement of parts; want of symmetry or of harmony.","pos":""}],"INCONGRUOUS":[{"def":"Not congruous; reciprocally disagreeing; not capable of harmonizing or readily assimilating; inharmonious; inappropriate; unsuitable; not fitting; inconsistent; improper; as, an incongruous remark; incongruous behavior, action, dress, etc.","pos":""}],"INCONNECTED":[{"def":"Not connected; disconnected.","pos":""}],"INCONNEXEDLY":[{"def":"Not connectedly; without connection.","pos":""}],"INCONSCIONABLE":[{"def":"In*con\"scion*a*ble, a.","pos":""}],"INCONSECUTIVENESS":[{"def":"The state or quality of not being consecutive.","pos":""}],"INCONSEQUENCE":[{"def":"The quality or state of being inconsequent; want of just or logical inference or argument; inconclusiveness.","pos":""}],"INCONSEQUENT":[{"def":"Not following from the premises; not regularly inferred; invalid; not characterized by logical method; illogical; arbitrary; inconsistent; of no consequence.","pos":""}],"INCONSEQUENTIAL":[{"def":"Not regularly following from the premises; hence, irrelevant; unimportant; of no consequence.","pos":""}],"INCONSEQUENTIALITY":[{"def":"The state of being inconsequential.","pos":""}],"INCONSEQUENTNESS":[{"def":"In*con\"se*quent*ness, n.","pos":""}],"INCONSIDERABLE":[{"def":"Not considerable; unworthy of consideration or notice; unimportant; small; trivial; as, an inconsiderable distance; an inconsiderable quantity, degree, value, or sum.","pos":""}],"INCONSIDERACY":[{"def":"Inconsiderateness; thoughtlessness.","pos":""}],"INCONSIDERATE":[{"def":"Not considerate; not attentive to safety or to propriety; not regarding the rights or feelings of others; hasty; careless; thoughtless; heedless; as, the young are generally inconsiderate; inconsiderate conduct.","pos":""}],"INCONSIDERATELY":[{"def":"In an inconsiderate manner.","pos":""}],"INCONSIDERATENESS":[{"def":"The quality or state of being inconsiderate.","pos":""}],"INCONSIDERATION":[{"def":"Want of due consideration; inattention to consequences; inconsiderateness.","pos":""}],"INCONSISTENCY":[{"def":"The quality or state of being inconsistent; discordance in respect to sentiment or action; such contrariety between two things that both can not exist or be true together; disagreement; incompatibility.","pos":""},{"def":"Absurdity in argument ore narration; incoherence or irreconcilability in the parts of a statement, argument, or narration; that which is inconsistent.","pos":""}],"INCONSISTENT":[{"def":"Not consistent; showing inconsistency; irreconcilable; discordant; at variance, esp.","pos":""},{"def":"Not exhibiting uniformity of sentiment, steadiness to principle, etc.","pos":""}],"INCONSISTENTLY":[{"def":"In an inconsistent manner.","pos":""}],"INCONSISTENTNESS":[{"def":"In`con*sist\"ent*ness, n.","pos":""}],"INCONSOLABLE":[{"def":"Not consolable; incapable of being consoled; grieved beyond susceptibility of comfort; disconsolate.","pos":""},{"def":"Want of consonance or harmony of sound, action, or thought; disagreement.","pos":""}],"INCONSONANT":[{"def":"Not consonant or agreeing; inconsistent; discordant.","pos":""}],"INCONSPICUOUS":[{"def":"Not conspicuous or noticeable; hardly discernible.","pos":""}],"INCONSTANCY":[{"def":"The quality or state of being inconstant; want of constancy; mutability; fickleness; variableness.","pos":""}],"INCONSTANT":[{"def":"Not constant; not stable or uniform; subject to change of character, appearance, opinion, inclination, or purpose, etc.","pos":""}],"INCONSTANTLY":[{"def":"In an inconstant manner.","pos":""}],"INCONSUMABLE":[{"def":"Not consumable; incapable of being consumed, wasted, or spent.","pos":""}],"INCONSUMMATE":[{"def":"Not consummated; not finished; incomplete.","pos":""}],"INCONSUMPTIBLE":[{"def":"In`con*sump\"ti*ble, a.","pos":""}],"INCONTAMINATE":[{"def":"Not contaminated; pure.","pos":""}],"INCONTENTATION":[{"def":"In*con`ten*ta\"tion, n.","pos":""}],"INCONTESTABILITY":[{"def":"The quality or state of being incontestable.","pos":""}],"INCONTESTABLE":[{"def":"Not contestable; not to be disputed; that cannot be called in question or controverted; incontrovertible; indisputable; as, incontestable evidence, truth, or facts.","pos":""}],"INCONTIGUOUS":[{"def":"Not contiguous; not adjoining or in contact; separate.","pos":""},{"def":"The inability of any of the animal organs to restrain the natural evacuations, so that the discharges are involuntary; as, incontinence of urine.","pos":""}],"INCONTINENT":[{"def":"Unable to restrain natural evacuations.","pos":""}],"INCONTINENTLY":[{"def":"In an incontinent manner; without restraint, or without due restraint; -- used esp.","pos":""},{"def":"Immediately; at once; forthwith.","pos":""}],"INCONTROLLABLE":[{"def":"Not controllable; uncontrollable.","pos":""}],"INCONTROVERTIBILITY":[{"def":"The state or condition of being incontrovertible.","pos":""}],"INCONTROVERTIBLE":[{"def":"Not controvertible; too clear or certain to admit of dispute; indisputable.","pos":""}],"INCONVENIENCE":[{"def":"The quality or condition of being inconvenient; want of convenience; unfitness; unsuitableness; inexpediency; awkwardness; as, the inconvenience of the arrangement.","pos":""},{"def":"That which gives trouble, embarrassment, or uneasiness; disadvantage; anything that disturbs quiet, impedes prosperity, or increases the difficulty of action or success; as, one inconvenience of life is poverty.","pos":""}],"INCONVENIENT":[{"def":"Not becoming or suitable; unfit; inexpedient.","pos":""},{"def":"Not convenient; giving trouble, uneasiness, or annoyance; hindering progress or success; uncomfortable; disadvantageous; incommodious; inopportune; as, an inconvenient house, garment, arrangement, or time.","pos":""}],"INCONVENIENTLY":[{"def":"In an inconvenient manner; incommodiously; unsuitably; unseasonably.","pos":""}],"INCONVERSABLE":[{"def":"Incommunicative; unsocial; reserved.","pos":""}],"INCONVERSANT":[{"def":"Not conversant; not acquainted; not versed; unfamiliar.","pos":""}],"INCONVERTED":[{"def":"Not turned or changed about.","pos":""}],"INCONVERTIBILITY":[{"def":"The quality or state of being inconvertible; not capable of being exchanged for, or converted into, something else; as, the inconvertibility of an irredeemable currency, or of lead, into gold.","pos":""}],"INCONVERTIBLE":[{"def":"Not convertible; not capable of being transmuted, changed into, or exchanged for, something else; as, one metal is inconvertible into another; bank notes are sometimes inconvertible into specie.","pos":""}],"INCONVERTIBLENESS":[{"def":"Inconvertibility.","pos":""}],"INCONVERTIBLY":[{"def":"In an inconvertible manner.","pos":""}],"INCONVINCIBLE":[{"def":"Not convincible; incapable of being convinced.","pos":""}],"INCONVINCIBLY":[{"def":"In a manner not admitting of being convinced.","pos":""}],"INCONY":[{"def":"Unlearned; artless; pretty; delicate.","pos":""}]}