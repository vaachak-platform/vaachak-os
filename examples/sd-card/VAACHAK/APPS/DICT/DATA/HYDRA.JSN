{"HYDRA":[{"def":"A serpent or monster in the lake or marsh of Lerna, in the Peloponnesus, represented as having many heads, one of which, when cut off, was immediately succeeded by two others, unless the wound was cauterized.","pos":""},{"def":"Any small fresh-water hydroid of the genus Hydra, usually found attached to sticks, stones, etc.","pos":""}],"HYDRA-TAINTED":[{"def":"Dipped in the gall of the fabulous hydra; poisonous; deadly.","pos":""}],"HYDRACHNID":[{"def":"An aquatic mite of the genus Hydrachna.","pos":""}],"HYDRACID":[{"def":"An acid containing hydrogen; -- sometimes applied to distinguish acids like hydrochloric, hydrofluoric, and the like, which contain no oxygen, from the oxygen acids or oxacids.","pos":""}],"HYDRACRYLIC":[{"def":"Pertaining to, or designating, an isomeric variety of lastic acid that breaks down into acrylic acid and water.","pos":""}],"HYDRACTINIAN":[{"def":"Any species or marine hydroids, of the genus Hydractinia and allied genera.","pos":""}],"HYDRAEMIA":[{"def":"An abnormally watery state of the blood; anæmia.","pos":""}],"HYDRAGOGUE":[{"def":"Causing a discharge of water; expelling serum effused into any part of the body, as in dropsy.","pos":""},{"def":"A hydragogue medicine, usually a cathartic or diuretic.","pos":""}],"HYDRAMIDE":[{"def":"One of a group of crystalline bodies produced by the action of ammonia on certain aldehydes.","pos":""}],"HYDRAMINE":[{"def":"One of a series of artificial, organic bases, usually produced as thick viscous liquids by the action of ammonia on ethylene oxide.","pos":""}],"HYDRANGEA":[{"def":"A genus of shrubby plants bearing opposite leaves and large heads of showy flowers, white, or of various colors.","pos":""}],"HYDRANT":[{"def":"A discharge pipe with a valve and spout at which water may be drawn from the mains of waterworks; a water plug.","pos":""}],"HYDRANTH":[{"def":"One of the nutritive zooids of a hydroid colony.","pos":""}],"HYDRARGOCHLORIDE":[{"def":"A compound of the bichloride of mercury with another chloride.","pos":""}],"HYDRARGYRATE":[{"def":"Of or pertaining to mercury; containing, or impregnated with, mercury.","pos":""}],"HYDRARGYRISM":[{"def":"A diseased condition produced by poisoning with hydrargyrum, or mercury; mercurialism.","pos":""}],"HYDRARGYRUM":[{"def":"Quicksilver; mercury.","pos":""}],"HYDRARTHROSIS":[{"def":"An effusion of watery liquid into the cavity of a joint.","pos":""}],"HYDRASTINE":[{"def":"An alkaloid, found in the rootstock of the golden seal (Hydrastis Canadensis), and extracted as a bitter, white, crystalline substance.","pos":""}],"HYDRATE":[{"def":"To form into a hydrate; to combine with water.","pos":""}],"HYDRATED":[{"def":"Formed into a hydrate; combined with water.","pos":""}],"HYDRATION":[{"def":"The act of becoming, or state of being, a hydrate.","pos":""}],"HYDRAULIC":[{"def":"Of or pertaining to hydraulics, or to fluids in motion; conveying, or acting by, water; as, an hydraulic clock, crane, or dock.","pos":""}],"HYDRAULICON":[{"def":"An ancient musical instrument played by the action of water; a water organ.","pos":""}],"HYDRAULICS":[{"def":"That branch of science, or of engineering, which treats of fluids in motion, especially of water, its action in rivers and canals, the works and machinery for conducting or raising it, its use as a prime mover, and the like.","pos":""}],"HYDRAZINE":[{"def":"Any one of a series of nitrogenous bases, resembling the amines and produced by the reduction of certain nitroso and diazo compounds; as, methyl hydrazine, phenyl hydrazine, etc.","pos":""}]}