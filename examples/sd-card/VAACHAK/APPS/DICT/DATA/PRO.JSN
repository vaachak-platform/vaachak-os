{"PRO":[{"def":"A Latin preposition signifying for, before, forth.","pos":""}],"PRO RATA":[{"def":"In proportion; proportionately; according to the share, interest, or liability of each.","pos":""}],"PRO THYALOSOMA":[{"def":"The investing portion, or spherical envelope, surrounding the eccentric germinal spot of the germinal vesicle.","pos":""}]}