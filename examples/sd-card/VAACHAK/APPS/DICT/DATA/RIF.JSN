{"RIFACIMENTO":[{"def":"A remaking or recasting; an adaptation, esp.","pos":""}],"RIFE":[{"def":"Prevailing; prevalent; abounding.","pos":""},{"def":"Having power; active; nimble.","pos":""}],"RIFFLE":[{"def":"A trough or sluice having cleats, grooves, or steps across the bottom for holding quicksilver and catching particles of gold when auriferous earth is washed; also, one of the cleats, grooves, or steps in such a trough.","pos":""}],"RIFFLER":[{"def":"A curved file used in carving wool and marble.","pos":""}],"RIFFRAFF":[{"def":"Sweepings; refuse; the lowest order of society.","pos":""}],"RIFLE":[{"def":"To seize and bear away by force; to snatch away; to carry off.","pos":""},{"def":"To strip; to rob; to pillage.","pos":""}],"RIFLEBIRD":[{"def":"Any one of several species of beautiful birds of Australia and New Guinea, of the genera Ptiloris and Craspidophora, allied to the paradise birds.","pos":""}],"RIFLEMAN":[{"def":"A soldier armed with a rifle.","pos":""}],"RIFLER":[{"def":"One who rifles; a robber.","pos":""}],"RIFT":[{"def":"An opening made by riving or splitting; a cleft; a fissure.","pos":""},{"def":"A shallow place in a stream; a ford.","pos":""}]}