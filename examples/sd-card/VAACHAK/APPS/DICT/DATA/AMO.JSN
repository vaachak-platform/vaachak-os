{"AMOEBAEUM":[{"def":"A poem in which persons are represented at speaking alternately; as the third and seventh eclogues of Virgil.","pos":""}],"AMOEBEA":[{"def":"That division of the Rhizopoda which includes the amoeba and similar forms.","pos":""}],"AMOEBEAN":[{"def":"Alternately answering.","pos":""}],"AMOEBIAN":[{"def":"One of the Amoebea.","pos":""},{"def":"Resembling an amoeba; amoeba-shaped; changing in shape like an amoeba.","pos":""}],"AMOEBOUS":[{"def":"Like an amoeba in structure.","pos":""}],"AMOLE":[{"def":"Any detergent plant, or the part of it used as a detergent, as the roots of Agave Americana, Chlorogalum pomeridianum, etc.","pos":""}],"AMOLITION":[{"def":"Removal; a putting away.","pos":""}],"AMOMUM":[{"def":"A genus of aromatic plants.","pos":""}],"AMONESTE":[{"def":"Mixed or mingled; surrounded by.","pos":""},{"def":"Conjoined, or associated with, or making part of the number of; in the number or class of.","pos":""}],"AMONTILLADO":[{"def":"A dry kind of cherry, of a light color.","pos":""}],"AMORET":[{"def":"An amorous girl or woman; a wanton.","pos":""},{"def":"A love knot, love token, or love song.","pos":""}],"AMORIST":[{"def":"A lover; a gallant.","pos":""}],"AMOROSA":[{"def":"A wanton woman; a courtesan.","pos":""}],"AMOROSITY":[{"def":"The quality of being amorous; lovingness.","pos":""}],"AMOROSO":[{"def":"A lover; a man enamored.","pos":""}],"AMOROUS":[{"def":"Inclined to love; having a propensity to love, or to sexual enjoyment; loving; fond; affectionate; as, an amorous disposition.","pos":""},{"def":"Affected with love; in love; enamored; -- usually with of; formerly with on.","pos":""}],"AMOROUSLY":[{"def":"In an amorous manner; fondly.","pos":""}],"AMOROUSNESS":[{"def":"The quality of being amorous, or inclined to sexual love; lovingness.","pos":""}],"AMORPHA":[{"def":"A genus of leguminous shrubs, having long clusters of purple flowers; false or bastard indigo.","pos":""}],"AMORPHISM":[{"def":"A state of being amorphous; esp.","pos":""}],"AMORPHOUS":[{"def":"Having no determinate form; of irregular; shapeless.","pos":""},{"def":"Without crystallization in the ultimate texture of a solid substance; uncrystallized.","pos":""}],"AMORPHOZOA":[{"def":"Animals without a mouth or regular internal organs, as the sponges.","pos":""}],"AMORPHOZOIC":[{"def":"Of or pertaining to the Amorphozoa.","pos":""}],"AMORT":[{"def":"As if dead; lifeless; spiritless; dejected; depressed.","pos":""},{"def":"Same as Amortize, Amortization, etc.","pos":""}],"AMORTIZABLE":[{"def":"Capable of being cleared off, as a debt.","pos":""}],"AMORTIZATION":[{"def":"The act or right of alienating lands to a corporation, which was considered formerly as transferring them to dead hands, or in mortmain.","pos":""}],"AMORTIZE":[{"def":"To alienate in mortmain, that is, to convey to a corporation.","pos":""}],"AMORTIZEMENT":[{"def":"Same as Amortization.","pos":""}],"AMORWE":[{"def":"On the following morning.","pos":""}],"AMOTION":[{"def":"Removal; ousting; especially, the removal of a corporate officer from his office.","pos":""},{"def":"Deprivation of possession.","pos":""}],"AMOTUS":[{"def":"Elevated, -- as a toe, when raised so high that the tip does not touch the ground.","pos":""}],"AMOUNT":[{"def":"To go up; to ascend.","pos":""},{"def":"To rise or reach by an accumulation of particular sums or quantities; to come (to) in the aggregate or whole; -- with to or unto.","pos":""}],"AMOUR":[{"def":"Love; affection.","pos":""},{"def":"Love making; a love affair; usually, an unlawful connection in love; a love intrigue; an illicit love affair.","pos":""}],"AMOUR PROPRE":[{"def":"Self-love; self-esteem.","pos":""}],"AMOVABILITY":[{"def":"Liability to be removed or dismissed from office.","pos":""}],"AMOVE":[{"def":"To dismiss from an office or station.","pos":""}]}