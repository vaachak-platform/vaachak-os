{"INDE":[{"def":"Azure-colored; of a bright blue color.","pos":""}],"INDEBT":[{"def":"To bring into debt; to place under obligation; -- chiefly used in the participle indebted.","pos":""}],"INDEBTED":[{"def":"Brought into debt; being under obligation; held to payment or requital; beholden.","pos":""},{"def":"Placed under obligation for something received, for which restitution or gratitude is due; as, we are indebted to our parents for their care of us in infancy; indebted to friends for help and encouragement.","pos":""}],"INDEBTEDNESS":[{"def":"The state of being indebted.","pos":""},{"def":"The sum owed; debts, collectively.","pos":""}],"INDECENCY":[{"def":"The quality or state of being indecent; want of decency, modesty, or good manners; obscenity.","pos":""},{"def":"That which is indecent; an indecent word or act; an offense against delicacy.","pos":""}],"INDECENT":[{"def":"Not decent; unfit to be seen or heard; offensive to modesty and delicacy; as, indecent language.","pos":""}],"INDECENTLY":[{"def":"In an indecent manner.","pos":""}],"INDECIDUATE":[{"def":"Having no decidua; nondeciduate.","pos":""}],"INDECIDUOUS":[{"def":"Not deciduous or falling, as the leaves of trees in autumn; lasting; evergreen; persistent; permanent; perennial.","pos":""}],"INDECIMABLE":[{"def":"Not decimable, or liable to be decimated; not liable to the payment of tithes.","pos":""}],"INDECIPHERABLE":[{"def":"Not decipherable; incapable of being deciphered, explained, or solved.","pos":""}],"INDECISION":[{"def":"Want of decision; want of settled purpose, or of firmness; indetermination; wavering of mind; irresolution; vacillation; hesitation.","pos":""}],"INDECISIVE":[{"def":"Not decisive; not bringing to a final or ultimate issue; as, an indecisive battle, argument, answer.","pos":""},{"def":"Undetermined; prone to indecision; irresolute; unsettled; wavering; vacillating; hesitating; as, an indecisive state of mind; an indecisive character.","pos":""}],"INDECISIVELY":[{"def":"Without decision.","pos":""}],"INDECISIVENESS":[{"def":"The state of being indecisive; unsettled state.","pos":""}],"INDECLINABLE":[{"def":"Not declinable; not varied by inflective terminations; as, nihil (nothing), in Latin, is an indeclinable noun.","pos":""},{"def":"An indeclinable word.","pos":""}],"INDECLINABLY":[{"def":"Without variation of termination.","pos":""}],"INDECOMPOSABLE":[{"def":"Not decomposable; incapable or difficult of decomposition; not resolvable into its constituents or elements.","pos":""}],"INDECOMPOSABLENESS":[{"def":"Incapableness of decomposition; stability; permanence; durability.","pos":""}],"INDECOROUS":[{"def":"Not decorous; violating good manners; contrary to good breeding or etiquette; unbecoming; improper; out of place; as, indecorous conduct.","pos":""}],"INDECOROUSLY":[{"def":"In an indecorous manner.","pos":""}],"INDECOROUSNESS":[{"def":"The quality of being indecorous; want of decorum.","pos":""}],"INDECORUM":[{"def":"Want of decorum; impropriety of behavior; that in behavior or manners which violates the established rules of civility, custom, or etiquette; indecorousness.","pos":""},{"def":"An indecorous or becoming action.","pos":""}],"INDEED":[{"def":"In reality; in truth; in fact; verily; truly; -- used in a variety of sense.","pos":""}],"INDEFATIGABILITY":[{"def":"The state of being indefatigable.","pos":""}],"INDEFATIGABLE":[{"def":"Incapable of being fatigued; not readily exhausted; unremitting in labor or effort; untiring; unwearying; not yielding to fatigue; as, indefatigable exertions, perseverance, application.","pos":""}],"INDEFATIGABLENESS":[{"def":"Indefatigable quality; unweariedness; persistency.","pos":""}],"INDEFATIGABLY":[{"def":"Without weariness; without yielding to fatigue; persistently.","pos":""}],"INDEFATIGATION":[{"def":"Indefatigableness; unweariedness.","pos":""}],"INDEFEASIBILITY":[{"def":"The quality of being undefeasible.","pos":""}],"INDEFEASIBLE":[{"def":"Not to be defeated; not defeasible; incapable of being annulled or made void; as, an indefeasible or title.","pos":""}],"INDEFECTIBILITY":[{"def":"The quality of being indefectible.","pos":""}],"INDEFECTIBLE":[{"def":"Not defectible; unfailing; not liable to defect, failure, or decay.","pos":""}],"INDEFECTIVE":[{"def":"Not defective; perfect; complete.","pos":""}],"INDEFENSIBILITY":[{"def":"The quality or state of not being defensible.","pos":""}],"INDEFENSIBLE":[{"def":"Not defensible; not capable of being defended, maintained, vindicated, or justified; unjustifiable; untenable; as, an indefensible fortress, position, cause, etc.","pos":""}],"INDEFENSIBLY":[{"def":"In an indefensible manner.","pos":""}],"INDEFENSIVE":[{"def":"The sword awes the indefensive villager.","pos":""}],"INDEFICIENCY":[{"def":"The state or quality of not being deficient.","pos":""}],"INDEFICIENT":[{"def":"Not deficient; full.","pos":""}],"INDEFINABLE":[{"def":"Incapable of being defined or described; inexplicable.","pos":""}],"INDEFINABLY":[{"def":"In an indefinable manner.","pos":""}],"INDEFINITE":[{"def":"Too numerous or variable to make a particular enumeration important; -- said of the parts of a flower, and the like.","pos":""}],"INDEFINITELY":[{"def":"In an indefinite manner or degree; without any settled limitation; vaguely; not with certainty or exactness; as, to use a word indefinitely.","pos":""}],"INDEFINITENESS":[{"def":"The quality of being indefinite.","pos":""}],"INDEFINITUDE":[{"def":"Indefiniteness; vagueness; also, number or quantity not limited by our understanding, though yet finite.","pos":""}],"INDEHISCENCE":[{"def":"The property or state of being indehiscent.","pos":""}],"INDEHISCENT":[{"def":"Remaining closed at maturity, or not opening along regular lines, as the acorn, or a cocoanut.","pos":""}],"INDELECTABLE":[{"def":"Not delectable; unpleasant; disagreeable.","pos":""}],"INDELIBERATE":[{"def":"Done without deliberation; unpremeditated.","pos":""}],"INDELIBERATED":[{"def":"In`de*lib\"er*a`ted, a.","pos":""}],"INDELIBILITY":[{"def":"The quality of being indelible.","pos":""}],"INDELIBLE":[{"def":"That can not be removed, washed away, blotted out, or effaced; incapable of being canceled, lost, or forgotten; as, indelible characters; an indelible stain; an indelible impression on the memory.","pos":""},{"def":"That can not be annulled; indestructible.","pos":""}],"INDELICACY":[{"def":"The quality of being indelicate; want of delicacy, or of a nice sense of, or regard for, purity, propriety, or refinement in manners, language, etc.","pos":""}],"INDELICATE":[{"def":"Not delicate; wanting delicacy; offensive to good manners, or to purity of mind; coarse; rude; as, an indelicate word or suggestion; indelicate behavior.","pos":""}],"INDEMNIFICATION":[{"def":"The act or process of indemnifying, preserving, or securing against loss, damage, or penalty; reimbursement of loss, damage, or penalty; the state of being indemnified.","pos":""},{"def":"That which indemnifies.","pos":""}],"INDEMNIFY":[{"def":"To save harmless; to secure against loss or damage; to insure.","pos":""},{"def":"To make restitution or compensation for, as for that which is lost; to make whole; to reimburse; to compensate.","pos":""}],"INDEMNITY":[{"def":"Security; insurance; exemption from loss or damage, past or to come; immunity from penalty, or the punishment of past offenses; amnesty.","pos":""},{"def":"Indemnification, compensation, or remuneration for loss, damage, or injury sustained.","pos":""}],"INDEMONSTRABILITY":[{"def":"The quality of being indemonstrable.","pos":""}],"INDEMONSTRABLE":[{"def":"Incapable of being demonstrated.","pos":""}],"INDENIZATION":[{"def":"The act of naturalizing; endenization.","pos":""}],"INDENIZEN":[{"def":"To invest with the privileges of a denizen; to naturalize.","pos":""}],"INDENT":[{"def":"To bind out by indenture or contract; to indenture; to apprentice; as, to indent a young man to a shoemaker; to indent a servant.","pos":""},{"def":"To begin (a line or lines) at a greater or less distance from the margin; as, to indent the first line of a paragraph one em; to indent the second paragraph two ems more than the first.","pos":""}],"INDENTATION":[{"def":"The act of indenting or state of being indented.","pos":""},{"def":"A notch or recess, in the margin or border of anything; as, the indentations of a leaf, of the coast, etc.","pos":""}],"INDENTED":[{"def":"Notched like the part of a saw consisting of the teeth; serrated; as, an indented border or ordinary.","pos":""},{"def":"Notched along the margin with a different color, as the feathers of some birds.","pos":""}],"INDENTEDLY":[{"def":"With indentations.","pos":""}],"INDENTING":[{"def":"Indentation; an impression like that made by a tooth.","pos":""}],"INDENTION":[{"def":"Same as Indentation, 4.","pos":""}],"INDENTURE":[{"def":"A mutual agreement in writing between two or more parties, whereof each party has usually a counterpart or duplicate; sometimes in the pl.","pos":""}],"INDEPENDENCE":[{"def":"The state or quality of being independent; freedom from dependence; exemption from reliance on, or control by, others; self- subsistence or maintenance; direction of one's own affairs without interference.","pos":""},{"def":"Sufficient means for a comfortable livelihood.","pos":""}],"INDEPENDENCE DAY":[{"def":"In the United States, a holiday, the 4th of July, commemorating the adoption of the Declaration of Independence on that day in 1776.","pos":""}],"INDEPENDENCY":[{"def":"Doctrine and polity of the Independents.","pos":""}],"INDEPENDENT":[{"def":"Belonging or pertaining to, or holding to the doctrines or methods of, the Independents.","pos":""},{"def":"Not dependent upon another quantity in respect to value or rate of variation; -- said of quantities or functions.","pos":""}],"INDEPENDENTISM":[{"def":"Independency; the church system of Independents.","pos":""}],"INDEPENDENTLY":[{"def":"In an independent manner; without control.","pos":""}],"INDEPOSABLE":[{"def":"Incapable of being deposed.","pos":""}],"INDEPRECABLE":[{"def":"Incapable or undeserving of being deprecated.","pos":""}],"INDEPREHENSIBLE":[{"def":"Incapable of being found out.","pos":""}],"INDEPRIVABLE":[{"def":"Incapable of being deprived, or of being taken away.","pos":""}],"INDESCRIBABLE":[{"def":"Incapable of being described.","pos":""}],"INDESCRIPTIVE":[{"def":"Not descriptive.","pos":""}],"INDESINENT":[{"def":"Not ceasing; perpetual.","pos":""}],"INDESTRUCTIBILITY":[{"def":"The quality of being indestructible.","pos":""}],"INDESTRUCTIBLE":[{"def":"Not destructible; incapable of decomposition or of being destroyed.","pos":""}],"INDETERMINABLE":[{"def":"Not determinable; impossible to be determined; not to be definitely known, ascertained, defined, or limited.","pos":""}],"INDETERMINATE":[{"def":"Not determinate; not certain or fixed; indefinite; not precise; as, an indeterminate number of years.","pos":""}],"INDETERMINATION":[{"def":"Want of determination; an unsettled or wavering state, as of the mind.","pos":""},{"def":"Want of fixed or stated direction.","pos":""}],"INDEVIRGINATE":[{"def":"Not devirginate.","pos":""}],"INDEVOTION":[{"def":"Want of devotion; impiety; irreligion.","pos":""}],"INDEX":[{"def":"The second digit, that next pollex, in the manus, or hand; the forefinger; index finger.","pos":""},{"def":"The figure or letter which shows the power or root of a quantity; the exponent.","pos":""}],"INDEXER":[{"def":"One who makes an index.","pos":""}],"INDEXICAL":[{"def":"Of, pertaining to, or like, an index; having the form of an index.","pos":""}],"INDEXICALLY":[{"def":"In the manner of an index.","pos":""}],"INDEXTERITY":[{"def":"Want of dexterity or readiness, especially in the use of the hands; clumsiness; awkwardness.","pos":""}]}