{"INSABBATATI":[{"def":"The Waldenses; -- so called from their peculiary cut or marked sabots, or shoes.","pos":""}],"INSAFETY":[{"def":"Insecurity; danger.","pos":""}],"INSALIVATION":[{"def":"The mixing of the food with the saliva and other secretions of the mouth in eating.","pos":""}],"INSALUBRIOUS":[{"def":"Not salubrious or healthful; unwholesome; as, an insalubrious air or climate.","pos":""}],"INSALUBRITY":[{"def":"Unhealthfulness; unwholesomeness; as, the insalubrity of air, water, or climate.","pos":""}],"INSALUTARY":[{"def":"Not salutary or wholesome; unfavorable to health.","pos":""},{"def":"Not tending to safety; productive of evil.","pos":""}],"INSANABILITY":[{"def":"The state of being insanable or incurable; insanableness.","pos":""}],"INSANABLE":[{"def":"Not capable of being healed; incurable; irremediable.","pos":""}],"INSANABLENESS":[{"def":"The state of being insanable; insanability; incurableness.","pos":""}],"INSANABLY":[{"def":"In an incurable manner.","pos":""}],"INSANE":[{"def":"Exhibiting unsoundness or disorded of mind; not sane; mad; deranged in mind; delirious; distracted.","pos":""},{"def":"Used by, or appropriated to, insane persons; as, an insane hospital.","pos":""}],"INSANELY":[{"def":"Without reason; madly; foolishly.","pos":""}],"INSANENESS":[{"def":"Insanity; madness.","pos":""}],"INSANIATE":[{"def":"To render unsound; to make mad.","pos":""}],"INSANITARY":[{"def":"Not sanitary; unhealthy; as, insanitary conditions of drainage.","pos":""}],"INSANITATION":[{"def":"Lack of sanitation; careless or dangerous hygienic conditions.","pos":""}],"INSANITY":[{"def":"Such a mental condition, as, either from the existence of delusions, or from incapacity to distinguish between right and wrong, with regard to any matter under action, does away with individual responsibility.","pos":""}],"INSAPORY":[{"def":"Tasteless; unsavory.","pos":""}],"INSATIABILITY":[{"def":"The state or quality of being insatiable; insatiableness.","pos":""}],"INSATIABLE":[{"def":"Not satiable; incapable of being satisfied or appeased; very greedy; as, an insatiable appetite, thirst, or desire.","pos":""}],"INSATIABLENESS":[{"def":"Greediness of appetite that can not be satisfied or appeased; insatiability.","pos":""}],"INSATIABLY":[{"def":"In an insatiable manner or degree; unappeasably.","pos":""}],"INSATIATE":[{"def":"Insatiable; as, insatiate thirst.","pos":""}],"INSATIATENESS":[{"def":"The state of being insatiate.","pos":""}],"INSATISFACTION":[{"def":"Insufficiency; emptiness.","pos":""},{"def":"Dissatisfaction.","pos":""}],"INSATURABLE":[{"def":"Not capable of being saturated or satisfied.","pos":""}]}