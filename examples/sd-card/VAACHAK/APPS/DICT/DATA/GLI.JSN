{"GLIADIN":[{"def":"Vegetable glue or gelatin; glutin.","pos":""}],"GLIB":[{"def":"Smooth; slippery; as, ice is glib.","pos":""},{"def":"Speaking or spoken smoothly and with flippant rapidity; fluent; voluble; as, a glib tongue; a glib speech.","pos":""}],"GLIBBERY":[{"def":"Slippery; changeable.","pos":""},{"def":"Moving easily; nimble; voluble.","pos":""}],"GLIBLY":[{"def":"In a glib manner; as, to speak glibly.","pos":""}],"GLIBNESS":[{"def":"The quality of being glib.","pos":""}],"GLIDDEN":[{"def":"Giving no sure footing; smooth; slippery.","pos":""}],"GLIDE":[{"def":"The glede or kite.","pos":""}],"GLIDER":[{"def":"One who, or that which, glides.","pos":""}],"GLIDING MACHINE":[{"def":"A construction consisting essentially of one or more aëroplanes for gliding in an inclined path from a height to the ground.","pos":""}],"GLIDINGLY":[{"def":"In a gliding manner.","pos":""}],"GLIFF":[{"def":"A transient glance; an unexpected view of something that startles one; a sudden fear.","pos":""},{"def":"A moment: as, for a gliff.","pos":""}],"GLIKE":[{"def":"A sneer; a flout.","pos":""}],"GLIM":[{"def":"Brightness; splendor.","pos":""},{"def":"A light or candle.","pos":""}],"GLIMMER":[{"def":"To give feeble or scattered rays of light; to shine faintly; to show a faint, unsteady light; as, the glimmering dawn; a glimmering lamp.","pos":""}],"GLIMMERING":[{"def":"Faint, unsteady light; a glimmer.","pos":""},{"def":"A faint view or idea; a glimpse; an inkling.","pos":""}],"GLIMPSE":[{"def":"A sudden flash; transient luster.","pos":""},{"def":"A short, hurried view; a transitory or fragmentary perception; a quick sight.","pos":""}],"GLINT":[{"def":"A glimpse, glance, or gleam.","pos":""}],"GLIOMA":[{"def":"A tumor springing from the neuroglia or connective tissue of the brain, spinal cord, or other portions of the nervous system.","pos":""}],"GLIRES":[{"def":"An order of mammals; the Rodentia.","pos":""}],"GLISSADE":[{"def":"A sliding, as down a snow slope in the Alps.","pos":""}],"GLISSANDO":[{"def":"A gliding effect; gliding.","pos":""}],"GLISSETTE":[{"def":"The locus described by any point attached to a curve that slips continuously on another fixed curve, the movable curve having no rotation at any instant.","pos":""}],"GLISTEN":[{"def":"To sparkle or shine; especially, to shine with a mild, subdued, and fitful luster; to emit a soft, scintillating light; to gleam; as, the glistening stars.","pos":""}],"GLISTER":[{"def":"To be bright; to sparkle; to be brilliant; to shine; to glisten; to glitter.","pos":""}],"GLISTERINGLY":[{"def":"In a glistering manner.","pos":""}],"GLITTER":[{"def":"To sparkle with light; to shine with a brilliant and broken light or showy luster; to gleam; as, a glittering sword.","pos":""},{"def":"To be showy, specious, or striking, and hence attractive; as, the glittering scenes of a court.","pos":""}],"GLITTERINGLY":[{"def":"In a glittering manner.","pos":""}]}