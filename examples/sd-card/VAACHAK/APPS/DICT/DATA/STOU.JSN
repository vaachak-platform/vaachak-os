{"STOUND":[{"def":"To be in pain or sorrow.","pos":""}],"STOUP":[{"def":"A basin at the entrance of Roman Catholic churches for containing the holy water with which those who enter, dipping their fingers in it, cross themselves; -- called also holy-water stoup.","pos":""}],"STOUR":[{"def":"A battle or tumult; encounter; combat; disturbance; passion.","pos":""}],"STOUT":[{"def":"Strong; lusty; vigorous; robust; sinewy; muscular; hence, firm; resolute; dauntless.","pos":""},{"def":"Proud; haughty; arrogant; hard.","pos":""}],"STOUT-HEARTED":[{"def":"Having a brave heart; courageous.","pos":""}],"STOUTISH":[{"def":"Somewhat stout; somewhat corpulent.","pos":""}],"STOUTLY":[{"def":"In a stout manner; lustily; boldly; obstinately; as, he stoutly defended himself.","pos":""}],"STOUTNESS":[{"def":"The state or quality of being stout.","pos":""},{"def":"A substance, C14H22O2NCl, the hydrochloride of an amino compound containing benzol, used, in solution with strychnine, as a local anæsthetic, esp.","pos":""}]}