{"SIX":[{"def":"One more than five; twice three; as, six yards.","pos":""}],"SIX-FOOTER":[{"def":"One who is six feet tall.","pos":""}],"SIX-SHOOTER":[{"def":"A pistol or other firearm which can be fired six times without reloading especially, a six-chambered revolver.","pos":""}],"SIXFOLD":[{"def":"Six times repeated; six times as much or as many.","pos":""}],"SIXPENCE":[{"def":"An English silver coin of the value of six pennies; half a shilling, or about twelve cents.","pos":""}],"SIXPENNY":[{"def":"Of the value of, or costing, sixpence; as, a sixpenny loaf.","pos":""}],"SIXSCORE":[{"def":"Six times twenty; one hundred and twenty.","pos":""}],"SIXTEEN":[{"def":"Six and ten; consisting of six and ten; fifteen and one more.","pos":""}],"SIXTEENMO":[{"def":"See Sextodecimo.","pos":""}],"SIXTEENTH":[{"def":"Sixth after the tenth; next in order after the fifteenth.","pos":""},{"def":"Constituting or being one of sixteen equal parts into which anything is divided.","pos":""}],"SIXTH":[{"def":"First after the fifth; next in order after the fifth.","pos":""},{"def":"Constituting or being one of six equal parts into which anything is divided.","pos":""}],"SIXTHLY":[{"def":"In the sixth place.","pos":""}],"SIXTIETH":[{"def":"Next in order after the fifty-ninth.","pos":""},{"def":"Constituting or being one one of sixty equal parts into which anything is divided.","pos":""}],"SIXTY":[{"def":"Six times ten; fifty-nine and one more; threescore.","pos":""}],"SIXTY-FOURTH":[{"def":"Constituting or being one of sixty-four equal parts into which a thing is divided.","pos":""}]}