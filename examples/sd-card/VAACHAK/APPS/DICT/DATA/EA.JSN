{"EACH":[{"def":"Every one of the two or more individuals composing a number of objects, considered separately from the rest.","pos":""},{"def":"Every; -- sometimes used interchangeably with every.","pos":""}],"EACHWHERE":[{"def":"The sky eachwhere did show full bright and fair.","pos":""}],"EAGER":[{"def":"Sharp; sour; acid.","pos":""},{"def":"Sharp; keen; bitter; severe.","pos":""}],"EAGERLY":[{"def":"In an eager manner.","pos":""}],"EAGERNESS":[{"def":"The state or quality of being eager; ardent desire.","pos":""},{"def":"Tartness; sourness.","pos":""}],"EAGLE":[{"def":"Any large, rapacious bird of the Falcon family, esp.","pos":""},{"def":"A northern constellation, containing Altair, a star of the first magnitude.","pos":""}],"EAGLE-EYED":[{"def":"Sharp-sighted as an eagle.","pos":""}],"EAGLE-SIGHTED":[{"def":"Farsighted and strong-sighted; sharp-sighted.","pos":""}],"EAGLE-WINGED":[{"def":"Having the wings of an eagle; swift, or soaring high, like an eagle.","pos":""}],"EAGLESS":[{"def":"A female or hen eagle.","pos":""}],"EAGLESTONE":[{"def":"A concretionary nodule of clay ironstone, of the size of a walnut or larger, so called by the ancients, who believed that the eagle transported these stones to her nest to facilitate the laying of her eggs; aëtites.","pos":""}],"EAGLET":[{"def":"A young eagle, or a diminutive eagle.","pos":""}],"EAGLEWOOD":[{"def":"A kind of fragrant wood.","pos":""}],"EAGRE":[{"def":"A wave, or two or three successive waves, of great height and violence, at flood tide moving up an estuary or river; -- commonly called the bore.","pos":""}],"EAN":[{"def":"To bring forth, as young; to yean.","pos":""}],"EANLING":[{"def":"A lamb just brought forth; a yeanling.","pos":""}],"EAR":[{"def":"The organ of hearing; the external ear.","pos":""},{"def":"The sense of hearing; the perception of sounds; the power of discriminating between different tones; as, a nice ear for music; -- in the singular only.","pos":""}],"EAR-BORED":[{"def":"Having the ear perforated.","pos":""}],"EAR-MINDED":[{"def":"Thinking chiefly or most readily through, or in terms related to, the sense of hearing; specif.","pos":""}],"EAR-SHELL":[{"def":"A flattened marine univalve shell of the genus Haliotis; -- called also sea-ear.","pos":""}],"EAR-SPLITTING":[{"def":"Deafening; disagreeably loud or shrill; as, ear-splitting strains.","pos":""}],"EARABLE":[{"def":"Arable; tillable.","pos":""}],"EARACHE":[{"def":"Ache or pain in the ear.","pos":""}],"EARAL":[{"def":"Receiving by the ear.","pos":""}],"EARCAP":[{"def":"A cap or cover to protect the ear from cold.","pos":""}],"EARCOCKLE":[{"def":"A disease in wheat, in which the blackened and contracted grain, or ear, is filled with minute worms.","pos":""}],"EARDROP":[{"def":"A species of primrose.","pos":""}],"EARED":[{"def":"Having external ears; having tufts of feathers resembling ears.","pos":""}],"EARINESS":[{"def":"Fear or timidity, especially of something supernatural.","pos":""}],"EARING":[{"def":"Coming into ear, as corn.","pos":""}],"EARL":[{"def":"A nobleman of England ranking below a marquis, and above a viscount.","pos":""}],"EARL MARSHAL":[{"def":"An officer of state in England who marshals and orders all great ceremonials, takes cognizance of matters relating to honor, arms, and pedigree, and directs the proclamation of peace and war.","pos":""}],"EARLAP":[{"def":"The lobe of the ear.","pos":""}],"EARLDOM":[{"def":"The jurisdiction of an earl; the territorial possessions of an earl.","pos":""},{"def":"The status, title, or dignity of an earl.","pos":""}],"EARLDUCK":[{"def":"The red-breasted merganser (Merganser serrator).","pos":""}],"EARLESS":[{"def":"Without ears; hence, deaf or unwilling to hear.","pos":""}],"EARLET":[{"def":"The Ismaelites were accustomed to wear golden earlets.","pos":""}],"EARLINESS":[{"def":"The state of being early or forward; promptness.","pos":""}],"EARLOCK":[{"def":"A lock or curl of hair near the ear; a lovelock.","pos":""}],"EARLY":[{"def":"Soon; in good season; seasonably; betimes; as, come early.","pos":""}],"EARMARK":[{"def":"A mark on the ear of sheep, oxen, dogs, etc.","pos":""},{"def":"A mark for identification; a distinguishing mark.","pos":""}],"EARN":[{"def":"To merit or deserve, as by labor or service; to do that which entitles one to (a reward, whether the reward is received or not).","pos":""},{"def":"To acquire by labor, service, or performance; to deserve and receive as compensation or wages; as, to earn a good living; to earn honors or laurels.","pos":""}],"EARNEST":[{"def":"Seriousness; reality; fixed determination; eagerness; intentness.","pos":""}],"EARNESTLY":[{"def":"In an earnest manner.","pos":""}],"EARNESTNESS":[{"def":"The state or quality of being earnest; intentness; anxiety.","pos":""}],"EARNFUL":[{"def":"Full of anxiety or yearning.","pos":""}],"EARNING":[{"def":"That which is earned; wages gained by work or services; money earned; -- used commonly in the plural.","pos":""}],"EARPICK":[{"def":"An instrument for removing wax from the ear.","pos":""}],"EARRING":[{"def":"An ornament consisting of a ring passed through the lobe of the ear, with or without a pendant.","pos":""}],"EARSHOT":[{"def":"Reach of the ear; distance at which words may be heard.","pos":""}],"EARSHRIFT":[{"def":"A nickname for auricular confession; shrift.","pos":""}],"EARSORE":[{"def":"An annoyance to the ear.","pos":""}],"EARTH":[{"def":"The globe or planet which we inhabit; the world, in distinction from the sun, moon, or stars.","pos":""},{"def":"The solid materials which make up the globe, in distinction from the air or water; the dry land.","pos":""}],"EARTH FLAX":[{"def":"A variety of asbestus.","pos":""}],"EARTH SHINE":[{"def":"See Earth light, under Earth.","pos":""}],"EARTH-TONGUE":[{"def":"A fungus of the genus Geoglossum.","pos":""},{"def":"Toward the earth; -- opposed to heavenward or skyward.","pos":""}],"EARTHBAG":[{"def":"A bag filled with earth, used commonly to raise or repair a parapet.","pos":""}],"EARTHBANK":[{"def":"A bank or mound of earth.","pos":""}],"EARTHBOARD":[{"def":"The part of a plow, or other implement, that turns over the earth; the moldboard.","pos":""}],"EARTHBORN":[{"def":"Born of the earth; terrigenous; springing originally from the earth; human.","pos":""},{"def":"Relating to, or occasioned by, earthly objects.","pos":""}],"EARTHBRED":[{"def":"Low; grovelling; vulgar.","pos":""}],"EARTHDRAKE":[{"def":"A mythical monster of the early Anglo-Saxon literature; a dragon.","pos":""}],"EARTHEN":[{"def":"Made of earth; made of burnt or baked clay, or other like substances; as, an earthen vessel or pipe.","pos":""}],"EARTHEN-HEARTED":[{"def":"Hard-hearted; sordid; gross.","pos":""}],"EARTHENWARE":[{"def":"Vessels and other utensils, ornaments, or the like, made of baked clay.","pos":""}],"EARTHFORK":[{"def":"A pronged fork for turning up the earth.","pos":""}],"EARTHINESS":[{"def":"The quality or state of being earthy, or of containing earth; hence, grossness.","pos":""}],"EARTHLIGHT":[{"def":"The sunlight reflected from the earth to the moon, by which we see faintly, when the moon is near the sun (either before or after new moon), that part of the moon's disk unillumined by direct sunlight, or \"the old moon in the arms of the new.","pos":""}],"EARTHLINESS":[{"def":"The quality or state of being earthly; worldliness; grossness; perishableness.","pos":""}],"EARTHLING":[{"def":"An inhabitant of the earth; a mortal.","pos":""}],"EARTHLY":[{"def":"Pertaining to the earth; belonging to this world, or to man's existence on the earth; not heavenly or spiritual; carnal; worldly; as, earthly joys; earthly flowers; earthly praise.","pos":""},{"def":"Of all things on earth; possible; conceivable.","pos":""}],"EARTHLY-MINDED":[{"def":"Having a mind devoted to earthly things; worldly-minded; -- opposed to spiritual-minded.","pos":""}],"EARTHMAD":[{"def":"The earthmads and all the sorts of worms .","pos":""}],"EARTHNUT":[{"def":"A name given to various roots, tubers, or pods grown under or on the ground; as to: (a) The esculent tubers of the umbelliferous plants Bunium flexuosum and Carum Bulbocastanum.","pos":""}],"EARTHPEA":[{"def":"A species of pea (Amphicarpæa monoica).","pos":""}],"EARTHQUAKE":[{"def":"A shaking, trembling, or concussion of the earth, due to subterranean causes, often accompanied by a rumbling noise.","pos":""}],"EARTHSTAR":[{"def":"A curious fungus of the genus Geaster, in which the outer coating splits into the shape of a star, and the inner one forms a ball containing the dustlike spores.","pos":""}],"EARTHWORK":[{"def":"Any construction, whether a temporary breastwork or permanent fortification, for attack or defense, the material of which is chiefly earth.","pos":""}],"EARTHWORM":[{"def":"Any worm of the genus Lumbricus and allied genera, found in damp soil.","pos":""}],"EARTHY":[{"def":"Without luster, or dull and roughish to the touch; as, an earthy fracture.","pos":""}],"EARWIG":[{"def":"Any insect of the genus Forticula and related genera, belonging to the order Euplexoptera.","pos":""},{"def":"In America, any small chilopodous myriapod, esp.","pos":""}],"EARWITNESS":[{"def":"A witness by means of his ears; one who is within hearing and does hear; a hearer.","pos":""}],"EASE":[{"def":"Satisfaction; pleasure; hence, accommodation; entertainment.","pos":""},{"def":"Freedom from anything that pains or troubles; as: (a) Relief from labor or effort; rest; quiet; relaxation; as, ease of body.","pos":""}],"EASEFUL":[{"def":"Full of ease; suitable for affording ease or rest; quiet; comfortable; restful.","pos":""}],"EASEL":[{"def":"A frame (commonly) of wood serving to hold a canvas upright, or nearly upright, for the painter's convenience or for exhibition.","pos":""}],"EASEMENT":[{"def":"A liberty, privilege, or advantage, which one proprietor has in the estate of another proprietor, distinct from the ownership of the soil, as a way, water course, etc.","pos":""},{"def":"A curved member instead of an abrupt change of direction, as in a baseboard, hand rail, etc.","pos":""}],"EASILY":[{"def":"With ease; without difficulty or much effort; as, this task may be easily performed; that event might have been easily foreseen.","pos":""},{"def":"Without pain, anxiety, or disturbance; as, to pass life well and easily.","pos":""}],"EASINESS":[{"def":"The state or condition of being easy; freedom from distress; rest.","pos":""},{"def":"Freedom from difficulty; ease; as the easiness of a task.","pos":""}],"EAST":[{"def":"Formerly, the part of the United States east of the Alleghany Mountains, esp.","pos":""}],"EAST INDIAN":[{"def":"Belonging to, or relating to, the East Indies.","pos":""},{"def":"A native of, or a dweller in, the East Indies.","pos":""}],"EAST-INSULAR":[{"def":"Relating to the Eastern Islands; East Indian.","pos":""},{"def":"Toward the east; in the direction of east from some point or place; as, New Haven lies eastward from New York.","pos":""}],"EASTER":[{"def":"An annual church festival commemorating Christ's resurrection, and occurring on Sunday, the second day after Good Friday.","pos":""},{"def":"The day on which the festival is observed; Easter day.","pos":""}],"EASTER LILY":[{"def":"Harrisii) called also Bermuda lily.","pos":""}],"EASTERLING":[{"def":"A native of a country eastward of another; -- used, by the English, of traders or others from the coasts of the Baltic.","pos":""},{"def":"A piece of money coined in the east by Richard II.","pos":""}],"EASTERLY":[{"def":"Coming from the east; as, it was easterly wind.","pos":""},{"def":"Situated, directed, or moving toward the east; as, the easterly side of a lake; an easterly course or voyage.","pos":""}],"EASTERN":[{"def":"Situated or dwelling in the east; oriental; as, an eastern gate; Eastern countries.","pos":""},{"def":"Going toward the east, or in the direction of east; as, an eastern voyage.","pos":""}],"EASTERN CHURCH":[{"def":"That portion of the Christian church which prevails in the countries once comprised in the Eastern Roman Empire and the countries converted to Christianity by missionaries from them.","pos":""}],"EASTING":[{"def":"The distance measured toward the east between two meridians drawn through the extremities of a course; distance of departure eastward made by a vessel.","pos":""}],"EASY":[{"def":"Not straitened as to money matters; as, the market is easy; -- opposed to tight.","pos":""}],"EASY-CHAIR":[{"def":"An armichair for ease or repose.","pos":""}],"EASY-GOING":[{"def":"Moving easily; hence, mild-tempered; ease-loving; inactive.","pos":""}],"EAT":[{"def":"To chew and swallow as food; to devour; -- said especially of food not liquid; as, to eat bread.","pos":""},{"def":"To corrode, as metal, by rust; to consume the flesh, as a cancer; to waste or wear away; to destroy gradually; to cause to disappear.","pos":""}],"EATABLE":[{"def":"Capable of being eaten; fit to be eaten; proper for food; esculent; edible.","pos":""},{"def":"Something fit to be eaten.","pos":""}],"EATAGE":[{"def":"Eatable growth of grass for horses and cattle, esp.","pos":""}],"EATER":[{"def":"One who, or that which, eats.","pos":""}],"EATING":[{"def":"The act of tasking food; the act of consuming or corroding.","pos":""},{"def":"Something fit to be eaten; food; as, a peach is good eating.","pos":""}],"EAU DE COLOGNE":[{"def":"Same as Cologne.","pos":""}],"EAU DE VIE":[{"def":"French name for brandy.","pos":""}],"EAU FORTE":[{"def":"An etching or a print from an etched plate.","pos":""}],"EAVEDROP":[{"def":"A drop from the eaves; eavesdrop.","pos":""}],"EAVES":[{"def":"The edges or lower borders of the roof of a building, which overhang the walls, and cast off the water that falls on the roof.","pos":""}],"EAVESDROP":[{"def":"To stand under the eaves, near a window or at the door, of a house, to listen and learn what is said within doors; hence, to listen secretly to what is said in private.","pos":""}],"EAVESDROPPER":[{"def":"One who stands under the eaves, or near the window or door of a house, to listen; hence, a secret listener.","pos":""}],"EAVESDROPPING":[{"def":"The habit of lurking about dwelling houses, and other places where persons meet fro private intercourse, secretly listening to what is said, and then tattling it abroad.","pos":""}]}