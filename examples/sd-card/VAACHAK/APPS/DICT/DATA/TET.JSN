{"TETANIC":[{"def":"Of or pertaining to tetanus; having the character of tetanus; as, a tetanic state; tetanic contraction.","pos":""},{"def":"Producing, or tending to produce, tetanus, or tonic contraction of the muscles; as, a tetanic remedy.","pos":""}],"TETANIN":[{"def":"A poisonous base (ptomaine) formed in meat broth through the agency of a peculiar microbe from the wound of a person who has died of tetanus; -- so called because it produces tetanus as one of its prominent effects.","pos":""}],"TETANIZATION":[{"def":"The production or condition of tetanus.","pos":""}],"TETANIZE":[{"def":"To throw, as a muscle, into a state of permanent contraction; to cause tetanus in.","pos":""}],"TETANOID":[{"def":"Resembling tetanus.","pos":""}],"TETANOMOTOR":[{"def":"An instrument from tetanizing a muscle by irritating its nerve by successive mechanical shocks.","pos":""}],"TETANUS":[{"def":"A painful and usually fatal disease, resulting generally from a wound, and having as its principal symptom persistent spasm of the voluntary muscles.","pos":""},{"def":"That condition of a muscle in which it is in a state of continued vibratory contraction, as when stimulated by a series of induction shocks.","pos":""}],"TETANY":[{"def":"A morbid condition resembling tetanus, but distinguished from it by being less severe and having intermittent spasms.","pos":""}],"TETARD":[{"def":"A gobioid fish (Eleotris gyrinus) of the Southern United States; -- called also sleeper.","pos":""}],"TETARTOHEDRAL":[{"def":"Having one fourth the number of planes which are requisite to complete symmetry.","pos":""}],"TETARTOHEDRISM":[{"def":"The property of being tetartohedral.","pos":""}],"TETE":[{"def":"A kind of wig; false hair.","pos":""}],"TETE-A-TETE":[{"def":"Private conversation; familiar interview or conference of two persons.","pos":""},{"def":"A short sofa intended to accomodate two persons.","pos":""}],"TETE-DE-PONT":[{"def":"A work thrown up at the end of a bridge nearest the enemy, for covering the communications across a river; a bridgehead.","pos":""}],"TETEL":[{"def":"A large African antelope (Alcejaphus tora).","pos":""}],"TETHER":[{"def":"A long rope or chain by which an animal is fastened, as to a stake, so that it can range or feed only within certain limits.","pos":""}],"TETHER-BALL":[{"def":"A game played with rackets and a ball suspended by a string from an upright pole, the object of each side being to wrap the string around the pole by striking the ball in a direction opposite to the other.","pos":""}],"TETHYODEA":[{"def":"A division of Tunicata including the common attached ascidians, both simple and compound.","pos":""}],"TETHYS":[{"def":"A genus of a large naked mollusks having a very large, broad, fringed cephalic disk, and branched dorsal gills.","pos":""}],"TETRA-":[{"def":"A combining form (also used adjectively) denoting four proportional or combining parts of the substance or ingredient denoted by the term to which it is prefixed, as in tetra-chloride, tetroxide.","pos":""}],"TETRABASIC":[{"def":"Capable of neutralizing four molecules of a monacid base; having four hydrogen atoms capable of replacement by bases; quadribasic; -- said of certain acids; thus, normal silicic acid, Si(OH)4, is a tetrabasic acid.","pos":""}],"TETRABORIC":[{"def":"Same as Pyroboric.","pos":""}],"TETRABRANCHIATA":[{"def":"An order of Cephalopoda having four gills.","pos":""}],"TETRABRANCHIATE":[{"def":"Of or pertaining to the Tetrabranchiata.","pos":""},{"def":"One of the Tetrabranchiata.","pos":""}],"TETRACARPEL":[{"def":"Composed of four carpels.","pos":""}],"TETRACHORD":[{"def":"A scale series of four sounds, of which the extremes, or first and last, constituted a fourth.","pos":""}],"TETRACHOTOMOUS":[{"def":"Having a division by fours; separated into four parts or series, or into series of fours.","pos":""}],"TETRACID":[{"def":"Capable of neutralizing four molecules of a monobasic acid; having four hydrogen atoms capable of replacement ba acids or acid atoms; -- said of certain bases; thus, erythrine, C4H6(OH)4, is a tetracid alcohol.","pos":""}],"TETRACOCCOUS":[{"def":"Having four cocci, or carpels.","pos":""}],"TETRACOLON":[{"def":"A stanza or division in lyric poetry, consisting of four verses or lines.","pos":""}],"TETRACTINELLID":[{"def":"Any species of sponge of the division Tetractinellida.","pos":""}],"TETRACTINELLIDA":[{"def":"A division of Spongiæ in which the spicules are siliceous and have four branches diverging at right angles.","pos":""}],"TETRAD":[{"def":"A tetravalent or quadrivalent atom or radical; as, carbon is a tetrad.","pos":""}],"TETRADACTYLOUS":[{"def":"Having, or characterized by, four digits to the foot or hand.","pos":""}],"TETRADECANE":[{"def":"A light oily hydrocarbon, C14H30, of the marsh-gas series; -- so called from the fourteen carbon atoms in the molecule.","pos":""}],"TETRADECAPODA":[{"def":"Same as Arthrostraca.","pos":""}],"TETRADIC":[{"def":"Of or pertaining to a tetrad; possessing or having the characteristics of a tetrad; as, a carbon is a tetradic element.","pos":""}],"TETRADITE":[{"def":"A person in some way remarkable with regard to the number four, as one born on the fourth day of the month, or one who reverenced four persons in the Godhead.","pos":""}],"TETRADONT":[{"def":"A silver coin among the ancient Greeks, of the value of four drachms.","pos":""}],"TETRADYMITE":[{"def":"A telluride of bismuth.","pos":""}],"TETRADYNAMIA":[{"def":"A Linnæan class of plants having six stamens, four of which are longer than the others.","pos":""}],"TETRADYNAMIAN":[{"def":"A plant of the order Tetradynamia.","pos":""},{"def":"Belonging to the order Tetradynamia; having six stamens, four of which are uniformly longer than the others.","pos":""}],"TETRAGON":[{"def":"A plane figure having four sides and angles; a quadrangle, as a square, a rhombus, etc.","pos":""},{"def":"An aspect of two planets with regard to the earth when they are distant from each other ninety degrees, or the fourth of a circle.","pos":""}],"TETRAGONAL":[{"def":"Of or pertaining to a tetragon; having four angles or sides; thus, the square, the parallelogram, the rhombus, and the trapezium are tetragonal fingers.","pos":""},{"def":"Having four prominent longitudinal angles.","pos":""}],"TETRAGRAMMATON":[{"def":"The mystic number four, which was often symbolized to represent the Deity, whose name was expressed by four letters among some ancient nations; as, the Hebrew JeHoVaH, Greek qeo`s, Latin deus, etc.","pos":""}],"TETRAGYNIA":[{"def":"A Linnæan order of plants having four styles.","pos":""},{"def":"Belonging to the order Tetragynia; having four styles.","pos":""}],"TETRAHEDRAL":[{"def":"Having, or composed of, four sides.","pos":""}],"TETRAHEDRALLY":[{"def":"In a tetrahedral manner.","pos":""}],"TETRAHEDRITE":[{"def":"A sulphide of antimony and copper, with small quantities of other metals.","pos":""}],"TETRAHEDRON":[{"def":"A solid figure inclosed or bounded by four triangles.","pos":""}],"TETRAHEXAHEDRAL":[{"def":"Pertaining to a tetrahexahedron.","pos":""}],"TETRAHEXAHEDRON":[{"def":"A solid in the isometric system, bounded by twenty-four equal triangular faces, four corresponding to each face of the cube.","pos":""}],"TETRAKISHEXAHEDRON":[{"def":"A tetrahexahedron.","pos":""}],"TETRAKOSANE":[{"def":"A hydrocarbon, C24H50, resembling paraffin, and like it belonging to the marsh-gas series; -- so called from having twenty- four atoms of carbon in the molecule.","pos":""}],"TETRALOGY":[{"def":"A group or series of four dramatic pieces, three tragedies and one satyric, or comic, piece (or sometimes four tragedies), represented consequently on the Attic stage at the Dionysiac festival.","pos":""}],"TETRAMERA":[{"def":"A division of Coleoptera having, apparently, only four tarsal joints, one joint being rudimentary.","pos":""}],"TETRAMEROUS":[{"def":"Having the parts arranged in sets of four; as, a tetramerous flower.","pos":""},{"def":"Having four joints in each of the tarsi; -- said of certain insects.","pos":""}],"TETRAMETER":[{"def":"A verse or line consisting of four measures, that is, in iambic, trochaic, and anapestic verse, of eight feet; in other kinds of verse, of four feet.","pos":""}],"TETRAMETHYLENE":[{"def":"Tet`ra*meth\"yl*ene, n.","pos":""}],"TETRAMORPH":[{"def":"The union of the four attributes of the Evangelists in one figure, which is represented as winged, and standing on winged fiery wheels, the wings being covered with eyes.","pos":""}],"TETRANDRIA":[{"def":"A Linnæan class of plants having four stamens.","pos":""},{"def":"Belonging to the class Tetrandria.","pos":""}],"TETRAONID":[{"def":"A bird belonging to the tribe of which the genus Tetrao is the type, as the grouse, partridge, quail, and the like.","pos":""}],"TETRAPETALOUS":[{"def":"Containing four distinct petals, or flower leaves; as, a tetrapetalous corolla.","pos":""},{"def":"A combination of wax, resin, lard, and pitch, composing an ointment.","pos":""}],"TETRAPHYLLOUS":[{"def":"Having four leaves; consisting of four distinct leaves or leaflets.","pos":""}],"TETRAPLA":[{"def":"A Bible consisting of four different Greek versions arranged in four columns by Origen; hence, any version in four languages or four columns.","pos":""}],"TETRAPNEUMONA":[{"def":"A division of Arachnida including those spiders which have four lungs, or pulmonary sacs.","pos":""}],"TETRAPNUEMONIAN":[{"def":"One of the Tetrapneumona.","pos":""}],"TETRAPOD":[{"def":"An insect characterized by having but four perfect legs, as certain of the butterflies.","pos":""}],"TETRAPODY":[{"def":"A set of four feet; a measure or distance of four feet.","pos":""}],"TETRAPTERAN":[{"def":"An insect having four wings.","pos":""}],"TETRAPTEROUS":[{"def":"Having four wings.","pos":""}],"TETRAPTOTE":[{"def":"A noun that has four cases only.","pos":""}],"TETRARCH":[{"def":"A Roman governor of the fourth part of a province; hence, any subordinate or dependent prince; also, a petty king or sovereign.","pos":""}],"TETRARCHICAL":[{"def":"Of or pertaining to a tetrarch or tetrarchy.","pos":""}],"TETRARCHY":[{"def":"The district under a Roman tetrarch; the office or jurisdiction of a tetrarch; a tetrarchate.","pos":""}],"TETRASCHISTIC":[{"def":"Characterized by division into four parts.","pos":""}],"TETRASEPALOUS":[{"def":"Having four sepals.","pos":""}],"TETRASPASTON":[{"def":"A machine in which four pulleys act together.","pos":""}],"TETRASPERMOUS":[{"def":"Having four seeds.","pos":""}],"TETRASPORE":[{"def":"A nonsexual spore, one of a group of four regularly occurring in red seaweeds.","pos":""}],"TETRASTICH":[{"def":"A stanza, epigram, or poem, consisting of four verses or lines.","pos":""}],"TETRASTYLE":[{"def":"Having four columns in front; -- said of a temple, portico, or colonnade.","pos":""},{"def":"A tetrastyle building.","pos":""}],"TETRASYLLABLE":[{"def":"A word consisting of four syllables; a quadrisyllable.","pos":""}],"TETRATHECAL":[{"def":"Having four loculaments, or thecæ.","pos":""}],"TETRATHIONATE":[{"def":"A salt of tetrathionic acid.","pos":""}],"TETRAVALENCE":[{"def":"The quality or state of being tetravalent; quadrivalence.","pos":""}],"TETRAVALENT":[{"def":"Having a valence of four; tetratomic; quadrivalent.","pos":""}],"TETRAXILE":[{"def":"Having four branches diverging at right angles; -- said of certain spicules of sponges.","pos":""},{"def":"A hypothetical compound, C2H2N4 which may be regarded as benzene with four CH groups replaced by nitrogen atoms; also, any of various derivatives of the same.","pos":""}],"TETRAZO-":[{"def":"A combining form (also used adjectively), designating any one of a series of double derivatives of the azo and diazo compounds containing four atoms of nitrogen.","pos":""}],"TETRAZOLE":[{"def":"A crystalline acid substance, CH2N4, which may be regarded as pyrrol in which nitrogen atoms replace three CH groups; also, any of various derivatives of the same.","pos":""}],"TETRAZONE":[{"def":"Any one of a certain series of basic compounds containing a chain of four nitrogen atoms; for example, ethyl tetrazone, (C2H5)2N.","pos":""},{"def":"Forward; perverse; harsh; sour; rugged.","pos":""}],"TETRICITY":[{"def":"Crabbedness; perverseness.","pos":""}],"TETRINIC":[{"def":"Of, pertaining to, or designating, a complex ketonic acid, C5H6O3, obtained as a white crystalline substance; -- so called because once supposed to contain a peculiar radical of four carbon atoms.","pos":""}],"TETRODON":[{"def":"Any one of numerous species of plectognath fishes belonging to Tetrodon and allied genera.","pos":""}],"TETRODONT":[{"def":"Of or pertaining to the tetrodons.","pos":""}],"TETROL":[{"def":"A hypothetical hydrocarbon, C4H4, analogous to benzene; -- so called from the four carbon atoms in the molecule.","pos":""}],"TETROLIC":[{"def":"Of, pertaining to, or designating, an acid, C3H3.","pos":""}],"TETROSE":[{"def":"A monosaccharide derived from a certain alcohol.","pos":""}],"TETROXIDE":[{"def":"An oxide having four atoms of oxygen in the molecule; a quadroxide; as, osmium tetroxide, OsO.","pos":""}],"TETRYL":[{"def":"Butyl; -- so called from the four carbon atoms in the molecule.","pos":""}],"TETRYLENE":[{"def":"Butylene; -- so called from the four carbon atoms in the molecule.","pos":""}],"TETTER":[{"def":"A vesicular disease of the skin; herpes.","pos":""}],"TETTER-TOTTER":[{"def":"A certain game of children; seesaw; -- called also titter- totter, and titter-cum-totter.","pos":""}],"TETTEROUS":[{"def":"Having the character of, or pertaining to, tetter.","pos":""}],"TETTERWORT":[{"def":"A plant used as a remedy for tetter, -- in England the calendine, in America the bloodroot.","pos":""}],"TETTIGONIAN":[{"def":"Any one of numerous species of Hemiptera belonging to Tettigonia and allied genera; a leaf hopper.","pos":""}],"TETTISH":[{"def":"Captious; testy.","pos":""}],"TETTIX":[{"def":"A genus of small grasshoppers.","pos":""}],"TETTY":[{"def":"Testy; irritable.","pos":""}]}