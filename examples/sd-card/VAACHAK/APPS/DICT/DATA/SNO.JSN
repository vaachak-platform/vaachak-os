{"SNOB":[{"def":"A vulgar person who affects to be better, richer, or more fashionable, than he really is; a vulgar upstart; one who apes his superiors.","pos":""},{"def":"A journeyman shoemaker.","pos":""}],"SNOBBERY":[{"def":"The quality of being snobbish; snobbishness.","pos":""}],"SNOBBISH":[{"def":"Of or pertaining to a snob; characteristic of, or befitting, a snob; vulgarly pretentious.","pos":""}],"SNOBBISHNESS":[{"def":"Vulgar affectation or ostentation; mean admiration of mean things; conduct or manners of a snob.","pos":""}],"SNOBOCRACY":[{"def":"Snobs, collectively.","pos":""}],"SNOD":[{"def":"A fillet; a headband; a snood.","pos":""}],"SNOFF":[{"def":"A short candle end used for igniting a fuse.","pos":""}],"SNOOD":[{"def":"The fillet which binds the hair of a young unmarried woman, and is emblematic of her maiden character.","pos":""},{"def":"A short line (often of horsehair) connecting a fishing line with the hook; a snell; a leader.","pos":""}],"SNOODED":[{"def":"Wearing or having a snood.","pos":""}],"SNOOK":[{"def":"To lurk; to lie in ambush.","pos":""}],"SNOOZE":[{"def":"A short sleep; a nap.","pos":""}],"SNORE":[{"def":"To breathe with a rough, hoarse, nasal voice in sleep.","pos":""}],"SNORING":[{"def":"The act of respiring through the open mouth so that the currents of inspired and expired air cause a vibration of the uvula and soft palate, thus giving rise to a sound more or less harsh.","pos":""}],"SNORT":[{"def":"To force the air with violence through the nose, so as to make a noise, as do high-spirited horsed in prancing and play.","pos":""}],"SNORTER":[{"def":"The wheather; -- so called from its cry.","pos":""}],"SNOT":[{"def":"Mucus secreted in, or discharged from, the nose.","pos":""},{"def":"A mean, insignificant fellow.","pos":""}],"SNOTTER":[{"def":"To snivel; to cry or whine.","pos":""}],"SNOTTERY":[{"def":"Filth; abomination.","pos":""}],"SNOTTY":[{"def":"Foul with snot; hence, mean; dirty.","pos":""}],"SNOUT":[{"def":"The long, projecting nose of a beast, as of swine.","pos":"verb"},{"def":"The nose of a man; -- in contempt.","pos":"verb"}],"SNOUTY":[{"def":"Resembling a beast's snout.","pos":""}],"SNOW":[{"def":"A square-rigged vessel, differing from a brig only in that she has a trysail mast close abaft the mainmast, on which a large trysail is hoisted.","pos":""}],"SNOW BANNER":[{"def":"A bannerlike stream of snow blown into the air from a mountain peak, often having a pinkish color and extending horizontally for several miles across the sky.","pos":""}],"SNOW-BLIND":[{"def":"Affected with blindness by the brilliancy of snow.","pos":""}],"SNOW-BOUND":[{"def":"Enveloped in, or confined by, snow.","pos":""}],"SNOW-BROTH":[{"def":"Snow and water mixed, or snow just melted; very cold liquor.","pos":""}],"SNOW-CAPPED":[{"def":"Having the top capped or covered with snow; as, snow-capped mountains.","pos":""}],"SNOW-WHITE":[{"def":"White as snow; very white.","pos":""}],"SNOWBALL":[{"def":"The Guelder-rose.","pos":""}],"SNOWBERRY":[{"def":"A name of several shrubs with white berries; as, the Symphoricarpus racemosus of the Northern United States, and the Chiococca racemosa of Florida and tropical America.","pos":""}],"SNOWCAP":[{"def":"A very small humming bird (Microchæra albocoronata) native of New Grenada.","pos":""}],"SNOWDRIFT":[{"def":"A bank of drifted snow.","pos":""}],"SNOWDROP":[{"def":"A bulbous plant (Galanthus nivalis) bearing white flowers, which often appear while the snow is on the ground.","pos":""}],"SNOWFLAKE":[{"def":"See Snowbird, 1.","pos":""},{"def":"A name given to several bulbous plants of the genus Leucoium (L.","pos":""}],"SNOWFLECK":[{"def":"See Snowbird, 1.","pos":""}],"SNOWL":[{"def":"The hooded merganser.","pos":""}],"SNOWLESS":[{"def":"Destitute of snow.","pos":""},{"def":"An implement operating like a plow, but on a larger scale, for clearing away the snow from roads, railways, etc.","pos":""}],"SNOWSHED":[{"def":"A shelter to protect from snow, esp.","pos":""}],"SNOWSHOE":[{"def":"A slight frame of wood three or four feet long and about one third as wide, with thongs or cords stretched across it, and having a support and holder for the foot; -- used by persons for walking on soft snow.","pos":""}],"SNOWSHOEING":[{"def":"Traveling on snowshoes.","pos":""}],"SNOWSHOER":[{"def":"One who travels on snowshoes; an expert in using snowshoes.","pos":""}],"SNOWSLIP":[{"def":"A large mass or avalanche of snow which slips down the side of a mountain, etc.","pos":""}],"SNOWSTORM":[{"def":"A storm with falling snow.","pos":""}],"SNOWY":[{"def":"White like snow.","pos":""},{"def":"Abounding with snow; covered with snow.","pos":""}]}