{"EXCLAIM":[{"def":"To cry out from earnestness or passion; to utter with vehemence; to call out or declare loudly; to protest vehemently; to vociferate; to shout; as, to exclaim against oppression with wonder or astonishment; \"The field is won!\" he exclaimed.","pos":""}],"EXCLAIMER":[{"def":"One who exclaims.","pos":""}],"EXCLAMATION":[{"def":"A word expressing outcry; an interjection; a word expressing passion, as wonder, fear, or grief.","pos":""},{"def":"A mark or sign by which outcry or emphatic utterance is marked; thus [!]; -- called also exclamation point.","pos":""}],"EXCLAMATORY":[{"def":"Containing, expressing, or using exclamation; as, an exclamatory phrase or speaker.","pos":""}],"EXCLAVE":[{"def":"A portion of a country which is separated from the main part and surrounded by politically alien territory.","pos":""}],"EXCLUDE":[{"def":"To thrust out or eject; to expel; as, to exclude young animals from the womb or from eggs.","pos":""}],"EXCLUSION":[{"def":"The act of expelling or ejecting a fetus or an egg from the womb.","pos":""}],"EXCLUSIONARY":[{"def":"Tending to exclude; causing exclusion; exclusive.","pos":""}],"EXCLUSIONISM":[{"def":"The character, manner, or principles of an exclusionist.","pos":""}],"EXCLUSIONIST":[{"def":"One who would exclude another from some right or privilege; esp.","pos":""}],"EXCLUSIVE":[{"def":"Having the power of preventing entrance; debarring from participation or enjoyment; possessed and enjoyed to the exclusion of others; as, exclusive bars; exclusive privilege; exclusive circles of society.","pos":""},{"def":"Not taking into the account; excluding from consideration; -- opposed to inclusive; as, five thousand troops, exclusive of artillery.","pos":""}],"EXCLUSIVENESS":[{"def":"Quality of being exclusive.","pos":""}],"EXCLUSIVISM":[{"def":"The act or practice of excluding being exclusive; exclusiveness.","pos":""}],"EXCLUSIVIST":[{"def":"One who favor or practices any from of exclusiveness or exclusivism.","pos":""}],"EXCLUSORY":[{"def":"Able to exclude; excluding; serving to exclude.","pos":""}]}