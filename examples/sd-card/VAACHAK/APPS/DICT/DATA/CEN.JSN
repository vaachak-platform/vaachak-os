{"CENANTHY":[{"def":"The absence or suppression of the essential organs (stamens and pistil) in a flower.","pos":""}],"CENATION":[{"def":"Meal-taking; dining or supping.","pos":""}],"CENATORY":[{"def":"Of or pertaining to dinner or supper.","pos":""}],"CENOBITE":[{"def":"One of a religious order, dwelling in a convent, or a community, in opposition to an anchoret, or hermit, who lives in solitude.","pos":""},{"def":"Of or pertaining to a cenobite.","pos":""}],"CENOBITISM":[{"def":"The state of being a cenobite; the belief or practice of a cenobite.","pos":""}],"CENOGAMY":[{"def":"The state of a communty which permits promiseuous sexual intercourse among its members, as in certain societies practicing communism.","pos":""}],"CENOTAPH":[{"def":"An empty tomb or a monument erected in honor of a person who is buried elsewhere.","pos":""}],"CENOTAPHY":[{"def":"Lord Cobham honored him with a cenotaphy.","pos":""}],"CENOZOIC":[{"def":"Belonging to the most recent division of geological time, including the tertiary, or Age of mammals, and the Quaternary, or Age of man.","pos":""}],"CENSE":[{"def":"A census; -- also, a public rate or tax.","pos":""},{"def":"Condition; rank.","pos":""}],"CENSER":[{"def":"A vessel for perfumes; esp.","pos":""}],"CENSOR":[{"def":"One of two magistrates of Rome who took a register of the number and property of citizens, and who also exercised the office of inspector of morals and conduct.","pos":""}],"CENSORIAL":[{"def":"Belonging to a censor, or to the correction of public morals.","pos":""},{"def":"Full of censure; censorious.","pos":""}],"CENSORIOUS":[{"def":"Addicted to censure; apt to blame or condemn; severe in making remarks on others, or on their writings or manners.","pos":""},{"def":"Implying or expressing censure; as, censorious remarks.","pos":""}],"CENSORSHIP":[{"def":"The office or power of a censor; as, to stand for a censorship.","pos":""}],"CENSUAL":[{"def":"Relating to, or containing, a census.","pos":""}],"CENSURABLE":[{"def":"Deserving of censure; blamable; culpable; reprehensible; as, a censurable person, or censurable conduct.","pos":""}],"CENSURE":[{"def":"Judgment either favorable or unfavorable; opinion.","pos":""},{"def":"The act of blaming or finding fault with and condemning as wrong; reprehension; blame.","pos":""}],"CENSURER":[{"def":"One who censures.","pos":""}],"CENSUS":[{"def":"A numbering of the people, and valuation of their estate, for the purpose of imposing taxes, etc.","pos":""}],"CENT":[{"def":"A hundred; as, ten per cent, the proportion of ten parts in a hundred.","pos":""},{"def":"A United States coin, the hundredth part of a dollar, formerly made of copper, now of copper, tin, and zinc.","pos":""}],"CENTAGE":[{"def":"Rate by the hundred; percentage.","pos":""}],"CENTAL":[{"def":"A weight of one hundred pounds avoirdupois; -- called in many parts of the United States a Hundredweight.","pos":""}],"CENTAUR":[{"def":"A fabulous being, represented as half man and half horse.","pos":""},{"def":"A constellation in the southern heavens between Hydra and the Southern Cross.","pos":""}],"CENTAUREA":[{"def":"A large genus of composite plants, related to the thistles and including the cornflower or bluebottle (Centaurea Cyanus) and the star thistle (C.","pos":""}],"CENTAUROMACHY":[{"def":"A fight in which centaurs take part, -- a common theme for relief sculpture, as in the Parthenon metopes.","pos":""}],"CENTAURY":[{"def":"A gentianaceous plant not fully identified.","pos":""}],"CENTENARIAN":[{"def":"Of or relating to a hundred years.","pos":""},{"def":"A person a hundred years old.","pos":""}],"CENTENARY":[{"def":"Relating to, or consisting of, a hundred.","pos":""},{"def":"Occurring once in every hundred years; centennial.","pos":""}],"CENTENNIAL":[{"def":"Relating to, or associated with, the commemoration of an event that happened a hundred years before; as, a centennial ode.","pos":""},{"def":"Happening once in a hundred years; as, centennial jubilee; a centennial celebration.","pos":""}],"CENTENNIAL STATE":[{"def":"Colorado; -- a nickname alluding to the fact that it was admitted to the Union in the centennial year, 1876.","pos":""}],"CENTENNIALLY":[{"def":"Once in a hundred years.","pos":""}],"CENTER":[{"def":"A temporary structure upon which the materials of a vault or arch are supported in position util the work becomes self-supporting.","pos":""},{"def":"To form a recess or indentation for the reception of a center.","pos":""}],"CENTERFIRE CARTRIDGE":[{"def":"See under Cartridge.","pos":""}],"CENTERING":[{"def":"Same as Center, n.","pos":""},{"def":"An ornament to be placed in the center, as of a table, ceiling, atc.","pos":""}],"CENTESIMAL":[{"def":"A hundredth part.","pos":""}],"CENTESIMATION":[{"def":"The infliction of the death penalty upon one person in every hundred, as in cases of mutiny.","pos":""}],"CENTESIMO":[{"def":"A copper coin of Italy and Spain equivalent to a centime.","pos":""}],"CENTIFIDOUS":[{"def":"Divided into a hundred parts.","pos":""}],"CENTIFOLIOUS":[{"def":"Having a hundred leaves.","pos":""}],"CENTIGRADE":[{"def":"Consisting of a hundred degrees; graduated into a hundred divisions or equal parts.","pos":""},{"def":"The hundredth part of a gram; a weight equal to .","pos":""}],"CENTILOQUY":[{"def":"A work divided into a hundred parts.","pos":""}],"CENTIME":[{"def":"The hundredth part of a franc; a small French copper coin and money of account.","pos":""},{"def":"The hundredth part of a meter; a measure of length equal to rather more than thirty-nine hundredths (0.","pos":""}],"CENTINODY":[{"def":"A weed with a sterm of many joints (Illecebrum verticillatum); also, the Polygonum aviculare or knotgrass.","pos":""}],"CENTIPED":[{"def":"A species of the Myriapoda; esp.","pos":""}],"CENTISTERE":[{"def":"The hundredth part of a stere, equal to .","pos":""}],"CENTNER":[{"def":"A weight divisible first into a hundred parts, and then into smaller parts.","pos":""}],"CENTO":[{"def":"A literary or a musical composition formed by selections from different authors disposed in a new order.","pos":""}],"CENTONISM":[{"def":"The composition of a cento; the act or practice of composing a cento or centos.","pos":""}],"CENTRAL":[{"def":"Relating to the center; situated in or near the center or middle; containing the center; of or pertaining to the parts near the center; equidistant or equally accessible from certain points.","pos":""},{"def":"The central, or one of the central, bones of the carpus or or tarsus.","pos":""}],"CENTRALISM":[{"def":"The state or condition of being central; the combination of several parts into one whole; centralization.","pos":""},{"def":"The system by which power is centralized, as in a government.","pos":""}],"CENTRALITY":[{"def":"The state of being central; tendency towards a center.","pos":""}],"CENTRALIZATION":[{"def":"The act or process of centralizing, or the state of being centralized; the act or process of combining or reducing several parts into a whole; as, the centralization of power in the general government; the centralization of commerce in a city.","pos":""}],"CENTRALIZE":[{"def":"To draw or bring to a center point; to gather into or about a center; to bring into one system, or under one control.","pos":""}],"CENTRALLY":[{"def":"In a central manner or situation.","pos":""}],"CENTRE":[{"def":"Placed in the center or middle; central.","pos":""}],"CENTRICITY":[{"def":"The state or quality of being centric; centricalness.","pos":""}],"CENTRIFUGAL":[{"def":"Tending, or causing, to recede from the center.","pos":""}],"CENTRIFUGAL FILTER":[{"def":"A filter, as for sugar, in which a cylinder with a porous or foraminous periphery is rapidly rotated so as to drive off liquid by centrifugal action.","pos":""}],"CENTRIFUGENCE":[{"def":"The property or quality of being centrifugal.","pos":""}],"CENTRIPETAL":[{"def":"Tending, or causing, to approach the center.","pos":""},{"def":"Progressing by changes from the exterior of a thing toward its center; as, the centripetal calcification of a bone.","pos":""}],"CENTRIPETENCY":[{"def":"Tendency toward the center.","pos":""}],"CENTRISCOID":[{"def":"Allied to, or resembling, the genus Centriscus, of which the bellows fish is an example.","pos":""}],"CENTROBARIC":[{"def":"Relating to the center of gravity, or to the process of finding it.","pos":""}],"CENTRODE":[{"def":"In two figures having relative motion, one of the two curves which are the loci of the instantaneous center.","pos":""}],"CENTROID":[{"def":"The center of mass, inertia, or gravity of a body or system of bodies.","pos":""}],"CENTROLECITHAL":[{"def":"Having the food yolk placed at the center of the ovum, segmentation being either regular or unequal.","pos":""}],"CENTROLINEAD":[{"def":"An instrument for drawing lines through a point, or lines converging to a center.","pos":""}],"CENTROLINEAL":[{"def":"Converging to a center; -- applied to lines drawn so as to meet in a point or center.","pos":""}],"CENTROSOME":[{"def":"A peculiar rounded body lying near the nucleus of a cell.","pos":""}],"CENTROSPHERE":[{"def":"The nucleus or central part of the earth, forming most of its mass; -- disting.","pos":""}],"CENTROSTALTIC":[{"def":"A term applied to the action of nerve force in the spinal center.","pos":""}],"CENTRUM":[{"def":"The body, or axis, of a vertebra.","pos":""}],"CENTUMVIR":[{"def":"One of a court of about one hundred judges chosen to try civil suits.","pos":""}],"CENTUMVIRAL":[{"def":"Of or pertaining to the centumviri, or to a centumvir.","pos":""}],"CENTUMVIRATE":[{"def":"The office of a centumvir, or of the centumviri.","pos":""}],"CENTUPLE":[{"def":"To increase a hundredfold.","pos":""}],"CENTUPLICATE":[{"def":"To make a hundredfold; to repeat a hundred times.","pos":""}],"CENTURIAL":[{"def":"Of or pertaining to a century; as, a centurial sermon.","pos":""}],"CENTURIATE":[{"def":"Pertaining to, or divided into, centuries or hundreds.","pos":""}],"CENTURION":[{"def":"A military officer who commanded a minor division of the Roman army; a captain of a century.","pos":""}],"CENTURY":[{"def":"A hundred; as, a century of sonnets; an aggregate of a hundred things.","pos":""},{"def":"A period of a hundred years; as, this event took place over two centuries ago.","pos":""}]}