{"AGAIN":[{"def":"Against; also, towards (in order to meet).","pos":""}],"AGAINST":[{"def":"Abreast; opposite to; facing; towards; as, against the mouth of a river; -- in this sense often preceded by over.","pos":""},{"def":"From an opposite direction so as to strike or come in contact with; in contact with; upon; as, hail beats against the roof.","pos":""}],"AGAINWARD":[{"def":"Failure of the due secretion of milk after childbirth.","pos":""}],"AGAL-AGAL":[{"def":"Same as Agar-agar.","pos":""},{"def":"A soft, resinous wood (Aquilaria Agallocha) of highly aromatic smell, burnt by the orientals as a perfume.","pos":""}],"AGALACTOUS":[{"def":"Lacking milk to suckle with.","pos":""}],"AGALMATOLITE":[{"def":"A soft, compact stone, of a grayish, greenish, or yellowish color, carved into images by the Chinese, and hence called figure stone, and pagodite.","pos":""}],"AGAMA":[{"def":"A genus of lizards, one of the few which feed upon vegetable substances; also, one of these lizards.","pos":""}],"AGAMI":[{"def":"A South American bird (Psophia crepitans), allied to the cranes, and easily domesticated; -- called also the gold-breasted trumpeter.","pos":""}],"AGAMICALLY":[{"def":"In an agamic manner.","pos":""}],"AGAMIST":[{"def":"An unmarried person; also, one opposed to marriage.","pos":""}],"AGAMOGENESIS":[{"def":"Reproduction without the union of parents of distinct sexes: asexual reproduction.","pos":""}],"AGAMOGENETIC":[{"def":"Reproducing or produced without sexual union.","pos":""}],"AGAMOUS":[{"def":"Having no visible sexual organs; asexual.","pos":""}],"AGANGLIONIC":[{"def":"Without ganglia.","pos":""}],"AGAPE":[{"def":"Gaping, as with wonder, expectation, or eager attention.","pos":""}],"AGAR-AGAR":[{"def":"A fucus or seaweed much used in the East for soups and jellies; Ceylon moss (Gracilaria lichenoides).","pos":""}],"AGARIC":[{"def":"A fungus of the genus Agaricus, of many species, of which the common mushroom is an example.","pos":""}],"AGASP":[{"def":"In a state of gasping.","pos":""}],"AGAST":[{"def":"To affright; to terrify.","pos":""}],"AGASTRIC":[{"def":"Having to stomach, or distinct digestive canal, as the tapeworm.","pos":""}],"AGATE":[{"def":"On the way; agoing; as, to be agate; to set the bells agate.","pos":""}],"AGATIFEROUS":[{"def":"Containing or producing agates.","pos":""}],"AGATINE":[{"def":"Pertaining to, or like, agate.","pos":""}],"AGATIZE":[{"def":"To convert into agate; to make resemble agate.","pos":""}],"AGATY":[{"def":"Of the nature of agate, or containing agate.","pos":""}],"AGAVE":[{"def":"A genus of plants (order Amaryllidaceæ) of which the chief species is the maguey or century plant (A.","pos":""}],"AGAZED":[{"def":"Gazing with astonishment; amazed.","pos":""}]}