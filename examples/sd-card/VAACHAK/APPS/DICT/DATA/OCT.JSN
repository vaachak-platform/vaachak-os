{"OCTA-":[{"def":"A prefix meaning eight.","pos":""}],"OCTACHORD":[{"def":"An instrument of eight strings; a system of eight tones.","pos":""}],"OCTAD":[{"def":"An atom or radical which has a valence of eight, or is octavalent.","pos":""}],"OCTAEMERON":[{"def":"A fast of eight days before a great festival.","pos":""}],"OCTAGON":[{"def":"A plane figure of eight sides and eight angles.","pos":""}],"OCTAGONAL":[{"def":"Having eight sides and eight angles.","pos":""}],"OCTAGYNOUS":[{"def":"Having eight pistils or styles; octogynous.","pos":""}],"OCTAHEDRAL":[{"def":"Having eight faces or sides; of, pertaining to, or formed in, octahedrons; as, octahedral cleavage.","pos":""}],"OCTAHEDRITE":[{"def":"Titanium dioxide occurring in acute octahedral crystals.","pos":""}],"OCTAHEDRON":[{"def":"A solid bounded by eight faces.","pos":""}],"OCTAMEROUS":[{"def":"Having the parts in eights; as, an octamerous flower; octamerous mesenteries in polyps.","pos":""}],"OCTAMETER":[{"def":"A verse containing eight feet; as, -- Deep'' in|to'' the | dark''ness | peer''ing, | long'' I | stood'' there | wond'''ring, | fear''ing.","pos":""}],"OCTANDER":[{"def":"One of the Octandria.","pos":""}],"OCTANDRIA":[{"def":"A Linnæan class of plants, in which the flowers have eight stamens not united to one another or to the pistil.","pos":"noun"},{"def":"Of or pertaining to the Octandria; having eight distinct stamens.","pos":"noun"}],"OCTANE":[{"def":"Any one of a group of metametric hydrocarcons (C8H18) of the methane series.","pos":""}],"OCTANGULAR":[{"def":"Having eight angles; eight-angled.","pos":""}],"OCTANT":[{"def":"The eighth part of a circle; an arc of 45 degrees.","pos":""},{"def":"The position or aspect of a heavenly body, as the moon or a planet, when half way between conjunction, or opposition, and quadrature, or distant from another body 45 degrees.","pos":""}],"OCTAPLA":[{"def":"A portion of the Old Testament prepared by Origen in the 3d century, containing the Hebrew text and seven Greek versions of it, arranged in eight parallel columns.","pos":""}],"OCTATEUCH":[{"def":"A collection of eight books; especially, the first eight books of the Old Testament.","pos":""}],"OCTAVALENT":[{"def":"Having a valence of eight; capable of being combined with, exchanged for, or compared with, eight atoms of hydrogen; -- said of certain atoms or radicals.","pos":""}],"OCTAVE":[{"def":"The first two stanzas of a sonnet, consisting of four verses each; a stanza of eight lines.","pos":""}],"OCTAVO":[{"def":"A book composed of sheets each of which is folded into eight leaves; hence, indicating more or less definitely a size of book so made; -- usually written 8vo or 8º.","pos":""}],"OCTENE":[{"def":"Same as Octylene.","pos":""}],"OCTENNIAL":[{"def":"Happening every eighth year; also, lasting a period of eight years.","pos":""}],"OCTET":[{"def":"A composition for eight parts, usually for eight solo instruments or voices.","pos":""}],"OCTIC":[{"def":"Of the eighth degree or order.","pos":""},{"def":"A quantic of the eighth degree.","pos":""}],"OCTILE":[{"def":"Same as Octant, 2.","pos":""}],"OCTILLION":[{"def":"According to the French method of numeration (which method is followed also in the United States) the number expressed by a unit with twenty-seven ciphers annexed.","pos":""},{"def":"A combining form meaning eight; as in octodecimal, octodecimal, octolocular.","pos":""}],"OCTOATE":[{"def":"A salt of an octoic acid; a caprylate.","pos":""}],"OCTOBER":[{"def":"The tenth month of the year, containing thirty-one days.","pos":""},{"def":"Ale or cider made in that month.","pos":""}],"OCTOCERATA":[{"def":"A suborder of Cephalopoda including Octopus, Argonauta, and allied genera, having eight arms around the head; -- called also Octopoda.","pos":"noun"}],"OCTODECIMO":[{"def":"Having eighteen leaves to a sheet; as, an octodecimo form, book, leaf, size, etc.","pos":""}],"OCTODENTATE":[{"def":"Having eight teeth.","pos":""}],"OCTODONT":[{"def":"Of or pertaining to the Octodontidæ, a family of rodents which includes the coypu, and many other South American species.","pos":""}],"OCTOFID":[{"def":"Cleft or separated into eight segments, as a calyx.","pos":""}],"OCTOGAMY":[{"def":"A marrying eight times.","pos":""}],"OCTOGENARIAN":[{"def":"A person eighty years, or more, of age.","pos":""}],"OCTOGENARY":[{"def":"Of eighty years of age.","pos":""}],"OCTOGILD":[{"def":"A pecuniary compensation for an injury, of eight times the value of the thing.","pos":""}],"OCTOGYNIA":[{"def":"A Linnaean order of plants having eight pistils.","pos":"noun"},{"def":"Having eight pistils; octagynous.","pos":"noun"}],"OCTOIC":[{"def":"Pertaining to, derived from, or resembling, octane; -- used specifically, to designate any one of a group of acids, the most important of which is called caprylic acid.","pos":""}],"OCTOLOCULAR":[{"def":"Having eight cells for seeds.","pos":""}],"OCTONAPHTHENE":[{"def":"A colorless liquid hydrocarbon of the octylene series, occurring in Caucasian petroleum.","pos":""}],"OCTONARY":[{"def":"Of or pertaining to the number eight.","pos":""}],"OCTONOCULAR":[{"def":"Having eight eyes.","pos":""}],"OCTOPEDE":[{"def":"An animal having eight feet, as a spider.","pos":""}],"OCTOPETALOUS":[{"def":"Having eight petals or flower leaves.","pos":""}],"OCTOPOD":[{"def":"One of the Octocerata.","pos":""}],"OCTOPODIA":[{"def":"Same as Octocerata.","pos":"noun"}],"OCTOPUS":[{"def":"A genus of eight-armed cephalopods, including numerous species, some of them of large size.","pos":""}],"OCTORADIATED":[{"def":"Having eight rays.","pos":""}],"OCTOROON":[{"def":"The offspring of a quadroon and a white person; a mestee.","pos":""}],"OCTOSPERMOUS":[{"def":"Containing eight seeds.","pos":""}],"OCTOSTICHOUS":[{"def":"In eight vertical ranks, as leaves on a stem.","pos":""}],"OCTOSTYLE":[{"def":"Having eight columns in the front; -- said of a temple or portico.","pos":""},{"def":"An octostyle portico or temple.","pos":""}],"OCTOSYLLABLE":[{"def":"A word of eight syllables.","pos":""}],"OCTOYL":[{"def":"A hypothetical radical (C8H15O), regarded as the essential residue of octoic acid.","pos":""}],"OCTROI":[{"def":"A privilege granted by the sovereign authority, as the exclusive right of trade granted to a guild or society; a concession.","pos":""},{"def":"A tax levied in money or kind at the gate of a French city on articles brought within the walls.","pos":""}],"OCTYL":[{"def":"A hypothetical hydrocarbon radical regarded as an essential residue of octane, and as entering into its derivatives; as, octyl alcohol.","pos":""}],"OCTYLENE":[{"def":"Any one of a series of metameric hydrocarbons (C8H16) of the ethylene series.","pos":""}],"OCTYLIC":[{"def":"Pertaining to, derived from, or containing, octyl; as, octylic ether.","pos":""}]}