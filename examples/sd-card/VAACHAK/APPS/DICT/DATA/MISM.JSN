{"MISMAKE":[{"def":"To make or form amiss; to spoil in making.","pos":""}],"MISMANAGE":[{"def":"To manage ill or improperly; as, to mismanage public affairs.","pos":""}],"MISMANAGEMENT":[{"def":"Wrong or bad management; as, he failed through mismagement.","pos":""}],"MISMANAGER":[{"def":"One who manages ill.","pos":""}],"MISMARK":[{"def":"To mark wrongly.","pos":""}],"MISMATCH":[{"def":"To match unsuitably.","pos":""}],"MISMATE":[{"def":"To mate wrongly or unsuitably; as, to mismate gloves or shoes; a mismated couple.","pos":""}],"MISMEASURE":[{"def":"To measure or estimate incorrectly.","pos":""}],"MISMEASUREMENT":[{"def":"Wrong measurement.","pos":""}],"MISMETER":[{"def":"To give the wrong meter to, as to a line of verse.","pos":""}]}