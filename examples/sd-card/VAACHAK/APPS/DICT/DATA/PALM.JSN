{"PALM":[{"def":"The inner and somewhat concave part of the hand between the bases of the fingers and the wrist.","pos":""},{"def":"A metallic disk, attached to a strap, and worn the palm of the hand, -- used to push the needle through the canvas, in sewing sails, etc.","pos":""}],"PALM SUNDAY":[{"def":"The Sunday next before Easter; -- so called in commemoration of our Savior's triumphal entry into Jerusalem, when the multitude strewed palm branches in the way.","pos":""}],"PALMA CHRISTI":[{"def":"A plant (Ricinus communis) with ornamental peltate and palmately cleft foliage, growing as a woody perennial in the tropics, and cultivated as an herbaceous annual in temperate regions; -- called also castor-oil plant.","pos":""}],"PALMACEOUS":[{"def":"Of or pertaining to palms; of the nature of, or resembling, palms.","pos":""}],"PALMAR":[{"def":"Pertaining to, or corresponding with, the palm of the hand.","pos":""},{"def":"Of or pertaining to the under side of the wings of birds.","pos":""}],"PALMARIUM":[{"def":"One of the bifurcations of the brachial plates of a crinoid.","pos":""}],"PALMARY":[{"def":"Worthy of the palm; palmy; preëminent; superior; principal; chief; as, palmary work.","pos":""}],"PALMATE":[{"def":"Spreading from the apex of a petiole, as the divisions of a leaf, or leaflets, so as to resemble the hand with outspread fingers.","pos":""}],"PALMATELY":[{"def":"In a palmate manner.","pos":""}],"PALMATIFID":[{"def":"Palmate, with the divisions separated but little more than halfway to the common center.","pos":""}],"PALMATILOBED":[{"def":"Palmate, with the divisions separated less than halfway to the common center.","pos":""},{"def":"Divided, as a palmate leaf, down to the midrib, so that the parenchyma is interrupted.","pos":""}],"PALMCRIST":[{"def":"The palma Christi.","pos":""}],"PALMED":[{"def":"Having or bearing a palm or palms.","pos":""}],"PALMER":[{"def":"One who palms or cheats, as at cards or dice.","pos":""}],"PALMETTE":[{"def":"A floral ornament, common in Greek and other ancient architecture; -- often called the honeysuckle ornament.","pos":""}],"PALMETTO":[{"def":"A name given to palms of several genera and species growing in the West Indies and the Southern United States.","pos":""}],"PALMETTO FLAG":[{"def":"Any of several flags adopted by South California after its secession.","pos":""}],"PALMETTO STATE":[{"def":"South California; -- a nickname alluding to the State Arms, which contain a representation of a palmetto tree.","pos":""}],"PALMIC":[{"def":"Of, pertaining to, or derived from, the castor-oil plant (Ricinus communis, or Palma Christi); -- formerly used to designate an acid now called ricinoleic acid.","pos":""}],"PALMIDACTYLES":[{"def":"A group of wading birds having the toes webbed, as the avocet.","pos":""}],"PALMIGRADE":[{"def":"Putting the whole foot upon the ground in walking, as some mammals.","pos":""}],"PALMIPED":[{"def":"Web-footed, as a water fowl.","pos":""},{"def":"A swimming bird; a bird having webbed feet.","pos":""}],"PALMIPEDES":[{"def":"Same as Natatores.","pos":""}],"PALMISTER":[{"def":"One who practices palmistry Bp.","pos":""}],"PALMISTRY":[{"def":"The art or practice of divining or telling fortunes, or of judging of character, by the lines and marks in the palm of the hand; chiromancy.","pos":"noun"},{"def":"A dexterous use or trick of the hand.","pos":"noun"}],"PALMITATE":[{"def":"A salt of palmitic acid.","pos":""}],"PALMITE":[{"def":"A South African plant (Prionium Palmita) of the Rush family, having long serrated leaves.","pos":""}],"PALMITIC":[{"def":"Pertaining to, or obtained from, palmitin or palm oil; as, palmitic acid, a white crystalline body belonging to the fatty acid series.","pos":""}],"PALMITIN":[{"def":"A solid crystallizable fat, found abundantly in animals and in vegetables.","pos":""}],"PALMITOLIC":[{"def":"Pertaining to, or designating, an artificial acid of the oleic acid series, isomeric with linoleic acid.","pos":""}],"PALMITONE":[{"def":"The ketone of palmitic acid.","pos":""}],"PALMY":[{"def":"Bearing palms; abounding in palms; derived from palms; as, a palmy shore.","pos":""},{"def":"Worthy of the palm; flourishing; prosperous.","pos":""}],"PALMYRA":[{"def":"A species of palm (Borassus flabelliformis) having a straight, black, upright trunk, with palmate leaves.","pos":""}]}