{"VIOL":[{"def":"A stringed musical instrument formerly in use, of the same form as the violin, but larger, and having six strings, to be struck with a bow, and the neck furnished with frets for stopping the strings.","pos":""},{"def":"A large rope sometimes used in weighing anchor.","pos":""}],"VIOLA":[{"def":"A genus of polypetalous herbaceous plants, including all kinds of violets.","pos":""}],"VIOLABLE":[{"def":"Capable of being violated, broken, or injured.","pos":""}],"VIOLACEOUS":[{"def":"Of or pertaining to a natural order of plants, of which the violet is the type.","pos":""}],"VIOLANILINE":[{"def":"A dyestuff of the induline group, made from aniline, and used as a substitute for indigo in dyeing wool and silk a violet-blue or a gray-blue color.","pos":""}],"VIOLANTIN":[{"def":"A complex nitrogenous substance, produced as a yellow crystalline substance, and regarded as a complex derivative of barbituric acid.","pos":""}],"VIOLAQUERCITRIN":[{"def":"A yellow crystalline glucoside obtained from the pansy (Viola tricolor), and decomposing into glucose and quercitrin.","pos":""}],"VIOLATE":[{"def":"To treat in a violent manner; to abuse.","pos":""},{"def":"To do violence to, as to anything that should be held sacred or respected; to profane; to desecrate; to break forcibly; to trench upon; to infringe.","pos":""}],"VIOLATION":[{"def":"The act of violating, treating with violence, or injuring; the state of being violated.","pos":""}],"VIOLATIVE":[{"def":"Violating, or tending to violate.","pos":""}],"VIOLATOR":[{"def":"One who violates; an infringer; a profaner; a ravisher.","pos":""}],"VIOLENCE":[{"def":"The quality or state of being violent; highly excited action, whether physical or moral; vehemence; impetuosity; force.","pos":""},{"def":"Injury done to that which is entitled to respect, reverence, or observance; profanation; infringement; unjust force; outrage; assault.","pos":""}],"VIOLENT":[{"def":"Moving or acting with physical strength; urged or impelled with force; excited by strong feeling or passion; forcible; vehement; impetuous; fierce; furious; severe; as, a violent blow; the violent attack of a disease.","pos":""},{"def":"Acting, characterized, or produced by unjust or improper force; outrageous; unauthorized; as, a violent attack on the right of free speech.","pos":""}],"VIOLENTLY":[{"def":"In a violent manner.","pos":""}],"VIOLESCENT":[{"def":"Tending to a violet color; violascent.","pos":""}],"VIOLET":[{"def":"Any plant or flower of the genus Viola, of many species.","pos":""},{"def":"Any one of numerous species of small violet-colored butterflies belonging to Lycæna, or Rusticus, and allied genera.","pos":""}],"VIOLET-EAR":[{"def":"Any tropical humming bird of the genus Petasophora, having violet or purplish ear tufts.","pos":""}],"VIOLET-TIP":[{"def":"A very handsome American butterfly (Polygonia interrogationis).","pos":""}],"VIOLIN":[{"def":"A small instrument with four strings, played with a bow; a fiddle.","pos":""}],"VIOLINIST":[{"def":"A player on the violin.","pos":""}],"VIOLIST":[{"def":"A player on the viol.","pos":""}],"VIOLONCELLIST":[{"def":"A player on the violoncello.","pos":""}],"VIOLONCELLO":[{"def":"A stringed instrument of music; a bass viol of four strings, or a bass violin with long, large strings, giving sounds an octave lower than the viola, or tenor or alto violin.","pos":""}],"VIOLONE":[{"def":"The largest instrument of the bass-viol kind, having strings tuned an octave below those of the violoncello; the contrabasso; -- called also double bass.","pos":""}],"VIOLURIC":[{"def":"Of, pertaining to, or designating, a complex nitroso derivative of barbituric acid.","pos":""}]}