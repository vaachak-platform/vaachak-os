{"BAA":[{"def":"To cry baa, or bleat as a sheep.","pos":""}],"BAAING":[{"def":"The bleating of a sheep.","pos":""}],"BAAL":[{"def":"The supreme male divinity of the Phoenician and Canaanitish nations.","pos":""},{"def":"The whole class of divinities to whom the name Baal was applied.","pos":""}],"BAALISM":[{"def":"Worship of Baal; idolatry.","pos":""},{"def":"A worshiper of Baal; a devotee of any false religion; an idolater.","pos":""}]}