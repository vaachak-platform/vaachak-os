{"CURE":[{"def":"Care, heed, or attention.","pos":""},{"def":"Spiritual charge; care of soul; the office of a parish priest or of a curate; hence, that which is committed to the charge of a parish priest or of a curate; a curacy; as, to resign a cure; to obtain a cure.","pos":""}],"CUREALL":[{"def":"Cure\"*all` (kr\"l`), n.","pos":""}],"CURELESS":[{"def":"Incapable of cure; incurable.","pos":""}],"CURER":[{"def":"One who cures; a healer; a physician.","pos":""},{"def":"One who prepares beef, fish, etc.","pos":""}],"CURETTE":[{"def":"A scoop or ring with either a blunt or a cutting edge, for removing substances from the walls of a cavity, as from the eye, ear, or womb.","pos":"noun"}]}