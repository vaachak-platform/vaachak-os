{"PREFACE":[{"def":"The prelude or introduction to the canon of the Mass.","pos":""}],"PREFACER":[{"def":"The writer of a preface.","pos":""}],"PREFATORILY":[{"def":"In a prefatory manner; by way of preface.","pos":""}],"PREFATORY":[{"def":"Pertaining to, or of the nature of, a preface; introductory to a book, essay, or discourse; as, prefatory remarks.","pos":""}],"PREFECT":[{"def":"A Roman officer who controlled or superintended a particular command, charge, department, etc.","pos":""},{"def":"A superintendent of a department who has control of its police establishment, together with extensive powers of municipal regulation.","pos":""}],"PREFECTORIAL":[{"def":"Of or pertaining to a prefect.","pos":""}],"PREFECTSHIP":[{"def":"The office or jurisdiction of a prefect.","pos":""}],"PREFECTURE":[{"def":"The office, position, or jurisdiction of a prefect; also, his official residence.","pos":""}],"PREFECUNDATION":[{"def":"A term collectively applied to the changes or conditions preceding fecundation, especially to the changes which the ovum undergoes before fecundation.","pos":""}],"PREFECUNDATORY":[{"def":"Of or pertaining to prefecundation.","pos":""}],"PREFER":[{"def":"To carry or bring (something) forward, or before one; hence, to bring for consideration, acceptance, judgment, etc.","pos":""},{"def":"To go before, or be before, in estimation; to outrank; to surpass.","pos":""}],"PREFERABILITY":[{"def":"The quality or state of being preferable; preferableness.","pos":""}],"PREFERABLE":[{"def":"Worthy to be preferred or chosen before something else; more desirable; as, a preferable scheme.","pos":""}],"PREFERABLENESS":[{"def":"The quality or state of being preferable.","pos":""}],"PREFERABLY":[{"def":"In preference; by choice.","pos":""}],"PREFERENCE":[{"def":"The act of Preferring, or the state of being preferred; the setting of one thing before another; precedence; higher estimation; predilection; choice; also, the power or opportunity of choosing; as, to give him his preference.","pos":""}],"PREFERENTIAL":[{"def":"Giving, indicating, or having a preference or precedence; as, a preferential claim; preferential shares.","pos":""}],"PREFERMENT":[{"def":"The act of choosing, or the state of being chosen; preference.","pos":""},{"def":"The act of preferring, or advancing in dignity or office; the state of being advanced; promotion.","pos":""}],"PREFERRER":[{"def":"One who prefers.","pos":""}],"PREFIDENCE":[{"def":"The quality or state of being prefident.","pos":""}],"PREFIDENT":[{"def":"Trusting beforehand; hence, overconfident.","pos":""}],"PREFIGURATION":[{"def":"The act of prefiguring, or the state of being prefigured.","pos":""}],"PREFIGURATIVE":[{"def":"Showing by prefiguration.","pos":""}],"PREFIGURE":[{"def":"To show, suggest, or announce, by antecedent types and similitudes; to foreshadow.","pos":""}],"PREFIGUREMENT":[{"def":"The act of prefiguring; prefiguration; also, that which is prefigured.","pos":""}],"PREFINE":[{"def":"To limit beforehand.","pos":""}],"PREFINITION":[{"def":"Previous limitation.","pos":""}],"PREFIX":[{"def":"To put or fix before, or at the beginning of, another thing; as, to prefix a syllable to a word, or a condition to an agreement.","pos":""},{"def":"To set or appoint beforehand; to settle or establish antecedently.","pos":""}],"PREFIXION":[{"def":"The act of prefixing.","pos":""}],"PREFORM":[{"def":"To form beforehand, or for special ends.","pos":""}],"PREFORMATION":[{"def":"An old theory of the preëxistence of germs.","pos":""}],"PREFORMATIVE":[{"def":"A formative letter at the beginning of a word.","pos":""}],"PREFRONTAL":[{"def":"Situated in front of the frontal bone, or the frontal region of the skull; ectethmoid, as a certain bone in the nasal capsule of many animals, and certain scales of reptiles and fishes.","pos":""},{"def":"A prefrontal bone or scale.","pos":""}],"PREFULGENCY":[{"def":"Superior brightness or effulgency.","pos":""}]}