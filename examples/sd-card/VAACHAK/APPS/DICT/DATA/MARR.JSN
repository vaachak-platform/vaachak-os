{"MARRAM":[{"def":"A coarse grass found on sandy beaches (Ammophila arundinacea).","pos":""}],"MARRER":[{"def":"One who mars or injures.","pos":""}],"MARRIAGE":[{"def":"The act of marrying, or the state of being married; legal union of a man and a woman for life, as husband and wife; wedlock; matrimony.","pos":""},{"def":"The marriage vow or contract.","pos":""}],"MARRIAGEABILITY":[{"def":"The quality or state of being marriageable.","pos":""}],"MARRIAGEABLE":[{"def":"Fit for, or capable of, marriage; of an age at which marriage is allowable.","pos":""}],"MARRIED":[{"def":"Being in the state of matrimony; wedded; as, a married man or woman.","pos":""},{"def":"Of or pertaining to marriage; connubial; as, the married state.","pos":""}],"MARRIER":[{"def":"One who marries.","pos":""}],"MARRON":[{"def":"A paper or pasteboard box or shell, wound about with strong twine, filled with an explosive, and ignited with a fuse, -- used to make a noise like a cannon.","pos":""}],"MARROON":[{"def":"Same as 1st Maroon.","pos":""}],"MARROW":[{"def":"The tissue which fills the cavities of most bones; the medulla.","pos":""},{"def":"One of a pair; a match; a companion; an intimate associate.","pos":""}],"MARROWBONE":[{"def":"A bone containing marrow; pl.","pos":""}],"MARROWFAT":[{"def":"A rich but late variety of pea.","pos":""}],"MARROWISH":[{"def":"Of the nature of, or like, marrow.","pos":""}],"MARROWLESS":[{"def":"Destitute of marrow.","pos":""}],"MARROWY":[{"def":"Full of marrow; pithy.","pos":""}],"MARRUBIUM":[{"def":"A genus of bitter aromatic plants, sometimes used in medicine; hoarhound.","pos":""}],"MARRY":[{"def":"To unite in wedlock or matrimony; to perform the ceremony of joining, as a man and a woman, for life; to constitute (a man and a woman) husband and wife according to the laws or customs of the place.","pos":""},{"def":"To join according to law, (a man) to a woman as his wife, or (a woman) to a man as her husband.","pos":""}]}