{"CAUCASIAN":[{"def":"Of or pertaining to the Caucasus, a mountainous region between the Black and Caspian seas.","pos":""},{"def":"Of or pertaining to the white races of mankind, of whom the people about Mount Caucasus were formerly taken as the type.","pos":""}],"CAUCUS":[{"def":"A meeting, especially a preliminary meeting, of persons belonging to a party, to nominate candidates for public office, or to select delegates to a nominating convention, or to confer regarding measures of party policy; a political primary meeting.","pos":""}],"CAUDA GALLI":[{"def":"A plume-shaped fossil, supposed to be a seaweed, characteristic of the lower Devonian rocks; as, the cauda galli grit.","pos":""}],"CAUDAD":[{"def":"Backwards; toward the tail or posterior part.","pos":""}],"CAUDAL":[{"def":"Of the nature of, or pertaining to, a tail; having a tail-like appendage.","pos":""}],"CAUDATA":[{"def":"Having a taill; having a termination like a tail.","pos":""}],"CAUDEX":[{"def":"The sterm of a tree.","pos":""},{"def":"A slender, elastic process, to which the masses of pollen in orchidaceous plants are attached.","pos":""}],"CAUDLE":[{"def":"A kind of warm drink for sick persons, being a mixture of wine with eggs, bread, sugar, and spices.","pos":""}],"CAUF":[{"def":"A chest with holes for keeping fish alive in water.","pos":""}],"CAUFLE":[{"def":"A gung of slaves.","pos":""}],"CAUGHT":[{"def":"See Cawk, Calker.","pos":""}],"CAUL":[{"def":"The fold of membrane loaded with fat, which covers more or less of the intestines in mammals; the great omentum See Omentum.","pos":""}],"CAULESCENT":[{"def":"Having a leafy stem.","pos":""}],"CAULICLE":[{"def":"A short caulis or stem, esp.","pos":""}],"CAULICULUS":[{"def":"In the Corinthian capital, one of the eight stalks rising out of the lower leafage and terminating in leaves which seem to suport the volutes.","pos":""}],"CAULIFLOWER":[{"def":"An annual variety of Brassica oleracea, or cabbage of which the cluster of young flower stalks and buds is eaten as a vegetable.","pos":""}],"CAULIFORM":[{"def":"Having the form of a caulis.","pos":""}],"CAULINE":[{"def":"Growing immediately on a caulis; of or pertaining to a caulis.","pos":""}],"CAULIS":[{"def":"An herbaceous or woody stem which bears leaves, and may bear flowers.","pos":""}],"CAULOCARPOUS":[{"def":"Having stems which bear flowers and fruit year after year, as most trees and shrubs.","pos":""}],"CAULOME":[{"def":"A stem structure or stem axis of a plant, viewed as a whole.","pos":""}],"CAUMA":[{"def":"Great heat, as of the body in fever.","pos":""}],"CAUPONIZE":[{"def":"To sell wine or victuals.","pos":""}],"CAUSABLE":[{"def":"Capable of being caused.","pos":""}],"CAUSAL":[{"def":"Relating to a cause or causes; inplying or containing a cause or causes; expressing a cause; causative.","pos":""}],"CAUSALITY":[{"def":"The faculty of tracing effects to their causes.","pos":""}],"CAUSALLY":[{"def":"According to the order or series of causes; by tracing effects to causes.","pos":""}],"CAUSATION":[{"def":"The act of causing; also the act or agency by which an effect is produced.","pos":""}],"CAUSATIONIST":[{"def":"One who believes in the law of universal causation.","pos":""}],"CAUSATIVE":[{"def":"Effective, as a cause or agent; causing.","pos":""},{"def":"Expressing a cause or reason; causal; as, the ablative is a causative case.","pos":""}],"CAUSATIVELY":[{"def":"In a causative manner.","pos":""}],"CAUSE":[{"def":"A suit or action in court; any legal process by which a party endeavors to obtain his claim, or what he regards as his right; case; ground of action.","pos":""}],"CAUSELESS":[{"def":"Without just or sufficient reason; groundless.","pos":""}],"CAUSELESSNESS":[{"def":"The state of being causeless.","pos":""}],"CAUSER":[{"def":"One who or that which causes.","pos":""}],"CAUSERIE":[{"def":"Informal talk or discussion, as about literary matters; light conversation; chat.","pos":""}],"CAUSEUSE":[{"def":"A kind of sofa for two person.","pos":""},{"def":"A way or road rasid above the natural level of the ground, serving as a dry passage over wet or marshy ground.","pos":""}],"CAUSIDICAL":[{"def":"Pertaining to an advocate, or to the maintenance and defense of suits.","pos":""}],"CAUSTIC":[{"def":"A caustic curve or caustic surface.","pos":""}],"CAUSTICALLY":[{"def":"In a caustic manner.","pos":""}],"CAUSTICILY":[{"def":"The quality of being caustic; corrosiveness; as, the causticity of potash.","pos":""},{"def":"Severity of language; sarcasm; as, the causticity of a reply or remark.","pos":""}],"CAUSTICNESS":[{"def":"The quality of being caustic; causticity.","pos":""}],"CAUTEL":[{"def":"Caution; prudence; wariness.","pos":""},{"def":"Craft; deceit; falseness.","pos":""}],"CAUTELOUS":[{"def":"Caution; prudent; wary.","pos":""},{"def":"Crafty; deceitful; false.","pos":""}],"CAUTER":[{"def":"A hot iron for searing or cauterizing.","pos":""}],"CAUTERANT":[{"def":"A cauterizing substance.","pos":""}],"CAUTERISM":[{"def":"The use or application of a caustic; cautery.","pos":""}],"CAUTERIZATION":[{"def":"The act of searing some morbid part by the application of a cautery or caustic; also, the effect of such application.","pos":""}],"CAUTERIZE":[{"def":"To burn or sear with a cautery or caustic.","pos":""},{"def":"To sear, as the conscience.","pos":""}],"CAUTERY":[{"def":"A burning or searing, as of morbid flesh, with a hot iron, or by application of a caustic that will burn, corrode, or destroy animal tissue.","pos":""}],"CAUTION":[{"def":"A careful attention to the probable effects of an act, in order that failure or harm may be avoided; prudence in regard to danger; provident care; wariness.","pos":""},{"def":"Security; guaranty; bail.","pos":""}],"CAUTIONARY":[{"def":"Conveying a caution, or warning to avoid danger; as, cautionary signals.","pos":""},{"def":"Given as a pledge or as security.","pos":""}],"CAUTIONARY BLOCK":[{"def":"A block in which two or more trains are permitted to travel, under restrictions imposed by a caution card or the like.","pos":""}],"CAUTIONER":[{"def":"A surety or sponsor.","pos":""}],"CAUTIOUS":[{"def":"Attentive to examine probable effects and consequences of acts with a view to avoid danger or misfortune; prudent; circumspect; wary; watchful; as, a cautious general.","pos":""}],"CAUTIOUSLY":[{"def":"In a cautious manner.","pos":""}],"CAUTIOUSNESS":[{"def":"The quality of being cautious.","pos":""}]}