{"ABOARD":[{"def":"On board; into or within a ship or boat; hence, into or within a railway car.","pos":""}],"ABODANCE":[{"def":"An omen; a portending.","pos":""}],"ABODE":[{"def":"Act of waiting; delay.","pos":""},{"def":"Stay or continuance in a place; sojourn.","pos":""}],"ABODEMENT":[{"def":"A foreboding; an omen.","pos":""}],"ABOLISH":[{"def":"To do away with wholly; to annul; to make void; -- said of laws, customs, institutions, governments, etc.","pos":""},{"def":"To put an end to, or destroy, as a physical objects; to wipe out.","pos":""}],"ABOLISHABLE":[{"def":"Capable of being abolished.","pos":""}],"ABOLISHER":[{"def":"One who abolishes.","pos":""}],"ABOLISHMENT":[{"def":"The act of abolishing; abolition; destruction.","pos":""}],"ABOLITION":[{"def":"The act of abolishing, or the state of being abolished; an annulling; abrogation; utter destruction; as, the abolition of slavery or the slave trade; the abolition of laws, decrees, ordinances, customs, taxes, debts, etc.","pos":""}],"ABOLITIONISM":[{"def":"The principles or measures of abolitionists.","pos":""}],"ABOLITIONIST":[{"def":"A person who favors the abolition of any institution, especially negro slavery.","pos":""}],"ABOLITIONIZE":[{"def":"To imbue with the principles of abolitionism.","pos":""}],"ABOMA":[{"def":"A large South American serpent (Boa aboma).","pos":""},{"def":"The fourth or digestive stomach of a ruminant, which leads from the third stomach omasum.","pos":""}],"ABOMINABLE":[{"def":"Worthy of, or causing, abhorrence, as a thing of evil omen; odious in the utmost degree; very hateful; detestable; loathsome; execrable.","pos":""},{"def":"Excessive; large; -- used as an intensive.","pos":""}],"ABOMINABLENESS":[{"def":"The quality or state of being abominable; odiousness.","pos":""}],"ABOMINABLY":[{"def":"In an abominable manner; very odiously; detestably.","pos":""}],"ABOMINATE":[{"def":"To turn from as ill-omened; to hate in the highest degree, as if with religious dread; loathe; as, to abominate all impiety.","pos":""}],"ABOMINATION":[{"def":"The feeling of extreme disgust and hatred; abhorrence; detestation; loathing; as, he holds tobacco in abomination.","pos":""},{"def":"That which is abominable; anything hateful, wicked, or shamefully vile; an object or state that excites disgust and hatred; a hateful or shameful vice; pollution.","pos":""}],"ABOON":[{"def":"Aboon the pass of Bally-Brough.","pos":""}],"ABORAL":[{"def":"Situated opposite to, or away from, the mouth.","pos":""}],"ABORD":[{"def":"Manner of approaching or accosting; address.","pos":""}],"ABORIGINAL":[{"def":"First; original; indigenous; primitive; native; as, the aboriginal tribes of America.","pos":""},{"def":"Of or pertaining to aborigines; as, a Hindoo of aboriginal blood.","pos":""}],"ABORIGINALITY":[{"def":"The quality of being aboriginal.","pos":""}],"ABORIGINALLY":[{"def":"Ab`o*rig\"i*nal*ly, adv.","pos":""}],"ABORIGINES":[{"def":"The earliest known inhabitants of a country; native races.","pos":""}],"ABORSEMENT":[{"def":"Abortment; abortion.","pos":""}],"ABORT":[{"def":"To become checked in normal development, so as either to remain rudimentary or shrink away wholly; to become sterile.","pos":""}],"ABORTED":[{"def":"Rendered abortive or sterile; undeveloped; checked in normal development at a very early stage; as, spines are aborted branches.","pos":""}],"ABORTICIDE":[{"def":"The act of destroying a fetus in the womb; feticide.","pos":""}],"ABORTIFACIENT":[{"def":"Producing miscarriage.","pos":""},{"def":"A drug or an agent that causes premature delivery.","pos":""}],"ABORTION":[{"def":"Arrest of development of any organ, so that it remains an imperfect formation or is absorbed.","pos":""}],"ABORTIONAL":[{"def":"Pertaining to abortion; miscarrying; abortive.","pos":""}],"ABORTIONIST":[{"def":"One who procures abortion or miscarriage.","pos":""}],"ABORTIVE":[{"def":"Imperfectly formed or developed; rudimentary; sterile; as, an abortive organ, stamen, ovule, etc.","pos":""}],"ABORTIVELY":[{"def":"In an abortive or untimely manner; immaturely; fruitlessly.","pos":""}],"ABORTIVENESS":[{"def":"The quality of being abortive.","pos":""}],"ABOUND":[{"def":"To be in great plenty; to be very prevalent; to be plentiful.","pos":""},{"def":"To be copiously supplied; -- followed by in or with.","pos":""}],"ABOUT":[{"def":"On the point or verge of; going; in act of.","pos":""}],"ABOUT-SLEDGE":[{"def":"The largest hammer used by smiths.","pos":""}],"ABOVE":[{"def":"In or to a higher place; higher than; on or over the upper surface; over; -- opposed to below or beneath.","pos":""},{"def":"Figuratively, higher than; superior to in any respect; surpassing; beyond; higher in measure or degree than; as, things above comprehension; above mean actions; conduct above reproach.","pos":""}],"ABOVE-CITED":[{"def":"Cited before, in the preceding part of a book or writing.","pos":""}],"ABOVEBOARD":[{"def":"Above the board or table.","pos":""}],"ABOVEDECK":[{"def":"On deck; and hence, like aboveboard, without artifice.","pos":""},{"def":"Mentioned or named before; aforesaid.","pos":""}],"ABOVESAID":[{"def":"Mentioned or recited before.","pos":""}]}