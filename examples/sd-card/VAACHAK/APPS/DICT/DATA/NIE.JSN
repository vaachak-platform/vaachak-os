{"NIECE":[{"def":"A relative, in general; especially, a descendant, whether male or female; a granddaughter or a grandson.","pos":""},{"def":"A daughter of one's brother or sister, or of one's brother-in-law or sister-in-law.","pos":""}],"NIEF":[{"def":"See Neif, the fist.","pos":""}],"NIELLIST":[{"def":"One who practices the style of ornamentation called niello.","pos":""}],"NIELLO":[{"def":"A metallic alloy of a deep black color.","pos":""},{"def":"The art, process, or method of decorating metal with incised designs filled with the black alloy.","pos":""}],"NIEPCE'S PROCESS":[{"def":"A process, now no longer used, invented by J.","pos":""}]}