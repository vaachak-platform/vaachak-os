{"RECIDIVATE":[{"def":"To baskslide; to fall again.","pos":""}],"RECIDIVATION":[{"def":"A falling back; a backsliding.","pos":""}],"RECIDIVISM":[{"def":"The state or quality of being recidivous; relapse, specif.","pos":""},{"def":"a falling back or relapse into prior criminal habits, esp.","pos":""}],"RECIDIVIST":[{"def":"One who is recidivous or is characterized by recidivism; an incorrigible criminal.","pos":""}],"RECIPE":[{"def":"A formulary or prescription for making some combination, mixture, or preparation of materials; a receipt; especially, a prescription for medicine.","pos":""}],"RECIPIANGLE":[{"def":"An instrument with two arms that are pivoted together at one end, and a graduated arc, -- used by military engineers for measuring and laying off angles of fortifications.","pos":""},{"def":"The quality or state of being recipient; a receiving; reception; receptiveness.","pos":""}],"RECIPIENT":[{"def":"A receiver; the person or thing that receives; one to whom, or that to which, anything is given or communicated; specifically, the receiver of a still.","pos":""}],"RECIPROCAL":[{"def":"Reflexive; -- applied to pronouns and verbs, but sometimes limited to such pronouns as express mutual action.","pos":""},{"def":"Used to denote different kinds of mutual relation; often with reference to the substitution of reciprocals for given quantities.","pos":""}],"RECIPROCALITY":[{"def":"The quality or condition of being reciprocal; reciprocalness.","pos":""}],"RECIPROCALLY":[{"def":"In the manner of reciprocals.","pos":""}],"RECIPROCALNESS":[{"def":"The quality or condition of being reciprocal; mutual return; alternateness.","pos":""}],"RECIPROCATE":[{"def":"To move forward and backward alternately; to recur in vicissitude; to act interchangeably; to alternate.","pos":""}],"RECIPROCATION":[{"def":"The act of reciprocating; interchange of acts; a mutual giving and returning; as, the reciprocation of kindness.","pos":""},{"def":"Alternate recurrence or action; as, the reciprocation of the sea in the flow and ebb of tides.","pos":""}],"RECIPROCITY":[{"def":"Mutual action and reaction.","pos":""},{"def":"Reciprocal advantages, obligations, or rights; reciprocation.","pos":""}],"RECIPROCORNOUS":[{"def":"Having horns turning backward and then forward, like those of a ram.","pos":""}],"RECISION":[{"def":"The act of cutting off.","pos":""}],"RECITAL":[{"def":"A vocal or instrumental performance by one person; -- distinguished from concert; as, a song recital; an organ, piano, or violin recital.","pos":""},{"def":"The formal statement, or setting forth, of some matter of fact in any deed or writing in order to explain the reasons on which the transaction is founded; the statement of matter in pleading introductory to some positive allegation.","pos":""}],"RECITATION":[{"def":"The rehearsal of a lesson by pupils before their instructor.","pos":""}],"RECITATIVE":[{"def":"A species of musical recitation in which the words are delivered in manner resembling that of ordinary declamation; also, a piece of music intended for such recitation; -- opposed to melisma.","pos":""}],"RECITE":[{"def":"To state in or as a recital.","pos":""}],"RECITER":[{"def":"One who recites; also, a book of extracts for recitation.","pos":""}]}