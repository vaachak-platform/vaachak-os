{"MEIBOMIAN":[{"def":"Of, pertaining to, or discovered by, Meibomius.","pos":""}],"MEINE":[{"def":"A family, including servants, etc.","pos":""},{"def":"Company; band; army.","pos":""}],"MEIONITE":[{"def":"A member of the scapolite, group, occuring in glassy crystals on Monte Somma, near Naples.","pos":""}],"MEIOSIS":[{"def":"Diminution; a species of hyperbole, representing a thing as being less than it really is.","pos":""}],"MEIOSTEMONOUS":[{"def":"Having fever stamens than the parts of the corolla.","pos":""}],"MEISTERSINGER":[{"def":"See Mastersinger.","pos":""}]}