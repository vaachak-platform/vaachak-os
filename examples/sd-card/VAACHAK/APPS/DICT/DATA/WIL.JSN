{"WILD":[{"def":"Hard to steer; -- said of a vessel.","pos":""}],"WILD-CAT":[{"def":"Running without control; running along the line without a train; as, a wild-cat locomotive.","pos":""}],"WILDED":[{"def":"An old garden plant escaped and wilded.","pos":""}],"WILDER":[{"def":"To bewilder; to perplex.","pos":""}],"WILDERING":[{"def":"A plant growing in a state of nature; especially, one which has run wild, or escaped from cultivation.","pos":""}],"WILDERMENT":[{"def":"The state of being bewildered; confusion; bewilderment.","pos":""}],"WILDERNESS":[{"def":"A tract of land, or a region, uncultivated and uninhabited by human beings, whether a forest or a wide, barren plain; a wild; a waste; a desert; a pathless waste of any kind.","pos":""},{"def":"A disorderly or neglected place.","pos":""}],"WILDFIRE":[{"def":"A composition of inflammable materials, which, kindled, is very hard to quench; Greek fire.","pos":""},{"def":"A sort of lightning unaccompanied by thunder.","pos":""}],"WILDGRAVE":[{"def":"A waldgrave, or head forest keeper.","pos":""}],"WILDING":[{"def":"A wild or uncultivated plant; especially, a wild apple tree or crab apple; also, the fruit of such a plant.","pos":""}],"WILDISH":[{"def":"Somewhat wild; rather wild.","pos":""}],"WILDLY":[{"def":"In a wild manner; without cultivation; with disorder; rudely; distractedly; extravagantly.","pos":""}],"WILDNESS":[{"def":"The quality or state of being wild; an uncultivated or untamed state; disposition to rove or go unrestrained; rudeness; savageness; irregularity; distraction.","pos":""}],"WILDWOOD":[{"def":"A wild or unfrequented wood.","pos":""}],"WILE":[{"def":"A trick or stratagem practiced for insnaring or deception; a sly, insidious; artifice; a beguilement; an allurement.","pos":""}],"WILEFUL":[{"def":"Full of wiles; trickish; deceitful.","pos":""}],"WILFLEY TABLE":[{"def":"An inclined percussion table, usually with longitudinal grooves in its surface, agitated by side blows at right angles to the flow of the pulp; -- so called after the inventor.","pos":""},{"def":"See Willful, Willfully, and Willfulness.","pos":""}],"WILINESS":[{"def":"The quality or state of being wily; craftiness; cunning; guile.","pos":""}],"WILL":[{"def":"The legal declaration of a person's mind as to the manner in which he would have his property or estate disposed of after his death; the written instrument, legally executed, by which a man makes disposition of his estate, to take effect after his death; testament; devise.","pos":""}],"WILL-O'-THE-WISP":[{"def":"See Ignis fatuus.","pos":""}],"WILLEMITE":[{"def":"A silicate of zinc, usually occurring massive and of a greenish yellow color, also in reddish crystals (troostite) containing manganese.","pos":""}],"WILLET":[{"def":"A large North American snipe (Symphemia semipalmata); -- called also pill-willet, will-willet, semipalmated tattler, or snipe, duck snipe, and stone curlew.","pos":""}],"WILLFUL":[{"def":"Of set purpose; self-determined; voluntary; as, willful murder.","pos":""},{"def":"Governed by the will without yielding to reason; obstinate; perverse; inflexible; stubborn; refractory; as, a willful man or horse.","pos":""}],"WILLIER":[{"def":"One who works at a willying machine.","pos":""}],"WILLING":[{"def":"Free to do or to grant; having the mind inclined; not opposed in mind; not choosing to refuse; disposed; not averse; desirous; consenting; complying; ready.","pos":""},{"def":"Received of choice, or without reluctance; submitted to voluntarily; chosen; desired.","pos":""}],"WILLINGLY":[{"def":"In a willing manner; with free will; without reluctance; cheerfully.","pos":""}],"WILLINGNESS":[{"def":"The quality or state of being willing; free choice or consent of the will; freedom from reluctance; readiness of the mind to do or forbear.","pos":""},{"def":"A whirlwind, or whirlwind squall, encountered in the Straits of Magellan.","pos":""}],"WILLOW":[{"def":"Any tree or shrub of the genus Salix, including many species, most of which are characterized often used as an emblem of sorrow, desolation, or desertion.","pos":""}],"WILLOW-HERB":[{"def":"A perennial herb (Epilobium spicatum) with narrow willowlike leaves and showy rose-purple flowers.","pos":""}],"WILLOW-THORN":[{"def":"A thorny European shrub (Hippophaë rhamnoides) resembling a willow.","pos":""}],"WILLOWED":[{"def":"Abounding with willows; containing willows; covered or overgrown with willows.","pos":""}],"WILLOWISH":[{"def":"Having the color of the willow; resembling the willow; willowy.","pos":""}],"WILLOWY":[{"def":"Abounding with willows.","pos":""},{"def":"Resembling a willow; pliant; flexible; pendent; drooping; graceful.","pos":""}],"WILLSOME":[{"def":"Willful; obstinate.","pos":""}],"WILLY":[{"def":"Same as 1st Willow, 2.","pos":""}],"WILLY NILLY":[{"def":"See Will I, nill I, etc.","pos":""}],"WILLYING":[{"def":"The process of cleansing wool, cotton, or the like, with a willy, or willow.","pos":""}],"WILNE":[{"def":"To wish; to desire.","pos":""}],"WILT":[{"def":"Wilt, Defn: 2d pers.","pos":""}],"WILTON CARPET":[{"def":"A kind of carpet woven with loops like the Brussels, but differing from it in having the loops cut so as to form an elastic velvet pile; -- so called because made originally at Wilton, England.","pos":""}],"WILY":[{"def":"Full of wiles, tricks, or stratagems; using craft or stratagem to accomplish a purpose; mischievously artful; subtle.","pos":""}]}