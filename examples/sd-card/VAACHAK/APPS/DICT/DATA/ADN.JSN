{"ADNASCENT":[{"def":"Growing to or on something else.","pos":""}],"ADNATE":[{"def":"Grown to congenitally.","pos":""},{"def":"Growing together; -- said only of organic cohesion of unlike parts.","pos":""}],"ADNATION":[{"def":"The adhesion or cohesion of different floral verticils or sets of organs.","pos":""}],"ADNOMINAL":[{"def":"Pertaining to an adnoun; adjectival; attached to a noun.","pos":""}],"ADNOUN":[{"def":"An adjective, or attribute.","pos":""}],"ADNUBILATED":[{"def":"Clouded; obscured.","pos":""}]}