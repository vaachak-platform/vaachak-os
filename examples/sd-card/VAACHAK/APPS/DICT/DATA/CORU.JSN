{"CORUNDUM":[{"def":"The earth alumina, as found native in a crystalline state, including sapphire, which is the fine blue variety; the oriental ruby, or red sapphire; the oriental amethyst, or purple sapphire; and adamantine spar, the hair-brown variety.","pos":""}],"CORUSCANT":[{"def":"Glittering in flashes; flashing.","pos":""}],"CORUSCATE":[{"def":"To glitter in flashes; to flash.","pos":""}],"CORUSCATION":[{"def":"A sudden flash or play of light.","pos":""},{"def":"A flash of intellectual brilliancy.","pos":""}]}