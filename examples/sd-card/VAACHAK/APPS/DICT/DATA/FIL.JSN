{"FILACEOUS":[{"def":"Composed of threads.","pos":""}],"FILACER":[{"def":"A former officer in the English Court of Common Pleas; -- so called because he filed the writs on which he made out process.","pos":""}],"FILAMENT":[{"def":"A thread or threadlike object or appendage; a fiber; esp.","pos":""}],"FILAMENTARY":[{"def":"Having the character of, or formed by, a filament.","pos":""}],"FILAMENTOID":[{"def":"Like a filament.","pos":""}],"FILAMENTOUS":[{"def":"Like a thread; consisting of threads or filaments.","pos":""}],"FILANDER":[{"def":"A species of kangaroo (Macropus Brunii), inhabiting New Guinea.","pos":""}],"FILANDERS":[{"def":"A disease in hawks, characterized by the presence of small threadlike worms, also of filaments of coagulated blood, from the rupture of a vein; -- called also backworm.","pos":""}],"FILAR":[{"def":"Of or pertaining to a thread or line; characterized by threads stretched across the field of view; as, a filar microscope; a filar micrometer.","pos":""}],"FILARIA":[{"def":"A genus of slender, nematode worms of many species, parasitic in various animals.","pos":""}],"FILARIAL":[{"def":"Of, pertaining to, or caused by, filariæ and allied parasitic worms.","pos":""}],"FILARIASIS":[{"def":"The presence of filariæ in the blood; infection with filariæ.","pos":""}],"FILASSE":[{"def":"Vegetable fiber, as jute or ramie, prepared for manufacture.","pos":""}],"FILATORY":[{"def":"A machine for forming threads.","pos":""}],"FILATURE":[{"def":"A drawing out into threads; hence, the reeling of silk from cocoons.","pos":""},{"def":"A reel for drawing off silk from cocoons; also, an establishment for reeling silk.","pos":""}],"FILBERT":[{"def":"The fruit of the Corylus Avellana or hazel.","pos":""}],"FILCH":[{"def":"To steal or take privily (commonly, that which is of little value); to pilfer.","pos":""}],"FILCHER":[{"def":"One who filches; a thief.","pos":""}],"FILCHINGLY":[{"def":"By pilfering or petty stealing.","pos":""}],"FILE":[{"def":"Course of thought; thread of narration.","pos":""}],"FILE CLOSER":[{"def":"A commissioned or noncommissioned officer posted in the rear of a line, or on the flank of a column, of soldiers, to rectify mistakes and insure steadiness and promptness in the ranks.","pos":""}],"FILEFISH":[{"def":"Any plectognath fish of the genera Monacanthus, Alutera, balistes, and allied genera; -- so called on account of the roughly granulated skin, which is sometimes used in place of sandpaper.","pos":""}],"FILER":[{"def":"One who works with a file.","pos":""}],"FILIAL":[{"def":"Of or pertaining to a son or daughter; becoming to a child in relation to his parents; as, filial obedience.","pos":""},{"def":"Bearing the relation of a child.","pos":""}],"FILIALLY":[{"def":"In a filial manner.","pos":""}],"FILIATE":[{"def":"To adopt as son or daughter; to establish filiation between.","pos":""}],"FILIATION":[{"def":"The assignment of a bastard child to some one as its ather; affiliation.","pos":""}],"FILIBUSTER":[{"def":"To act as a filibuster, or military freebooter.","pos":""},{"def":"To delay legislation, by dilatory motions or other artifices.","pos":""}],"FILIBUSTERISM":[{"def":"The characteristics or practices of a filibuster.","pos":""}],"FILICAL":[{"def":"Belonging to the Filices, r ferns.","pos":""}],"FILICIC":[{"def":"Pertaining to, or derived from, ferns; as, filicic acid.","pos":""}],"FILICIDE":[{"def":"The act of murdering a son or a daughter; also, parent who commits such a murder.","pos":""}],"FILICIFORM":[{"def":"Shaped like a fern or like the parts of a fern leaf.","pos":""}],"FILICOID":[{"def":"Fernlike, either in form or in the nature of the method of reproduction.","pos":""}],"FILIETY":[{"def":"The relation of a son to a father; sonship; -- the correlative of paternity.","pos":""}],"FILIFEROUS":[{"def":"Producing threads.","pos":""}],"FILIFORM":[{"def":"Having the shape of a thread or filament; as, the filiform papillæ of the tongue; a filiform style or peduncle.","pos":""}],"FILIGREE":[{"def":"Ornamental work, formerly with grains or breads, but now composed of fine wire and used chiefly in decorating gold and silver to which the wire is soldered, being arranged in designs frequently of a delicate and intricate arabesque pattern.","pos":""}],"FILIGREED":[{"def":"Adorned with filigree.","pos":""}],"FILING":[{"def":"A fragment or particle rubbed off by the act of filing; as, iron filings.","pos":""}],"FILIOQUE":[{"def":"The Latin for, \"and from the Son,\" equivalent to et filio, inserted by the third council of Toledo (a.","pos":""}],"FILIPENDULOUS":[{"def":"Suspended by, or strung upon, a thread; -- said of tuberous swellings in the middle or at the extremities of slender, threadlike rootlets.","pos":""}],"FILIPINO":[{"def":"A native of the Philippine Islands, specif.","pos":""}],"FILL":[{"def":"One of the thills or shafts of a carriage.","pos":""}],"FILLED CHEESE":[{"def":"An inferior kind of cheese made from skim milk with a fatty \"filling,\" such as oleomargarine or lard, to replace the fat removed in the cream.","pos":""}],"FILLER":[{"def":"One who, or that which, fills; something used for filling.","pos":""}],"FILLET":[{"def":"A piece of lean meat without bone; sometimes, a long strip rolled together and tied.","pos":""},{"def":"A concave filling in of a reëntrant angle where two surfaces meet, forming a rounded corner.","pos":""}],"FILLETING":[{"def":"The protecting of a joint, as between roof and parapet wall, with mortar, or cement, where flashing is employed in better work.","pos":""}],"FILLING":[{"def":"Prepared wort added to ale to cleanse it.","pos":""}],"FILLIP":[{"def":"To strike with the nail of the finger, first placed against the ball of the thumb, and forced from that position with a sudden spring; to snap with the finger.","pos":""},{"def":"To snap; to project quickly.","pos":""}],"FILLISTER":[{"def":"The rabbet on the outer edge of a sash bar to hold the glass and the putty.","pos":""},{"def":"A plane for making a rabbet.","pos":""}],"FILLY":[{"def":"A female foal or colt; a young mare.","pos":""}],"FILM":[{"def":"A thin skin; a pellicle; a membranous covering, causing opacity; hence, any thin, slight covering.","pos":""},{"def":"A slender thread, as that of a cobweb.","pos":""}],"FILMINESS":[{"def":"State of being filmy.","pos":""}],"FILMY":[{"def":"Composed of film or films.","pos":""}],"FILOPLUMACEOUS":[{"def":"Having the structure of a filoplume.","pos":""}],"FILOPLUME":[{"def":"A hairlike feather; a father with a slender scape and without a web in most or all of its length.","pos":""}],"FILOSE":[{"def":"Terminating in a threadlike process.","pos":""}],"FILOSELLE":[{"def":"A kind of silk thread less glossy than floss, and spun from coarser material.","pos":""}],"FILS":[{"def":"Son; -- sometimes used after a French proper name to distinguish a son from his father, as, Alexandre Dumas, fils.","pos":""}],"FILTER":[{"def":"Any porous substance, as cloth, paper, sand, or charcoal, through which water or other liquid may passed to cleanse it from the solid or impure matter held in suspension; a chamber or device containing such substance; a strainer; also, a similar device for purifying air.","pos":""}],"FILTH":[{"def":"Foul matter; anything that soils or defiles; dirt; nastiness.","pos":""},{"def":"Anything that sullies or defiles the moral character; corruption; pollution.","pos":""}],"FILTHILY":[{"def":"In a filthy manner; foully.","pos":""}],"FILTHINESS":[{"def":"The state of being filthy.","pos":""},{"def":"That which is filthy, or makes filthy; foulness; nastiness; corruption; pollution; impurity.","pos":""}],"FILTHY":[{"def":"Defiled with filth, whether material or moral; nasty; dirty; polluted; foul; impure; obscene.","pos":""}],"FILTRATE":[{"def":"To filter; to defecate; as liquid, by straining or percolation.","pos":""}],"FILTRATION":[{"def":"The act or process of filtering; the mechanical separation of a liquid from the undissolved particles floating in it.","pos":""},{"def":"Light summer hemp, that bears no seed.","pos":""}]}