{"POLIANITE":[{"def":"Manganese dioxide, occurring in tetragonal crystals nearly as hard as quartz.","pos":""}],"POLICATE":[{"def":"Same as Pollicate.","pos":""}],"POLICE":[{"def":"Military police, the body of soldiers detailed to preserve civil order and attend to sanitary arrangements in a camp or garrison.","pos":""}],"POLICE POWER":[{"def":"The inherent power of a government to regulate its police affairs.","pos":""}],"POLICED":[{"def":"Regulated by laws for the maintenance of peace and order, enforced by organized administration.","pos":""}],"POLICEMAN":[{"def":"A member of a body of police; a constable.","pos":""}],"POLICIAL":[{"def":"Relating to the police.","pos":""}],"POLICY":[{"def":"The settled method by which the government and affairs of a nation are, or may be, administered; a system of public or official administration, as designed to promote the external or internal prosperity of a state.","pos":""}],"POLING":[{"def":"The operation of dispersing worm casts over the walks with poles.","pos":""}],"POLISH":[{"def":"Of or pertaining to Poland or its inhabitants.","pos":""},{"def":"The language of the Poles.","pos":""}],"POLISHABLE":[{"def":"Capable of being polished.","pos":""}],"POLISHED":[{"def":"Made smooth and glossy, as by friction; hence, highly finished; refined; polite; as, polished plate; polished manners; polished verse.","pos":""}],"POLISHEDNESS":[{"def":"The quality of being polished.","pos":""}],"POLISHER":[{"def":"One who, or that which, polishes; also, that which is used in polishing.","pos":""}],"POLISHING":[{"def":"Pol\"ish*ing, Defn: a.","pos":""}],"POLISHMENT":[{"def":"The act of polishing, or the state of being polished.","pos":""}],"POLISSOIR":[{"def":"A polishing or grinding implement or instrument.","pos":""}],"POLITE":[{"def":"Smooth; polished.","pos":""},{"def":"Smooth and refined in behavior or manners; well bred; courteous; complaisant; obliging; civil.","pos":""}],"POLITELY":[{"def":"In a polished manner; so as to be smooth or glossy.","pos":""},{"def":"In a polite manner; with politeness.","pos":""}],"POLITENESS":[{"def":"High finish; smoothness; burnished elegance.","pos":""},{"def":"The quality or state of being polite; refinement of manners; urbanity; courteous behavior; complaisance; obliging attentions.","pos":""}],"POLITIC":[{"def":"Of or pertaining to polity, or civil government; political; as, the body politic.","pos":""},{"def":"Pertaining to, or promoting, a policy, especially a national policy; well-devised; adapted to its end, whether right or wrong; -- said of things; as, a politic treaty.","pos":""}],"POLITICAL":[{"def":"Having, or conforming to, a settled system of administration.","pos":""},{"def":"Of or pertaining to public policy, or to politics; relating to affairs of state or administration; as, a political writer.","pos":""}],"POLITICALISM":[{"def":"Zeal or party spirit in politics.","pos":""}],"POLITICALLY":[{"def":"In a political manner.","pos":""},{"def":"Politicly; artfully.","pos":""}],"POLITICASTER":[{"def":"A petty politician; a pretender in politics.","pos":""}],"POLITICIAN":[{"def":"One versed or experienced in the science of government; one devoted to politics; a statesman.","pos":""},{"def":"One primarily devoted to his own advancement in public office, or to the success of a political party; -- used in a depreciatory sense; one addicted or attached to politics as managed by parties (see Politics, 2); a schemer; an intriguer; as, a mere politician.","pos":""}],"POLITICIST":[{"def":"A political writer.","pos":""}],"POLITICLY":[{"def":"In a politic manner; sagaciously; shrewdly; artfully.","pos":""}],"POLITICS":[{"def":"When we say that two men are talking politics, we often mean that they are wrangling about some mere party question.","pos":""}],"POLITIZE":[{"def":"To play the politician; to dispute as politicians do.","pos":""}],"POLITY":[{"def":"The form or constitution of the civil government of a nation or state; the framework or organization by which the various departments of government are combined into a systematic whole.","pos":""},{"def":"Hence: The form or constitution by which any institution is organized; the recognized principles which lie at the foundation of any human institution.","pos":""}],"POLITZERIZATION":[{"def":"The act of inflating the middle ear by blowing air up the nose during the act of swallowing; -- so called from Prof.","pos":""}]}