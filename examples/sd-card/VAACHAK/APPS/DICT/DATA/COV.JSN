{"COVARIANT":[{"def":"A function involving the coefficients and the variables of a quantic, and such that when the quantic is lineally transformed the same function of the new variables and coefficients shall be equal to the old function multiplied by a factor.","pos":""}],"COVE":[{"def":"A retired nook; especially, a small, sheltered inlet, creek, or bay; a recess in the shore.","pos":""},{"def":"A strip of prairie extending into woodland; also, a recess in the side of a mountain.","pos":""}],"COVENABLE":[{"def":"Fit; proper; suitable.","pos":""}],"COVENABLY":[{"def":"Fitly; suitably.","pos":""}],"COVENANT":[{"def":"An agreement made by the Scottish Parliament in 1638, and by the English Parliament in 1643, to preserve the reformed religion in Scotland, and to extirpate popery and prelacy; -- usually called the \"Solemn League and Covenant.","pos":""},{"def":"The promises of God as revealed in the Scriptures, conditioned on certain terms on the part of man, as obedience, repentance, faith, etc.","pos":""}],"COVENANTEE":[{"def":"The person in whose favor a covenant is made.","pos":""}],"COVENANTER":[{"def":"One who subscribed and defended the \"Solemn League and Covenant.","pos":""}],"COVENANTING":[{"def":"Belonging to a covenant.","pos":""}],"COVENANTOR":[{"def":"The party who makes a covenant.","pos":""}],"COVENOUS":[{"def":"See Covinous, and Covin.","pos":""}],"COVENT":[{"def":"A convent or monastery.","pos":""}],"COVENTRY":[{"def":"A town in the county of Warwick, England.","pos":""}],"COVER":[{"def":"To overspread the surface of (one thing) with another; as, to cover wood with paint or lacquer; to cover a table with a cloth.","pos":""},{"def":"To envelop; to clothe, as with a mantle or cloak.","pos":""}],"COVER CROP":[{"def":"A catch crop planted, esp.","pos":""}],"COVER-POINT":[{"def":"The fielder in the games of cricket and lacrosse who supports \"point.","pos":""}],"COVER-SHAME":[{"def":"Something used to conceal infamy.","pos":""}],"COVERAGE":[{"def":"The aggregate of risks covered by the terms of a contract of insurance.","pos":""}],"COVERCHIEF":[{"def":"A covering for the head.","pos":""}],"COVERCLE":[{"def":"A small cover; a lid.","pos":""}],"COVERED":[{"def":"Under cover; screened; sheltered; not exposed; hidden.","pos":""}],"COVERER":[{"def":"One who, or that which, covers.","pos":""}],"COVERING":[{"def":"Anything which covers or conceals, as a roof, a screen, a wrapper, clothing, etc.","pos":""}],"COVERLET":[{"def":"The uppermost cover of a bed or of any piece of furniture.","pos":""}],"COVERLID":[{"def":"All the coverlid was clocth of gold.","pos":""}],"COVERSED SINE":[{"def":"The versed sine of the complement of an arc or angle.","pos":""}],"COVERSIDE":[{"def":"A region of country having covers; a hunting country.","pos":""}],"COVERT":[{"def":"Under cover, authority or protection; as, a feme covert, a married woman who is considered as being under the protection and control of her husband.","pos":""}],"COVERT BARON":[{"def":"Under the protection of a husband; married.","pos":""}],"COVERTLY":[{"def":"Secretly; in private; insidiously.","pos":""}],"COVERTNESS":[{"def":"Secrecy; privacy.","pos":""}],"COVERTURE":[{"def":"The condition of a woman during marriage, because she is considered under the cover, influence, power, and protection of her husband, and therefore called a feme covert, or femme couverte.","pos":""}],"COVET":[{"def":"To wish for with eagerness; to desire possession of; -- used in a good sen Covet earnestly the best gifts.","pos":""},{"def":"To long for inordinately or unlawfully; to hanker after (something forbidden).","pos":""}],"COVETABLE":[{"def":"That may be coveted; desirable.","pos":""}],"COVETIVENESS":[{"def":"Acquisitiveness.","pos":""}],"COVETOUS":[{"def":"Very desirous; eager to obtain; -- used in a good sense.","pos":""},{"def":"Inordinately desirous; excessively eager to obtain and possess (esp.","pos":""}],"COVETOUSLY":[{"def":"In a covetous manner.","pos":""}],"COVETOUSNESS":[{"def":"A strong or inordinate desire of obtaining and possessing some supposed good; excessive desire for riches or money; -- in a bad sense.","pos":""}],"COVEY":[{"def":"A brood or hatch of birds; an old bird with her brood of young; hence, a small flock or number of birds together; -- said of game; as, a covey of partridges.","pos":""},{"def":"A company; a bevy; as, a covey of girls.","pos":""}],"COVIN":[{"def":"A collusive agreement between two or more persons to prejudice a third.","pos":""}],"COVINOUS":[{"def":"Deceitful; collusive; fraudulent; dishonest.","pos":""}]}