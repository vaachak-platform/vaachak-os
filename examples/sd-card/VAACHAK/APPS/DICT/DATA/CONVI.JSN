{"CONVICIATE":[{"def":"To utter reproaches; to raise a clamor; to rail.","pos":""}],"CONVICINITY":[{"def":"Immediate vicinity; neighborhood.","pos":""}],"CONVICIOUS":[{"def":"Expressing reproach; abusive; railing; taunting.","pos":""}],"CONVICT":[{"def":"Proved or found guilty; convicted.","pos":""}],"CONVICTIBLE":[{"def":"Capable of being convicted.","pos":""}],"CONVICTION":[{"def":"A judgment of condemnation entered by a court having jurisdiction; the act or process of finding guilty, or the state of being found guilty of any crime by a legal tribunal.","pos":""}],"CONVICTISM":[{"def":"The policy or practice of transporting convicts to penal settlements.","pos":""}],"CONVICTIVE":[{"def":"The best and most convictive argument.","pos":""}],"CONVINCE":[{"def":"To overpower; to overcome; to subdue or master.","pos":""},{"def":"To overcome by argument; to force to yield assent to truth; to satisfy by proof.","pos":""}],"CONVINCEMENT":[{"def":"Act of convincing, or state of being convinced; conviction.","pos":""}],"CONVINCER":[{"def":"One who, or that which, convinces; one who wins over by proof.","pos":""}],"CONVINCIBLE":[{"def":"Capable of being convinced or won over.","pos":""},{"def":"Capable of being confuted and disproved by argument; refutable.","pos":""}],"CONVINCINGLY":[{"def":"in a convincing manner; in a manner to compel assent.","pos":""}],"CONVINCINGNESS":[{"def":"The power of convincing, or the quality of being convincing.","pos":""}],"CONVIVAL":[{"def":"pertaining to a feast or to festivity; convivial.","pos":""}],"CONVIVE":[{"def":"To feast together; to be convivial.","pos":""}],"CONVIVIAL":[{"def":"Of or relating to a feast or entertainment, or to eating and drinking, with accompanying festivity; festive; social; gay; jovial.","pos":""}],"CONVIVIALIST":[{"def":"A person of convivial habits.","pos":""}],"CONVIVIALITY":[{"def":"The good humor or mirth indulged in upon festive occasions; a convivial spirit or humor; festivity.","pos":""}],"CONVIVIALLY":[{"def":"In a convivial manner.","pos":""}]}