{"COG":[{"def":"To seduce, or draw away, by adulation, artifice, or falsehood; to wheedle; to cozen; to cheat.","pos":""},{"def":"To obtrude or thrust in, by falsehood or deception; as, to cog in a word; to palm off.","pos":""}],"COGENCY":[{"def":"The quality of being cogent; power of compelling conviction; conclusiveness; force.","pos":""}],"COGENT":[{"def":"Compelling, in a physical sense; powerful.","pos":""},{"def":"Having the power to compel conviction or move the will; constraining; conclusive; forcible; powerful; not easily reasisted.","pos":""}],"COGENTLY":[{"def":"In a cogent manner; forcibly; convincigly; conclusively.","pos":""}],"COGGER":[{"def":"A flatterer or deceiver; a sharper.","pos":""}],"COGGERY":[{"def":"Trick; deception.","pos":""}],"COGGLE":[{"def":"A small fishing boat.","pos":""}],"COGITABILITY":[{"def":"The quality of being cogitable; conceivableness.","pos":""}],"COGITABLE":[{"def":"Capable of being brought before the mind as a throught or idea; conceivable; thinkable.","pos":""}],"COGITABUND":[{"def":"Full of thought; thoughtful.","pos":""}],"COGITATE":[{"def":"To engage in continuous thought; to think.","pos":""}],"COGITATION":[{"def":"The act of thinking; thought; meditation; contemplation.","pos":""}],"COGITATIVE":[{"def":"Possessing, or pertaining to, the power of thinking or meditating.","pos":""},{"def":"Given to thought or contemplation.","pos":""}],"COGMAN":[{"def":"A dealer in cogware or coarse cloth.","pos":""}],"COGNAC":[{"def":"A kind of French brandy, so called from the town of Cognac.","pos":""}],"COGNATE":[{"def":"Allied by blood; kindred by birth; specifically (Law), related on the mother's side.","pos":""},{"def":"Of the same or a similar nature; of the same family; proceeding from the same stock or root; allied; kindred; as, a cognate language.","pos":""}],"COGNATENESS":[{"def":"The state of being cognate.","pos":""}],"COGNATI":[{"def":"Relatives by the mother's side.","pos":""}],"COGNATION":[{"def":"That tie of consanguinity which exists between persons descended from the same mother; -- used in distinction from agnation.","pos":""}],"COGNATUS":[{"def":"A person cinnected through cognation.","pos":""},{"def":"See Cognizor, Cognizee.","pos":""}],"COGNITION":[{"def":"The act of knowing; knowledge; perception.","pos":""},{"def":"That which is known.","pos":""}],"COGNITIVE":[{"def":"Knowing, or apprehending by the understanding; as, cognitive power.","pos":""}],"COGNIZABLE":[{"def":"Capable of being known or apprehended; as, cognizable causes.","pos":""},{"def":"Fitted to be a subject of judicial investigation; capable of being judicially heard and determined.","pos":""}],"COGNIZABLY":[{"def":"In a cognizable manner.","pos":""}],"COGNIZANCE":[{"def":"Apprehension by the understanding; perception; observation.","pos":""},{"def":"Recollection; recognition.","pos":""}],"COGNIZANT":[{"def":"Having cognizance or knowledge.","pos":""}],"COGNIZE":[{"def":"To know or perceive; to recognize.","pos":""}],"COGNIZEE":[{"def":"One to whom a fine of land was ackowledged.","pos":""}],"COGNIZOR":[{"def":"One who ackowledged the right of the plaintiff or cognizee in a fine; the defendant.","pos":""}],"COGNOMEN":[{"def":"The last of the three names of a person among the ancient Romans, denoting his house or family.","pos":""}],"COGNOMINAL":[{"def":"Of or pertaining to a cognomen; of the nature of a surname.","pos":""}],"COGNOMINATION":[{"def":"A cognomen or surname.","pos":""}],"COGNOSCIBILITY":[{"def":"The quality of being cognoscible.","pos":""}],"COGNOSCIBLE":[{"def":"Capable of being known.","pos":""},{"def":"Liable to judicial investigation.","pos":""}],"COGNOSCITIVE":[{"def":"Having the power of knowing.","pos":""}],"COGNOVIT":[{"def":"An instrument in writting whereby a defendant in an action acknowledges a plaintiff's demand to be just.","pos":""}],"COGON":[{"def":"A tall, coarse grass (Imperata arundinacea) of the Philippine Islands and adjacent countries, used for thatching.","pos":""}],"COGUARDIAN":[{"def":"A joint guardian.","pos":""}],"COGUE":[{"def":"A small wooden vessel; a pail.","pos":""}],"COGWARE":[{"def":"A coarse, narrow cloth, like frieze, used by the lower classes in the sixteenth century.","pos":""}],"COGWHEEL":[{"def":"A wheel with cogs or teeth; a gear wheel.","pos":""}]}