{"APT":[{"def":"Fit or fitted; suited; suitable; appropriate.","pos":""},{"def":"Having an habitual tendency; habitually liable or likely; -- used of things.","pos":""}],"APTABLE":[{"def":"Capable of being adapted.","pos":""}],"APTERA":[{"def":"Insects without wings, constituting the seventh Linnæn order of insects, an artificial group, which included Crustacea, spiders, centipeds, and even worms.","pos":""}],"APTERAL":[{"def":"Without lateral columns; -- applied to buildings which have no series of columns along their sides, but are either prostyle or amphiprostyle, and opposed to peripteral.","pos":""}],"APTERAN":[{"def":"One of the Aptera.","pos":""}],"APTERIA":[{"def":"Naked spaces between the feathered areas of birds.","pos":""}],"APTEROUS":[{"def":"Destitute of wings; apteral; as, apterous insects.","pos":""},{"def":"Destitute of winglike membranous expansions, as a stem or petiole; -- opposed to atate.","pos":""}],"APTERYGES":[{"def":"An order of birds, including the genus Apteryx.","pos":""}],"APTERYX":[{"def":"A genus of New Zealand birds about the size of a hen, with only short rudiments of wings, armed with a claw and without a tail; the kiwi.","pos":""}],"APTITUDE":[{"def":"A natural or acquired disposition or capacity for a particular purpose, or tendency to a particular action or effect; as, oil has an aptitude to burn.","pos":""},{"def":"A general fitness or suitableness; adaptation.","pos":""}],"APTLY":[{"def":"In an apt or suitable manner; fitly; properly; pertinently; appropriately; readily.","pos":""}],"APTNESS":[{"def":"Fitness; suitableness; appropriateness; as, the aptness of things to their end.","pos":""},{"def":"Disposition of the mind; propensity; as, the aptness of men to follow example.","pos":""}],"APTOTE":[{"def":"A noun which has no distinction of cases; an indeclinable noun.","pos":""}],"APTOTIC":[{"def":"Pertaining to, or characterized by, aptotes; uninflected; as, aptotic languages.","pos":""}],"APTYCHUS":[{"def":"A shelly plate found in the terminal chambers of ammonite shells.","pos":""}]}