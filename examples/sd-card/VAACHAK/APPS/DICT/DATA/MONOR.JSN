{"MONORGANIC":[{"def":"Belonging to, or affecting, a single organ, or set of organs.","pos":""}],"MONORHINA":[{"def":"The Marsipobranchiata.","pos":""}],"MONORHYME":[{"def":"A composition in verse, in which all the lines end with the same rhyme.","pos":""},{"def":"A simple sugar; any of a number of sugars (including the trioses, tetroses, pentoses, hexoses, etc.","pos":""}]}