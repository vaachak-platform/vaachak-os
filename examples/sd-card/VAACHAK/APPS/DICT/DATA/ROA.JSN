{"ROACH":[{"def":"A convex curve or arch cut in the edge of a sail to prevent chafing, or to secure a better fit.","pos":""}],"ROACH-BACKED":[{"def":"Having a back like that of roach; -- said of a horse whose back a convex instead of a concave curve.","pos":""}],"ROAD":[{"def":"A place where ships may ride at anchor at some distance from the shore; a roadstead; -- often in the plural; as, Hampton Roads.","pos":""}],"ROADBED":[{"def":"In railroads, the bed or foundation on which the superstructure (ties, rails, etc.","pos":""}],"ROADLESS":[{"def":"Destitute of roads.","pos":""}],"ROADMAKER":[{"def":"One who makes roads.","pos":""}],"ROADSIDE":[{"def":"Land adjoining a road or highway; the part of a road or highway that borders the traveled part.","pos":""}],"ROADSTEAD":[{"def":"An anchorage off shore.","pos":""}],"ROADSTER":[{"def":"A clumsy vessel that works its way from one anchorage to another by means of the tides.","pos":""}],"ROADWAY":[{"def":"A road; especially, the part traveled by carriages.","pos":""}],"ROAM":[{"def":"To go from place to place without any certain purpose or direction; to rove; to wander.","pos":""}],"ROAMER":[{"def":"One who roams; a wanderer.","pos":""}],"ROAN":[{"def":"Having a bay, chestnut, brown, or black color, with gray or white thickly interspersed; -- said of a horse.","pos":""},{"def":"Made of the leather called roan; as, roan binding.","pos":""}],"ROAR":[{"def":"To cry with a full, loud, continued sound.","pos":""},{"def":"To make a loud, confused sound, as winds, waves, passing vehicles, a crowd of persons when shouting together, or the like.","pos":""}],"ROARER":[{"def":"A horse subject to roaring.","pos":""}],"ROARING":[{"def":"An affection of the windpipe of a horse, causing a loud, peculiar noise in breathing under exertion; the making of the noise so caused.","pos":""}],"ROARING FORTIES":[{"def":"The middle latitudes of the southern hemisphere.","pos":""}],"ROARINGLY":[{"def":"In a roaring manner.","pos":""}],"ROAST":[{"def":"To dissipate by heat the volatile parts of, as ores.","pos":""}],"ROASTER":[{"def":"One who roasts meat.","pos":""},{"def":"A contrivance for roasting.","pos":""}],"ROASTING":[{"def":"Roast\"ing, Defn: a.","pos":""}]}