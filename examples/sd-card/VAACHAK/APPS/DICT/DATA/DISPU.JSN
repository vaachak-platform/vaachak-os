{"DISPUNCT":[{"def":"Wanting in punctilious respect; discourteous.","pos":""}],"DISPUNGE":[{"def":"To expunge; to erase.","pos":""}],"DISPUNISHABLE":[{"def":"Without penal restraint; not punishable.","pos":""}],"DISPURPOSE":[{"def":"To dissuade; to frustrate; as, to dispurpose plots.","pos":""}],"DISPURVEY":[{"def":"To disfurnish; to strip.","pos":""}],"DISPURVEYANCE":[{"def":"Want of provisions; [Obs.","pos":""}],"DISPUTABLE":[{"def":"Capable of being disputed; liable to be called in question, controverted, or contested; or doubtful certainty or propriety; controvertible; as, disputable opinions, propositions, points, or questions.","pos":""},{"def":"Disputatious; contentious.","pos":""}],"DISPUTABLENESS":[{"def":"State of being disputable.","pos":""}],"DISPUTACITY":[{"def":"Proneness to dispute.","pos":""}],"DISPUTANT":[{"def":"Disputing; engaged in controversy.","pos":""}],"DISPUTATION":[{"def":"The act of disputing; a reasoning or argumentation in opposition to something, or on opposite sides; controversy in words; verbal contest respecting the truth of some fact, opinion, proposition, or argument.","pos":""},{"def":"A rhetorical exercise in which parties reason in opposition to each other on some question proposed.","pos":""}],"DISPUTATIOUS":[{"def":"Inclined to dispute; apt to civil or controvert; characterized by dispute; as, a disputatious person or temper.","pos":""}],"DISPUTATIVE":[{"def":"Disposed to dispute; inclined to cavil or to reason in opposition; as, a disputative temper.","pos":""}],"DISPUTE":[{"def":"To contend in argument; to argue against something maintained, upheld, or claimed, by another; to discuss; to reason; to debate; to altercate; to wrangle.","pos":""}],"DISPUTELESS":[{"def":"Admitting no dispute; incontrovertible.","pos":""}],"DISPUTER":[{"def":"One who disputes, or who is given to disputes; a controvertist.","pos":""}],"DISPUTISON":[{"def":"Dispute; discussion.","pos":""}]}