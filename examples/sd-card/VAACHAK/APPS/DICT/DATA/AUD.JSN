{"AUDACIOUS":[{"def":"Daring; spirited; adventurous.","pos":""},{"def":"Contemning the restraints of law, religion, or decorum; bold in wickedness; presumptuous; impudent; insolent.","pos":""}],"AUDACIOUSLY":[{"def":"In an audacious manner; with excess of boldness; impudently.","pos":""}],"AUDACIOUSNESS":[{"def":"The quality of being audacious; impudence; audacity.","pos":""}],"AUDACITY":[{"def":"Daring spirit, resolution, or confidence; venturesomeness.","pos":""},{"def":"Reckless daring; presumptuous impudence; -- implying a contempt of law or moral restraints.","pos":""}],"AUDIBILITY":[{"def":"The quality of being audible; power of being heard; audible capacity.","pos":""}],"AUDIBLE":[{"def":"Capable of being heard; loud enough to be heard; actually heard; as, an audible voice or whisper.","pos":""}],"AUDIBLENESS":[{"def":"The quality of being audible.","pos":""}],"AUDIBLY":[{"def":"So as to be heard.","pos":""}],"AUDIENCE":[{"def":"The act of hearing; attention to sounds.","pos":""},{"def":"Admittance to a hearing; a formal interview, esp.","pos":""}],"AUDIENT":[{"def":"Listening; paying attention; as, audient souls.","pos":""}],"AUDILE":[{"def":"One whose thoughts take the form of mental sounds or of internal discourse rather than of visual or motor images.","pos":""}],"AUDIOMETER":[{"def":"An instrument by which the power of hearing can be gauged and recorded on a scale.","pos":""}],"AUDIPHONE":[{"def":"An instrument which, placed against the teeth, conveys sound to the auditory nerve and enables the deaf to hear more or less distinctly; a dentiphone.","pos":""}],"AUDIT":[{"def":"An audience; a hearing.","pos":""},{"def":"An examination in general; a judicial examination.","pos":""}],"AUDITA QUERELA":[{"def":"A writ which lies for a party against whom judgment is recovered, but to whom good matter of discharge has subsequently accrued which could not have been availed of to prevent such judgment.","pos":""}],"AUDITION":[{"def":"The act of hearing or listening; hearing.","pos":""}],"AUDITIVE":[{"def":"Of or pertaining to hearing; auditory.","pos":""}],"AUDITOR":[{"def":"A hearer or listener.","pos":""},{"def":"A person appointed and authorized to audit or examine an account or accounts, compare the charges with the vouchers, examine the parties and witnesses, allow or reject charges, and state the balance.","pos":""}],"AUDITORIUM":[{"def":"The part of a church, theater, or other public building, assigned to the audience.","pos":""}],"AUDITORSHIP":[{"def":"The office or function of auditor.","pos":""}],"AUDITORY":[{"def":"Of or pertaining to hearing, or to the sense or organs of hearing; as, the auditory nerve.","pos":""}],"AUDITRESS":[{"def":"A female hearer.","pos":""}]}