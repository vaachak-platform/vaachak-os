{"DON":[{"def":"Sir; Mr; Signior; -- a title in Spain, formerly given to noblemen and gentlemen only, but now common to all classes.","pos":""},{"def":"A grand personage, or one making pretension to consequence; especially, the head of a college, or one of the fellows at the English universities.","pos":""}],"DONABLE":[{"def":"Capable of being donated or given.","pos":""}],"DONARY":[{"def":"A thing given to a sacred use.","pos":""}],"DONATE":[{"def":"To give; to bestow; to present; as, to donate fifty thousand dollars to a college.","pos":""}],"DONATION":[{"def":"The act or contract by which a person voluntarily transfers the title to a thing of which be is the owner, from himself to another, without any consideration, as a free gift.","pos":""}],"DONATISM":[{"def":"The tenets of the Donatists.","pos":""}],"DONATIST":[{"def":"A follower of Donatus, the leader of a body of North African schismatics and purists, who greatly disturbed the church in the 4th century.","pos":""}],"DONATISTIC":[{"def":"Pertaining to Donatism.","pos":""}],"DONATIVE":[{"def":"A benefice conferred on a person by the founder or patron, without either presentation or institution by the ordinary, or induction by his orders.","pos":""}],"DONATOR":[{"def":"One who makes a gift; a donor; a giver.","pos":""}],"DONATORY":[{"def":"A donee of the crown; one the whom, upon certain condition, escheated property is made over.","pos":""}],"DONAX":[{"def":"A canelike grass of southern Europe (Arundo Donax), used for fishing rods, etc.","pos":""}],"DONCELLA":[{"def":"A handsome fish of Florida and the West Indies (Platyglossus radiatus).","pos":""}],"DONE":[{"def":"Performed; executed; finished.","pos":""},{"def":"It is done or agreed; let it be a match or bargain; -- used elliptically.","pos":""}],"DONEE":[{"def":"Anciently, one to whom lands were given; in later use, one to whom lands and tenements are given in tail; in modern use, one on whom a power is conferred for execution; -- sometimes called the appointor.","pos":""}],"DONGOLA":[{"def":"A government of Upper Egypt.","pos":""}],"DONI":[{"def":"A clumsy craft, having one mast with a long sail, used for trading purposes on the coasts of Coromandel and Ceylon.","pos":""}],"DONJON":[{"def":"The chief tower, also called the keep; a massive tower in ancient castles, forming the strongest part of the fortifications.","pos":""}],"DONKEY":[{"def":"An ass; or (less frequently) a mule.","pos":""},{"def":"A stupid or obstinate fellow; an ass.","pos":""}],"DONNA":[{"def":"A lady; madam; mistress; -- the title given a lady in Italy.","pos":""}],"DONNEE":[{"def":"That favorite romance donnée of the heir kept out of his own.","pos":""}],"DONNISM":[{"def":"Self-importance; loftiness of carriage.","pos":""}],"DONOR":[{"def":"One who grants an estate; in later use, one who confers a power; -- the opposite of donee.","pos":""}],"DONSHIP":[{"def":"The quality or rank of a don, gentleman, or knight.","pos":""}],"DONZEL":[{"def":"A young squire, or knight's attendant; a page.","pos":""}]}