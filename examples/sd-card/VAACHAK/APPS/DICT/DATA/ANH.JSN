{"ANHELATION":[{"def":"Short and rapid breathing; a panting; asthma.","pos":""}],"ANHELE":[{"def":"To pant; to be breathlessly anxious or eager (for).","pos":""}],"ANHELOSE":[{"def":"Anhelous; panting.","pos":""}],"ANHELOUS":[{"def":"Short of breath; panting.","pos":""}],"ANHIMA":[{"def":"A South American aquatic bird; the horned screamer or kamichi (Palamedea cornuta).","pos":""}],"ANHINGA":[{"def":"An aquatic bird of the southern United States (Platus anhinga); the darter, or snakebird.","pos":""}],"ANHISTOUS":[{"def":"Without definite structure; as, an anhistous membrane.","pos":""}],"ANHUNGERED":[{"def":"Ahungered; longing.","pos":""}],"ANHYDRIDE":[{"def":"An oxide of a nonmetallic body or an organic radical, capable of forming an acid by uniting with the elements of water; -- so called because it may be formed from an acid by the abstraction of water.","pos":""}],"ANHYDRITE":[{"def":"A mineral of a white a slightly bluish color, usually massive.","pos":""}],"ANHYDROUS":[{"def":"Destitute of water; as, anhydrous salts or acids.","pos":""},{"def":"A black bird of tropical America, the West Indies and Florida (Crotophaga ani), allied to the cuckoos, and remarkable for communistic nesting.","pos":""}]}