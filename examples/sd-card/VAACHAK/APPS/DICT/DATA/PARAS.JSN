{"PARASANG":[{"def":"A Persian measure of length, which, according to Herodotus and Xenophon, was thirty stadia, or somewhat more than three and a half miles.","pos":""}],"PARASCENIUM":[{"def":"One of two apartments adjoining the stage, probably used as robing rooms.","pos":""}],"PARASCEVE":[{"def":"Among the Jews, the evening before the Sabbath.","pos":""}],"PARASCHEMATIC":[{"def":"Of or pertaining to a change from the right form, as in the formation of a word from another by a change of termination, gender, etc.","pos":""}],"PARASELENE":[{"def":"A mock moon; an image of the moon which sometimes appears at the point of intersection of two lunar halos.","pos":""}],"PARASHAH":[{"def":"A lesson from the Torah, or Law, from which at least one section is read in the Jewish synagogue on every Sabbath and festival.","pos":""}],"PARASITAL":[{"def":"Of or pertaining to parasites; parasitic.","pos":""}],"PARASITE":[{"def":"Of or pertaining to parasites; living on, or deriving nourishment from, some other living animal or plant.","pos":""}],"PARASITICIDE":[{"def":"Anything used to destroy parasites.","pos":""}],"PARASITISM":[{"def":"The state of being parasitic.","pos":""}],"PARASOL":[{"def":"A kind of small umbrella used by women as a protection from the sun.","pos":""}],"PARASOLETTE":[{"def":"A small parasol.","pos":""}],"PARASPHENOID":[{"def":"Near the sphenoid bone; -- applied especially to a bone situated immediately beneath the sphenoid in the base of the skull in many animals.","pos":""},{"def":"The parasphenoid bone.","pos":""}],"PARASTICHY":[{"def":"A secondary spiral in phyllotaxy, as one of the evident spirals in a pine cone.","pos":""}],"PARASYNAXIS":[{"def":"An unlawful meeting.","pos":""}],"PARASYNTHETIC":[{"def":"Formed from a compound word.","pos":""}]}