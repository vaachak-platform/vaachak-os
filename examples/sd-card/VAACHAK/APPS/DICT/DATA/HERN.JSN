{"HERNANI":[{"def":"A thin silk or woolen goods, for women's dresses, woven in various styles and colors.","pos":""}],"HERNE":[{"def":"Lurking in hernes and in lanes blind.","pos":""}],"HERNIA":[{"def":"A protrusion, consisting of an organ or part which has escaped from its natural cavity, and projects through some natural or accidental opening in the walls of the latter; as, hernia of the brain, of the lung, or of the bowels.","pos":""}],"HERNIAL":[{"def":"Of, or connected with, hernia.","pos":""}],"HERNIOTOMY":[{"def":"A cutting for the cure or relief of hernia; celotomy.","pos":""}]}