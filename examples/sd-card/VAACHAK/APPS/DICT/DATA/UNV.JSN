{"UNVALUABLE":[{"def":"Invaluable; being beyond price.","pos":""},{"def":"Not valuable; having little value.","pos":""}],"UNVALUED":[{"def":"Not valued; not appraised; hence, not considered; disregarded; valueless; as, an unvalued estate.","pos":""},{"def":"Having inestimable value; invaluable.","pos":""}],"UNVEIL":[{"def":"To remove a veil from; to divest of a veil; to uncover; to disclose to view; to reveal; as, she unveiled her face.","pos":""}],"UNVEILER":[{"def":"One who removes a veil.","pos":""}],"UNVERACITY":[{"def":"Want of veracity; untruthfulness; as, unveracity of heart.","pos":""}],"UNVESSEL":[{"def":"To cause to be no longer a vessel; to empty.","pos":""}],"UNVICAR":[{"def":"To deprive of the position or office a vicar.","pos":""}],"UNVISARD":[{"def":"To take the vizard or mask from; to unmask.","pos":""}],"UNVITIATED":[{"def":"Not vitiated; pure.","pos":""}],"UNVOTE":[{"def":"To reverse or annul by vote, as a former vote.","pos":""}],"UNVOWELED":[{"def":"Having no vowel sounds or signs.","pos":""}],"UNVULGARIZE":[{"def":"To divest of vulgarity; to make to be not vulgar.","pos":""}]}