{"CLAUDE LORRAINE GLASS":[{"def":"A slightly convex mirror, commonly of black glass, used as a toy for viewing the reflected landscape.","pos":""}],"CLAUDENT":[{"def":"Shutting; confining; drawing together; as, a claudent muscle.","pos":""}],"CLAUDICATION":[{"def":"A halting or limping.","pos":""}],"CLAUSE":[{"def":"A subordinate portion or a subdivision of a sentence containing a subject and its predicate.","pos":""}],"CLAUSTRUM":[{"def":"A thin lamina of gray matter in each cerebral hemiphere of the brain of man.","pos":""}],"CLAUSULAR":[{"def":"Consisting of, or having, clauses.","pos":""}],"CLAUSURE":[{"def":"The act of shutting up or confining; confinement.","pos":""},{"def":"Club-shaped; having the form of a club; growing gradually thicker toward the top.","pos":""}]}