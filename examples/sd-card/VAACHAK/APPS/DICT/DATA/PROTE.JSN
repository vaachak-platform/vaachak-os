{"PROTEACEOUS":[{"def":"Of or pertaining to the Proteaceæ, an order of apetalous evergreen shrubs, mostly natives of the Cape of Good Hope or of Australia.","pos":""}],"PROTEAN":[{"def":"Of or pertaining to Proteus; characteristic of Proteus.","pos":""},{"def":"Exceedingly variable; readily assuming different shapes or forms; as, an amoeba is a protean animalcule.","pos":""}],"PROTEANLY":[{"def":"In a protean manner.","pos":""}],"PROTECT":[{"def":"To cover or shield from danger or injury; to defend; to guard; to preserve in safety; as, a father protects his children.","pos":""}],"PROTECTINGLY":[{"def":"By way of protection; in a protective manner.","pos":""}],"PROTECTION":[{"def":"A theory, or a policy, of protecting the producers in a country from foreign competition in the home market by the imposition of such discriminating duties on goods of foreign production as will restrict or prevent their importation; -- opposed to free trade.","pos":""}],"PROTECTIONISM":[{"def":"The doctrine or policy of protectionists.","pos":""}],"PROTECTIONIST":[{"def":"One who favors protection.","pos":""}],"PROTECTIVE":[{"def":"Affording protection; sheltering; defensive.","pos":""}],"PROTECTIVENESS":[{"def":"The quality or state of being protective.","pos":""}],"PROTECTOR":[{"def":"One having the care of the kingdom during the king's minority; a regent.","pos":""},{"def":"A cardinal, from one of the more considerable Roman Catholic nations, who looks after the interests of his people at Rome; also, a cardinal who has the same relation to a college, religious order, etc.","pos":""}],"PROTECTORAL":[{"def":"Of or pertaining to a protector; protectorial; as, protectoral power.","pos":""}],"PROTECTORATE":[{"def":"Government by a protector; -- applied especially to the government of England by Oliver Cromwell.","pos":""},{"def":"The authority assumed by a superior power over an inferior or a dependent one, whereby the former protects the latter from invasion and shares in the management of its affairs.","pos":""}],"PROTECTORIAL":[{"def":"Same as Protectoral.","pos":""}],"PROTECTORLESS":[{"def":"Having no protector; unprotected.","pos":""}],"PROTECTORSHIP":[{"def":", The office of a protector or regent; protectorate.","pos":""},{"def":"A woman who protects.","pos":""}],"PROTEID":[{"def":"One of a class of amorphous nitrogenous principles, containing, as a rule, a small amount of sulphur; an albuminoid, as blood fibrin, casein of milk, etc.","pos":""}],"PROTEIDEA":[{"def":"An order of aquatic amphibians having prominent external gills and four legs.","pos":""}],"PROTEIFORM":[{"def":"Changeable in form; resembling a Proteus, or an amoeba.","pos":""}],"PROTEIN":[{"def":"A body now known as alkali albumin, but originally considered to be the basis of all albuminous substances, whence its name.","pos":""}],"PROTEINACEOUS":[{"def":"Of or related to protein; albuminous; proteid.","pos":""}],"PROTELES":[{"def":"A South Africa genus of Carnivora, allied to the hyenas, but smaller and having weaker jaws and teeth.","pos":""}],"PROTEND":[{"def":"To hold out; to stretch forth.","pos":""}],"PROTENSION":[{"def":"A drawing out; extension.","pos":""}],"PROTENSIVE":[{"def":"Drawn out; extended.","pos":""}],"PROTEOLYSIS":[{"def":"The digestion or dissolving of proteid matter by proteolytic ferments.","pos":""}],"PROTEOLYTIC":[{"def":"Converting proteid or albuminous matter into soluble and diffusible products, as peptones.","pos":""}],"PROTEOSE":[{"def":"One of a class of soluble products formed in the digestion of proteids with gastric and pancreatic juice, and also by the hydrolytic action of boiling dilute acids on proteids.","pos":""}],"PROTERANDROUS":[{"def":"Having the stamens come to maturity before the pistil; -- opposed to proterogynous.","pos":""}],"PROTERANDRY":[{"def":"The condition of being proterandrous.","pos":""}],"PROTERANTHOUS":[{"def":"Having flowers appearing before the leaves; -- said of certain plants.","pos":""}],"PROTEROGLYPHA":[{"def":"A suborder of serpents including those that have permanently erect grooved poison fangs, with ordinary teeth behind them in the jaws.","pos":""}],"PROTEROGYNOUS":[{"def":"Having the pistil come to maturity before the stamens; protogynous; -- opposed to proterandrous.","pos":""}],"PROTEROSAURUS":[{"def":"An extinct genus of reptiles of the Permian period.","pos":""}],"PROTERVITY":[{"def":"Peevishness; petulance.","pos":""}],"PROTEST":[{"def":"To affirm in a public or formal manner; to bear witness; to declare solemnly; to avow.","pos":""},{"def":"To make a solemn declaration (often a written one) expressive of opposition; -- with against; as, he protest against your votes.","pos":""}],"PROTESTANT":[{"def":"One who protests; -- originally applied to those who adhered to Luther, and protested against, or made a solemn declaration of dissent from, a decree of the Emperor Charles V.","pos":""}],"PROTESTANTICAL":[{"def":"Prot`es*tant\"ic*al, a.","pos":""}],"PROTESTANTISM":[{"def":"The quality or state of being protestant, especially against the Roman Catholic Church; the principles or religion of the Protestants.","pos":""}],"PROTESTANTLY":[{"def":"Like a Protestant; in conformity with Protestantism.","pos":""}],"PROTESTATION":[{"def":"Formerly, a declaration in common-law pleading, by which the party interposes an oblique allegation or denial of some fact, protesting that it does or does not exist, and at the same time avoiding a direct affirmation or denial.","pos":""}],"PROTESTATOR":[{"def":"One who makes protestation; a protester.","pos":""}],"PROTESTER":[{"def":"One who protests a bill of exchange, or note.","pos":""}],"PROTESTINGLY":[{"def":"By way of protesting.","pos":""}],"PROTEUS":[{"def":"A sea god in the service of Neptune who assumed different shapes at will.","pos":""},{"def":"A song in celebration of a marriage.","pos":""}]}