{"KNEAD":[{"def":"To work and press into a mass, usually with the hands; esp.","pos":""}],"KNEADABLE":[{"def":"That may be kneaded; capable of being worked into a mass.","pos":""}],"KNEADINGLY":[{"def":"In the manner of one kneading.","pos":""}],"KNEBELITE":[{"def":"A mineral of a gray, red, brown, or green color, and glistening luster.","pos":""}],"KNECK":[{"def":"The twisting of a rope or cable, as it is running out.","pos":""}],"KNEE":[{"def":"A piece of timber or metal formed with an angle somewhat in the shape of the human knee when bent.","pos":""}],"KNEE JERK":[{"def":"A jerk or kick produced by a blow or sudden strain upon the patellar tendon of the knee, which causes a sudden contraction of the quadriceps muscle.","pos":""}],"KNEE-CROOKING":[{"def":"Obsequious; fawning; cringing.","pos":""}],"KNEE-DEEP":[{"def":"Rising to the knees; knee-high; as, water or snow knee-deep.","pos":""},{"def":"Sunk to the knees; as, men knee-deep in water.","pos":""}],"KNEE-HIGH":[{"def":"Rising or reaching upward to the knees; as, the water is knee- high.","pos":""}],"KNEEBRUSH":[{"def":"A tuft or brush of hair on the knees of some species of antelopes and other animals; -- chiefly used in the plural.","pos":""},{"def":"A thick mass or collection of hairs on the legs of bees, by aid of which they carry the collected pollen to the hive or nest; -- usually in the plural.","pos":""}],"KNEECAP":[{"def":"A cap or protection for the knee.","pos":""}],"KNEED":[{"def":"Geniculated; forming an obtuse angle at the joints, like the knee when a little bent; as, kneed grass.","pos":""}],"KNEEJOINT":[{"def":"A toggle joint; -- so called because consisting of two pieces jointed to each other end to end, making an angle like the knee when bent.","pos":""}],"KNEEJOINTED":[{"def":"Geniculate; kneed.","pos":""}],"KNEEL":[{"def":"To bend the knee; to fall or rest on the knees; -- sometimes with down.","pos":""}],"KNEELER":[{"def":"A name given to certain catechumens and penitents who were permitted to join only in parts of church worship.","pos":""}],"KNEELINGLY":[{"def":"In a kneeling position.","pos":""}],"KNEEPAN":[{"def":"A roundish, flattened, sesamoid bone in the tendon in front of the knee joint; the patella; the kneecap.","pos":""}],"KNEEPIECE":[{"def":"A piece shaped like a knee; as, the kneepieces or ears of a boat.","pos":""},{"def":"Treatment of disease by forms of hydrotherapy, as walking barefoot in the morning dew, baths, wet compresses, cold affusions, etc.","pos":""}],"KNELL":[{"def":"The stoke of a bell tolled at a funeral or at the death of a person; a death signal; a passing bell; hence, figuratively, a warning of, or a sound indicating, the passing away of anything.","pos":""}]}