{"OVERFALL":[{"def":"A turbulent surface of water, caused by strong currents setting over submerged ridges; also, a dangerous submerged ridge or shoal.","pos":""}],"OVERFATIGUE":[{"def":"Excessive fatigue.","pos":""}],"OVERFEED":[{"def":"To feed to excess; to surfeit.","pos":""}],"OVERFIERCE":[{"def":"Excessively fierce.","pos":""}],"OVERFILL":[{"def":"To fill to excess; to surcharge.","pos":""}],"OVERFISH":[{"def":"To fish to excess.","pos":""}],"OVERFLOURISH":[{"def":"To make excessive display or flourish of.","pos":""},{"def":"To embellish with outward ornaments or flourishes; to varnish over.","pos":""}],"OVERFLOW":[{"def":"To flow over; to cover woth, or as with, water or other fluid; to spread over; to inundate; to overwhelm.","pos":""},{"def":"To flow over the brim of; to fill more than full.","pos":""}],"OVERFLOWING":[{"def":"An overflow; that which overflows; exuberance; copiousness.","pos":""}],"OVERFLOWINGLY":[{"def":"In great abundance; exuberantly.","pos":""}],"OVERFLUSH":[{"def":"To flush to excess.","pos":""}],"OVERFLUTTER":[{"def":"To flutter over.","pos":""}],"OVERFLUX":[{"def":"Overflow; exuberance.","pos":""}],"OVERFLY":[{"def":"To cross or pass over by flight.","pos":""}],"OVERFOND":[{"def":"O\"ver*fond\" Defn: , Milton.","pos":""}],"OVERFORCE":[{"def":"Excessive force; violence.","pos":""}],"OVERFORWARD":[{"def":"Forward to excess; too forward.","pos":""}],"OVERFREE":[{"def":"Free to excess; too liberal; too familiar.","pos":""}],"OVERFREIGHT":[{"def":"To put too much freight in or upon; to load too full, or too heavily; to overload.","pos":""}],"OVERFRIEZE":[{"def":"To cover with a frieze, or as with a frieze.","pos":""}],"OVERFRONT":[{"def":"To confront; to oppose; to withstand.","pos":""}],"OVERFULL":[{"def":"Too full; filled to overflowing; excessively full; surfeited.","pos":""}],"OVERFULLNESS":[{"def":"The state of being excessively or abnormally full, so as to cause overflow, distention, or congestion; excess of fullness; surfeit.","pos":""}]}