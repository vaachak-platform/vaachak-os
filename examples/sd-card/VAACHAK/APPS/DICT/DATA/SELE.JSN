{"SELECT":[{"def":"Taken from a number by preferance; picked out as more valuable or exellent than others; of special value or exellence; nicely chosen; selected; choice.","pos":""}],"SELECTEDLY":[{"def":"With care and selection.","pos":""}],"SELECTION":[{"def":"The act of selecting, or the state of being selected; choice, by preference.","pos":""}],"SELECTIVE":[{"def":"Selecting; tending to select.","pos":""}],"SELECTMAN":[{"def":"One of a board of town officers chosen annually in the New England States to transact the general public business of the town, and have a kind of executive authority.","pos":""}],"SELECTNESS":[{"def":"The quality or state of being select.","pos":""}],"SELECTOR":[{"def":"One who selects.","pos":""}],"SELENATE":[{"def":"A salt of selenic acid; -- formerly called also seleniate.","pos":""}],"SELENHYDRIC":[{"def":"Of, pertaining to, or designating, hydrogen selenide, H2Se, regarded as an acid analogous to sulphydric acid.","pos":""}],"SELENIC":[{"def":"Of or pertaining to selenium; derived from, or containing, selenium; specifically, designating those compounds in which the element has a higher valence as contrasted with selenious compounds.","pos":""}],"SELENIDE":[{"def":"A binary compound of selenium, or a compound regarded as binary; as, ethyl selenide.","pos":""}],"SELENIFEROUS":[{"def":"Containing, or impregnated with, selenium; as, seleniferous pyrites.","pos":""}],"SELENIO-":[{"def":"A combining form (also used adjectively) denoting the presence of selenium or its compounds; as, selenio-phosphate, a phosphate having selenium in place of all, or a part, of the oxygen.","pos":""}],"SELENIOUS":[{"def":"Of, pertaining to, or containing, selenium; specifically, designating those compounds in which the element has a lower valence as contrasted with selenic compounds.","pos":""}],"SELENITE":[{"def":"A salt of selenious acid.","pos":""}],"SELENIUM":[{"def":"A nonmetallic element of the sulphur group, and analogous to sulphur in its compounds.","pos":""}],"SELENIURETED":[{"def":"Combined with selenium as in a selenide; as, seleniureted hydrogen.","pos":""}],"SELENOCENTRIC":[{"def":"As seen or estimated from the center of the moon; with the moon central.","pos":""}],"SELENOGRAPH":[{"def":"Se*le\"no*graph Defn: , n.","pos":""}],"SELENOGRAPHER":[{"def":"One skilled in selenography.","pos":""},{"def":"Of or pertaining to selenography.","pos":""}],"SELENOGRAPHIST":[{"def":"A selenographer.","pos":""}],"SELENOGRAPHY":[{"def":"The science that treats of the physical features of the moon; - - corresponding to physical geography in respect to the earth.","pos":""}],"SELENOLOGY":[{"def":"That branch of astronomy which treats of the moon.","pos":""}],"SELENONIUM":[{"def":"A hypothetical radical of selenium, analogous to sulphonium.","pos":""}]}