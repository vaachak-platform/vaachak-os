{"VERIDICAL":[{"def":"Truth-telling; truthful; veracious.","pos":""}],"VERIFIABLE":[{"def":"Capable of being verified; confirmable.","pos":""}],"VERIFICATION":[{"def":"The act of verifying, or the state of being verified; confirmation; authentication.","pos":""}],"VERIFICATIVE":[{"def":"Serving to verify; verifying; authenciating; confirming.","pos":""}],"VERIFIER":[{"def":"One who, or that which, verifies.","pos":""}],"VERIFY":[{"def":"To prove to be true or correct; to establish the truth of; to confirm; to substantiate.","pos":""},{"def":"To confirm or establish the authenticity of by examination or competent evidence; to authenciate; as, to verify a written statement; to verify an account, a pleading, or the like.","pos":""}],"VERILOQUENT":[{"def":"Speaking truth; truthful.","pos":""}],"VERILY":[{"def":"In very truth; beyond doubt or question; in fact; certainly.","pos":""}],"VERINE":[{"def":"An alkaloid obtained as a yellow amorphous substance by the decomposition of veratrine.","pos":""}],"VERISIMILAR":[{"def":"Having the appearance of truth; probable; likely.","pos":""}],"VERISIMILITUDE":[{"def":"The quality or state of being verisimilar; the appearance of truth; probability; likelihood.","pos":""}],"VERISIMILITY":[{"def":"The verisimility or probable truth.","pos":""}],"VERITABLE":[{"def":"Agreeable to truth or to fact; actual; real; true; genuine.","pos":""}],"VERITAS":[{"def":"The Bureau Veritas.","pos":""}],"VERITY":[{"def":"The quality or state of being true, or real; consonance of a statement, proposition, or other thing, with fact; truth; reality.","pos":""},{"def":"That which is true; a true assertion or tenet; a truth; a reality.","pos":""}]}