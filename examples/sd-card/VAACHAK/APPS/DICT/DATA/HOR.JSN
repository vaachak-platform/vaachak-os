{"HORAL":[{"def":"Of or pertaining to an hour, or to hours.","pos":""}],"HORARY":[{"def":"Of or pertaining to an hour; noting the hours.","pos":""},{"def":"Occurring once an hour; continuing an hour; hourly; ephemeral.","pos":""}],"HORATIAN":[{"def":"Of or pertaining to Horace, the Latin poet, or resembling his style.","pos":""}],"HORDE":[{"def":"A wandering troop or gang; especially, a clan or tribe of a nomadic people migrating from place to place for the sake of pasturage, plunder, etc.","pos":""}],"HORDEIC":[{"def":"Pertaining to, or derived from, barley; as, hordeic acid, an acid identical or isomeric with lauric acid.","pos":""}],"HORDEIN":[{"def":"A peculiar starchy matter contained in barley.","pos":""}],"HORDEOLUM":[{"def":"A small tumor upon the eyelid, resembling a grain of barley; a sty.","pos":""}],"HORDOCK":[{"def":"An unidentified plant mentioned by Shakespeare, perhaps equivalent to burdock.","pos":""}],"HOREHOUND":[{"def":"A plant of the genus Marrubium (M.","pos":""}],"HORIZON":[{"def":"The epoch or time during which a deposit was made.","pos":""},{"def":"The chief horizontal line in a picture of any sort, which determines in the picture the height of the eye of the spectator; in an extended landscape, the representation of the natural horizon corresponds with this line.","pos":""}],"HORIZONTAL":[{"def":"Pertaining to, or near, the horizon.","pos":""},{"def":"Parallel to the horizon; on a level; as, a horizontalline or surface.","pos":""}],"HORIZONTALITY":[{"def":"The state or quality of being horizontal.","pos":""}],"HORIZONTALLY":[{"def":"In a horizontal direction or position; on a level; as, moving horizontally.","pos":""}],"HORMOGONIUM":[{"def":"A chain of small cells in certain algæ, by which the plant is propogated.","pos":""}],"HORMONE":[{"def":"A chemical substance formed in one organ and carried in the circulation to another organ on which it exerts a stimulating effect; thus, according to Starling, the gastric glands are stimulated by a hormone from the pyloric mucous membrane.","pos":""}],"HORN":[{"def":"Any natural projection or excrescence from an animal, resembling or thought to resemble a horn in substance or form; esp.","pos":""},{"def":"An incurved, tapering and pointed appendage found in the flowers of the milkweed (Asclepias).","pos":""}],"HORN-MAD":[{"def":"Quite mad; -- raving crazy.","pos":""}],"HORNBEAM":[{"def":"A tree of the genus Carpinus (C.","pos":""}],"HORNBILL":[{"def":"Any bird of the family Bucerotidæ, of which about sixty species are known, belonging to numerous genera.","pos":""}],"HORNBLENDE":[{"def":"The common black, or dark green or brown, variety of amphibole.","pos":""}],"HORNBLENDIC":[{"def":"Composed largely of hornblende; resembling or relating to hornblende.","pos":""}],"HORNBLOWER":[{"def":"One who, or that which, blows a horn.","pos":""}],"HORNBOOK":[{"def":"The first book for children, or that from which in former times they learned their letters and rudiments; -- so called because a sheet of horn covered the small, thin board of oak, or the slip of paper, on which the alphabet, digits, and often the Lord's Prayer, were written or printed; a primer.","pos":""},{"def":"A book containing the rudiments of any science or branch of knowledge; a manual; a handbook.","pos":""}],"HORNBUG":[{"def":"A large nocturnal beetle of the genus Lucanus (as L.","pos":""}],"HORNED":[{"def":"Furnished with a horn or horns; furnished with a hornlike process or appendage; as, horned cattle; having some part shaped like a horn.","pos":""}],"HORNEDNESS":[{"def":"The condition of being horned.","pos":""}],"HORNEL":[{"def":"The European sand eel.","pos":""}],"HORNER":[{"def":"The British sand lance or sand eel (Ammodytes lanceolatus).","pos":""}],"HORNET":[{"def":"A large, strong wasp.","pos":""}],"HORNFISH":[{"def":"The garfish or sea needle.","pos":""}],"HORNFOOT":[{"def":"Having hoofs; hoofed.","pos":""}],"HORNIFY":[{"def":"To horn; to cuckold.","pos":""}],"HORNING":[{"def":"Appearance of the moon when increasing, or in the form of a crescent.","pos":""}],"HORNISH":[{"def":"Somewhat like horn; hard.","pos":""}],"HORNITO":[{"def":"A low, oven-shaped mound, common in volcanic regions, and emitting smoke and vapors from its sides and summit.","pos":""}],"HORNOTINE":[{"def":"A yearling; a bird of the year.","pos":""}],"HORNPIPE":[{"def":"Many a hornpipe he tuned to his Phyllis.","pos":""}],"HORNPOUT":[{"def":"See Horned pout, under Horned.","pos":""}],"HORNSNAKE":[{"def":"A harmless snake (Farancia abacura), found in the Southern United States.","pos":""}],"HORNSTONE":[{"def":"A siliceous stone, a variety of quartz, closely resembling flint, but more brittle; -- called also chert.","pos":""}],"HORNTAIL":[{"def":"Any one of family (Uroceridæ) of large hyminopterous insects, allied to the sawflies.","pos":""}],"HORNWORK":[{"def":"An outwork composed of two demibastions joined by a curtain.","pos":""}],"HORNWORT":[{"def":"An aquatic plant (Ceratophyllum), with finely divided leaves.","pos":""}],"HORNWRACK":[{"def":"A bryozoan of the genus Flustra.","pos":""}],"HORNY":[{"def":"Having horns or hornlike projections.","pos":""},{"def":"Composed or made of horn, or of a substance resembling horn; of the nature of horn.","pos":""}],"HORNY-HANDED":[{"def":"Having the hands horny and callous from labor.","pos":""}],"HORNYHEAD":[{"def":"Any North American river chub of the genus Hybopsis, esp.","pos":""}],"HOROGRAPHY":[{"def":"An account of the hours.","pos":""},{"def":"The art of constructing instruments for making the hours, as clocks, watches, and dials.","pos":""}],"HOROLOGE":[{"def":"A servant who called out the hours.","pos":""},{"def":"An instrument indicating the time of day; a timepiece of any kind; a watch, clock, or dial.","pos":""}],"HOROLOGER":[{"def":"A maker or vender of clocks and watches; one skilled in horology.","pos":""}],"HOROLOGICAL":[{"def":"Relating to a horologe, or to horology.","pos":""}],"HOROLOGIOGRAPHER":[{"def":"A maker of clocks, watches, or dials.","pos":""}],"HOROLOGIOGRAPHIC":[{"def":"Of or pertaining to horologiography.","pos":""}],"HOROLOGIOGRAPHY":[{"def":"An account of instruments that show the hour.","pos":""},{"def":"The art of constructing clocks or dials; horography.","pos":""}],"HOROLOGIST":[{"def":"One versed in horology.","pos":""}],"HOROLOGY":[{"def":"The science of measuring time, or the principles and art of constructing instruments for measuring and indicating portions of time, as clocks, watches, dials, etc.","pos":""}],"HOROMETER":[{"def":"An instrument for measuring time.","pos":""}],"HOROMETRICAL":[{"def":"Belonging to horometry.","pos":""}],"HOROMETRY":[{"def":"The art, practice, or method of measuring time by hours and subordinate divisions.","pos":""}],"HOROPTER":[{"def":"The line or surface in which are situated all the points which are seen single while the point of sight, or the adjustment of the eyes, remains unchanged.","pos":""}],"HOROPTERIC":[{"def":"Of or pertaining to the horopter.","pos":""}],"HOROSCOPE":[{"def":"One versed in horoscopy; an astrologer.","pos":""}],"HOROSCOPY":[{"def":"The art or practice of casting horoscopes, or observing the disposition of the stars, with a view to prediction events.","pos":""},{"def":"Aspect of the stars at the time of a person's birth.","pos":""}],"HORRENDOUS":[{"def":"Fearful; frightful.","pos":""}],"HORRENT":[{"def":"Standing erect, as bristles; covered with bristling points; bristled; bristling.","pos":""}],"HORRIBLE":[{"def":"Exciting, or tending to excite, horror or fear; dreadful; terrible; shocking; hideous; as, a horrible sight; a horrible story; a horrible murder.","pos":""}],"HORRIBLENESS":[{"def":"The state or quality of being horrible; dreadfulness; hideousness.","pos":""}],"HORRIBLY":[{"def":"In a manner to excite horror; dreadfully; terribly.","pos":""}],"HORRID":[{"def":"Rough; rugged; bristling.","pos":""},{"def":"Fitted to excite horror; dreadful; hideous; shocking; hence, very offensive.","pos":""}],"HORRIDLY":[{"def":"In a horrid manner.","pos":""}],"HORRIDNESS":[{"def":"The quality of being horrid.","pos":""}],"HORRIFIC":[{"def":"Causing horror; frightful.","pos":""}],"HORRIFICATION":[{"def":"That which causes horror.","pos":""}],"HORRIFY":[{"def":"To cause to feel horror; to strike or impress with horror; as, the sight horrified the beholders.","pos":""}],"HORRIPILATION":[{"def":"A real or fancied bristling of the hair of the head or body, resulting from disease, terror, chilliness, etc.","pos":""}],"HORRISONOUS":[{"def":"Sounding dreadfully; uttering a terrible sound.","pos":""}],"HORROR":[{"def":"A bristling up; a rising into roughness; tumultuous movement.","pos":""},{"def":"A shaking, shivering, or shuddering, as in the cold fit which precedes a fever; in old medical writings, a chill of less severity than a rigor, and more marked than an algor.","pos":""}],"HORROR-STICKEN":[{"def":"Struck with horror; horrified.","pos":""}],"HORROR-STRUCK":[{"def":"Horror-stricken; horrified.","pos":""}],"HORS D'OEUVRE":[{"def":"Something unusual or extraordinary.","pos":""},{"def":"A dish served as a relish, usually at the beginning of a meal.","pos":""}],"HORS DE COMBAT":[{"def":"Out of the combat; disabled from fighting.","pos":""}],"HORSE":[{"def":"A hoofed quadruped of the genus Equus; especially, the domestic horse (E.","pos":""},{"def":"A mass of earthy matter, or rock of the same character as the wall rock, occurring in the course of a vein, as of coal or ore; hence, to take horse -- said of a vein -- is to divide into branches for a distance.","pos":""}],"HORSE GUARDS":[{"def":"A body of cavalry so called; esp.","pos":""}],"HORSE POWER":[{"def":"A unit of power, used in stating the power required to drive machinery, and in estimating the capabilities of animals or steam engines and other prime movers for doing work.","pos":""}],"HORSE-CHESTNUT":[{"def":"Hippocastanum), formerly ground, and fed to horses, whence the name.","pos":""}],"HORSE-DRENCH":[{"def":"A dose of physic for a horse.","pos":""},{"def":"The appliance by which the dose is administred.","pos":""}],"HORSE-JOCKEY":[{"def":"A professional rider and trainer of race horses.","pos":""},{"def":"A trainer and dealer in horses.","pos":""}],"HORSE-LEECH":[{"def":"A large blood-sucking leech (Hæmopsis vorax), of Europe and Northern Africa.","pos":""}],"HORSE-LEECHERY":[{"def":"The business of a farrier; especially, the art of curing the diseases of horses.","pos":""}],"HORSE-LITTER":[{"def":"A carriage hung on poles, and borne by and between two horses.","pos":""}],"HORSE-RADISH":[{"def":"A plant of the genus Nasturtium (N.","pos":""}],"HORSEBACK":[{"def":"The back of a horse.","pos":""},{"def":"An extended ridge of sand, gravel, and bowlders, in a half- stratified condition.","pos":""}],"HORSEFLESH":[{"def":"The flesh of horses.","pos":""},{"def":"Horses, generally; the qualities of a horse; as, he is a judge of horseflesh.","pos":""}],"HORSEFLY":[{"def":"Any dipterous fly of the family Tabanidæ, that stings horses, and sucks their blood.","pos":""},{"def":"The horse tick or forest fly (Hippobosca).","pos":""}],"HORSEFOOT":[{"def":"The Limulus or horseshoe crab.","pos":""}],"HORSEHAIR":[{"def":"A hair of a horse, especially one from the mane or tail; the hairs of the mane or tail taken collectively; a fabric or tuft made of such hairs.","pos":""}],"HORSEHEAD":[{"def":"The silver moonfish (Selene vomer).","pos":""}],"HORSEHIDE":[{"def":"The hide of a horse.","pos":""},{"def":"Leather made of the hide of a horse.","pos":""}],"HORSELAUGH":[{"def":"A loud, boisterous laugh; a guffaw.","pos":""}],"HORSELESS":[{"def":"Being without a horse; specif.","pos":""}],"HORSEMAN":[{"def":"A mounted soldier; a cavalryman.","pos":""}],"HORSEMANSHIP":[{"def":"The act or art of riding, and of training and managing horses; manege.","pos":""}],"HORSENAIL":[{"def":"A thin, pointed nail, with a heavy flaring head, for securing a horsehoe to the hoof; a horsehoe nail.","pos":""}],"HORSEPLAY":[{"def":"Rude, boisterous play.","pos":""}],"HORSEPOND":[{"def":"A pond for watering horses.","pos":""}],"HORSERAKE":[{"def":"A rake drawn by a horse.","pos":""}],"HORSESHOE":[{"def":"The Limulus of horsehoe crab.","pos":""}],"HORSESHOEING":[{"def":"The act or employment of shoeing horses.","pos":""}],"HORSESHOER":[{"def":"One who shoes horses.","pos":""}],"HORSETAIL":[{"def":"A leafless plant, with hollow and rushlike stems.","pos":""}],"HORSEWEED":[{"def":"A composite plant (Erigeron Canadensis), which is a common weed.","pos":""}],"HORSEWHIP":[{"def":"A whip for horses.","pos":""}],"HORSEWOMAN":[{"def":"A woman who rides on horseback.","pos":""}],"HORSEWOOD":[{"def":"A West Indian tree (Calliandra latifolia) with showy, crimson blossoms.","pos":""}],"HORSEWORM":[{"def":"The larva of a botfly.","pos":""}],"HORSINESS":[{"def":"The condition or quality of being a horse; that which pertains to a horse.","pos":""},{"def":"Fondness for, or interest in, horses.","pos":""}],"HORSY":[{"def":"Pertaining to, or suggestive of, a horse, or of horse racing; as, horsy manners; garments of fantastically horsy fashions.","pos":""}],"HORTATION":[{"def":"The act of exhorting, inciting, or giving advice; exhortation.","pos":""}],"HORTATIVE":[{"def":"Giving exhortation; advisory; exhortative.","pos":""}],"HORTATORY":[{"def":"Giving exhortation or advise; encouraging; exhortatory; inciting; as, a hortatory speech.","pos":""}],"HORTENSIAL":[{"def":"Fit for a garden.","pos":""}],"HORTICULTOR":[{"def":"One who cultivates a garden.","pos":""}],"HORTICULTURAL":[{"def":"Of or pertaining to horticulture, or the culture of gardens or orchards.","pos":""}],"HORTICULTURE":[{"def":"The cultivation of a garden or orchard; the art of cultivating gardens or orchards.","pos":""}],"HORTICULTURIST":[{"def":"One who practices horticulture.","pos":""}],"HORTULAN":[{"def":"Belonging to a garden.","pos":""}],"HORTUS SICCUS":[{"def":"A collection of specimens of plants, dried and preserved, and arranged systematically; an herbarium.","pos":""}]}