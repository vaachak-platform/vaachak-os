{"HELAMYS":[{"def":"See Jumping hare, under Hare.","pos":""}],"HELCOPLASTY":[{"def":"The act or process of repairing lesions made by ulcers, especially by a plastic operation.","pos":""}],"HELE":[{"def":"Health; welfare.","pos":""}],"HELENIN":[{"def":"A neutral organic substance found in the root of the elecampane (Inula helenium), and extracted as a white crystalline or oily material, with a slightly bitter taste.","pos":""}],"HELIACAL":[{"def":"Emerging from the light of the sun, or passing into it; rising or setting at the same, or nearly the same, time as the sun.","pos":""}],"HELIACALLY":[{"def":"In a heliacal manner.","pos":""}],"HELIANTHIN":[{"def":"An artificial, orange dyestuff, analogous to tropaolin, and like it used as an indicator in alkalimetry; -- called also methyl orange.","pos":""}],"HELIANTHOID":[{"def":"Of or pertaining to the Helianthoidea.","pos":""}],"HELIANTHOIDEA":[{"def":"An order of Anthozoa; the Actinaria.","pos":""}],"HELICAL":[{"def":"Of or pertaining to, or in the form of, a helix; spiral; as, a helical staircase; a helical spring.","pos":""}],"HELICHRYSUM":[{"def":"A genus of composite plants, with shining, commonly white or yellow, or sometimes reddish, radiated involucres, which are often called \"everlasting flowers.","pos":""}],"HELICIFORM":[{"def":"Having the form of a helix; spiral.","pos":""}],"HELICIN":[{"def":"A glucoside obtained as a white crystalline substance by partial oxidation of salicin, from a willow (Salix Helix of Linnæus.","pos":""}],"HELICINE":[{"def":"Curled; spiral; helicoid; -- applied esp.","pos":""}],"HELICOGRAPH":[{"def":"An instrument for drawing spiral lines on a plane.","pos":""}],"HELICOID":[{"def":"Shaped like a snail shell; pertaining to the Helicidæ, or Snail family.","pos":""}],"HELICOIDAL":[{"def":"Same as Helicoid.","pos":""}],"HELICON":[{"def":"A mountain in Boeotia, in Greece, supposed by the Greeks to be the residence of Apollo and the Muses.","pos":""}],"HELICONIA":[{"def":"One of numerous species of Heliconius, a genus of tropical American butterflies.","pos":""}],"HELICONIAN":[{"def":"Like or pertaining to the butterflies of the genus Heliconius.","pos":""}],"HELICOTREMA":[{"def":"The opening by which the two scalæ communicate at the top of the cochlea of the ear.","pos":""}],"HELIO-":[{"def":"A combining form from Gr.","pos":""},{"def":"pertaining to the sun's center, or appearing to be seen from it; having, or relating to, the sun as a center; -- opposed to geocentrical.","pos":""}],"HELIOCHROME":[{"def":"A photograph in colors.","pos":""}],"HELIOCHROMIC":[{"def":"Pertaining to, or produced by, heliochromy.","pos":""}],"HELIOCHROMY":[{"def":"The art of producing photographs in color.","pos":""}],"HELIOGRAM":[{"def":"A message transmitted by a heliograph.","pos":""}],"HELIOGRAPH":[{"def":"A picture taken by heliography; a photograph.","pos":""},{"def":"An instrument for taking photographs of the sun.","pos":""}],"HELIOGRAPHIC":[{"def":"Of or pertaining to heliography or a heliograph; made by heliography.","pos":""}],"HELIOGRAVURE":[{"def":"The process of photographic engraving.","pos":""}],"HELIOLATER":[{"def":"A worshiper of the sun.","pos":""}],"HELIOLITE":[{"def":"A fossil coral of the genus Heliolites, having twelve-rayed cells.","pos":""}],"HELIOMETER":[{"def":"An instrument devised originally for measuring the diameter of the sun; now employed for delicate measurements of the distance and relative direction of two stars too far apart to be easily measured in the field of view of an ordinary telescope.","pos":""},{"def":"Of or pertaining to the heliometer, or to heliometry.","pos":""}],"HELIOMETRY":[{"def":"The apart or practice of measuring the diameters of heavenly bodies, their relative distances, etc.","pos":""}],"HELIOPORA":[{"def":"An East Indian stony coral now known to belong to the Alcyonaria; -- called also blue coral.","pos":""}],"HELIOSCOPE":[{"def":"A telescope or instrument for viewing the sun without injury to the eyes, as through colored glasses, or with mirrors which reflect but a small portion of light.","pos":""}],"HELIOSTAT":[{"def":"An instrument consisting of a mirror moved by clockwork, by which a sunbeam is made apparently stationary, by being steadily directed to one spot during the whole of its diurnal period; also, a geodetic heliotrope.","pos":""}],"HELIOTROPE":[{"def":"An instrument or machine for showing when the sun arrived at the tropics and equinoctial line.","pos":""},{"def":"A plant of the genus Heliotropium; -- called also turnsole and girasole.","pos":""}],"HELIOTROPER":[{"def":"The person at a geodetic station who has charge of the heliotrope.","pos":""}],"HELIOTROPIC":[{"def":"Manifesting heliotropism; turning toward the sun.","pos":""}],"HELIOTROPISM":[{"def":"The phenomenon of turning toward the light, seen in many leaves and flowers.","pos":""}],"HELIOTYPE":[{"def":"A picture obtained by the process of heliotypy.","pos":""}],"HELIOTYPIC":[{"def":"Relating to, or obtained by, heliotypy.","pos":""}],"HELIOTYPY":[{"def":"A method of transferring pictures from photographic negatives to hardened gelatin plates from which impressions are produced on paper as by lithography.","pos":""}],"HELIOZOA":[{"def":"An order of fresh-water rhizopods having a more or less globular form, with slender radiating pseudopodia; the sun animalcule.","pos":""}],"HELIUM":[{"def":"A gaseous element found in the atmospheres of the sun and earth and in some rare minerals.","pos":""}],"HELIX":[{"def":"A nonplane curve whose tangents are all equally inclined to a given plane.","pos":""},{"def":"A caulicule or little volute under the abacus of the Corinthian capital.","pos":""}],"HELL":[{"def":"The place of the dead, or of souls after death; the grave; -- called in Hebrew sheol, and by the Greeks hades.","pos":""},{"def":"The place or state of punishment for the wicked after death; the abode of evil spirits.","pos":""}],"HELL-HAUNTED":[{"def":"Haunted by devils; hellish.","pos":""}],"HELLANODIC":[{"def":"A judge or umpire in games or combats.","pos":""}],"HELLBENDER":[{"def":"A large North American aquatic salamander (Protonopsis horrida or Menopoma Alleghaniensis).","pos":""}],"HELLBORN":[{"def":"Born in or of hell.","pos":""}],"HELLBRED":[{"def":"Produced in hell.","pos":""}],"HELLBREWED":[{"def":"Prepared in hell.","pos":""}],"HELLBROTH":[{"def":"A composition for infernal purposes; a magical preparation.","pos":""}],"HELLEBORE":[{"def":"A genus of perennial herbs (Helleborus) of the Crowfoot family, mostly having powerfully cathartic and even poisonous qualities.","pos":""},{"def":"Any plant of several species of the poisonous liliaceous genus Veratrum, especially V.","pos":""}],"HELLEBOREIN":[{"def":"A poisonous glucoside accompanying helleborin in several species of hellebore, and extracted as a white crystalline substance with a bittersweet taste.","pos":""}],"HELLEBORIN":[{"def":"A poisonous glucoside found in several species of hellebore, and extracted as a white crystalline substance with a sharp tingling taste.","pos":""}],"HELLEBORISM":[{"def":"The practice or theory of using hellebore as a medicine.","pos":""}],"HELLENE":[{"def":"A native of either ancient or modern Greece; a Greek.","pos":""}],"HELLENIAN":[{"def":"Of or pertaining to the Hellenes, or Greeks.","pos":""}],"HELLENIC":[{"def":"Of or pertaining to the Hellenes, or inhabitants of Greece; Greek; Grecian.","pos":""}],"HELLENISM":[{"def":"A phrase or form of speech in accordance with genius and construction or idioms of the Greek language; a Grecism.","pos":""},{"def":"The type of character of the ancient Greeks, who aimed at culture, grace, and amenity, as the chief elements in human well-being and perfection.","pos":""}],"HELLENIST":[{"def":"Pertaining to the Hellenists.","pos":""}],"HELLENISTICALLY":[{"def":"According to the Hellenistic manner or dialect.","pos":""}],"HELLENIZE":[{"def":"To use the Greek language; to play the Greek; to Grecize.","pos":""}],"HELLESPONT":[{"def":"A narrow strait between Europe and Asia, now called the Daradanelles.","pos":""}],"HELLESPONTINE":[{"def":"Of or pertaining to the Hellespont.","pos":""},{"def":"The aquatic larva of a large American winged insect (Corydalus cornutus), much used a fish bait by anglers; the dobson.","pos":""}],"HELLHAG":[{"def":"A hag of or fit for hell.","pos":""}],"HELLHOUND":[{"def":"A dog of hell; an agent of hell.","pos":""}],"HELLIER":[{"def":"One who heles or covers; hence, a tiler, slater, or thatcher.","pos":""}],"HELLISH":[{"def":"Of or pertaining to hell; like hell; infernal; malignant; wicked; detestable; diabolical.","pos":""}],"HELLKITE":[{"def":"A kite of infernal breed.","pos":""}],"HELM":[{"def":"See Haulm, straw.","pos":""}],"HELMAGE":[{"def":"Guidance; direction.","pos":""}],"HELMED":[{"def":"Covered with a helmet.","pos":""}],"HELMET":[{"def":"A defensive covering for the head.","pos":""},{"def":"The representation of a helmet over shields or coats of arms, denoting gradations of rank by modifications of form.","pos":""}],"HELMET-SHAPED":[{"def":"Shaped like a helmet; galeate.","pos":""}],"HELMETED":[{"def":"Wearing a helmet; furnished with or having a helmet or helmet- shaped part; galeate.","pos":""}],"HELMINTH":[{"def":"An intestinal worm, or wormlike intestinal parasite; one of the Helminthes.","pos":""}],"HELMINTHES":[{"def":"One of the grand divisions or branches of the animal kingdom.","pos":""}],"HELMINTHIASIS":[{"def":"A disease in which worms are present in some part of the body.","pos":""}],"HELMINTHIC":[{"def":"Of or relating to worms, or Helminthes; expelling worms.","pos":""},{"def":"A vermifuge; an anthelmintic.","pos":""}],"HELMINTHITE":[{"def":"One of the sinuous tracks on the surfaces of many stones, and popularly considered as worm trails.","pos":""}],"HELMINTHOID":[{"def":"Wormlike; vermiform.","pos":""},{"def":"Of or pertaining to helminthology.","pos":""}],"HELMINTHOLOGIST":[{"def":"One versed in helminthology.","pos":""}],"HELMINTHOLOGY":[{"def":"The natural history, or study, of worms, esp.","pos":""}],"HELMLESS":[{"def":"Destitute of a helmet.","pos":""},{"def":"Without a helm or rudder.","pos":""}],"HELMSMAN":[{"def":"The man at the helm; a steersman.","pos":""}],"HELMWIND":[{"def":"A wind attending or presaged by the cloud called helm.","pos":""}],"HELOT":[{"def":"A slave in ancient Sparta; a Spartan serf; hence, a slave or serf.","pos":""}],"HELOTISM":[{"def":"The condition of the Helots or slaves in Sparta; slavery.","pos":""}],"HELOTRY":[{"def":"The Helots, collectively; slaves; bondsmen.","pos":""}],"HELP":[{"def":"To furnish with strength or means for the successful performance of any action or the attainment of any object; to aid; to assist; as, to help a man in his work; to help one to remember; -- the following infinitive is commonly used without to; as, \"Help me scale yon balcony.","pos":""},{"def":"To furnish with the means of deliverance from trouble; as, to help one in distress; to help one out of prison.","pos":""}],"HELPER":[{"def":"One who, or that which, helps, aids, assists, or relieves; as, a lay helper in a parish.","pos":""}],"HELPFUL":[{"def":"Furnishing help; giving aid; assistant; useful; salutary.","pos":""}],"HELPLESS":[{"def":"Destitute of help or strength; unable to help or defend one's self; needing help; feeble; weak; as, a helpless infant.","pos":""},{"def":"Beyond help; irremediable.","pos":""}],"HELPMATE":[{"def":"A helper; a companion; specifically, a wife.","pos":""}],"HELPMEET":[{"def":"A wife; a helpmate.","pos":""}],"HELTER-SKELTER":[{"def":"In hurry and confusion; without definite purpose; irregularly.","pos":""}],"HELVE":[{"def":"The handle of an ax, hatchet, or adze.","pos":""}],"HELVETIAN":[{"def":"Same as Helvetic.","pos":""},{"def":"A Swiss; a Switzer.","pos":""}],"HELVETIC":[{"def":"Of or pertaining to the Helvetii, the ancient inhabitant of the Alps, now Switzerland, or to the modern states and inhabitant of the Alpine regions; as, the Helvetic confederacy; Helvetic states.","pos":""},{"def":"A mineral of a yellowish color, consisting chiefly of silica, glucina, manganese, and iron, with a little sulphur.","pos":""}]}