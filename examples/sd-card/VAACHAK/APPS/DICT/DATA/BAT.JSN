{"BAT":[{"def":"Shale or bituminous shale.","pos":""}],"BAT PRINTING":[{"def":"A mode of printing on glazed ware.","pos":""}],"BATABLE":[{"def":"Note: The border land between England and Scotland, being formerly a subject of contention, was called batable or debatable ground.","pos":""}],"BATARDEAU":[{"def":"A wall built across the ditch of a fortification, with a sluice gate to regulate the height of water in the ditch on both sides of the wall.","pos":""},{"def":"An aboriginal American name for the sweet potato (Ipomæa batatas).","pos":""}],"BATAVIAN":[{"def":"Of or pertaining to (a) the Batavi, an ancient Germanic tribe; or to (b) as, a Batavian legion.","pos":""}],"BATCH":[{"def":"The quantity of bread baked at one time.","pos":""},{"def":"A quantity of anything produced at one operation; a group or collection of persons or things of the same kind; as, a batch of letters; the next batch of business.","pos":""}],"BATE":[{"def":"Strife; contention.","pos":""}],"BATED":[{"def":"Reduced; lowered; restrained; as, to speak with bated breath.","pos":""}],"BATEFUL":[{"def":"Exciting contention; contentious.","pos":""}],"BATELESS":[{"def":"Not to be abated.","pos":""}],"BATEMENT":[{"def":"Abatement; diminution.","pos":""}],"BATFISH":[{"def":"A name given to several species of fishes: (a) The Malthe vespertilio of the Atlantic coast.","pos":""}],"BATFOWLER":[{"def":"One who practices or finds sport in batfowling.","pos":""}],"BATFOWLING":[{"def":"A mode of catching birds at night, by holding a torch or other light, and beating the bush or perch where they roost.","pos":""}],"BATH":[{"def":"A medium, as heated sand, ashes, steam, hot air, through which heat is applied to a body.","pos":""},{"def":"A solution in which plates or prints are immersed; also, the receptacle holding the solution.","pos":""}],"BATHE":[{"def":"To wash by immersion, as in a bath; to subject to a bath.","pos":""},{"def":"To lave; to wet.","pos":""}],"BATHETIC":[{"def":"Having the character of bathos.","pos":""}],"BATHING":[{"def":"Act of taking a bath or baths.","pos":""}],"BATHMISM":[{"def":"See Vital force.","pos":""}],"BATHOMETER":[{"def":"An instrument for measuring depths, esp.","pos":""}],"BATHORSE":[{"def":"A horse which carries an officer's baggage during a campaign.","pos":""}],"BATHOS":[{"def":"A ludicrous descent from the elevated to the low, in writing or speech; anticlimax.","pos":""}],"BATHYBIUS":[{"def":"A name given by Prof.","pos":""}],"BATHYGRAPHIC":[{"def":"Descriptive of the ocean depth; as, a bathygraphic chart.","pos":""},{"def":"Pertaining to bathymetry; relating to the measurement of depths, especially of depths in the sea.","pos":""}],"BATHYMETRY":[{"def":"The art or science of sounding, or measuring depths in the sea.","pos":""}],"BATING":[{"def":"With the exception of; excepting.","pos":""}],"BATISTE":[{"def":"Originally, cambric or lawn of fine linen; now applied also to cloth of similar texture made of cotton.","pos":""}],"BATLET":[{"def":"A short bat for beating clothes in washing them; -- called also batler, batling staff, batting staff.","pos":""}],"BATMAN":[{"def":"A weight used in the East, varying according to the locality; in Turkey, the greater batman is about 157 pounds, the lesser only a fourth of this; at Aleppo and Smyrna, the batman is 17 pounds.","pos":""}],"BATOIDEI":[{"def":"The division of fishes which includes the rays and skates.","pos":""}],"BATON":[{"def":"An ordinary with its ends cut off, borne sinister as a mark of bastardy, and containing one fourth in breadth of the bend sinister; -- called also bastard bar.","pos":""}],"BATOON":[{"def":"See Baton, and Baston.","pos":""}],"BATRACHIA":[{"def":"The order of amphibians which includes the frogs and toads; the Anura.","pos":""}],"BATRACHIAN":[{"def":"Pertaining to the Batrachia.","pos":""},{"def":"One of the Batrachia.","pos":""}],"BATRACHOMYOMACHY":[{"def":"The battle between the frogs and mice; -- a Greek parody on the Iliad, of uncertain authorship.","pos":""}],"BATRACHOPHAGOUS":[{"def":"Feeding on frogs.","pos":""}],"BATSMAN":[{"def":"The one who wields the bat in cricket, baseball, etc.","pos":""},{"def":"Shaped like a bat's wing; as, a bat's-wing burner.","pos":""}],"BATTA":[{"def":"Rate of exchange; also, the discount on uncurrent coins.","pos":""}],"BATTABLE":[{"def":"Capable of culti [Obs.","pos":""}],"BATTAILANT":[{"def":"Prepared for battle; combatant; warlike.","pos":""}],"BATTAILOUS":[{"def":"Arrayed for battle; fit or eager for battle; warlike.","pos":""}],"BATTALIA":[{"def":"Order of battle; disposition or arrangement of troops (brigades, regiments, battalions, etc.","pos":""},{"def":"An army in battle array; also, the main battalia or body.","pos":""}],"BATTALION":[{"def":"A regiment, or two or more companies of a regiment, esp.","pos":""}],"BATTEL":[{"def":"A single combat; as, trial by battel.","pos":""}],"BATTEN":[{"def":"To make fat by plenteous feeding; to fatten.","pos":""},{"def":"To fertilize or enrich, as land.","pos":""}],"BATTENING":[{"def":"Furring done with small pieces nailed directly upon the wall.","pos":""}],"BATTER":[{"def":"To flatten (metal) by hammering, so as to compress it inwardly and spread it outwardly.","pos":""}],"BATTERER":[{"def":"One who, or that which, batters.","pos":""}],"BATTERING TRAIN":[{"def":"A train of artillery for siege operations.","pos":""}],"BATTERING-RAM":[{"def":"A blacksmith's hammer, suspended, and worked horizontally.","pos":""}],"BATTERY":[{"def":"The unlawful beating of another.","pos":""},{"def":"A series of stamps operated by one motive power, for crushing ores containing the precious metals.","pos":""}],"BATTING":[{"def":"The act of one who bats; the management of a bat in playing games of ball.","pos":""},{"def":"Cotton in sheets, prepared for use in making quilts, etc.","pos":""}],"BATTLE":[{"def":"A general action, fight, or encounter, in which all the divisions of an army are or may be engaged; an engagement; a combat.","pos":""},{"def":"A struggle; a contest; as, the battle of life.","pos":""}],"BATTLE RANGE":[{"def":"The range within which the fire of small arms is very destructive.","pos":""}],"BATTLE SHIP":[{"def":"An armor-plated man-of-war built of steel and heavily armed, generally having from ten thousand to fifteen thousand tons displacement, and intended to be fit to meet the heaviest ships in line of battle.","pos":""}],"BATTLEDOOR":[{"def":"A child's hornbook.","pos":""}],"BATTLEMENTED":[{"def":"Having battlements.","pos":""}],"BATTOLOGIST":[{"def":"One who battologizes.","pos":""}],"BATTOLOGIZE":[{"def":"To keep repeating needlessly; to iterate.","pos":""}],"BATTOLOGY":[{"def":"A needless repetition of words in speaking or writing.","pos":""}],"BATTON":[{"def":"See Batten, and Baton.","pos":""}],"BATTURE":[{"def":"An elevated river bed or sea bed.","pos":""}],"BATTUTA":[{"def":"The measuring of time by beating.","pos":""}],"BATTY":[{"def":"Belonging to, or resembling, a bat.","pos":""}],"BATULE":[{"def":"A springboard in a circus or gymnasium; -- called also batule board.","pos":""}],"BATZ":[{"def":"A small copper coin, with a mixture of silver, formerly current in some parts of Germany and Switzerland.","pos":""}]}