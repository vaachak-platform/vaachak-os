{"GEM":[{"def":"A precious stone of any kind, as the ruby, emerald, topaz, sapphire, beryl, spinel, etc.","pos":""},{"def":"Anything of small size, or expressed within brief limits, which is regarded as a gem on account of its beauty or value, as a small picture, a verse of poetry, a witty or wise saying.","pos":""}],"GEMARA":[{"def":"The second part of the Talmud, or the commentary on the Mishna (which forms the first part or text).","pos":""}],"GEMARIC":[{"def":"Pertaining to the Gemara.","pos":""}],"GEMARIST":[{"def":"One versed in the Gemara, or adhering to its teachings.","pos":""}],"GEMEL":[{"def":"Coupled; paired.","pos":""}],"GEMELLIPA-ROUS":[{"def":"Producing twins.","pos":""}],"GEMINATE":[{"def":"In pairs or twains; two together; binate; twin; as, geminate flowers.","pos":""}],"GEMINATION":[{"def":"A doubling; duplication; repetition.","pos":""}],"GEMINI":[{"def":"A constellation of the zodiac, containing the two bright stars Castor and Pollux; also, the third sign of the zodiac, which the sun enters about May 20th.","pos":""}],"GEMINIFLOROUS":[{"def":"Having the flowers arranged in pairs.","pos":""}],"GEMINOUS":[{"def":"Double; in pairs.","pos":""}],"GEMINY":[{"def":"Twins; a pair; a couple.","pos":""}],"GEMITORES":[{"def":"A division of birds including the true pigeons.","pos":""}],"GEMMA":[{"def":"A leaf bud, as distinguished from a flower bud.","pos":""},{"def":"A bud spore; one of the small spores or buds in the reproduction of certain Protozoa, which separate one at a time from the parent cell.","pos":""}],"GEMMACEOUS":[{"def":"Of or pertaining to gems or to gemmæ; of the nature of, or resembling, gems or gemmæ.","pos":""}],"GEMMARY":[{"def":"Of or pertaining to gems.","pos":""}],"GEMMATE":[{"def":"Having buds; reproducing by buds.","pos":""}],"GEMMATED":[{"def":"Having buds; adorned with gems or jewels.","pos":""}],"GEMMATION":[{"def":"The formation of a new individual, either animal or vegetable, by a process of budding; an asexual method of reproduction; gemmulation; gemmiparity.","pos":""},{"def":"The arrangement of buds on the stalk; also, of leaves in the bud.","pos":""}],"GEMMEOUS":[{"def":"Pertaining to gems; of the nature of gems; resembling gems.","pos":""}],"GEMMIFEROUS":[{"def":"Producing gems or buds; (Biol.","pos":""},{"def":"multiplying by buds.","pos":""}],"GEMMIFICATION":[{"def":"The production of a bud or gem.","pos":""}],"GEMMIFLORATE":[{"def":"Having flowers like buds.","pos":""}],"GEMMINESS":[{"def":"The state or quality of being gemmy; spruceness; smartness.","pos":""},{"def":"Animals which increase by budding, as hydroids.","pos":""}],"GEMMIPARITY":[{"def":"Reproduction by budding; gemmation.","pos":""}],"GEMMIPAROUS":[{"def":"Producing buds; reproducing by buds.","pos":""}],"GEMMOSITY":[{"def":"The quality or characteristics of a gem or jewel.","pos":""}],"GEMMULIFEROUS":[{"def":"Bearing or producing gemmules or buds.","pos":""}],"GEMMY":[{"def":"Full of gems; bright; glittering like a gem.","pos":""}],"GEMOTE":[{"def":"A meeting; -- used in combination, as, Witenagemote, an assembly of the wise men.","pos":""}],"GEMS-HORN":[{"def":"An organ stop with conical tin pipes.","pos":""}],"GEMSBOK":[{"def":"A South African antelope (Oryx Capensis), having long, sharp, nearly straight horns.","pos":""}],"GEMUL":[{"def":"A small South American deer (Furcifer Chilensis), with simple forked horns.","pos":""}]}