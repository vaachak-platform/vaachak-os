{"BRONCHIA":[{"def":"The bronchial tubes which arise from the branching of the trachea, esp.","pos":""}],"BRONCHIAL":[{"def":"Belonging to the bronchi and their ramifications in the lungs.","pos":""}],"BRONCHIOLE":[{"def":"A minute bronchial tube.","pos":""}],"BRONCHITIC":[{"def":"Of or pertaining to bronchitis; as, bronchitic inflammation.","pos":""}],"BRONCHITIS":[{"def":"Inflammation, acute or chronic, of the bronchial tubes or any part of them.","pos":""}],"BRONCHO":[{"def":"A native or a Mexican horse of small size.","pos":""}],"BRONCHO-PNEUMONIA":[{"def":"Inflammation of the bronchi and lungs; catarrhal pneumonia.","pos":""}],"BRONCHOPHONY":[{"def":"A modification of the voice sounds, by which they are intensified and heightened in pitch; -- observed in auscultation of the chest in certain cases of intro-thoracic disease.","pos":""}],"BRONCHOTOME":[{"def":"An instrument for cutting into the bronchial tubes.","pos":""}],"BRONCHOTOMY":[{"def":"An incision into the windpipe or larynx, including the operations of tracheotomy and laryngotomy.","pos":""}],"BRONCHUS":[{"def":"One of the subdivisions of the trachea or windpipe; esp.","pos":""}],"BRONCO":[{"def":"Same as Broncho.","pos":""}],"BRONTOGRAPH":[{"def":"BRONTOLITE; BRONTOLITH Bron\"to*lite, Bron\"to*lith, n.","pos":""}],"BRONTOLOGY":[{"def":"A treatise upon thunder.","pos":""}],"BRONTOMETER":[{"def":"An instrument for noting or recording phenomena attendant on thunderstorms.","pos":""}],"BRONTOSAURUS":[{"def":"A genus of American jurassic dinosaurs.","pos":""}],"BRONTOTHERIUM":[{"def":"A genus of large extinct mammals from the miocene strata of western North America.","pos":""}],"BRONTOZOUM":[{"def":"An extinct animal of large size, known from its three-toed footprints in Mesozoic sandstone.","pos":""}],"BRONZE":[{"def":"An alloy of copper and tin, to which small proportions of other metals, especially zinc, are sometimes added.","pos":""},{"def":"A statue, bust, etc.","pos":""}],"BRONZE STEEL":[{"def":"A hard tough alloy of tin, copper, and iron, which can be used for guns.","pos":""}],"BRONZEWING":[{"def":"An Australian pigeon of the genus Phaps, of several species; -- so called from its bronze plumage.","pos":""}],"BRONZINE":[{"def":"A metal so prepared as to have the appearance of bronze.","pos":""},{"def":"Made of bronzine; resembling bronze; bronzelike.","pos":""}],"BRONZING":[{"def":"The act or art of communicating to articles in metal, wood, clay, plaster, etc.","pos":""},{"def":"A material for bronzing.","pos":""}],"BRONZIST":[{"def":"One who makes, imitates, collects, or deals in, bronzes.","pos":""}],"BRONZITE":[{"def":"A variety of enstatite, often having a bronzelike luster.","pos":""}]}