{"EIDER":[{"def":"Any species of sea duck of the genus Somateria, esp.","pos":""}],"EIDOGRAPH":[{"def":"An instrument for copying drawings on the same or a different scale; a form of the pantograph.","pos":""}],"EIDOLON":[{"def":"An image or representation; a form; a phantom; an apparition.","pos":""}],"EIGH":[{"def":"An exclamation expressing delight.","pos":""}],"EIGHT":[{"def":"An island in a river; an ait.","pos":""}],"EIGHTEEN":[{"def":"Eight and ten; as, eighteen pounds.","pos":""}],"EIGHTEENTH":[{"def":"Next in order after the seventeenth.","pos":""},{"def":"Consisting of one of eighteen equal parts or divisions of a thing.","pos":""}],"EIGHTFOLD":[{"def":"Eight times a quantity.","pos":""}],"EIGHTH":[{"def":"Next in order after the seventh.","pos":""},{"def":"Consisting of one of eight equal divisions of a thing.","pos":""}],"EIGHTHLY":[{"def":"As the eighth in order.","pos":""}],"EIGHTIETH":[{"def":"The next in order after seventy-ninth.","pos":""},{"def":"Consisting of one of eighty equal parts or divisions.","pos":""}],"EIGHTLING":[{"def":"A compound or twin crystal made up of eight individuals.","pos":""}],"EIGHTSCORE":[{"def":"Eight times twenty; a hundred and sixty.","pos":""}],"EIGHTY":[{"def":"Eight times ten; fourscore.","pos":""}],"EIGNE":[{"def":"Eldest; firstborn.","pos":""}],"EIKON":[{"def":"An image or effigy; -- used rather in an abstract sense, and rarely for a work of art.","pos":""}],"EIKONOGEN":[{"def":"The sodium salt of a sulphonic acid of a naphthol, C10H5(OH)(NH2)SO3Na used as a developer.","pos":""}],"EIKOSANE":[{"def":"A solid hydrocarbon, C20H42, of the paraffine series, of artificial production, and also probably occurring in petroleum.","pos":""}],"EIKOSYLENE":[{"def":"A liquid hydrocarbon, C20H38, of the acetylene series, obtained from brown coal.","pos":""}],"EIRENARCH":[{"def":"A justice of the peace; irenarch.","pos":""}],"EIRIE":[{"def":"See Aerie, and Eyrie.","pos":""}],"EISEL":[{"def":"Vinegar; verjuice.","pos":""}],"EISTEDDFOD":[{"def":"Am assembly or session of the Welsh bards; an annual congress of bards, minstrels and literati of Wales, -- being a patriotic revival of the old custom.","pos":""}],"EITHER":[{"def":"One of two; the one or the other; -- properly used of two things, but sometimes of a larger number, for any one.","pos":""},{"def":"Each of two; the one and the other; both; -- formerly, also, each of any number.","pos":""}]}