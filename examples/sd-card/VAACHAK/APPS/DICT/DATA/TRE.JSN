{"TREACHER":[{"def":"A traitor; a cheat.","pos":""}],"TREACHEROUS":[{"def":"Like a traitor; involving treachery; violating allegiance or faith pledged; traitorous to the state or sovereign; perfidious in private life; betraying a trust; faithless.","pos":""}],"TREACHERY":[{"def":"Violation of allegiance or of faith and confidence; treasonable or perfidious conduct; perfidy; treason.","pos":""}],"TREACLE":[{"def":"A remedy against poison.","pos":""}],"TREACLY":[{"def":"Like, or composed of, treacle.","pos":""}],"TREAD":[{"def":"To set the foot; to step.","pos":""},{"def":"To walk or go; especially, to walk with a stately or a cautious step.","pos":""}],"TREADLE":[{"def":"The chalaza of a bird's egg; the tread.","pos":""}],"TREADMILL":[{"def":"A mill worked by persons treading upon steps on the periphery of a wide wheel having a horizontal axis.","pos":""}],"TREADWHEEL":[{"def":"A wheel turned by persons or animals, by treading, climbing, or pushing with the feet, upon its periphery or face.","pos":""}],"TREASON":[{"def":"The offense of attempting to overthrow the government of the state to which the offender owes allegiance, or of betraying the state into the hands of a foreign power; disloyalty; treachery.","pos":""},{"def":"Loosely, the betrayal of any trust or confidence; treachery; perfidy.","pos":""}],"TREASONABLE":[{"def":"Pertaining to treason; consisting of treason; involving the crime of treason, or partaking of its guilt.","pos":""}],"TREASONOUS":[{"def":"The treasonous book of the Court of King James.","pos":""}],"TREASURE":[{"def":"Wealth accumulated; especially, a stock, or store of money in reserve.","pos":""},{"def":"A great quantity of anything collected for future use; abundance; plenty.","pos":""}],"TREASURE-HOUSE":[{"def":"A house or building where treasures and stores are kept.","pos":""}],"TREASURE-TROVE":[{"def":"Any money, bullion, or the like, found in the earth, or otherwise hidden, the owner of which is not known.","pos":""}],"TREASURERSHIP":[{"def":"The office of treasurer.","pos":""}],"TREASURESS":[{"def":"A woman who is a treasurer.","pos":""}],"TREASURY":[{"def":"A place or building in which stores of wealth are deposited; especially, a place where public revenues are deposited and kept, and where money is disbursed to defray the expenses of government; hence, also, the place of deposit and disbursement of any collected funds.","pos":""},{"def":"That department of a government which has charge of the finances.","pos":""}],"TREASURY STOCK":[{"def":"Issued stock of an incorporated company held by the company itself.","pos":""}],"TREAT":[{"def":"To care for medicinally or surgically; to manage in the use of remedies or appliances; as, to treat a disease, a wound, or a patient.","pos":""}],"TREATABLE":[{"def":"Manageable; tractable; hence, moderate; not violent.","pos":""}],"TREATABLY":[{"def":"In a treatable manner.","pos":""}],"TREATER":[{"def":"One who treats; one who handles, or discourses on, a subject; also, one who entertains.","pos":""}],"TREATISE":[{"def":"A written composition on a particular subject, in which its principles are discussed or explained; a tract.","pos":""},{"def":"Story; discourse.","pos":""}],"TREATISER":[{"def":"One who writes a treatise.","pos":""}],"TREATMENT":[{"def":"The act or manner of treating; management; manipulation; handling; usage; as, unkind treatment; medical treatment.","pos":""},{"def":"Entertainment; treat.","pos":""}],"TREATY":[{"def":"The act of treating for the adjustment of differences, as for forming an agreement; negotiation.","pos":""}],"TREBLE":[{"def":"Threefold; triple.","pos":""}],"TREBLENESS":[{"def":"The quality or state of being treble; as, the trebleness of tones.","pos":""}],"TREBLET":[{"def":"Same as Triblet.","pos":""}],"TREBLY":[{"def":"In a treble manner; with a threefold number or quantity; triply.","pos":""}],"TRECENTIST":[{"def":"A member of the trecento, or an imitator of its characteristics.","pos":""}],"TRECENTO":[{"def":"The fourteenth century, when applied to Italian art, literature, etc.","pos":""}],"TRECHOMETER":[{"def":"An odometer for vehicles.","pos":""}],"TRECKSCHUYT":[{"def":"A covered boat for goods and passengers, used on the Dutch and Flemish canals.","pos":""}],"TREDDLE":[{"def":"The dung of sheep or hares.","pos":""}],"TREDILLE":[{"def":"A game at cards for three.","pos":""}],"TREE":[{"def":"Any perennial woody plant of considerable size (usually over twenty feet high) and growing with a single trunk.","pos":""},{"def":"A mass of crystals, aggregated in arborescent forms, obtained by precipitation of a metal from solution.","pos":""}],"TREE BURIAL":[{"def":"Disposal of the dead by placing the corpse among the branches of a tree or in a hollow trunk, a practice among many primitive peoples.","pos":""}],"TREE CALF":[{"def":"A bright brown polished calfskin binding of books, stained with a conventional treelike design.","pos":""}],"TREEBEARD":[{"def":"A pendulous branching lichen (Usnea barbata); -- so called from its resemblance to hair.","pos":""}],"TREEFUL":[{"def":"The quantity or number which fills a tree.","pos":""}],"TREELESS":[{"def":"Destitute of trees.","pos":""}],"TREEN":[{"def":"Made of wood; wooden.","pos":""},{"def":"Relating to, or drawn from, trees.","pos":""}],"TREENAIL":[{"def":"A long wooden pin used in fastening the planks of a vessel to the timbers or to each other.","pos":""}],"TREF":[{"def":"Ceremonially unclean, according to the Jewish law; -- opposed to kosher.","pos":""}],"TREFLE":[{"def":"A species of time; -- so called from its resemblance in form to a trefoil.","pos":""}],"TREFOIL":[{"def":"Any plant of the genus Trifolium, which includes the white clover, red clover, etc.","pos":""},{"def":"An ornamental foliation consisting of three divisions, or foils.","pos":""}],"TREGET":[{"def":"Guile; trickery.","pos":""}],"TREGETOUR":[{"def":"A juggler who produces illusions by the use of elaborate machinery.","pos":""}],"TREGETRY":[{"def":"Trickery; also, a trick.","pos":""}],"TREHALA":[{"def":"An amorphous variety of manna obtained from the nests and cocoons of a Syrian coleopterous insect (Larinus maculatus, L.","pos":""}],"TREHALOSE":[{"def":"Mycose; -- so called because sometimes obtained from trehala.","pos":""}],"TREILLAGE":[{"def":"Latticework for supporting vines, etc.","pos":""}],"TREK":[{"def":"To draw or haul a load, as oxen.","pos":""}],"TREKOMETER":[{"def":"A field range finger used in the British service.","pos":""}],"TRELLIS":[{"def":"A structure or frame of crossbarred work, or latticework, used for various purposes, as for screens or for supporting plants.","pos":""}],"TRELLISED":[{"def":"Having a trellis or trellises.","pos":""}],"TREMANDO":[{"def":"Trembling; -- used as a direction to perform a passage with a general shaking of the whole chord.","pos":""}],"TREMATODE":[{"def":"One of the Trematodea.","pos":""}],"TREMATODEA":[{"def":"An extensive order of parasitic worms.","pos":""}],"TREMATOID":[{"def":"f or pertaining to the Trematodea.","pos":""}],"TREMBLE":[{"def":"To shake involuntarily, as with fear, cold, or weakness; to quake; to quiver; to shiver; to shudder; -- said of a person or an animal.","pos":""},{"def":"To totter; to shake; -- said of a thing.","pos":""}],"TREMBLER":[{"def":"One who trembles.","pos":""}],"TREMBLING":[{"def":"Shaking; tottering; quivering.","pos":""}],"TREMELLA":[{"def":"A genus of gelatinous fungi found in moist grounds.","pos":""}],"TREMENDOUS":[{"def":"Fitted to excite fear or terror; such as may astonish or terrify by its magnitude, force, or violence; terrible; dreadful; as, a tremendous wind; a tremendous shower; a tremendous shock or fall.","pos":""}],"TREMEX":[{"def":"A genus of large hymenopterous insects allied to the sawflies.","pos":""}],"TREMIE":[{"def":"An apparatus for depositing and consolidating concrete under water, essentially a tube of wood or sheet metal with a hooperlike top.","pos":""}],"TREMOLANDO":[{"def":"Same as Tremando.","pos":""}],"TREMOLITE":[{"def":"A white variety of amphibole, or hornblende, occurring in long, bladelike crystals, and coarsely fibrous masses.","pos":""}],"TREMOR":[{"def":"A trembling; a shivering or shaking; a quivering or vibratory motion; as, the tremor of a person who is weak, infirm, or old.","pos":""},{"def":"Tremulous; trembling; shaking.","pos":""}],"TREMULOUS":[{"def":"Shaking; shivering; quivering; as, a tremulous limb; a tremulous motion of the hand or the lips; the tremulous leaf of the poplar.","pos":""},{"def":"Affected with fear or timidity; trembling.","pos":""}],"TRENAIL":[{"def":"Same as Treenail.","pos":""}],"TRENCH":[{"def":"To fortify by cutting a ditch, and raising a rampart or breastwork with the earth thrown out of the ditch; to intrench.","pos":""}],"TRENCHANT":[{"def":"Fitted to trench or cut; gutting; sharp.","pos":""}],"TRENCHANTLY":[{"def":"In a trenchant, or sharp, manner; sharply; severely.","pos":""}],"TRENCHER":[{"def":"One who trenches; esp.","pos":""},{"def":"A large wooden plate or platter, as for table use.","pos":""}],"TRENCHER-MAN":[{"def":"A feeder; a great eater; a gormandizer.","pos":""}],"TRENCHMORE":[{"def":"A kind of lively dance of a rude, boisterous character.","pos":""}],"TREND":[{"def":"To have a particular direction; to run; to stretch; to tend; as, the shore of the sea trends to the southwest.","pos":""}],"TRENDER":[{"def":"One whose business is to free wool from its filth.","pos":""}],"TRENDLE":[{"def":"A wheel, spindle, or the like; a trundle.","pos":""}],"TRENNEL":[{"def":"Corrupt form of Treenail.","pos":""}],"TRENTAL":[{"def":"An office and mass for the dead on the thirtieth day after death or burial.","pos":""}],"TRENTE ET QUARANTE":[{"def":"Same as Rouge et noir, under Rouge.","pos":""}],"TRENTON PERIOD":[{"def":"A subdivision in the lower Silurian system of America; -- so named from Trenton Falls, in New York.","pos":""}],"TREPAN":[{"def":"A crown-saw or cylindrical saw for perforating the skull, turned, when used, like a bit or gimlet.","pos":""},{"def":"A kind of broad chisel for sinking shafts.","pos":""}],"TREPANG":[{"def":"Any one of several species of large holothurians, some of which are dried and extensively used as food in China; -- called also bêche de mer, sea cucumber, and sea slug.","pos":""}],"TREPANNER":[{"def":"One who trepans.","pos":""}],"TREPHINE":[{"def":"An instrument for trepanning, being an improvement on the trepan.","pos":""}],"TREPID":[{"def":"Trembling; quaking.","pos":""}],"TREPIDATION":[{"def":"A libration of the starry sphere in the Ptolemaic system; a motion ascribed to the firmament, to account for certain small changes in the position of the ecliptic and of the stars.","pos":""}],"TRES-TINE":[{"def":"The third tine above the base of a stag's antler; the royal antler.","pos":""}],"TRES-TYNE":[{"def":"In the antler of a stag, the third tyne above the base.","pos":""}],"TRESAYLE":[{"def":"A grandfather's grandfather.","pos":""}],"TRESPASS":[{"def":"To commit a trespass; esp.","pos":""}],"TRESPASSER":[{"def":"One who commits a trespass; as: (a) (Law) One who enters upon another's land, or violates his rights.","pos":""}],"TRESS":[{"def":"A braid, knot, or curl, of hair; a ringlet.","pos":""}],"TRESSED":[{"def":"Formed into ringlets or braided; braided; curled.","pos":""}],"TRESSURE":[{"def":"A kind of border similar to the orle, but of only half the breadth of the latter.","pos":""}],"TRESSURED":[{"def":"Provided or bound with a tressure; arranged in the form of a tressure.","pos":""}],"TRESSY":[{"def":"Abounding in tresses.","pos":""}],"TRESTLE":[{"def":"The frame of a table.","pos":""}],"TRESTLETREE":[{"def":"One of two strong bars of timber, fixed horizontally on the opposite sides of the masthead, to support the crosstrees and the frame of the top; -- generally used in the plural.","pos":""}],"TRESTLEWORK":[{"def":"A viaduct, pier, scaffold, or the like, resting on trestles connected together.","pos":""}],"TRET":[{"def":"An allowance to purchasers, for waste or refuse matter, of four pounds on every 104 pounds of suttle weight, or weight after the tare deducted.","pos":""}],"TRETABLE":[{"def":"Tractable; moderate.","pos":""}],"TRETHING":[{"def":"A tax; an impost.","pos":""},{"def":"A treatise; also, a treaty.","pos":""}],"TREVAT":[{"def":"A weaver's cutting instrument; for severing the loops of the pile threads of velvet.","pos":""}],"TREVET":[{"def":"A stool or other thing supported by three legs; a trivet.","pos":""}],"TREWS":[{"def":"Trowsers; especially, those of the Scotch Highlanders.","pos":""}],"TREY":[{"def":"Three, at cards, dice, or dominoes; a card, die, or domino of three spots or pips.","pos":""}]}