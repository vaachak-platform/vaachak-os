{"OIDIUM":[{"def":"A genus of minute fungi which form a floccose mass of filaments on decaying fruit, etc.","pos":""}],"OIL":[{"def":"Any one of a great variety of unctuous combustible substances, not miscible with water; as, olive oil, whale oil, rock oil, etc.","pos":""}],"OILCLOTH":[{"def":"Cloth treated with oil or paint, and used for marking garments, covering flooors, etc.","pos":""}],"OILED":[{"def":"Covered or treated with oil; dressed with, or soaked in, oil.","pos":""}],"OILER":[{"def":"One who deals in oils.","pos":""},{"def":"One who, or that which, oils.","pos":""}],"OILERY":[{"def":"The business, the place of business, or the goods, of a maker of, or dealer in, oils.","pos":""}],"OILINESS":[{"def":"The quality of being oily.","pos":""}],"OILMAN":[{"def":"One who deals in oils; formerly, one who dealt in oils and pickles.","pos":""}],"OILNUT":[{"def":"The buffalo nut.","pos":""}],"OILSKIN":[{"def":"Cloth made waterproof by oil.","pos":""}],"OILSTONE":[{"def":"A variety of hone slate, or whetstone, used for whetting tools when lubricated with oil.","pos":""}],"OILY":[{"def":"Consisting of oil; containing oil; having the nature or qualities of oil; unctuous; oleaginous; as, oily matter or substance.","pos":""},{"def":"Covered with oil; greasy; hence, resembling oil; as, an oily appearance.","pos":""}],"OINTMENT":[{"def":"That which serves to anoint; any soft unctuous substance used for smearing or anointing; an unguent.","pos":""}]}