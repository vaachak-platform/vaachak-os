{"MORA":[{"def":"A game of guessing the number of fingers extended in a quick movement of the hand, -- much played by Italians of the lower classes.","pos":""}],"MORAINE":[{"def":"An accumulation of earth and stones carried forward and deposited by a glacier.","pos":""}],"MORAINIC":[{"def":"Of or pertaining to a moranie.","pos":""}],"MORAL":[{"def":"Conformed to accepted rules of right; acting in conformity with such rules; virtuous; just; as, a moral man.","pos":""}],"MORALE":[{"def":"The moral condition, or the condition in other respects, so far as it is affected by, or dependent upon, moral considerations, such as zeal, spirit, hope, and confidence; mental state, as of a body of men, an army, and the like.","pos":""}],"MORALISM":[{"def":"A maxim or saying embodying a moral truth.","pos":""}],"MORALIST":[{"def":"One who moralizes; one who teaches or animadverts upon the duties of life; a writer of essays intended to correct vice and inculcate moral duties.","pos":""},{"def":"One who practices moral duties; a person who lives in conformity with moral rules; one of correct deportment and dealings with his fellow-creatures; -- sometimes used in contradistinction to one whose life is controlled by religious motives.","pos":""}],"MORALITY":[{"def":"The relation of conformity or nonconformity to the moral standard or rule; quality of an intention, a character, an action, a principle, or a sentiment, when tried by the standard of right.","pos":""},{"def":"The quality of an action which renders it good; the conformity of an act to the accepted standard of right.","pos":""}],"MORALIZATION":[{"def":"The act of moralizing; moral reflections or discourse.","pos":""},{"def":"Explanation in a moral sense.","pos":""}],"MORALIZE":[{"def":"To apply to a moral purpose; to explain in a moral sense; to draw a moral from.","pos":""},{"def":"To furnish with moral lessons, teachings, or examples; to lend a moral to.","pos":""}],"MORALIZER":[{"def":"One who moralizes.","pos":""}],"MORALLY":[{"def":"In a moral or ethical sense; according to the rules of morality.","pos":""},{"def":"According to moral rules; virtuously.","pos":""}],"MORASS":[{"def":"A tract of soft, wet ground; a marsh; a fen.","pos":""}],"MORATE":[{"def":"A salt of moric acid.","pos":""}],"MORATION":[{"def":"A delaying tarrying; delay.","pos":""}],"MORATORIUM":[{"def":"A period during which an obligor has a legal right to delay meeting an obligation, esp.","pos":""}],"MORATORY":[{"def":"Of or pertaining to delay; esp.","pos":""}],"MORAVIAN":[{"def":"Of or pertaining to Moravia, or to the United Brethren.","pos":""}],"MORAVIANISM":[{"def":"The religious system of the Moravians.","pos":""}]}