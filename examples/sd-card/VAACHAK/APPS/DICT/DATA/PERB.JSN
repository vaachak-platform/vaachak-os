{"PERBROMATE":[{"def":"A salt of perbromic acid.","pos":""}],"PERBROMIC":[{"def":"Pertaining to, or designating, the highest oxygen acid, HBrO4, of bromine.","pos":""}],"PERBROMIDE":[{"def":"A bromide having a higher proportion of bromine than any other bromide of the same substance or series.","pos":""}]}