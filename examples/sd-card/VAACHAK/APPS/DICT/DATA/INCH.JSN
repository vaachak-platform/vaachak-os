{"INCH":[{"def":"An island; -- often used in the names of small islands off the coast of Scotland, as in Inchcolm, Inchkeith, etc.","pos":""}],"INCHAMBER":[{"def":"To lodge in a chamber.","pos":""}],"INCHANGEABILITY":[{"def":"Unchangeableness.","pos":""}],"INCHARITABLE":[{"def":"Uncharitable; unfeeling.","pos":""}],"INCHARITY":[{"def":"Want of charity.","pos":""}],"INCHED":[{"def":"Having or measuring (so many) inches; as, a four-inched bridge.","pos":""}],"INCHEST":[{"def":"To put into a chest.","pos":""}],"INCHMEAL":[{"def":"A piece an inch long.","pos":""}],"INCHOATE":[{"def":"Recently, or just, begun; beginning; partially but not fully in existence or operation; existing in its elements; incomplete.","pos":""}],"INCHOATION":[{"def":"Act of beginning; commencement; inception.","pos":""}],"INCHOATIVE":[{"def":"Expressing or pertaining to a beginning; inceptive; as, an inchoative verb.","pos":""},{"def":"An inchoative verb.","pos":""}],"INCHPIN":[{"def":"The sweetbread of a deer.","pos":""}],"INCHWORM":[{"def":"The larva of any geometrid moth.","pos":""}]}