{"REDHEAD":[{"def":"A kind of milkweed (Asclepias Curassavica) with red flowers.","pos":""}],"REDHIBITION":[{"def":"The annulling of a sale, and the return by the buyer of the article sold, on account of some defect.","pos":""}],"REDHIBITORY":[{"def":"Of or pertaining to redhibition; as, a redhibitory action or fault.","pos":""}],"REDHOOP":[{"def":"The male of the European bullfinch.","pos":""}],"REDHORN":[{"def":"Any species of a tribe of butterflies (Fugacia) including the common yellow species and the cabbage butterflies.","pos":""}]}