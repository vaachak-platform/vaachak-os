{"LOELLINGITE":[{"def":"A tin-white arsenide of iron, isomorphous with arsenopyrite.","pos":""}],"LOESS":[{"def":"A quaternary deposit, usually consisting of a fine yellowish earth, on the banks of the Rhine and other large rivers.","pos":""}],"LOEVEN'S LARVA":[{"def":"The peculiar larva of Polygordius.","pos":""}]}