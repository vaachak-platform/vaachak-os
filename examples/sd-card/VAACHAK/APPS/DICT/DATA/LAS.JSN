{"LASCAR":[{"def":"A native sailor, employed in European vessels; also, a menial employed about arsenals, camps, camps, etc.","pos":""}],"LASCIOUS":[{"def":"Loose; lascivious.","pos":""}],"LASCIVIENCY":[{"def":"Lasciviousness; wantonness.","pos":""}],"LASCIVIOUS":[{"def":"Wanton; lewd; lustful; as, lascivious men; lascivious desires.","pos":""},{"def":"Tending to produce voluptuous or lewd emotions.","pos":""}],"LASERWORT":[{"def":"Any plant of the umbelliferous genus Laserpitium, of several species (as L.","pos":""}],"LASH":[{"def":"The thong or braided cord of a whip, with which the blow is given.","pos":""},{"def":"A leash in which an animal is caught or held; hence, a snare.","pos":""}],"LASHER":[{"def":"One who whips or lashes.","pos":""}],"LASHING":[{"def":"The act of one who, or that which, lashes; castigation; chastisement.","pos":""}],"LASK":[{"def":"A diarrhea or flux.","pos":""}],"LASS":[{"def":"A youth woman; a girl; a sweetheart.","pos":""}],"LASSIE":[{"def":"A young girl; a lass.","pos":""}],"LASSITUDE":[{"def":"A condition of the body, or mind, when its voluntary functions are performed with difficulty, and only by a strong exertion of the will; languor; debility; weariness.","pos":""}],"LASSLORN":[{"def":"Forsaken by a lass.","pos":""}],"LASSO":[{"def":"A rope or long thong of leather with, a running noose, used for catching horses, cattle, etc.","pos":""}],"LAST":[{"def":"of Last, to endure, contracted from lasteth.","pos":""}],"LASTAGE":[{"def":"A duty exacted, in some fairs or markets, for the right to carry things where one will.","pos":""},{"def":"A tax on wares sold by the last.","pos":""}],"LASTE":[{"def":"of Last, to endure.","pos":""}],"LASTER":[{"def":"A workman whose business it is to shape boots or shoes, or place leather smoothly, on lasts; a tool for stretching leather on a last.","pos":""}],"LASTING":[{"def":"Existing or continuing a long while; enduring; as, a lasting good or evil; a lasting color.","pos":""}],"LASTINGLY":[{"def":"In a lasting manner.","pos":""}],"LASTLY":[{"def":"In the last place; in conclusion.","pos":""}]}