{"POU STO":[{"def":"A place to stand upon; a locus standi; hence, a foundation or basis for operations.","pos":""}],"POUCH":[{"def":"A small bag; usually, a leathern bag; as, a pouch for money; a shot pouch; a mail pouch, etc.","pos":""},{"def":"That which is shaped like, or used as, a pouch; as: (a) A protuberant belly; a paunch; -- so called in ridicule.","pos":""}],"POUCH-MOUTHED":[{"def":"Having a pouch mouth; blobber-lipped.","pos":""}],"POUCH-SHELL":[{"def":"A small British and American pond snail (Bulinus hypnorum).","pos":""}],"POUCHET BOX":[{"def":"See Pouncet box.","pos":""}],"POUCHONG":[{"def":"A superior kind of souchong tea.","pos":""}],"POUDRE":[{"def":"Merchant], a kind of flavoring powder used in the Middle Ages.","pos":""}],"POUDRETTE":[{"def":"A manure made from night soil, dried and mixed with charcoal, gypsum, etc.","pos":""}],"POULAINE":[{"def":"A long pointed shoe.","pos":""}],"POULARD":[{"def":"A pullet from which the ovaries have been removed to produce fattening; hence, a fat pullet.","pos":""}],"POULDAVIS":[{"def":"Same as Poledavy.","pos":""}],"POULDRON":[{"def":"Same as Octopus.","pos":""}],"POULT":[{"def":"A young chicken, partridge, grouse, or the like.","pos":""}],"POULTERER":[{"def":"One who deals in poultry.","pos":""}],"POULTICE":[{"def":"A soft composition, as of bread, bran, or a mucilaginous substance, to be applied to sores, inflamed parts of the body, etc.","pos":""}],"POULTRY":[{"def":"Domestic fowls reared for the table, or for their eggs or feathers, such as cocks and hens, capons, turkeys, ducks, and geese.","pos":""}],"POUNCE":[{"def":"A fine powder, as of sandarac, or cuttlefish bone, -- formerly used to prevent ink from spreading on manuscript.","pos":""},{"def":"Charcoal dust, or some other colored powder for making patterns through perforated designs, -- used by embroiderers, lace makers, etc.","pos":""}],"POUNCED":[{"def":"Furnished with claws or talons; as, the pounced young of the eagle.","pos":""},{"def":"Ornamented with perforations or dots.","pos":""}],"POUNCET BOX":[{"def":"A box with a perforated lid, for sprinkling pounce, or for holding perfumes.","pos":""}],"POUNCING":[{"def":"The art or practice of transferring a design by means of pounce.","pos":""},{"def":"Decorative perforation of cloth.","pos":""}],"POUND":[{"def":"To strike repeatedly with some heavy instrument; to beat.","pos":""},{"def":"To comminute and pulverize by beating; to bruise or break into fine particles with a pestle or other heavy instrument; as, to pound spice or salt.","pos":""}],"POUND-BREACH":[{"def":"The breaking of a public pound for releasing impounded animals.","pos":""}],"POUNDAGE":[{"def":"The sum allowed to a sheriff or other officer upon the amount realized by an execution; -- estimated in England, and formerly in the United States, at so much of the pound.","pos":""}],"POUNDAL":[{"def":"A unit of force based upon the pound, foot, and second, being the force which, acting on a pound avoirdupois for one second, causes it to acquire by the of that time a velocity of one foot per second.","pos":""}],"POUNDCAKE":[{"def":"A kind of rich, sweet cake; -- so called from the ingredients being used by pounds, or in equal quantities.","pos":""}],"POUNDER":[{"def":"One who, or that which, pounds, as a stamp in an ore mill.","pos":""},{"def":"An instrument used for pounding; a pestle.","pos":""}],"POUNDING":[{"def":"The keeper of a pound.","pos":""}],"POUNDRATE":[{"def":"A rate or proportion estimated at a certain amount for each pound; poundage.","pos":""}],"POUPART'S LIGAMENT":[{"def":"A ligament, of fascia, extending, in most mammals, from the ventral side of the ilium to near the symphysis of the pubic bones.","pos":""}],"POUPETON":[{"def":"A puppet, or little baby.","pos":""}],"POUR":[{"def":"To cause to flow in a stream, as a liquid or anything flowing like a liquid, either out of a vessel or into it; as, to pour water from a pail; to pour wine into a decanter; to pour oil upon the waters; to pour out sand or dust.","pos":""},{"def":"To send forth as in a stream or a flood; to emit; to let escape freely or wholly.","pos":""}],"POURPARLER":[{"def":"A consultation preliminary to a treaty.","pos":""}],"POURPARTY":[{"def":"A division; a divided share.","pos":""}],"POURPOINT":[{"def":"A quilted military doublet or gambeson worn in the 14th and 15th centuries; also, a name for the doublet of the 16th and 17th centuries worn by civilians.","pos":""}],"POURPRESTURE":[{"def":"See Purpresture.","pos":""}],"POUSSE-CAFE":[{"def":"A drink served after coffee at dinner, usually one of several liqueurs, or cordials, of different specific gravities poured so as to remain separate in layers; hence, such a drink of cordials served at any time.","pos":""}],"POUSSETTE":[{"def":"A movement, or part of a figure, in the contradance.","pos":""}],"POUT":[{"def":"The young of some birds, as grouse; a young fowl.","pos":""}],"POUTER":[{"def":"A variety of the domestic pigeon remarkable for the extent to which it is able to dilate its throat and breast.","pos":""}],"POUTING":[{"def":"Childish sullenness.","pos":""}],"POUTINGLY":[{"def":"In a pouting, or a sullen, manner.","pos":""}]}