{"DESTEMPER":[{"def":"A kind of painting.","pos":""}],"DESTINABLE":[{"def":"Determined by destiny; fated.","pos":""}],"DESTINABLY":[{"def":"In a destinable manner.","pos":""}],"DESTINAL":[{"def":"Determined by destiny; fated.","pos":""}],"DESTINATE":[{"def":"To destine, design, or choose.","pos":""}],"DESTINATION":[{"def":"The act of destining or appointing.","pos":""},{"def":"Purpose for which anything is destined; predetermined end, object, or use; ultimate design.","pos":""}],"DESTINE":[{"def":"To determine the future condition or application of; to set apart by design for a future use or purpose; to fix, as by destiny or by an authoritative decree; to doom; to ordain or preordain; to appoint; -- often with the remoter object preceded by to or for.","pos":""}],"DESTINIST":[{"def":"A believer in destiny; a fatalist.","pos":""}],"DESTINY":[{"def":"That to which any person or thing is destined; predetermined state; condition foreordained by the Divine or by human will; fate; lot; doom.","pos":""},{"def":"The fixed order of things; invincible necessity; fate; a resistless power or agency conceived of as determining the future, whether in general or of an individual.","pos":""}],"DESTITUENT":[{"def":"Deficient; wanting; as, a destituent condition.","pos":""}],"DESTITUTE":[{"def":"Forsaken; not having in possession (something necessary, or desirable); deficient; lacking; devoid; -- often followed by of.","pos":""},{"def":"Not possessing the necessaries of life; in a condition of want; needy; without possessions or resources; very poor.","pos":""}],"DESTITUTION":[{"def":"The state of being deprived of anything; the state or condition of being destitute, needy, or without resources; deficiency; lack; extreme poverty; utter want; as, the inundation caused general destitution.","pos":""}],"DESTROY":[{"def":"To unbuild; to pull or tear down; to separate virulently into its constituent parts; to break up the structure and organic existence of; to demolish.","pos":""},{"def":"To ruin; to bring to naught; to put an end to; to annihilate; to consume.","pos":""}],"DESTROYER":[{"def":"One who destroys, ruins, kills, or desolates.","pos":""}],"DESTRUCTIBILITY":[{"def":"The quality of being capable of destruction; destructibleness.","pos":""}],"DESTRUCTIBLE":[{"def":"Liable to destruction; capable of being destroyed.","pos":""}],"DESTRUCTIBLENESS":[{"def":"The quality of being destructible.","pos":""}],"DESTRUCTION":[{"def":"The act of destroying; a tearing down; a bringing to naught; subversion; demolition; ruin; slaying; devastation.","pos":""},{"def":"The state of being destroyed, demolished, ruined, slain, or devastated.","pos":""}],"DESTRUCTIONIST":[{"def":"One who believes in the final destruction or complete annihilation of the wicked; -- called also annihilationist.","pos":""}],"DESTRUCTIVE":[{"def":"Causing destruction; tending to bring about ruin, death, or devastation; ruinous; fatal; productive of serious evil; mischievous; pernicious; -- often with of or to; as, intemperance is destructive of health; evil examples are destructive to the morals of youth.","pos":""}],"DESTRUCTIVELY":[{"def":"In a destructive manner.","pos":""}],"DESTRUCTIVENESS":[{"def":"The faculty supposed to impel to the commission of acts of destruction; propensity to destroy.","pos":""}],"DESTRUCTOR":[{"def":"Fire, the destructive and the artificial death of things.","pos":""}]}