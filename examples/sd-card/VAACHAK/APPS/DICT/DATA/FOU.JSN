{"FOUCAULT CURRENT":[{"def":"An eddy current.","pos":""},{"def":"A small mine, in the form of a well sunk from the surface of the ground, charged with explosive and projectiles.","pos":""}],"FOUGHTEN":[{"def":"Fought\"en, Defn: p.","pos":""}],"FOUL":[{"def":"Scurrilous; obscene or profane; abusive; as, foul words; foul language.","pos":""}],"FOUL-MOUTHED":[{"def":"Using language scurrilous, opprobrious, obscene, or profane; abusive.","pos":""}],"FOUL-SPOKEN":[{"def":"Using profane, scurrilous, slanderous, or obscene language.","pos":""}],"FOULARD":[{"def":"A thin, washable material of silk, or silk and cotton, originally imported from India, but now also made elsewhere.","pos":""}],"FOULDER":[{"def":"To flash, as lightning; to lighten; to gleam; to thunder.","pos":""}],"FOULLY":[{"def":"In a foul manner; filthily; nastily; shamefully; unfairly; dishonorably.","pos":""}],"FOULNESS":[{"def":"The quality or condition of being foul.","pos":""}],"FOUMART":[{"def":"The European polecat; -- called also European ferret, and fitchew.","pos":""}],"FOUND":[{"def":"To form by melting a metal, and pouring it into a mold; to cast.","pos":""}],"FOUNDATION":[{"def":"The lowest and supporting part or member of a wall, including the base course (see Base course (a), under Base, n.","pos":""}],"FOUNDATIONER":[{"def":"One who derives support from the funds or foundation of a college or school.","pos":""}],"FOUNDATIONLESS":[{"def":"Having no foundation.","pos":""}],"FOUNDER":[{"def":"One who founds, establishes, and erects; one who lays a foundation; an author; one from whom anything originates; one who endows.","pos":""}],"FOUNDEROUS":[{"def":"Difficult to travel; likely to trip one up; as, a founderous road.","pos":""}],"FOUNDERSHAFT":[{"def":"The first shaft sunk.","pos":""}],"FOUNDERY":[{"def":"Same as Foundry.","pos":""}],"FOUNDING":[{"def":"The art of smelting and casting metals.","pos":""}],"FOUNDLING":[{"def":"A deserted or exposed infant; a child found without a parent or owner.","pos":""}],"FOUNDRESS":[{"def":"A female founder; a woman who founds or establishes, or who endows with a fund.","pos":""}],"FOUNDRY":[{"def":"The act, process, or art of casting metals.","pos":""},{"def":"The buildings and works for casting metals.","pos":""}],"FOUNTAIN":[{"def":"A spring of water issuing from the earth.","pos":""},{"def":"An artificially produced jet or stream of water; also, the structure or works in which such a jet or stream rises or flows; a basin built and constantly supplied with pure water for drinking and other useful purposes, or for ornament.","pos":""}],"FOUNTAINLESS":[{"def":"Having no fountain; destitute of springs or sources of water.","pos":""}],"FOUNTFUL":[{"def":"Full of fountains.","pos":""}],"FOUR":[{"def":"One more than three; twice two.","pos":""}],"FOUR-CORNERED":[{"def":"Having four corners or angles.","pos":""}],"FOUR-CYCLE":[{"def":"A four-stroke cycle, as the Otto cycle, for an internal- combustion engine.","pos":""}],"FOUR-IN-HAND":[{"def":"Consisting of four horses controlled by one person; as, a four- in-hand team; drawn by four horses driven by one person; as, a four- in-hand coach.","pos":""},{"def":"A team of four horses driven by one person; also, a vehicle drawn by such a team.","pos":""}],"FOUR-O'CLOCK":[{"def":"A plant of the genus Mirabilis.","pos":""},{"def":"The friar bird; -- so called from its cry, which resembles these words.","pos":""}],"FOUR-POSTER":[{"def":"A large bedstead with tall posts at the corners to support curtains.","pos":""}],"FOUR-WAY":[{"def":"Allowing passage in either of four directions; as, a four-way cock, or valve.","pos":""}],"FOUR-WHEELED":[{"def":"Having four wheels.","pos":""}],"FOUR-WHEELER":[{"def":"A vehicle having four wheels.","pos":""}],"FOURCHE":[{"def":"Having the ends forked or branched, and the ends of the branches terminating abruptly as if cut off; -- said of an ordinary, especially of a cross.","pos":""}],"FOURCHETTE":[{"def":"An instrument used to raise and support the tongue during the cutting of the frænum.","pos":""},{"def":"The forked piece between two adjacent fingers, to which the front and back portions are sewed.","pos":""}],"FOURDRINIER":[{"def":"A machine used in making paper; -- so named from an early inventor of improvements in this class of machinery.","pos":""}],"FOURFOLD":[{"def":"Four times; quadruple; as, a fourfold division.","pos":""}],"FOURFOOTED":[{"def":"Having four feet; quadruped; as, fourfooted beasts.","pos":""}],"FOURHANDED":[{"def":"Having four hands; quadrumanous.","pos":""},{"def":"Requiring four \"hands\" or players; as, a fourhanded game at cards.","pos":""}],"FOURIERISM":[{"def":"The coöperative socialistic system of Charles Fourier, a Frenchman, who recommended the reorganization of society into small communities, living in common.","pos":""},{"def":"One who adopts the views of Fourier.","pos":""}],"FOURLING":[{"def":"A compound or twin crystal consisting of four individuals.","pos":""}],"FOURNEAU":[{"def":"The chamber of a mine in which the powder is placed.","pos":""}],"FOURPENCE":[{"def":"A British silver coin, worth four pence; a groat.","pos":""},{"def":"A name formerly given in New England to the Spanish half real, a silver coin worth six and a quarter cents.","pos":""}],"FOURSCORE":[{"def":"Four times twenty; eighty.","pos":""}],"FOURSOME":[{"def":"Consisting of four; requiring four participants.","pos":""}],"FOURSQUARE":[{"def":"Having four sides and four equal angles.","pos":""}],"FOURTEEN":[{"def":"Four and ten more; twice seven.","pos":""}],"FOURTEENTH":[{"def":"Next in order after the thirteenth; as, the fourteenth day of the month.","pos":""},{"def":"Making or constituting one of fourteen equal parts into which anything may be derived.","pos":""}],"FOURTH":[{"def":"Next in order after the third; the ordinal of four.","pos":""},{"def":"Forming one of four equal parts into which anything may be divided.","pos":""}],"FOURTHLY":[{"def":"In the fourth place.","pos":""}],"FOUSSA":[{"def":"A viverrine animal of Madagascar (Cryptoprocta ferox).","pos":""}],"FOUTER":[{"def":"A despicable fellow.","pos":""}],"FOUTRA":[{"def":"A fig; -- a word of contempt.","pos":""}]}