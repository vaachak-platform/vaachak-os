{"CHALAZA":[{"def":"The place on an ovule, or seed, where its outer coats cohere with each other and the nucleus.","pos":""},{"def":"A spiral band of thickened albuminous substance which exists in the white of the bird's egg, and serves to maintain the yolk in its position; the treadle.","pos":""}],"CHALAZAL":[{"def":"Of or pertaining to the chalaza.","pos":""}],"CHALAZE":[{"def":"Same as Chalaza.","pos":""}],"CHALAZIFEROUS":[{"def":"Having or bearing chalazas.","pos":""}],"CHALAZION":[{"def":"A small circumscribed tumor of the eyelid caused by retention of secretion, and by inflammation of the Melbomian glands.","pos":""}],"CHALAZOGAMY":[{"def":"A process of fecundation in which the pollen tube penetrates to the embryosac through the tissue of the chalaza, instead of entering through the micropyle.","pos":""}],"CHALCANTHITE":[{"def":"Native blue vitriol.","pos":""}],"CHALCEDONIC":[{"def":"Of or pertaining to chalcedony.","pos":""}],"CHALCEDONY":[{"def":"A cryptocrystalline, translucent variety of quartz, having usually a whitish color, and a luster nearly like wax.","pos":""}],"CHALCHIHUITL":[{"def":"The Mexican name for turquoise.","pos":""}],"CHALCID FLY":[{"def":"One of a numerous family of hymenopterous insects (Chalcididæ.","pos":""}],"CHALCIDIAN":[{"def":"One of a tropical family of snakelike lizards (Chalcidæ), having four small or rudimentary legs.","pos":""}],"CHALCOCITE":[{"def":"Native copper sulphide, called also copper glance, and vitreous copper; a mineral of a black color and metallic luster.","pos":""},{"def":"An engraver on copper or brass; hence, an engraver of copper plates for printing upon paper.","pos":""}],"CHALCOGRAPHY":[{"def":"The act or art of engraving on copper or brass, especially of engraving for printing.","pos":""}],"CHALCOPYRITE":[{"def":"Copper pyrites, or yellow copper ore; a common ore of opper, containing copper, iron, and sulphur.","pos":""}],"CHALDAIC":[{"def":"Of or pertaining to Chaldes.","pos":""},{"def":"The language or dialect of the Chaldeans; Chaldee.","pos":""}],"CHALDAISM":[{"def":"An idiom or peculiarity in the Chaldee dialect.","pos":""}],"CHALDEAN":[{"def":"Of or pertaining to Chaldea.","pos":""}],"CHALDEE":[{"def":"Of or pertaining to Chaldea.","pos":""},{"def":"The language or dialect of the Chaldeans; eastern Aramaic, or the Aramaic used in Chaldea.","pos":""}],"CHALDRON":[{"def":"An English dry measure, being, at London, 36 bushels heaped up, or its equivalent weight, and more than twice as much at Newcastle.","pos":""}],"CHALET":[{"def":"A herdsman's hut in the mountains of Switzerland.","pos":""},{"def":"A summer cottage or country house in the Swiss mountains; any country house built in the style of the Swiss cottages.","pos":""}],"CHALICE":[{"def":"A cup or bowl; especially, the cup used in the sacrament of the Lord's Supper.","pos":""}],"CHALICED":[{"def":"Having a calyx or cup; cupshaped.","pos":""}],"CHALK":[{"def":"A soft, earthy substance, of a white, grayish, or yellowish white color, consisting of calcium carbonate, and having the same composition as common limestone.","pos":""},{"def":"Finely prepared chalk, used as a drawing implement; also, by extension, a compound, as of clay and black lead, or the like, used in the same manner.","pos":""}],"CHALKCUTTER":[{"def":"A man who digs chalk.","pos":""}],"CHALKINESS":[{"def":"The state of being chalky.","pos":""}],"CHALKSTONE":[{"def":"A chalklike concretion, consisting mainly of urate of sodium, found in and about the small joints, in the external ear, and in other situations, in those affected with gout; a tophus.","pos":""}],"CHALKY":[{"def":"Consisting of, or resembling, chalk; containing chalk; as, a chalky cliff; a chalky taste.","pos":""}],"CHALLENGE":[{"def":"The opening and crying of hounds at first finding the scent of their game.","pos":""},{"def":"An exception to a juror or to a member of a court martial, coupled with a demand that he should be held incompetent to act; the claim of a party that a certain person or persons shall not sit in trial upon him or his cause.","pos":""}],"CHALLENGEABLE":[{"def":"That may be challenged.","pos":""}],"CHALLENGER":[{"def":"One who challenges.","pos":""}],"CHALLIS":[{"def":"A soft and delicate woolen, or woolen and silk, fabric, for ladies' dresses.","pos":""}],"CHALYBEAN":[{"def":"Of or pertaining to the Chalybes, an ancient people of Pontus in Asia Minor, celebrated for working in iron and steel.","pos":""},{"def":"Of superior quality and temper; -- applied to steel.","pos":""}],"CHALYBEATE":[{"def":"Impregnated with salts of iron; having a taste like iron; as, chalybeate springs.","pos":""}],"CHALYBEOUS":[{"def":"Steel blue; of the color of tempered steel.","pos":""}],"CHALYBITE":[{"def":"Native iron carbonate; -- usually called siderite.","pos":""}]}