{"SUABILITY":[{"def":"Liability to be sued; the state of being subjected by law to civil process.","pos":""}],"SUABLE":[{"def":"Capable of being sued; subject by law to be called to answer in court.","pos":""}],"SUANT":[{"def":"Spread equally over the surface; uniform; even.","pos":""}],"SUASIBLE":[{"def":"Capable of being persuaded; easily persuaded.","pos":""}],"SUASION":[{"def":"The act of persuading; persuasion; as, moral suasion.","pos":""}],"SUASIVE":[{"def":"Having power to persuade; persuasive; suasory.","pos":""}],"SUASORY":[{"def":"Tending to persuade; suasive.","pos":""}],"SUAVE":[{"def":"Sweet; pleasant; delightful; gracious or agreeable in manner; bland.","pos":""}],"SUAVIFY":[{"def":"To make affable or suave.","pos":""}],"SUAVILOQUENT":[{"def":"Sweetly speaking; using agreeable speech.","pos":""}],"SUAVILOQUY":[{"def":"Sweetness of speech.","pos":""}],"SUAVITY":[{"def":"Sweetness to the taste.","pos":""},{"def":"The quality of being sweet or pleasing to the mind; agreeableness; softness; pleasantness; gentleness; urbanity; as, suavity of manners; suavity of language, conversation, or address.","pos":""}]}