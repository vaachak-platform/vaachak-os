{"REVE":[{"def":"An officer, steward, or governor.","pos":""}],"REVEAL":[{"def":"To make known (that which has been concealed or kept secret); to unveil; to disclose; to show.","pos":""},{"def":"Specifically, to communicate (that which could not be known or discovered without divine or supernatural instruction or agency).","pos":""}],"REVEALABILITY":[{"def":"The quality or state of being revealable; revealableness.","pos":""}],"REVEALABLE":[{"def":"Capable of being revealed.","pos":""}],"REVEALER":[{"def":"One who, or that which, reveals.","pos":""}],"REVEALMENT":[{"def":"Act of revealing.","pos":""}],"REVEGETATE":[{"def":"To vegetate anew.","pos":""}],"REVEILLE":[{"def":"The beat of drum, or bugle blast, about break of day, to give notice that it is time for the soldiers to rise, and for the sentinels to forbear challenging.","pos":""}],"REVEL":[{"def":"A feast with loose and noisy jollity; riotous festivity or merrymaking; a carousal.","pos":""}],"REVEL-ROUT":[{"def":"Tumultuous festivity; revelry.","pos":""},{"def":"A rabble; a riotous assembly; a mob.","pos":""}],"REVELATION":[{"def":"The act of revealing, disclosing, or discovering to others what was before unknown to them.","pos":""},{"def":"That which is revealed.","pos":""}],"REVELATOR":[{"def":"One who makes a revelation; a revealer.","pos":""}],"REVELLENT":[{"def":"Causing revulsion; revulsive.","pos":""},{"def":"A revulsive medicine.","pos":""}],"REVELMENT":[{"def":"The act of reveling.","pos":""}],"REVELOUS":[{"def":"Fond of festivity; given to merrymaking or reveling.","pos":""}],"REVELRY":[{"def":"The act of engaging in a revel; noisy festivity; reveling.","pos":""}],"REVENDICATE":[{"def":"To reclaim; to demand the restoration of.","pos":""}],"REVENDICATION":[{"def":"The act of revendicating.","pos":""}],"REVENGE":[{"def":"To inflict harm in return for, as an injury, insult, etc.","pos":""},{"def":"To inflict injury for, in a spiteful, wrong, or malignant spirit; to wreak vengeance for maliciously.","pos":""}],"REVENGEABLE":[{"def":"Capable of being revenged; as, revengeable wrong.","pos":""}],"REVENGEANCE":[{"def":"Vengeance; revenge.","pos":""}],"REVENGEFUL":[{"def":"Full of, or prone to, revenge; vindictive; malicious; revenging; wreaking revenge.","pos":""}],"REVENGEMENT":[{"def":"He 'll breed revengement and a scourge for me.","pos":""}],"REVENGER":[{"def":"One who revenges.","pos":""}],"REVENGING":[{"def":"Executing revenge; revengeful.","pos":""}],"REVENUE":[{"def":"That which returns, or comes back, from an investment; the annual rents, profits, interest, or issues of any species of property, real or personal; income.","pos":""},{"def":"Hence, return; reward; as, a revenue of praise.","pos":""}],"REVERBERANT":[{"def":"Having the quality of reverberation; reverberating.","pos":""}],"REVERBERATE":[{"def":"Driven back, as sound; reflected.","pos":""}],"REVERBERATION":[{"def":"The act of reverberating; especially, the act of reflecting light or heat, or reëchoing sound; as, the reverberation of rays from a mirror; the reverberation of rays from a mirror; the reverberation of voices; the reverberation of heat or flame in a furnace.","pos":""}],"REVERBERATIVE":[{"def":"Of the nature of reverberation; tending to reverberate; reflective.","pos":""}],"REVERBERATOR":[{"def":"One who, or that which, produces reverberation.","pos":""}],"REVERBERATORY":[{"def":"Producing reverberation; acting by reverberation; reverberative.","pos":""}],"REVERDURE":[{"def":"To cover again with verdure.","pos":""}],"REVERE":[{"def":"To regard with reverence, or profound respect and affection, mingled with awe or fear; to venerate; to reverence; to honor in estimation.","pos":""}],"REVERENCE":[{"def":"Profound respect and esteem mingled with fear and affection, as for a holy being or place; the disposition to revere; veneration.","pos":""},{"def":"The act of revering; a token of respect or veneration; an obeisance.","pos":""}],"REVERENCER":[{"def":"One who regards with reverence.","pos":""}],"REVEREND":[{"def":"Worthy of reverence; entitled to respect mingled with fear and affection; venerable.","pos":""}],"REVERENT":[{"def":"Disposed to revere; impressed with reverence; submissive; humble; respectful; as, reverent disciples.","pos":""},{"def":"Expressing reverence, veneration, devotion, or submission; as, reverent words; reverent behavior.","pos":""}],"REVERENTIAL":[{"def":"Proceeding from, or expressing, reverence; having a reverent quality; reverent; as, reverential fear or awe.","pos":""}],"REVERENTIALLY":[{"def":"In a reverential manner.","pos":""}],"REVERENTLY":[{"def":"In a reverent manner; in respectful regard.","pos":""}],"REVERER":[{"def":"One who reveres.","pos":""}],"REVERS":[{"def":"A part turned or folded back so as to show the inside, or a piece put on in imitation of such a part, as the lapel of a coat.","pos":"noun"}],"REVERSAL":[{"def":"Intended to reverse; implying reversal.","pos":""}],"REVERSE":[{"def":"Reversed; as, a reverse shell.","pos":""}],"REVERSED":[{"def":"Annulled and the contrary substituted; as, a reversed judgment or decree.","pos":""}],"REVERSEDLY":[{"def":"In a reversed way.","pos":""}],"REVERSELY":[{"def":"In a reverse manner; on the other hand; on the opposite.","pos":""}],"REVERSER":[{"def":"One who reverses.","pos":""}],"REVERSIBILITY":[{"def":"The quality of being reversible.","pos":""}],"REVERSIBLE":[{"def":"Capable of being reversed; as, a chair or seat having a reversible back; a reversible judgment or sentence.","pos":""},{"def":"Hence, having a pattern or finished surface on both sides, so that either may be used; -- said of fabrics.","pos":""}],"REVERSIBLY":[{"def":"In a reversible manner.","pos":""}],"REVERSING":[{"def":"Serving to effect reversal, as of motion; capable of being reversed.","pos":""}],"REVERSION":[{"def":"A payment which is not to be received, or a benefit which does not begin, until the happening of some event, as the death of a living person.","pos":""}],"REVERSIONARY":[{"def":"Of or pertaining to a reversion; involving a reversion; to be enjoyed in succession, or after the termination of a particular estate; as, a reversionary interest or right.","pos":""}],"REVERSIONER":[{"def":"One who has a reversion, or who is entitled to lands or tenements, after a particular estate granted is terminated.","pos":""}],"REVERSIS":[{"def":"A certain game at cards.","pos":""}],"REVERT":[{"def":"To turn back, or to the contrary; to reverse.","pos":""},{"def":"To throw back; to reflect; to reverberate.","pos":""}],"REVERTED":[{"def":"Turned back; reversed.","pos":""}],"REVERTENT":[{"def":"A remedy which restores the natural order of the inverted irritative motions in the animal system.","pos":""}],"REVERTER":[{"def":"One who, or that which, reverts.","pos":""}],"REVERTIBLE":[{"def":"Capable of, or admitting of, reverting or being reverted; as, a revertible estate.","pos":""}],"REVERTIVE":[{"def":"Reverting, or tending to revert; returning.","pos":""}],"REVERY":[{"def":"Same as Reverie.","pos":""}],"REVEST":[{"def":"To clothe again; to cover, as with a robe; to robe.","pos":""},{"def":"To vest again with possession or office; as, to revest a magistrate with authority.","pos":""}],"REVESTIARY":[{"def":"The apartment, in a church or temple, where the vestments, etc.","pos":""}],"REVESTRY":[{"def":"Same as Revestiary.","pos":""}],"REVESTTURE":[{"def":"Richrevesture of cloth of gold.","pos":""}],"REVET":[{"def":"To face, as an embankment, with masonry, wood, or other material.","pos":""}],"REVETMENT":[{"def":"A facing of wood, stone, or any other material, to sustain an embankment when it receives a slope steeper than the natural slope; also, a retaining wall.","pos":""}]}