{"MAELSTROM":[{"def":"A celebrated whirlpool on the coast of Norway.","pos":""}],"MAENAD":[{"def":"A Bacchante; a priestess or votary of Bacchus.","pos":""},{"def":"A frantic or frenzied woman.","pos":""}],"MAESTOSO":[{"def":"Majestic or majestically; -- a direction to perform a passage or piece of music in a dignified manner.","pos":""}],"MAESTRICHT MONITOR":[{"def":"The Mosasaurus Hofmanni.","pos":""}],"MAESTRO":[{"def":"A master in any art, especially in music; a composer.","pos":""},{"def":"A secret society which organized in Sicily as a political organization, but is now widespread among Italians, and is used to further or protect private interests, reputedly by illegal methods.","pos":""}]}