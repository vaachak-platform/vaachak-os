{"END":[{"def":"One of the yarns of the worsted warp in a Brussels carpet.","pos":""}],"ENDABLE":[{"def":"That may be ended; terminable.","pos":""},{"def":"Complete termination.","pos":""}],"ENDAMAGE":[{"def":"To bring loss or damage to; to harm; to injure.","pos":""}],"ENDAMAGEABLE":[{"def":"Capable of being damaged, or injured; damageable.","pos":""}],"ENDAMAGEMENT":[{"def":"Damage; injury; harm.","pos":""}],"ENDAMNIFY":[{"def":"To damnify; to injure.","pos":""}],"ENDANGER":[{"def":"To put to hazard; to bring into danger or peril; to expose to loss or injury; as, to endanger life or peace.","pos":""},{"def":"To incur the hazard of; to risk.","pos":""}],"ENDASPIDEAN":[{"def":"Having the anterior scutes extending around the tarsus on the inner side; -- said of certain birds.","pos":""}],"ENDEAR":[{"def":"To make dear or beloved.","pos":""},{"def":"To raise the price or cost of; to make costly or expensive.","pos":""}],"ENDEAREDLY":[{"def":"With affection or endearment; dearly.","pos":""}],"ENDEAREDNESS":[{"def":"State of being endeared.","pos":""}],"ENDEARING":[{"def":"Making dear or beloved; causing love.","pos":""}],"ENDEARMENT":[{"def":"The act of endearing or the state of being endeared; also, that which manifests, excites, or increases, affection.","pos":""}],"ENDEAVOR":[{"def":"To exert physical or intellectual strength for the attainment of; to use efforts to effect; to strive to achieve or reach; to try; to attempt.","pos":""}],"ENDEAVORER":[{"def":"One who makes an effort or attempt.","pos":""}],"ENDEAVORMENT":[{"def":"Act of endeavoring; endeavor.","pos":""}],"ENDECAGON":[{"def":"A plane figure of eleven sides and angles.","pos":""}],"ENDECAGYNOUS":[{"def":"Having eleven pistils; as, an endecagynous flower.","pos":""}],"ENDECANE":[{"def":"One of the higher hydrocarbons of the paraffin series, C11H24, found as a constituent of petroleum.","pos":""}],"ENDECAPHYLLOUS":[{"def":"Composed of eleven leaflets; -- said of a leaf.","pos":""}],"ENDEICTIC":[{"def":"Serving to show or exhibit; as, an endeictic dialogue, in the Platonic philosophy, is one which exhibits a specimen of skill.","pos":""}],"ENDEMIAL":[{"def":"Peculiar to a district or particular locality, or class of persons; as, an endemic disease.","pos":""}],"ENDEMIC":[{"def":"An endemic disease.","pos":""}],"ENDEMICALLY":[{"def":"In an endemic manner.","pos":""}],"ENDEMIOLOGY":[{"def":"The science which treats of endemic affections.","pos":""}],"ENDENIZATION":[{"def":"The act of naturalizing.","pos":""}],"ENDENIZEN":[{"def":"To admit to the privileges of a denizen; to naturalize.","pos":""}],"ENDER":[{"def":"One who, or that which, makes an end of something; as, the ender of my life.","pos":""}],"ENDERMIC":[{"def":"Acting through the skin, or by direct application to the skin.","pos":""}],"ENDERMICALLY":[{"def":"By the endermic method; as, applied endermically.","pos":""}],"ENDERON":[{"def":"The deep sensitive and vascular layer of the skin and mucous membranes.","pos":""}],"ENDIAPER":[{"def":"To decorate with a diaper pattern.","pos":""}],"ENDING":[{"def":"The final syllable or letter of a word; the part joined to the stem.","pos":""}],"ENDIVE":[{"def":"A composite herb (Cichorium Endivia).","pos":""}],"ENDLESS":[{"def":"Without end; having no end or conclusion; perpetual; interminable; -- applied to length, and to duration; as, an endless line; endless time; endless bliss; endless praise; endless clamor.","pos":""},{"def":"Infinite; excessive; unlimited.","pos":""}],"ENDLESSLY":[{"def":"In an endless manner.","pos":""}],"ENDLESSNESS":[{"def":"The quality of being endless; perpetuity.","pos":""}],"ENDLONG":[{"def":"Lengthwise; along.","pos":""}],"ENDMOST":[{"def":"Farthest; remotest; at the very end.","pos":""},{"def":"A combining form signifying within; as, endocarp, endogen, endocuneiform, endaspidean.","pos":""}],"ENDOBLAST":[{"def":"Entoblast; endoplast.","pos":""}],"ENDOBLASTIC":[{"def":"Relating to the endoblast; as, the endoblastic layer.","pos":""},{"def":"Seated or generated within the heart; as, endocardial murmurs.","pos":""}],"ENDOCARDITIS":[{"def":"Inflammation of the endocardium.","pos":""}],"ENDOCARDIUM":[{"def":"The membrane lining the cavities of the heart.","pos":""}],"ENDOCARP":[{"def":"The inner layer of a ripened or fructified ovary.","pos":""}],"ENDOCHONDRAL":[{"def":"Growing or developing within cartilage; -- applied esp.","pos":""}],"ENDOCHROME":[{"def":"The coloring matter within the cells of plants, whether green, red, yellow, or any other color.","pos":""}],"ENDOCTRINE":[{"def":"To teach; to indoctrinate.","pos":""}],"ENDOCYST":[{"def":"The inner layer of the cells of Bryozoa.","pos":""}],"ENDODERM":[{"def":"Of or pertaining to the endoderm.","pos":""}],"ENDODERMIS":[{"def":"A layer of cells forming a kind of cuticle inside of the proper cortical layer, or surrounding an individual fibrovascular bundle.","pos":""}],"ENDOGAMOUS":[{"def":"Marrying within the same tribe; -- opposed to exogamous.","pos":""}],"ENDOGAMY":[{"def":"Marriage only within the tribe; a custom restricting a man in his choice of a wife to the tribe to which he belongs; -- opposed to exogamy.","pos":""}],"ENDOGEN":[{"def":"A plant which increases in size by internal growth and elongation at the summit, having the wood in the form of bundles or threads, irregularly distributed throughout the whole diameter, not forming annual layers, and with no distinct pith.","pos":""}],"ENDOGENOUS":[{"def":"Increasing by internal growth and elongation at the summit, instead of externally, and having no distinction of pith, wood, and bark, as the rattan, the palm, the cornstalk.","pos":""},{"def":"Originating from within; increasing by internal growth.","pos":""}],"ENDOGENOUSLY":[{"def":"By endogenous growth.","pos":""}],"ENDOGENY":[{"def":"Growth from within; multiplication of cells by endogenous division, as in the development of one or more cells in the interior of a parent cell.","pos":""}],"ENDOGNATH":[{"def":"The inner or principal branch of the oral appendages of Crustacea.","pos":""}],"ENDOGNATHAL":[{"def":"Pertaining to the endognath.","pos":""}],"ENDOLYMPH":[{"def":"The watery fluid contained in the membranous labyrinth of the internal ear.","pos":""}],"ENDOLYMPHANGIAL":[{"def":"Within a lymphatic vessel.","pos":""}],"ENDOME":[{"def":"To cover as with a dome.","pos":""}],"ENDOMETRITIS":[{"def":"Inflammation of the endometrium.","pos":""}],"ENDOMETRIUM":[{"def":"The membrane lining the inner surface of the uterus, or womb.","pos":""}],"ENDOMORPH":[{"def":"A crystal of one species inclosed within one of another, as one of rutile inclosed in quartz.","pos":""}],"ENDOMYSIUM":[{"def":"The delicate bands of connective tissue interspersed among muscular fibers.","pos":""}],"ENDONEURIUM":[{"def":"The delicate bands of connective tissue among nerve fibers.","pos":""}],"ENDOPARASITE":[{"def":"Any parasite which lives in the internal organs of an animal, as the tapeworms, Trichina, etc.","pos":""}],"ENDOPHLOEUM":[{"def":"The inner layer of the bark of trees.","pos":""}],"ENDOPHRAGMA":[{"def":"A chitinous structure above the nervous cord in the thorax of certain Crustacea.","pos":""}],"ENDOPHRAGMAL":[{"def":"Of or pertaining to the endophragma.","pos":""}],"ENDOPHYLLOUS":[{"def":"Wrapped up within a leaf or sheath.","pos":""}],"ENDOPLASM":[{"def":"The protoplasm in the interior of a cell.","pos":""}],"ENDOPLASMA":[{"def":"Same as Entoplasm and Endosarc.","pos":""}],"ENDOPLEURA":[{"def":"The inner coating of a seed.","pos":""}],"ENDOPLEURITE":[{"def":"The portion of each apodeme developed from the interepimeral membrane in certain crustaceans.","pos":""}],"ENDOPODITE":[{"def":"The internal or principal branch of the locomotive appendages of Crustacea.","pos":""}],"ENDORHIZA":[{"def":"Any monocotyledonous plant; -- so named because many monocotyledons have an endorhizal embryo.","pos":""},{"def":"Having the radicle of the embryo sheathed by the cotyledon, through which the embryo bursts in germination, as in many monocotyledonous plants.","pos":""}],"ENDORSE":[{"def":"Same as Indorse.","pos":""}],"ENDORSEE":[{"def":"Same as Indorsee.","pos":""}],"ENDORSEMENT":[{"def":"Same as Indorsement.","pos":""}],"ENDORSER":[{"def":"Same as Indorser.","pos":""}],"ENDOSARC":[{"def":"The semifluid, granular interior of certain unicellular organisms, as the inner layer of sarcode in the amoeba; entoplasm; endoplasta.","pos":""}],"ENDOSCOPE":[{"def":"An instrument for examining the interior of the rectum, the urethra, and the bladder.","pos":""}],"ENDOSCOPY":[{"def":"The art or process of examining by means of the endoscope.","pos":""}],"ENDOSKELETAL":[{"def":"Pertaining to, or connected with, the endoskeleton; as, endoskeletal muscles.","pos":""}],"ENDOSKELETON":[{"def":"The bony, cartilaginous, or other internal framework of an animal, as distinguished from the exoskeleton.","pos":""}],"ENDOSMOMETER":[{"def":"An instrument for measuring the force or amount of endosmotic action.","pos":""}],"ENDOSMOMETRIC":[{"def":"Pertaining to, or designed for, the measurement of endosmotic action.","pos":""},{"def":"The transmission of a fluid or gas from without inward in the phenomena, or by the process, of osmose.","pos":""}],"ENDOSMOTIC":[{"def":"Pertaining to endosmose; of the nature endosmose; osmotic.","pos":""}],"ENDOSPERM":[{"def":"The albumen of a seed; -- limited by recent writers to that formed within the embryo sac.","pos":""}],"ENDOSPERMIC":[{"def":"Relating to, accompanied by, or containing, endosperm.","pos":""}],"ENDOSPORE":[{"def":"The thin inner coat of certain spores.","pos":""}],"ENDOSPOROUS":[{"def":"Having the spores contained in a case; -- applied to fungi.","pos":""}],"ENDOSS":[{"def":"To put upon the back or outside of anything; -- the older spelling of endorse.","pos":""}],"ENDOSTEAL":[{"def":"Relating to endostosis; as, endosteal ossification.","pos":""}],"ENDOSTERNITE":[{"def":"The part of each apodeme derived from the intersternal membrane in Crustacea and insects.","pos":""}],"ENDOSTEUM":[{"def":"The layer of vascular connective tissue lining the medullary cavities of bone.","pos":""}],"ENDOSTOMA":[{"def":"A plate which supports the labrum in certain Crustacea.","pos":""}],"ENDOSTOME":[{"def":"The foramen or passage through the inner integument of an ovule.","pos":""}],"ENDOSTOSIS":[{"def":"A process of bone formation in which ossification takes place within the substance of the cartilage.","pos":""}],"ENDOSTYLE":[{"def":"A fold of the endoderm, which projects into the blood cavity of ascidians.","pos":""}],"ENDOTHECA":[{"def":"The tissue which partially fills the interior of the interseptal chambers of most madreporarian corals.","pos":""}],"ENDOTHECIUM":[{"def":"The inner lining of an another cell.","pos":""}],"ENDOTHELIAL":[{"def":"Of, or relating to, endothelium.","pos":""}],"ENDOTHELIUM":[{"def":"The thin epithelium lining the blood vessels, lymphatics, and serous cavities.","pos":""}],"ENDOTHELOID":[{"def":"Like endothelium.","pos":""}],"ENDOTHERMIC":[{"def":"Designating, or pert.","pos":""}],"ENDOTHORAX":[{"def":"An internal process of the sternal plates in the thorax of insects.","pos":""}],"ENDOW":[{"def":"To furnish with money or its equivalent, as a permanent fund for support; to make pecuniary provision for; to settle an income upon; especially, to furnish with dower; as, to endow a wife; to endow a public institution.","pos":""},{"def":"To enrich or furnish with anything of the nature of a gift (as a quality or faculty); -- followed by with, rarely by of; as, man is endowed by his Maker with reason; to endow with privileges or benefits.","pos":""}],"ENDOWMENT":[{"def":"The act of bestowing a dower, fund, or permanent provision for support.","pos":""},{"def":"That which is bestowed or settled on a person or an institution; property, fund, or revenue permanently appropriated to any object; as, the endowment of a church, a hospital, or a college.","pos":""}],"ENDRUDGE":[{"def":"To make a drudge or slave of.","pos":""}],"ENDUE":[{"def":"Tarry ye in the city of Jerusalem, until ye be endued with power from on high.","pos":""}],"ENDUEMENT":[{"def":"Act of enduing; induement.","pos":""}],"ENDURABLE":[{"def":"Capable of being endured or borne; sufferable.","pos":""}],"ENDURABLY":[{"def":"In an endurable manner.","pos":""}],"ENDURANCE":[{"def":"A state or quality of lasting or duration; lastingness; continuance.","pos":""},{"def":"The act of bearing or suffering; a continuing under pain or distress without resistance, or without being overcome; sufferance; patience.","pos":""}],"ENDURANT":[{"def":"Capable of enduring fatigue, pain, hunger, etc.","pos":""}],"ENDURE":[{"def":"To continue in the same state without perishing; to last; to remain.","pos":""},{"def":"To remain firm, as under trial or suffering; to suffer patiently or without yielding; to bear up under adversity; to hold out.","pos":""}],"ENDURER":[{"def":"One who, or that which, endures or lasts; one who bears, suffers, or sustains.","pos":""}],"ENDURING":[{"def":"Lasting; durable; long-suffering; as, an enduring disposition.","pos":""}],"ENDYSIS":[{"def":"The act of developing a new coat of hair, a new set of feathers, scales, etc.","pos":""}]}