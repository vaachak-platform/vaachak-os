{"INQUEST":[{"def":"Inquiry; quest; search.","pos":""}],"INQUIETUDE":[{"def":"Disturbed state; uneasiness either of body or mind; restlessness; disquietude.","pos":""}],"INQUILINE":[{"def":"A gallfly which deposits its eggs in galls formed by other insects.","pos":""}],"INQUINATE":[{"def":"To defile; to pollute; to contaminate; to befoul.","pos":""}],"INQUINATION":[{"def":"A defiling; pollution; stain.","pos":""}],"INQUIRABLE":[{"def":"Capable of being inquired into; subject or liable to inquisition or inquest.","pos":""}],"INQUIRE":[{"def":"To ask a question; to seek for truth or information by putting queries.","pos":""},{"def":"To seek to learn anything by recourse to the proper means of knoledge; to make examination.","pos":""}],"INQUIRENT":[{"def":"Making inquiry; inquiring; questioning.","pos":""}],"INQUIRER":[{"def":"One who inquires or examines; questioner; investigator.","pos":""}],"INQUIRING":[{"def":"Given to inquiry; disposed to investigate causes; curious; as, an inquiring mind.","pos":""}],"INQUIRINGLY":[{"def":"In an inquiring manner.","pos":""}],"INQUIRY":[{"def":"The act of inquiring; a seeking for information by asking questions; interrogation; a question or questioning.","pos":""},{"def":"Search for truth, information, or knoledge; examination into facts or principles; research; invextigation; as, physical inquiries.","pos":""}],"INQUISIBLE":[{"def":"Admitting judicial inquiry.","pos":""}],"INQUISITION":[{"def":"A court or tribunal for the examination and punishment of heretics, fully established by Pope Gregory IX.","pos":""}],"INQUISITIONAL":[{"def":"Relating to inquiry or inquisition; inquisitorial; also, of or pertaining to, or characteristic of, the Inquisition.","pos":""}],"INQUISITIONARY":[{"def":"In`qui*si\"tion*a*ry, (, a.","pos":""}],"INQUISITIVE":[{"def":"Disposed to ask questions, especially in matters which do not concern the inquirer.","pos":""},{"def":"Given to examination, investigation, or research; searching; curious.","pos":""}],"INQUISITIVELY":[{"def":"In an inquisitive manner.","pos":""}],"INQUISITIVENESS":[{"def":"The quality or state of being inquisitive; the disposition to seek explanation and information; curiosity to learn what is unknown; esp.","pos":""}],"INQUISITOR":[{"def":"One whose official duty it is to examine and inquire, as coroners, sheriffs, etc.","pos":""},{"def":"A member of the Court of Inquisition.","pos":""}],"INQUISITORIAL":[{"def":"Pertaining to inquisition; making rigorous and unfriendly inquiry; searching; as, inquisitorial power.","pos":""},{"def":"Pertaining to the Court of Inquisition or resembling its practices.","pos":""}],"INQUISITORIALLY":[{"def":"In an inquisitorial manner.","pos":""}],"INQUISITORIOUS":[{"def":"Making strict inquiry; inquisitorial.","pos":""}],"INQUISITURIENT":[{"def":"In*quis`i*tu\"ri*ent, a.","pos":""}]}