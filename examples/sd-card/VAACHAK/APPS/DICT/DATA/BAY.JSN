{"BAY":[{"def":"Reddish brown; of the color of a chestnut; -- applied to the color of horses.","pos":""}],"BAY LEAF":[{"def":"See under 3d Bay.","pos":""}],"BAY RUM":[{"def":"A fragrant liquid, used for cosmetic and medicinal purposes.","pos":""}],"BAY SALT":[{"def":"Salt which has been obtained from sea water, by evaporation in shallow pits or basins, by the heat of the sun; the large crystalline salt of commerce.","pos":""}],"BAY STATE":[{"def":"Massachusetts, which had been called the Colony of Massachusetts Bay; -- a nickname.","pos":""}],"BAY TREE":[{"def":"A species of laurel.","pos":""}],"BAY WINDOW":[{"def":"A window forming a bay or recess in a room, and projecting outward from the wall, either in a rectangular, polygonal, or semicircular form; -- often corruptly called a bow window.","pos":""}],"BAY YARN":[{"def":"In the East, an exchange, marketplace, or assemblage of shops where goods are exposed for sale.","pos":""},{"def":"A spacious hall or suite of rooms for the sale of goods, as at a fair.","pos":""}],"BAY-ANTLER":[{"def":"The second tine of a stag's horn.","pos":""}],"BAYA":[{"def":"The East Indian weaver bird (Ploceus Philippinus).","pos":""},{"def":"A large, edible, siluroid fish of the Nile, of two species (Bagrina bayad and B.","pos":""}],"BAYADERE":[{"def":"A female dancer in the East Indies.","pos":""}],"BAYAMO":[{"def":"A violent thunder squall occurring on the south coast of Cuba, esp.","pos":""}],"BAYARD":[{"def":"Properly, a bay horse, but often any horse.","pos":""},{"def":"A stupid, clownish fellow.","pos":""}],"BAYBOLT":[{"def":"A bolt with a barbed shank.","pos":""}],"BAYED":[{"def":"Having a bay or bays.","pos":""}],"BAYEUX TAPESTRY":[{"def":"A piece of linen about 1 ft.","pos":""}],"BAYMAN":[{"def":"In the United States navy, a sick-bay nurse; -- now officially designated as hospital apprentice.","pos":""}],"BAYONET":[{"def":"A pointed instrument of the dagger kind fitted on the muzzle of a musket or rifle, so as to give the soldier increased means of offense and defense.","pos":""},{"def":"A pin which plays in and out of holes made to receive it, and which thus serves to engage or disengage parts of the machinery.","pos":""}],"BAYOU":[{"def":"An inlet from the Gulf of Mexico, from a lake, or from a large river, sometimes sluggish, sometimes without perceptible movement except from tide and wind.","pos":""}],"BAYOU STATE":[{"def":"Mississippi; -- a nickname, from its numerous bayous.","pos":""}]}