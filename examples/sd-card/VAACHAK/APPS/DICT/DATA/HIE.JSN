{"HIE":[{"def":"To hasten; to go in haste; -- also often with the reciprocal pronoun.","pos":""}],"HIERAPICRA":[{"def":"A warming cathartic medicine, made of aloes and canella bark.","pos":""}],"HIERARCH":[{"def":"One who has high and controlling authority in sacred things; the chief of a sacred order; as, princely hierarchs.","pos":""},{"def":"Pertaining to a hierarch.","pos":""}],"HIERARCHICAL":[{"def":"Pertaining to a hierarchy.","pos":""}],"HIERARCHISM":[{"def":"The principles or authority of a hierarchy.","pos":""}],"HIERARCHY":[{"def":"Dominion or authority in sacred things.","pos":""},{"def":"A body of officials disposed organically in ranks and orders each subordinate to the one above it; a body of ecclesiastical rulers.","pos":""}],"HIERATIC":[{"def":"Consecrated to sacred uses; sacerdotal; pertaining to priests.","pos":""}],"HIEROCRACY":[{"def":"Government by ecclesiastics; a hierarchy.","pos":""}],"HIEROGLYPHICALLY":[{"def":"In hieroglyphics.","pos":""}],"HIEROGLYPHIST":[{"def":"One versed in hieroglyphics.","pos":""}],"HIEROGRAM":[{"def":"A form of sacred or hieratic writing.","pos":""}],"HIEROGRAMMATIC":[{"def":"Written in, or pertaining to, hierograms; expressive of sacred writing.","pos":""}],"HIEROGRAMMATIST":[{"def":"A writer of hierograms; also, one skilled in hieroglyphics.","pos":""},{"def":"Of or pertaining to sacred writing.","pos":""}],"HIEROLATRY":[{"def":"The worship of saints or sacred things.","pos":""},{"def":"Pertaining to hierology.","pos":""}],"HIEROLOGIST":[{"def":"One versed in, or whostudies, hierology.","pos":""}],"HIEROLOGY":[{"def":"A treatise on sacred things; especially, the science which treats of the ancient writings and inscriptions of the Egyptians, or a treatise on that science.","pos":""}],"HIEROMANCY":[{"def":"Divination by observing the objects offered in sacrifice.","pos":""}],"HIEROMARTYR":[{"def":"A priest who becomes a martyr.","pos":""}],"HIEROMNEMON":[{"def":"The sacred secretary or recorder sent by each state belonging to the Amphictyonic Council, along with the deputy or minister.","pos":""},{"def":"A magistrate who had charge of religious matters, as at Byzantium.","pos":""}],"HIERON":[{"def":"A consecrateo place; esp.","pos":""}],"HIEROPHANT":[{"def":"The presiding priest who initiated candidates at the Eleusinian mysteries; hence, one who teaches the mysteries and duties of religion.","pos":""}],"HIEROPHANTIC":[{"def":"Of or relating to hierophants or their teachings.","pos":""}],"HIEROSCOPY":[{"def":"Divination by inspection of entrails of victims offered in sacrifice.","pos":""}],"HIEROTHECA":[{"def":"A receptacle for sacred objects.","pos":""}],"HIEROURGY":[{"def":"A sacred or holy work or worship.","pos":""}]}