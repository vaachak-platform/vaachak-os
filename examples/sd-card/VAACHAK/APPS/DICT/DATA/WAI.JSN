{"WAI WU PU":[{"def":"The Department of Foreign Affairs in the Chinese government.","pos":""}],"WAID":[{"def":"Oppressed with weight; crushed; weighed down.","pos":""}],"WAIF":[{"def":"Goods found of which the owner is not known; originally, such goods as a pursued thief threw away to prevent being apprehended, which belonged to the king unless the owner made pursuit of the felon, took him, and brought him to justice.","pos":""}],"WAIL":[{"def":"To choose; to select.","pos":""}],"WAILER":[{"def":"One who wails or laments.","pos":""}],"WAILERESS":[{"def":"A woman who wails.","pos":""}],"WAILFUL":[{"def":"Sorrowful; mournful.","pos":""}],"WAILINGLY":[{"def":"In a wailing manner.","pos":""}],"WAILMENT":[{"def":"Lamentation; loud weeping; wailing.","pos":""}],"WAIN":[{"def":"A four-wheeled vehicle for the transportation of goods, produce, etc.","pos":""}],"WAINABLE":[{"def":"Capable of being plowed or cultivated; arable; tillable.","pos":""}],"WAINAGE":[{"def":"A finding of carriages, carts, etc.","pos":""}],"WAINSCOT":[{"def":"A wooden lining or boarding of the walls of apartments, usually made in panels.","pos":""},{"def":"Any one of numerous species of European moths of the family Leucanidæ.","pos":""}],"WAINSCOTING":[{"def":"The act or occupation of covering or lining with boards in panel.","pos":""},{"def":"The material used to wainscot a house, or the wainscot as a whole; panelwork.","pos":""}],"WAINWRIGHT":[{"def":"Same as Wagonwright.","pos":""}],"WAIR":[{"def":"A piece of plank two yard Bailey.","pos":""}],"WAIST":[{"def":"That part of the human body which is immediately below the ribs or thorax; the small part of the body between the thorax and hips.","pos":""},{"def":"Hence, the middle part of other bodies; especially (Naut.","pos":""}],"WAISTBAND":[{"def":"The band which encompasses the waist; esp.","pos":""},{"def":"A sash worn by women around the waist.","pos":""}],"WAISTCLOTH":[{"def":"A covering of canvas or tarpaulin for the hammocks, stowed on the nettings, between the quarterdeck and the forecastle.","pos":""}],"WAISTCOAT":[{"def":"Note: The waistcoat was a part of female attire as well as male .","pos":""}],"WAISTCOATEER":[{"def":"One wearing a waistcoat; esp.","pos":""}],"WAISTCOATING":[{"def":"A fabric designed for waistcoats; esp.","pos":""}],"WAISTER":[{"def":"A seaman, usually a green hand or a broken-down man, stationed in the waist of a vessel of war.","pos":""}],"WAIT":[{"def":"To watch; to observe; to take notice.","pos":""},{"def":"To stay or rest in expectation; to stop or remain stationary till the arrival of some person or event; to rest in patience; to stay; not to depart.","pos":""}],"WAIT-A-BIT":[{"def":"Any of several plants bearing thorns or stiff hooked appendages, which catch and tear the clothing, as: (a) The greenbrier.","pos":""}],"WAITER":[{"def":"One who, or that which, waits; an attendant; a servant in attendance, esp.","pos":""},{"def":"A vessel or tray on which something is carried, as dishes, etc.","pos":""}],"WAITRESS":[{"def":"A female waiter or attendant; a waiting maid or waiting woman.","pos":""}],"WAIVE":[{"def":"A woman put out of the protection of the law.","pos":""}],"WAIVER":[{"def":"The act of waiving, or not insisting on, some right, claim, or privilege.","pos":""}]}