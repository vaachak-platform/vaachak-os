{"PALACE":[{"def":"The residence of a sovereign, including the lodgings of high officers of state, and rooms for business, as well as halls for ceremony and reception.","pos":""},{"def":"The official residence of a bishop or other distinguished personage.","pos":""}],"PALADIN":[{"def":"A knight-errant; a distinguished champion; as, the paladins of Charlemagne.","pos":""}],"PALAEO-":[{"def":"See Paleographer, Paleographic, etc.","pos":""}],"PALAEOTYPE":[{"def":"A system of representing all spoken sounds by means of the printing types in common use.","pos":""}],"PALAETIOLOGIST":[{"def":"One versed in palætiology.","pos":""}],"PALAETIOLOGY":[{"def":"The science which explains, by the law of causation, the past condition and changes of the earth.","pos":""}],"PALAMA":[{"def":"A membrane extending between the toes of a bird, and uniting them more or less closely together.","pos":""}],"PALAMEDEAE":[{"def":"An order, or suborder, including the kamichi, and allied South American birds; -- called also screamers.","pos":""}],"PALANKA":[{"def":"A camp permanently intrenched, attached to Turkish frontier fortresses.","pos":""}],"PALANQUIN":[{"def":"An inclosed carriage or litter, commonly about eight feet long, four feet wide, and four feet high, borne on the shoulders of men by means of two projecting poles, -- used in India, China, etc.","pos":""}],"PALAPTERYX":[{"def":"A large extinct ostrichlike bird of New Zealand.","pos":""}],"PALATABLE":[{"def":"Agreeable to the palate or taste; savory; hence, acceptable; pleasing; as, palatable food; palatable advice.","pos":""}],"PALATABLENESS":[{"def":"The quality or state of being agreeable to the taste; relish; acceptableness.","pos":""}],"PALATABLY":[{"def":"In a palatable manner.","pos":""}],"PALATAL":[{"def":"Uttered by the aid of the palate; -- said of certain sounds, as the sound of k in kirk.","pos":""}],"PALATE":[{"def":"The roof of the mouth.","pos":""},{"def":"A projection in the throat of such flowers as the snapdragon.","pos":""}],"PALATIAL":[{"def":"Of or pertaining to a palace; suitable for a palace; resembling a palace; royal; magnificent; as, palatial structures.","pos":""}],"PALATIC":[{"def":"Palatal; palatine.","pos":""}],"PALATINATE":[{"def":"The province or seigniory of a palatine; the dignity of a palatine.","pos":""}],"PALATINE":[{"def":"Of or pertaining to a palace, or to a high officer of a palace; hence, possessing royal privileges.","pos":""}],"PALATIVE":[{"def":"Pleasing to the taste; palatable.","pos":""}],"PALATIZE":[{"def":"To modify, as the tones of the voice, by means of the palate; as, to palatize a letter or sound.","pos":""}],"PALATO-":[{"def":"A combining form used in anatomy to indicate relation to, or connection with, the palate; as in palatolingual.","pos":""}],"PALATONARES":[{"def":"The posterior nares.","pos":""}],"PALATOPTERYGOID":[{"def":"Pertaining to the palatine and pterygoid region of the skull; as, the palatopterygoid cartilage, or rod, from which the palatine and pterygoid bones are developed.","pos":""}],"PALAVER":[{"def":"Talk; conversation; esp.","pos":""},{"def":"In Africa, a parley with the natives; a talk; hence, a public conference and deliberation; a debate.","pos":""}],"PALAVERER":[{"def":"One who palavers; a flatterer.","pos":""}]}