{"ABACA":[{"def":"The Manila-hemp plant (Musa textilis); also, its fiber.","pos":""}],"ABACINATE":[{"def":"To blind by a red-hot metal plate held before the eyes.","pos":"verb"}],"ABACINATION":[{"def":"The act of abacinating.","pos":""}],"ABACISCUS":[{"def":"One of the tiles or squares of a tessellated pavement; an abaculus.","pos":""}],"ABACIST":[{"def":"One who uses an abacus in casting accounts; a calculator.","pos":""}],"ABACK":[{"def":"Backward against the mast;-said of the sails when pressed by the wind.","pos":""}],"ABACTINAL":[{"def":"Pertaining to the surface or end opposite to the mouth in a radiate animal; -- opposed to actinal.","pos":""}],"ABACTION":[{"def":"Stealing cattle on a large scale.","pos":""}],"ABACTOR":[{"def":"One who steals and drives away cattle or beasts by herds or droves.","pos":""}],"ABACULUS":[{"def":"A small tile of glass, marble, or other substance, of various colors, used in making ornamental patterns in mosaic pavements.","pos":""}],"ABACUS":[{"def":"A table or tray strewn with sand, anciently used for drawing, calculating, etc.","pos":""},{"def":"A calculating table or frame; an instrument for performing arithmetical calculations by balls sliding on wires, or counters in grooves, the lowest line representing units, the second line, tens, etc.","pos":""}],"ABADDON":[{"def":"The destroyer, or angel of the bottomless pit; -- the same as Apollyon and Asmodeus.","pos":""},{"def":"Hell; the bottomless pit.","pos":""}],"ABAFT":[{"def":"Behind; toward the stern from; as, abaft the wheelhouse.","pos":""}],"ABAISER":[{"def":"Ivory black or animal charcoal.","pos":""}],"ABAIST":[{"def":"Abashed; confounded; discomfited.","pos":""}],"ABALIENATE":[{"def":"To transfer the title of from one to another; to alienate.","pos":"verb"}],"ABALIENATION":[{"def":"The act of abalienating; alienation; estrangement.","pos":""}],"ABALONE":[{"def":"A univalve mollusk of the genus Haliotis.","pos":""}],"ABAND":[{"def":"To banish; to expel.","pos":"verb"}],"ABANDON":[{"def":"To relinquish all claim to; -- used when an insured person gives up to underwriters all claim to the property covered by a policy, which may remain after loss or damage by a peril insured against.","pos":"verb"}],"ABANDONED":[{"def":"Forsaken, deserted.","pos":""},{"def":"Self-abandoned, or given up to vice; extremely wicked, or sinning without restraint; irreclaimably wicked ; as, an abandoned villain.","pos":""}],"ABANDONEE":[{"def":"One to whom anything is legally abandoned.","pos":""}],"ABANDONER":[{"def":"One who abandons.","pos":""}],"ABANDONMENT":[{"def":"The relinquishment by the insured to the underwriters of what may remain of the property insured after a loss or damage by a peril insured against.","pos":""},{"def":"(a) The relinquishment of a right, claim, or privilege, as to mill site, etc.","pos":""}],"ABANDUM":[{"def":"Anything forfeited or confiscated.","pos":""}],"ABANGA":[{"def":"A West Indian palm; also the fruit of this palm, the seeds of which are used as a remedy for diseases of the chest.","pos":""}],"ABARTICULATION":[{"def":"Articulation, usually that kind of articulation which admits of free motion in the joint; diarthrosis.","pos":""}],"ABASE":[{"def":"To lower or depress; to throw or cast down; as, to abase the eye.","pos":"verb"},{"def":"To cast down or reduce low or lower, as in rank, office, condition in life, or estimation of worthiness; to depress; to humble; to degrade.","pos":"verb"}],"ABASED":[{"def":"Borne lower than usual, as a fess; also, having the ends of the wings turned downward towards the point of the shield.","pos":""}],"ABASEDLY":[{"def":"Abjectly; downcastly.","pos":""}],"ABASEMENT":[{"def":"The act of abasing, humbling, or bringing low; the state of being abased or humbled; humiliation.","pos":""}],"ABASER":[{"def":"He who, or that which, abases.","pos":""}],"ABASH":[{"def":"To destroy the self-possession of; to confuse or confound, as by exciting suddenly a consciousness of guilt, mistake, or inferiority; to put to shame; to disconcert; to discomfit.","pos":"verb"}],"ABASHEDLY":[{"def":"In an abashed manner.","pos":""}],"ABASHMENT":[{"def":"The state of being abashed; confusion from shame.","pos":""}],"ABASIA":[{"def":"Inability to coördinate muscular actions properly in walking.","pos":""},{"def":"A silver coin of Persia, worth about twenty cents.","pos":""}],"ABATABLE":[{"def":"Capable of being abated; as, an abatable writ or nuisance.","pos":""}],"ABATE":[{"def":"(a) To bring entirely down or put an end to; to do away with; as, to abate a nuisance, to abate a writ.","pos":"verb"}],"ABATEMENT":[{"def":"A mark of dishonor on an escutcheon.","pos":""},{"def":"The entry of a stranger, without right, into a freehold after the death of the last possessor, before the heir or devisee.","pos":""}],"ABATER":[{"def":"One who, or that which, abates.","pos":""},{"def":"A means of defense formed by felled trees, the ends of whose branches are sharpened and directed outwards, or against the enemy.","pos":""}],"ABATISED":[{"def":"Provided with an abatis.","pos":""}],"ABATOR":[{"def":"(a) One who abates a nuisance.","pos":""}],"ABATTOIR":[{"def":"A public slaughterhouse for cattle, sheep, etc.","pos":""}],"ABATURE":[{"def":"Grass and sprigs beaten or trampled down by a stag passing through them.","pos":""}],"ABATVOIX":[{"def":"The sounding-board over a pulpit or rostrum.","pos":""}],"ABAWED":[{"def":"Astonished; abashed.","pos":""},{"def":"Away from the axis or central line; eccentric.","pos":""}],"ABAY":[{"def":"Barking; baying of dogs upon their prey.","pos":""}]}