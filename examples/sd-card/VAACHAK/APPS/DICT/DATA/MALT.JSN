{"MALT":[{"def":"Barley or other grain, steeped in water and dried in a kiln, thus forcing germination until the saccharine principle has been evolved.","pos":""}],"MALTALENT":[{"def":"Ill will; malice.","pos":""}],"MALTESE":[{"def":"Of or pertaining to Malta or to its inhabitants.","pos":""},{"def":"A native or inhabitant of Malta; the people of Malta.","pos":""}],"MALTHA":[{"def":"A variety of bitumen, viscid and tenacious, like pitch, unctuous to the touch, and exhaling a bituminous odor.","pos":""}],"MALTHUSIAN":[{"def":"Of or pertaining to the political economist, the Rev.","pos":""}],"MALTHUSIANISM":[{"def":"The system of Malthusian doctrines relating to population.","pos":""},{"def":"The fermentative principle of malt; malt diastase; also, a name given to various medicinal preparations made from or containing malt.","pos":""}],"MALTING":[{"def":"The process of making, or of becoming malt.","pos":""}],"MALTMAN":[{"def":"A man whose occupation is to make malt.","pos":""}],"MALTONIC":[{"def":"Of, pertaining to, or derived from, maltose; specif.","pos":""}],"MALTOSE":[{"def":"A crystalline sugar formed from starch by the action of distance of malt, and the amylolytic ferment of saliva and pancreatic juice.","pos":""}],"MALTREAT":[{"def":"To treat ill; to abuse; to treat roughly.","pos":""}],"MALTREATMENT":[{"def":"Ill treatment; ill usage; abuse.","pos":""}],"MALTY":[{"def":"Consisting, or like, malt.","pos":""}]}