{"VAGABOND":[{"def":"Moving from place to place without a settled habitation; wandering.","pos":""},{"def":"Floating about without any certain direction; driven to and fro.","pos":""}],"VAGABONDAGE":[{"def":"The condition of a vagabond; a state or habit of wandering about in idleness; vagrancy.","pos":""}],"VAGABONDIZE":[{"def":"To play the vagabond; to wander about in idleness.","pos":""}],"VAGAL":[{"def":"Of or pertaining to the vagus, or pneumogastric nerves; pneumogastric.","pos":""}],"VAGANCY":[{"def":"A wandering; vagrancy.","pos":""}],"VAGANTES":[{"def":"A tribe of spiders, comprising some of those which take their prey in a web, but which also frequently run with agility, and chase and seize their prey.","pos":""}],"VAGARIOUS":[{"def":"Given to, or characterized by, vagaries; capricious; whimsical; crochety.","pos":""}],"VAGARY":[{"def":"A wandering or strolling.","pos":""},{"def":"Hence, a wandering of the thoughts; a wild or fanciful freak; a whim; a whimsical purpose.","pos":""}],"VAGIENT":[{"def":"Crying like a child.","pos":""}],"VAGINA":[{"def":"The terminal part of the oviduct in insects and various other invertebrates.","pos":""},{"def":"The basal expansion of certain leaves, which inwraps the stem; a sheath.","pos":""}],"VAGINAL":[{"def":"Of or pertaining to the vagina of the genital canal; as, the vaginal artery.","pos":""}],"VAGINANT":[{"def":"Serving to in invest, or sheathe; sheathing.","pos":""},{"def":"Invested with, or as if with, a sheath; as, a vaginate stem, or one invested by the tubular base of a leaf.","pos":""}],"VAGINATI":[{"def":"A tribe of birds comprising the sheathbills.","pos":""}],"VAGINERVOSE":[{"def":"Having the nerves, or veins, placed in apparent disorder.","pos":""}],"VAGINICOLA":[{"def":"A genus of Infusoria which form minute vaselike or tubular cases in which they dwell.","pos":""}],"VAGINISMUS":[{"def":"A painful spasmodic contraction of the vagina, often rendering copulation impossible.","pos":""}],"VAGINITIS":[{"def":"Inflammation of the vagina, or the genital canal, usually of its mucous living membrane.","pos":""}],"VAGINOPENNOUS":[{"def":"Having elytra; sheath-winged.","pos":""}],"VAGISSATE":[{"def":"To caper or frolic.","pos":""}],"VAGOUS":[{"def":"Wandering; unsettled.","pos":""}],"VAGRANCY":[{"def":"The quality or state of being a vagrant; a wandering without a settled home; an unsettled condition; vagabondism.","pos":""}],"VAGRANT":[{"def":"Moving without certain direction; wandering; erratic; unsettled.","pos":""},{"def":"Wandering from place to place without any settled habitation; as, a vagrant beggar.","pos":""}],"VAGRANTLY":[{"def":"In a vagrant manner.","pos":""}],"VAGRANTNESS":[{"def":"State of being vagrant; vagrancy.","pos":""}],"VAGUE":[{"def":"Wandering; vagrant; vagabond.","pos":""},{"def":"Unsettled; unfixed; undetermined; indefinite; ambiguous; as, a vague idea; a vague proposition.","pos":""}],"VAGUELY":[{"def":"In a vague manner.","pos":""}],"VAGUENESS":[{"def":"The quality or state of being vague.","pos":""}],"VAGUS":[{"def":"Wandering; -- applied especially to the pneumogastric nerve.","pos":""},{"def":"The vagus, ore pneumogastric, nerve.","pos":""}]}