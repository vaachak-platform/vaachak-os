{"HACHURE":[{"def":"A short line used in drawing and engraving, especially in shading and denoting different surfaces, as in map drawing.","pos":""}],"HACIENDA":[{"def":"A large estate where work of any kind is done, as agriculture, manufacturing, mining, or raising of animals; a cultivated farm, with a good house, in distinction from a farming establishment with rude huts for herdsmen, etc.","pos":""}],"HACK":[{"def":"A frame or grating of various kinds; as, a frame for drying bricks, fish, or cheese; a rack for feeding cattle; a grating in a mill race, etc.","pos":""},{"def":"Unburned brick or tile, stacked up for drying.","pos":""}],"HACKAMORE":[{"def":"A halter consisting of a long leather or rope strap and headstall, -- used for leading or tieing a pack animal.","pos":""}],"HACKBERRY":[{"def":"A genus of trees (Celtis) related to the elm, but bearing drupes with scanty, but often edible, pulp.","pos":""}],"HACKBOLT":[{"def":"The greater shearwater or hagdon.","pos":""}],"HACKEE":[{"def":"The chipmunk; also, the chickaree or red squirrel.","pos":""}],"HACKER":[{"def":"One who, or that which, hacks.","pos":""}],"HACKERY":[{"def":"A cart with wooden wheels, drawn by bullocks.","pos":""}],"HACKLE":[{"def":"A comb for dressing flax, raw silk, etc.","pos":""},{"def":"Any flimsy substance unspun, as raw silk.","pos":""}],"HACKLY":[{"def":"Having fine, short, and sharp points on the surface; as, the hackly fracture of metallic iron.","pos":""}],"HACKMAN":[{"def":"The driver of a hack or carriage for public hire.","pos":""}],"HACKMATACK":[{"def":"The American larch (Larix Americana), a coniferous tree with slender deciduous leaves; also, its heavy, close-grained timber.","pos":""}],"HACKNEY":[{"def":"A horse for riding or driving; a nag; a pony.","pos":""},{"def":"A horse or pony kept for hire.","pos":""}],"HACKNEYMAN":[{"def":"A man who lets horses and carriages for hire.","pos":""}],"HACKSTER":[{"def":"A bully; a bravo; a ruffian; an assassin.","pos":""}]}