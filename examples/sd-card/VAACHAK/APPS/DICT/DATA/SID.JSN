{"SIDA":[{"def":"A genus of malvaceous plants common in the tropics.","pos":""}],"SIDE":[{"def":"Any outer portion of a thing considered apart from, and yet in relation to, the rest; as, the upper side of a sphere; also, any part or position viewed as opposite to or contrasted with another; as, this or that side.","pos":""}],"SIDE SLIP":[{"def":"See Skid, below.","pos":""}],"SIDE-CHAIN THEORY":[{"def":"A theory proposed by Ehrlich as a chemical explanation of immunity phenomena.","pos":""}],"SIDE-SLIP":[{"def":"See Skid, below.","pos":""}],"SIDE-TAKING":[{"def":"A taking sides, as with a party, sect, or faction.","pos":""}],"SIDE-WHEEL":[{"def":"Having a paddle wheel on each side; -- said of steam vessels; as, a side-wheel steamer.","pos":""}],"SIDEBOARD":[{"def":"A piece of dining-room furniture having compartments and shelves for keeping or displaying articles of table service.","pos":""}],"SIDEBONE":[{"def":"A morbid growth or deposit of bony matter and at the sides of the coronet and coffin bone of a horse.","pos":""}],"SIDED":[{"def":"Having (such or so many) sides; -- used in composition; as, one-sided; many-sided.","pos":""}],"SIDEFLASH":[{"def":"A disruptive discharge between a conductor traversed by an oscillatory current of high frequency (as lightning) and neighboring masses of metal, or between different parts of the same conductor.","pos":""}],"SIDEHILL":[{"def":"The side or slope of a hill; sloping ground; a descent.","pos":""}],"SIDELING":[{"def":"Sidelong; on the side; laterally; also, obliquely; askew.","pos":""}],"SIDELONG":[{"def":"Laterally; obliquely; in the direction of the side.","pos":""},{"def":"On the side; as, to lay a thing sidelong.","pos":""}],"SIDEPIECE":[{"def":"The jamb, or cheek, of an opening in a wall, as of door or window.","pos":""}],"SIDER":[{"def":"One who takes a side.","pos":""}],"SIDERAL":[{"def":"Affecting unfavorably by the supposed influence of the stars; baleful.","pos":""}],"SIDERATED":[{"def":"Planet-struck; blasted.","pos":""}],"SIDERATION":[{"def":"The state of being siderated, or planet-struck; esp.","pos":""}],"SIDEREAL":[{"def":"Measuring by the apparent motion of the stars; designated, marked out, or accompanied, by a return to the same position in respect to the stars; as, the sidereal revolution of a planet; a sidereal day.","pos":""}],"SIDEREALIZE":[{"def":"To elevate to the stars, or to the region of the stars; to etherealize.","pos":""}],"SIDERITE":[{"def":"Any plant of the genus Sideritis; ironwort.","pos":""},{"def":"Of or pertaining to siderography; executed by engraved plates of steel; as, siderographic art; siderographic impressions.","pos":""}],"SIDEROGRAPHIST":[{"def":"One skilled in siderography.","pos":""}],"SIDEROLITE":[{"def":"A kind of meteorite.","pos":""}],"SIDEROMANCY":[{"def":"Divination by burning straws on red-hot iron, and noting the manner of their burning.","pos":""}],"SIDEROSCOPE":[{"def":"An instrument for detecting small quantities of iron in any substance by means of a very delicate combination of magnetic needles.","pos":""}],"SIDEROSIS":[{"def":"A sort of pneumonia occuring in iron workers, produced by the inhalation of particles of iron.","pos":"noun"}],"SIDEROSTAT":[{"def":"An apparatus consisting essentially of a mirror moved by clockwork so as to throw the rays of the sun or a star in a fixed direction; -- a more general term for heliostat.","pos":""}],"SIDEROXYLON":[{"def":"A genus of tropical sapotaceous trees noted for their very hard wood; ironwood.","pos":""}],"SIDESADDLE":[{"def":"A saddle for women, in which the rider sits with both feet on one side of the animal mounted.","pos":""}],"SIDESMAN":[{"def":"A party man; a partisan.","pos":""},{"def":"An assistant to the churchwarden; a questman.","pos":""}],"SIDETRACK":[{"def":"Such a project was, in fact, sidetracked in favor of the census of school children.","pos":""}],"SIDEWALK":[{"def":"A walk for foot passengers at the side of a street or road; a foot pavement.","pos":""}],"SIDEWAYS":[{"def":"Toward the side; sidewise.","pos":""}],"SIDEWINDER":[{"def":"A heavy swinging blow from the side, which disables an adversary.","pos":""}],"SIDEWISE":[{"def":"On or toward one side; laterally; sideways.","pos":""}],"SIDING":[{"def":"The covering of the outside wall of a frame house, whether made of weatherboards, vertical boarding with cleats, shingles, or the like.","pos":""},{"def":"The thickness of a rib or timber, measured, at right angles with its side, across the curved edge; as, a timber having a siding of ten inches.","pos":""}],"SIDLE":[{"def":"To go or move with one side foremost; to move sidewise; as, to sidle through a crowd or narrow opening.","pos":""}]}