{"SWICH":[{"def":"Swich things as that I know I will declare.","pos":""}],"SWIETENIA":[{"def":"A genus of meliaceous trees consisting of one species (Sweitenia Mahogoni), the mahogany tree.","pos":""}],"SWIFT":[{"def":"Moving a great distance in a short time; moving with celerity or velocity; fleet; rapid; quick; speedy; prompt.","pos":""},{"def":"Of short continuance; passing away quickly.","pos":""}],"SWIFTER":[{"def":"To tighten, as slack standing rigging, by bringing the opposite shrouds nearer.","pos":""}],"SWIFTLET":[{"def":"Any one of numerous species of small East Indian and Asiatic swifts of the genus Collocalia.","pos":""}],"SWIFTLY":[{"def":"In a swift manner; with quick motion or velocity; fleetly.","pos":""}],"SWIFTNESS":[{"def":"The quality or state of being swift; speed; quickness; celerity; velocity; rapidity; as, the swiftness of a bird; the swiftness of a stream; swiftness of descent in a falling body; swiftness of thought, etc.","pos":""}],"SWIG":[{"def":"To drink in long draughts; to gulp; as, to swig cider.","pos":"verb"}],"SWILL":[{"def":"To drink in great draughts; to swallow greedily.","pos":""}],"SWIM":[{"def":"To be supported by water or other fluid; not to sink; to float; as, any substance will swim, whose specific gravity is less than that of the fluid in which it is immersed.","pos":""},{"def":"To move progressively in water by means of strokes with the hands and feet, or the fins or the tail.","pos":""}],"SWIMBEL":[{"def":"A moaning or sighing sound or noise; a sough.","pos":""}],"SWIMMER":[{"def":"A protuberance on the leg of a horse.","pos":""},{"def":"A swimming bird; one of the natatores.","pos":""}],"SWIMMERET":[{"def":"One of a series of flat, fringed, and usually bilobed, appendages, of which several pairs occur on the abdominal somites of many crustaceans.","pos":""}],"SWIMMING":[{"def":"That swims; capable of swimming; adapted to, or used in, swimming; as, a swimming bird; a swimming motion.","pos":""},{"def":"Suffused with moisture; as, swimming eyes.","pos":""}],"SWIMMINGLY":[{"def":"In an easy, gliding manner, as if swimming; smoothly; successfully; prosperously.","pos":""}],"SWIMMINGNESS":[{"def":"Act or state of swimming; suffusion.","pos":""}],"SWINDLE":[{"def":"To cheat defraud grossly, or with deliberate artifice; as, to swindle a man out of his property.","pos":""}],"SWINDLER":[{"def":"One who swindles, or defrauds grossly; one who makes a practice of defrauding others by imposition or deliberate artifice; a cheat.","pos":""}],"SWINDLERY":[{"def":"Swindling; rougery.","pos":""}],"SWINE":[{"def":"Any animal of the hog kind, especially one of the domestical species.","pos":"noun"}],"SWINE-POX":[{"def":"A variety of the chicken pox, with acuminated vesicles containing a watery fluid; the water pox.","pos":""}],"SWINEHERD":[{"def":"A keeper of swine.","pos":""}],"SWINEPIPE":[{"def":"The European redwing.","pos":""}],"SWINERY":[{"def":"Same as Piggery.","pos":""}],"SWINESTY":[{"def":"A sty, or pen, for swine.","pos":""}],"SWING":[{"def":"To turn round by action of wind or tide when at anchor; as, a ship swings with the tide.","pos":""}],"SWINGDEVIL":[{"def":"The European swift.","pos":""}],"SWINGE":[{"def":"To beat soundly; to whip; to chastise; to punish.","pos":""},{"def":"To move as a lash; to lash.","pos":""}],"SWINGEBUCKLER":[{"def":"A swashbuckler; a bully; a roiserer.","pos":""}],"SWINGEING":[{"def":"Huge; very large.","pos":""}],"SWINGEL":[{"def":"The swinging part of a flail which falls on the grain in thrashing; the swiple.","pos":""}],"SWINGER":[{"def":"One who swings or whirls.","pos":""}],"SWINGLE":[{"def":"To dangle; to wave hanging.","pos":""},{"def":"To swing for pleasure.","pos":""}],"SWINGLETAIL":[{"def":"The thrasher, or fox shark.","pos":""}],"SWINGLETREE":[{"def":"A whiffletree, or whippletree.","pos":""}],"SWINGLING":[{"def":"from Swingle, v.","pos":""}],"SWINGTREE":[{"def":"The bar of a carriage to which the traces are fastened; the whiffletree.","pos":""}],"SWINISH":[{"def":"Of or pertaining to swine; befitting swine; like swine; hoggish; gross; beasty; as, a swinish drunkard or sot.","pos":""}],"SWINK":[{"def":"To labor; to toil; to salve.","pos":""}],"SWIPE":[{"def":"Poor, weak beer; small beer.","pos":""}],"SWIPLE":[{"def":"That part of a flail which strikes the grain in thrashing; a swingel.","pos":""}],"SWIRL":[{"def":"To whirl, or cause to whirl, as in an eddy.","pos":""}],"SWISH":[{"def":"To flourish, so as to make the sound swish.","pos":""},{"def":"To flog; to lash.","pos":""}],"SWISS":[{"def":"A native or inhabitant of Switzerland; a Switzer; the people of Switzerland.","pos":"noun"}],"SWITCH":[{"def":"A movable part of a rail; or of opposite rails, for transferring cars from one track to another.","pos":""},{"def":"A mechanical device for shifting an electric current to another circuit.","pos":""}],"SWITCHEL":[{"def":"A beverage of molasses and water, seasoned with vinegar and ginger.","pos":""}],"SWITCHMAN":[{"def":"One who tends a switch on a railway.","pos":""}],"SWITHE":[{"def":"Instantly; quickly; speedily; rapidly.","pos":""}],"SWITZER":[{"def":"A native or inhabitant of Switzerland; a Swiss.","pos":""}],"SWIVE":[{"def":"To copulate with (a woman).","pos":""}],"SWIVEL":[{"def":"A piece, as a ring or hook, attached to another piece by a pin, in such a manner as to permit rotation about the pin as an axis.","pos":""},{"def":"A small piece of ordnance, turning on a point or swivel; -- called also swivel gun.","pos":""}],"SWIZZLE":[{"def":"To drink; to swill.","pos":""}]}