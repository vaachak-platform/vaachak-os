{"SEME":[{"def":"Sprinkled or sown; -- said of field, or a charge, when strewed or covered with small charges.","pos":""},{"def":"A description of the signs of disease.","pos":""}],"SEMELE":[{"def":"A daughter of Cadmus, and by Zeus mother of Bacchus.","pos":""}],"SEMEN":[{"def":"The seed of plants.","pos":""},{"def":"The seed or fecundating fluid of male animals; sperm.","pos":""}],"SEMESTER":[{"def":"A period of six months; especially, a term in a college or uneversity which divides the year into two terms.","pos":""}]}