{"UNCO":[{"def":"Unknown; strange, or foreign; unusual, or surprising; distant in manner; reserved.","pos":""}],"UNCOACH":[{"def":"To detach or loose from a coach.","pos":""}],"UNCOCK":[{"def":"To let down the cock of, as a firearm.","pos":""},{"def":"To deprive of its cocked shape, as a hat, etc.","pos":""}],"UNCOFFLE":[{"def":"To release from a coffle.","pos":""}],"UNCOIF":[{"def":"To deprive of the coif or cap.","pos":""}],"UNCOIL":[{"def":"To unwind or open, as a coil of rope.","pos":""}],"UNCOINED":[{"def":"Not coined, or minted; as, uncoined silver.","pos":""},{"def":"Not fabricated; not artificial or counterfeit; natural.","pos":""}],"UNCOMBINE":[{"def":"To separate, as substances in combination; to release from combination or union.","pos":""}],"UNCOMEATABLE":[{"def":"Not to be come at, or reached; inaccessible.","pos":""}],"UNCOMFORTABLE":[{"def":"Feeling discomfort; uneasy; as, to be uncomfortable on account of one's position.","pos":""},{"def":"Causing discomfort; disagreeable; unpleasant; as, an uncomfortable seat or situation.","pos":""}],"UNCOMMON":[{"def":"Not common; unusual; infrequent; rare; hence, remarkable; strange; as, an uncommon season; an uncommon degree of cold or heat; uncommon courage.","pos":""}],"UNCOMPREHEND":[{"def":"To fail to comprehend.","pos":""}],"UNCOMPREHENSIVE":[{"def":"Unable to comprehend.","pos":""},{"def":"Incomprehensible.","pos":""}],"UNCOMPROMISING":[{"def":"Not admitting of compromise; making no truce or concessions; obstinate; unyielding; inflexible.","pos":""}],"UNCONCERN":[{"def":"Want of concern; absence of anxiety; freedom from solicitude; indifference.","pos":""}],"UNCONCERNED":[{"def":"Not concerned; not anxious or solicitous; easy in mind; carelessly secure; indifferent; as, to be unconcerned at what has happened; to be unconcerned about the future.","pos":""}],"UNCONCERNING":[{"def":"Not interesting of affecting; insignificant; not belonging to one.","pos":""}],"UNCONCERNMENT":[{"def":"The state of being unconcerned, or of having no share or concern; unconcernedness.","pos":""}],"UNCONDITIONAL":[{"def":"Not conditional limited, or conditioned; made without condition; absolute; unreserved; as, an unconditional surrender.","pos":""}],"UNCONDITIONED":[{"def":"Not subject to condition or limitations; infinite; absolute; hence, inconceivable; incogitable.","pos":""}],"UNCONFIDENCE":[{"def":"Absence of confidence; uncertainty; doubt.","pos":""}],"UNCONFORM":[{"def":"Not unconform to other shining globes.","pos":""}],"UNCONFORMABILITY":[{"def":"Want of parallelism between one series of strata and another, especially when due to a disturbance of the position of the earlier strata before the latter were deposited.","pos":""}],"UNCONFORMABLE":[{"def":"Not conformable; not lying in a parallel position; as, unconformable strata.","pos":""}],"UNCONFORMIST":[{"def":"A nonconformist.","pos":""}],"UNCONFORMITY":[{"def":"Want of parallelism between strata in contact.","pos":""}],"UNCONFOUND":[{"def":"To free from a state of confusion, or of being confounded.","pos":""}],"UNCONGEAL":[{"def":"To thaw; to become liquid again.","pos":""}],"UNCONNING":[{"def":"Not knowing; ignorant.","pos":""}],"UNCONQUERABLE":[{"def":"Not conquerable; indomitable.","pos":""}],"UNCONSCIONABLE":[{"def":"Not conscionable; not conforming to reason; unreasonable; exceeding the limits of any reasonable claim or expectation; inordinate; as, an unconscionable person or demand; unconscionable size.","pos":""},{"def":"Not guided by, or conformed to, conscience.","pos":""}],"UNCONSCIOUS":[{"def":"Not conscious; having no consciousness or power of mental perception; without cerebral appreciation; hence, not knowing or regarding; ignorant; as, an unconscious man.","pos":""},{"def":"Not known or apprehended by consciousness; as, an unconscious cerebration.","pos":""}],"UNCONSECRATE":[{"def":"To render not sacred; to deprive of sanctity; to desecrate.","pos":""}],"UNCONSEQUENTIAL":[{"def":"Inconsequential.","pos":""}],"UNCONSIDERATE":[{"def":"Inconsiderate; heedless; careless.","pos":""}],"UNCONSIDERED":[{"def":"Not considered or attended to; not regarded; inconsiderable; trifling.","pos":""}],"UNCONSONANT":[{"def":"Incongruous; inconsistent.","pos":""}],"UNCONSTANT":[{"def":"Not constant; inconstant; fickle; changeable.","pos":""}],"UNCONSTITUTIONAL":[{"def":"Not constitutional; not according to, or consistent with, the terms of a constitution of government; contrary to the constitution; as, an unconstitutional law, or act of an officer.","pos":""}],"UNCONSTRAINT":[{"def":"Freedom from constraint; ease.","pos":""}],"UNCONSUMMATE":[{"def":"Not consummated; not accomplished.","pos":""}],"UNCONTINENT":[{"def":"Not continent; incontinent.","pos":""}],"UNCONTROLLABLE":[{"def":"Incapable of being controlled; ungovernable; irresistible; as, an uncontrollable temper; uncontrollable events.","pos":""},{"def":"Indisputable; irrefragable; as, an uncontrollable maxim; an uncontrollable title.","pos":""}],"UNCONTROVERSORY":[{"def":"Not involving controversy.","pos":""}],"UNCONTROVERTIBLE":[{"def":"Incontrovertible.","pos":""}],"UNCONTROVERTIBLY":[{"def":"Incontrovertibly.","pos":""}],"UNCONVERSION":[{"def":"The state of being unconverted; impenitence.","pos":""}],"UNCONVERTED":[{"def":"Not converted or exchanged.","pos":""},{"def":"Not changed in opinion, or from one faith to another.","pos":""}],"UNCORD":[{"def":"To release from cords; to loosen the cord or cords of; to unfasten or unbind; as, to uncord a package.","pos":""}],"UNCORK":[{"def":"To draw the cork from; as, to uncork a bottle.","pos":""}],"UNCORRIGIBLE":[{"def":"Incorrigible; not capable of correction.","pos":""}],"UNCOUPLE":[{"def":"To loose, as dogs, from their couples; also, to set loose; to disconnect; to disjoin; as, to uncouple railroad cars.","pos":""}],"UNCOURTLINESS":[{"def":"Absence of courtliness; rudeness; rusticity.","pos":""}],"UNCOUS":[{"def":"Hooklike; hooked.","pos":""}],"UNCOUTH":[{"def":"Uncommon; rare; exquisite; elegant.","pos":""}],"UNCOVENABLE":[{"def":"Not covenable; inconvenient.","pos":""}],"UNCOVENANTED":[{"def":"Not having entered into relationship with God through the appointed means of grace; also, not promised or assured by the divine promises or conditions; as, uncovenanted mercies.","pos":""}],"UNCOVER":[{"def":"To take the cover from; to divest of covering; as, to uncover a box, bed, house, or the like; to uncover one's body.","pos":""},{"def":"To show openly; to disclose; to reveal.","pos":""}],"UNCOWL":[{"def":"To divest or deprive of a cowl.","pos":""}]}