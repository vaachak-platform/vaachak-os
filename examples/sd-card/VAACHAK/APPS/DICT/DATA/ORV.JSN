{"ORVAL":[{"def":"A kind of sage (Salvia Horminum).","pos":""}],"ORVIETAN":[{"def":"A kind of antidote for poisons; a counter poison formerly in vogue.","pos":""},{"def":"A noun suffix denoting that which pertains to, or serves for; as in ambulatory, that which serves for walking; consistory, factory, etc.","pos":""}]}