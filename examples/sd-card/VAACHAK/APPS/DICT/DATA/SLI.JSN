{"SLICE":[{"def":"A thin, broad piece cut off; as, a slice of bacon; a slice of cheese; a slice of bread.","pos":""},{"def":"That which is thin and broad, like a slice.","pos":""}],"SLICER":[{"def":"One who, or that which, slices; specifically, the circular saw of the lapidary.","pos":""}],"SLICK":[{"def":"To make sleek or smoth.","pos":""}],"SLICKENS":[{"def":"The pulverized matter from a quartz mill, or the lighter soil of hydraulic mines.","pos":""}],"SLICKENSIDES":[{"def":"The smooth, striated, or partially polished surfaces of a fissure or seam, supposed to have been produced by the sliding of one surface on another.","pos":""},{"def":"A variety of galena found in Derbyshire, England.","pos":""}],"SLICKER":[{"def":"That which makes smooth or sleek.","pos":""}],"SLICKING":[{"def":"Narrow veins of ore.","pos":""}],"SLICKNESS":[{"def":"The state or quality of being slick; smoothness; sleekness.","pos":""}],"SLIDDER":[{"def":"To slide with interruption.","pos":""}],"SLIDE":[{"def":"To pass from one note to another with no perceptible cassation of sound.","pos":""}],"SLIDEGROAT":[{"def":"The game of shovelboard.","pos":""}],"SLIDER":[{"def":"The red-bellied terrapin (Pseudemys rugosa).","pos":""}],"SLIDEWAY":[{"def":"A way along which something slides.","pos":""}],"SLIDING":[{"def":"That slides or slips; gliding; moving smoothly.","pos":""},{"def":"Slippery; elusory.","pos":""}],"SLIDOMETER":[{"def":"An instrument for indicating and recording shocks to railway cars occasioned by sudden stopping.","pos":""}],"SLIGHT":[{"def":"To overthrow; to demolish.","pos":""},{"def":"To make even or level.","pos":""}],"SLIGHTER":[{"def":"One who slights.","pos":""}],"SLIGHTING":[{"def":"Characterized by neglect or disregard.","pos":""}],"SLIGHTINGLY":[{"def":"In a slighting manner.","pos":""}],"SLIGHTLY":[{"def":"In a slight manner.","pos":""},{"def":"Slightingly; negligently.","pos":""}],"SLIGHTNESS":[{"def":"The quality or state of being slight; slenderness; feebleness; superficiality; also, formerly, negligence; indifference; disregard.","pos":""}],"SLIK":[{"def":"Note: Used by Chaucer as of the Northern dialect.","pos":""}],"SLIKENSIDES":[{"def":"Same as Slickensides.","pos":""}],"SLIM":[{"def":"Weak; slight; unsubstantial; poor; as, a slim argument.","pos":""}],"SLIME":[{"def":"Mud containing metallic ore, obtained in the preparatory dressing.","pos":""}],"SLIMILY":[{"def":"In a slimy manner.","pos":""}],"SLIMINESS":[{"def":"The quality or state of being slimy.","pos":""}],"SLIMLY":[{"def":"In a state of slimness; in a slim manner; slenderly.","pos":""}],"SLIMNESS":[{"def":"The quality or state of being slim.","pos":""}],"SLIMY":[{"def":"Of or pertaining to slime; resembling slime; of the nature of slime; viscous; glutinous; also, covered or daubed with slime; yielding, or abounding in, slime.","pos":""}],"SLING":[{"def":"An instrument for throwing stones or other missiles, consisting of a short strap with two strings fastened to its ends, or with a string fastened to one end and a light stick to the other.","pos":""},{"def":"The act or motion of hurling as with a sling; a throw; figuratively, a stroke.","pos":""}],"SLINGER":[{"def":"One who slings, or uses a sling.","pos":""}],"SLINK":[{"def":"To creep away meanly; to steal away; to sneak.","pos":""},{"def":"To miscarry; -- said of female beasts.","pos":""}],"SLIP":[{"def":"To move along the surface of a thing without bounding, rolling, or stepping; to slide; to glide.","pos":""},{"def":"To slide; to lose one's footing or one's hold; not to tread firmly; as, it is necessary to walk carefully lest the foot should slip.","pos":""}],"SLIP-ON":[{"def":"A kind of overcoat worn upon the shoulders in the manner of a cloak.","pos":""}],"SLIPBOARD":[{"def":"A board sliding in grooves.","pos":""}],"SLIPCOAT CHEESE":[{"def":"A rich variety of new cheese, resembling butter, but white.","pos":""}],"SLIPES":[{"def":"Sledge runners on which a skip is dragged in a mine.","pos":""}],"SLIPKNOT":[{"def":"knot which slips along the rope or line around which it is made.","pos":""}],"SLIPPAGE":[{"def":"The act of slipping; also, the amount of slipping.","pos":""}],"SLIPPER":[{"def":"A piece, usually a plate, applied to a sliding piece, to receive wear and afford a means of adjustment; -- also called shoe, and gib.","pos":""}],"SLIPPERED":[{"def":"Wearing slippers.","pos":""}],"SLIPPERILY":[{"def":"In a slippery manner.","pos":""}],"SLIPPERINESS":[{"def":"The quality of being slippery.","pos":""}],"SLIPPERWORT":[{"def":"See Calceolaria.","pos":""}],"SLIPPERY":[{"def":"Having the quality opposite to adhesiveness; allowing or causing anything to slip or move smoothly, rapidly, and easily upon the surface; smooth; glib; as, oily substances render things slippery.","pos":""},{"def":"Not affording firm ground for confidence; as, a slippery promise.","pos":""}],"SLIPSHOD":[{"def":"Wearing shoes or slippers down at the heel.","pos":""},{"def":"Figuratively: Careless in dress, manners, style, etc.","pos":""}],"SLIPSLOP":[{"def":"Weak, poor, or flat liquor; weak, profitless discourse or writing.","pos":""}],"SLIPSTRING":[{"def":"One who has shaken off restraint; a prodigal.","pos":""}],"SLISH":[{"def":"A cut; as, slish and slash.","pos":""}],"SLIT":[{"def":"To cut lengthwise; to cut into long pieces or strips; as, to slit iron bars into nail rods; to slit leather into straps.","pos":""},{"def":"To cut or make a long fissure in or upon; as, to slit the ear or the nose.","pos":""}],"SLIT-SHELL":[{"def":"Any species of Pleurotomaria, a genus of beautiful, pearly, spiral gastropod shells having a deep slit in the outer lip.","pos":""}],"SLITHER":[{"def":"To slide; to glide.","pos":""}],"SLITTER":[{"def":"One who, or that which, slits.","pos":""}],"SLIVE":[{"def":"To cut; to split; to separate.","pos":""}],"SLIVER":[{"def":"To cut or divide into long, thin pieces, or into very small pieces; to cut or rend lengthwise; to slit; as, to sliver wood.","pos":""}]}