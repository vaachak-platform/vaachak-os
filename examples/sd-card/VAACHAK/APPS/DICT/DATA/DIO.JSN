{"DIOCESAN":[{"def":"Of or pertaining to a diocese; as, diocesan missions.","pos":""}],"DIOCESE":[{"def":"The circuit or extent of a bishop's jurisdiction; the district in which a bishop exercises his ecclesiastical authority.","pos":""}],"DIOCESENER":[{"def":"One who belongs to a diocese.","pos":""}],"DIODON":[{"def":"A genus of spinose, plectognath fishes, having the teeth of each jaw united into a single beaklike plate.","pos":""},{"def":"A genus of whales.","pos":""}],"DIODONT":[{"def":"Like or pertaining to the genus Diodon.","pos":""},{"def":"A fish of the genus Diodon, or an allied genus.","pos":""}],"DIOECIA":[{"def":"A Linnæan class of plants having the stamens and pistils on different plants.","pos":""},{"def":"A subclass of gastropod mollusks in which the sexes are separate.","pos":""}],"DIOECIOUSLY":[{"def":"In a dioecious manner.","pos":""}],"DIOECIOUSNESS":[{"def":"The state or quality of being dioecious.","pos":""}],"DIOECISM":[{"def":"The condition of being dioecious.","pos":""}],"DIOGENES":[{"def":"A Greek Cynic philosopher (412-323 B.","pos":""}],"DIOMEDEA":[{"def":"A genus of large sea birds, including the albatross.","pos":""}],"DIONAEA":[{"def":"An insectivorous plant.","pos":""}],"DIONYSIA":[{"def":"Any of the festivals held in honor of the Olympian god Dionysus.","pos":""}],"DIONYSIAC":[{"def":"Of or pertaining to Dionysus or to the Dionysia; Bacchic; as, a Dionysiac festival; the Dionysiac theater at Athens.","pos":""}],"DIONYSIAN":[{"def":"Relating to Dionysius, a monk of the 6th century; as, the Dionysian, or Christian, era.","pos":""}],"DIOPHANTINE":[{"def":"Originated or taught by Diophantus, the Greek writer on algebra.","pos":""}],"DIOPSIDE":[{"def":"A crystallized variety of pyroxene, of a clear, grayish green color; mussite.","pos":""}],"DIOPTASE":[{"def":"A hydrous silicate of copper, occurring in emerald-green crystals.","pos":""},{"def":"An optical instrument, invented by Hipparchus, for taking altitudes, leveling, etc.","pos":""}],"DIOPTRE":[{"def":"A unit employed by oculists in numbering glasses according to the metric system; a refractive power equal to that of a glass whose principal focal distance is one meter.","pos":""}],"DIOPTRIC":[{"def":"Of or pertaining to the dioptre, or to the metric system of numbering glasses.","pos":""}],"DIOPTRICS":[{"def":"The science of the refraction of light; that part of geometrical optics which treats of the laws of the refraction of light in passing from one medium into another, or through different mediums, as air, water, or glass, and esp.","pos":""}],"DIORAMA":[{"def":"A mode of scenic representation, invented by Daguerre and Bouton, in which a painting is seen from a distance through a large opening.","pos":""},{"def":"A building used for such an exhibition.","pos":""}],"DIORAMIC":[{"def":"Pertaining to a diorama.","pos":""}],"DIORISM":[{"def":"Definition; logical direction.","pos":""}],"DIORISTIC":[{"def":"Distinguishing; distinctive; defining.","pos":""}],"DIORITE":[{"def":"An igneous, crystalline in structure, consisting essentially of a triclinic feldspar and hornblende.","pos":""}],"DIORITIC":[{"def":"Containing diorite.","pos":""}],"DIORTHOTIC":[{"def":"Relating to the correcting or straightening out of something; corrective.","pos":""}],"DIOSCOREA":[{"def":"A genus of plants.","pos":""}],"DIOTA":[{"def":"A vase or drinking cup having two handles or ears.","pos":""}],"DIOXINDOL":[{"def":"A white, crystalline, nitrogenous substance obtained by the reduction of isatin.","pos":""}]}