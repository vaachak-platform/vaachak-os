{"DILACERATE":[{"def":"To rend asunder; to tear to pieces.","pos":""}],"DILACERATION":[{"def":"The act of rending asunder.","pos":""}],"DILANIATE":[{"def":"To rend in pieces; to tear.","pos":""}],"DILANIATION":[{"def":"A rending or tearing in pieces; dilaceration.","pos":""}],"DILAPIDATE":[{"def":"To bring into a condition of decay or partial ruin, by misuse or through neglect; to destroy the fairness and good condition of; -- said of a building.","pos":""},{"def":"To impair by waste and abuse; to squander.","pos":""}],"DILAPIDATED":[{"def":"Decayed; fallen into partial ruin; injured by bad usage or neglect.","pos":""}],"DILAPIDATION":[{"def":"The pulling down of a building, or suffering it to fall or be in a state of decay.","pos":""}],"DILAPIDATOR":[{"def":"One who causes dilapidation.","pos":""}],"DILATABILITY":[{"def":"The quality of being dilatable, or admitting expansion; -- opposed to contractibility.","pos":""}],"DILATABLE":[{"def":"Capable of expansion; that may be dilated; -- opposed to contractible; as, the lungs are dilatable by the force of air; air is dilatable by heat.","pos":""}],"DILATATION":[{"def":"A dilation or enlargement of a canal or other organ.","pos":""}],"DILATATOR":[{"def":"A muscle which dilates any part; a dilator.","pos":""}],"DILATE":[{"def":"To expand; to distend; to enlarge or extend in all directions; to swell; -- opposed to contract; as, the air dilates the lungs; air is dilated by increase of heat.","pos":""},{"def":"To enlarge upon; to relate at large; to tell copiously or diffusely.","pos":""}],"DILATED":[{"def":"Widening into a lamina or into lateral winglike appendages.","pos":""},{"def":"Having the margin wide and spreading.","pos":""}],"DILATEDLY":[{"def":"In a dilated manner.","pos":""}],"DILATER":[{"def":"One who, or that which, dilates, expands, o r enlarges.","pos":""}],"DILATION":[{"def":"The act of dilating, or the state of being dilated; expansion; dilatation.","pos":""}],"DILATIVE":[{"def":"Causing dilation; tending to dilate, on enlarge; expansive.","pos":""}],"DILATOMETER":[{"def":"An instrument for measuring the dilatation or expansion of a substance, especially of a fluid.","pos":""}],"DILATOR":[{"def":"A muscle that dilates any part.","pos":""},{"def":"An instrument for expanding a part; as, a urethral dilator.","pos":""}],"DILATORILY":[{"def":"With delay; tardily.","pos":""}],"DILATORINESS":[{"def":"The quality of being dilatory; lateness; slowness; tardiness; sluggishness.","pos":""}],"DILATORY":[{"def":"Inclined to defer or put off what ought to be done at once; given the procrastination; delaying; procrastinating; loitering; as, a dilatory servant.","pos":""},{"def":"Marked by procrastination or delay; tardy; slow; sluggish; -- said of actions or measures.","pos":""}],"DILDO":[{"def":"A burden in popular songs.","pos":""}],"DILEMMA":[{"def":"An argument which presents an antagonist with two or more alternatives, but is equally conclusive against him, whichever alternative he chooses.","pos":""}],"DILETTANT":[{"def":"Of or pertaining to dilettanteism; amateur; as, dilettant speculation.","pos":""}],"DILETTANTE":[{"def":"An admirer or lover of the fine arts; popularly, an amateur; especially, one who follows an art or a branch of knowledge, desultorily, or for amusement only.","pos":""}],"DILETTANTEISH":[{"def":"Somewhat like a dilettante.","pos":""}],"DILETTANTEISM":[{"def":"The state or quality of being a dilettante; the desultory pursuit of art, science, or literature.","pos":""}],"DILETTANTISM":[{"def":"Same as Dilettanteism.","pos":""}],"DILIGENCE":[{"def":"Process by which persons, lands, or effects are seized for debt; process for enforcing the attendance of witnesses or the production of writings.","pos":""}],"DILIGENCY":[{"def":"Diligence; care; persevering endeavor.","pos":""}],"DILIGENT":[{"def":"Prosecuted with careful attention and effort; careful; painstaking; not careless or negligent.","pos":""},{"def":"Interestedly and perseveringly attentive; steady and earnest in application to a subject or pursuit; assiduous; industrious.","pos":""}],"DILIGENTLY":[{"def":"In a diligent manner; not carelessly; not negligently; with industry or assiduity.","pos":""}],"DILL":[{"def":"An herb (Peucedanum graveolens), the seeds of which are moderately warming, pungent, and aromatic, and were formerly used as a soothing medicine for children; -- called also dill-seed.","pos":""}],"DILLING":[{"def":"A darling; a favorite.","pos":""}],"DILLUING":[{"def":"A process of sorting ore by washing in a hand sieve.","pos":""}],"DILLY":[{"def":"A kind of stagecoach.","pos":""}],"DILLY-DALLY":[{"def":"To loiter or trifle; to waste time.","pos":""}],"DILOGICAL":[{"def":"Ambiguous; of double meaning.","pos":""}],"DILOGY":[{"def":"An ambiguous speech; a figure in which a word is used an equivocal sense.","pos":""}],"DILUCIDATION":[{"def":"The act of making clear.","pos":""}],"DILUENT":[{"def":"Diluting; making thinner or weaker by admixture, esp.","pos":""}],"DILUTE":[{"def":"To make thinner or more liquid by admixture with something; to thin and dissolve by mixing.","pos":""},{"def":"To diminish the strength, flavor, color, etc.","pos":""}],"DILUTED":[{"def":"Reduced in strength; thin; weak.","pos":""}],"DILUTENESS":[{"def":"The quality or state of being dilute.","pos":""}],"DILUTER":[{"def":"One who, or that which, dilutes or makes thin, more liquid, or weaker.","pos":""}],"DILUTION":[{"def":"The act of diluting, or the state of being diluted.","pos":""}],"DILUVIAL":[{"def":"Effected or produced by a flood or deluge of water; -- said of coarse and imperfectly stratified deposits along ancient or existing water courses.","pos":""}],"DILUVIALIST":[{"def":"One who explains geological phenomena by the Noachian deluge.","pos":""}],"DILUVIAN":[{"def":"Of or pertaining to a deluge, esp.","pos":""}],"DILUVIATE":[{"def":"To run as a flood.","pos":""}],"DILUVIUM":[{"def":"A deposit of superficial loam, sand, gravel, stones, etc.","pos":""}]}