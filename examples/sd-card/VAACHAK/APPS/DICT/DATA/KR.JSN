{"KRA":[{"def":"A long-tailed ape (Macacus cynomolgus) of India and Sumatra.","pos":""}],"KRAAL":[{"def":"A collection of huts within a stockade; a village; sometimes, a single hut.","pos":""},{"def":"An inclosure into which are driven wild elephants which are to be tamed and educated.","pos":""}],"KRAIT":[{"def":"A very venomous snake of India (Bungarus coeruleus), allied to the cobra.","pos":""}],"KRAKEN":[{"def":"A fabulous Scandinavian sea monster, often represented as resembling an island, but sometimes as resembling an immense octopus.","pos":""}],"KRAKOWIAK":[{"def":"A lively Polish dance.","pos":""}],"KRAMERIA":[{"def":"A genus of spreading shrubs with many stems, from one species of which (K.","pos":""}],"KRAMERIC":[{"def":"Pertaining to, or derived from, Krameria (rhatany); as, krameric acid, usually called ratanhia-tannic acid.","pos":""}],"KRANG":[{"def":"The carcass of a whale after the blubber has been removed.","pos":""}],"KRANGING HOOK":[{"def":"A hook for holding the blubber while cutting it away.","pos":""}],"KREMLIN":[{"def":"The citadel of a town or city; especially, the citadel of Moscow, a large inclosure which contains imperial palaces, cathedrals, churches, an arsenal, etc.","pos":""}],"KREMS":[{"def":"A variety of white lead.","pos":""}],"KREUTZER":[{"def":"A small copper coin formerly used in South Germany; also, a small Austrian copper coin.","pos":""}],"KRIEGSSPIEL":[{"def":"A game of war, played for practice, on maps.","pos":""}],"KRISHNA":[{"def":"The most popular of the Hindoo divinities, usually held to be the eighth incarnation of the god Vishnu.","pos":""}],"KRITARCHY":[{"def":"The rule of the judges over Israel.","pos":""}],"KROKIDOLITE":[{"def":"See Crocidolite.","pos":""}],"KRONE":[{"def":"A coin of Denmark, Norway, and Sweden, of the value of about twenty-eight cents.","pos":"noun"}],"KROOMAN":[{"def":"One of a negro tribe of Liberia and the adjacent coast, whose members are much employed on shipboard.","pos":""}],"KRULLER":[{"def":"KRUMMHORN; KRUMHORN Krumm\"horn`, Krum\"horn`, n.","pos":""}],"KRUPP GUN":[{"def":"Krupp\" gun\" Defn: .","pos":""}],"KRUPPIZE":[{"def":"To treat by, or subject to, the Krupp process.","pos":""}],"KRYPTON":[{"def":"An inert gaseous element of the argon group, occurring in air to the extent of about one volume in a million.","pos":""}]}