{"SHAFFLE":[{"def":"To hobble or limp; to shuffle.","pos":""}],"SHAFFLER":[{"def":"A hobbler; one who limps; a shuffer.","pos":""}],"SHAFIITE":[{"def":"A member of one of the four sects of the Sunnites, or Orthodox Mohammedans; -- so called from its founder, Mohammed al-Shafeï.","pos":""}],"SHAFT":[{"def":"A rod at the end of a heddle.","pos":""},{"def":"A humming bird (Thaumastura cora) having two of the tail feathers next to the middle ones very long in the male; -- called also cora humming bird.","pos":""}],"SHAFTED":[{"def":"Having a shaft; -- applied to a spear when the head and the shaft are of different tinctures.","pos":""}],"SHAFTING":[{"def":"Shafts, collectivelly; a system of connected shafts for communicating motion.","pos":""},{"def":"A measure of about six inches.","pos":""}]}