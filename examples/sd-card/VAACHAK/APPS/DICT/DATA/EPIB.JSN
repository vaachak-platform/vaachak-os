{"EPIBLAST":[{"def":"The outer layer of the blastoderm; the ectoderm.","pos":""}],"EPIBLASTIC":[{"def":"Of or relating to, or consisting of, the epiblast.","pos":""}],"EPIBLEMA":[{"def":"The epidermal cells of rootlets, specially adapted to absorb liquids.","pos":""}],"EPIBOLIC":[{"def":"Growing or covering over; -- said of a kind of invagination.","pos":""}],"EPIBOLY":[{"def":"Epibolic invagination.","pos":""}],"EPIBRANCHIAL":[{"def":"Pertaining to the segment between the ceratobranchial and pharyngobranchial in a branchial arch.","pos":""},{"def":"An epibranchial cartilage or bone.","pos":""}]}