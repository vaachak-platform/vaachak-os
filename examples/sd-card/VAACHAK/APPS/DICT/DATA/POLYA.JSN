{"POLYACID":[{"def":"Capable of neutralizing, or of combining with, several molecules of a monobasic acid; having more than one hydrogen atom capable of being replaced by acid radicals; -- said of certain bases; as, calcium hydrate and glycerin are polyacid bases.","pos":""}],"POLYACOUSTIC":[{"def":"Multiplying or magnifying sound.","pos":""},{"def":"A polyacoustic instrument.","pos":""}],"POLYACOUSTICS":[{"def":"The art of multiplying or magnifying sounds.","pos":""}],"POLYACRON":[{"def":"A solid having many summits or angular points; a polyhedron.","pos":""}],"POLYACTINIA":[{"def":"An old name for those Anthozoa which, like the actinias, have numerous simple tentacles.","pos":""}],"POLYADELPHIA":[{"def":"A Linnæan class of plants having stamens united in three or more bodies or bundles by the filaments.","pos":""},{"def":"Belonging to the class Polyadelphia; having stamens united in three or more bundles.","pos":""}],"POLYANDRIA":[{"def":"A Linnæan class of monoclinous or hermaphrodite plants, having many stamens, or any number above twenty, inserted in the receptacle.","pos":""}],"POLYANDRIC":[{"def":"Pertaining to, or characterized by, polyandry; mating with several males.","pos":""}],"POLYANDROUS":[{"def":"Belonging to the class Polyandria; having many stamens, or any number above twenty, inserted in the receptacle.","pos":""}],"POLYANDRY":[{"def":"The possession by a woman of more than one husband at the same time; -- contrasted with Ant: monandry.","pos":""}],"POLYARCHIST":[{"def":"One who advocates polyarchy; -- opposed to monarchist.","pos":""}],"POLYARCHY":[{"def":"A government by many persons, of whatever order or class.","pos":""}],"POLYAUTOGRAPHY":[{"def":"The act or practice of multiplying copies of one's own handwriting, or of manuscripts, by printing from stone, -- a species of lithography.","pos":""}]}