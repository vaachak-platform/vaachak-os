{"SEMIOCCASIONALLY":[{"def":"Once in a while; on rare occasions.","pos":""}],"SEMIOFFICIAL":[{"def":"Half official; having some official authority or importance; as, a semiofficial statement.","pos":""},{"def":"Same as Semeiography, Semeiology, Semeiological.","pos":""}],"SEMIOPAL":[{"def":"A variety of opal not possessing opalescence.","pos":""}],"SEMIOPAQUE":[{"def":"Half opaque; only half transparent.","pos":""}],"SEMIORBICULAR":[{"def":"Having the shape of a half orb or sphere.","pos":""}],"SEMIOTIC":[{"def":"Same as Semeiotic.","pos":""}],"SEMIOTICS":[{"def":"Same as Semeiotics.","pos":""}],"SEMIOXYGENATED":[{"def":"Combined with oxygen only in part.","pos":""}]}