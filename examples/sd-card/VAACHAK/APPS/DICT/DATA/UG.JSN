{"UGH":[{"def":"An exclamation expressive of disgust, horror, or recoil.","pos":""}],"UGLIFY":[{"def":"To disfigure; to make ugly.","pos":""}],"UGLILY":[{"def":"In an ugly manner; with deformity.","pos":""}],"UGLINESS":[{"def":"The quality or state of being ugly.","pos":""}],"UGLY":[{"def":"Offensive to the sight; contrary to beauty; being of disagreeable or loathsome aspect; unsightly; repulsive; deformed.","pos":""},{"def":"Ill-natured; crossgrained; quarrelsome; as, an ugly temper; to feel ugly.","pos":""}],"UGRIAN":[{"def":"A Mongolian race, ancestors of the Finns.","pos":""}],"UGSOME":[{"def":"Ugly; offensive; loathsome.","pos":""}]}