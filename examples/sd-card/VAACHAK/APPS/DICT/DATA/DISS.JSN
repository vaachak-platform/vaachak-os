{"DISSATISFACTION":[{"def":"The state of being dissatisfied, unsatisfied, or discontented; uneasiness proceeding from the want of gratification, or from disappointed wishes and expectations.","pos":""}],"DISSATISFACTORY":[{"def":"Causing dissatisfaction; unable to give content; unsatisfactory; displeasing.","pos":""}],"DISSATISFY":[{"def":"To render unsatisfied or discontented; to excite uneasiness in by frustrating wishes or expectations; to displease by the want of something requisite; as, to be dissatisfied with one's fortune.","pos":""}],"DISSECT":[{"def":"To divide into separate parts; to cut in pieces; to separate and expose the parts of, as an animal or a plant, for examination and to show their structure and relations; to anatomize.","pos":""}],"DISSECTED":[{"def":"Cut deeply into many lobes or divisions; as, a dissected leaf.","pos":""}],"DISSECTIBLE":[{"def":"Capable of being dissected, or separated by dissection.","pos":""}],"DISSECTING":[{"def":"Dividing or separating the parts of an animal or vegetable body; as, a dissecting aneurism, one which makes its way between or within the coats of an artery.","pos":""},{"def":"Of or pertaining to, or received during, a dissection; as, a dissecting wound.","pos":""}],"DISSECTION":[{"def":"The act of dissecting an animal or plant; as, dissection of the human body was held sacrilege till the time of Francis I.","pos":""}],"DISSECTOR":[{"def":"One who dissects; an anatomist.","pos":""}],"DISSEIZE":[{"def":"To deprive of seizin or possession; to dispossess or oust wrongfully (one in freehold possession of land); -- followed by of; as, to disseize a tenant of his freehold.","pos":""}],"DISSEIZEE":[{"def":"A person disseized, or put out of possession of an estate unlawfully; -- correlative to disseizor.","pos":""}],"DISSEIZIN":[{"def":"The act of disseizing; an unlawful dispossessing and ouster of a person actually seized of the freehold.","pos":""}],"DISSEIZOR":[{"def":"One who wrongfully disseizes, or puts another out of possession of a freehold.","pos":""}],"DISSEIZORESS":[{"def":"A woman disseizes.","pos":""}],"DISSEMBLANCE":[{"def":"Want of resemblance; dissimilitude.","pos":""}],"DISSEMBLE":[{"def":"To hide under a false semblance or seeming; to feign (something) not to be what it really is; to put an untrue appearance upon; to disguise; to mask.","pos":""},{"def":"To put on the semblance of; to make pretense of; to simulate; to feign.","pos":""}],"DISSEMBLER":[{"def":"One who dissembles; one who conceals his opinions or dispositions under a false appearance; a hypocrite.","pos":""}],"DISSEMBLING":[{"def":"That dissembles; hypocritical; false.","pos":""}],"DISSEMINATE":[{"def":"To sow broadcast or as seed; to scatter for growth and propagation, like seed; to spread abroad; to diffuse; as, principles, ideas, opinions, and errors are disseminated when they are spread abroad for propagation.","pos":""},{"def":"To spread or extend by dispersion.","pos":""}],"DISSEMINATED":[{"def":"Occurring in small portions scattered through some other substance.","pos":""}],"DISSEMINATION":[{"def":"The act of disseminating, or the state of being disseminated; diffusion for propagation and permanence; a scattering or spreading abroad, as of ideas, beliefs, etc.","pos":""}],"DISSEMINATIVE":[{"def":"Tending to disseminate, or to become disseminated.","pos":""}],"DISSEMINATOR":[{"def":"One who, or that which, disseminates, spreads, or propagates; as, disseminators of disease.","pos":""}],"DISSENSION":[{"def":"Disagreement in opinion, usually of a violent character, producing warm debates or angry words; contention in words; partisan and contentious divisions; breach of friendship and union; strife; discord; quarrel.","pos":""}],"DISSENSIOUS":[{"def":"Disposed to discord; contentious; dissentious.","pos":""}],"DISSENT":[{"def":"To differ from an established church in regard to doctrines, rites, or government.","pos":""}],"DISSENTANEOUS":[{"def":"Disagreeing; contrary; differing; -- opposed to consentaneous.","pos":""}],"DISSENTANY":[{"def":"Dissentaneous; inconsistent.","pos":""}],"DISSENTER":[{"def":"One who separates from the service and worship of an established church; especially, one who disputes the authority or tenets of the Church of England; a nonconformist.","pos":""}],"DISSENTERISM":[{"def":"The spirit or principles of dissenters.","pos":""}],"DISSENTIATE":[{"def":"To throw into a state of dissent.","pos":""}],"DISSENTIENT":[{"def":"Disagreeing; declaring dissent; dissenting.","pos":""},{"def":"One who dissents.","pos":""}],"DISSENTIOUS":[{"def":"Marked by dissensions; apt to breed discord; quarrelsome; contentious; factious.","pos":""}],"DISSENTIVE":[{"def":"Disagreeing; inconsistent.","pos":""}],"DISSEPIMENT":[{"def":"One of the partitions which divide a compound ovary into cells.","pos":""},{"def":"One of the transverse, calcareous partitions between the radiating septa of a coral.","pos":""}],"DISSERT":[{"def":"To discourse or dispute; to discuss.","pos":""}],"DISSERTATE":[{"def":"To deal in dissertation; to write dissertations; to discourse.","pos":""}],"DISSERTATION":[{"def":"A formal or elaborate argumentative discourse, oral or written; a disquisition; an essay; a discussion; as, Dissertations on the Prophecies.","pos":""}],"DISSERTATIONAL":[{"def":"Relating to dissertations; resembling a dissertation.","pos":""}],"DISSERTATIONIST":[{"def":"A writer of dissertations.","pos":""}],"DISSERTATOR":[{"def":"One who writers a dissertation; one who discourses.","pos":""}],"DISSERVE":[{"def":"To fail to serve; to do injury or mischief to; to damage; to hurt; to harm.","pos":""}],"DISSERVICE":[{"def":"Injury; mischief.","pos":""}],"DISSERVICEABLE":[{"def":"Calculated to do disservice or harm; not serviceable; injurious; harmful; unserviceable.","pos":""}],"DISSETTLEMENT":[{"def":"The act of unsettling, or the state of being unsettled.","pos":""}],"DISSEVER":[{"def":"To part in two; to sever thoroughly; to sunder; to disunite; to separate; to disperse.","pos":""}],"DISSEVERANCE":[{"def":"The act of disserving; separation.","pos":""}],"DISSEVERATION":[{"def":"The act of disserving; disseverance.","pos":""}],"DISSHADOW":[{"def":"To free from shadow or shade.","pos":""}],"DISSHEATHE":[{"def":"To become unsheathed.","pos":""}],"DISSHIP":[{"def":"To dismiss from service on board ship.","pos":""}],"DISSHIVER":[{"def":"To shiver or break in pieces.","pos":""}],"DISSIDENCE":[{"def":"Disagreement; dissent; separation from the established religion.","pos":""}],"DISSIDENT":[{"def":"No agreeing; dissenting; discordant; different.","pos":""}],"DISSIDENTLY":[{"def":"In a dissident manner.","pos":""},{"def":"The act of leaping or starting asunder.","pos":""}],"DISSILIENT":[{"def":"Starting asunder; bursting and opening with an elastic force; dehiscing explosively; as, a dissilient pericarp.","pos":""}],"DISSILITION":[{"def":"The act of bursting or springing apart.","pos":""}],"DISSIMILAR":[{"def":"Not similar; unlike; heterogeneous; as, the tempers of men are as dissimilar as their features.","pos":""}],"DISSIMILARITY":[{"def":"Want of resemblance; unlikeness; dissimilitude; variety; as, the dissimilarity of human faces and forms.","pos":""}],"DISSIMILARLY":[{"def":"In a dissimilar manner; in a varied style.","pos":""}],"DISSIMILATE":[{"def":"To render dissimilar.","pos":""}],"DISSIMILATION":[{"def":"The act of making dissimilar.","pos":""}],"DISSIMILE":[{"def":"Comparison or illustration by contraries.","pos":""}],"DISSIMILITUDE":[{"def":"A comparison by contrast; a dissimile.","pos":""}],"DISSIMULATE":[{"def":"Feigning; simulating; pretending.","pos":""}],"DISSIMULATION":[{"def":"The act of dissembling; a hiding under a false appearance; concealment by feigning; false pretension; hypocrisy.","pos":""}],"DISSIMULATOR":[{"def":"One who dissimulates; a dissembler.","pos":""}],"DISSIPABLE":[{"def":"Capable of being scattered or dissipated.","pos":""}],"DISSIPATE":[{"def":"To scatter completely; to disperse and cause to disappear; -- used esp.","pos":""},{"def":"To destroy by wasteful extravagance or lavish use; to squander.","pos":""}],"DISSIPATED":[{"def":"Squandered; scattered.","pos":""},{"def":"Wasteful of health, money, etc.","pos":""}],"DISSIPATION":[{"def":"The act of dissipating or dispersing; a state of dispersion or separation; dispersion; waste.","pos":""},{"def":"A dissolute course of life, in which health, money, etc.","pos":""}],"DISSIPATIVE":[{"def":"Tending to dissipate.","pos":""}],"DISSIPATIVITY":[{"def":"The rate at which palpable energy is dissipated away into other forms of energy.","pos":""}],"DISSITE":[{"def":"Lands far dissite and remote asunder.","pos":""}],"DISSOCIABILITY":[{"def":"Want of sociability; unsociableness.","pos":""}],"DISSOCIABLE":[{"def":"Not They came in two and two, though matched in the most dissociable manner.","pos":""},{"def":"Having a tendency to dissolve social connections; unsuitable to society; unsociable.","pos":""}],"DISSOCIAL":[{"def":"Unfriendly to society; contracted; selfish; as, dissocial feelings.","pos":""}],"DISSOCIALIZE":[{"def":"To render unsocial.","pos":""}],"DISSOCIATE":[{"def":"To separate from fellowship or union; to disunite; to disjoin; as, to dissociate the particles of a concrete substance.","pos":""}],"DISSOCIATION":[{"def":"The process by which a compound body breaks up into simpler constituents; -- said particularly of the action of heat on gaseous or volatile substances; as, the dissociation of the sulphur molecules; the dissociation of ammonium chloride into hydrochloric acid and ammonia.","pos":""}],"DISSOCIATIVE":[{"def":"Tending or leading to dissociation.","pos":""}],"DISSOLUBILITY":[{"def":"The quality of being dissoluble; capacity of being dissoluble; capacity of being dissolved by heat or moisture, and converted into a fluid.","pos":""}],"DISSOLUBLE":[{"def":"Capable of being dissolved; having its parts separable by heat or moisture; convertible into a fluid.","pos":""},{"def":"Capable of being disunited.","pos":""}],"DISSOLUBLENESS":[{"def":"The quality of being dissoluble; dissolubility.","pos":""}],"DISSOLUTE":[{"def":"With nerves unstrung; weak.","pos":""},{"def":"Loosed from restraint; esp.","pos":""}],"DISSOLUTELY":[{"def":"In a dissolute manner.","pos":""}],"DISSOLUTENESS":[{"def":"State or quality of being dissolute; looseness of morals and manners; addictedness to sinful pleasures; debauchery; dissipation.","pos":""}],"DISSOLUTION":[{"def":"The act of dissolving, sundering, or separating into component parts; separation.","pos":""},{"def":"Change from a solid to a fluid state; solution by heat or moisture; liquefaction; melting.","pos":""}],"DISSOLVABILITY":[{"def":"Capacity of being dissolved; solubility.","pos":""}],"DISSOLVABLE":[{"def":"Capable of being dissolved, or separated into component parts; capable of being liquefied; soluble.","pos":""}],"DISSOLVATIVE":[{"def":"Having the power to dissolve anything; solvent.","pos":""}],"DISSOLVE":[{"def":"To annul; to rescind; to discharge or release; as, to dissolve an injunction.","pos":""}],"DISSOLVENT":[{"def":"Having power to dissolve power to dissolve a solid body; as, the dissolvent juices of the stomach.","pos":""}],"DISSOLVER":[{"def":"One who, or that which, has power to dissolve or dissipate.","pos":""}],"DISSOLVING":[{"def":"Melting; breaking up; vanishing.","pos":""}],"DISSONANCE":[{"def":"A mingling of discordant sounds; an inharmonious combination of sounds; discord.","pos":""},{"def":"Want of agreement; incongruity.","pos":""}],"DISSONANCY":[{"def":"Discord; dissonance.","pos":""}],"DISSONANT":[{"def":"Sounding harshly; discordant; unharmonious.","pos":""},{"def":"Disagreeing; incongruous; discrepfrom or to.","pos":""}],"DISSUADE":[{"def":"To advise or exhort against; to try to persuade (one from a course).","pos":""},{"def":"To divert by persuasion; to turn from a purpose by reasons or motives; -- with from; as, I could not dissuade him from his purpose.","pos":""}],"DISSUADER":[{"def":"One who dissuades; a dehorter.","pos":""}],"DISSUASION":[{"def":"The act of dissuading; exhortation against a thing; dehortation.","pos":""},{"def":"A motive or consideration tending to dissuade; a dissuasive.","pos":""}],"DISSUASIVE":[{"def":"Tending to dissuade or divert from a measure or purpose; dehortatory; as, dissuasive advice.","pos":""},{"def":"A dissuasive argument or counsel; dissuasion; dehortation.","pos":""}],"DISSUASORY":[{"def":"This virtuous and reasonable person, however, has ill luck in all his dissuasories.","pos":""}],"DISSUNDER":[{"def":"To separate; to sunder; to destroy.","pos":""}],"DISSWEETEN":[{"def":"To deprive of sweetness.","pos":""}],"DISSYLLABIC":[{"def":"Consisting of two syllabas, a dissyllabic foot in poetry.","pos":""}],"DISSYLLABIFICATION":[{"def":"Dis`syl*lab`i*fi*ca\"tion, n.","pos":""}],"DISSYLLABIFY":[{"def":"To form into two syllables.","pos":""}],"DISSYLLABIZE":[{"def":"To form into two syllables; to dyssyllabify.","pos":""}],"DISSYLLABLE":[{"def":"A word of two syllables; as, pa-per.","pos":""}],"DISSYMMETRICAL":[{"def":"Not having symmetry; asymmetrical; unsymmetrical.","pos":""}],"DISSYMMETRY":[{"def":"Absence or defect of symmetry; asymmetry.","pos":""}],"DISSYMPATHY":[{"def":"Lack of sympathy; want of interest; indifference.","pos":""}]}