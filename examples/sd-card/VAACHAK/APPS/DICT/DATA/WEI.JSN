{"WEIGH":[{"def":"A corruption of Way, used only in the phrase under weigh.","pos":""}],"WEIGH-HOUSE":[{"def":"A building at or within which goods, and the like, are weighed.","pos":""}],"WEIGHABLE":[{"def":"Capable of being weighed.","pos":""}],"WEIGHAGE":[{"def":"A duty or toil paid for weighing merchandise.","pos":""}],"WEIGHBEAM":[{"def":"A kind of large steelyard for weighing merchandise; -- also called weighmaster's beam.","pos":""}],"WEIGHBOARD":[{"def":"Clay intersecting a vein.","pos":""}],"WEIGHBRIDGE":[{"def":"A weighing machine on which loaded carts may be weighed; platform scales.","pos":""}],"WEIGHER":[{"def":"One who weighs; specifically, an officer whose duty it is to weigh commodities.","pos":""}],"WEIGHING":[{"def":"Weigh\"ing, Defn: a.","pos":""}],"WEIGHLOCK":[{"def":"A lock, as on a canal, in which boats are weighed and their tonnage is settled.","pos":""}],"WEIGHMASTER":[{"def":"One whose business it is to weigh ore, hay, merchandise, etc.","pos":""}],"WEIGHT":[{"def":"The resistance against which a machine acts, as opposed to the power which moves it.","pos":""}],"WEIGHTILY":[{"def":"In a weighty manner.","pos":""}],"WEIGHTINESS":[{"def":"The quality or state of being weighty; weight; force; importance; impressiveness.","pos":""}],"WEIGHTLESS":[{"def":"Having no weight; imponderable; hence, light.","pos":""}],"WEIGHTY":[{"def":"Having weight; heavy; ponderous; as, a weighty body.","pos":""},{"def":"Adapted to turn the balance in the mind, or to convince; important; forcible; serious; momentous.","pos":""}],"WEIL'S DISEASE":[{"def":"An acute infectious febrile disease, resembling typhoid fever, with muscular pains, disturbance of the digestive organs, jaundice, etc.","pos":""}],"WEIRD":[{"def":"Fate; destiny; one of the Fates, or Norns; also, a prediction.","pos":""},{"def":"A spell or charm.","pos":""}],"WEIRDNESS":[{"def":"The quality or state of being weird.","pos":""}],"WEISM":[{"def":"Same as Wegotism.","pos":""}],"WEISMANNISM":[{"def":"The theories and teachings in regard to heredity propounded by the German biologist August Weismann, esp.","pos":""}],"WEISS BEER":[{"def":"A light-colored highly effervescent beer made by the top- fermentation process.","pos":""}]}