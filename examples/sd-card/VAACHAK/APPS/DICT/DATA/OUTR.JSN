{"OUTRAGE":[{"def":"To rage in excess of.","pos":""}],"OUTRAGEOUS":[{"def":"Of the nature of an outrage; exceeding the limits of right, reason, or decency; involving or doing an outrage; furious; violent; atrocious.","pos":""}],"OUTRANCE":[{"def":"The utmost or last extremity.","pos":""}],"OUTRANK":[{"def":"To exceed in rank; hence, to take precedence of.","pos":""}],"OUTRAY":[{"def":"To spread out in array.","pos":""}],"OUTRAYE":[{"def":"This warn I you, that ye not suddenly Out of yourself for no woe should outraye.","pos":""}],"OUTRE":[{"def":"Being out of the common course or limits; extravagant; bizarre.","pos":""}],"OUTREACH":[{"def":"To reach beyond.","pos":""}],"OUTREASON":[{"def":"To excel or surpass in reasoning; to reason better than.","pos":""}],"OUTRECKON":[{"def":"To exceed in reckoning or computation.","pos":""}],"OUTRECUIDANCE":[{"def":"Excessive presumption.","pos":""}],"OUTREDE":[{"def":"To surpass in giving rede, or counsel.","pos":""}],"OUTREIGN":[{"def":"To go beyond in reigning; to reign through the whole of, or longer than.","pos":""}],"OUTRIDE":[{"def":"To surpass in speed of riding; to ride beyond or faster than.","pos":""}],"OUTRIDER":[{"def":"A summoner whose office is to cite men before the sheriff.","pos":""},{"def":"One who rides out on horseback.","pos":""}],"OUTRIGGER":[{"def":"Any spar or projecting timber run out for temporary use, as from a ship's mast, to hold a rope or a sail extended, or from a building, to support hoisting teckle.","pos":""}],"OUTRIGHT":[{"def":"Immediately; without delay; at once; as, he was killed outright.","pos":""},{"def":"Completely; utterly.","pos":""}],"OUTRING":[{"def":"To excel in volume of ringing sound; to ring louder than.","pos":""}],"OUTRIVAL":[{"def":"To surpass in a rivalry.","pos":""}],"OUTRIVE":[{"def":"To river; to sever.","pos":""}],"OUTROAR":[{"def":"To exceed in roaring.","pos":""}],"OUTROMANCE":[{"def":"To exceed in romantic character.","pos":""}],"OUTROOT":[{"def":"To eradicate; to extirpate.","pos":""}],"OUTRUN":[{"def":"To exceed, or leave behind, in running; to run faster than; to outstrip; to go beyond.","pos":""}],"OUTRUNNER":[{"def":"An offshoot; a branch.","pos":""}],"OUTRUSH":[{"def":"To rush out; to issue, or ru Garth.","pos":""}]}