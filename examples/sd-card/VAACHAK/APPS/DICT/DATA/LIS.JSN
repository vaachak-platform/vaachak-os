{"LISBON":[{"def":"A sweet, light-colored species of wine, produced in the province of Estremadura, and so called as being shipped from Lisbon, in Portugal.","pos":""}],"LISLE":[{"def":"A city of France celebrated for certain manufactures.","pos":""}],"LISNE":[{"def":"A cavity or hollow.","pos":""}],"LISP":[{"def":"To pronounce the sibilant letter s imperfectly; to give s and z the sound of th; -- a defect common among children.","pos":""},{"def":"To speak with imperfect articulation; to mispronounce, as a child learning to talk.","pos":""}],"LISPINGLY":[{"def":"With a lisp; in a lisping manner.","pos":""}],"LISS":[{"def":"Release; remission; ease; relief.","pos":""}],"LISSENCEPHALA":[{"def":"A general name for all those placental mammals that have a brain with few or no cerebral convolutions, as Rodentia, Insectivora, etc.","pos":""}],"LIST":[{"def":"A line inclosing or forming the extremity of a piece of ground, or field of combat; hence, in the plural (lists), the ground or field inclosed for a race or combat.","pos":""}],"LISTEL":[{"def":"Same as List, n.","pos":""}],"LISTEN":[{"def":"To give close attention with the purpose of hearing; to give ear; to hearken; to attend.","pos":""},{"def":"To give heed; to yield to advice; to follow admonition; to obey.","pos":""}],"LISTENER":[{"def":"One who listens; a hearkener.","pos":""}],"LISTER":[{"def":"One who makes a list or roll.","pos":""}],"LISTERIAN":[{"def":"Of or pertaining to listerism.","pos":""}],"LISTERISM":[{"def":"The systematic use of antiseptics in the performance of operations and the treatment of wounds; -- so called from Joseph Lister, an English surgeon.","pos":""}],"LISTERIZE":[{"def":"To make antiseptic.","pos":""}],"LISTING":[{"def":"The sapwood cut from the edge of a board.","pos":""},{"def":"The throwing up of the soil into ridges, -- a method adopted in the culture of beets and some garden crops.","pos":""}],"LISTLESS":[{"def":"Having no desire or inclination; indifferent; heedless; spiritless.","pos":""}]}