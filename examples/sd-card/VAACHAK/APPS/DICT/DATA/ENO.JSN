{"ENODATION":[{"def":"The act or operation of clearing of knots, or of untying; hence, also, the solution of a difficulty.","pos":""}],"ENODE":[{"def":"To clear of knots; to make clear.","pos":""}],"ENOMOTARCH":[{"def":"The commander of an enomoty.","pos":""}],"ENOMOTY":[{"def":"A band of sworn soldiers; a division of the Spartan army ranging from twenty-five to thirty-six men, bound together by oath.","pos":""}],"ENOPLA":[{"def":"One of the orders of Nemertina, characterized by the presence of a peculiar armature of spines or plates in the proboscis.","pos":""}],"ENOPTOMANCY":[{"def":"Divination by the use of a mirror.","pos":""}],"ENORMITY":[{"def":"The state or quality of exceeding a measure or rule, or of being immoderate, monstrous, or outrageous.","pos":""},{"def":"That which is enormous; especially, an exceeding offense against order, right, or decency; an atrocious crime; flagitious villainy; an atrocity.","pos":""}],"ENORMOUS":[{"def":"Exceeding the usual rule, norm, or measure; out of due proportion; inordinate; abnormal.","pos":""},{"def":"Exceedingly wicked; outrageous; atrocious; monstrous; as, an enormous crime.","pos":""}],"ENORMOUSLY":[{"def":"In an enormous degree.","pos":""}],"ENORMOUSNESS":[{"def":"The state of being enormous.","pos":""}],"ENORTHOTROPE":[{"def":"An optical toy; a card on which confused or imperfect figures are drawn, but which form to the eye regular figures when the card is rapidly revolved.","pos":""}],"ENOUGH":[{"def":"Satisfying desire; giving content; adequate to meet the want; sufficient; -- usually, and more elegantly, following the noun to which it belongs.","pos":""}],"ENOUNCE":[{"def":"To announce; to declare; to state, as a proposition or argument.","pos":""},{"def":"To utter; to articulate.","pos":""}],"ENOUNCEMENT":[{"def":"Act of enouncing; that which is enounced.","pos":""}],"ENOW":[{"def":"A form of Enough.","pos":""}]}