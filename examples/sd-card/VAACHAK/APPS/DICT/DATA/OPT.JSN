{"OPTABLE":[{"def":"That may be chosen; desirable.","pos":""}],"OPTATE":[{"def":"To choose; to wish for; to desire.","pos":""}],"OPTATION":[{"def":"The act of optating; a wish.","pos":""}],"OPTATIVE":[{"def":"Expressing desire or wish.","pos":""}],"OPTATIVELY":[{"def":"In an optative manner; with the expression of desire.","pos":""}],"OPTIC":[{"def":"The organ of sight; an eye.","pos":""}],"OPTICALLY":[{"def":"By optics or sight; with reference to optics.","pos":""}],"OPTICIAN":[{"def":"One skilled in optics.","pos":""},{"def":"One who deals in optical glasses and instruments.","pos":""}],"OPTICS":[{"def":"That branch of physical science which treats of the nature and properties of light, the laws of its modification by opaque and transparent bodies, and the phenomena of vision.","pos":""}],"OPTIGRAPH":[{"def":"A telescope with a diagonal eyepiece, suspended vertically in gimbals by the object end beneath a fixed diagonal plane mirror.","pos":""}],"OPTIMACY":[{"def":"Government by the nobility.","pos":""},{"def":"Collectively, the nobility.","pos":""}],"OPTIMATE":[{"def":"Of or pertaining to the nobility or aristocracy.","pos":""},{"def":"A nobleman or aristocrat; a chief man in a state or city.","pos":""}],"OPTIMATES":[{"def":"The nobility or aristocracy of ancient Rome, as opposed to the populares.","pos":""}],"OPTIME":[{"def":"One of those who stand in the second rank of honors, immediately after the wranglers, in the University of Cambridge, England.","pos":""}],"OPTIMISM":[{"def":"The opinion or doctrine that everything in nature, being the work of God, is ordered for the best, or that the ordering of things in the universe is such as to produce the highest good.","pos":""}],"OPTIMIST":[{"def":"One who holds the opinion that all events are ordered for the best.","pos":""}],"OPTIMISTIC":[{"def":"Of or pertaining to optimism; tending, or conforming, to the opinion that all events are ordered for the best.","pos":""}],"OPTIMITY":[{"def":"The state of being best.","pos":""}],"OPTION":[{"def":"A right formerly belonging to an archbishop to select any one dignity or benefice in the gift of a suffragan bishop consecrated or confirmed by him, for bestowal by himself when next vacant; -- annulled by Parliament in 1845.","pos":""},{"def":"A stipulated privilege, given to a party in a time contract, of demanding its fulfillment on any day within a specified limit.","pos":""}],"OPTIONAL":[{"def":"Involving an option; depending on the exercise of an option; left to one's discretion or choice; not compulsory; as, optional studies; it is optional with you to go or stay.","pos":""},{"def":"See Elective, n.","pos":""}],"OPTIONALLY":[{"def":"In an optional manner.","pos":""},{"def":"The cavity of one of the optic lobes of the brain in many animals.","pos":""}],"OPTOGRAM":[{"def":"An image of external objects fixed on the retina by the photochemical action of light on the visual purple.","pos":""}],"OPTOGRAPHY":[{"def":"The production of an optogram on the retina by the photochemical action of light on the visual purple; the fixation of an image in the eye.","pos":""}],"OPTOMETER":[{"def":"An instrument for measuring the distance of distinct vision, mainly for the selection of eveglasses.","pos":""}],"OPTOMETRIST":[{"def":"One who is skilled in or practices optometry.","pos":""}],"OPTOMETRY":[{"def":"As defined (with minor variations) in the statutes of various States of the United States: (a) \"The employment of subjective and objective mechanical means to determine the accomodative and refractive states of the eye and the scope of its function in general.","pos":""}]}