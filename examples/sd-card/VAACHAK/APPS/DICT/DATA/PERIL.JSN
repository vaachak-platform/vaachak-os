{"PERIL":[{"def":"Danger; risk; hazard; jeopardy; exposure of person or property to injury, loss, or destruction.","pos":""}],"PERILLA":[{"def":"A genus of labiate herbs, of which one species (Perilla ocimoides, or P.","pos":""}],"PERILOUS":[{"def":"Full of, attended with, or involving, peril; dangerous; hazardous; as, a perilous undertaking.","pos":""},{"def":"Daring; reckless; dangerous.","pos":""}],"PERILYMPH":[{"def":"The fluid which surrounds the membranous labyrinth of the internal ear, and separates it from the walls of the chambers in which the labyrinth lies.","pos":""}],"PERILYMPHANGIAL":[{"def":"Around, or at the side of, a lymphatic vessel.","pos":""}]}