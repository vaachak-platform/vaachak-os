{"MANTA":[{"def":"See Coleoptera and Sea devil.","pos":""}],"MANTEAU":[{"def":"A woman's cloak or mantle.","pos":""},{"def":"A gown worn by women.","pos":""}],"MANTEL":[{"def":"The finish around a fireplace, covering the chimney-breast in front and sometimes on both sides; especially, a shelf above the fireplace, and its supports.","pos":""}],"MANTELET":[{"def":"A musket-proof shield of rope, wood, or metal, which is sometimes used for the protection of sappers or riflemen while attacking a fortress, or of gunners at embrasures; -- now commonly written mantlet.","pos":""}],"MANTELLETTA":[{"def":"A silk or woolen vestment without sleeves worn by cardinals, bishops, abbots, and the prelates of the Roman court.","pos":""}],"MANTELSHELF":[{"def":"The shelf of a mantel.","pos":""}],"MANTELTREE":[{"def":"The lintel of a fireplace when of wood, as frequently in early houses.","pos":""}],"MANTIC":[{"def":"Of or pertaining to divination, or to the condition of one inspired, or supposed to be inspired, by a deity; prophetic.","pos":""}],"MANTILLA":[{"def":"A lady's light cloak of cape of silk, velvet, lace, or the like.","pos":""},{"def":"A kind of veil, covering the head and falling down upon the shoulders; -- worn in Spain, Mexico, etc.","pos":""}],"MANTIS":[{"def":"Any one of numerous species of voracious orthopterous insects of the genus Mantis, and allied genera.","pos":""}],"MANTISPID":[{"def":"Any neuropterous insect of the genus Mantispa, and allied genera.","pos":""}],"MANTISSA":[{"def":"The decimal part of a logarithm, as distinguished from the integral part, or characteristic.","pos":""}],"MANTLE":[{"def":"Same as Mantling.","pos":""}],"MANTLING":[{"def":"The representation of a mantle, or the drapery behind and around a coat of arms: -- called also lambrequin.","pos":""}],"MANTOLOGIST":[{"def":"One who is skilled in mantology; a diviner.","pos":""}],"MANTOLOGY":[{"def":"The act or art of divination.","pos":""}],"MANTRA":[{"def":"A prayer; an invocation; a religious formula; a charm.","pos":""}],"MANTRAP":[{"def":"A trap for catching trespassers.","pos":""},{"def":"A dangerous place, as an open hatch, into which one may fall.","pos":""}],"MANTUA":[{"def":"A superior kind of rich silk formerly exported from Mantua in Italy.","pos":""},{"def":"A woman's cloak or mantle; also, a woman's gown.","pos":""}],"MANTUAMAKER":[{"def":"One who makes dresses, cloaks, etc.","pos":""}],"MANTUAN":[{"def":"Of or pertaining to Mantua.","pos":""},{"def":"A native or inhabitant of Mantua.","pos":""}]}