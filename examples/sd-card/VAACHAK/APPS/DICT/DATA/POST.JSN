{"POST":[{"def":"Hired to do what is wrong; suborned.","pos":""}],"POST NOTE":[{"def":"A note issued by a bank, payable at some future specified time, as distinguished from a note payable on demand.","pos":""}],"POST OFFICE":[{"def":"See under 4th Post.","pos":""}],"POST-":[{"def":"A prefix signifying behind, back, after; as, postcommissure, postdot, postscript.","pos":""}],"POST-ABDOMEN":[{"def":"That part of a crustacean behind the cephalothorax; -- more commonly called abdomen.","pos":""}],"POST-CAPTAIN":[{"def":"A captain of a war vessel whose name appeared, or was \"posted,\" in the seniority list of the British navy, as distinguished from a commander whose name was not so posted.","pos":""}],"POST-DISSEIZIN":[{"def":"A subsequent disseizin committed by one of lands which the disseizee had before recovered of the same disseizor; a writ founded on such subsequent disseizin, now abolished.","pos":""}],"POST-DISSEIZOR":[{"def":"A person who disseizes another of lands which the disseizee had before recovered of the same disseizor.","pos":""}],"POST-FINE":[{"def":"A duty paid to the king by the cognizee in a fine of lands, when the same was fully passed; -- called also the king's silver.","pos":""}],"POST-IMPRESSIONISM":[{"def":"In the broadest sense, the theory or practice of any of several groups of recent painters, or of these groups taken collectively, whose work and theories have in common a tendency to reaction against the scientific and naturalistic character of impressionism and neo- impressionism.","pos":""}],"POST-MORTEM":[{"def":"After death; as, post-mortem rigidity.","pos":""}],"POST-TEMPORAL":[{"def":"Situated back of the temporal bone or the temporal region of the skull; -- applied especially to a bone which usually connects the supraclavicle with the skull in the pectoral arch of fishes.","pos":""},{"def":"A post-temporal bone.","pos":""}],"POST-TRAGUS":[{"def":"A ridge within and behind the tragus in the ear of some animals.","pos":""}],"POST-TYMPANIC":[{"def":"Situated behind the tympanum, or in the skull, behind the auditory meatus.","pos":""}],"POSTABLE":[{"def":"Capable of being carried by, or as by, post.","pos":""}],"POSTACT":[{"def":"An act done afterward.","pos":""}],"POSTAGE":[{"def":"The price established by law to be paid for the conveyance of a letter or other mailable matter by a public post.","pos":""}],"POSTAL":[{"def":"Belonging to the post office or mail service; as, postal arrangements; postal authorities.","pos":""}],"POSTANAL":[{"def":"Situated behind, or posterior to, the anus.","pos":""}],"POSTAXIAL":[{"def":"Situated behind any transverse axis in the body of an animal; caudal; posterior; especially, behind, or on the caudal or posterior (that is, ulnar or fibular) side of, the axis of a vertebrate limb.","pos":""}],"POSTBOY":[{"def":"One who rides post horses; a position; a courier.","pos":""},{"def":"A boy who carries letters from the post.","pos":""}],"POSTCAVA":[{"def":"The inferior vena cava.","pos":""}],"POSTCLAVICLE":[{"def":"A bone in the pectoral girdle of many fishes projecting backward from the clavicle.","pos":""}],"POSTCOMMISSURE":[{"def":"A transverse commisure in the posterior part of the roof of the third ventricle of the brain; the posterior cerebral commisure.","pos":""}],"POSTCOMMUNION":[{"def":"The concluding portion of the communion service.","pos":""},{"def":"A prayer or prayers which the priest says at Mass, after the ablutions.","pos":""}],"POSTCORNU":[{"def":"The posterior horn of each lateral ventricle of the brain.","pos":""}],"POSTDATE":[{"def":"To date after the real time; as, to postdate a contract, that is, to date it later than the time when it was in fact made.","pos":""},{"def":"To affix a date to after the event.","pos":""}],"POSTDILUVIAN":[{"def":"One who lived after the flood.","pos":""}],"POSTEA":[{"def":"The return of the judge before whom a cause was tried, after a verdict, of what was done in the cause, which is indorsed on the nisi prius record.","pos":""}],"POSTENCEPHALON":[{"def":"The metencephalon.","pos":""}],"POSTENTRY":[{"def":"An additional or subsequent entry.","pos":""}],"POSTER":[{"def":"A large bill or placard intended to be posted in public places.","pos":""},{"def":"One who posts bills; a billposter.","pos":""}],"POSTERIOR":[{"def":"At or toward the caudal extremity; caudal; -- in human anatomy often used for dorsal.","pos":""},{"def":"On the side next the axis of inflorescence; -- said of an axillary flower.","pos":""}],"POSTERIORITY":[{"def":"The state of being later or subsequent; as, posteriority of time, or of an event; -- opposed to priority.","pos":""}],"POSTERIORLY":[{"def":"Subsequently in time; also, behind in position.","pos":""}],"POSTERIORS":[{"def":"The hinder parts, as of an animal's body.","pos":""}],"POSTERITY":[{"def":"The race that proceeds from a progenitor; offspring to the furthest generation; the aggregate number of persons who are descended from an ancestor of a generation; descendants; -- contrasted with ancestry; as, the posterity of Abraham.","pos":""},{"def":"Succeeding generations; future times.","pos":""}],"POSTERN":[{"def":"A subterraneous passage communicating between the parade and the main ditch, or between the ditches and the interior of the outworks.","pos":""}],"POSTERO":[{"def":"- (posterior, back; as, postero-inferior, situated back and below; postero-lateral, situated back and at the side.","pos":""},{"def":"After the exile; specif.","pos":""}],"POSTEXIST":[{"def":"To exist after; to live subsequently.","pos":""}],"POSTEXISTENCE":[{"def":"Subsequent existence.","pos":""}],"POSTEXISTENT":[{"def":"Existing or living after.","pos":""}],"POSTFACT":[{"def":"Relating to a fact that occurs after another.","pos":""}],"POSTFACTUM":[{"def":"Same as Postfact.","pos":""}],"POSTFIX":[{"def":"A letter, syllable, or word, added to the end of another word; a suffix.","pos":""}],"POSTFRONTAL":[{"def":"Situated behind the frontal bone or the frontal region of the skull; -- applied especially to a bone back of and below the frontal in many animals.","pos":""},{"def":"A postfrontal bone.","pos":""}],"POSTFURCA":[{"def":"One of the internal thoracic processes of the sternum of an insect.","pos":""}],"POSTGENITURE":[{"def":"The condition of being born after another in the same family; - - distinguished from primogeniture.","pos":""}],"POSTGLACIAL":[{"def":"Pleistocene period, or at a locality within the area of Pleistocene glaciation after the final disappearance of the glacier from the locality.","pos":""}],"POSTGLENOID":[{"def":"Situated behind the glenoid fossa of the temporal bone.","pos":""}],"POSTGRADUATE":[{"def":"Of, pertaining to, or designating, the studies pursued after graduation, esp.","pos":""},{"def":"A student who pursues such studies.","pos":""}],"POSTHASTE":[{"def":"Haste or speed in traveling, like that of a post or courier.","pos":""}],"POSTHOUSE":[{"def":"A house established for the convenience of the post, where relays of horses can be obtained.","pos":""},{"def":"A house for distributing the malls; a post office.","pos":""}],"POSTHUMOUS":[{"def":"Born after the death of the father, or taken from the dead body of the mother; as, a posthumous son or daughter.","pos":""},{"def":"Published after the death of the author; as, posthumous works; a posthumous edition.","pos":""}],"POSTHUMOUSLY":[{"def":"It a posthumous manner; after one's decease.","pos":""}],"POSTIL":[{"def":"A short homily or commentary on a passage of Scripture; as, the first postils were composed by order of Charlemagne.","pos":""}],"POSTILER":[{"def":"One who writers marginal notes; one who illustrates the text of a book by notes in the margin.","pos":""}],"POSTILION":[{"def":"One who rides and guides the first pair of horses of a coach or post chaise; also, one who rides one of the horses when one pair only is used.","pos":""}],"POSTILLATE":[{"def":"To explain by marginal notes; to postil.","pos":""}],"POSTILLATION":[{"def":"The act of postillating; exposition of Scripture in preaching.","pos":""}],"POSTILLATOR":[{"def":"One who postillates; one who expounds the Scriptures verse by verse.","pos":""}],"POSTING":[{"def":"The act of transferring an account, as from the journal to the ledger.","pos":""}],"POSTLIMINIAR":[{"def":"Contrived, done, or existing subsequently.","pos":""}],"POSTLIMINIARY":[{"def":"Pertaining to, or involving, the right of postliminium.","pos":""},{"def":"The return to his own country, and his former privileges, of a person who had gone to sojourn in a foreign country, or had been banished, or taken by an enemy.","pos":""}],"POSTLUDE":[{"def":"A voluntary at the end of a service.","pos":""}],"POSTMAN":[{"def":"One of the two most experienced barristers in the Court of Exchequer, who have precedence in motions; -- so called from the place where he sits.","pos":""}],"POSTMARK":[{"def":"The mark, or stamp, of a post office on a letter, giving the place and date of mailing or of arrival.","pos":""}],"POSTMASTER":[{"def":"One who has charge of a station for the accommodation of travelers; one who supplies post horses.","pos":""},{"def":"One who has charge of a post office, and the distribution and forwarding of mails.","pos":""}],"POSTMASTER-GENERAL":[{"def":"The chief officer of the post-office department of a government.","pos":""}],"POSTMASTERSHIP":[{"def":"The office of postmaster.","pos":""}],"POSTMERIDIAN":[{"def":"Coming after the sun has passed the meridian; being in, or belonging to, the afternoon.","pos":""}],"POSTNARES":[{"def":"The posterior nares.","pos":""}],"POSTNATAL":[{"def":"After birth; subsequent to birth; as, postnatal infanticide; postnatal diseases.","pos":""}],"POSTNUPTIAL":[{"def":"Being or happening after marriage; as, a postnuptial settlement on a wife.","pos":""},{"def":"A bond in which the obligor, in consideration of having received a certain sum of money, binds himself to pay a larger sum, on unusual interest, on the death of some specified individual from whom he has expectations.","pos":""}],"POSTOBLONGATA":[{"def":"The posterior part of the medulla oblongata.","pos":""}],"POSTOCULAR":[{"def":"Same as Postorbital.","pos":""}],"POSTORAL":[{"def":"Situated behind, or posterior to, the mouth.","pos":""}],"POSTORBITAL":[{"def":"Situated behind the orbit; as, the postorbital scales of some fishes and reptiles.","pos":""},{"def":"A postorbital bone or scale.","pos":""}],"POSTPAID":[{"def":"Having the postage prepaid, as a letter.","pos":""}],"POSTPALATINE":[{"def":"Situated behind the palate, or behind the palatine bones.","pos":""}],"POSTPLIOCENE":[{"def":"Of or pertaining to the period immediately following the Pliocene; Pleistocene.","pos":""}],"POSTPONE":[{"def":"To defer to a future or later time; to put off; also, to cause to be deferred or put off; to delay; to adjourn; as, to postpone the consideration of a bill to the following day, or indefinitely.","pos":""},{"def":"To place after, behind, or below something, in respect to precedence, preference, value, or importance.","pos":""}],"POSTPONEMENT":[{"def":"The act of postponing; a deferring, or putting off, to a future time; a temporary delay.","pos":""}],"POSTPONENCE":[{"def":"The act of postponing, in sense 2.","pos":""}],"POSTPONER":[{"def":"One who postpones.","pos":""}],"POSTPOSITION":[{"def":"The act of placing after, or the state of being placed after.","pos":""},{"def":"A word or particle placed after, or at the end of, another word; - - distinguished from preposition.","pos":""}],"POSTPOSITIONAL":[{"def":"Of or pertaining to postposition.","pos":""}],"POSTPOSITIVE":[{"def":"Placed after another word; as, a postpositive conjunction; a postpositive letter.","pos":""}],"POSTPRANDIAL":[{"def":"Happening, or done, after dinner; after-dinner; as, postprandial speeches.","pos":""}],"POSTREMOGENITURE":[{"def":"The right of the youngest born.","pos":""}],"POSTREMOTE":[{"def":"More remote in subsequent time or order.","pos":""}],"POSTRIDER":[{"def":"One who rides over a post road to carry the mails.","pos":""}],"POSTSCAPULA":[{"def":"The part of the scapula behind or below the spine, or mesoscapula.","pos":""}],"POSTSCAPULAR":[{"def":"Of or pertaining to the postscapula; infraspinous.","pos":""}],"POSTSCENIUM":[{"def":"The part of a theater behind the scenes; the back part of the stage of a theater.","pos":""}],"POSTSCRIBE":[{"def":"To make a postscript.","pos":""}],"POSTSCRIPT":[{"def":"A paragraph added to a letter after it is concluded and signed by the writer; an addition made to a book or composition after the main body of the work has been finished, containing something omitted, or something new occurring to the writer.","pos":""}],"POSTSCRIPTED":[{"def":"Having a postscript; added in a postscript.","pos":""}],"POSTSCUTELLUM":[{"def":"The hindermost dorsal piece of a thoracic somite of an insect; the plate behind the scutellum.","pos":""}],"POSTSPHENOID":[{"def":"Of or pertaining to the posterior part of the sphenoid bone.","pos":""}],"POSTTERTIARY":[{"def":"Following, or more recent than, the Tertiary; Quaternary.","pos":""}],"POSTULANT":[{"def":"One who makes a request or demand; hence, a candidate.","pos":""}],"POSTULATE":[{"def":"The enunciation of a self-evident problem, in distinction from an axiom, which is the enunciation of a self-evident theorem.","pos":""}],"POSTULATED":[{"def":"Assumed without proof; as, a postulated inference.","pos":""}],"POSTULATION":[{"def":"The act of postulating, or that which is postulated; assumption; solicitation; suit; cause.","pos":""}],"POSTULATORY":[{"def":"Of the nature of a postulate.","pos":""}],"POSTURAL":[{"def":"Of or pertaining to posture.","pos":""}],"POSTURE":[{"def":"The position of the body; the situation or disposition of the several parts of the body with respect to each other, or for a particular purpose; especially (Fine Arts), the position of a figure with regard to the several principal members by which action is expressed; attitude.","pos":""},{"def":"Place; position; situation.","pos":""}],"POSTURER":[{"def":"One who postures.","pos":""}],"POSTZYGAPOPHYSIS":[{"def":"A posterior zygapophysis.","pos":""}]}