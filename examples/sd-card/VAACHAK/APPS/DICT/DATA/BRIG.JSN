{"BRIG":[{"def":"A two-masted, square-rigged vessel.","pos":""}],"BRIGADE":[{"def":"A body of troops, whether cavalry, artillery, infantry, or mixed, consisting of two or more regiments, under the command of a brigadier general.","pos":""}],"BRIGADIER GENERAL":[{"def":"An officer in rank next above a colonel, and below a major general.","pos":""}],"BRIGAND":[{"def":"A light-armed, irregular foot soldier.","pos":""},{"def":"A lawless fellow who lives by plunder; one of a band of robbers; especially, one of a gang living in mountain retreats; a highwayman; a freebooter.","pos":""}],"BRIGANDAGE":[{"def":"Life and practice of brigands; highway robbery; plunder.","pos":""}],"BRIGANDINE":[{"def":"A coast of armor for the body, consisting of scales or plates, sometimes overlapping each other, generally of metal, and sewed to linen or other material.","pos":""}],"BRIGANDISH":[{"def":"Like a brigand or freebooter; robberlike.","pos":""}],"BRIGANTINE":[{"def":"A practical vessel.","pos":""},{"def":"A two-masted, square-rigged vessel, differing from a brig in that she does not carry a square mainsail.","pos":""}],"BRIGHT":[{"def":"Radiating or reflecting light; shedding or having much light; shining; luminous; not dark.","pos":""},{"def":"Transmitting light; clear; transparent.","pos":""}],"BRIGHT'S DISEASE":[{"def":"An affection of the kidneys, usually inflammatory in character, and distinguished by the occurrence of albumin and renal casts in the urine.","pos":""}],"BRIGHT-HARNESSED":[{"def":"Having glittering armor.","pos":""}],"BRIGHTEN":[{"def":"To make bright or brighter; to make to shine; to increase the luster of; to give a brighter hue to.","pos":""},{"def":"To make illustrious, or more distinguished; to add luster or splendor to.","pos":""}],"BRIGHTLY":[{"def":"Brilliantly; splendidly; with luster; as, brightly shining armor.","pos":""},{"def":"With lively intelligence; intelligently.","pos":""}],"BRIGHTNESS":[{"def":"The quality or state of being bright; splendor; luster; brilliancy; clearness.","pos":""},{"def":"Acuteness (of the faculties); sharpness 9wit.","pos":""}],"BRIGHTSOME":[{"def":"Bright; clear; luminous; brilliant.","pos":""}],"BRIGOSE":[{"def":"Contentious; quarrelsome.","pos":""}],"BRIGUE":[{"def":"A cabal, intrigue, faction, contention, strife, or quarrel.","pos":""}]}