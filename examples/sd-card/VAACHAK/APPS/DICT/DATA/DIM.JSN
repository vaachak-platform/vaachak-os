{"DIM":[{"def":"Not bright or distinct; wanting luminousness or clearness; obscure in luster or sound; dusky; darkish; obscure; indistinct; overcast; tarnished.","pos":""},{"def":"Of obscure vision; not seeing clearly; hence, dull of apprehension; of weak perception; obtuse.","pos":""}],"DIM-SIGHTED":[{"def":"Having dim sight; lacking perception.","pos":""},{"def":"An order of lamellibranchiate mollusks having an anterior and posterior adductor muscle, as the common clam.","pos":""}],"DIMBLE":[{"def":"A bower; a dingle.","pos":""}],"DIME":[{"def":"A silver coin of the United States, of the value of ten cents; the tenth of a dollar.","pos":""}],"DIMENSION":[{"def":"The degree of manifoldness of a quantity; as, time is quantity having one dimension; volume has three dimensions, relative to extension.","pos":""},{"def":"A literal factor, as numbered in characterizing a term.","pos":""}],"DIMENSIONAL":[{"def":"Pertaining to dimension.","pos":""}],"DIMENSIONED":[{"def":"Having dimensions.","pos":""}],"DIMENSIONLESS":[{"def":"Without dimensions; having no appreciable or noteworthy extent.","pos":""}],"DIMENSIVE":[{"def":"Without dimensions; marking dimensions or the limits.","pos":""}],"DIMERAN":[{"def":"One of the Dimera.","pos":""}],"DIMEROUS":[{"def":"Composed of, or having, two parts of each kind.","pos":""}],"DIMETER":[{"def":"Having two poetical measures or meters.","pos":""},{"def":"A verse of two meters.","pos":""}],"DIMETHYL":[{"def":"Ethane; -- sometimes so called because regarded as consisting of two methyl radicals.","pos":""}],"DIMETRIC":[{"def":"Same as Tetragonal.","pos":""}],"DIMICATION":[{"def":"A fight; contest.","pos":""}],"DIMIDIATE":[{"def":"Divided into two equal parts; reduced to half in shape or form.","pos":""}],"DIMIDIATION":[{"def":"The act of dimidiating or halving; the state of being dimidiate.","pos":""}],"DIMINISH":[{"def":"To make smaller by a half step; to make (an interval) less than minor; as, a diminished seventh.","pos":""}],"DIMINISHABLE":[{"def":"Capable of being diminished or lessened.","pos":""}],"DIMINISHER":[{"def":"One who, or that which, diminishes anything.","pos":""}],"DIMINISHINGLY":[{"def":"In a manner to diminish.","pos":""}],"DIMINUENDO":[{"def":"In a gradually diminishing manner; with abatement of tone; decrescendo; -- expressed on the staff by Dim.","pos":""}],"DIMINUTAL":[{"def":"Indicating or causing diminution.","pos":""}],"DIMINUTE":[{"def":"Small; diminished; diminutive.","pos":""}],"DIMINUTION":[{"def":"Omission, inaccuracy, or defect in a record.","pos":""},{"def":"In counterpoint, the imitation of, or reply to, a subject, in notes of half the length or value of those the subject itself.","pos":""}],"DIMINUTIVAL":[{"def":"Indicating diminution; diminutive.","pos":""}],"DIMINUTIVE":[{"def":"Below the average size; very small; little.","pos":""},{"def":"Expressing diminution; as, a diminutive word.","pos":""}],"DIMINUTIVELY":[{"def":"In a diminutive manner.","pos":""}],"DIMINUTIVENESS":[{"def":"The quality of being diminutive; smallness; littleness; minuteness.","pos":""}],"DIMISSION":[{"def":"Leave to depart; a dismissing.","pos":""}],"DIMISSORY":[{"def":"Sending away; dismissing to another jurisdiction; granting leave to depart.","pos":""}],"DIMIT":[{"def":"To dismiss, let go, or release.","pos":""}],"DIMITY":[{"def":"A cotton fabric employed for hangings and furniture coverings, and formerly used for women's under-garments.","pos":""}],"DIMLY":[{"def":"In a dim or obscure manner; not brightly or clearly; with imperfect sight.","pos":""},{"def":"Somewhat dim; as, dimmish eyes.","pos":""}],"DIMNESS":[{"def":"The state or quality 2.","pos":""}],"DIMORPH":[{"def":"Either one of the two forms of a dimorphous substance; as, calcite and aragonite are dimorphs.","pos":""}],"DIMORPHIC":[{"def":"Having the property of dimorphism; dimorphous.","pos":""}],"DIMORPHISM":[{"def":"Difference of form between members of the same species, as when a plant has two kinds of flowers, both hermaphrodite (as in the partridge berry), or when there are two forms of one or both sexes of the same species of butterfly.","pos":""},{"def":"Crystallization in two independent forms of the same chemical compound, as of calcium carbonate as calcite and aragonite.","pos":""}],"DIMORPHOUS":[{"def":"Characterized by dimorphism; occurring under two distinct forms, not dependent on sex; dimorphic.","pos":""},{"def":"Crystallizing under two forms fundamentally different, while having the same chemical composition.","pos":""}],"DIMPLE":[{"def":"A slight natural depression or indentation on the surface of some part of the body, esp.","pos":""},{"def":"A slight indentation on any surface.","pos":""}],"DIMPLEMENT":[{"def":"The state of being dimpled, or marked with gentle depressions.","pos":""}],"DIMPLY":[{"def":"Full of dimples, or small depressions; dimpled; as, the dimply pool.","pos":""}],"DIMYARIAN":[{"def":"Like or pertaining to the Dimya.","pos":""},{"def":"One of the Dimya.","pos":""}],"DIMYARY":[{"def":"Same as Dimyarian.","pos":""}]}