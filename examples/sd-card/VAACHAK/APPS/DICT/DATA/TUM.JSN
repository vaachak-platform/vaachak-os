{"TUM-TUM":[{"def":"A dish made in the West Indies by beating boiled plantain quite soft in a wooden mortar.","pos":""}],"TUMBLE":[{"def":"To roll over, or to and fro; to throw one's self about; as, a person on pain tumbles and tosses.","pos":""},{"def":"To roll down; to fall suddenly and violently; to be precipitated; as, to tumble from a scaffold.","pos":""}],"TUMBLE-DOWN":[{"def":"Ready to fall; dilapidated; ruinous; as, a tumble-down house.","pos":""}],"TUMBLEDUNG":[{"def":"Any one of numerous species of scaraboid beetles belonging to Scarabæus, Copris, Phanæus, and allied genera.","pos":""}],"TUMBLER":[{"def":"A piece attached to, or forming part of, the hammer of a gunlock, upon which the mainspring acts and in which are the notches for sear point to enter.","pos":""},{"def":"A variety of the domestic pigeon remarkable for its habit of tumbling, or turning somersaults, during its flight.","pos":""}],"TUMBLERFUL":[{"def":"As much as a tumbler will hold; enough to fill a tumbler.","pos":""}],"TUMBLEWEED":[{"def":"Any plant which habitually breaks away from its roots in the autumn, and is driven by the wind, as a light, rolling mass, over the fields and prairies; as witch grass, wild indigo, Amarantus albus, etc.","pos":""}],"TUMBLING":[{"def":"A cart or carriage with two wheels, which accompanies troops or artillery, to convey the tools of pioneers, cartridges, and the like.","pos":""}],"TUMEFACIENT":[{"def":"Producing swelling; tumefying.","pos":""}],"TUMEFACTION":[{"def":"The act or process of tumefying, swelling, or rising into a tumor; a swelling.","pos":""}],"TUMEFY":[{"def":"To swell; to cause to swell, or puff up.","pos":""}],"TUMESCENCE":[{"def":"The act of becoming tumid; the state of being swollen; intumescence.","pos":""}],"TUMESCENT":[{"def":"Slightly tumid; swollen, as certain moss capsules.","pos":""}],"TUMID":[{"def":"Swelled, enlarged, or distended; as, a tumid leg; tumid flesh.","pos":""},{"def":"Rising above the level; protuberant.","pos":""}],"TUMIDITY":[{"def":"The quality or state of being tumid.","pos":""}],"TUMMALS":[{"def":"A great quantity or heap.","pos":""}],"TUMOR":[{"def":"A morbid swelling, prominence, or growth, on any part of the body; especially, a growth produced by deposition of new tissue; a neoplasm.","pos":""}],"TUMORED":[{"def":"Distended; swelled.","pos":""}],"TUMOROUS":[{"def":"Swelling; protuberant.","pos":""},{"def":"Inflated; bombastic.","pos":""}],"TUMP":[{"def":"A little hillock; a knoll.","pos":""}],"TUMPLINE":[{"def":"A strap placed across a man's forehead to assist him in carrying a pack on his back.","pos":""}],"TUMULAR":[{"def":"Consisting in a heap; formed or being in a heap or hillock.","pos":""}],"TUMULATE":[{"def":"To cover, as a corpse, with a mound or tomb; to bury.","pos":""}],"TUMULOSITY":[{"def":"The quality or state of being tumulous; hilliness.","pos":""}],"TUMULOUS":[{"def":"Full of small hills or mounds; hilly; tumulose.","pos":""}],"TUMULT":[{"def":"The commotion or agitation of a multitude, usually accompanied with great noise, uproar, and confusion of voices; hurly-burly; noisy confusion.","pos":""},{"def":"Violent commotion or agitation, with confusion of sounds; as, the tumult of the elements.","pos":""}],"TUMULTER":[{"def":"A maker of tumults.","pos":""}],"TUMULTUARILY":[{"def":"In a tumultuary manner.","pos":""}],"TUMULTUARINESS":[{"def":"The quality or state of being tumultuary.","pos":""}],"TUMULTUARY":[{"def":"Attended by, or producing, a tumult; disorderly; promiscuous; confused; tumultuous.","pos":""},{"def":"Restless; agitated; unquiet.","pos":""}],"TUMULTUATE":[{"def":"To make a tumult.","pos":""}],"TUMULTUATION":[{"def":"Irregular or disorderly movement; commotion; as, the tumultuation of the parts of a fluid.","pos":""}],"TUMULTUOUS":[{"def":"Full of tumult; characterized by tumult; disorderly; turbulent.","pos":""},{"def":"Conducted with disorder; noisy; confused; boisterous; disorderly; as, a tumultuous assembly or meeting.","pos":""}],"TUMULUS":[{"def":"An artificial hillock, especially one raised over a grave, particularly over the graves of persons buried in ancient times; a barrow.","pos":""}]}