{"MALIC":[{"def":"Pertaining to, or obtained from, apples; as, malic acid.","pos":""}],"MALICE":[{"def":"Any wicked or mischievous intention of the mind; a depraved inclination to mischief; an intention to vex, annoy, or injure another person, or to do a wrongful act without just cause or cause or excuse; a wanton disregard of the rights or safety of others; willfulness.","pos":""}],"MALICIOUS":[{"def":"With wicked or mischievous intentions or motives; wrongful and done intentionally without just cause or excuse; as, a malicious act.","pos":""}],"MALIGN":[{"def":"Having an evil disposition toward others; harboring violent enmity; malevolent; malicious; spiteful; -- opposed to benign.","pos":""},{"def":"Unfavorable; unpropitious; pernicious; tending to injure; as, a malign aspect of planets.","pos":""}],"MALIGNANT":[{"def":"Tending to produce death; threatening a fatal issue; virulent; as, malignant diphtheria.","pos":""}],"MALIGNANTLY":[{"def":"In a malignant manner.","pos":""}],"MALIGNER":[{"def":"One who maligns.","pos":""}],"MALIGNIFY":[{"def":"To make malign or malignant.","pos":""}],"MALIGNITY":[{"def":"The state or quality of being malignant; disposition to do evil; virulent enmity; malignancy; malice; spite.","pos":""},{"def":"Virulence; deadly quality.","pos":""}],"MALIGNLY":[{"def":"In a malign manner; with malignity.","pos":""}],"MALINGER":[{"def":"To act the part of a malingerer; to feign illness or inability.","pos":""}],"MALINGERER":[{"def":"In the army, a soldier who feigns himself sick, or who induces or protracts an illness, in order to avoid doing his duty; hence, in general, one who shirks his duty by pretending illness or inability.","pos":""}],"MALINGERY":[{"def":"The spirit or practices of a malingerer; malingering.","pos":""}],"MALISON":[{"def":"Malediction; curse; execration.","pos":""}]}