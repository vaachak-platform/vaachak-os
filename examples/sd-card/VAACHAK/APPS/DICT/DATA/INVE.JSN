{"INVECTED":[{"def":"Having a border or outline composed of semicircles with the convexity outward; -- the opposite of engrailed.","pos":""}],"INVECTION":[{"def":"An inveighing against; invective.","pos":""}],"INVECTIVE":[{"def":"Characterized by invection; critical; denunciatory; satirical; abusive; railing.","pos":""}],"INVECTIVELY":[{"def":"In an invective manner.","pos":""}],"INVEIGH":[{"def":"To declaim or rail (against some person or thing); to utter censorious and bitter language; to attack with harsh criticism or reproach, either spoken or written; to use invectives; -- with against; as, to inveigh against character, conduct, manners, customs, morals, a law, an abuse.","pos":""}],"INVEIGHER":[{"def":"One who inveighs.","pos":""}],"INVEIGLE":[{"def":"To lead astray as if blind; to persuade to something evil by deceptive arts or flattery; to entice; to insnare; to seduce; to wheedle.","pos":""}],"INVEIGLEMENT":[{"def":"The act of inveigling, or the state of being inveigled; that which inveigles; enticement; seduction.","pos":""}],"INVEIGLER":[{"def":"One who inveigles.","pos":""}],"INVEIL":[{"def":"To cover, as with a vail.","pos":""}],"INVENDIBILITY":[{"def":"The quality of being invendible; invendibleness; unsalableness.","pos":""}],"INVENDIBLE":[{"def":"Not vendible or salable.","pos":""}],"INVENT":[{"def":"To come or light upon; to meet; to find.","pos":""},{"def":"To discover, as by study or inquiry; to find out; to devise; to contrive or produce for the first time; -- applied commonly to the discovery of some serviceable mode, instrument, or machine.","pos":""}],"INVENTER":[{"def":"One who invents.","pos":""}],"INVENTFUL":[{"def":"Full of invention.","pos":""}],"INVENTIBLE":[{"def":"Capable of being invented.","pos":""}],"INVENTIBLENESS":[{"def":"Quality of being inventible.","pos":""}],"INVENTION":[{"def":"The exercise of the imagination in selecting and treating a theme, or more commonly in contriving the arrangement of a piece, or the method of presenting its parts.","pos":""}],"INVENTIVE":[{"def":"Able and apt to invent; quick at contrivance; ready at expedients; as, an inventive head or genius.","pos":""}],"INVENTOR":[{"def":"One who invents or finds out something new; a contriver; especially, one who invents mechanical devices.","pos":""}],"INVENTORIAL":[{"def":"Of or pertaining to an inventory.","pos":""}],"INVENTORY":[{"def":"There take an inventory of all I have.","pos":""}],"INVENTRESS":[{"def":"A woman who invents.","pos":""}],"INVERACITY":[{"def":"Want of veracity.","pos":""}],"INVERISIMILITUDE":[{"def":"Want of verisimilitude or likelihood; improbability.","pos":""},{"def":"A kind of full sleeveless cape, fitting closely about the neck.","pos":""}],"INVERSE":[{"def":"Inverted; having a position or mode of attachment the reverse of that which is usual.","pos":""},{"def":"Opposite in nature and effect; -- said with reference to any two operations, which, when both are performed in succession upon any quantity, reproduce that quantity; as, multiplication is the inverse operation to division.","pos":""}],"INVERSELY":[{"def":"In an inverse order or manner; by inversion; -- opposed to directly.","pos":""}],"INVERSION":[{"def":"A movement in tactics by which the order of companies in line is inverted, the right being on the left, the left on the right, and so on.","pos":""},{"def":"A change in the order of the terms of a proportion, so that the second takes the place of the first, and the fourth of the third.","pos":""}],"INVERT":[{"def":"To change the position of; -- said of tones which form a chord, or parts which compose harmony.","pos":""},{"def":"To convert; to reverse; to decompose by, or subject to, inversion.","pos":""}],"INVERTEBRAL":[{"def":"Same as Invertebrate.","pos":""}],"INVERTEBRATA":[{"def":"A comprehensive division of the animal kingdom, including all except the Vertebrata.","pos":""}],"INVERTEBRATE":[{"def":"Destitute of a backbone; having no vertebræ; of or pertaining to the Invertebrata.","pos":""},{"def":"One of the Invertebrata.","pos":""}],"INVERTEBRATED":[{"def":"Having no backbone; invertebrate.","pos":""}],"INVERTED":[{"def":"Situated apparently in reverse order, as strata when folded back upon themselves by upheaval.","pos":""}],"INVERTEDLY":[{"def":"In an inverted order.","pos":""}],"INVERTIBLE":[{"def":"Capable of being changed or converted; as, invertible sugar.","pos":""}],"INVERTIN":[{"def":"An unorganized ferment which causes cane sugar to take up a molecule of water and be converted into invert sugar.","pos":""}],"INVEST":[{"def":"To inclose; to surround of hem in with troops, so as to intercept succors of men and provisions and prevent escape; to lay siege to; as, to invest a town.","pos":""}],"INVESTIENT":[{"def":"Covering; clothing.","pos":""}],"INVESTIGABLE":[{"def":"Capable or susceptible of being investigated; admitting research.","pos":""}],"INVESTIGATE":[{"def":"To follow up step by step by patient inquiry or observation; to trace or track mentally; to search into; to inquire and examine into with care and accuracy; to find out by careful inquisition; as, to investigate the causes of natural phenomena.","pos":""}],"INVESTIGATION":[{"def":"The act of investigating; the process of inquiring into or following up; research; study; inquiry, esp.","pos":""}],"INVESTIGATIVE":[{"def":"Given to investigation; inquisitive; curious; searching.","pos":""}],"INVESTIGATOR":[{"def":"One who searches diligently into a subject.","pos":""}],"INVESTITURE":[{"def":"Livery of seizin.","pos":""}],"INVESTMENT":[{"def":"The act of surrounding, blocking up, or besieging by an armed force, or the state of being so surrounded.","pos":""}],"INVESTOR":[{"def":"One who invests.","pos":""}],"INVESTURE":[{"def":"Investiture; investment.","pos":""}],"INVETERACY":[{"def":"Firm establishment by long continuance; firmness or deep-rooted obstinacy of any quality or state acquired by time; as, the inveteracy of custom, habit, or disease; -- usually in a bad sense; as, the inveteracy of prejudice or of error.","pos":""},{"def":"Malignity; spitefulness; virulency.","pos":""}],"INVETERATE":[{"def":"Old; long-established.","pos":""},{"def":"Firmly established by long continuance; obstinate; deep-rooted; of long standing; as, an inveterate disease; an inveterate abuse.","pos":""}],"INVETERATELY":[{"def":"In an inveterate manner or degree.","pos":""}],"INVETERATENESS":[{"def":"In*vet\"er*ate*ness, n.","pos":""}],"INVETERATION":[{"def":"The act of making inveterate.","pos":""}]}