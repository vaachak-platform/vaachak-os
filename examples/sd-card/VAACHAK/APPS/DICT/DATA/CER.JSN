{"CERACEOUS":[{"def":"Having the texture and color of new wax; like wax; waxy.","pos":""}],"CERAMIC":[{"def":"Of or pertaining to pottery; relating to the art of making earthenware; as, ceramic products; ceramic ornaments for ceilings.","pos":""}],"CERAMICS":[{"def":"Work formed of clay in whole or in part, and baked; as, vases, urns, etc.","pos":""}],"CERARGYRITE":[{"def":"Native silver chloride, a mineral of a white to pale yellow or gray color, darkening on exposure to the light.","pos":""}],"CERASIN":[{"def":"A white amorphous substance, the insoluble part of cherry gum; -- called also meta-arabinic acid.","pos":""},{"def":"A gummy mucilaginous substance; -- called also bassorin, tragacanthin, etc.","pos":""}],"CERASINOUS":[{"def":"Pertaining to, or containing, cerasin.","pos":""},{"def":"Of a cherry color.","pos":""}],"CERASTES":[{"def":"A genus of poisonous African serpents, with a horny scale over each eye; the horned viper.","pos":""}],"CERATE":[{"def":"An unctuous preparation for external application, of a consistence intermediate between that of an ointment and a plaster, so that it can be spread upon cloth without the use of heat, but does not melt when applied to the skin.","pos":""}],"CERATED":[{"def":"Covered with wax.","pos":""}],"CERATOBRANCHIA":[{"def":"A group of nudibranchiate Mollusca having on the back papilliform or branched organs serving as gills.","pos":""}],"CERATOBRANCHIAL":[{"def":"Pertaining to the bone, or cartilage, below the epibranchial in a branchial arch.","pos":""},{"def":"A ceratobranchial bone, or cartilage.","pos":""}],"CERATODUS":[{"def":"A genus of ganoid fishes, of the order Dipnoi, first known as Mesozoic fossil fishes; but recently two living species have been discovered in Australian rivers.","pos":""}],"CERATOHYAL":[{"def":"Pertaining to the bone, or carts, large, below the epihyal in the hyoid arch.","pos":""},{"def":"A ceratohyal bone, or cartilage, which, in man, forms one of the small horns of the hyoid.","pos":""}],"CERATOSAURUS":[{"def":"A carnivorous American Jurassic dinosaur allied to the European Megalosaurus.","pos":""}],"CERATOSPONGIAE":[{"def":"An order of sponges in which the skeleton consists of horny fibers.","pos":""}],"CERAUNICS":[{"def":"That branch of physics which treats of heat and electricity.","pos":""}],"CERAUNOSCOPE":[{"def":"An instrument or apparatus employed in the ancient mysteries to imitate thunder and lightning.","pos":""}],"CERBEREAN":[{"def":"Of or pertaining to, or resembling, Cerberus.","pos":""}],"CERBERUS":[{"def":"A monster, in the shape, of a three-headed dog, guarding the entrance into the infernal regions, Hence: Any vigilant custodian or guardian, esp.","pos":""},{"def":"A genus of East Indian serpents, allied to the pythons; the bokadam.","pos":""}],"CERCAL":[{"def":"Of or pertaining to the tail.","pos":""}],"CERCARIA":[{"def":"The larval form of a trematode worm having the shape of a tadpole, with its body terminated by a tail-like appendage.","pos":""}],"CERCARIAN":[{"def":"Of, like, or pertaining to, the Cercariæ.","pos":""},{"def":"One of the Cercariæ.","pos":""}],"CERCOPOD":[{"def":"One of the jointed antenniform appendage of the posterior somites of cartain insects.","pos":""}],"CERE":[{"def":"The soft naked sheath at the base of the beak of birds of prey, parrots, and some other birds.","pos":""}],"CEREAL":[{"def":"Of or pertaining to the grasses which are cultivated for their edible seeds (as wheat, maize, rice, etc.","pos":""}],"CEREALIA":[{"def":"Public festivals in honor of Ceres.","pos":""}],"CEREALIN":[{"def":"A nitrogenous substance closely resembling diastase, obtained from bran, and possessing the power of converting starch into dextrin, sugar, and lactic acid.","pos":""}],"CEREBEL":[{"def":"Pertaining to the cerebellum.","pos":""}],"CEREBELLUM":[{"def":"The large lobe of the hind brain in front of and above the medulla; the little brain.","pos":""}],"CEREBRAL":[{"def":"Of or pertaining to the cerebrum.","pos":""}],"CEREBRALISM":[{"def":"The doctrine or theory that psychical phenomena are functions or products of the brain only.","pos":""}],"CEREBRALIST":[{"def":"One who accepts cerebralism.","pos":""}],"CEREBRATE":[{"def":"To exhibit mental activity; to have the brain in action.","pos":""}],"CEREBRATION":[{"def":"Action of the brain, whether conscious or unconscious.","pos":""}],"CEREBRIC":[{"def":"Of, pertaining to, or derived from, the brain.","pos":""}],"CEREBRIFORM":[{"def":"Like the brain in form or substance.","pos":""}],"CEREBRIFUGAL":[{"def":"Applied to those nerve fibers which go from the brain to the spinal cord, and so transfer cerebral impulses (centrifugal impressions) outwards.","pos":""}],"CEREBRIN":[{"def":"A nonphosphorized, nitrogenous substance, obtained from brain and nerve tissue by extraction with boiling alcohol.","pos":""}],"CEREBRIPETAL":[{"def":"Applied to those nerve fibers which go from the spinal cord to the brain and so transfer sensations (centripetal impressions) from the exterior inwards.","pos":""}],"CEREBRITIS":[{"def":"Inflammation of the cerebrum.","pos":""}],"CEREBRO-SPINAL":[{"def":"Of or pertaining to the central nervous system consisting of the brain and spinal cord.","pos":""}],"CEREBROID":[{"def":"Resembling, or analogous to, the cerebrum or brain.","pos":""}],"CEREBROLOGY":[{"def":"The science which treats of the cerebrum or brain.","pos":""}],"CEREBROPATHY":[{"def":"A hypochondriacal condition verging upon insanity, occurring in those whose brains have been unduly taxed; -- called also brain fag.","pos":""}],"CEREBROSCOPY":[{"def":"Examination of the brain for the diagnosis of diseas; esp.","pos":""}],"CEREBROSE":[{"def":"A sugarlike body obtained by the decomposition of the nitrogenous non-phosphorized principles of the brain.","pos":""}],"CEREBRUM":[{"def":"The anterior, and in man the larger, division of the brain; the seat of the reasoning faculties and the will.","pos":""}],"CERECLOTH":[{"def":"A cloth smeared with melted wax, or with some gummy or glutinous matter.","pos":""}],"CEREMONIAL":[{"def":"Relating to ceremony, or external rite; ritual; according to the forms of established rites.","pos":""},{"def":"Observant of forms; ceremonious.","pos":""}],"CEREMONIALISM":[{"def":"Adherence to external rites; fondness for ceremony.","pos":""}],"CEREMONIALLY":[{"def":"According to rites and ceremonies; as, a person ceremonially unclean.","pos":""}],"CEREMONIALNESS":[{"def":"Quality of being ceremonial.","pos":""}],"CEREMONIOUS":[{"def":"Consisting of outward forms and rites; ceremonial.","pos":""},{"def":"According to prescribed or customary rules and forms; devoted to forms and ceremonies; formally respectful; punctilious.","pos":""}],"CEREMONIOUSLY":[{"def":"In a ceremonious way.","pos":""}],"CEREMONIOUSNESS":[{"def":"The quality, or practice, of being ceremonious.","pos":""}],"CEREMONY":[{"def":"Behavior regulated by strict etiquette; a formal method of performing acts of civility; forms of civility prescribed by custom or authority.","pos":""}],"CEREOUS":[{"def":"Waxen; like wax.","pos":""}],"CERES":[{"def":"The daughter of Saturn and Ops or Rhea, the goddess of corn and tillage.","pos":""},{"def":"The first discovered asteroid.","pos":""}],"CERESIN":[{"def":"A white wax, made by bleaching and purifying ozocerite, and used as a substitute for beeswax.","pos":""}],"CEREUS":[{"def":"A genus of plants of the Cactus family.","pos":""}],"CEREVIS":[{"def":"A small visorless cap, worn by members of German student corps.","pos":""}],"CERIA":[{"def":"Cerium oxide, CeO2, a white infusible substance constituting about one per cent of the material of the common incandescent mantle.","pos":""}],"CERIN":[{"def":"A waxy substance extracted by alcohol or ether from cork; sometimes applied also to the portion of beeswax which is soluble in alcohol.","pos":""},{"def":"A variety of the mineral allanite.","pos":""}],"CERINTHIAN":[{"def":"One of an ancient religious sect, so called fron Cerinthus, a Jew, who attempted to unite the doctrines of Christ with the opinions of the Jews and Gnostics.","pos":""}],"CERIPH":[{"def":"One of the fine lines of a letter, esp.","pos":""}],"CERISE":[{"def":"Cherry-colored; a light bright red; --- applied to textile fabrics, especially silk.","pos":""}],"CERITE":[{"def":"A gastropod shell belonging to the family Cerithiïdæ; -- so called from its hornlike form.","pos":""}],"CERIUM":[{"def":"A rare metallic element, occurring in the minerals cerite, allanite, monazite, etc.","pos":""}],"CERNUOUS":[{"def":"Inclining or nodding downward; pendulous; drooping; -- said of a bud, flower, fruit, or the capsule of a moss.","pos":""}],"CERO":[{"def":"A large and valuable fish of the Mackerel family, of the genus Scomberomorus.","pos":""}],"CEROGRAPH":[{"def":"A writing on wax.","pos":""},{"def":"Of or pertaining to cerography.","pos":""}],"CEROGRAPHIST":[{"def":"One who practices cerography.","pos":""}],"CEROGRAPHY":[{"def":"The art of making characters or designs in, or with, wax.","pos":""},{"def":"A method of making stereotype plates from inscribed sheets of wax.","pos":""}],"CEROLITE":[{"def":"A hydrous silicate of magnesium, allied to serpentine, occurring in waxlike masses of a yellow or greenish color.","pos":""}],"CEROMA":[{"def":"That part of the baths and gymnasia in which bathers and wrestlers anointed themselves.","pos":""},{"def":"The cere of birds.","pos":""}],"CEROMANCY":[{"def":"Divination by dropping melted wax in water.","pos":""}],"CEROON":[{"def":"A bale or package.","pos":""}],"CEROPLASTIC":[{"def":"The art of modeling in wax.","pos":""}],"CEROSIN":[{"def":"A waxy substance obtained from the bark of the sugar cane, and crystallizing in delicate white laminæ.","pos":""}],"CEROTENE":[{"def":"A white waxy solid obtained from Chinese wax, and by the distillation of cerotin.","pos":""}],"CEROTIC":[{"def":"Pertaining to, or derived from, beeswax or Chinese wax; as, cerotic acid or alcohol.","pos":""}],"CEROTIN":[{"def":"A white crystalline substance, C27H55.","pos":""}],"CEROTYPE":[{"def":"A printing process of engraving on a surface of wax spread on a steel plate, for electrotyping.","pos":""}],"CERRIAL":[{"def":"Of or pertaining to the cerris.","pos":""}],"CERRIS":[{"def":"A species of oak (Quercus cerris) native in the Orient and southern Europe; -- called also bitter oak and Turkey oak.","pos":""}],"CERTAIN":[{"def":"Assured in mind; having no doubts; free from suspicions concerning.","pos":""},{"def":"Determined; resolved; -- used with an infinitive.","pos":""}],"CERTAINLY":[{"def":"Without doubt or question; unquestionably.","pos":""}],"CERTAINTY":[{"def":"Clearness; freedom from ambiguity; lucidity.","pos":""}],"CERTES":[{"def":"Certainly; in truth; verily.","pos":""}],"CERTIFICATE":[{"def":"A written testimony to the truth of any fact; as, certificate of good behavior.","pos":""},{"def":"A written declaration legally authenticated.","pos":""}],"CERTIFICATION":[{"def":"The act of certifying.","pos":"noun"}],"CERTIFIER":[{"def":"One who certifies or assures.","pos":""}],"CERTIFY":[{"def":"To give cetain information to; to assure; to make certain.","pos":""},{"def":"To give certain information of; to make certain, as a fact; to verify.","pos":""}],"CERTIORARI":[{"def":"A writ issuing out of chancery, or a superior court, to call up the records of a inferior court, or remove a cause there depending, in order that the party may have more sure and speedy justice, or that errors and irreguarities may be corrected.","pos":""}],"CERTITUDE":[{"def":"Freedom from doubt; assurance; certainty.","pos":""}],"CERULEAN":[{"def":"Sky-colored; blue; azure.","pos":""}],"CERULEIN":[{"def":"A fast dyestuff, C20H8O6, made by heating gallein with strong sulphuric acid.","pos":""}],"CERULESCENT":[{"def":"Tending to cerulean; light bluish.","pos":""}],"CERULEUM":[{"def":"A greenish blue pigment prepared in various ways, consisting essentially of cobalt stannate.","pos":""}],"CERULIFIC":[{"def":"Producing a blue or sky color.","pos":""}],"CERUMEN":[{"def":"The yellow, waxlike secretion from the glands of the external ear; the earwax.","pos":""}],"CERUMINOUS":[{"def":"Pertaining to, or secreting, cerumen; as, the ceruminous glands.","pos":""}],"CERUSE":[{"def":"The native carbonate of lead.","pos":""}],"CERUSED":[{"def":"Washed with a preparation of white lead; as, cerused face.","pos":""},{"def":"Native lead carbonate; a mineral occurring in colorless, white, or yellowish transparent crystals, with an adamantine, also massive and compact.","pos":""}],"CERVANTITE":[{"def":"See under Antimony.","pos":""}],"CERVELAT":[{"def":"An ancient wind instrument, resembling the bassoon in tone.","pos":""}],"CERVICAL":[{"def":"Of or pertaining to the neck; as, the cervical vertebræ.","pos":""}],"CERVICIDE":[{"def":"The act of killing deer; deer-slaying.","pos":""}],"CERVINE":[{"def":"Of or pertaining to the deer, or to the family Cervidæ.","pos":""}],"CERVIX":[{"def":"The neck; also, the necklike portion of any part, as of the womb.","pos":""}],"CERVUS":[{"def":"A genus of ruminants, including the red deer and other allied species.","pos":""}],"CERYL":[{"def":"A radical, C27H55 supposed to exist in several compounds obtained from Chinese wax, beeswax, etc.","pos":""},{"def":"Same as Cæsarean, Cæsarian.","pos":""}]}