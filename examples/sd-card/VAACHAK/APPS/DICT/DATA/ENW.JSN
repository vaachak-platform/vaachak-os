{"ENWALLOW":[{"def":"To plunge into, or roll in, flith; to wallow.","pos":""}],"ENWIND":[{"def":"To wind about; to encircle.","pos":""}],"ENWOMAN":[{"def":"To endow with the qualities of a woman.","pos":""}],"ENWOMB":[{"def":"To conceive in the womb.","pos":""},{"def":"To bury, as it were in a womb; to hide, as in a gulf, pit, or cavern.","pos":""}],"ENWRAPMENT":[{"def":"Act of enwrapping; a wrapping or an envelope.","pos":""}],"ENWREATHE":[{"def":"Afflicting animals; -- used of a disease affecting the animals of a district.","pos":""}]}