{"HUCK":[{"def":"To higgle in trading.","pos":""}],"HUCKABACK":[{"def":"A kind of linen cloth with raised figures, used for towelings.","pos":""}],"HUCKLE":[{"def":"The hip; the haunch.","pos":""},{"def":"A bunch or part projecting like the hip.","pos":""}],"HUCKLEBERRY":[{"def":"American genus Gaylussacia, shrubs nearly related to the blueberries (Vaccinium), and formerly confused with them.","pos":""}],"HUCKSTER":[{"def":"A retailer of small articles, of provisions, and the like; a peddler; a hawker.","pos":""},{"def":"A mean, trickish fellow.","pos":""}],"HUCKSTERAGE":[{"def":"The business of a huckster; small dealing; peddling.","pos":""}],"HUCKSTERER":[{"def":"Those hucksterers or money-jobbers.","pos":""}],"HUCKSTRESS":[{"def":"A female huckster.","pos":""}]}