{"FIVE":[{"def":"Four and one added; one more than four.","pos":""}],"FIVE-FINGER":[{"def":"A starfish with five rays, esp.","pos":""}],"FIVE-LEAF":[{"def":"Cinquefoil; five-finger.","pos":""},{"def":"Having five leaflets, as the Virginia creeper.","pos":""}],"FIVE-TWENTIES":[{"def":"Five-twenty bonds of the United States (bearing six per cent interest), issued in 1862, '64, and '65, redeemable after five and payable in twenty years.","pos":""}],"FIVEFOLD":[{"def":"In fives; consisting of five in one; five repeated; quintuple.","pos":""}],"FIVELING":[{"def":"A compound or twin crystal consisting of five individuals.","pos":""}],"FIVES":[{"def":"A kind of play with a ball against a wall, resembling tennis; - - so named because three fives, or fifteen, are counted to the game.","pos":""}]}