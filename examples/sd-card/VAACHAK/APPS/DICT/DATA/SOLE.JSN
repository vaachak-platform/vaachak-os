{"SOLE":[{"def":"The bottom of the body of a plow; -- called also slade; also, the bottom of a furrow.","pos":""}],"SOLE TRADER":[{"def":"A feme sole trader.","pos":""}],"SOLECISM":[{"def":"An impropriety or incongruity of language in the combination of words or parts of a sentence; esp.","pos":"noun"},{"def":"Any inconsistency, unfitness, absurdity, or impropriety, as in deeds or manners.","pos":"noun"}],"SOLECIST":[{"def":"One who commits a solecism.","pos":""}],"SOLECISTICAL":[{"def":"Pertaining to, or involving, a solecism; incorrect.","pos":""}],"SOLECISTICALLY":[{"def":"In a solecistic manner.","pos":""}],"SOLECIZE":[{"def":"To commit a solecism.","pos":""}],"SOLELY":[{"def":"Singly; alone; only; without another; as, to rest a cause solely one argument; to rely solelyn one's own strength.","pos":""}],"SOLEMN":[{"def":"Made in form; ceremonious; as, solemn war; conforming with all legal requirements; as, probate in solemn form.","pos":""}],"SOLEMNESS":[{"def":"Some think he wanted solemnes.","pos":""}],"SOLEMNITY":[{"def":"A solemn or formal observance; proceeding according to due form; the formality which is necessary to render a thing done valid.","pos":""}],"SOLEMNIZATE":[{"def":"To solemnize; as, to solemnizate matrimony.","pos":""}],"SOLEMNIZATION":[{"def":"The act of solemnizing; celebration; as, the solemnization of a marriage.","pos":""}],"SOLEMNIZE":[{"def":"To perform with solemn or ritual ceremonies, or according to legal forms.","pos":""},{"def":"To dignify or honor by ceremonies; to celebrate.","pos":""}],"SOLEMNIZER":[{"def":"One who solemnizes.","pos":""}],"SOLEMNLY":[{"def":"In a solemn manner; with gravity; seriously; formally.","pos":""}],"SOLEMNNESS":[{"def":"The state or quality of being solemn; solemnity; impressiveness; gravity; as, the solemnness of public worship.","pos":""}],"SOLEMPNE":[{"def":"Solemn; grand; stately; splendid; magnificent.","pos":""}],"SOLEN":[{"def":"A cradle, as for a broken limb.","pos":""},{"def":"Any marine bivalve mollusk belonging to Solen or allied genera of the family Solenidæ; a razor shell.","pos":""}],"SOLENACEAN":[{"def":"Any species of marine bivalve shells belonging to the family Solenidæ.","pos":""}],"SOLENACEOUS":[{"def":"Of or pertaining to the solens or family Solenidæ.","pos":""}],"SOLENESS":[{"def":"The state of being sole, or alone; singleness.","pos":""}],"SOLENETTE":[{"def":"A small European sole (Solea minuta).","pos":""}],"SOLENOCONCHA":[{"def":"Same as Scaphopoda.","pos":""}],"SOLENODON":[{"def":"Either one of two species of singular West Indian insectivores, allied to the tenrec.","pos":""}],"SOLENOGASTRA":[{"def":"An order of lowly organized Mollusca belonging to the Isopleura.","pos":""}],"SOLENOGLYPH":[{"def":"Pertaining to the Selenoglypha.","pos":""},{"def":"One of the Selenoglypha.","pos":""}],"SOLENOGLYPHA":[{"def":"A suborder of serpents including those which have tubular erectile fangs, as the viper and rattlesnake.","pos":""}],"SOLENOID":[{"def":"An electrodynamic spiral having the conjuctive wire turned back along its axis, so as to neutralize that component of the effect of the current which is due to the length of the spiral, and reduce the whole effect to that of a series of equal and parallel circular currents.","pos":"noun"}],"SOLENOSTOMI":[{"def":"A tribe of lophobranch fishes having a tubular snout.","pos":""}],"SOLEPLATE":[{"def":"A loft or garret.","pos":""}],"SOLERT":[{"def":"Skillful; clever; crafty.","pos":""}],"SOLERTIOUSNESS":[{"def":"The quality or state of being solert.","pos":""}],"SOLESHIP":[{"def":"The state of being sole, or alone; soleness.","pos":""}]}