{"NEUFCHATEL":[{"def":"A kind of soft sweet-milk cheese; -- so called from Neufchâtel- en-Bray in France.","pos":""}],"NEURAD":[{"def":"Toward the neural side; -- opposed to hæmad.","pos":""}],"NEURAL":[{"def":"relating to the nerves or nervous system; taining to, situated in the region of, or on the side with, the neural, or cerebro-spinal, axis; -- opposed to hemal.","pos":""}],"NEURALGIA":[{"def":"A disease, the chief symptom of which is a very acute pain, exacerbating or intermitting, which follows the course of a nervous branch, extends to its ramifications, and seems therefore to be seated in the nerve.","pos":""}],"NEURALGIC":[{"def":"of or pertaining to, or having the character of, neuralgia; as, a neuralgic headache.","pos":""}],"NEURAPOPHYSIAL":[{"def":"of or pertaining to a neurapophysis.","pos":""}],"NEURASTHENIA":[{"def":"A condition of nervous debility supposed to be dependent upon impairment in the functions of the spinal cord.","pos":""}],"NEURATION":[{"def":"The arrangement or distribution of nerves, as in the leaves of a plant or the wings of an insect; nervation.","pos":""}],"NEURAXIS":[{"def":"See Axis cylinder, under Axis.","pos":""}],"NEURENTERIC":[{"def":"Of or pertaining to both the neuron and the enteron; as, the neurenteric canal, which, in embroys of many vertebrates, connects the medullary tube and the primitive intestine.","pos":""}],"NEURIDIN":[{"def":"a nontoxic base, C5H14N2, found in the putrescent matters of flesh, fish, decaying cheese, etc.","pos":""}],"NEURILITY":[{"def":"The special properties and functions of the nerves; that capacity for transmitting a stimulus which belongs to nerves.","pos":""}],"NEURINE":[{"def":"A poisonous organic base (a ptomaine) formed in the decomposition of protagon with boiling baryta water, and in the putrefraction of proteid matter.","pos":""}],"NEURITIS":[{"def":"Inflammation of a nerve.","pos":""}],"NEURO-":[{"def":"A combining denoting a nerve, of or pertaining to a nerve or the nervous system.","pos":""}],"NEURO-CENTRAL":[{"def":"Between the neural arch and the centrum of a vertebra; as, the neurocentral suture.","pos":""}],"NEURO-EPIDERMAL":[{"def":"Pertaining to, or giving rise to, the central nervous system and epiderms; as, the neuroepidermal, or epiblastic, layer of the blastoderm.","pos":""}],"NEUROCITY":[{"def":"The central canal and ventricles of the spinal cord and brain; the myelencephalic cavity.","pos":""}],"NEUROCORD":[{"def":"A cordlike organ composed of elastic fibers situated above the ventral nervous cord of annelids, like the earthworm.","pos":""}],"NEUROGLIA":[{"def":"The delicate connective tissue framework which supports the nervous matter and blood vessels of the brain and spinal cord.","pos":""}],"NEUROGRAPHY":[{"def":"A description of the nerves.","pos":""}],"NEUROKERATIN":[{"def":"A substance, resembling keratin, present in nerve tissue, as in the sheath of the axis cylinder of medullated nerve fibers.","pos":""}],"NEUROLOGICAL":[{"def":"Of or pertaining to neurolgy.","pos":""}],"NEUROLOGIST":[{"def":"One who is versed in neurology; also, one skilled in the treatment of nervous diseases.","pos":""}],"NEUROLOGY":[{"def":"The branch of science which treats of the nervous system.","pos":""}],"NEUROMA":[{"def":"A tumor developed on, or connected with, a nerve, esp.","pos":""}],"NEUROMERE":[{"def":"A metameric segment of the cerebro-spinal nervous system.","pos":""}],"NEURON":[{"def":"The brain and spinal cord; the cerebro-spinal axis; myelencephalon.","pos":""}],"NEUROPATHIC":[{"def":"Of or pertaining to neuropathy; of the nature of, or suffering from, nervous disease.","pos":""}],"NEUROPATHY":[{"def":"An affection of the nervous system or of a nerve.","pos":""}],"NEUROPOD":[{"def":"A neuropodous animal.","pos":""}],"NEUROPODIUM":[{"def":"The ventral lobe or branch of a parapodium.","pos":""}],"NEUROPODOUS":[{"def":"Having the limbs on, or directed toward, the neural side, as in most invertebrates; -- opposed to Ant: hæmapodous.","pos":""}],"NEUROPORE":[{"def":"An opening at either end of the embryonic neural canal.","pos":""}],"NEUROPTER":[{"def":"One of the Neuroptera.","pos":""}],"NEUROPTERA":[{"def":"An order of hexapod insects having two pairs of large, membranous, net-veined wings.","pos":""}],"NEUROPTERAL":[{"def":"Of or pertaining to the Neuroptera.","pos":""}],"NEUROPTERIS":[{"def":"An extensive genus of fossil ferns, of which species have been found from the Devonian to the Triassic formation.","pos":""}],"NEUROSENSIFEROUS":[{"def":"Pertaining to, or forming, both nerves and sense organs.","pos":""}],"NEUROSIS":[{"def":"A functional nervous affection or disease, that is, a disease of the nerves without any appreciable change of nerve structure.","pos":""}],"NEUROSKELETAL":[{"def":"Of or pertaining to the neuroskeleton.","pos":""}],"NEUROSKELETON":[{"def":"The deep-seated parts of the vertebrate skeleton which are relation with the nervous axis and locomation.","pos":""}],"NEUROTIC":[{"def":"Of or pertaining to the nerves; seated in the nerves; nervous; as, a neurotic disease.","pos":""},{"def":"Uself in disorders of, or affecting, the nerves.","pos":""}],"NEUROTOME":[{"def":"An instrument for cutting or dissecting nerves.","pos":""}],"NEUROTOMICAL":[{"def":"Of or pertaining to neurotomy.","pos":""}],"NEUROTOMIST":[{"def":"One who skilled in or practices neurotomy.","pos":""}],"NEUROTOMY":[{"def":"The division of a nerve, for the relief of neuralgia, or for other purposes.","pos":""}],"NEURULA":[{"def":"An embryo or certain invertebrates in the stage when the primitive band is first developed.","pos":""}],"NEUTER":[{"def":"Having no generative organs, or imperfectly developed ones; sexless.","pos":""}],"NEUTRAL":[{"def":"Having neither acid nor basic properties; unable to turn red litmus blue or blue litmus red; -- said of certain salts or other compounds.","pos":""}],"NEUTRALIST":[{"def":"A neutral; one who professes or practices neutrality.","pos":""}],"NEUTRALITY":[{"def":"The quality or state of being neutral.","pos":""},{"def":"The condition of a nation or government which refrains from taking part, directly or indirectly, in a war between other powers.","pos":""}],"NEUTRALIZATION":[{"def":"The act or process by which an acid and a base are combined in such proportions that the resulting compound is neutral.","pos":""}],"NEUTRALIZE":[{"def":"To render inert or imperceptible the peculiar affinities of, as a chemical substance; to destroy the effect of; as, to neutralize an acid with a base.","pos":""}],"NEUTRALIZER":[{"def":"One who, or that which, neutralizes; that which destroys, disguises, or renders inert the peculiar properties of a body.","pos":""}],"NEUTRALLY":[{"def":"In a neutral manner; without taking part with either side; indifferently.","pos":""},{"def":"One of a group of leucocytes whose granules stain only with neutral dyes.","pos":""}],"NEUVAINES":[{"def":"Prayers offered up for nine successive days.","pos":""}]}