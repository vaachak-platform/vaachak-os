{"HUFF":[{"def":"To remove from the board (the piece which could have captured an opposing piece).","pos":""}],"HUFFCAP":[{"def":"A blusterer; a bully.","pos":""},{"def":"Blustering; swaggering.","pos":""}],"HUFFER":[{"def":"A bully; a blusterer.","pos":""}],"HUFFINESS":[{"def":"The state of being huffish; petulance; bad temper.","pos":""}],"HUFFINGLY":[{"def":"Blusteringly; arrogantly.","pos":""}],"HUFFISH":[{"def":"Disposed to be blustering or arrogant; petulant.","pos":""}],"HUFFY":[{"def":"Puffed up; as, huffy bread.","pos":""},{"def":"Characterized by arrogance or petulance; easily offended.","pos":""}]}