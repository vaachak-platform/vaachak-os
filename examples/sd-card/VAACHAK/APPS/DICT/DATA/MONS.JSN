{"MONSEIGNEUR":[{"def":"My lord; -- a title in France of a person of high birth or rank; as, Monseigneur the Prince, or Monseigneur the Archibishop.","pos":""}],"MONSEL'S SALT":[{"def":"A basic sulphate of iron; -- so named from Monsel, a Frenchman.","pos":""}],"MONSEL'S SOLUTION":[{"def":"An aqueous solution of Monsel's salt, having valuable styptic properties.","pos":""}],"MONSIEUR":[{"def":"The common title of civility in France in speaking to, or of, a man; Mr.","pos":""},{"def":"The oldest brother of the king of France.","pos":""}],"MONSIGNORE":[{"def":"My lord; -- an ecclesiastical dignity bestowed by the pope, entitling the bearer to social and domestic rank at the papal court.","pos":""}],"MONSTER":[{"def":"Something of unnatural size, shape, or quality; a prodigy; an enormity; a marvel.","pos":""},{"def":"Specifically , an animal or plant departing greatly from the usual type, as by having too many limbs.","pos":""}],"MONSTRANCE":[{"def":"A transparent pyx, in which the consecrated host is exposed to view.","pos":""}],"MONSTRATION":[{"def":"The act of demonstrating; proof.","pos":""}],"MONSTROSITY":[{"def":"The state of being monstrous, or out of the common order of nature; that which is monstrous; a monster.","pos":""}],"MONSTROUS":[{"def":"Marvelous; strange.","pos":""},{"def":"Having the qualities of a monster; deviating greatly from the natural form or character; abnormal; as, a monstrous birth.","pos":""}],"MONSTROUSLY":[{"def":"In a monstrous manner; unnaturally; extraordinarily; as, monstrously wicked.","pos":""}],"MONSTROUSNESS":[{"def":"The state or quality of being monstrous, unusual, extraordinary.","pos":""}]}