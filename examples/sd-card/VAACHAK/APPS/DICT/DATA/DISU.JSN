{"DISULPHIDE":[{"def":"A binary compound of sulphur containing two atoms of sulphur in each molecule; -- formerly called disulphuret.","pos":""}],"DISULPHURIC":[{"def":"Applied to an acid having in each molecule two atoms of sulphur in the higher state of oxidation.","pos":""}],"DISUNION":[{"def":"The termination of union; separation; disjunction; as, the disunion of the body and the soul.","pos":""},{"def":"A breach of concord and its effect; alienation.","pos":""}],"DISUNIONIST":[{"def":"An advocate of disunion, specifically, of disunion of the United States.","pos":""}],"DISUNITE":[{"def":"To destroy the union of; to divide; to part; to sever; to disjoin; to sunder; to separate; as, to disunite particles of matter.","pos":""},{"def":"To alienate in spirit; to break the concord of.","pos":""}],"DISUNITER":[{"def":"One who, or that which, disjoins or causes disunion.","pos":""}],"DISUNITY":[{"def":"A state of separation or disunion; want of unity.","pos":""}],"DISUSAGE":[{"def":"Gradual cessation of use or custom; neglect of use; disuse.","pos":""}],"DISUSE":[{"def":"To cease to use; to discontinue the practice of.","pos":""},{"def":"To disaccustom; -- with to or from; as, disused to toil.","pos":""}],"DISUTILIZE":[{"def":"To deprive of utility; to render useless.","pos":""}]}