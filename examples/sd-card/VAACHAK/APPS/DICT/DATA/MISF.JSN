{"MISFAITH":[{"def":"Want of faith; distrust.","pos":""}],"MISFALL":[{"def":"To befall, as ill luck; to happen to unluckily.","pos":""}],"MISFASHION":[{"def":"To form wrongly.","pos":""}],"MISFEASANCE":[{"def":"A trespass; a wrong done; the improper doing of an act which a person might lawfully do.","pos":""}],"MISFEIGN":[{"def":"To feign with an evil design.","pos":""}],"MISFIT":[{"def":"The act or the state of fitting badly; as, a misfit in making a coat; a ludicrous misfit.","pos":""},{"def":"Something that fits badly, as a garment.","pos":""}],"MISFORM":[{"def":"To make in an ill form.","pos":""}],"MISFORTUNATE":[{"def":"Producing misfortune.","pos":""}],"MISFORTUNE":[{"def":"Bad fortune or luck; calamity; an evil accident; disaster; mishap; mischance.","pos":""}],"MISFRAME":[{"def":"To frame wrongly.","pos":""}]}