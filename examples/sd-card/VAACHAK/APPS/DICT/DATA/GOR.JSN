{"GOR-BELLY":[{"def":"A prominent belly; a big-bellied person.","pos":""}],"GORACCO":[{"def":"A paste prepared from tobacco, and smoked in hookahs in Western India.","pos":""}],"GORAL":[{"def":"An Indian goat antelope (Nemorhedus goral), resembling the chamois.","pos":""}],"GORAMY":[{"def":"Same as Gourami.","pos":""}],"GORCE":[{"def":"A pool of water to keep fish in; a wear.","pos":""}],"GORCOCK":[{"def":"The moor cock, or red grouse.","pos":""}],"GORCROW":[{"def":"The carrion crow; -- called also gercrow.","pos":""}],"GORD":[{"def":"An instrument of gaming; a sort of dice.","pos":""}],"GORDIACEA":[{"def":"A division of nematoid worms, including the hairworms or hair eels (Gordius and Mermis).","pos":""}],"GORDIAN":[{"def":"Pertaining to the Gordiacea.","pos":""}],"GORE":[{"def":"Blood; especially, blood that after effusion has become thick or clotted.","pos":""}],"GORGE":[{"def":"A concave molding; a cavetto.","pos":""},{"def":"The groove of a pulley.","pos":""}],"GORGED":[{"def":"Bearing a coronet or ring about the neck.","pos":""}],"GORGELET":[{"def":"A small gorget, as of a humming bird.","pos":""}],"GORGEOUS":[{"def":"Imposing through splendid or various colors; showy; fine; magnificent.","pos":""}],"GORGERIN":[{"def":"In some columns, that part of the capital between the termination of the shaft and the annulet of the echinus, or the space between two neck moldings; -- called also neck of the capital, and hypotrachelium.","pos":""}],"GORGET":[{"def":"A crescent-shaped, colored patch on the neck of a bird or mammal.","pos":""}],"GORGON":[{"def":"One of three fabled sisters, Stheno, Euryale, and Medusa, with snaky hair and of terrific aspect, the sight of whom turned the beholder to stone.","pos":""},{"def":"The brindled gnu.","pos":""}],"GORGONACEA":[{"def":"See Gorgoniacea.","pos":""}],"GORGONEAN":[{"def":"See Gorgonian, 1.","pos":""}],"GORGONEION":[{"def":"A mask carved in imitation of a Gorgon's head.","pos":""}],"GORGONIA":[{"def":"A genus of Gorgoniacea, formerly very extensive, but now restricted to such species as the West Indian sea fan (Gorgonia flabellum), sea plume (G.","pos":""},{"def":"Any slender branched gorgonian.","pos":""}],"GORGONIACEA":[{"def":"Note: The axis is commonly horny, but it may be solid and stony (composed of calcium carbonate), as in the red coral of commerce, or it may be in alternating horny and stony joints, as in Isis.","pos":""}],"GORGONIAN":[{"def":"Pertaining to the Gorgoniacea; as, gorgonian coral.","pos":""}],"GORGONIZE":[{"def":"To have the effect of a Gorgon upon; to turn into stone; to petrify.","pos":""}],"GORGONZOLA":[{"def":"A kind of Italian pressed milk cheese; -- so called from a village near Milan.","pos":""}],"GORHEN":[{"def":"The female of the gorcock.","pos":""}],"GORILLA":[{"def":"A large, arboreal, anthropoid ape of West Africa.","pos":""},{"def":"A piece of canvas cut obliquely to widen a sail at the foot.","pos":""}],"GORM":[{"def":"To daub, as the hands or clothing, with gorm; to daub with anything sticky.","pos":""}],"GORMA":[{"def":"The European cormorant.","pos":""}],"GORMAND":[{"def":"A greedy or ravenous eater; a luxurious feeder; a gourmand.","pos":""}],"GORMANDIZE":[{"def":"To eat greedily; to swallow voraciously; to feed ravenously or like a glutton.","pos":""}],"GORMANDIZER":[{"def":"A greedy, voracious eater; a gormand; a glutton.","pos":""}],"GOROON SHELL":[{"def":"A large, handsome, marine, univalve shell (Triton femorale).","pos":""}],"GORSE":[{"def":"The common, overgrown with fern, and rough With prickly gorse.","pos":""}],"GORY":[{"def":"Covered with gore or clotted blood.","pos":""},{"def":"Bloody; murderous.","pos":""}]}