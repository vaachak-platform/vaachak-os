{"SUBPEDUNCULAR":[{"def":"Situated beneath the peduncle; as, the subpeduncular lobe of the cerebellum.","pos":""}],"SUBPEDUNCULATE":[{"def":"Supported on, or growing from, a very short stem; having a short peduncle.","pos":""}],"SUBPELLUCID":[{"def":"Somewhat pellucid; nearly pellucid.","pos":""}],"SUBPENTANGULAR":[{"def":"Nearly or approximately pentangular; almost pentangular.","pos":""}],"SUBPERICARDIAL":[{"def":"Situated under the cardiac pericardium.","pos":""}],"SUBPERIOSTEAL":[{"def":"Situated under the periosteum.","pos":""}],"SUBPERITONEAL":[{"def":"Situated under the peritoneal membrane.","pos":""}],"SUBPETIOLAR":[{"def":"Concealed within the base of the petiole, as the leaf buds of the plane tree.","pos":""}],"SUBPLEURAL":[{"def":"Situated under the pleural membrane.","pos":""}],"SUBPODOPHYLLOUS":[{"def":"Situated under the podophyllous tissue of the horse's foot.","pos":""}],"SUBPOENA":[{"def":"A writ commanding the attendance in court, as a witness, of the person on whom it is served, under a penalty; the process by which a defendant in equity is commanded to appear and answer the plaintiff's bill.","pos":""}],"SUBPOENAL":[{"def":"Required or done under penalty.","pos":""}],"SUBPOLAR":[{"def":"Situated below the poles.","pos":""}],"SUBPOLYGONAL":[{"def":"Approximately polygonal; somewhat or almost polygonal.","pos":""}],"SUBPREHENSILE":[{"def":"Somewhat prehensile; prehensile in an inferior degree.","pos":""}],"SUBPRIOR":[{"def":"The vicegerent of a prior; a claustral officer who assists the prior.","pos":""}],"SUBPUBIC":[{"def":"Situated under, or posterior to, the pubic bones.","pos":""}],"SUBPULMONARY":[{"def":"Situated under, or on the ventral side of, the lungs.","pos":""}],"SUBPURCHASER":[{"def":"A purchaser who buys from a purchaser; one who buys at second hand.","pos":""}],"SUBPYRIFORM":[{"def":"Somewhat pyriform.","pos":""}]}