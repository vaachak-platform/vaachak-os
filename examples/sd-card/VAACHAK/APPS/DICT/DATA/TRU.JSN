{"TRUAGE":[{"def":"A pledge of truth or peace made on payment of a tax.","pos":""},{"def":"A tax or impost; tribute.","pos":""}],"TRUANCY":[{"def":"The act of playing truant, or the state of being truant; as, addicted to truancy.","pos":""}],"TRUANT":[{"def":"One who stays away from business or any duty; especially, one who stays out of school without leave; an idler; a loiterer; a shirk.","pos":""}],"TRUANTLY":[{"def":"Like a truant; in idleness.","pos":""}],"TRUANTSHIP":[{"def":"The conduct of a truant; neglect of employment; idleness; truancy.","pos":""}],"TRUBTALL":[{"def":"A short, squat woman.","pos":""}],"TRUBU":[{"def":"An East India herring (Clupea toli) which is extensively caught for the sake of its roe and for its flesh.","pos":""}],"TRUCE":[{"def":"A suspension of arms by agreement of the commanders of opposing forces; a temporary cessation of hostilities, for negotiation or other purpose; an armistice.","pos":""}],"TRUCEBREAKER":[{"def":"One who violates a truce, covenant, or engagement.","pos":""}],"TRUCELESS":[{"def":"Without a truce; unforbearing.","pos":""}],"TRUCHMAN":[{"def":"And after, by the tongue, Her truchman, she reports the mind's each throw.","pos":""}],"TRUCIDATION":[{"def":"The act of killing.","pos":""}],"TRUCK":[{"def":"A swiveling carriage, consisting of a frame with one or more pairs of wheels and the necessary boxes, springs, etc.","pos":""}],"TRUCKAGE":[{"def":"The practice of bartering goods; exchange; barter; truck.","pos":""}],"TRUCKER":[{"def":"One who trucks; a trafficker.","pos":""}],"TRUCKING":[{"def":"The business of conveying goods on trucks.","pos":""}],"TRUCKLE":[{"def":"A small wheel or caster.","pos":""}],"TRUCKLE-BED":[{"def":"A low bed on wheels, that may be pushed under another bed; a trundle-bed.","pos":""}],"TRUCKLER":[{"def":"One who truckles, or yields servilely to the will of another.","pos":""}],"TRUCKMAN":[{"def":"One who does business in the way of barter or exchange.","pos":""},{"def":"One who drives a truck, or whose business is the conveyance of goods on trucks.","pos":""}],"TRUCULENT":[{"def":"Fierce; savage; ferocious; barbarous; as, the truculent inhabitants of Scythia.","pos":""},{"def":"Cruel; destructive; ruthless.","pos":""}],"TRUCULENTLY":[{"def":"In a truculent manner.","pos":""}],"TRUDGE":[{"def":"To walk or march with labor; to jog along; to move wearily.","pos":""}],"TRUDGEN STROKE":[{"def":"A racing stroke in which a double over-arm motion is used; -- so called from its use by an amateur named Trudgen, but often erroneously written trudgeon.","pos":""}],"TRUE":[{"def":"Conformable to fact; in accordance with the actual state of things; correct; not false, erroneous, inaccurate, or the like; as, a true relation or narration; a true history; a declaration is true when it states the facts.","pos":""},{"def":"Right to precision; conformable to a rule or pattern; exact; accurate; as, a true copy; a true likeness of the original.","pos":""}],"TRUE-BLUE":[{"def":"Of inflexible honesty and fidelity; -- a term derived from the true, or Coventry, blue, formerly celebrated for its unchanging color.","pos":""}],"TRUE-BORN":[{"def":"Of genuine birth; having a right by birth to any title; as, a true-born Englishman.","pos":""}],"TRUE-BRED":[{"def":"Of a genuine or right breed; as, a true-bred beast.","pos":""},{"def":"Being of real breeding or education; as, a true-bred gentleman.","pos":""}],"TRUE-HEARTED":[{"def":"Of a faithful heart; honest; sincere; not faithless or deceitful; as, a truhearted friend.","pos":""}],"TRUE-PENNY":[{"def":"An honest fellow.","pos":""}],"TRUELOVE":[{"def":"One really beloved.","pos":""},{"def":"An unexplained word occurring in Chaucer, meaning, perhaps, an aromatic sweetmeat for sweetening the breath.","pos":""}],"TRUENESS":[{"def":"The quality of being true; reality; genuineness; faithfulness; sincerity; exactness; truth.","pos":""}],"TRUFFLE":[{"def":"Any one of several kinds of roundish, subterranean fungi, usually of a blackish color.","pos":""}],"TRUFFLED":[{"def":"Provided or cooked with truffles; stuffed with truffles; as, a truffled turkey.","pos":""}],"TRUG":[{"def":"A trough, or tray.","pos":""},{"def":"A concubine; a harlot.","pos":""}],"TRUISM":[{"def":"An undoubted or self-evident truth; a statement which is pliantly true; a proposition needing no proof or argument; -- opposed to falsism.","pos":""}],"TRUISMATIC":[{"def":"Of or pertaining to truisms; consisting of truisms.","pos":""}],"TRUITE":[{"def":"Having a delicately crackled surface; --applied to porcelian, etc.","pos":""}],"TRULL":[{"def":"A drab; a strumpet; a harlot; a trollop.","pos":""},{"def":"A girl; a wench; a lass.","pos":""}],"TRULLIZATION":[{"def":"The act of laying on coats of plaster with a trowel.","pos":""}],"TRULY":[{"def":"In a true manner; according to truth; in agreement with fact; as, to state things truly; the facts are truly represented.","pos":""},{"def":"Exactly; justly; precisely; accurately; as, to estimate truly the weight of evidence.","pos":""}],"TRUMP":[{"def":"A wind instrument of music; a trumpet, or sound of a trumpet; - - used chiefly in Scripture and poetry.","pos":""}],"TRUMPERY":[{"def":"Something serving to deceive by false show or pretense; falsehood; deceit; worthless but showy matter; hence, things worn out and of no value; rubbish.","pos":""}],"TRUMPET":[{"def":"A wind instrument of great antiquity, much used in war and military exercises, and of great value in the orchestra.","pos":""}],"TRUMPET-SHAPED":[{"def":"Tubular with one end dilated, as the flower of the trumpet creeper.","pos":""}],"TRUMPET-TONGUED":[{"def":"Having a powerful, far-reaching voice or speech.","pos":""}],"TRUMPETER":[{"def":"A large edible fish (Latris hecateia) of the family Cirrhitidæ, native of Tasmania and New Zealand.","pos":""}],"TRUMPETING":[{"def":"A channel cut behind the brick lining of a shaft.","pos":""}],"TRUMPETS":[{"def":"A plant (Sarracenia flava) with long, hollow leaves.","pos":""}],"TRUMPETWOOD":[{"def":"A tropical American tree (Cecropia peltata) of the Breadfruit family, having hollow stems, which are used for wind instruments; -- called also snakewood, and trumpet tree.","pos":""}],"TRUMPIE":[{"def":"The Richardson's skua (Stercorarius parasiticus).","pos":""}],"TRUMPLIKE":[{"def":"Resembling a trumpet, esp.","pos":""}],"TRUNCAL":[{"def":"Of or pertaining to the trunk, or body.","pos":""}],"TRUNCATE":[{"def":"To cut off; to lop; to maim.","pos":""}],"TRUNCATED":[{"def":"Replaced, or cut off, by a plane, especially when equally inclined to the adjoining faces; as, a truncated edge.","pos":""},{"def":"Lacking the apex; -- said of certain spiral shells in which the apex naturally drops off.","pos":""}],"TRUNCATION":[{"def":"The replacement of an edge or solid angle by a plane, especially when the plane is equally inclined to the adjoining faces.","pos":""}],"TRUNCH":[{"def":"A stake; a small post.","pos":""}],"TRUNCHEON":[{"def":"A short staff, a club; a cudgel; a shaft of a spear.","pos":""},{"def":"A baton, or military staff of command.","pos":""}],"TRUNCHEONED":[{"def":"Having a truncheon.","pos":""}],"TRUNCHEONEER":[{"def":"A person armed with a truncheon.","pos":""}],"TRUNCUS":[{"def":"The thorax of an insect.","pos":""}],"TRUNDLE":[{"def":"A round body; a little wheel.","pos":""},{"def":"A lind of low-wheeled cart; a truck.","pos":""}],"TRUNDLE-BED":[{"def":"A low bed that is moved on trundles, or little wheels, so that it can be pushed under a higher bed; a truckle-bed; also, sometimes, a simiral bed without wheels.","pos":""}],"TRUNDLEHEAD":[{"def":"One of the disks forming the ends of a lantern wheel or pinion.","pos":""}],"TRUNDLETAIL":[{"def":"A round or curled-up tail; also, a dog with such a tail.","pos":""}],"TRUNK":[{"def":"That part of a pilaster which is between the base and the capital, corresponding to the shaft of a column.","pos":""},{"def":"That segment of the body of an insect which is between the head and abdomen, and bears the wings and legs; the thorax; the truncus.","pos":""}],"TRUNK ENGINE":[{"def":"An engine having a trunk piston, as most internal combustion engines.","pos":""}],"TRUNK PISTON":[{"def":"In a single-acting engine, an elongated hollow piston, open at the end, in which the end of the connecting rod is pivoted.","pos":""}],"TRUNK STEAMER":[{"def":"A freight steamer having a high hatch coaming extending almost continuously fore and aft, but not of whaleback form at the sides.","pos":""}],"TRUNKBACK":[{"def":"The leatherback.","pos":""}],"TRUNKED":[{"def":"Having (such) a trunk.","pos":""}],"TRUNKFISH":[{"def":"Any one of several species of plectognath fishes, belonging to the genus Ostracion, or the family Ostraciontidæ, having an angular body covered with a rigid integument consisting of bony scales.","pos":""}],"TRUNKFUL":[{"def":"As much as a trunk will hold; enough to fill a trunk.","pos":""}],"TRUNKWORK":[{"def":"Work or devices suitable to be concealed; a secret stratagem.","pos":""}],"TRUNNION":[{"def":"A cylindrical projection on each side of a piece, whether gun, mortar, or howitzer, serving to support it on the cheeks of the carriage.","pos":""},{"def":"A gudgeon on each side of an oscillating steam cylinder, to support it.","pos":""}],"TRUNNIONED":[{"def":"Provided with trunnions; as, the trunnioned cylinder of an oscillating steam engine.","pos":""}],"TRUSION":[{"def":"The act of pushing or thrusting.","pos":""}],"TRUSS":[{"def":"A bandage or apparatus used in cases of hernia, to keep up the reduced parts and hinder further protrusion, and for other purposes.","pos":""},{"def":"A tuft of flowers formed at the top of the main stalk, or stem, of certain plants.","pos":""}],"TRUSSING":[{"def":"The timbers, etc.","pos":""},{"def":"The art of stiffening or bracing a set of timbers, or the like, by putting in struts, ties, etc.","pos":""}],"TRUST":[{"def":"Assured resting of the mind on the integrity, veracity, justice, friendship, or other sound principle, of another person; confidence; reliance; reliance.","pos":""},{"def":"Credit given; especially, delivery of property or merchandise in reliance upon future payment; exchange without immediate receipt of an equivalent; as, to sell or buy goods on trust.","pos":""}],"TRUST COMPANY":[{"def":"Any corporation formed for the purpose of acting as trustee.","pos":""}],"TRUSTEE":[{"def":"A person to whom property is legally committed in trust, to be applied either for the benefit of specified individuals, or for public uses; one who is intrusted with property for the benefit of another; also, a person in whose hands the effects of another are attached in a trustee process.","pos":""}],"TRUSTEE PROCESS":[{"def":"The process of attachment by garnishment.","pos":""}],"TRUSTEE STOCK":[{"def":"High-grade stock in which trust funds may be legally invested.","pos":""}],"TRUSTEESHIP":[{"def":"The office or duty of a trustee.","pos":""}],"TRUSTER":[{"def":"One who makes a trust; -- the correlative of trustee.","pos":""}],"TRUSTFUL":[{"def":"Full of trust; trusting.","pos":""},{"def":"Worthy of trust; faithful; trusty; trustworthy.","pos":""}],"TRUSTILY":[{"def":"In a trusty manner.","pos":""}],"TRUSTINESS":[{"def":"The quality or state of being trusty.","pos":""}],"TRUSTING":[{"def":"Having or exercising trust; confiding; unsuspecting; trustful.","pos":""}],"TRUSTLESS":[{"def":"That may not be trusted; not worthy of trust; unfaithful.","pos":""}],"TRUSTWORTHY":[{"def":"Worthy of trust or confidence; trusty.","pos":""}],"TRUSTY":[{"def":"Admitting of being safely trusted; justly deserving confidence; fit to be confided in; trustworthy; reliable.","pos":""},{"def":"Hence, not liable to fail; strong; firm.","pos":""}],"TRUTH":[{"def":"The quality or being true; as: -- (a) Conformity to fact or reality; exact accordance with that which is, or has been; or shall be.","pos":""},{"def":"That which is true or certain concerning any matter or subject, or generally on all subjects; real state of things; fact; verity; reality.","pos":""}],"TRUTH-LOVER":[{"def":"One who loves the truth.","pos":""}],"TRUTH-TELLER":[{"def":"One who tells the truth.","pos":""}],"TRUTHFUL":[{"def":"Full of truth; veracious; reliable.","pos":""}],"TRUTHLESS":[{"def":"Devoid of truth; dishonest; dishonest; spurious; faithless.","pos":""}],"TRUTHY":[{"def":"Truthful; likely; probable.","pos":""}],"TRUTINATION":[{"def":"The act of weighing.","pos":""}],"TRUTTACEOUS":[{"def":"Of, pertaining to, or resembling, a trout; as, fish of the truttaceous kind.","pos":""}]}