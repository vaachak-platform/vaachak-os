{"RESAIL":[{"def":"To sail again; also, to sail back, as to a former port.","pos":""}],"RESALE":[{"def":"A sale at second hand, or at retail; also, a second sale.","pos":""}],"RESALGAR":[{"def":"Re*sal\"gar (r-sl\"gr), n.","pos":""}],"RESALUTE":[{"def":"To salute again.","pos":""}],"RESAW":[{"def":"To saw again; specifically, to saw a balk, or a timber, which has already been squared, into dimension lumber, as joists, boards, etc.","pos":""}]}