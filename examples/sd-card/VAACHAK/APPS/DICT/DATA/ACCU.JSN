{"ACCUBATION":[{"def":"The act or posture of reclining on a couch, as practiced by the ancients at meals.","pos":""}],"ACCUMB":[{"def":"To recline, as at table.","pos":""}],"ACCUMBENCY":[{"def":"The state of being accumbent or reclining.","pos":""}],"ACCUMBENT":[{"def":"Lying against anything, as one part of a leaf against another leaf.","pos":""}],"ACCUMULATE":[{"def":"To heap up in a mass; to pile up; to collect or bring together; to amass; as, to accumulate a sum of money.","pos":""}],"ACCUMULATION":[{"def":"The concurrence of several titles to the same proof.","pos":""}],"ACCUMULATIVE":[{"def":"Characterized by accumulation; serving to collect or amass; cumulative; additional.","pos":""}],"ACCUMULATOR":[{"def":"An apparatus by means of which energy or power can be stored, such as the cylinder or tank for storing water for hydraulic elevators, the secondary or storage battery used for accumulating the energy of electrical charges, etc.","pos":""}],"ACCURACY":[{"def":"The state of being accurate; freedom from mistakes, this exemption arising from carefulness; exact conformity to truth, or to a rule or model; precision; exactness; nicety; correctness; as, the value of testimony depends on its accuracy.","pos":""}],"ACCURATE":[{"def":"In exact or careful conformity to truth, or to some standard of requirement, the result of care or pains; free from failure, error, or defect; exact; as, an accurate calculator; an accurate measure; accurate expression, knowledge, etc.","pos":""},{"def":"Precisely fixed; executed with care; careful.","pos":""}],"ACCURATELY":[{"def":"In an accurate manner; exactly; precisely; without error or defect.","pos":""}],"ACCURATENESS":[{"def":"The state or quality of being accurate; accuracy; exactness; nicety; precision.","pos":""}],"ACCURSE":[{"def":"To devote to destruction; to imprecate misery or evil upon; to curse; to execrate; to anathematize.","pos":""},{"def":"Doomed to destruction or misery; cursed; hence, bad enough to be under the curse; execrable; detestable; exceedingly hateful; -- as, an accursed deed.","pos":""}],"ACCUSABLE":[{"def":"Liable to be accused or censured; chargeable with a crime or fault; blamable; -- with of.","pos":""}],"ACCUSATION":[{"def":"The act of accusing or charging with a crime or with a lighter offense.","pos":""},{"def":"That of which one is accused; the charge of an offense or crime, or the declaration containing the charge.","pos":""}],"ACCUSATIVAL":[{"def":"Pertaining to the accusative case.","pos":""}],"ACCUSATIVE":[{"def":"Applied to the case (as the fourth case of Latin and Greek nouns) which expresses the immediate object on which the action or influence of a transitive verb terminates, or the immediate object of motion or tendency to, expressed by a preposition.","pos":""}],"ACCUSATIVELY":[{"def":"In an accusative manner.","pos":""},{"def":"In relation to the accusative case in grammar.","pos":""}],"ACCUSATORIALLY":[{"def":"By way accusation.","pos":""}],"ACCUSATORY":[{"def":"Pertaining to, or containing, an accusation; as, an accusatory libel.","pos":""}],"ACCUSE":[{"def":"to charge with an offense, judicially or by a public process; - - with of; as, to accuse one of a high crime or misdemeanor.","pos":""}],"ACCUSED":[{"def":"Charged with offense; as, an accused person.","pos":""}],"ACCUSER":[{"def":"One who accuses; one who brings a charge of crime or fault.","pos":""}],"ACCUSINGLY":[{"def":"In an accusing manner.","pos":""}],"ACCUSTOM":[{"def":"To make familiar by use; to habituate, familiarize, or inure; - - with to.","pos":""}],"ACCUSTOMABLE":[{"def":"Habitual; customary; wonted.","pos":""}],"ACCUSTOMABLY":[{"def":"According to custom; ordinarily; customarily.","pos":""}],"ACCUSTOMANCE":[{"def":"Custom; habitual use.","pos":""}],"ACCUSTOMARILY":[{"def":"Ac*cus\"tom*a*ri*ly, adv.","pos":""}],"ACCUSTOMARY":[{"def":"Usual; customary.","pos":""}],"ACCUSTOMED":[{"def":"Familiar through use; usual; customary.","pos":""},{"def":"Frequented by customers.","pos":""}],"ACCUSTOMEDNESS":[{"def":"Accustomedness to sin hardens the heart.","pos":""}]}