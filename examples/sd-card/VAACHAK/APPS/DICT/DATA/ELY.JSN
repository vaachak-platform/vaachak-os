{"ELYSIAN":[{"def":"Pertaining, or the abode of the blessed after death; hence, yielding the highest pleasures; exceedingly delightful; beatific.","pos":""}],"ELYSIUM":[{"def":"A dwelling place assigned to happy souls after death; the seat of future happiness; Paradise.","pos":""},{"def":"Hence, any delightful place.","pos":""}],"ELYTRIFORM":[{"def":"Having the form, or structure, of an elytron.","pos":""}],"ELYTROID":[{"def":"Resembling a beetle's wing case.","pos":""}]}