{"DREAD":[{"def":"To fear in a great degree; to regard, or look forward to, with terrific apprehension.","pos":""}],"DREAD-BOLTED":[{"def":"Armed with dreaded bolts.","pos":""}],"DREADABLE":[{"def":"Worthy of being dreaded.","pos":""}],"DREADER":[{"def":"One who fears, or lives in fear.","pos":""}],"DREADFUL":[{"def":"Full of dread or terror; fearful.","pos":""},{"def":"Inspiring dread; impressing great fear; fearful; terrible; as, a dreadful storm.","pos":""}],"DREADFULLY":[{"def":"In a dreadful manner; terribly.","pos":""}],"DREADFULNESS":[{"def":"The quality of being dreadful.","pos":""}],"DREADLESS":[{"def":"Free from dread; fearless; intrepid; dauntless; as, dreadless heart.","pos":""},{"def":"Exempt from danger which causes dread; secure.","pos":""}],"DREADLESSNESS":[{"def":"Freedom from dread.","pos":""}],"DREADNAUGHT":[{"def":"A fearless person.","pos":""},{"def":"Hence: A garment made of very thick cloth, that can defend against storm and cold; also, the cloth itself; fearnaught.","pos":""}],"DREADNOUGHT":[{"def":"A British battleship, completed in 1906 -- 1907, having an armament consisting of ten 12-inch guns, and of twenty-four 12-pound quick-fire guns for protection against torpedo boats.","pos":""},{"def":"Any battleship having its main armament entirely of big guns all of one caliber.","pos":""}],"DREAM":[{"def":"The thoughts, or series of thoughts, or imaginary transactions, which occupy the mind during sleep; a sleeping vision.","pos":""},{"def":"A visionary scheme; a wild conceit; an idle fancy; a vagary; a revery; -- in this sense, applied to an imaginary or anticipated state of happiness; as, a dream of bliss; the dream of his youth.","pos":""}],"DREAMER":[{"def":"A visionary; one lost in wild imaginations or vain schemes of some anticipated good; as, a political dreamer.","pos":""}],"DREAMILY":[{"def":"As if in a dream; softly; slowly; languidly.","pos":""}],"DREAMINESS":[{"def":"The state of being dreamy.","pos":""}],"DREAMINGLY":[{"def":"In a dreamy manner.","pos":""}],"DREAMLAND":[{"def":"An unreal, delightful country such as in sometimes pictured in dreams; region of fancies; fairyland.","pos":""}],"DREAMLESS":[{"def":"Free from, or without, dreams.","pos":""}],"DREAMY":[{"def":"Abounding in dreams or given to dreaming; appropriate to, or like, dreams; visionary.","pos":""}],"DREAR":[{"def":"Dismal; gloomy with solitude.","pos":""}],"DREARILY":[{"def":"Gloomily; dismally.","pos":""}],"DREARINESS":[{"def":"Sorrow; wretchedness.","pos":""},{"def":"Dismalness; gloomy solitude.","pos":""}],"DREARY":[{"def":"Sorrowful; distressful.","pos":""},{"def":"Exciting cheerless sensations, feelings, or associations; comfortless; dismal; gloomy.","pos":""}],"DRECCHE":[{"def":"To vex; to torment; to trouble.","pos":""}],"DREDGE":[{"def":"Very fine mineral matter held in suspension in water.","pos":""}],"DREDGER":[{"def":"One who fishes with a dredge.","pos":""},{"def":"A dredging machine.","pos":""}],"DREE":[{"def":"To endure; to suffer.","pos":""}],"DREG":[{"def":"Corrupt or defiling matter contained in a liquid, or precipitated from it; refuse; feculence; lees; grounds; sediment; hence, the vilest and most worthless part of anything; as, the dregs of society.","pos":""}],"DREGGINESS":[{"def":"Fullness of dregs or lees; foulness; feculence.","pos":""}],"DREGGISH":[{"def":"Foul with lees; feculent.","pos":""}],"DREGGY":[{"def":"Containing dregs or lees; muddy; foul; feculent.","pos":""}],"DREIBUND":[{"def":"A triple alliance; specif.","pos":""}],"DREIN":[{"def":"DREINTE; DREINT Drein\"te, imp.","pos":""}],"DREISSENA":[{"def":"A genus of bivalve shells of which one species (D.","pos":""}],"DRENCH":[{"def":"To cause to drink; especially, to dose by force; to put a potion down the throat of, as of a horse; hence.","pos":""},{"def":"To steep in moisture; to wet thoroughly; to soak; to saturate with water or other liquid; to immerse.","pos":""}],"DRENCHE":[{"def":"In the sea he drenched.","pos":""}],"DRENCHER":[{"def":"One who, or that which, west or steeps.","pos":""},{"def":"One who administers a drench.","pos":""}],"DRENGAGE":[{"def":"The tenure by which a drench held land.","pos":""}],"DRENT":[{"def":"Drenched; drowned.","pos":""}],"DRESDEN WARE":[{"def":"A superior kind of decorated porcelain made near Dresden in Saxony.","pos":""}],"DRESS":[{"def":"To arrange in exact continuity of line, as soldiers; commonly to adjust to a straight line and at proper distance; to align; as, to dress the ranks.","pos":""},{"def":"To treat methodically with remedies, bandages, or curative appliances, as a sore, an ulcer, a wound, or a wounded or diseased part.","pos":""}],"DRESS CIRCLE":[{"def":"A gallery or circle in a theater, generally the first above the floor, in which originally dress clothes were customarily worn.","pos":""}],"DRESS COAT":[{"def":"A coat with skirts behind only, as distinct from the frock coat, of which the skirts surround the body.","pos":""}],"DRESS GOODS":[{"def":"A term applied to fabrics for the gowns of women and girls; -- most commonly to fabrics of mixed materials, but also applicable to silks, printed linens, and calicoes.","pos":""}],"DRESSER":[{"def":"A kind of pick for shaping large coal.","pos":""}],"DRESSINESS":[{"def":"The state of being dressy.","pos":""}],"DRESSING":[{"def":"An application (a remedy, bandage, etc.","pos":""}],"DRESSMAKER":[{"def":"A maker of gowns, or similar garments; a mantuamaker.","pos":""}],"DRESSMAKING":[{"def":"The art, process, or occupation, of making dresses.","pos":""}],"DRESSY":[{"def":"Showy in dress; attentive to dress.","pos":""}],"DREVIL":[{"def":"A fool; a drudge.","pos":""}],"DREY":[{"def":"A squirrel's nest.","pos":""}],"DREYE":[{"def":"DREYNTE; DREYNT Dreyn\"te, imp.","pos":""}]}