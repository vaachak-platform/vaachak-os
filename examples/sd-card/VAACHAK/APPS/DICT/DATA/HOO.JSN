{"HOO":[{"def":"A termination denoting state, condition, quality, character, totality, as in manhood, childhood, knighthood, brotherhood.","pos":""}],"HOOD":[{"def":"The endmost plank of a strake which reaches the stem or stern.","pos":""}],"HOODCAP":[{"def":"See Hooded seal, under Hooded.","pos":""}],"HOODED":[{"def":"Covered with a hood.","pos":""},{"def":"Furnished with a hood or something like a hood.","pos":""}],"HOODLUM":[{"def":"A young rowdy; a rough, lawless fellow.","pos":""}],"HOODMAN":[{"def":"The person blindfolded in the game called hoodman-blind.","pos":""}],"HOODMAN-BLIND":[{"def":"An old term for blindman's buff.","pos":""},{"def":"A projecting molding over the head of an arch, forming the outermost member of the archivolt; -- called also hood mold.","pos":""}],"HOODOO":[{"def":"One who causes bad luck.","pos":""}],"HOODWINK":[{"def":"To blind by covering the eyes.","pos":""},{"def":"To cover; to hide.","pos":""}],"HOODY":[{"def":"The hooded crow; also, in Scotland, the hooded gull.","pos":""}],"HOOF":[{"def":"The horny substance or case that covers or terminates the feet of certain animals, as horses, oxen, etc.","pos":""},{"def":"A hoofed animal; a beast.","pos":""}],"HOOFBOUND":[{"def":"Having a dry and contracted hoof, which occasions pain and lameness.","pos":""}],"HOOFED":[{"def":"Furnished with hoofs.","pos":""}],"HOOFLESS":[{"def":"Destitute of hoofs.","pos":""}],"HOOK":[{"def":"See Eccentric, and V-hook.","pos":""},{"def":"The projecting points of the thigh bones of cattle; -- called also hook bones.","pos":""}],"HOOK-BILLED":[{"def":"Having a strongly curved bill.","pos":""}],"HOOK-NOSED":[{"def":"Having a hooked or aquiline nose.","pos":""}],"HOOKAH":[{"def":"A pipe with a long, flexible stem, so arranged that the smoke is cooled by being made to pass through water.","pos":""}],"HOOKE'S GEARING":[{"def":"Spur gearing having teeth slanting across the face of the wheel, sometimes slanting in opposite directions from the middle.","pos":""}],"HOOKE'S JOINT":[{"def":"A universal joint.","pos":""}],"HOOKED":[{"def":"Having the form of a hookl curvated; as, the hooked bill of a bird.","pos":""},{"def":"Provided with a hook or hooks.","pos":""}],"HOOKEDNESS":[{"def":"The state of being bent like a hook; incurvation.","pos":""}],"HOOKER":[{"def":"One who, or that which, hooks.","pos":""}],"HOOKY":[{"def":"Full of hooks; pertaining to hooks.","pos":""}],"HOOLOCK":[{"def":"A small black gibbon (Hylobates hoolock), found in the mountains of Assam.","pos":""}],"HOONOOMAUN":[{"def":"An Indian monkey.","pos":""}],"HOOP":[{"def":"A pliant strip of wood or metal bent in a circular form, and united at the ends, for holding together the staves of casks, tubs, etc.","pos":""},{"def":"A ring; a circular band; anything resembling a hoop, as the cylinder (cheese hoop) in which the curd is pressed in making cheese.","pos":""}],"HOOPER":[{"def":"One who hoops casks or tubs; a cooper.","pos":""}],"HOOSIER":[{"def":"A nickname given to an inhabitant of the State of Indiana.","pos":""}],"HOOSIER STATE":[{"def":"Indiana; -- a nickname of obscure origin.","pos":""}],"HOOT":[{"def":"To cry out or shout in contempt.","pos":""},{"def":"To make the peculiar cry of an owl.","pos":""}],"HOOVE":[{"def":"A disease in cattle consisting in inflammation of the stomach by gas, ordinarily caused by eating too much green food; tympany; bloating.","pos":""},{"def":"Affected with hoove; as, hooven, or hoven, cattle.","pos":""}]}