{"OSMANLI":[{"def":"A Turkish official; one of the dominant tribe of Turks; loosely, any Turk.","pos":""}],"OSMATE":[{"def":"A salt of osmic acid.","pos":""}],"OSMATERIUM":[{"def":"One of a pair of scent organs which the larvæ of certain butterflies emit from the first body segment, either above or below.","pos":""}],"OSMAZOME":[{"def":"A substance formerly supposed to give to soup and broth their characteristic odor, and probably consisting of one or several of the class of nitrogenous substances which are called extractives.","pos":""}],"OSMIAMATE":[{"def":"A salt of osmiamic acid.","pos":""}],"OSMIAMIC":[{"def":"Of, pertaining to, or designating, a nitrogenous acid of osmium, H2N2Os2O5, forming a well-known series of yellow salts.","pos":""}],"OSMIC":[{"def":"Pertaining to, derived from, or containing, osmium; specifically, designating those compounds in which it has a valence higher than in other lower compounds; as, osmic oxide.","pos":""}],"OSMIDROSIS":[{"def":"The secretion of fetid sweat.","pos":""}],"OSMIOUS":[{"def":"Denoting those compounds of osmium in which the element has a valence relatively lower than in the osmic compounds; as, osmious chloride.","pos":""}],"OSMITE":[{"def":"A salt of osmious acid.","pos":""}],"OSMIUM":[{"def":"A rare metallic element of the platinum group, found native as an alloy in platinum ore, and in iridosmine.","pos":""}],"OSMOGENE":[{"def":"An apparatus, consisting of a number of cells whose sides are of parchment paper, for conducting the process of osmosis.","pos":""}],"OSMOGRAPH":[{"def":"An instrument for recording the height of the liquid in an endosmometer or for registering osmotic pressures.","pos":""}],"OSMOMETER":[{"def":"An instrument for measuring the amount of osmotic action in different liquids.","pos":""}],"OSMOMETRY":[{"def":"The study of osmose by means of the osmometer.","pos":""}],"OSMOSE":[{"def":"Electric endosmose (Elec.","pos":""}],"OSMOTIC":[{"def":"Pertaining to, or having the property of, osmose; as, osmotic force.","pos":""}],"OSMUND":[{"def":"A fern of the genus Osmunda, or flowering fern.","pos":""}]}