{"AND":[{"def":"A particle which expresses the relation of connection or addition.","pos":""},{"def":"In order to; -- used instead of the infinitival to, especially after try, come, go.","pos":""}],"ANDABATISM":[{"def":"Doubt; uncertainty.","pos":""}],"ANDALUSITE":[{"def":"A silicate of aluminium, occurring usually in thick rhombic prisms, nearly square, of a grayish or pale reddish tint.","pos":""}],"ANDANTE":[{"def":"Moving moderately slow, but distinct and flowing; quicker than larghetto, and slower than allegretto.","pos":""},{"def":"A movement or piece in andante time.","pos":""}],"ANDANTINO":[{"def":"Rather quicker than andante; between that allegretto.","pos":""}],"ANDEAN":[{"def":"Pertaining to the Andes.","pos":""}],"ANDESINE":[{"def":"A kind of triclinic feldspar found in the Andes.","pos":""}],"ANDESITE":[{"def":"An eruptive rock allied to trachyte, consisting essentially of a triclinic feldspar, with pyroxene, hornblende, or hypersthene.","pos":""}],"ANDINE":[{"def":"Andean; as, Andine flora.","pos":""}],"ANDIRON":[{"def":"A utensil for supporting wood when burning in a fireplace, one being placed on each side; a firedog; as, a pair of andirons.","pos":""}],"ANDRANATOMY":[{"def":"The dissection of a human body, especially of a male; androtomy.","pos":""}],"ANDROCEPHALOUS":[{"def":"Having a human head (upon an animal's body), as the Egyptian sphinx.","pos":""},{"def":"Having perfect and staminate flowers on different plants.","pos":""}],"ANDROECIUM":[{"def":"The stamens of a flower taken collectively.","pos":""}],"ANDROGYNE":[{"def":"An androgynous plant.","pos":""},{"def":"Bearing both staminiferous and pistilliferous flowers in the same cluster.","pos":""}],"ANDROID":[{"def":"Resembling a man.","pos":""},{"def":"A machine or automaton in the form of a human being.","pos":""}],"ANDROMEDA":[{"def":"A northern constellation, supposed to represent the mythical Andromeda.","pos":""},{"def":"A genus of ericaceous flowering plants of northern climates, of which the original species was found growing on a rock surrounded by water.","pos":""}],"ANDRON":[{"def":"The apartment appropriated for the males.","pos":""}],"ANDROPETALOUS":[{"def":"Produced by the conversion of the stamens into petals, as double flowers, like the garden ranunculus.","pos":""}],"ANDROPHAGI":[{"def":"Cannibals; man-eaters; anthropophagi.","pos":""}],"ANDROPHAGOUS":[{"def":"Anthropophagous.","pos":""}],"ANDROPHORE":[{"def":"A support or column on which stamens are raised.","pos":""},{"def":"The part which in some Siphonophora bears the male gonophores.","pos":""}],"ANDROPOGON":[{"def":"A very large and important genus of grasses, found in nearly all parts of the world.","pos":""}],"ANDROSPHINX":[{"def":"A man sphinx; a sphinx having the head of a man and the body of a lion.","pos":""}],"ANDROSPORE":[{"def":"A spore of some algæ, which has male functions.","pos":""}],"ANDROTOMOUS":[{"def":"Having the filaments of the stamens divided into two parts.","pos":""}],"ANDROTOMY":[{"def":"Dissection of the human body, as distinguished from zoötomy; anthropotomy.","pos":""}],"ANDROUS":[{"def":"A terminal combining form: Having a stamen or stamens; staminate; as, monandrous, with one stamen; polyandrous, with many stamens.","pos":""}]}