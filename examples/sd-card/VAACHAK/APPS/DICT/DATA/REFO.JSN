{"REFOCILLATE":[{"def":"To refresh; to revive.","pos":""}],"REFOCILLATION":[{"def":"Restoration of strength by refreshment.","pos":""}],"REFOMENT":[{"def":"Re`fo*ment\" (r`f*mnt\"), v.","pos":""}],"REFOREST":[{"def":"To replant with trees; to reafforest; to reforestize.","pos":""}],"REFORESTIZATION":[{"def":"The act or process of reforestizing.","pos":""}],"REFORESTIZE":[{"def":"To convert again into a forest; to plant again with trees.","pos":""}],"REFORGE":[{"def":"To forge again or anew; hence, to fashion or fabricate anew; to make over.","pos":""}],"REFORGER":[{"def":"One who reforges.","pos":""}],"REFORM":[{"def":"To put into a new and improved form or condition; to restore to a former good state, or bring from bad to good; to change from worse to better; to amend; to correct; as, to reform a profligate man; to reform corrupt manners or morals.","pos":""}],"REFORMABLE":[{"def":"Capable of being reformed.","pos":""}],"REFORMADE":[{"def":"Ref`or*made\" (rf`r*md\"), n.","pos":""}],"REFORMADO":[{"def":"A monk of a reformed order.","pos":""},{"def":"An officer who, in disgrace, is deprived of his command, but retains his rank, and sometimes his pay.","pos":""}],"REFORMALIZE":[{"def":"To affect reformation; to pretend to correctness.","pos":""}],"REFORMATION":[{"def":"The act of reforming, or the state of being reformed; change from worse to better; correction or amendment of life, manners, or of anything vicious or corrupt; as, the reformation of manners; reformation of the age; reformation of abuses.","pos":""},{"def":"Specifically (Eccl.","pos":""}],"REFORMATIVE":[{"def":"Forming again; having the quality of renewing form; reformatory.","pos":""}],"REFORMATORY":[{"def":"Tending to produce reformation; reformative.","pos":""}],"REFORMED":[{"def":"Retained in service on half or full pay after the disbandment of the company or troop; -- said of an officer.","pos":""}],"REFORMER":[{"def":"One of those who commenced the reformation of religion in the sixteenth century, as Luther, Melanchthon, Zwingli, and Calvin.","pos":""}],"REFORMLY":[{"def":"In the manner of a reform; for the purpose of reform.","pos":""}],"REFORTIFICATION":[{"def":"A fortifying anew, or a second time.","pos":""}],"REFORTIFY":[{"def":"To fortify anew.","pos":""}],"REFOSSION":[{"def":"The act of digging up again.","pos":""}],"REFOUND":[{"def":"To found or cast anew.","pos":""}],"REFOUNDER":[{"def":"One who refounds.","pos":""}]}