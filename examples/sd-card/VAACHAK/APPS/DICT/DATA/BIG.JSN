{"BIG":[{"def":"Barley, especially the hardy four-rowed kind.","pos":""}],"BIG BEND STATE":[{"def":"Tennessee; -- a nickname.","pos":""}],"BIG-BELLIED":[{"def":"Having a great belly; as, a big-bellied man or flagon; advanced in pregnancy.","pos":""}],"BIG-WIGGED":[{"def":"characterized by pomposity of manner.","pos":""}],"BIGA":[{"def":"A two-horse chariot.","pos":""}],"BIGAMIST":[{"def":"One who is guilty of bigamy.","pos":""}],"BIGAMOUS":[{"def":"Guilty of bigamy; involving bigamy; as, a bigamous marriage.","pos":""}],"BIGAMY":[{"def":"The offense of marrying one person when already legally married to another.","pos":""},{"def":"The large white-heart cherry.","pos":""}],"BIGEMINATE":[{"def":"Having a forked petiole, and a pair of leaflets at the end of each division; biconjugate; twice paired; -- said of a decompound leaf.","pos":""}],"BIGENTIAL":[{"def":"Including two tribes or races of men.","pos":""}],"BIGEYE":[{"def":"A fish of the genus Priacanthus, remarkable for the large size of the eye.","pos":""}],"BIGGEN":[{"def":"To make or become big; to enlarge.","pos":""}],"BIGGIN":[{"def":"A child's cap; a hood, or something worn on the head.","pos":""}],"BIGHA":[{"def":"A measure of land in India, varying from a third of an acre to an acre.","pos":""}],"BIGHORN":[{"def":"The Rocky Mountain sheep (Ovis or Caprovis montana).","pos":""}],"BIGHT":[{"def":"A bend in a coast forming an open bay; as, the Bight of Benin.","pos":""},{"def":"The double part of a rope when folded, in distinction from the ends; that is, a round, bend, or coil not including the ends; a loop.","pos":""}],"BIGLANDULAR":[{"def":"Having two glands, as a plant.","pos":""}],"BIGLY":[{"def":"In a tumid, swelling, blustering manner; haughtily; violently.","pos":""}],"BIGNESS":[{"def":"The state or quality of being big; largeness; size; bulk.","pos":""}],"BIGNONIA":[{"def":"A large genus of American, mostly tropical, climbing shrubs, having compound leaves and showy somewhat tubular flowers.","pos":""}],"BIGNONIACEOUS":[{"def":"Of pertaining to, or resembling, the family of plants of which the trumpet flower is an example.","pos":""}],"BIGOT":[{"def":"A hypocrite; esp.","pos":""},{"def":"A person who regards his own faith and views in matters of religion as unquestionably right, and any belief or opinion opposed to or differing from them as unreasonable or wicked.","pos":""}],"BIGOTED":[{"def":"Obstinately and blindly attached to some creed, opinion practice, or ritual; unreasonably devoted to a system or party, and illiberal toward the opinions of others.","pos":""}],"BIGOTEDLY":[{"def":"In the manner of a bigot.","pos":""}],"BIGOTRY":[{"def":"The state of mind of a bigot; obstinate and unreasoning attachment of one's own belief and opinions, with narrow-minded intolerance of beliefs opposed to them.","pos":""},{"def":"The practice or tenets of a bigot.","pos":""}],"BIGWIG":[{"def":"A person of consequence; as, the bigwigs of society.","pos":""}]}