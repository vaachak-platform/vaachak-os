{"SHALE":[{"def":"A fine-grained sedimentary rock of a thin, laminated, and often friable, structure.","pos":""}],"SHALL":[{"def":"To owe; to be under obligation for.","pos":""},{"def":"To be obliged; must.","pos":""}],"SHALLON":[{"def":"An evergreen shrub (Gaultheria Shallon) of Northwest America; also, its fruit.","pos":""}],"SHALLOON":[{"def":"A thin, loosely woven, twilled worsted stuff.","pos":""}],"SHALLOP":[{"def":"Note: The term shallop is applied to boats of all sizes, from a light canoe up to a large boat with masts and sails.","pos":""}],"SHALLOT":[{"def":"A small kind of onion (Allium Ascalonicum) growing in clusters, and ready for gathering in spring; a scallion, or eschalot.","pos":""}],"SHALLOW":[{"def":"Not deep; having little depth; shoal.","pos":""},{"def":"Not deep in tone.","pos":""}],"SHALLOW-BODIED":[{"def":"Having a moderate depth of hold; -- said of a vessel.","pos":""}],"SHALLOW-BRAINED":[{"def":"Weak in intellect; foolish; empty-headed.","pos":""}],"SHALLOW-HEARTED":[{"def":"Incapable of deep feeling.","pos":""}],"SHALLOW-PATED":[{"def":"Shallow-brained.","pos":""}],"SHALLOW-WAISTED":[{"def":"Having a flush deck, or with only a moderate depression amidships; -- said of a vessel.","pos":""}],"SHALLOWLY":[{"def":"In a shallow manner.","pos":""}],"SHALLOWNESS":[{"def":"Quality or state of being shallow.","pos":""}],"SHALT":[{"def":"Shalt, Defn: 2d per.","pos":""}],"SHALY":[{"def":"Resembling shale in structure.","pos":""}]}