{"FEU":[{"def":"A free and gratuitous right to lands made to one for service to be performed by him; a tenure where the vassal, in place of military services, makes a return in grain or in money.","pos":""}],"FEU DE JOIE":[{"def":"A fire kindled in a public place in token of joy; a bonfire; a firing of guns in token of joy.","pos":""}],"FEUAR":[{"def":"One who holds a feu.","pos":""}],"FEUD":[{"def":"A combination of kindred to avenge injuries or affronts, done or offered to any of their blood, on the offender and all his race.","pos":""},{"def":"A contention or quarrel; especially, an inveterate strife between families, clans, or parties; deadly hatred; contention satisfied only by bloodshed.","pos":""}],"FEUDAL":[{"def":"Of or pertaining to feuds, fiefs, or feels; as, feudal rights or services; feudal tenures.","pos":""},{"def":"Consisting of, or founded upon, feuds or fiefs; embracing tenures by military services; as, the feudal system.","pos":""}],"FEUDALISM":[{"def":"The feudal system; a system by which the holding of estates in land is made dependent upon an obligation to render military service to the kind or feudal superior; feudal principles and usages.","pos":""}],"FEUDALIST":[{"def":"An upholder of feudalism.","pos":""}],"FEUDALITY":[{"def":"The state or quality of being feudal; feudal form or constitution.","pos":""}],"FEUDALIZATION":[{"def":"The act of reducing to feudal tenure.","pos":""}],"FEUDALIZE":[{"def":"To reduce toa feudal tenure; to conform to feudalism.","pos":""}],"FEUDALLY":[{"def":"In a feudal manner.","pos":""}],"FEUDARY":[{"def":"Held by, or pertaining to, feudal tenure.","pos":""}],"FEUDATORY":[{"def":"A tenant or vassal who held his lands of a superior on condition of feudal service; the tenant of a feud or fief.","pos":""}],"FEUDIST":[{"def":"A writer on feuds; a person versed in feudal law.","pos":""}],"FEUILLANTS":[{"def":"A reformed branch of the Bernardines, founded in 1577 at Feuillans, near Toulouse, in France.","pos":""}],"FEUILLEMORT":[{"def":"Having the color of a faded leaf.","pos":""}],"FEUILLETON":[{"def":"A part of a French newspaper (usually the bottom of the page), devoted to light literature, criticism, etc.","pos":""}],"FEUILLTONIST":[{"def":"A writer of feuilletons.","pos":""}],"FEUTER":[{"def":"To set close; to fix in rest, as a spear.","pos":""}]}