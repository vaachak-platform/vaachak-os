{"ADEEM":[{"def":"To revoke, as a legacy, grant, etc.","pos":""}],"ADELANTADILLO":[{"def":"A Spanish red wine made of the first ripe grapes.","pos":""}],"ADELANTADO":[{"def":"A governor of a province; a commander.","pos":""}],"ADELASTER":[{"def":"A provisional name for a plant which has not had its flowers botanically examined, and therefore has not been referred to its proper genus.","pos":""}],"ADELING":[{"def":"Same as Atheling.","pos":""}],"ADELOCODONIC":[{"def":"Applied to sexual zooids of hydroids, that have a saclike form and do not become free; -- opposed to phanerocodonic.","pos":""}],"ADELOPOD":[{"def":"An animal having feet that are not apparent.","pos":""}],"ADELPHIA":[{"def":"A \"brotherhood,\" or collection of stamens in a bundle; -- used in composition, as in the class names, Monadelphia, Diadelphia, etc.","pos":""}],"ADELPHOUS":[{"def":"Having coalescent or clustered filaments; -- said of stamens; as, adelphous stamens.","pos":""}],"ADEMPT":[{"def":"Without any sinister suspicion of anything being added or adempt.","pos":""}],"ADEMPTION":[{"def":"The revocation or taking away of a grant donation, legacy, or the like.","pos":""},{"def":"Combining forms of the Greek word for gland; -- used in words relating to the structure, diseases, etc.","pos":""}],"ADEN ULCER":[{"def":"A disease endemic in various parts of tropical Asia, due to a specific microörganism which produces chronic ulcers on the limbs.","pos":""}],"ADENIFORM":[{"def":"Shaped like a gland; adenoid.","pos":""}],"ADENITIS":[{"def":"Glandular inflammation.","pos":""}],"ADENOGRAPHIC":[{"def":"Pertaining to adenography.","pos":""}],"ADENOGRAPHY":[{"def":"That part of anatomy which describes the glands.","pos":""},{"def":"Glandlike; glandular.","pos":""}],"ADENOLOGICAL":[{"def":"Pertaining to adenology.","pos":""}],"ADENOLOGY":[{"def":"The part of physiology that treats of the glands.","pos":""}],"ADENOMA":[{"def":"A benign tumor of a glandlike structure; morbid enlargement of a gland.","pos":""}],"ADENOPATHY":[{"def":"Disease of a gland.","pos":""}],"ADENOPHOROUS":[{"def":"Producing glands.","pos":""}],"ADENOPHYLLOUS":[{"def":"Having glands on the leaves.","pos":""}],"ADENOSCLEROSIS":[{"def":"The hardening of a gland.","pos":""}],"ADENOSE":[{"def":"Like a gland; full of glands; glandulous; adenous.","pos":""}],"ADENOTOMIC":[{"def":"Pertaining to adenotomy.","pos":""}],"ADENOTOMY":[{"def":"Dissection of, or incision into, a gland or glands.","pos":""}],"ADENOUS":[{"def":"Same as Adenose.","pos":""}],"ADEPS":[{"def":"Animal fat; lard.","pos":""}],"ADEPT":[{"def":"One fully skilled or well versed in anything; a proficient; as, adepts in philosophy.","pos":""}],"ADEPTION":[{"def":"An obtaining; attainment.","pos":""}],"ADEPTIST":[{"def":"A skilled alchemist.","pos":""}],"ADEPTNESS":[{"def":"The quality of being adept; skill.","pos":""}],"ADEQUACY":[{"def":"The state or quality of being adequate, proportionate, or sufficient; a sufficiency for a particular purpose; as, the adequacy of supply to the expenditure.","pos":""}],"ADEQUATE":[{"def":"Equal to some requirement; proportionate, or correspondent; fully sufficient; as, powers adequate to a great work; an adequate definition.","pos":""}],"ADEQUATELY":[{"def":"In an adequate manner.","pos":""}],"ADEQUATENESS":[{"def":"The quality of being adequate; suitableness; sufficiency; adequacy.","pos":""}],"ADEQUATION":[{"def":"The act of equalizing; act or result of making adequate; an equivalent.","pos":""}],"ADESMY":[{"def":"The division or defective coherence of an organ that is usually entire.","pos":""}],"ADESSENARIAN":[{"def":"One who held the real presence of Christ's body in the eucharist, but not by transubstantiation.","pos":""}]}