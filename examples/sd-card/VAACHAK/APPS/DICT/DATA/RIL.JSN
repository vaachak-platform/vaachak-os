{"RILE":[{"def":"To render turbid or muddy; to stir up; to roil.","pos":""},{"def":"To stir up in feelings; to make angry; to vex.","pos":""}],"RILIEVO":[{"def":"Same as Relief, n.","pos":"noun"}],"RILL":[{"def":"A very small brook; a streamlet.","pos":""}],"RILLE":[{"def":"One of certain narrow, crooked valleys seen, by aid of the telescope, on the surface of the moon.","pos":""}]}