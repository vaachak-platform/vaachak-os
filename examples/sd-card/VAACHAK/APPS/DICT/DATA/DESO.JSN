{"DESOLATE":[{"def":"Destitute or deprived of inhabitants; deserted; uninhabited; hence, gloomy; as, a desolate isle; a desolate wilderness; a desolate house.","pos":""},{"def":"Laid waste; in a ruinous condition; neglected; destroyed; as, desolate altars.","pos":""}],"DESOLATELY":[{"def":"In a desolate manner.","pos":""}],"DESOLATENESS":[{"def":"The state of being desolate.","pos":""}],"DESOLATER":[{"def":"One who, or that which, desolates or lays waste.","pos":""}],"DESOLATION":[{"def":"The act of desolating or laying waste; destruction of inhabitants; depopulation.","pos":""},{"def":"The state of being desolated or laid waste; ruin; solitariness; destitution; gloominess.","pos":""}],"DESOLATOR":[{"def":"Same as Desolater.","pos":""}],"DESOLATORY":[{"def":"Causing desolation.","pos":""}],"DESOPHISTICATE":[{"def":"To clear from sophism or error.","pos":""}],"DESOXALIC":[{"def":"Made or derived from oxalic acid; as, desoxalic acid.","pos":""}]}