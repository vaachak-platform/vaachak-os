{"PYRIDIC":[{"def":"Related to, or formed from, pyridin or its homologues; as, the pyridic bases.","pos":""}],"PYRIDINE":[{"def":"A nitrogenous base, C5H5N, obtained from the distillation of bone oil or coal tar, and by the decomposition of certain alkaloids, as a colorless liquid with a peculiar pungent odor.","pos":""}],"PYRIDYL":[{"def":"A hypothetical radical, C5H4N, regarded as the essential residue of pyridine, and analogous to phenyl.","pos":""}],"PYRIFORM":[{"def":"Having the form of a pear; pear-shaped.","pos":""}],"PYRITACEOUS":[{"def":"Of or pertaining to pyrites.","pos":""}],"PYRITE":[{"def":"A common mineral of a pale brass-yellow color and brilliant metallic luster, crystallizing in the isometric system; iron pyrites; iron disulphide.","pos":""}],"PYRITES":[{"def":"A name given to a number of metallic minerals, sulphides of iron, copper, cobalt, nickel, and tin, of a white or yellowish color.","pos":""},{"def":"Of or pertaining to pyrites; consisting of, or resembling, pyrites.","pos":""}],"PYRITIFEROUS":[{"def":"Containing or producing pyrites.","pos":""}],"PYRITIZE":[{"def":"To convert into pyrites.","pos":""}],"PYRITOHEDRAL":[{"def":"Like pyrites in hemihedral form.","pos":""}],"PYRITOHEDRON":[{"def":"The pentagonal dodecahedron, a common form of pyrite.","pos":""}],"PYRITOLOGY":[{"def":"The science of blowpipe analysis.","pos":""}],"PYRITOUS":[{"def":"Combining forms designating fire or heat; specifically (Chem.","pos":""}]}