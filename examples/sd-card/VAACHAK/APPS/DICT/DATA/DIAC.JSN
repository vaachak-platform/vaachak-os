{"DIACATHOLICON":[{"def":"A universal remedy; -- name formerly to a purgative electuary.","pos":""}],"DIACAUSTIC":[{"def":"Pertaining to, or possessing the properties of, a species of caustic curves formed by refraction.","pos":""}],"DIACID":[{"def":"Divalent; -- said of a base or radical as capable of saturating two acid monad radicals or a dibasic acid.","pos":""}],"DIACODIUM":[{"def":"A sirup made of poppies.","pos":""}],"DIACONAL":[{"def":"Of or pertaining to a deacon.","pos":""}],"DIACONATE":[{"def":"The office of a deacon; deaconship; also, a body or board of deacons.","pos":""}],"DIACOUSTIC":[{"def":"Pertaining to the science or doctrine of refracted sounds.","pos":""}],"DIACOUSTICS":[{"def":"That branch of natural philosophy which treats of the properties of sound as affected by passing through different mediums; -- called also diaphonics.","pos":""},{"def":"That separates or distinguishes; -- applied to points or marks used to distinguish letters of similar form, or different sounds of the same letter, as, a, â, ä, o, ô, etc.","pos":""}],"DIACTINIC":[{"def":"Capable of transmitting the chemical or actinic rays of light; as, diactinic media.","pos":""}]}