{"INCIDE":[{"def":"To cut; to separate and remove; to resolve or break up, as by medicines.","pos":""}],"INCIDENCE":[{"def":"The direction in which a body, or a ray of light or heat, falls on any surface.","pos":""}],"INCIDENT":[{"def":"Dependent upon, or appertaining to, another thing, called the principal.","pos":""}],"INCIDENTAL":[{"def":"Happening, as an occasional event, without regularity; coming without design; casual; accidental; hence, not of prime concern; subordinate; collateral; as, an incidental conversation; an incidental occurrence; incidental expenses.","pos":""}],"INCINERABLE":[{"def":"Capable of being incinerated or reduced to ashes.","pos":""}],"INCINERATE":[{"def":"Reduced to ashes by burning; thoroughly consumed.","pos":""}],"INCINERATION":[{"def":"The act of incinerating, or the state of being incinerated; cremation.","pos":""},{"def":"Beginning; commencement; incipient state.","pos":""}],"INCIPIENT":[{"def":"Beginning to be, or to show itself; commencing; initial; as, the incipient stage of a fever; incipient light of day.","pos":""}],"INCIRCUMSCRIPTIBLE":[{"def":"Incapable of being circumscribed or limited.","pos":""}],"INCIRCUMSCRIPTION":[{"def":"Condition or quality of being incircumscriptible or limitless.","pos":""}],"INCIRCUMSPECT":[{"def":"Not circumspect; heedless; careless; reckless; impolitic.","pos":""}],"INCIRCUMSPECTION":[{"def":"Want of circumspection.","pos":""}],"INCISE":[{"def":"To cut in or into with a sharp instrument; to carve; to engrave.","pos":""},{"def":"To cut, gash, or wound with a sharp instrument; to cut off.","pos":""}],"INCISED":[{"def":"Having deep and sharp notches, as a leaf or a petal.","pos":""}],"INCISELY":[{"def":"In an incised manner.","pos":""}],"INCISION":[{"def":"The act of incising, or cutting into a substance.","pos":""},{"def":"That which is produced by incising; the separation of the parts of any substance made by a cutting or pointed instrument; a cut; a gash.","pos":""}],"INCISIVE":[{"def":"Of or pertaining to the incisors; incisor; as, the incisive bones, the premaxillaries.","pos":""}],"INCISOR":[{"def":"One of the teeth in front of the canines in either jaw; an incisive tooth.","pos":""}],"INCISORY":[{"def":"Having the quality of cutting; incisor; incisive.","pos":""}],"INCISURE":[{"def":"A cut; an incision; a gash.","pos":""}],"INCITANT":[{"def":"Inciting; stimulating.","pos":""}],"INCITATION":[{"def":"The act of inciting or moving to action.","pos":""},{"def":"That which incites to action; that which rouses or prompts; incitement; motive; incentive.","pos":""}],"INCITATIVE":[{"def":"A provocative; an incitant; a stimulant.","pos":""}],"INCITE":[{"def":"To move to action; to stir up; to rouse; to spur or urge on.","pos":""}],"INCITEMENT":[{"def":"The act of inciting.","pos":""},{"def":"That which incites the mind, or moves to action; motive; incentive; impulse.","pos":""}],"INCITER":[{"def":"One who, or that which, incites.","pos":""}],"INCITINGLY":[{"def":"So as to incite or stimulate.","pos":""}],"INCITO-MOTOR":[{"def":"Inciting to motion; -- applied to that action which, in the case of muscular motion, commences in the nerve centers, and excites the muscles to contraction.","pos":""}],"INCIVILITY":[{"def":"The quality or state of being uncivil; want of courtesy; rudeness of manner; impoliteness.","pos":""},{"def":"Any act of rudeness or ill breeding.","pos":""}],"INCIVILIZATION":[{"def":"The state of being uncivilized; want of civilization; barbarism.","pos":""}],"INCIVISM":[{"def":"Want of civism; want of patriotism or love to one's country; unfriendliness to one's state or government.","pos":""}]}