{"LANGAHA":[{"def":"A curious colubriform snake of the genus Xyphorhynchus, from Madagascar.","pos":""}],"LANGAREY":[{"def":"One of numerous species of long-winged, shrikelike birds of Australia and the East Indies, of the genus Artamus, and allied genera; called also wood swallow.","pos":""}],"LANGATE":[{"def":"A linen roller used in dressing wounds.","pos":""}],"LANGDAK":[{"def":"A wolf (Canis pallipes), found in India, allied to the jackal.","pos":""},{"def":"A kind of shot formerly used at sea for tearing sails and rigging.","pos":""}],"LANGRET":[{"def":"A kind of loaded die.","pos":""}],"LANGRIDGE":[{"def":"Note: [Sometimes compounded with shot.","pos":""}],"LANGSYNE":[{"def":"Long since; long ago.","pos":""}],"LANGTERALOO":[{"def":"An old game at cards.","pos":""}],"LANGUAGE":[{"def":"Any means of conveying or communicating ideas; specifically, human speech; the expression of ideas by the voice; sounds, expressive of thought, articulated by the organs of the throat and mouth.","pos":""},{"def":"The expression of ideas by writing, or any other instrumentality.","pos":""}],"LANGUAGED":[{"def":"Having a language; skilled in language; -- chiefly used in composition.","pos":""}],"LANGUAGELESS":[{"def":"Lacking or wanting language; speechless; silent.","pos":""}],"LANGUE D'OC":[{"def":"The dialect, closely akin to French, formerly spoken south of the Loire (in which the word for \"yes\" was oc); Provencal.","pos":""}],"LANGUE D'OIL":[{"def":"The dialect formerly spoken north of the Loire (in which the word for \"yes\" was oïl, F.","pos":""}],"LANGUED":[{"def":"Tongued; having the tongue visible.","pos":""}],"LANGUENTE":[{"def":"In a languishing manner; pathetically.","pos":""}],"LANGUET":[{"def":"Anything resembling the tongue in form or office; specif.","pos":""},{"def":"That part of the hilt, in certain kinds of swords, which overlaps the scabbard.","pos":""}],"LANGUID":[{"def":"Drooping or flagging from exhaustion; indisposed to exertion; without animation; weak; weary; heavy; dull.","pos":""},{"def":"Slow in progress; tardy.","pos":""}],"LANGUISH":[{"def":"To become languid or weak; to lose strength or animation; to be or become dull, feeble or spiritless; to pine away; to wither or fade.","pos":""},{"def":"To assume an expression of weariness or tender grief, appealing for sympathy.","pos":""}],"LANGUISHER":[{"def":"One who languishes.","pos":""}],"LANGUISHING":[{"def":"Becoming languid and weak; pining; losing health and strength.","pos":""},{"def":"Amorously pensive; as, languishing eyes, or look.","pos":""}],"LANGUISHINGLY":[{"def":"In a languishing manner.","pos":""}],"LANGUISHMENT":[{"def":"The state of languishing.","pos":""},{"def":"Tenderness of look or mien; amorous pensiveness.","pos":""}],"LANGUOR":[{"def":"A state of the body or mind which is caused by exhaustion of strength and characterized by a languid feeling; feebleness; lassitude; laxity.","pos":""},{"def":"Any enfeebling disease.","pos":""}],"LANGUOROUS":[{"def":"Producing, or tending to produce, languor; characterized by languor.","pos":""}],"LANGYA":[{"def":"One of several species of East Indian and Asiatic fresh-water fishes of the genus Ophiocephalus, remarkable for their power of living out of water, and for their tenacity of life; -- called also walking fishes.","pos":""}]}