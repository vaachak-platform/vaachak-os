{"BECALM":[{"def":"To render calm or quiet; to calm; to still; to appease.","pos":""},{"def":"To keep from motion, or stop the progress of, by the stilling of the wind; as, the fleet was becalmed.","pos":""}],"BECARD":[{"def":"A South American bird of the flycatcher family.","pos":""}],"BECAUSE":[{"def":"By or for the cause that; on this account that; for the reason that.","pos":""},{"def":"In order that; that.","pos":""}],"BECCAFICO":[{"def":"Italians for the delicacy of its flesh in the autumn, when it has fed on figs, grapes, etc.","pos":""}],"BECCHI'S TEST":[{"def":"A qualitative test for cottonseed oil, based on the fact this oil imparts a maroon color to an alcoholic solution of silver nitrate.","pos":""}],"BECHAMEL":[{"def":"A rich, white sauce, prepared with butter and cream.","pos":""}],"BECHANCE":[{"def":"By chance; by accident.","pos":""}],"BECHARM":[{"def":"To charm; to captivate.","pos":""}],"BECHIC":[{"def":"Pertaining to, or relieving, a cough.","pos":""},{"def":"A medicine for relieving coughs.","pos":""}],"BECHUANAS":[{"def":"A division of the Bantus, dwelling between the Orange and Zambezi rivers, supposed to be the most ancient Bantu population of South Africa.","pos":""}],"BECK":[{"def":"The brooks, the becks, the rills.","pos":""}],"BECK'S SCALE":[{"def":"A hydrometer scale on which the zero point corresponds to sp.","pos":""}],"BECKER":[{"def":"A European fish (Pagellus centrodontus); the sea bream or braise.","pos":""}],"BECKET":[{"def":"A small grommet, or a ring or loop of rope 2.","pos":""}],"BECKON":[{"def":"To make a significant sign to; hence, to summon, as by a motion of the hand.","pos":""}],"BECLAP":[{"def":"To catch; to grasp; to insnare.","pos":""}],"BECLIP":[{"def":"To embrace; to surround.","pos":""}],"BECLOUD":[{"def":"To cause obscurity or dimness to; to dim; to cloud.","pos":""}],"BECOME":[{"def":"To pass from one state to another; to enter into some state or condition, by a change from another state, or by assuming or receiving new properties or qualities, additional matter, or a new character.","pos":""},{"def":"To come; to get.","pos":""}],"BECOMED":[{"def":"Proper; decorous.","pos":""}],"BECOMING":[{"def":"Appropriate or fit; congruous; suitable; graceful; befitting.","pos":""}],"BECOMINGLY":[{"def":"In a becoming manner.","pos":""}],"BECOMINGNESS":[{"def":"The quality of being becoming, appropriate, or fit; congruity; fitness.","pos":""}],"BECQUEREL RAYS":[{"def":"Radiations first observed by the French physicist Henri Becquerel, in working with uranium and its compounds.","pos":""}],"BECRIPPLE":[{"def":"To make a cripple of; to cripple; to lame.","pos":""},{"def":"The nut of the Brazilian tree Myristica Bicuhyba, which yields a medicinal balsam used for rheumatism.","pos":""}],"BECUNA":[{"def":"A fish of the Mediterranean (Sphyræna spet).","pos":""}],"BECURL":[{"def":"To curl; to adorn with curls.","pos":""}]}