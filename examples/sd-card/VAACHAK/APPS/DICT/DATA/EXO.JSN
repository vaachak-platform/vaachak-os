{"EXOCARP":[{"def":"The outer portion of a fruit, as the flesh of a peach or the rind of an orange.","pos":""}],"EXOCCIPITAL":[{"def":"Pertaining to a bone or region on each side of the great foremen of the skull.","pos":""},{"def":"The exoccipital bone, which often forms a part of the occipital in the adult, but is usually distinct in the young.","pos":""}],"EXOCULATE":[{"def":"To deprive of eyes.","pos":""}],"EXODE":[{"def":"The final chorus; the catastrophe.","pos":""},{"def":"An afterpiece of a comic description, either a farce or a travesty.","pos":""}],"EXODIC":[{"def":"Conducting influences from the spinal cord outward; -- said of the motor or efferent nerves.","pos":""}],"EXODUS":[{"def":"A going out; particularly (the Exodus), the going out or journey of the Israelites from Egypt under the conduct of Moses; and hence, any large migration from a place.","pos":""},{"def":"The second of the Old Testament, which contains the narrative of the departure of the Israelites from Egypt.","pos":""}],"EXODY":[{"def":"Exodus; withdrawal.","pos":""}],"EXOGAMOUS":[{"def":"Relating to exogamy; marrying outside of the limits of one's own tribe; -- opposed to endogenous.","pos":""}],"EXOGAMY":[{"def":"The custom, or tribal law, which prohibits marriage between members of the same tribe; marriage outside of the tribe; -- opposed to endogamy.","pos":""}],"EXOGEN":[{"def":"A plant belonging to one of the greater part of the vegetable kingdom, and which the plants are characterized by having c wood bark, and pith, the wood forming a layer between the other two, and increasing, if at all, by the animal addition of a new layer to the outside next to the bark.","pos":""}],"EXOGENETIC":[{"def":"Arising or growing from without; exogenous.","pos":""}],"EXOGENOUS":[{"def":"Pertaining to, or having the character of, an exogen; -- the opposite of endogenous.","pos":""},{"def":"Growing by addition to the exterior.","pos":""}],"EXOGYRA":[{"def":"A genus of Cretaceous fossil shells allied to oysters.","pos":""}],"EXOLETE":[{"def":"Obsolete; out of use; state; insipid.","pos":""}],"EXOLVE":[{"def":"To loose; to pay.","pos":""}],"EXON":[{"def":"A native or inhabitant of Exeter, in England.","pos":""}],"EXONERATE":[{"def":"To unload; to disburden; to discharge.","pos":""},{"def":"To relieve, in a moral sense, as of a charge, obligation, or load of blame resting on one; to clear of something that lies upon oppresses one, as an accusation or imputation; as, to exonerate one's self from blame, or from the charge of avarice.","pos":""}],"EXONERATION":[{"def":"The act of disburdening, discharging, or freeing morally from a charge or imputation; also, the state of being disburdened or freed from a charge.","pos":""}],"EXONERATIVE":[{"def":"Freeing from a burden or obligation; tending to exonerate.","pos":""}],"EXONERATOR":[{"def":"One who exonerates or frees from obligation.","pos":""}],"EXOPHTHALMIA":[{"def":"The protrusion of the eyeball so that the eyelids will not cover it, in consequence of disease.","pos":""}],"EXOPHTHALMIC":[{"def":"Of or pertaining to, or characterized by, exophthalmia.","pos":""},{"def":"Same as Exophthalmia.","pos":""}],"EXOPHYLLOUS":[{"def":"Not sheathed in another leaf.","pos":""}],"EXOPLASM":[{"def":"See Ectosarc, and Ectoplasm.","pos":""}],"EXOPODITE":[{"def":"The external branch of the appendages of Crustacea.","pos":""}],"EXOPTILE":[{"def":"A name given by Lestiboudois to dicotyledons; -- so called because the plumule is naked.","pos":""}],"EXORABLE":[{"def":"Capable of being moved by entreaty; pitiful; tender.","pos":""}],"EXORATE":[{"def":"To persuade, or to gain, by entreaty.","pos":""}],"EXORATION":[{"def":"A going out of or beyond the usual or due limit; hence, enormity; extravagance; gross deviation from rule, right, or propriety; as, the exorbitances of the tongue or of deportment; exorbitance of demands.","pos":""}],"EXORBITANT":[{"def":"Departing from an orbit or usual track; hence, deviating from the usual or due course; going beyond the appointed rules or established limits of right or propriety; excessive; extravagant; enormous; inordinate; as, exorbitant appetites and passions; exorbitant charges, demands, or claims.","pos":""},{"def":"Not comprehended in a settled rule or method; anomalous.","pos":""}],"EXORBITANTLY":[{"def":"In an exorbitant, excessive, or irregular manner; enormously.","pos":""}],"EXORBITATE":[{"def":"To go out of the track; to deviate.","pos":""}],"EXORCISE":[{"def":"To cast out, as a devil, evil spirits, etc.","pos":""},{"def":"To deliver or purify from the influence of an evil spirit or demon.","pos":""}],"EXORCISM":[{"def":"The act of exorcising; the driving out of evil spirits from persons or places by conjuration; also, the form of conjuration used.","pos":""},{"def":"Conjuration for raising spirits.","pos":""}],"EXORCIST":[{"def":"One who expels evil spirits by conjuration or exorcism.","pos":""},{"def":"A conjurer who can raise spirits.","pos":""}],"EXORDIAL":[{"def":"Pertaining to the exordium of a discourse: introductory.","pos":""}],"EXORDIUM":[{"def":"A beginning; an introduction; especially, the introductory part of a discourse or written composition, which prepares the audience for the main subject; the opening part of an oration.","pos":""}],"EXORHIZA":[{"def":"A plant Whose radicle is not inclosed or sheathed by the cotyledons or plumule.","pos":""},{"def":"Having a radicle which is not inclosed by the cotyledons or plumule; of or relating to an exorhiza.","pos":""}],"EXORNATION":[{"def":"Ornament; decoration; embellishment.","pos":""}],"EXORTIVE":[{"def":"Rising; relating to the east.","pos":""}],"EXOSCULATE":[{"def":"To kiss; especially, to kiss repeatedly or fondly.","pos":""}],"EXOSKELETAL":[{"def":"Pertaining to the exoskeleton; as exoskeletal muscles.","pos":""}],"EXOSKELETON":[{"def":"The hardened parts of the external integument of an animal, including hair, feathers, nails, horns, scales, etc.","pos":""}],"EXOSMOSE":[{"def":"The passage of gases, vapors, or liquids thought membranes or porous media from within outward, in the phenomena of osmose; -- opposed to endosmose.","pos":""}],"EXOSMOTIC":[{"def":"Pertaining to exosmose.","pos":""}],"EXOSPORE":[{"def":"The extreme outer wall of a spore; the epispore.","pos":""}],"EXOSSATE":[{"def":"To deprive of bones; to take out the bones of; to bone.","pos":""}],"EXOSSATION":[{"def":"A depriving of bone or of fruit stones.","pos":""}],"EXOSTOME":[{"def":"The small aperture or foremen in the outer coat of the ovule of a plant.","pos":""}],"EXOSTOSIS":[{"def":"Any protuberance of a bone which is not natural; an excrescence or morbid enlargement of a bone.","pos":""},{"def":"A knot formed upon or in the wood of trees by disease.","pos":""}],"EXOTERICS":[{"def":"The public lectures or published writings of Aristotle.","pos":""}],"EXOTERY":[{"def":"That which is obvious, public, or common.","pos":""}],"EXOTHECA":[{"def":"The tissue which fills the interspaces between the costæ of many madreporarian corals, usually consisting of small transverse or oblique septa.","pos":""}],"EXOTHECIUM":[{"def":"The outer coat of the anther.","pos":""}],"EXOTHERMIC":[{"def":"Characterized by, or formed with, evolution of heat; as, an exothermic reaction; -- opposed to endothermic.","pos":""}],"EXOTIC":[{"def":"Introduced from a foreign country; not native; extraneous; foreign; as, an exotic plant; an exotic term or word.","pos":""}],"EXOTICAL":[{"def":"Foreign; not native; exotic.","pos":""}],"EXOTICISM":[{"def":"The state of being exotic; also, anything foreign, as a word or idiom; an exotic.","pos":""}]}