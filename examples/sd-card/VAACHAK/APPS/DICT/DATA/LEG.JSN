{"LEG":[{"def":"The course and distance made by a vessel on one tack or between tacks.","pos":""},{"def":"An extension of the boiler downward, in the form of a narrow space between vertical plates, sometimes nearly surrounding the furnace and ash pit, and serving to support the boiler; -- called also water leg.","pos":""}],"LEG BRIDGE":[{"def":"A type of bridge for small spans in which the floor girders are rigidly secured at their extremities to supporting steel legs, driven into the round as piling, or resting on mudsills.","pos":""}],"LEG-OF-MUTTON":[{"def":"Having the general shape or outline of a leg of mutton; as, a leg-of-mutton, or shoulder-of-mutton, sail.","pos":""}],"LEGACY":[{"def":"A gift of property by will, esp.","pos":""},{"def":"A business with which one is intrusted by another; a commission; - - obsolete, except in the phrases last legacy, dying legacy, and the like.","pos":""}],"LEGAL":[{"def":"Governed by the rules of law as distinguished from the rules of equity; as, legal estate; legal assets.","pos":""}],"LEGALISM":[{"def":"Strictness, or the doctrine of strictness, in conforming to law.","pos":""}],"LEGALIST":[{"def":"One who practices or advocates strict conformity to law; in theology, one who holds to the law of works.","pos":""}],"LEGALITY":[{"def":"The state or quality of being letter of the law.","pos":""}],"LEGALIZATION":[{"def":"The act of making legal.","pos":""}],"LEGALIZE":[{"def":"To interpret or apply in a legal spirit.","pos":""}],"LEGALLY":[{"def":"In a legal manner.","pos":""}],"LEGATE":[{"def":"An ambassador or envoy.","pos":""},{"def":"An ecclesiastic representing the pope and invested with the authority of the Holy See.","pos":""}],"LEGATEE":[{"def":"One to whom a legacy is bequeathed.","pos":""}],"LEGATESHIP":[{"def":"The office of a legate.","pos":""}],"LEGATINE":[{"def":"Of or pertaining to a legate; as, legatine power.","pos":""}],"LEGATION":[{"def":"The sending forth or commissioning one person to act for another.","pos":""},{"def":"A legate, or envoy, and the persons associated with him in his mission; an embassy; or, in stricter usage, a diplomatic minister and his suite; a deputation.","pos":""}],"LEGATO":[{"def":"Connected; tied; -- a term used when successive tones are to be produced in a closely connected, smoothly gliding manner.","pos":""}],"LEGATOR":[{"def":"A testator; one who bequeaths a legacy.","pos":""}],"LEGATURA":[{"def":"A tie or brace; a syncopation.","pos":""}],"LEGE":[{"def":"To allege; to assert.","pos":""}],"LEGEND":[{"def":"That which is appointed to be read; especially, a chronicle or register of the lives of saints, formerly read at matins, and in the refectories of religious houses.","pos":""},{"def":"A story respecting saints; especially, one of a marvelous nature.","pos":""}],"LEGENDARY":[{"def":"Of or pertaining to a legend or to legends; consisting of legends; like a legend; fabulous.","pos":""}],"LEGER":[{"def":"Anything that lies in a place; that which, or one who, remains in a place.","pos":""},{"def":"A minister or ambassador resident at a court or seat of government.","pos":""}],"LEGERDEMAIN":[{"def":"Sleight of hand; a trick of sleight of hand; hence, any artful deception or trick.","pos":""}],"LEGERDEMAINIST":[{"def":"One who practices sleight of hand; a prestidigitator.","pos":""}],"LEGERITY":[{"def":"Lightness; nimbleness [Archaic] Shak.","pos":""}],"LEGGE":[{"def":"To lighten; to allay.","pos":""}],"LEGGED":[{"def":"Having (such or so many) legs; -- used in composition; as, a long-legged man; a two-legged animal.","pos":""},{"def":"Light or graceful; in a light, delicate, and brick style.","pos":""}],"LEGGY":[{"def":"Having long legs.","pos":""}],"LEGHORN":[{"def":"A straw plaiting used for bonnets and hats, made from the straw of a particular kind of wheat, grown for the purpose in Tuscany, Italy; -- so called from Leghorn, the place of exportation.","pos":""}],"LEGIBILITY":[{"def":"The quality of being legible; legibleness.","pos":""}],"LEGIBLE":[{"def":"Capable of being read or deciphered; distinct to the eye; plain; - - used of writing or printing; as, a fair, legible manuscript.","pos":""},{"def":"Capable of being discovered or understood by apparent marks or indications; as, the thoughts of men are often legible in their countenances.","pos":""}],"LEGIBLENESS":[{"def":"The state or quality of being legible.","pos":""}],"LEGIBLY":[{"def":"In a legible manner.","pos":""}],"LEGIFIC":[{"def":"Of or pertaining to making laws.","pos":""}],"LEGION":[{"def":"A body of foot soldiers and cavalry consisting of different numbers at different periods, -- from about four thousand to about six thousand men, -- the cavalry being about one tenth.","pos":""},{"def":"A group of orders inferior to a class.","pos":""}],"LEGIONARY":[{"def":"Belonging to a legion; consisting of a legion or legions, or of an indefinitely great number; as, legionary soldiers; a legionary force.","pos":""}],"LEGIONED":[{"def":"Formed into a legion or legions; legionary.","pos":""}],"LEGIONRY":[{"def":"A body of legions; legions, collectively.","pos":""}],"LEGISLATE":[{"def":"To make or enact a law or laws.","pos":""}],"LEGISLATION":[{"def":"The act of legislating; preparation and enactment of laws; the laws enacted.","pos":""}],"LEGISLATIVE":[{"def":"Making, or having the power to make, a law or laws; lawmaking; -- distinguished from executive; as, a legislative act; a legislative body.","pos":""},{"def":"Of or pertaining to the making of laws; suitable to legislation; as, the transaction of legislative business; the legislative style.","pos":""}],"LEGISLATIVELY":[{"def":"In a legislative manner.","pos":""}],"LEGISLATOR":[{"def":"A lawgiver; one who makes laws for a state or community; a member of a legislative body.","pos":""}],"LEGISLATORIAL":[{"def":"Of or pertaining to a legislator or legislature.","pos":""}],"LEGISLATORSHIP":[{"def":"The office of a legislator.","pos":""},{"def":"A woman who makes laws.","pos":""}],"LEGISLATURE":[{"def":"The body of persons in a state or kingdom invested with power to make and repeal laws; a legislative body.","pos":""}],"LEGIST":[{"def":"One skilled in the laws; a writer on law.","pos":""}],"LEGITIM":[{"def":"The portion of movable estate to which the children are entitled upon the death of the father.","pos":""}],"LEGITIMACY":[{"def":"The state, or quality, of being legitimate, or in conformity with law; hence, the condition of having been lawfully begotten, or born in wedlock.","pos":""}],"LEGITIMATE":[{"def":"Accordant with law or with established legal forms and requirements; lawful; as, legitimate government; legitimate rights; the legitimate succession to the throne; a legitimate proceeding of an officer; a legitimate heir.","pos":""},{"def":"Lawfully begotten; born in wedlock.","pos":""}],"LEGITIMATELY":[{"def":"In a legitimate manner; lawfully; genuinely.","pos":""}],"LEGITIMATENESS":[{"def":"The state or quality of being legitimate; lawfulness; genuineness.","pos":""}],"LEGITIMATION":[{"def":"The act of making legitimate.","pos":""}],"LEGITIMISM":[{"def":"The principles or plans of legitimists.","pos":""}],"LEGITIMIST":[{"def":"One who supports legitimate authority; esp.","pos":""},{"def":"Specifically, a supporter of the claims of the elder branch of the Bourbon dynasty to the crown of France.","pos":""}],"LEGLESS":[{"def":"Not having a leg.","pos":""}],"LEGO-LITERARY":[{"def":"Pertaining to the literature of law.","pos":""}],"LEGULEIAN":[{"def":"Lawyerlike; legal.","pos":""}],"LEGUME":[{"def":"A pod dehiscent into two pieces or valves, and having the seed attached at one suture, as that of the pea.","pos":""},{"def":"The fruit of leguminous plants, as peas, beans, lupines; pulse.","pos":""}],"LEGUMIN":[{"def":"An albuminous substance resembling casein, found as a characteristic ingredient of the seeds of leguminous and grain- bearing plants.","pos":""}],"LEGUMINOUS":[{"def":"Belonging to, or resembling, a very large natural order of plants (Leguminosæ), which bear legumes, including peas, beans, clover, locust trees, acacias, and mimosas.","pos":""}]}