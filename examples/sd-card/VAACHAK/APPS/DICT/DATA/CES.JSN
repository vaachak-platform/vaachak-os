{"CESPITINE":[{"def":"An oil obtained by distillation of peat, and containing various members of the pyridine series.","pos":""}],"CESPITITIOUS":[{"def":"Same as Cespitious.","pos":""}],"CESPITOSE":[{"def":"Having the form a piece of turf, i.","pos":""}],"CESPITOUS":[{"def":"Pertaining to, consisting, of resembling, turf; turfy.","pos":""}],"CESS":[{"def":"The poor jade is wrung in the withers out of all cess.","pos":""}],"CESSANT":[{"def":"Inactive; dormant [Obs.","pos":""}],"CESSATION":[{"def":"A ceasing of discontinuance, as of action, whether termporary or final; a stop; as, a cessation of the war.","pos":""}],"CESSAVIT":[{"def":"A writ given by statute to recover lands when the tenant has for two years failed to perform the conditions of his tenure.","pos":""}],"CESSER":[{"def":"a neglect of a tenant to perform services, or make payment, for two years.","pos":""}],"CESSIBLE":[{"def":"Giving way; yielding.","pos":""}],"CESSION":[{"def":"The giving up or vacating a benefice by accepting another without a proper dispensation.","pos":""},{"def":"The voluntary surrender of a person's effects to his creditors to avoid imprisonment.","pos":""}],"CESSIONARY":[{"def":"Having surrendered the effects; as, a cessionary bankrupt.","pos":""}],"CESSMENT":[{"def":"An assessment or tax.","pos":""}],"CESSOR":[{"def":"One who neglects, for two years, to perform the service by which he holds lands, so that he incurs the danger of the writ of cessavit.","pos":""}],"CESSPIPE":[{"def":"A pipe for carrying off waste water, etc.","pos":""}],"CESSPOOL":[{"def":"A cistern in the course, or the termination, of a drain, to collect sedimentary or superfluous matter; a privy vault; any receptace of filth.","pos":""}],"CEST":[{"def":"A woman's girdle; a cestus.","pos":""}],"CESTODE":[{"def":"Of or pertaining to the Cestoidea.","pos":""},{"def":"One of the Cestoidea.","pos":""}],"CESTOID":[{"def":"Of or pertaining to the Cestoidea.","pos":""},{"def":"One of the Cestoidea.","pos":""}],"CESTOIDEA":[{"def":"A class of parasitic worms (Platelminthes) of which the tapeworms are the most common examples.","pos":""}],"CESTOLDEAN":[{"def":"One of the Cestoidea.","pos":""}],"CESTRACIONT":[{"def":"A shark of the genus Cestracion, and of related genera.","pos":""}],"CESTUS":[{"def":"A girdle; particularly that of Aphrodite (or Venus) which gave the wearer the power of exciting love.","pos":""},{"def":"A genus of Ctenophora.","pos":""}]}