{"HYDRIA":[{"def":"A water jar; esp.","pos":""}],"HYDRIC":[{"def":"Pertaining to, or containing, hydrogen; as, hydric oxide.","pos":""}],"HYDRIDE":[{"def":"A compound of the binary type, in which hydrogen is united with some other element.","pos":""}],"HYDRIFORM":[{"def":"Having the form or structure of a hydra.","pos":""}],"HYDRINA":[{"def":"The group of hydroids to which the fresh-water hydras belong.","pos":""}],"HYDRIODATE":[{"def":"Same as Hydriodide.","pos":""}],"HYDRIODIC":[{"def":"Pertaining to, or derived from, hydrogen and iodine; -- said of an acid produced by the combination of these elements.","pos":""}],"HYDRIODIDE":[{"def":"A compound of hydriodic acid with a base; -- distinguished from an iodide, in which only the iodine combines with the base.","pos":""},{"def":"A combining form of hydrogen, indicating hydrogen as an ingredient, as hydrochloric; or a reduction product obtained by hydrogen, as hydroquinone.","pos":""}]}