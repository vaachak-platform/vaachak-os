{"SOD":[{"def":"That stratum of the surface of the soil which is filled with the roots of grass, or any portion of that surface; turf; sward.","pos":""}],"SODA":[{"def":"Sodium carbonate, under Sodium.","pos":""}],"SODAIC":[{"def":"Pertaining to, or containing, soda.","pos":""}],"SODALITE":[{"def":"A mineral of a white to blue or gray color, occuring commonly in dodecahedrons, also massive.","pos":""}],"SODALITY":[{"def":"Specifically, a lay association for devotion or for charitable purposes.","pos":""}],"SODAMIDE":[{"def":"A greenish or reddish crystalline substance, NaNH2, obtained by passing ammonia over heated sodium.","pos":""}],"SODDEN":[{"def":"Boiled; seethed; also, soaked; heavy with moisture; saturated; as, sodden beef; sodden bread; sodden fields.","pos":""}],"SODDY":[{"def":"Consisting of sod; covered with sod; turfy.","pos":""}],"SODIC":[{"def":"Of or pertaining to sodium; containing sodium.","pos":""}],"SODIO-":[{"def":"A combining form (also used adjectively) denoting the presence of sodium or one of its compounds.","pos":""}],"SODIUM":[{"def":"A common metallic element of the alkali group, in nature always occuring combined, as in common salt, in albite, etc.","pos":""}],"SODIUM SULPHATE":[{"def":"A salt well known as a catharic under the name of Glauber's salt, which term is properly applied to the hydrate, Na2SO4.","pos":""}],"SODOMITE":[{"def":"An inhabitant of Sodom.","pos":""},{"def":"One guilty of sodomy.","pos":""}],"SODOMITICAL":[{"def":"Pertaining to, or of the nature of, sodomy.","pos":""}],"SODOMY":[{"def":"Carnal copulation in a manner against nature; buggery.","pos":""}]}