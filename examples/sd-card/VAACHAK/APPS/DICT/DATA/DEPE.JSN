{"DEPEACH":[{"def":"As soon as the party .","pos":""}],"DEPECTIBLE":[{"def":"Tough; thick; capable of extension.","pos":""}],"DEPECULATION":[{"def":"A robbing or embezzlement.","pos":""}],"DEPEND":[{"def":"To hang down; to be sustained by being fastened or attached to something above.","pos":""},{"def":"To hang in suspense; to be pending; to be undetermined or undecided; as, a cause depending in court.","pos":""}],"DEPENDABLE":[{"def":"Worthy of being depended on; trustworthy.","pos":""},{"def":"See Dependent, Dependence, Dependency.","pos":""}],"DEPENDENCE":[{"def":"The act or state of depending; state of being dependent; a hanging down or from; suspension from a support.","pos":""},{"def":"The state of being influenced and determined by something; subjection (as of an effect to its cause).","pos":""}],"DEPENDENCY":[{"def":"State of being dependent; dependence; state of being subordinate; subordination; concatenation; connection; reliance; trust.","pos":""},{"def":"A thing hanging down; a dependence.","pos":""}],"DEPENDENT":[{"def":"Hanging down; as, a dependent bough or leaf.","pos":""}],"DEPENDENTLY":[{"def":"In a dependent manner.","pos":""}],"DEPENDER":[{"def":"One who depends; a dependent.","pos":""}],"DEPENDINGLY":[{"def":"As having dependence.","pos":""}],"DEPERDIT":[{"def":"That which is lost or destroyed.","pos":""}],"DEPERDITELY":[{"def":"De*per\"dite*ly Defn: , adv.","pos":""}],"DEPERDITION":[{"def":"Loss; destruction.","pos":""}]}