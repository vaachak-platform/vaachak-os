{"DECOCT":[{"def":"To prepare by boiling; to digest in hot or boiling water; to extract the strength or flavor of by boiling; to make an infusion of.","pos":""},{"def":"To prepare by the heat of the stomach for assimilation; to digest; to concoct.","pos":""}],"DECOCTIBLE":[{"def":"Capable of being boiled or digested.","pos":""}],"DECOCTION":[{"def":"The act or process of boiling anything in a watery fluid to extract its virtues.","pos":""},{"def":"An extract got from a body by boiling it in water.","pos":""}],"DECOHERER":[{"def":"A device for restoring a coherer to its normal condition after it has been affected by an electric wave, a process usually accomplished by some method of tapping or shaking, or by rotation of the coherer.","pos":""}],"DECOLLATE":[{"def":"To sever from the neck; to behead; to decapitate.","pos":""}],"DECOLLATED":[{"def":"Decapitated; worn or cast off in the process of growth, as the apex of certain univalve shells.","pos":""}],"DECOLLATION":[{"def":"The act of beheading or state of one beheaded; -- especially used of the execution of St.","pos":""},{"def":"A painting representing the beheading of a saint or martyr, esp.","pos":""}],"DECOLLETAGE":[{"def":"The upper border or part of a décolleté corsage.","pos":""}],"DECOLLETE":[{"def":"Leaving the neck and shoulders uncovered; cut low in the neck, or low-necked, as a dress.","pos":""}],"DECOLLING":[{"def":"By a speedy dethroning and decolling of the king.","pos":""}],"DECOLOR":[{"def":"To deprive of color; to bleach.","pos":""}],"DECOLORANT":[{"def":"A substance which removes color, or bleaches.","pos":""}],"DECOLORATE":[{"def":"Deprived of color.","pos":""}],"DECOLORATION":[{"def":"The removal or absence of color.","pos":""}],"DECOLORIZE":[{"def":"To deprive of color; to whiten.","pos":""}],"DECOMPLEX":[{"def":"Repeatedly compound; made up of complex constituents.","pos":""}],"DECOMPOSABLE":[{"def":"Capable of being resolved into constituent elements.","pos":""}],"DECOMPOSE":[{"def":"To separate the constituent parts of; to resolve into original elements; to set free from previously existing forms of chemical combination; to bring to dissolution; to rot or decay.","pos":""}],"DECOMPOSED":[{"def":"Separated or broken up; -- said of the crest of birds when the feathers are divergent.","pos":""}],"DECOMPOSITE":[{"def":"See Decompound, a.","pos":""}],"DECOMPOSITION":[{"def":"The state of being reduced into original elements.","pos":""}],"DECOMPOUND":[{"def":"To compound or mix with that is already compound; to compound a second time.","pos":""},{"def":"To reduce to constituent parts; to decompose.","pos":""}],"DECOMPOUNDABLE":[{"def":"Capable of being decompounded.","pos":""}],"DECONCENTRATE":[{"def":"To withdraw from concentration; to decentralize.","pos":""}],"DECONCENTRATION":[{"def":"Act of deconcentrating.","pos":""}],"DECONSECRATE":[{"def":"To deprive of sacredness; to secularize.","pos":""}],"DECORATE":[{"def":"To deck with that which is becoming, ornamental, or honorary; to adorn; to beautify; to embellish; as, to decorate the person; to decorate an edifice; to decorate a lawn with flowers; to decorate the mind with moral beauties; to decorate a hero with honors.","pos":""}],"DECORATION":[{"def":"The act of adorning, embellishing, or honoring; ornamentation.","pos":""},{"def":"That which adorns, enriches, or beautifies; something added by way of embellishment; ornament.","pos":""}],"DECORATIVE":[{"def":"Suited to decorate or embellish; adorning.","pos":""}],"DECORATOR":[{"def":"One who decorates, adorns, or embellishes; specifically, an artisan whose business is the decoration of houses, esp.","pos":""}],"DECORE":[{"def":"To decorate; to beautify.","pos":""}],"DECOROUS":[{"def":"Suitable to a character, or to the time, place, and occasion; marked with decorum; becoming; proper; seemly; befitting; as, a decorous speech; decorous behavior; a decorous dress for a judge.","pos":""}],"DECORTICATE":[{"def":"To divest of the bark, husk, or exterior coating; to husk; to peel; to hull.","pos":""}],"DECORTICATION":[{"def":"The act of stripping off the bark, rind, hull, or outer coat.","pos":""}],"DECORTICATOR":[{"def":"A machine for decorticating wood, hulling grain, etc.","pos":""}],"DECORUM":[{"def":"Propriety of manner or conduct; grace arising from suitableness of speech and behavior to one's own character, or to the place and occasion; decency of conduct; seemliness; that which is seemly or suitable.","pos":""}],"DECOY":[{"def":"To lead into danger by artifice; to lure into a net or snare; to entrap; to insnare; to allure; to entice; as, to decoy troops into an ambush; to decoy ducks into a net.","pos":""}],"DECOY-DUCK":[{"def":"A duck used to lure wild ducks into a decoy; hence, a person employed to lure others into danger.","pos":""}],"DECOY-MAN":[{"def":"A man employed in decoying wild fowl.","pos":""}],"DECOYER":[{"def":"One who decoys another.","pos":""}]}