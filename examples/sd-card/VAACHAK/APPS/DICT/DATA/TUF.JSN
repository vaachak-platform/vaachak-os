{"TUF-TAFFETA":[{"def":"A silk fabric formerly in use, having a nap or pile.","pos":""}],"TUFA":[{"def":"Tofus, Toph, and Tophin.","pos":""}],"TUFACEOUS":[{"def":"Pertaining to tufa; consisting of, or resembling, tufa.","pos":""}],"TUFT":[{"def":"A collection of small, flexible, or soft things in a knot or bunch; a waving or bending and spreading cluster; as, a tuft of flowers or feathers.","pos":""},{"def":"A cluster; a clump; as, a tuft of plants.","pos":""}],"TUFTED":[{"def":"Adorned with a tuft; as, the tufted duck.","pos":""},{"def":"Growing in tufts or clusters; tufty.","pos":""}],"TUFTHUNTER":[{"def":"A hanger-on to noblemen, or persons of quality, especially in English universities; a toady.","pos":""}],"TUFTHUNTING":[{"def":"The practice of seeking after, and hanging on, noblemen, or persons of quality, especially in English universities.","pos":""}],"TUFTY":[{"def":"Abounding with tufts.","pos":""},{"def":"Growing in tufts or clusters.","pos":""}]}