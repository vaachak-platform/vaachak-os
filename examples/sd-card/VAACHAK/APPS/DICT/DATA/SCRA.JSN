{"SCRABBED EGGS":[{"def":"A Lenten dish, composed of eggs boiled hard, chopped, and seasoned with butter, salt, and pepper.","pos":""}],"SCRABBLE":[{"def":"To scrape, paw, or scratch with the hands; to proceed by clawing with the hands and feet; to scramble; as, to scrabble up a cliff or a tree.","pos":""},{"def":"To make irregular, crooked, or unmeaning marks; to scribble; to scrawl.","pos":""}],"SCRAFFLE":[{"def":"To scramble or struggle; to wrangle; also, to be industrious.","pos":""}],"SCRAG":[{"def":"Something thin, lean, or rough; a bony piece; especially, a bony neckpiece of meat; hence, humorously or in contempt, the neck.","pos":""},{"def":"A rawboned person.","pos":""}],"SCRAG-NECKED":[{"def":"Having a scraggy neck.","pos":""}],"SCRAGGED":[{"def":"Rough with irregular points, or a broken surface; scraggy; as, a scragged backbone.","pos":""},{"def":"Lean and rough; scraggy.","pos":""}],"SCRAGGEDNESS":[{"def":"Quality or state of being scragged.","pos":""}],"SCRAGGILY":[{"def":"in a scraggy manner.","pos":""}],"SCRAGGINESS":[{"def":"The quality or state of being scraggy; scraggedness.","pos":""}],"SCRAGGY":[{"def":"Rough with irregular points; scragged.","pos":""},{"def":"Lean and rough; scragged.","pos":""}],"SCRAMBLE":[{"def":"To clamber with hands and knees; to scrabble; as, to scramble up a cliff; to scramble over the rocks.","pos":""},{"def":"To struggle eagerly with others for something thrown upon the ground; to go down upon all fours to seize something; to catch rudely at what is desired.","pos":""}],"SCRAMBLED EGGS":[{"def":"Eggs of which the whites and yolks are stirred together while cooking, or eggs beaten slightly, often with a little milk, and stirred while cooking.","pos":""}],"SCRAMBLER":[{"def":"One who scrambles; one who climbs on all fours.","pos":""},{"def":"A greedy and unceremonious contestant.","pos":""}],"SCRAMBLING":[{"def":"Confused and irregular; awkward; scambling.","pos":""}],"SCRANCH":[{"def":"To grind with the teeth, and with a crackling sound; to craunch.","pos":""}],"SCRANNEL":[{"def":"Slight; thin; lean; poor.","pos":""}],"SCRANNY":[{"def":"Thin; lean; meager; scrawny; scrannel.","pos":""}],"SCRAP":[{"def":"The crisp substance that remains after trying out animal fat; as, pork scraps.","pos":""},{"def":"Same as Scrap iron, below.","pos":""}],"SCRAPBOOK":[{"def":"A blank book in which extracts cut from books and papers may be pasted and kept.","pos":""}],"SCRAPE":[{"def":"To remove by rubbing or scraping (in the sense above).","pos":""}],"SCRAPEPENNY":[{"def":"One who gathers and hoards money in trifling sums; a miser.","pos":""}],"SCRAPER":[{"def":"An instrument with which anything is scraped.","pos":""},{"def":"One who scrapes.","pos":""}],"SCRAPING":[{"def":"The act of scraping; the act or process of making even, or reducing to the proper form, by means of a scraper.","pos":""},{"def":"Something scraped off; that which is separated from a substance, or is collected by scraping; as, the scraping of the street.","pos":""}],"SCRAPPILY":[{"def":"In a scrappy manner; in scraps.","pos":""}],"SCRAPPLE":[{"def":"An article of food made by boiling together bits or scraps of meat, usually pork, and flour or Indian meal.","pos":""}],"SCRAPPY":[{"def":"Consisting of scraps; fragmentary; lacking unity or consistency; as, a scrappy lecture.","pos":""}],"SCRAT":[{"def":"To rake; to search.","pos":""}],"SCRATCH":[{"def":"To rub and tear or mark the surface of with something sharp or ragged; to scrape, roughen, or wound slightly by drawing something pointed or rough across, as the claws, the nails, a pin, or the like.","pos":""},{"def":"To write or draw hastily or awkwardly.","pos":""}],"SCRATCH COAT":[{"def":"The first coat in plastering; -- called also scratchwork.","pos":""}],"SCRATCHBACK":[{"def":"A toy which imitates the sound of tearing cloth, -- used by drawing it across the back of unsuspecting persons.","pos":""}],"SCRATCHBRUSH":[{"def":"A stiff wire brush for cleaning iron castings and other metal.","pos":""}],"SCRATCHER":[{"def":"One who, or that which, scratches; specifically (Zoöl.","pos":""}],"SCRATCHING":[{"def":"With the action of scratching.","pos":""},{"def":"One that starts from the scratch; hence, one of first-rate ability.","pos":""}],"SCRATCHWORK":[{"def":"See Scratch coat.","pos":""}],"SCRATCHY":[{"def":"Characterized by scratches.","pos":""}],"SCRAWL":[{"def":"To draw or mark awkwardly and irregularly; to write hastily and carelessly; to scratch; to scribble; as, to scrawl a letter.","pos":""}],"SCRAWLER":[{"def":"One who scrawls; a hasty, awkward writer.","pos":""}],"SCRAWNY":[{"def":"Meager; thin; rawboned; bony; scranny.","pos":""}],"SCRAY":[{"def":"A tern; the sea swallow.","pos":""}]}