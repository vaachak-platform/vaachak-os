{"HEXABASIC":[{"def":"Having six hydrogen atoms or six radicals capable of being replaced or saturated by bases; -- said of acids; as, mellitic acid is hexabasic.","pos":""}],"HEXACAPSULAR":[{"def":"Having six capsules or seed vessels.","pos":""}],"HEXACHORD":[{"def":"A series of six notes, with a semitone between the third and fourth, the other intervals being whole tones.","pos":""}],"HEXACID":[{"def":"Having six atoms or radicals capable of being replaced by acids; hexatomic; hexavalent; -- said of bases; as, mannite is a hexacid base.","pos":""}],"HEXACTINELLID":[{"def":"Having six-rayed spicules; belonging to the Hexactinellinæ.","pos":""}],"HEXACTINELLINE":[{"def":"Belonging to the Hexactinellinæ, a group of sponges, having six-rayed siliceous spicules.","pos":""}],"HEXAD":[{"def":"An atom whose valence is six, and which can be theoretically combined with, substituted for, or replaced by, six monad atoms or radicals; as, sulphur is a hexad in sulphuric acid.","pos":""}],"HEXADACTYLOUS":[{"def":"Having six fingers or toes.","pos":""}],"HEXADE":[{"def":"A series of six numbers.","pos":""}],"HEXAGON":[{"def":"A plane figure of six angles.","pos":""}],"HEXAGONAL":[{"def":"Having six sides and six angles; six-sided.","pos":""}],"HEXAGONALLY":[{"def":"In an hexagonal manner.","pos":""}],"HEXAGRAM":[{"def":"Yih King, or \"Book of Changes.","pos":""}],"HEXAGYNIA":[{"def":"A Linnæan order of plants having six pistils.","pos":""},{"def":"Having six pistils.","pos":""}],"HEXAHEDRAL":[{"def":"In the form of a hexahedron; having six sides or faces.","pos":""}],"HEXAHEDRON":[{"def":"A solid body of six sides or faces.","pos":""}],"HEXAHEMERON":[{"def":"A term of six days.","pos":""},{"def":"The history of the six day's work of creation, as contained in the first chapter of Genesis.","pos":""}],"HEXAMEROUS":[{"def":"In six parts; in sixes.","pos":""}],"HEXAMETER":[{"def":"A verse of six feet, the first four of which may be either dactyls or spondees, the fifth must regularly be a dactyl, and the sixth always a spondee.","pos":""}],"HEXAMETRIST":[{"def":"One who writes in hexameters.","pos":""}],"HEXANDRIA":[{"def":"A Linnæan class of plants having six stamens.","pos":""},{"def":"Having six stamens.","pos":""}],"HEXANE":[{"def":"Any one of five hydrocarbons, C6H14, of the paraffin series.","pos":""}],"HEXANGULAR":[{"def":"Having six angles or corners.","pos":""}],"HEXAPETALOUS":[{"def":"Having six petals.","pos":""}],"HEXAPHYLLOUS":[{"def":"Having six leaves or leaflets.","pos":""}],"HEXAPLA":[{"def":"A collection of the Holy Scriptures in six languages or six versions in parallel columns; particularly, the edition of the Old Testament published by Origen, in the 3d century.","pos":""}],"HEXAPOD":[{"def":"Having six feet.","pos":""},{"def":"An animal having six feet; one of the Hexapoda.","pos":""}],"HEXAPODA":[{"def":"The true, or six-legged, insects; insects other than myriapods and arachnids.","pos":""}],"HEXAPODOUS":[{"def":"Having six feet; belonging to the Hexapoda.","pos":""}],"HEXAPTEROUS":[{"def":"Having six processes.","pos":""},{"def":"A poem consisting of six verses or lines.","pos":""}],"HEXASTYLE":[{"def":"Having six columns in front; -- said of a portico or temple.","pos":""},{"def":"A hexastyle portico or temple.","pos":""}],"HEXATEUCH":[{"def":"The first six books of the Old Testament.","pos":""}],"HEXAVALENT":[{"def":"Having a valence of six; -- said of hexads.","pos":""}],"HEXDECYL":[{"def":"The essential radical, C16H33, of hecdecane.","pos":""}],"HEXDECYLIC":[{"def":"Pertaining to, or derived from, hexdecyl or hecdecane; as, hexdecylic alcohol.","pos":""}],"HEXEIKOSANE":[{"def":"A hydrocarbon, C26H54, resembling paraffine; -- so called because each molecule has twenty-six atoms of carbon.","pos":""}],"HEXENE":[{"def":"Same as Hexylene.","pos":""}],"HEXICOLOGY":[{"def":"The science which treats of the complex relations of living creatures to other organisms, and to their surrounding conditions generally.","pos":""}],"HEXINE":[{"def":"A hydrocarbon, C6H10, of the acetylene series, obtained artificially as a colorless, volatile, pungent liquid; -- called also hexoylene.","pos":""}],"HEXOCTAHEDRON":[{"def":"A solid having forty-eight equal triangular faces.","pos":""}],"HEXOIC":[{"def":"Pertaining to, or derived from, hexane; as, hexoic acid.","pos":""}],"HEXONE":[{"def":"A liquid hydrocarbon, C6H8, of the valylene series, obtained from distillation products of certain fats and gums.","pos":""}],"HEXOSE":[{"def":"Any member of a group of sugars containing six carbon atoms in the molecule.","pos":""}],"HEXYL":[{"def":"A compound radical, C6H13, regarded as the essential residue of hexane, and a related series of compounds.","pos":""}],"HEXYLENE":[{"def":"A colorless, liquid hydrocarbon, C6H12, of the ethylene series, produced artificially, and found as a natural product of distillation of certain coals; also, any one several isomers of hexylene proper.","pos":""}],"HEXYLIC":[{"def":"Pertaining to, or derived from, hexyl or hexane; as, hexylic alcohol.","pos":""}]}