{"EXPLAIN":[{"def":"To flatten; to spread out; to unfold; to expand.","pos":""},{"def":"To make plain, manifest, or intelligible; to clear of obscurity; to expound; to unfold and illustrate the meaning of; as, to explain a chapter of the Bible.","pos":""}],"EXPLAINABLE":[{"def":"Capable of being explained or made plain to the understanding; capable of being interpreted.","pos":""}],"EXPLAINER":[{"def":"One who explains; an expounder or expositor; a commentator; an interpreter.","pos":""}],"EXPLANATE":[{"def":"Spreading or extending outwardly in a flat form.","pos":""}],"EXPLANATION":[{"def":"The act of explaining, expounding, or interpreting; the act of clearing from obscurity and making intelligible; as, the explanation of a passage in Scripture, or of a contract or treaty.","pos":""},{"def":"That which explains or makes clear; as, a satisfactory explanation.","pos":""}],"EXPLANATORINESS":[{"def":"The quality of being explanatory.","pos":""}],"EXPLANATORY":[{"def":"Serving to explain; containing explanation; as explanatory notes.","pos":""},{"def":"To explain; to unfold.","pos":""}],"EXPLETION":[{"def":"Accomplishment; fulfillment.","pos":""}],"EXPLETIVE":[{"def":"Filling up; hence, added merely for the purpose of filling up; superfluous.","pos":""}],"EXPLETIVELY":[{"def":"In the manner of an expletive.","pos":""}],"EXPLETORY":[{"def":"Serving to fill up; expletive; superfluous; as, an expletory word.","pos":""}],"EXPLICABLE":[{"def":"Capable of being explicated; that may be explained or accounted for; admitting explanation.","pos":""}],"EXPLICABLENESS":[{"def":"Quality of being explicable.","pos":""}],"EXPLICATE":[{"def":"Evolved; unfolded.","pos":""}],"EXPLICATION":[{"def":"The act of opening, unfolding, or explaining; explanation; exposition; interpretation.","pos":""},{"def":"The sense given by an expositor.","pos":""}],"EXPLICATIVE":[{"def":"Serving to unfold or explain; tending to lay open to the understanding; explanatory.","pos":""}],"EXPLICATOR":[{"def":"One who unfolds or explains; an expounder; an explainer.","pos":""}],"EXPLICIT":[{"def":"A word formerly used (as finis is now) at the conclusion of a book to indicate the end.","pos":""}],"EXPLICITLY":[{"def":"In an explicit manner; clearly; plainly; without disguise or reservation of meaning; not by inference or implication; as, he explicitly avows his intention.","pos":""}],"EXPLICITNESS":[{"def":"The quality of being explicit; clearness; directness.","pos":""}],"EXPLODE":[{"def":"To become suddenly expanded into a great volume of gas or vapor; to burst violently into flame; as gunpowder explodes.","pos":""},{"def":"To burst with force and a loud report; to detonate, as a shell filled with powder or the like material, or as a boiler from too great pressure of steam.","pos":""}],"EXPLODENT":[{"def":"An instrument or agent causing explosion; an exploder; also, an explosive.","pos":""},{"def":"See Explosive, n.","pos":""}],"EXPLODER":[{"def":"One who or that which explodes.","pos":""},{"def":"One who rejects an opinion or scheme with open contempt.","pos":""}],"EXPLOIT":[{"def":"To utilize; to make available; to get the value or usefulness out of; as, to exploit a mine or agricultural lands; to exploit public opinion.","pos":""}],"EXPLOITATION":[{"def":"The act of exploiting or utilizing.","pos":""}],"EXPLOITURE":[{"def":"The act of exploiting or accomplishing; achievement.","pos":""}],"EXPLORABLE":[{"def":"That may be explored; as, an explorable region.","pos":""}],"EXPLORATION":[{"def":"The act of exploring, penetrating, or ranging over for purposes of discovery, especially of geographical discovery; examination; as, the exploration of unknown countries; (Med.","pos":""},{"def":"physical examination.","pos":""}],"EXPLORATOR":[{"def":"One who explores; one who examines closely; a searcher.","pos":""}],"EXPLORATORY":[{"def":"Serving or intended to explore; searching; examining; explorative.","pos":""}],"EXPLORE":[{"def":"To seek for or after; to strive to attain by search; to look wisely and carefully for.","pos":""},{"def":"To search through or into; to penetrate or range over for discovery; to examine thoroughly; as, to explore new countries or seas; to explore the depths of science.","pos":""}],"EXPLOREMENT":[{"def":"The act of exploring; exploration.","pos":""}],"EXPLORER":[{"def":"One who explores; also, an apparatus with which one explores, as a diving bell.","pos":""}],"EXPLORING":[{"def":"Employed in, or designed for, exploration.","pos":""}],"EXPLOSION":[{"def":"The act of exploding; detonation; a chemical action which causes the sudden formation of a great volume of expanded gas; as, the explosion of gunpowder, of fire damp,etc.","pos":""},{"def":"A bursting with violence and loud noise, because of internal pressure; as, the explosion of a gun, a bomb, a steam boiler, etc.","pos":""}],"EXPLOSIVE":[{"def":"Driving or bursting out with violence and noise; causing explosion; as, the explosive force of gunpowder.","pos":""}],"EXPLOSIVELY":[{"def":"In an explosive manner.","pos":""}]}