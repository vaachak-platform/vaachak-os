{"SEMIFABLE":[{"def":"That which is part fable and part truth; a mixture of truth and fable.","pos":""}],"SEMIFLORET":[{"def":"See Semifloscule.","pos":""}],"SEMIFLOSCULE":[{"def":"A floscule, or florest, with its corolla prolonged into a strap-shaped petal; -- called also semifloret.","pos":""}],"SEMIFLOSCULOUS":[{"def":"Having all the florets ligulate, as in the dandelion.","pos":""}],"SEMIFLUID":[{"def":"Imperfectly fluid.","pos":""},{"def":"A semifluid substance.","pos":""}],"SEMIFORM":[{"def":"A half form; an imperfect form.","pos":""}],"SEMIFORMED":[{"def":"Half formed; imperfectly formed; as, semiformed crystals.","pos":""}]}