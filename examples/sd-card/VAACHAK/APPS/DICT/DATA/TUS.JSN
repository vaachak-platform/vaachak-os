{"TUSCAN":[{"def":"Of or pertaining to Tuscany in Italy; -- specifically designating one of the five orders of architecture recognized and described by the Italian writers of the 16th century, or characteristic of the order.","pos":""}],"TUSCARORAS":[{"def":"A tribe of North American Indians formerly living on the Neuse and Tar rivers in North Carolina.","pos":""},{"def":"A lithographic drawing or painting material of the same nature as lithographic ink.","pos":""}],"TUSCOR":[{"def":"A tush of a horse.","pos":""}],"TUSH":[{"def":"An exclamation indicating check, rebuke, or contempt; as, tush, tush! do not speak of it.","pos":""}],"TUSK":[{"def":"One of the elongated incisor or canine teeth of the wild boar, elephant, etc.","pos":""},{"def":"A toothshell, or Dentalium; -- called also tusk-shell.","pos":""}],"TUSKED":[{"def":"Furnished with tusks.","pos":""}],"TUSKER":[{"def":"An elephant having large tusks.","pos":""}],"TUSSAC GRASS":[{"def":"An undomesticated East Indian silkworn (Antheræa mylitta), that feeds on the leaves of the oak and other plants.","pos":""}],"TUSSAL":[{"def":"Pertaining to, or manifested by, cough.","pos":""}],"TUSSICULAR":[{"def":"Of or pertaining to a cough.","pos":""}],"TUSSIVE":[{"def":"Pertaining to a cough; caused by coughing.","pos":""}],"TUSSLE":[{"def":"To struggle, as in sport; to scuffle; to struggle with.","pos":""}],"TUSSOCK":[{"def":"Same as Tussock grass, below.","pos":""},{"def":"A caterpillar of any one of numerous species of bombycid moths.","pos":""}],"TUSSOCKY":[{"def":"Having the form of tussocks; full of, or covered with, tussocks, or tufts.","pos":""}]}