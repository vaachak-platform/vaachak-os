{"OBSCENE":[{"def":"Offensive to chastity or modesty; expressing of presenting to the mind or view something which delicacy, purity, and decency forbid to be exposed; impure; as, obscene language; obscene pictures.","pos":""},{"def":"Foul; fifthy; disgusting.","pos":""}],"OBSCENITY":[{"def":"That quality in words or things which presents what is offensive to chasity or purity of mind; obscene or impure lanquage or acts; moral impurity; lewdness; obsceneness; as, the obscenity of a speech, or a picture.","pos":""}],"OBSCURANT":[{"def":"One who obscures; one who prevents enlightenment or hinders the progress of knowledge and wisdom.","pos":""}],"OBSCURANTISM":[{"def":"The system or the principles of the obscurants.","pos":""}],"OBSCURANTIST":[{"def":"Same as Obscurant.","pos":""}],"OBSCURATION":[{"def":"The act or operation of obscuring; the state of being obscured; as, the obscuration of the moon in an eclipse.","pos":""}],"OBSCURE":[{"def":"Covered over, shaded, or darkened; destitute of light; imperfectly illuminated; dusky; dim.","pos":""},{"def":"Of or pertaining to darkness or night; inconspicuous to the sight; indistinctly seen; hidden; retired; remote from observation; unnoticed.","pos":""}],"OBSCURELY":[{"def":"In an obscure manner.","pos":""}],"OBSCUREMENT":[{"def":"The act of obscuring, or the state of being obscured; obscuration.","pos":""}],"OBSCURER":[{"def":"One who, or that which, obscures.","pos":""}],"OBSCURITY":[{"def":"The quality or state of being obscure; darkness; privacy; inconspicuousness; unintelligibleness; uncertainty.","pos":""}],"OBSECRATE":[{"def":"To beseech; to supplicate; to implore.","pos":""}],"OBSECRATION":[{"def":"A figure of speech in which the orator implores the assistance of God or man.","pos":""}],"OBSECRATORY":[{"def":"Expressing, or used in, entreaty; supplicatory.","pos":""}],"OBSEQUENT":[{"def":"Obedient; submissive; obsequious.","pos":""}],"OBSEQUIOUS":[{"def":"Of or pertaining to obsequies; funereal.","pos":""}],"OBSEQUIOUSLY":[{"def":"In an obsequious manner; compliantly; fawningly.","pos":""},{"def":"In a manner appropriate to obsequies.","pos":""}],"OBSEQUIOUSNESS":[{"def":"The quality or state of being obsequious.","pos":""}],"OBSEQUY":[{"def":"The last duty or service to a person, rendered after his death; hence, a rite or ceremony pertaining to burial; -- now used only in the plural.","pos":""}],"OBSERVABLE":[{"def":"Worthy or capable of being observed; discernible; noticeable; remarkable.","pos":""}],"OBSERVANCE":[{"def":"The act or practice of observing or noticing with attention; a heeding or keeping with care; performance; -- usually with a sense of strictness and fidelity; as, the observance of the Sabbath is general; the strict observance of duties.","pos":""},{"def":"An act, ceremony, or rite, as of worship or respect; especially, a customary act or service of attention; a form; a practice; a rite; a custom.","pos":""}],"OBSERVANDUM":[{"def":"A thing to be observed.","pos":""}],"OBSERVANT":[{"def":"Taking notice; viewing or noticing attentively; watchful; attentive; as, an observant spectator; observant habits.","pos":""},{"def":"Submissively attentive; obediently watchful; regardful; mindful; obedient (to); -- with of, as, to be observant of rules.","pos":""}],"OBSERVANTINE":[{"def":"One of a branch of the Order of Franciscans, who profess to adhere more strictly than the Conventuals to the intention of the founder, especially as to poverty; -- called also Observants.","pos":""}],"OBSERVANTLY":[{"def":"In an observant manner.","pos":""}],"OBSERVATION":[{"def":"The act or the faculty of observing or taking notice; the act of seeing, or of fixing the mind upon, anything.","pos":""},{"def":"The result of an act, or of acts, of observing; view; reflection; conclusion; judgment.","pos":""}],"OBSERVATION CAR":[{"def":"A railway passenger car made so as to facilitate seeing the scenery en route; a car open, or with glass sides, or with a kind of open balcony at the rear.","pos":""}],"OBSERVATIONAL":[{"def":"Of a pertaining to observation; consisting of, or containing, observations.","pos":""}],"OBSERVATIVE":[{"def":"Observing; watchful.","pos":""}],"OBSERVATOR":[{"def":"One who observes or takes notice.","pos":""},{"def":"One who makes a remark.","pos":""}],"OBSERVATORY":[{"def":"A lookout on a flank of a battery whence an officer can note the range and effect of the fire.","pos":""}],"OBSERVE":[{"def":"To take notice of by appropriate conduct; to conform one's action or practice to; to keep; to heed; to obey; to comply with; as, to observe rules or commands; to observe civility.","pos":""},{"def":"To be on the watch respecting; to pay attention to; to notice with care; to see; to perceive; to discover; as, to observe an eclipse; to observe the color or fashion of a dress; to observe the movements of an army.","pos":""}],"OBSERVER":[{"def":"One who observes, or pays attention to, anything; especially, one engaged in, or trained to habits of, close and exact observation; as, an astronomical observer.","pos":""},{"def":"One who keeps any law, custom, regulation, rite, etc.","pos":""}],"OBSERVERSHIP":[{"def":"The office or work of an observer.","pos":""}],"OBSERVING":[{"def":"Giving particular attention; habitually attentive to what passes; as, an observing person; an observing mind.","pos":""}],"OBSESS":[{"def":"To besiege; to beset.","pos":""}],"OBSESSION":[{"def":"The act of besieging.","pos":""},{"def":"The state of being besieged; -- used specifically of a person beset by a spirit from without.","pos":""}],"OBSIDIAN":[{"def":"A kind of glass produced by volcanoes.","pos":""}],"OBSIDIONAL":[{"def":"Of or pertaining to a siege.","pos":""}],"OBSIGN":[{"def":"To seal; to confirm, as by a seal or stamp.","pos":""}],"OBSIGNATE":[{"def":"To seal; to ratify.","pos":""}],"OBSIGNATION":[{"def":"The act of sealing or ratifying; the state of being sealed or confirmed; confirmation, as by the Holy Spirit.","pos":""}],"OBSIGNATORY":[{"def":"Ratifying; confirming by sealing.","pos":""}],"OBSOLESCE":[{"def":"To become obsolescent.","pos":""}],"OBSOLESCENCE":[{"def":"The state of becoming obsolete.","pos":""}],"OBSOLESCENT":[{"def":"Going out of use; becoming obsolete; passing into desuetude.","pos":""}],"OBSOLETE":[{"def":"Not very distinct; obscure; rudimental; imperfectly developed; abortive.","pos":""}],"OBSOLETELY":[{"def":"In an obsolete manner.","pos":""}],"OBSOLETENESS":[{"def":"Indistinctness; want of development.","pos":""}],"OBSOLETISM":[{"def":"A disused word or phrase; an archaism.","pos":""}],"OBSTACLE":[{"def":"That which stands in the way, or opposes; anything that hinders progress; a hindrance; an obstruction, physical or moral.","pos":""}],"OBSTANCY":[{"def":"Opposition; impediment; obstruction.","pos":""},{"def":"Of or pertaining to midwifery, or the delivery of women in childbed; as, the obstetric art.","pos":""}],"OBSTETRICATE":[{"def":"To perform the office of midwife.","pos":""}],"OBSTETRICATION":[{"def":"The act of assisting as a midwife; delivery.","pos":""}],"OBSTETRICIAN":[{"def":"One skilled in obstetrics; an accoucheur.","pos":""}],"OBSTETRICIOUS":[{"def":"Serving to assist childbirth; obstetric; hence, facilitating any bringing forth or deliverance.","pos":""}],"OBSTETRICS":[{"def":"The science of midwifery; the art of assisting women in parturition, or in the trouble incident to childbirth.","pos":""}],"OBSTINACY":[{"def":"A fixedness in will, opinion, or resolution that can not be shaken at all, or only with great difficulty; firm and usually unreasonable adherence to an opinion, purpose, or system; unyielding disposition; stubborness; pertinacity; persistency; contumacy.","pos":""},{"def":"The quality or state of being difficult to remedy, relieve, or subdue; as, the obstinacy of a disease or evil.","pos":""}],"OBSTINATE":[{"def":"Pertinaciously adhering to an opinion, purpose, or course; persistent; not yielding to reason, arguments, or other means; stubborn; pertinacious; -- usually implying unreasonableness.","pos":""},{"def":"Not yielding; not easily subdued or removed; as, obstinate fever; obstinate obstructions.","pos":""}],"OBSTINATION":[{"def":"Obstinacy; stubbornness.","pos":""}],"OBSTIPATION":[{"def":"Extreme constipation.","pos":""}],"OBSTREPEROUS":[{"def":"Attended by, or making, a loud and tumultuous noise; clamorous; noisy; vociferous.","pos":""}],"OBSTRICTION":[{"def":"The state of being constrained, bound, or obliged; that which constrains or obliges; obligation; bond.","pos":""}],"OBSTRINGE":[{"def":"To constrain; to put under obligation.","pos":""}],"OBSTRUCT":[{"def":"To block up; to stop up or close, as a way or passage; to place an obstacle in, or fill with obstacles or impediments that prevent or hinder passing; as, to obstruct a street; to obstruct the channels of the body.","pos":""},{"def":"To be, or come, in the way of; to hinder from passing; to stop; to impede; to retard; as, the bar in the harbor obstructs the passage of ships; clouds obstruct the light of the sun; unwise rules obstruct legislation.","pos":""}],"OBSTRUCTER":[{"def":"One who obstructs or hinders.","pos":""}],"OBSTRUCTION":[{"def":"The act of obstructing, or state of being obstructed.","pos":""},{"def":"That which obstructs or impedes; an obstacle; an impediment; a hindrance.","pos":""}],"OBSTRUCTIONISM":[{"def":"The act or the policy of obstructing progress.","pos":""}],"OBSTRUCTIONIST":[{"def":"One who hinders progress; one who obstructs business, as in a legislative body.","pos":""},{"def":"Of or pertaining to obstructionists.","pos":""}],"OBSTRUCTIVE":[{"def":"Tending to obstruct; presenting obstacles; hindering; causing impediment.","pos":""}],"OBSTRUENT":[{"def":"Causing obstruction; blocking up; hindering; as, an obstruent medicine.","pos":""}],"OBSTUPEFACTION":[{"def":"See Stupefaction.","pos":""}],"OBSTUPEFACTIVE":[{"def":"Ob*stu`pe*fac\"tive, a.","pos":""}]}