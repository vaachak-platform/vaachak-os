{"GEE":[{"def":"To turn to the off side, or from the driver (i.","pos":""}],"GEEST":[{"def":"Alluvial matter on the surface of land, not of recent origin.","pos":""}],"GEEZ":[{"def":"The original native name for the ancient Ethiopic language or people.","pos":""}],"GEEZER":[{"def":"A queer old fellow; an old chap; an old woman.","pos":""}]}