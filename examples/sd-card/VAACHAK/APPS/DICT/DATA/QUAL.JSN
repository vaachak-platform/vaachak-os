{"QUALIFIABLE":[{"def":"Capable of being qualified; abatable; modifiable.","pos":""}],"QUALIFICATION":[{"def":"The act of qualifying, or the condition of being qualified.","pos":""},{"def":"That which qualifies; any natural endowment, or any acquirement, which fits a person for a place, office, or employment, or which enables him to sustian any character with success; an enabling quality or circumstance; requisite capacity or possession.","pos":""}],"QUALIFICATIVE":[{"def":"That which qualifies, modifies, or restricts; a qualifying term or statement.","pos":""}],"QUALIFICATOR":[{"def":"An officer whose business it is to examine and prepare causes for trial in the ecclesiastical courts.","pos":""}],"QUALIFIED":[{"def":"Fitted by accomplishments or endowments.","pos":""},{"def":"Modified; limited; as, a qualified statement.","pos":""}],"QUALIFIEDLY":[{"def":"In the way of qualification; with modification or qualification.","pos":""}],"QUALIFIEDNESS":[{"def":"The state of being qualified.","pos":""}],"QUALIFIER":[{"def":", One who, or that which, qualifies; that which modifies, reduces, tempers or restrains.","pos":""}],"QUALIFY":[{"def":"To give individual quality to; to modulate; to vary; to regulate.","pos":""}],"QUALITATIVE":[{"def":"Relating to quality; having the character of quality.","pos":""}],"QUALITIED":[{"def":"Furnished with qualities; endowed.","pos":""}],"QUALITY":[{"def":"The condition of being of such and such a sort as distinguished from others; nature or character relatively considered, as of goods; character; sort; rank.","pos":""},{"def":"Special or temporary character; profession; occupation; assumed or asserted rank, part, or position.","pos":""}],"QUALM":[{"def":"Sickness; disease; pestilence; death.","pos":""},{"def":"A sudden attack of illness, faintness, or pain; an agony.","pos":""}],"QUALMISH":[{"def":"Sick at the stomach; affected with nausea or sickly languor; inclined to vomit.","pos":""}]}