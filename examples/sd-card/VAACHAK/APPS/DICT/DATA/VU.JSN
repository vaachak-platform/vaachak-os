{"VULCAN":[{"def":"The god of fire, who presided over the working of metals; -- answering to the Greek Hephæstus.","pos":""}],"VULCAN POWDER":[{"def":"A dynamite composed of nitroglycerin (30 parts), sodium nitrate (52.","pos":""}],"VULCANIAN":[{"def":"Of or pertaining to Vulcan; made by Vulcan; hence, of or pertaining to works in iron or other metals.","pos":""}],"VULCANIC":[{"def":"Of or pertaining to Vulcan; made by Vulcan; Vulcanian.","pos":""},{"def":"Of or pertaining to volcanoes; specifically, relating to the geological theory of the Vulcanists, or Plutonists.","pos":""}],"VULCANITE":[{"def":"Hard rubber produced by vulcanizing with a large proportion of sulphur.","pos":""}],"VULCANIZATION":[{"def":"The act or process of imparting to caoutchouc, gutta-percha, or the like, greater elasticity, durability, or hardness by heating with sulphur under pressure.","pos":""}],"VULCANIZE":[{"def":"To change the properties of, as caoutchouc, or India rubber, by the process of vulcanization.","pos":""}],"VULCANIZER":[{"def":"One who, or that which, vulcanizes; esp.","pos":""}],"VULCANOLOGY":[{"def":"The science which treats of phenomena due to plutonic action, as in volcanoes, hot springs, etc.","pos":""}],"VULGAR":[{"def":"Of or pertaining to the mass, or multitude, of people; common; general; ordinary; public; hence, in general use; vernacular.","pos":""},{"def":"Belonging or relating to the common people, as distinguished from the cultivated or educated; pertaining to common life; plebeian; not select or distinguished; hence, sometimes, of little or no value.","pos":""}],"VULGARIAN":[{"def":"A vulgar person; one who has vulgar ideas.","pos":""}],"VULGARISM":[{"def":"Grossness; rudeness; vulgarity.","pos":""},{"def":"A vulgar phrase or expression.","pos":""}],"VULGARITY":[{"def":"The quality or state of being vulgar; mean condition of life; the state of the lower classes of society.","pos":""},{"def":"Grossness or clownishness of manners of language; absence of refinement; coarseness.","pos":""}],"VULGARIZATION":[{"def":"The act or process of making vulgar, or common.","pos":""}],"VULGARIZE":[{"def":"To make vulgar, or common.","pos":""}],"VULGARLY":[{"def":"In a vulgar manner.","pos":""}],"VULGARNESS":[{"def":"The quality of being vulgar.","pos":""}],"VULGATE":[{"def":"An ancient Latin version of the Scripture, and the only version which the Roman Church admits to be authentic; -- so called from its common use in the Latin Church.","pos":""}],"VULNERABILITY":[{"def":"The quality or state of being vulnerable; vulnerableness.","pos":""}],"VULNERABLE":[{"def":"Capable of being wounded; susceptible of wounds or external injuries; as, a vulnerable body.","pos":""},{"def":"Liable to injury; subject to be affected injuriously; assailable; as, a vulnerable reputation.","pos":""}],"VULNERABLENESS":[{"def":"The quality or state of being vulnerable; vulnerability.","pos":""}],"VULNERARY":[{"def":"Useful in healing wounds; adapted to the cure of external injuries; as, vulnerary plants or potions.","pos":""},{"def":"A vulnerary remedy.","pos":""}],"VULNERATE":[{"def":"To wound; to hurt.","pos":""}],"VULNERATION":[{"def":"The act of wounding, or the state of being wounded.","pos":""}],"VULNEROSE":[{"def":"Full of wounds; wounded.","pos":""},{"def":"Causing wounds; inflicting wounds; wounding.","pos":""}],"VULNOSE":[{"def":"Having wounds; vulnerose.","pos":""}],"VULPES":[{"def":"A genus of Carnivora including the foxes.","pos":""}],"VULPIC":[{"def":"Pertaining to, derived from, or designating, an acid obtained from a lichen (Cetraria vulpina) as a yellow or red crystalline substance which on decomposition yields pulvinic acid.","pos":""}],"VULPICIDE":[{"def":"One who kills a fox, except in hunting; also, the act of so killing a fox.","pos":""}],"VULPINE":[{"def":"Of or pertaining to the fox; resembling the fox; foxy; cunning; crafty; artful.","pos":""}],"VULPINISM":[{"def":"The quality of being cunning like the fox; craft; artfulness.","pos":""}],"VULPINITE":[{"def":"A scaly granular variety of anhydrite of a grayish white color, used for ornamental purposes.","pos":""}],"VULTERN":[{"def":"The brush turkey (Talegallus Lathami) of Australia.","pos":""}],"VULTURE":[{"def":"Any one of numerous species of rapacious birds belonging to Vultur, Cathartes, Catharista, and various other genera of the family Vulturidæ.","pos":""}],"VULTURINE":[{"def":"Of or pertaining to a vulture; resembling a vulture in qualities or looks; as, the vulturine sea eagle (Gypohierax Angolensis); vulturine rapacity.","pos":""}],"VULTURISM":[{"def":"The quality or state of being like a vulture; rapaciousness.","pos":""}],"VULTUROUS":[{"def":"Like a vulture; rapacious.","pos":""}],"VULVA":[{"def":"The external parts of the female genital organs; sometimes, the opening between the projecting parts of the external organs.","pos":""},{"def":"The orifice of the oviduct of an insect or other invertebrate.","pos":""}],"VULVIFORM":[{"def":"Like a cleft with projecting edges.","pos":""}],"VULVITIS":[{"def":"Inflammation of the vulva.","pos":""}],"VULVO-UTERINE":[{"def":"Pertaining both to the vulva and the uterus.","pos":""}],"VULVOVAGINAL":[{"def":"Pertaining both to the vulva and the vagina.","pos":""}]}