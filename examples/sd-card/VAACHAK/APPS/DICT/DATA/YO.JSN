{"YODE":[{"def":"Went; walked; proceeded.","pos":""},{"def":"To sing in a manner common among the Swiss and Tyrolese mountaineers, by suddenly changing from the head voice, or falsetto, to the chest voice, and the contrary; to warble.","pos":""}],"YOGA":[{"def":"A species of asceticism among the Hindoos, which consists in a complete abstraction from all worldly objects, by which the votary expects to obtain union with the universal spirit, and to acquire superhuman faculties.","pos":""}],"YOGI":[{"def":"A follower of the yoga philosophy; an ascetic.","pos":""}],"YOGISM":[{"def":"Yoga, or its practice.","pos":""}],"YOICKS":[{"def":"A cry of encouragement to foxhounds.","pos":""}],"YOIT":[{"def":"The European yellow-hammer.","pos":""}],"YOJAN":[{"def":"A measure of distance, varying from four to ten miles, but usually about five.","pos":""}],"YOKE":[{"def":"A bar or frame of wood by which two oxen are joined at the heads or necks for working together.","pos":""},{"def":"A frame or piece resembling a yoke, as in use or shape.","pos":""}],"YOKE-TOED":[{"def":"Having two toes in front and two behind, as the trogons and woodpeckers.","pos":""}],"YOKEFELLOW":[{"def":"An associate or companion in, or as in; a mate; a fellow; especially, a partner in marriage.","pos":""}],"YOKEL":[{"def":"A country bumpkin.","pos":""}],"YOKELET":[{"def":"A small farm; -- so called as requiring but one yoke of oxen to till it.","pos":""}],"YOKEMATE":[{"def":"Same as Yokefellow.","pos":""}],"YOLK":[{"def":"An oily secretion which naturally covers the wool of sheep.","pos":""}],"YOM":[{"def":"Day; -- a Hebrew word used in the names of various Jewish feast days; as, Yom Kippur, the Day of Atonement; Yom Teruah (lit.","pos":""}],"YON":[{"def":"At a distance, but within view; yonder.","pos":""}],"YONCOPIN":[{"def":"A local name in parts of the Mississippi Valley for the American lotus (Nelumbo lutea).","pos":""}],"YOND":[{"def":"Furious; mad; angry; fierce.","pos":""}],"YONDER":[{"def":"At a distance, but within view.","pos":""}],"YONI":[{"def":"The symbol under which Sakti, or the personification of the female power in nature, is worshiped.","pos":""}],"YONKER":[{"def":"A young fellow; a younker.","pos":""}],"YORE":[{"def":"In time long past; in old time; long since.","pos":""}],"YORK RITE":[{"def":"The rite or ceremonial observed by one of the Masonic systems, deriving its name from the city of York, in England; also, the system itself, which, in England, confers only the first three degrees.","pos":""}],"YORK USE":[{"def":"The one of the three printed uses of England which was followed in the north.","pos":""}],"YORKSHIRE":[{"def":"A county in the north of England.","pos":""}],"YOT":[{"def":"To unite closely.","pos":""}],"YOTE":[{"def":"To pour water on; to soak in, or mix with, water.","pos":""}],"YOU":[{"def":"The pronoun of the second person, in the nominative, dative, and objective case, indicating the person or persons addressed.","pos":""}],"YOUL":[{"def":"To yell; to yowl.","pos":""}],"YOUNG":[{"def":"Not long born; still in the first part of life; not yet arrived at adolescence, maturity, or age; not old; juvenile; -- said of animals; as, a young child; a young man; a young fawn.","pos":""},{"def":"Being in the first part, pr period, of growth; as, a young plant; a young tree.","pos":""}],"YOUNG ONE":[{"def":"A young human being; a child; also, a young animal, as a colt.","pos":""}],"YOUNGGER":[{"def":"One who is younger; an inferior in age; a junior.","pos":""}],"YOUNGLING":[{"def":"A young person; a youth; also, any animal in its early life.","pos":""}],"YOUNGLY":[{"def":"Like a young person or thing; young; youthful.","pos":""}],"YOUNGNESS":[{"def":"The quality or state of being young.","pos":""}],"YOUNGSTER":[{"def":"A young person; a youngling; a lad.","pos":""}],"YOUNGTH":[{"def":"Youngth is a bubble blown up with breath.","pos":""}],"YOUNGTHLY":[{"def":"Pertaining to, or resembling, youth; youthful.","pos":""},{"def":"An organization for promoting the spiritual, intellectual, social, and economic welfare of young women, originating in 1855 with Lady Kinnaird's home for young women, and Miss Emma Robert's prayer union for young women,in England, which were combined in the year 1884 as a national association.","pos":""}],"YOUNKER":[{"def":"A young person; a stripling; a yonker.","pos":""}],"YOUR":[{"def":"The form of the possessive case of the personal pronoun you.","pos":""}],"YOURS":[{"def":"See the Note under Your.","pos":""}],"YOURSELF":[{"def":"An emphasized or reflexive form of the pronoun of the second person; -- used as a subject commonly with you; as, you yourself shall see it; also, alone in the predicate, either in the nominative or objective case; as, you have injured yourself.","pos":""}],"YOUTH":[{"def":"The quality or state of being young; youthfulness; juvenility.","pos":""},{"def":"The part of life that succeeds to childhood; the period of existence preceding maturity or age; the whole early part of life, from childhood, or, sometimes, from infancy, to manhood.","pos":""}],"YOUTHFUL":[{"def":"Also used figuratively.","pos":""}],"YOUTHHOOD":[{"def":"The quality or state of being a youth; the period of youth.","pos":""}],"YOUTHLY":[{"def":"Young; youthful.","pos":""}],"YOWL":[{"def":"To utter a loud, long, and mournful cry, as a dog; to howl; to yell.","pos":""}],"YOWLEY":[{"def":"The European yellow-hammer.","pos":""}]}