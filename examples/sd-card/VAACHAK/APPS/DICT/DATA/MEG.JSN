{"MEGACHILE":[{"def":"A leaf-cutting bee of the genus Megachilus.","pos":""}],"MEGACOULOMB":[{"def":"A million coulombs.","pos":""}],"MEGADERM":[{"def":"Any one of several species of Old World blood-sucking bats of the genus Megaderma.","pos":""}],"MEGADYNE":[{"def":"One of the larger measures of force, amounting to one million dynes.","pos":""}],"MEGAFARAD":[{"def":"One of the larger measures of electrical capacity, amounting to one million farads; a macrofarad.","pos":""}],"MEGALERG":[{"def":"A million ergs; a megerg.","pos":""}],"MEGALESIAN":[{"def":"Pertaining to, or in honor of, Cybele; as, the Megalesian games at Rome.","pos":""}],"MEGALETHOSCOPE":[{"def":"An optical apparatus in which pictures are viewed through a large lens with stereoptical effects.","pos":""}],"MEGALITH":[{"def":"A large stone; especially, a large stone used in ancient building.","pos":""}],"MEGALO-":[{"def":"The condition of having an abnormally large head.","pos":""}],"MEGALOCYTE":[{"def":"A large, flattened corpuscle, twice the diameter of the ordinary red corpuscle, found in considerable numbers in the blood in profound anæmia.","pos":""}],"MEGALOMANIA":[{"def":"A form of mental alienation in which the patient has grandiose delusions.","pos":""}],"MEGALONYX":[{"def":"An extinct quaternary mammal, of great size, allied to the sloth.","pos":""}],"MEGALOPHONOUS":[{"def":"Having a loud voice.","pos":""}],"MEGALOPOLIS":[{"def":"A chief city; a metropolis.","pos":""}],"MEGALOPS":[{"def":"A larva, in a stage following the zoëa, in the development of most crabs.","pos":""},{"def":"A large fish; the tarpum.","pos":""}],"MEGALOPSYCHY":[{"def":"Greatness of soul.","pos":""},{"def":"A gigantic carnivorous dinosaur, whose fossil remains have been found in England and elsewhere.","pos":""}],"MEGAMETER":[{"def":"In the metric system, one million meters, or one thousand kilometers.","pos":""}],"MEGAMPERE":[{"def":"A million ampères.","pos":""}],"MEGAPHONE":[{"def":"A device to magnify sound, or direct it in a given direction in a greater volume, as a very large funnel used as an ear trumpet or as a speaking trumpet.","pos":""}],"MEGAPHYTON":[{"def":"An extinct genus of tree ferns with large, two-ranked leaves, or fronds.","pos":""}],"MEGAPODE":[{"def":"Any one of several species of large-footed, gallinaceous birds of the genera Megapodius and Leipoa, inhabiting Australia and other Pacific islands.","pos":""}],"MEGAPOLIS":[{"def":"Belonging, or pertaining, to Megara, a city of ancient Greece.","pos":""}],"MEGASCOPE":[{"def":"A modification of the magic lantern, used esp.","pos":""}],"MEGASEME":[{"def":"Having the orbital index relatively large; having the orbits narrow transversely; -- opposed to microseme.","pos":""}],"MEGASTHENE":[{"def":"One of a group which includes the higher orders of mammals, having a large size as a typical characteristic.","pos":""}],"MEGASTHENIC":[{"def":"Having a typically large size; belonging to the megasthenes.","pos":""}],"MEGASTOME":[{"def":"One of a group of univalve shells, having a large aperture or mouth.","pos":""},{"def":"An extinct gigantic quaternary mammal, allied to the ant-eaters and sloths.","pos":""}],"MEGATHEROID":[{"def":"One of a family of extinct edentates found in America.","pos":""}],"MEGAVOLT":[{"def":"One of the larger measures of electro-motive force, amounting to one million volts.","pos":""}],"MEGAWEBER":[{"def":"A million webers.","pos":""}],"MEGERG":[{"def":"One of the larger measures of work, amounting to one million ergs; -- called also megalerg.","pos":""},{"def":"A gelatinous compound of linseed oil and mastic varnish, used by artists as a vehicle for colors.","pos":""}],"MEGOHM":[{"def":"One of the larger measures of electrical resistance, amounting to one million ohms.","pos":""}],"MEGRIM":[{"def":"A sudden vertigo in a horse, succeeded sometimes by unconsciousness, produced by an excess of blood in the brain; a mild form of apoplexy.","pos":""}]}