{"ADMARGINATE":[{"def":"To write in the margin.","pos":""}],"ADMAXILLARY":[{"def":"Near to the maxilla or jawbone.","pos":""}],"ADMEASURE":[{"def":"To determine the proper share of, or the proper apportionment; as, to admeasure dower; to admeasure common of pasture.","pos":""},{"def":"Formerly, the adjustment of proportion, or ascertainment of shares, as of dower or pasture held in common.","pos":""}],"ADMEASURER":[{"def":"One who admeasures.","pos":""}],"ADMENSURATION":[{"def":"Same as Admeasurement.","pos":""}],"ADMINICLE":[{"def":"Corroborative or explanatory proof.","pos":""}],"ADMINICULAR":[{"def":"Supplying help; auxiliary; corroborative; explanatory; as, adminicular evidence.","pos":""}],"ADMINISTER":[{"def":"To settle, as the estate of one who dies without a will, or whose will fails of an executor.","pos":""}],"ADMINISTERIAL":[{"def":"Pertaining to administration, or to the executive part of government.","pos":""}],"ADMINISTRABLE":[{"def":"Capable of being administered; as, an administrable law.","pos":""}],"ADMINISTRANT":[{"def":"Executive; acting; managing affairs.","pos":""},{"def":"One who administers.","pos":""}],"ADMINISTRATION":[{"def":"The act of administering; government of public affairs; the service rendered, or duties assumed, in conducting affairs; the conducting of any office or employment; direction; management.","pos":""},{"def":"The executive part of government; the persons collectively who are intrusted with the execution of laws and the superintendence of public affairs; the chief magistrate and his cabinet or council; or the council, or ministry, alone, as in Great Britain.","pos":""}],"ADMINISTRATIVE":[{"def":"Pertaining to administration; administering; executive; as, an administrative body, ability, or energy.","pos":""}],"ADMINISTRATOR":[{"def":"A man who manages or settles the estate of an intestate, or of a testator when there is no competent executor; one to whom the right of administration has been committed by competent authority.","pos":""}],"ADMINISTRATORSHIP":[{"def":"The position or office of an administrator.","pos":""}],"ADMINISTRATRIX":[{"def":"A woman who administers; esp.","pos":""}],"ADMIRABLE":[{"def":"Fitted to excite wonder; wonderful; marvelous.","pos":""},{"def":"Having qualities to excite wonder united with approbation; deserving the highest praise; most excellent; -- used of persons or things.","pos":""}],"ADMIRABLENESS":[{"def":"The quality of being admirable; wonderful excellence.","pos":""}],"ADMIRABLY":[{"def":"In an admirable manner.","pos":""}],"ADMIRAL":[{"def":"A handsome butterfly (Pyrameis Atalanta) of Europe and America.","pos":""}],"ADMIRALSHIP":[{"def":"The office or position oaf an admiral; also, the naval skill of an admiral.","pos":""}],"ADMIRALTY":[{"def":"The office or jurisdiction of an admiral.","pos":""},{"def":"The department or officers having authority over naval affairs generally.","pos":""}],"ADMIRATION":[{"def":"Wonder; astonishment.","pos":""},{"def":"Wonder mingled with approbation or delight; an emotion excited by a person or thing possessed of wonderful or high excellence; as, admiration of a beautiful woman, of a landscape, of virtue.","pos":""}],"ADMIRATIVE":[{"def":"Relating to or expressing admiration or wonder.","pos":""}],"ADMIRE":[{"def":"To regard with wonder or astonishment; to view with surprise; to marvel at.","pos":""},{"def":"To regard with wonder and delight; to look upon with an elevated feeling of pleasure, as something which calls out approbation, esteem, love, or reverence; to estimate or prize highly; as, to admire a person of high moral worth, to admire a landscape.","pos":""}],"ADMIRED":[{"def":"Regarded with wonder and delight; highly prized; as, an admired poem.","pos":""},{"def":"Wonderful; also, admirable.","pos":""}],"ADMIRER":[{"def":"One who admires; one who esteems or loves greatly.","pos":""}],"ADMIRING":[{"def":"Expressing admiration; as, an admiring glance.","pos":""}],"ADMISSIBILITY":[{"def":"The quality of being admissible; admissibleness; as, the admissibility of evidence.","pos":""}],"ADMISSIBLE":[{"def":"Entitled to be admitted, or worthy of being admitted; that may be allowed or conceded; allowable; as, the supposition is hardly admissible.","pos":""}],"ADMISSION":[{"def":"Acquiescence or concurrence in a statement made by another, and distinguishable from a confession in that an admission presupposes prior inquiry by another, but a confession may be made without such inquiry.","pos":""},{"def":"Declaration of the bishop that he approves of the presentee as a fit person to serve the cure of the church to which he is presented.","pos":""}],"ADMISSIVE":[{"def":"Implying an admission; tending to admit.","pos":""}],"ADMISSORY":[{"def":"Pertaining to admission.","pos":""}],"ADMIT":[{"def":"To suffer to enter; to grant entrance, whether into a place, or into the mind, or consideration; to receive; to take; as, they were into his house; to admit a serious thought into the mind; to admit evidence in the trial of a cause.","pos":""},{"def":"To give a right of entrance; as, a ticket one into a playhouse.","pos":""}],"ADMITTANCE":[{"def":"The act of giving possession of a copyhold estate.","pos":""}],"ADMITTATUR":[{"def":"The certificate of admission given in some American colleges.","pos":""},{"def":"Received as true or valid; acknowledged.","pos":""}],"ADMIX":[{"def":"To mingle with something else; to mix.","pos":""}],"ADMIXTION":[{"def":"A mingling of different things; admixture.","pos":""}],"ADMIXTURE":[{"def":"The act of mixing; mixture.","pos":""},{"def":"The compound formed by mixing different substances together.","pos":""}],"ADMONISH":[{"def":"To warn or notify of a fault; to reprove gently or kindly, but seriously; to exhort.","pos":""},{"def":"To counsel against wrong practices; to cation or advise; to warn against danger or an offense; -- followed by of, against, or a subordinate clause.","pos":""}],"ADMONISHER":[{"def":"One who admonishes.","pos":""}],"ADMONITION":[{"def":"Gentle or friendly reproof; counseling against a fault or error; expression of authoritative advice; friendly caution or warning.","pos":""}],"ADMONITOR":[{"def":"Admonisher; monitor.","pos":""}],"ADMONITORY":[{"def":"That conveys admonition; warning or reproving; as, an admonitory glance.","pos":""}],"ADMONITRIX":[{"def":"A female admonitor.","pos":""}],"ADMORTIZATION":[{"def":"The reducing or lands or tenements to mortmain.","pos":""}],"ADMOVE":[{"def":"To move or conduct to or toward.","pos":""}]}