{"DEHISCE":[{"def":"To gape; to open by dehiscence.","pos":""}],"DEHISCENCE":[{"def":"A gaping or bursting open along a definite line of attachment or suture, without tearing, as in the opening of pods, or the bursting of capsules at maturity so as to emit seeds, etc.","pos":""}],"DEHISCENT":[{"def":"Characterized by dehiscence; opening in some definite way, as the capsule of a plant.","pos":""}],"DEHONESTATION":[{"def":"A dishonoring; disgracing.","pos":""}],"DEHORN":[{"def":"To deprive of horns; to prevent the growth or the horns of (cattle) by burning their ends soon after they start.","pos":""}],"DEHORS":[{"def":"Out of; without; foreign to; out of the agreement, record, will, or other instrument.","pos":""}],"DEHORT":[{"def":"To urge to abstain or refrain; to dissuade.","pos":""}],"DEHORTATION":[{"def":"Dissuasion; advice against something.","pos":""}],"DEHORTATORY":[{"def":"Fitted or designed to dehort or dissuade.","pos":""}],"DEHORTER":[{"def":"A dissuader; an adviser to the contrary.","pos":""}],"DEHUMANIZE":[{"def":"To divest of human qualities, such as pity, tenderness, etc.","pos":""}],"DEHUSK":[{"def":"To remove the husk from.","pos":""}],"DEHYDRATE":[{"def":"To deprive of water; to render free from water; as, to dehydrate alcohol.","pos":""}],"DEHYDRATION":[{"def":"The act or process of freeing from water; also, the condition of a body from which the water has been removed.","pos":""}],"DEHYDROGENATE":[{"def":"To deprive of, or free from, hydrogen.","pos":""}],"DEHYDROGENATION":[{"def":"The act or process or freeing from hydrogen; also, the condition resulting from the removal of hydrogen.","pos":""}]}