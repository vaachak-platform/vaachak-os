{"TULA METAL":[{"def":"An alloy of silver, copper, and lead made at Tula in Russia.","pos":""}],"TULE":[{"def":"A large bulrush (Scirpus lacustris, and S.","pos":""}],"TULIP":[{"def":"Any plant of the liliaceous genus Tulipa.","pos":""}],"TULIP-EARED":[{"def":"Having erect, pointed ears; prick-eared; -- said of certain dogs.","pos":""}],"TULIP-SHELL":[{"def":"A large, handsomely colored, marine univalve shell (Fasciolaria tulipa) native of the Southern United States.","pos":""}],"TULIPIST":[{"def":"A person who is especially devoted to the cultivation of tulips.","pos":""}],"TULIPOMANIA":[{"def":"A violent passion for the acquisition or cultivation of tulips; -- a word said by Beckman to have been coined by Menage.","pos":""}],"TULIPOMANIAC":[{"def":"One who is affected with tulipomania.","pos":""}],"TULIPWOOD":[{"def":"The beautiful rose-colored striped wood of a Brazilian tree (Physocalymna floribunda), much used by cabinetmakers for inlaying.","pos":""}],"TULL":[{"def":"To allure; to tole.","pos":""}],"TULLE":[{"def":"A kind of silk lace or light netting, used for veils, etc.","pos":""}],"TULLIAN":[{"def":"Belonging to, or in the style of, Tully (Marcus Tullius Cicero).","pos":""}],"TULLIBEE":[{"def":"A whitefish (Coregonus tullibee) found in the Great Lakes of North America; -- called also mongrel whitefish.","pos":""}]}