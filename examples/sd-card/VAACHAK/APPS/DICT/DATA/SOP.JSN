{"SOP":[{"def":"Anything steeped, or dipped and softened, in any liquid; especially, something dipped in broth or liquid food, and intended to be eaten.","pos":""},{"def":"Anything given to pacify; -- so called from the sop given to Cerberus, as related in mythology.","pos":""}],"SOPH":[{"def":"A contraction of Soph ister.","pos":""}],"SOPHI":[{"def":"Teaching wisdom.","pos":""}],"SOPHIME":[{"def":"I trow ye study aboute some sophime.","pos":""}],"SOPHISM":[{"def":"The doctrine or mode of reasoning practiced by a sophist; hence, any fallacy designed to deceive.","pos":""}],"SOPHIST":[{"def":"One of a class of men who taught eloquence, philosophy, and politics in ancient Greece; especially, one of those who, by their fallacious but plausible reasoning, puzzled inquirers after truth, weakened the faith of the people, and drew upon themselves general hatred and contempt.","pos":""},{"def":"Hence, an impostor in argument; a captious or fallacious reasoner.","pos":""}],"SOPHISTER":[{"def":"A student who is advanced beyond the first year of his residence.","pos":""}],"SOPHISTICATE":[{"def":"To render worthless by admixture; to adulterate; to damage; to pervert; as, to sophisticate wine.","pos":""},{"def":"Adulterated; not pure; not genuine.","pos":""}],"SOPHISTICATION":[{"def":"The act of sophisticating; adulteration; as, the sophistication of drugs.","pos":""}],"SOPHISTICATOR":[{"def":"One who sophisticates.","pos":""}],"SOPHISTRY":[{"def":"The art or process of reasoning; logic.","pos":""},{"def":"The practice of a sophist; fallacious reasoning; reasoning sound in appearance only.","pos":""}],"SOPHOMORE":[{"def":"One belonging to the second of the four classes in an American college, or one next above a freshman.","pos":""},{"def":"Of or pertaining to a sophomore; resembling a sophomore; hence, pretentious; inflated in style or manner; as, sophomoric affectation.","pos":""}],"SOPITE":[{"def":"To lay asleep; to put to sleep; to quiet.","pos":""}],"SOPITION":[{"def":"The act of putting to sleep, or the state of being put to sleep; sleep.","pos":""}],"SOPOR":[{"def":"Profound sleep from which a person can be roused only with difficulty.","pos":""}],"SOPORATE":[{"def":"To lay or put to sleep; to stupefy.","pos":""}],"SOPORIFEROUS":[{"def":"Causing sleep; somniferous; soporific.","pos":""}],"SOPORIFIC":[{"def":"Causing sleep; tending to cause sleep; soporiferous; as, the soporific virtues of opium.","pos":""}],"SOPPING":[{"def":"more recent version of soppy.","pos":""}],"SOPPY":[{"def":"Soaked or saturated with liquid or moisture; very wet or sloppy.","pos":""}],"SOPRA":[{"def":"Above; before; over; upon.","pos":""}],"SOPRANIST":[{"def":"A treble singer.","pos":""}],"SOPSAVINE":[{"def":"See Sops of wine, under Sop.","pos":""}]}