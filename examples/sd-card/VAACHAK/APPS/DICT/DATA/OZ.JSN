{"OZENA":[{"def":"A discharge of fetid matter from the nostril, particularly if associated with ulceration of the soft parts and disease of the bones of the nose.","pos":""}],"OZOCERITE":[{"def":"A waxlike mineral resin; -- sometimes called native paraffin, and mineral wax.","pos":""}],"OZONATION":[{"def":"The act of treating with ozone; also, the act of converting into, or producing, ozone; ozonization.","pos":""}],"OZONE PAPER":[{"def":"Paper coated with starch and potassium iodine.","pos":""}],"OZONIC":[{"def":"Pertaining to, resembling, or containing, ozone.","pos":""}],"OZONIFICATION":[{"def":"The act or process of producing, or of subjecting to the action of, ozone.","pos":""}],"OZONIZER":[{"def":"An apparatus or agent for the production or application of ozone.","pos":""}],"OZONOMETER":[{"def":"An instrument for ascertaining the amount of ozone in the atmosphere, or in any gaseous mixture.","pos":""}],"OZONOMETRIC":[{"def":"Pertaining to, or used for, the determination of the amount of ozone; of or relating to ozonometry.","pos":""}],"OZONOMETRY":[{"def":"The measurement or determination of the quantity of ozone.","pos":""}],"OZONOSCOPE":[{"def":"An apparatus employed to indicate the presence, or the amount, of ozone.","pos":""}],"OZONOSCOPIC":[{"def":"Serving to indicate the presence or the amount of ozone.","pos":""}],"OZONOUS":[{"def":"Pertaining to or containing, ozone.","pos":""},{"def":"the sixteenth letter of the English alphabet, is a nonvocal consonant whose form and value come from the Latin, into which language the letter was brought, through the ancient Greek, from the Phonician, its probable origin being Egyptian.","pos":""}]}