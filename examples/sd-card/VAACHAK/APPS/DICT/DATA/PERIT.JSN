{"PERITHECIUM":[{"def":"An organ in certain fungi and lichens, surrounding and enveloping the masses of fructification.","pos":""}],"PERITOMOUS":[{"def":"Cleaving in more directions than one, parallel to the axis.","pos":""}],"PERITONAEUM":[{"def":"Same as Peritoneum.","pos":""}],"PERITONEAL":[{"def":"Of or pertaining to the peritoneum.","pos":""}],"PERITONEUM":[{"def":"The smooth serous membrane which lines the cavity of the abdomen, or the whole body cavity when there is no diaphragm, and, turning back, surrounds the viscera, forming a closed, or nearly closed, sac.","pos":""}],"PERITONITIS":[{"def":"Inflammation of the peritoneum.","pos":""}],"PERITRACHEAL":[{"def":"Surrounding the tracheæ.","pos":""}],"PERITRICHA":[{"def":"A division of ciliated Infusoria having a circle of cilia around the oral disk and sometimes another around the body.","pos":""}],"PERITROCHIUM":[{"def":"The wheel which, together with the axle, forms the axis in peritrochio, which see under Axis.","pos":""}],"PERITROPAL":[{"def":"Rotatory; circuitous.","pos":""},{"def":"Having the axis of the seed perpendicular to the axis of the pericarp to which it is attached.","pos":""}],"PERITYPHLITIS":[{"def":"Inflammation of the connective tissue about the cæcum.","pos":""}]}