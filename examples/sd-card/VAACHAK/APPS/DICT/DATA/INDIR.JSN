{"INDIRECT":[{"def":"Not reaching the end aimed at by the most plain and direct method; as, an indirect proof, demonstration, etc.","pos":""}],"INDIRECTED":[{"def":"Not directed; aimless.","pos":""}],"INDIRECTION":[{"def":"Oblique course or means; dishonest practices; indirectness.","pos":""}],"INDIRECTLY":[{"def":"In an direct manner; not in a straight line or course; not in express terms; obliquely; not by direct means; hence, unfairly; wrongly.","pos":""}],"INDIRECTNESS":[{"def":"The quality or state of being indirect; obliquity; deviousness; crookedness.","pos":""},{"def":"Deviation from an upright or straightforward course; unfairness; dishonesty.","pos":""}],"INDIRETIN":[{"def":"A dark brown resinous substance obtained from indican.","pos":""}],"INDIRUBIN":[{"def":"A substance isomeric with, and resembling, indigo blue, and accompanying it as a side product, in its artificial production.","pos":""}]}