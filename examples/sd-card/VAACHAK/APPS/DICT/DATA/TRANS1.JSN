{"TRANS-":[{"def":"A prefix, signifying over, beyond, through and through, on the other side, as in transalpine, beyond the Alps; transform, to form through and through, that is, anew, transfigure.","pos":""}],"TRANSACT":[{"def":"To carry through; to do; perform; to manage; as, to transact commercial business; to transact business by an agent.","pos":""}],"TRANSACTION":[{"def":"An adjustment of a dispute between parties by mutual agreement.","pos":""}],"TRANSACTOR":[{"def":"One who transacts, performs, or conducts any business.","pos":""}],"TRANSALPINE":[{"def":"Being on the farther side of the Alps in regard to Rome, that is, on the north or west side of the Alps; of or pertaining to the region or the people beyond the Alps; as, transalpine Gaul; -- opposed to cisalpine.","pos":""}],"TRANSANIMATE":[{"def":"To animate with a soul conveyed from another body.","pos":""}],"TRANSANIMATION":[{"def":"The conveyance of a soul from one body to another.","pos":""}],"TRANSATLANTIC":[{"def":"Lying or being beyond the Atlantic Ocean.","pos":""},{"def":"Crossing the Atlantic Ocean.","pos":""}],"TRANSAUDIENT":[{"def":"Permitting the passage of sound.","pos":""}],"TRANSCALENCY":[{"def":"The quality or state of being transcalent.","pos":""}],"TRANSCALENT":[{"def":"Pervious to, or permitting the passage of, heat.","pos":""}],"TRANSCEND":[{"def":"To rise above; to surmount; as, lights in the heavens transcending the region of the clouds.","pos":""},{"def":"To pass over; to go beyond; to exceed.","pos":""}],"TRANSCENDENT":[{"def":"Transcending, or reaching beyond, the limits of human knowledge; -- applied to affirmations and speculations concerning what lies beyond the reach of the human intellect.","pos":""}],"TRANSCENDENTAL":[{"def":"In the Kantian system, of or pertaining to that which can be determined a priori in regard to the fundamental principles of all human knowledge.","pos":""}],"TRANSCENDENTALISM":[{"def":"The transcending, or going beyond, empiricism, and ascertaining a priori the fundamental principles of human knowledge.","pos":""}],"TRANSCENDENTALIST":[{"def":"One who believes in transcendentalism.","pos":""}],"TRANSCENDENTALITY":[{"def":"The quality or state of being transcendental.","pos":""}],"TRANSCENDENTALLY":[{"def":"In a transcendental manner.","pos":""}],"TRANSCENDENTLY":[{"def":"In a transcendent manner.","pos":""}],"TRANSCENDENTNESS":[{"def":"Same as Transcendence.","pos":""}],"TRANSCENSION":[{"def":"The act of transcending, or surpassing; also, passage over.","pos":""}],"TRANSCOLATE":[{"def":"To cause to pass through a sieve or colander; to strain, as through a sieve.","pos":""}],"TRANSCOLATION":[{"def":"Act of transcolating, or state of being transcolated.","pos":""}],"TRANSCONTINENTAL":[{"def":"Extending or going across a continent; as, a transcontinental railroad or journey.","pos":""}],"TRANSCORPORATE":[{"def":"To transmigrate.","pos":""}],"TRANSCRIBBLER":[{"def":"A transcriber; -- used in contempt.","pos":""}],"TRANSCRIBE":[{"def":"To write over again, or in the same words; to copy; as, to transcribe Livy or Tacitus; to transcribe a letter.","pos":""}],"TRANSCRIBER":[{"def":"One who transcribes, or writes from a copy; a copier; a copyist.","pos":""}],"TRANSCRIPT":[{"def":"A written version of what was said orally; as, a transcript of a trial.","pos":""}],"TRANSCRIPTION":[{"def":"The act or process of transcribing, or copying; as, corruptions creep into books by repeated transcriptions.","pos":""},{"def":"A copy; a transcript.","pos":""}],"TRANSCRIPTIVE":[{"def":"Done as from a copy; having the style or appearance of a transcription.","pos":""}],"TRANSCUR":[{"def":"To run or rove to and fro.","pos":""}],"TRANSCURRENCE":[{"def":"A roving hither and thither.","pos":""}],"TRANSCURSION":[{"def":"A rambling or ramble; a passage over bounds; an excursion.","pos":""}],"TRANSDIALECT":[{"def":"To change or translate from one dialect into another.","pos":""}],"TRANSDUCTION":[{"def":"The act of conveying over.","pos":""}],"TRANSE":[{"def":"To change or transpose the elements of; to transubstantiate.","pos":""}],"TRANSELEMENTATION":[{"def":"Transubstantiation.","pos":""}],"TRANSEPT":[{"def":"The transversal part of a church, which crosses at right angles to the greatest length, and between the nave and choir.","pos":""}],"TRANSFEMINATE":[{"def":"To change into a woman, as a man.","pos":""}],"TRANSFER":[{"def":"To convey from one place or person another; to transport, remove, or cause to pass, to another place or person; as, to transfer the laws of one country to another; to transfer suspicion.","pos":""},{"def":"To make over the possession or control of; to pass; to convey, as a right, from one person to another; to give; as, the title to land is transferred by deed.","pos":""}],"TRANSFERABILITY":[{"def":"The quality or state of being transferable.","pos":""}],"TRANSFERABLE":[{"def":"Capable of being transferred or conveyed from one place or person to another.","pos":""},{"def":"Negotiable, as a note, bill of exchange, or other evidence of property, that may be conveyed from one person to another by indorsement or other writing; capable of being transferred with no loss of value; as, the stocks of most public companies are transferable; some tickets are not transferable.","pos":""}],"TRANSFEREE":[{"def":"The person to whom a transfer in made.","pos":""}],"TRANSFERENCE":[{"def":"The act of transferring; conveyance; passage; transfer.","pos":""}],"TRANSFEROGRAPHY":[{"def":"The act or process of copying inscriptions, or the like, by making transfers.","pos":""}],"TRANSFERRENCE":[{"def":"See Transference.","pos":""}],"TRANSFERRER":[{"def":"One who makes a transfer or conveyance.","pos":""}],"TRANSFERRIBLE":[{"def":"Capable of being transferred; transferable.","pos":""}],"TRANSFIGURATE":[{"def":"To transfigure; to transform.","pos":""}],"TRANSFIGURATION":[{"def":"A feast held by some branches of the Christian church on the 6th of August, in commemoration of the miraculous change above mentioned.","pos":""}],"TRANSFIGURE":[{"def":"To change the outward form or appearance of; to metamorphose; to transform.","pos":""},{"def":"Especially, to change to something exalted and glorious; to give an ideal form to.","pos":""}],"TRANSFIX":[{"def":"To pierce through, as with a pointed weapon; to impale; as, to transfix one with a dart.","pos":""}],"TRANSFIXION":[{"def":"The act of transfixing, or the state of being transfixed, or pierced.","pos":""}],"TRANSFLUENT":[{"def":"Passing or flowing through a bridge; -- said of water.","pos":""}],"TRANSFLUX":[{"def":"A flowing through, across, or beyond.","pos":""}],"TRANSFORATE":[{"def":"To bore through; to perforate.","pos":""}],"TRANSFORM":[{"def":"To change, as an algebraic expression or geometrical figure, into another from without altering its value.","pos":""}],"TRANSFORMABLE":[{"def":"Capable of being transformed or changed.","pos":""}],"TRANSFORMATION":[{"def":"The act of transforming, or the state of being transformed; change of form or condition.","pos":""},{"def":"Any change in an organism which alters its general character and mode of life, as in the development of the germ into the embryo, the egg into the animal, the larva into the insect (metamorphosis), etc.","pos":""}],"TRANSFORMATIVE":[{"def":"Having power, or a tendency, to transform.","pos":""}],"TRANSFORMER":[{"def":"One who, or that which, transforms.","pos":""}],"TRANSFORMISM":[{"def":"The hypothesis, or doctrine, that living beings have originated by the modification of some other previously existing forms of living matter; -- opposed to abiogenesis.","pos":""}],"TRANSFRETATION":[{"def":"The act of passing over a strait or narrow sea.","pos":""}],"TRANSFRETE":[{"def":"To pass over a strait or narrow sea.","pos":""},{"def":"One who flees from one side to another; hence, a deserter; a turncoat; an apostate.","pos":""}],"TRANSFUND":[{"def":"To pour from one vessel into another; to transfuse.","pos":""}],"TRANSFUSE":[{"def":"To transfer, as blood, from the veins or arteries of one man or animal to those of another.","pos":""}],"TRANSFUSIBLE":[{"def":"Capable of being transfused; transferable by transfusion.","pos":""}],"TRANSFUSION":[{"def":"The act of transfusing, or pouring, as liquor, out of one vessel into another.","pos":""}],"TRANSFUSIVE":[{"def":"Tending to transfuse; having power to transfuse.","pos":""}],"TRANSGRESS":[{"def":"To pass over or beyond; to surpass.","pos":""},{"def":"Hence, to overpass, as any prescribed as the For man will hearken to his glozing lies, And easily transgress the sole command.","pos":""}],"TRANSGRESSION":[{"def":"The act of transgressing, or of passing over or beyond any law, civil or moral; the violation of a law or known principle of rectitude; breach of command; fault; offense; crime; sin.","pos":""}],"TRANSGRESSIONAL":[{"def":"Of pertaining to transgression; involving a transgression.","pos":""}],"TRANSGRESSIVE":[{"def":"Disposed or tending to transgress; faulty; culpable.","pos":""}],"TRANSGRESSIVELY":[{"def":"In a transgressive manner Adam, perhaps, .","pos":""}],"TRANSGRESSOR":[{"def":"One who transgresses; one who breaks a law, or violates a command; one who violates any known rule or principle of rectitude; a sinner.","pos":""}],"TRANSHIP":[{"def":"Same as Transship.","pos":""}],"TRANSHIPMENT":[{"def":"Same as Transshipment.","pos":""}],"TRANSHUMAN":[{"def":"More than human; superhuman.","pos":""}],"TRANSHUMANIZE":[{"def":"To make more than human; to purity; to elevate above humanity.","pos":""},{"def":"The quality of being transient; transientness.","pos":""}],"TRANSIENT":[{"def":"Passing before the sight or perception, or, as it were, moving over or across a space or scene viewed, and then disappearing; hence, of short duration; not permanent; not lasting or durable; not stationary; passing; fleeting; brief; transitory; as, transient pleasure.","pos":""},{"def":"Hasty; momentary; imperfect; brief; as, a transient view of a landscape.","pos":""}],"TRANSIRE":[{"def":"A customhouse clearance for a coasting vessel; a permit.","pos":""}],"TRANSISTHMIAN":[{"def":"Extending across an isthmus, as at Suez or Panama.","pos":""}],"TRANSIT":[{"def":"The act of passing; passage through or over.","pos":""},{"def":"The act or process of causing to pass; conveyance; as, the transit of goods through a country.","pos":""}],"TRANSITION":[{"def":"A direct or indirect passing from one key to another; a modulation.","pos":""},{"def":"A passing from one subject to another.","pos":""}],"TRANSITION ZONE":[{"def":"The zone lying between the Boreal and Sonoran zones of North America.","pos":""}],"TRANSITIONAL":[{"def":"Of or pertaining to transition; involving or denoting transition; as, transitional changes; transitional stage.","pos":""}],"TRANSITIVE":[{"def":"Passing over to an object; expressing an action which is not limited to the agent or subject, but which requires an object to complete the sense; as, a transitive verb, for example, he holds the book.","pos":""}],"TRANSITORILY":[{"def":"In a transitory manner; with brief continuance.","pos":""}],"TRANSITORINESS":[{"def":"The quality or state of being transitory; speedy passage or departure.","pos":""}],"TRANSITORY":[{"def":"Continuing only for a short time; not enduring; fleeting; evanescent.","pos":""}],"TRANSLATABLE":[{"def":"Capable of being translated, or rendered into another language.","pos":""}],"TRANSLATE":[{"def":"To remove, as a bishop, from one see to another.","pos":""},{"def":"To cause to remove from one part of the body to another; as, to translate a disease.","pos":""}],"TRANSLATION":[{"def":"A transfer of meaning in a word or phrase, a metaphor; a tralation.","pos":""},{"def":"Transfer of meaning by association; association of ideas.","pos":""}],"TRANSLATITIOUS":[{"def":"Metaphorical; tralatitious; also, foreign; exotic.","pos":""}],"TRANSLATIVE":[{"def":"tropical; figurative; as, a translative sense.","pos":""}],"TRANSLATOR":[{"def":"A repeating instrument.","pos":""}],"TRANSLATORSHIP":[{"def":"The office or dignity of a translator.","pos":""}],"TRANSLATORY":[{"def":"Serving to translate; transferring.","pos":""}],"TRANSLATRESS":[{"def":"A woman who translates.","pos":""}],"TRANSLAVATION":[{"def":"A laving or lading from one vessel to another.","pos":""}],"TRANSLITERATE":[{"def":"To express or represent in the characters of another alphabet; as, to transliterate Sanskrit words by means of English letters.","pos":""}],"TRANSLITERATION":[{"def":"The act or product of transliterating, or of expressing words of a language by means of the characters of another alphabet.","pos":""}],"TRANSLOCATION":[{"def":"removal of things from one place to another; substitution of one thing for another.","pos":""},{"def":"The quality or state of being translucent; clearness; partial transparency.","pos":""}],"TRANSLUCENT":[{"def":"Transmitting rays of light without permitting objects to be distinctly seen; partially transparent.","pos":""},{"def":"Transparent; clear.","pos":""}],"TRANSLUCENTLY":[{"def":"In a translucent manner.","pos":""}],"TRANSLUNARY":[{"def":"Being or lying beyond the moon; hence, ethereal; -- opposed to sublunary.","pos":""}],"TRANSMARINE":[{"def":"Lying or being beyond the sea.","pos":""},{"def":"Capable of being passed over or traversed; passable.","pos":""}],"TRANSMEATE":[{"def":"To pass over or beyond.","pos":""}],"TRANSMEATION":[{"def":"The act of transmeating; a passing through or beyond.","pos":""}],"TRANSMEW":[{"def":"To transmute; to transform; to metamorphose.","pos":""}],"TRANSMIGRANT":[{"def":"Migrating or passing from one place or state to another; passing from one residence to another.","pos":""},{"def":"One who transmigrates.","pos":""}],"TRANSMIGRATE":[{"def":"To pass from one country or jurisdiction to another for the purpose of residence, as men or families; to migrate.","pos":""},{"def":"To pass from one body or condition into another.","pos":""}],"TRANSMIGRATION":[{"def":"The act of passing from one country to another; migration.","pos":""},{"def":"The passing of the soul at death into another mortal body; metempsychosis.","pos":""}],"TRANSMIGRATOR":[{"def":"One who transmigrates.","pos":""}],"TRANSMIGRATORY":[{"def":"Passing from one body or state to another.","pos":""}],"TRANSMISSIBILITY":[{"def":"The quality of being transmissible.","pos":""}]}