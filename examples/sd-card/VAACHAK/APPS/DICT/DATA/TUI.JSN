{"TUILLE":[{"def":"In plate armor, a suspended plate in from of the thigh.","pos":""}],"TUITION":[{"def":"Superintending care over a young person; the particular watch and care of a tutor or guardian over his pupil or ward; guardianship.","pos":""},{"def":"Especially, the act, art, or business of teaching; instruction; as, children are sent to school for tuition; his tuition was thorough.","pos":""}],"TUITIONARY":[{"def":"Of or pertaining to tuition.","pos":""}]}