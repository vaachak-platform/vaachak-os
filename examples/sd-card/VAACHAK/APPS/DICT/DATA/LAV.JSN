{"LAVA":[{"def":"The melted rock ejected by a volcano from its top or fissured sides.","pos":""},{"def":"A neck ornament consisting of a chain and single pendant, or drop.","pos":""}],"LAVARET":[{"def":"A European whitefish (Coregonus laveretus), found in the mountain lakes of Sweden, Germany, and Switzerland.","pos":""}],"LAVATIC":[{"def":"Like lava, or composed of lava; lavic.","pos":""}],"LAVATION":[{"def":"A washing or cleansing.","pos":""}],"LAVATORY":[{"def":"Washing, or cleansing by washing.","pos":""}],"LAVATURE":[{"def":"A wash or lotion.","pos":""}],"LAVE":[{"def":"To wash; to bathe; as, to lave a bruise.","pos":""}],"LAVE-EARED":[{"def":"Having large, pendent ears.","pos":""}],"LAVEER":[{"def":"To beat against the wind; to tack.","pos":""}],"LAVEMENT":[{"def":"A washing or bathing; also, a clyster.","pos":""}],"LAVENDER":[{"def":"An aromatic plant of the genus Lavandula (L.","pos":""}],"LAVER":[{"def":"A vessel for washing; a large basin.","pos":""},{"def":"That which washes or cleanses.","pos":""}],"LAVISH":[{"def":"Expending or bestowing profusely; profuse; prodigal; as, lavish of money; lavish of praise.","pos":""},{"def":"Superabundant; excessive; as, lavish spirits.","pos":""}],"LAVISHER":[{"def":"One who lavishes.","pos":""}],"LAVISHLY":[{"def":"In a lavish manner.","pos":""}],"LAVISHMENT":[{"def":"The act of lavishing.","pos":""}],"LAVISHNESS":[{"def":"The quality or state of being lavish.","pos":""}],"LAVOESIUM":[{"def":"A supposed new metallic element.","pos":""},{"def":"An old dance, for two persons, being a kind of waltz, in which the woman made a high spring or bound.","pos":""}],"LAVOLTATEER":[{"def":"A dancer of the lavolta.","pos":""}],"LAVROCK":[{"def":"Same as Laverock.","pos":""}]}