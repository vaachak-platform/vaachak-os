{"ANTIDIPHTHERITIC":[{"def":"Destructive to, or hindering the growth of, diphtheria bacilli.","pos":""},{"def":"An antidiphtheritic agent.","pos":""}],"ANTIDOTAL":[{"def":"Having the quality an antidote; fitted to counteract the effects of poison.","pos":""}],"ANTIDOTE":[{"def":"A remedy to counteract the effects of poison, or of anything noxious taken into the stomach; -- used with against, for, or to; as, an antidote against, for, or to, poison.","pos":""},{"def":"Whatever tends to prevent mischievous effects, or to counteract evil which something else might produce.","pos":""}],"ANTIDOTICAL":[{"def":"Serving as an antidote.","pos":""}],"ANTIDROMOUS":[{"def":"Changing the direction in the spiral sequence of leaves on a stem.","pos":""}],"ANTIDYSENTERIC":[{"def":"Good against dysentery.","pos":""},{"def":"A medicine for dysentery.","pos":""}]}