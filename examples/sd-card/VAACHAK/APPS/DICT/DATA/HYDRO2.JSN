{"HYDROTHERAPEUTICS":[{"def":"A system of treating disease by baths and mineral waters.","pos":""}],"HYDROTHERMAL":[{"def":"Of or pertaining to hot water; -- used esp.","pos":""}],"HYDROTHORAX":[{"def":"An accumulation of serous fluid in the cavity of the chest.","pos":""}],"HYDROTIC":[{"def":"Causing a discharge of water or phlegm.","pos":""},{"def":"A hydrotic medicine.","pos":""}],"HYDROTROPE":[{"def":"A device for raising water by the direct action of steam; a pulsometer.","pos":""}],"HYDROTROPIC":[{"def":"Turning or bending towards moisture, as roots.","pos":""}],"HYDROTROPISM":[{"def":"A tendency towards moisture.","pos":""}],"HYDROUS":[{"def":"Containing water of hydration or crystallization.","pos":""}],"HYDROXANTHANE":[{"def":"A persulphocyanate.","pos":""}],"HYDROXANTHIC":[{"def":"Persulphocyanic.","pos":""}],"HYDROXIDE":[{"def":"A hydrate; a substance containing hydrogen and oxygen, made by combining water with an oxide, and yielding water by elimination.","pos":""}],"HYDROXY-":[{"def":"A combining form, also used adjectively, indicating hydroxyl as an ingredient.","pos":""}],"HYDROXYL":[{"def":"A compound radical, or unsaturated group, HO, consisting of one atom of hydrogen and one of oxygen.","pos":""}],"HYDROXYLAMINE":[{"def":"A nitrogenous, organic base, NH2.","pos":""}],"HYDROZOA":[{"def":"The Acalephæ; one of the classes of coelenterates, including the Hydroidea, Discophora, and Siphonophora.","pos":""}],"HYDROZOAL":[{"def":"Of or pertaining to the Hydrozoa.","pos":""},{"def":"One of the Hydrozoa.","pos":""}]}