{"EDACIOUS":[{"def":"Given to eating; voracious; devouring.","pos":""}],"EDACITY":[{"def":"Greediness; voracity; ravenousness; rapacity.","pos":""},{"def":"A Dutch pressed cheese of yellow color and fine flavor, made in balls weighing three or four pounds, and usually colored crimson outside; -- so called from the village of Edam, near Amsterdam.","pos":""}],"EDDA":[{"def":"The religious or mythological book of the old Scandinavian tribes of German origin, containing two collections of Sagas (legends, myths) of the old northern gods and heroes.","pos":""},{"def":"Relating to the Eddas; resembling the Eddas.","pos":""}],"EDDER":[{"def":"An adder or serpent.","pos":""}],"EDDISH":[{"def":"Aftermath; also, stubble and stubble field.","pos":""}],"EDDOES":[{"def":"The tubers of Colocasia antiquorum.","pos":""}],"EDDY":[{"def":"A current of air or water running back, or in a direction contrary to the main current.","pos":""},{"def":"A current of water or air moving in a circular direction; a whirlpool.","pos":""}],"EDDY CURRENT":[{"def":"An induced electric current circulating wholly within a mass of metal; -- called also Foucault current.","pos":""}],"EDDY KITE":[{"def":"A quadrilateral, tailless kite, with convex surfaces exposed to the wind.","pos":""}],"EDELWEISS":[{"def":"A little, perennial, white, woolly plant (Leontopodium alpinum), growing at high elevations in the Alps.","pos":""}],"EDEMA":[{"def":"Same as oedematous.","pos":""}],"EDEN":[{"def":"The garden where Adam and Eve first dwelt; hence, a delightful region or residence.","pos":""}],"EDENIC":[{"def":"Of or pertaining to Eden; paradisaic.","pos":""}],"EDENITE":[{"def":"A variety of amphibole.","pos":""}],"EDENIZED":[{"def":"Admitted to a state of paradisaic happiness.","pos":""}],"EDENTAL":[{"def":"See Edentate, a.","pos":""},{"def":"One of the Edentata.","pos":""}],"EDENTALOUS":[{"def":"See Edentate, a.","pos":""}],"EDENTATA":[{"def":"An order of mammals including the armadillos, sloths, and anteaters; -- called also Bruta.","pos":""}],"EDENTATE":[{"def":"Belonging to the Edentata.","pos":""}],"EDENTATED":[{"def":"Same as Edentate, a.","pos":""}],"EDENTATION":[{"def":"A depriving of teeth.","pos":""}],"EDGE":[{"def":"The thin cutting side of the blade of an instrument; as, the edge of an ax, knife, sword, or scythe.","pos":""},{"def":"Any sharp terminating border; a margin; a brink; extreme verge; as, the edge of a table, a precipice.","pos":""}],"EDGEBONE":[{"def":"Same as Aitchbone.","pos":""}],"EDGELESS":[{"def":"Without an edge; not sharp; blunt; obtuse; as, an edgeless sword or weapon.","pos":""}],"EDGELONG":[{"def":"In the direction of the edge.","pos":""}],"EDGESHOT":[{"def":"Having an edge planed, -- said of a board.","pos":""},{"def":"With the edge towards anything; in the direction of the edge.","pos":""}],"EDGING":[{"def":"That which forms an edge or border, as the fringe, trimming, etc.","pos":""},{"def":"The operation of shaping or dressing the edge of anything, as of a piece of metal.","pos":""}],"EDGINGLY":[{"def":"Gradually; gingerly.","pos":""}],"EDGY":[{"def":"Having some of the forms, such as drapery or the like, too sharply defined.","pos":""}],"EDH":[{"def":"The name of the Anglo-Saxon letter edh, capital form th in a similar word: oedher, other, dôedh, doth.","pos":""}],"EDIBILITY":[{"def":"Suitableness for being eaten; edibleness.","pos":""}],"EDIBLE":[{"def":"Fit to be eaten as food; eatable; esculent; as, edible fishes.","pos":""},{"def":"Anything edible.","pos":""}],"EDIBLENESS":[{"def":"Suitableness for being eaten.","pos":""}],"EDICT":[{"def":"A public command or ordinance by the sovereign power; the proclamation of a law made by an absolute authority, as if by the very act of announcement; a decree; as, the edicts of the Roman emperors; the edicts of the French monarch.","pos":""}],"EDICTAL":[{"def":"Relating to, or consisting of, edicts; as, the Roman edictal law.","pos":""}],"EDIFICANT":[{"def":"Building; constructing.","pos":""}],"EDIFICATION":[{"def":"The act of edifying, or the state of being edified; a building up, especially in a moral or spiritual sense; moral, intellectual, or spiritual improvement; instruction.","pos":""},{"def":"A building or edifice.","pos":""}],"EDIFICATORY":[{"def":"Tending to edification.","pos":""}],"EDIFICE":[{"def":"A building; a structure; an architectural fabric; -- chiefly applied to elegant houses, and other large buildings; as, a palace, a church, a statehouse.","pos":""}],"EDIFICIAL":[{"def":"Pertaining to an edifice; structural.","pos":""}],"EDIFIER":[{"def":"One who edifies, builds up, or strengthens another by moral or religious instruction.","pos":""}],"EDIFY":[{"def":"To build; to construct.","pos":""},{"def":"To instruct and improve, especially in moral and religious knowledge; to teach.","pos":""}],"EDIFYING":[{"def":"Instructing; improving; as, an edifying conversation.","pos":""}],"EDILESHIP":[{"def":"The office of ædile.","pos":""}],"EDINGTONITE":[{"def":"A grayish white zeolitic mineral, in tetragonal crystals.","pos":""}],"EDIT":[{"def":"To superintend the publication of; to revise and prepare for publication; to select, correct, arrange, etc.","pos":""}],"EDITION":[{"def":"A literary work edited and published, as by a certain editor or in a certain manner; as, a good edition of Chaucer; Chalmers' edition of Shakespeare.","pos":""},{"def":"The whole number of copies of a work printed and published at one time; as, the first edition was soon sold.","pos":""}],"EDITOR":[{"def":"One who edits; esp.","pos":""}],"EDITORIAL":[{"def":"Of or pertaining to an editor; written or sanctioned by an editor; as, editorial labors; editorial remarks.","pos":""}],"EDITORIALLY":[{"def":"In the manner or character of an editor or of an editorial article.","pos":""}],"EDITORSHIP":[{"def":"The office or charge of an editor; care and superintendence of a publication.","pos":""}],"EDITRESS":[{"def":"A female editor.","pos":""}],"EDITUATE":[{"def":"To guard as a churchwarden does.","pos":""}],"EDOMITE":[{"def":"One of the descendants of Esau or Edom, the brother of Jacob; an Idumean.","pos":""}],"EDRIOPHTHALMA":[{"def":"A group of Crustacea in which the eyes are without stalks; the Arthrostraca.","pos":""}],"EDRIOPHTHALMOUS":[{"def":"Pertaining to the Edriophthalma.","pos":""}],"EDUCABILITY":[{"def":"Capability of being educated.","pos":""}],"EDUCABLE":[{"def":"Capable of being educated.","pos":""}],"EDUCATE":[{"def":"To bring as, to educate a child; to educate the eye or the taste.","pos":""}],"EDUCATED":[{"def":"Formed or developed by education; as, an educated man.","pos":""}],"EDUCATION":[{"def":"To prepare us for complete living is the function which education has to discharge.","pos":""}],"EDUCATIONAL":[{"def":"Of or pertaining to education.","pos":""}],"EDUCATIONIST":[{"def":"One who is versed in the theories of, or who advocates and promotes, education.","pos":""}],"EDUCATIVE":[{"def":"Tending to educate; that gives education; as, an educative process; an educative experience.","pos":""}],"EDUCATOR":[{"def":"One who educates; a teacher.","pos":""}],"EDUCE":[{"def":"To bring or draw out; to cause to appear; to produce against counter agency or influence; to extract; to evolve; as, to educe a form from matter.","pos":""}],"EDUCIBLE":[{"def":"Capable of being educed.","pos":""}],"EDUCT":[{"def":"That which is educed, as by analysis.","pos":""}],"EDUCTION":[{"def":"The act of drawing out or bringing into view.","pos":""}],"EDUCTIVE":[{"def":"Tending to draw out; extractive.","pos":""}],"EDUCTOR":[{"def":"One who, or that which, brings forth, elicits, or extracts.","pos":""}],"EDULCORANT":[{"def":"Having a tendency to purify or to sweeten by removing or correcting acidity and acrimony.","pos":""}],"EDULCORATE":[{"def":"To free from acids, salts, or other soluble substances, by washing; to purify.","pos":""}],"EDULCORATION":[{"def":"The act of freeing from acids or any soluble substances, by affusions of water.","pos":""}],"EDULCORATOR":[{"def":"A contrivance used to supply small quantities of sweetened liquid, water, etc.","pos":""}],"EDULIOUS":[{"def":"A suffix used, chiefly in law terms, in a passive signification, to indicate the direct or indirect object of an action, or the one to whom an act is done or on whom a right is conferred; as in assignee, donee, alienee, grantee, etc.","pos":""}]}