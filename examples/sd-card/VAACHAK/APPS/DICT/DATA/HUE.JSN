{"HUE":[{"def":"A predominant shade in a composition of primary colors; a primary color modified by combination with others.","pos":""}],"HUED":[{"def":"Having color; -- usually in composition; as, bright-hued; many- hued.","pos":""}],"HUELESS":[{"def":"Destitute of color.","pos":""}],"HUER":[{"def":"One who cries out or gives an alarm; specifically, a balker; a conder.","pos":""}]}