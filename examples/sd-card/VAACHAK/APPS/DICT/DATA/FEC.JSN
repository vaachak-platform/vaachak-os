{"FECAL":[{"def":"relating to, or containing, dregs, feces, or ordeure; fæcal.","pos":""}],"FECES":[{"def":"dregs; sediment; excrement.","pos":""}],"FECIAL":[{"def":"Pertaining to heralds, declarations of war, and treaties of peace; as, fecial law.","pos":""}],"FECIFORK":[{"def":"The anal fork on which the larvæ of certain insects carry their fæces.","pos":""}],"FECK":[{"def":"Efficacy; force; value.","pos":""}],"FECKLESS":[{"def":"Spiritless; weak; worthless.","pos":""}],"FECKLESSNESS":[{"def":"absence of merit.","pos":""}],"FECKS":[{"def":"A corruption of the word faith.","pos":""}],"FECULA":[{"def":"Any pulverulent matter obtained from plants by simply breaking down the texture, washing with water, and subsidence.","pos":""}],"FECULENCE":[{"def":"The state or quality of being feculent; muddiness; foulness.","pos":""},{"def":"That which is feculent; sediment; lees; dregs.","pos":""}],"FECULENT":[{"def":"Foul with extraneous or impure substances; abounding with sediment or excrementitious matter; muddy; thick; turbid.","pos":""}],"FECUND":[{"def":"Fruitful in children; prolific.","pos":""}],"FECUNDATE":[{"def":"To render fruitful or prolific; to impregnate; as, in flowers the pollen fecundates the ovum through the stigma.","pos":""}],"FECUNDATION":[{"def":"The act by which, either in animals or plants, material prepared by the generative organs the female organism is brought in contact with matter from the organs of the male, so that a new organism results; impregnation; fertilization.","pos":""}],"FECUNDIFY":[{"def":"To make fruitful; to fecundate.","pos":""}],"FECUNDITY":[{"def":"The quality or power of producing fruit; fruitfulness; especially (Biol.","pos":""},{"def":"The power of germinating; as in seeds.","pos":""}]}