{"BIRAMOUS":[{"def":"Having, or consisting of, two branches.","pos":""}],"BIRCH":[{"def":"A tree of several species, constituting the genus Betula; as, the white or common birch (B.","pos":""},{"def":"The wood or timber of the birch.","pos":""}],"BIRCHEN":[{"def":"Of or relating to birch.","pos":""}],"BIRD":[{"def":"A warm-blooded, feathered vertebrate provided with wings.","pos":""}],"BIRD CHERRY":[{"def":"A shrub (Prunus Padus ) found in Northern and Central Europe.","pos":""}],"BIRD FANCIER":[{"def":"One who takes pleasure in rearing or collecting rare or curious birds.","pos":""},{"def":"One who has for sale the various kinds of birds which are kept in cages.","pos":""}],"BIRD OF PARADISE":[{"def":"The name of several very beautiful birds of the genus Paradisea and allied genera, inhabiting New Guinea and the adjacent islands.","pos":""}],"BIRD PEPPER":[{"def":"A species of capsicum (Capsicum baccatum), whose small, conical, coral-red fruit is among the most piquant of all red peppers.","pos":""}],"BIRD'S-BEAK":[{"def":"A molding whose section is thought to resemble a beak.","pos":""}],"BIRD'S-EYE":[{"def":"Seen from above, as if by a flying bird; embraced at a glance; hence, generalas, a bird's-eye view.","pos":""},{"def":"Marked with spots resembling bird's eyes; as, bird's-eye diaper; bird's-eye maple.","pos":""}],"BIRD'S-EYE MAPLE":[{"def":"See under Maple.","pos":""}],"BIRD'S-FOOT":[{"def":"A papilionaceous plant, the Ornithopus, having a curved, cylindrical pod tipped with a short, clawlike point.","pos":""}],"BIRD'S-MOUTH":[{"def":"An interior acrow's-foot in the United States.","pos":""},{"def":"The nest of a small swallow (Collocalia nidifica and several allied species), of China and the neighboring countries, which is mixed with soups.","pos":""}],"BIRD'S-NESTING":[{"def":"Hunting for, or taking, birds' nests or their contents.","pos":""}],"BIRD'S-TONGUE":[{"def":"The knotgrass (Polygonum aviculare).","pos":""}],"BIRD-EYED":[{"def":"Quick-sighted; catching a glance as one goes.","pos":""}],"BIRD-WITTED":[{"def":"Flighty; passing rapidly from one subject to another; not having the faculty of attention.","pos":""}],"BIRDBOLT":[{"def":"A short blunt arrow for killing birds without piercing them.","pos":""},{"def":"A cage for confining birds.","pos":""}],"BIRDCALL":[{"def":"A sound made in imitation of the note or cry of a bird for the purpose of decoying the bird or its mate.","pos":""},{"def":"An instrument of any kind, as a whistle, used in making the sound of a birdcall.","pos":""}],"BIRDCATCHER":[{"def":"One whose employment it is to catch birds; a fowler.","pos":""}],"BIRDCATCHING":[{"def":"The art, act, or occupation or catching birds or wild fowls.","pos":""}],"BIRDIE":[{"def":"A pretty or dear little bird; -- a pet name.","pos":""}],"BIRDING":[{"def":"Birdcatching or fowling.","pos":""}],"BIRDLET":[{"def":"A little bird; a nestling.","pos":""}],"BIRDLIKE":[{"def":"Resembling a bird.","pos":""}],"BIRDLIME":[{"def":"An extremely adhesive viscid substance, usually made of the middle bark of the holly, by boiling, fermenting, and cleansing it.","pos":""}],"BIRDLING":[{"def":"A little bird; a nestling.","pos":""}],"BIRDMAN":[{"def":"A fowler or birdcatcher.","pos":""}],"BIRDSEED":[{"def":"Canary seed, hemp, millet or other small seeds used for feeding caged birds.","pos":""}],"BIRDWOMAN":[{"def":"An airwoman; an aviatress.","pos":""}],"BIRECTANGULAR":[{"def":"Containing or having two right angles; as, a birectangular spherical triangle.","pos":""}],"BIREME":[{"def":"An ancient galley or vessel with two banks or tiers of oars.","pos":""}],"BIRETTA":[{"def":"Same as Berretta.","pos":""}],"BIRK":[{"def":"A small European minnow (Leuciscus phoxinus).","pos":""}],"BIRKEN":[{"def":"To whip with a birch or rod.","pos":""}],"BIRKIE":[{"def":"A lively or mettlesome fellow.","pos":""}],"BIRL":[{"def":"To revolve or cause to revolve; to spin.","pos":""}],"BIRLAW":[{"def":"A law made by husbandmen respecting rural affairs; a rustic or local law or by-law.","pos":""},{"def":"Having a double beak, or two processes resembling beaks.","pos":""}],"BIRR":[{"def":"To make, or move with, a whirring noise, as of wheels in motion.","pos":""}],"BIRRUS":[{"def":"A coarse kind of thick woolen cloth, worn by the poor in the Middle Ages; also, a woolen cap or hood worn over the shoulders or over the head.","pos":""}],"BIRSE":[{"def":"A bristle or bristles.","pos":""}],"BIRT":[{"def":"A fish of the turbot kind; the brill.","pos":""}],"BIRTH":[{"def":"The act or fact of coming into life, or of being born; -- generally applied to human beings; as, the birth of a son.","pos":""},{"def":"Lineage; extraction; descent; sometimes, high birth; noble extraction.","pos":""}],"BIRTHDAY":[{"def":"The day in which any person is born; day of origin or commencement.","pos":""},{"def":"The day of the month in which a person was born, in whatever succeeding year it may recur; the anniversary of one's birth.","pos":""}],"BIRTHDOM":[{"def":"The land of one's birth; one's inheritance.","pos":""}],"BIRTHING":[{"def":"Anything added to raise the sides of a ship.","pos":""}],"BIRTHLESS":[{"def":"Of mean extraction.","pos":""}],"BIRTHMARK":[{"def":"Some peculiar mark or blemish on the body at birth.","pos":""}],"BIRTHNIGHT":[{"def":"The night in which a person is born; the anniversary of that night in succeeding years.","pos":""}],"BIRTHPLACE":[{"def":"The town, city, or country, where a person is born; place of origin or birth, in its more general sense.","pos":""}],"BIRTHRIGHT":[{"def":"Any right, privilege, or possession to which a person is entitled by birth, such as an estate descendible by law to an heir, or civil liberty under a free constitution; esp.","pos":""}],"BIRTHROOT":[{"def":"An herbaceous plant (Trillium erectum), and its astringent rootstock, which is said to have medicinal properties.","pos":""}],"BIRTHWORT":[{"def":"A genus of herbs and shrubs (Aristolochia), reputed to have medicinal properties.","pos":""}]}