{"BARYCENTRIC":[{"def":"Of or pertaining to the center of gravity.","pos":""}],"BARYPHONY":[{"def":"Difficulty of speech.","pos":""}],"BARYSPHERE":[{"def":"The heavy interior portion of the earth, within the lithosphere.","pos":""}],"BARYTA":[{"def":"An oxide of barium (or barytum); a heavy earth with a specific gravity above 4.","pos":""}],"BARYTES":[{"def":"Barium sulphate, generally called heavy spar or barite.","pos":""}],"BARYTIC":[{"def":"Of or pertaining to baryta.","pos":""}],"BARYTO-CALCITE":[{"def":"A mineral of a white or gray color, occurring massive or crystallized.","pos":""},{"def":"Grave and deep, as a kind of male voice.","pos":""}],"BARYTUM":[{"def":"The metal barium.","pos":""}]}