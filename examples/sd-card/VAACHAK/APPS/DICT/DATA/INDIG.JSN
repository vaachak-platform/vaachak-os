{"INDIGEEN":[{"def":"Same as Indigene.","pos":""}],"INDIGENCE":[{"def":"The condition of being indigent; want of estate, or means of comfortable subsistence; penury; poverty; as, helpless, indigence.","pos":""}],"INDIGENCY":[{"def":"New indigencies founded upon new desires.","pos":""}],"INDIGENE":[{"def":"One born in a country; an aboriginal animal or plant; an autochthon.","pos":""}],"INDIGENOUS":[{"def":"Native; produced, growing, or living, naturally in a country or climate; not exotic; not imported.","pos":""},{"def":"Native; inherent; innate.","pos":""}],"INDIGENT":[{"def":"Wanting; void; free; destitute; -- used with of.","pos":""},{"def":"Destitute of property or means of comfortable subsistence; needy; poor; in want; necessitous.","pos":""}],"INDIGENTLY":[{"def":"In an indigent manner.","pos":""}],"INDIGEST":[{"def":"Crude; unformed; unorganized; undigested.","pos":""}],"INDIGESTED":[{"def":"Not digested; undigested.","pos":""},{"def":"Not resolved; not regularly disposed and arranged; not methodical; crude; as, an indigested array of facts.","pos":""}],"INDIGESTEDNESS":[{"def":"The state or quality of being undigested; crudeness.","pos":""}],"INDIGESTIBILITY":[{"def":"The state or quality of being indigestible; indigestibleness.","pos":""}],"INDIGESTIBLE":[{"def":"Not digestible; not readily soluble in the digestive juices; not easily convertible into products fitted for absorption.","pos":""},{"def":"Not digestible in the mind; distressful; intolerable; as, an indigestible simile.","pos":""}],"INDIGESTION":[{"def":"Lack of proper digestive action; a failure of the normal changes which food should undergo in the alimentary canal; dyspepsia; incomplete or difficult digestion.","pos":""}],"INDIGITATE":[{"def":"To communicative ideas by the fingers; to show or compute by the fingers.","pos":""}],"INDIGITATION":[{"def":"The act of pointing out as with the finger; indication.","pos":""}],"INDIGLUCIN":[{"def":"The variety of sugar (glucose) obtained from the glucoside indican.","pos":""}],"INDIGN":[{"def":"Unworthy; undeserving; disgraceful; degrading.","pos":""}],"INDIGNANT":[{"def":"Affected with indignation; wrathful; passionate; irate; feeling wrath, as when a person is exasperated by unworthy or unjust treatment, by a mean action, or by a degrading accusation.","pos":""}],"INDIGNANTLY":[{"def":"In an indignant manner.","pos":""}],"INDIGNATION":[{"def":"The feeling excited by that which is unworthy, base, or disgraceful; anger mingled with contempt, disgust, or abhorrence.","pos":""},{"def":"The effect of anger; punishment.","pos":""}],"INDIGNIFY":[{"def":"To treat disdainfully or with indignity; to contemn.","pos":""}],"INDIGNITY":[{"def":"Any action toward another which manifests contempt for him; an offense against personal dignity; unmerited contemptuous treatment; contumely; incivility or injury, accompanied with insult.","pos":""}],"INDIGO":[{"def":"A blue dyestuff obtained from several plants belonging to very different genera and orders; as, the woad, Isatis tinctoria, Indigofera tinctoria, I.","pos":""}],"INDIGOFERA":[{"def":"A genus of leguminous plants having many species, mostly in tropical countries, several of them yielding indigo, esp.","pos":""}],"INDIGOGEN":[{"def":"See Indigo white, under Indigo.","pos":""},{"def":"Same as Indican, 2.","pos":""}],"INDIGOMETER":[{"def":"An instrument for ascertaining the strength of an indigo solution, as in volumetric analysis.","pos":""}],"INDIGOMETRY":[{"def":"The art or method of determining the coloring power of indigo.","pos":""}],"INDIGOTIC":[{"def":"Pertaining to, or derived from, indigo; as, indigotic acid, which is also called anilic or nitrosalicylic acid.","pos":""}],"INDIGOTIN":[{"def":"See Indigo blue, under Indigo.","pos":""}],"INDIGRUBIN":[{"def":"Same as Urrhodin.","pos":""}]}