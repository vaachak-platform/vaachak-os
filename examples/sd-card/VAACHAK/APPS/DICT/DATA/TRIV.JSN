{"TRIVALENCE":[{"def":"The quality or state of being trivalent.","pos":""}],"TRIVALENT":[{"def":"Having a valence of three; capable of being combined with, substituted for, or compared with, three atoms of hydrogen; -- said of triad atoms or radicals; thus, nitrogen is trivalent in ammonia.","pos":""}],"TRIVALVE":[{"def":"Anything having three valves, especially a shell.","pos":""}],"TRIVALVULAR":[{"def":"Having three valves; three-valved.","pos":""}],"TRIVERBIAL":[{"def":"Pertaining to, or designating, certain days allowed to the pretor for hearing causes, when be might speak the three characteristic words of his office, do, dico, addico.","pos":""}],"TRIVET":[{"def":"A tree-legged stool, table, or other support; especially, a stand to hold a kettle or similar vessel near the fire; a tripod.","pos":""},{"def":"A weaver's knife.","pos":""}],"TRIVIAL":[{"def":"Found anywhere; common.","pos":""},{"def":"Ordinary; commonplace; trifling; vulgar.","pos":""}],"TRIVIALISM":[{"def":"A trivial matter or method; a triviality.","pos":""}],"TRIVIALITY":[{"def":"The quality or state of being trivial; trivialness.","pos":""},{"def":"That which is trivial; a trifle.","pos":""}],"TRIVIALLY":[{"def":"In a trivial manner.","pos":""}],"TRIVIALNESS":[{"def":"Quality or state of being trivial.","pos":""}],"TRIVIUM":[{"def":"The three anterior ambulacra of echinoderms, collectively.","pos":""}]}