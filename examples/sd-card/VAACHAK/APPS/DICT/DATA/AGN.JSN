{"AGNAIL":[{"def":"A corn on the toe or foot.","pos":""},{"def":"An inflammation or sore under or around the nail; also, a hangnail.","pos":""}],"AGNATE":[{"def":"Related or akin by the father's side; also, sprung from the same male ancestor.","pos":""}],"AGNATIC":[{"def":"Pertaining to descent by the male line of ancestors.","pos":""}],"AGNATION":[{"def":"Consanguinity by a line of males only, as distinguished from cognation.","pos":""}],"AGNIZE":[{"def":"To recognize; to acknowledge.","pos":""}],"AGNOIOLOGY":[{"def":"The doctrine concerning those things of which we are necessarily ignorant.","pos":""}],"AGNOMEN":[{"def":"An additional or fourth name given by the Romans, or account of some remarkable exploit or event; as, Publius Caius Scipio Africanus.","pos":""},{"def":"An additional name, or an epithet appended to a name; as, Aristides the Just.","pos":""}],"AGNOMINATION":[{"def":"Paronomasia; also, alliteration; annomination.","pos":""}],"AGNOSTIC":[{"def":"Professing ignorance; involving no dogmatic; pertaining to or involving agnosticism.","pos":""}],"AGNOSTICISM":[{"def":"That doctrine which, professing ignorance, neither asserts nor denies.","pos":""},{"def":"The doctrine that the existence of a personal Deity, an unseen world, etc.","pos":""}],"AGNUS CASTUS":[{"def":"A species of Vitex (V.","pos":""}],"AGNUS SCYTHICUS":[{"def":"The Scythian lamb, a kind of woolly-skinned rootstock.","pos":""}]}