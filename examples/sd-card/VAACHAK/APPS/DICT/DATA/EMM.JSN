{"EMMANTLE":[{"def":"To cover over with, or as with, a mantle; to put about as a protection.","pos":""}],"EMMARBLE":[{"def":"To turn to marble; to harden.","pos":""}],"EMMENAGOGUE":[{"def":"A medicine that promotes the menstrual discharge.","pos":""}],"EMMETROPIA":[{"def":"That refractive condition of the eye in which the rays of light are all brought accurately and without undue effort to a focus upon the retina; -- opposed to hypermetropia, myopia, an astigmatism.","pos":""}],"EMMETROPIC":[{"def":"Pertaining to, or characterized by, emmetropia.","pos":""}],"EMMETROPY":[{"def":"Same as Emmetropia.","pos":""}],"EMMEW":[{"def":"To mew or coop up.","pos":""}],"EMMOVE":[{"def":"To move; to rouse; to excite.","pos":""}]}