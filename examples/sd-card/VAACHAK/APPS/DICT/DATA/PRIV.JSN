{"PRIVACY":[{"def":"The state of being in retirement from the company or observation of others; seclusion.","pos":""},{"def":"A place of seclusion from company or observation; retreat; solitude; retirement.","pos":""}],"PRIVADO":[{"def":"A private friend; a confidential friend; a confidant.","pos":""}],"PRIVATDOCENT":[{"def":"In the universities of Germany and some other European countries, a licensed teacher or lecturer having no share in the university government and dependent upon fees for remuneration.","pos":""}],"PRIVATE":[{"def":"Belonging to, or concerning, an individual person, company, or interest; peculiar to one's self; unconnected with others; personal; one's own; not public; not general; separate; as, a man's private opinion; private property; a private purse; private expenses or interests; a private secretary.","pos":""},{"def":"Sequestered from company or observation; appropriated to an individual; secret; secluded; lonely; solitary; as, a private room or apartment; private prayer.","pos":""}],"PRIVATEER":[{"def":"An armed private vessel which bears the commission of the sovereign power to cruise against the enemy.","pos":""},{"def":"The commander of a privateer.","pos":""}],"PRIVATEERING":[{"def":"Cruising in a privateer.","pos":""}],"PRIVATEERSMAN":[{"def":"An officer or seaman of a privateer.","pos":""}],"PRIVATELY":[{"def":"In a private manner; not openly; without the presence of others.","pos":""},{"def":"In a manner affecting an individual; personally not officially; as, he is not privately benefited.","pos":""}],"PRIVATENESS":[{"def":"Seclusion from company or society; retirement; privacy; secrecy.","pos":""},{"def":"The state of one not invested with public office.","pos":""}],"PRIVATION":[{"def":"The act of depriving, or taking away; hence, the depriving of rank or office; degradation in rank; deprivation.","pos":""},{"def":"The state of being deprived or destitute of something, especially of something required or desired; destitution; need; as, to undergo severe privations.","pos":""}],"PRIVATIVE":[{"def":"Implying privation or negation; giving a negative force to a word; as, alpha privative; privative particles; -- applied to such prefixes and suffixes as a- (Gr.","pos":""}],"PRIVATIVELY":[{"def":"In a privative manner; by the absence of something; negatively.","pos":""}],"PRIVATIVENESS":[{"def":"The state of being privative.","pos":""}],"PRIVET":[{"def":"An ornamental European shrub (Ligustrum vulgare), much used in hedges; -- called also prim.","pos":""}],"PRIVILEGE":[{"def":"See Call, Put, Spread, etc.","pos":""}],"PRIVILEGED":[{"def":"Invested with a privilege; enjoying a peculiar right, advantage, or immunity.","pos":""}],"PRIVILY":[{"def":"In a privy manner; privately; secretly.","pos":""}],"PRIVITY":[{"def":"The genitals; the privates.","pos":""},{"def":"A connection, or bond of union, between parties, as to some particular transaction; mutual or successive relationship to the same rights of property.","pos":""}],"PRIVY":[{"def":"Of or pertaining to some person exclusively; assigned to private uses; not public; private; as, the privy purse.","pos":""},{"def":"Secret; clandestine.","pos":""}]}