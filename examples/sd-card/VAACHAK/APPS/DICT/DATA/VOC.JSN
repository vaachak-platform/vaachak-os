{"VOCABLE":[{"def":"A word; a term; a name; specifically, a word considered as composed of certain sounds or letters, without regard to its meaning.","pos":""}],"VOCABULARY":[{"def":"A list or collection of words arranged in alphabetical order and explained; a dictionary or lexicon, either of a whole language, a single work or author, a branch of science, or the like; a word-book.","pos":""},{"def":"A sum or stock of words employed.","pos":""}],"VOCABULIST":[{"def":"The writer or maker of a vocabulary; a lexicographer.","pos":""}],"VOCAL":[{"def":"Of or pertaining to the voice or speech; having voice; endowed with utterance; full of voice, or voices.","pos":""},{"def":"Uttered or modulated by the voice; oral; as, vocal melody; vocal prayer.","pos":""}],"VOCALIC":[{"def":"Of or pertaining to vowel sounds; consisting of the vowel sounds.","pos":""}],"VOCALISM":[{"def":"The exercise of the vocal organs; vocalization.","pos":""},{"def":"A vocalic sound.","pos":""}],"VOCALIST":[{"def":"A singer, or vocal musician, as opposed to an instrumentalist.","pos":""}],"VOCALITY":[{"def":"The quality or state of being vocal; utterableness; resonance; as, the vocality of the letters.","pos":""},{"def":"The quality of being a vowel; vocalic character.","pos":""}],"VOCALIZATION":[{"def":"The act of vocalizing, or the state of being vocalized.","pos":""},{"def":"The formation and utterance of vocal sounds.","pos":""}],"VOCALIZE":[{"def":"To form into voice; to make vocal or sonant; to give intonation or resonance to.","pos":""},{"def":"To practice singing on the vowel sounds.","pos":""}],"VOCALLY":[{"def":"In a vocal manner; with voice; orally; with audible sound.","pos":""},{"def":"In words; verbally; as, to express desires vocally.","pos":""}],"VOCALNESS":[{"def":"The quality of being vocal; vocality.","pos":""}],"VOCATION":[{"def":"A calling by the will of God.","pos":""}],"VOCATIVE":[{"def":"Of or pertaining to calling; used in calling; specifically (Gram.","pos":""}],"VOCIFERANCE":[{"def":"Vociferation; noise; clamor.","pos":""}],"VOCIFERANT":[{"def":"Noisy; clamorous.","pos":""}],"VOCIFERATE":[{"def":"To cry out with vehemence; to exclaim; to bawl; to clamor.","pos":""}],"VOCIFERATION":[{"def":"The act of vociferating; violent outcry; vehement utterance of the voice.","pos":""}],"VOCIFERATOR":[{"def":"One who vociferates, or is clamorous.","pos":""}],"VOCIFEROUS":[{"def":"Making a loud outcry; clamorous; noisy; as, vociferous heralds.","pos":""}],"VOCULE":[{"def":"A short or weak utterance; a faint or feeble sound, as that heard on separating the lips in pronouncing p or b.","pos":""}]}