{"EPILEPSY":[{"def":"The \"falling sickness,\" so called because the patient falls suddenly to the ground; a disease characterized by paroxysms (or fits) occurring at interval and attended by sudden loss of consciousness, and convulsive motions of the muscles.","pos":""}],"EPILEPTIC":[{"def":"Pertaining to, affected with, or of the nature of, epilepsy.","pos":""}],"EPILEPTIFORM":[{"def":"Resembling epilepsy.","pos":""}],"EPILEPTOGENOUS":[{"def":"Producing epilepsy or epileptoid convulsions; -- applied to areas of the body or of the nervous system, stimulation of which produces convulsions.","pos":""}],"EPILEPTOID":[{"def":"Resembling epilepsy; as, epileptoid convulsions.","pos":""}],"EPILOGATION":[{"def":"A summing up in a brief account.","pos":""},{"def":"Of or pertaining to an epilogue.","pos":""}],"EPILOGISM":[{"def":"Enumeration; computation.","pos":""}],"EPILOGISTIC":[{"def":"Of or pertaining to epilogue; of the nature of an epilogue.","pos":""}],"EPILOGIZE":[{"def":"To speak an epilogue to; to utter as an epilogue.","pos":""}],"EPILOGUE":[{"def":"A speech or short poem addressed to the spectators and recited by one of the actors, after the conclusion of the play.","pos":""},{"def":"The closing part of a discourse, in which the principal matters are recapitulated; a conclusion.","pos":""}],"EPILOGUIZE":[{"def":"Same as Epilogize.","pos":""}]}