{"BRAVADO":[{"def":"Boastful and threatening behavior; a boastful menace.","pos":""}],"BRAVE":[{"def":"Bold; courageous; daring; intrepid; -- opposed to cowardly; as, a brave man; a brave act.","pos":""},{"def":"Having any sort of superiority or excellence; -- especially such as in conspicuous.","pos":""}],"BRAVELY":[{"def":"In a brave manner; courageously; gallantly; valiantly; splendidly; nobly.","pos":""},{"def":"Finely; gaudily; gayly; showily.","pos":""}],"BRAVENESS":[{"def":"The quality of state or being brave.","pos":""}],"BRAVERY":[{"def":"The quality of being brave; fearless; intrepidity.","pos":""},{"def":"The act of braving; defiance; bravado.","pos":""}],"BRAVING":[{"def":"A bravado; a boast.","pos":""}],"BRAVINGLY":[{"def":"In a defiant manner.","pos":""}],"BRAVO":[{"def":"A daring villain; a bandit; one who sets law at defiance; a professional assassin or murderer.","pos":""}],"BRAVURA":[{"def":"A florid, brilliant style of music, written for effect, to show the range and flexibility of a singer's voice, or the technical force and skill of a performer; virtuoso music.","pos":""}]}