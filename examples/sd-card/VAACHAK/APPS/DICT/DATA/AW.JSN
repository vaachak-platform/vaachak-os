{"AWAIT":[{"def":"To watch for; to look out for.","pos":""},{"def":"To wait on, serve, or attend.","pos":""}],"AWAKE":[{"def":"To rouse from sleep.","pos":""},{"def":"To rouse from a state resembling sleep, as from death, stupidity.","pos":""}],"AWAKEN":[{"def":"To rouse from sleep or torpor; to awake; to wake.","pos":""}],"AWAKENER":[{"def":"One who, or that which, awakens.","pos":""}],"AWAKENING":[{"def":"Rousing from sleep, in a natural or a figurative sense; rousing into activity; exciting; as, the awakening city; an awakening discourse; the awakening dawn.","pos":""}],"AWANTING":[{"def":"Missing; wanting.","pos":""}],"AWARD":[{"def":"To give by sentence or judicial determination; to assign or apportion, after careful regard to the nature of the case; to adjudge; as, the arbitrators awarded damages to the complainant.","pos":""}],"AWARDER":[{"def":"One who awards, or assigns by sentence or judicial determination; a judge.","pos":""}],"AWARE":[{"def":"Watchful; vigilant or on one's guard against danger or difficulty.","pos":""},{"def":"Apprised; informed; cognizant; conscious; as, he was aware of the enemy's designs.","pos":""}],"AWASH":[{"def":"Washed by the waves or tide; -- said of a rock or strip of shore, or (Naut.","pos":""}],"AWAY":[{"def":"From a place; hence.","pos":""},{"def":"Absent; gone; at a distance; as, the master is away from home.","pos":""}],"AWAY-GOING":[{"def":"Sown during the last years of a tenancy, but not ripe until after its expiration; -- said of crops.","pos":""}],"AWAYWARD":[{"def":"Turned away; away.","pos":""}],"AWE":[{"def":"Dread; great fear mingled with respect.","pos":""},{"def":"The emotion inspired by something dreadful and sublime; an undefined sense of the dreadful and the sublime; reverential fear, or solemn wonder; profound reverence.","pos":""}],"AWE-STRUCK":[{"def":"Struck with awe.","pos":""}],"AWEATHER":[{"def":"On the weather side, or toward the wind; in the direction from which the wind blows; -- opposed to alee; as, helm aweather ! Totten.","pos":""}],"AWEIGH":[{"def":"Just drawn out of the ground, and hanging perpendicularly; atrip; -- said of the anchor.","pos":""}],"AWESOME":[{"def":"Causing awe; appalling; awful; as, an awesome sight.","pos":""},{"def":"Expressive of awe or terror.","pos":""}],"AWESOMENESS":[{"def":"The quality of being awesome.","pos":""}],"AWFUL":[{"def":"Oppressing with fear or horror; appalling; terrible; as, an awful scene.","pos":""},{"def":"Inspiring awe; filling with profound reverence, or with fear and admiration; fitted to inspire reverential fear; profoundly impressive.","pos":""}],"AWFULLY":[{"def":"In an awful manner; in a manner to fill with terror or awe; fearfully; reverently.","pos":""},{"def":"Very; excessively.","pos":""}],"AWFULNESS":[{"def":"The quality of striking with awe, or with reverence; dreadfulness; solemnity; as, the awfulness of this sacred place.","pos":""},{"def":"The state of being struck with awe; a spirit of solemnity; profound reverence.","pos":""}],"AWHAPE":[{"def":"To confound; to terrify; to amaze.","pos":""}],"AWHILE":[{"def":"For a while; for some time; for a short time.","pos":""}],"AWING":[{"def":"On the wing; flying; fluttering.","pos":""}],"AWK":[{"def":"Odd; out of order; perverse.","pos":""},{"def":"Wrong, or not commonly used; clumsy; sinister; as, the awk end of a rod (the but end).","pos":""}],"AWKLY":[{"def":"In an unlucky (left-handed) or perverse manner.","pos":""}],"AWKWARD":[{"def":"Wanting dexterity in the use of the hands, or of instruments; not dexterous; without skill; clumsy; wanting ease, grace, or effectiveness in movement; ungraceful; as, he was awkward at a trick; an awkward boy.","pos":""},{"def":"Not easily managed or effected; embarrassing.","pos":""}],"AWKWARD SQUAD":[{"def":"A squad of inapt recruits assembled for special drill.","pos":""}],"AWL":[{"def":"A pointed instrument for piercing small holes, as in leather or wood; used by shoemakers, saddlers, cabinetmakers, etc.","pos":""}],"AWL-SHAPED":[{"def":"Shaped like an awl.","pos":""}],"AWLESS":[{"def":"Wanting reverence; void of respectful fear.","pos":""},{"def":"Inspiring no awe.","pos":""}],"AWLESSNESS":[{"def":"The quality of being awless.","pos":""}],"AWLWORT":[{"def":"A plant (Subularia aquatica), with awl-shaped leaves.","pos":""}],"AWN":[{"def":"The bristle or beard of barley, oats, grasses, etc.","pos":""}],"AWNED":[{"def":"Furnished with an awn, or long bristle-shaped tip; bearded.","pos":""}],"AWNING":[{"def":"A rooflike cover, usually of canvas, extended over or before any place as a shelter from the sun, rain, or wind.","pos":""}],"AWNINGED":[{"def":"Furnished with an awning.","pos":""}],"AWNLESS":[{"def":"Without awns or beard.","pos":""}],"AWNY":[{"def":"Having awns; bearded.","pos":""}],"AWORK":[{"def":"At work; in action.","pos":""}],"AWORKING":[{"def":"At work; in action.","pos":""}],"AWRY":[{"def":"Turned or twisted toward one side; not in a straight or true direction, or position; out of the right course; distorted; obliquely; asquint; with oblique vision; as, to glance awry.","pos":""},{"def":"Aside from the line of truth, or right reason; unreasonable or unreasonably; perverse or perversely.","pos":""}],"AWSOME":[{"def":"Same as Awesome.","pos":""},{"def":"A tool or instrument of steel, or of iron with a steel edge or blade, for felling trees, chopping and splitting wood, hewing timber, etc.","pos":""}]}