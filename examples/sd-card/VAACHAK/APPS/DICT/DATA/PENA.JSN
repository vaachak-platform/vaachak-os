{"PENAL":[{"def":"Of or pertaining to punishment, to penalties, or to crimes and offenses; pertaining to criminal jurisprudence: as: (a) Enacting or threatening punishment; as, a penal statue; the penal code.","pos":""}],"PENALITY":[{"def":"The quality or state of being penal; lability to punishment.","pos":""}],"PENALIZE":[{"def":"To put a penalty on.","pos":""}],"PENALLY":[{"def":"In a penal manner.","pos":""}],"PENALTY":[{"def":"Penal retribution; punishment for crime or offense; the suffering in person or property which is annexed by law or judicial decision to the commission of a crime, offense, or trespass.","pos":""},{"def":"The suffering, or the sum to be forfeited, to which a person subjects himself by covenant or agreement, in case of nonfulfillment of stipulations; forfeiture; fine.","pos":""}],"PENANCE":[{"def":"A means of repairing a sin committed, and obtaining pardon for it, consisting partly in the performance of expiatory rites, partly in voluntary submission to a punishment corresponding to the transgression.","pos":""}],"PENANCELESS":[{"def":"Free from penance.","pos":""}],"PENANG LAWYER":[{"def":"A kind of walking stick made from the stem of an East Asiatic palm (Licuala acutifida).","pos":""}],"PENANNULAR":[{"def":"Nearly annular; having nearly the form of a ring.","pos":""}],"PENATES":[{"def":"The household gods of the ancient Romans.","pos":""}]}