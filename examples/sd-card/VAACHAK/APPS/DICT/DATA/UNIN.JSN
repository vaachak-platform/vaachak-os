{"UNINCUMBERED":[{"def":"Free from any temporary estate or interest, or from mortgage, or other charge or debt; as, an estate unincumbered with dower.","pos":""}],"UNINFRINGIBLE":[{"def":"That may not be infringed; as, an uninfringible monopoly.","pos":""}],"UNINTELLIGENCE":[{"def":"Absence or lack of intelligence; unwisdom; ignorance.","pos":""}],"UNINTERESSED":[{"def":"Uninterested; unaffected.","pos":""}],"UNINTERESTED":[{"def":"Not interested; not having any interest or property in; having nothing at stake; as, to be uninterested in any business.","pos":""},{"def":"Not having the mind or the passions engaged; as, uninterested in a discourse or narration.","pos":""}],"UNINTERMISSION":[{"def":"Want or failure of intermission.","pos":""}],"UNINUCLEATED":[{"def":"Possessed of but a single nucleus; as, a uninucleated cell.","pos":""}]}