{"AFT":[{"def":"Near or towards the stern of a vessel; astern; abaft.","pos":""}],"AFTER":[{"def":"To ward the stern of the ship; -- applied to any object in the rear part of a vessel; as the after cabin, after hatchway.","pos":""}],"AFTER DAMP":[{"def":"An irrespirable gas, remaining after an explosion of fire damp in mines; choke damp.","pos":""}],"AFTER-DINNER":[{"def":"The time just after dinner.","pos":""},{"def":"Following dinner; post-prandial; as, an after-dinner nap.","pos":""}],"AFTER-GLOW":[{"def":"A glow of refulgence in the western sky after sunset.","pos":""}],"AFTER-IMAGE":[{"def":"The impression of a vivid sensation retained by the retina of the eye after the cause has been removed; also extended to impressions left of tones, smells, etc.","pos":""}],"AFTER-MENTIONED":[{"def":"Mentioned afterwards; as, persons after-mentioned (in a writing).","pos":""}],"AFTER-NOTE":[{"def":"One of the small notes occur on the unaccented parts of the measure, taking their time from the preceding note.","pos":""}],"AFTER-SAILS":[{"def":"The sails on the mizzenmast, or on the stays between the mainmast and mizzenmast.","pos":""}],"AFTER-WIT":[{"def":"Wisdom or perception that comes after it can be of use.","pos":""}],"AFTER-WITTED":[{"def":"Characterized by afterwit; slow-witted.","pos":""}],"AFTERBIRTH":[{"def":"The placenta and membranes with which the fetus is connected, and which come away after delivery.","pos":""}],"AFTERCAST":[{"def":"A throw of dice after the game in ended; hence, anything done too late.","pos":""}],"AFTERCLAP":[{"def":"An unexpected subsequent event; something disagreeable happening after an affair is supposed to be at an end.","pos":""}],"AFTERCROP":[{"def":"A second crop or harvest in the same year.","pos":""}],"AFTERGAME":[{"def":"A second game; hence, a subsequent scheme or expedient.","pos":""}],"AFTERGRASS":[{"def":"The grass that grows after the first crop has been mown; aftermath.","pos":""}],"AFTERGROWTH":[{"def":"A second growth or crop, or (metaphorically) development.","pos":""}],"AFTERGUARD":[{"def":"The seaman or seamen stationed on the poop or after part of the ship, to attend the after-sails.","pos":""}],"AFTERINGS":[{"def":"The last milk drawn in milking; strokings.","pos":""}],"AFTERMATH":[{"def":"A second moving; the grass which grows after the first crop of hay in the same season; rowen.","pos":""}],"AFTERMOST":[{"def":"Nearest the stern; most aft.","pos":""}],"AFTERNOON":[{"def":"The part of the day which follows noon, between noon and evening.","pos":""}],"AFTERPAINS":[{"def":"The pains which succeed childbirth, as in expelling the afterbirth.","pos":""}],"AFTERPIECE":[{"def":"The heel of a rudder.","pos":""}],"AFTERSENSATION":[{"def":"A sensation or sense impression following the removal of a stimulus producing a primary sensation, and reproducing the primary sensation in positive, negative, or complementary form.","pos":""}],"AFTERTASTE":[{"def":"A taste which remains in the mouth after eating or drinking.","pos":""}],"AFTERTHOUGHT":[{"def":"Reflection after an act; later or subsequent thought or expedient.","pos":""},{"def":"At a later or succeeding time.","pos":""}],"AFTERWISE":[{"def":"Wise after the event; wise or knowing, when it is too late.","pos":""}],"AFTMOST":[{"def":"Nearest the stern.","pos":""}],"AFTWARD":[{"def":"Toward the stern.","pos":""},{"def":"In Turkey, a commander or chief officer.","pos":""}]}