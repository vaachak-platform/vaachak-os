{"PYRACANTH":[{"def":"The evergreen thorn (Cratægus Pyracantha), a shrub native of Europe.","pos":""}],"PYRAL":[{"def":"Of or pertaining to a pyre.","pos":""}],"PYRALID":[{"def":"Any moth of the family Pyralidæ.","pos":""}],"PYRAMID":[{"def":"A solid figure contained by a plane rectilineal figure as base and several triangles which have a common vertex and whose bases are sides of the base.","pos":""},{"def":"The game of pool in which the balls are placed in the form of a triangle at spot.","pos":""}],"PYRAMIDAL":[{"def":"Same as Tetragonal.","pos":""}],"PYRAMIDALLY":[{"def":"Of or pertaining to a pyramid; having the form of a pyramid; pyramidal.","pos":""}],"PYRAMIDION":[{"def":"The small pyramid which crowns or completes an obelisk.","pos":""}],"PYRAMIDOID":[{"def":"A solid resembling a pyramid; -- called also pyramoid.","pos":""}],"PYRARGYRITE":[{"def":"Ruby silver; dark red silver ore.","pos":""},{"def":"A feebly basic solid, C4H4N2, obtained by distilling piperazine with zinc dust, and in other ways.","pos":""}]}