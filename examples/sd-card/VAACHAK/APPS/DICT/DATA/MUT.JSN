{"MUTABILITY":[{"def":"The quality of being mutable, or subject to change or alteration, either in form, state, or essential character; susceptibility of change; changeableness; inconstancy; variation.","pos":""}],"MUTABLE":[{"def":"Capable of alteration; subject to change; changeable in form, qualities, or nature.","pos":""},{"def":"Changeable; inconstant; unsettled; unstable; fickle.","pos":""}],"MUTABLENESS":[{"def":"The quality of being mutable.","pos":""}],"MUTAGE":[{"def":"A process for checking the fermentation of the must of grapes.","pos":""}],"MUTANDUM":[{"def":"A thing which is to be changed; something which must be altered; -- used chiefly in the plural.","pos":""}],"MUTATION":[{"def":"Change; alteration, either in form or qualities.","pos":""}],"MUTCH":[{"def":"The close linen or muslin cap of an old woman.","pos":""}],"MUTCHKIN":[{"def":"A liquid measure equal to four gills, or an imperial pint.","pos":""}],"MUTE":[{"def":"To cast off; to molt.","pos":""}],"MUTELY":[{"def":"Without uttering words or sounds; in a mute manner; silently.","pos":""}],"MUTENESS":[{"def":"The quality or state of being mute; speechlessness.","pos":""}],"MUTESSARIF":[{"def":"In Turkey, an administrative authority of any of certain sanjaks.","pos":""}],"MUTESSARIFAT":[{"def":"In Turkey, a sanjak whose head is a mutessarif.","pos":""},{"def":"Without a point or pointed process; blunt.","pos":""}],"MUTILATE":[{"def":"Having finlike appendages or flukes instead of legs, as a cetacean.","pos":""}],"MUTILATION":[{"def":"The act of mutilating, or the state of being mutilated; deprivation of a limb or of an essential part.","pos":""}],"MUTILATOR":[{"def":"One who mutilates.","pos":""}],"MUTILOUS":[{"def":"Mutilated; defective; imperfect.","pos":""}],"MUTINEER":[{"def":"One guilty of mutiny.","pos":""}],"MUTINOUS":[{"def":"Disposed to mutiny; in a state of mutiny; characterized by mutiny; seditious; insubordinate.","pos":""}],"MUTINY":[{"def":"Insurrection against constituted authority, particularly military or naval authority; concerted revolt against the rules of discipline or the lawful commands of a superior officer; hence, generally, forcible resistance to rightful authority; insubordination.","pos":""},{"def":"Violent commotion; tumult; strife.","pos":""}],"MUTISM":[{"def":"The condition, state, or habit of being mute, or without speech.","pos":""}],"MUTOSCOPE":[{"def":"A simple form of moving-picture machine in which the series of views, exhibiting the successive phases of a scene, are printed on paper and mounted around the periphery of a wheel.","pos":""}],"MUTTER":[{"def":"To utter words indistinctly or with a low voice and lips partly closed; esp.","pos":""},{"def":"To sound with a low, rumbling noise.","pos":""}],"MUTTERER":[{"def":"One who mutters.","pos":""}],"MUTTERINGLY":[{"def":"With a low voice and indistinct articulation; in a muttering manner.","pos":""}],"MUTTON":[{"def":"The flesh of a sheep.","pos":""}],"MUTTONY":[{"def":"Like mutton; having a flavor of mutton.","pos":""}],"MUTUAL":[{"def":"Reciprocally acting or related; reciprocally receiving and giving; reciprocally given and received; reciprocal; interchanged; as, a mutual love, advantage, assistance, aversion, etc.","pos":""},{"def":"Possessed, experienced, or done by two or more persons or things at the same time; common; joint; as, mutual happiness; a mutual effort.","pos":""}],"MUTUALISM":[{"def":"The doctrine of mutual dependence as the condition of individual and social welfare.","pos":""}],"MUTUALITY":[{"def":"Reciprocity of consideration.","pos":""}],"MUTUALLY":[{"def":"In a mutual manner.","pos":""}],"MUTUARY":[{"def":"One who borrows personal chattels which are to be consumed by him, and which he is to return or repay in kind.","pos":""}],"MUTUATION":[{"def":"The act of borrowing or exchanging.","pos":""}],"MUTULE":[{"def":"A projecting block worked under the corona of the Doric corice, in the same situation as the modillion of the Corinthian and Composite orders.","pos":""}]}