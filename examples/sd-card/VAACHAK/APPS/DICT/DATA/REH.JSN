{"REHABILITATE":[{"def":"To invest or clothe again with some right, authority, or dignity; to restore to a former capacity; to reinstate; to qualify again; to restore, as a delinquent, to a former right, rank, or privilege lost or forfeited; -- a term of civil and canon law.","pos":""}],"REHABILITATION":[{"def":"The act of rehabilitating, or the state of being rehabilitated.","pos":""}],"REHASH":[{"def":"To hash over again; to prepare or use again; as, to rehash old arguments.","pos":""}],"REHEAR":[{"def":"To hear again; to try a second time; as, to rehear a cause in Chancery.","pos":""}],"REHEARSAL":[{"def":"The act of rehearsing; recital; narration; repetition; specifically, a private recital, performance, or season of practice, in preparation for a public exhibition or exercise.","pos":""}],"REHEARSE":[{"def":"To repeat, as what has been already said; to tell over again; to recite.","pos":""},{"def":"To narrate; to relate; to tell.","pos":""}],"REHEARSER":[{"def":"One who rehearses.","pos":""}],"REHEAT":[{"def":"To revive; to cheer; to cherish.","pos":""}],"REHIBITION":[{"def":"The returning of a thing purchased to the seller, on the ground of defect or frand.","pos":""}],"REHIBITORY":[{"def":"Of or relating to rehibition; as, a rehibitory action.","pos":""}],"REHYPOTHECATE":[{"def":"To hypothecate again.","pos":""}]}