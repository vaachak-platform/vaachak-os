{"MAZARD":[{"def":"A kind of small black cherry.","pos":""}],"MAZARINE":[{"def":"Of or pertaining to Cardinal Mazarin, prime minister of France, 1643-1661.","pos":""}],"MAZDEAN":[{"def":"Of or pertaining to Ahura-Mazda, or Ormuzd, the beneficent deity in the Zoroastrian dualistic system; hence, Zoroastrian.","pos":""}],"MAZDEISM":[{"def":"The Zoroastrian religion.","pos":""}],"MAZE":[{"def":"A wild fancy; a confused notion.","pos":""},{"def":"Confusion of thought; perplexity; uncertainty; state of bewilderment.","pos":""}],"MAZEDNESS":[{"def":"The condition of being mazed; confusion; astonishment.","pos":""}],"MAZER":[{"def":"A large drinking bowl; -- originally made of maple.","pos":""}],"MAZILY":[{"def":"In a mazy manner.","pos":""}],"MAZINESS":[{"def":"The state or quality of being mazy.","pos":""}],"MAZOLOGICAL":[{"def":"Of or pertaining to mazology.","pos":""}],"MAZOLOGIST":[{"def":"One versed in mazology or mastology.","pos":""}],"MAZOLOGY":[{"def":"Same as Mastology.","pos":""},{"def":"A Polish dance, or the music which accompanies it, usually in 3-4 or 3-8 measure, with a strong accent on the second beat.","pos":""}],"MAZY":[{"def":"Perplexed with turns and windings; winding; intricate; confusing; perplexing; embarrassing; as, mazy error.","pos":""}]}