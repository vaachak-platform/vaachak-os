{"NUCAMENT":[{"def":"A catkin or ament; the flower cluster of the hazel, pine, willow, and the like.","pos":""}],"NUCAMENTACEOUS":[{"def":"Like a nut either in structure or in being indehiscent; bearing one-seeded nutlike fruits.","pos":""}],"NUCELLUS":[{"def":"See Nucleus, 3 (a).","pos":""}],"NUCHA":[{"def":"The back or upper part of the neck; the nape.","pos":""}],"NUCHAL":[{"def":"Of, pertaining to, or in the region of, the back, or nape, of the neck; -- applied especially to the anterior median plate in the carapace of turtles.","pos":""}],"NUCIFEROUS":[{"def":"Bearing, or producing, nuts.","pos":""}],"NUCIFORM":[{"def":"Shaped like a nut; nut-shaped.","pos":""}],"NUCIN":[{"def":"Of or pertaining to a nucleus; as, the nuclear spindle (see Illust.","pos":""}],"NUCLEATE":[{"def":"Having a nucleus; nucleated.","pos":""}],"NUCLEATED":[{"def":"Having a nucleus; nucleate; as, nucleated cells.","pos":""}],"NUCLEIFORM":[{"def":"Formed like a nucleus or kernel.","pos":""}],"NUCLEIN":[{"def":"A constituent of the nuclei of all cells.","pos":""}],"NUCLEOBRANCH":[{"def":"Belonging to the Nucleobranchiata.","pos":""},{"def":"One of the Nucleobranchiata.","pos":""}],"NUCLEOBRANCHIATA":[{"def":"Nu`cle*o*bran`chi*a\"ta, n.","pos":""}],"NUCLEOIDIOPLASMA":[{"def":"Hyaline plasma contained in the nucleus of vegetable cells.","pos":""}],"NUCLEOLAR":[{"def":"Of or pertaining to the nucleolus of a cell.","pos":""}],"NUCLEOLATED":[{"def":"Having a nucleole, or second inner nucleus.","pos":""}],"NUCLEOLE":[{"def":"The nucleus within a nucleus; nucleolus.","pos":""}],"NUCLEOLUS":[{"def":"A small rounded body contained in the nucleus of a cell or a protozoan.","pos":""}],"NUCLEOPLASM":[{"def":"The matter composing the nucleus of a cell; the protoplasm of the nucleus; karyoplasma.","pos":""}],"NUCLEOPLASMIC":[{"def":"Of or pertaining to nucleoplasm; -- esp.","pos":""}],"NUCLEUS":[{"def":"The body or the head of a comet.","pos":""},{"def":"A body, usually spheroidal, in a cell or a protozoan, distinguished from the surrounding protoplasm by a difference in refrangibility and in behavior towards chemical reagents.","pos":""}],"NUCULA":[{"def":"A genus of small marine bivalve shells, having a pearly interior.","pos":""}],"NUCUMENTACEOUS":[{"def":"See Nucamentaceous.","pos":""}]}