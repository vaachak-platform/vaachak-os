{"GAR":[{"def":"Gar pike, or Garpike (Zoöl.","pos":""}],"GARAGE":[{"def":"A place for housing automobiles.","pos":""},{"def":"A side way or space in a canal to enable vessels to pass each other; a siding.","pos":""}],"GARANCIN":[{"def":"An extract of madder by sulphuric acid.","pos":""}],"GARB":[{"def":"External appearance, as expressive of the feelings or character; looks; fashion or manner, as of speech.","pos":""}],"GARBAGE":[{"def":"Offal, as the bowels of an animal or fish; refuse animal or vegetable matter from a kitchen; hence, anything worthless, disgusting, or loathsome.","pos":""}],"GARBED":[{"def":"Dressed; habited; clad.","pos":""}],"GARBEL":[{"def":"Same as Garboard.","pos":""}],"GARBLE":[{"def":"To sift or bolt, to separate the fine or valuable parts of from the coarse and useless parts, or from dros or dirt; as, to garble spices.","pos":""},{"def":"To pick out such parts of as may serve a purpose; to mutilate; to pervert; as, to garble a quotation; to garble an account.","pos":""}],"GARBLER":[{"def":"One who garbles.","pos":""}],"GARBOARD":[{"def":"One of the planks next the keel on the outside, which form a garboard strake.","pos":""}],"GARBOIL":[{"def":"Tumult; disturbance; disorder.","pos":""}],"GARCINIA":[{"def":"A genus of plants, including the mangosteen tree (Garcinia Mangostana), found in the islands of the Indian Archipelago; -- so called in honor of Dr.","pos":""}],"GARCON":[{"def":"A boy; fellow; esp.","pos":""}],"GARDANT":[{"def":"Turning the head towards the spectator, but not the body; -- said of a lion or other beast.","pos":""}],"GARDE CIVIQUE":[{"def":"See Army organization, above.","pos":""}],"GARDEN":[{"def":"A piece of ground appropriates to the cultivation of herbs, fruits, flowers, or vegetables.","pos":""},{"def":"A rich, well-cultivated spot or tract of country.","pos":""}],"GARDENER":[{"def":"One who makes and tends a garden; a horticulturist.","pos":""}],"GARDENIA":[{"def":"A genus of plants, some species of which produce beautiful and fragrant flowers; Cape jasmine; -- so called in honor of Dr.","pos":""}],"GARDENING":[{"def":"The art of occupation of laying out and cultivating gardens; horticulture.","pos":""}],"GARDENLESS":[{"def":"Destitute of a garden.","pos":""}],"GARDON":[{"def":"A European cyprinoid fish; the id.","pos":""}],"GARDYLOO":[{"def":"An old cry in throwing water, slops, etc.","pos":""}],"GARE":[{"def":"Coarse wool on the legs of sheep.","pos":""}],"GAREFOWL":[{"def":"The great auk; also, the razorbill.","pos":""}],"GARFISH":[{"def":"Caribbæus, a very large species, and T.","pos":""}],"GARGALIZE":[{"def":"To gargle; to rinse.","pos":""}],"GARGANEY":[{"def":"A small European duck (Anas querquedula); -- called also cricket teal, and summer teal.","pos":""}],"GARGANTUAN":[{"def":"Characteristic of Gargantua, a gigantic, wonderful personage; enormous; prodigious; inordinate.","pos":""}],"GARGARIZE":[{"def":"To gargle; to rinse or wash, as the mouth and throat.","pos":""}],"GARGET":[{"def":"A diseased condition of the udders of cows, etc.","pos":""}],"GARGIL":[{"def":"A distemper in geese, affecting the head.","pos":""}],"GARGLE":[{"def":"To wash or rinse, as the mouth or throat, particular the latter, agitating the liquid (water or a medicinal preparation) by an expulsion of air from the lungs.","pos":""},{"def":"To warble; to sing as if gargling [Obs.","pos":""}],"GARGOL":[{"def":"A distemper in swine; garget.","pos":""}],"GARGOULETTE":[{"def":"A water cooler or jug with a handle and spout; a gurglet.","pos":""}],"GARGOYLE":[{"def":"A spout projecting from the roof gutter of a building, often carved grotesquely.","pos":""}],"GARIBALDI":[{"def":"A California market fish (Pomancentrus rubicundus) of a deep scarlet color.","pos":""}],"GARISH":[{"def":"Showy; dazzling; ostentatious; attracting or exciting attention.","pos":""},{"def":"Gay to extravagance; flighty.","pos":""}],"GARLAND":[{"def":"The crown of a king.","pos":""},{"def":"A wreath of chaplet made of branches, flowers, or feathers, and sometimes of precious stones, to be worn on the head like a crown; a coronal; a wreath.","pos":""}],"GARLANDLESS":[{"def":"Destitute of a garland.","pos":""}],"GARLIC":[{"def":"A plant of the genus Allium (A.","pos":""}],"GARLICKY":[{"def":"Like or containing garlic.","pos":""}],"GARMENT":[{"def":"Any article of clothing, as a coat, a gown, etc.","pos":""}],"GARMENTED":[{"def":"Having on a garment; attired; enveloped, as with a garment.","pos":""}],"GARMENTURE":[{"def":"Clothing; dress.","pos":""}],"GARNER":[{"def":"A granary; a building or place where grain is stored for preservation.","pos":""}],"GARNET":[{"def":"A mineral having many varieties differing in color and in their constituents, but with the same crystallization (isometric), and conforming to the same general chemical formula.","pos":""}],"GARNETIFEROUS":[{"def":"Containing garnets.","pos":""}],"GARNIERITE":[{"def":"An amorphous mineral of apple-green color; a hydrous silicate of nickel and magnesia.","pos":""}],"GARNISH":[{"def":"To ornament, as a dish, with something laid about it; as, a dish garnished with parsley.","pos":""},{"def":"To warn by garnishment; to give notice to; to garnishee.","pos":""}],"GARNISHEE":[{"def":"One who is garnished; a person upon whom garnishment has been served in a suit by a creditor against a debtor, such person holding property belonging to the debtor, or owing him money.","pos":""}],"GARNISHER":[{"def":"One who, or that which, garnishes.","pos":""}],"GARNISHMENT":[{"def":"Ornament; embellishment; decoration.","pos":""}],"GARNITURE":[{"def":"That which garnishes; ornamental appendage; embellishment; furniture; dress.","pos":""}],"GAROOKUH":[{"def":"A small fishing vessel met with in the Persian Gulf.","pos":""}],"GAROUS":[{"def":"Pertaining to, or resembling, garum.","pos":""}],"GARRET":[{"def":"A turret; a watchtower.","pos":""},{"def":"That part of a house which is on the upper floor, immediately under or within the roof; an attic.","pos":""}],"GARRETED":[{"def":"Protected by turrets.","pos":""}],"GARRETEER":[{"def":"One who lives in a garret; a poor author; a literary hack.","pos":""}],"GARRETING":[{"def":"Small splinters of stone inserted into the joints of coarse masonry.","pos":""}],"GARROT":[{"def":"A stick or small wooden cylinder used for tightening a bandage, in order to compress the arteries of a limb.","pos":""}],"GARROTE":[{"def":"A Spanish mode of execution by strangulation, with an iron collar affixed to a post and tightened by a screw until life become extinct; also, the instrument by means of which the punishment is inflicted.","pos":""}],"GARROTER":[{"def":"One who seizes a person by the throat from behind, with a view to strangle and rob him.","pos":""}],"GARRULITY":[{"def":"Talkativeness; loquacity.","pos":""}],"GARRULOUS":[{"def":"Having a loud, harsh note; noisy; -- said of birds; as, the garrulous roller.","pos":""}],"GARRUPA":[{"def":"One of several species of California market fishes, of the genus Sebastichthys; -- called also rockfish.","pos":""}],"GARTER":[{"def":"Same as Bendlet.","pos":""}],"GARTER STITCH":[{"def":"The simplest stitch in knitting.","pos":""}],"GARTH":[{"def":"A close; a yard; a croft; a garden; as, a cloister garth.","pos":""},{"def":"A dam or weir for catching fish.","pos":""}],"GARUM":[{"def":"A sauce made of small fish.","pos":""}],"GARVIE":[{"def":"The spart; -- called also garvie herring, and garvock.","pos":""}]}