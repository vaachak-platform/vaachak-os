{"WHEAL":[{"def":"A pustule; a whelk.","pos":""}],"WHEALWORM":[{"def":"The harvest mite; -- so called from the wheals, caused by its bite.","pos":""}],"WHEAT":[{"def":"A cereal grass (Triticum vulgare) and its grain, which furnishes a white flour for bread, and, next to rice, is the grain most largely used by the human race.","pos":""}],"WHEAT RUST":[{"def":"A disease of wheat and other grasses caused by the rust fungus Puccinia graminis; also, the fungus itself.","pos":""}],"WHEATBIRD":[{"def":"A bird that feeds on wheat, especially the chaffinch.","pos":""}],"WHEATEAR":[{"def":"A small European singing bird (Saxicola oenanthe).","pos":""}],"WHEATEN":[{"def":"Made of wheat; as, wheaten bread.","pos":""}],"WHEATSEL BIRD":[{"def":"The male of the chaffinch.","pos":""}],"WHEATSTONE'S BRIDGE":[{"def":"See under Bridge.","pos":""}],"WHEATSTONE'S RODS":[{"def":"Flexible rods the period of vibration of which in two planes at right angles are in some exact ratio to one another.","pos":""}],"WHEATWORM":[{"def":"A small nematode worm (Anguillula tritici) which attacks the grains of wheat in the ear.","pos":""}],"WHEEDLE":[{"def":"To entice by soft words; to cajole; to flatter; to coax.","pos":""},{"def":"To grain, or get away, by flattery.","pos":""}],"WHEEL":[{"def":"A firework which, while burning, is caused to revolve on an axis by the reaction of the escaping gases.","pos":""}],"WHEEL BASE":[{"def":"The figure inclosed by lines through the points contact of the wheels of a vehicle, etc.","pos":""}],"WHEEL OF FORTUNE":[{"def":"A gambling or lottery device consisting of a wheel which is spun horizontally, articles or sums to which certain marks on its circumference point when it stops being distributed according to varying rules.","pos":""}],"WHEEL-SHAPED":[{"def":"Expanding into a flat, circular border at top, with scarcely any tube; as, a wheel-shaped corolla.","pos":""}],"WHEEL-WORN":[{"def":"Worn by the action of wheels; as, a wheel-worn road.","pos":""}],"WHEELBAND":[{"def":"The tire of a wheel.","pos":""}],"WHEELBARROW":[{"def":"A light vehicle for conveying small loads.","pos":""}],"WHEELBIRD":[{"def":"The European goatsucker.","pos":""}],"WHEELED":[{"def":"Having wheels; -- used chiefly in composition; as, a four- wheeled carriage.","pos":""}],"WHEELER":[{"def":"A steam vessel propelled by a paddle wheel or by paddle wheels; -- used chiefly in the terms side-wheeler and stern-wheeler.","pos":""},{"def":"The European goatsucker.","pos":""}],"WHEELING":[{"def":"The act of conveying anything, or traveling, on wheels, or in a wheeled vehicle.","pos":""},{"def":"The act or practice of using a cycle; cycling.","pos":""}],"WHEELMAN":[{"def":"One who rides a bicycle or tricycle; a cycler, or cyclist.","pos":""}],"WHEELWORK":[{"def":"A combination of wheels, and their connection, in a machine or mechanism.","pos":""}],"WHEELWRIGHT":[{"def":"A man whose occupation is to make or repair wheels and wheeled vehicles, as carts, wagons, and the like.","pos":""}],"WHEELY":[{"def":"Circular; suitable to rotation.","pos":""}],"WHEEN":[{"def":"A quantity; a goodly number.","pos":""}],"WHEEZE":[{"def":"To breathe hard, and with an audible piping or whistling sound, as persons affected with asthma.","pos":""}],"WHEEZY":[{"def":"Breathing with difficulty and with a wheeze; wheezing.","pos":""}],"WHELK":[{"def":"Any one numerous species of large marine gastropods belonging to Buccinum and allied genera; especially, Buccinum undatum, common on the coasts both of Europe and North America, and much used as food in Europe.","pos":""}],"WHELKED":[{"def":"Having whelks; whelky; as, whelked horns.","pos":""}],"WHELKY":[{"def":"Having whelks, ridges, or protuberances; hence, streaked; striated.","pos":""}],"WHELM":[{"def":"To cover with water or other fluid; to cover by immersion in something that envelops on all sides; to overwhelm; to ingulf.","pos":""}],"WHELP":[{"def":"One of the longitudinal ribs or ridges on the barrel of a capstan or a windless; -- usually in the plural; as, the whelps of a windlass.","pos":""}],"WHEN":[{"def":"At what time; -- used interrogatively.","pos":""},{"def":"At what time; at, during, or after the time that; at or just after, the moment that; -- used relatively.","pos":""}],"WHENAS":[{"def":"Whereas; while [Obs.","pos":""}],"WHENCE":[{"def":"From what place; hence, from what or which source, origin, antecedent, premise, or the like; how; -- used interrogatively.","pos":""},{"def":"From what or which place, source, material, cause, etc.","pos":""}],"WHENCEFORTH":[{"def":"From, or forth from, what or which place; whence.","pos":""}],"WHENCESOEVER":[{"def":"From what place soever; from what cause or source soever.","pos":""}],"WHENEVER":[{"def":"At whatever time.","pos":""}],"WHENSOEVER":[{"def":"At what time soever; at whatever time; whenever.","pos":""}],"WHERE":[{"def":"At or in what place; hence, in what situation, position, or circumstances; -- used interrogatively.","pos":""},{"def":"At or in which place; at the place in which; hence, in the case or instance in which; -- used relatively.","pos":""}],"WHERE'ER":[{"def":"Wherever; -- a contracted and poetical form.","pos":""}],"WHEREAS":[{"def":"At which place; where.","pos":""}],"WHEREAT":[{"def":"At which; upon which; whereupon; -- used relatively.","pos":""}],"WHEREBY":[{"def":"By which; -- used relatively.","pos":""},{"def":"By what; how; -- used interrogatively.","pos":""}],"WHEREFORE":[{"def":"For which reason; so; -- used relatively.","pos":""},{"def":"For what reason; why; -- used interrogatively.","pos":""}],"WHEREFORM":[{"def":"From which; from which or what place.","pos":""}],"WHEREIN":[{"def":"In which; in which place, thing, time, respect, or the like; -- used relatively.","pos":""},{"def":"In what; -- used interrogatively.","pos":""}],"WHEREINTO":[{"def":"Into which; -- used relatively.","pos":""},{"def":"Into what; -- used interrogatively.","pos":""}],"WHERENESS":[{"def":"The quality or state of having a place; ubiety; situation; position.","pos":""}],"WHEREOF":[{"def":"Of which; of whom; formerly, also, with which; -- used relatively.","pos":""},{"def":"Of what; -- used interrogatively.","pos":""}],"WHEREON":[{"def":"On which; -- used relatively; as, the earth whereon we live.","pos":""}],"WHEREOUT":[{"def":"The cleft whereout the lightning breaketh.","pos":""}],"WHERESOEVER":[{"def":"In what place soever; in whatever place; wherever.","pos":""}],"WHERETO":[{"def":"To which; -- used relatively.","pos":""},{"def":"To what; to what end; -- used interrogatively.","pos":""}],"WHEREUNTO":[{"def":"Same as Whereto.","pos":""}],"WHEREUPON":[{"def":"Upon which; in consequence of which; after which.","pos":""}],"WHEREVER":[{"def":"At or in whatever place; wheresoever.","pos":""}],"WHEREWITH":[{"def":"With which; -- used relatively.","pos":""},{"def":"With what; -- used interrogatively.","pos":""}],"WHEREWITHAL":[{"def":"Wherewithal shall a young man cleanse his way Ps.","pos":""}],"WHERRET":[{"def":"To hurry; to trouble; to tease.","pos":""},{"def":"To box (one) on the ear; to strike or box.","pos":""}],"WHERRY":[{"def":"A liquor made from the pulp of crab apples after the verjuice is expressed; -- sometimes called crab wherry.","pos":""}],"WHET":[{"def":"To rub or on with some substance, as a piece of stone, for the purpose of sharpening; to sharpen by attrition; as, to whet a knife.","pos":""},{"def":"To make sharp, keen, or eager; to excite; to stimulate; as, to whet the appetite or the courage.","pos":""}],"WHETHER":[{"def":"Which (of two); which one (of two); -- used interrogatively and relatively.","pos":""}],"WHETHERING":[{"def":"The retention of the afterbirth in cows.","pos":""}],"WHETILE":[{"def":"The green woodpecker, or yaffle.","pos":""}],"WHETSTONE":[{"def":"A piece of stone, natural or artificial, used for whetting, or sharpening, edge tools.","pos":""}],"WHETTER":[{"def":"One who, or that which, whets, sharpens, or stimulates.","pos":""},{"def":"A tippler; one who drinks whets.","pos":""}],"WHETTLEBONES":[{"def":"The vertebræ of the back.","pos":""}],"WHEW":[{"def":"A sound like a half-formed whistle, expressing astonishment, scorn, or dislike.","pos":""}],"WHEWELLITE":[{"def":"Calcium oxalate, occurring in colorless or white monoclinic crystals.","pos":""}],"WHEWER":[{"def":"The European widgeon.","pos":""}],"WHEY":[{"def":"The serum, or watery part, of milk, separated from the more thick or coagulable part, esp.","pos":""}],"WHEY CURE":[{"def":"Treatment with whey as a drink and in baths.","pos":""}],"WHEY-FACED":[{"def":"Having a pale or white face, as from fright.","pos":""}],"WHEYEY":[{"def":"Of the nature of, or containing, whey; resembling whey; wheyish.","pos":""}],"WHEYFACE":[{"def":"One who is pale, as from fear.","pos":""}],"WHEYISH":[{"def":"Somewhat like whey; wheyey.","pos":""}]}