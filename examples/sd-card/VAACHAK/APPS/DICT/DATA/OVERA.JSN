{"OVERABOUND":[{"def":"To be exceedingly plenty or superabundant.","pos":""}],"OVERACT":[{"def":"To act or perform to excess; to exaggerate in acting; as, he overacted his part.","pos":""},{"def":"To act upon, or influence, unduly.","pos":""}],"OVERAFFECT":[{"def":"To affect or care for unduly.","pos":""}],"OVERAGITATE":[{"def":"To agitate or discuss beyond what is expedient.","pos":""}],"OVERALLS":[{"def":"A kind of loose trousers worn over others to protect them from soiling.","pos":""},{"def":"Waterproof leggings.","pos":""}],"OVERANXIETY":[{"def":"The state of being overanxious; excessive anxiety.","pos":""}],"OVERANXIOUS":[{"def":"Anxious in an excessive or needless degree.","pos":""}],"OVERARCH":[{"def":"To make or place an arch over; to hang over like an arch.","pos":""}],"OVERAWE":[{"def":"To awe exceedingly; to subjugate or restrain by awe or great fear.","pos":""}],"OVERAWFUL":[{"def":"Awful, or reverential, in an excessive degree.","pos":""}]}