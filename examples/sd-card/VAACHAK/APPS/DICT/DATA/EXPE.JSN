{"EXPECT":[{"def":"To wait for; to await.","pos":""}],"EXPECTABLE":[{"def":"That may be expected or looked for.","pos":""}],"EXPECTANT":[{"def":"Waiting in expectation; looking for; (Med.","pos":""},{"def":"waiting for the efforts of nature, with little active treatment.","pos":""}],"EXPECTATION":[{"def":"The leaving of the disease principally to the efforts of nature to effect a cure.","pos":""}],"EXPECTATIVE":[{"def":"Constituting an object of expectation; contingent.","pos":""}],"EXPECTEDLY":[{"def":"In conformity with expectation.","pos":""}],"EXPECTER":[{"def":"One who expects.","pos":""}],"EXPECTINGLY":[{"def":"In state of expectation.","pos":""}],"EXPECTORANT":[{"def":"Tending to facilitate expectoration or to promote discharges of mucus, etc.","pos":""},{"def":"An expectorant medicine.","pos":""}],"EXPECTORATE":[{"def":"To eject from the trachea or lungs; to discharge, as phlegm or other matter, by coughing, hawking, and spitting; to spit forth.","pos":""}],"EXPECTORATION":[{"def":"The act of ejecting phlegm or mucus from the throat or lungs, by coughing, hawking, and spitting.","pos":""},{"def":"That which is expectorated, as phlegm or mucus.","pos":""}],"EXPECTORATIVE":[{"def":"Same as Expectorant.","pos":""}],"EXPEDE":[{"def":"To expedite; to hasten.","pos":""}],"EXPEDIATE":[{"def":"To hasten; to expedite.","pos":""}],"EXPEDIENT":[{"def":"Hastening or forward; hence, tending to further or promote a proposed object; fit or proper under the circumstances; conducive to self-interest; desirable; advisable; advantageous; -- sometimes contradistinguished from right.","pos":""},{"def":"Quick; expeditious.","pos":""}],"EXPEDIENTIAL":[{"def":"Ex*pe`di*en\"tial Defn: .","pos":""}],"EXPEDIENTLY":[{"def":"In an expedient manner; fitly; suitably; conveniently.","pos":""},{"def":"With expedition; quickly.","pos":""}],"EXPEDIMENT":[{"def":"A like expediment to remove discontent.","pos":""}],"EXPEDITATE":[{"def":"To deprive of the claws or the balls of the fore feet; as, to expeditate a dog that he may not chase deer.","pos":""}],"EXPEDITE":[{"def":"Free of impediment; unimpeded.","pos":""},{"def":"Expeditious; quick; speedily; prompt.","pos":""}],"EXPEDITELY":[{"def":"In expedite manner; expeditiously.","pos":""}],"EXPEDITENESS":[{"def":"Quality of being expedite.","pos":""}],"EXPEDITION":[{"def":"The quality of being expedite; efficient promptness; haste; dispatch; speed; quickness; as to carry the mail with expedition.","pos":""},{"def":"A sending forth or setting forth the execution of some object of consequence; progress.","pos":""}],"EXPEDITIONARY":[{"def":"Of or pertaining to an expedition; as, an expeditionary force.","pos":""}],"EXPEDITIONIST":[{"def":"One who goes upon an expedition.","pos":""}],"EXPEDITIOUS":[{"def":"Possessed of, or characterized by, expedition, or efficiency and rapidity in action; performed with, or acting with, expedition; quick; having celerity; speedily; as, an expeditious march or messenger.","pos":""}],"EXPEDITIVE":[{"def":"Performing with speed.","pos":""}],"EXPEL":[{"def":"To drive or force out from that within which anything is contained, inclosed, or situated; to eject; as to expel air from a bellows.","pos":""},{"def":"To drive away from one's country; to banish.","pos":""}],"EXPELLABLE":[{"def":"Capable of being expelled or driven out.","pos":""}],"EXPEND":[{"def":"To lay out, apply, or employ in any way; to consume by use; to use up or distribute, either in payment or in donations; to spend; as, they expend money for food or in charity; to expend time labor, and thought; to expend hay in feeding cattle, oil in a lamp, water in mechanical operations.","pos":""}],"EXPENDITOR":[{"def":"A disburser; especially, one of the disbursers of taxes for the repair of sewers.","pos":""}],"EXPENDITURE":[{"def":"The act of expending; a laying out, as of money; disbursement.","pos":""},{"def":"That which is expended or paid out; expense.","pos":""}],"EXPENSE":[{"def":"A spending or consuming; disbursement; expenditure.","pos":""},{"def":"That which is expended, laid out, or consumed; cost; outlay; charge; -- sometimes with the notion of loss or damage to those on whom the expense falls; as, the expenses of war; an expense of time.","pos":""}],"EXPENSEFULL":[{"def":"Full of expense; costly; chargeable.","pos":""}],"EXPENSELESS":[{"def":"Without cost or expense.","pos":""}],"EXPENSIVE":[{"def":"Occasioning expense; calling for liberal outlay; costly; dear; liberal; as, expensive dress; an expensive house or family.","pos":""},{"def":"Free in expending; very liberal; especially, in a bad scene; extravagant; lavish.","pos":""}],"EXPERIENCE":[{"def":"Trial, as a test or experiment.","pos":""},{"def":"The effect upon the judgment or feelings produced by any event, whether witnessed or participated in; personal and direct impressions as contrasted with description or fancies; personal acquaintance; actual enjoyment or suffering.","pos":""}],"EXPERIENCE TABLE":[{"def":"A table of mortality computed from the experience of one or more life-insurance companies.","pos":""}],"EXPERIENCED":[{"def":"Taught by practice or by repeated observations; skillful or wise by means of trials, use, or observation; as, an experienced physician, workman, soldier; an experienced eye.","pos":""}],"EXPERIENCER":[{"def":"One who experiences.","pos":""},{"def":"An experimenter.","pos":""}],"EXPERIENT":[{"def":"Ex*pe\"ri*ent (-ent), a.","pos":""}],"EXPERIENTIAL":[{"def":"Derived from, or pertaining to, experience.","pos":""}],"EXPERIENTIALISM":[{"def":"The doctrine that experience, either that ourselves or of others, is the test or criterion of general knowledge; -- opposed to intuitionists.","pos":""}],"EXPERIENTIALIST":[{"def":"One who accepts the doctrine of experientialism.","pos":""}],"EXPERIMENT":[{"def":"Atrial or special observation, made to confirm or disprove something doubtful; esp.","pos":""}],"EXPERIMENTAL":[{"def":"Pertaining to experiment; founded on, or derived from, experiment or trial; as, experimental science; given to, or skilled in, experiment; as, an experimental philosopher.","pos":""},{"def":"Known by, or derived from, experience; as, experimental religion.","pos":""}],"EXPERIMENTALIST":[{"def":"One who makes experiments; an experimenter.","pos":""}],"EXPERIMENTALIZE":[{"def":"To make experiments (upon); to experiment.","pos":""}],"EXPERIMENTALLY":[{"def":"By experiment; by experience or trial.","pos":""}],"EXPERIMENTARIAN":[{"def":"Relying on experiment or experience.","pos":""},{"def":"One who relies on experiment or experience.","pos":""}],"EXPERIMENTATION":[{"def":"The act of experimenting; practice by experiment.","pos":""}],"EXPERIMENTATIVE":[{"def":"Experimental; of the nature of experiment.","pos":""}],"EXPERIMENTATOR":[{"def":"An experimenter.","pos":""}],"EXPERIMENTER":[{"def":"One who makes experiments; one skilled in experiments.","pos":""}],"EXPERIMENTIST":[{"def":"An experimenter.","pos":""}],"EXPERRECTION":[{"def":"A waking up or arousing.","pos":""}],"EXPERT":[{"def":"Taught by use, practice, or experience, experienced; having facility of operation or performance from practice; knowing and ready from much practice; clever; skillful; as, an expert surgeon; expert in chess or archery.","pos":""}],"EXPERTLY":[{"def":"In a skillful or dexterous manner; adroitly; with readiness and accuracy.","pos":""}],"EXPERTNESS":[{"def":"Skill derived from practice; readiness; as, expertness in seamanship, or in reasoning.","pos":""}],"EXPETIBLE":[{"def":"Worthy of being wished for; desirable.","pos":""}]}