{"RETRACE":[{"def":"To trace back, as a line.","pos":""},{"def":"To go back, in or over (a previous course); to go over again in a reverse direction; as, to retrace one's steps; to retrace one's proceedings.","pos":""}],"RETRACT":[{"def":"To draw back; to draw up or shorten; as, the cat can retract its claws; to retract a muscle.","pos":""},{"def":"Ti withdraw; to recall; to disavow; to recant; to take back; as, to retract an accusation or an assertion.","pos":""}],"RETRACTABLE":[{"def":"Capable of being retracted; retractile.","pos":""}],"RETRACTATE":[{"def":"To retract; to recant.","pos":""}],"RETRACTATION":[{"def":"The act of retracting what has been said; recantation.","pos":""}],"RETRACTILE":[{"def":"CApable of retraction; capable of being drawn back or up; as, the claws of a cat are retractile.","pos":""}],"RETRACTION":[{"def":"The act of retracting, or drawing back; the state of being retracted; as, the retraction of a cat's claws.","pos":""},{"def":"The act of withdrawing something advanced, stated, claimed, or done; declaration of change of opinion; recantation.","pos":""}],"RETRACTIVE":[{"def":"Serving to retract; of the nature of a retraction.","pos":""}],"RETRACTOR":[{"def":"One who, or that which, retracts.","pos":""},{"def":"An instrument for holding apart the edges of a wound during amputation.","pos":""}],"RETRAIT":[{"def":"A portrait; a likeness.","pos":""}],"RETRANSFORM":[{"def":"To transform anew or back.","pos":""}],"RETRANSLATE":[{"def":"To translate anew; especially, to translate back into the original language.","pos":""}],"RETRAXIT":[{"def":"The withdrawing, or open renunciation, of a suit in court by the plaintiff, by which he forever lost his right of action.","pos":""}],"RETREAT":[{"def":"The act of retiring or withdrawing one's self, especially from what is dangerous or disagreeable.","pos":""},{"def":"The place to which anyone retires; a place or privacy or safety; a refuge; an asylum.","pos":""}],"RETREATFUL":[{"def":"Furnishing or serving as a retreat.","pos":""}],"RETREATMENT":[{"def":"The act of retreating; specifically, the Hegira.","pos":""}],"RETRENCH":[{"def":"To furnish with a retrenchment; as, to retrench bastions.","pos":""}],"RETRENCHMENT":[{"def":"A work constructed within another, to prolong the defense of the position when the enemy has gained possession of the outer work; or to protect the defenders till they can retreat or obtain terms for a capitulation.","pos":""}],"RETRIAL":[{"def":"A secdond trial, experiment, or test; a second judicial trial, as of an accused person.","pos":""}],"RETRIBUTE":[{"def":"To pay back; to give in return, as payment, reward, or punishment; to requite; as, to retribute one for his kindness; to retribute just punishment to a criminal.","pos":""}],"RETRIBUTER":[{"def":"One who makes retribution.","pos":""}],"RETRIBUTION":[{"def":"Of or pertaining to retribution; of the nature of retribution; involving retribution or repayment; as, retributive justice; retributory comforts.","pos":""}],"RETRIEVABLE":[{"def":"That may be retrieved or recovered; admitting of retrieval.","pos":""}],"RETRIEVAL":[{"def":"The act retrieving.","pos":""}],"RETRIEVE":[{"def":"To find again; to recover; to regain; to restore from loss or injury; as, to retrieve one's character; to retrieve independence.","pos":""},{"def":"To recall; to bring back.","pos":""}],"RETRIEVER":[{"def":"A dor, or a breed of dogs, chiefly employed to retrieve, or to find and recover game birds that have been killed or wounded.","pos":""}],"RETRO-":[{"def":"A prefix or combining form signifying backward, back; as, retroact, to act backward; retrospect, a looking back.","pos":""}],"RETROACT":[{"def":"To act backward, or in return; to act in opposition; to be retrospective.","pos":""}],"RETROACTION":[{"def":"Action returned, or action backward.","pos":""},{"def":"Operation on something past or preceding.","pos":""}],"RETROACTIVE":[{"def":"Fitted or designed to retroact; operating by returned action; affecting what is past; retrospective.","pos":""}],"RETROACTIVELY":[{"def":"In a retroactive manner.","pos":""}],"RETROCEDE":[{"def":"To cede or grant back; as, to retrocede a territory to a former proprietor.","pos":""}],"RETROCEDENT":[{"def":"Disposed or likely to retrocede; -- said of diseases which go from one part of the body to another, as the gout.","pos":""}],"RETROCESSION":[{"def":"Metastasis of an eruption or a tumor from the surface to the interior of the body.","pos":""}],"RETROCHOIR":[{"def":"Any extension of a church behind the higggggggh altar, as a chapel; also, in an apsidal church, all the space beyond the line of the back or eastern face of the altar.","pos":""}],"RETROCOPULANT":[{"def":"Copulating backward, or from behind.","pos":""}],"RETROCOPULATION":[{"def":"Copulation from behind.","pos":""}],"RETRODUCTION":[{"def":"A leading or bringing back.","pos":""},{"def":"Reflexed; bent or turned abruptly backward.","pos":""}],"RETROFLEXION":[{"def":"The act of reflexing; the state of being retroflexed.","pos":""},{"def":"Refracted; as, a retrofract stem.","pos":""}],"RETROGENERATIVE":[{"def":"Begetting young by retrocopulation.","pos":""}],"RETROGRADATION":[{"def":"The act of retrograding, or moving backward.","pos":""},{"def":"The state of being retrograde; decline.","pos":""}],"RETROGRADE":[{"def":"Apparently moving backward, and contrary to the succession of the signs, that is, from east to west, as a planet.","pos":""}],"RETROGRADINGLY":[{"def":"By retrograding; so as to retrograde.","pos":""}],"RETROGRESSION":[{"def":"Backward development; a passing from a higher to a lower state of organization or structure, as when an animal, approaching maturity, becomes less highly organized than would be expected from its earlier stages or known relationship.","pos":""}],"RETROGRESSIVE":[{"def":"Passing from a higher to a lower condition; declining from a more perfect state of organization; regressive.","pos":""}],"RETROGRESSIVELY":[{"def":"In a retrogressive manner.","pos":""}],"RETROMINGENCY":[{"def":"The quality or state of being retromingent.","pos":""}],"RETROMINGENT":[{"def":"Organized so as to discharge the urine backward.","pos":""},{"def":"An animal that discharges its urine backward.","pos":""}],"RETROPULSIVE":[{"def":"Driving back; repelling.","pos":""}],"RETRORSE":[{"def":"Bent backward or downward.","pos":""}],"RETROSPECT":[{"def":"To look backward; hence, to affect or concern what is past.","pos":""}],"RETROSPECTION":[{"def":"The act, or the faculty, of looking back on things past.","pos":""}],"RETROSPECTIVE":[{"def":"Looking backward; contemplating things past; -- opposed to prospective; as, a retrospective view.","pos":""},{"def":"Having reference to what is past; affecting things past; retroactive; as, a retrospective law.","pos":""}],"RETROSPECTIVELY":[{"def":"By way of retrospect.","pos":""}],"RETROUSSE":[{"def":"Turned up; -- said of a pug nose.","pos":""}],"RETROVACCINATION":[{"def":"The inoculation of a cow with human vaccine virus.","pos":""}],"RETROVERSION":[{"def":"A turning or bending backward; also, the state of being turned or bent backward; displacement backwards; as, retroversion of the uterus.","pos":""}],"RETROVERTED":[{"def":"In a state of retroversion.","pos":""}],"RETRUSION":[{"def":"The act of retruding, or the state of being retruded.","pos":""}]}