{"RIS":[{"def":"A bough or branch; a twig.","pos":""}],"RISE":[{"def":"To be lifted, or to admit of being lifted, from the imposing stone without dropping any of the type; -- said of a form.","pos":""}],"RISER":[{"def":"A shaft excavated from below upward.","pos":""}],"RISH":[{"def":"A rush (the plant).","pos":""}],"RISIBILITY":[{"def":"The quality of being risible; as, risibility is peculiar to the human species.","pos":""}],"RISIBLE":[{"def":"Having the faculty or power of laughing; disposed to laugh.","pos":""},{"def":"Exciting laughter; worthy to be laughed at; amusing.","pos":""}],"RISING":[{"def":"Attaining a higher place; taking, or moving in, an upward direction; appearing above the horizon; ascending; as, the rising moon.","pos":""},{"def":"Increasing in wealth, power, or distinction; as, a rising state; a rising character.","pos":""}],"RISK":[{"def":"Hazard of loss; liabillity to loss in property.","pos":""}],"RISKER":[{"def":"One who risks or hazards.","pos":""}],"RISKY":[{"def":"Attended with risk or danger; hazardous.","pos":""}],"RISORIAL":[{"def":"Pertaining to, or producing, laughter; as, the risorial muscles.","pos":""}],"RISOTTO":[{"def":"A kind of pottage.","pos":""},{"def":"Hazardous; risky; esp.","pos":""}],"RISSOID":[{"def":"Any one of very numerous species of small spiral gastropods of the genus Rissoa, or family Rissoidæ, found both in fresh and salt water.","pos":""}],"RISSOLE":[{"def":"A small ball of rich minced meat or fish, covered with pastry and fried.","pos":""}]}