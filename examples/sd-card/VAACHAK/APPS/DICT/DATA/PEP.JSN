{"PEPASTIC":[{"def":"Same as Maturative.","pos":""},{"def":"A volcanic rock, formed by the cementing together of sand, scoria, cinders, etc.","pos":""}],"PEPLIS":[{"def":"A genus of plants including water purslane.","pos":""}],"PEPLUS":[{"def":"An upper garment worn by Grecian and Roman women.","pos":""},{"def":"A kind of kerchief formerly worn by Englishwomen.","pos":""}],"PEPO":[{"def":"Any fleshy fruit with a firm rind, as a pumpkin, melon, or gourd.","pos":""}],"PEPPER":[{"def":"The plant which yields pepper, an East Indian woody climber (Piper nigrum), with ovate leaves and apetalous flowers in spikes opposite the leaves.","pos":""}],"PEPPER BOX":[{"def":"A buttress on the left-hand wall of a fives court as the game is played at Eton College, England.","pos":""}],"PEPPER DULSE":[{"def":"A variety of edible seaweed (Laurencia pinnatifida) distinguished for its pungency.","pos":""}],"PEPPERCORN":[{"def":"A dried berry of the black pepper (Piper nigrum).","pos":""},{"def":"Anything insignificant; a particle.","pos":""}],"PEPPERER":[{"def":"A grocer; -- formerly so called because he sold pepper.","pos":""}],"PEPPERIDGE":[{"def":"A North American tree (Nyssa multiflora) with very tough wood, handsome oval polished leaves, and very acid berries, -- the sour gum, or common tupelo.","pos":""}],"PEPPERING":[{"def":"Hot; pungent; peppery.","pos":""}],"PEPPERMINT":[{"def":"An aromatic and pungent plant of the genus Mentha (M.","pos":""}],"PEPPERWORT":[{"def":"See Peppergrass.","pos":""}],"PEPPERY":[{"def":"Of or pertaining to pepper; having the qualities of pepper; hot; pungent.","pos":""}],"PEPSIN":[{"def":"An unorganized proteolytic ferment or enzyme contained in the secretory glands of the stomach.","pos":""}],"PEPSINHYDROCHLORIC":[{"def":"Same as Peptohydrochloric.","pos":""}],"PEPSINOGEN":[{"def":"The antecedent of the ferment pepsin.","pos":""}],"PEPTIC":[{"def":"Pertaining to pepsin; resembling pepsin in its power of digesting or dissolving albuminous matter; containing or yielding pepsin, or a body of like properties; as, the peptic glands.","pos":""}],"PEPTICS":[{"def":"The science of digestion.","pos":""}],"PEPTOGEN":[{"def":"A substance convertible into peptone.","pos":""}],"PEPTOGENIC":[{"def":"Same as Peptogenous.","pos":""}],"PEPTOGENOUS":[{"def":"Capable of yielding, or being converted into, peptone.","pos":""}],"PEPTOHYDROCHLORIC":[{"def":"Designating a hypothetical acid (called peptohydrochloric acid, pepsinhydrochloric acid, and chloropeptic acid) which is supposed to be formed when pepsin and dilute (0.","pos":""}],"PEPTONE":[{"def":"Note: Pure peptones are of three kinds, amphopeptone, antipeptone, and hemipeptone, and, unlike the albumose bodies, are not precipitated by saturating their solutions with ammonium sulphate.","pos":""}],"PEPTONIZE":[{"def":"To convert into peptone; to digest or dissolve by means of a proteolytic ferment; as, peptonized food.","pos":""}],"PEPTONOID":[{"def":"A substance related to peptone.","pos":""}],"PEPTONURIA":[{"def":"The presence of peptone, or a peptonelike body, in the urine.","pos":""}],"PEPTOTOXINE":[{"def":"A toxic alkaloid found occasionally associated with the peptones formed from fibrin by pepsinhydrochloric acid.","pos":""}]}