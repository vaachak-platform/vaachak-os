{"PAW":[{"def":"The foot of a quadruped having claws, as the lion, dog, cat, etc.","pos":""}],"PAWK":[{"def":"A small lobster.","pos":""}],"PAWKY":[{"def":"Arch; cunning; sly.","pos":""}],"PAWL":[{"def":"A pivoted tongue, or sliding bolt, on one part of a machine, adapted to fall into notches, or interdental spaces, on another part, as a ratchet wheel, in such a manner as to permit motion in one direction and prevent it in the reverse, as in a windlass; a catch, click, or detent.","pos":""}],"PAWN":[{"def":"See Pan, the masticatory.","pos":""}],"PAWNABLE":[{"def":"Capable of being pawned.","pos":""}],"PAWNBROKER":[{"def":"One who makes a business of lending money on the security of personal property pledged or deposited in his keeping.","pos":""}],"PAWNBROKING":[{"def":"The business of a pawnbroker.","pos":""}],"PAWNEE":[{"def":"One or two whom a pledge is delivered as security; one who takes anything in pawn.","pos":""}],"PAWNEES":[{"def":"A tribe of Indians (called also Loups) who formerly occupied the region of the Platte river, but now live mostly in the Indian Territory.","pos":""},{"def":"One who pawns or pledges anything as security for the payment of borrowed money or of a debt.","pos":""}]}