{"ELM":[{"def":"A tree of the genus Ulmus, of several species, much used as a shade tree, particularly in America.","pos":""}],"ELMEN":[{"def":"Belonging to elms.","pos":""}],"ELMO'S FIRE":[{"def":"See Corposant; also Saint Elmo's Fire, under Saint.","pos":""}],"ELMY":[{"def":"Abounding with elms.","pos":""}]}