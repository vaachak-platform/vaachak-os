{"KIBBLE":[{"def":"To bruise; to grind coarsely; as, kibbled oats.","pos":""}],"KIBBLINGS":[{"def":"Portions of small fish used for bait on the banks of Newfoundland.","pos":""}],"KIBE":[{"def":"A chap or crack in the flesh occasioned by cold; an ulcerated chilblain.","pos":""}],"KIBED":[{"def":"Chapped; cracked with cold; affected with chilblains; as kibed heels.","pos":""}],"KIBITKA":[{"def":"A tent used by the Kirghiz Tartars.","pos":""},{"def":"A rude kind of Russian vehicle, on wheels or on runners, sometimes covered with cloth or leather, and often used as a movable habitation.","pos":""}],"KIBOSH":[{"def":"Nonsense; stuff; also, fashion; style.","pos":""},{"def":"Portland cement when thrown or blown into the recesses of carved stonework to intensify the shadows.","pos":""}],"KIBY":[{"def":"Affected with kibes.","pos":""}]}