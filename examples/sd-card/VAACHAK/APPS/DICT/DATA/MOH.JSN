{"MOHA":[{"def":"A kind of millet (Setaria Italica); German millet.","pos":""}],"MOHAIR":[{"def":"The long silky hair or wool of the Angora goat of Asia Minor; also, a fabric made from this material, or an imitation of such fabric.","pos":""}],"MOHAMMEDAN":[{"def":"Of or pertaining to Mohammed, or the religion and institutions founded by Mohammed.","pos":""}],"MOHAMMEDAN CALENDAR":[{"def":"A lunar calendar reckoning from the year of the hegira, 622 a.","pos":""}],"MOHAMMEDAN ERA":[{"def":"The era in use in Mohammedan countries.","pos":""},{"def":"The religion, or doctrines and precepts, of Mohammed, contained in the Koran; Islamism.","pos":""}],"MOHAMMEDAN YEAR":[{"def":"The year used by Mohammedans, consisting of twelve lunar months without intercalation, so that they retrograde through all the seasons in about 32½ years.","pos":""}],"MOHAWK":[{"def":"One of a tribe of Indians who formed part of the Five Nations.","pos":""}],"MOHICANS":[{"def":"A tribe of Lenni-Lenape Indians who formerly inhabited Western Connecticut and Eastern New York.","pos":""}],"MOHO":[{"def":"A gallinule (Notornis Mantelli) formerly inhabiting New Zealand, but now supposed to be extinct.","pos":""}],"MOHR":[{"def":"A West African gazelle (Gazella mohr), having horns on which are eleven or twelve very prominent rings.","pos":""}],"MOHUR":[{"def":"A British Indian gold coin, of the value of fifteen silver rupees, or $7.","pos":""}]}