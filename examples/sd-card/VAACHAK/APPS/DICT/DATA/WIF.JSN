{"WIFE":[{"def":"A woman; an adult female; -- now used in literature only in certain compounds and phrases, as alewife, fishwife, goodwife, and the like.","pos":""},{"def":"The lawful consort of a man; a woman who is united to a man in wedlock; a woman who has a husband; a married woman; -- correlative of husband.","pos":""}],"WIFEHOOD":[{"def":"The state of being a wife; the character of a wife.","pos":""}],"WIFELESS":[{"def":"Without a wife; unmarried.","pos":""}],"WIFELIKE":[{"def":"Of, pertaining to, or like, a wife or a woman.","pos":""}],"WIFELY":[{"def":"Becoming or life; of or pertaining to a wife.","pos":""}]}