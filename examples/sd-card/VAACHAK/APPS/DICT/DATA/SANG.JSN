{"SANG":[{"def":"The Abyssinian ox (Bos or Bibos, Africanus), noted for the great length of its horns.","pos":""}],"SANG-FROID":[{"def":"Freedom from agitation or excitement of mind; coolness in trying circumstances; indifference; calmness.","pos":""}],"SANGAREE":[{"def":"Wine and water sweetened and spiced, -- a favorite West Indian drink.","pos":""}],"SANGIAC":[{"def":"See Holy Grail, under Grail.","pos":""}],"SANGUIFEROUS":[{"def":"Conveying blood; as, sanguiferous vessels, i.","pos":""}],"SANGUIFICATION":[{"def":"The production of blood; the conversion of the products of digestion into blood; hematosis.","pos":""}],"SANGUIFIER":[{"def":"A producer of blood.","pos":""}],"SANGUIFLUOUS":[{"def":"Flowing or running with blood.","pos":""}],"SANGUIFY":[{"def":"To produce blood from.","pos":""}],"SANGUIGENOUS":[{"def":"Producing blood; as, sanguigenous food.","pos":""}],"SANGUINACEOUS":[{"def":"Of a blood-red color; sanguine.","pos":""}],"SANGUINARIA":[{"def":"A genus of plants of the Poppy family.","pos":""}],"SANGUINARILY":[{"def":"In a sanguinary manner.","pos":""}],"SANGUINARINESS":[{"def":"The quality or state of being sanguinary.","pos":""}],"SANGUINARY":[{"def":"Attended with much bloodshed; bloody; murderous; as, a sanguinary war, contest, or battle.","pos":""},{"def":"Bloodthirsty; cruel; eager to shed blood.","pos":""}],"SANGUINE":[{"def":"Having the color of blood; red.","pos":""},{"def":"Characterized by abundance and active circulation of blood; as, a sanguine bodily temperament.","pos":""}],"SANGUINELESS":[{"def":"Destitute of blood; pale.","pos":""}],"SANGUINELY":[{"def":"In a sanguine manner.","pos":""}],"SANGUINENESS":[{"def":"The quality of being sanguine.","pos":""}],"SANGUINEOUS":[{"def":"Abounding with blood; sanguine.","pos":""},{"def":"Of or pertaining to blood; bloody; constituting blood.","pos":""}],"SANGUINITY":[{"def":"The quality of being sanguine; sanguineness.","pos":""}],"SANGUINIVOROUS":[{"def":"Subsisting on blood.","pos":""}],"SANGUINOLENCY":[{"def":"The state of being sanguinolent, or bloody.","pos":""}],"SANGUINOLENT":[{"def":"Tinged or mingled with blood; bloody; as, sanguinolent sputa.","pos":""}],"SANGUISUGE":[{"def":"A bloodsucker, or leech.","pos":""}],"SANGUIVOROUS":[{"def":"Subsisting upon blood; -- said of certain blood-sucking bats and other animals.","pos":""},{"def":"the great council of the Jews, which consisted of seventy members, to whom the high priest was added.","pos":""}]}