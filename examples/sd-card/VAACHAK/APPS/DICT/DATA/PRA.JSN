{"PRAAM":[{"def":"A flat-bottomed boat or lighter, -- used in Holland and the Baltic, and sometimes armed in case of war.","pos":""}],"PRACTIC":[{"def":"Artful; deceitful; skillful.","pos":""}],"PRACTICABILITY":[{"def":"The quality or state of being practicable; practicableness; feasibility.","pos":""}],"PRACTICABLE":[{"def":"That may be practiced or performed; capable of being done or accomplished with available means or resources; feasible; as, a practicable method; a practicable aim; a practicable good.","pos":""},{"def":"Capable of being used; passable; as, a practicable weapon; a practicable road.","pos":""}],"PRACTICAL":[{"def":"Of or pertaining to practice or action.","pos":""},{"def":"Capable of being turned to use or account; useful, in distinction from ideal or theoretical; as, practical chemistry.","pos":""}],"PRACTICALITY":[{"def":"The quality or state of being practical; practicalness.","pos":""}],"PRACTICALIZE":[{"def":"To render practical.","pos":""}],"PRACTICALLY":[{"def":"By means of practice or use; by experience or experiment; as, practically wise or skillful; practically acquainted with a subject.","pos":""},{"def":"In practice or use; as, a medicine practically safe; theoretically wrong, but practically right.","pos":""}],"PRACTICALNESS":[{"def":"Same as Practicality.","pos":""}],"PRACTICE":[{"def":"A easy and concise method of applying the rules of arithmetic to questions which occur in trade and business.","pos":""},{"def":"The form, manner, and order of conducting and carrying on suits and prosecutions through their various stages, according to the principles of law and the rules laid down by the courts.","pos":""}],"PRACTICED":[{"def":"Experienced; expert; skilled; as, a practiced marksman.","pos":""},{"def":"Used habitually; learned by practice.","pos":""}],"PRACTICER":[{"def":"One who practices, or puts in practice; one who customarily performs certain acts.","pos":""},{"def":"One who exercises a profession; a practitioner.","pos":""}],"PRACTICIAN":[{"def":"One who is acquainted with, or skilled in, anything by practice; a practitioner.","pos":""}],"PRACTISANT":[{"def":"An agent or confederate in treachery.","pos":""}],"PRACTISE":[{"def":"Note: The analogy of the English language requires that the noun and verb which are pronounced alike should agree in spelling.","pos":""}],"PRACTITIONER":[{"def":"One who is engaged in the actual use or exercise of any art or profession, particularly that of law or medicine.","pos":""},{"def":"One who does anything customarily or habitually.","pos":""}],"PRACTIVE":[{"def":"The preacher and the people both, Then practively did thrive.","pos":""}],"PRAECAVA":[{"def":"The superior vena cava.","pos":""}],"PRAECOCES":[{"def":"A division of birds including those whose young are able to run about when first hatched.","pos":""}],"PRAECOCIAL":[{"def":"Of or pertaining to the Præcoces.","pos":""}],"PRAECOGNITA":[{"def":"This previously known, or which should be known in order to understand something else.","pos":""}],"PRAECOMMISSURE":[{"def":"A transverse commissure in the anterior part of the third ventricle of the brain; the anterior cerebral commissure.","pos":""}],"PRAECORACOID":[{"def":"See Precoracoid.","pos":""}],"PRAECORDIA":[{"def":"The front part of the thoracic region; the epigastrium.","pos":""}],"PRAECORDIAL":[{"def":"Same as Precordial.","pos":""}],"PRAECORNU":[{"def":"The anterior horn of each lateral ventricle of the brain.","pos":""}],"PRAEFLORATION":[{"def":"Same as Prefloration.","pos":""}],"PRAEFOLIATION":[{"def":"Same as Prefoliation.","pos":""}],"PRAEMORSE":[{"def":"Same as Premorse.","pos":""}],"PRAEMUNIRE":[{"def":"Wolsey incurred a præmunire, and forfeited his honor, estate, and life.","pos":""}],"PRAEMUNITORY":[{"def":"See Premunitory.","pos":""}],"PRAENARES":[{"def":"The anterior nares.","pos":""}],"PRAENASAL":[{"def":"Same as Prenasal.","pos":""}],"PRAENOMEN":[{"def":"The first name of a person, by which individuals of the same family were distinguished, answering to our Christian name, as Caius, Lucius, Marcus, etc.","pos":""}],"PRAENOMINICAL":[{"def":"Of or pertaining to a prænomen.","pos":""}],"PRAEOPERCULUM":[{"def":"Same as Preoperculum.","pos":""},{"def":"Same as Preoral, Prepubis, Prescapula, etc.","pos":""}],"PRAETEXTA":[{"def":"A white robe with a purple border, worn by a Roman boy before he was entitled to wear the toga virilis, or until about the completion of his fourteenth year, and by girls until their marriage.","pos":""}],"PRAETORES":[{"def":"A division of butterflies including the satyrs.","pos":""}],"PRAEZYGAPOPHYSIS":[{"def":"Same as Prezygapophysis.","pos":""}],"PRAGMATIC":[{"def":"One skilled in affairs.","pos":""},{"def":"A solemn public ordinance or decree.","pos":""}],"PRAGMATICALLY":[{"def":"In a pragmatical manner.","pos":""}],"PRAGMATICALNESS":[{"def":"The quality or state of being pragmatical.","pos":""}],"PRAGMATISM":[{"def":"The quality or state of being pragmatic; in literature, the pragmatic, or philosophical, method.","pos":""}],"PRAGMATIST":[{"def":"One who is pragmatic.","pos":""}],"PRAGMATIZE":[{"def":"To consider, represent, or embody (something unreal) as fact; to materialize.","pos":""}],"PRAIRIAL":[{"def":"The ninth month of the French Republican calendar, which dated from September 22, 1792.","pos":""}],"PRAIRIE":[{"def":"An extensive tract of level or rolling land, destitute of trees, covered with coarse grass, and usually characterized by a deep, fertile soil.","pos":""},{"def":"A meadow or tract of grass; especially, a so called natural meadow.","pos":""}],"PRAIRIE STATE":[{"def":"Illinois; -- a nickname.","pos":""}],"PRAISABLE":[{"def":"Fit to be praised; praise-worthy; laudable; commendable.","pos":""}],"PRAISABLY":[{"def":"In a praisable manner.","pos":""}],"PRAISE":[{"def":"To commend; to applaud; to express approbation of; to laud; -- applied to a person or his acts.","pos":""},{"def":"To extol in words or song; to magnify; to glorify on account of perfections or excellent works; to do honor to; to display the excellence of; -- applied especially to the Divine Being.","pos":""}],"PRAISE-MEETING":[{"def":"A religious service mainly in song.","pos":""}],"PRAISELESS":[{"def":"Without praise or approbation.","pos":""}],"PRAISER":[{"def":"One who praises.","pos":""},{"def":"An appraiser; a valuator.","pos":""}],"PRAISEWORTHILY":[{"def":"In a praiseworthy manner.","pos":""}],"PRAISEWORTHINESS":[{"def":"The quality or state of being praiseworthy.","pos":""}],"PRAISEWORTHY":[{"def":"Worthy of praise or applause; commendable; as, praiseworthy action; he was praiseworthy.","pos":""}],"PRAKRIT":[{"def":"Any one of the popular dialects descended from, or akin to, Sanskrit; -- in distinction from the Sanskrit, which was used as a literary and learned language when no longer spoken by the people.","pos":""}],"PRAKRITIC":[{"def":"Pertaining to Prakrit.","pos":""}],"PRALINE":[{"def":"A confection made of nut kernels, usually of almonds, roasted in boiling sugar until brown and crisp.","pos":""}],"PRALLTRILLER":[{"def":"A melodic embellishment consisting of the quick alternation of a principal tone with an auxiliary tone above it, usually the next of the scale; --called also the inverted mordente.","pos":""}],"PRANCE":[{"def":"To spring or bound, as a horse in high mettle.","pos":""},{"def":"To ride on a prancing horse; to ride in an ostentatious manner.","pos":""}],"PRANCER":[{"def":"A horse which prances.","pos":""}],"PRANDIAL":[{"def":"Of or pertaining to a repast, especially to dinner.","pos":""}],"PRANGOS":[{"def":"A genus of umbelliferous plants, one species of which (P.","pos":""}],"PRANK":[{"def":"To adorn in a showy manner; to dress or equip ostentatiously; - - often followed by up; as, to prank up the body.","pos":""}],"PRANKER":[{"def":"One who dresses showily; a prinker.","pos":""}],"PRANKISH":[{"def":"Full of pranks; frolicsome.","pos":""}],"PRASE":[{"def":"A variety of cryptocrystalline of a leek-green color.","pos":""}],"PRASEO-":[{"def":"A combining form signifying green; as, praseocobalt, a green variety of cobalt.","pos":""}],"PRASEODYMIUM":[{"def":"An elementary substance, one of the constituents of didymium; - - so called from the green color of its salts.","pos":""}],"PRASEOLITE":[{"def":"A variety of altered iolite of a green color and greasy luster.","pos":""}],"PRASINOUS":[{"def":"Grass-green; clear, lively green, without any mixture.","pos":""}],"PRASOID":[{"def":"Resembling prase.","pos":""}],"PRATE":[{"def":"To talk much and to little purpose; to be loquacious; to speak foolishly; to babble.","pos":""}],"PRATINCOLE":[{"def":"Any bird of the Old World genus Glareola, or family Glareolidæ, allied to the plovers.","pos":""}],"PRATINGLY":[{"def":"With idle talk; with loquacity.","pos":""}],"PRATIQUE":[{"def":"Primarily, liberty of converse; intercourse; hence, a certificate, given after compliance with quarantine regulations, permitting a ship to land passengers and crew; -- a term used particularly in the south of Europe.","pos":""}],"PRATTLE":[{"def":"To talk much and idly; to prate; hence, to talk lightly and artlessly, like a child; to utter child's talk.","pos":""}],"PRATTLER":[{"def":"One who prattles.","pos":""}],"PRAVITY":[{"def":"Deterioration; degeneracy; corruption; especially, moral crookedness; moral perversion; perverseness; depravity; as, the pravity of human nature.","pos":""}],"PRAWN":[{"def":"Any one of numerous species of large shrimplike Crustacea having slender legs and long antennæ.","pos":""}],"PRAXINOSCOPE":[{"def":"An instrument, similar to the phenakistoscope, for presenting to view, or projecting upon a screen, images the natural motions of real objects.","pos":""}],"PRAXIS":[{"def":"Use; practice; especially, exercise or discipline for a specific purpose or object.","pos":""},{"def":"An example or form of exercise, or a collection of such examples, for practice.","pos":""}],"PRAY":[{"def":"To make request with earnestness or zeal, as for something desired; to make entreaty or supplication; to offer prayer to a deity or divine being as a religious act; specifically, to address the Supreme Being with adoration, confession, supplication, and thanksgiving.","pos":""}],"PRAYER":[{"def":"One who prays; a supplicant.","pos":""}],"PRAYERFUL":[{"def":"Given to prayer; praying much or often; devotional.","pos":""}],"PRAYERLESS":[{"def":"Not using prayer; habitually neglecting prayer to God; without prayer.","pos":""}],"PRAYINGLY":[{"def":"With supplication to God.","pos":""}]}