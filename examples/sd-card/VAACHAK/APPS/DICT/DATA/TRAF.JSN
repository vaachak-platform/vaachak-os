{"TRAFFIC":[{"def":"To pass goods and commodities from one person to another for an equivalent in goods or money; to buy or sell goods; to barter; to trade.","pos":""},{"def":"To trade meanly or mercenarily; to bargain.","pos":""}],"TRAFFIC MILE":[{"def":"Any unit of the total obtained by adding the passenger miles and ton miles in a railroad's transportation for a given period; -- a term and practice of restricted or erroneous usage.","pos":""}],"TRAFFICABLE":[{"def":"Capable of being disposed of in traffic; marketable.","pos":""}],"TRAFFICKER":[{"def":"One who traffics, or carries on commerce; a trader; a merchant.","pos":""}],"TRAFFICLESS":[{"def":"Destitute of traffic, or trade.","pos":""}]}