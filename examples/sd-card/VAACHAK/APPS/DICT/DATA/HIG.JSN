{"HIG-TAPER":[{"def":"A plant of the genus Verbascum (V.","pos":""}],"HIGGLE":[{"def":"To hawk or peddle provisions.","pos":""},{"def":"To chaffer; to stickle for small advantages in buying and selling; to haggle.","pos":""}],"HIGGLEDY-PIGGLEDY":[{"def":"In confusion; topsy-turvy.","pos":""}],"HIGGLER":[{"def":"One who higgles.","pos":""}],"HIGH":[{"def":"Men must high them apace, and make haste.","pos":""}],"HIGH FIVE":[{"def":"See Cinch (the game).","pos":""}],"HIGH PRIEST":[{"def":"A chief priest; esp.","pos":""}],"HIGH STEEL":[{"def":"Steel containing a high percentage of carbon; high-carbon steel.","pos":""}],"HIGH-BLOWN":[{"def":"Inflated, as with conceit.","pos":""}],"HIGH-BRED":[{"def":"Bred in high life; of pure blood.","pos":""}],"HIGH-BUILT":[{"def":"Of lofty structure; tall.","pos":""}],"HIGH-CHURCH":[{"def":"Of or pertaining to, or favoring, the party called the High Church, or their doctrines or policy.","pos":""}],"HIGH-CHURCHISM":[{"def":"The principles of the high-church party.","pos":""}],"HIGH-CHURCHMAN":[{"def":"One who holds high-church principles.","pos":""}],"HIGH-CHURCHMAN-SHIP":[{"def":"The state of being a high-churchman.","pos":""}],"HIGH-COLORED":[{"def":"Having a strong, deep, or glaring color; flushed.","pos":""},{"def":"Vivid; strong or forcible in representation; hence, exaggerated; as, high-colored description.","pos":""}],"HIGH-EMBOWED":[{"def":"Having lofty arches.","pos":""}],"HIGH-FED":[{"def":"Pampered; fed luxuriously.","pos":""}],"HIGH-FINISHED":[{"def":"Finished with great care; polished.","pos":""}],"HIGH-FLOWN":[{"def":"Elevated; proud.","pos":""},{"def":"Turgid; extravagant; bombastic; inflated; as, high-flown language.","pos":""}],"HIGH-GO":[{"def":"A spree; a revel.","pos":""}],"HIGH-HANDED":[{"def":"Overbearing; oppressive; arbitrary; violent; as, a high-handed act.","pos":""}],"HIGH-HEARTED":[{"def":"Full of courage or nobleness; high-souled.","pos":""}],"HIGH-HOE":[{"def":"The European green woodpecker or yaffle.","pos":""}],"HIGH-HOLDER":[{"def":"The flicker; -- called also high-hole.","pos":""}],"HIGH-LOW":[{"def":"A laced boot, ankle high.","pos":""}],"HIGH-METTLED":[{"def":"Having abundance of mettle; ardent; full of fire; as, a high- mettled steed.","pos":""}],"HIGH-MINDED":[{"def":"Proud; arrogant.","pos":""},{"def":"Having, or characterized by, honorable pride; of or pertaining to elevated principles and feelings; magnanimous; -- opposed to mean.","pos":""}],"HIGH-MINDEDNESS":[{"def":"The quality of being highminded; nobleness; magnanimity.","pos":""}],"HIGH-PALMED":[{"def":"Having high antlers; bearing full-grown antlers aloft.","pos":""}],"HIGH-PRESSURE":[{"def":"Having or involving a pressure greatly exceeding that of the atmosphere; -- said of steam, air, water, etc.","pos":""}],"HIGH-PRIESTHOOD":[{"def":"The office, dignity, or position of a high priest.","pos":""}],"HIGH-PRIESTSHIP":[{"def":"High-priesthood.","pos":""}],"HIGH-PRINCIPLED":[{"def":"Possessed of noble or honorable principles.","pos":""}],"HIGH-PROOF":[{"def":"Highly rectified; very strongly alcoholic; as, high-proof spirits.","pos":""},{"def":"So as to stand any test.","pos":""}],"HIGH-RAISED":[{"def":"Elevated; raised aloft; upreared.","pos":""},{"def":"Elated with great ideas or hopes.","pos":""}],"HIGH-REACHING":[{"def":"Reaching high or upward; hence, ambitious; aspiring.","pos":""}],"HIGH-RED":[{"def":"Of a strong red color.","pos":""}],"HIGH-SEASONED":[{"def":"Enriched with spice and condiments; hence, exciting; piquant.","pos":""}],"HIGH-SIGHTED":[{"def":"Looking upward; supercilious.","pos":""}],"HIGH-SOULED":[{"def":"Having a high or noble spirit; honorable.","pos":""}],"HIGH-SOUNDING":[{"def":"Pompous; noisy; ostentatious; as, high-sounding words or titles.","pos":""}],"HIGH-SPIRITED":[{"def":"Full of spirit or natural fire; haughty; courageous; impetuous; not brooking restraint or opposition.","pos":""}],"HIGH-STEPPER":[{"def":"A horse that moves with a high step or proud gait; hence, a person having a proud bearing.","pos":""}],"HIGH-STOMACHED":[{"def":"Having a lofty spirit; haughty.","pos":""}],"HIGH-STRUNG":[{"def":"Strung to a high pitch; spirited; sensitive; as, a high-strung horse.","pos":""}],"HIGH-SWELLING":[{"def":"Inflated; boastful.","pos":""}],"HIGH-TONED":[{"def":"High in tone or sound.","pos":""},{"def":"Elevated; high-principled; honorable.","pos":""}],"HIGH-TOP":[{"def":"A ship's masthead.","pos":""}],"HIGH-WROUGHT":[{"def":"Wrought with fine art or skill; elaborate.","pos":""},{"def":"Worked up, or swollen, to a high degree; as, a highwrought passion.","pos":""}],"HIGHBINDER":[{"def":"A ruffian; one who hounds, or spies upon, another; app.","pos":""}],"HIGHBOY":[{"def":"One who lives high; also, in politics, a highflyer.","pos":""},{"def":"A kind of set of drawers.","pos":""}],"HIGHER CRITICISM":[{"def":"Criticism which includes the study of the contents, literary character, date, authorship, etc.","pos":""}],"HIGHER THOUGHT":[{"def":"See New thought, below.","pos":""}],"HIGHER-UP":[{"def":"A superior officer or official; -- used chiefly in pl.","pos":""}],"HIGHERING":[{"def":"Rising higher; ascending.","pos":""}],"HIGHFALUTING":[{"def":"High-flown, bombastic language.","pos":""}],"HIGHFLIER":[{"def":"One who is extravagant in pretensions, opinions, or manners.","pos":""}],"HIGHFLYING":[{"def":"Extravagant in opinions or ambition.","pos":""}],"HIGHLAND":[{"def":"Elevated or mountainous land; (often in the pl.","pos":""}],"HIGHLANDER":[{"def":"An inhabitant of highlands, especially of the Highlands of Scotland.","pos":""}],"HIGHLANDRY":[{"def":"Highlanders, collectively.","pos":""}],"HIGHLY":[{"def":"In a high manner, or to a high degree; very much; as, highly esteemed.","pos":""}],"HIGHMEN":[{"def":"Loaded dice so contrived as to turn up high numbers.","pos":""}],"HIGHNESS":[{"def":"The state of being high; elevation; loftiness.","pos":""},{"def":"A title of honor given to kings, princes, or other persons of rank; as, His Royal Highness.","pos":""}],"HIGHT":[{"def":"A variant of Height.","pos":""}],"HIGHTENER":[{"def":"That which heightens.","pos":""}],"HIGHTH":[{"def":"Variant of Height.","pos":""}],"HIGHWAY":[{"def":"A road or way open to the use of the public; a main road or thoroughfare.","pos":""}],"HIGHWAYMAN":[{"def":"One who robs on the public road; a highway robber.","pos":""}]}