{"HARD":[{"def":"Not easily penetrated, cut, or separated into parts; not yielding to pressure; firm; solid; compact; -- applied to material bodies, and opposed to soft; as, hard wood; hard flesh; a hard apple.","pos":""},{"def":"Difficult, mentally or judicially; not easily apprehended, decided, or resolved; as a hard problem.","pos":""}],"HARD GRASS":[{"def":"A name given to several different grasses, especially to the Roltböllia incurvata, and to the species of Ægilops, from one of which it is contended that wheat has been derived.","pos":""}],"HARD STEEL":[{"def":"Steel hardened by the addition of other elements, as manganese, phosphorus, or (usually) carbon.","pos":""}],"HARD-FAVORED":[{"def":"Hard-featured; ill-looking; as, Vulcan was hard-favored.","pos":""}],"HARD-FAVOREDNESS":[{"def":"Coarseness of features.","pos":""}],"HARD-FEATURED":[{"def":"Having coarse, unattractive or stern features.","pos":""}],"HARD-FISTED":[{"def":"Having hard or strong hands; as, a hard-fisted laborer.","pos":""},{"def":"Close-fisted; covetous; niggardly.","pos":""}],"HARD-FOUGHT":[{"def":"contested; as, a hard-fought battle.","pos":""}],"HARD-HANDED":[{"def":"Having hard hands, as a manual laborer.","pos":""}],"HARD-HEADED":[{"def":"Having sound judgment; sagacious; shrewd.","pos":""}],"HARD-HEARTED":[{"def":"Unsympathetic; inexorable; cruel; pitiless.","pos":""}],"HARD-LABORED":[{"def":"Wrought with severe labor; elaborate; studied.","pos":""}],"HARD-MOUTHED":[{"def":"Not sensible to the bit; not easily governed; as, a hard- mouthed horse.","pos":""}],"HARD-SHELL":[{"def":"Unyielding; insensible to argument; uncompromising; strict.","pos":""}],"HARD-TACK":[{"def":"A name given by soldiers and sailors to a kind of hard biscuit or sea bread.","pos":""}],"HARD-VISAGED":[{"def":"Of a harsh or stern countenance; hard-featured.","pos":""}],"HARDBAKE":[{"def":"A sweetmeat of boiled brown sugar or molasses made with almonds, and flavored with orange or lemon juice, etc.","pos":""}],"HARDBEAM":[{"def":"A tree of the genus Carpinus, of compact, horny texture; hornbeam.","pos":""}],"HARDEN":[{"def":"To make hard or harder; to make firm or compact; to indurate; as, to harden clay or iron.","pos":""},{"def":"To accustom by labor or suffering to endure with constancy; to strengthen; to stiffen; to inure; also, to confirm in wickedness or shame; to make unimpressionable.","pos":""}],"HARDENED":[{"def":"Made hard, or compact; made unfeeling or callous; made obstinate or obdurate; confirmed in error or vice.","pos":""}],"HARDENER":[{"def":"One who, or that which, hardens; specif.","pos":""}],"HARDENING":[{"def":"Making hard or harder.","pos":""},{"def":"That which hardens, as a material used for converting the surface of iron into steel.","pos":""}],"HARDER":[{"def":"A South African mullet, salted for food.","pos":""}],"HARDERIAN":[{"def":"A term applied to a lachrymal gland on the inner side of the orbit of many animals which have a third eyelid, or nictitating membrane.","pos":""}],"HARDFAVOREDNESS":[{"def":"Coarseness of features.","pos":""}],"HARDFERN":[{"def":"A species of fern (Lomaria borealis), growing in Europe and Northwestern America.","pos":""}],"HARDHACK":[{"def":"A very astringent shrub (Spiræa tomentosa), common in pastures.","pos":""}],"HARDHEAD":[{"def":"Clash or collision of heads in contest.","pos":""}],"HARDIHOOD":[{"def":"Boldness, united with firmness and constancy of mind; bravery; intrepidity; also, audaciousness; impudence.","pos":""}],"HARDILY":[{"def":"Boldly; stoutly; resolutely.","pos":""}],"HARDIMENT":[{"def":"Hardihood; boldness; courage; energetic action.","pos":""}],"HARDINESS":[{"def":"Capability of endurance.","pos":""},{"def":"Hardihood; boldness; firmness; assurance.","pos":""}],"HARDLY":[{"def":"In a hard or difficult manner; with difficulty.","pos":""},{"def":"Unwillingly; grudgingly.","pos":""}],"HARDNESS":[{"def":"The cohesion of the particles on the surface of a body, determined by its capacity to scratch another, or be itself scratched;-measured among minerals on a scale of which diamond and talc form the extremes.","pos":""},{"def":"The peculiar quality exhibited by water which has mineral salts dissolved in it.","pos":""}],"HARDPAN":[{"def":"The hard substratum.","pos":""}],"HARDS":[{"def":"The refuse or coarse part of fiax; tow.","pos":""}],"HARDSHIP":[{"def":"That which is hard to hear, as toil, privation, injury, injustice, etc.","pos":""}],"HARDSPUN":[{"def":"Firmly twisted in spinning.","pos":""}],"HARDWARE":[{"def":"Ware made of metal, as cutlery, kitchen utensils, and the like; ironmongery.","pos":""}],"HARDWAREMAN":[{"def":"One who makes, or deals in, hardware.","pos":""}],"HARDY":[{"def":"Bold; brave; stout; daring; resolue; intrepid.","pos":""},{"def":"Confident; full of assurance; in a bad sense, morally hardened; shameless.","pos":""}]}