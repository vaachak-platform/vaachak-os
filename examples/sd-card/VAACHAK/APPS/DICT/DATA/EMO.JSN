{"EMODIN":[{"def":"An orange-red crystalline substance, C15H10O5, obtained from the buckthorn, rhubarb, etc.","pos":""}],"EMOLLESCENCE":[{"def":"That degree of softness in a body beginning to melt which alters its shape; the first or lowest degree of fusibility.","pos":""}],"EMOLLIATE":[{"def":"To soften; to render effeminate.","pos":""}],"EMOLLIENT":[{"def":"Softening; making supple; acting as an emollient.","pos":""}],"EMOLLITION":[{"def":"The act of softening or relaxing; relaxation.","pos":""}],"EMOLUMENT":[{"def":"The profit arising from office, employment, or labor; gain; compensation; advantage; perquisites, fees, or salary.","pos":""}],"EMOLUMENTAL":[{"def":"Pertaining to an emolument; profitable.","pos":""}],"EMOTION":[{"def":"A moving of the mind or soul; excitement of the feelings, whether pleasing or painful; disturbance or agitation of mind caused by a specific exciting cause and manifested by some sensible effect on the body.","pos":""}],"EMOTIONAL":[{"def":"Pertaining to, or characterized by, emotion; excitable; easily moved; sensational; as, an emotional nature.","pos":""}],"EMOTIONALISM":[{"def":"The cultivation of an emotional state of mind; tendency to regard things in an emotional manner.","pos":""}],"EMOTIONALIZE":[{"def":"To give an emotional character to.","pos":""}],"EMOTIONED":[{"def":"Affected with emotion.","pos":""}],"EMOTIVE":[{"def":"Attended by, or having the character of, emotion.","pos":""}],"EMOTIVENESS":[{"def":"Susceptibility to emotion.","pos":""}]}