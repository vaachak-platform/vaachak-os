{"DRY":[{"def":"Of certain morbid conditions, in which there is entire or comparative absence of moisture; as, dry gangrene; dry catarrh.","pos":""},{"def":"Exhibiting a sharp, frigid preciseness of execution, or the want of a delicate contour in form, and of easy transition in coloring.","pos":""}],"DRY GOODS":[{"def":"A commercial name for textile fabrics, cottons, woolens, linen, silks, laces, etc.","pos":""}],"DRY NURSE":[{"def":"A nurse who attends and feeds a child by hand; -- in distinction from a wet nurse, who suckles it.","pos":""}],"DRY-BEAT":[{"def":"To beat severely.","pos":""}],"DRY-BONED":[{"def":"Having dry bones, or bones without flesh.","pos":""}],"DRY-EYED":[{"def":"Not having tears in the eyes.","pos":""}],"DRY-RUB":[{"def":"To rub and cleanse without wetting.","pos":""}],"DRY-SHOD":[{"def":"Without wetting the feet.","pos":""}],"DRY-STONE":[{"def":"Constructed of uncemented stone.","pos":""}],"DRYAD":[{"def":"A wood nymph; a nymph whose life was bound up with that of her tree.","pos":""}],"DRYANDRA":[{"def":"A genus of shrubs growing in Australia, having beautiful, hard, dry, evergreen leaves.","pos":""}],"DRYFOOT":[{"def":"The scent of the game, as far as it can be traced.","pos":""}],"DRYING":[{"def":"Adapted or tending to exhaust moisture; as, a drying wind or day; a drying room.","pos":""},{"def":"Having the quality of rapidly becoming dry.","pos":""}],"DRYLY":[{"def":"In a dry manner; not succulently; without interest; without sympathy; coldly.","pos":""}],"DRYNESS":[{"def":"The state of being dry.","pos":""}],"DRYNURSE":[{"def":"To feed, attend, and bring up without the breast.","pos":""}],"DRYOBALANOPS":[{"def":"The genus to which belongs the single species D.","pos":""}],"DRYSALTER":[{"def":"A dealer in salted or dried meats, pickles, sauces, etc.","pos":""}],"DRYSALTERY":[{"def":"The articles kept by a drysalter; also, the business of a drysalter.","pos":""}]}