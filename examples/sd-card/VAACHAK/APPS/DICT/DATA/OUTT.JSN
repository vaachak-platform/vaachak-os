{"OUTTALK":[{"def":"To overpower by talking; to exceed in talking; to talk down.","pos":""}],"OUTTELL":[{"def":"To surpass in telling, counting, or reckoning.","pos":""}],"OUTTERM":[{"def":"An external or superficial thing; outward manner; superficial remark, etc.","pos":""}],"OUTTHROW":[{"def":"To excel in throwing, as in ball playing.","pos":""}],"OUTTOIL":[{"def":"To exceed in toiling.","pos":""}],"OUTTONGUE":[{"def":"To silence by talk, clamor, or noise.","pos":""}],"OUTTRAVEL":[{"def":"To exceed in speed o Mad.","pos":""}]}