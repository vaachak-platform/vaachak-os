{"MUFF":[{"def":"A short hollow cylinder surrounding an object, as a pipe.","pos":""},{"def":"A blown cylinder of glass which is afterward flattened out to make a sheet.","pos":""}],"MUFFETEE":[{"def":"A small muff worn over the wrist.","pos":""}],"MUFFIN":[{"def":"A light, spongy, cylindrical cake, used for breakfast and tea.","pos":""}],"MUFFINEER":[{"def":"A dish for keeping muffins hot.","pos":""}],"MUFFISH":[{"def":"Stupid; awkward.","pos":""}],"MUFFLE":[{"def":"The bare end of the nose between the nostrils; -- used esp.","pos":""}],"MUFFLER":[{"def":"A cushion for terminating or softening a note made by a stringed instrument with a keyboard.","pos":""}],"MUFTI":[{"def":"An official expounder of Mohammedan law.","pos":""}]}