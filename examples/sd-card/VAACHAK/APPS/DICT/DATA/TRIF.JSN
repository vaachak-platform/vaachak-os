{"TRIFALLOW":[{"def":"To plow the third time before sowing, as land.","pos":""}],"TRIFARIOUS":[{"def":"Facing three ways; arranged in three vertical ranks, as the leaves of veratrum.","pos":""}],"TRIFASCIATED":[{"def":"Having, or surrounded by, three fasciæ, or bands.","pos":""}],"TRIFID":[{"def":"Cleft to the middle, or slightly beyond the middle, into three parts; three-cleft.","pos":""}],"TRIFISTULARY":[{"def":"Having three pipes.","pos":""}],"TRIFLE":[{"def":"A thing of very little value or importance; a paltry, or trivial, affair.","pos":""},{"def":"A dish composed of sweetmeats, fruits, cake, wine, etc.","pos":""}],"TRIFLER":[{"def":"One who trifles.","pos":""}],"TRIFLING":[{"def":"Being of small value or importance; trivial; paltry; as, a trifling debt; a trifling affair.","pos":""},{"def":"Three-flowered; having or bearing three flowers; as, a triflorous peduncle.","pos":""}],"TRIFLUCTUATION":[{"def":"A concurrence of three waves.","pos":""},{"def":"Having three leaves or leaflets, as clover.","pos":""}],"TRIFOLIUM":[{"def":"A genus of leguminous herbs with densely spiked flowers and usually trifoliate leaves; trefoil.","pos":""}],"TRIFOLY":[{"def":"She was crowned with a chaplet of trifoly.","pos":""}],"TRIFORIUM":[{"def":"The gallery or open space between the vaulting and the roof of the aisles of a church, often forming a rich arcade in the interior of the church, above the nave arches and below the clearstory windows.","pos":""}],"TRIFORM":[{"def":"Having a triple form or character.","pos":""}],"TRIFORMITY":[{"def":"The state of being triform, or of having a threefold shape.","pos":""},{"def":"Having three branches or forks; trichotomous.","pos":""}]}