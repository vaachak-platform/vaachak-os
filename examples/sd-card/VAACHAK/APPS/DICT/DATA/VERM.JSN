{"VERMEIL":[{"def":"Vermilion; also, the color of vermilion, a bright, beautiful red.","pos":""},{"def":"Silver gilt or gilt bronze.","pos":""}],"VERMEOLOGIST":[{"def":"One who treats of vermes, or worms; a helminthologist.","pos":""}],"VERMEOLOGY":[{"def":"A discourse or treatise on worms; that part of zoölogy which treats of worms; helminthology.","pos":""}],"VERMETID":[{"def":"Any species of vermetus.","pos":""}],"VERMETUS":[{"def":"Any one of many species of marine gastropods belonging to Vermetus and allied genera, of the family Vermetidæ.","pos":""}],"VERMICELLI":[{"def":"The flour of a hard and small-grained wheat made into dough, and forced through small cylinders or pipes till it takes a slender, wormlike form, whence the Italian name.","pos":""}],"VERMICIDE":[{"def":"A medicine which destroys intestinal worms; a worm killer.","pos":""}],"VERMICIOUS":[{"def":"Of or pertaining to worms; wormy.","pos":""}],"VERMICULAR":[{"def":"Of or pertaining to a worm or worms; resembling a worm; shaped like a worm; especially, resembling the motion or track of a worm; as, the vermicular, or peristaltic, motion of the intestines.","pos":""}],"VERMICULATE":[{"def":"To form or work, as by inlaying, with irregular lines or impressions resembling the tracks of worms, or appearing as if formed by the motion of worms.","pos":""}],"VERMICULATED":[{"def":"Made or marked with irregular wavy lines or impressions; vermiculate.","pos":""}],"VERMICULATION":[{"def":"A very fine wavy crosswise color marking, or a patch of such markings, as on the feathers of birds.","pos":""}],"VERMICULE":[{"def":"A small worm or insect larva; also, a wormlike body.","pos":""}],"VERMICULITE":[{"def":"A group of minerals having, a micaceous structure.","pos":""},{"def":"Containing, or full of, worms; resembling worms.","pos":""}],"VERMIFORM":[{"def":"Resembling a worm in form or motions; vermicular; as, the vermiform process of the cerebellum.","pos":""}],"VERMIFORMIA":[{"def":"A tribe of worms including Phoronis.","pos":""}],"VERMIFUGAL":[{"def":"Tending to prevent, destroy, or expel, worms or vermin; anthelmintic.","pos":""}],"VERMIFUGE":[{"def":"A medicine or substance that expels worms from animal bodies; an anthelmintic.","pos":""}],"VERMILINGUIA":[{"def":"The tongue is long, slender, exsertile, and very flexible, whence the name.","pos":""}],"VERMILION":[{"def":"A bright red pigment consisting of mercuric sulphide, obtained either from the mineral cinnabar or artificially.","pos":""}],"VERMIN":[{"def":"An animal, in general.","pos":""},{"def":"A noxious or mischievous animal; especially, noxious little animals or insects, collectively, as squirrels, rats, mice, flies, lice, bugs, etc.","pos":""}],"VERMINATE":[{"def":"To breed vermin.","pos":""}],"VERMINATION":[{"def":"The generation or breeding of vermin.","pos":""},{"def":"A griping of the bowels.","pos":""}],"VERMINLY":[{"def":"Resembling vermin; in the manner of vermin.","pos":""}],"VERMINOUS":[{"def":"Tending to breed vermin; infested by vermin.","pos":""},{"def":"Caused by, or arising from the presence of, vermin; as, verminous disease.","pos":""}],"VERMINOUSLY":[{"def":"In a verminous manner.","pos":""}],"VERMIPAROUS":[{"def":"Producing or breeding worms.","pos":""}],"VERMIVOROUS":[{"def":"Devouring worms; feeding on worms; as, vermivorous birds.","pos":""}],"VERMUTH":[{"def":"A liqueur made of white wine, absinthe, and various aromatic drugs, used to excite the appetite.","pos":""}]}