{"UNEARED":[{"def":"Not eared, or plowed.","pos":""}],"UNEARNED":[{"def":"Not earned; not gained by labor or service.","pos":""}],"UNEARTH":[{"def":"To drive or draw from the earth; hence, to uncover; to bring out from concealment; to bring to light; to disclose; as, to unearth a secret.","pos":""}],"UNEARTHLY":[{"def":"Not terrestrial; supernatural; preternatural; hence, weird; appalling; terrific; as, an unearthly sight or sound.","pos":""}],"UNEASE":[{"def":"Want of ease; uneasiness.","pos":""}],"UNEASILY":[{"def":"In an uneasy manner.","pos":""}],"UNEASINESS":[{"def":"The quality or state of being uneasy; restlessness; disquietude; anxiety.","pos":""},{"def":"The quality of making uneasy; discomfort; as, the uneasiness of the road.","pos":""}],"UNEASY":[{"def":"Not easy; difficult.","pos":""},{"def":"Restless; disturbed by pain, anxiety, or the like; disquieted; perturbed.","pos":""}],"UNEATH":[{"def":"Not easy; difficult; hard.","pos":""}],"UNEDGE":[{"def":"To deprive of the edge; to blunt.","pos":""}],"UNELASTIC":[{"def":"Not elastic; inelastic.","pos":""}],"UNEMBARRASSED":[{"def":"Not embarrassed.","pos":""}],"UNEMBARRASSMENT":[{"def":"Freedom from embarrassment.","pos":""}],"UNEMBODIED":[{"def":"Free from a corporeal body; disembodied; as, unembodied spirits.","pos":""},{"def":"Not embodied; not collected into a body; not yet organized; as, unembodied militia.","pos":""}],"UNEMPIRICALLY":[{"def":"Not empirically; without experiment or experience.","pos":""}],"UNEMPLOYED":[{"def":"Nor employed in manual or other labor; having no regular work.","pos":""},{"def":"Not invested or used; as, unemployed capital.","pos":""}],"UNEMPLOYMENT":[{"def":"Quality or state of being not employed; -- used esp.","pos":""}],"UNENCUMBER":[{"def":"To free from incumbrance; to disencumber.","pos":""}],"UNENDLY":[{"def":"Unending; endless.","pos":""}],"UNEQUAL":[{"def":"Not having the two sides or the parts symmetrical.","pos":""}],"UNEQUALABLE":[{"def":"Not capable of being equaled or paralleled.","pos":""}],"UNEQUALED":[{"def":"Not equaled; unmatched; unparalleled; unrivaled; exceeding; surpassing; -- in a good or bad sense; as, unequaled excellence; unequaled ingratitude or baseness.","pos":""}],"UNEQUALLY":[{"def":"In an unequal manner.","pos":""}],"UNEQUALNESS":[{"def":"The quality or state of being unequal; inequality; unevenness.","pos":""}],"UNEQUITY":[{"def":"Want of equity or uprightness; injustice; wickedness; iniquity.","pos":""}],"UNEQUIVOCAL":[{"def":"Not equivocal; not doubtful; not ambiguous; evident; sincere; plain; as, unequivocal evidence; unequivocal words.","pos":""}],"UNERRING":[{"def":"Committing no mistake; incapable or error or failure certain; sure; unfailing; as, the unerring wisdom of God.","pos":""}],"UNERRINGLY":[{"def":"In an unerring manner.","pos":""}],"UNESSENTIAL":[{"def":"Not essential; not of prime importance; not indispensable; unimportant.","pos":""},{"def":"Void of essence, or real being.","pos":""}],"UNESSENTIALLY":[{"def":"In an unessential manner.","pos":""}],"UNESTABLISH":[{"def":"To disestablish.","pos":""},{"def":"With difficulty; scarcely.","pos":""}],"UNEVEN":[{"def":"Not even; not level; not uniform; rough; as, an uneven road or way; uneven ground.","pos":""},{"def":"Not equal; not of equal length.","pos":""}],"UNEXACT":[{"def":"Not exact; inexact.","pos":""}],"UNEXAMPLED":[{"def":"Having no example or similar case; being without precedent; unprecedented; unparalleled.","pos":""}],"UNEXCEPTIONABLE":[{"def":"Not liable to any exception or objection; unobjectionable; faultless; good; excellent; as, a man of most unexceptionable character.","pos":""}],"UNEXCEPTIVE":[{"def":"Not exceptive; not including, admitting, or being, an exception.","pos":""}],"UNEXPECTATION":[{"def":"Absence of expectation; want of foresight.","pos":""}],"UNEXPECTED":[{"def":"Not expected; coming without warning; sudden.","pos":""}],"UNEXPERIENCED":[{"def":"Not experienced; being without experience; inexperienced.","pos":""},{"def":"Untried; -- applied to things.","pos":""}],"UNEXPERT":[{"def":"Not expert; inexpert.","pos":""}],"UNEXPERTLY":[{"def":"In an unexpert manner.","pos":""}],"UNEXPRESSIVE":[{"def":"Not expressive; not having the power of utterance; inexpressive.","pos":""},{"def":"Incapable of being expressed; inexpressible; unutterable; ineffable.","pos":""}],"UNEXTINGUISHABLE":[{"def":"Inextinguishable.","pos":""}],"UNEXTRICABLE":[{"def":"Not extricable; inextricable.","pos":""}]}