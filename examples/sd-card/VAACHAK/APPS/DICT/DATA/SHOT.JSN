{"SHOT":[{"def":"Woven in such a way as to produce an effect of variegation, of changeable tints, or of being figured; as, shot silks.","pos":""}],"SHOT SAMPLES":[{"def":"Samples taken for assay from a molten metallic mass pouring a portion into water, to granulate it.","pos":""}],"SHOT-CLOG":[{"def":"A person tolerated only because he pays the shot, or reckoning, for the rest of the company, otherwise a mere clog on them.","pos":""}],"SHOT-FREE":[{"def":"Not to be injured by shot; shot-proof.","pos":""}],"SHOT-PROOF":[{"def":"Impenetrable by shot.","pos":""}],"SHOTE":[{"def":"A fish resembling the trout.","pos":""},{"def":"A young hog; a shoat.","pos":""}],"SHOTGUN":[{"def":"A light, smooth-bored gun, often double-barreled, especially designed for firing small shot at short range, and killing small game.","pos":""}],"SHOTS":[{"def":"The refuse of cattle taken from a drove.","pos":""}],"SHOTTED":[{"def":"Having a shot attached; as, a shotten suture.","pos":""}],"SHOTTEN":[{"def":"Having ejected the spawn; as, a shotten herring.","pos":""},{"def":"Shot out of its socket; dislocated, as a bone.","pos":""}]}