{"PRONAOS":[{"def":"The porch or vestibule of a temple.","pos":""}],"PRONATE":[{"def":"Somewhat prone; inclined; as, pronate trees.","pos":""}],"PRONATION":[{"def":"Opposed to supination.","pos":""}],"PRONATOR":[{"def":"A muscle which produces pronation.","pos":""}],"PRONE":[{"def":"Bending forward; inclined; not erect.","pos":""},{"def":"Prostrate; flat; esp.","pos":""}],"PRONELY":[{"def":"In a prone manner or position.","pos":""}],"PRONENESS":[{"def":"The quality or state of being prone, or of bending downward; as, the proneness of beasts is opposed to the erectness of man.","pos":""},{"def":"The state of lying with the face down; -- opposed to supineness.","pos":""}],"PRONEPHRIC":[{"def":"Of or pertaining to the pronephros.","pos":""},{"def":"The head kidney.","pos":""}],"PRONG":[{"def":"A sharp-pointed instrument.","pos":""},{"def":"The tine of a fork, or of a similar instrument; as, a fork of two or three prongs.","pos":""}],"PRONG-HOE":[{"def":"A hoe with prongs to break the earth.","pos":""}],"PRONGED":[{"def":"Having prongs or projections like the tines of a fork; as, a three-pronged fork.","pos":""}],"PRONGHORN":[{"def":"An American antelope (Antilocapra Americana), native of the plain near the Rocky Mountains.","pos":""}],"PRONITY":[{"def":"Proneness; propensity.","pos":""}],"PRONOMINAL":[{"def":"Belonging to, or partaking of the nature of, a pronoun.","pos":""}],"PRONOMINALIZE":[{"def":"To give the effect of a pronoun to; as, to pronominalize the substantives person, people, etc.","pos":""}],"PRONOMINALLY":[{"def":"Pro*nom\"i*nal*ly, adv.","pos":""}],"PRONONCE":[{"def":"Strongly marked; decided, as in manners, etc.","pos":""}],"PRONOTARY":[{"def":"See Prothonotary.","pos":""}],"PRONOTUM":[{"def":"The dorsal plate of the prothorax in insects.","pos":""}],"PRONOUN":[{"def":"A word used instead of a noun or name, to avoid the repetition of it.","pos":""}],"PRONOUNCE":[{"def":"To utter articulately; to speak out or distinctly; to utter, as words or syllables; to speak with the proper sound and accent as, adults rarely learn to pronounce a foreign language correctly.","pos":""},{"def":"To utter officially or solemnly; to deliver, as a decree or sentence; as, to pronounce sentence of death.","pos":""}],"PRONOUNCEABLE":[{"def":"Capable of being pronounced.","pos":""}],"PRONOUNCED":[{"def":"Strongly marked; unequivocal; decided.","pos":""}],"PRONOUNCEMENT":[{"def":"The act of pronouncing; a declaration; a formal announcement.","pos":""}],"PRONOUNCER":[{"def":"One who pronounces, utters, or declares; also, a pronouncing book.","pos":""}],"PRONOUNCING":[{"def":"Pertaining to, or indicating, pronunciation; as, a pronouncing dictionary.","pos":""}],"PRONUBIAL":[{"def":"Presiding over marriage.","pos":""}],"PRONUCLEUS":[{"def":"One of the two bodies or nuclei (called male and female pronuclei) which unite to form the first segmentation nucleus of an impregnated ovum.","pos":""}],"PRONUNCIAL":[{"def":"Of or pertaining to pronunciation; pronunciative.","pos":""}],"PRONUNCIAMENTO":[{"def":"A proclamation or manifesto; a formal announcement or declaration.","pos":""}],"PRONUNCIAMIENTO":[{"def":"See Pronunciamento.","pos":""}],"PRONUNCIATION":[{"def":"The art of manner of uttering a discourse publicly with propriety and gracefulness; -- now called delivery.","pos":""}],"PRONUNCIATIVE":[{"def":"Of or pertaining to pronunciation.","pos":""},{"def":"Uttering confidently; dogmatical.","pos":""}],"PRONUNCIATOR":[{"def":"One who pronounces; a pronouncer.","pos":""}],"PRONUNCIATORY":[{"def":"Of or pertaining to pronunciation; that pronounces.","pos":""}]}