{"TAC":[{"def":"A kind of customary payment by a tenant; -- a word used in old records.","pos":""},{"def":"Any tree yielding tacamahac resin, especially, in North America, the balsam poplar, or balm of Gilead (Populus balsamifera).","pos":""}],"TAC-AU-TAC":[{"def":"The parry which is connected with a riposte; also, a series of quick attacks and parries in which neither fencer gains a point.","pos":""}],"TACAUD":[{"def":"The bib, or whiting pout.","pos":""}],"TACE":[{"def":"The cross, or church, of St.","pos":""}],"TACET":[{"def":"It is silent; -- a direction for a vocal or instrumental part to be silent during a whole movement.","pos":"verb"}],"TACHE":[{"def":"Something used for taking hold or holding; a catch; a loop; a button.","pos":""}],"TACHHYDRITE":[{"def":"A hydrous chloride of calcium and magnesium occurring in yellowish masses which rapidly deliquesce upon exposure.","pos":""}],"TACHINA":[{"def":"Any one of numerous species of Diptera belonging to Tachina and allied genera.","pos":""}],"TACHISTOSCOPE":[{"def":"An apparatus for exposing briefly to view a screen bearing letters or figures.","pos":""}],"TACHOGRAPH":[{"def":"A recording or registering tachometer; also, its autographic record.","pos":""}],"TACHOMETER":[{"def":"An instrument for measuring the velocity, or indicating changes in the velocity, of a moving body or substance.","pos":""}],"TACHOMETRY":[{"def":"Measurement by a tachometer; the science or use of tachometers.","pos":""}],"TACHYDIDAXY":[{"def":"A short or rapid method of instructing.","pos":""}],"TACHYGLOSSA":[{"def":"A division of monotremes which comprises the spiny ant-eaters of Australia and New Guinea.","pos":""}],"TACHYGRAPH":[{"def":"An example of tachygraphy; esp.","pos":""}],"TACHYGRAPHER":[{"def":"One who writes shorthand; a stenographer; esp.","pos":""},{"def":"Of or pertaining to tachygraphy; written in shorthand.","pos":""}],"TACHYGRAPHY":[{"def":"The art or practice of rapid writing; shorthand writing; stenography.","pos":""}],"TACHYLYTE":[{"def":"A vitreous form of basalt; -- so called because decompposable by acids and readily fusible.","pos":""}],"TACHYMETER":[{"def":"A speed indicator; a tachometer.","pos":""}],"TACHYMETRY":[{"def":"The science or use of the tachymeter.","pos":""}],"TACHYSCOPE":[{"def":"An early form of antimated-picture machine, devised in 1889 by Otto Anschütz of Berlin, in which the chronophotographs were mounted upon the periphery of a rotating wheel.","pos":""}],"TACIT":[{"def":"Done or made in silence; implied, but not expressed; silent; as, tacit consent is consent by silence, or by not interposing an objection.","pos":""}],"TACITURN":[{"def":"Habitually silent; not given to converse; not apt to talk or speak.","pos":""}],"TACITURNITY":[{"def":"Habilual silence, or reserve in speaking.","pos":""}],"TACK":[{"def":"A peculiar flavor or taint; as, a musty tack.","pos":""}],"TACKET":[{"def":"A small, broad-headed nail.","pos":""}],"TACKING":[{"def":"A union of securities given at different times, all of which must be redeemed before an intermediate purchaser can interpose his claim.","pos":""}],"TACKLE":[{"def":"The rigging and apparatus of a ship; also, any purchase where more than one block is used.","pos":"verb"}],"TACKLED":[{"def":"Made of ropes tacked together.","pos":""}],"TACKLING":[{"def":"Furniture of the masts and yards of a vessel, as cordage, sails, etc.","pos":""},{"def":"Instruments of action; as, fishing tackling.","pos":""}],"TACKSMAN":[{"def":"One who holds a tack or lease from another; a tenant, or lessee.","pos":""}],"TACKY":[{"def":"Sticky; adhesive; raw; -- said of paint, varnish, etc.","pos":""}],"TACONIC":[{"def":"Designating, or pertaining to, the series of rocks forming the Taconic mountains in Western New England.","pos":""}],"TACT":[{"def":"The stroke in beating time.","pos":""}],"TACTABLE":[{"def":"Capable of being touched; tangible.","pos":""}],"TACTFUL":[{"def":"Full of tact; characterized by a discerning sense of what is right, proper, or judicious.","pos":""},{"def":"Of or pertaining to the art of military and naval tactics.","pos":""}],"TACTICIAN":[{"def":"One versed in tactics; hence, a skillful maneuverer; an adroit manager.","pos":""}],"TACTICS":[{"def":"The science and art of disposing military and naval forces in order for battle, and performing military and naval evolutions.","pos":""},{"def":"Hence, any system or method of procedure.","pos":""}],"TACTILE":[{"def":"Of or pertaining to the organs, or the sense, of touch; perceiving, or perceptible, by the touch; capable of being touched; as, tactile corpuscles; tactile sensations.","pos":""}],"TACTILITY":[{"def":"The quality or state of being tactile; perceptibility by touch; tangibleness.","pos":""}],"TACTION":[{"def":"The act of touching; touch; contact; tangency.","pos":""}],"TACTLESS":[{"def":"Destitute of tact.","pos":""}],"TACTUAL":[{"def":"Of or pertaining to the sense, or the organs, of touch; derived from touch.","pos":""}]}