{"SUBTANGENT":[{"def":"The part of the axis contained between the ordinate and tangent drawn to the same point in a curve.","pos":""}],"SUBTARTAREAN":[{"def":"Being or living under Tartarus; infernal.","pos":""}],"SUBTECTACLE":[{"def":"A space under a roof; a tabernacle; a dwelling.","pos":""}],"SUBTEGULANEOUS":[{"def":"Under the roof or eaves; within doors.","pos":""}],"SUBTENANT":[{"def":"One who rents a tenement, or land, etc.","pos":""}],"SUBTEND":[{"def":"To extend under, or be opposed to; as, the line of a triangle which subtends the right angle; the chord subtends an arc.","pos":""}],"SUBTENSE":[{"def":"A line subtending, or stretching across; a chord; as, the subtense of an arc.","pos":""}],"SUBTERETE":[{"def":"Somewhat terete.","pos":""},{"def":"Running under or beneath.","pos":""}],"SUBTERFUGE":[{"def":"That to which one resorts for escape or concealment; an artifice employed to escape censure or the force of an argument, or to justify opinions or conduct; a shift; an evasion.","pos":""}],"SUBTERRANE":[{"def":"A cave or room under ground.","pos":""}],"SUBTERRANEAL":[{"def":"Being or lying under the surface of the earth; situated within the earth, or under ground; as, subterranean springs; a subterraneous passage.","pos":""}],"SUBTERRANITY":[{"def":"A place under ground; a subterrany.","pos":""}],"SUBTERRANY":[{"def":"A subterranean place.","pos":""}],"SUBTERRESTRIAL":[{"def":"Sub`ter*res\"tri*al, a.","pos":""}],"SUBTHALAMIC":[{"def":"Situated under the optic thalamus.","pos":""}],"SUBTILE":[{"def":"Thin; not dense or gross; rare; as, subtile air; subtile vapor; a subtile medium.","pos":""},{"def":"Delicately constituted or constructed; nice; fine; delicate; tenuous; finely woven.","pos":""}],"SUBTILIATE":[{"def":"To make thin or rare.","pos":""}],"SUBTILISM":[{"def":"The quality or state of being subtile; subtility; subtlety.","pos":""}],"SUBTILIZATION":[{"def":"The operation of making so volatile as to rise in steam or vapor.","pos":""}],"SUBTILIZE":[{"def":"To make thin or fine; to make less gross or coarse.","pos":""},{"def":"To refine; to spin into niceties; as, to subtilize arguments.","pos":""}],"SUBTILIZER":[{"def":"One who subtilizes.","pos":""}],"SUBTILTY":[{"def":"The quality or state of being subtile; thinness; fineness; as, the subtility of air or light.","pos":""},{"def":"Refinement; extreme acuteness; subtlety.","pos":""}],"SUBTLE":[{"def":"Sly in design; artful; cunning; insinuating; subtile; -- applied to persons; as, a subtle foe.","pos":""},{"def":"Cunningly devised; crafty; treacherous; as, a subtle stratagem.","pos":""}],"SUBTLENESS":[{"def":"The quality or state of being subtle; subtlety.","pos":""}],"SUBTLETY":[{"def":"The quality or state of being subtle, or sly; cunning; craftiness; artfulness.","pos":""},{"def":"Nice discernment with delicacy of mental action; nicety of discrimination.","pos":""}],"SUBTLY":[{"def":"In a subtle manner; slyly; artfully; cunningly.","pos":""}],"SUBTONIC":[{"def":"Applied to, or distinguishing, a speech element consisting of tone, or proper vocal sound, not pure as in the vowels, but dimmed and otherwise modified by some kind of obstruction in the oral or the nasal passage, and in some cases with a mixture of breath sound; -- a term introduced by Dr.","pos":""}],"SUBTRACT":[{"def":"To withdraw, or take away, as a part from the whole; to deduct; as, subtract 5 from 9, and the remainder is 4.","pos":""}],"SUBTRACTER":[{"def":"One who subtracts.","pos":""}],"SUBTRACTION":[{"def":"The taking of a lesser number or quantity from a greater of the same kind or denomination; an operation for finding the difference between two numbers or quantities.","pos":""},{"def":"The withdrawing or withholding from a person of some right to which he is entitled by law.","pos":""}],"SUBTRACTIVE":[{"def":"Having the negative sign, or sign minus.","pos":""}],"SUBTRAHEND":[{"def":"The sum or number to be subtracted, or taken from another.","pos":""}],"SUBTRANSLUCENT":[{"def":"Not perfectly translucent.","pos":""}],"SUBTRANSPARENT":[{"def":"Not perfectly transparent.","pos":""}],"SUBTREASURER":[{"def":"The public officer who has charge of a subtreasury.","pos":""}],"SUBTREASURY":[{"def":"A subordinate treasury, or place of deposit; as, the United States subtreasury at New York.","pos":""}],"SUBTRIANGULAR":[{"def":"Nearly, but not perfectly, triangular.","pos":""}],"SUBTRIBE":[{"def":"A division of a tribe; a group of genera of a little lower rank than a tribe.","pos":""}],"SUBTRIHEDRAL":[{"def":"Approaching the form of a three-sided pyramid; as, the subtrihedral crown of a tooth.","pos":""}],"SUBTRIPLE":[{"def":"Containing a third, or one part to three.","pos":""}],"SUBTRIPLICATE":[{"def":"Expressed by the cube root; -- said especially of ratios.","pos":""}],"SUBTROPICAL":[{"def":"Nearly tropical.","pos":""}],"SUBTRUDE":[{"def":"To place under; to insert.","pos":""}],"SUBTURRICULATE":[{"def":"Somewhat turriculate.","pos":""}],"SUBTYPICAL":[{"def":"Deviating somewhat from the type of a species, genus, or other group; slightly aberrant.","pos":""},{"def":"Very narrow, and tapering gradually to a fine point from a broadish base; awl-shaped; linear.","pos":""}]}