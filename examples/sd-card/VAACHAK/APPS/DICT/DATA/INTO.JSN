{"INTO":[{"def":"To the inside of; within.","pos":""}],"INTOLERABILITY":[{"def":"The quality of being intolerable; intolerableness.","pos":""}],"INTOLERABLE":[{"def":"Not tolerable; not capable of being borne or endured; not proper or right to be allowed; insufferable; insupportable; unbearable; as, intolerable pain; intolerable heat or cold; an intolerable burden.","pos":""}],"INTOLERANCE":[{"def":"Want of capacity to endure; as, intolerance of light.","pos":""},{"def":"The quality of being intolerant; refusal to allow to others the enjoyment of their opinions, chosen modes of worship, and the like; want of patience and forbearance; illiberality; bigotry; as, intolerance shown toward a religious sect.","pos":""}],"INTOLERANT":[{"def":"Not enduring; not able to endure.","pos":""},{"def":"Not tolerating difference of opinion or sentiment, especially in religious matters; refusing to allow others the enjoyment of their opinions, rights, or worship; unjustly impatient of the opinion of those disagree with us; not tolerant; unforbearing; bigoted.","pos":""}],"INTOLERANTLY":[{"def":"In an intolerant manner.","pos":""}],"INTOLERATION":[{"def":"Intolerance; want of toleration; refusal to tolerate a difference of opinion.","pos":""}],"INTOMB":[{"def":"To place in a tomb; to bury; to entomb.","pos":""}],"INTONATE":[{"def":"To sound the tones of the musical scale; to practice the sol- fa.","pos":""}],"INTONATION":[{"def":"A thundering; thunder.","pos":""}],"INTONE":[{"def":"To utter with a musical or prolonged note or tone; to chant; as, to intone the church service.","pos":""}],"INTORSION":[{"def":"The bending or twining of any part of a plant toward one side or the other, or in any direction from the vertical.","pos":""}],"INTORT":[{"def":"To twist in and out; to twine; to wreathe; to wind; to wring.","pos":""}],"INTOXICANT":[{"def":"That which intoxicates; an intoxicating agent; as, alcohol, opium, and laughing gas are intoxicants.","pos":""}],"INTOXICATE":[{"def":"Overexcited, as with joy or grief.","pos":""}],"INTOXICATEDNESS":[{"def":"The state of being intoxicated; intoxication; drunkenness.","pos":""}],"INTOXICATING":[{"def":"Producing intoxication; as, intoxicating liquors.","pos":""}],"INTOXICATION":[{"def":"A poisoning, as by a spirituous or a narcotic substance.","pos":""}]}