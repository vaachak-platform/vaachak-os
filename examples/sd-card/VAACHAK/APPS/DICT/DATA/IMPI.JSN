{"IMPI":[{"def":"A body of Kaffir warriors; a body of native armed men.","pos":""}],"IMPICTURED":[{"def":"Pictured; impressed.","pos":""}],"IMPIERCE":[{"def":"To pierce; to penetrate.","pos":""}],"IMPIERCEABLE":[{"def":"Not capable of being pierced; impenetrable.","pos":""}],"IMPIETY":[{"def":"The quality of being impious; want of piety; irreverence toward the Supreme Being; ungodliness; wickedness.","pos":""},{"def":"An impious act; an act of wickednes.","pos":""}],"IMPIGNORATE":[{"def":"To pledge or pawn.","pos":""}],"IMPIGNORATION":[{"def":"The act of pawning or pledging; the state of being pawned.","pos":""}],"IMPING":[{"def":"The process of repairing broken feathers or a deficient wing.","pos":""}],"IMPINGE":[{"def":"To fall or dash against; to touch upon; to strike; to hit; to ciash with; -- with on or upon.","pos":""}],"IMPINGEMENT":[{"def":"The act of impinging.","pos":""}],"IMPINGENT":[{"def":"Striking against or upon.","pos":""}],"IMPINGUATE":[{"def":"To fatten; to make fat.","pos":""}],"IMPINGUATION":[{"def":"The act of making fat, or the state of being fat or fattened.","pos":""}],"IMPIOUS":[{"def":"Not pious; wanting piety; irreligious; irreverent; ungodly; profane; wanting in reverence for the Supreme Being; as, an impious deed; impious language.","pos":""}],"IMPISH":[{"def":"Having the qualities, or showing the characteristics, of an imp.","pos":""}],"IMPISHLY":[{"def":"In the manner of an imp.","pos":""}],"IMPITEOUS":[{"def":"Pitiless; cruel.","pos":""}]}