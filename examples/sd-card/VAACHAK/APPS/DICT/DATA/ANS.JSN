{"ANSA":[{"def":"A name given to either of the projecting ends of Saturn's ring.","pos":""}],"ANSATED":[{"def":"Having a handle.","pos":""}],"ANSERATED":[{"def":"Having the extremities terminate in the heads of eagles, lions, etc.","pos":""}],"ANSERES":[{"def":"A Linnæan order of aquatic birds swimming by means of webbed feet, as the duck, or of lobed feet, as the grebe.","pos":""}],"ANSERIFORMES":[{"def":"A division of birds including the geese, ducks, and closely allied forms.","pos":""}],"ANSERINE":[{"def":"Pertaining to the Anseres.","pos":""}],"ANSEROUS":[{"def":"Resembling a goose; silly; simple.","pos":""}],"ANSWER":[{"def":"To speak in defense against; to reply to in defense; as, to answer a charge; to answer an accusation.","pos":""},{"def":"To speak or write in return to, as in return to a call or question, or to a speech, declaration, argument, or the like; to reply to (a question, remark, etc.","pos":""}],"ANSWERABLE":[{"def":"Obliged to answer; liable to be called to account; liable to pay, indemnify, or make good; accountable; amenable; responsible; as, an agent is answerable to his principal; to be answerable for a debt, or for damages.","pos":""},{"def":"Capable of being answered or refuted; admitting a satisfactory answer.","pos":""}],"ANSWERABLENESS":[{"def":"The quality of being answerable, liable, responsible, or correspondent.","pos":""}],"ANSWERABLY":[{"def":"In an answerable manner; in due proportion or correspondence; suitably.","pos":""}],"ANSWERER":[{"def":"One who answers.","pos":""}],"ANSWERLESS":[{"def":"Having no answer, or impossible to be answered.","pos":""}]}