{"HIDAGE":[{"def":"A tax formerly paid to the kings of England for every hide of land.","pos":""}],"HIDALGO":[{"def":"A title, denoting a Spanish nobleman of the lower class.","pos":""}],"HIDDEN":[{"def":"Bring to light the hidden things of darkness.","pos":""}],"HIDDENITE":[{"def":"An emerald-green variety of spodumene found in North Carolina; lithia emerald, -- used as a gem.","pos":""}],"HIDDENLY":[{"def":"In a hidden manner.","pos":""}],"HIDE":[{"def":"To conceal, or withdraw from sight; to put out of view; to secrete.","pos":""},{"def":"To withhold from knowledge; to keep secret; to refrain from avowing or confessing.","pos":""}],"HIDEBOUND":[{"def":"Having the bark so close and constricting that it impedes the growth; -- said of trees.","pos":""}],"HIDEOUS":[{"def":"Frightful, shocking, or offensive to the eyes; dreadful to behold; as, a hideous monster; hideous looks.","pos":""},{"def":"Distressing or offensive to the ear; exciting terror or dismay; as, a hideous noise.","pos":""}],"HIDER":[{"def":"One who hides or conceals.","pos":""}],"HIDING":[{"def":"The act of hiding or concealing, or of withholding from view or knowledge; concealment.","pos":""}],"HIDROSIS":[{"def":"Excretion of sweat; perspiration.","pos":""}],"HIDROTIC":[{"def":"Causing perspiration; diaphoretic or sudorific.","pos":""}]}