{"OUT":[{"def":"In its original and strict sense, out means from the interior of something; beyond the limits or boundary of somethings; in a position or relation which is exterior to something; -- opposed to in or into.","pos":""}],"OUT-HEROD":[{"def":"To surpass (Herod) in violence or wickedness; to exceed in any vicious or offensive particular.","pos":""}],"OUT-OF-DOOR":[{"def":"Being out of the house; being, or done, in the open air; outdoor; as, out-of-door exercise.","pos":""}],"OUT-OF-THE-WAY":[{"def":"See under Out, adv.","pos":""}],"OUT-PATIENT":[{"def":"A patient who is outside a hospital, but receives medical aid from it.","pos":""}]}