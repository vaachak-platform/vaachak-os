{"ANT":[{"def":"A hymenopterous insect of the Linnæan genus Formica, which is now made a family of several genera; an emmet; a pismire.","pos":""}],"ANT BIRD":[{"def":"See Ant bird, under Ant, n.","pos":""}],"ANT COW":[{"def":"Any aphid from which ants obtain honeydew.","pos":""}],"ANT EGG":[{"def":"One of the small white egg-shaped pupæ or cocoons of the ant, often seen in or about ant-hills, and popularly supposed to be eggs.","pos":""}],"ANT-":[{"def":"See Anti-, prefix.","pos":""},{"def":"A suffix sometimes marking the agent for action; as, merchant, covenant, servant, pleasant, etc.","pos":""}],"ANT-BEAR":[{"def":"An edentate animal of tropical America (the Tamanoir), living on ants.","pos":""}],"ANT-CATTLE":[{"def":"Various kinds of plant lice or aphids tended by ants for the sake of the honeydew which they secrete.","pos":""}],"ANT-EATER":[{"def":"One of several species of edentates and monotremes that feed upon ants.","pos":""}],"ANT-HILL":[{"def":"A mound thrown up by ants or by termites in forming their nests.","pos":""}],"ANT-LION":[{"def":"A neuropterous insect, the larva of which makes in the sand a pitfall to capture ants, etc.","pos":""},{"def":"Those who live under the same meridian, but on opposite parallels of latitude, north and south of the equator.","pos":""}]}