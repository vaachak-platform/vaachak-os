{"ENMANCHE":[{"def":"Resembling, or covered with, a sleeve; -- said of the chief when lines are drawn from the middle point of the upper edge upper edge to the sides.","pos":""}],"ENMARBLE":[{"def":"To make hard as marble; to harden.","pos":""}],"ENMESH":[{"def":"To catch or entangle in, or as in, meshes.","pos":""}],"ENMIST":[{"def":"To infold, as in a mist.","pos":""}],"ENMITY":[{"def":"The quality of being an enemy; hostile or unfriendly disposition.","pos":""},{"def":"A state of opposition; hostility.","pos":""}],"ENMOSSED":[{"def":"Covered with moss; mossed.","pos":""}]}