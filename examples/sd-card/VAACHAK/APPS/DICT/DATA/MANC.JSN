{"MANCHET":[{"def":"Fine white bread; a loaf of fine bread.","pos":""}],"MANCHINEEL":[{"def":"A euphorbiaceous tree (Hippomane Mancinella) of tropical America, having a poisonous and blistering milky juice, and poisonous acrid fruit somewhat resembling an apple.","pos":""}],"MANCHU":[{"def":"Of or pertaining to Manchuria or its inhabitants.","pos":""},{"def":"A native or inhabitant of Manchuria; also, the language spoken by the Manchus.","pos":""}],"MANCIPATE":[{"def":"To enslave; to bind; to restrict.","pos":""}],"MANCIPATION":[{"def":"Slavery; involuntary servitude.","pos":""}],"MANCIPLE":[{"def":"A steward; a purveyor, particularly of a college or Inn of Court.","pos":""}],"MANCONA BARK":[{"def":"Man*co\"na bark` Defn: .","pos":""}],"MANCUS":[{"def":"An old Anglo Saxon coin both of gold and silver, and of variously estimated values.","pos":""},{"def":"A combining form denoting divination; as, aleuromancy, chiromancy, necromancy, etc.","pos":""}]}