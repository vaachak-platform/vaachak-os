{"PERUKE":[{"def":"A wig; a periwig.","pos":""}],"PERULA":[{"def":"One of the scales of a leaf bud.","pos":""},{"def":"A pouchlike portion of the perianth in certain orchides.","pos":""}],"PERUSAL":[{"def":"The act of carefully viewing or examining.","pos":""},{"def":"The act of reading, especially of reading through or with care.","pos":""}],"PERUSE":[{"def":"To observe; to examine with care.","pos":""},{"def":"To read through; to read carefully.","pos":""}],"PERUSER":[{"def":"One who peruses.","pos":""}],"PERUVIAN":[{"def":"Of or pertaining to Peru, in South America.","pos":""},{"def":"A native or an inhabitant of Peru.","pos":""}]}