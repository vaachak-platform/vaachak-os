{"SOLD":[{"def":"Solary; military pay.","pos":""}],"SOLDANEL":[{"def":"A plant of the genus Soldanella, low Alpine herbs of the Primrose family.","pos":""}],"SOLDANRIE":[{"def":"The country ruled by a soldan, or sultan.","pos":""}],"SOLDER":[{"def":"A metal or metallic alloy used when melted for uniting adjacent metallic edges or surfaces; a metallic coment.","pos":""}],"SOLDERER":[{"def":"One who solders.","pos":""}],"SOLDIER":[{"def":"The red or cuckoo gurnard (Trigla pini.","pos":""},{"def":"One of the asexual polymorphic forms of white ants, or termites, in which the head and jaws are very large and strong.","pos":""}],"SOLDIERESS":[{"def":"A female soldier.","pos":""}],"SOLDIERING":[{"def":"The act of serving as a soldier; the state of being a soldier; the occupation of a soldier.","pos":""},{"def":"The act of feigning to work.","pos":""}],"SOLDIERLIKE":[{"def":"Like a soldier; soldierly.","pos":""}],"SOLDIERLY":[{"def":"Like or becoming a real soldier; brave; martial; heroic; honorable; soldierlike.","pos":""}],"SOLDIERSHIP":[{"def":"Military qualities or state; martial skill; behavior becoming a soldier.","pos":""}],"SOLDIERWOOD":[{"def":"A showy leguminous plant (Calliandra purpurea) of the West Indies.","pos":""}],"SOLDIERY":[{"def":"A body of soldiers; soldiers, collectivelly; the military.","pos":""},{"def":"Military service.","pos":""}],"SOLDO":[{"def":"A small Italian coin worth a sou or a cent; the twentieth part of a lira.","pos":""}]}