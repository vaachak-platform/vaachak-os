{"OSCAN":[{"def":"Of or pertaining to the Osci, a primitive people of Campania, a province of ancient Italy.","pos":""},{"def":"The language of the Osci.","pos":""}],"OSCILLANCY":[{"def":"The state of oscillating; a seesaw kind of motion.","pos":""}],"OSCILLARIA":[{"def":"A genus of dark green, or purplish black, filamentous, fresh- water algæ, the threads of which have an automatic swaying or crawling motion.","pos":""}],"OSCILLATE":[{"def":"To move backward and forward; to vibrate like a pendulum; to swing; to sway.","pos":""},{"def":"To vary or fluctuate between fixed limits; to act or move in a fickle or fluctuating manner; to change repeatedly, back and forth.","pos":""}],"OSCILLATING":[{"def":"That oscillates; vibrating; swinging.","pos":""}],"OSCILLATING CURRENT":[{"def":"A current alternating in direction.","pos":""}],"OSCILLATION":[{"def":"The act of oscillating; a swinging or moving backward and forward, like a pendulum; vibration.","pos":""},{"def":"Fluctuation; variation; change back and forth.","pos":""}],"OSCILLATIVE":[{"def":"Tending to oscillate; vibratory.","pos":""}],"OSCILLATOR":[{"def":"Any device for producing electric oscillations; esp.","pos":""}],"OSCILLATORIA":[{"def":"Same as Oscillaria.","pos":""}],"OSCILLATORY":[{"def":"Moving, or characterized by motion, backward and forward like a pendulum; swinging; oscillating; vibratory; as, oscillatory motion.","pos":""}],"OSCILLOGRAM":[{"def":"An autographic record made by an oscillograph.","pos":""}],"OSCILLOGRAPH":[{"def":"An apparatus for recording or indicating alternating-current wave forms or other electrical oscillations, usually consisting of a galvanometer with strong field, in which the mass of the moving part is very small and frequency of vibration very high.","pos":""}],"OSCILLOMETER":[{"def":"An instrument for measuring the angle through which a ship rolls or pitches at sea.","pos":""}],"OSCILLOSCOPE":[{"def":"An instrument for showing visually the changes in a varying current; an oscillograph.","pos":""}],"OSCINE":[{"def":"Relating to the Oscines.","pos":""}],"OSCINES":[{"def":"Singing birds; a group of the Passeres, having numerous syringeal muscles, conferring musical ability.","pos":""}],"OSCINIAN":[{"def":"One of the Oscines, or singing birds.","pos":""}],"OSCININE":[{"def":"Of or pertaining to the Oscines.","pos":""}],"OSCITANCY":[{"def":"The act of gaping or yawning.","pos":""},{"def":"Drowsiness; dullness; sluggishness.","pos":""}],"OSCITANT":[{"def":"Yawning; gaping.","pos":""},{"def":"Sleepy; drowsy; dull; sluggish; careless.","pos":""}],"OSCITANTLY":[{"def":"In an oscitant manner.","pos":""}],"OSCITATE":[{"def":"To gape; to yawn.","pos":""}],"OSCITATION":[{"def":"The act of yawning or gaping.","pos":""}],"OSCULANT":[{"def":"Adhering closely; embracing; -- applied to certain creeping animals, as caterpillars.","pos":""},{"def":"Intermediate in character, or on the border, between two genera, groups, families, etc.","pos":""}],"OSCULATE":[{"def":"To touch closely, so as to have a common curvature at the point of contact.","pos":""}],"OSCULATION":[{"def":"The contact of one curve with another, when the number of consecutive points of the latter through which the former passes suffices for the complete determination of the former curve.","pos":""}],"OSCULATORY":[{"def":"Pertaining to, or having the properties of, an osculatrix; capable of osculation; as, a circle may be osculatory with a curve, at a given point.","pos":""}],"OSCULATRIX":[{"def":"A curve whose contact with a given curve, at a given point, is of a higher order (or involves the equality of a greater number of successive differential coefficients of the ordinates of the curves taken at that point) than that of any other curve of the same kind.","pos":""}],"OSCULE":[{"def":"One of the excurrent apertures of sponges.","pos":""}],"OSCULUM":[{"def":"A suffix indicating that the substance to the name of wich it is affixed is a member of the carbohydrate group; as in cellulose, sucrose, dextrose, etc.","pos":""}]}