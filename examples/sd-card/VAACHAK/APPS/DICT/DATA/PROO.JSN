{"PROOF":[{"def":"A trial impression, as from type, taken for correction or examination; -- called also proof sheet.","pos":""},{"def":"A process for testing the accuracy of an operation performed.","pos":""}],"PROOF-ARM":[{"def":"To arm with proof armor; to arm securely; as, to proof-arm herself.","pos":""}],"PROOF-PROOF":[{"def":"Proof against proofs; obstinate in the wrong.","pos":""},{"def":"The anterior prolongation of the guard of the phragmocone of belemnites and allied fossil cephalopods, whether horny or calcareous.","pos":""}],"PROOFLESS":[{"def":"Wanting sufficient evidence to induce belief; not proved.","pos":""}]}