{"SEQUACIOUS":[{"def":"Inclined to follow a leader; following; attendant.","pos":""},{"def":"Hence, ductile; malleable; pliant; manageable.","pos":""}],"SEQUACIOUSNESS":[{"def":"Quality of being sequacious.","pos":""}],"SEQUACITY":[{"def":"Quality or state of being sequacious; sequaciousness.","pos":""}],"SEQUEL":[{"def":"That which follows; a succeeding part; continuation; as, the sequel of a man's advantures or history.","pos":""},{"def":"Consequence; event; effect; result; as, let the sun cease, fail, or swerve, and the sequel would be ruin.","pos":""}],"SEQUELA":[{"def":"One who, or that which, follows.","pos":""},{"def":"A morbid phenomenon left as the result of a disease; a disease resulting from another.","pos":""}],"SEQUENCE":[{"def":"Simple succession, or the coming after in time, without asserting or implying causative energy; as, the reactions of chemical agents may be conceived as merely invariable sequences.","pos":""},{"def":"A hymn introduced in the Mass on certain festival days, and recited or sung immediately before the gospel, and after the gradual or introit, whence the name.","pos":""}],"SEQUENT":[{"def":"Following; succeeding; in continuance.","pos":""},{"def":"Following as an effect; consequent.","pos":""}],"SEQUENTIAL":[{"def":"Succeeding or following in order.","pos":""}],"SEQUESTER":[{"def":"To cause (one) to submit to the process of sequestration; to deprive (one) of one's estate, property, etc.","pos":""},{"def":"To set apart; to put aside; to remove; to separate from other things.","pos":""}],"SEQUESTERED":[{"def":"Retired; secluded.","pos":""}],"SEQUESTRABLE":[{"def":"Capable of being sequestered; subject or liable to sequestration.","pos":""}],"SEQUESTRAL":[{"def":"Of or pertaining to a sequestrum.","pos":""}],"SEQUESTRATION":[{"def":"The state of being separated or set aside; separation; retirement; seclusion from society.","pos":""},{"def":"Disunion; disjunction.","pos":""}],"SEQUESTRUM":[{"def":"A portion of dead bone which becomes separated from the sound portion, as in necrosis.","pos":""}],"SEQUIN":[{"def":"An old gold coin of Italy and Turkey.","pos":""}],"SEQUOIA":[{"def":"A genus of coniferous trees, consisting of two species, Sequoia Washingtoniana, syn.","pos":""}],"SEQUOIENE":[{"def":"A hydrocarbon (C13H10) obtained in white fluorescent crystals, in the distillation products of the needles of the California \"big tree\" (Sequoia gigantea).","pos":""}]}