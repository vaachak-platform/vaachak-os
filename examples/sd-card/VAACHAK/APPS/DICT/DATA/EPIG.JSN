{"EPIGAEA":[{"def":"An American genus of plants, containing but a single species (E.","pos":""}],"EPIGAEOUS":[{"def":"Growing on, or close to, the ground.","pos":""}],"EPIGASTRIC":[{"def":"Pertaining to the epigastrium, or to the epigastric region.","pos":""},{"def":"Over the stomach; -- applied to two of the areas of the carapace of crabs.","pos":""}],"EPIGASTRIUM":[{"def":"The upper part of the abdomen.","pos":""}],"EPIGENE":[{"def":"Foreign; unnatural; unusual; -- said of forms of crystals not natural to the substances in which they are found.","pos":""},{"def":"Formed originating on the surface of the earth; -- opposed to hypogene; as, epigene rocks.","pos":""}],"EPIGENESIS":[{"def":"The theory of generation which holds that the germ is created entirely new, not merely expanded, by the procreative power of the parents.","pos":""}],"EPIGENESIST":[{"def":"One who believes in, or advocates the theory of, epigenesis.","pos":""}],"EPIGENETIC":[{"def":"Of or pertaining to the epigenesis; produced according to the theory of epigenesis.","pos":""}],"EPIGEOUS":[{"def":"Same as Epigæous.","pos":""}],"EPIGLOTTIC":[{"def":"Pertaining to, or connected with, the epiglottis.","pos":""}],"EPIGLOTTIDEAN":[{"def":"Same as Epiglottic.","pos":""}],"EPIGLOTTIS":[{"def":"A cartilaginous lidlike appendage which closes the glottis while food or drink is passing while food or drink is passing through the pharynx.","pos":""}],"EPIGNATHOUS":[{"def":"Hook-billed; having the upper mandible longer than the lower.","pos":""}],"EPIGRAM":[{"def":"A short poem treating concisely and pointedly of a single thought or event.","pos":""},{"def":"An effusion of wit; a bright thought tersely and sharply expressed, whether in verse or prose.","pos":""}],"EPIGRAMMATICALLY":[{"def":"In the way of epigram; in an epigrammatic style.","pos":""}],"EPIGRAMMATIST":[{"def":"One who composes epigrams, or makes use of them.","pos":""}],"EPIGRAMMATIZE":[{"def":"To represent by epigrams; to express by epigrams.","pos":""}],"EPIGRAMMATIZER":[{"def":"One who writes in an affectedly pointed style.","pos":""}],"EPIGRAMMIST":[{"def":"An epigrammatist.","pos":""}],"EPIGRAPH":[{"def":"A citation from some author, or a sentence framed for the purpose, placed at the beginning of a work or of its separate divisions; a motto.","pos":""},{"def":"Of or pertaining to epigraphs or to epigraphy; as, an epigraphic style; epigraphical works or studies.","pos":""}],"EPIGRAPHICS":[{"def":"The science or study of epigraphs.","pos":""}],"EPIGRAPHIST":[{"def":"A student of, or one versed in, epigraphy.","pos":""}],"EPIGRAPHY":[{"def":"The science of inscriptions; the art of engraving inscriptions or of deciphering them.","pos":""}],"EPIGYNOUS":[{"def":"Adnate to the surface of the ovary, so as to be apparently inserted upon the top of it; -- said of stamens, petals, sepals, and also of the disk.","pos":""}]}