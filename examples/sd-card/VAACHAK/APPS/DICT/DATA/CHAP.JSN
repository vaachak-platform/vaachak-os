{"CHAP":[{"def":"To cause to open in slits or chinks; to split; to cause the skin of to crack or become rough.","pos":""},{"def":"To strike; to beat.","pos":""}],"CHAPARAJOS":[{"def":"Overalls of sheepskin or leather, usually open at the back, worn, esp.","pos":""}],"CHAPARERAS":[{"def":"Same as Chaparajos.","pos":""}],"CHAPARRAL":[{"def":"A thicket of low evergreen oaks.","pos":""},{"def":"An almost impenetrable thicket or succession of thickets of thorny shrubs and brambles.","pos":""}],"CHAPBOOK":[{"def":"Any small book carried about for sale by chapmen or hawkers.","pos":""}],"CHAPE":[{"def":"The piece by which an object is attached to something, as the frog of a scabbard or the metal loop at the back of a buckle by which it is fastened to a strap.","pos":""},{"def":"The transverse guard of a sword or dagger.","pos":""}],"CHAPEAU":[{"def":"A cap of maintenance.","pos":""}],"CHAPED":[{"def":"Furnished with a chape or chapes.","pos":""}],"CHAPEL":[{"def":"A subordinate place of worship; as, (a) a small church, often a private foundation, as for a memorial; (b) a small building attached to a church; (c) a room or recess in a church, containing an altar.","pos":""},{"def":"A place of worship not connected with a church; as, the chapel of a palace, hospital, or prison.","pos":""}],"CHAPELESS":[{"def":"Without a chape.","pos":""}],"CHAPELET":[{"def":"A pair of Straps, with stirrups, joined at the top and fastened to the pommel or the frame of the saddle, after they have been adjusted to the convenience of the rider.","pos":""},{"def":"A kind of chain pump, or dredging machine.","pos":""}],"CHAPELLANY":[{"def":"A chapel within the jurisdiction of a church; a subordinate ecclesiastical foundation.","pos":""}],"CHAPELRY":[{"def":"The territorial disrict legally assigned to a chapel.","pos":""}],"CHAPERON":[{"def":"A hood; especially, an ornamental or an official hood.","pos":""},{"def":"A divice placed on the foreheads of horses which draw the hearse in pompous funerals.","pos":""}],"CHAPERONAGE":[{"def":"Attendance of a chaperon on a lady in public; protection afforded by a chaperon.","pos":""}],"CHAPFALLEN":[{"def":"Having the lower chap or jaw drooping, -- an indication of humiliation and dejection; crestfallen; discouraged.","pos":""}],"CHAPITER":[{"def":"A summary in writing of such matters as are to be inquired of or presented before justices in eyre, or justices of assize, or of the peace, in their sessions; -- also called articles.","pos":""}],"CHAPLAIN":[{"def":"An ecclesiastic who has a chapel, or who performs religious service in a chapel.","pos":""},{"def":"A clergyman who is officially atteched to the army or navy, to some public institution, or to a family or court, for the purpose of performing divine service.","pos":""}],"CHAPLAINCY":[{"def":"The office, position, or station of a chaplain.","pos":""}],"CHAPLAINSHIP":[{"def":"The office or business of a chaplain.","pos":""},{"def":"The possession or revenue of a chapel.","pos":""}],"CHAPLESS":[{"def":"Having no lower jaw; hence, fleshless.","pos":""}],"CHAPLET":[{"def":"A small molding, carved into beads, pearls, olives, etc.","pos":""}],"CHAPMAN":[{"def":"One who buys and sells; a merchant; a buyer or a seller.","pos":""},{"def":"A peddler; a hawker.","pos":""}],"CHAPPY":[{"def":"Full of chaps; cleft; gaping; open.","pos":""}],"CHAPS":[{"def":"The jaws, or the fleshy parts about them.","pos":""}],"CHAPTER":[{"def":"A division of a book or treatise; as, Genesis has fifty chapters.","pos":""},{"def":"An organized branch of some society or fraternity as of the Freemasons.","pos":""}],"CHAPTREL":[{"def":"One of the several species of fishes of the genus Salvelinus, allied to the spotted trout and salmon, inhabiting deep lakes in mountainous regions in Europe.","pos":""}]}