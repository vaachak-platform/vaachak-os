{"HAG":[{"def":"An eel-like marine marsipobranch (Myxine glutinosa), allied to the lamprey.","pos":""},{"def":"The hagdon or shearwater.","pos":""}],"HAG-RIDDEN":[{"def":"Ridden by a hag or witch; hence, afflicted with nightmare.","pos":""}],"HAG-TAPER":[{"def":"The great woolly mullein (Verbascum Thapsus).","pos":""}],"HAGBERRY":[{"def":"A plant of the genus Prunus (P.","pos":""}],"HAGBORN":[{"def":"Born of a hag or witch.","pos":""}],"HAGBUT":[{"def":"A harquebus, of which the but was bent down or hooked for convenience in taking aim.","pos":""}],"HAGBUTTER":[{"def":"A soldier armed with a hagbut or arquebus.","pos":""}],"HAGDON":[{"def":"One of several species of sea birds of the genus Puffinus; esp.","pos":""}],"HAGGADA":[{"def":"A story, anecdote, or legend in the Talmud, to explain or illustrate the text of the Old Testament.","pos":""}],"HAGGARD":[{"def":"Having the expression of one wasted by want or suffering; hollow-eyed; having the features distorted or wasted, or anxious in appearance; as, haggard features, eyes.","pos":""}],"HAGGARDLY":[{"def":"In a haggard manner.","pos":""}],"HAGGED":[{"def":"Like a hag; lean; ugly.","pos":""}],"HAGGIS":[{"def":"A Scotch pudding made of the heart, liver, lights, etc.","pos":""}],"HAGGISH":[{"def":"Like a hag; ugly; wrinkled.","pos":""}],"HAGGISHLY":[{"def":"In the manner of a hag.","pos":""}],"HAGGLE":[{"def":"To cut roughly or hack; to cut into small pieces; to notch or cut in an unskillful manner; to make rough or mangle by cutting; as, a boy haggles a stick of wood.","pos":""}],"HAGGLER":[{"def":"One who haggles or is difficult in bargaining.","pos":""},{"def":"One who forestalls a market; a middleman between producer and dealer in London vegetable markets.","pos":""}],"HAGIARCHY":[{"def":"A sacred government; by holy orders of men.","pos":""}],"HAGIOCRACY":[{"def":"Government by a priesthood; hierarchy.","pos":""}],"HAGIOGRAPHA":[{"def":"The lives of the saints.","pos":""}],"HAGIOGRAPHAL":[{"def":", Pertaining to the hagiographa, or to sacred writings.","pos":""}],"HAGIOGRAPHER":[{"def":"One of the writers of the hagiographa; a writer of lives of the saints.","pos":""}],"HAGIOGRAPHY":[{"def":"Same Hagiographa.","pos":""}],"HAGIOLATRY":[{"def":"The invocation or worship of saints.","pos":""}],"HAGIOLOGIST":[{"def":"One who treats of the sacred writings; a writer of the lives of the saints; a hagiographer.","pos":""}],"HAGIOLOGY":[{"def":"The history or description of the sacred writings or of sacred persons; a narrative of the lives of the saints; a catalogue of saints.","pos":""}],"HAGIOSCOPE":[{"def":"An opening made in the interior walls of a cruciform church to afford a view of the altar to those in the transepts; -- called, in architecture, a squint.","pos":""}],"HAGSEED":[{"def":"The offspring of a hag.","pos":""}],"HAGSHIP":[{"def":"The state or title of a hag.","pos":""}],"HAGUE TRIBUNAL":[{"def":"The permanent court of arbitration created by the \"International Convention for the Pacific Settle of International Disputes.","pos":""}]}