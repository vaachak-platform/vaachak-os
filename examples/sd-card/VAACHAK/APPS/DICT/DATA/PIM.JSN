{"PIMARIC":[{"def":"Pertaining to, or designating, an acid found in galipot, and isomeric with abietic acid.","pos":""}],"PIMELITE":[{"def":"An apple-green mineral having a greasy feel.","pos":""}],"PIMENT":[{"def":"Wine flavored with spice or honey.","pos":""}],"PIMENTA":[{"def":"Same as Pimento.","pos":""}],"PIMENTO":[{"def":"Allspice; -- applied both to the tree and its fruit.","pos":""}],"PIMIENTO":[{"def":"The Spanish sweet pepper, the fruit of which is used as a vegetable, to stuff olives, etc.","pos":""}],"PIMOLA":[{"def":"An olive stuffed with a kind of sweet red pepper, or pimiento.","pos":""}],"PIMP":[{"def":"One who provides gratification for the lust of others; a procurer; a pander.","pos":""}],"PIMPERNEL":[{"def":"A plant of the genus Anagallis, of which one species (A.","pos":""}],"PIMPILLO":[{"def":"A West Indian name for the prickly pear (Opuntia); -- called also pimploes.","pos":""}],"PIMPINEL":[{"def":"The burnet saxifrage.","pos":""}],"PIMPING":[{"def":"Little; petty; pitiful.","pos":""}],"PIMPLE":[{"def":"Any small acuminated elevation of the cuticle, whether going on to suppuration or not.","pos":""}],"PIMPSHIP":[{"def":"The office, occupation, or persom of a pimp.","pos":""}]}