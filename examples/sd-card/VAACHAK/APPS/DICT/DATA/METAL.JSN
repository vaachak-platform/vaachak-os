{"METAL":[{"def":"An elementary substance, as sodium, calcium, or copper, whose oxide or hydroxide has basic rather than acid properties, as contrasted with the nonmetals, or metalloids.","pos":""},{"def":"The rails of a railroad.","pos":""}],"METALAMMONIUM":[{"def":"A hypothetical radical derived from ammonium by the substitution of metallic atoms in place of hydrogen.","pos":""}],"METALBUMIN":[{"def":"A form of albumin found in ascitic and certain serous fluids.","pos":""}],"METALDEHYDE":[{"def":"A white crystalline substance isomeric with, and obtained from, acetic aldehyde by polymerization, and reconvertible into the same.","pos":""}],"METALEPSIS":[{"def":"The continuation of a trope in one word through a succession of significations, or the union of two or more tropes of a different kind in one word.","pos":""}],"METALEPSY":[{"def":"Exchange; replacement; substitution; metathesis.","pos":""}],"METALEPTIC":[{"def":"Of, pertaining to, concerned in, or occurring by, metalepsy.","pos":""}],"METALLIC":[{"def":"Of, pertaining to, or characterized by, the essential and implied properties of a metal, as contrasted with a nonmetal or metalloid; basic; antacid; positive.","pos":""}],"METALLICLY":[{"def":"In a metallic manner; by metallic means.","pos":""}],"METALLIFACTURE":[{"def":"The production and working or manufacture of metals.","pos":""}],"METALLIFEROUS":[{"def":"Producing metals; yielding metals.","pos":""}],"METALLIFORM":[{"def":"Having the form or structure of a metal.","pos":""}],"METALLINE":[{"def":"A substance of variable composition, but resembling a soft, dark-colored metal, used in the bearings of machines for obviating friction, and as a substitute for lubricants.","pos":""}],"METALLIST":[{"def":"A worker in metals, or one skilled in metals.","pos":""}],"METALLIZATION":[{"def":"The act or process of metallizing.","pos":""}],"METALLIZE":[{"def":"To impart metallic properties to; to impregnate with a metal.","pos":""}],"METALLOCHROME":[{"def":"A coloring produced by the deposition of some metallic compound; specifically, the prismatic tints produced by depositing a film of peroxide of lead on polished steel by electricity.","pos":""}],"METALLOCHROMY":[{"def":"The art or process of coloring metals.","pos":""}],"METALLOGRAPH":[{"def":"A print made by metallography.","pos":""}],"METALLOGRAPHIC":[{"def":"Pertaining to, or by means of, metallography.","pos":""}],"METALLOGRAPHIST":[{"def":"One who writes on the subject of metals.","pos":""}],"METALLOGRAPHY":[{"def":"The science or art of metals and metal working; also, a treatise on metals.","pos":""},{"def":"A method of transferring impressions of the grain of wood to metallic surfaces by chemical action.","pos":""}],"METALLOID":[{"def":"Having the properties of a nonmetal; nonmetallic; acid; negative.","pos":""}],"METALLOTHERAPY":[{"def":"Treatment of disease by applying metallic plates to the surface of the body.","pos":""},{"def":"Of or pertaining to metallurgy.","pos":""}],"METALLURGIST":[{"def":"One who works in metals, or prepares them for use; one who is skilled in metallurgy.","pos":""}],"METALLURGY":[{"def":"The art of working metals, comprehending the whole process of separating them from other matters in the ore, smelting, refining, and parting them; sometimes, in a narrower sense, only the process of extracting metals from their ores.","pos":""}],"METALMAN":[{"def":"A worker in metals.","pos":""}],"METALOGICAL":[{"def":"Beyond the scope or province of logic.","pos":""}],"METALORGANIC":[{"def":"Pertaining to, or denoting, any one of a series of compounds of certain metallic elements with organic radicals; as, zinc methyl, sodium ethyl, etc.","pos":""}]}