{"SEMICALCAREOUS":[{"def":"Half or partially calcareous; as, a semicalcareous plant.","pos":""}],"SEMICALCINED":[{"def":"Half calcined; as, semicalcined iron.","pos":""}],"SEMICASTRATE":[{"def":"To deprive of one testicle.","pos":""}],"SEMICENTENNIAL":[{"def":"Of or pertaining to half of a century, or a period of fifty years; as, a semicentennial commemoration.","pos":""}],"SEMICHAOTIC":[{"def":"Partially chaotic.","pos":""}],"SEMICHORUS":[{"def":"A half chorus; a passage to be sung by a selected portion of the voices, as the female voices only, in contrast with the full choir.","pos":""}],"SEMICIRCLE":[{"def":"A body in the form of half of a circle, or half of a circumference.","pos":""},{"def":"An instrument for measuring angles.","pos":""}],"SEMICIRCULAR":[{"def":"Having the form of half of a circle.","pos":""}],"SEMICIRQUE":[{"def":"A semicircular hollow or opening among trees or hills.","pos":""}],"SEMICOLON":[{"def":"The punctuation mark [;] indicating a separation between parts or members of a sentence more distinct than that marked by a comma.","pos":""}],"SEMICOLUMN":[{"def":"A half column; a column bisected longitudinally, or along its axis.","pos":""}],"SEMICOLUMNAR":[{"def":"Like a semicolumn; flat on one side and round on the other; imperfectly columnar.","pos":""}],"SEMICOMPACT":[{"def":"Half compact; imperfectly indurated.","pos":""}],"SEMICONSCIOUS":[{"def":"Half conscious; imperfectly conscious.","pos":""}],"SEMICOPE":[{"def":"A short cope, or an inferier kind of cope.","pos":""}],"SEMICRYSTALLINE":[{"def":"Half crystalline; -- said of certain cruptive rocks composed partly of crystalline, partly of amorphous matter.","pos":""}],"SEMICUBICAL":[{"def":"Of or pertaining to the square root of the cube of a quantity.","pos":""},{"def":"A half bath, or one that covers only the lewer extremities and the hips; a sitz-bath; a half bath, or hip bath.","pos":""}]}