{"BAN":[{"def":"A calling together of the king's (esp.","pos":""},{"def":"Notice of a proposed marriage, proclaimed in church.","pos":""}],"BANAL":[{"def":"Commonplace; trivial; hackneyed; trite.","pos":""}],"BANALITY":[{"def":"Something commonplace, hackneyed, or trivial; the commonplace, in speech.","pos":""}],"BANANA":[{"def":"A perennial herbaceous plant of almost treelike size (Musa sapientum); also, its edible fruit.","pos":""}],"BANANA SOLUTION":[{"def":"A solution used as a vehicle in applying bronze pigments.","pos":""}],"BANAT":[{"def":"The territory governed by a ban.","pos":""},{"def":"A bench; a high seat, or seat of distinction or judgment; a tribunal or court.","pos":""}],"BANCAL":[{"def":"An ornamental covering, as of carpet or leather, for a bench or form.","pos":""}],"BANCO":[{"def":"A bank, especially that of Venice.","pos":""}],"BAND":[{"def":"Two strips of linen hanging from the neck in front as part of a clerical, legal, or academic dress.","pos":""},{"def":"A space between elevated lines or ribs, as of the fruits of umbelliferous plants.","pos":""}],"BAND FISH":[{"def":"A small red fish of the genus Cepola; the ribbon fish.","pos":""}],"BANDAGE":[{"def":"A fillet or strip of woven material, used in dressing and binding up wounds, etc.","pos":""},{"def":"Something resembling a bandage; that which is bound over or round something to cover, strengthen, or compress it; a ligature.","pos":""}],"BANDALA":[{"def":"A fabric made in Manilla from the older leaf sheaths of the abaca (Musa textilis).","pos":""}],"BANDBOX":[{"def":"A light box of pasteboard or thin wood, usually cylindrical, for holding ruffs (the bands of the 17th century), collars, caps, bonnets, etc.","pos":""}],"BANDEAU":[{"def":"A narrow band or fillet; a part of a head-dress.","pos":""},{"def":"A small band or fillet; any little band or flat molding, compassing a column, like a ring.","pos":""}],"BANDER":[{"def":"One banded with others.","pos":""}],"BANDERILLA":[{"def":"A barbed dart carrying a banderole which the banderillero thrusts into the neck or shoulder of the bull in a bullfight.","pos":""}],"BANDERILLERO":[{"def":"One who thrusts in the banderillas in bullfighting.","pos":""},{"def":"A little banner, flag, or streamer.","pos":""}],"BANDING PLANE":[{"def":"A plane used for cutting out grooves and inlaying strings and bands in straight and circular work.","pos":""}],"BANDIT":[{"def":"An outlaw; a brigand.","pos":""}],"BANDLE":[{"def":"An Irish measure of two feet in length.","pos":""}],"BANDLET":[{"def":"Same as Bandelet.","pos":""}],"BANDMASTER":[{"def":"The conductor of a musical band.","pos":""}],"BANDOG":[{"def":"A mastiff or other large and fierce dog, usually kept chained or tied up.","pos":""}],"BANDOLINE":[{"def":"A glutinous pomatum for the fair.","pos":""}],"BANDON":[{"def":"Disposal; control; license.","pos":""}],"BANDORE":[{"def":"A musical stringed instrument, similar in form to a guitar; a pandore.","pos":""}],"BANDROL":[{"def":"Same as Banderole.","pos":""}],"BANDY":[{"def":"A carriage or cart used in India, esp.","pos":""}],"BANDY-LEGGED":[{"def":"Having crooked legs.","pos":""}],"BANE":[{"def":"That which destroys life, esp.","pos":""},{"def":"Destruction; death.","pos":""}],"BANEBERRY":[{"def":"A genus (Actæa) of plants, of the order Ranunculaceæ, native in the north temperate zone.","pos":""}],"BANEFUL":[{"def":"Having poisonous qualities; deadly; destructive; injurious; noxious; pernicious.","pos":""}],"BANEWORT":[{"def":"Deadly nightshade.","pos":""}],"BANG":[{"def":"To beat, as with a club or cudgel; to treat with violence; to handle roughly.","pos":""},{"def":"To beat or thump, or to cause ( something) to hit or strike against another object, in such a way as to make a loud noise; as, to bang a drum or a piano; to bang a door (against the doorpost or casing) in shutting it.","pos":""}],"BANGING":[{"def":"Huge; great in size.","pos":""}],"BANGLE":[{"def":"To waste by little and little; to fritter away.","pos":""}],"BANIAN":[{"def":"A Hindoo trader, merchant, cashier, or money changer.","pos":""},{"def":"A man's loose gown, like that worn by the Banians.","pos":""}],"BANISH":[{"def":"To condemn to exile, or compel to leave one's country, by authority of the ruling power.","pos":""},{"def":"To drive out, as from a home or familiar place; -- used with from and out of.","pos":""}],"BANISHER":[{"def":"One who banishes.","pos":""}],"BANISHMENT":[{"def":"The act of banishing, or the state of being banished.","pos":""}],"BANISTER":[{"def":"A stringed musical instrument having a head and neck like the guitar, and its body like a tambourine.","pos":""}],"BANJO":[{"def":"A stringed musical instrument having a head and neck like the guitar, and its body like a tambourine.","pos":""}],"BANJORINE":[{"def":"A kind of banjo, with a short neck, tuned a fourth higher than the common banjo; -- popularly so called.","pos":""}],"BANK":[{"def":"A mound, pile, or ridge of earth, raised above the surrounding level; hence, anything shaped like a mound or ridge of earth; as, a bank of clouds; a bank of snow.","pos":""},{"def":"A steep acclivity, as the slope of a hill, or the side of a ravine.","pos":""}],"BANK BILL":[{"def":"In America (and formerly in England), a promissory note of a bank payable to the bearer on demand, and used as currency; a bank note.","pos":""},{"def":"In England, a note, or a bill of exchange, of a bank, payable to order, and usually at some future specified time.","pos":""}],"BANK BOOK":[{"def":"A book kept by a depositor, in which an officer of a bank enters the debits and credits of the depositor's account with the bank.","pos":""}],"BANK DISCOUNT":[{"def":"A sum equal to the interest at a given rate on the principal (face) of a bill or note from the time of discounting until it becomes due.","pos":""}],"BANK NOTE":[{"def":"A promissory note issued by a bank or banking company, payable to bearer on demand.","pos":""},{"def":"Formerly, a promissory note made by a banker, or banking company, payable to a specified person at a fixed date; a bank bill.","pos":""}],"BANK SWALLOW":[{"def":"See under 1st Bank, n.","pos":""}],"BANK-SIDED":[{"def":"Having sides inclining inwards, as a ship; -- opposed to wall- sided.","pos":""}],"BANKABLE":[{"def":"Receivable at a bank.","pos":""}],"BANKER":[{"def":"One who conducts the business of banking; one who, individually, or as a member of a company, keeps an establishment for the deposit or loan of money, or for traffic in money, bills of exchange, etc.","pos":"noun"},{"def":"A money changer.","pos":"noun"}],"BANKERESS":[{"def":"A female banker.","pos":""}],"BANKING":[{"def":"The business of a bank or of a banker.","pos":""}],"BANKRUPT":[{"def":"A trader who secretes himself, or does certain other acts tending to defraud his creditors.","pos":""},{"def":"A person who, in accordance with the terms of a law relating to bankruptcy, has been judicially declared to be unable to meet his liabilities.","pos":""}],"BANKRUPTCY":[{"def":"The state of being actually or legally bankrupt.","pos":""},{"def":"The act or process of becoming a bankrupt.","pos":""}],"BANKSIDE":[{"def":"The slope of a bank, especially of the bank of a steam.","pos":""}],"BANLIEUE":[{"def":"The territory without the walls, but within the legal limits, of a town or city.","pos":""}],"BANNER":[{"def":"A kind of flag attached to a spear or pike by a crosspiece, and used by a chief as his standard in battle.","pos":""},{"def":"A large piece of silk or other cloth, with a device or motto, extended on a crosspiece, and borne in a procession, or suspended in some conspicuous place.","pos":""}],"BANNERED":[{"def":"Decorated with a banner or banners \"bannered host.","pos":""}],"BANNERET":[{"def":"Originally, a knight who led his vassals into the field under his own banner; -- commonly used as a title of rank.","pos":"noun"},{"def":"A title of rank, conferred for heroic deeds, and hence, an order of knighthood; also, the person bearing such title or rank.","pos":"noun"}],"BANNEROL":[{"def":"A banderole; esp.","pos":""}],"BANNITION":[{"def":"The act of expulsion.","pos":""}],"BANNOCK":[{"def":"A kind of cake or bread, in shape flat and roundish, commonly made of oatmeal or barley meal and baked on an iron plate, or griddle; -- used in Scotland and the northern counties of England.","pos":""}],"BANNS":[{"def":"Notice of a proposed marriage, proclaimed in a church, or other place prescribed by law, in order that any person may object, if he knows of just cause why the marriage should not take place.","pos":""}],"BANQUET":[{"def":"A feast; a sumptuous entertainment of eating and drinking; often, a complimentary or ceremonious feast, followed by speeches.","pos":""},{"def":"A dessert; a course of sweetmeats; a sweetmeat or sweetmeats.","pos":""}],"BANQUETTE":[{"def":"A raised way or foot bank, running along the inside of a parapet, on which musketeers stand to fire upon the enemy.","pos":""},{"def":"A narrow window seat; a raised shelf at the back or the top of a buffet or dresser.","pos":""}],"BANSTICKLE":[{"def":"A small fish, the three-spined stickleback.","pos":""}],"BANTAM":[{"def":"A variety of small barnyard fowl, with feathered legs, probably brought from Bantam, a district of Java.","pos":""}],"BANTAM WORK":[{"def":"Carved and painted work in imitation of Japan ware.","pos":""}],"BANTENG":[{"def":"The wild ox of Java (Bibos Banteng).","pos":""}],"BANTER":[{"def":"To address playful good-natured ridicule to, -- the person addressed, or something pertaining to him, being the subject of the jesting; to rally; as, he bantered me about my credulity.","pos":""},{"def":"To jest about; to ridicule in speaking of, as some trait, habit, characteristic, and the like.","pos":""}],"BANTERER":[{"def":"One who banters or rallies.","pos":""}],"BANTINGISM":[{"def":"A method of reducing corpulence by avoiding food containing much farinaceous, saccharine, or oily matter; -- so called from William Banting of London.","pos":""}],"BANTLING":[{"def":"A young or small child; an infant.","pos":""}],"BANTU":[{"def":"A member of one of the great family of Negroid tribes occupying equatorial and southern Africa.","pos":""}],"BANXRING":[{"def":"An East Indian insectivorous mammal of the genus Tupaia.","pos":""}],"BANYAN":[{"def":"A tree of the same genus as the common fig, and called the Indian fig (Ficus Indica), whose branches send shoots to the ground, which take root and become additional trunks, until it may be the tree covers some acres of ground and is able to shelter thousands of men.","pos":""}]}