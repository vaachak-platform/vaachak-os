{"EMBRACE":[{"def":"To fasten on, as armor.","pos":""}],"EMBRACEMENT":[{"def":"A clasp in the arms; embrace.","pos":""},{"def":"State of being contained; inclosure.","pos":""}],"EMBRACEOR":[{"def":"One guilty of embracery.","pos":""}],"EMBRACER":[{"def":"One who embraces.","pos":""}],"EMBRACERY":[{"def":"An attempt to influence a court, jury, etc.","pos":""}],"EMBRACIVE":[{"def":"Disposed to embrace; fond of caressing.","pos":""}],"EMBRAID":[{"def":"To braid up, as hair.","pos":""}],"EMBRANCHMENT":[{"def":"The branching forth, as of trees.","pos":""}],"EMBRANGLE":[{"def":"To confuse; to entangle.","pos":""}],"EMBRASURE":[{"def":"A splay of a door or window.","pos":""},{"def":"An aperture with slant sides in a wall or parapet, through which cannon are pointed and discharged; a crenelle.","pos":""}],"EMBRAVE":[{"def":"To inspire with bravery.","pos":""},{"def":"To decorate; to make showy and fine.","pos":""}],"EMBRAWN":[{"def":"It will embrawn and iron-crust his flesh.","pos":""}],"EMBREATHEMENT":[{"def":"The act of breathing in; inspiration.","pos":""}],"EMBREW":[{"def":"To imbrue; to stain with blood.","pos":""}],"EMBROCATE":[{"def":"To moisten and rub (a diseased part) with a liquid substance, as with spirit, oil, etc.","pos":""}],"EMBROIDER":[{"def":"To ornament with needlework; as, to embroider a scarf.","pos":""}],"EMBROIDERER":[{"def":"One who embroiders.","pos":""}],"EMBROIDERY":[{"def":"Needlework used to enrich textile fabrics, leather, etc.","pos":""},{"def":"Diversified ornaments, especially by contrasted figures and colors; variegated decoration.","pos":""}],"EMBROIL":[{"def":"To throw into confusion or commotion by contention or discord; to entangle in a broil or quarrel; to make confused; to distract; to involve in difficulties by dissension or strife.","pos":""},{"def":"To implicate in confusion; to complicate; to jumble.","pos":""}],"EMBROILER":[{"def":"One who embroils.","pos":""}],"EMBROILMENT":[{"def":"The act of embroiling, or the condition of being embroiled; entanglement in a broil.","pos":""}],"EMBRONZE":[{"def":"To embody in bronze; to set up a bronze representation of, as of a person.","pos":""},{"def":"To color in imitation of bronze.","pos":""}],"EMBROTHEL":[{"def":"To inclose in a brothel.","pos":""},{"def":"To embroider; to adorn.","pos":""}],"EMBROWN":[{"def":"To give a brown color to; to imbrown.","pos":""}],"EMBRUE":[{"def":"See Imbrue, Embrew.","pos":""}],"EMBRUTE":[{"def":"To brutify; to imbrute.","pos":""}],"EMBRYO":[{"def":"The first rudiments of an organism, whether animal or plant; as: (a) The young of an animal in the womb, or more specifically, before its parts are developed and it becomes a fetus (see Fetus).","pos":""}],"EMBRYO SAC":[{"def":"See under Embryonic.","pos":""}],"EMBRYOGENIC":[{"def":"Pertaining to the development of an embryo.","pos":""}],"EMBRYOGENY":[{"def":"The production and development of an embryo.","pos":""}],"EMBRYOGONY":[{"def":"The formation of an embryo.","pos":""}],"EMBRYOGRAPHY":[{"def":"The general description of embryos.","pos":""},{"def":"Of or pertaining to embryology.","pos":""}],"EMBRYOLOGIST":[{"def":"One skilled in embryology.","pos":""}],"EMBRYOLOGY":[{"def":"The science which relates to the formation and development of the embryo in animals and plants; a study of the gradual development of the ovum until it reaches the adult stage.","pos":""}],"EMBRYONAL":[{"def":"Pertaining to an embryo, or the initial state of any organ; embryonic.","pos":""}],"EMBRYONARY":[{"def":"In the state of, or having, an embryonal.","pos":""}],"EMBRYONIC":[{"def":"Of or pertaining to an embryo; embryonal; rudimentary.","pos":""}],"EMBRYONIFEROUS":[{"def":"Having an embryo.","pos":""}],"EMBRYONIFORM":[{"def":"Like an embryo in form.","pos":""}],"EMBRYOPLASTIC":[{"def":"Relating to, or aiding in, the formation of an embryo; as, embryoplastic cells.","pos":""}],"EMBRYOTOMY":[{"def":"The cutting a fetus into pieces within the womb, so as to effect its removal.","pos":""}],"EMBRYOTROPH":[{"def":"The material from which an embryo is formed and nourished.","pos":""}],"EMBRYOUS":[{"def":"Embryonic; undeveloped.","pos":""}]}