{"PLUCK":[{"def":"To reject at an examination for degrees.","pos":""}],"PLUCKED":[{"def":"Having courage and spirit.","pos":""}],"PLUCKER":[{"def":"One who, or that which, plucks.","pos":""},{"def":"A machine for straightening and cleaning wool.","pos":""}],"PLUCKILY":[{"def":"In a plucky manner.","pos":""}],"PLUCKINESS":[{"def":"The quality or state of being plucky.","pos":""}],"PLUCKLESS":[{"def":"Without pluck; timid; faint-hearted.","pos":""}],"PLUCKY":[{"def":"Having pluck or courage; characterized by pluck; displaying pluck; courageous; spirited; as, a plucky race.","pos":""}],"PLUFF":[{"def":"To throw out, as smoke, dust, etc.","pos":""}],"PLUG":[{"def":"A block of wood let into a wall, to afford a hold for nails.","pos":""}],"PLUG BOARD":[{"def":"A switchboard in which connections are made by means of plugs.","pos":""}],"PLUGGER":[{"def":"One who, or that which, plugs.","pos":""}],"PLUGGING":[{"def":"The act of stopping with a plug.","pos":""},{"def":"The material of which a plug or stopple is made.","pos":""}],"PLUM":[{"def":"The edible drupaceous fruit of the Prunus domestica, and of several other species of Prunus; also, the tree itself, usually called plum tree.","pos":""}],"PLUMAGE":[{"def":"The entire clothing of a bird.","pos":""}],"PLUMASSARY":[{"def":"A plume or collection of ornamental feathers.","pos":""}],"PLUMASSIER":[{"def":"One who prepares or deals in ornamental plumes or feathers.","pos":""}],"PLUMB":[{"def":"A little mass or weight of lead, or the like, attached to a line, and used by builders, etc.","pos":""}],"PLUMBAGIN":[{"def":"A crystalline substance said to be found in the root of a certain plant of the Leadwort (Plumbago) family.","pos":""}],"PLUMBAGINEOUS":[{"def":"Pertaining to natural order (Plumbagineæ) of gamopetalous herbs, of which plumbago is the type.","pos":""}],"PLUMBAGINOUS":[{"def":"Resembling plumbago; consisting of, or containing, plumbago; as, a plumbaginous slate.","pos":""}],"PLUMBAGO":[{"def":"Same as Graphite.","pos":""},{"def":"A genus of herbaceous plants with pretty salver-shaped corollas, usually blue or violet; leadwort.","pos":""}],"PLUMBER":[{"def":"One who works in lead; esp.","pos":""}],"PLUMBERY":[{"def":"The business of a plumber.","pos":""},{"def":"A place where plumbing is carried on; lead works.","pos":""}],"PLUMBIC":[{"def":"Of, pertaining to, resembling, or containing, lead; -- used specifically to designate those compounds in which it has a higher valence as contrasted with plumbous compounds; as, plumbic oxide.","pos":""}],"PLUMBIFEROUS":[{"def":"Producing or containing lead.","pos":""}],"PLUMBING":[{"def":"The art of casting and working in lead, and applying it to building purposes; especially, the business of furnishing, fitting, and repairing pipes for conducting water, sewage, etc.","pos":""},{"def":"The lead or iron pipes, and other apparatus, used in conveying water, sewage, etc.","pos":""}],"PLUMBISM":[{"def":"A diseased condition, produced by the absorption of lead, common among workers in this metal or in its compounds, as among painters, typesetters, etc.","pos":""}],"PLUMBOUS":[{"def":"Of, pertaining to, or containing, lead; -- used specifically to designate those compounds in which it has a lower valence as contrasted with plumbic compounds.","pos":""}],"PLUMBUM":[{"def":"The technical name of lead.","pos":""}],"PLUMCOT":[{"def":"A cross between the plum and apricot.","pos":""}],"PLUME":[{"def":"An ornamental tuft of feathers.","pos":""},{"def":"A large and flexible panicle of inflorescence resembling a feather, such as is seen in certain large ornamental grasses.","pos":""}],"PLUMELET":[{"def":"When rosy plumelets tuft the larch.","pos":""}],"PLUMERY":[{"def":"Plumes, collectively or in general; plumage.","pos":""}],"PLUMICORN":[{"def":"An ear tuft of feathers, as in the horned owls.","pos":""}],"PLUMIGEROUS":[{"def":"Feathered; having feathers.","pos":""}],"PLUMILIFORM":[{"def":"Having the of a plume or feather.","pos":""}],"PLUMIPED":[{"def":"Having feet covered with feathers.","pos":""},{"def":"A plumiped bird.","pos":""}],"PLUMMET":[{"def":"A piece of lead attached to a line, used in sounding the depth of water.","pos":""},{"def":"A plumb bob or a plumb line.","pos":""}],"PLUMMING":[{"def":"The operation of finding, by means of a mine dial, the place where to sink an air shaft, or to bring an adit to the work, or to find which way the lode inclines.","pos":""}],"PLUMMY":[{"def":"Of the nature of a plum; desirable; profitable; advantageous.","pos":""}],"PLUMOSITE":[{"def":"Same as Jamesonite.","pos":""}],"PLUMOSITY":[{"def":"The quality or state of being plumose.","pos":""}],"PLUMP":[{"def":"Well rounded or filled out; full; fleshy; fat; as, a plump baby; plump cheeks.","pos":""}],"PLUMPER":[{"def":"A vote given to one candidate only, when two or more are to be elected, thus giving him the advantage over the others.","pos":""}],"PLUMPLY":[{"def":"Fully; roundly; plainly; without reserve.","pos":""}],"PLUMPNESS":[{"def":"The quality or state of being plump.","pos":""}],"PLUMPY":[{"def":"Plump; fat; sleek.","pos":""}],"PLUMULACEOUS":[{"def":"Downy; bearing down.","pos":""}],"PLUMULAR":[{"def":"Relating to a plumule.","pos":""}],"PLUMULARIA":[{"def":"Any hydroid belonging to Plumularia and other genera of the family Plumularidæ.","pos":""}],"PLUMULE":[{"def":"The first bud, or gemmule, of a young plant; the bud, or growing point, of the embryo, above the cotyledons.","pos":""}],"PLUMULOSE":[{"def":"Having hairs branching out laterally, like the parts of a feather.","pos":""}],"PLUMY":[{"def":"Covered or adorned with plumes, or as with plumes; feathery.","pos":""}],"PLUNDER":[{"def":"To take the goods of by force, or without right; to pillage; to spoil; to sack; to strip; to rob; as, to plunder travelers.","pos":""},{"def":"To take by pillage; to appropriate forcibly; as, the enemy plundered all the goods they found.","pos":""}],"PLUNDERAGE":[{"def":"The embezzlement of goods on shipboard.","pos":""}],"PLUNDERER":[{"def":"One who plunders or pillages.","pos":""}],"PLUNGE":[{"def":"To thrust into water, or into any substance that is penetrable; to immerse; to cause to penetrate or enter quickly and forcibly; to thrust; as, to plunge the body into water; to plunge a dagger into the breast.","pos":""},{"def":"To baptize by immersion.","pos":""}],"PLUNGER":[{"def":"A boiler in which clay is beaten by a wheel to a creamy consistence.","pos":""},{"def":"The firing pin of a breechloader.","pos":""}],"PLUNK":[{"def":"To pluck and release quickly (a musical string); to twang.","pos":""},{"def":"To throw, push, drive heavily, plumply, or suddenly; as, to plunk down a dollar; also, to hit or strike.","pos":""}],"PLUNKET":[{"def":"A kind of blue color; also, anciently, a kind of cloth, generally blue.","pos":""}],"PLUPERFECT":[{"def":"More than perfect; past perfect; -- said of the tense which denotes that an action or event was completed at or before the time of another past action or event.","pos":""},{"def":"The pluperfect tense; also, a verb in the pluperfect tense.","pos":""}],"PLURAL":[{"def":"Relating to, or containing, more than one; designating two or more; as, a plural word.","pos":""}],"PLURALISM":[{"def":"The state of a pluralist; the holding of more than one ecclesiastical living at a time.","pos":""}],"PLURALIST":[{"def":"A clerk or clergyman who holds more than one ecclesiastical benefice.","pos":""}],"PLURALITY":[{"def":"See Plurality of benefices, below.","pos":""}],"PLURALIZATION":[{"def":"The act of pluralizing.","pos":""}],"PLURALIZE":[{"def":"To make plural by using the plural termination; to attribute plurality to; to express in the plural form.","pos":""},{"def":"To multiply; to make manifold.","pos":""}],"PLURALLY":[{"def":"In a plural manner or sense.","pos":""}],"PLURI-":[{"def":"A combining form from L.","pos":""}],"PLURIES":[{"def":"A writ issued in the third place, after two former writs have been disregarded.","pos":""}],"PLURIFARIOUS":[{"def":"Of many kinds or fashions; multifarious.","pos":""}],"PLURIFOLIOLATE":[{"def":"Having several or many leaflets.","pos":""}],"PLURILITERAL":[{"def":"Consisting of more letters than three.","pos":""},{"def":"A pluriliteral word.","pos":""}],"PLURILOCULAR":[{"def":"Having several cells or loculi; specifically (Bot.","pos":""},{"def":"having several divisions containing seeds; as, the lemon and the orange are plurilocular fruits.","pos":""}],"PLURIPAROUS":[{"def":"Producing several young at a birth; as, a pluriparous animal.","pos":""}],"PLURIPARTITE":[{"def":"Deeply divided into several portions.","pos":""}],"PLURIPRESENCE":[{"def":"Presence in more places than one.","pos":""}],"PLURISY":[{"def":"Superabundance; excess; plethora.","pos":""}],"PLUS":[{"def":"More, required to be added; positive, as distinguished from negative; -- opposed to Ant: minus.","pos":""}],"PLUSH":[{"def":"A textile fabric with a nap or shag on one side, longer and softer than the nap of velvet.","pos":""}],"PLUSHY":[{"def":"Like plush; soft and shaggy.","pos":""}],"PLUTARCHY":[{"def":"Plutocracy; the rule of wealth.","pos":""}],"PLUTEAL":[{"def":"Of or pertaining to a pluteus.","pos":""}],"PLUTEUS":[{"def":"The free-swimming larva of sea urchins and ophiurans, having several long stiff processes inclosing calcareous rods.","pos":""}],"PLUTO":[{"def":"The son of Saturn and Rhea, brother of Jupiter and Neptune; the dark and gloomy god of the Lower World.","pos":""}],"PLUTOCRACY":[{"def":"A form of government in which the supreme power is lodged in the hands of the wealthy classes; government by the rich; also, a controlling or influential class of rich men.","pos":""}],"PLUTOCRAT":[{"def":"One whose wealth gives him power or influence; one of the plutocracy.","pos":""}],"PLUTOCRATIC":[{"def":"Of or pertaining to plutocracy; as, plutocratic ideas.","pos":""}],"PLUTOLOGY":[{"def":"The science which treats of wealth.","pos":""}],"PLUTONIC":[{"def":"Of or pertaining to Pluto; Plutonian; hence, pertaining to the interior of the earth; subterranean.","pos":""},{"def":"Of, pertaining to, or designating, the system of the Plutonists; igneous; as, the Plutonic theory.","pos":""}],"PLUTONISM":[{"def":"The theory, early advanced in geology, that the successive rocks of the earth''s crust were formed by igneous fusion; -- opposed to the Neptunian theory.","pos":""}],"PLUTONIST":[{"def":"One who adopts the geological theory of igneous fusion; a Plutonian.","pos":""}],"PLUTUS":[{"def":"The son of Jason and Ceres, and the god of wealth.","pos":""}],"PLUVIAL":[{"def":"Produced by the action of rain.","pos":""}],"PLUVIAMETER":[{"def":"See Pluviometer.","pos":""}],"PLUVIAMETRICAL":[{"def":"See Pluviometrical.","pos":""}],"PLUVIAN":[{"def":"The crocodile bird.","pos":""}],"PLUVIOGRAPH":[{"def":"A self-registering rain gauge.","pos":""}],"PLUVIOGRAPHY":[{"def":"The branch of meteorology treating of the automatic registration of the precipitation of rain, snow, etc.","pos":""}],"PLUVIOMETER":[{"def":"An instrument for ascertaining the amount of rainfall at any place in a given time; a rain gauge.","pos":""}],"PLUVIOMETRICAL":[{"def":"Of or pertaining to a pluviometer; determined by a pluviometer.","pos":""}],"PLUVIOMETRY":[{"def":"That department of meteorology that treats of the measurement of the precipitation of rain, snow, etc.","pos":""}],"PLUVIOSE":[{"def":"The fifth month of the French republican calendar adopted in 1793.","pos":""}],"PLUVIOUS":[{"def":"Abounding in rain; rainy; pluvial.","pos":""}]}