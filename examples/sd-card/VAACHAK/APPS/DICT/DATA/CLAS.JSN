{"CLASH":[{"def":"To make a noise by striking against something; to dash noisily together.","pos":""},{"def":"To meet in opposition; to act in a contrary direction; to come onto collision; to interfere.","pos":""}],"CLASH GEAR":[{"def":"A change-speed gear in which the gears are changed by sliding endwise.","pos":""}],"CLASP":[{"def":"To shut or fasten together with, or as with, a clasp; to shut or fasten (a clasp, or that which fastens with a clasp).","pos":""},{"def":"To inclose and hold in the hand or with the arms; to grasp; to embrace.","pos":""}],"CLASPER":[{"def":"One who, or that which, clasps, as a tendril.","pos":""}],"CLASPERED":[{"def":"Furnished with tendrils.","pos":""}],"CLASS":[{"def":"One of the sections into which a church or congregation is divided, and which is under the supervision of a class leader.","pos":""}],"CLASSIBLE":[{"def":"Capable of being classed.","pos":""}],"CLASSIC":[{"def":"A work of acknowledged excellence and authrity, or its author; -- originally used of Greek and Latin works or authors, but now applied to authors and works of a like character in any language.","pos":""},{"def":"One learned in the literature of Greece and Rome, or a student of classical literature.","pos":""}],"CLASSICALISM":[{"def":"A classical idiom, style, or expression; a classicism.","pos":""},{"def":"Adherence to what are supposed or assumed to be the classical canons of art.","pos":""}],"CLASSICALIST":[{"def":"One who adheres to what he thinks the classical canons of art.","pos":""},{"def":"The quality of being classical.","pos":""}],"CLASSICALLY":[{"def":"In a classical manner; according to the manner of classical authors.","pos":""},{"def":"In the manner of classes; according to a regular order of classes or sets.","pos":""}],"CLASSICISM":[{"def":"A classic idiom or expression; a classicalism.","pos":""}],"CLASSICIST":[{"def":"One learned in the classics; an advocate for the classics.","pos":""}],"CLASSIFIABLE":[{"def":"Capable of being classified.","pos":""}],"CLASSIFIC":[{"def":"Characterizing a class or classes; relating to classification.","pos":""}],"CLASSIFICATION":[{"def":"The act of forming into a class or classes; a distibution into groups, as classes, orders, families, etc.","pos":""}],"CLASSIFICATORY":[{"def":"Pertaining to classification; admitting of classification.","pos":""}],"CLASSIFIER":[{"def":"One who classifies.","pos":""}],"CLASSIFY":[{"def":"To distribute into classes; to arrange according to a system; to arrnge in sets according to some method founded on common properties or characters.","pos":""}],"CLASSIS":[{"def":"A class or order; sort; kind.","pos":""}],"CLASSMAN":[{"def":"A member of a class; a classmate.","pos":""},{"def":"A candidate for graduation in arts who is placed in an honor class, as opposed to a passman, who is not classified.","pos":""}],"CLASSMATE":[{"def":"One who is in the same class with another, as at school or college.","pos":""}],"CLASTIC":[{"def":"Fragmental; made up of brokas, sandstone is a clastic rock.","pos":""}]}