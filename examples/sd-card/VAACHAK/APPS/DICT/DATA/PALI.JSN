{"PALI":[{"def":"A dialect descended from Sanskrit, and like that, a dead language, except when used as the sacred language of the Buddhist religion in Farther India, etc.","pos":""}],"PALIFICATION":[{"def":"The act or practice of driving piles or posts into the ground to make it firm.","pos":""}],"PALIFORM":[{"def":"Resembling a palus; as, the paliform lobes of the septa in corals.","pos":""}],"PALILOGY":[{"def":"The repetition of a word, or part of a sentence, for the sake of greater emphasis; as, \"The living, the living, he shall praise thee.","pos":""}],"PALIMPSEST":[{"def":"A parchment which has been written upon twice, the first writing having been erased to make place for the second.","pos":""}],"PALINDROME":[{"def":"A word, verse, or sentence, that is the same when read backward or forward; as, madam; Hannah; or Lewd did I live, & evil I did dwel.","pos":""},{"def":"Of, pertaining to, or like, a palindrome.","pos":""}],"PALINDROMIST":[{"def":"A writer of palindromes.","pos":""}],"PALING":[{"def":"Pales, in general; a fence formed with pales or pickets; a limit; an inclosure.","pos":""},{"def":"The act of placing pales or stripes on cloth; also, the stripes themselves.","pos":""}],"PALINGENESIA":[{"def":"See Palingenesis.","pos":"noun"},{"def":"That form of evolution in which the truly ancestral characters conserved by heredity are reproduced in development; original simple descent; -- distinguished from kenogenesis.","pos":"noun"}],"PALINGENETIC":[{"def":"Of or pertaining to palingenesis: as, a palingenetic process.","pos":""}],"PALINODE":[{"def":"An ode recanting, or retracting, a former one; also, a repetition of an ode.","pos":""},{"def":"A retraction; esp.","pos":""}],"PALINODIAL":[{"def":"Of or pertaining to a palinode, or retraction.","pos":""}],"PALISADE":[{"def":"A strong, long stake, one end of which is set firmly in the ground, and the other is sharpened; also, a fence formed of such stakes set in the ground as a means of defense.","pos":""}],"PALISADING":[{"def":") A row of palisades set in the ground.","pos":""}],"PALISH":[{"def":"Somewhat pale or wan.","pos":""}],"PALISSY":[{"def":"Designating, or of the nature of, a kind of pottery made by Bernard Palissy, in France, in the 16th centry.","pos":""}]}