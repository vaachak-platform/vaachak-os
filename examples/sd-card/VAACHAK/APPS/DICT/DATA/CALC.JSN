{"CALC-SINTER":[{"def":"See under Calcite.","pos":""}],"CALC-SPAR":[{"def":"Same as Calcite.","pos":""}],"CALC-TUFA":[{"def":"See under Calcite.","pos":""}],"CALCANEAL":[{"def":"Pertaining to the calcaneum; as, calcaneal arteries.","pos":""}],"CALCANEUM":[{"def":"One of the bones of the tarsus which in man, forms the great bone of the heel; -- called also fibulare.","pos":""}],"CALCAR":[{"def":"A kind of oven, or reverberatory furnace, used for the calcination of sand and potash, and converting them into frit.","pos":""}],"CALCAREO-ARGILLACEOUS":[{"def":"consisting of, or containing, calcareous and argillaceous earths.","pos":""}],"CALCAREO-BITUMINOUS":[{"def":"Consisting of, or containing, lime and bitumen.","pos":""}],"CALCAREO-SILICEOUS":[{"def":"Consisting of, or containing calcareous and siliceous earths.","pos":""}],"CALCAREOUS":[{"def":"Partaking of the nature ofcalcite or calcium carbonate; consisting of, or containg, calcium carbonate or carbonate of lime.","pos":""}],"CALCAREOUSNESS":[{"def":"Quality of being calcareous.","pos":""}],"CALCARINE":[{"def":"Pertaining to, or situated near, the calcar of the brain.","pos":""}],"CALCAVELLA":[{"def":"A sweet wine from Portugal; -- so called from the district of Carcavelhos.","pos":""}],"CALCEATED":[{"def":"Fitted with, or wearing, shoes.","pos":""}],"CALCED":[{"def":"Wearing shoes; calceated; -- in distintion from discalced or barefooted; as the calced Carmelites.","pos":""}],"CALCEDON":[{"def":"A foul vein, like chalcedony, in some precious stones.","pos":""},{"def":"See Chalcedonic.","pos":""}],"CALCEIFORM":[{"def":"Shaped like a plipper, as one petal of the lady's-slipper; calceolate.","pos":""}],"CALCEOLARIA":[{"def":"A genus of showy herbaceous or shrubby plant, biought from South America; slipperwort.","pos":""}],"CALCIC":[{"def":"Pertaining to, derived from, or containing, calcium or lime.","pos":""}],"CALCIFEROUS":[{"def":"Bearing producing, or containing calcite, or carbonate of lime.","pos":""}],"CALCIFICATION":[{"def":"The process of chenge into a stony or calcareous substance by the deposition of lime salt; -- normally, as in the formation of bone and teeth; abnormally, as in calcareous degeneration of tissue.","pos":""}],"CALCIFIED":[{"def":"Consisting of, or containing, calcareous matter or lime salts; calcareous.","pos":""}],"CALCIFORM":[{"def":"In the form of chalk or lime.","pos":""}],"CALCIFY":[{"def":"To make stony or calcareous by the deposit or secretion of salts of lime.","pos":""}],"CALCIGENOUS":[{"def":"Tending to form, or to become, a calx or earthlike substance on being oxidized or burnt; as magnesium, calcium.","pos":""}],"CALCIGEROUS":[{"def":"Holding lime or other earthy salts; as, the calcigerous cells of the teeth.","pos":""}],"CALCIMINE":[{"def":"A white or colored wash for the ceiling or other plastering of a room, consisting of a mixture of clear glue, Paris white or zinc white, and water.","pos":""}],"CALCIMINER":[{"def":"One who calcimines.","pos":""}],"CALCINABLE":[{"def":"That may be calcined; as, a calcinable fossil.","pos":""}],"CALCINATION":[{"def":"The act or process of disintegrating a substance, or rendering it friable by the action of heat, esp.","pos":""}],"CALCINATORY":[{"def":"A vessel used in calcination.","pos":""}],"CALCINE":[{"def":"To reduce to a powder, or to a friable state, by the action of heat; to expel volatile matter from by means of heat, as carbonic acid from limestone, and thus (usually) to produce disintegration; as to, calcine bones.","pos":""},{"def":"To oxidize, as a metal by the action of heat; to reduce to a metallic calx.","pos":""}],"CALCINER":[{"def":"One who, or that which, calcines.","pos":""}],"CALCISPONGIAE":[{"def":"An order of marine sponges, containing calcareous spicules.","pos":""}],"CALCITE":[{"def":"Calcium carbonate, or carbonate of lime.","pos":""}],"CALCIUM":[{"def":"An elementary substance; a metal which combined with oxygen forms lime.","pos":""}],"CALCIVOROUS":[{"def":"Eroding, or eating into, limestone.","pos":""}],"CALCOGRAPHER":[{"def":"One who practices calcography.","pos":""},{"def":"Relating to, or in the style of, calcography.","pos":""}],"CALCOGRAPHY":[{"def":"The art of drawing with chalk.","pos":""}],"CALCULABLE":[{"def":"That may be calculated or ascertained by calculation.","pos":""}],"CALCULARY":[{"def":"Of or pertaining to calculi.","pos":""}],"CALCULATE":[{"def":"To ascertain or determine by mathematical processes, usually by the ordinary rules of arithmetic; to reckon up; to estimate; to compute.","pos":""},{"def":"To ascertain or predict by mathematical or astrological computations the time, circumstances, or other conditions of; to forecast or compute the character or consequences of; as, to calculate or cast one's nativity.","pos":""}],"CALCULATED":[{"def":"Worked out by calculation; as calculated tables for computing interest; ascertained or conjectured as a result of calculation; as, the calculated place of a planet; the calculated velocity of a cannon ball.","pos":""},{"def":"Adapted by calculation, contrivance.","pos":""}],"CALCULATING":[{"def":"Of or pertaining to mathematical calculations; performing or able to perform mathematical calculations.","pos":""},{"def":"Given to contrivance or forethought; forecasting; scheming; as, a cool calculating disposition.","pos":""}],"CALCULATION":[{"def":"The act or process, or the result, of calculating; computation; reckoning, estimate.","pos":""},{"def":"An expectation based on cirumstances.","pos":""}],"CALCULATIVE":[{"def":"Of or pertaining to calculation; involving calculation.","pos":""}],"CALCULATOR":[{"def":"One who computes or reckons: one who estimates or considers the force and effect of causes, with a view to form a correct estimate of the effects.","pos":""}],"CALCULATORY":[{"def":"Belonging to calculation.","pos":""}],"CALCULE":[{"def":"Reckoning; computation.","pos":""}],"CALCULOUS":[{"def":"Of the nature of a calculus; like stone; gritty; as, a calculous concretion.","pos":""},{"def":"Caused, or characterized, by the presence of a calculus or calculi; a, a calculous disorder; affected with gravel or stone; as, a calculous person.","pos":""}],"CALCULUS":[{"def":"Any solid concretion, formed in any part of the body, but most frequent in the organs that act as reservoirs, and in the passages connected with them; as, biliary calculi; urinary calculi, etc.","pos":""},{"def":"A method of computation; any process of reasoning by the use of symbols; any branch of mathematics that may involve calculation.","pos":""}]}