{"NUGACITY":[{"def":"Futility; trifling talk or behavior; drollery.","pos":""}],"NUGATION":[{"def":"The act or practice of trifling.","pos":""}],"NUGATORY":[{"def":"Trifling; vain; futile; insignificant.","pos":""},{"def":"Of no force; inoperative; ineffectual.","pos":""}],"NUGGET":[{"def":"A lump; a mass, esp.","pos":""}],"NUGIFY":[{"def":"To render trifling or futile; to make silly.","pos":""}]}