{"LOP":[{"def":"To cut off as the top or extreme part of anything; to shoas, to lop a tree or its branches.","pos":""},{"def":"To cut partly off and bend down; as, to lop bushes in a hedge.","pos":""}],"LOPE":[{"def":"And, laughing, lope into a tree.","pos":""}],"LOPEARED":[{"def":"Having ears which lop or hang down.","pos":""}],"LOPEMAN":[{"def":"Leaper; ropedancer.","pos":""}],"LOPER":[{"def":"A swivel at one end of a ropewalk, used in laying the strands.","pos":""}],"LOPHINE":[{"def":"A nitrogenous organic base obtained by the oxidation of amarine, and regarded as a derivative of benzoic aldehyde.","pos":""}],"LOPHIOMYS":[{"def":"A very singular rodent (Lophiomys Imhausi) of Northeastern Africa.","pos":""}],"LOPHOBRANCH":[{"def":"Of or pertaining to the Lophobranchii.","pos":""},{"def":"One of the Lophobranchii.","pos":""}],"LOPHOBRANCHIATE":[{"def":"Of or pertaining to the Lophobranchii.","pos":""}],"LOPHOBRANCHII":[{"def":"An order of teleostean fishes, having the gills arranged in tufts on the branchial arches, as the Hippocampus and pipefishes.","pos":""}],"LOPHOPHORE":[{"def":"A disk which surrounds the mouth and bears the tentacles of the Bryozoa.","pos":""}],"LOPHOPODA":[{"def":"Same as Phylactolemata.","pos":""}],"LOPHOSTEON":[{"def":"The central keel-bearing part of the sternum in birds.","pos":""}],"LOPPARD":[{"def":"A tree, the top of which has been lopped off.","pos":""}],"LOPPER":[{"def":"One who lops or cuts off.","pos":""}],"LOPPING":[{"def":"A cutting off, as of branches; that which is cut off; leavings.","pos":""}],"LOPPY":[{"def":"Somewhat lop; inclined to lop.","pos":""}],"LOPSEED":[{"def":"A perennial herb (Phryma Leptostachya), having slender seedlike fruits.","pos":""}],"LOPSIDED":[{"def":"Leaning to one side because of some defect of structure; as, a lopsided ship.","pos":""},{"def":"Unbalanced; poorly proportioned; full of idiosyncrasies.","pos":""}]}