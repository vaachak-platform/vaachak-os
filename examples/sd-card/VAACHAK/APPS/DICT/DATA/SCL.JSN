{"SCLAFF":[{"def":"To scuff or shuffle along.","pos":""}],"SCLAUNDRE":[{"def":"SCLAV; SCLAVE Sclav, Sclave, n.","pos":""}],"SCLAVISM":[{"def":"Same as Slavism.","pos":""}],"SCLAVONIAN":[{"def":"Same as Slavonian.","pos":""}],"SCLAVONIC":[{"def":"Same as Slavonic.","pos":""}],"SCLERAGOGY":[{"def":"Severe discipline.","pos":""}],"SCLEREMA":[{"def":"Induration of the cellular tissue.","pos":""}],"SCLERENCHYMA":[{"def":"Vegetable tissue composed of short cells with thickened or hardened walls, as in nutshells and the gritty parts of a pear.","pos":""},{"def":"The hard calcareous deposit in the tissues of Anthozoa, constituing the stony corals.","pos":""}],"SCLERENCHYMATOUS":[{"def":"Pertaining to, or composed of, sclerenchyma.","pos":""}],"SCLERITE":[{"def":"A hard chitinous or calcareous process or corpuscle, especially a spicule of the Alcyonaria.","pos":""}],"SCLEROBASE":[{"def":"The calcareous or hornlike coral forming the central stem or axis of most compound alcyonarians; -- called also foot secretion.","pos":""}],"SCLERODERM":[{"def":"Scler\"o*derm ( or ; 277), n.","pos":""}],"SCLERODERMA":[{"def":"A disease of adults, characterized by a diffuse rigidity and hardness of the skin.","pos":""}],"SCLERODERMATA":[{"def":"The stony corals; the Madreporaria.","pos":""}],"SCLEROGEN":[{"def":"The thickening matter of woody cells; lignin.","pos":""}],"SCLEROGENOUS":[{"def":"Making or secreting a hard substance; becoming hard.","pos":""}],"SCLEROID":[{"def":"Having a hard texture, as nutshells.","pos":""}],"SCLEROMA":[{"def":"Induration of the tissues.","pos":""}],"SCLEROMETER":[{"def":"An instrument for determining with accuracy the degree of hardness of a mineral.","pos":""}],"SCLEROSED":[{"def":"Affected with sclerosis.","pos":""}],"SCLEROSIS":[{"def":"Induration; hardening; especially, that form of induration produced in an organ by increase of its interstitial connective tissue.","pos":""},{"def":"Hardening of the cell wall by lignification.","pos":""}],"SCLEROSKELETON":[{"def":"That part of the skeleton which is developed in tendons, ligaments, and aponeuroses.","pos":""}],"SCLEROTAL":[{"def":"The optic capsule; the sclerotic coat of the eye.","pos":""}],"SCLEROTIC":[{"def":"Of or pertaining to the sclerotic coat of the eye; sclerotical.","pos":""}],"SCLEROTITIS":[{"def":"Inflammation of the sclerotic coat.","pos":""}],"SCLEROTIUM":[{"def":"A hardened body formed by certain fungi, as by the Claviceps purpurea, which produced ergot.","pos":""},{"def":"The nature or resting stage of a plasmodium.","pos":""}],"SCLEROTOME":[{"def":"One of the bony, cartilaginous, or membranous partitoins which separate the myotomes.","pos":""}],"SCLEROUS":[{"def":"Hard; indurated; sclerotic.","pos":""}]}