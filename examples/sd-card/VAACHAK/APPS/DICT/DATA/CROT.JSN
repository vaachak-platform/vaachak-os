{"CROTALARIA":[{"def":"A genus of leguminous plants; rattlebox.","pos":""}],"CROTALINE":[{"def":"Resembling, or pertaining to, the Crotalidae, or Rattlesnake family.","pos":""}],"CROTALO":[{"def":"A Turkish musical instrument.","pos":""}],"CROTALUM":[{"def":"A kind of castanet used by the Corybantes.","pos":""}],"CROTALUS":[{"def":"A genus of poisonous serpents, including the rattlesnakes.","pos":""}],"CROTAPHITE":[{"def":"The temple or temporal fossa.","pos":""}],"CROTAPHITIC":[{"def":"Pertaining to the temple; temporal.","pos":""}],"CROTCH":[{"def":"A stanchion or post of wood or iron, with two arms for supporting a boom, spare yards, etc.","pos":""}],"CROTCH CHAIN":[{"def":"A form of tackle for loading a log sideways on a sled, skidway, etc.","pos":""}],"CROTCHED":[{"def":"Having a crotch; forked.","pos":""}],"CROTCHET":[{"def":"A time note, with a stem, having one fourth the value of a semibreve, one half that of a minim, and twice that of a quaver; a quarter note.","pos":""},{"def":"An indentation in the glacis of the covered way, at a point where a traverse is placed.","pos":""}],"CROTCHETED":[{"def":"Marked or measured by crotchets; having musical notation.","pos":""}],"CROTCHETINESS":[{"def":"The state or character of being crotchety, or whimsical.","pos":""}],"CROTCHETY":[{"def":"Given to crotchets; subject to whims; as, a crotchety man.","pos":""}],"CROTON":[{"def":"A genus of euphorbiaceous plants belonging to tropical countries.","pos":""}],"CROTON BUG":[{"def":"A small, active, winged species of cockroach (Ectobia Germanica), the water bug.","pos":""}],"CROTONIC":[{"def":"Of or pertaining to, or derived from, a plant of the genus Croton, or from croton oil.","pos":""}],"CROTONINE":[{"def":"A supposed alkaloid obtained from croton oil by boiling it with water and magnesia, since found to be merely a magnesia soap of the oil.","pos":""}],"CROTONYLENE":[{"def":"A colorless, volatile, pungent liquid, C4H6, produced artificially, and regarded as an unsaturated hydrocarbon of the acetylene series, and analogous to crotonic acid.","pos":""}],"CROTTLES":[{"def":"A name given to various lichens gathered for dyeing.","pos":""}]}