{"DESCANT":[{"def":"A discourse formed on its theme, like variations on a musical air; a comment or comments.","pos":""}],"DESCANTER":[{"def":"One who descants.","pos":""}],"DESCEND":[{"def":"To move toward the south, or to the southward.","pos":""},{"def":"To fall in pitch; to pass from a higher to a lower tone.","pos":""}],"DESCENDANT":[{"def":"One who descends, as offspring, however remotely; -- correlative to ancestor or ascendant.","pos":""}],"DESCENDENT":[{"def":"Descending; falling; proceeding from an ancestor or source.","pos":""}],"DESCENDER":[{"def":"One who descends.","pos":""}],"DESCENDIBILITY":[{"def":"The quality of being descendible; capability of being transmitted from ancestors; as, the descendibility of an estate.","pos":""}],"DESCENDIBLE":[{"def":"Admitting descent; capable of being descended.","pos":""},{"def":"That may descend from an ancestor to an heir.","pos":""}],"DESCENDING":[{"def":"Of or pertaining to descent; moving downwards.","pos":""}],"DESCENDINGLY":[{"def":"In a descending manner.","pos":""}],"DESCENSION":[{"def":"The act of going downward; descent; falling or sinking; declension; degradation.","pos":""}],"DESCENSIONAL":[{"def":"Pertaining to descension.","pos":""}],"DESCENSIVE":[{"def":"Tending to descend; tending downwards; descending.","pos":""}],"DESCENSORY":[{"def":"A vessel used in alchemy to extract oils.","pos":""}],"DESCENT":[{"def":"Transmission of an estate by inheritance, usually, but not necessarily, in the descending line; title to inherit an estate by reason of consanguinity.","pos":""},{"def":"A passing from a higher to a lower tone.","pos":""}],"DESCRIBABLE":[{"def":"That can be described; capable of description.","pos":""}],"DESCRIBE":[{"def":"To represent by drawing; to draw a plan of; to delineate; to trace or mark out; as, to describe a circle by the compasses; a torch waved about the head in such a way as to describe a circle.","pos":""},{"def":"To represent by words written or spoken; to give an account of; to make known to others by words or signs; as, the geographer describes countries and cities.","pos":""}],"DESCRIBENT":[{"def":"Same as Generatrix.","pos":""}],"DESCRIBER":[{"def":"One who describes.","pos":""}],"DESCRIER":[{"def":"One who descries.","pos":""}],"DESCRIPTION":[{"def":"The act of describing; a delineation by marks or signs.","pos":""},{"def":"A sketch or account of anything in words; a portraiture or representation in language; an enumeration of the essential qualities of a thing or species.","pos":""}],"DESCRIPTIVE":[{"def":"Tending to describe; having the quality of representing; containing description; as, a descriptive figure; a descriptive phrase; a descriptive narration; a story descriptive of the age.","pos":""}],"DESCRY":[{"def":"To spy out or discover by the eye, as objects distant or obscure; to espy; to recognize; to discern; to discover.","pos":""},{"def":"To discover; to disclose; to reveal.","pos":""}]}