{"LANIARIFORM":[{"def":"Shaped like a laniary, or canine, tooth.","pos":""}],"LANIARY":[{"def":"Lacerating or tearing; as, the laniary canine teeth.","pos":""}],"LANIATE":[{"def":"To tear in pieces.","pos":""}],"LANIATION":[{"def":"A tearing in pieces.","pos":""}],"LANIER":[{"def":"A thong of leather; a whip lash.","pos":""},{"def":"A strap used to fasten together parts of armor, to hold the shield by, and the like.","pos":""}],"LANIFEROUS":[{"def":"Bearing or producing wool.","pos":""}],"LANIFICAL":[{"def":"Working in wool.","pos":""}],"LANIFICE":[{"def":"Anything made of wool.","pos":""}],"LANIGEROUS":[{"def":"Bearing or producing wool.","pos":""}],"LANIOID":[{"def":"Of or pertaining to the shrikes (family Laniidæ).","pos":""}]}