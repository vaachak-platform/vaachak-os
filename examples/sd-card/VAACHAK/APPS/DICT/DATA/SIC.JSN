{"SIC":[{"def":"Note: This word is sometimes inserted in a quotation [sic], to call attention to the fact that some remarkable or inaccurate expression, misspelling, or the like, is literally reproduced.","pos":""}],"SICCA":[{"def":"A seal; a coining die; -- used adjectively to designate the silver currency of the Mogul emperors, or the Indian rupee of 192 grains.","pos":""}],"SICCATION":[{"def":"The act or process of drying.","pos":""}],"SICCATIVE":[{"def":"Drying; causing to dry.","pos":""},{"def":"That which promotes drying.","pos":""}],"SICCIFIC":[{"def":"Causing dryness.","pos":""}],"SICCITY":[{"def":"Dryness; aridity; destitution of moisture.","pos":""}],"SICE":[{"def":"The number six at dice.","pos":""}],"SICER":[{"def":"A strong drink; cider.","pos":""}],"SICILIAN":[{"def":"Of or pertaining to Sicily or its inhabitants.","pos":""}],"SICILIANO":[{"def":"A Sicilian dance, resembling the pastorale, set to a rather slow and graceful melody in 12-8 or 6-8 measure; also, the music to the dance.","pos":""}],"SICILIENNE":[{"def":"A kind of rich poplin.","pos":""}],"SICK":[{"def":"Affected with disease of any kind; ill; indisposed; not in health.","pos":""},{"def":"Affected with, or attended by, nausea; inclined to vomit; as, sick at the stomach; a sick headache.","pos":""}],"SICK-BRAINED":[{"def":"Disordered in the brain.","pos":""}],"SICKEN":[{"def":"To make sick; to disease.","pos":""},{"def":"To make qualmish; to nauseate; to disgust; as, to sicken the stomach.","pos":""}],"SICKENING":[{"def":"Causing sickness; specif.","pos":""}],"SICKER":[{"def":"To percolate, trickle, or ooze, as water through a crack.","pos":""},{"def":"Sure; certain; trusty.","pos":""}],"SICKISH":[{"def":"Somewhat sick or diseased.","pos":""},{"def":"Somewhat sickening; as, a sickish taste.","pos":""}],"SICKLE":[{"def":"A group of stars in the constellation Leo.","pos":""}],"SICKLED":[{"def":"Furnished with a sickle.","pos":""}],"SICKLEMAN":[{"def":"One who uses a sickle; a reaper.","pos":""}],"SICKLER":[{"def":"One who uses a sickle; a sickleman; a reaper.","pos":""}],"SICKLESS":[{"def":"Free from sickness.","pos":""}],"SICKLINESS":[{"def":"The quality or state of being sickly.","pos":""}],"SICKLY":[{"def":"Somewhat sick; disposed to illness; attended with disease; as, a sickly body.","pos":""},{"def":"Producing, or tending to, disease; as, a sickly autumn; a sickly climate.","pos":""}],"SICKNESS":[{"def":"The quality or state of being sick or diseased; illness; sisease or malady.","pos":""},{"def":"Nausea; qualmishness; as, sickness of stomach.","pos":""}],"SICLE":[{"def":"The holy mother brought five sicles and a pair of turtledoves to redeem the Lamb of God.","pos":""}]}