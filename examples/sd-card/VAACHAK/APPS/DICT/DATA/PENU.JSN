{"PENULT":[{"def":"The last syllable but one of a word; the syllable preceding the final one.","pos":""}],"PENULTIMATE":[{"def":"Last but one; as, the penultimate syllable, the last syllable but one of a word.","pos":""}],"PENUMBRA":[{"def":"The shadow cast, in an eclipse, where the light is partly, but not wholly, cut off by the intervening body; the space of partial illumination between the umbra, or perfect shadow, on all sides, and the full light.","pos":""},{"def":"The part of a picture where the shade imperceptibly blends with the light.","pos":""}],"PENUMBRALA":[{"def":"Of or pertaining to a penumbra; resembling a penumbra; partially illuminated.","pos":""}],"PENURIOUS":[{"def":"Excessively sparing in the use of money; sordid; stingy; miserly.","pos":""},{"def":"Not bountiful or liberal; scanty.","pos":""}],"PENURY":[{"def":"Absence of resources; want; privation; indigence; extreme poverty; destitution.","pos":""},{"def":"Penuriousness; miserliness.","pos":""}]}