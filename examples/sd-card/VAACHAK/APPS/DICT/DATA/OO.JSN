{"OO":[{"def":"A beautiful bird (Moho nobilis) of the Hawaiian Islands.","pos":""}],"OOECIUM":[{"def":"One of the special zooids, or cells, of Bryozoa, destined to receive and develop ova; an ovicell.","pos":""},{"def":"The development, or mode of origin, of the ova.","pos":""}],"OOIDAL":[{"def":"Shaped like an egg.","pos":""}],"OOK":[{"def":"A variety of limestone, consisting of small round grains, resembling the roe of a fish.","pos":""}],"OOLONG":[{"def":"A fragrant variety of black tea having somewhat the flavor of green tea.","pos":""},{"def":"A long, broad boat used by the Eskimos.","pos":""}],"OOP":[{"def":"To bind with a thread or cord; to join; to unite.","pos":""},{"def":"A kind of black tea.","pos":""}],"OORDOBA":[{"def":"The monetary unit of Nicaragua, equivalent to the United States gold dollar.","pos":""},{"def":"A wild, bearded sheep inhabiting the Ladakh mountains.","pos":""}],"OOZE":[{"def":"Soft mud or slime; earth so wet as to flow gently, or easily yield to pressure.","pos":""},{"def":"Soft flow; spring.","pos":""}],"OOZE LEATHER":[{"def":"Leather made from sheep and calf skins by mechanically forcing ooze through them; esp.","pos":""}],"OOZY":[{"def":"Miry; containing soft mud; resembling ooze; as, the oozy bed of a river.","pos":""}]}