{"SWEAL":[{"def":"To melt and run down, as the tallow of a candle; to waste away without feeding the flame.","pos":""}],"SWEAR":[{"def":"To give evidence on oath; as, to swear to the truth of a statement; he swore against the prisoner.","pos":""}],"SWEARER":[{"def":"One who swears; one who calls God to witness for the truth of his declaration.","pos":""},{"def":"A profane person; one who uses profane language.","pos":""}],"SWEARING":[{"def":"Idle swearing is a cursedness.","pos":""}],"SWEAT":[{"def":"To excrete sensible moisture from the pores of the skin; to perspire.","pos":""}],"SWEATER":[{"def":"One who, or that which, causes to sweat; as: (a) A sudorific.","pos":""}],"SWEATILY":[{"def":"In a sweaty manner.","pos":""}],"SWEATINESS":[{"def":"Quality or state of being sweaty.","pos":""}],"SWEATING":[{"def":"Sweat\"ing, Defn: a.","pos":""}],"SWEATY":[{"def":"Moist with sweat; as, a sweaty skin; a sweaty garment.","pos":""},{"def":"Consisting of sweat; of the nature of sweat.","pos":""}],"SWEDE":[{"def":"A Swedish turnip.","pos":""}],"SWEDENBORGIAN":[{"def":"One who holds the doctrines of the New Jerusalem church, as taught by Emanuel Swedenborg, a Swedish philosopher and religious writer, who was born a.","pos":""}],"SWEDENBORGIANISM":[{"def":"The doctrines of the Swedenborgians.","pos":""}],"SWEDISH":[{"def":"Of or pertaining to Sweden or its inhabitants.","pos":""}],"SWEENY":[{"def":"An atrophy of the muscles of the shoulder in horses; also, atrophy of any muscle in horses.","pos":""}],"SWEEP":[{"def":"To draw or drag something over; as, to sweep the bottom of a river with a net.","pos":""}],"SWEEPAGE":[{"def":"The crop of hay got in a meadow.","pos":""}],"SWEEPER":[{"def":"One who, or that which, sweeps, or cleans by sweeping; a sweep; as, a carpet sweeper.","pos":""}],"SWEEPING":[{"def":"Cleaning off surfaces, or cleaning away dust, dirt, or litter, as a broom does; moving with swiftness and force; carrying everything before it; including in its scope many persons or things; as, a sweeping flood; a sweeping majority; a sweeping accusation.","pos":""}],"SWEEPINGS":[{"def":"Things collected by sweeping; rubbish; as, the sweepings of a street.","pos":""}],"SWEEPSTAKE":[{"def":"A winning of all the stakes or prizes.","pos":""},{"def":"A complete removal or carrying away; a clean sweep.","pos":""}],"SWEEPSTAKES":[{"def":"The whole money or other things staked at a horse race, a given sum being put up for each horse, all of which goes to the winner, or is divided among several, as may be previously agreed.","pos":""}],"SWEEPWASHER":[{"def":"One who extracts the residuum of precious metals from the sweepings, potsherds, etc.","pos":""}],"SWEEPY":[{"def":"Moving with a sweeping motion.","pos":""}],"SWEET":[{"def":"Having an agreeable taste or flavor such as that of sugar; saccharine; -- opposed to sour and bitter; as, a sweet beverage; sweet fruits; sweet oranges.","pos":""},{"def":"Pleasing to the smell; fragrant; redolent; balmy; as, a sweet rose; sweet odor; sweet incense.","pos":""}],"SWEET-BREASTED":[{"def":"Having a sweet, musical voice, as the nightingale.","pos":""}],"SWEET-SCENTED":[{"def":"Having a sweet scent or smell; fragrant.","pos":""}],"SWEET-SOP":[{"def":"A kind of custard apple (Anona squamosa).","pos":""}],"SWEETBREAD":[{"def":"Either the thymus gland or the pancreas, the former being called neck, or throat, sweetbread, the latter belly sweetbread.","pos":""}],"SWEETBRIER":[{"def":"A kind of rose (Rosa rubiginosa) with minutely glandular and fragrant foliage.","pos":""}],"SWEETEN":[{"def":"To make sweet to the taste; as, to sweeten tea.","pos":""},{"def":"To make pleasing or grateful to the mind or feelings; as, to sweeten life; to sweeten friendship.","pos":""}],"SWEETENER":[{"def":"One who, or that which, sweetens; one who palliates; that which moderates acrimony.","pos":""}],"SWEETENING":[{"def":"The act of making sweet.","pos":""},{"def":"That which sweetens.","pos":""}],"SWEETHEART":[{"def":"A lover of mistress.","pos":""}],"SWEETING":[{"def":"A darling; -- a word of endearment.","pos":""}],"SWEETLY":[{"def":"In a sweet manner.","pos":""}],"SWEETMEAT":[{"def":"A boat shell (Crepidula fornicata) of the American coast.","pos":""}],"SWEETNESS":[{"def":"The quality or state of being sweet (in any sense of the adjective); gratefulness to the taste or to the smell; agreeableness.","pos":""}],"SWEETWATER":[{"def":"A variety of white grape, having a sweet watery juice; -- also called white sweetwater, and white muscadine.","pos":""}],"SWEETWEED":[{"def":"A name for two tropical American weeds (Capraria biflora, and Scoparia dulcis) of the Figwort family.","pos":""}],"SWEETWOOD":[{"def":"The name is also applied to the timber of several other related trees.","pos":""}],"SWEETWORT":[{"def":"Any plant of a sweet taste.","pos":""}],"SWELL":[{"def":"To grow larger; to dilate or extend the exterior surface or dimensions, by matter added within, or by expansion of the inclosed substance; as, the legs swell in dropsy; a bruised part swells; a bladder swells by inflation.","pos":""},{"def":"To increase in size or extent by any addition; to increase in volume or force; as, a river swells, and overflows its banks; sounds swell or diminish.","pos":""}],"SWELLDOM":[{"def":"People of rank and fashion; the class of swells, collectively.","pos":""}],"SWELLFISH":[{"def":"Any plectognath fish that dilates itself, as the bur fish, puffer, or diodon.","pos":""}],"SWELLING":[{"def":"an unnatural prominence or protuberance; as, a scrofulous swelling.","pos":""}],"SWELLISH":[{"def":"Dandified; stylish.","pos":""}],"SWELT":[{"def":"To die; to perish.","pos":""},{"def":"To faint; to swoon.","pos":""}],"SWELTER":[{"def":"To be overcome and faint with heat; to be ready to perish with heat.","pos":""},{"def":"To welter; to soak.","pos":""}],"SWELTRY":[{"def":"Suffocating with heat; oppressively hot; sultry.","pos":""}],"SWERVE":[{"def":"To stray; to wander; to rope.","pos":""},{"def":"To go out of a straight line; to deflect.","pos":""}],"SWEVEN":[{"def":"A vision seen in sleep; a dream.","pos":""}]}