{"ACCREDIT":[{"def":"To put or bring into credit; to invest with credit or authority; to sanction.","pos":""},{"def":"To send with letters credential, as an ambassador, envoy, or diplomatic agent; to authorize, as a messenger or delegate.","pos":""}],"ACCREDITATION":[{"def":"The act of accrediting; as, letters of accreditation.","pos":""}],"ACCREMENTITIAL":[{"def":"Pertaining to accremention.","pos":""}],"ACCREMENTITION":[{"def":"The process of generation by development of blastema, or fission of cells, in which the new formation is in all respect like the individual from which it proceeds.","pos":""}],"ACCRESCE":[{"def":"To increase; to grow.","pos":""}],"ACCRESCENCE":[{"def":"Continuous growth; an accretion.","pos":""}],"ACCRESCENT":[{"def":"Growing larger after flowering.","pos":""}],"ACCRETE":[{"def":"To grow together.","pos":""},{"def":"To adhere; to grow (to); to be added; -- with to.","pos":""}],"ACCRETION":[{"def":"The act of increasing by natural growth; esp.","pos":""},{"def":"The act of increasing, or the matter added, by an accession of parts externally; an extraneous addition; as, an accretion of earth.","pos":""}],"ACCRETIVE":[{"def":"Relating to accretion; increasing, or adding to, by growth.","pos":""}],"ACCRIMINATE":[{"def":"To accuse of a crime.","pos":""}],"ACCROACH":[{"def":"To hook, or draw to one's self as with a hook.","pos":""},{"def":"To usurp, as jurisdiction or royal prerogatives.","pos":""}],"ACCROACHMENT":[{"def":"An encroachment; usurpation.","pos":""}],"ACCRUE":[{"def":"To increase; to augment.","pos":""},{"def":"To come to by way of increase; to arise or spring as a growth or result; to be added as increase, profit, or damage, especially as the produce of money lent.","pos":""}],"ACCRUER":[{"def":"The act of accruing; accretion; as, title by accruer.","pos":""}],"ACCRUMENT":[{"def":"The process of accruing, or that which has accrued; increase.","pos":""}]}