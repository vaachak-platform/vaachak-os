{"ARRACK":[{"def":"A name in the East Indies and the Indian islands for all ardent spirits.","pos":""}],"ARRAIGN":[{"def":"To call or set as a prisoner at the bar of a court to answer to the matter charged in an indictment or complaint.","pos":""}],"ARRAIGNER":[{"def":"One who arraigns.","pos":""}],"ARRAIGNMENT":[{"def":"The act of arraigning, or the state of being arraigned; the act of calling and setting a prisoner before a court to answer to an indictment or complaint.","pos":""},{"def":"Clothes; raiment.","pos":""}],"ARRANGE":[{"def":"To put in proper order; to dispose (persons, or parts) in the manner intended, or best suited for the purpose; as, troops arranged for battle.","pos":""},{"def":"To adjust or settle; to prepare; to determine; as, to arrange the preliminaries of an undertaking.","pos":""}],"ARRANGEMENT":[{"def":"The act of arranging or putting in an orderly condition; the state of being arranged or put in order; disposition in suitable form.","pos":""},{"def":"The manner or result of arranging; system of parts disposed in due order; regular and systematic classification; as, arrangement of one's dress; the Linnæan arrangement of plants.","pos":""}],"ARRANGER":[{"def":"One who arranges.","pos":""}],"ARRANT":[{"def":"Notoriously or preëminently bad; thorough or downright, in a bad sense; shameless; unmitigated; as, an arrant rogue or coward.","pos":""}],"ARRANTLY":[{"def":"Notoriously, in an ill sense; infamously; impudently; shamefully.","pos":""}],"ARRAS":[{"def":"Tapestry; a rich figured fabric; especially, a screen or hangings of heavy cloth with interwoven figures.","pos":""}],"ARRASENE":[{"def":"A material of wool or silk used for working the figures in embroidery.","pos":""}],"ARRASTRE":[{"def":"A rude apparatus for pulverizing ores, esp.","pos":""},{"def":"Placed in such a position as to exhibit the top and two sides, the corner being in front; -- said of a rectangular form.","pos":""}],"ARRAUGHT":[{"def":"Obtained; seized.","pos":""}],"ARRAY":[{"def":"Order; a regular and imposing arrangement; disposition in regular lines; hence, order of battle; as, drawn up in battle array.","pos":""},{"def":"The whole body of persons thus placed in order; an orderly collection; hence, a body of soldiers.","pos":""}],"ARREAR":[{"def":"To or in the rear; behind; backwards.","pos":""}],"ARREARAGE":[{"def":"That which remains unpaid and overdue, after payment of a part; arrears.","pos":""}],"ARRECT":[{"def":"Etym: [See Aret.","pos":""}],"ARRECTARY":[{"def":"An upright beam.","pos":""}],"ARRENOTOKOUS":[{"def":"Producing males from unfertilized eggs, as certain wasps and bees.","pos":""}],"ARRENTATION":[{"def":"A letting or renting, esp.","pos":""}],"ARREPTION":[{"def":"The act of taking away.","pos":""}],"ARREPTITIOUS":[{"def":"Snatched away; seized or possessed, as a demoniac; raving; mad; crack-brained.","pos":""}],"ARREST":[{"def":"To take, seize, or apprehend by authority of law; as, to arrest one for debt, or for a crime.","pos":""}],"ARRESTATION":[{"def":"The arrestation of the English resident in France was decreed by the National Convention.","pos":""}],"ARRESTEE":[{"def":"The person in whose hands is the property attached by arrestment.","pos":""}],"ARRESTER":[{"def":"The person at whose suit an arrestment is made.","pos":""}],"ARRESTING":[{"def":"Striking; attracting attention; impressive.","pos":""}],"ARRESTIVE":[{"def":"Tending to arrest.","pos":""}],"ARRESTMENT":[{"def":"The arrest of a person, or the seizure of his effects; esp.","pos":""}],"ARRHA":[{"def":"Money or other valuable thing given to evidence a contract; a pledge or earnest.","pos":""}],"ARRHAPHOSTIC":[{"def":"Destitute of a true root, as a parasitical plant.","pos":""}],"ARRIDE":[{"def":"To please; to gratify.","pos":""}],"ARRIERE":[{"def":"\"That which is behind\"; the rear; -- chiefly used as an adjective in the sense of behind, rear, subordinate.","pos":""}],"ARRIERE-BAN":[{"def":"A proclamation, as of the French kings, calling not only their immediate feudatories, but the vassals of these feudatories, to take the field for war; also, the body of vassals called or liable to be called to arms, as in ancient France.","pos":""}],"ARRIS":[{"def":"The sharp edge or salient angle formed by two surfaces meeting each other, whether plane or curved; -- applied particularly to the edges in moldings, and to the raised edges which separate the flutings in a Doric column.","pos":""}],"ARRISH":[{"def":"The stubble of wheat or grass; a stubble field; eddish.","pos":""}],"ARRISWISE":[{"def":"Diagonally laid, as tiles; ridgewise.","pos":""}],"ARRIVAL":[{"def":"The act of arriving, or coming; the act of reaching a place from a distance, whether by water (as in its original sense) or by land.","pos":""},{"def":"The attainment or reaching of any object, by effort, or in natural course; as, our arrival at this conclusion was wholly unexpected.","pos":""}],"ARRIVE":[{"def":"To come to the shore or bank.","pos":""},{"def":"To reach a point by progressive motion; to gain or compass an object by effort, practice, study, inquiry, reasoning, or experiment.","pos":""}],"ARRIVER":[{"def":"One who arrives.","pos":""}],"ARROBA":[{"def":"A Spanish weight used in Mexico and South America = 25.","pos":""},{"def":"A Spanish liquid measure for wine = 3.","pos":""}],"ARROGANCE":[{"def":"I hate not you for her proud arrogance.","pos":""}],"ARROGANT":[{"def":"Making, or having the disposition to make, exorbitant claims of rank or estimation; giving one's self an undue degree of importance; assuming; haughty; -- applied to persons.","pos":""},{"def":"Containing arrogance; marked with arrogance; proceeding from undue claims or self-importance; -- applied to things; as, arrogant pretensions or behavior.","pos":""}],"ARROGANTLY":[{"def":"In an arrogant manner; with undue pride or self-importance.","pos":""}],"ARROGATE":[{"def":"To assume, or claim as one's own, unduly, proudly, or presumptuously; to make undue claims to, from vanity or baseless pretensions to right or merit; as, the pope arrogated dominion over kings.","pos":""}],"ARROGATION":[{"def":"Adoption of a person of full age.","pos":""}],"ARROGATIVE":[{"def":"Making undue claims and pretension; prone to arrogance.","pos":""}],"ARRONDISSEMENT":[{"def":"A subdivision of a department.","pos":""}],"ARROSE":[{"def":"To drench; to besprinkle; to moisten.","pos":""}],"ARROW":[{"def":"A missile weapon of offense, slender, pointed, and usually feathered and barbed, to be shot from a bow.","pos":""}],"ARROW GRASS":[{"def":"An herbaceous grasslike plant (Triglochin palustre, and other species) with pods opening so as to suggest barbed arrowheads.","pos":""}],"ARROWHEAD":[{"def":"An aquatic plant of the genus Sagittaria, esp.","pos":""}],"ARROWHEADED":[{"def":"Shaped like the head of an arow; cuneiform.","pos":""}],"ARROWROOT":[{"def":"A west Indian plant of the genus Maranta, esp.","pos":""}],"ARROWWOOD":[{"def":"A shrub (Viburnum dentatum) growing in damp woods and thickets; -- so called from the long, straight, slender shoots.","pos":""}],"ARROWWORM":[{"def":"A peculiar transparent worm of the genus Sagitta, living at the surface of the sea.","pos":""}],"ARROWY":[{"def":"Consisting of arrows.","pos":""},{"def":"Formed or moving like, or in any respect resembling, an arrow; swift; darting; piercing.","pos":""}],"ARROYO":[{"def":"A water course; a rivulet.","pos":""},{"def":"The dry bed of a small stream.","pos":""}]}