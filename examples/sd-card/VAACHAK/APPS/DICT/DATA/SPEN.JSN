{"SPENCE":[{"def":"A place where provisions are kept; a buttery; a larder; a pantry.","pos":""},{"def":"The inner apartment of a country house; also, the place where the family sit and eat.","pos":""}],"SPENCER":[{"def":"One who has the care of the spence, or buttery.","pos":""}],"SPEND":[{"def":"To weigh or lay out; to dispose of; to part with; as, to spend money for clothing.","pos":""},{"def":"To bestow; to employ; -- often with on or upon.","pos":""}],"SPENDER":[{"def":"One who spends; esp.","pos":""}],"SPENDING":[{"def":"The act of expending; expenditure.","pos":""}],"SPENDTHRIFT":[{"def":"One who spends money profusely or improvidently; a prodigal; one who lavishes or wastes his estate.","pos":""}],"SPENDTHRIFTY":[{"def":"Spendthrift; prodigal.","pos":""}],"SPENSERIAN":[{"def":"Of or pertaining to the English poet Spenser; -- specifically applied to the stanza used in his poem \"The Faërie Queene.","pos":""}],"SPENT":[{"def":"Exhausted of spawn or sperm; -- said especially of fishes.","pos":""},{"def":"To shut in; to support; to inclose; to fasten.","pos":""}]}