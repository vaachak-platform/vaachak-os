{"CORVEE":[{"def":"An obligation to perform certain services, as the repair of roads, for the lord or sovereign.","pos":""}],"CORVEN":[{"def":"A war vessel, ranking next below a frigate, and having usually only one tier of guns; -- called in the United States navy a sloop of war.","pos":""}],"CORVETTO":[{"def":"Cor*vet\"to (-vt\"t), n.","pos":""}],"CORVINE":[{"def":"Of or pertaining to the crow; crowlike.","pos":""}],"CORVORANT":[{"def":"Cor\"vo*rant (kr\"v-rant), n.","pos":""}]}