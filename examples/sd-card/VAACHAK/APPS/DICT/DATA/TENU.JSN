{"TENUATE":[{"def":"To make thin; to attenuate.","pos":""}],"TENUIFOLIOUS":[{"def":"Having thin or narrow leaves.","pos":""}],"TENUIOUS":[{"def":"Rare or subtile; tenuous; -- opposed to dense.","pos":""}],"TENUIROSTER":[{"def":"One of the Tenuirostres.","pos":""}],"TENUIROSTRAL":[{"def":"Thin-billed; -- applied to birds with a slender bill, as the humming birds.","pos":""}],"TENUIROSTRES":[{"def":"An artificial group of passerine birds having slender bills, as the humming birds.","pos":""}],"TENUIS":[{"def":"One of the three surd mutes k, p, t; -- so called in relation to their respective middle letters, or medials, g, b, d, and their aspirates, x, f, th.","pos":""}],"TENUITY":[{"def":"The quality or state of being tenuous; thinness, applied to a broad substance; slenderness, applied to anything that is long; as, the tenuity of a leaf; the tenuity of a hair.","pos":""},{"def":"Rarily; rareness; thinness, as of a fluid; as, the tenuity of the air; the tenuity of the blood.","pos":""}],"TENUOUS":[{"def":"Lacking substance, as a tenuous argument.","pos":""}],"TENURE":[{"def":"The manner of holding lands and tenements of a superior.","pos":""}]}