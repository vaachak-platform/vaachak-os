{"SAC":[{"def":"The privilege formerly enjoyed the lord of a manor, of holding courts, trying causes, and imposing fines.","pos":""}],"SACALAIT":[{"def":"A kind of fresh-water bass; the crappie.","pos":""}],"SACCADE":[{"def":"A sudden, violent check of a horse by drawing or twitching the reins on a sudden and with one pull.","pos":""}],"SACCATE":[{"def":"Having the form of a sack or pouch; furnished with a sack or pouch, as a petal.","pos":""},{"def":"Of or pertaining to the Saccata, a suborder of ctenophores having two pouches into which the long tentacles can be retracted.","pos":""}],"SACCHARIC":[{"def":"Of, pertaining to, or obtained from, saccharine substances; specifically, designating an acid obtained, as a white amorphous gummy mass, by the oxidation of mannite, glucose, sucrose, etc.","pos":""}],"SACCHARIFEROUS":[{"def":"Producing sugar; as, sacchariferous canes.","pos":""}],"SACCHARIFY":[{"def":"Toconvert into, or to impregnate with, sugar.","pos":""}],"SACCHARILLA":[{"def":"A kind of muslin.","pos":""}],"SACCHARIMETER":[{"def":"An instrument for ascertain the quantity of saccharine matter in any solution, as the juice of a plant, or brewers' and distillers' worts.","pos":""}],"SACCHARIMETRICAL":[{"def":"Of or pertaining to saccharimetry; obtained saccharimetry.","pos":""}],"SACCHARIMETRY":[{"def":"The act, process or method of determining the amount and kind of sugar present in sirup, molasses, and the like, especially by the employment of polarizing apparatus.","pos":""}],"SACCHARIN":[{"def":"A bitter white crystalline substance obtained from the saccharinates and regarded as the lactone of saccharinic acid; -- so called because formerly supposed to be isomeric with cane sugar (saccharose).","pos":""}],"SACCHARINE":[{"def":"Of or pertaining to sugar; having the qualities of sugar; producing sugar; sweet; as, a saccharine taste; saccharine matter.","pos":""}],"SACCHARINIC":[{"def":"Of, pertaining to, or derived from, saccharin; specifically, designating a complex acid not known in the free state but well known in its salts, which are obtained by boiling dextrose and levulose (invert sugar) with milk of lime.","pos":""}],"SACCHARIZE":[{"def":"To convert into, or to impregnate with, sugar.","pos":""},{"def":"resembling sugar, as in taste, appearance, consistency, or composition; as, saccharoidal limestone.","pos":""}],"SACCHAROMETER":[{"def":"A saccharimeter.","pos":""}],"SACCHAROMYCES":[{"def":"A genus of budding fungi, the various species of which have the power, to a greater or less extent, or splitting up sugar into alcohol and carbonic acid.","pos":""}],"SACCHAROMYCETES":[{"def":"A family of fungi consisting of the one genus Saccharomyces.","pos":""}],"SACCHARONATE":[{"def":"A salt of saccharonic acid.","pos":""}],"SACCHARONIC":[{"def":"Of, pertaining to, or derived from, saccharone; specifically, designating an unstable acid which is obtained from saccharone (a) by hydration, and forms a well-known series of salts.","pos":""}],"SACCHAROSE":[{"def":"Cane sugar; sucrose; also, in general, any one of the group of which saccharose, or sucrose proper, is the type.","pos":""}],"SACCHARUM":[{"def":"A genus of tall tropical grasses including the sugar cane.","pos":""}],"SACCHOLACTATE":[{"def":"A salt of saccholactactic acid; -- formerly called also saccholate.","pos":""}],"SACCHOLACTIC":[{"def":"Of, pertaining to, or designating, an acid now called mucic acid; saccholic.","pos":""}],"SACCHULMATE":[{"def":"A salt of sacchulmic acid.","pos":""}],"SACCHULMIC":[{"def":"Of, pertaining to, or designating, an acid obtained as a dark amorphous substance by the long-continued boiling of sucrose with very dilute sulphuric acid.","pos":""}],"SACCHULMIN":[{"def":"An amorphous huminlike substance resembling sacchulmic acid, and produced together with it.","pos":""}],"SACCIFORM":[{"def":"Having the general form of a sac.","pos":""}],"SACCOGLOSSA":[{"def":"Same as Pellibranchiata.","pos":""}],"SACCULAR":[{"def":"Like a sac; sacciform.","pos":""}],"SACCULATED":[{"def":"Furnished with little sacs.","pos":""}],"SACCULE":[{"def":"A little sac; specifically, the sacculus of the ear.","pos":""}],"SACCULO-COCHLEAR":[{"def":"pertaining to the sacculus and cochlea of the ear.","pos":""}],"SACCULO-UTRICULAR":[{"def":"Pertaining to the sacculus and utriculus of the ear.","pos":""}],"SACCULUS":[{"def":"A little sac; esp.","pos":""}],"SACERDOTAL":[{"def":"Of or pertaining to priests, or to the order of priests; relating to the priesthood; priesty; as, sacerdotal dignity; sacerdotal functions.","pos":""}],"SACERDOTALISM":[{"def":"The system, style, spirit, or character, of a priesthood, or sacerdotal order; devotion to the interests of the sacerdotal order.","pos":""}],"SACERDOTALLY":[{"def":"In a sacerdotal manner.","pos":""}],"SACHEM":[{"def":"A chief of a tribe of the American Indians; a sagamore.","pos":""}],"SACHEMDOM":[{"def":"The government or jurisdiction of a sachem.","pos":""}],"SACHEMSHIP":[{"def":"Office or condition of a sachem.","pos":""}],"SACHET":[{"def":"A scent bag, or perfume cushion, to be laid among handkerchiefe, garments, etc.","pos":""}],"SACK":[{"def":"A anme formerly given to various dry Spanish wines.","pos":""}],"SACK-WINGED":[{"def":"Having a peculiar pouch developed near the front edge of the wing; -- said of certain bats of the genus Saccopteryx.","pos":""}],"SACKAGE":[{"def":"The act of taking by storm and pillaging; sack.","pos":""}],"SACKBUT":[{"def":"A brass wind instrument, like a bass trumpet, so contrived that it can be lengthened or shortened according to the tone required; -- said to be the same as the trombone.","pos":""}],"SACKCLOTH":[{"def":"Linen or cotton cloth such a sacks are made of; coarse cloth; anciently, a cloth or garment worn in mourning, distress, mortification, or penitence.","pos":""}],"SACKCLOTHED":[{"def":"Clothed in sackcloth.","pos":""}],"SACKER":[{"def":"One who sacks; one who takes part in the storm and pillage of a town.","pos":""}],"SACKFUL":[{"def":"As much as a sack will hold.","pos":""}],"SACKING":[{"def":"Stout, coarse cloth of which sacks, bags, etc.","pos":""}],"SACKLESS":[{"def":"Quiet; peaceable; harmless; innocent.","pos":""}],"SACQUE":[{"def":"Same as 2d Sack, 3.","pos":""}],"SACRAL":[{"def":"Of or pertaining to the sacrum; in the region of the sacrum.","pos":""}],"SACRAMENT":[{"def":"One of the solemn religious ordinances enjoined by Christ, the head of the Christian church, to be observed by his followers; hence, specifically, the eucharist; the Lord's Supper.","pos":""}],"SACRAMENTAL":[{"def":"Of or pertaining to a sacrament or the sacraments; of the nature of a sacrament; sacredly or solemny binding; as, sacramental rites or elements.","pos":""},{"def":"Bound by a sacrament.","pos":""}],"SACRAMENTALISM":[{"def":"The doctrine and use of sacraments; attashment of excessive importance to sacraments.","pos":""}],"SACRAMENTALIST":[{"def":"One who holds the doctrine of the real objective presence of Christ;s body and blood in the holy eucharist.","pos":""}],"SACRAMENTALLY":[{"def":"In a sacrament manner.","pos":""}],"SACRAMENTARIAN":[{"def":"A name given in the sixteenth century to those German reformers who rejected both the Roman and the Lutheran doctrine of the holy eucharist.","pos":""}],"SACRAMENTARY":[{"def":"Of or pertaining a sacrament or the sacraments; sacramental.","pos":""},{"def":"Of or pertaining to the Sacramentarians.","pos":""}],"SACRAMENTIZE":[{"def":"To administer the sacraments.","pos":""}],"SACRARIUM":[{"def":"A sort of family chapel in the houses of the Romans, devoted to a special divinity.","pos":""},{"def":"The adytum of a temple.","pos":""}],"SACRE":[{"def":"To consecrate; to make sacred.","pos":""}],"SACRED":[{"def":"Employed in sacrifice.","pos":""}],"SACRIFICABLE":[{"def":"Capable of being offered in sacrifice.","pos":""}],"SACRIFICANT":[{"def":"One who offers a sacrifice.","pos":""}],"SACRIFICATOR":[{"def":"A sacrificer; one who offers a sacrifice.","pos":""}],"SACRIFICATORY":[{"def":"Offering sacrifice.","pos":""}],"SACRIFICE":[{"def":"The offering of anything to God, or to a god; consecratory rite.","pos":""},{"def":"Anything consecrated and offered to God, or to a divinity; an immolated victin, or an offering of any kind, laid upon an altar, or otherwise presented in the way of religious thanksgiving, atonement, or conciliation.","pos":""}],"SACRIFICER":[{"def":"One who sacrifices.","pos":""}],"SACRIFICIAL":[{"def":"Of or pertaining to sacrifice or sacrifices; consisting in sacrifice; performing sacrifice.","pos":""}],"SACRILEGE":[{"def":"The sin or crime of violating or profaning sacred things; the alienating to laymen, or to common purposes, what has been appropriated or consecrated to religious persons or uses.","pos":""}],"SACRILEGIOUS":[{"def":"Violating sacred things; polluted with sacrilege; involving sacrilege; profane; impious.","pos":""}],"SACRILEGIST":[{"def":"One guilty of sacrilege.","pos":""}],"SACRIST":[{"def":"A sacristan; also, a person retained in a cathedral to copy out music for the choir, and take care of the books.","pos":""}],"SACRISTAN":[{"def":"An officer of the church who has the care of the utensils or movables, and of the church in general; a sexton.","pos":""}],"SACRISTY":[{"def":"A apartment in a church where the sacred utensils, vestments, etc.","pos":""}],"SACRO-":[{"def":"A combining form denoting connection with, or relation to, the sacrum, as in sacro-coccyageal, sacro-iliac, sacrosciatic.","pos":""}],"SACROSANCT":[{"def":"Sacred; inviolable.","pos":""}],"SACROSCIATIC":[{"def":"Of or pertaining to both the sacrum and the hip; as, the sacrosciatic formina formed by the sacrosciatic ligaments which connect the sacrum and hip bone.","pos":""}],"SACROVERTEBRAL":[{"def":"Of or pertaining to the sacrum and that part of the vertebral column immediately anterior to it; as, the sacrovertebral angle.","pos":""}],"SACRUM":[{"def":"That part of the vertebral column which is directly connected with, or forms a part of, the pelvis.","pos":""}],"SACS":[{"def":"A tribe of Indians, which, together with the Foxes, formerly occupied the region about Green Bay, Wisconsin.","pos":""}]}