{"DUR":[{"def":"Major; in the major mode; as, C dur, that is, C major.","pos":""}],"DURA":[{"def":"Short form for Dura mater.","pos":""}],"DURA MATER":[{"def":"The tough, fibrous membrane, which lines the cavity of the skull and spinal column, and surrounds the brain and spinal cord; -- frequently abbreviated to dura.","pos":""}],"DURABILITY":[{"def":"The state or quality of being durable; the power of uninterrupted or long continuance in any condition; the power of resisting agents or influences which tend to cause changes, decay, or dissolution; lastingness.","pos":""}],"DURABLE":[{"def":"Able to endure or continue in a particular condition; lasting; not perishable or changeable; not wearing out or decaying soon; enduring; as, durable cloth; durable happiness.","pos":""}],"DURABLENESS":[{"def":"Power of lasting, enduring, or resisting; durability.","pos":""}],"DURABLY":[{"def":"In a lasting manner; with long continuance.","pos":""}],"DURAL":[{"def":"Pertaining to the dura, or dura mater.","pos":""}],"DURAMEN":[{"def":"The heartwood of an exogenous tree.","pos":""}],"DURANCE":[{"def":"Continuance; duration.","pos":""},{"def":"Imprisonment; restraint of the person; custody by a jailer; duress.","pos":""}],"DURANTE":[{"def":"During; as, durante vita, during life; durante bene placito, during pleasure.","pos":""}],"DURATION":[{"def":"The state or quality of lasting; continuance in time; the portion of time during which anything exists.","pos":""}],"DURATIVE":[{"def":"Continuing; not completed; implying duration.","pos":""}],"DURBAR":[{"def":"An audience hall; the court of a native prince; a state levee; a formal reception of native princes, given by the governor general of India.","pos":""}],"DURE":[{"def":"Hard; harsh; severe; rough; toilsome.","pos":""}],"DURENE":[{"def":"A colorless, crystalline, aromatic hydrocarbon, C6H2(CH3)4, off artificial production, with an odor like camphor.","pos":""}],"DURESS":[{"def":"The state of compulsion or necessity in which a person is influenced, whether by the unlawful restrain of his liberty or by actual or threatened physical violence, to incur a civil liability or to commit an offense.","pos":""}],"DURESSOR":[{"def":"One who subjects another to duress Bacon.","pos":""}],"DURHAM":[{"def":"One or a breed of short-horned cattle, originating in the county of Durham, England.","pos":""},{"def":"The fruit of the durio.","pos":""}],"DURING":[{"def":"In the time of; as long as the action or existence of; as, during life; during the space of a year.","pos":""}],"DURIO":[{"def":"A fruit tree (D.","pos":""}],"DURITY":[{"def":"Hardness; firmness.","pos":""},{"def":"Harshness; cruelty.","pos":""}],"DUROMETER":[{"def":"An instrument for measuring the degree of hardness; especially, an instrument for testing the relative hardness of steel rails and the like.","pos":""}],"DURRA":[{"def":"A kind of millet, cultivated throughout Asia, and introduced into the south of Europe; a variety of Sorghum vulgare; -- called also Indian millet, and Guinea corn.","pos":""}],"DURUKULI":[{"def":"A small, nocturnal, South American monkey (Nyctipthecus trivirgatus).","pos":""}],"DURYLIC":[{"def":"Pertaining to, allied to, or derived from, durene; as, durylic acid.","pos":""}]}