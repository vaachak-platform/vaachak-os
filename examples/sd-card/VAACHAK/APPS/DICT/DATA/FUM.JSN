{"FUM":[{"def":"To play upon a fiddle.","pos":""}],"FUMACIOUS":[{"def":"Smoky; hence, fond of smoking; addicted to smoking tobacco.","pos":""},{"def":"A salted and smoked fish, as the pilchard.","pos":""}],"FUMAGE":[{"def":"Fumage, or fuage, vulgarly called smoke farthings.","pos":""}],"FUMARATE":[{"def":"A salt of fumaric acid.","pos":""}],"FUMARIC":[{"def":"Pertaining to, or derived from, fumitory (Fumaria officinalis).","pos":""}],"FUMARINE":[{"def":"An alkaloid extracted from fumitory, as a white crystalline substance.","pos":""}],"FUMAROLE":[{"def":"A hole or spot in a volcanic or other region, from which fumes issue.","pos":""}],"FUMATORIUM":[{"def":"An air-tight compartment in which vapor may be generated to destroy germs or insects; esp.","pos":""}],"FUMBLE":[{"def":"To feel or grope about; to make awkward attempts to do or find something.","pos":""},{"def":"To grope about in perplexity; to seek awkwardly; as, to fumble for an excuse.","pos":""}],"FUMBLER":[{"def":"One who fumbles.","pos":""}],"FUMBLINGLY":[{"def":"In the manner of one who fumbles.","pos":""}],"FUME":[{"def":"Exhalation; volatile matter (esp.","pos":""},{"def":"Rage or excitement which deprives the mind of self-control; as, the fumes of passion.","pos":""}],"FUMED OAK":[{"def":"Oak given a weathered appearance by exposure in an air-tight compartment to fumes of ammonia from uncorked cans, being first given a coat of filler.","pos":""}],"FUMELESS":[{"def":"Free from fumes.","pos":""}],"FUMER":[{"def":"One who makes or uses perfumes.","pos":""}],"FUMET":[{"def":"The dung of deer.","pos":""},{"def":"The stench or high flavor of game or other meat when kept long.","pos":""}],"FUMID":[{"def":"Smoky; vaporous.","pos":""},{"def":"The state of being fumid; smokiness.","pos":""}],"FUMIFEROUS":[{"def":"Producing smoke.","pos":""}],"FUMIFUGIST":[{"def":"One who, or that which, drives away smoke or fumes.","pos":""}],"FUMIFY":[{"def":"To subject to the action of smoke.","pos":""}],"FUMIGATE":[{"def":"To apply smoke to; to expose to smoke or vapor; to purify, or free from infection, by the use of smoke or vapors.","pos":""},{"def":"To smoke; to perfume.","pos":""}],"FUMIGATION":[{"def":"The act of fumigating, or applying smoke or vapor, as for disinfection.","pos":""},{"def":"Vapor raised in the process of fumigating.","pos":""}],"FUMIGATOR":[{"def":"One who, or that which, fumigates; an apparattus for fumigating.","pos":""}],"FUMIGATORY":[{"def":"Having the quality of purifying by smoke.","pos":""}],"FUMILY":[{"def":"Smokily; with fume.","pos":""}],"FUMING":[{"def":"Producing fumes, or vapors.","pos":""}],"FUMINGLY":[{"def":"In a fuming manner; angrily.","pos":""}],"FUMISH":[{"def":"Smoky; hot; choleric.","pos":""}],"FUMISHNESS":[{"def":"Choler; fretfulness; passion.","pos":""}],"FUMITORY":[{"def":"The common uame of several species of the genus Fumaria, annual herbs of the Old World, with finely dissected leaves and small flowers in dense racemes or spikes.","pos":""}],"FUMOSITY":[{"def":"The fumes of drink.","pos":""}],"FUMOUS":[{"def":"Producing smoke; smoky.","pos":""},{"def":"Producing fumes; full of fumes.","pos":""}],"FUMY":[{"def":"Producing fumes; fumous.","pos":""}]}