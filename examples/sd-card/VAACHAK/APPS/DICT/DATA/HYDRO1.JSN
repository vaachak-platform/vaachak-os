{"HYDRO-AEROPLANE":[{"def":"An aëroplane with a boatlike or other understructure that enables it to travel on, or to rise from the surface of, a body of water by its own motive power.","pos":""}],"HYDRO-ELECTRIC":[{"def":"Pertaining to, employed in, or produced by, the evolution of electricity by means of a battery in which water or steam is used.","pos":""}],"HYDRO-EXTRACTOR":[{"def":"An apparatus for drying anything, as yarn, cloth, sugar, etc.","pos":""}],"HYDROBAROMETER":[{"def":"An instrument for determining the depth of the sea water by its pressure.","pos":""}],"HYDROBILIRUBIN":[{"def":"A body formed from bilirubin, identical with urobilin.","pos":""}],"HYDROBIPLANE":[{"def":"A hydro-aëroplane having two supporting planes.","pos":""}],"HYDROBRANCHIATA":[{"def":"An extensive artificial division of gastropod mollusks, including those that breathe by gills, as contrasted with the Pulmonifera.","pos":""}],"HYDROBROMATE":[{"def":"Same as Hydrobromide.","pos":""}],"HYDROBROMIC":[{"def":"Composed of hydrogen and bromine; as, hydrobromic acid.","pos":""}],"HYDROBROMIDE":[{"def":"A compound of hydrobromic acid with a base; -- distinguished from a bromide, in which only the bromine unites with the base.","pos":""}],"HYDROCARBON":[{"def":"A compound containing only hydrogen and carbon, as methane, benzene, etc.","pos":""}],"HYDROCARBONACEOUS":[{"def":"Of the nature, or containing, hydrocarbons.","pos":""}],"HYDROCARBONATE":[{"def":"Hy`dro*car\"bon*ate, n.","pos":""}],"HYDROCARBOSTYRIL":[{"def":"A white, crystalline, nitrogenous hydrocarbon, C9H9NO, obtained from certain derivatives of cinnamic acid and closely related to quinoline and carbostyril.","pos":""}],"HYDROCARBURET":[{"def":"Carbureted hydrogen; also, a hydrocarbon.","pos":""}],"HYDROCAULUS":[{"def":"The hollow stem of a hydroid, either simple or branched.","pos":""}],"HYDROCELE":[{"def":"A collection of serous fluid in the areolar texture of the scrotum or in the coverings, especially in the serous sac, investing the testicle or the spermatic cord; dropsy of the testicle.","pos":""}],"HYDROCEPHALIC":[{"def":"Relating to, or connected with, hydrocephalus, or dropsy of the brain.","pos":""}],"HYDROCEPHALOID":[{"def":"Resembling hydrocephalus.","pos":""}],"HYDROCEPHALOUS":[{"def":"Having hydrocephalus.","pos":""}],"HYDROCEPHALUS":[{"def":"An accumulation of liquid within the cavity of the cranium, especially within the ventricles of the brain; dropsy of the brain.","pos":""}],"HYDROCHLORATE":[{"def":"Same as Hydrochloride.","pos":""}],"HYDROCHLORIC":[{"def":"Pertaining to, or compounded of, chlorine and hydrogen gas; as, hydrochloric acid; chlorhydric.","pos":""}],"HYDROCHLORIDE":[{"def":"A compound of hydrochloric acid with a base; -- distinguished from a chloride, where only chlorine unites with the base.","pos":""}],"HYDROCORALLIA":[{"def":"A division of Hydroidea, including those genera that secrete a stony coral, as Millepora and Stylaster.","pos":""}],"HYDROCYANATE":[{"def":"See Hydrocyanide.","pos":""}],"HYDROCYANIC":[{"def":"Pertaining to, or derived from the combination of, hydrogen and cyanogen.","pos":""}],"HYDROCYANIDE":[{"def":"A compound of hydrocyanic acid with a base; -- distinguished from a cyanide, in which only the cyanogen so combines.","pos":""},{"def":"Pertaining to, or derived from, the dynamical action of water of a liquid; of or pertaining to water power.","pos":""}],"HYDRODYNAMICS":[{"def":"That branch of the science of mechanics which relates to fluids, or, as usually limited, which treats of the laws of motion and action of nonelastic fluids, whether as investigated mathematically, or by observation and experiment; the principles of dynamics, as applied to water and other fluids.","pos":""}],"HYDRODYNAMOMETER":[{"def":"An instrument to measure the velocity of a liquid current by the force of its impact.","pos":""}],"HYDROFERRICYANIC":[{"def":"Pertaining to, or containing, or obtained from, hydrogen, ferric iron, and cyanogen; as, hydroferricyanic acid.","pos":""}],"HYDROFERROCYANIC":[{"def":"Pertaining to, or containing, or obtained from, hydrogen, ferrous iron, and cyanogen; as, hydroferrocyanic acid.","pos":""}],"HYDROFLUATE":[{"def":"A supposed compound of hydrofluoris acid and a base; a fluoride.","pos":""}],"HYDROFLUORIC":[{"def":"Pertaining to, or containing, hydrogen and fluorine; fluohydric; as, hydrofluoric acid.","pos":""}],"HYDROFLUOSILICATE":[{"def":"A salt of hydrofluosilic acid; a silicofluoride.","pos":""}],"HYDROFLUOSILICIC":[{"def":"Pertaining to, or denoting, a compound consisting of a double fluoride of hydrogen and silicon; silicofluoric.","pos":""}],"HYDROGALVANIC":[{"def":"Pertaining to, produced by, or consisting of, electricity evolved by the action or use of fluids; as, hydrogalvanic currents.","pos":""}],"HYDROGEN":[{"def":"A gaseous element, colorless, tasteless, and odorless, the lightest known substance, being fourteen and a half times lighter than air (hence its use in filling balloons), and over eleven thousand times lighter than water.","pos":""}],"HYDROGENATION":[{"def":"The act of combining with hydrogen, or the state of being so combined.","pos":""}],"HYDROGENIDE":[{"def":"A binary compound containing hydrogen; a hydride.","pos":""}],"HYDROGENIUM":[{"def":"Hydrogen; -- called also in view of its supposed metallic nature.","pos":""}],"HYDROGENIZE":[{"def":"To combine with hydrogen; to treat with, or subject to the action of, hydrogen; to reduce; -- contrasted with oxidize.","pos":""}],"HYDROGENOUS":[{"def":"Of or pertaining to hydrogen; containing hydrogen.","pos":""}],"HYDROGNOSY":[{"def":"A treatise upon, or a history and description of, the water of the earth.","pos":""}],"HYDROGODE":[{"def":"The negative pole or cathode.","pos":""}],"HYDROGRAPHER":[{"def":"One skilled in the hydrography; one who surveys, or draws maps or charts of, the sea, lakes, or other waters, with the adjacent shores; one who describes the sea or other waters.","pos":""},{"def":"Of or relating to hydrography.","pos":""}],"HYDROGRAPHY":[{"def":"The art of measuring and describing the sea, lakes, rivers, and other waters, with their phenomena.","pos":""},{"def":"That branch of surveying which embraces the determination of the contour of the bottom of a harbor or other sheet of water, the depth of soundings, the position of channels and shoals, with the construction of charts exhibiting these particulars.","pos":""}],"HYDROID":[{"def":"Related to, or resembling, the hydra; of or pertaining to the Hydroidea.","pos":""},{"def":"One of the Hydroideas.","pos":""}],"HYDROIDEA":[{"def":"An extensive order of Hydrozoa or Acalephæ.","pos":""}],"HYDROKINETIC":[{"def":"Of or pertaining to the motions of fluids, or the forces which produce or affect such motions; -- opposed to hydrostatic.","pos":""}],"HYDROLOGICAL":[{"def":"Of or pertaining to hydrology.","pos":""}],"HYDROLOGIST":[{"def":"One skilled in hydrology.","pos":""}],"HYDROLOGY":[{"def":"The science of water, its properties, phenomena, and distribution over the earth's surface.","pos":""}],"HYDROLYSIS":[{"def":"A chemical process involving the addition of the elements of water.","pos":""}],"HYDROLYTIC":[{"def":"Tending to remove or separate water; eliminating water.","pos":""}],"HYDROMAGNESITE":[{"def":"A hydrous carbonate of magnesia occurring in white, early, amorphous masses.","pos":""}],"HYDROMANCY":[{"def":"Divination by means of water, -- practiced by the ancients.","pos":""}],"HYDROMANTIC":[{"def":"Of or pertaining to divination by water.","pos":""}],"HYDROMECHANICS":[{"def":"That branch of physics which treats of the mechanics of liquids, or of their laws of equilibrium and of motion.","pos":""}],"HYDROMEDUSA":[{"def":"Any medusa or jellyfish which is produced by budding from a hydroid.","pos":""}],"HYDROMEL":[{"def":"A liquor consisting of honey diluted in water, and after fermentation called mead.","pos":""}],"HYDROMETALLURGICAL":[{"def":"Of or pertaining to hydrometallurgy; involving the use of liquid reagents in the treatment or reduction of ores.","pos":""}],"HYDROMETALLURGY":[{"def":"The art or process of assaying or reducing ores by means of liquid reagents.","pos":""}],"HYDROMETEOR":[{"def":"A meteor or atmospheric phenomenon dependent upon the vapor of water; -- in the pl.","pos":""}],"HYDROMETEOROLOGICAL":[{"def":"Of or pertaining to hydrometeorology, or to rain, clouds, storms, etc.","pos":""}],"HYDROMETEOROLOGY":[{"def":"That branch of meteorology which relates to, or treats of, water in the atmosphere, or its phenomena, as rain, clouds, snow, hail, storms, etc.","pos":""}],"HYDROMETER":[{"def":"An instrument for determining the specific gravities of liquids, and thence the strength spirituous liquors, saline solutions, etc.","pos":""}],"HYDROMETROGRAPH":[{"def":"An instrument for determining and recording the quantity of water discharged from a pipe, orifice, etc.","pos":""}],"HYDROMETRY":[{"def":"The art of determining the specific gravity of liquids, and thence the strength of spirituous liquors, saline solutions, etc.","pos":""},{"def":"The art or operation of measuring the velocity or discharge of running water, as in rivers, etc.","pos":""}],"HYDROMICA":[{"def":"A variety of potash mica containing water.","pos":""}],"HYDRONEPHROSIS":[{"def":"An accumulation of urine in the pelvis of the kidney, occasioned by obstruction in the urinary passages.","pos":""}],"HYDROPATH":[{"def":"Of or pertaining to hydropathy.","pos":""}],"HYDROPATHIST":[{"def":"One who practices hydropathy; a water-cure doctor.","pos":""}],"HYDROPATHY":[{"def":"The water cure; a mode of treating diseases by the copious and frequent use of pure water, both internally and externally.","pos":""}],"HYDROPERITONEUM":[{"def":"Same as Ascites.","pos":""}],"HYDROPHANE":[{"def":"A semitranslucent variety of opal that becomes translucent or transparent on immersion in water.","pos":""}],"HYDROPHANOUS":[{"def":"Made transparent by immersion in water.","pos":""}],"HYDROPHID":[{"def":"Any sea snake of the genus Hydrophys and allied genera.","pos":""}],"HYDROPHLORONE":[{"def":"A white, crystalline benzene derivative, C8H10O2, obtained by the reduction of phlorone.","pos":""}],"HYDROPHOBIC":[{"def":"Of or pertaining to hydrophobia; producing or caused by rabies; as, hydrophobic symptoms; the hydrophobic poison.","pos":""}],"HYDROPHOBY":[{"def":"See Hydrophobia.","pos":""}],"HYDROPHORE":[{"def":"An instrument used for the purpose of obtaining specimens of water from any desired depth, as in a river, a lake, or the ocean.","pos":""}],"HYDROPHYLLIUM":[{"def":"One of the flat, leaflike, protective zooids, covering other zooids of certain Siphonophora.","pos":""}],"HYDROPHYTE":[{"def":"An aquatic plant; an alga.","pos":""}],"HYDROPHYTOLOGY":[{"def":"The branch of botany which treats of water plants.","pos":""},{"def":"Dropsical, or resembling dropsy.","pos":""}],"HYDROPICALLY":[{"def":"In a hydropical manner.","pos":""}],"HYDROPIPER":[{"def":"A species (Polygonum Hydropiper) of knotweed with acrid foliage; water pepper; smartweed.","pos":""}],"HYDROPLANE":[{"def":"A plane, or any of a number of planes, projecting from the hull of a submarine boat, which by being elevated or depressed cause the boat, when going ahead, to sink or rise, after the manner of an aëroplane.","pos":""},{"def":"A projecting plane or fin on a gliding boat to lift the moving boat on top of the water; also, a gliding boat.","pos":""}],"HYDROPNEUMATIC":[{"def":"Pertaining to, or depending upon, both liquid and gaseous substances; as, hydropneumatic apparatus for collecting gases over water or other liquids.","pos":""},{"def":"A disappearing gun carriage in which the recoil is checked by cylinders containing liquid and air, the air when compressed furnishing the power for restoring the gun to the firing position.","pos":""}],"HYDROPULT":[{"def":"A machine for throwing water by hand power, as a garden engine, a fire extinguisher, etc.","pos":""}],"HYDROQUINONE":[{"def":"A white crystalline substance, C6H4(OH)2, obtained by the reduction of quinone.","pos":""}],"HYDRORHIZA":[{"def":"The rootstock or decumbent stem by which a hydroid is attached to other objects.","pos":""}],"HYDROSCOPE":[{"def":"All the zooids of a hydroid colony collectively, including the nutritive and reproductive zooids, and often other kinds.","pos":""}],"HYDROSORBIC":[{"def":"Pertaining to, or designating, an acid obtained from sorbic acid when this takes up hydrogen; as, hydrosorbic acid.","pos":""}],"HYDROSPHERE":[{"def":"The aqueous vapor of the entire atmosphere.","pos":""}],"HYDROSTAT":[{"def":"A contrivance or apparatus to prevent the explosion of steam boilers.","pos":""},{"def":"Of or relating to hydrostatics; pertaining to, or in accordance with, the principles of the equilibrium of fluids.","pos":""}],"HYDROSTATICALLY":[{"def":"According to hydrostatics, or to hydrostatic principles.","pos":""}],"HYDROSTATICIAN":[{"def":"One who is versed or skilled in hydrostatics.","pos":""}],"HYDROSTATICS":[{"def":"The branch of science which relates to the pressure and equilibrium of nonelastic fluids, as water, mercury, etc.","pos":""}],"HYDROSULPHATE":[{"def":"Same as Hydrosulphurent.","pos":""}],"HYDROSULPHIDE":[{"def":"One of a series of compounds, derived from hydrogen sulphide by the replacement of half its hydrogen by a base or basic radical; as, potassium hydrosulphide, KSH.","pos":""}],"HYDROSULPHITE":[{"def":"A saline compound of hydrosulphurous acid and a base.","pos":""}],"HYDROSULPHURET":[{"def":"A hydrosulphide.","pos":""}],"HYDROSULPHURETED":[{"def":"Combined with hydrogen sulphide.","pos":""}],"HYDROSULPHURIC":[{"def":"Pertaining to, or derived from, hydrogen and sulphur; as, hydrosulphuricacid, a designation applied to the solution of hydrogen sulphide in water.","pos":""}],"HYDROSULPHUROUS":[{"def":"Pertaining to, or designating, an acid obtained by the reduction of sulphurous acid.","pos":""}],"HYDROTELLURATE":[{"def":"A salt formed by the union of hydrotelluric acid and the base.","pos":""}],"HYDROTELLURIC":[{"def":"Formed by hydrogen and tellurium; as, hydrotelluric acid, or hydrogen telluride.","pos":""}],"HYDROTHECA":[{"def":"One of the calicles which, in some Hydroidea (Thecaphora), protect the hydrants.","pos":""}]}