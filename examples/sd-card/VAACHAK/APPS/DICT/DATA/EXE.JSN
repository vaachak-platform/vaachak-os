{"EXEAT":[{"def":"A license for absence from a college or a religious house.","pos":""},{"def":"A permission which a bishop grants to a priest to go out of his diocese.","pos":""}],"EXECRABLE":[{"def":"Deserving to be execrated; accursed; damnable; detestable; abominable; as, an execrable wretch.","pos":""}],"EXECRATE":[{"def":"To denounce evil against, or to imprecate evil upon; to curse; to protest against as unholy or detestable; hence, to detest utterly; to abhor; to abominate.","pos":""}],"EXECRATION":[{"def":"The act of cursing; a curse dictated by violent feelings of hatred; imprecation; utter detestation expressed.","pos":""},{"def":"That which is execrated; a detested thing.","pos":""}],"EXECRATIVE":[{"def":"Cursing; imprecatory; vilifying.","pos":""}],"EXECRATORY":[{"def":"Of the nature of execration; imprecatory; denunciatory.","pos":""},{"def":"A formulary of execrations.","pos":""}],"EXECT":[{"def":"To cut off or out.","pos":""}],"EXECUTABLE":[{"def":"Capable of being executed; feasible; as, an executable project.","pos":""}],"EXECUTANT":[{"def":"One who executes or performs; esp.","pos":""}],"EXECUTE":[{"def":"To perform, as a piece of music, either on an instrument or with the voice; as, to execute a difficult part brilliantly.","pos":""}],"EXECUTER":[{"def":"One who performs or carries into effect.","pos":""}],"EXECUTION":[{"def":"The act of executing; a carrying into effect or to completion; performance; achievement; consummation; as, the execution of a plan, a work, etc.","pos":""},{"def":"A putting to death as a legal penalty; death lawfully inflicted; as, the execution of a murderer.","pos":""}],"EXECUTIONER":[{"def":"One who executes; an executer.","pos":""},{"def":"One who puts to death in conformity to legal warrant, as a hangman.","pos":""}],"EXECUTIVE":[{"def":"Designed or fitted for execution, or carrying into effect; as, executive talent; qualifying for, concerned with, or pertaining to, the execution of the laws or the conduct of affairs; as, executive power or authority; executive duties, officer, department, etc.","pos":""}],"EXECUTIVELY":[{"def":"In the way of executing or performing.","pos":""}],"EXECUTOR":[{"def":"The person appointed by a Executor de son tort Etym: [Of.","pos":""}],"EXECUTORIAL":[{"def":"Of or pertaining to an executive.","pos":""}],"EXECUTORSHIP":[{"def":"The office of an executor.","pos":""}],"EXECUTORY":[{"def":"Designed to be executed or carried into effect in time to come, or to take effect on a future contingency; as, an executory devise, reminder, or estate; an executory contract.","pos":""}],"EXECUTRIX":[{"def":"A woman exercising the functions of an executor.","pos":""}],"EXEDENT":[{"def":"Eating out; consuming.","pos":""}],"EXEDRA":[{"def":"A room in a public building, furnished with seats.","pos":""}],"EXEGESIS":[{"def":"The process of finding the roots of an equation.","pos":""}],"EXEGETE":[{"def":"Pertaining to exegesis; tending to unfold or illustrate; explanatory; expository.","pos":""}],"EXEGETICS":[{"def":"The science of interpretation or exegesis.","pos":""}],"EXEGETIST":[{"def":"One versed in the science of exegesis or interpretation; -- also called exegete.","pos":""}],"EXEMPLAR":[{"def":"A model, original, or pattern, to be copied or imitated; a specimen; sometimes; an ideal model or type, as that which an artist conceives.","pos":""},{"def":"A copy of a book or writing.","pos":""}],"EXEMPLARILY":[{"def":"In a manner fitted or designed to be an example for imitation or for warning; by way of example.","pos":""}],"EXEMPLARINESS":[{"def":"The state or quality of being exemplary; fitness to be an example.","pos":""}],"EXEMPLARITY":[{"def":"The exemplarity of Christ's life.","pos":""}],"EXEMPLARY":[{"def":"Serving as a pattern; deserving to be proposed for imitation; commendable; as, an exemplary person; exemplary conduct.","pos":""},{"def":"Serving as a warning; monitory; as, exemplary justice, punishment, or damages.","pos":""}],"EXEMPLIFIABLE":[{"def":"That can be exemplified.","pos":""}],"EXEMPLIFICATION":[{"def":"A copy or transcript attested to be correct by the seal of an officer having custody of the original.","pos":""}],"EXEMPLIFIER":[{"def":"One who exemplifies by following a pattern.","pos":""}],"EXEMPLIFY":[{"def":"To show or illustrate by example.","pos":""},{"def":"To copy; to transcribe; to make an attested copy or transcript of, under seal, as of a record.","pos":""}],"EXEMPT":[{"def":"Cut off; set apart.","pos":""},{"def":"Extraordinary; exceptional.","pos":""}],"EXEMPTIBLE":[{"def":"That may be exempted.","pos":""}],"EXEMPTION":[{"def":"The act of exempting; the state of being exempt; freedom from any charge, burden, evil, etc.","pos":""}],"EXENTERATE":[{"def":"To take out the bowels or entrails of; to disembowel; to eviscerate; as, exenterated fishes.","pos":""}],"EXENTERATION":[{"def":"Act of exenterating.","pos":""}],"EXEQUATUR":[{"def":"A written official recognition of a consul or commercial agent, issued by the government to which he is accredited, and authorizing him to exercise his powers in the place to which he is assigned.","pos":""},{"def":"Official recognition or permission.","pos":""}],"EXEQUIAL":[{"def":"Of or pertaining to funerals; funereal.","pos":""}],"EXEQUY":[{"def":"A funeral rite (usually in the plural); the ceremonies of burial; obsequies; funeral procession.","pos":""}],"EXERCENT":[{"def":"Practicing; professional.","pos":""}],"EXERCISABLE":[{"def":"That may be exercised, used, or exerted.","pos":""}],"EXERCISE":[{"def":"The act of exercising; a setting in action or practicing; employment in the proper mode of activity; exertion; application; use; habitual activity; occupation, in general; practice.","pos":""},{"def":"Exertion for the sake of training or improvement whether physical, intellectual, or moral; practice to acquire skill, knowledge, virtue, perfectness, grace, etc.","pos":""}],"EXERCISER":[{"def":"One who exercises.","pos":""}],"EXERCISIBLE":[{"def":"Capable of being exercised, employed, or enforced; as, the authority of a magistrate is exercisible within his jurisdiction.","pos":""}],"EXERCITATION":[{"def":"exercise; practice; use.","pos":""}],"EXERGUE":[{"def":"The small space beneath the base line of a subject engraved on a coin or medal.","pos":""}],"EXERT":[{"def":"To thrust forth; to emit; to push out.","pos":""},{"def":"To put force, ability, or anything of the nature of an active faculty; to put in vigorous action; to bring into active operation; as, to exert the strength of the body, limbs, faculties, or imagination; to exert the mind or the voice.","pos":""}],"EXERTION":[{"def":"The act of exerting, or putting into motion or action; the active exercise of any power or faculty; an effort, esp.","pos":""}],"EXERTIVE":[{"def":"Having power or a tendency to exert; using exertion.","pos":""}],"EXESION":[{"def":"The act of eating out or through.","pos":""}],"EXESTUATE":[{"def":"To be agitated; to boil up; to effervesce.","pos":""}],"EXESTUATION":[{"def":"A boiling up; effervescence.","pos":""}],"EXEUNT":[{"def":"They go out, or retire from the scene; as, exeunt all except Hamlet.","pos":""}]}