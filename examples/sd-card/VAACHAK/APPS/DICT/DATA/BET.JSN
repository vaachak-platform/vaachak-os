{"BET":[{"def":"That which is laid, staked, or pledged, as between two parties, upon the event of a contest or any contingent issue; the act of giving such a pledge; a wager.","pos":""}],"BETA":[{"def":"The second letter of the Greek alphabet, B, b.","pos":""},{"def":"Excessive or extended use of the b sound in speech, due to conversion of other sounds into it, as through inability to distinguish them from b, or because of difficulty in pronouncing them.","pos":""}],"BETA RAYS":[{"def":"Penetrating rays readily deflected by a magnetic or electric field, emitted by radioactive substances, as radium.","pos":""}],"BETAINE":[{"def":"A nitrogenous base, C5H11NO2, produced artificially, and also occurring naturally in beetroot molasses and its residues, from which it is extracted as a white crystalline substance; -- called also lycine and oxyneurine.","pos":""}],"BETAKE":[{"def":"To take or seize.","pos":""},{"def":"To have recourse to; to apply; to resort; to go; -- with a reflexive pronoun.","pos":""}],"BETAUGHT":[{"def":"Delivered; committed in trust.","pos":""}],"BETE":[{"def":"To better; to mend.","pos":""}],"BETE NOIRE":[{"def":"Something especially hated or dreaded; a bugbear.","pos":""}],"BETEELA":[{"def":"An East India muslin, formerly used for cravats, veils, etc.","pos":""}],"BETEEM":[{"def":"To give ; to bestow; to grant; to accord; to consent.","pos":""},{"def":"To allow; to permit; to suffer.","pos":""}],"BETEL":[{"def":"A species of pepper (Piper betle), the leaves of which are chewed, with the areca or betel nut and a little shell lime, by the inhabitants of the East Indies.","pos":""}],"BETEL NUT":[{"def":"The nutlike seed of the areca palm, chewed in the East with betel leaves (whence its name) and shell lime.","pos":""}],"BETELGUESE":[{"def":"A bright star of the first magnitude, near one shoulder of Orion.","pos":""}],"BETHABARA WOOD":[{"def":"A highly elastic wood, used for fishing rods, etc.","pos":""}],"BETHEL":[{"def":"A place of worship; a hallowed spot.","pos":""},{"def":"A chapel for dissenters.","pos":""}],"BETHINK":[{"def":"To call to mind; to recall or bring to recollection, reflection, or consideration; to think; to consider; -- generally followed by a reflexive pronoun, often with of or that before the subject of thought.","pos":""}],"BETHLEHEM":[{"def":"In the Ethiopic church, a small building attached to a church edifice, in which the bread for the eucharist is made.","pos":""}],"BETHOUGHT":[{"def":"Be*thought\", Defn: imp.","pos":""}],"BETHRALL":[{"def":"To reduce to thralldom; to inthrall.","pos":""}],"BETHUMB":[{"def":"To handle; to wear or soil by handling; as books.","pos":""}],"BETHUMP":[{"def":"To beat or thump soundly.","pos":""}],"BETIDE":[{"def":"To happen to; to befall; to come to ; as, woe betide the wanderer.","pos":""}],"BETITLE":[{"def":"To furnish with a title or titles; to entitle.","pos":""}],"BETOKEN":[{"def":"To signify by some visible object; to show by signs or tokens.","pos":""},{"def":"To foreshow by present signs; to indicate something future by that which is seen or known; as, a dark cloud often betokens a storm.","pos":""}],"BETON":[{"def":"The French name for concrete; hence, concrete made after the French fashion.","pos":""}],"BETONGUE":[{"def":"To attack with the tongue; to abuse; to insult.","pos":""}],"BETONY":[{"def":"A plant of the genus Betonica (Linn.","pos":""}],"BETORN":[{"def":"Torn in pieces; tattered.","pos":""}],"BETOSS":[{"def":"To put in violent motion; to agitate; to disturb; to toss.","pos":""}],"BETRAP":[{"def":"To draw into, or catch in, a trap; to insnare; to circumvent.","pos":""},{"def":"To put trappings on; to clothe; to deck.","pos":""}],"BETRAY":[{"def":"To deliver into the hands of an enemy by treachery or fraud, in violation of trust; to give up treacherously or faithlessly; as, an officer betrayed the city.","pos":""},{"def":"To prove faithless or treacherous to, as to a trust or one who trusts; to be false to; to deceive; as, to betray a person or a cause.","pos":""}],"BETRAYAL":[{"def":"The act or the result of betraying.","pos":""}],"BETRAYER":[{"def":"One who, or that which, betrays.","pos":""}],"BETRIM":[{"def":"To set in order; to adorn; to deck, to embellish; to trim.","pos":""}],"BETROTH":[{"def":"To contract to any one for a marriage; to engage or promise in order to marriage; to affiance; -- used esp.","pos":""},{"def":"To promise to take (as a future spouse); to plight one's troth to.","pos":""}],"BETROTHAL":[{"def":"The act of betrothing, or the fact of being betrothed; a mutual promise, engagement, or contract for a future marriage between the persons betrothed; betrothment; affiance.","pos":""}],"BETROTHMENT":[{"def":"The act of betrothing, or the state of being betrothed; betrothal.","pos":""}],"BETRUST":[{"def":"To trust or intrust.","pos":""}],"BETRUSTMENT":[{"def":"The act of intrusting, or the thing intrusted.","pos":""}],"BETSO":[{"def":"A small brass Venetian coin.","pos":""}],"BETTER":[{"def":"Having good qualities in a greater degree than another; as, a better man; a better physician; a better house; a better air.","pos":""},{"def":"Preferable in regard to rank, value, use, fitness, acceptableness, safety, or in any other respect.","pos":""}],"BETTERMENT":[{"def":"An improvement of an estate which renders it better than mere repairing would do; -- generally used in the plural.","pos":""}],"BETTERNESS":[{"def":"The quality of being better or superior; superiority.","pos":""},{"def":"The difference by which fine gold or silver exceeds in fineness the standard.","pos":""}],"BETTONG":[{"def":"A small, leaping Australian marsupial of the genus Bettongia; the jerboa kangaroo.","pos":""}],"BETTOR":[{"def":"One who bets; a better.","pos":""}],"BETTY":[{"def":"A short bar used by thieves to wrench doors open.","pos":""},{"def":"A name of contempt given to a man who interferes with the duties of women in a household, or who occupies himself with womanish matters.","pos":""}],"BETULIN":[{"def":"A substance of a resinous nature, obtained from the outer bark of the common European birch (Betula alba), or from the tar prepared therefrom; -- called also birch camphor.","pos":""}],"BETUMBLE":[{"def":"To throw into disorder; to tumble.","pos":""}],"BETUTOR":[{"def":"To tutor; to instruct.","pos":""}],"BETWEEN":[{"def":"In the space which separates; betwixt; as, New York is between Boston and Philadelphia.","pos":""},{"def":"Used in expressing motion from one body or place to another; from one to another of two.","pos":""}],"BETWIXT":[{"def":"In the space which separates; between.","pos":""},{"def":"From one to another of; mutually affecting.","pos":""}]}