{"CANE":[{"def":"A walking stick; a staff; -- so called because originally made of one the species of cane.","pos":""},{"def":"A lance or dart made of cane.","pos":""}],"CANEBRAKE":[{"def":"A thicket of canes.","pos":""}],"CANED":[{"def":"Filled with white flakes; mothery; -- said vinegar when containing mother.","pos":""}],"CANELLA":[{"def":"A genus of trees of the order Canellaceæ, growing in the West Indies.","pos":""}],"CANESCENT":[{"def":"Growing white, or assuming a color approaching to white.","pos":""}]}