{"POSE":[{"def":"Standing still, with all the feet on the ground; -- said of the attitude of a lion, horse, or other beast.","pos":""}],"POSED":[{"def":"Firm; determined; fixed.","pos":""}],"POSER":[{"def":"One who, or that which, puzzles; a difficult or inexplicable question or fact.","pos":""},{"def":"A person who poses or attitudizes, esp.","pos":""}]}