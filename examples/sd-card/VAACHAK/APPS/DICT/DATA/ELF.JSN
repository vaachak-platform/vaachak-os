{"ELF":[{"def":"An imaginary supernatural being, commonly a little sprite, much like a fairy; a mythological diminutive spirit, supposed to haunt hills and wild places, and generally represented as delighting in mischievous tricks.","pos":""},{"def":"A very diminutive person; a dwarf.","pos":""}],"ELFIN":[{"def":"Relating to elves.","pos":""}],"ELFISH":[{"def":"Of or relating to the elves; elflike; implike; weird; scarcely human; mischievous, as though caused by elves.","pos":""}],"ELFISHLY":[{"def":"In an elfish manner.","pos":""}],"ELFISHNESS":[{"def":"The quality of being elfish.","pos":""}],"ELFLOCK":[{"def":"Hair matted, or twisted into a knot, as if by elves.","pos":""}]}