{"NOW":[{"def":"At the present time; at this moment; at the time of speaking; instantly; as, I will write now.","pos":""},{"def":"Very lately; not long ago.","pos":""}],"NOWADAYS":[{"def":"In these days; at the present time.","pos":""},{"def":"In no manner or degree; not at all; nowise.","pos":""}],"NOWD":[{"def":"The European gray gurnard (Trigla gurnardus).","pos":""}],"NOWED":[{"def":"Knotted; tied in a knot, as a serpent.","pos":""}],"NOWEL":[{"def":"A kind of hymn, or canticle, of mediæval origin, sung in honor of the Nativity of our Lord; a Christmas carol.","pos":""}],"NOWES":[{"def":"The marriage knot.","pos":""}],"NOWHERE":[{"def":"Not anywhere; not in any place or state; as, the book is nowhere to be found.","pos":""}],"NOWHITHER":[{"def":"Not anywhither; in no direction; nowhere.","pos":""}],"NOWISE":[{"def":"Not in any manner or degree; in no way; noways.","pos":""}]}