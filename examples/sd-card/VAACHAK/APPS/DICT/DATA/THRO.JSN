{"THRO'":[{"def":"A contraction of Through.","pos":""}],"THROAT":[{"def":"The part of a chimney between the gathering, or portion of the funnel which contracts in ascending, and the flue.","pos":""},{"def":"The inside of a timber knee.","pos":""}],"THROATBAND":[{"def":"Same as Throatlatch.","pos":""}],"THROATBOLL":[{"def":"The Adam's apple in the neck.","pos":""}],"THROATING":[{"def":"A drip, or drip molding.","pos":""}],"THROATLATCH":[{"def":"A strap of a bridle, halter, or the like, passing under a horse's throat.","pos":""}],"THROATWORT":[{"def":"A plant (Campanula Trachelium) formerly considered a remedy for sore throats because of its throat-shaped corolla.","pos":""}],"THROATY":[{"def":"Guttural; hoarse; having a guttural voice.","pos":""}],"THROB":[{"def":"To beat, or pulsate, with more than usual force or rapidity; to beat in consequence of agitation; to palpitate; -- said of the heart, pulse, etc.","pos":""}],"THRODDEN":[{"def":"To grow; to thrive.","pos":""}],"THROE":[{"def":"Extreme pain; violent pang; anguish; agony; especially, one of the pangs of travail in childbirth, or purturition.","pos":""},{"def":"A tool for splitting wood into shingles; a frow.","pos":""}],"THROMBIN":[{"def":"The fibrin ferment which produces the formation of fibrin from fibrinogen.","pos":""}],"THROMBOSIS":[{"def":"The obstruction of a blood vessel by a clot formed at the site of obstruction; -- distinguished from embolism, which is produced by a clot or foreign body brought from a distance.","pos":""}],"THRONE":[{"def":"A high order of angels in the celestial hierarchy; -- a meaning given by the schoolmen.","pos":""}],"THRONELESS":[{"def":"Having no throne.","pos":""}],"THRONG":[{"def":"A multitude of persons or of living beings pressing or pressed into a close body or assemblage; a crowd.","pos":""},{"def":"A great multitude; as, the heavenly throng.","pos":""}],"THRONGLY":[{"def":"In throngs or crowds.","pos":""}],"THROSTLE":[{"def":"The song thrush.","pos":""}],"THROSTLING":[{"def":"A disease of bovine cattle, consisting of a swelling under the throat, which, unless checked, causes strangulation.","pos":""}],"THROTTLE":[{"def":"The throttle valve.","pos":""}],"THROTTLER":[{"def":"See Flasher, 3 (b).","pos":""}],"THROUGH":[{"def":"From end to end of, or from side to side of; from one surface or limit of, to the opposite; into and out of at the opposite, or at another, point; as, to bore through a piece of timber, or through a board; a ball passes through the side of a ship.","pos":""},{"def":"Between the sides or walls of; within; as, to pass through a door; to go through an avenue.","pos":""}],"THROUGHLY":[{"def":"Wash me throughly from mine iniquity.","pos":""}],"THROUGHOUT":[{"def":"Quite through; from one extremity to the other of; also, every part of; as, to search throughout the house.","pos":""}],"THROW":[{"def":"Pain; especially, pain of travail; throe.","pos":""}],"THROW-CROOK":[{"def":"An instrument used for twisting ropes out of straw.","pos":""}],"THROW-OFF":[{"def":"A start in a hunt or a race.","pos":""}],"THROWE":[{"def":"A turning lathe.","pos":""}],"THROWING":[{"def":"Throw\"ing, Defn: a.","pos":""}],"THROWING STICK":[{"def":"An instrument used by various savage races for throwing a spear; -- called also throw stick and spear thrower.","pos":""}],"THROWSTER":[{"def":"One who throws or twists silk; a thrower.","pos":""}]}