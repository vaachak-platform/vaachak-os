{"WESLEYAN":[{"def":"Of or pertaining to Wesley or Wesleyanism.","pos":""}],"WESLEYANISM":[{"def":"The system of doctrines and church polity inculcated by John Wesley (b.","pos":""}],"WEST":[{"def":"A country, or region of country, which, with regard to some other country or region, is situated in the direction toward the west.","pos":""}],"WEST INDIAN":[{"def":"A native of, or a dweller in, the West Indies.","pos":""}],"WESTERING":[{"def":"Passing to the west.","pos":""}],"WESTERLY":[{"def":"Of or pertaining to the west; toward the west; coming from the west; western.","pos":""}],"WESTERN":[{"def":"Of or pertaining to the west; situated in the west, or in the region nearly in the direction of west; being in that quarter where the sun sets; as, the western shore of France; the western ocean.","pos":""},{"def":"Moving toward the west; as, a ship makes a western course; coming from the west; as, a western breeze.","pos":""}],"WESTERNER":[{"def":"A native or inhabitant of the west.","pos":""}],"WESTERNMOST":[{"def":"Situated the farthest towards the west; most western.","pos":""},{"def":"Belonging or relating to the West Indies.","pos":""}],"WESTING":[{"def":"The distance, reckoned toward the west, between the two meridians passing through the extremities of a course, or portion of a ship's path; the departure of a course which lies to the west of north.","pos":""}],"WESTMINSTER ASSEMBLY":[{"def":"See under Assembly.","pos":""}],"WESTMOST":[{"def":"Lying farthest to the west; westernmost.","pos":""},{"def":"Toward the west; as, to ride or sail westward.","pos":""}],"WESTWARD":[{"def":"Lying toward the west.","pos":""}],"WESTWARDLY":[{"def":"In a westward direction.","pos":""}]}