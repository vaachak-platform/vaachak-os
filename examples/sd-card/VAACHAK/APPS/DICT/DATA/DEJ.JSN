{"DEJECT":[{"def":"To cast down the spirits of; to dispirit; to discourage; to dishearten.","pos":""}],"DEJECTA":[{"def":"Excrements; as, the dejecta of the sick.","pos":""}],"DEJECTED":[{"def":"Cast down; afflicted; low-spirited; sad; as, a dejected look or countenance.","pos":""}],"DEJECTER":[{"def":"One who casts down, or dejects.","pos":""}],"DEJECTION":[{"def":"A casting down; depression.","pos":""},{"def":"The act of humbling or abasing one's self.","pos":""}],"DEJECTORY":[{"def":"Having power, or tending, to cast down.","pos":""},{"def":"Promoting evacuations by stool.","pos":""}],"DEJECTURE":[{"def":"That which is voided; excrements.","pos":""}],"DEJERATE":[{"def":"To swear solemnly; to take an oath.","pos":""}],"DEJERATION":[{"def":"The act of swearing solemnly.","pos":""}],"DEJEUNE":[{"def":"Take a déjeuné of muskadel and eggs.","pos":""}],"DEJEUNER":[{"def":"A breakfast; sometimes, also, a lunch or collation.","pos":""}]}