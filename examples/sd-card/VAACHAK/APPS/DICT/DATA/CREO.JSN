{"CREOLE":[{"def":"One born of European parents in the American colonies of France or Spain or in the States which were once such colonies, esp.","pos":""}],"CREOLE STATE":[{"def":"Louisiana; -- a nickname.","pos":""}],"CREOSOL":[{"def":"A colorless liquid resembling phenol or carbolic acid, homologous with pyrocatechin, and obtained from beechwood tar and gum guaiacum.","pos":""}],"CREOSOTE":[{"def":"Wood-tar oil; an oily antiseptic liquid, of a burning smoky taste, colorless when pure, but usually colored yellow or brown by impurity or exposure.","pos":""}],"CREOSOTE BUSH":[{"def":"A shrub (Covillea mexicana) found in desert regions from Colorado to California and southward through Mexico.","pos":""},{"def":"An injury in a horse's leg, caused by the shoe of one hind foot striking and cutting the other leg.","pos":""}]}