{"SANICLE":[{"def":"Any plant of the umbelliferous genus Sanicula, reputed to have healing powers.","pos":""}],"SANIDINE":[{"def":"A variety of orthoclase feldspar common in certain eruptive rocks, as trachyte; -- called also glassy feldspar.","pos":""}],"SANIES":[{"def":"A thin, serous fluid commonly discharged from ulcers or foul wounds.","pos":""}],"SANIOUS":[{"def":"pertaining to sanies, or partaking of its nature and appearance; thin and serous, with a slight bloody tinge; as, the sanious matter of an ulcer.","pos":""},{"def":"Discharging sanies; as, a sanious ulcer.","pos":""}],"SANITARIAN":[{"def":"Of or pertaining to health, or the laws of health; sanitary.","pos":""}],"SANITARIUM":[{"def":"A health station or retreat; a sanatorium.","pos":""}],"SANITARY":[{"def":"Of or pertaining to health; designed to secure or preserve health; relating to the preservation or restoration of health; hygienic; as, sanitary regulations.","pos":""}],"SANITATION":[{"def":"The act of rendering sanitary; the science of sanitary conditions; the preservation of health; the use of sanitary measures; hygiene.","pos":""}],"SANITY":[{"def":"The condition or quality of being sane; soundness of health of body or mind, especially of the mind; saneness.","pos":""}]}