{"ABJECT":[{"def":"Cast down; low-lying.","pos":""},{"def":"Sunk to a law condition; down in spirit or hope; degraded; servile; groveling; despicable; as, abject posture, fortune, thoughts.","pos":""}],"ABJECTEDNESS":[{"def":"A very abject or low condition; abjectness.","pos":""}],"ABJECTION":[{"def":"The act of bringing down or humbling.","pos":""},{"def":"The state of being rejected or cast out.","pos":""}],"ABJECTLY":[{"def":"Meanly; servilely.","pos":""}],"ABJECTNESS":[{"def":"The state of being abject; abasement; meanness; servility.","pos":""}],"ABJUDGE":[{"def":"To take away by judicial decision.","pos":""}],"ABJUDICATE":[{"def":"To reject by judicial sentence; also, to abjudge.","pos":""}],"ABJUDICATION":[{"def":"Rejection by judicial sentence.","pos":""}],"ABJUNCTIVE":[{"def":"It is this power which leads on from the accidental and abjunctive to the universal.","pos":""}],"ABJURATION":[{"def":"The act of abjuring or forswearing; a renunciation upon oath; as, abjuration of the realm, a sworn banishment, an oath taken to leave the country and never to return.","pos":""},{"def":"A solemn recantation or renunciation; as, an abjuration of heresy.","pos":""}],"ABJURATORY":[{"def":"Containing abjuration.","pos":""}],"ABJURE":[{"def":"To renounce upon oath; to forswear; to disavow; as, to abjure allegiance to a prince.","pos":""},{"def":"To renounce or reject with solemnity; to recant; to abandon forever; to reject; repudiate; as, to abjure errors.","pos":""}],"ABJURER":[{"def":"One who abjures.","pos":""}]}