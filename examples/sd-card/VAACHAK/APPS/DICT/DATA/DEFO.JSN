{"DEFOEDATION":[{"def":"Deprived of leaves, as by their natural fall.","pos":""}],"DEFOLIATION":[{"def":"The separation of ripened leaves from a branch or stem; the falling or shedding of the leaves.","pos":""}],"DEFORCEOR":[{"def":"Same as Deforciant.","pos":""}],"DEFORCIATION":[{"def":"Same as Deforcement, n.","pos":""}],"DEFOREST":[{"def":"To clear of forests; to dis U.","pos":""}],"DEFORM":[{"def":"To spoil the form of; to mar in form; to misshape; to disfigure.","pos":""},{"def":"To render displeasing; to deprive of comeliness, grace, or perfection; to dishonor.","pos":""}],"DEFORMATION":[{"def":"The act of deforming, or state of anything deformed.","pos":""},{"def":"Transformation; change of shape.","pos":""}],"DEFORMED":[{"def":"Unnatural or distorted in form; having a deformity; misshapen; disfigured; as, a deformed person; a deformed head.","pos":""}],"DEFORMER":[{"def":"One who deforms.","pos":""}],"DEFORMITY":[{"def":"The state of being deformed; want of proper form or symmetry; any unnatural form or shape; distortion; irregularity of shape or features; ugliness.","pos":""},{"def":"Anything that destroys beauty, grace, or propriety; irregularity; absurdity; gross deviation from other or the established laws of propriety; as, deformity in an edifice; deformity of character.","pos":""}],"DEFOUL":[{"def":"To make foul; to defile.","pos":""}]}