{"ANARCH":[{"def":"The author of anarchy; one who excites revolt.","pos":""}],"ANARCHAL":[{"def":"Lawless; anarchical.","pos":""},{"def":"Pertaining to anarchy; without rule or government; in political confusion; tending to produce anarchy; as, anarchic despotism; anarchical opinions.","pos":""}],"ANARCHISM":[{"def":"The doctrine or practice of anarchists.","pos":""}],"ANARCHIST":[{"def":"An anarch; one who advocates anarchy of aims at the overthrow of civil government.","pos":""}],"ANARCHIZE":[{"def":"To reduce to anarchy.","pos":""}],"ANARCHY":[{"def":"Absence of government; the state of society where there is no law or supreme power; a state of lawlessness; political confusion.","pos":""},{"def":"Hence, confusion or disorder, in general.","pos":""}],"ANARTHROPODA":[{"def":"One of the divisions of Articulata in which there are no jointed legs, as the annelids; -- opposed to Arthropoda.","pos":""}],"ANARTHROPODOUS":[{"def":"Having no jointed legs; pertaining to Anarthropoda.","pos":""}],"ANARTHROUS":[{"def":"Used without the article; as, an anarthrous substantive.","pos":""},{"def":"Without joints, or having the joints indistinct, as some insects.","pos":""}]}