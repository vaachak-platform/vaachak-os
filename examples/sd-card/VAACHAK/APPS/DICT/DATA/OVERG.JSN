{"OVERGARRISON":[{"def":"To garrison to excess.","pos":""}],"OVERGAZE":[{"def":"To gaze; to overlook.","pos":""}],"OVERGET":[{"def":"To reach; to overtake; to pass.","pos":""},{"def":"To get beyond; to get over or recover from.","pos":""}],"OVERGILD":[{"def":"To gild over; to varnish.","pos":""}],"OVERGIRD":[{"def":"To gird too closely.","pos":""}],"OVERGIVE":[{"def":"To give over; to surrender; to yield.","pos":""}],"OVERGLAD":[{"def":"Excessively or unduly glad.","pos":""}],"OVERGLAZE":[{"def":"Suitable for applying upon the glaze; -- said of vitrifiable colors used in ceramic decoration.","pos":""}],"OVERGLOOM":[{"def":"To spread gloom over; to make gloomy; to overshadow.","pos":""}],"OVERGO":[{"def":"To exceed; to surpass.","pos":""}],"OVERGORGE":[{"def":"To gorge to excess.","pos":""}],"OVERGRACE":[{"def":"To grace or honor exceedingly or beyond desert.","pos":""}],"OVERGRASSED":[{"def":"Overstocked, or overgrown, or covered, with grass.","pos":""}],"OVERGREATNESS":[{"def":"Excessive greatness.","pos":""}],"OVERGREEDY":[{"def":"Excessively greedy.","pos":""}],"OVERGROUND":[{"def":"Situated over or above ground; as, the overground portion of a plant.","pos":""}],"OVERGROW":[{"def":"To grow over; to cover with growth or herbage, esp.","pos":""},{"def":"To grow beyond; to rise above; hence, to overcome; to oppress.","pos":""}],"OVERGROWTH":[{"def":"Excessive growth.","pos":""}]}