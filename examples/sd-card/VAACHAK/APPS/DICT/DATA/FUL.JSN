{"FULCIBLE":[{"def":"Capable of being propped up.","pos":""}],"FULCIMENT":[{"def":"A prop; a fulcrum.","pos":""}],"FULCRATE":[{"def":"Propped; supported by accessory organs.","pos":""}],"FULCRUM":[{"def":"That by which a lever is sustained, or about which it turns in lifting or moving a body.","pos":""},{"def":"An accessory organ such as a tendril, stipule, spine, and the like.","pos":""}],"FULFILL":[{"def":"To fill up; to make full or complete.","pos":""},{"def":"To accomplish or carry into effect, as an intention, promise, or prophecy, a desire, prayer, or requirement, etc.","pos":""}],"FULFILLER":[{"def":"One who fulfills.","pos":""}],"FULFILLMENT":[{"def":"The act of fulfilling; accomplishment; completion; as, the fulfillment of prophecy.","pos":""},{"def":"Execution; performance; as, the fulfillment of a promise.","pos":""}],"FULGENCY":[{"def":"Brightness; splendor; glitter; effulgence.","pos":""}],"FULGENT":[{"def":"Exquisitely bright; shining; dazzling; effulgent.","pos":""}],"FULGENTLY":[{"def":"Dazzlingly; glitteringly.","pos":""}],"FULGID":[{"def":"Shining; glittering; dazzling.","pos":""}],"FULGIDITY":[{"def":"Splendor; resplendence; effulgence.","pos":""}],"FULGOR":[{"def":"Dazzling brightness; splendor.","pos":""}],"FULGURATA":[{"def":"A spectro-electric tube in which the decomposition of a liquid by the passage of an electric spark is observed.","pos":""}],"FULGURATE":[{"def":"To flash as lightning.","pos":""}],"FULGURATING":[{"def":"Resembling lightning; -- used to describe intense lancinating painsaccompanying locomotor ataxy.","pos":""}],"FULGURATION":[{"def":"The sudden brightening of a fused globule of gold or silver, when the last film of the oxide of lead or copper leaves its surface; -- also called blick.","pos":""}],"FULGURITE":[{"def":"A vitrified sand tube produced by the striking of lightning on sand; a lightning tube; also, the portion of rock surface fused by a lightning discharge.","pos":""}],"FULIGINOSITY":[{"def":"The condition or quality of being fuliginous; sootiness; matter deposited by smoke.","pos":""}],"FULIGINOUS":[{"def":"Pertaining to soot; sooty; dark; dusky.","pos":""},{"def":"Pertaining to smoke; resembling smoke.","pos":""}],"FULIGINOUSLY":[{"def":"In a smoky manner.","pos":""}],"FULIMART":[{"def":"Same as Foumart.","pos":""}],"FULL":[{"def":"Filled up, having within its limits all that it can contain; supplied; not empty or vacant; -- said primarily of hollow vessels, and hence of anything else; as, a cup full of water; a house full of people.","pos":""},{"def":"Abundantly furnished or provided; sufficient in.","pos":""}],"FULL HOUSE":[{"def":"A hand containing three of a kind and a pair, as three kings and two tens.","pos":""}],"FULL-BLOODED":[{"def":"Having a full supply of blood.","pos":""},{"def":"Of pure blood; thoroughbred; as, a full-blooded horse.","pos":""}],"FULL-BLOOMED":[{"def":"Like a perfect blossom.","pos":""}],"FULL-BLOWN":[{"def":"Fully expanded, as a blossom; as, a full-bloun rose.","pos":""},{"def":"Fully distended with wind, as a sail.","pos":""}],"FULL-BOTTOMED":[{"def":"Of great capacity below the water line.","pos":""}],"FULL-BUTT":[{"def":"With direct and violentop position; with sudden collision.","pos":""}],"FULL-DRIVE":[{"def":"With full speed.","pos":""}],"FULL-FORMED":[{"def":"Full in form or shape; rounded out with flesh.","pos":""}],"FULL-GROWN":[{"def":"Having reached the limits of growth; mature.","pos":""}],"FULL-HEARTED":[{"def":"Full of courage or confidence.","pos":""}],"FULL-MANNED":[{"def":"Completely furnished wiith men, as a ship.","pos":""}],"FULL-ORBED":[{"def":"Having the orb or disk complete or fully illuminated; like the full moon.","pos":""}],"FULL-SAILED":[{"def":"Having all its sails set,; hence, without restriction or reservation.","pos":""}],"FULL-WINGED":[{"def":"Having large and strong or complete wings.","pos":""},{"def":"Beady for flight; eager.","pos":""}],"FULLAGE":[{"def":"The money or price paid for fulling or cleansing cloth.","pos":""}],"FULLER":[{"def":"One whose occupation is to full cloth.","pos":""}],"FULLERY":[{"def":"The place or the works where the fulling of cloth is carried on.","pos":""}],"FULLING":[{"def":"The process of cleansing, shrinking, and thickening cloth by moisture, heat, and pressure.","pos":""}],"FULLNESS":[{"def":"The state of being full, or of abounding; abundance; completeness.","pos":""}],"FULLONICAL":[{"def":"Pertaining to a fuller of cloth.","pos":""}],"FULLY":[{"def":"In a full manner or degree; completely; entirely; without lack or defect; adequately; satisfactorily; as, to be fully persuaded of the truth of a proposition.","pos":""}],"FULMAR":[{"def":"One of several species of sea birds, of the family procellariidæ, allied to the albatrosses and petrels.","pos":""}],"FULMINANT":[{"def":"Thundering; fulminating.","pos":""}],"FULMINATE":[{"def":"To thunder; hence, to make a loud, sudden noise; to detonate; to explode with a violent report.","pos":""},{"def":"To issue or send forth decrees or censures with the assumption of supreme authority; to thunder forth menaces.","pos":""}],"FULMINATING":[{"def":"Thundering; exploding in a peculiarly sudden or violent manner.","pos":""},{"def":"Hurling denunciations, menaces, or censures.","pos":""}],"FULMINATION":[{"def":"The act of fulminating or exploding; detonation.","pos":""},{"def":"The act of thundering forth threats or censures, as with authority.","pos":""}],"FULMINATORY":[{"def":"Thundering; striking terror.","pos":""}],"FULMINE":[{"def":"To shoot; to dart like lightning; to fulminate; to utter with authority or vehemence.","pos":""}],"FULMINEOUS":[{"def":"Of, or concerning thunder.","pos":""}],"FULMINIC":[{"def":"Pertaining to fulmination; detonating; specifically (Chem.","pos":""}],"FULMINURIC":[{"def":"Pertaining to fulminic and cyanuric acids, and designating an acid so called.","pos":""}],"FULSOME":[{"def":"Full; abundant; plenteous; not shriveled.","pos":""},{"def":"Offending or disgusting by overfullness, excess, or grossness; cloying; gross; nauseous; esp.","pos":""}],"FULVOUS":[{"def":"Tawny; dull yellow, with a mixture of gray and brown.","pos":""}]}