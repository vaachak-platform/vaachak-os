{"DISH":[{"def":"A vessel, as a platter, a plate, a bowl, used for serving up food at the table.","pos":""},{"def":"The food served in a dish; hence, any particular kind of food; as, a cold dish; a warm dish; a delicious dish.","pos":""}],"DISHABILLE":[{"def":"An undress; a loose, negligent dress; deshabille.","pos":""}],"DISHABIT":[{"def":"Those sleeping stones .","pos":""}],"DISHABITED":[{"def":"Rendered uninhabited.","pos":""}],"DISHABITUATE":[{"def":"To render unaccustomed.","pos":""}],"DISHALLOW":[{"def":"To make unholy; to profane.","pos":""}],"DISHARMONIOUS":[{"def":"Unharmonious; discordant.","pos":""}],"DISHARMONY":[{"def":"Want of harmony; discord; incongruity.","pos":""}],"DISHAUNT":[{"def":"To leave; to quit; to cease to haunt.","pos":""}],"DISHCLOTH":[{"def":"A cloth used for washing dishes.","pos":""}],"DISHEARTEN":[{"def":"To discourage; to deprive of courage and hope; to depress the spirits of; to deject.","pos":""}],"DISHEARTENMENT":[{"def":"Discouragement; dejection; depression of spirits.","pos":""}],"DISHELM":[{"def":"To deprive of the helmet.","pos":""}],"DISHERISON":[{"def":"The act of disheriting, or debarring from inheritance; disinhersion.","pos":""}],"DISHERIT":[{"def":"To disinherit; to cut off, or detain, from the possession or enjoyment of an inheritance.","pos":""}],"DISHERITANCE":[{"def":"The act of disinheriting or state of being disinherited; disinheritance.","pos":""}],"DISHERITOR":[{"def":"One who puts another out of his inheritance.","pos":""}],"DISHEVEL":[{"def":"To suffer (the hair) to hang loosely or disorderly; to spread or throw (the hair) in disorder; -- used chiefly in the passive participle.","pos":""},{"def":"To spread loosely or disorderly.","pos":""}],"DISHEVELE":[{"def":"Dishevele, save his cap, he rode all bare.","pos":""}],"DISHEVELED":[{"def":"Having in loose disorder; disarranged; as, disheveled hair.","pos":""},{"def":"Having the hair in loose disorder.","pos":""}],"DISHFUL":[{"def":"As much as a dish holds when full.","pos":""}],"DISHING":[{"def":"Dish-shaped; concave.","pos":""}],"DISHONEST":[{"def":"Dishonorable; shameful; indecent; unchaste; lewd.","pos":""},{"def":"Dishonored; disgraced; disfigured.","pos":""}],"DISHONESTLY":[{"def":"In a dishonest manner.","pos":""}],"DISHONESTY":[{"def":"Dishonor; dishonorableness; shame.","pos":""},{"def":"Want of honesty, probity, or integrity in principle; want of fairness and straightforwardness; a disposition to defraud, deceive, or betray; faithlessness.","pos":""}],"DISHONOR":[{"def":"The nonpayment or nonacceptance of commercial paper by the party on whom it is drawn.","pos":""}],"DISHONORABLE":[{"def":"Wanting in honor; not honorable; bringing or deserving dishonor; staining the character, and lessening the reputation; shameful; disgraceful; base.","pos":""},{"def":"Wanting in honor or esteem; disesteemed.","pos":""}],"DISHONORARY":[{"def":"Bringing dishonor on; tending to disgrace; lessening reputation.","pos":""}],"DISHONORER":[{"def":"One who dishonors or disgraces; one who treats another indignity.","pos":""}],"DISHORN":[{"def":"To deprive of horns; as, to dishorn cattle.","pos":""}],"DISHOUSE":[{"def":"To deprive of house or home.","pos":""}],"DISHUMOR":[{"def":"To deprive of humor or desire; to put out of humor.","pos":""}],"DISHWASHER":[{"def":"A European bird; the wagtail.","pos":""}],"DISHWATER":[{"def":"Water in which dishes have been washed.","pos":""}]}