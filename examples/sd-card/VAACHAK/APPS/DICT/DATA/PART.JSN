{"PART":[{"def":"Such portion of any quantity, as when taken a certain number of times, will exactly make that quantity; as, 3 is a part of 12; -- the opposite of multiple.","pos":""},{"def":"One of the different melodies of a concerted composition, which heard in union compose its harmony; also, the music for each voice or instrument; as, the treble, tenor, or bass part; the violin part, etc.","pos":""}],"PARTAGE":[{"def":"Division; the act of dividing or sharing.","pos":""},{"def":"Part; portion; share.","pos":""}],"PARTAKE":[{"def":"To take a part, portion, lot, or share, in common with others; to have a share or part; to participate; to share; as, to partake of a feast with others.","pos":""},{"def":"To have something of the properties, character, or office; -- usually followed by of.","pos":""}],"PARTAKER":[{"def":"One who partakes; a sharer; a participator.","pos":""},{"def":"An accomplice; an associate; a partner.","pos":""}],"PARTAN":[{"def":"An edible British crab.","pos":""}],"PARTED":[{"def":"Cleft so that the divisions reach nearly, but not quite, to the midrib, or the base of the blade; -- said of a leaf, and used chiefly in composition; as, three-parted, five-parted, etc.","pos":""}],"PARTER":[{"def":"One who, or which, parts or separates.","pos":""}],"PARTERRE":[{"def":"An ornamental and diversified arrangement of beds or plots, in which flowers are cultivated, with intervening spaces of gravel or turf for walking on.","pos":""}],"PARTHENIAD":[{"def":"A poem in honor of a virgin.","pos":""}],"PARTHENIC":[{"def":"Of or pertaining to the Spartan Partheniæ, or sons of unmarried women.","pos":""}],"PARTHENOGENESIS":[{"def":"The production of new individuals from virgin females by means of ova which have the power of developing without the intervention of the male element; the production, without fertilization, of cells capable of germination.","pos":""},{"def":"The production of seed without fertilization, believed to occur through the nonsexual formation of an embryo extraneous to the embrionic vesicle.","pos":""}],"PARTHENOGENETIC":[{"def":"Of, pertaining to, or produced by, parthenogenesis; as, parthenogenetic forms.","pos":""}],"PARTHENOGENITIVE":[{"def":"Parthenogenetic.","pos":""}],"PARTHENOGENY":[{"def":"Same as Parthenogenesis.","pos":""}],"PARTHENON":[{"def":"A celebrated marble temple of Athene, on the Acropolis at Athens.","pos":""},{"def":"One of the Sirens, who threw herself into the sea, in despair at not being able to beguile Ulysses by her songs.","pos":""}],"PARTHIAN":[{"def":"Of or pertaining to ancient Parthia, in Asia.","pos":""},{"def":"A native Parthia.","pos":""}],"PARTIAL":[{"def":"Pertaining to a subordinate portion; as, a compound umbel is made up of a several partial umbels; a leaflet is often supported by a partial petiole.","pos":""}],"PARTIALISM":[{"def":"Partiality; specifically (Theol.","pos":""}],"PARTIALIST":[{"def":"One who holds that the atonement was made only for a part of mankind, that is, for the elect.","pos":""}],"PARTIALITY":[{"def":"The quality or state of being partial; inclination to favor one party, or one side of a question, more than the other; undue bias of mind.","pos":""},{"def":"A predilection or inclination to one thing rather than to others; special taste or liking; as, a partiality for poetry or painting.","pos":""}],"PARTIALIZE":[{"def":"To make or be partial.","pos":""}],"PARTIALLY":[{"def":"In part; not totally; as, partially true; the sun partially eclipsed.","pos":""},{"def":"In a partial manner; with undue bias of mind; with unjust favor or dislike; as, to judge partially.","pos":""}],"PARTIBILITY":[{"def":"The quality or state of being partible; divisibility; separability; as, the partibility of an inherttance.","pos":""}],"PARTIBLE":[{"def":"Admitting of being parted; divisible; separable; susceptible of severance or partition; as, an estate of inheritance may be partible.","pos":""}],"PARTICIPABLE":[{"def":"Capable of being participated or shared.","pos":""}],"PARTICIPANT":[{"def":"Sharing; participating; having a share of part.","pos":""}],"PARTICIPANTLY":[{"def":"In a participant manner.","pos":""}],"PARTICIPATE":[{"def":"Acting in common; participating.","pos":""}],"PARTICIPATION":[{"def":"The act or state of participating, or sharing in common with others; as, a participation in joy or sorrows.","pos":""},{"def":"Distribution; division into shares.","pos":""}],"PARTICIPATIVE":[{"def":"Capable of participating.","pos":""}],"PARTICIPATOR":[{"def":"One who participates, or shares with another; a partaker.","pos":""}],"PARTICIPIAL":[{"def":"Having, or partaking of, the nature and use of a participle; formed from a participle; as, a participial noun.","pos":""}],"PARTICIPIALIZE":[{"def":"To form into, or put in the form of, a participle.","pos":""}],"PARTICIPIALLY":[{"def":"In the sense or manner of a participle.","pos":""}],"PARTICIPLE":[{"def":"A part of speech partaking of the nature both verb and adjective; a form of a verb, or verbal adjective, modifying a noun, but taking the adjuncts of the verb from which it is derived.","pos":""}],"PARTICLE":[{"def":"A subordinate word that is never inflected (a preposition, conjunction, interjection); or a word that can not be used except in compositions; as, ward in backward, ly in lovely.","pos":""}],"PARTICOLORED":[{"def":"Same as Party-colored.","pos":""}],"PARTICULAR":[{"def":"Forming a part of a genus; relatively limited in extension; affirmed or denied of a part of a subject; as, a particular proposition; -- opposed to universal: e.","pos":""}],"PARTICULARISM":[{"def":"The doctrine of particular election.","pos":""},{"def":"Devotion to the interests of one's own kingdom or province rather than to those of the empire.","pos":""}],"PARTICULARIST":[{"def":"One who holds to particularism.","pos":""}],"PARTICULARITY":[{"def":"The state or quality of being particular; distinctiveness; circumstantiality; minuteness in detail.","pos":""},{"def":"That which is particular; as: (a) Peculiar quality; individual characteristic; peculiarity.","pos":""}],"PARTICULARIZATION":[{"def":"The act of particularizing.","pos":""}],"PARTICULARIZE":[{"def":"To give as a particular, or as the particulars; to mention particularly; to give the particulars of; to enumerate or specify in detail.","pos":""}],"PARTICULARLY":[{"def":"In a particular manner; expressly; with a specific reference or interest; in particular; distinctly.","pos":""},{"def":"In an especial manner; in a high degree; as, a particularly fortunate man; a particularly bad failure.","pos":""}],"PARTICULARMENT":[{"def":"A particular; a detail.","pos":""}],"PARTICULATE":[{"def":"To particularize.","pos":""}],"PARTING":[{"def":"Serving to part; dividing; separating.","pos":""},{"def":"Given when departing; as, a parting shot; a parting salute.","pos":""}],"PARTISAN":[{"def":"An adherent to a party or faction; esp.","pos":""}],"PARTISANSHIP":[{"def":"The state of being a partisan, or adherent to a party; feelings or conduct appropriate to a partisan.","pos":""}],"PARTITA":[{"def":"A suite; a set of variations.","pos":""}],"PARTITE":[{"def":"Divided nearly to the base; as, a partite leaf is a simple separated down nearly to the base.","pos":""}],"PARTITION":[{"def":"The servance of common or undivided interests, particularly in real estate.","pos":""}],"PARTITIONMENT":[{"def":"The act of partitioning.","pos":""}],"PARTITIVE":[{"def":"Denoting a part; as, a partitive genitive.","pos":""}],"PARTITIVELY":[{"def":"In a partitive manner.","pos":""}],"PARTLET":[{"def":"A covering for the neck, and sometimes for the shoulders and breast; originally worn by both sexes, but laterby women alone; a ruff.","pos":""},{"def":"A hen; -- so called from the ruffing of her neck feathers.","pos":""}],"PARTLY":[{"def":"In part; in some measure of degree; not wholly.","pos":""}],"PARTNER":[{"def":"An associate in any business or occupation; a member of a partnership.","pos":""},{"def":"A framework of heavy timber surrounding an opening in a deck, to strengthen it for the support of a mast, pump, capstan, or the like.","pos":""}],"PARTNERSHIP":[{"def":"A contract between two or more competent persons for joining together their money, goods, labor, and skill, or any or all of them, under an understanding that there shall be a communion of profit between them, and for the purpose of carrying on a legal trade, business, or adventure.","pos":""},{"def":"See Fellowship, n.","pos":""}],"PARTOOK":[{"def":"Par*took\", Defn: imp.","pos":""}],"PARTRIDGE":[{"def":"Any one of numerous species of small gallinaceous birds of the genus Perdix and several related genera of the family Perdicidæ, of the Old World.","pos":""},{"def":"Any one of several species of quail-like birds belonging to Colinus, and allied genera.","pos":""}],"PARTURIATE":[{"def":"To bring forth young.","pos":""}],"PARTURIENT":[{"def":"Bringing forth, or about to bring forth, young; fruitful.","pos":""}],"PARTURIFACIENT":[{"def":"A medicine tending to cause parturition, or to give relief in childbearing.","pos":""}],"PARTURITION":[{"def":"The act of bringing forth, or being delivered of, young; the act of giving birth; delivery; childbirth.","pos":""},{"def":"That which is brought forth; a birth.","pos":""}],"PARTURITIVE":[{"def":"Pertaining to parturition; obstetric.","pos":""}],"PARTY":[{"def":"A part or portion.","pos":""},{"def":"A number of persons united in opinion or action, as distinguished from, or opposed to, the rest of a community or association; esp.","pos":""}],"PARTY-COATED":[{"def":"Having a motley coat, or coat of divers colors.","pos":""},{"def":"Colored with different tints; variegated; as, a party-colored flower.","pos":""}],"PARTYISM":[{"def":"Devotion to party.","pos":""}]}