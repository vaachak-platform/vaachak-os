{"RESCAT":[{"def":"To ransom; to release; to rescue.","pos":""}],"RESCIND":[{"def":"To cut off; to abrogate; to annul.","pos":""},{"def":"Specifically, to vacate or make void, as an act, by the enacting authority or by superior authority; to repeal; as, to rescind a law, a resolution, or a vote; to rescind a decree or a judgment.","pos":""}],"RESCINDABLE":[{"def":"Capable of being rescinded.","pos":""}],"RESCINDMENT":[{"def":"The act of rescinding; rescission.","pos":""}],"RESCISSION":[{"def":"The act of rescinding, abrogating, annulling, or vacating; as, the rescission of a law, decree, or judgment.","pos":""}],"RESCISSORY":[{"def":"Tending to rescind; rescinding.","pos":""}],"RESCOUS":[{"def":"Rescue; deliverance.","pos":""}],"RESCRIBE":[{"def":"To write back; to write in reply.","pos":""},{"def":"To write over again.","pos":""}],"RESCRIPT":[{"def":"The answer of an emperor when formallyconsulted by particular persons on some difficult question; hence, an edict or decree.","pos":""},{"def":"The official written answer of the pope upon a question of canon law, or morals.","pos":""}],"RESCRIPTION":[{"def":"A writing back; the answering of a letter.","pos":""}],"RESCRIPTIVE":[{"def":"Pertaining to, or answering the purpose of, a rescript; hence, deciding; settling; determining.","pos":""}],"RESCRIPTIVELY":[{"def":"Re*scrip\"tive*ly, adv.","pos":""}],"RESCUABLE":[{"def":"That may be rescued.","pos":""}],"RESCUE":[{"def":"To free or deliver from any confinement, violence, danger, or evil; to liberate from actual restraint; to remove or withdraw from a state of exposure to evil; as, to rescue a prisoner from the enemy; to rescue seamen from destruction.","pos":""}],"RESCUELESS":[{"def":"Without rescue or release.","pos":""}],"RESCUER":[{"def":"One who rescues.","pos":""}],"RESCUSSEE":[{"def":"The party in whose favor a rescue is made.","pos":""}],"RESCUSSOR":[{"def":"One who makes an unlawful rescue; a rescuer.","pos":""}]}