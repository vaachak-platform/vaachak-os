{"COLE":[{"def":"A plant of the Brassica or Cabbage genus; esp.","pos":""}],"COLEMANITE":[{"def":"A hydrous borate of lime occurring in transparent colorless or white crystals, also massive, in Southern California.","pos":""}],"COLEOPTER":[{"def":"One of the Coleoptera.","pos":""}],"COLEOPTERA":[{"def":"An order of insects having the anterior pair of wings (elytra) hard and horny, and serving as coverings for the posterior pair, which are membranous, and folded transversely under the others when not in use.","pos":""},{"def":"Having wings covered with a case or sheath; belonging to the Coleoptera.","pos":""}],"COLEOPTERAN":[{"def":"One of the order of Coleoptera.","pos":""}],"COLEOPTERIST":[{"def":"One versed in the study of the Coleoptera.","pos":""}],"COLEORHIZA":[{"def":"A sheath in the embryo of grasses, inclosing the caulicle.","pos":""}],"COLEPERCH":[{"def":"A kind of small black perch.","pos":""}],"COLERIDGIAN":[{"def":"Pertaining to Samuel Taylor Coleridge, or to his poetry or metaphysics.","pos":""}],"COLESEED":[{"def":"The common rape or cole.","pos":""}],"COLESLAW":[{"def":"A salad made of sliced cabbage.","pos":""}],"COLESTAFF":[{"def":"An inferior church servant.","pos":""}],"COLEUS":[{"def":"A plant of several species of the Mint family, cultivated for its bright-colored or variegated leaves.","pos":""}],"COLEWORT":[{"def":"A variety of cabbage in which the leaves never form a compact head.","pos":""},{"def":"Any white cabbage before the head has become firm.","pos":""}]}