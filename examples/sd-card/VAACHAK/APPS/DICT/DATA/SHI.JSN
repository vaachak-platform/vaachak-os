{"SHIBBOLETH":[{"def":"Also in an extended sense.","pos":""}],"SHICER":[{"def":"An unproductive mine; a duffer.","pos":""}],"SHIDE":[{"def":"A thin board; a billet of wood; a splinter.","pos":"verb"}],"SHIE":[{"def":"See Shy, to throw.","pos":""}],"SHIELD":[{"def":"In lichens, a Hardened cup or disk surrounded by a rim and containing the fructification, or asci.","pos":""},{"def":"The escutcheon or field on which are placed the bearings in coats of arms.","pos":""}],"SHIELD-BEARER":[{"def":"Any small moth of the genus Aspidisca, whose larva makes a shieldlike covering for itself out of bits of leaves.","pos":""}],"SHIELDLESS":[{"def":"Destitute of a shield, or of protection.","pos":""}],"SHIELDTAIL":[{"def":"Any species of small burrowing snakes of the family Uropeltidæ, native of Ceylon and Southern Asia.","pos":""}],"SHIELING":[{"def":"A hut or shelter for shepherds of fishers.","pos":""}],"SHIFT":[{"def":"To divide; to distribute; to apportion.","pos":""},{"def":"To change the place of; to move or remove from one place to another; as, to shift a burden from one shoulder to another; to shift the blame.","pos":""}],"SHIFTABLE":[{"def":"Admitting of being shifted.","pos":""}],"SHIFTER":[{"def":"An assistant to the ship's cook in washing, steeping, and shifting the salt provisions.","pos":""}],"SHIFTINESS":[{"def":"The quality or state of being shifty.","pos":""}],"SHIFTING":[{"def":"Changing in place, position, or direction; varying; variable; fickle; as, shifting winds; shifting opinions or principles.","pos":""},{"def":"Adapted or used for shifting anything.","pos":""}],"SHIFTINGLY":[{"def":"In a shifting manner.","pos":""}],"SHIFTLESS":[{"def":"Destitute of expedients, or not using successful expedients; characterized by failure, especially by failure to provide for one's own support, through negligence or incapacity; hence, lazy; improvident; thriftless; as, a shiftless fellow; shiftless management.","pos":""}],"SHIFTY":[{"def":"Full of, or ready with, shifts; fertile in expedients or contrivance.","pos":""},{"def":"A member of that branch of the Mohammedans to which the Persians belong.","pos":""}],"SHILL":[{"def":"To put under cover; to sheal.","pos":""},{"def":"An oaken sapling or cudgel; any cudgel; -- so called from Shillelagh, a place in Ireland of that name famous for its oaks.","pos":""}],"SHILLING":[{"def":"In an irresolute, undecided, or hesitating manner.","pos":""}],"SHILLY-SHALLY":[{"def":"To hesitate; to act in an irresolute manner; hence, to occupy one's self with trifles.","pos":""}],"SHILOH":[{"def":"A word used by Jacob on his deathbed, and interpreted variously, as \"the Messiah,\" or as the city \"Shiloh,\" or as \"Rest.","pos":""}],"SHIM":[{"def":"A thin piece of metal placed between two parts to make a fit.","pos":""}],"SHIMMER":[{"def":"To shine with a tremulous or intermittent light; to shine faintly; to gleam; to glisten; to glimmer.","pos":""}],"SHIMMERING":[{"def":"A gleam or glimmering.","pos":""}],"SHIN":[{"def":"A fish plate for rails.","pos":""}],"SHIN SHU":[{"def":"The leading and most progressive Buddhist sect of Japan, resting its faith rather upon Amida than Gautama Buddha.","pos":""},{"def":"A kind of wide loose drawers or trousers worn by women in Mohammedan countries.","pos":""}],"SHINDLE":[{"def":"A shingle; also, a slate for roofing.","pos":""}],"SHINDY":[{"def":"An uproar or disturbance; a spree; a row; a riot.","pos":""},{"def":"Hockey; shinney.","pos":""}],"SHINE":[{"def":"To emit rays of light; to give light; to beam with steady radiance; to exhibit brightness or splendor; as, the sun shines by day; the moon shines by night.","pos":""},{"def":"To be bright by reflection of light; to gleam; to be glossy; as, to shine like polished silver.","pos":""}],"SHINER":[{"def":"That which shines.","pos":""},{"def":"The common Lepisma, or furniture bug.","pos":""}],"SHINGLE":[{"def":"Round, water-worn, and loose gravel and pebbles, or a collection of roundish stones, such as are common on the seashore and elsewhere.","pos":""}],"SHINGLER":[{"def":"One who shingles.","pos":""},{"def":"A machine for shingling puddled iron.","pos":""}],"SHINGLES":[{"def":"A kind of herpes (Herpes zoster) which spreads half way around the body like a girdle, and is usually attended with violent neuralgic pain.","pos":""}],"SHINGLING":[{"def":"The process of expelling scoriæ and other impurities by hammering and squeezing, in the production of wrought iron.","pos":""}],"SHINGLY":[{"def":"Abounding with shingle, or gravel.","pos":""}],"SHINING":[{"def":"Emitting light, esp.","pos":""},{"def":"Splendid; illustrious; brilliant; distinguished; conspicious; as, a shining example of charity.","pos":""}],"SHINNEY":[{"def":"The game of hockey; -- so called because of the liability of the players to receive blows on the shin.","pos":""}],"SHINPLASTER":[{"def":"Formerly, a jocose term for a bank note greatly depreciated in value; also, for paper money of a denomination less than a dollar.","pos":""}],"SHINTOIST":[{"def":"An adherent of Shintoism.","pos":""}],"SHINTY":[{"def":"A Scotch game resembling hockey; also, the club used in the game.","pos":""}],"SHINY":[{"def":"Bright; luminous; clear; unclouded.","pos":""},{"def":"A suffix denoting state, office, dignity, profession, or art; as in lordship, friendship, chancellorship, stewardship, horsemanship.","pos":""}],"SHIP":[{"def":"In withholding or abridging of the ship or the hire or the wages of servants.","pos":""}],"SHIP-RIGGED":[{"def":"Rigged like a ship, that is, having three masts, each with square sails.","pos":""}],"SHIPBOARD":[{"def":"A ship's side; hence, by extension, a ship; -- found chiefly in adverbial phrases; as, on shipboard; a shipboard.","pos":""}],"SHIPBUILDER":[{"def":"A person whose occupation is to construct ships and other vessels; a naval architect; a shipwright.","pos":""}],"SHIPBUILDING":[{"def":"Naval architecturel the art of constructing ships and other vessels.","pos":""}],"SHIPFUL":[{"def":"As much or as many as a ship will hold; enough to fill a ship.","pos":""}],"SHIPLESS":[{"def":"Destitute of ships.","pos":""}],"SHIPLOAD":[{"def":"The load, or cargo, of a ship.","pos":""}],"SHIPMAN":[{"def":"A seaman, or sailor.","pos":""}],"SHIPMASTER":[{"def":"The captain, master, or commander of a ship.","pos":""}],"SHIPMATE":[{"def":"One who serves on board of the same ship with another; a fellow sailor.","pos":""}],"SHIPMENT":[{"def":"The act or process of shipping; as, he was engaged in the shipment of coal for London; an active shipment of wheat from the West.","pos":""},{"def":"That which is shipped.","pos":""}],"SHIPOWNER":[{"def":"Owner of a ship or ships.","pos":""}],"SHIPPEN":[{"def":"A stable; a cowhouse.","pos":""}],"SHIPPER":[{"def":"One who sends goods from one place to another not in the same city or town, esp.","pos":""}],"SHIPPING":[{"def":"Relating to ships, their ownership, transfer, or employment; as, shiping concerns.","pos":""},{"def":"Relating to, or concerned in, the forwarding of goods; as, a shipping clerk.","pos":""}],"SHIPPING NOTE":[{"def":"A document used in shipping goods by sea.","pos":""}],"SHIPPO":[{"def":"Cloisonné enamel on a background of metal or porcelain.","pos":""}],"SHIPPON":[{"def":"A cowhouse; a shippen.","pos":""}],"SHIPSHAPE":[{"def":"Arranged in a manner befitting a ship; hence, trim; tidy; orderly.","pos":""}],"SHIPWORM":[{"def":"Any long, slender, worm-shaped bivalve mollusk of Teredo and allied genera.","pos":""}],"SHIPWRECK":[{"def":"The breaking in pieces, or shattering, of a ship or other vessel by being cast ashore or driven against rocks, shoals, etc.","pos":""},{"def":"A ship wrecked or destroyed upon the water, or the parts of such a ship; wreckage.","pos":""}],"SHIPWRIGHT":[{"def":"One whose occupation is to construct ships; a builder of ships or other vessels.","pos":""}],"SHIPYARD":[{"def":"A yard, place, or inclosure where ships are built or repaired.","pos":""}],"SHIRAZ":[{"def":"A kind of Persian wine; -- so called from the place whence it is brought.","pos":""}],"SHIRE":[{"def":"A portion of Great Britain originally under the supervision of an earl; a territorial division, usually identical with a county, but sometimes limited to a smaller district; as, Wiltshire, Yorkshire, Richmondshire, Hallamshire.","pos":""},{"def":"A division of a State, embracing several contiguous townships; a county.","pos":""}],"SHIRE HORSE":[{"def":"One of an English breed of heavy draft horses believed to be descended largely from the horses used in war in the days of heavy armor.","pos":""}],"SHIRK":[{"def":"To procure by petty fraud and trickery; to obtain by mean solicitation.","pos":""},{"def":"To avoid; to escape; to neglect; -- implying unfaithfulness or fraud; as, to shirk duty.","pos":""}],"SHIRKY":[{"def":"Disposed to shirk.","pos":""}],"SHIRR":[{"def":"A series of close parallel runnings which are drawn up so as to make the material between them set full by gatherings; -- called also shirring, and gauging.","pos":""}],"SHIRRED":[{"def":"Made or gathered into a shirr; as, a shirred bonnet.","pos":""},{"def":"Broken into an earthen dish and baked over the fire; -- said of eggs.","pos":""}],"SHIRT":[{"def":"A loose under-garment for the upper part of the body, made of cotton, linen, or other material; -- formerly used of the under- garment of either sex, now commonly restricted to that worn by men and boys.","pos":""}],"SHIRT WAIST":[{"def":"A belted waist resembling a shirt in plainness of cut and style, worn by women or children; -- in England called a blouse.","pos":""}],"SHIRT-WAIST SUIT":[{"def":"A costume consisting of a plain belted waist and skirt of the same material.","pos":""},{"def":"See Shist, Schistose.","pos":""}],"SHIRTING":[{"def":"Cloth, specifically cotton cloth, suitable for making shirts.","pos":""}],"SHIRTLESS":[{"def":"Not having or wearing a shirt.","pos":""}],"SHITTLE":[{"def":"Wavering; unsettled; inconstant.","pos":""}],"SHITTLENESS":[{"def":"Instability; inconstancy.","pos":""}],"SHIVE":[{"def":"A slice; as, a shive of bread.","pos":""},{"def":"A thin piece or fragment; specifically, one of the scales or pieces of the woody part of flax removed by the operation of breaking.","pos":""}],"SHIVER":[{"def":"A variety of blue slate.","pos":""},{"def":"A sheave or small wheel in a pulley.","pos":""}],"SHIVER-SPAR":[{"def":"A variety of calcite, so called from its slaty structure; -- called also slate spar.","pos":""}],"SHIVERINGLY":[{"def":"In a shivering manner.","pos":""}],"SHIVERY":[{"def":"Tremulous; shivering.","pos":""},{"def":"Easily broken; brittle; shattery.","pos":""}],"SHIZOKU":[{"def":"The Japanese warrior gentry or middle class, formerly called samurai; also, any member of this class.","pos":""}]}