{"HETCHEL":[{"def":"Same as Hatchel.","pos":""}],"HETE":[{"def":"Variant of Hote.","pos":""}],"HETERACANTH":[{"def":"Having the spines of the dorsal fin unsymmetrical, or thickened alternately on the right and left sides.","pos":""}],"HETERARCHY":[{"def":"The government of an alien.","pos":""}],"HETERAUXESIS":[{"def":"Unequal growth of a cell, or of a part of a plant.","pos":""}],"HETERO-":[{"def":"A combining form signifying other, other than usual, different; as, heteroclite, heterodox, heterogamous.","pos":""}],"HETEROCARPISM":[{"def":"The power of producing two kinds of reproductive bodies, as in Amphicarpæa, in which besides the usual pods, there are others underground.","pos":""}],"HETEROCARPOUS":[{"def":"Characterized by heterocarpism.","pos":""}],"HETEROCEPHALOUS":[{"def":"Bearing two kinds of heads or capitula; -- said of certain composite plants.","pos":""}],"HETEROCERA":[{"def":"A division of Lepidoptera, including the moths, and hawk moths, which have the antennæ variable in form.","pos":""}],"HETEROCERCAL":[{"def":"Having the vertebral column evidently continued into the upper lobe of the tail, which is usually longer than the lower one, as in sharks.","pos":""}],"HETEROCERCY":[{"def":"Unequal development of the tail lobes of fishes; the possession of a heterocercal tail.","pos":""}],"HETEROCHROMOUS":[{"def":"Having the central florets of a flower head of a different color from those of the circumference.","pos":""},{"def":"In evolution, a deviation from the typical sequence in the formation of organs or parts.","pos":""}],"HETEROCLITE":[{"def":"Deviating from ordinary forms or rules; irregular; anomalous; abnormal.","pos":""}],"HETEROCYST":[{"def":"A cell larger than the others, and of different appearance, occurring in certain algæ related to nostoc.","pos":""}],"HETERODACTYL":[{"def":"Heterodactylous.","pos":""},{"def":"One of the Heterodactylæ.","pos":""}],"HETERODACTYLAE":[{"def":"A group of birds including the trogons.","pos":""}],"HETERODACTYLOUS":[{"def":"Having the first and second toes turned backward, as in the trogons.","pos":""}],"HETERODONT":[{"def":"Having the teeth differentiated into incisors, canines, and molars, as in man; -- opposed to homodont.","pos":""}],"HETERODOX":[{"def":"Contrary to, or differing from, some acknowledged standard, as the Bible, the creed of a church, the decree of a council, and the like; not orthodox; heretical; -- said of opinions, doctrines, books, etc.","pos":""},{"def":"Holding heterodox opinions, or doctrines not orthodox; heretical; -- said of persons.","pos":""}],"HETERODOXY":[{"def":"An opinion or doctrine, or a system of doctrines, contrary to some established standard of faith, as the Scriptures, the creed or standards of a church, etc.","pos":""}],"HETERODROMOUS":[{"def":"Having spirals of changing direction.","pos":""},{"def":"Moving in opposite directions; -- said of a lever, pulley, etc.","pos":""}],"HETEROECIOUS":[{"def":"Passing through the different stages in its life history on an alternation of hosts, as the common wheat-rust fungus (Puccinia graminis), and certain other parasitic fungi; -- contrasted with autocious.","pos":""}],"HETEROGAMY":[{"def":"The process of fertilization in plants by an indirect or circuitous method; -- opposed to orthogamy.","pos":""},{"def":"That form of alternate generation in which two kinds of sexual generation, or a sexual and a parthenogenetic generation, alternate; -- in distinction from metagenesis, where sexual and asexual generations alternate.","pos":""}],"HETEROGANGLIATE":[{"def":"Having the ganglia of the nervous system unsymmetrically arranged; -- said of certain invertebrate animals.","pos":""}],"HETEROGENEITY":[{"def":"The state of being heterogeneous; contrariety.","pos":""}],"HETEROGENEOUS":[{"def":"Differing in kind; having unlike qualities; possessed of different characteristics; dissimilar; -- opposed to homogeneous, and said of two or more connected objects, or of a conglomerate mass, considered in respect to the parts of which it is made up.","pos":""}],"HETEROGENESIS":[{"def":"Spontaneous generation, so called.","pos":""},{"def":"That method of reproduction in which the successive generations differ from each other, the parent organism producing offspring different in habit and structure from itself, the original form, however, reappearing after one or more generations; -- opposed to homogenesis, or gamogenesis.","pos":""}],"HETEROGENETIC":[{"def":"Relating to heterogenesis; as, heterogenetic transformations.","pos":""}],"HETEROGENIST":[{"def":"One who believes in the theory of spontaneous generation, or heterogenesis.","pos":""}],"HETEROGENOUS":[{"def":"Of or pertaining to heterogenesis; heterogenetic.","pos":""}],"HETEROGONOUS":[{"def":"Characterized by heterogony.","pos":""}],"HETEROGONY":[{"def":"The condition of having two or more kinds of flowers, different as to the length of their stamens and pistils.","pos":""}],"HETEROGRAPHIC":[{"def":"Employing the same letters to represent different sounds in different words or syllables; -- said of methods of spelling; as, the ordinary English orthography is heterographic.","pos":""}],"HETEROGRAPHY":[{"def":"That method of spelling in which the same letters represent different sounds in different words, as in the ordinary English orthography; e.","pos":""}],"HETEROGYNOUS":[{"def":"Having females very unlike the males in form and structure; -- as certain insects, the males of which are winged, and the females wingless.","pos":""}],"HETEROLOGOUS":[{"def":"Characterized by heterology; consisting of different elements, or of like elements in different proportions; different; -- opposed to homologous; as, heterologous organs.","pos":""}],"HETEROLOGY":[{"def":"The absence of correspondence, or relation, in type of structure; lack of analogy between parts, owing to their being composed of different elements, or of like elements in different proportions; variation in structure from the normal form; -- opposed to homology.","pos":""}],"HETEROMERA":[{"def":"A division of Coleoptera, having heteromerous tarsi.","pos":""}],"HETEROMEROUS":[{"def":"Unrelated in chemical composition, though similar or indentical in certain other respects; as, borax and augite are homoemorphous, but heteromerous.","pos":""},{"def":"With the parts not corresponding in number.","pos":""}],"HETEROMORPHIC":[{"def":"The state or quality of being heteromorphic.","pos":""}],"HETEROMORPHOUS":[{"def":"Het`er*o*mor\"phous, a.","pos":""}],"HETEROMYARIA":[{"def":"A division of bivalve shells, including the marine mussels, in which the two adductor muscles are very unequal.","pos":""}],"HETERONEREIS":[{"def":"A free-swimming, dimorphic, sexual form of certain species of Nereis.","pos":""}],"HETERONOMOUS":[{"def":"Subject to the law of another.","pos":""}],"HETERONOMY":[{"def":"A term applied by Kant to those laws which are imposed on us from without, or the violence done to us by our passions, wants, or desires.","pos":""}],"HETERONYM":[{"def":"That which is heteronymous; a thing having a different name or designation from some other thing; -- opposed to homonym.","pos":""}],"HETERONYMOUS":[{"def":"Having different names or designations; standing in opposite relations.","pos":""}],"HETEROOUSIAN":[{"def":"Having different essential qualities; of a different nature.","pos":""}],"HETEROOUSIOUS":[{"def":"See Heteroousian.","pos":""}],"HETEROPATHIC":[{"def":"Of or pertaining to the method of heteropathy; allopathic.","pos":""}],"HETEROPATHY":[{"def":"That mode of treating diseases, by which a morbid condition is removed by inducing an opposite morbid condition to supplant it; allopathy.","pos":""}],"HETEROPELMOUS":[{"def":"Having each of the two flexor tendons of the toes bifid, the branches of one going to the first and second toes; those of the other, to the third and fourth toes.","pos":""}],"HETEROPHEMIST":[{"def":"One liable to the fault of heterophemy.","pos":""}],"HETEROPHEMY":[{"def":"The unconscious saying, in speech or in writing, of that which one does not intend to say; -- frequently the very reverse of the thought which is present to consciousness.","pos":""}],"HETEROPHONY":[{"def":"An abnormal state of the voice.","pos":""}],"HETEROPHYLLOUS":[{"def":"Having leaves of more than one shape on the same plant.","pos":""}],"HETEROPLASM":[{"def":"An abnormal formation foreign to the economy, and composed of elements different from those are found in it in its normal condition.","pos":""}],"HETEROPLASTIC":[{"def":"Producing a different type of organism; developing into a different form of tissue, as cartilage which develops into bone.","pos":""}],"HETEROPOD":[{"def":"One of the Heteropoda.","pos":""}],"HETEROPODA":[{"def":"An order of pelagic Gastropoda, having the foot developed into a median fin.","pos":""}],"HETEROPODOUS":[{"def":"Of or pertaining to the Heteropoda.","pos":""}],"HETEROPTER":[{"def":"One of the Heteroptera.","pos":""}],"HETEROPTERA":[{"def":"A suborder of Hemiptera, in which the base of the anterior wings is thickened.","pos":""}],"HETEROSCIAN":[{"def":"One who lives either north or south of the tropics, as contrasted with one who lives on the other side of them; -- so called because at noon the shadows always fall in opposite directions (the one northward, the other southward).","pos":""}],"HETEROSIS":[{"def":"A figure of speech by which one form of a noun, verb, or pronoun, and the like, is used for another, as in the sentence: \"What is life to such as me\" Aytoun.","pos":""}],"HETEROSOMATI":[{"def":"An order of fishes, comprising the flounders, halibut, sole, etc.","pos":""},{"def":"Producing two kinds of spores unlike each other.","pos":""}],"HETEROSTYLED":[{"def":"Having styles of two or more distinct forms or lengths.","pos":""}],"HETEROSTYLISM":[{"def":"The condition of being heterostyled.","pos":""}],"HETEROTACTOUS":[{"def":"Relating to, or characterized by, heterotaxy.","pos":""}],"HETEROTAXY":[{"def":"Variation in arrangement from that existing in a normal form; heterogenous arrangement or structure, as, in botany, the deviation in position of the organs of a plant, from the ordinary or typical arrangement.","pos":""},{"def":"A deviation from the natural position; -- a term applied in the case of organs or growths which are abnormal in situation.","pos":""}],"HETEROTRICHA":[{"def":"A division of ciliated Infusoria, having fine cilia all over the body, and a circle of larger ones around the anterior end.","pos":""},{"def":"Having the embryo or ovule oblique or transverse to the funiculus; amphitropous.","pos":""}],"HETHING":[{"def":"Contempt; scorn.","pos":""}],"HETMAN":[{"def":"A Cossack headman or general.","pos":""}]}