{"KUDA":[{"def":"The East Indian tapir.","pos":""}],"KUDOS":[{"def":"Glory; fame; renown; praise.","pos":""}],"KUKLUX":[{"def":"The name adopted in the southern part of the United States by a secret political organization, active for several years after the close of the Civil War, and having for its aim the repression of the political power of the freedmen; -- called also Kuklux Klan.","pos":""}],"KULTURKAMPF":[{"def":"KUMISH; KUMISS Ku\"mish, Ku\"miss, n.","pos":""}],"KUMMEL":[{"def":"A Russian and German liqueur, consisting of a sweetened spirit flavored with caraway seeds.","pos":""}],"KUMQUAT":[{"def":"A small tree of the genus Citrus (C.","pos":""}],"KUPFERNICKEL":[{"def":"Copper-nickel; niccolite.","pos":""}],"KURD":[{"def":"A native or inhabitant of a mountainous region of Western Asia belonging to the Turkish and Persian monarchies.","pos":""}],"KURDISH":[{"def":"Of or pertaining to the Kurds.","pos":""}],"KURILIAN":[{"def":"Of or pertaining to the Kurile Islands, a chain of islands in the Pacific ocean, extending from the southern extremity of Kamschatka to Yesso.","pos":""},{"def":"A native or an inhabitant of the Kurile Islands.","pos":""}],"KURO-SIWO":[{"def":"See Japan Current, above.","pos":""}],"KURSAAL":[{"def":"A public hall or room, for the use of visitors at watering places and health resorts in Germany.","pos":"noun"}],"KUSIMANSE":[{"def":"A carnivorous animal (Crossarchus obscurus) of tropical Africa.","pos":""}],"KUTAUSS":[{"def":"The India civet (Viverra zibetha).","pos":""}],"KUTCH":[{"def":"The packet of vellum leaves in which the gold is first beaten into thin sheets.","pos":""}]}