{"IRIAN":[{"def":"Of or pertaining to the iris.","pos":""}],"IRICISM":[{"def":"Pertaining to, or resembling, a large natural order of endogenous plants (Iridaceæ), which includes the genera Iris, Ixia, Crocus, Gladiolus, and many others.","pos":""}],"IRIDAL":[{"def":"Of or pertaining to the iris or rainbow; prismatic; as, the iridal colors.","pos":""}],"IRIDECTOMY":[{"def":"The act or process of cutting out a portion of the iris in order to form an artificial pupil.","pos":""}],"IRIDESCENCE":[{"def":"Exhibition of colors like those of the rainbow; the quality or state of being iridescent; a prismatic play of color; as, the iridescence of mother-of-pearl.","pos":""}],"IRIDESCENT":[{"def":"Having colors like the rainbow; exhibiting a play of changeable colors; nacreous; prismatic; as, iridescent glass.","pos":""}],"IRIDIAN":[{"def":"Of or pertaining to the iris or rainbow.","pos":""}],"IRIDIC":[{"def":"Of or pertaining to the iris of the eye.","pos":""}],"IRIDIOSCOPE":[{"def":"A kind of ophthalmoscope.","pos":""}],"IRIDIOUS":[{"def":"Of or pertaining to iridium; -- applied specifically to compounds in which iridium has a low valence.","pos":""}],"IRIDIUM":[{"def":"A rare metallic element, of the same group as platinum, which it much resembles, being silver-white, but harder, and brittle, and indifferent to most corrosive agents.","pos":""}],"IRIDIZE":[{"def":"To point or tip with iridium, as a gold pen.","pos":""},{"def":"To make iridescent; as, to iridize glass.","pos":""}],"IRIDOLINE":[{"def":"A nitrogenous base C10H9N, extracted from coal-tar naphtha, as an oily liquid.","pos":""},{"def":"The native compound of iridium and osmium.","pos":""}],"IRIS":[{"def":"The goddess of the rainbow, and swift-footed messenger of the gods.","pos":""},{"def":"The contractile membrane perforated by the pupil, and forming the colored portion of the eye.","pos":""}],"IRIS DIAPHRAGM":[{"def":"An adjustable diaphragm, suggesting the iris of the eye in its action, for regulating the aperture of a lens, consisting of a number of thin pieces fastened to a ring.","pos":""}],"IRISATED":[{"def":"Exhibiting the prismatic colors; irised; iridescent.","pos":""}],"IRISCOPE":[{"def":"A philosophical toy for exhibiting the prismatic tints by means of thin films.","pos":""}],"IRISED":[{"def":"Having colors like those of the rainbow; iridescent.","pos":""}],"IRISH":[{"def":"Of or pertaining to Ireland or to its inhabitants; produced in Ireland.","pos":""}],"IRISH AMERICAN":[{"def":"A native of Ireland who has become an American citizen; also, a child or descendant of such a person.","pos":""}],"IRISHISM":[{"def":"A mode of speaking peculiar to the Irish; an Hibernicism.","pos":""}],"IRISHMAN":[{"def":"A man born in Ireland or of the Irish race; an Hibernian.","pos":""}],"IRISHRY":[{"def":"The Celtic people of Ireland.","pos":""}],"IRITIS":[{"def":"An inflammation of the iris of the eye.","pos":""}]}