{"FAT":[{"def":"A large tub, cistern, or vessel; a vat.","pos":""},{"def":"A measure of quantity, differing for different commodities.","pos":""}],"FAT-BRAINED":[{"def":"Dull of apprehension.","pos":""}],"FAT-KIDNEYED":[{"def":"Gross; lubberly.","pos":""}],"FATA MORGANA":[{"def":"A kind of mirage by which distant objects appear inverted, distorted, displaced, or multiplied.","pos":""}],"FATAL":[{"def":"Proceeding from, or appointed by, fate or destiny; necessary; inevitable.","pos":""},{"def":"Foreboding death or great disaster.","pos":""}],"FATALISM":[{"def":"The doctrine that all things are subject to fate, or that they take place by inevitable necessity.","pos":""}],"FATALIST":[{"def":"One who maintains that all things happen by inevitable necessity.","pos":""}],"FATALISTIC":[{"def":"Implying, or partaking of the nature of, fatalism.","pos":""}],"FATALITY":[{"def":"The state of being fatal, or proceeding from destiny; invincible necessity, superior to, and independent of, free and rational control.","pos":""},{"def":"The state of being fatal; tendency to destruction or danger, as if by decree of fate; mortaility.","pos":""}],"FATALLY":[{"def":"In a manner proceeding from, or determined by, fate.","pos":""},{"def":"In a manner issuing in death or ruin; mortally; destructively; as, fatally deceived or wounded.","pos":""}],"FATALNESS":[{"def":"Fa\"tal*ness Defn: , .","pos":""}],"FATE":[{"def":"The three goddesses, Clotho, Lachesis, and Atropos, sometimes called the Destinies, or Parcæwho were supposed to determine the course of human life.","pos":""}],"FATED":[{"def":"Decreed by fate; destined; doomed; as, he was fated to rule a factious people.","pos":""},{"def":"Invested with the power of determining destiny.","pos":""}],"FATEFUL":[{"def":"Having the power of serving or accomplishing fate.","pos":""}],"FATHER":[{"def":"One who has begotten a child, whether son or daughter; a generator; a male parent.","pos":""},{"def":"A male ancestor more remote than a parent; a progenitor; especially, a first ancestor; a founder of a race or family; -- in the plural, fathers, ancestors.","pos":""}],"FATHER LONGLEGS":[{"def":"See Daddy longlegs, 2.","pos":""}],"FATHER-IN-LAW":[{"def":"The father of one's husband or wife; -- correlative to son-in- law and daughter-in-law.","pos":""}],"FATHER-LASHER":[{"def":"A European marine fish (Cottus bubalis), allied to the sculpin; -- called also lucky proach.","pos":""}],"FATHERHOOD":[{"def":"The state of being a father; the character or authority of a father; paternity.","pos":""}],"FATHERLAND":[{"def":"One's native land; the native land of one's fathers or ancestors.","pos":""}],"FATHERLESS":[{"def":"Destitute of a living father; as, a fatherless child.","pos":""},{"def":"Without a known author.","pos":""}],"FATHERLESSNESS":[{"def":"The state of being without a father.","pos":""}],"FATHERLINESS":[{"def":"The qualities of a father; parantal kindness, care, etc.","pos":""}],"FATHERLY":[{"def":"Like a father in affection and care; paternal; tender; protecting; careful.","pos":""},{"def":"Of or pertaining to a father.","pos":""}],"FATHERSHIP":[{"def":"The state of being a father; fatherhood; paternity.","pos":""}],"FATHOM":[{"def":"A measure of length, containing six feet; the space to which a man can extend his arms; -- used chiefly in measuring cables, cordage, and the depth of navigable water by soundings.","pos":""},{"def":"The measure or extant of one's capacity; depth, as of intellect; profundity; reach; penetration.","pos":""}],"FATHOMABLE":[{"def":"Capable of being fathomed.","pos":""}],"FATHOMER":[{"def":"One who fathoms.","pos":""}],"FATHOMLESS":[{"def":"Incapable of being fathomed; immeasurable; that can not be sounded.","pos":""},{"def":"Incomprehensible.","pos":""}],"FATIDICAL":[{"def":"Having power to foretell future events; prophetic; fatiloquent; as, the fatidical oak.","pos":""}],"FATIFEROUS":[{"def":"Fate-bringing; deadly; mortal; destructive.","pos":""}],"FATIGATE":[{"def":"Wearied; tired; fatigued.","pos":""}],"FATIGUE":[{"def":"Weariness from bodily labor or mental exertion; lassitude or exhaustion of strength.","pos":""},{"def":"The cause of weariness; labor; toil; as, the fatigues of war.","pos":""}],"FATILOQUENT":[{"def":"Prophetic; fatidical.","pos":""}],"FATILOQUIST":[{"def":"A fortune teller.","pos":""},{"def":"Descended from Fatima, the daughter and only child of Mohammed.","pos":""}],"FATISCENCE":[{"def":"A gaping or opening; state of being chinky, or having apertures.","pos":""}],"FATLING":[{"def":"A calf, lamb, kid, or other young animal fattened for slaughter; a fat animal; -- said of such animals as are used for food.","pos":""}],"FATLY":[{"def":"Grossly; greasily.","pos":""}],"FATNER":[{"def":"One who fattens.","pos":""}],"FATNESS":[{"def":"The quality or state of being fat, plump, or full-fed; corpulency; fullness of flesh.","pos":""},{"def":"Hence; Richness; fertility; fruitfulness.","pos":""}],"FATTEN":[{"def":"To make fat; to feed for slaughter; to make fleshy or plump with fat; to fill full; to fat.","pos":""},{"def":"To make fertile and fruitful; to enrich; as, to fatten land; to fatten fields with blood.","pos":""}],"FATTENER":[{"def":"One who, or that which, fattens; that which gives fatness or fertility.","pos":""}],"FATTINESS":[{"def":"State or quality of being fatty.","pos":""}],"FATTISH":[{"def":"Somewhat fat; inclined to fatness.","pos":""}],"FATTY":[{"def":"Containing fat, or having the qualities of fat; greasy; gross; as, a fatty substance.","pos":""}],"FATUITOUS":[{"def":"Stupid; fatuous.","pos":""}],"FATUITY":[{"def":"Weakness or imbecility of mind; stupidity.","pos":""}],"FATUOUS":[{"def":"Feeble in mind; weak; silly; stupid; foolish; fatuitous.","pos":""},{"def":"Without reality; illusory, like the ignis fatuus.","pos":""}]}