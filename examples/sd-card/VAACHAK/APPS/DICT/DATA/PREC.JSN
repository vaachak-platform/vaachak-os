{"PRECALCULATE":[{"def":"To calculate or determine beforehand; to prearrange.","pos":""}],"PRECARIOUS":[{"def":"Depending on the will or pleasure of another; held by courtesy; liable to be changed or lost at the pleasure of another; as, precarious privileges.","pos":""},{"def":"Held by a doubtful tenure; depending on unknown causes or events; exposed to constant risk; not to be depended on for certainty or stability; uncertain; as, a precarious state of health; precarious fortunes.","pos":""}],"PRECATION":[{"def":"The act of praying; supplication; entreaty.","pos":""},{"def":"Suppliant; beseeching.","pos":""}],"PRECAUTION":[{"def":"Previous caution or care; caution previously employed to prevent mischief or secure good; as, his life was saved by precaution.","pos":""},{"def":"A measure taken beforehand to ward off evil or secure good or success; a precautionary act; as, to take precautions against accident.","pos":""}],"PRECAUTIONARY":[{"def":"Of or pertaining to precaution, or precautions; as, precautionary signals.","pos":""}],"PRECAUTIOUS":[{"def":"Taking or using precaution; precautionary.","pos":""}],"PRECEDANEOUS":[{"def":"Preceding; antecedent; previous.","pos":""}],"PRECEDE":[{"def":"To go before in order of time; to occur first with relation to anything.","pos":""},{"def":"To go before in place, rank, or importance.","pos":""}],"PRECEDENT":[{"def":"Going before; anterior; preceding; antecedent; as, precedent services.","pos":""}],"PRECEDENTED":[{"def":"Having a precedent; authorized or sanctioned by an example of a like kind.","pos":""}],"PRECEDENTIAL":[{"def":"Of the nature of a precedent; having force as an example for imitation; as, precedential transactions.","pos":""}],"PRECEDENTLY":[{"def":"Beforehand; antecedently.","pos":""}],"PRECEDING":[{"def":"In the direction toward which stars appear to move.","pos":""}],"PRECEL":[{"def":"To surpass; to excel; to exceed.","pos":""},{"def":"Excellence; superiority.","pos":""}],"PRECELLENT":[{"def":"Excellent; surpassing.","pos":""}],"PRECENTOR":[{"def":"A leader of a choir; a directing singer.","pos":""}],"PRECENTORSHIP":[{"def":"The office of a precentor.","pos":""}],"PRECEPT":[{"def":"A command in writing; a species of writ or process.","pos":""}],"PRECEPTIVE":[{"def":"Containing or giving precepts; of the nature of precepts; didactic; as, the preceptive parts of the Scriptures.","pos":""}],"PRECEPTOR":[{"def":"One who gives commands, or makes rules; specifically, the master or principal of a school; a teacher; an instructor.","pos":""},{"def":"The head of a preceptory among the Knights Templars.","pos":""}],"PRECEPTORIAL":[{"def":"Of or pertaining to a preceptor.","pos":""}],"PRECEPTORY":[{"def":"A religious house of the Knights Templars, subordinate to the temple or principal house of the order in London.","pos":""}],"PRECEPTRESS":[{"def":"A woman who is the principal of a school; a female teacher.","pos":""}],"PRECESSION":[{"def":"The act of going before, or forward.","pos":""}],"PRECESSIONAL":[{"def":"Of or pertaining to pression; as, the precessional movement of the equinoxes.","pos":""}],"PRECIEUSE":[{"def":"An affected woman of polite society, esp.","pos":""}],"PRECINCT":[{"def":"The limit or exterior line encompassing a place; a boundary; a confine; limit of jurisdiction or authority; -- often in the plural; as, the precincts of a state.","pos":""},{"def":"A district within certain boundaries; a minor territorial or jurisdictional division; as, an election precinct; a school precinct.","pos":""}],"PRECIOSITY":[{"def":"Preciousness; something precious.","pos":""}],"PRECIOUS":[{"def":"Of great price; costly; as, a precious stone.","pos":""},{"def":"Of great value or worth; very valuable; highly esteemed; dear; beloved; as, precious recollections.","pos":""}],"PRECIOUSLY":[{"def":"In a precious manner; expensively; extremely; dearly.","pos":""}],"PRECIOUSNESS":[{"def":"The quality or state of being precious; costliness; dearness.","pos":""}],"PRECIPE":[{"def":"See Præcipe, and Precept.","pos":""}],"PRECIPICE":[{"def":"A sudden or headlong fall.","pos":""},{"def":"A headlong steep; a very steep, perpendicular, or overhanging place; an abrupt declivity; a cliff.","pos":""}],"PRECIPIENT":[{"def":"Commanding; directing.","pos":""}],"PRECIPITABILITY":[{"def":"The quality or state of being precipitable.","pos":""}],"PRECIPITABLE":[{"def":"Capable of being precipitated, or cast to the bottom, as a substance in solution.","pos":""},{"def":"The quality or state of being precipitant, or precipitate; headlong hurry; excessive or rash haste in resolving, forming an opinion, or executing a purpose; precipitation; as, the precipitancy of youth.","pos":""}],"PRECIPITANT":[{"def":"Falling or rushing headlong; rushing swiftly, violently, or recklessly; moving precipitately.","pos":""},{"def":"Unexpectedly or foolishly brought on or hastened; rashly hurried; hasty; sudden; reckless.","pos":""}],"PRECIPITANTLY":[{"def":"With rash or foolish haste; in headlong manner.","pos":""}],"PRECIPITANTNESS":[{"def":"The quality or state of being precipitant; precipitation.","pos":""}],"PRECIPITATE":[{"def":"Overhasty; rash; as, the king was too precipitate in declaring war.","pos":""},{"def":"Lacking due deliberation or care; hurried; said or done before the time; as, a precipitate measure.","pos":""}],"PRECIPITATELY":[{"def":"In a precipitate manner; headlong; hastily; rashly.","pos":""}],"PRECIPITATION":[{"def":"The act or process from a solution.","pos":""}],"PRECIPITATOR":[{"def":"One who precipitates, or urges on with vehemence or rashness.","pos":""}],"PRECIPITOUS":[{"def":"Steep, like a precipice; as, a precipitous cliff or mountain.","pos":""},{"def":"Headlong; as, precipitous fall.","pos":""}],"PRECIS":[{"def":"A concise or abridged statement or view; an abstract; a summary.","pos":""}],"PRECISE":[{"def":"Having determinate limitations; exactly or sharply defined or stated; definite; exact; nice; not vague or equivocal; as, precise rules of morality.","pos":""},{"def":"Strictly adhering or conforming to rule; very nice or exact; punctilious in conduct or ceremony; formal; ceremonious.","pos":""}],"PRECISIAN":[{"def":"One who limits, or restrains.","pos":""},{"def":"An overprecise person; one rigidly or ceremoniously exact in the observance of rules; a formalist; -- formerly applied to the English Puritans.","pos":""}],"PRECISIANISM":[{"def":"The quality or state of being a precisian; the practice of a precisian.","pos":""}],"PRECISION":[{"def":"The quality or state of being precise; exact limitation; exactness; accuracy; strict conformity to a rule or a standard; definiteness.","pos":""}],"PRECISIVE":[{"def":"Cutting off; (Logic) exactly limiting by cutting off all that is not absolutely relative to the purpose; as, precisive censure; precisive abstraction.","pos":""}],"PRECLUDE":[{"def":"To put a barrier before; hence, to shut out; to hinder; to stop; to impede.","pos":""},{"def":"To shut out by anticipative action; to prevent or hinder by necessary consequence or implication; to deter action of, access to, employment of, etc.","pos":""}],"PRECLUSION":[{"def":"The act of precluding, or the state of being precluded; a shutting out.","pos":""}],"PRECLUSIVE":[{"def":"Shutting out; precluding, or tending to preclude; hindering.","pos":""}],"PRECOCES":[{"def":"Same as Præcoces.","pos":""}],"PRECOCIOUS":[{"def":"Ripe or mature before the proper or natural time; early or prematurely ripe or developed; as, precocious trees.","pos":""},{"def":"Developed more than is natural or usual at a given age; exceeding what is to be expected of one's years; too forward; -- used especially of mental forwardness; as, a precocious child; precocious talents.","pos":""}],"PRECOCIOUSLY":[{"def":"In a precocious manner.","pos":""},{"def":"The quality or state of being precocious; untimely ripeness; premature development, especially of the mental powers; forwardness.","pos":""}],"PRECOETANEAN":[{"def":"One contemporary with, but older than, another.","pos":""}],"PRECOGITATE":[{"def":"To cogitate beforehand.","pos":""}],"PRECOGITATION":[{"def":"Previous cogitation.","pos":""}],"PRECOGNITION":[{"def":"A preliminary examination of a criminal case with reference to a prosecution.","pos":""}],"PRECOGNIZABLE":[{"def":"Cognizable beforehand.","pos":""}],"PRECOGNOSCE":[{"def":"To examine beforehand, as witnesses or evidence.","pos":""}],"PRECOLLECTION":[{"def":"A collection previously made.","pos":""}],"PRECOMPOSE":[{"def":"To compose beforehand.","pos":""}],"PRECONCEIT":[{"def":"An opinion or notion formed beforehand; a preconception.","pos":""}],"PRECONCEIVE":[{"def":"To conceive, or form an opinion of, beforehand; to form a previous notion or idea of.","pos":""}],"PRECONCEPTION":[{"def":"The act of preconceiving; conception or opinion previously formed.","pos":""}],"PRECONCERT":[{"def":"To concert or arrange beforehand; to settle by previous agreement.","pos":""}],"PRECONCERTED":[{"def":"Previously arranged; agreed upon beforehand.","pos":""}],"PRECONCERTION":[{"def":"The act of preconcerting; preconcert.","pos":""}],"PRECONDEMN":[{"def":"To condemn beforehand.","pos":""}],"PRECONDITION":[{"def":"A previous or antecedent condition; a preliminary condition.","pos":""}],"PRECONFORM":[{"def":"To conform by way anticipation.","pos":""}],"PRECONFORMITY":[{"def":"Anticipative or antecedent conformity.","pos":""}],"PRECONIZATE":[{"def":"To proclaim; to publish; also, to summon; to call.","pos":""}],"PRECONIZATION":[{"def":"A formal approbation by the pope of a person nominated to an ecclesiastical dignity.","pos":""}],"PRECONIZE":[{"def":"To approve by preconization.","pos":""}],"PRECONQUER":[{"def":"To conquer in anticipation.","pos":""}],"PRECONSCIOUS":[{"def":"Of or pertaining to a state before consciousness.","pos":""}],"PRECONSENT":[{"def":"A previous consent.","pos":""}],"PRECONSIGN":[{"def":"To consign beforehand; to make a previous consignment of.","pos":""}],"PRECONSOLIDATED":[{"def":"Consolidated beforehand.","pos":""}],"PRECONSTITUTE":[{"def":"To constitute or establish beforehand.","pos":""}],"PRECONTRACT":[{"def":"To contract, engage, or stipulate previously.","pos":""}],"PRECONTRIVE":[{"def":"To contrive or plan beforehand.","pos":""}],"PRECORACOID":[{"def":"The anterior part of the coracoid (often closely united with the clavicle) in the shoulder girdle of many reptiles and amphibians.","pos":""}],"PRECORDIAL":[{"def":"Situated in front of the heart; of or pertaining to the præcordia.","pos":""}],"PRECRURAL":[{"def":"Situated in front of the leg or thigh; as, the precrural glands of the horse.","pos":""}],"PRECURSIVE":[{"def":"Preceding; introductory; precursory.","pos":""}],"PRECURSOR":[{"def":"One who, or that which, precedes an event, and indicates its approach; a forerunner; a harbinger.","pos":""}],"PRECURSORSHIP":[{"def":"The position or condition of a precursor.","pos":""}],"PRECURSORY":[{"def":"Preceding as a precursor or harbinger; indicating something to follow; as, precursory symptoms of a fever.","pos":""}]}