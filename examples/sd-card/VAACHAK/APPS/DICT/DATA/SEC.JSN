{"SECALE":[{"def":"A genus of cereal grasses including rye.","pos":""}],"SECANCY":[{"def":"A cutting; an intersection; as, the point of secancy of one line by another.","pos":""}],"SECANT":[{"def":"Cutting; divivding into two parts; as, a secant line.","pos":""}],"SECEDE":[{"def":"To withdraw from fellowship, communion, or association; to separate one's self by a solemn act; to draw off; to retire; especially, to withdraw from a political or religious body.","pos":""}],"SECEDER":[{"def":"One of a numerous body of Presbyterians in Scotland who seceded from the communion of the Established Church, about the year 1733, and formed the Secession Church, so called.","pos":""}],"SECERN":[{"def":"To secrete; as, mucus secerned in the nose.","pos":""}],"SECERNENT":[{"def":"Secreting; secretory.","pos":""}],"SECERNMENT":[{"def":"The act or process of secreting.","pos":""}],"SECESS":[{"def":"Retirement; retreat; secession.","pos":""}],"SECESSION":[{"def":"The withdrawal of a State from the national Union.","pos":""}],"SECESSIONISM":[{"def":"The doctrine or policy of secession; the tenets of secession; the tenets of secessionists.","pos":""}],"SECESSIONIST":[{"def":"One who holds to the belief that a State has the right to separate from the Union at its will.","pos":""}],"SECHIUM":[{"def":"The edible fruit of a West Indian plant (Sechium edule) of the Gourd family.","pos":""}],"SECK":[{"def":"Barren; unprofitable.","pos":""}],"SECKEL":[{"def":"A small reddish brown sweet and juicy pear.","pos":""}],"SECLUDE":[{"def":"To shut up apart from others; to withdraw into, or place in, solitude; to separate from society or intercourse with others.","pos":""},{"def":"To shut or keep out; to exclude.","pos":""}],"SECLUSION":[{"def":"The act of secluding, or the state of being secluded; separation from society or connection; a withdrawing; privacy; as, to live in seclusion.","pos":""}],"SECLUSIVE":[{"def":"Tending to seclude; keeping in seclusion; secluding; sequestering.","pos":""}],"SECOND":[{"def":"Immediately following the first; next to the first in order of place or time; hence, occuring again; another; other.","pos":""},{"def":"Next to the first in value, power, excellence, dignity, or rank; secondary; subordinate; inferior.","pos":""}],"SECOND-CLASS":[{"def":"Of the rank or degree below the best highest; inferior; second- rate; as, a second-class house; a second-class passage.","pos":""}],"SECOND-RATE":[{"def":"Of the second size, rank, quality, or value; as, a second-rate ship; second-rate cloth; a second-rate champion.","pos":""}],"SECOND-SIGHT":[{"def":"The power of discerning what is not visible to the physical eye, or of foreseeing future events, esp.","pos":""}],"SECOND-SIGHTED":[{"def":"Having the power of second-sight.","pos":""}],"SECONDARILY":[{"def":"In a secondary manner or degree.","pos":""},{"def":"Secondly; in the second place.","pos":""}],"SECONDARINESS":[{"def":"The state of being secondary.","pos":""}],"SECONDARY":[{"def":"Possessing some quality, or having been subject to some operation (as substitution), in the second degree; as, a secondary salt, a secondary amine, etc.","pos":""},{"def":"Subsequent in origin; -- said of minerals produced by alteertion or deposition subsequent to the formation of the original rocks mass; also of characters of minerals (as secondary cleavage, etc.","pos":""}],"SECONDER":[{"def":"One who seconds or supports what another attempts, affirms, moves, or proposes; as, the seconder of an enterprise or of a motion.","pos":""}],"SECONDHAND":[{"def":"Not original or primary; received from another.","pos":""},{"def":"Not new; already or previously or used by another; as, a secondhand book, garment.","pos":""}],"SECONDLY":[{"def":"In the second place.","pos":""}],"SECONDO":[{"def":"The second part in a concerted piece.","pos":""}],"SECRE":[{"def":"Secret; secretive; faithful to a secret.","pos":""}],"SECRECY":[{"def":"The state or quality of being hidden; as, his movements were detected in spite of their secrecy.","pos":""},{"def":"That which is concealed; a secret.","pos":""}],"SECRENESS":[{"def":"Secrecy; privacy.","pos":""}],"SECRET":[{"def":"Hidden; concealed; as, secret treasure; secret plans; a secret vow.","pos":""},{"def":"Withdraw from general intercourse or notice; in retirement or secrecy; secluded.","pos":""}],"SECRET SERVICE":[{"def":"The detective service of a government.","pos":""}],"SECRETAGE":[{"def":"A process in which mercury, or some of its salts, is employed to impart the property of felting to certain kinds of furs.","pos":""}],"SECRETARIAL":[{"def":"Of or pertaining to a secretary; befitting a secretary.","pos":""},{"def":"The office of a secretary; the place where a secretary transacts business, keeps records, etc.","pos":""}],"SECRETARY":[{"def":"The secretary bird.","pos":""}],"SECRETARYSHIP":[{"def":"The office, or the term of office, of a secretary.","pos":""}],"SECRETE":[{"def":"To separate from the blood and elaborate by the process of secretion; to elaborate and emit as a secretion.","pos":""}],"SECRETION":[{"def":"The act of secreting; the process by which material is separated from the blood through the agency of the cells of the various glands and elaborated by the cells into new substances so as to form the various secretions, as the saliva, bile, and other digestive fluids.","pos":""},{"def":"Any substance or fluid secreted, or elaborated and emitted, as the gastric juice.","pos":""}],"SECRETIST":[{"def":"A dealer in secrets.","pos":""}],"SECRETITIOUS":[{"def":"Parted by animal secretion; as, secretitious humors.","pos":""}],"SECRETIVE":[{"def":"Tending to secrete, or to keep secret or private; as, a secretive disposition.","pos":""}],"SECRETIVENESS":[{"def":"The faculty or propensity which impels to reserve, secrecy, or concealment.","pos":""}],"SECRETLY":[{"def":"In a secret manner.","pos":""}],"SECRETNESS":[{"def":"The state or quality of being secret, hid, or concealed.","pos":""},{"def":"Secretiveness; concealment.","pos":""}],"SECRETO-MOTORY":[{"def":"Causing secretion; -- said of nerves which go to glands and influence secretion.","pos":""}],"SECRETORY":[{"def":"Secreting; performing, or connected with, the office secretion; secernent; as, secretory vessels, nerves.","pos":""},{"def":"A secretory vessel; a secernent.","pos":""}],"SECT":[{"def":"A cutting; a scion.","pos":""}],"SECTANT":[{"def":"One of the portions of space bounded by the three coordinate planes.","pos":""}],"SECTARIAN":[{"def":"Pertaining to a sect, or to sects; peculiar to a sect; bigotedly attached to the tenets and interests of a denomination; as, sectarian principles or prejudices.","pos":""}],"SECTARIANISM":[{"def":"The quality or character of a sectarian; devotion to the interests of a party; excess of partisan or denominational zeal; adherence to a separate church organization.","pos":""}],"SECTARIANIZE":[{"def":"To imbue with sectarian feelings; to subject to the control of a sect.","pos":""}],"SECTARY":[{"def":"A sectarian; a member or adherent of a sect; a follower or disciple of some particular teacher in philosophy or religion; one who separates from an established church; a dissenter.","pos":""}],"SECTATOR":[{"def":"A follower; a disciple; an adherent to a sect.","pos":""}],"SECTILE":[{"def":"Capable of being cut; specifically (Min.","pos":""}],"SECTILITY":[{"def":"The state or quality of being sectile.","pos":""}],"SECTION":[{"def":"The figure made up of all the points common to a superficies and a solid which meet, or to two superficies which meet, or to two lines which meet.","pos":""},{"def":"A division of a genus; a group of species separated by some distinction from others of the same genus; -- often indicated by the sign §.","pos":""}],"SECTIONAL":[{"def":"Of or pertaining to a sections or distinct part of larger body or territory; local.","pos":""},{"def":"Consisting of sections, or capable of being divided into sections; as, a sectional steam boiler.","pos":""}],"SECTIONALISM":[{"def":"A disproportionate regard for the interests peculiar to a section of the country; local patriotism, as distinguished from national.","pos":""}],"SECTIONALITY":[{"def":"The state or quality of being sectional; sectionalism.","pos":""}],"SECTIONALIZE":[{"def":"To divide according to gepgraphical sections or local interests.","pos":""}],"SECTIONALLY":[{"def":"In a sectional manner.","pos":""}],"SECTIONIZE":[{"def":"To form into sections.","pos":""}],"SECTISM":[{"def":"Devotion to a sect.","pos":""}],"SECTIST":[{"def":"One devoted to a sect; a soetary.","pos":""}],"SECTIUNCLE":[{"def":"A little or petty sect.","pos":""}],"SECTOR":[{"def":"A part of a circle comprehended between two radii and the included arc.","pos":""}],"SECTORAL":[{"def":"Of or pertaining to a sector; as, a sectoral circle.","pos":""}],"SECTORIAL":[{"def":"Adapted for cutting.","pos":""},{"def":"A sectorial, or carnassial, tooth.","pos":""}],"SECULAR":[{"def":"Not regular; not bound by monastic vows or rules; not confined to a monastery, or subject to the rules of a religious community; as, a secular priest.","pos":""}],"SECULARISM":[{"def":"The state or quality of being secular; a secular spirit; secularity.","pos":""},{"def":"The tenets or principles of the secularists.","pos":""}],"SECULARITY":[{"def":"Supreme attention to the things of the present life; worldliness.","pos":""}],"SECULARIZATION":[{"def":"The act of rendering secular, or the state of being rendered secular; conversion from regular or monastic to secular; conversion from religious to lay or secular possession and uses; as, the secularization of church property.","pos":""}],"SECULARIZE":[{"def":"To convert from regular or monastic into secular; as, to secularize a priest or a monk.","pos":""},{"def":"To convert from spiritual or common use; as, to secularize a church, or church property.","pos":""}],"SECULARLY":[{"def":"In a secular or worldly manner.","pos":""}],"SECULARNESS":[{"def":"The quality or state of being secular; worldliness; worldly- minded-ness.","pos":""}],"SECUND":[{"def":"Arranged on one side only, as flowers or leaves on a stalk.","pos":""}],"SECUNDATE":[{"def":"To make prosperous.","pos":""}],"SECUNDINE":[{"def":"The second coat, or integument, of an ovule, lying within the primine.","pos":""},{"def":"The afterbirth, or placenta and membranes; -- generally used in the plural.","pos":""}],"SECUNDO-GENITURE":[{"def":"A right of inheritance belonging to a second son; a property or possession so inherited.","pos":""}],"SECURABLE":[{"def":"That may be secured.","pos":""}],"SECURE":[{"def":"Free from fear, care, or anxiety; easy in mind; not feeling suspicion or distrust; confident.","pos":""},{"def":"Overconfident; incautious; careless; -- in a bad sense.","pos":""}],"SECURELY":[{"def":"In a secure manner; without fear or apprehension; without danger; safely.","pos":""}],"SECUREMENT":[{"def":"The act of securing; protection.","pos":""}],"SECURENESS":[{"def":"The condition or quality of being secure; exemption from fear; want of vigilance; security.","pos":""}],"SECURER":[{"def":"One who, or that which, secures.","pos":""}],"SECURIFORM":[{"def":"Having the form of an ax hatchet.","pos":""}],"SECURIPALP":[{"def":"One of a family of beetles having the maxillary palpi terminating in a hatchet-shaped joint.","pos":""}],"SECURITY":[{"def":"The condition or quality of being secure; secureness.","pos":""},{"def":"That which secures or makes safe; protection; guard; defense.","pos":""}]}