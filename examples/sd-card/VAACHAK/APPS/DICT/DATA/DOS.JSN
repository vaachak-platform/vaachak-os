{"DOS--DOS":[{"def":"Back to back; as, to sit dos-à-dos in a dogcart; to dance dos- à-dos, or so that two dancers move forward and pass back to back.","pos":""}],"DOSAGE":[{"def":"The administration of medicine in doses; specif.","pos":""}],"DOSE":[{"def":"The quantity of medicine given, or prescribed to be taken, at one time.","pos":""},{"def":"A sufficient quantity; a portion; as much as one can take, or as falls to one to receive.","pos":""}],"DOSEL":[{"def":"Same as Dorsal, n.","pos":""}],"DOSIMETRY":[{"def":"Measurement of doses; specif.","pos":""}],"DOSS":[{"def":"A place to sleep in; a bed; hence, sleep.","pos":""}],"DOSS HOUSE":[{"def":"A cheap lodging house.","pos":""}],"DOSSEL":[{"def":"Same as Dorsal, n.","pos":""}],"DOSSER":[{"def":"A pannier, or basket.","pos":""},{"def":"A hanging tapestry; a dorsal.","pos":""}],"DOSSIER":[{"def":"A bundle containing the papers in reference to some matter.","pos":""}],"DOSSIL":[{"def":"A small ovoid or cylindrical roil or pledget of lint, for keeping a sore, wound, etc.","pos":""},{"def":"A roll of cloth for wiping off the face of a copperplate, leaving the ink in the engraved lines.","pos":""}]}