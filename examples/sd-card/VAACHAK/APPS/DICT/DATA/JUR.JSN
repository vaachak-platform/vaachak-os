{"JURA":[{"def":"The Jurassic period.","pos":""}],"JURA-TRIAS":[{"def":"A term applied to many American Mesozoic strata, in which the characteristics of the Jurassic and Triassic periods appear to be blended.","pos":""}],"JURAL":[{"def":"Of or pertaining to jurisprudence.","pos":""}],"JURASSIC":[{"def":"Of the age of the middle Mesozoic, including, as divided in England and Europe, the Lias, Oölite, and Wealden; -- named from certain rocks of the Jura mountains.","pos":""},{"def":"The Jurassic period or formation; -- called also the Jura.","pos":""}],"JURAT":[{"def":"The memorandum or certificate at the end of an asffidavit, or a bill or answer in chancery, showing when, before whom, and (in English practice), where, it was sworn or affirmed.","pos":""}],"JURATORY":[{"def":"Relating to or comprising an oath; as, juratory caution.","pos":""}],"JUREL":[{"def":"A yellow carangoid fish of the Atlantic and Gulf coasts (Caranx chrysos), most abundant southward, where it is valued as a food fish; -- called also hardtail, horse crevallé, jack, buffalo jack, skipjack, yellow mackerel, and sometimes, improperly, horse mackerel.","pos":""},{"def":"Pertaining to a judge or to jurisprudence; acting in the distribution of justice; used in courts of law; according to law; legal; as, juridical law.","pos":""}],"JURIDICALLY":[{"def":"In a juridical manner.","pos":""}],"JURISCONSULT":[{"def":"A man learned in the civil law; an expert in juridical science; a professor of jurisprudence; a jurist.","pos":""}],"JURISDICTION":[{"def":"The authority of a sovereign power to govern or legislate; the right of making or enforcing laws; the power or right of exercising authority.","pos":""},{"def":"Sphere of authority; the limits within which any particular power may be exercised, or within which a government or a court has authority.","pos":""}],"JURISDICTIONAL":[{"def":"Of or pertaining to jurisdiction; as jurisdictional rights.","pos":""}],"JURISDICTIVE":[{"def":"Having jurisdiction.","pos":""}],"JURISPRUDENCE":[{"def":"The science of juridical law; the knowledge of the laws, customs, and rights of men in a state or community, necessary for the due administration of justice.","pos":""}],"JURISPRUDENT":[{"def":"Understanding law; skilled in jurisprudence.","pos":""}],"JURISPRUDENTIAL":[{"def":"Of or pertaining to jurisprudence.","pos":""}],"JURIST":[{"def":"One who professes the science of law; one versed in the law, especially in the civil law; a writer on civil and international law.","pos":""},{"def":"Of or pertaining to a jurist, to the legal profession, or to jurisprudence.","pos":""}],"JUROR":[{"def":"A member of a jury; a juryman.","pos":""}],"JURY":[{"def":"For temporary use; -- applied to a temporary contrivance.","pos":""}],"JURY-RIGGED":[{"def":"Rigged for temporary service.","pos":""}],"JURYMAN":[{"def":"One who is impaneled on a jury, or who serves as a juror.","pos":""}]}