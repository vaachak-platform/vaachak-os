{"EXCIPIENT":[{"def":"Taking an exception.","pos":""}],"EXCISABLE":[{"def":"Liable or subject to excise; as, tobacco in an excisable commodity.","pos":""}],"EXCISE":[{"def":"In inland duty or impost operating as an indirect tax on the consumer, levied upon certain specified articles, as, tobacco, ale, spirits, etc.","pos":""},{"def":"That department or bureau of the public service charged with the collection of the excise taxes.","pos":""}],"EXCISEMAN":[{"def":"An officer who inspects and rates articles liable to excise duty.","pos":""}],"EXCISION":[{"def":"The act of cutting off from the church; excommunication.","pos":""},{"def":"The removal, especially of small parts, with a cutting instrument.","pos":""}],"EXCITABILITY":[{"def":"The property manifested by living organisms, and the elements and tissues of which they are constituted, of responding to the action of stimulants; irritability; as, nervous excitability.","pos":""}],"EXCITABLE":[{"def":"Capable of being excited, or roused into action; susceptible of excitement; easily stirred up, or stimulated.","pos":""}],"EXCITANT":[{"def":"Tending to excite; exciting.","pos":""}],"EXCITATION":[{"def":"The act of producing excitement (stimulation); also, the excitement produced.","pos":""}],"EXCITATIVE":[{"def":"Having power to excite; tending or serving to excite; excitatory.","pos":""}],"EXCITATOR":[{"def":"A kind of discarder.","pos":""}],"EXCITATORY":[{"def":"Tending to excite; containing excitement; excitative.","pos":""}],"EXCITE":[{"def":"To call forth or increase the vital activity of an organism, or any of its parts.","pos":""}],"EXCITEFUL":[{"def":"Full of exciting qualities; as, an exciteful story; exciteful players.","pos":""}],"EXCITEMENT":[{"def":"A state of aroused or increased vital activity in an organism, or any of its organs or tissues.","pos":""}],"EXCITER":[{"def":"One who, or that which, excites.","pos":""}],"EXCITING":[{"def":"Calling or rousing into action; producing excitement; as, exciting events; an exciting story.","pos":""}],"EXCITIVE":[{"def":"Serving or tending to excite; excitative.","pos":""}],"EXCITO-MOTION":[{"def":"Motion excited by reflex nerves.","pos":""}],"EXCITO-MOTOR":[{"def":"Excitomotory; as, excito-motor power or causes.","pos":""}],"EXCITO-MOTORY":[{"def":"Exciting motion; -- said of that portion of the nervous system concerned in reflex action, by which impressions are transmitted to a nerve center and then reflected back so as to produce muscular contraction without sensation or volition.","pos":""}],"EXCITO-NUTRIENT":[{"def":"Exciting nutrition; said of the reflex influence by which the nutritional processes are either excited or modified.","pos":""}],"EXCITO-SECRETORY":[{"def":"Exciting secretion; -- said of the influence exerted by reflex action on the function of secretion, by which the various glands are excited to action.","pos":""}]}