{"INTERSTICE":[{"def":"That which intervenes between one thing and another; especially, a space between things closely set, or between the parts which compose a body; a narrow chink; a crack; a crevice; a hole; an interval; as, the interstices of a wall.","pos":""},{"def":"An interval of time; specifically (R.","pos":""}],"INTERSTICED":[{"def":"Provided with interstices; having interstices between; situated at intervals.","pos":""}],"INTERSTITIAL":[{"def":"Of or pertaining to interstices; intermediate; within the tissues; as, interstitial cavities or spaces in the tissues of animals or plants.","pos":""}],"INTERSTITION":[{"def":"An intervening period of time; interval.","pos":""}],"INTERSTRATIFICATION":[{"def":"Stratification among or between other layers or strata; also, that which is interstratified.","pos":""}],"INTERSTRATIFIED":[{"def":"Stratified among or between other bodies; as, interstratified rocks.","pos":""}],"INTERSTRATIFY":[{"def":"To put or insert between other strata.","pos":""}],"INTERTANGLE":[{"def":"To entangle; to intertwine.","pos":""}],"INTERTARSAL":[{"def":"Between the tarsal bones; as, the intertarsal articulations.","pos":""}],"INTERTEX":[{"def":"To intertwine; to weave or bind together.","pos":""}],"INTERTEXTURE":[{"def":"The act of interweaving, or the state of being interwoven; that which is interwoven.","pos":""}],"INTERTIE":[{"def":"In any framed work, a horizontal tie other than sill and plate or other principal ties, securing uprights to one another.","pos":""}],"INTERTRAFFIC":[{"def":"Mutual trade of traffic.","pos":""}],"INTERTRANSPICUOUS":[{"def":"Transpicuous within or between.","pos":""}],"INTERTRANSVERSE":[{"def":"Between the transverse processes of the vertebræ.","pos":""}],"INTERTRIGO":[{"def":"A rubbing or chafing of the skin; especially, an abrasion or excoriation of the skin between folds, as in fat or neglected children.","pos":""}],"INTERTROCHANTERIC":[{"def":"Between the trochanters of the femur.","pos":""}],"INTERTROPICAL":[{"def":"Situated between or within the tropics.","pos":""}],"INTERTUBULAR":[{"def":"Between tubes or tubules; as, intertubular cells; intertubular substance.","pos":""}],"INTERTWINE":[{"def":"To unite by twining one with another; to entangle; to interlace.","pos":""}],"INTERTWININGLY":[{"def":"By intertwining or being intertwined.","pos":""}],"INTERTWIST":[{"def":"To twist together one with another; to intertwine.","pos":""}],"INTERTWISTINGLY":[{"def":"By intertwisting, or being intertwisted.","pos":""},{"def":"Between ungulæ; as, interungular glands.","pos":""}],"INTERURBAN":[{"def":"Going between, or connecting, cities or towns; as, interurban electric railways.","pos":""}],"INTERVAL":[{"def":"Difference in pitch between any two tones.","pos":""},{"def":"A tract of low ground between hills, or along the banks of a stream, usually alluvial land, enriched by the overflowings of the river, or by fertilizing deposits of earth from the adjacent hills.","pos":""}],"INTERVALLUM":[{"def":"And a' shall laugh without intervallums.","pos":""}],"INTERVARY":[{"def":"To alter or vary between; to change.","pos":""}],"INTERVEINED":[{"def":"Intersected, as with veins.","pos":""}],"INTERVENE":[{"def":"To come between, or to be between, persons or things; -- followed by between; as, the Mediterranean intervenes between Europe and Africa.","pos":""},{"def":"To occur, fall, or come between, points of time, or events; as, an instant intervened between the flash and the report; nothing intervened ( i.","pos":""}],"INTERVENER":[{"def":"One who intervenes; especially (Law), a person who assumes a part in a suit between others.","pos":""},{"def":"Intervention; interposition.","pos":""}],"INTERVENIENT":[{"def":"Being or coming between; intercedent; interposed.","pos":""}],"INTERVENT":[{"def":"To thwart; to obstruct.","pos":""}],"INTERVENTION":[{"def":"The act by which a third person, to protect his own interest, interposes and becomes a party to a suit pending between other parties.","pos":""}],"INTERVENTOR":[{"def":"One who intervenes; a mediator; especially (Eccles.","pos":""}],"INTERVENTRICULAR":[{"def":"Between the ventricles; as, the interventricular partition of the heart.","pos":""}],"INTERVERT":[{"def":"To turn to another course or use.","pos":""}],"INTERVERTEBRAL":[{"def":"Between vertebræ.","pos":""}],"INTERVIEW":[{"def":"A mutual sight or view; a meeting face to face; usually, a formal or official meeting for consultation; a conference; as, the secretary had an interview with the President.","pos":""},{"def":"A conservation, or questioning, for the purpose of eliciting information for publication; the published statement so elicited.","pos":""}],"INTERVIEWER":[{"def":"One who interviews; especially, one who obtains an interview with another for the purpose of eliciting his opinions or obtaining information for publication.","pos":""}],"INTERVIEWING":[{"def":"The act or custom of holding an interview or interviews.","pos":""}],"INTERVISIBLE":[{"def":"Mutually visible, or in sight, the one from the other, as stations.","pos":""}],"INTERVISIT":[{"def":"To exchange visits.","pos":""}],"INTERVITAL":[{"def":"Between two lives.","pos":""}],"INTERVOCALIC":[{"def":"Situated between vowels; immediately preceded and followed by vowel sounds, as, p in occupy, d in idea, etc.","pos":""}],"INTERVOLUTION":[{"def":"The state of being intervolved or coiled up; a convolution; as, the intervolutions of a snake.","pos":""}],"INTERVOLVE":[{"def":"To involve one within another; to twist or coil together.","pos":""}],"INTERWEAVE":[{"def":"To weave together; to intermix or unite in texture or construction; to intertwine; as, threads of silk and cotton interwoven.","pos":""},{"def":"To intermingle; to unite intimately; to connect closely; as, to interweave truth with falsehood.","pos":""}],"INTERWISH":[{"def":"To wish mutually in regarded to each other.","pos":""}],"INTERWORKING":[{"def":"The act of working in together; interweaving.","pos":""}],"INTERWORLD":[{"def":"A world between other worlds.","pos":""}],"INTERWREATHE":[{"def":"To weave into a wreath; to intertwine.","pos":""}]}