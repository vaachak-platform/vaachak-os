{"RADDLE":[{"def":"A long, flexible stick, rod, or branch, which is interwoven with others, between upright posts or stakes, in making a kind of hedge or fence.","pos":""},{"def":"A hedge or fence made with raddles; -- called also raddle hedge.","pos":""}],"RADEAU":[{"def":"A float; a raft.","pos":""}],"RADIAL":[{"def":"Of or pertaining to a radius or ray; consisting of, or like, radii or rays; radiated; as, (Bot.","pos":""}],"RADIAL ENGINE":[{"def":"An engine, usually an internal-combustion engine of a certain type (the radial type) having several cylinders arranged radially like the spokes of a complete wheel.","pos":""}],"RADIALE":[{"def":"The bone or cartilage of the carpus which articulates with the radius and corresponds to the scaphoid bone in man.","pos":""},{"def":"Radial plates in the calyx of a crinoid.","pos":""}],"RADIALLY":[{"def":"In a radial manner.","pos":""}],"RADIAN":[{"def":"An arc of a circle which is equal to the radius, or the angle measured by such an arc.","pos":""},{"def":"The quality of being radiant; brilliancy; effulgence; vivid brightness; as, the radiance of the sun.","pos":""}],"RADIANT":[{"def":"Giving off rays; -- said of a bearing; as, the sun radiant; a crown radiant.","pos":""},{"def":"Having a raylike appearance, as the large marginal flowers of certain umbelliferous plants; -- said also of the cluster which has such marginal flowers.","pos":""}],"RADIANT ENGINE":[{"def":"A semiradial engine.","pos":""}],"RADIANTLY":[{"def":"In a radiant manner; with glittering splendor.","pos":""}],"RADIATA":[{"def":"An extensive artificial group of invertebrates, having all the parts arranged radially around the vertical axis of the body, and the various organs repeated symmetrically in each ray or spheromere.","pos":""}],"RADIATE":[{"def":"To emit rays; to be radiant; to shine.","pos":""},{"def":"To proceed in direct lines from a point or surface; to issue in rays, as light or heat.","pos":""}],"RADIATE-VEINED":[{"def":"Having the principal veins radiating, or diverging, from the apex of the petiole; -- said of such leaves as those of the grapevine, most maples, and the castor-oil plant.","pos":""}],"RADIATED":[{"def":"Belonging to the Radiata.","pos":""}],"RADIATELY":[{"def":"In a radiate manner; with radiation or divergence from a center.","pos":""}],"RADIATIFORM":[{"def":"Having the marginal florets enlarged and radiating but not ligulate, as in the capitula or heads of the cornflower, Gray.","pos":""}],"RADIATION":[{"def":"The act of radiating, or the state of being radiated; emission and diffusion of rays of light; beamy brightness.","pos":""},{"def":"The shooting forth of anything from a point or surface, like the diverging rays of light; as, the radiation of heat.","pos":""}],"RADIATIVE":[{"def":"Capable of radiating; acting by radiation.","pos":""}],"RADIATOR":[{"def":"That which radiates or emits rays, whether of light or heat; especially, that part of a heating apparatus from which the heat is radiated or diffused; as, a stream radiator.","pos":""}],"RADICAL":[{"def":"Relating, or belonging, to the root, or ultimate source of derivation; as, a radical verbal form.","pos":""},{"def":"Of or pertaining to a radix or root; as, a radical quantity; a radical sign.","pos":""}],"RADICALISM":[{"def":"The quality or state of being radical; specifically, the doctrines or principles of radicals in politics or social reform.","pos":""}],"RADICALITY":[{"def":"Germinal principle; source; origination.","pos":""},{"def":"Radicalness; relation to root in essential to a root in essential nature or principle.","pos":""}],"RADICALLY":[{"def":"In a radical manner; at, or from, the origin or root; fundamentally; as, a scheme or system radically wrong or defective.","pos":""},{"def":"Without derivation; primitively; essentially.","pos":""}],"RADICALNESS":[{"def":"Quality or state of being radical.","pos":""}],"RADICANT":[{"def":"Taking root on, or above, the ground; rooting from the stem, as the trumpet creeper and the ivy.","pos":""}],"RADICATE":[{"def":"To take root; to become rooted.","pos":""}],"RADICATED":[{"def":"Rooted; specifically: (a) (Bot.","pos":""}],"RADICATION":[{"def":"The disposition of the roots of a plant.","pos":""}],"RADICEL":[{"def":"A small branch of a root; a rootlet.","pos":""}],"RADICIFORM":[{"def":"Having the nature or appearance of a radix or root.","pos":""}],"RADICULAR":[{"def":"Of or performance to roots, or the root of a plant.","pos":""}],"RADICULOSE":[{"def":"Producing numerous radicles, or rootlets.","pos":""}],"RADIO-":[{"def":"A combining form indicating connection with, or relation to, a radius or ray; specifically (Anat.","pos":""}],"RADIO-ACTIVE":[{"def":"Capable of luminescence under the action of cathode rays, X rays, or any of the allied forms of radiation.","pos":""}],"RADIO-FLAGELLATA":[{"def":"A group of Protozoa having both flagella and pseudopodia.","pos":""}],"RADIOCONDUCTOR":[{"def":"A substance or device that has its conductivity altered in some way by electric waves, as a coherer.","pos":""}],"RADIOGRAPH":[{"def":"A picture produced by the Röntgen rays upon a sensitive surface, photographic or fluorescent, especially a picture of opaque objects traversed by the rays.","pos":""}],"RADIOGRAPHY":[{"def":"Art or process of making radiographs.","pos":""}],"RADIOLARIA":[{"def":"Order of rhizopods, usually having a siliceous skeleton, or shell, and sometimes radiating spicules.","pos":""}],"RADIOLARIAN":[{"def":"Of or pertaining to the Radiolaria.","pos":""},{"def":"One of the Radiolaria.","pos":""}],"RADIOLI":[{"def":"The barbs of the radii of a feather; barbules.","pos":""}],"RADIOMETER":[{"def":"An instrument designed for measuring the mechanical effect of radiant energy.","pos":""}],"RADIOMETRY":[{"def":"The use of the radiometer, or the measurement of radiation.","pos":""}],"RADIOMICROMETER":[{"def":"A very sensitive modification or application of the thermopile, used for indicating minute changes of radiant heat, or temperature.","pos":""}],"RADIOPHARE":[{"def":"A radiotelegraphic station serving solely for determining the position of ships.","pos":""}],"RADIOPHONE":[{"def":"An apparatus for the production of sound by the action of luminous or thermal rays.","pos":""}],"RADIOPHONY":[{"def":"The art or practice of using the radiophone.","pos":""}],"RADIOPTICON":[{"def":"See Projector, above.","pos":""}],"RADIOSCOPY":[{"def":"Direct observation of objects opaque to light by means of some other form of radiant energy, as the Röntgen rays.","pos":""}],"RADIOTELEGRAM":[{"def":"A message transmitted by radiotelegraph.","pos":""}],"RADIOTELEGRAPH":[{"def":"A wireless telegraph.","pos":""}],"RADIOTELEGRAPHIC":[{"def":"Of or pertaining to radiotelegraphy; employing, or used or employed in, radiotelegraphy.","pos":""}],"RADIOTELEGRAPHY":[{"def":"Telegraphy using the radiant energy of electrical (Hertzian) waves; wireless telegraphy; -- the term adopted for use by the Radiotelegraphic Convention of 1912.","pos":""}],"RADIOTELEPHONE":[{"def":"A wireless telephone.","pos":""}],"RADIOTHERAPY":[{"def":"Treatment of disease by means of Röntgen rays or other forms of radioactivity.","pos":""}],"RADIOTHORIUM":[{"def":"A radioactive substance apparently formed as a product from thorium.","pos":""}],"RADIOUS":[{"def":"Consisting of rays, and light.","pos":""},{"def":"Radiating; radiant.","pos":""}],"RADISH":[{"def":"The pungent fleshy root of a well-known cruciferous plant (Paphanus sativus); also, the whole plant.","pos":""}],"RADIUM":[{"def":"An intensely radioactive metallic element found (combined) in minute quantities in pitchblende, and various other uranium minerals.","pos":""}],"RADIUS":[{"def":"A right line drawn or extending from the center of a circle to the periphery; the semidiameter of a circle or sphere.","pos":""},{"def":"The preaxial bone of the forearm, or brachium, corresponding to the tibia of the hind limb.","pos":""}],"RADIUS VECTOR":[{"def":"A straight line (or the length of such line) connecting any point, as of a curve, with a fixed point, or pole, round which the straight line turns, and to which it serves to refer the successive points of a curve, in a system of polar coördinates.","pos":""},{"def":"An ideal straight line joining the center of an attracting body with that of a body describing an orbit around it, as a line joining the sun and a planet or comet, or a planet and its satellite.","pos":""}],"RADIX":[{"def":"A primitive, from which spring other words; a radical; a root; an etymon.","pos":""},{"def":"The root of a plant.","pos":""}],"RADULA":[{"def":"The chitinous ribbon bearing the teeth of mollusks; -- called also lingual ribbon, and tongue.","pos":""}],"RADULIFORM":[{"def":"Rasplike; as, raduliform teeth.","pos":""}]}