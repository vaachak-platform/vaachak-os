{"HERIE":[{"def":"To praise; to worship.","pos":""}],"HERIOT":[{"def":"Formerly, a payment or tribute of arms or military accouterments, or the best beast, or chattel, due to the lord on the death of a tenant; in modern use, a customary tribute of goods or chattels to the lord of the fee, paid on the decease of a tenant.","pos":""}],"HERIOTABLE":[{"def":"Subject to the payment of a heriot.","pos":""}],"HERISSON":[{"def":"A beam or bar armed with iron spikes, and turning on a pivot; - - used to block up a passage.","pos":""}],"HERITABILITY":[{"def":"The state of being heritable.","pos":""}],"HERITABLE":[{"def":"Capable of being inherited or of passing by inheritance; inheritable.","pos":""},{"def":"Capable of inheriting or receiving by inheritance.","pos":""}],"HERITAGE":[{"def":"A possession; the Israelites, as God's chosen people; also, a flock under pastoral charge.","pos":""}],"HERITANCE":[{"def":"Heritage; inheritance.","pos":""}],"HERITOR":[{"def":"A proprietor or landholder in a parish.","pos":""}]}