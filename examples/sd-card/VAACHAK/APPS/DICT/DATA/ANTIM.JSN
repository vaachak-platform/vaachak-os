{"ANTIMACASSAR":[{"def":"A cover for the back or arms of a chair or sofa, etc.","pos":""}],"ANTIMAGISTRICAL":[{"def":"Opposed to the office or authority of magistrates.","pos":""}],"ANTIMALARIAL":[{"def":"Good against malaria.","pos":""}],"ANTIMASK":[{"def":"A secondary mask, or grotesque interlude, between the parts of a serious mask.","pos":""}],"ANTIMASON":[{"def":"One opposed to Freemasonry.","pos":""}],"ANTIMASONRY":[{"def":"Opposition to Freemasonry.","pos":""}],"ANTIMEPHITIC":[{"def":"Good against mephitic or deletplwious gases.","pos":""},{"def":"A remedy against mephitic gases.","pos":""}],"ANTIMERE":[{"def":"One of the two halves of bilaterally symmetrical animals; one of any opposite symmetrical or homotypic parts in animals and plants.","pos":""}],"ANTIMETABOLE":[{"def":"A figure in which the same words or ideas are repeated in transposed order.","pos":""}],"ANTIMETATHESIS":[{"def":"An antithesis in which the members are repeated in inverse order.","pos":""}],"ANTIMETER":[{"def":"A modification of the quadrant, for measuring small angles.","pos":""},{"def":"Opposed to monarchial government.","pos":""}],"ANTIMONARCHIST":[{"def":"An enemy to monarchial government.","pos":""}],"ANTIMONATE":[{"def":"A compound of antimonic acid with a base or basic radical.","pos":""}],"ANTIMONIAL":[{"def":"Of or pertaining to antimony.","pos":""},{"def":"A preparation or medicine containing antimony.","pos":""}],"ANTIMONIATED":[{"def":"Combined or prepared with antimony; as, antimoniated tartar.","pos":""}],"ANTIMONIC":[{"def":"Pertaining to, or derived from, antimony; -- said of those compounds of antimony in which this element has its highest equivalence; as, antimonic acid.","pos":""}],"ANTIMONIOUS":[{"def":"Pertaining to, or derived from, antimony; -- said of those compounds of antimony in which this element has an equivalence next lower than the highest; as, antimonious acid.","pos":""}],"ANTIMONITE":[{"def":"A compound of antimonious acid and a base or basic radical.","pos":""}],"ANTIMONIURETED":[{"def":"Combined with or containing antimony; as, antimoniureted hydrogen.","pos":""}],"ANTIMONSOON":[{"def":"The upper, contrary-moving current of the atmosphere over a monsoon.","pos":""}],"ANTIMONY":[{"def":"An elementary substance, resembling a metal in its appearance and physical properties, but in its chemical relations belonging to the class of nonmetallic substances.","pos":""}]}