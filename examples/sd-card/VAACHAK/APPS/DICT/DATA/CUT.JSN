{"CUT":[{"def":"To sparate the parts of with, or as with, a sharp instrument; to make an incision in; to gash; to sever; to divide.","pos":""},{"def":"To sever and cause to fall for the purpose of gathering; to hew; to mow or reap.","pos":""}],"CUT-OFF":[{"def":"That which cuts off or shortens, as a nearer passage or road.","pos":""}],"CUT-OUT":[{"def":"Cut\"-out` (kt\"out`), n.","pos":""}],"CUTANEOUS":[{"def":"Of pertaining to the skin; existing on, or affecting, the skin; as, a cutaneous disease; cutaneous absorption; cutaneous respiration.","pos":""}],"CUTAWAY":[{"def":"Having a part cut off or away; having the corners rounded or cut away.","pos":""}],"CUTCHERY":[{"def":"A hindoo hall of justice.","pos":""}],"CUTE":[{"def":"Clever; sharp; shrewd; ingenious; cunning.","pos":""}],"CUTENESS":[{"def":"Acuteness; cunning.","pos":""}],"CUTGRASS":[{"def":"A grass with leaves having edges furnished with very minute hooked prickles, which form a cutting edge; one or more species of Leersia.","pos":""}],"CUTICLE":[{"def":"The scarfskin or epidermis.","pos":""},{"def":"The outermost skin or pellicle of a plant, found especially in leaves and young stems.","pos":""}],"CUTICULAR":[{"def":"Pertaining to the cuticle, or external coat of the skin; epidermal.","pos":""}],"CUTIN":[{"def":"The substance which, added to the material of a cell wall, makes it waterproof, as in cork.","pos":""}],"CUTINIZATION":[{"def":"The conversion of cell walls into a material which repels water, as in cork.","pos":""}],"CUTINIZE":[{"def":"To change into cutin.","pos":""}],"CUTLASS":[{"def":"A short, heavy, curving sword, used in the navy.","pos":""}],"CUTLER":[{"def":"One who makes or deals in cutlery, or knives and other cutting instruments.","pos":""}],"CUTLERY":[{"def":"The business of a cutler.","pos":""},{"def":"Edged or cutting instruments, collectively.","pos":""}],"CUTLET":[{"def":"A piece of meat, especially of veal or mutton, cut for broiling.","pos":""}],"CUTLING":[{"def":"The art of making edged tools or cutlery.","pos":""}],"CUTOSE":[{"def":"A variety of cellulose, occuring as a fine transparent membrane covering the aerial organs of plants, and forming an essential ingredient of cork; by oxidation it passes to suberic acid.","pos":""}],"CUTPURSE":[{"def":"One who cuts purses for the sake of stealing them or their contents (an act common when men wore purses fastened by a string to their girdles); one who steals from the person; a pickpocket To have an open ear, a quick eye, and a nimble hand, is necessary for a cutpurse.","pos":""}],"CUTTER":[{"def":"One who cuts; as, a stone cutter; a die cutter; esp.","pos":""},{"def":"That which cuts; a machine or part of a machine, or a tool or instrument used for cutting, as that part of a mower which severs the stalk, or as a paper cutter.","pos":""}],"CUTTHROAT":[{"def":"One who cuts throats; a murderer; an assassin.","pos":""}],"CUTTING":[{"def":"The act or process of making an incision, or of severing, felling, shaping, etc.","pos":""}],"CUTTINGLY":[{"def":"In a cutting manner.","pos":""}],"CUTTLE":[{"def":"A cephalopod of the genus Sepia, having an internal shell, large eyes, and ten arms furnished with denticulated suckers, by means of which it secures its prey.","pos":""}],"CUTTLE BONE":[{"def":"The shell or bone of cuttlefishes, used for various purposes, as for making polishing powder, etc.","pos":""}],"CUTTOO PLATE":[{"def":"A hood over the end of a wagon wheel hub to keep dirt away from the axle.","pos":""}],"CUTTY":[{"def":"Short; as, a cutty knife; a cutty sark.","pos":""}],"CUTTYSTOOL":[{"def":"A low stool [Scot.","pos":""},{"def":"A seat in old Scottish churches, where offenders were made to sit, for public rebuke by the minister.","pos":""}],"CUTWAL":[{"def":"The chief police officer of a large city.","pos":""}],"CUTWATER":[{"def":"A sea bird of the Atlantic (Rhynchops nigra); -- called also black skimmer, scissorsbill, and razorbill.","pos":""}],"CUTWORK":[{"def":"An ancient term for embroidery, esp.","pos":""}],"CUTWORM":[{"def":"A caterpillar which at night eats off young plants of cabbage, corn, etc.","pos":""}]}