{"NEE":[{"def":"Born; -- a term sometimes used in introducing the name of the family to which a married woman belongs by birth; as, Madame de Staël, née Necker.","pos":""}],"NEED":[{"def":"A state that requires supply or relief; pressing occasion for something; necessity; urgent want.","pos":""},{"def":"Want of the means of subsistence; poverty; indigence; destitution.","pos":""}],"NEEDER":[{"def":"One who needs anything.","pos":""}],"NEEDFUL":[{"def":"Full of need; in need or want; needy; distressing.","pos":""},{"def":"Necessary for supply or relief; requisite.","pos":""}],"NEEDILY":[{"def":"In a needy condition or manner; necessarily.","pos":""}],"NEEDINESS":[{"def":"The state or quality of being needy; want; poverty; indigence.","pos":""}],"NEEDLE":[{"def":"One of the needle-shaped secondary leaves of pine trees.","pos":""}],"NEEDLE-POINTED":[{"def":"Pointed as needles.","pos":""}],"NEEDLEBOOK":[{"def":"A book-shaped needlecase, having leaves of cloth into which the needles are stuck.","pos":""}],"NEEDLECASE":[{"def":"A case to keep needles.","pos":""}],"NEEDLEFUL":[{"def":"As much thread as is used in a needle at one time.","pos":""}],"NEEDLER":[{"def":"One who makes or uses needles; also, a dealer in needles.","pos":""}],"NEEDLESS":[{"def":"Not wanted; unnecessary; not requiste; as, needless labor; needless expenses.","pos":""}],"NEEDLESTONE":[{"def":"Natrolite; -- called also needle zeolite.","pos":""}],"NEEDLEWOMAN":[{"def":"A woman who does needlework; a seamstress.","pos":""}],"NEEDLEWORK":[{"def":"Work executed with a needle; sewed work; sewing; embroidery; also, the business of a seamstress.","pos":""},{"def":"The combination of timber and plaster making the outside framework of some houses.","pos":""}],"NEEDLY":[{"def":"Like a needle or needles; as, a needly horn; a needly beard.","pos":""}],"NEEDMENT":[{"def":"Something needed or wanted.","pos":""},{"def":"Outfit; necessary luggage.","pos":""}],"NEEDS":[{"def":"Of necessity; necessarily; indispensably; -- often with must, and equivalent to of need.","pos":""}],"NEEDY":[{"def":"Distressed by want of the means of living; very por; indigent; necessitous.","pos":""},{"def":"Necessary; requiste.","pos":""}],"NEEM TREE":[{"def":"An Asiatic name for Melia Azadirachta, and M.","pos":""}]}