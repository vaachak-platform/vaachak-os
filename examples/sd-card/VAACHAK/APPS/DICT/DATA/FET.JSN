{"FET":[{"def":"And from the other fifty soon the prisoner fet.","pos":""}],"FETAL":[{"def":"Pertaining to, or connected with, a fetus; as, fetal circulation; fetal membranes.","pos":""}],"FETATION":[{"def":"The formation of a fetus in the womb; pregnancy.","pos":""}],"FETCH":[{"def":"To bear toward the person speaking, or the person or thing from whose point of view the action is contemplated; to go and bring; to get.","pos":""},{"def":"To obtain as price or equivalent; to sell for.","pos":""}],"FETCHER":[{"def":"One wo fetches or brings.","pos":""}],"FETE":[{"def":"To feast; to honor with a festival.","pos":"noun"},{"def":"A believer in fetiches.","pos":"noun"}],"FETICIDE":[{"def":"The act of killing the fetus in the womb; the offense of procuring an abortion.","pos":""}],"FETID":[{"def":"Having an offensive smell; stinking.","pos":""}],"FETIDITY":[{"def":"Fet*id\"i*ty ( or ), n.","pos":""}],"FETIDNESS":[{"def":"The quality or state of being fetid.","pos":""}],"FETIFEROUS":[{"def":"Producing young, as animals.","pos":""}],"FETIS":[{"def":"Neat; pretty; well made; graceful.","pos":""}],"FETISELY":[{"def":"Neatly; gracefully; properly.","pos":""}],"FETLOCK":[{"def":"The cushionlike projection, bearing a tuft of long hair, on the back side of the leg above the hoof of the horse and similar animals.","pos":""}],"FETOR":[{"def":"A strong, offensive smell; stench; fetidness.","pos":""}],"FETTER":[{"def":"A chain or shackle for the feet; a chain by which an animal is confined by the foot, either made fast or disabled from free and rapid motion; a bond; a shackle.","pos":""},{"def":"Anything that confines or restrains; a restraint.","pos":""}],"FETTERED":[{"def":"Seeming as if fettered, as the feet pf certain animals which bend backward, and appear unfit for walking.","pos":""}],"FETTERER":[{"def":"One who fetters.","pos":""}],"FETTERLESS":[{"def":"Free from fetters.","pos":""}],"FETTLE":[{"def":"To cover or line with a mixture of ore, cinders, etc.","pos":""}],"FETTLING":[{"def":"A mixture of ore, cinders, etc.","pos":""},{"def":"The operation of shaving or smoothing the surface of undried clay ware.","pos":""}],"FETUS":[{"def":"The young or embryo of an animal in the womb, or in the egg; often restricted to the later stages in the development of viviparous and oviparous animals, embryo being applied to the earlier stages.","pos":""}],"FETWAH":[{"def":"A written decision of a Turkish mufti on some point of law.","pos":""}]}