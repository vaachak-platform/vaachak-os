{"OCULAR":[{"def":"Of or pertaining to the eye; optic.","pos":""}],"OCULARLY":[{"def":"By the eye, or by actual sight.","pos":""}],"OCULARY":[{"def":"Of or pertaining to the eye; ocular; optic; as, oculary medicines.","pos":""}],"OCULIFORM":[{"def":"In the form of an eye; resembling an eye; as, an oculiform pebble.","pos":""}],"OCULINA":[{"def":"A genus of tropical corals, usually branched, and having a very volid texture.","pos":""}],"OCULINACEA":[{"def":"A suborder of corals including many reef-building species, having round, starlike calicles.","pos":"noun"}],"OCULIST":[{"def":"One skilled in treating diseases of the eye.","pos":""}],"OCULO-":[{"def":"A combining form from L.","pos":""}],"OCULOMOTOR":[{"def":"Of or pertaining to the movement of the eye; -- applied especially to the common motor nerves (or third pair of cranial nerves) which supply many of the muscles of the orbit.","pos":""},{"def":"The oculomotor nerve.","pos":""}],"OCULONASAL":[{"def":"Of or pertaining to the region of the eye and the nose; as, the oculonasal, or nasal, nerve, one of the branches of the ophthalmic.","pos":""}],"OCULUS":[{"def":"A round window, usually a small one.","pos":""}]}