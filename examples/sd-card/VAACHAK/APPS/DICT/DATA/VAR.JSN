{"VARA":[{"def":"A Spanish measure of length equal to about one yard.","pos":""}],"VARANGIAN":[{"def":"One of the Northmen who founded a dynasty in Russia in the 9th century; also, one of the Northmen composing, at a later date, the imperial bodyguard at Constantinople.","pos":""}],"VARANUS":[{"def":"A genus of very large lizards native of Asia and Africa.","pos":""}],"VARE":[{"def":"A wand or staff of authority or justice.","pos":""}],"VAREC":[{"def":"The calcined ashes of any coarse seaweed used for the manufacture of soda and iodine; also, the seaweed itself; fucus; wrack.","pos":""}],"VARGUENO":[{"def":"A decorative cabinet, of a form originating in Spain, the body being rectangular and supported on legs or an ornamental framework and the front opening downwards on hinges to serve as a writing desk.","pos":""}],"VARI":[{"def":"The ringtailed lemur (Lemur catta) of Madagascar.","pos":""}],"VARIABILITY":[{"def":"The power possessed by living organisms, both animal and vegetable, of adapting themselves to modifications or changes in their environment, thus possibly giving rise to ultimate variation of structure or function.","pos":""}],"VARIABLE":[{"def":"Having the capacity of varying or changing; capable of alternation in any manner; changeable; as, variable winds or seasons; a variable quantity.","pos":""},{"def":"Liable to vary; too susceptible of change; mutable; fickle; unsteady; inconstant; as, the affections of men are variable; passions are variable.","pos":""}],"VARIABLENESS":[{"def":"The quality or state of being variable; variability.","pos":""}],"VARIABLY":[{"def":"In a variable manner.","pos":""}],"VARIANCE":[{"def":"A disagreement or difference between two parts of the same legal proceeding, which, to be effectual, ought to agree, -- as between the writ and the declaration, or between the allegation and the proof.","pos":""}],"VARIANT":[{"def":"Varying in from, character, or the like; variable; different; diverse.","pos":""},{"def":"Changeable; changing; fickle.","pos":""}],"VARIATE":[{"def":"To alter; to make different; to vary.","pos":""}],"VARIATION":[{"def":"Change of termination of words, as in declension, conjugation, derivation, etc.","pos":""},{"def":"Repetition of a theme or melody with fanciful embellishments or modifications, in time, tune, or harmony, or sometimes change of key; the presentation of a musical thought in new and varied aspects, yet so that the essential features of the original shall still preserve their identity.","pos":""}],"VARICIFORM":[{"def":"Resembling a varix.","pos":""}],"VARICOCELE":[{"def":"A varicose enlargement of the veins of the spermatic cord; also, a like enlargement of the veins of the scrotum.","pos":""}],"VARICOSE":[{"def":"Intended for the treatment of varicose veins; -- said of elastic stockings, bandages.","pos":""}],"VARICOSIS":[{"def":"The formation of varices; varicosity.","pos":""}],"VARICOSITY":[{"def":"The quality or state of being varicose.","pos":""},{"def":"An enlargement or swelling in a vessel, fiber, or the like; a varix; as, the varicosities of nerve fibers.","pos":""}],"VARICOTOMY":[{"def":"Excision of a varicosity.","pos":""}],"VARIED":[{"def":"Changed; altered; various; diversified; as, a varied experience; varied interests; varied scenery.","pos":""}],"VARIEGATE":[{"def":"To diversify in external appearance; to mark with different colors; to dapple; to streak; as, to variegate a floor with marble of different colors.","pos":""}],"VARIEGATED":[{"def":"Having marks or patches of different colors; as, variegated leaves, or flowers.","pos":""}],"VARIEGATION":[{"def":"The act of variegating or diversifying, or the state of being diversified, by different colors; diversity of colors.","pos":""}],"VARIER":[{"def":"A wanderer; one who strays in search of variety.","pos":""}],"VARIETAL":[{"def":"Of or pertaining to a variety; characterizing a variety; constituting a variety, in distinction from an individual or species.","pos":""}],"VARIETAS":[{"def":"A variety; -- used in giving scientific names, and often abbreviated to var.","pos":""}],"VARIETY":[{"def":"The quality or state of being various; intermixture or succession of different things; diversity; multifariousness.","pos":""},{"def":"That which is various.","pos":""}],"VARIETY SHOW":[{"def":"A stage entertainment of successive separate performances, usually songs, dances, acrobatic feats, dramatic sketches, exhibitions of trained animals, or any specialties.","pos":""}],"VARIFORM":[{"def":"Having different shapes or forms.","pos":""}],"VARIFORMED":[{"def":"Formed with different shapes; having various forms; variform.","pos":""}],"VARIFY":[{"def":"To make different; to vary; to variegate.","pos":""}],"VARIOLATION":[{"def":"Inoculation with smallpox.","pos":""}],"VARIOLITE":[{"def":"A kind of diorite or diabase containing imbedded whitish spherules, which give the rock a spotted appearance.","pos":""}],"VARIOLITIC":[{"def":"Of, pertaining to, or resembling, variolite.","pos":""}],"VARIOLOID":[{"def":"Resembling smallpox; pertaining to the disease called varioloid.","pos":""}],"VARIOLOUS":[{"def":"Of or pertaining to the smallpox; having pits, or sunken impressions, like those of the smallpox; variolar; variolic.","pos":""}],"VARIOMETER":[{"def":"An instrument for comparing magnetic forces, esp.","pos":""}],"VARIORUM":[{"def":"Containing notes by different persons; -- applied to a publication; as, a variorum edition of a book.","pos":""}],"VARIOUS":[{"def":"Different; diverse; several; manifold; as, men of various names; various occupations; various colors.","pos":""},{"def":"Changeable; uncertain; inconstant; variable.","pos":""}],"VARIOUSLY":[{"def":"In various or different ways.","pos":""}],"VARISCITE":[{"def":"An apple-green mineral occurring in reniform masses.","pos":""}],"VARISSE":[{"def":"An imperfection on the inside of the hind leg in horses, different from a curb, but at the same height, and frequently injuring the sale of the animal by growing to an unsightly size.","pos":""}],"VARIX":[{"def":"A uneven, permanent dilatation of a vein.","pos":""},{"def":"One of the prominent ridges or ribs extending across each of the whorls of certain univalve shells.","pos":""}],"VARK":[{"def":"The bush hog, or boshvark.","pos":""}],"VARLET":[{"def":"A servant, especially to a knight; an attendant; a valet; a footman.","pos":""},{"def":"Hence, a low fellow; a scoundrel; a rascal; as, an impudent varlet.","pos":""}],"VARLETRY":[{"def":"The rabble; the crowd; the mob.","pos":""}],"VARNISH":[{"def":"A viscid liquid, consisting of a solution of resinous matter in an oil or a volatile liquid, laid on work with a brush, or otherwise.","pos":""},{"def":"That which resembles varnish, either naturally or artificially; a glossy appearance.","pos":""}],"VARNISHER":[{"def":"One who varnishes; one whose occupation is to varnish.","pos":""},{"def":"One who disguises or palliates; one who gives a fair external appearance.","pos":""}],"VARNISHING":[{"def":"The act of laying on varnish; also, materials for varnish.","pos":""}],"VARTABED":[{"def":"A doctor or teacher in the Armenian church.","pos":""}],"VARUNA":[{"def":"The god of the waters; the Indian Neptune.","pos":""}],"VARUS":[{"def":"A deformity in which the foot is turned inward.","pos":""}],"VARVEL":[{"def":"In falconry, one of the rings secured to the ends of the jesses.","pos":""}],"VARVELED":[{"def":"Having varvels, or rings.","pos":""}],"VARY":[{"def":"To embellish; to change fancifully; to present under new aspects, as of form, key, measure, etc.","pos":""}],"VARYING":[{"def":"Va\"ry*ing, Defn: a.","pos":""}]}