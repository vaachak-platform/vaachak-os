{"BRITANNIA":[{"def":"A white-metal alloy of tin, antimony, bismuth, copper, etc.","pos":""}],"BRITANNIC":[{"def":"Of or pertaining to Great Britain; British; as, her Britannic Majesty.","pos":""},{"def":"To be or become overripe, as wheat, barley, or hops.","pos":""}],"BRITICISM":[{"def":"A word, phrase, or idiom peculiar to Great Britain; any manner of using a word or words that is peculiar to Great Britain.","pos":""}],"BRITISH":[{"def":"Of or pertaining to Great Britain or to its inhabitants; -- sometimes restrict to the original inhabitants.","pos":""}],"BRITISHER":[{"def":"An Englishman; a subject or inhabitant of Great Britain, esp.","pos":""}],"BRITON":[{"def":"A native of Great Britain.","pos":""}],"BRITTLE":[{"def":"Easily broken; apt to break; fragile; not tough or tenacious.","pos":""}],"BRITTLE STAR":[{"def":"Any species of ophiuran starfishes.","pos":""}],"BRITTLELY":[{"def":"In a brittle manner.","pos":""}],"BRITTLENESS":[{"def":"Aptness to break; fragility.","pos":""}],"BRITZSKA":[{"def":"A long carriage, with a calash top, so constructed as to give space for reclining at night, when used on a journey.","pos":""}]}