{"PUMA":[{"def":"A large American carnivore (Felis concolor), found from Canada to Patagonia, especially among the mountains.","pos":""}],"PUMICATE":[{"def":"To make smooth with pumice.","pos":""}],"PUMICE":[{"def":"A very light porous volcanic scoria, usually of a gray color, the pores of which are capillary and parallel, giving it a fibrous structure.","pos":""}],"PUMICED":[{"def":"Affected with a kind of chronic laminitis in which there is a growth of soft spongy horn between the coffin bone and the hoof wall.","pos":""}],"PUMICEOUS":[{"def":"Of or pertaining to pumice; resembling pumice.","pos":""}],"PUMICIFORM":[{"def":"Resembling, or having the structure of, pumice.","pos":""}],"PUMP":[{"def":"A low shoe with a thin sole.","pos":""}],"PUMPAGE":[{"def":"That which is raised by pumps, or the work done by pumps.","pos":""}],"PUMPER":[{"def":"One who pumps; the instrument or machine used in pumping.","pos":""}],"PUMPERNICKEL":[{"def":"A sort of bread, made of unbolted rye, which forms the chief food of the Westphalian peasants.","pos":""}],"PUMPKIN":[{"def":"A well-known trailing plant (Cucurbita pepo) and its fruit, -- used for cooking and for feeding stock; a pompion.","pos":""}],"PUMY":[{"def":"Large and rounded.","pos":""}]}