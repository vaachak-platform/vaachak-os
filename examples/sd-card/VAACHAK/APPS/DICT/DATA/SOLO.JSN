{"SOLO":[{"def":"A tune, air, strain, or a whole piece, played by a single person on an instrument, or sung by a single voice.","pos":""}],"SOLO WHIST":[{"def":"A card game played with the full pack ranking as at whist, each player declaring for which of seven different points he proposes to play.","pos":""}],"SOLOIST":[{"def":"One who sings or plays a solo.","pos":""}],"SOLOMON":[{"def":"One of the kings of Israel, noted for his superior wisdom and magnificent reign; hence, a very wise man.","pos":""}],"SOLOMON'S SEAL":[{"def":"A mystic symbol consisting of two interlaced triangles forming a star with six points, often with one triangle dark and one light, symbolic of the union of soul and body.","pos":""}],"SOLON":[{"def":"A celebrated Athenian lawmaker, born about 638 b.","pos":""}]}