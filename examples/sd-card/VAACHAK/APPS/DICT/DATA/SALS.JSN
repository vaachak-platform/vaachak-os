{"SALSAMENTARIOUS":[{"def":"Salt; salted; saline.","pos":""}],"SALSE":[{"def":"A mud volcano, the water of which is often impregnated with salts, whence the name.","pos":""}],"SALSIFY":[{"def":"See Oyster plant (a), under Oyster.","pos":""}],"SALSO-ACID":[{"def":"Having a taste compounded of saltness and acidity; both salt and acid.","pos":""}],"SALSODA":[{"def":"See Sal soda, under Sal.","pos":""}],"SALSOLA":[{"def":"A genus of plants including the glasswort.","pos":""}],"SALSUGINOUS":[{"def":"Growing in brackish places or in salt marches.","pos":""}]}