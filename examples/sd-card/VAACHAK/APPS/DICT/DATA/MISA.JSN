{"MISACCEPTATION":[{"def":"Wrong acceptation; understanding in a wrong sense.","pos":""}],"MISACCOMPT":[{"def":"To account or reckon wrongly.","pos":""}],"MISADJUST":[{"def":"To adjust wrongly of unsuitably; to throw of adjustment.","pos":""}],"MISADJUSTMENT":[{"def":"Wrong adjustment; unsuitable arrangement.","pos":""}],"MISADVENTURE":[{"def":"Mischance; misfortune; ill lick; unlucky accident; ill adventure.","pos":""}],"MISADVENTUROUS":[{"def":"Mis`ad*ven\"tur*ous, a.","pos":""}],"MISADVISE":[{"def":"To give bad counsel to.","pos":""}],"MISAFFECTION":[{"def":"An evil or wrong affection; the state of being ill affected.","pos":""}],"MISAFFIRM":[{"def":"To affirm incorrectly.","pos":""}],"MISAIMED":[{"def":"Not rightly aimed.","pos":""}],"MISALLEGATION":[{"def":"A erroneous statement or allegation.","pos":""}],"MISALLEGE":[{"def":"To state erroneously.","pos":""}],"MISALLIANCE":[{"def":"A marriage with a person of inferior rank or social station; an improper alliance; a mesalliance.","pos":""}],"MISALLIED":[{"def":"Wrongly allied or associated.","pos":""}],"MISALLOTMENT":[{"def":"A wrong allotment.","pos":""}],"MISALTER":[{"def":"To alter wrongly; esp.","pos":""}],"MISANTHROPE":[{"def":"A hater of mankind; a misanthropist.","pos":""},{"def":"Hating or disliking mankind.","pos":""}],"MISANTHROPY":[{"def":"Hatred of, or dislike to, mankind; -- opposed to philanthropy.","pos":""}],"MISAPPLICATION":[{"def":"A wrong application.","pos":""}],"MISAPPLY":[{"def":"To apply wrongly; to use for a wrong purpose; as, to misapply a name or title; to misapply public money.","pos":""}],"MISAPPRECIATED":[{"def":"Improperly appreciated.","pos":""}],"MISAPPREHEND":[{"def":"To take in a wrong sense; to misunderstand.","pos":""}],"MISAPPREHENSION":[{"def":"A mistaking or mistake; wrong apprehension of one's meaning of a fact; misconception; misunderstanding.","pos":""}],"MISAPPREHENSIVELY":[{"def":"By, or with, misapprehension.","pos":""}],"MISAPPROPRIATE":[{"def":"To appropriate wrongly; to use for a wrong purpose.","pos":""}],"MISAPPROPRIATION":[{"def":"Wrong appropriation; wrongful use.","pos":""}],"MISARRANGE":[{"def":"To place in a wrong order, or improper manner.","pos":""}],"MISARRANGEMENT":[{"def":"Wrong arrangement.","pos":""}],"MISASCRIBE":[{"def":"To ascribe wrongly.","pos":""}],"MISASSAY":[{"def":"To assay, or attempt, improperly or unsuccessfully.","pos":""}],"MISASSIGN":[{"def":"To assign wrongly.","pos":""}],"MISATTEND":[{"def":"To misunderstand; to disregard.","pos":""}]}