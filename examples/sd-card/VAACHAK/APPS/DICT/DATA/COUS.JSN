{"COUSCOUS":[{"def":"A kind of food used by the natives of Western Africa, made of millet flour with flesh, and leaves of the baobab; -- called also lalo.","pos":""}],"COUSCOUSOU":[{"def":"A favorite dish in Barbary.","pos":""}],"COUSIN":[{"def":"One collaterally related more remotely than a brother or sister; especially, the son or daughter of an uncle or aunt.","pos":""},{"def":"A title formerly given by a king to a nobleman, particularly to those of the council.","pos":""}],"COUSIN-GERMAN":[{"def":"Cous\"in-ger\"man (-jr\"man), n.","pos":""}],"COUSINAGE":[{"def":"Relationship; kinship.","pos":""}],"COUSINHOOD":[{"def":"The state or condition of a cousin; also, the collective body of cousins; kinsfolk.","pos":""}],"COUSINLY":[{"def":"Like or becoming a cousin.","pos":""}],"COUSINRY":[{"def":"A body or collection of cousins; the whole number of persons who stand in the relation of cousins to a given person or persons.","pos":""}],"COUSINSHIP":[{"def":"The relationship of cousins; state of being cousins; cousinhood.","pos":""}],"COUSSINET":[{"def":"Cous\"si*net` (ks\"s-nt`), n.","pos":""}]}