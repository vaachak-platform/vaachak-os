{"PLEDGE":[{"def":"A person who undertook, or became responsible, for another; a bail; a surety; a hostage.","pos":""}],"PLEDGEE":[{"def":"The one to whom a pledge is given, or to whom property pledged is delivered.","pos":""}],"PLEDGELESS":[{"def":"Having no pledge.","pos":""},{"def":"One who pledges, or delivers anything in pledge; a pledger; -- opposed to Ant: pledgee.","pos":""}],"PLEDGER":[{"def":"One who pledges.","pos":""}],"PLEDGERY":[{"def":"A pledging; suretyship.","pos":""}],"PLEDGET":[{"def":"A string of oakum used in calking.","pos":""},{"def":"A compress, or small flat tent of lint, laid over a wound, ulcer, or the like, to exclude air, retain dressings, or absorb the matter discharged.","pos":""}]}