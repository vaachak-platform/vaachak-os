{"PUT":[{"def":"A rustic; a clown; an awkward or uncouth person.","pos":""}],"PUT-OFF":[{"def":"A shift for evasion or delay; an evasion; an excuse.","pos":""}],"PUT-UP":[{"def":"Arranged; plotted; -- in a bad sense; as, a put-up job.","pos":""}],"PUTAGE":[{"def":"Prostitution or fornication on the part of a woman.","pos":""}],"PUTAMEN":[{"def":"The shell of a nut; the stone of a drupe fruit.","pos":""}],"PUTANISM":[{"def":"Habitual lewdness or prostitution of a woman; harlotry.","pos":""}],"PUTATIVE":[{"def":"Commonly thought or deemed; supposed; reputed; as, the putative father of a child.","pos":""}],"PUTEAL":[{"def":"An inclosure surrounding a well to prevent persons from falling into it; a well curb.","pos":""}],"PUTID":[{"def":"Rotten; fetid; stinking; base; worthless.","pos":""},{"def":"The quality or state of being putrid.","pos":""}],"PUTLOG":[{"def":"One of the short pieces of timber on which the planks forming the floor of a scaffold are laid, -- one end resting on the ledger of the scaffold, and the other in a hole left in the wall temporarily for the purpose.","pos":""}],"PUTOUR":[{"def":"A keeper of a brothel; a procurer.","pos":""}],"PUTREDINOUS":[{"def":"Proceeding from putrefaction, or partaking of the putrefactive process; having an offensive smell; stinking; rotten.","pos":""}],"PUTREFACTION":[{"def":"The act or the process of putrefying; the offensive decay of albuminous or other matter.","pos":""},{"def":"The condition of being putrefied; also, that which putrefied.","pos":""}],"PUTREFACTIVE":[{"def":"Of or pertaining to putrefaction; as, the putrefactive smell or process.","pos":""},{"def":"Causing, or tending to promote, putrefaction.","pos":""}],"PUTREFY":[{"def":"To render putrid; to cause to decay offensively; to cause to be decomposed; to cause to rot.","pos":""},{"def":"To corrupt; to make foul.","pos":""}],"PUTRESCE":[{"def":"To become putrescent or putrid; to putrefy.","pos":""}],"PUTRESCENCE":[{"def":"The state of being putrescent; putrescent matter.","pos":""}],"PUTRESCENT":[{"def":"Becoming putrid or rotten.","pos":""},{"def":"Of or pertaining to the process of putrefaction; as, a putrescent smell.","pos":""}],"PUTRESCIBLE":[{"def":"Capable of putrefaction; liable to become putrid; as, putrescible substances.","pos":""}],"PUTRESCIN":[{"def":"A nontoxic diamine, C4H12N2, formed in the putrefaction of the flesh of mammals and some other animals.","pos":""}],"PUTRID":[{"def":"Tending to decomposition or decay; decomposed; rotten; -- said of animal or vegetable matter; as, putrid flesh.","pos":""},{"def":"Indicating or proceeding from a decayed state of animal or vegetable matter; as, a putrid smell.","pos":""}],"PUTRIDITY":[{"def":"The quality of being putrid; putrefaction; rottenness.","pos":""}],"PUTRIFACTED":[{"def":"What vermin bred of putrifacted slime.","pos":""}],"PUTRILAGE":[{"def":"That which is undergoing putrefaction; the products of putrefaction.","pos":""}],"PUTT":[{"def":"A stroke made on the putting green to play the ball into a hole.","pos":""}],"PUTTEE":[{"def":"Same as Putty, a kind of gaiter.","pos":""}],"PUTTER":[{"def":"One who puts or plates.","pos":""},{"def":"Specifically, one who pushes the small wagons in a coal mine, and the like.","pos":""}],"PUTTIER":[{"def":"One who putties; a glazier.","pos":""}],"PUTTING":[{"def":"The throwing of a heavy stone, shot, etc.","pos":""}],"PUTTING GREEN":[{"def":"The green, or plot of smooth turf, surrounding a hole.","pos":""}],"PUTTY":[{"def":"A kind of thick paste or cement compounded of whiting, or soft carbonate of lime, and linseed oil, when applied beaten or kneaded to the consistence of dough, -- used in fastening glass in sashes, stopping crevices, and for similar purposes.","pos":""}],"PUTTY-FACED":[{"def":"White-faced; -- used contemptuously.","pos":""}],"PUTTYROOT":[{"def":"An American orchidaceous plant (Aplectrum hyemale) which flowers in early summer.","pos":""}]}