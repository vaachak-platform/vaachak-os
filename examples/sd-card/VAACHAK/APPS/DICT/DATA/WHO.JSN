{"WHO":[{"def":"Originally, an interrogative pronoun, later, a relative pronoun also; -- used always substantively, and either as singular or plural.","pos":""}],"WHOA":[{"def":"Stop; stand; hold.","pos":""}],"WHOEVER":[{"def":"Whatever person; any person who; be or she who; any one who; as, he shall be punished, whoever he may be.","pos":""}],"WHOLE":[{"def":"Containing the total amount, number, etc.","pos":""},{"def":"Complete; entire; not defective or imperfect; not broken or fractured; unimpaired; uninjured; integral; as, a whole orange; the egg is whole; the vessel is whole.","pos":""}],"WHOLE-HOOFED":[{"def":"Having an undivided hoof, as the horse.","pos":""}],"WHOLE-LENGTH":[{"def":"Representing the whole figure; -- said of a picture or statue.","pos":""},{"def":"A portrait or statue representing the whole figure.","pos":""}],"WHOLE-SOULED":[{"def":"Thoroughly imbued with a right spirit; noble-minded; devoted.","pos":""}],"WHOLENESS":[{"def":"The quality or state of being whole, entire, or sound; entireness; totality; completeness.","pos":""}],"WHOLESALE":[{"def":"Sale of goods by the piece or large quantity, as distinguished from retail.","pos":""}],"WHOLESOME":[{"def":"Tending to promote health; favoring health; salubrious; salutary.","pos":""},{"def":"Contributing to the health of the mind; favorable to morals, religion, or prosperity; conducive to good; salutary; sound; as, wholesome advice; wholesome doctrines; wholesome truths; wholesome laws.","pos":""}],"WHOLLY":[{"def":"In a whole or complete manner; entirely; completely; perfectly.","pos":""},{"def":"To the exclusion of other things; totally; fully.","pos":""}],"WHOM":[{"def":"The objective case of who.","pos":""}],"WHOMSOEVER":[{"def":"The objective of whosoever.","pos":""}],"WHOOP":[{"def":"To utter a whoop, or loud cry, as eagerness, enthusiasm, or enjoyment; to cry out; to shout; to halloo; to utter a war whoop; to hoot, as an owl.","pos":""},{"def":"To cough or breathe with a sonorous inspiration, as in whooping cough.","pos":""}],"WHOOPER":[{"def":"One who, or that which, whooops.","pos":""}],"WHOOPING":[{"def":"Whoop\"ing, Defn: a.","pos":""}],"WHOPPER":[{"def":"One who, or that which, whops.","pos":""},{"def":"Same as Whapper.","pos":""}],"WHORE":[{"def":"A woman who practices unlawful sexual commerce with men, especially one who prostitutes her body for hire; a prostitute; a harlot.","pos":""}],"WHOREDOM":[{"def":"The sin of worshiping idols; idolatry.","pos":""}],"WHOREMASTER":[{"def":"A man who practices lewdness; a lecher; a whoremonger.","pos":""},{"def":"One keeps or procures whores for others; a pimp; a procurer.","pos":""}],"WHOREMASTERLY":[{"def":"Having the character of a whoremaster; lecherous; libidinous.","pos":""}],"WHOREMONGER":[{"def":"A whoremaster; a lecher; a man who frequents the society of whores.","pos":""}],"WHORESON":[{"def":"A bastard; colloquially, a low, scurvy fellow; -- used generally in contempt, or in coarse humor.","pos":""}],"WHORISH":[{"def":"Resembling a whore in character or conduct; addicted to unlawful pleasures; incontinent; lewd; unchaste.","pos":""}],"WHORL":[{"def":"A circle of two or more leaves, flowers, or other organs, about the same part or joint of a stem.","pos":""},{"def":"A volution, or turn, of the spire of a univalve shell.","pos":""}],"WHORLED":[{"def":"Furnished with whorls; arranged in the form of a whorl or whorls; verticillate; as, whorled leaves.","pos":""}],"WHORLER":[{"def":"A potter's wheel.","pos":""}],"WHORT":[{"def":"The whortleberry, or bilberry.","pos":""}],"WHORTLE":[{"def":"The whortleberry, or bilberry.","pos":""}],"WHOSE":[{"def":"The possessive case of who or which.","pos":""}],"WHOSESOEVER":[{"def":"The possessive of whosoever.","pos":""}],"WHOSO":[{"def":"Whoso shrinks or falters now, .","pos":""}],"WHOSOEVER":[{"def":"Whatsoever person; any person whatever that; whoever.","pos":""}]}