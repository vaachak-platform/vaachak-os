{"ASTACUS":[{"def":"A genus of crustaceans, containing the crawfish of fresh-water lobster of Europe, and allied species of western North America.","pos":""}],"ASTARBOARD":[{"def":"Over to the starboard side; -- said of the tiller.","pos":""}],"ASTARTE":[{"def":"A genus of bivalve mollusks, common on the coasts of America and Europe.","pos":""}],"ASTATIC":[{"def":"Having little or no tendency to take a fixed or definite position or direction: thus, a suspended magnetic needle, when rendered astatic, loses its polarity, or tendency to point in a given direction.","pos":""}],"ASTATICALLY":[{"def":"In an astatic manner.","pos":""}],"ASTATICISM":[{"def":"The state of being astatic.","pos":""}],"ASTATIZE":[{"def":"To render astatic.","pos":""}],"ASTATKI":[{"def":"A thick liquid residuum obtained in the distillation of Russian petroleum, much used as fuel.","pos":""}],"ASTAY":[{"def":"An anchor is said to be astay, in heaving it, an acute angle is formed between the cable and the surface of the water.","pos":""}],"ASTEISM":[{"def":"Genteel irony; a polite and ingenious manner of deriding another.","pos":""}],"ASTEL":[{"def":"An arch, or ceiling, of boards, placed over the men's heads in a mine.","pos":""}],"ASTER":[{"def":"A genus of herbs with compound white or bluish flowers; starwort; Michaelmas daisy.","pos":""},{"def":"A plant of the genus Callistephus.","pos":""}],"ASTERIAS":[{"def":"A genus of echinoderms.","pos":""}],"ASTERIATED":[{"def":"Radiated, with diverging rays; as, asteriated sapphire.","pos":""}],"ASTERIDIAN":[{"def":"Of or pertaining to the Asterioidea.","pos":""},{"def":"A starfish; one of the Asterioidea.","pos":""}],"ASTERION":[{"def":"The point on the side of the skull where the lambdoid, parieto- mastoid and occipito-mastoid sutures.","pos":""}],"ASTERISCUS":[{"def":"The smaller of the two otoliths found in the inner ear of many fishes.","pos":""}],"ASTERISM":[{"def":"An optical property of some crystals which exhibit a star- shaped by reflected light, as star sapphire, or by transmitted light, as some mica.","pos":""}],"ASTERN":[{"def":"In or at the hinder part of a ship; toward the hinder part, or stern; backward; as, to go astern.","pos":""},{"def":"Behind a ship; in the rear.","pos":""}],"ASTERNAL":[{"def":"Not sternal; -- said of ribs which do not join the sternum.","pos":""}],"ASTEROID":[{"def":"A starlike body; esp.","pos":""}],"ASTEROIDAL":[{"def":"Of or pertaining to an asteroid, or to the asteroids.","pos":""}],"ASTEROLEPIS":[{"def":"A genus of fishes, some of which were eighteen or twenty feet long, found in a fossil state in the Old Red Sandstone.","pos":""}],"ASTEROPE":[{"def":"One of the Pleiades; -- called also Sterope.","pos":""}],"ASTEROPHYLLITE":[{"def":"A fossil plant from the coal formations of Europe and America, now regarded as the branchlets and foliage of calamites.","pos":""}],"ASTERT":[{"def":"To start up; to befall; to escape; to shun.","pos":""}],"ASTHENIC":[{"def":"Characterized by, or pertaining to, debility; weak; debilitating.","pos":""}],"ASTHENOPIA":[{"def":"Weakness of sight.","pos":""}],"ASTHMA":[{"def":"A disease, characterized by difficulty of breathing (due to a spasmodic contraction of the bronchi), recurring at intervals, accompanied with a wheezing sound, a sense of constriction in the chest, a cough, and expectoration.","pos":""}],"ASTHMA PAPER":[{"def":"Paper impregnated with saltpeter.","pos":""},{"def":"Of or pertaining to asthma; as, an asthmatic cough; liable to, or suffering from, asthma; as, an asthmatic patient.","pos":""}],"ASTHMATIC":[{"def":"A person affected with asthma.","pos":""}],"ASTIGMATIC":[{"def":"Affected with, or pertaining to, astigmatism; as, astigmatic eyes; also, remedying astigmatism; as, astigmatic lenses.","pos":""}],"ASTIGMATISM":[{"def":"A defect of the eye or of a lens, in consequence of which the rays derived from one point are not brought to a single focal point, thus causing imperfect images or indistictness of vision.","pos":""}],"ASTIPULATION":[{"def":"Stipulation; agreement.","pos":""}],"ASTIR":[{"def":"Stirring; in a state of activity or motion; out of bed.","pos":""},{"def":"Not possessing a mouth.","pos":""}],"ASTONIED":[{"def":"Stunned; astonished.","pos":""}],"ASTONISH":[{"def":"To stun; to render senseless, as by a blow.","pos":""},{"def":"To strike with sudden fear, terror, or wonder; to amaze; to surprise greatly, as with something unaccountable; to confound with some sudden emotion or passion.","pos":""}],"ASTONISHEDLY":[{"def":"In an astonished manner.","pos":""}],"ASTONISHING":[{"def":"Very wonderful; of a nature to excite astonishment; as, an astonishing event.","pos":""}],"ASTONISHMENT":[{"def":"The condition of one who is stunned.","pos":""},{"def":"Dismay; consternation.","pos":""}],"ASTONY":[{"def":"To stun; to bewilder; to astonish; to dismay.","pos":""}],"ASTOOP":[{"def":"In a stooping or inclined position.","pos":""}],"ASTOUND":[{"def":"Stunned; astounded; astonished.","pos":""}],"ASTOUNDING":[{"def":"Of a nature to astound; astonishing; amazing; as, an astounding force, statement, or fact.","pos":""}],"ASTRADDLE":[{"def":"In a straddling position; astride; bestriding; as, to sit astraddle a horse.","pos":""}],"ASTRAEAN":[{"def":"Pertaining to the genus Astræa or the family Astræidæ.","pos":""},{"def":"A coral of the family Astræidæ; a star coral.","pos":""}],"ASTRAGAL":[{"def":"A convex molding of rounded surface, generally from half to three quarters of a circle.","pos":""},{"def":"A round molding encircling a cannon near the mouth.","pos":""}],"ASTRAGALAR":[{"def":"Of or pertaining to the astragalus.","pos":""}],"ASTRAGALOID":[{"def":"Resembling the astragalus in form.","pos":""}],"ASTRAGALOMANCY":[{"def":"Divination by means of small bones or dice.","pos":""}],"ASTRAGALUS":[{"def":"The ankle bone, or hock bone; the bone of the tarsus which articulates with the tibia at the ankle.","pos":""},{"def":"A genus of papilionaceous plants, of the tribe Galegeæ, containing numerous species, two of which are called, in English, milk vetch and licorice vetch.","pos":""}],"ASTRAKHAN":[{"def":"Of or pertaining to Astrakhan in Russia or its products; made of an Astrakhan skin.","pos":""},{"def":"The skin of stillborn or young lambs of that region, the curled wool of which resembles fur.","pos":""}],"ASTRAL":[{"def":"Pertaining to, coming from, or resembling, the stars; starry; starlike.","pos":""}],"ASTRAY":[{"def":"Out of the right, either in a literal or in a figurative sense; wandering; as, to lead one astray.","pos":""}],"ASTRICT":[{"def":"To restrict the tenure of; as, to astrict lands.","pos":""}],"ASTRICTION":[{"def":"An obligation to have the grain growing on certain lands ground at a certain mill, the owner paying a toll.","pos":""}],"ASTRICTIVE":[{"def":"Binding; astringent.","pos":""}],"ASTRIDE":[{"def":"With one leg on each side, as a man when on horseback; with the legs stretched wide apart; astraddle.","pos":""}],"ASTRINGE":[{"def":"To bind fast; to constrict; to contract; to cause parts to draw together; to compress.","pos":""},{"def":"To bind by moral or legal obligation.","pos":""}],"ASTRINGENCY":[{"def":"The quality of being astringent; the power of contracting the parts of the body; that quality in medicines or other substances which causes contraction of the organic textures; as, the astringency of tannin.","pos":""}],"ASTRINGENT":[{"def":"Drawing together the tissues; binding; contracting; -- opposed to laxative; as, astringent medicines; a butter and astringent taste; astringent fruit.","pos":""},{"def":"Stern; austere; as, an astringent type of virtue.","pos":""}],"ASTRINGENTLY":[{"def":"In an astringent manner.","pos":""}],"ASTRINGER":[{"def":"A falconer who keeps a goschawk.","pos":""}],"ASTRO-":[{"def":"The combining form of the Greek word 'a`stron, meaning star.","pos":""},{"def":"A bitter herb, probably the same as aster, or starwort.","pos":""}],"ASTROGENY":[{"def":"The creation or evolution of the stars or the heavens.","pos":""}],"ASTROGNOSY":[{"def":"The science or knowledge of the stars, esp.","pos":""}],"ASTROGONY":[{"def":"Same as Astrogeny.","pos":""}],"ASTROGRAPHY":[{"def":"The art of describing or delineating the stars; a description or mapping of the heavens.","pos":""}],"ASTROITE":[{"def":"A radiated stone or fossil; star-stone.","pos":""}],"ASTROLABE":[{"def":"An instrument for observing or showing the positions of the stars.","pos":""}],"ASTROLATER":[{"def":"A worshiper of the stars.","pos":""}],"ASTROLATRY":[{"def":"The worship of the stars.","pos":""}],"ASTROLITHOLOGY":[{"def":"The science of aërolites.","pos":""}],"ASTROLOGER":[{"def":"One who studies the stars; an astronomer.","pos":""},{"def":"One who practices astrology; one who professes to foretell events by the aspects and situation of the stars.","pos":""}],"ASTROLOGIAN":[{"def":"Of or pertaining to astrology; professing or practicing astrology.","pos":""}],"ASTROLOGIZE":[{"def":"To apply astrology to; to study or practice astrology.","pos":""}],"ASTROLOGY":[{"def":"In its etymological signification, the science of the stars; among the ancients, synonymous with astronomy; subsequently, the art of judging of the influences of the stars upon human affairs, and of foretelling events by their position and aspects.","pos":""}],"ASTROMANTIC":[{"def":"Of or pertaining to divination by means of the stars; astrologic.","pos":""}],"ASTROMETEOROLOGY":[{"def":"The investigation of the relation between the sun, moon, and stars, and the weather.","pos":""}],"ASTROMETER":[{"def":"An instrument for comparing the relative amount of the light of stars.","pos":""}],"ASTROMETRY":[{"def":"The art of making measurements among the stars, or of determining their relative magnitudes.","pos":""}],"ASTRONOMER":[{"def":"One who is versed in astronomy; one who has a knowledge of the laws of the heavenly orbs, or the principles by which their motions are regulated, with their various phenomena.","pos":""}],"ASTRONOMICAL":[{"def":"Of or pertaining to astronomy; in accordance with the methods or principles of astronomy.","pos":""}],"ASTRONOMIZE":[{"def":"To study or to talk astronomy.","pos":""}],"ASTRONOMY":[{"def":"The science which treats of the celestial bodies, of their magnitudes, motions, distances, periods of revolution, eclipses, constitution, physical condition, and of the causes of their various phenomena.","pos":""}],"ASTROPHOTOGRAPHY":[{"def":"The application of photography to the delineation of the sun, moon, and stars.","pos":""}],"ASTROPHOTOMETER":[{"def":"A photometer for measuring the brightness of stars.","pos":""}],"ASTROPHOTOMETRY":[{"def":"The determination of the brightness of stars, and also of the sun, moon, and planets.","pos":""}],"ASTROPHYSICAL":[{"def":"Pertaining to the physics of astronomical science.","pos":""}],"ASTROPHYSICS":[{"def":"The science treating of the physical characteristics of the stars and other heavenly bodies, their chemical constitution, light, heat, atmospheres, etc.","pos":""}],"ASTROPHYTON":[{"def":"A genus of ophiurans having the arms much branched.","pos":""}],"ASTROSCOPE":[{"def":"An old astronomical instrument, formed of two cones, on whose surface the constellations were delineated.","pos":""}],"ASTROSCOPY":[{"def":"Observation of the stars.","pos":""}],"ASTROTHEOLOGY":[{"def":"Theology founded on observation or knowledge of the celestial bodies.","pos":""}],"ASTRUCTIVE":[{"def":"Building up; constructive; -- opposed to destructive.","pos":""}],"ASTRUT":[{"def":"Sticking out, or puffed out; swelling; in a swelling manner.","pos":""},{"def":"In a strutting manner; with a strutting gait.","pos":""}],"ASTUCIOUS":[{"def":"Subtle; cunning; astute.","pos":""}],"ASTUCITY":[{"def":"Craftiness; astuteness.","pos":""}],"ASTURIAN":[{"def":"Of or pertaining to Asturias in Spain.","pos":""},{"def":"A native of Asturias.","pos":""}],"ASTUTE":[{"def":"Critically discerning; sagacious; shrewd; subtle; crafty.","pos":""}],"ASTYLAR":[{"def":"Without columns or pilasters.","pos":""}],"ASTYLLEN":[{"def":"A small dam to prevent free passage of water in an adit or level.","pos":""}]}