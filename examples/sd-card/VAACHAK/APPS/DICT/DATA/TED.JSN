{"TED":[{"def":"To spread, or turn from the swath, and scatter for drying, as new-mowed grass; -- chiefly used in the past participle.","pos":""}],"TEDDER":[{"def":"A machine for stirring and spreading hay, to expedite its drying.","pos":""}],"TEDESCO":[{"def":"German; -- used chiefly of art, literature, etc.","pos":""}],"TEDGE":[{"def":"The gate of a mold, through which the melted metal is poured; runner, geat.","pos":""}],"TEDIOUS":[{"def":"Involving tedium; tiresome from continuance, prolixity, slowness, or the like; wearisome.","pos":""}],"TEDIUM":[{"def":"Irksomeness; wearisomeness; tediousness.","pos":""}]}