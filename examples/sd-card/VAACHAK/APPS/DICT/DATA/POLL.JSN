{"POLL":[{"def":"A parrot; -- familiarly so called.","pos":""}],"POLLAGE":[{"def":"A head or poll tax; hence, extortion.","pos":""}],"POLLAN":[{"def":"A lake whitefish (Coregonus pollan), native of Ireland.","pos":""}],"POLLARD":[{"def":"A tree having its top cut off at some height above the ground, that may throw out branches.","pos":""},{"def":"A clipped coin; also, a counterfeit.","pos":""}],"POLLED":[{"def":"Deprived of a poll, or of something belonging to the poll.","pos":""}],"POLLEN":[{"def":"The fecundating dustlike cells of the anthers of flowers.","pos":""}],"POLLENARIOUS":[{"def":"Consisting of meal or pollen.","pos":""}],"POLLENED":[{"def":"Covered with pollen.","pos":""}],"POLLENIFEROUS":[{"def":"Producing pollen; polliniferous.","pos":""}],"POLLENIN":[{"def":"A substance found in the pollen of certain plants.","pos":""}],"POLLENIZE":[{"def":"To supply with pollen; to impregnate with pollen.","pos":""}],"POLLER":[{"def":"One who polls; specifically: (a) One who polls or lops trees.","pos":""}],"POLLEX":[{"def":"The first, or preaxial, digit of the fore limb, corresponding to the hallux in the hind limb; the thumb.","pos":""}],"POLLICATE":[{"def":"Having a curved projection or spine on the inner side of a leg joint; -- said of insects.","pos":""}],"POLLICITATION":[{"def":"A promise without mutuality; a promise which has not been accepted by the person to whom it is made.","pos":""}],"POLLINATE":[{"def":"To apply pollen to (a stigma).","pos":""}],"POLLINCTOR":[{"def":"One who prepared corpses for the funeral.","pos":""}],"POLLING":[{"def":"The act of topping, lopping, or cropping, as trees or hedges.","pos":""},{"def":"Plunder, or extortion.","pos":""}],"POLLINIFEROUS":[{"def":"Producing pollen; polleniferous.","pos":""}],"POLLINIUM":[{"def":"A coherent mass of pollen, as in the milkweed and most orchids.","pos":""}],"POLLINOSE":[{"def":"Having the surface covered with a fine yellow dust, like pollen.","pos":""},{"def":"A tadpole; -- called also purwiggy and porwigle.","pos":""}],"POLLOCK":[{"def":"A marine gadoid fish (Pollachius carbonarius), native both of the European and American coasts.","pos":""}],"POLLUCITE":[{"def":"A colorless transparent mineral, resembling quartz, occurring with castor or castorite on the island of Elba.","pos":""}],"POLLUTE":[{"def":"To render ceremonially unclean; to disqualify or unfit for sacred use or service, or for social intercourse.","pos":""}],"POLLUTED":[{"def":"Defiled; made unclean or impure; debauched.","pos":""}],"POLLUTER":[{"def":"One who pollutes.","pos":""}],"POLLUTING":[{"def":"Adapted or tending to pollute; causing defilement or pollution.","pos":""}],"POLLUTION":[{"def":"The emission of semen, or sperm, at other times than in sexual intercourse.","pos":""}],"POLLUX":[{"def":"A fixed star of the second magnitude, in the constellation Gemini.","pos":""},{"def":"Same as Pollucite.","pos":""}],"POLLY":[{"def":"A woman's name; also, a popular name for a parrot.","pos":""}]}