{"OKAPI":[{"def":"A peculiar mammal (Okapia johnostoni) closely related to the giraffe, discovered in the deep forests of Belgian Kongo in 1900.","pos":""}],"OKE":[{"def":"A Turkish and Egyptian weight, equal to about 2 2.","pos":""}],"OKENITE":[{"def":"A massive and fibrous mineral of a whitish color, chiefly hydrous silicate of lime.","pos":""}],"OKRA":[{"def":"An annual plant (Abelmoschus, or Hibiscus, esculentus), whose green pods, abounding in nutritious mucilage, are much used for soups, stews, or pickles; gumbo.","pos":""},{"def":"A suffix denoting that the substance in the name of which it appears belongs to the series of alcohols or hydroxyl derivatives, as carbinol, glycerol, etc.","pos":""}]}