{"HAECCEITY":[{"def":"Literally, this-ness.","pos":""},{"def":"Combining forms indicating relation or resemblance to blood, association with blood; as, hæmapod, hæmatogenesis, hæmoscope.","pos":""}],"HAEMACHROME":[{"def":"Hæm\"a*chrome ( or ), n.","pos":""}],"HAEMACYANIN":[{"def":"A substance found in the blood of the octopus, which gives to it its blue color.","pos":""}],"HAEMACYTOMETER":[{"def":"An apparatus for determining the number of corpuscles in a given quantity of blood.","pos":""}],"HAEMAD":[{"def":"Toward the hæmal side; on the hæmal side of; -- opposed to neurad.","pos":""},{"def":"Same as Hemadrometer.","pos":""}],"HAEMADROMOGRAPH":[{"def":"An instrument for registering the velocity of the blood.","pos":""},{"def":"Same as Hemadynamometer.","pos":""}],"HAEMADYNAMICS":[{"def":"Same as Hemadynamics.","pos":""}],"HAEMAL":[{"def":"Pertaining to the blood or blood vessels; also, ventral.","pos":""}],"HAEMAPHAEIN":[{"def":"A brownish substance sometimes found in the blood, in cases of jaundice.","pos":""}],"HAEMAPOD":[{"def":"An hæmapodous animal.","pos":""}],"HAEMAPODOUS":[{"def":"Having the limbs on, or directed toward, the ventral or hemal side, as in vertebrates; -- opposed to neuropodous.","pos":""}],"HAEMAPOIETIC":[{"def":"Bloodforming; as, the hæmapoietic function of the spleen.","pos":""}],"HAEMAPOPHYSIS":[{"def":"Same as Hemapophysis.","pos":""}],"HAEMASTATICS":[{"def":"Same as Hemastatics.","pos":""}],"HAEMATACHOMETER":[{"def":"A form of apparatus (somewhat different from the hemadrometer) for measuring the velocity of the blood.","pos":""}],"HAEMATACHOMETRY":[{"def":"The measurement of the velocity of the blood.","pos":""}],"HAEMATEMESIS":[{"def":"Same as Hematemesis.","pos":""}],"HAEMATIC":[{"def":"Of or pertaining to the blood; sanguine; brownish red.","pos":""}],"HAEMATIN":[{"def":"Same as Hematin.","pos":""}],"HAEMATINOMETER":[{"def":"Same as Hematinometer.","pos":""}],"HAEMATINOMETRIC":[{"def":"Same as Hematinometric.","pos":""}],"HAEMATITE":[{"def":"Same as Hematite.","pos":""}],"HAEMATITIC":[{"def":"Of a blood-red color; crimson; (Bot.","pos":""}],"HAEMATO-":[{"def":"Hæm\"a*to- ( or ), prefix.","pos":""}],"HAEMATOBLAST":[{"def":"One of the very minute, disk-shaped bodies found in blood with the ordinary red corpuscles and white corpuscles; a third kind of blood corpuscle, supposed by some to be an early stage in the development of the red corpuscles; -- called also blood plaque, and blood plate.","pos":""}],"HAEMATOCRYA":[{"def":"The cold-blooded vertebrates.","pos":""}],"HAEMATOCRYSTALLIN":[{"def":"Same as Hematocrystallin.","pos":""}],"HAEMATODYNAMOMETER":[{"def":"Same as Hemadynamometer.","pos":""}],"HAEMATOGENESIS":[{"def":"Hæm`a*to*gen\"e*sis, n.","pos":""}],"HAEMATOGENIC":[{"def":"Relating to hæmatogenesis.","pos":""}],"HAEMATOGENOUS":[{"def":"Originating in the blood.","pos":""}],"HAEMATOGLOBULIN":[{"def":"Same as Hematoglobin.","pos":""}],"HAEMATOID":[{"def":"Same as Hematoid.","pos":""}],"HAEMATOIDIN":[{"def":"Same as Hematoidin.","pos":""}],"HAEMATOIN":[{"def":"A substance formed from the hematin of blood, by removal of the iron through the action of concentrated sulphuric acid.","pos":""}],"HAEMATOLOGY":[{"def":"The science which treats of the blood.","pos":""}],"HAEMATOLYSIS":[{"def":"Dissolution of the red blood corpuscles with diminished coagulability of the blood; hæmolysis.","pos":""}],"HAEMATOPHILINA":[{"def":"A division of Cheiroptera, including the bloodsucking bats.","pos":""}],"HAEMATOPLAST":[{"def":"Same as Hæmatoblast.","pos":""}],"HAEMATOPLASTIC":[{"def":"Blood formative; -- applied to a substance in early fetal life, which breaks up gradually into blood vessels.","pos":""}],"HAEMATOPORPHYRIN":[{"def":"Hæm`a*to*por\"phy*rin, n.","pos":""}],"HAEMATOSAC":[{"def":"A vascular sac connected, beneath the brain, in many fishes, with the infundibulum.","pos":""}],"HAEMATOSIN":[{"def":"Hæm`a*to\"sin ( or ), n.","pos":""}],"HAEMATOSIS":[{"def":"Same as Hematosis.","pos":""}],"HAEMATOTHERMA":[{"def":"Same as Hematotherma.","pos":""}],"HAEMATOTHERMAL":[{"def":"Warm-blooded; homoiothermal.","pos":""}],"HAEMATOTHORAX":[{"def":"Same as Hemothorax.","pos":""}],"HAEMATOXYLIN":[{"def":"The coloring principle of logwood.","pos":""}],"HAEMATOXYLON":[{"def":"A genus of leguminous plants containing but a single species, the H.","pos":""},{"def":"A parasite inhabiting the blood; esp.","pos":""}],"HAEMO-":[{"def":"Hæm\"o- ( or ), prefix.","pos":""}],"HAEMOCHROME":[{"def":"Same as Hæmachrome.","pos":""}],"HAEMOCHROMOGEN":[{"def":"A body obtained from hemoglobin, by the action of reducing agents in the absence of oxygen.","pos":""}],"HAEMOCHROMOMETER":[{"def":"An apparatus for measuring the amount of hemoglobin in a fluid, by comparing it with a solution of known strength and of normal color.","pos":""}],"HAEMOCYANIN":[{"def":"Same as Hæmacyanin.","pos":""}],"HAEMOCYTOLYSIS":[{"def":"See Hæmocytotrypsis.","pos":""}],"HAEMOCYTOMETER":[{"def":"See Hæmacytometer.","pos":""}],"HAEMOCYTOTRYPSIS":[{"def":"A breaking up of the blood corpuscles, as by pressure, in distinction from solution of the corpuscles, or hæmcytolysis.","pos":""}],"HAEMODROMOGRAPH":[{"def":"Same as Hæmadromograph.","pos":""}],"HAEMODROMOMETER":[{"def":"Same as Hemadrometer.","pos":""}],"HAEMODYNAMETER":[{"def":"Same as Hemadynamics.","pos":""}],"HAEMODYNAMICS":[{"def":"Same as Hemadynamics.","pos":""}],"HAEMOGLOBIN":[{"def":"Same as Hemoglobin.","pos":""}],"HAEMOGLOBINOMETER":[{"def":"Same as Hemochromometer.","pos":""}],"HAEMOL":[{"def":"A dark brown powder containing iron, prepared by the action of zinc dust as a reducing agent upon the coloring matter of the blood, used medicinally as a hematinic.","pos":""}],"HAEMOLUTEIN":[{"def":"Same as Hæmatolysis, Hæmatolytic.","pos":""}],"HAEMOMANOMETER":[{"def":"Same as Hemadynamometer.","pos":""}],"HAEMOMETER":[{"def":"Same as Hemadynamometer.","pos":""}],"HAEMONY":[{"def":"A plant described by Milton as \"of sovereign use against all enchantments.","pos":""}],"HAEMOPLASTIC":[{"def":"Same as Hæmatoplastic.","pos":""}],"HAEMORRHOIDAL":[{"def":"Same as Hemorrhoidal.","pos":""}],"HAEMOSCOPE":[{"def":"An instrument devised by Hermann, for regulating and measuring the thickness of a layer of blood for spectroscopic examination.","pos":""}],"HAEMOSTATIC":[{"def":"Same Hemostatic.","pos":""}],"HAEMOTACHOMETER":[{"def":"Same as Hæmatachometer.","pos":""}],"HAEMOTACHOMETRY":[{"def":"Same as Hæmatachometry.","pos":""}]}