{"PROJECT":[{"def":"The place from which a thing projects, or starts forth.","pos":""},{"def":"That which is projected or designed; something intended or devised; a scheme; a design; a plan.","pos":""}],"PROJECTILE":[{"def":"Projecting or impelling forward; as, a projectile force.","pos":""},{"def":"Caused or imparted by impulse or projection; impelled forward; as, projectile motion.","pos":""}],"PROJECTION":[{"def":"Any method of representing the surface of the earth upon a plane.","pos":""}],"PROJECTMENT":[{"def":"Design; contrivance; projection.","pos":""}],"PROJECTOR":[{"def":"One who projects a scheme or design; hence, one who forms fanciful or chimerical schemes.","pos":""}],"PROJECTURE":[{"def":"A jutting out beyond a surface.","pos":""}],"PROJET":[{"def":"A plan proposed; a draft of a proposed measure; a project.","pos":""}]}