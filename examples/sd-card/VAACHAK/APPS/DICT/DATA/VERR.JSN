{"VERRICULATE":[{"def":"Having thickset tufts of parallel hairs, bristles, or branches.","pos":""}],"VERRUCIFORM":[{"def":"Shaped like a wart or warts.","pos":""}],"VERRUCOSE":[{"def":"Covered with wartlike elevations; tuberculate; warty; verrucous; as, a verrucose capsule.","pos":""}],"VERRUCULOSE":[{"def":"Minutely verrucose; as, a verruculose leaf or stalk.","pos":""}],"VERRUGAS":[{"def":"An endemic disease occurring in the Andes in Peru, characterized by warty tumors which ulcerate and bleed.","pos":""}]}