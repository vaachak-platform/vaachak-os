{"OF":[{"def":"In a general sense, from, or out from; proceeding from; belonging to; relating to; concerning; -- used in a variety of applications; as: 1.","pos":""}],"OFF":[{"def":"In a general sense, denoting from or away from; as: 1.","pos":""}],"OFFAL":[{"def":"The rejected or waste parts of a butchered animal.","pos":""},{"def":"A dead body; carrion.","pos":""}],"OFFCUT":[{"def":"A portion ofthe printed sheet, in certain sizes of books, that is cut off before folding.","pos":""}],"OFFEND":[{"def":"To oppose or obstruct in duty; to cause to stumble; to cause to sin or to fall.","pos":""}],"OFFENDER":[{"def":"One who offends; one who violates any law, divine or human; a wrongdoer.","pos":""}],"OFFENDRESS":[{"def":"A woman who offends.","pos":""}],"OFFENSEFUL":[{"def":"Causing offense; displeasing; wrong; as, an offenseful act.","pos":""}],"OFFENSELESS":[{"def":"Unoffending; inoffensive.","pos":""}],"OFFENSIBLE":[{"def":"That may give offense.","pos":""}],"OFFENSION":[{"def":"Assault; attack.","pos":""}],"OFFENSIVE":[{"def":"Giving offense; causing displeasure or resentment; displeasing; annoying; as, offensive words.","pos":""},{"def":"Giving pain or unpleasant sensations; disagreeable; revolting; noxious; as, an offensive smell; offensive sounds.","pos":""}],"OFFER":[{"def":"To present, as an act of worship; to immolate; to sacrifice; to present in prayer or devotion; -- often with up.","pos":""},{"def":"To bring to or before; to hold out to; to present for acceptance or rejection; as, to offer a present, or a bribe; to offer one's self in marriage.","pos":""}],"OFFERABLE":[{"def":"Capable of being offered; suitable or worthy to be offered.","pos":""}],"OFFERER":[{"def":"One who offers; esp.","pos":""}],"OFFERING":[{"def":"The act of an offerer; a proffering.","pos":""},{"def":"That which is offered, esp.","pos":""}],"OFFERTORY":[{"def":"The act of offering, or the thing offered.","pos":""}],"OFFERTURE":[{"def":"Offer; proposal; overture.","pos":""}],"OFFHAND":[{"def":"Instant; ready; extemporaneous; as, an offhand speech; offhand excuses.","pos":""},{"def":"In an offhand manner; as, he replied offhand.","pos":""}],"OFFICE":[{"def":"The apartments or outhouses in which the domestics discharge the duties attached to the service of a house, as kitchens, pantries, stables, etc.","pos":""},{"def":"Any service other than that of ordination and the Mass; any prescribed religious service.","pos":""}],"OFFICE WIRE":[{"def":"Copper wire with a strong but light insulation, used in wiring houses, etc.","pos":""}],"OFFICEHOLDER":[{"def":"An officer, particularly one in the civil service; a placeman.","pos":""}],"OFFICER":[{"def":"Specifically, a commissioned officer, in distinction from a warrant officer.","pos":""}],"OFFICIAL":[{"def":"Approved by authority; sanctioned by the pharmacopoeia; appointed to be used in medicine; as, an official drug or preparation.","pos":""}],"OFFICIALISM":[{"def":"The state of being official; a system of official government; also, adherence to office routine; red-tapism.","pos":""}],"OFFICIALLY":[{"def":"By the proper officer; by virtue of the proper authority; in pursuance of the special powers vested in an officer or office; as, accounts or reports officially vertified or rendered; letters officially communicated; persons officially notified.","pos":""}],"OFFICIALTY":[{"def":"The charge, office, court, or jurisdiction of an official.","pos":""}],"OFFICIANT":[{"def":"The officer who officiates or performs an office, as the burial office.","pos":""}],"OFFICIARY":[{"def":"Of or pertaining to an office or an officer; official.","pos":""}],"OFFICIATE":[{"def":"To act as an officer in performing a duty; to transact the business of an office or public trust; to conduct a public service.","pos":""}],"OFFICIATOR":[{"def":"One who officiates.","pos":""}],"OFFICINAL":[{"def":"Kept in stock by apothecaries; -- said of such drugs and medicines as may be obtained without special preparation or compounding; not magistral.","pos":""}],"OFFICIOUS":[{"def":"Pertaining to, or being in accordance with, duty.","pos":""},{"def":"Disposed to serve; kind; obliging.","pos":""}],"OFFING":[{"def":"That part of the sea at a good distance from the shore, or where there is deep water and no need of a pilot; also, distance from the shore; as, the ship had ten miles offing; we saw a ship in the offing.","pos":""}],"OFFISH":[{"def":"Shy or distant in manner.","pos":""}],"OFFLET":[{"def":"A pipe to let off water.","pos":""}],"OFFPRINT":[{"def":"A reprint or excerpt.","pos":""}],"OFFSCOURING":[{"def":"That which is scoured off; hence, refuse; rejected matter; that which is vile or despised.","pos":""}],"OFFSCUM":[{"def":"Removed scum; refuse; dross.","pos":""}],"OFFSET":[{"def":"In general, that which is set off, from, before, or against, something; as: -- 1.","pos":""},{"def":"A short prostrate shoot, which takes root and produces a tuft of leaves, etc.","pos":""}],"OFFSHOOT":[{"def":"That which shoots off or separates from a main stem, channel, family, race, etc.","pos":""}],"OFFSHORE":[{"def":"From the shore; as, an offshore wind; an offshore signal.","pos":""}],"OFFSKIP":[{"def":"That part of a landscape which recedes from the spectator into distance.","pos":""}],"OFFSPRING":[{"def":"The act of production; generation.","pos":"noun"},{"def":"That which is produced; a child or children; a descendant or descendants, however remote from the stock.","pos":"noun"}],"OFFTAKE":[{"def":"See Obfuscate, Obfuscation.","pos":""}],"OFT":[{"def":"Often; frequently; not rarely; many times.","pos":""}],"OFTEN":[{"def":"Frequently; many times; not seldom.","pos":""}],"OFTENSITH":[{"def":"Frequently; often.","pos":""}],"OFTENTIDE":[{"def":"Frequently; often.","pos":""}],"OFTENTIMES":[{"def":"Frequently; often; many times.","pos":""}],"OFTTIMES":[{"def":"Frequently; often.","pos":""}]}