{"EXCHANGE":[{"def":"The process of setting accounts or debts between parties residing at a distance from each other, without the intervention of money, by exchanging orders or drafts, called bills of exchange.","pos":""},{"def":"A mutual grant of equal interests, the one in consideration of the other.","pos":""}],"EXCHANGE EDITOR":[{"def":"An editor who inspects, and culls from, periodicals, or exchanges, for his own publication.","pos":""}],"EXCHANGEABILITY":[{"def":"The quality or state of being exchangeable.","pos":""}],"EXCHANGEABLE":[{"def":"Capable of being exchanged; fit or proper to be exchanged.","pos":""},{"def":"Available for making exchanges; ratable.","pos":""}],"EXCHANGEABLY":[{"def":"By way of exchange.","pos":""}],"EXCHANGER":[{"def":"One who exchanges; one who practices exchange.","pos":""}],"EXCHEQUER":[{"def":"One of the superior courts of law; -- so called from a checkered cloth, which covers, or formerly covered, the table.","pos":""},{"def":"The department of state having charge of the collection and management of the royal revenue.","pos":""}]}