{"SCREABLE":[{"def":"Capable of being spit out.","pos":""}],"SCREAK":[{"def":"To utter suddenly a sharp, shrill sound; to screech; to creak, as a door or wheel.","pos":""}],"SCREAM":[{"def":"To cry out with a shrill voice; to utter a sudden, sharp outcry, or shrill, loud cry, as in fright or extreme pain; to shriek; to screech.","pos":""}],"SCREAMER":[{"def":"Any one of three species of South American birds constituting the family Anhimidæ, and the suborder Palamedeæ.","pos":""}],"SCREAMING":[{"def":"Uttering screams; shrieking.","pos":""},{"def":"Having the nature of a scream; like a scream; shrill; sharp.","pos":""}],"SCREE":[{"def":"A pebble; a stone; also, a heap of stones or rocky débris.","pos":""}],"SCREECH":[{"def":"To utter a harsh, shrill cry; to make a sharp outcry, as in terror or acute pain; to scream; to shriek.","pos":""}],"SCREECHERS":[{"def":"The picarian birds, as distinguished from the singing birds.","pos":""}],"SCREECHY":[{"def":"Like a screech; shrill and harsh.","pos":""}],"SCREED":[{"def":"A fragment; a portion; a shred.","pos":""}],"SCREEN":[{"def":"A dwarf wall or partition carried up to a certain height for separation and protection, as in a church, to separate the aisle from the choir, or the like.","pos":""}],"SCREENINGS":[{"def":"The refuse left after screening sand, coal, ashes, etc.","pos":""}],"SCREW":[{"def":"A straight line in space with which a definite linear magnitude termed the pitch is associated (cf.","pos":""},{"def":"An amphipod crustacean; as, the skeleton screw (Caprella).","pos":""}],"SCREW-CUTTING":[{"def":"Adapted for forming a screw by cutting; as, a screw-cutting lathe.","pos":""}],"SCREW-DRIVER":[{"def":"A tool for turning screws so as to drive them into their place.","pos":""}],"SCREWER":[{"def":"One who, or that which, screws.","pos":""}],"SCREWING":[{"def":"Screw\"ing, Defn: a.","pos":""}]}