{"TOE":[{"def":"One of the terminal members, or digits, of the foot of a man or an animal.","pos":""},{"def":"The fore part of the hoof or foot of an animal.","pos":""}],"TOE DROP":[{"def":"A morbid condition of the foot in which the toe is depressed and the heel elevated.","pos":""}],"TOE HOLD":[{"def":"A hold in which the agressor bends back his opponent's foot.","pos":""}],"TOED":[{"def":"Having the end secured by nails driven obliquely, said of a board, plank, or joist serving as a brace, and in general of any part of a frame secured to other parts by diagonal nailing.","pos":""}]}