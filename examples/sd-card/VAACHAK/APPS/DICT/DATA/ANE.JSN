{"ANEAR":[{"def":"The measure of misery anear us.","pos":""}],"ANECDOTAGE":[{"def":"Anecdotes collectively; a collection of anecdotes.","pos":""}],"ANECDOTAL":[{"def":"Pertaining to, or abounding with, anecdotes; as, anecdotal conversation.","pos":""}],"ANECDOTE":[{"def":"Unpublished narratives.","pos":""},{"def":"Pertaining to, consisting of, or addicted to, anecdotes.","pos":""}],"ANECDOTIST":[{"def":"One who relates or collects anecdotes.","pos":""}],"ANELE":[{"def":"To give extreme unction to.","pos":""}],"ANELECTRIC":[{"def":"Not becoming electrified by friction; -- opposed to idioelectric.","pos":""},{"def":"A substance incapable of being electrified by friction.","pos":""}],"ANELECTRODE":[{"def":"The positive pole of a voltaic battery.","pos":""}],"ANELECTROTONUS":[{"def":"The condition of decreased irritability of a nerve in the region of the positive electrode or anode on the passage of a current of electricity through it.","pos":""}],"ANEMOGRAM":[{"def":"A record made by an anemograph.","pos":""}],"ANEMOGRAPH":[{"def":"An instrument for measuring and recording the direction and force of the wind.","pos":""}],"ANEMOGRAPHIC":[{"def":"Produced by an anemograph; of or pertaining to anemography.","pos":""}],"ANEMOGRAPHY":[{"def":"A description of the winds.","pos":""},{"def":"The art of recording the direction and force of the wind, as by means of an anemograph.","pos":""}],"ANEMOLOGY":[{"def":"The science of the wind.","pos":""}],"ANEMOMETER":[{"def":"An instrument for measuring the force or velocity of the wind; a wind gauge.","pos":""},{"def":"Of or pertaining to anemometry.","pos":""}],"ANEMOMETROGRAPH":[{"def":"An`e*mo*met\"ro*graph, n.","pos":""}],"ANEMOMETRY":[{"def":"The act or process of ascertaining the force or velocity of the wind.","pos":""}],"ANEMONE":[{"def":"A genus of plants of the Ranunculus or Crowfoot family; windflower.","pos":""},{"def":"The sea anemone.","pos":""}],"ANEMONIC":[{"def":"An acrid, poisonous, crystallizable substance, obtained from, the anemone, or from anemonin.","pos":""}],"ANEMONIN":[{"def":"An acrid, poisonous, crystallizable substance, obtained from some species of anemone.","pos":""}],"ANEMORPHILOUS":[{"def":"Fertilized by the agency of the wind; -- said of plants in which the pollen is carried to the stigma by the wind; wind- Fertilized.","pos":""}],"ANEMOSCOPE":[{"def":"An instrument which shows the direction of the wind; a wind vane; a weathercock; -- usually applied to a contrivance consisting of a vane above, connected in the building with a dial or index with pointers to show the changes of the wind.","pos":""}],"ANEMOSIS":[{"def":"A condition in the wood of some trees in which the rings are separated, as some suppose, by the action of high winds upon the trunk; wind shake.","pos":""},{"def":"Without a brain; brainless.","pos":""}],"ANENTEROUS":[{"def":"Destitute of a stomach or an intestine.","pos":""},{"def":"Lack of energy; inactivity.","pos":""}],"ANEROID":[{"def":"Containing no liquid; -- said of kind of barometer.","pos":""}],"ANES":[{"def":"Same as Anæsthesia, Anæsthetic.","pos":""}],"ANET":[{"def":"The herb dill, or dillseed.","pos":""}],"ANETHOL":[{"def":"A substance obtained from the volatile oils of anise, fennel, etc.","pos":""}],"ANEURISM":[{"def":"A soft, pulsating, hollow tumor, containing blood, arising from the preternatural dilation or rupture of the coats of an artery.","pos":""}],"ANEURISMAL":[{"def":"Of or pertaining to an aneurism; as, an aneurismal tumor; aneurismal diathesis.","pos":""}],"ANEW":[{"def":"Over again; another time; in a new form; afresh; as, to arm anew; to create anew.","pos":""}]}