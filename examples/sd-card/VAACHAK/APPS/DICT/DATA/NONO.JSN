{"NONOBEDIENCE":[{"def":"Neglect of obedience; failure to obey.","pos":""}],"NONOBSERVANCE":[{"def":"Neglect or failure to observe or fulfill.","pos":""}],"NONOIC":[{"def":"Pertaining to, derived from, or resembling, nonane; as, nonoic acid, which is also called pelargonic acid.","pos":""}],"NONONE":[{"def":"Any one of several metameric unsaturated hydrocarbons (C9H14) of the valylene series.","pos":""}],"NONOXYGENOUS":[{"def":"Without oxygen; characterized by the absence of oxygen; as, a nonoxygenous alkaloid.","pos":""}]}