{"FISC":[{"def":"A public or state treasury.","pos":""}],"FISCAL":[{"def":"Pertaining to the public treasury or revenue.","pos":""}],"FISETIC":[{"def":"Pertaining to fustet or fisetin.","pos":""}],"FISETIN":[{"def":"A yellow crystalline substance extracted from fustet, and regarded as its essential coloring principle; -- called also fisetic acid.","pos":""}],"FISH":[{"def":"A counter, used in various games.","pos":""}],"FISH-BELLIED":[{"def":"Bellying or swelling out on the under side; as, a fish-bellied rail.","pos":""}],"FISH-BLOCK":[{"def":"See Fish-tackle.","pos":""}],"FISH-TACKLE":[{"def":"A tackle or purchase used to raise the flukes of the anchor up to the gunwale.","pos":""}],"FISH-TAIL":[{"def":"Like the of a fish; acting, or producing something, like the tail of a fish.","pos":""}],"FISHER":[{"def":"A carnivorous animal of the Weasel family (Mustela Canadensis); the pekan; the \"black cat.","pos":""}],"FISHERMAN":[{"def":"A ship or vessel employed in the business of taking fish, as in the cod fishery.","pos":""}],"FISHERY":[{"def":"The right to take fish at a certain place, or in particular waters.","pos":""}],"FISHFUL":[{"def":"Abounding with fish.","pos":""}],"FISHGIG":[{"def":"A spear with barbed prongs used for harpooning fish.","pos":""}],"FISHHAWK":[{"def":"The osprey (Pandion haliaëtus), found both in Europe and America; -- so called because it plunges into the water and seizes fishes in its talons.","pos":""}],"FISHHOOK":[{"def":"A hook with a pendant, to the end of which the fish-tackle is hooked.","pos":""}],"FISHIFY":[{"def":"To change to fish.","pos":""}],"FISHINESS":[{"def":"The state or quality of being fishy or fishlike.","pos":""}],"FISHING":[{"def":"The act, practice, or art of one who fishes.","pos":""}],"FISHLIKE":[{"def":"Like fish; suggestive of fish; having some of the qualities of fish.","pos":""}],"FISHMONGER":[{"def":"A dealer in fish.","pos":""}],"FISHSKIN":[{"def":"The skin of a fish (dog fish, shark, etc.","pos":""}],"FISHWOMAN":[{"def":"A woman who retails fish.","pos":""}],"FISHY":[{"def":"Consisting of fish; fishlike; having the qualities or taste of fish; abounding in fish.","pos":""},{"def":"Extravagant, like some stories about catching fish; improbable; also, rank or foul.","pos":""}],"FISK":[{"def":"To run about; to frisk; to whisk.","pos":""}],"FISSIGEMMATION":[{"def":"A process of reproduction intermediate between fission and gemmation.","pos":""}],"FISSILE":[{"def":"Capable of being split, cleft, or divided in the direction of the grain, like wood, or along natural planes of cleavage, like crystals.","pos":""}],"FISSILINGUAL":[{"def":"Having the tongue forked.","pos":""}],"FISSILINGUIA":[{"def":"A group of Lacertilia having the tongue forked, including the common lizards.","pos":""}],"FISSILITY":[{"def":"Quality of being fissile.","pos":""}],"FISSION":[{"def":"A process by which certain coral polyps, echinoderms, annelids, etc.","pos":""}],"FISSIPALMATE":[{"def":"Semipalmate and loboped, as a grebe's foot.","pos":""}],"FISSIPARA":[{"def":"Animals which reproduce by fission.","pos":""}],"FISSIPARISM":[{"def":"Reproduction by spontaneous fission.","pos":""}],"FISSIPARITY":[{"def":"Quality of being fissiparous; fissiparism.","pos":""}],"FISSIPAROUS":[{"def":"Reproducing by spontaneous fission.","pos":""}],"FISSIPATION":[{"def":"Reproduction by fission; fissiparism.","pos":""},{"def":"Having the toes separated to the base.","pos":""}],"FISSIPED":[{"def":"One of the Fissipedia.","pos":""}],"FISSIPEDIA":[{"def":"A division of the Carnivora, including the dogs, cats, and bears, in which the feet are not webbed; -- opposed to Pinnipedia.","pos":""}],"FISSIROSTRAL":[{"def":"Having the bill cleft beyond the horny part, as in the case of swallows and goatsuckers.","pos":""}],"FISSIROSTRES":[{"def":"A group of birds having the bill deeply cleft.","pos":""}],"FISSURAL":[{"def":"Pertaining to a fissure or fissures; as, the fissural pattern of a brain.","pos":""}],"FISSURATION":[{"def":"The act of dividing or opening; the state of being fissured.","pos":""}],"FISSURE":[{"def":"A narrow opening, made by the parting of any substance; a cleft; as, the fissure of a rock.","pos":""}],"FISSURELLA":[{"def":"A genus of marine gastropod mollusks, having a conical or limpetlike shell, with an opening at the apex; -- called also keyhole limpet.","pos":""}],"FIST":[{"def":"the index mark [], used to direct special attention to the passage which follows.","pos":""}],"FISTIC":[{"def":"Pertaining to boxing, or to encounters with the fists; puglistic; as, fistic exploits; fistic heroes.","pos":""}],"FISTICUFF":[{"def":"A cuff or blow with the fist or hand; (pl.","pos":""},{"def":"a fight with the fists; boxing.","pos":""}],"FISTINUT":[{"def":"A pistachio nut.","pos":""}],"FISTUCA":[{"def":"An instrument used by the ancients in driving piles.","pos":""}],"FISTULA":[{"def":"A permanent abnormal opening into the soft parts with a constant discharge; a deep, narrow, chronic abscess; an abnormal opening between an internal cavity and another cavity or the surface; as, a salivary fistula; an anal fistula; a recto-vaginal fistula.","pos":""}],"FISTULAR":[{"def":"Hollow and cylindrical, like a pipe or reed.","pos":""}],"FISTULARIA":[{"def":"A genus of fishes, having the head prolonged into a tube, with the mouth at the extremity.","pos":""}],"FISTULARIOID":[{"def":"Like or pertaining to the genus Fistularia.","pos":""}],"FISTULATE":[{"def":"To make hollow or become hollow like a fistula, or pipe.","pos":""}],"FISTULIFORM":[{"def":"Of a fistular form; tubular; pipe-shaped.","pos":""}],"FISTULOSE":[{"def":"Formed like a fistula; hollow; reedlike.","pos":""}],"FISTULOUS":[{"def":"Having the form or nature of a fistula; as, a fistulous ulcer.","pos":""},{"def":"Hollow, like a pipe or reed; fistulose.","pos":""}]}