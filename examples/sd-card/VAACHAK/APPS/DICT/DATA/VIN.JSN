{"VIN ORDINAIRE":[{"def":"A cheap claret, used as a table wine in France.","pos":""}],"VINACEOUS":[{"def":"Belonging to, or like, wine or grapes.","pos":""},{"def":"Of the color of wine, especially of red wine.","pos":""}],"VINAIGRETTE":[{"def":"A sauce, made of vinegar, oil, and other ingredients, -- used esp.","pos":""}],"VINAIGROUS":[{"def":"Resembling vinegar; sour.","pos":""}],"VINASSE":[{"def":"The waste liquor remaining in the process of making beet sugar, -- used in the manufacture of potassium carbonate.","pos":""}],"VINATICO":[{"def":"Madeira mahogany; the coarse, dark-colored wood of the Persea Indica.","pos":""}],"VINCENTIAN":[{"def":"Of or pertaining to Saint Vincent de Paul, or founded by him.","pos":""}],"VINCETOXIN":[{"def":"A glucoside extracted from the root of the white swallowwort (Vincetoxicum officinale, a plant of the Asclepias family) as a bitter yellow amorphous substance; -- called also asclepiadin, and cynanchin.","pos":""}],"VINCIBILITY":[{"def":"The quality or state of being vincible, vincibleness.","pos":""}],"VINCIBLE":[{"def":"Capable of being overcome or subdued; conquerable.","pos":""}],"VINCIBLENESS":[{"def":"The quality or state of being vincible.","pos":""}],"VINCULUM":[{"def":"A straight, horizontal mark placed over two or more members of a compound quantity, which are to be subjected to the same operation, as in the expression x2 + y2 - x + y.","pos":""},{"def":"A band or bundle of fibers; a frænum.","pos":""}],"VINDEMIAL":[{"def":"Of or pertaining to a vintage, or grape harvest.","pos":""}],"VINDEMIATE":[{"def":"To gather the vintage.","pos":""}],"VINDEMIATION":[{"def":"The operation of gathering grapes.","pos":""}],"VINDICABLE":[{"def":"Capable of being vindicated.","pos":""}],"VINDICATE":[{"def":"To lay claim to; to assert a right to; to claim.","pos":""},{"def":"To maintain or defend with success; to prove to be valid; to assert convincingly; to sustain against assault; as, to vindicate a right, claim, or title.","pos":""}],"VINDICATION":[{"def":"The claiming a thing as one's own; the asserting of a right or title in, or to, a thing.","pos":""}],"VINDICATIVE":[{"def":"Tending to vindicate; vindicating; as, a vindicative policy.","pos":""},{"def":"Revengeful; vindictive.","pos":""}],"VINDICATOR":[{"def":"One who vindicates; one who justifies or maintains.","pos":""}],"VINDICATORY":[{"def":"Tending or serving to vindicate or justify; justificatory; vindicative.","pos":""},{"def":"Inflicting punishment; avenging; punitory.","pos":""}],"VINDICTIVE":[{"def":"Disposed to revenge; prompted or characterized by revenge; revengeful.","pos":""}],"VINE":[{"def":"There shall be no grapes on the vine.","pos":""}],"VINE-CLAD":[{"def":"Covered with vines.","pos":""}],"VINEAL":[{"def":"Of or pertaining to vines; containing vines.","pos":""}],"VINED":[{"def":"Having leaves like those of the vine; ornamented with vine leaves.","pos":""}],"VINEDRESSER":[{"def":"One who cultivates, prunes, or cares for, grapevines; a laborer in a vineyard.","pos":""}],"VINEGAR":[{"def":"A sour liquid used as a condiment, or as a preservative, and obtained by the spontaneous (acetous) fermentation, or by the artificial oxidation, of wine, cider, beer, or the like.","pos":""},{"def":"Hence, anything sour; -- used also metaphorically.","pos":""}],"VINEGAR FLY":[{"def":"Any of several fruit flies, esp.","pos":""}],"VINEGARETTE":[{"def":"See Vinaigrette, n.","pos":""}],"VINEGARROON":[{"def":"A whip scorpion, esp.","pos":""}],"VINEGARY":[{"def":"Having the nature of vinegar; sour; unamiable.","pos":""}],"VINERY":[{"def":"A structure, usually inclosed with glass, for rearing and protecting vines; a grapery.","pos":""}],"VINETTE":[{"def":"A sprig or branch.","pos":""}],"VINEWED":[{"def":"Same as Vinnewed.","pos":""}],"VINEYARD":[{"def":"An inclosure or yard for grapevines; a plantation of vines producing grapes.","pos":""}],"VINEYARDIST":[{"def":"One who cultivates a vineyard.","pos":""}],"VINGT ET UN":[{"def":"A game at cards, played by two or more persons.","pos":""}],"VINGTUN":[{"def":"Contraction for Vingt et un.","pos":""}],"VINIC":[{"def":"Of or pertaining to wine; as, vinic alcohol.","pos":""}],"VINICULTURE":[{"def":"The cultivation of the vine, esp.","pos":""}],"VINIFICATION":[{"def":"The conversion of a fruit juice or other saccharine solution into alcohol by fermentation.","pos":""}],"VINNEWED":[{"def":"Many of Chaucer's words are become, as it were, vinnewed and hoary with over-long lying.","pos":""}],"VINOLENT":[{"def":"Given to wine; drunken; intemperate.","pos":""}],"VINOMETER":[{"def":"An instrument for determining the strength or purity of wine by measuring its density.","pos":""}],"VINOSITY":[{"def":"The quality or state of being vinous.","pos":""}],"VINOUS":[{"def":"Of or pertaining to wine; having the qualities of wine; as, a vinous taste.","pos":""}],"VINQUISH":[{"def":"See Vanquish, n.","pos":""}],"VINTAGE":[{"def":"The produce of the vine for one season, in grapes or in wine; as, the vintage is abundant; the vintage of 1840.","pos":""},{"def":"The act or time of gathering the crop of grapes, or making the wine for a season.","pos":""}],"VINTAGER":[{"def":"One who gathers the vintage.","pos":""}],"VINTAGING":[{"def":"The act of gathering the vintage, or crop of grapes.","pos":""}],"VINTNER":[{"def":"One who deals in wine; a wine seller, or wine merchant.","pos":""}],"VINTRY":[{"def":"A place where wine is sold.","pos":""}],"VINUM":[{"def":"Wine, --chiefly used in Pharmacy in the name of solutions of some medicinal substance in wine; as: vina medicata, medicated wines; vinum opii, wine of opium.","pos":""}],"VINY":[{"def":"Of or pertaining to vines; producing, or abounding in, vines.","pos":""}],"VINYL":[{"def":"The hypothetical radical C2H3, regarded as the characteristic residue of ethylene and that related series of unsaturated hydrocarbons with which the allyl compounds are homologous.","pos":""}]}