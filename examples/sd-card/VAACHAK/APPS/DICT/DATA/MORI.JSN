{"MORIA":[{"def":"Idiocy; imbecility; fatuity; foolishness.","pos":""}],"MORIAN":[{"def":"In vain the Turks and Morians armed be.","pos":""}],"MORIBUND":[{"def":"In a dying state; dying; at the point of death.","pos":""}],"MORIC":[{"def":"Pertaining to, or derived from, fustic (see Morin); as, moric acid.","pos":""}],"MORIGERATION":[{"def":"Obsequiousness; obedience.","pos":""}],"MORIGEROUS":[{"def":"Obedient; obsequious.","pos":""}],"MORIL":[{"def":"An edible fungus.","pos":""}],"MORIN":[{"def":"A yellow crystalline substance of acid properties extracted from fustic (Maclura tinctoria, formerly called Morus tinctoria); -- called also moric acid.","pos":""}],"MORINDA":[{"def":"A genus of rubiaceous trees and shrubs, mostly East Indian, many species of which yield valuable red and yellow dyes.","pos":""}],"MORINDIN":[{"def":"A yellow dyestuff extracted from the root bark of an East Indian plant (Morinda citrifolia).","pos":""}],"MORINGA":[{"def":"A genus of trees of Southern India and Northern Africa.","pos":""}],"MORINGIC":[{"def":"Designating an organic acid obtained from oil of ben.","pos":""}],"MORINTANNIC":[{"def":"Pertaining to, or designating, a variety of tannic acid extracted from fustic (Maclura, formerly Morus, tinctoria) as a yellow crystalline substance; -- called also maclurin.","pos":""}],"MORION":[{"def":"A kind of open helmet, without visor or beaver, and somewhat resembling a hat.","pos":""}],"MORIOPLASTY":[{"def":"The restoration of lost parts of the body.","pos":""}],"MORISCO":[{"def":"A thing of Moorish origin; as: (a) The Moorish language.","pos":""}],"MORISK":[{"def":"Same as Morisco.","pos":""}]}