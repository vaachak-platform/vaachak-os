{"SHOW":[{"def":"To exhibit or present to view; to place in sight; to display; -- the thing exhibited being the object, and often with an indirect object denoting the person or thing seeing or beholding; as, to show a house; show your colors; shopkeepers show customers goods (show goods to customers).","pos":""},{"def":"To exhibit to the mental view; to tell; to disclose; to reveal; to make known; as, to show one's designs.","pos":""}],"SHOWBREAD":[{"def":"Bread of exhibition; loaves to set before God; -- the term used in translating the various phrases used in the Hebrew and Greek to designate the loaves of bread which the priest of the week placed before the Lord on the golden table in the sanctuary.","pos":""}],"SHOWER":[{"def":"One who shows or exhibits.","pos":""},{"def":"That which shows; a mirror.","pos":""}],"SHOWERFUL":[{"def":"Full of showers.","pos":""}],"SHOWERINESS":[{"def":"Quality of being showery.","pos":""}],"SHOWERLESS":[{"def":"Rainless; freo from showers.","pos":""}],"SHOWERY":[{"def":"Raining in showers; abounding with frequent showers of rain.","pos":""},{"def":"Of or pertaining to a shower or showers.","pos":""}],"SHOWILY":[{"def":"In a showy manner; pompously; with parade.","pos":""}],"SHOWINESS":[{"def":"The quality or state of being showy; pompousness; great parade; ostentation.","pos":""}],"SHOWING":[{"def":"Appearance; display; exhibition.","pos":""},{"def":"Presentation of facts; statement.","pos":""}],"SHOWISH":[{"def":"Showy; ostentatious.","pos":""}],"SHOWMAN":[{"def":"One who exhibits a show; a proprietor of a show.","pos":""}],"SHOWROOM":[{"def":"A room or apartment where a show is exhibited.","pos":""}],"SHOWY":[{"def":"Making a show; attracting attention; presenting a marked appearance; ostentatious; gay; gaudy.","pos":""}]}