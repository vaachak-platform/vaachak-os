{"INDIVERTIBLE":[{"def":"Not to be diverted or turned aside.","pos":""}],"INDIVIDUAL":[{"def":"Not divided, or not to be divided; existing as one entity, or distinct being or object; single; one; as, an individual man, animal, or city.","pos":""},{"def":"Of or pertaining to one only; peculiar to, or characteristic of, a single person or thing; distinctive; as, individual traits of character; individual exertions; individual peculiarities.","pos":""}],"INDIVIDUALISM":[{"def":"The quality of being individual; individuality; personality.","pos":""},{"def":"An excessive or exclusive regard to one's personal interest; self- interest; selfishness.","pos":""}],"INDIVIDUALISTIC":[{"def":"Of or pertaining to the individual or individualism.","pos":""}],"INDIVIDUALITY":[{"def":"The quality or state of being individual or constituting an individual; separate or distinct existence; oneness; unity.","pos":""},{"def":"The character or property appropriate or peculiar to an individual; that quality which distinguishes one person or thing from another; the sum of characteristic traits; distinctive character; as, he is a person of marked individuality.","pos":""}],"INDIVIDUALIZATION":[{"def":"The act of individualizing; the state of being individualized; individuation.","pos":""}],"INDIVIDUALIZE":[{"def":"The mark as an individual, or to distinguish from others by peculiar properties; to invest with individuality.","pos":""}],"INDIVIDUALIZER":[{"def":"One who individualizes.","pos":""}],"INDIVIDUALLY":[{"def":"In an individual manner or relation; as individuals; separately; each by itself.","pos":""},{"def":"In an inseparable manner; inseparably; incommunicably; indivisibly; as, individuallyhe same.","pos":""}],"INDIVIDUATE":[{"def":"To distinguish from others from others of the species; to endow with individuality; to divide into individuals; to discriminate.","pos":""}],"INDIVIDUATION":[{"def":"The act of individuating or state of being individuated; individualization.","pos":""}],"INDIVIDUATOR":[{"def":"One who, or that which, individuates.","pos":""}],"INDIVIDUITY":[{"def":"Separate existence; individuality; oneness.","pos":""}],"INDIVINITY":[{"def":"Want or absence of divine power or of divinity.","pos":""}],"INDIVISIBILITY":[{"def":"The state or property of being indivisible or inseparable; inseparability.","pos":""}],"INDIVISIBLE":[{"def":"Not capable of exact division, as one quantity by another; incommensurable.","pos":""}],"INDIVISIBLENESS":[{"def":"The state of being indivisible; indivisibility.","pos":""}],"INDIVISIBLY":[{"def":"In an indivisible manner.","pos":""}],"INDIVISION":[{"def":"A state of being not divided; oneness.","pos":""}]}