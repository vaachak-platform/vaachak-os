{"SUDAMINA":[{"def":"Minute vesicles surrounded by an area of reddened skin, produced by excessive sweating.","pos":""}],"SUDARIUM":[{"def":"The handkerchief upon which the Savior is said to have impressed his own portrait miraculously, when wiping his face with it, as he passed to the crucifixion.","pos":""}],"SUDARY":[{"def":"A napkin or handkerchief.","pos":""}],"SUDATORY":[{"def":"Sweating; perspiring.","pos":""}],"SUDD":[{"def":"A tangled mass of floating vegetal matter obstructing navigation.","pos":""}],"SUDDEN":[{"def":"Happening without previous notice or with very brief notice; coming unexpectedly, or without the common preparation; immediate; instant; speedy.","pos":""},{"def":"Hastly prepared or employed; quick; rapid.","pos":""}],"SUDDENTY":[{"def":"Suddenness; a sudden.","pos":""}],"SUDORAL":[{"def":"Of or pertaining to sweat; as, sudoral eruptions.","pos":""}],"SUDORIFEROUS":[{"def":"Producing, or secreting, sweat; sudoriparous.","pos":""}],"SUDORIFIC":[{"def":"Causing sweat; as, sudorific herbs.","pos":""},{"def":"A sudorific medicine.","pos":""}],"SUDORIPAROUS":[{"def":"Same as Sudoriferous.","pos":""}],"SUDOROUS":[{"def":"Consisting of sweat.","pos":""}],"SUDRA":[{"def":"The lowest of the four great castes among the Hindoos.","pos":""}],"SUDS":[{"def":"Water impregnated with soap, esp.","pos":""}]}