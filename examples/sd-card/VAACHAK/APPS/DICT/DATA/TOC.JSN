{"TOCCATA":[{"def":"An old form of piece for the organ or harpsichord, somewhat in the free and brilliant style of the prelude, fantasia, or capriccio.","pos":""},{"def":"A short or simple toccata.","pos":""}],"TOCHER":[{"def":"Dowry brought by a bride to her husband.","pos":""}],"TOCKAY":[{"def":"A spotted lizard native of India.","pos":""}],"TOCO":[{"def":"A toucan (Ramphastos toco) having a very large beak.","pos":""}],"TOCOLOGY":[{"def":"The science of obstetrics, or midwifery; that department of medicine which treats of parturition.","pos":""}],"TOCORORO":[{"def":"A cuban trogon (Priotelus temnurus) having a serrated bill and a tail concave at the end.","pos":""}],"TOCSIN":[{"def":"An alarm bell, or the ringing of a bell for the purpose of alarm.","pos":""}]}