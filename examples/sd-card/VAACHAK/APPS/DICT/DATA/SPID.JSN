{"SPIDER":[{"def":"Any one of numerous species of arachnids comprising the order Araneina.","pos":"noun"},{"def":"Any one of various other arachnids resembling the true spiders, especially certain mites, as the red spider (see under Red).","pos":"noun"}],"SPIDER STITCH":[{"def":"A stitch in lace making used to fill in open spaces with threads resembling a cobweb.","pos":""},{"def":"The silken web which is formed by most kinds of spiders, particularly the web spun to entrap their prey.","pos":""}],"SPIDERED":[{"def":"Infested by spiders; cobwebbed.","pos":""}],"SPIDERWORT":[{"def":"An American endogenous plant (Tradescantia Virginica), with long linear leaves and ephemeral blue flowers.","pos":""}]}