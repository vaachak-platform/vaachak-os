{"CHIP":[{"def":"To cut small pieces from; to diminsh or reduce to shape, by cutting away a little at a time; to hew.","pos":""},{"def":"To break or crack, or crack off a portion of, as of an eggshell in hatching, or a piece of crockery.","pos":""}],"CHIPMUNK":[{"def":"A squirrel-like animal of the genus Tamias, sometimes called the striped squirrel, chipping squirrel, ground squirrel, hackee.","pos":""}],"CHIPPENDALE":[{"def":"Designating furniture designed, or like that designed, by Thomas Chippendale, an English cabinetmaker of the 18th century.","pos":""}],"CHIPPER":[{"def":"To chirp or chirrup.","pos":""}],"CHIPPEWAYS":[{"def":"A tribe of Indians formerly inhabiting the northern and weastern shores of Lake Superior; -- called also Objibways.","pos":""}],"CHIPPING":[{"def":"A chip; a piece separated by a cutting or graving instrument; a fragment.","pos":""},{"def":"The act or process of cutting or breaking off small pieces, as in dressing iron with a chisel, or reducing a timber or block of stone to shape.","pos":""}],"CHIPPY":[{"def":"Abounding in, or resembling, chips; dry and tasteless.","pos":""}],"CHIPS":[{"def":"A ship's carpenter.","pos":""}]}