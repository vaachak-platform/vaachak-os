{"DISQUALIFICATION":[{"def":"The act of disqualifying, or state of being disqualified; want of qualification; incompetency; disability; as, the disqualification of men for holding certain offices.","pos":""},{"def":"That which disqualifies; that which incapacitates or makes unfit; as, conviction of crime is a disqualification of a person for office; sickness is a disqualification for labor.","pos":""}],"DISQUALIFY":[{"def":"To deprive of the qualities or properties necessary for any purpose; to render unfit; to incapacitate; -- with for or from before the purpose, state, or act.","pos":""},{"def":"To deprive of some power, right, or privilege, by positive restriction; to disable; to debar legally; as, a conviction of perjury disqualifies a man to be a witness.","pos":""}],"DISQUANTITY":[{"def":"To diminish the quantity of; to lessen.","pos":""}],"DISQUIET":[{"def":"Deprived of quiet; impatient; restless; uneasy.","pos":""}],"DISQUIETAL":[{"def":"The act of disquieting; a state of disquiet.","pos":""}],"DISQUIETER":[{"def":"One who, or that which, disquiets, or makes uneasy; a disturber.","pos":""}],"DISQUIETFUL":[{"def":"Producing inquietude or uneasiness.","pos":""}],"DISQUIETIVE":[{"def":"Tending to disquiet.","pos":""}],"DISQUIETLY":[{"def":"In a disquiet manner; uneasily; as, he rested disquietly that night.","pos":""}],"DISQUIETMENT":[{"def":"State of being disquieted; uneasiness; harassment.","pos":""}],"DISQUIETNESS":[{"def":"Disturbance of quiet in body or mind; restlessness; uneasiness.","pos":""}],"DISQUIETOUS":[{"def":"Causing uneasiness.","pos":""}],"DISQUIETTUDE":[{"def":"Want of peace or tranquility; uneasiness; disturbance; agitation; anxiety.","pos":""}],"DISQUISITION":[{"def":"A formal or systematic inquiry into, or discussion of, any subject; a full examination or investigation of a matter, with the arguments and facts bearing upon it; elaborate essay; dissertation.","pos":""}],"DISQUISITIONAL":[{"def":"Pertaining to disquisition; of the nature of disquisition.","pos":""}],"DISQUISITIONARY":[{"def":"Pertaining to disquisition; disquisitional.","pos":""}],"DISQUISITIVE":[{"def":"Relating to disquisition; fond discussion or investigation; examining; inquisitive.","pos":""}],"DISQUISITORIAL":[{"def":"Dis*quis`i*to\"ri*al, a.","pos":""}],"DISQUISITORY":[{"def":"Of or pertaining to disquisition; disquisitive.","pos":""}]}