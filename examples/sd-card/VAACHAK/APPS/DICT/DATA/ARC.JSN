{"ARC":[{"def":"A portion of a curved line; as, the arc of a circle or of an ellipse.","pos":""}],"ARC LIGHT":[{"def":"The light of an arc lamp.","pos":""}],"ARCADE":[{"def":"An arched or covered passageway or avenue.","pos":""}],"ARCADED":[{"def":"Furnished with an arcade.","pos":""}],"ARCADIA":[{"def":"Of or pertaining to Arcadia; pastoral; ideally rural; as, Arcadian simplicity or scenery.","pos":""}],"ARCANUM":[{"def":"A secret remedy; an elixir.","pos":""}],"ARCBOUTANT":[{"def":"A flying buttress.","pos":""}],"ARCH":[{"def":"Any part of a curved line.","pos":""}],"ARCH BRICK":[{"def":"A wedge-shaped brick used in the building of an arch.","pos":""}],"ARCH STONE":[{"def":"A wedge-shaped stone used in an arch; a voussoir.","pos":""}],"ARCH-":[{"def":"A prefix signifying chief, as in archbuilder, archfiend.","pos":""}],"ARCHAEAN":[{"def":"Ancient; pertaining to the earliest period in geological history.","pos":""}],"ARCHAEOGRAPHY":[{"def":"A description of, or a treatise on, antiquity or antiquities.","pos":""}],"ARCHAEOLITHIC":[{"def":"Of or pertaining to the earliest Stone age; -- applied to a prehistoric period preceding the Paleolithic age.","pos":""}],"ARCHAEOLOGIAN":[{"def":"An archæologist.","pos":""},{"def":"Relating to archæology, or antiquities; as, archæological researches.","pos":""}],"ARCHAEOLOGIST":[{"def":"One versed in archæology; an antiquary.","pos":""}],"ARCHAEOLOGY":[{"def":"The science or study of antiquities, esp.","pos":""}],"ARCHAEOPTERYX":[{"def":"A fossil bird, of the Jurassic period, remarkable for having a long tapering tail of many vertebræ with feathers along each side, and jaws armed with teeth, with other reptilian characteristics.","pos":""}],"ARCHAEOSTOMATOUS":[{"def":"Applied to a gastrula when the blastorope does not entirely up.","pos":""}],"ARCHAEOZOIC":[{"def":"Like or belonging to the earliest forms of animal life.","pos":""}],"ARCHAIC":[{"def":"Of or characterized by antiquity or archaism; antiquated; obsolescent.","pos":""}],"ARCHAISM":[{"def":"An ancient, antiquated, or old-fashioned, word, expression, or idiom; a word or form of speech no longer in common use.","pos":""},{"def":"Antiquity of style or use; obsoleteness.","pos":""}],"ARCHAIST":[{"def":"One who uses archaisms.","pos":""}],"ARCHAISTIC":[{"def":"Like, or imitative of, anything archaic; pertaining to an archaism.","pos":""}],"ARCHAIZE":[{"def":"To make appear archaic or antique.","pos":""}],"ARCHANGEL":[{"def":"A term applied to several different species of plants (Angelica archangelica, Lamium album, etc.","pos":""}],"ARCHANGELIC":[{"def":"Of or pertaining to archangels; of the nature of, or resembling, an archangel.","pos":""}],"ARCHBISHOP":[{"def":"A chief bishop; a church dignitary of the first class (often called a metropolitan or primate) who superintends the conduct of the suffragan bishops in his province, and also exercises episcopal authority in his own diocese.","pos":""}],"ARCHBISHOPRIC":[{"def":"The jurisdiction or office of an archbishop; the see or province over which archbishop exercises archiepiscopal authority.","pos":""}],"ARCHBUTLER":[{"def":"A chief butler; -- an officer of the German empire.","pos":""}],"ARCHCHAMBERLAIN":[{"def":"A chief chamberlain; -- an officer of the old German empire, whose office was similar to that of the great chamberlain in England.","pos":""}],"ARCHCHANCELLOR":[{"def":"A chief chancellor; -- an officer in the old German empire, who presided over the secretaries of the court.","pos":""}],"ARCHCHEMIC":[{"def":"Of supreme chemical powers.","pos":""}],"ARCHDEACON":[{"def":"In England, an ecclesiastical dignitary, next in rank below a bishop, whom he assists, and by whom he is appointed, though with independent authority.","pos":""}],"ARCHDEACONRY":[{"def":"The district, office, or residence of an archdeacon.","pos":""}],"ARCHDEACONSHIP":[{"def":"The office of an archdeacon.","pos":""}],"ARCHDIOCESE":[{"def":"The diocese of an archbishop.","pos":""}],"ARCHDUCAL":[{"def":"Of or pertaining to an archduke or archduchy.","pos":""}],"ARCHDUCHESS":[{"def":"The consort of an archduke; also, a princess of the imperial family of Austria.","pos":""}],"ARCHDUCHY":[{"def":"The territory of an archduke or archduchess.","pos":""}],"ARCHDUKE":[{"def":"A prince of the imperial family of Austria.","pos":""}],"ARCHEBIOSIS":[{"def":"To origination of living matter from non-living.","pos":""}],"ARCHED":[{"def":"Made with an arch or curve; covered with an arch; as, an arched door.","pos":""}],"ARCHEGONIAL":[{"def":"Relating to the archegonium.","pos":""}],"ARCHEGONIUM":[{"def":"The pistillidium or female organ in the higher cryptogamic plants, corresponding to the pistil in flowering plants.","pos":""}],"ARCHEGONY":[{"def":"Spontaneous generation; abiogenesis.","pos":""}],"ARCHELOGY":[{"def":"The science of, or a treatise on, first principles.","pos":""}],"ARCHENCEPHALA":[{"def":"The division that includes man alone.","pos":""}],"ARCHENEMY":[{"def":"A principal enemy.","pos":""}],"ARCHENTERIC":[{"def":"Relating to the archenteron; as, archenteric invagination.","pos":""}],"ARCHENTERON":[{"def":"The primitive enteron or undifferentiated digestive sac of a gastrula or other embryo.","pos":""},{"def":"Same as Archæology, etc.","pos":""}],"ARCHER":[{"def":"A bowman, one skilled in the use of the bow and arrow.","pos":""}],"ARCHER FISH":[{"def":"A small fish (Toxotes jaculator), of the East Indies; -- so called from its ejecting drops of water from its mouth at its prey.","pos":""}],"ARCHERESS":[{"def":"A female archer.","pos":""}],"ARCHERSHIP":[{"def":"The art or skill of an archer.","pos":""}],"ARCHERY":[{"def":"The use of the bow and arrows in battle, hunting, etc.","pos":""},{"def":"Archers, or bowmen, collectively.","pos":""}],"ARCHES":[{"def":"Mary-le-Bow (de arcubus).","pos":""}],"ARCHETYPAL":[{"def":"Of or pertaining to an archetype; consisting a model (real or ideal) or pattern; original.","pos":""}],"ARCHETYPALLY":[{"def":"With reference to the archetype; originally.","pos":""}],"ARCHETYPE":[{"def":"The standard weight or coin by which others are adjusted.","pos":""},{"def":"The plan or fundamental structure on which a natural group of animals or plants or their systems of organs are assumed to have been constructed; as, the vertebrate archetype.","pos":""}],"ARCHETYPICAL":[{"def":"Relating to an archetype; archetypal.","pos":""}],"ARCHEUS":[{"def":"The vital principle or force which (according to the Paracelsians) presides over the growth and continuation of living beings; the anima mundi or plastic power of the old philosophers.","pos":""}],"ARCHI-":[{"def":"A prefix signifying chief, arch; as, architect, archiepiscopal.","pos":""}],"ARCHIANNELIDA":[{"def":"A group of Annelida remarkable for having no external segments or distinct ventral nerve ganglions.","pos":""}],"ARCHIATER":[{"def":"Chief physician; -- a term applied, on the continent of Europe, to the first or body physician of princes and to the first physician of some cities.","pos":""}],"ARCHIBALD WHEEL":[{"def":"A metal-hubbed wheel of great strength and elasticity, esp.","pos":""}],"ARCHICAL":[{"def":"Chief; primary; primordial.","pos":""}],"ARCHIDIACONAL":[{"def":"Of or pertaining to an archdeacon.","pos":""}],"ARCHIEPISCOPACY":[{"def":"That form of episcopacy in which the chief power is in the hands of archbishops.","pos":""},{"def":"The state or dignity of an archbishop.","pos":""}],"ARCHIEPISCOPAL":[{"def":"Of or pertaining to an archbishop; as, Canterbury is an archiepiscopal see.","pos":""}],"ARCHIEPISCOPALITY":[{"def":"The station or dignity of an archbishop; archiepiscopacy.","pos":""}],"ARCHIEPISCOPATE":[{"def":"The office of an archbishop; an archbishopric.","pos":""}],"ARCHIEREY":[{"def":"The higher order of clergy in Russia, including metropolitans, archbishops, and bishops.","pos":""}],"ARCHIL":[{"def":"A violet dye obtained from several species of lichen (Roccella tinctoria, etc.","pos":""},{"def":"The plant from which the dye is obtained.","pos":""}],"ARCHILOCHIAN":[{"def":"Of or pertaining to the satiric Greek poet Archilochus; as, Archilochian meter.","pos":""}],"ARCHIMANDRITE":[{"def":"Church) (a) A chief of a monastery, corresponding to abbot in the Roman Catholic church.","pos":""}],"ARCHIMEDEAN":[{"def":"Of or pertaining to Archimedes, a celebrated Greek philosopher; constructed on the principle of Archimedes' screw; as, Archimedean drill, propeller, etc.","pos":""}],"ARCHIMEDES":[{"def":"An extinct genus of Bryzoa characteristic of the subcarboniferous rocks.","pos":""}],"ARCHING":[{"def":"Hogging; -- opposed to sagging.","pos":""}],"ARCHIPELAGIC":[{"def":"Of or pertaining to an archipelago.","pos":""}],"ARCHIPELAGO":[{"def":"The Grecian Archipelago, or Ægean Sea, separating Greece from Asia Minor.","pos":""},{"def":"Hence: Any sea or broad sheet of water interspersed with many islands or with a group of islands.","pos":""}],"ARCHIPTERYGIUM":[{"def":"The primitive form of fin, like that of Ceratodus.","pos":""}],"ARCHITECT":[{"def":"A person skilled in the art of building; one who understands architecture, or makes it his occupation to form plans and designs of buildings, and to superintend the artificers employed.","pos":""},{"def":"A contriver, designer, or maker.","pos":""}],"ARCHITECTIVE":[{"def":"Used in building; proper for building.","pos":""}],"ARCHITECTONIC":[{"def":"The science of architecture.","pos":""},{"def":"The act of arranging knowledge into a system.","pos":""}],"ARCHITECTONICS":[{"def":"The science of architecture.","pos":""}],"ARCHITECTRESS":[{"def":"A female architect.","pos":""}],"ARCHITECTURAL":[{"def":"Of or pertaining to the art of building; conformed to the rules of architecture.","pos":""}],"ARCHITECTURE":[{"def":"The art or science of building; especially, the art of building houses, churches, bridges, and other structures, for the purposes of civil life; -- often called civil architecture.","pos":""},{"def":"Construction, in a more general sense; frame or structure; workmanship.","pos":""}],"ARCHITEUTHIS":[{"def":"A genus of gigantic cephalopods, allied to the squids, found esp.","pos":""}],"ARCHITRAVED":[{"def":"Furnished with an architrave.","pos":""}],"ARCHIVAL":[{"def":"Pertaining to, or contained in, archives or records.","pos":""}],"ARCHIVE":[{"def":"The place in which public records or historic documents are kept.","pos":""},{"def":"Public records or documents preserved as evidence of facts; as, the archives of a country or family.","pos":""}],"ARCHIVIST":[{"def":"A keeper of archives or records.","pos":""}],"ARCHIVOLT":[{"def":"A large theorbo, or double-necked lute, formerly in use, having the bass strings doubled with an octave, and the higher strings with a unison.","pos":""}],"ARCHLY":[{"def":"In an arch manner; with attractive slyness or roguishness; slyly; waggishly.","pos":""}],"ARCHMARSHAL":[{"def":"The grand marshal of the old German empire, a dignity that to the Elector of Saxony.","pos":""}],"ARCHNESS":[{"def":"The quality of being arch; cleverness; sly humor free from malice; waggishness.","pos":""}],"ARCHON":[{"def":"One of the chief magistrates in ancient Athens, especially, by preëminence, the first of the nine chief magistrates.","pos":""}],"ARCHONSHIP":[{"def":"The office of an archon.","pos":""}],"ARCHONTATE":[{"def":"An archon's term of office.","pos":""}],"ARCHONTS":[{"def":"The group including man alone.","pos":""}],"ARCHOPLASM":[{"def":"The substance from which attraction spheres develop in mitotic cell division, and of which they consist.","pos":""}],"ARCHPRELATE":[{"def":"An archbishop or other chief prelate.","pos":""}],"ARCHPRESBYTER":[{"def":"Same as Archpriest.","pos":""}],"ARCHPRESBYTERY":[{"def":"The absolute dominion of presbytery.","pos":""}],"ARCHPRIEST":[{"def":"A chief priest; also, a kind of vicar, or a rural dean.","pos":""}],"ARCHPRIMATE":[{"def":"The chief primate.","pos":""}],"ARCHTRAITOR":[{"def":"A chief or transcendent traitor.","pos":""}],"ARCHTREASURER":[{"def":"A chief treasurer.","pos":""}],"ARCHWAY":[{"def":"A way or passage under an arch.","pos":""}],"ARCHWIFE":[{"def":"A big, masculine wife.","pos":""}],"ARCHY":[{"def":"Arched; as, archy brows.","pos":""}],"ARCIFORM":[{"def":"Having the form of an arch; curved.","pos":""}],"ARCOGRAPH":[{"def":"An instrument for drawing a circular arc without the use of a central point; a cyclograph.","pos":""}],"ARCTATION":[{"def":"Constriction or contraction of some natural passage, as in constipation from inflammation.","pos":""}],"ARCTIC":[{"def":"Pertaining to, or situated under, the northern constellation called the Bear; northern; frigid; as, the arctic pole, circle, region, ocean; an arctic expedition, night, temperature.","pos":""}],"ARCTISCA":[{"def":"A group of Arachnida.","pos":""}],"ARCTOGEAL":[{"def":"Of or pertaining to arctic lands; as, the arctogeal fauna.","pos":""}],"ARCTOIDEA":[{"def":"A group of the Carnivora, that includes the bears, weasels, etc.","pos":""}],"ARCTURUS":[{"def":"A fixed star of the first magnitude in the constellation Boötes.","pos":""}],"ARCUAL":[{"def":"Of or pertaining to an arc.","pos":""},{"def":"Bent or curved in the form of a bow.","pos":""}],"ARCUATELY":[{"def":"In the form of a bow.","pos":""}],"ARCUATION":[{"def":"A mode of propagating trees by bending branches to the ground, and covering the small shoots with earth; layering.","pos":""}],"ARCUBALISTER":[{"def":"A crossbowman; one who used the arcubalist.","pos":""}],"ARCUBUS":[{"def":"The termination of many English words; as, coward, reynard, drunkard, mostly from the French, in which language this ending is of German origin, being orig.","pos":""}]}