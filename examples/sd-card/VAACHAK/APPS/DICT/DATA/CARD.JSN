{"CARD":[{"def":"A perforated pasteboard or sheet-metal plate for warp threads, making part of the Jacquard apparatus of a loom.","pos":""}],"CARDAMINE":[{"def":"A genus of cruciferous plants, containing the lady's-smock, cuckooflower, bitter cress, meadow cress, etc.","pos":""}],"CARDAMOM":[{"def":"A plant which prduces cardamoms, esp.","pos":""}],"CARDBOARD":[{"def":"A stiff compact pasteboard of various qualities, for making cards, etc.","pos":""}],"CARDCASE":[{"def":"A case for visiting cards.","pos":""}],"CARDECU":[{"def":"A quarter of a crown.","pos":""}],"CARDER":[{"def":"One who, or that which cards wool flax, etc.","pos":""}],"CARDIAC":[{"def":"Pertaining to, resembling, or hear the heart; as, the cardiac arteries; the cardiac, or left, end of the stomach.","pos":""},{"def":"Exciting action in the heart, through the medium of the stomach; cordial; stimulant.","pos":""}],"CARDIACLE":[{"def":"A pain about the heart.","pos":""}],"CARDIAGRAPH":[{"def":"See Cardiograph.","pos":""},{"def":"A burning or gnawing pain, or feeling of distress, referred to the region of the heart, accompanied with cardisc palpitation; heartburn.","pos":""}],"CARDIGAN JACKET":[{"def":"A warm jacket of knit worsted with or without sleeves.","pos":""}],"CARDINAL":[{"def":"Of fundamental importance; preëminet; superior; chief; principal.","pos":""}],"CARDINALATE":[{"def":"The office, rank, or dignity of a cardinal.","pos":""}],"CARDINALIZE":[{"def":"To exalt to the office of a cardinal.","pos":""}],"CARDING":[{"def":"The act or process of preparing staple for spinning, etc.","pos":""},{"def":"A roll of wool or other fiber as it comes from the carding machine.","pos":""}],"CARDIOGRAM":[{"def":"The curve or tracing made by a cardiograph.","pos":""}],"CARDIOGRAPH":[{"def":"An instrument which, when placed in contact with the chest, will register graphically the comparative duration and intensity of the heart's movements.","pos":""}],"CARDIOGRAPHIC":[{"def":"Of or pertaining to, or produced by, a cardiograph.","pos":""}],"CARDIOGRAPHY":[{"def":"Description of the heart.","pos":""}],"CARDIOID":[{"def":"An algebraic curve, so called from its resemblance to a heart.","pos":""}],"CARDIOINHIBITORY":[{"def":"Checking or arresting the heart's action.","pos":""}],"CARDIOLGY":[{"def":"The science which treats of the heart and its functions.","pos":""}],"CARDIOMETRY":[{"def":"Measurement of the heart, as by percussion or auscultation.","pos":""}],"CARDIOSCLEROSIS":[{"def":"Induration of the heart, caused by development of fibrous tissue in the cardiac muscle.","pos":""}],"CARDIOSPHYGMOGRAPH":[{"def":"A combination of cardiograph and shygmograph.","pos":""}],"CARDITIS":[{"def":"Inflammation of the fleshy or muscular substance of the heart.","pos":""}],"CARDOL":[{"def":"A yellow oil liquid, extracted from the shell of the cashew nut.","pos":""}],"CARDOON":[{"def":"A large herbaceos plant (Cynara Cardunculus) related to the artichoke; -- used in cookery and as a sald.","pos":""}]}