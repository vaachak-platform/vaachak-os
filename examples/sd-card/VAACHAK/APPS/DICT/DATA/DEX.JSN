{"DEXTER":[{"def":"On the right-hand side of a shield, i.","pos":""}],"DEXTERITY":[{"def":"Right-handedness.","pos":""},{"def":"Readiness and grace in physical activity; skill and ease in using the hands; expertness in manual acts; as, dexterity with the chisel.","pos":""}],"DEXTEROUS":[{"def":"Ready and expert in the use of the body and limbs; skillful and active with the hands; handy; ready; as, a dexterous hand; a dexterous workman.","pos":""},{"def":"Skillful in contrivance; quick at inventing expedients; expert; as, a dexterous manager.","pos":""}],"DEXTEROUSLY":[{"def":"In a dexterous manner; skillfully.","pos":""}],"DEXTEROUSNESS":[{"def":"The quality of being dexterous; dexterity.","pos":""}],"DEXTRAD":[{"def":"Toward the right side; dextrally.","pos":""}],"DEXTRAL":[{"def":"Right, as opposed to sinistral, or left.","pos":""}],"DEXTRALITY":[{"def":"The state of being on the right-hand side; also, the quality of being right-handed; right-handedness.","pos":""}],"DEXTRALLY":[{"def":"Dex\"tral*ly Defn: (adv.","pos":""}],"DEXTRER":[{"def":"A war horse; a destrer.","pos":""}],"DEXTRIN":[{"def":"A translucent, gummy, amorphous substance, nearly tasteless and odorless, used as a substitute for gum, for sizing, etc.","pos":""}],"DEXTRO-":[{"def":"A prefix, from L.","pos":""},{"def":"having the property of turning the plane of polarized light to the right; as, dextrotartaric acid.","pos":""}],"DEXTROGEROUS":[{"def":"See Dextrogyrate.","pos":""}],"DEXTROGLUCOSE":[{"def":"Same as Dextrose.","pos":""}],"DEXTROGYRATE":[{"def":"Same as Dextrorotatory.","pos":""}],"DEXTRONIC":[{"def":"Pertaining to, or derived from, dextrose; as, dextronic acid.","pos":""}],"DEXTROROTARY":[{"def":"See Dextrotatory.","pos":""}],"DEXTROROTATORY":[{"def":"Turning, or causing to turn, toward the right hand; esp.","pos":""},{"def":"Turning from the left to the right, in the ascending line, as in the spiral inclination of the stem of the common morning-glóry.","pos":""}],"DEXTROSE":[{"def":"A sirupy, or white crystalline, variety of sugar, C6H12O6 (so called from turning the plane of polarization to the right), occurring in many ripe fruits.","pos":""},{"def":"Same as Dexterous, Dexterously, etc.","pos":""}]}