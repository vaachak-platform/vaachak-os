{"TRIBAL":[{"def":"Of or pertaining to a tribe or tribes; as, a tribal scepter.","pos":""}],"TRIBALISM":[{"def":"The state of existing in tribes; also, tribal feeling; tribal prejudice or exclusiveness; tribal peculiarities or characteristics.","pos":""}],"TRIBASIC":[{"def":"Capable of neutralizing three molecules of a monacid base, or their equivalent; having three hydrogen atoms capable of replacement by basic elements on radicals; -- said of certain acids; thus, citric acid is a tribasic acid.","pos":""}],"TRIBBLE":[{"def":"A frame on which paper is dried.","pos":""}],"TRIBE":[{"def":"A number of species or genera having certain structural characteristics in common; as, a tribe of plants; a tribe of animals.","pos":""},{"def":"A family of animals descended from some particular female progenitor, through the female line; as, the Duchess tribe of shorthorns.","pos":""}],"TRIBOMETER":[{"def":"An instrument to ascertain the degree of friction in rubbing surfaces.","pos":""}],"TRIBRACH":[{"def":"A poetic foot of three short syllables, as, mèlì\\'dcs.","pos":""}],"TRIBRACTEATE":[{"def":"Having three bracts.","pos":""},{"def":"A colorless crystalline substance prepared by the reaction of carbolic acid with bromine.","pos":""}],"TRIBULATION":[{"def":"That which occasions distress, trouble, or vexation; severe affliction.","pos":""}],"TRIBUNAL":[{"def":"The seat of a judge; the bench on which a judge and his associates sit for administering justice.","pos":""},{"def":"Hence, a court or forum; as, the House of Lords, in England, is the highest tribunal in the kingdom.","pos":""}],"TRIBUNARY":[{"def":"Of or pertaining to tribunes; as, tribunary powers or authority.","pos":""}],"TRIBUNATE":[{"def":"The state or office of a tribune; tribuneship.","pos":""}],"TRIBUNE":[{"def":"An officer or magistrate chosen by the people, to protect them from the oppression of the patricians, or nobles, and to defend their liberties against any attempts that might be made upon them by the senate and consuls.","pos":""}],"TRIBUNESHIP":[{"def":"The office or power of a tribune.","pos":""},{"def":"Of or pertaining to tribunes; befitting a tribune; as, tribunitial power or authority.","pos":""}],"TRIBUNITIOUS":[{"def":"Tribunician; tribunitial.","pos":""}],"TRIBUTARILY":[{"def":"In a tributary manner.","pos":""}],"TRIBUTARINESS":[{"def":"The quality or state of being tributary.","pos":""}],"TRIBUTARY":[{"def":"Paying tribute to another, either from compulsion, as an acknowledgment of submission, or to secure protection, or for the purpose of purchasing peace.","pos":""},{"def":"Hence, subject; subordinate; inferior.","pos":""}],"TRIBUTE":[{"def":"A certain proportion of the ore raised, or of its value, given to the miner as his recompense.","pos":""}],"TRIBUTER":[{"def":"One who works for a certain portion of the ore, or its value.","pos":""}]}