{"DIE":[{"def":"To disappear gradually in another surface, as where moldings are lost in a sloped or curved face.","pos":""}],"DIEDRAL":[{"def":"The same as Dihedral.","pos":""}],"DIEGESIS":[{"def":"A narrative or history; a recital or relation.","pos":""}],"DIELECTRIC":[{"def":"Any substance or medium that transmits the electric force by a process different from conduction, as in the phenomena of induction; a nonconductor.","pos":""}],"DIENCEPHALON":[{"def":"The interbrain or thalamencephalon; -- sometimes abbreviated to dien.","pos":""}],"DIERESIS":[{"def":"Same as Diæresis.","pos":""},{"def":"A type of internal-combustion engine in which the air drawn in by the suction stroke is so highly compressed that the heat generated ignites the fuel (usually crude oil), the fuel being automatically sprayed into the cylinder under pressure.","pos":""}],"DIES IRAE":[{"def":"Day of wrath; -- the name and beginning of a famous mediæval Latin hymn on the Last Judgment.","pos":""}],"DIES JURIDICUS":[{"def":"Di\"es ju*rid\"i*cus; pl.","pos":""}],"DIES NON":[{"def":"A day on which courts are not held, as Sunday or any legal holiday.","pos":""}],"DIESINKER":[{"def":"An engraver of dies for stamping coins, medals, etc.","pos":""}],"DIESINKING":[{"def":"The process of engraving dies.","pos":""}],"DIESIS":[{"def":"A small interval, less than any in actual practice, but used in the mathematical calculation of intervals.","pos":""},{"def":"The mark ||; -- called also double dagger.","pos":""}],"DIESTOCK":[{"def":"A stock to hold the dies used for cutting screws.","pos":""}],"DIET":[{"def":"Course of living or nourishment; what is eaten and drunk habitually; food; victuals; fare.","pos":""},{"def":"A course of food selected with reference to a particular state of health; prescribed allowance of food; regimen prescribed.","pos":""}],"DIETARIAN":[{"def":"One who lives in accordance with prescribed rules for diet; a dieter.","pos":""}],"DIETARY":[{"def":"Pertaining to diet, or to the rules of diet.","pos":""}],"DIETER":[{"def":"One who diets; one who prescribes, or who partakes of, food, according to hygienic rules.","pos":""},{"def":"Of or performance to diet, or to the rules for regulating the kind and quantity of food to be eaten.","pos":""}],"DIETETICALLY":[{"def":"In a dietetical manner.","pos":""}],"DIETETICS":[{"def":"That part of the medical or hygienic art which relates to diet or food; rules for diet.","pos":""}],"DIETETIST":[{"def":"A physician who applies the rules of dietetics to the cure of diseases.","pos":""}],"DIETHYLAMINE":[{"def":"A colorless, volatile, alkaline liquid, NH(C2H5)2, having a strong fishy odor resembling that of herring or sardines.","pos":""}],"DIETINE":[{"def":"A subordinate or local assembly; a diet of inferior rank.","pos":""},{"def":"One skilled in dietetics.","pos":""}]}