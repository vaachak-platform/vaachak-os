{"FLOAT":[{"def":"A contrivance for affording a copious stream of water to the heated surface of an object of large bulk, as an anvil or die.","pos":"noun"},{"def":"The trowel or tool with which the floated coat of plastering is leveled and smoothed.","pos":"noun"}],"FLOATABLE":[{"def":"That may be floated.","pos":""}],"FLOATAGE":[{"def":"Same as Flotage.","pos":""}],"FLOATER":[{"def":"One who floats or swims.","pos":""},{"def":"A float for indicating the height of a liquid surface.","pos":""}],"FLOATING":[{"def":"Buoyed upon or in a fluid; a, the floating timbers of a wreck; floating motes in the air.","pos":""},{"def":"Free or lose from the usual attachment; as, the floating ribs in man and some other animals.","pos":""}],"FLOATINGLY":[{"def":"In a floating manner.","pos":""}],"FLOATY":[{"def":"Swimming on the surface; buoyant; light.","pos":""}],"FLOBERT":[{"def":"A small cartridge designed for target shooting; -- sometimes called ball cap.","pos":""}],"FLOCCILLATION":[{"def":"A delirious picking of bedclothes by a sick person, as if to pick off flocks of wool; carphology; -- an alarming symptom in acute diseases.","pos":""}],"FLOCCOSE":[{"def":"Having tufts of soft hairs, which are often deciduous.","pos":""}],"FLOCCULAR":[{"def":"Of or pertaining to the flocculus.","pos":""}],"FLOCCULATE":[{"def":"To aggregate into small lumps.","pos":""}],"FLOCCULATION":[{"def":"The process by which small particles of fine soils and sediments aggregate into larger lumps.","pos":""}],"FLOCCULE":[{"def":"A detached mass of loosely fibrous structure like a shredded tuft of wool.","pos":""}],"FLOCCULENCE":[{"def":"The state of being flocculent.","pos":""}],"FLOCCULENT":[{"def":"Applied to the down of newly hatched or unfledged birds.","pos":""}],"FLOCCULUS":[{"def":"A small lobe in the under surface of the cerebellum, near the middle peduncle; the subpeduncular lobe.","pos":""}],"FLOCCUS":[{"def":"A woolly filament sometimes occuring with the sporules of certain fungi.","pos":""}],"FLOCK":[{"def":"A company or collection of living creatures; -- especially applied to sheep and birds, rarely to persons or (except in the plural) to cattle and other large animals; as, a flock of ravenous fowl.","pos":""},{"def":"A Christian church or congregation; considered in their relation to the pastor, or minister in charge.","pos":""}],"FLOCKLY":[{"def":"In flocks; in crowds.","pos":""}],"FLOCKMEL":[{"def":"In a flock; in a body.","pos":""}],"FLOCKY":[{"def":"Abounding with flocks; floccose.","pos":""}],"FLOE":[{"def":"A low, flat mass of floating ice.","pos":""}],"FLOG":[{"def":"To beat or strike with a rod or whip; to whip; to lash; to chastise with repeated blows.","pos":""}],"FLOGGER":[{"def":"A kind of mallet for beating the bung stave of a cask to start the bung.","pos":""}],"FLOOD":[{"def":"A great flow of water; a body of moving water; the flowing stream, as of a river; especially, a body of water, rising, swelling, and overflowing land not usually thus covered; a deluge; a freshet; an inundation.","pos":""},{"def":"The flowing in of the tide; the semidiurnal swell or rise of water in the ocean; -- opposed to ebb; as, young flood; high flood.","pos":""}],"FLOODER":[{"def":"One who floods anything.","pos":""}],"FLOODING":[{"def":"The filling or covering with water or other fluid; overflow; inundation; the filling anything to excess.","pos":""},{"def":"An abnormal or excessive discharge of blood from the uterus.","pos":""}],"FLOOK":[{"def":"A fluke of an anchor.","pos":""}],"FLOOR":[{"def":"That part of the bottom of a vessel on each side of the keelson which is most nearly horizontal.","pos":""}],"FLOORER":[{"def":"Anything that floors or upsets a person, as a blow that knocks him down; a conclusive answer or retort; a task that exceeds one's abilities.","pos":""}],"FLOORHEADS":[{"def":"The upper extermities of the floor of a vessel.","pos":""}],"FLOORING":[{"def":"A platform; the bottom of a room; a floor; pavement.","pos":""}],"FLOORLESS":[{"def":"Having no floor.","pos":""}],"FLOORWALKER":[{"def":"One who walks about in a large retail store as an overseer and director.","pos":""}],"FLOP":[{"def":"To clap or strike, as a bird its wings, a fish its tail, etc.","pos":""},{"def":"To turn suddenly, as something broad and flat.","pos":""}],"FLOPPY":[{"def":"Having a tendency to flop or flap; as, a floppy hat brim.","pos":""}],"FLORA":[{"def":"The goddess of flowers and spring.","pos":""},{"def":"The complete system of vegetable species growing without cultivation in a given locality, region, or period; a list or description of, or treatise on, such plants.","pos":""}],"FLORAL":[{"def":"Containing, or belonging to, a flower; as, a floral bud; a floral leaf; floral characters.","pos":""}],"FLORALLY":[{"def":"In a floral manner.","pos":""}],"FLORAMOUR":[{"def":"The plant love-lies-bleeding.","pos":"noun"}],"FLORAN":[{"def":"Tin ore scarcely perceptible in the stone; tin ore stamped very fine.","pos":""}],"FLOREAL":[{"def":"The eight month of the French republican calendar.","pos":""}],"FLOREN":[{"def":"A cerain gold coin; a Florence.","pos":""}],"FLORENCE":[{"def":"An ancient gold coin of the time of Edward III.","pos":""},{"def":"A kind of cloth.","pos":""}],"FLORENTINE":[{"def":"Belonging or relating to Florence, in Italy.","pos":""}],"FLORESCENCE":[{"def":"A bursting into flower; a blossoming.","pos":""}],"FLORESCENT":[{"def":"Expanding into flowers; blossoming.","pos":""}],"FLORET":[{"def":"A little flower; one of the numerous little flowers which compose the head or anthodium in such flowers as the daisy, thistle, and dandelion.","pos":""},{"def":"A foil; a blunt sword used in fencing.","pos":""}],"FLORIATED":[{"def":"Having floral ornaments; as, floriated capitals of Gothic pillars.","pos":""}],"FLORIATION":[{"def":"Ornamentation by means of flower forms, whether closely imitated or conventionalized.","pos":""},{"def":"Any floral ornament or decoration.","pos":""}],"FLORICOMOUS":[{"def":"Having the head adorned with flowers.","pos":""}],"FLORICULTURAL":[{"def":"Pertaining to the cultivation of flowering plants.","pos":""}],"FLORICULTURE":[{"def":"The cultivation of flowering plants.","pos":""}],"FLORICULTURIST":[{"def":"One skilled in the cultivation of flowers; a florist.","pos":""}],"FLORID":[{"def":"Flowery; ornamental; running in rapid melodic figures, divisions, or passages, as in variations; full of fioriture or little ornamentations.","pos":""}],"FLORIDEAE":[{"def":"A subclass of algæ including all the red or purplish seaweeds; the Rhodospermeæ of many authors; -- so called from the rosy or florid color of most of the species.","pos":""}],"FLORIDITY":[{"def":"The quality of being florid; floridness.","pos":""}],"FLORIDLY":[{"def":"In a florid manner.","pos":""}],"FLORIDNESS":[{"def":"The quality of being florid.","pos":""}],"FLORIFEROUS":[{"def":"Producing flowers.","pos":""}],"FLORIFICATION":[{"def":"The act, process, or time of flowering; florescence.","pos":""}],"FLORIFORM":[{"def":"Having the form of a flower; flower-shaped.","pos":""}],"FLORIKEN":[{"def":"An Indian bustard (Otis aurita).","pos":""}],"FLORILEGE":[{"def":"The act of gathering flowers.","pos":""}],"FLORIN":[{"def":"A silver coin of Florence, first struck in the twelfth century, and noted for its beauty.","pos":""}],"FLORIST":[{"def":"A cultivator of, or dealer in, flowers.","pos":""},{"def":"One who writes a flora, or an account of plants.","pos":""}],"FLOROON":[{"def":"A border worked with flowers.","pos":""}],"FLORULENT":[{"def":"Flowery; blossoming.","pos":""}],"FLOS-FERRI":[{"def":"A variety of aragonite, occuring in delicate white coralloidal forms; -- common in beds of iron ore.","pos":"noun"}],"FLOSCULARIAN":[{"def":"One of a group of stalked rotifers, having ciliated tentacles around the lobed disk.","pos":""}],"FLOSCULOUS":[{"def":"Consisting of many gamopetalous florets.","pos":""}],"FLOSH":[{"def":"A hopper-shaped box or Knight.","pos":""}],"FLOSS":[{"def":"The slender styles of the pistillate flowers of maize; also called silk.","pos":""}],"FLOSSIFICATION":[{"def":"A flowering; florification.","pos":""}],"FLOSSY":[{"def":"Pertaining to, made of, or resembling, floss; hence, light; downy.","pos":""}],"FLOTAGE":[{"def":"The state of floating.","pos":""},{"def":"That which floats on the sea or in rivers.","pos":""}],"FLOTANT":[{"def":"Represented as flying or streaming in the air; as, a banner flotant.","pos":""}],"FLOTATION":[{"def":"The act, process, or state of floating.","pos":""},{"def":"The science of floating bodies.","pos":""}],"FLOTE":[{"def":"To fleet; to skim.","pos":""}],"FLOTILLA":[{"def":"A little fleet, or a fleet of small vessels.","pos":""},{"def":"Goods lost by shipwreck, and floating on the sea; -- in distinction from jetsam or jetson.","pos":""}],"FLOUNCE":[{"def":"To throw the limbs and body one way and the other; to spring, turn, or twist with sudden effort or violence; to struggle, as a horse in mire; to flounder; to throw one's self with a jerk or spasm, often as in displeasure.","pos":""}],"FLOUNDER":[{"def":"A flatfish of the family Pleuronectidæ, of many species.","pos":"verb"},{"def":"A tool used in crimping boot fronts.","pos":"verb"}],"FLOUR":[{"def":"The finely ground meal of wheat, or of any other grain; especially, the finer part of meal separated by bolting; hence, the fine and soft powder of any substance; as, flour of emery; flour of mustard.","pos":""}],"FLOURED":[{"def":"Finely granulated; -- said of quicksilver which has been granulated by agitation during the amalgamation process.","pos":""}],"FLOURISH":[{"def":"To grow luxuriantly; to increase and enlarge, as a healthy growing plant; a thrive.","pos":""},{"def":"To be prosperous; to increase in wealth, honor, comfort, happiness, or whatever is desirable; to thrive; to be prominent and influental; specifically, of authors, painters, etc.","pos":""}],"FLOURISHER":[{"def":"One who flourishes.","pos":""}],"FLOURISHINGLY":[{"def":"Flour\"ish*ing*ly Defn: , adv.","pos":""}],"FLOURY":[{"def":"Of or resembling flour; mealy; covered with flour.","pos":""}],"FLOUT":[{"def":"To mock or insult; to treat with contempt.","pos":""}],"FLOUTER":[{"def":"One who flouts; a mocker.","pos":""}],"FLOUTINGLY":[{"def":"With flouting; insultingly; as, to treat a lover floutingly.","pos":""}],"FLOW":[{"def":"To move with a continual change of place among the particles or parts, as a fluid; to change place or circulate, as a liquid; as, rivers flow from springs and lakes; tears flow from the eyes.","pos":""},{"def":"To become liquid; to melt.","pos":""}],"FLOWAGE":[{"def":"An overflowing with water; also, the water which thus overflows.","pos":""}],"FLOWER":[{"def":"That part of a plant destined to produce seed, and hence including one or both of the sexual organs; an organ or combination of the organs of reproduction, whether inclosed by a circle of foliar parts or not.","pos":""},{"def":"A substance in the form of a powder, especially when condensed from sublimation; as, the flowers of sulphur.","pos":""}],"FLOWER STATE":[{"def":"Florida; -- a nickname, alluding to sense of L.","pos":""}],"FLOWER-DE-LUCE":[{"def":"A genus of perennial herbs (Iris) with swordlike leaves and large three-petaled flowers often of very gay colors, but probably white in the plant first chosen for the royal French emblem.","pos":""}],"FLOWER-FENCE":[{"def":"A tropical leguminous bush (Poinciana, or Cæsalpinia, pulcherrima) with prickly branches, and showy yellow or red flowers; -- so named from its having been sometimes used for hedges in the West Indies.","pos":""}],"FLOWER-GENTLE":[{"def":"A species of amaranth (Amarantus melancholicus).","pos":""}],"FLOWERAGE":[{"def":"State of flowers; flowers, collectively or in general.","pos":""}],"FLOWERER":[{"def":"A plant which flowers or blossoms.","pos":""}],"FLOWERET":[{"def":"A small flower; a floret.","pos":""}],"FLOWERFUL":[{"def":"Abounding with flowers.","pos":""}],"FLOWERINESS":[{"def":"The state of being flowery.","pos":""}],"FLOWERING":[{"def":"Having conspicuous flowers; -- used as an epithet with many names of plants; as, flowering ash; flowering dogwood; flowering almond, etc.","pos":""}],"FLOWERLESS":[{"def":"Having no flowers.","pos":""}],"FLOWERLESSNESS":[{"def":"State of being without flowers.","pos":""}],"FLOWERPOT":[{"def":"A vessel, commonly or earthenware, for earth in which plants are grown.","pos":""}],"FLOWERY":[{"def":"Full of flowers; abounding with blossoms.","pos":""},{"def":"Highly embellished with figurative language; florid; as, a flowery style.","pos":""}],"FLOWERY-KIRTLED":[{"def":"Dressed with garlands of flowers.","pos":""}],"FLOWING":[{"def":"That flows or for flowing (in various sense of the verb); gliding along smoothly; copious.","pos":""}],"FLOWINGLY":[{"def":"In a flowing manner.","pos":""}],"FLOWINGNESS":[{"def":"Flowing tendency or quality; fluency.","pos":""}],"FLOWN":[{"def":"Flushed, inflated.","pos":""}],"FLOXED SILK":[{"def":"See Floss silk, under Floss.","pos":""}],"FLOYTE":[{"def":"A variant of Flute.","pos":""}]}