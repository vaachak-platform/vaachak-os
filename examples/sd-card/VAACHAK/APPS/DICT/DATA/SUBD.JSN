{"SUBDEACON":[{"def":"One belonging to an order in the Roman Catholic Church, next interior to the order of deacons; also, a member of a minor order in the Greek Church.","pos":""},{"def":"The order or office of subdeacon.","pos":""}],"SUBDEAN":[{"def":"An under dean; the deputy or substitute of a dean.","pos":""}],"SUBDEANERY":[{"def":"Office or rank of subdean.","pos":""}],"SUBDECANAL":[{"def":"Of or pertaining to a subdean or subdeanery.","pos":""}],"SUBDECUPLE":[{"def":"Containing one part of ten.","pos":""}],"SUBDELEGATE":[{"def":"A subordinate delegate, or one with inferior powers.","pos":""}],"SUBDENTED":[{"def":"Indented beneath.","pos":""}],"SUBDEPARTMENT":[{"def":"A subordinate department; a bureau.","pos":""}],"SUBDEPOSIT":[{"def":"That which is deposited beneath something else.","pos":""}],"SUBDERISORIOUS":[{"def":"Ridiculing with moderation.","pos":""}],"SUBDERIVATIVE":[{"def":"A word derived from a derivative, and not directly from the root; as, \"friendliness\" is a subderivative, being derived from \"friendly\", which is in turn a derivative from \"friend.","pos":""}],"SUBDIACONATE":[{"def":"Of or pertaining to a subdeacon, or to the office or rank of a subdeacon.","pos":""}],"SUBDIAL":[{"def":"Of or pertaining to the open air; being under the open sky.","pos":""}],"SUBDIALECT":[{"def":"A subordinate dialect.","pos":""}],"SUBDICHOTOMY":[{"def":"A subordinate, or inferior, division into parts; a subdivision.","pos":""}],"SUBDILATED":[{"def":"Partially dilated.","pos":""}],"SUBDITITIOUS":[{"def":"Put secretly in the place of something else; foisted in.","pos":""}],"SUBDIVERSIFY":[{"def":"To diversify aggain what is already diversified.","pos":""}],"SUBDIVIDE":[{"def":"To divide the parts of (anything) into more parts; to part into smaller divisions; to divide again, as what has already been divided.","pos":""}],"SUBDIVINE":[{"def":"Partaking of divinity; divine in a partial or lower degree.","pos":""}],"SUBDIVISIBLE":[{"def":"Susceptible of subdivision.","pos":""}],"SUBDIVISION":[{"def":"The act of subdividing, or separating a part into smaller parts.","pos":""},{"def":"A part of a thing made by subdividing.","pos":""}],"SUBDOLOUS":[{"def":"Sly; crafty; cunning; artful.","pos":""}],"SUBDOMINANT":[{"def":"The fourth tone above, or fifth below, the tonic; -- so called as being under the dominant.","pos":""}],"SUBDUABLE":[{"def":"Able to be subdued.","pos":""}],"SUBDUAL":[{"def":"Act of subduing.","pos":""}],"SUBDUCTION":[{"def":"The act of subducting or taking away.","pos":""},{"def":"Arithmetical subtraction.","pos":""}],"SUBDUE":[{"def":"To bring under; to conquer by force or the exertion of superior power, and bring into permanent subjection; to reduce under dominion; to vanquish.","pos":""},{"def":"To overpower so as to disable from further resistance; to crush.","pos":""}],"SUBDUED":[{"def":"Conquered; overpowered; crushed; submissive; mild.","pos":""},{"def":"Not glaring in color; soft in tone.","pos":""}],"SUBDUER":[{"def":"One who, or that which, subdues; a conqueror.","pos":""}],"SUBDULCID":[{"def":"Somewhat sweet; sweetish.","pos":""}],"SUBDUPLE":[{"def":"Indicating one part of two; in the ratio of one to two.","pos":""}],"SUBDUPLICATE":[{"def":"Expressed by the square root; -- said of ratios.","pos":""}],"SUBDURAL":[{"def":"Situated under the dura mater, or between the dura mater and the arachnoid membrane.","pos":""}]}