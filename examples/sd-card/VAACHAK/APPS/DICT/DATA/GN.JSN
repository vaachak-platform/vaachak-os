{"GNAPHALIUM":[{"def":"A genus of composite plants with white or colored dry and persistent involucres; a kind of everlasting.","pos":""}],"GNAR":[{"def":"A knot or gnarl in wood; hence, a tough, thickset man; -- written also gnarr.","pos":""}],"GNARL":[{"def":"To growl; to snarl.","pos":""}],"GNARLED":[{"def":"Knotty; full of knots or gnarls; twisted; crossgrained.","pos":""}],"GNARLY":[{"def":"Full of knots; knotty; twisted; crossgrained.","pos":""}],"GNASH":[{"def":"To strike together, as in anger or pain; as, to gnash the teeth.","pos":""}],"GNAT":[{"def":"A blood-sucking dipterous fly, of the genus Culex, undergoing a metamorphosis in water.","pos":""}],"GNATHIC":[{"def":"Of or pertaining to the jaw.","pos":""}],"GNATHIDIUM":[{"def":"The ramus of the lower jaw of a bird as far as it is naked; -- commonly used in the plural.","pos":""}],"GNATHITE":[{"def":"Any one of the mouth appendages of the Arthropoda.","pos":""},{"def":"Flattering; deceitful.","pos":""}],"GNATHOPOD":[{"def":"A gnathopodite or maxilliped.","pos":""}],"GNATHOPODITE":[{"def":"Any leglike appendage of a crustacean, when modified wholly, or in part, to serve as a jaw, esp.","pos":""}],"GNATHOSTEGITE":[{"def":"One of a pair of broad plates, developed from the outer maxillipeds of crabs, and forming a cover for the other mouth organs.","pos":""}],"GNATHOSTOMA":[{"def":"A comprehensive division of vertebrates, including all that have distinct jaws, in contrast with the leptocardians and marsipobranchs (Cyclostoma), which lack them.","pos":""}],"GNATHOTHECA":[{"def":"The horney covering of the lower mandible of a bird.","pos":""}],"GNATWORM":[{"def":"The aquatic larva of a gnat; -- called also, colloquially, wiggler.","pos":""}],"GNAW":[{"def":"To bite, as something hard or tough, which is not readily separated or crushed; to bite off little by little, with effort; to wear or eat away by scraping or continuous biting with the teeth; to nibble at.","pos":""},{"def":"To bite in agony or rage.","pos":""}],"GNAWER":[{"def":"One who, or that which, gnaws.","pos":""}],"GNEISS":[{"def":"A crystalline rock, consisting, like granite, of quartz, feldspar, and mica, but having these materials, especially the mica, arranged in planes, so that it breaks rather easily into coarse slabs or flags.","pos":""}],"GNEISSIC":[{"def":"Relating to, or resembling, gneiss; consisting of gneiss.","pos":""}],"GNEISSOID":[{"def":"Resembling gneiss; having some of the characteristics of gneiss; -- applied to rocks of an intermediate character between granite and gneiss, or mica slate and gneiss.","pos":""}],"GNEISSOSE":[{"def":"Having the structure of gneiss.","pos":""}],"GNIDE":[{"def":"To rub; to bruise; to break in pieces.","pos":""}],"GNOF":[{"def":"Churl; curmudgeon.","pos":""}],"GNOME":[{"def":"A small owl (Glaucidium gnoma) of the Western United States.","pos":""},{"def":"A brief reflection or maxim.","pos":""}],"GNOMICALLY":[{"def":"In a gnomic, didactic, or sententious manner.","pos":""},{"def":"Pertaining to, of the nature of, or resembling, a gnomology.","pos":""}],"GNOMOLOGY":[{"def":"A collection of, or a treatise on, maxims, grave sentences, or reflections.","pos":""}],"GNOMON":[{"def":"The style or pin, which by its shadow, shows the hour of the day.","pos":""},{"def":"A style or column erected perpendicularly to the horizon, formerly used in astronomocal observations.","pos":""}],"GNOMONICALLY":[{"def":"According to the principles of the gnomonic projection.","pos":""}],"GNOMONICS":[{"def":"The art or science of dialing, or of constructing dials to show the hour of the day by the shadow of a gnomon.","pos":""}],"GNOMONIST":[{"def":"One skilled in gnomonics.","pos":""}],"GNOMONOLOGY":[{"def":"A treatise on gnomonics.","pos":""}],"GNOSCOPINE":[{"def":"An alkaloid existing in small quantities in opium.","pos":""}],"GNOSIS":[{"def":"The deeper wisdom; knowledge of spiritual truth, such as was claimed by the Gnostics.","pos":""}],"GNOSTIC":[{"def":"Of or pertaining to Gnosticism or its adherents; as, the Gnostic heresy.","pos":""}],"GNOSTICISM":[{"def":"The system of philosophy taught by the Gnostics.","pos":""}],"GNU":[{"def":"One of two species of large South African antelopes of the genus Catoblephas, having a mane and bushy tail, and curved horns in both sexes.","pos":""}]}