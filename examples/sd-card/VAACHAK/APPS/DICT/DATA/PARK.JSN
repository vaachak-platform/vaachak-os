{"PARK":[{"def":"A piece of ground inclosed, and stored with beasts of the chase, which a man may have by prescription, or the king's grant.","pos":""},{"def":"A space occupied by the animals, wagons, pontoons, and materials of all kinds, as ammunition, ordnance stores, hospital stores, provisions, etc.","pos":""}],"PARKER":[{"def":", The keeper of a park.","pos":""}],"PARKERIA":[{"def":"A genus of large arenaceous fossil Foraminifera found in the Cretaceous rocks.","pos":""}],"PARKESINE":[{"def":"A compound, originally made from gun cotton and castor oil, but later from different materials, and used as a substitute for vulcanized India rubber and for ivory; -- called also xylotile.","pos":""}],"PARKLEAVES":[{"def":"A European species of Saint John's-wort; the tutsan.","pos":""}]}