{"ORPHAN":[{"def":"A child bereaved of both father and mother; sometimes, also, a child who has but one parent living.","pos":""}],"ORPHANAGE":[{"def":"The state of being an orphan; orphanhood; orphans, collectively.","pos":""},{"def":"An institution or asylum for the care of orphans.","pos":""}],"ORPHANET":[{"def":"A little orphan.","pos":""}],"ORPHANHOOD":[{"def":"The state or condition of being an orphan; orphanage.","pos":""}],"ORPHANOTROPHISM":[{"def":"The care and support of orphans.","pos":""}],"ORPHANOTROPHY":[{"def":"A hospital for orphans.","pos":""},{"def":"The act of supporting orphans.","pos":""}],"ORPHARION":[{"def":"An old instrument of the lute or cittern kind.","pos":""}],"ORPHEAN":[{"def":"Of or pertaining to Orpheus, the mythic poet and musician; as, Orphean strains.","pos":""}],"ORPHEUS":[{"def":"The famous mythic Thracian poet, son of the Muse Calliope, and husband of Eurydice.","pos":""}],"ORPHIC":[{"def":"Pertaining to Orpheus; Orphean; as, Orphic hymns.","pos":""}],"ORPHREY":[{"def":"A band of rich embroidery, wholly or in part of gold, affixed to vestments, especially those of ecclesiastics.","pos":""}],"ORPIMENT":[{"def":"Arsenic sesquisulphide, produced artificially as an amorphous lemonyellow powder, and occurring naturally as a yellow crystalline mineral; -- formerly called auripigment.","pos":""}],"ORPIN":[{"def":"A yellow pigment of various degrees of intensity, approaching also to red.","pos":""}],"ORPINE":[{"def":"A low plant with fleshy leaves (Sedum telephium), having clusters of purple flowers.","pos":""}]}