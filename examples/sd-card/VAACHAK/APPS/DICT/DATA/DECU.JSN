{"DECUBATION":[{"def":"Act of lying down; decumbence.","pos":""}],"DECUBITUS":[{"def":"An attitude assumed in lying down; as, the dorsal decubitus.","pos":""},{"def":"An accidental blowing off of, or other serious damage to, the breechblock of a gun; also, a removal of the breechblock for the purpose of disabling the gun.","pos":""}],"DECUMAN":[{"def":"Large; chief; -- applied to an extraordinary billow, supposed by some to be every tenth in order.","pos":""},{"def":"The act or posture of lying down.","pos":""}],"DECUMBENT":[{"def":"Reclining on the ground, as if too weak to stand, and tending to rise at the summit or apex; as, a decumbent stem.","pos":""}],"DECUMBENTLY":[{"def":"In a decumbent posture.","pos":""}],"DECUMBITURE":[{"def":"Aspect of the heavens at the time of taking to one's sick bed, by which the prognostics of recovery or death were made.","pos":""}],"DECUPLE":[{"def":"A number ten times repeated.","pos":""}],"DECURION":[{"def":"A head or chief over ten; especially, an officer who commanded a division of ten soldiers.","pos":""}],"DECURIONATE":[{"def":"The office of a decurion.","pos":""}],"DECURRENCE":[{"def":"The act of running down; a lapse.","pos":""}],"DECURRENT":[{"def":"Extending downward; -- said of a leaf whose base extends downward and forms a wing along the stem.","pos":""}],"DECURSION":[{"def":"A flowing; also, a hostile incursion.","pos":""}],"DECURSIVE":[{"def":"Running down; decurrent.","pos":""}],"DECURSIVELY":[{"def":"In a decursive manner.","pos":""}],"DECURT":[{"def":"To cut short; to curtail.","pos":""}],"DECURTATION":[{"def":"Act of cutting short.","pos":""}],"DECURY":[{"def":"A set or squad of ten men under a decurion.","pos":""}],"DECUSSATE":[{"def":"To cross at an acute angle; to cut or divide in the form of X; to intersect; -- said of lines in geometrical figures, rays of light, nerves, etc.","pos":""},{"def":"Growing in pairs, each of which is at right angles to the next pair above or below; as, decussated leaves or branches.","pos":""}],"DECUSSATELY":[{"def":"In a decussate manner.","pos":""}],"DECUSSATION":[{"def":"Act of crossing at an acute angle, or state of being thus crossed; an intersection in the form of an X; as, the decussation of lines, nerves, etc.","pos":""}],"DECUSSATIVE":[{"def":"Intersecting at acute angles.","pos":""}],"DECUSSATIVELY":[{"def":"Crosswise; in the form of an X.","pos":""}]}