{"HAS":[{"def":"Has, Defn: 3d pers.","pos":""}],"HASH":[{"def":"That which is hashed or chopped up; meat and vegetables, especially such as have been already cooked, chopped into small pieces and mixed.","pos":""},{"def":"A new mixture of old matter; a second preparation or exhibition.","pos":""}],"HASK":[{"def":"A basket made of rushes or flags, as for carrying fish.","pos":""}],"HASLET":[{"def":"The edible viscera, as the heart, liver, etc.","pos":""}],"HASP":[{"def":"A clasp, especially a metal strap permanently fast at one end to a staple or pin, while the other passes over a staple, and is fastened by a padlock or a pin; also, a metallic hook for fastening a door.","pos":""},{"def":"A spindle to wind yarn, thread, or silk on.","pos":""}],"HASSOCK":[{"def":"A rank tuft of bog grass; a tussock.","pos":""},{"def":"A small stuffed cushion or footstool, for kneeling on in church, or for home use.","pos":""}],"HAST":[{"def":"Shaped like the head of a halberd; triangular, with the basal angles or lobes spreading; as, a hastate leaf.","pos":""}],"HASTE":[{"def":"Celerity of motion; speed; swiftness; dispatch; expedition; -- applied only to voluntary beings, as men and other animals.","pos":""},{"def":"The state of being urged or pressed by business; hurry; urgency; sudden excitement of feeling or passion; precipitance; vehemence.","pos":""}],"HASTEN":[{"def":"To press; to drive or urge forward; to push on; to precipitate; to accelerate the movement of; to expedite; to hurry.","pos":""}],"HASTENER":[{"def":"One who hastens.","pos":""},{"def":"That which hastens; especially, a stand or reflector used for confining the heat of the fire to meat while roasting before it.","pos":""}],"HASTILE":[{"def":"Same as Hastate.","pos":""}],"HASTILY":[{"def":"In haste; with speed or quickness; speedily; nimbly.","pos":""},{"def":"Without due reflection; precipitately; rashly.","pos":""}],"HASTINESS":[{"def":"The quality or state of being hasty; haste; precipitation; rashness; quickness of temper.","pos":""}],"HASTINGS":[{"def":"Early fruit or vegetables; especially, early pease.","pos":""}],"HASTINGS SANDS":[{"def":"The lower group of the Wealden formation; -- so called from its development around Hastings, in Sussex, England.","pos":""}],"HASTIVE":[{"def":"Forward; early; -- said of fruits.","pos":""}],"HASTY":[{"def":"Proceeding from, or indicating, a quick temper.","pos":""}],"HASTY PUDDING":[{"def":"A thick batter pudding made of Indian meal stirred into boiling water; mush.","pos":""},{"def":"A batter or pudding made of flour or oatmeal, stirred into boiling water or milk.","pos":""}]}