{"PERISARC":[{"def":"The outer, hardened integument which covers most hydroids.","pos":""}],"PERISCIAN":[{"def":"Having the shadow moving all around.","pos":""},{"def":"Those who live within a polar circle, whose shadows, during some summer days, will move entirely round, falling toward every point of the compass.","pos":""}],"PERISCOPE":[{"def":"A general or comprehensive view.","pos":""}],"PERISCOPIC":[{"def":"Viewing all around, or on all sides.","pos":""}],"PERISH":[{"def":"To be destroyed; to pass away; to become nothing; to be lost; to die; hence, to wither; to waste away.","pos":""}],"PERISHABILITY":[{"def":"Per`ish*a*bil\"i*ty, n.","pos":""}],"PERISHABLE":[{"def":"Liable to perish; subject to decay, destruction, or death; as, perishable goods; our perishable bodies.","pos":""}],"PERISHABLENESS":[{"def":"The quality or state of being perishable; liability to decay or destruction.","pos":""}],"PERISHABLY":[{"def":"In a perishable degree or manner.","pos":""}],"PERISHMENT":[{"def":"The act of perishing.","pos":""}],"PERISOMA":[{"def":"Same as Perisome.","pos":""}],"PERISOME":[{"def":"The entire covering of an invertebrate animal, as echinoderm or coelenterate; the integument.","pos":""}],"PERISPERM":[{"def":"The albumen of a seed, especially that portion which is formed outside of the embryo sac.","pos":""},{"def":"Exactly spherical; globular.","pos":""}],"PERISPOMENON":[{"def":"A word which has the circumflex accent on the last syllable.","pos":""}],"PERISPORE":[{"def":"The outer covering of a spore.","pos":""}],"PERISSAD":[{"def":"Odd; not even; -- said of elementary substances and of radicals whose valence is not divisible by two without a remainder.","pos":""}],"PERISSODACTYL":[{"def":"One of the Perissodactyla.","pos":""}],"PERISSODACTYLA":[{"def":"A division of ungulate mammals, including those that have an odd number of toes, as the horse, tapir, and rhinoceros; -- opposed to Artiodactyla.","pos":""}],"PERISSOLOGICAL":[{"def":"Redundant or excessive in words.","pos":""}],"PERISSOLOGY":[{"def":"Superfluity of words.","pos":""}],"PERISTALSIS":[{"def":"Peristaltic contraction or action.","pos":""}],"PERISTALTIC":[{"def":"Applied to the peculiar wormlike wave motion of the intestines and other similar structures, produced by the successive contraction of the muscular fibers of their walls, forcing their contents onwards; as, peristaltic movement.","pos":""}],"PERISTERIA":[{"def":"A genus of orchidaceous plants.","pos":""}],"PERISTERION":[{"def":"The herb vervain (Verbena officinalis).","pos":""}],"PERISTERITE":[{"def":"A variety of albite, whitish and slightly iridescent like a pigeon's neck.","pos":""}],"PERISTEROMORPHOUS":[{"def":"Like or pertaining to the pigeons or Columbæ.","pos":""}],"PERISTEROPODOUS":[{"def":"Having pigeonlike feet; -- said of those gallinaceous birds that rest on all four toes, as the curassows and megapods.","pos":""}],"PERISTOLE":[{"def":"Peristaltic action, especially of the intestines.","pos":""}],"PERISTOMA":[{"def":"Same as Peristome.","pos":""}],"PERISTOME":[{"def":"The fringe of teeth around the orifice of the capsule of mosses.","pos":""}],"PERISTOMIAL":[{"def":"Of or pertaining to a peristome.","pos":""}],"PERISTOMIUM":[{"def":"Same as Peristome.","pos":""}],"PERISTREPHIC":[{"def":"Turning around; rotatory; revolving; as, a peristrephic painting (of a panorama).","pos":""}],"PERISTYLE":[{"def":"A range of columns with their entablature, etc.","pos":""}],"PERISYSTOLE":[{"def":"The interval between the diastole and systole of the heart.","pos":""}]}