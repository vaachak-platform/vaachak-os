{"HIP":[{"def":"The external angle formed by the meeting of two sloping sides or skirts of a roof, which have their wall plates running in different directions.","pos":""},{"def":"In a bridge truss, the place where an inclined end post meets the top chord.","pos":""}],"HIP LOCK":[{"def":"A lock in which a close grip is obtained and a fall attempted by a heave over the hip.","pos":""},{"def":"A genus of marine decapod crustaceans, which burrow rapidly in the sand by pushing themselves backward; -- called also bait bug.","pos":""}],"HIP-ROOFED":[{"def":"Having a hip roof.","pos":""}],"HIPE":[{"def":"To throw by means of a hipe.","pos":""}],"HIPHALT":[{"def":"Lame in the hip.","pos":""}],"HIPPARION":[{"def":"An extinct genus of Tertiary mammals allied to the horse, but three-toed, having on each foot a small lateral hoof on each side of the main central one.","pos":""},{"def":"Somewhat hypochondriac; melancholy.","pos":""}],"HIPPOBOSCA":[{"def":"A genus of dipterous insects including the horsefly or horse tick.","pos":""}],"HIPPOCAMP":[{"def":"See Hippocampus.","pos":""}],"HIPPOCAMPAL":[{"def":"Of or pertaining to the hippocampus.","pos":""}],"HIPPOCAMPUS":[{"def":"A fabulous monster, with the head and fore quarters of a horse joined to the tail of a dolphin or other fish (Hippocampus brevirostris), -- seen in Pompeian paintings, attached to the chariot of Neptune.","pos":""},{"def":"A genus of lophobranch fishes of several species in which the head and neck have some resemblance to those of a horse; -- called also sea horse.","pos":""}],"HIPPOCENTAUR":[{"def":"Same as Centaur.","pos":""}],"HIPPOCRAS":[{"def":"A cordial made of spiced wine, etc.","pos":""}],"HIPPOCRATES":[{"def":"A famous Greek physician and medical writer, born in Cos, about 460 B.","pos":""}],"HIPPOCRATIC":[{"def":"Of or pertaining to Hippocrates, or to his teachings.","pos":""}],"HIPPOCRATISM":[{"def":"The medical philosophy or system of Hippocrates.","pos":""}],"HIPPOCRENE":[{"def":"A fountain on Mount Helicon in Boeotia, fabled to have burst forth when the ground was struck by the hoof of Pegasus.","pos":""}],"HIPPOCREPIAN":[{"def":"One of an order of fresh-water Bryozoa, in which the tentacles are on a lophophore, shaped like a horseshoe.","pos":""}],"HIPPOCREPIFORM":[{"def":"Shaped like a horseshoe.","pos":""}],"HIPPODAME":[{"def":"A fabulous sea monster.","pos":""}],"HIPPODROME":[{"def":"A place set apart for equestrian and chariot races.","pos":""}],"HIPPOGRIFF":[{"def":"A fabulous winged animal, half horse and half griffin.","pos":""}],"HIPPOLITH":[{"def":"A concretion, or kind of bezoar, from the intestines of the horse.","pos":""}],"HIPPOPATHOLOGY":[{"def":"The science of veterinary medicine; the pathology of the horse.","pos":""}],"HIPPOPHAGI":[{"def":"Eaters of horseflesh.","pos":""}],"HIPPOPHAGIST":[{"def":"One who eats horseflesh.","pos":""}],"HIPPOPHAGOUS":[{"def":"Feeding on horseflesh; -- said of certain nomadic tribes, as the Tartars.","pos":""}],"HIPPOPHAGY":[{"def":"The act or practice of feeding on horseflesh.","pos":""}],"HIPPOPHILE":[{"def":"One who loves horses.","pos":""}],"HIPPOPOTAMUS":[{"def":"A large, amphibious, herbivorous mammal (Hippopotamus amphibius), common in the rivers of Africa.","pos":""}],"HIPPOTOMY":[{"def":"Anatomy of the horse.","pos":""}],"HIPPURIC":[{"def":"Obtained from the urine of horses; as, hippuric acid.","pos":""}],"HIPPURITE":[{"def":"A fossil bivalve mollusk of the genus Hippurites, of many species, having a conical, cup-shaped under valve, with a flattish upper valve or lid.","pos":""}],"HIPSHOT":[{"def":"Having the hip dislocated; hence, having one hip lower than the other.","pos":""}]}