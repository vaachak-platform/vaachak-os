{"SNUB":[{"def":"To sob with convulsions.","pos":"verb"}],"SNUB-NOSED":[{"def":"Having a short, flat nose, slightly turned up; as, the snub- nosed eel.","pos":""}],"SNUDGE":[{"def":"To lie snug or quiet.","pos":""}],"SNUFF":[{"def":"The part of a candle wick charred by the flame, whether burning or not.","pos":""}],"SNUFFBOX":[{"def":"A small box for carrying snuff about the person.","pos":""}],"SNUFFER":[{"def":"The common porpoise.","pos":""}],"SNUFFERS":[{"def":"An instrument for cropping and holding the snuff of a candle.","pos":""}],"SNUFFINGLY":[{"def":"In a snuffing manner.","pos":""}],"SNUFFLE":[{"def":"To speak through the nose; to breathe through the nose when it is obstructed, so as to make a broken sound.","pos":"verb"}],"SNUFFLER":[{"def":"One who snuffles; one who uses cant.","pos":""}],"SNUFFY":[{"def":"Soiled with snuff.","pos":""},{"def":"Sulky; angry; vexed.","pos":""}],"SNUG":[{"def":"Close and warm; as, an infant lies snug.","pos":""},{"def":"Close; concealed; not exposed to notice.","pos":""}],"SNUGGERY":[{"def":"A snug, cozy place.","pos":""}],"SNUGGLE":[{"def":"To move one way and the other so as to get a close place; to lie close for comfort; to cuddle; to nestle.","pos":""}],"SNUGLY":[{"def":"In a snug manner; closely; safely.","pos":""}],"SNUGNESS":[{"def":"The quality or state of being snug.","pos":""}]}