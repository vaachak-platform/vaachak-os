{"CALI":[{"def":"The tenth avatar or incarnation of the god Vishnu.","pos":""},{"def":"The diameter of the bore, as a cannon or other firearm, or of any tube; or the weight or size of the projectile which a firearm will carry; as, an 8 inch gun, a 12-pounder, a 44 caliber.","pos":""}],"CALIBRATE":[{"def":"To ascertain the caliber of, as of a thermometer tube; also, more generally, to determine or rectify the graduation of, as of the various standards or graduated instruments.","pos":""}],"CALIBRATION":[{"def":"The process of estimating the caliber a tube, as of a thermometer tube, in order to graduate it to a scale of degrees; also, more generally, the determination of the true value of the spaces in any graduated instrument.","pos":""}],"CALICLE":[{"def":"One of the cuplike structures inclosing the zooids of certain hydroids.","pos":""}],"CALICO":[{"def":"Plain white cloth made from cotton, but which receives distinctive names according to quality and use, as, super calicoes, shirting calicoes, unbleached calicoes, etc.","pos":""},{"def":"Cotton cloth printed with a figured pattern.","pos":""}],"CALICOBACK":[{"def":"Relating to, or resembling, a cup; also improperly used for calycular, calyculate.","pos":""}],"CALID":[{"def":"Hot; burning; ardent.","pos":""}],"CALIDUCT":[{"def":"A pipe or duct used to convey hot air or steam.","pos":""},{"def":"Same as Caliph, Caliphate, etc.","pos":""}],"CALIFORNIA JACK":[{"def":"A game at cards, a modification of seven-up, or all fours.","pos":""}],"CALIFORNIAN":[{"def":"Of or pertaining to California.","pos":""},{"def":"A native or inhabitant of California.","pos":""}],"CALIGATION":[{"def":"Dimness; cloudiness.","pos":""}],"CALIGINOUS":[{"def":"Affected with darkness or dimness; dark; obscure.","pos":""}],"CALIGO":[{"def":"Dimness or obscurity of sight, dependent upon a speck on the cornea; also, the speck itself.","pos":""}],"CALIGRAPHIC":[{"def":"See Calligraphic.","pos":""}],"CALIN":[{"def":"An alloy of lead and tin, of which the Chinese make tea canisters.","pos":""}],"CALIPASH":[{"def":"A part of a turtle which is next to the upper shell.","pos":""}],"CALIPEE":[{"def":"A part of a turtle which is attached to the lower shell.","pos":""}],"CALIPERS":[{"def":"An instrument, usually resembling a pair of dividers or compasses with curved legs, for measuring the diameter or thickness of bodies, as of work shaped in a lathe or planer, timber, masts, shot, etc.","pos":""}],"CALIPH":[{"def":"Successor or vicar; -- a title of the successors of Mohammed both as temporal and spiritual rulers, now used by the sultans of Turkey, [Writting also calif.","pos":""}],"CALIPHATE":[{"def":"The office, dignity, or government of a caliph or of the caliphs.","pos":""}],"CALIPPIC":[{"def":"Of or pertaining to Calippus, an Athenian astronomer.","pos":""}],"CALISAYA BARK":[{"def":"A valuable kind of Peruvian bark obtained from the Cinchona Calisaya, and other closely related species.","pos":""}],"CALISTHENEUM":[{"def":"A gymnasium; esp.","pos":""}],"CALISTHENIC":[{"def":"Of or pertaining to calisthenics.","pos":""}],"CALISTHENICS":[{"def":"The science, art, or practice of healthful exercise of the body and limbs, to promote strength and gracefulness; light gymnastics.","pos":""}],"CALIVER":[{"def":"An early form of hand gun, variety of the arquebus; originally a gun having a regular size of bore.","pos":""}]}