{"TRON":[{"def":"See 3d Trone, 2.","pos":""}],"TRONA":[{"def":"A native double salt, consisting of a combination of neutral and acid sodium carbonate, Na2CO3.","pos":""}],"TRONAGE":[{"def":"A toll or duty paid for weighing wool; also, the act of weighing wool.","pos":""}],"TRONATOR":[{"def":"An officer in London whose duty was to weigh wool.","pos":""}],"TRONE":[{"def":"A form of weighing machine for heavy wares, consisting of two horizontal bars crossing each other, beaked at the extremities, and supported by a wooden pillar.","pos":""}]}