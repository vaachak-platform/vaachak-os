{"BUXEOUS":[{"def":"Belonging to the box tree.","pos":""}],"BUXINE":[{"def":"An alkaloid obtained from the Buxus sempervirens, or common box tree.","pos":""}],"BUXOM":[{"def":"Yielding; pliable or compliant; ready to obey; obedient; tractable; docile; meek; humble.","pos":""},{"def":"Having the characteristics of health, vigor, and comeliness, combined with a gay, lively manner; stout and rosy; jolly; frolicsome.","pos":""}]}