{"CHIMAERA":[{"def":"A cartilaginous fish of several species, belonging to the order Holocephali.","pos":""}],"CHIMAEROID":[{"def":"Related to, or like, the chimæra.","pos":""}],"CHIMANGO":[{"def":"A south American carrion buzzard (Milvago chimango).","pos":""}],"CHIMB":[{"def":"The edge of a cask, etc; a chine.","pos":""}],"CHIME":[{"def":"The harmonious sound of bells, or of musical instruments.","pos":""},{"def":"A set of bells musically tuned to each other; specif.","pos":""}],"CHIMERA":[{"def":"A monster represented as vomiting flames, and as having the head of a lion, the body of a goat, and the tail of a dragon.","pos":""}],"CHIMERE":[{"def":"The upper robe worn by a bishop, to which lawn sleeves are usually attached.","pos":""}],"CHIMERICAL":[{"def":"Merely imaginary; fanciful; fantastic; wildly or vainly conceived; having, or capable of having, no existence except in thought; as, chimerical projects.","pos":""}],"CHIMERICALLY":[{"def":"Wildy; vainly; fancifully.","pos":""}],"CHIMINAGE":[{"def":"A toll for passage through a forest.","pos":""}],"CHIMNEY":[{"def":"A body of ore, usually of elongated form, extending downward in a vein.","pos":""}],"CHIMNEY-BREAST":[{"def":"The horizontal projection of a chimney from the wall in which it is built; -- commonly applied to its projection in the inside of a building only.","pos":""}],"CHIMNEY-PIECE":[{"def":"A decorative construction around the opning of a fireplace.","pos":""}],"CHIMPANZEE":[{"def":"An african ape (Anthropithecus troglodytes or Troglodytes niger) which approaches more nearly to man, in most respects, than any other ape.","pos":""}]}