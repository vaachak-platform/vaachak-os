{"AGO":[{"def":"Past; gone by; since; as, ten years ago; gone long ago.","pos":""}],"AGOG":[{"def":"In eager desire; eager; astir.","pos":""}],"AGOING":[{"def":"In motion; in the act of going; as, to set a mill agoing.","pos":""}],"AGON":[{"def":"A contest for a prize at the public games.","pos":""}],"AGONE":[{"def":"Three days agone I fell sick.","pos":""}],"AGONIC":[{"def":"Not forming an angle.","pos":""}],"AGONISM":[{"def":"Contention for a prize; a contest.","pos":""}],"AGONIST":[{"def":"One who contends for the prize in public games.","pos":""},{"def":"Pertaining to violent contests, bodily or mental; pertaining to athletic or polemic feats; athletic; combative; hence, strained; unnatural.","pos":""}],"AGONISTICALLY":[{"def":"In an agonistic manner.","pos":""}],"AGONISTICS":[{"def":"The science of athletic combats, or contests in public games.","pos":""}],"AGONIZE":[{"def":"To writhe with agony; to suffer violent anguish.","pos":""},{"def":"To struggle; to wrestle; to strive desperately.","pos":""}],"AGONIZINGLY":[{"def":"With extreme anguish or desperate struggles.","pos":""}],"AGONOTHETE":[{"def":"An officer who presided over the great public games in Greece.","pos":""}],"AGONOTHETIC":[{"def":"Pertaining to the office of an agonothete.","pos":""}],"AGONY":[{"def":"Violent contest or striving.","pos":""},{"def":"Pain so extreme as to cause writhing or contortions of the body, similar to those made in the athletic contests in Greece; and hence, extreme pain of mind or body; anguish; paroxysm of grief; specifically, the sufferings of Christ in the garden of Gethsemane.","pos":""}],"AGOOD":[{"def":"In earnest; heartily.","pos":""}],"AGORA":[{"def":"An assembly; hence, the place of assembly, especially the market place, in an ancient Greek city.","pos":""}],"AGOUARA":[{"def":"The crab-eating raccoon (Procyon cancrivorus), found in the tropical parts of America.","pos":""}],"AGOUTA":[{"def":"A small insectivorous mammal (Solenodon paradoxus), allied to the moles, found only in Hayti.","pos":""},{"def":"A rodent of the genus Dasyprocta, about the size of a rabbit, peculiar to South America and the West Indies.","pos":""}]}