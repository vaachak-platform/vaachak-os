{"PIA MATER":[{"def":"The delicate and highly vascular membrane immediately investing the brain and spinal cord.","pos":""}],"PIACLE":[{"def":"A heinous offense which requires expiation.","pos":""}],"PIACULAR":[{"def":"Expiatory; atoning.","pos":""},{"def":"Requiring expiation; criminal; atrociously bad.","pos":""}],"PIACULARITY":[{"def":"The quality or state of being piacular; criminality; wickedness.","pos":""}],"PIACULOUS":[{"def":"Same as Piacular.","pos":""}],"PIAL":[{"def":"Pertaining to the pia mater.","pos":""}],"PIANETTE":[{"def":"A small piano; a pianino.","pos":""}],"PIANINO":[{"def":"A pianette, or small piano.","pos":""}],"PIANISSIMO":[{"def":"Very soft; -- a direction to execute a passage as softly as possible.","pos":""}],"PIANIST":[{"def":"A performer, esp.","pos":""}],"PIANO":[{"def":"Soft; -- a direction to the performer to execute a certain passage softly, and with diminished volume of tone.","pos":""},{"def":"A well-known musical instrument somewhat resembling the harpsichord, and consisting of a sreies of wires of graduated length, thickness, and tension, struck by hammers moved by keys.","pos":""}],"PIANOGRAPH":[{"def":"A form of melodiograph applied to a piano.","pos":""}],"PIAPEC":[{"def":"A West African pie (Ptilostomus Senegalensis).","pos":""}],"PIARIST":[{"def":"One of a religious order who are the regular clerks of the Scuole Pie (religious schools), an institute of secondary education, founded at Rome in the last years of the 16th century.","pos":""}],"PIASSAVA":[{"def":"A fibrous product of two Brazilian palm trees (Attalea funifera and Leopoldinia Piassaba), -- used in making brooms, and for other purposes.","pos":""}],"PIASTER":[{"def":"A silver coin of Spain and various other countries.","pos":""}],"PIATION":[{"def":"The act of making atonement; expiation.","pos":""}],"PIAZZA":[{"def":"An open square in a European town, especially an Italian town; hence (Arch.","pos":""}]}