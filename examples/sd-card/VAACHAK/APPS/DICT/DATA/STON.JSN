{"STOND":[{"def":"Stop; halt; hindrance.","pos":""},{"def":"A stand; a post; a station.","pos":""}],"STONE":[{"def":"A calculous concretion, especially one in the kidneys or bladder; the disease arising from a calculus.","pos":""},{"def":"The hard endocarp of drupes; as, the stone of a cherry or peach.","pos":""}],"STONE-BLIND":[{"def":"As blind as a stone; completely blind.","pos":""}],"STONE-COLD":[{"def":"Cold as a stone.","pos":""}],"STONE-DEAD":[{"def":"As dead as a stone.","pos":""}],"STONE-DEAF":[{"def":"As deaf as a stone; completely deaf.","pos":""}],"STONE-HEARTED":[{"def":"Hard-hearted; cruel; pitiless; unfeeling.","pos":""}],"STONE-STILL":[{"def":"As still as a stone.","pos":""}],"STONEBIRD":[{"def":"The yellowlegs; -- called also stone snipe.","pos":""}],"STONEBOW":[{"def":"A kind of crossbow formerly used for shooting stones.","pos":""}],"STONEBRASH":[{"def":"A subsoil made up of small stones or finely-broken rock; brash.","pos":""}],"STONEBREARER":[{"def":"A machine for crushing or hammering stone.","pos":""}],"STONECHAT":[{"def":"Note: The name is sometimes applied to various species of Saxicola, Pratincola, and allied genera; as, the pied stonechat of India (Saxicola picata).","pos":""}],"STONECRAY":[{"def":"A distemper in hawks.","pos":""}],"STONECROP":[{"def":"Any low succulent plant of the genus Sedum, esp.","pos":""}],"STONECUTTER":[{"def":"One whose occupation is to cut stone; also, a machine for dressing stone.","pos":""}],"STONECUTTING":[{"def":"Hewing or dressing stone.","pos":""}],"STONEHATCH":[{"def":"The ring plover, or dotterel.","pos":""}],"STONEHENGE":[{"def":"An assemblage of upright stones with others placed horizontally on their tops, on Salisbury Plain, England, -- generally supposed to be the remains of an ancient Druidical temple.","pos":""}],"STONER":[{"def":"One who stones; one who makes an assault with stones.","pos":""},{"def":"One who walls with stones.","pos":""}],"STONEROOT":[{"def":"A North American plant (Collinsonia Canadensis) having a very hard root; horse balm.","pos":""}],"STONESMICKLE":[{"def":"The stonechat; -- called also stonesmitch.","pos":""}],"STONEWARE":[{"def":"A species of coarse potter's ware, glazed and baked.","pos":""}],"STONEWEED":[{"def":"Any plant of the genus Lithospermum, herbs having a fruit composed of four stony nutlets.","pos":""}],"STONEWORK":[{"def":"Work or wall consisting of stone; mason's work of stone.","pos":""}],"STONEWORT":[{"def":"Any plant of the genus Chara; -- so called because they are often incrusted with carbonate of lime.","pos":""}],"STONILY":[{"def":"In a stony manner.","pos":""}],"STONINESS":[{"def":"The quality or state of being stony.","pos":""}],"STONY":[{"def":"Of or pertaining to stone, consisting of, or abounding in, stone or stones; resembling stone; hard; as, a stony tower; a stony cave; stony ground; a stony crust.","pos":""},{"def":"Converting into stone; petrifying; petrific.","pos":""}]}