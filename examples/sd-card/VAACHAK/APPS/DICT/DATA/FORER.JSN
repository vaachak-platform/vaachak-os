{"FORERAN":[{"def":"Fore*ran\", Defn: imp.","pos":""}],"FORERANK":[{"def":"The first rank; the front.","pos":""}],"FOREREACH":[{"def":"To advance or gain upon; -- said of a vessel that gains upon another when sailing closehauled.","pos":""}],"FOREREAD":[{"def":"To tell beforehand; to signify by tokens; to predestine.","pos":""}],"FORERECITED":[{"def":"Named or recited before.","pos":""}],"FOREREMEMBERED":[{"def":"Called to mind previously.","pos":""}],"FORERIGHT":[{"def":"Ready; directly forward; going before.","pos":""}],"FORERUN":[{"def":"To turn before; to precede; to be in advance of (something following).","pos":""},{"def":"To come before as an earnest of something to follow; to introduce as a harbinger; to announce.","pos":""}],"FORERUNNER":[{"def":"A piece of rag terminating the log line.","pos":""}]}