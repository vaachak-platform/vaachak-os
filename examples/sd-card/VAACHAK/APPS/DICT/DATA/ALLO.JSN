{"ALLOCATE":[{"def":"To distribute or assign; to allot.","pos":""}],"ALLOCATION":[{"def":"The act of putting one thing to another; a placing; disposition; arrangement.","pos":""},{"def":"An allotment or apportionment; as, an allocation of shares in a company.","pos":""}],"ALLOCHROIC":[{"def":"Changeable in color.","pos":""}],"ALLOCUTION":[{"def":"The act or manner of speaking to, or of addressing in words.","pos":""},{"def":"An address; a hortatory or authoritative address as of a pope to his clergy.","pos":""}],"ALLODIAL":[{"def":"Pertaining to allodium; freehold; free of rent or service; held independent of a lord paramount; -- opposed to feudal; as, allodial lands; allodial system.","pos":""}],"ALLODIALISM":[{"def":"The allodial system.","pos":""}],"ALLODIALIST":[{"def":"One who holds allodial land.","pos":""}],"ALLODIALLY":[{"def":"By allodial tenure.","pos":""}],"ALLODIARY":[{"def":"One who holds an allodium.","pos":""}],"ALLODIUM":[{"def":"Freehold estate; land which is the absolute property of the owner; real estate held in absolute independence, without being subject to any rent, service, or acknowledgment to a superior.","pos":""}],"ALLOGAMOUS":[{"def":"Characterized by allogamy.","pos":""}],"ALLOGAMY":[{"def":"Fertilization of the pistil of a plant by pollen from another of the same species; cross-fertilization.","pos":""}],"ALLOGENEOUS":[{"def":"Different in nature or kind.","pos":""}],"ALLOGRAPH":[{"def":"A writing or signature made by some person other than any of the parties thereto; -- opposed to autograph.","pos":""}],"ALLOMERISM":[{"def":"Variability in chemical constitution without variation in crystalline form.","pos":""}],"ALLOMEROUS":[{"def":"Characterized by allomerism.","pos":""}],"ALLOMORPHIC":[{"def":"Of or pertaining to allomorphism.","pos":""}],"ALLOMORPHISM":[{"def":"The property which constitutes an allomorph; the change involved in becoming an allomorph.","pos":""}],"ALLONGE":[{"def":"A thrust or pass; a lunge.","pos":""}],"ALLONYM":[{"def":"The name of another person assumed by the author of a work.","pos":""},{"def":"A work published under the name of some one other than the author.","pos":""}],"ALLONYMOUS":[{"def":"Published under the name of some one other than the author.","pos":""}],"ALLOO":[{"def":"To incite dogs by a call; to halloo.","pos":""}],"ALLOPATHIC":[{"def":"Of or pertaining to allopathy.","pos":""}],"ALLOPATHICALLY":[{"def":"In a manner conformable to allopathy; by allopathic methods.","pos":""}],"ALLOPATHIST":[{"def":"One who practices allopathy; one who professes allopathy.","pos":""}],"ALLOPATHY":[{"def":"That system of medical practice which aims to combat disease by the use of remedies which produce effects different from those produced by the special disease treated; -- a term invented by Hahnemann to designate the ordinary practice, as opposed to homeopathy.","pos":""},{"def":"Pertaining to a race or a language neither Aryan nor Semitic.","pos":""}],"ALLOQUY":[{"def":"A speaking to another; an address.","pos":""}],"ALLOT":[{"def":"To distribute by lot.","pos":""},{"def":"To distribute, or parcel out in parts or portions; or to distribute to each individual concerned; to assign as a share or lot; to set apart as one's share; to bestow on; to grant; to appoint; as, let every man be contented with that which Providence allots him.","pos":""}],"ALLOTHEISM":[{"def":"The worship of strange gods.","pos":""}],"ALLOTMENT":[{"def":"The allowance of a specific amount of scrip or of a particular thing to a particular person.","pos":""}],"ALLOTRIOPHAGY":[{"def":"A depraved appetite; a desire for improper food.","pos":""}],"ALLOTROPHIC":[{"def":"Of or pertaining to allotropism.","pos":""}],"ALLOTROPICITY":[{"def":"Allotropic property or nature.","pos":""},{"def":"The property of existing in two or more conditions which are distinct in their physical or chemical relations.","pos":""}],"ALLOTROPIZE":[{"def":"To change in physical properties but not in substance.","pos":""}],"ALLOTTABLE":[{"def":"Capable of being allotted.","pos":""}],"ALLOTTEE":[{"def":"One to whom anything is allotted; one to whom an allotment is made.","pos":""}],"ALLOW":[{"def":"To praise; to approve of; hence, to sanction.","pos":""},{"def":"To like; to be suited or pleased with.","pos":""}],"ALLOWABLE":[{"def":"Praiseworthy; laudable.","pos":""},{"def":"Proper to be, or capable of being, allowed; permissible; admissible; not forbidden; not unlawful or improper; as, a certain degree of freedom is allowable among friends.","pos":""}],"ALLOWABLENESS":[{"def":"The quality of being allowable; permissibleness; lawfulness; exemption from prohibition or impropriety.","pos":""}],"ALLOWABLY":[{"def":"In an allowable manner.","pos":""}],"ALLOWANCE":[{"def":"A customary deduction from the gross weight of goods, different in different countries, such as tare and tret.","pos":""}],"ALLOWEDLY":[{"def":"By allowance; admittedly.","pos":""}],"ALLOWER":[{"def":"An approver or abettor.","pos":""},{"def":"One who allows or permits.","pos":""}],"ALLOXAN":[{"def":"An oxidation product of uric acid.","pos":""}],"ALLOXANATE":[{"def":"A combination of alloxanic acid and a base or base or positive radical.","pos":""}],"ALLOXANIC":[{"def":"Of or pertaining to alloxan; -- applied to an acid obtained by the action of soluble alkalies on alloxan.","pos":""}],"ALLOXANTIN":[{"def":"A substance produced by acting upon uric with warm and very dilute nitric acid.","pos":""}],"ALLOY":[{"def":"Any combination or compound of metals fused together; a mixture of metals; for example, brass, which is an alloy of copper and zinc.","pos":""},{"def":"The quality, or comparative purity, of gold or silver; fineness.","pos":""}],"ALLOY STEEL":[{"def":"Any steel containing a notable quantity of some other metal alloyed with the iron, usually chromium, nickel, manganese, tungsten, or vanadium.","pos":""}],"ALLOYAGE":[{"def":"The act or art of alloying metals; also, the combination or alloy.","pos":""}]}