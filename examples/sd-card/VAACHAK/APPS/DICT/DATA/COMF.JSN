{"COMFIT":[{"def":"A dry sweetmeat; any kind of fruit, root, or seed preserved with sugar and dried; a confection.","pos":""}],"COMFORT":[{"def":"To make strong; to invigorate; to fortify; to corroborate.","pos":""},{"def":"To assist or help; to aid.","pos":""}],"COMFORTABLE":[{"def":"Strong; vigorous; valiant.","pos":""},{"def":"Serviceable; helpful.","pos":""}],"COMFORTABLENESS":[{"def":"State of being comfortable or comforting manner.","pos":""}],"COMFORTABLY":[{"def":"In a comfortable or comforting manner.","pos":""}],"COMFORTER":[{"def":"The Holy Spirit, -- reffering to his office of comforting believers.","pos":""}],"COMFORTLESS":[{"def":"Without comfort or comforts; in want or distress; cheerless.","pos":""}],"COMFORTMENT":[{"def":"Act or process of administering comfort.","pos":""}],"COMFORTRESS":[{"def":"A woman who comforts.","pos":""}],"COMFREY":[{"def":"A rough, hairy, perennial plant of several species, of the genus Symphytum.","pos":""}]}