{"PYTHAGOREAN":[{"def":"Of or pertaining to Pythagoras (a Greek philosopher, born about 582 b.","pos":""}],"PYTHAGOREANISM":[{"def":"The doctrines of Pythagoras or the Pythagoreans.","pos":""},{"def":"See Pythagorean, a.","pos":""}],"PYTHAGORISM":[{"def":"The doctrines taught by Pythagoras.","pos":""}],"PYTHAGORIZE":[{"def":"To speculate after the manner of Pythagoras.","pos":""}],"PYTHIAD":[{"def":"The period intervening between one celebration of the Pythian games and the next.","pos":""}],"PYTHIAN":[{"def":"Of or pertaining to Delphi, to the temple of Apollo, or to the priestess of Apollo, who delivered oracles at Delphi.","pos":""}],"PYTHOCENIC":[{"def":"Producing decomposition, as diseases which are supposed to be accompanied or caused by decomposition.","pos":""}],"PYTHON":[{"def":"Any species of very large snakes of the genus Python, and allied genera, of the family Pythonidæ.","pos":""}],"PYTHONESS":[{"def":"The priestess who gave oracular answers at Delphi in Greece.","pos":""}],"PYTHONIC":[{"def":"Prophetic; oracular; pretending to foretell events.","pos":""}],"PYTHONISM":[{"def":"The art of predicting events after the manner of the priestess of Apollo at Delphi; equivocal prophesying.","pos":""}],"PYTHONIST":[{"def":"A conjurer; a diviner.","pos":""}],"PYTHONOMORPHA":[{"def":"Same as Mosasauria.","pos":""}]}