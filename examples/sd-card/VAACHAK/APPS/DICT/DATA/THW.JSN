{"THWACK":[{"def":"To strike with something flat or heavy; to bang, or thrash: to thump.","pos":""},{"def":"To fill to overflow.","pos":""}],"THWAITE":[{"def":"Forest land cleared, and converted to tillage; an assart.","pos":""}],"THWART":[{"def":"Situated or placed across something else; transverse; oblique.","pos":""}],"THWARTER":[{"def":"A disease in sheep, indicated by shaking, trembling, or convulsive motions.","pos":""}],"THWARTINGLY":[{"def":"In a thwarting or obstructing manner; so as to thwart.","pos":""}],"THWARTLY":[{"def":"Transversely; obliquely.","pos":""}],"THWARTNESS":[{"def":"The quality or state of being thwart; obliquity; perverseness.","pos":""}],"THWITE":[{"def":"To cut or clip with a knife; to whittle.","pos":""}],"THWITTLE":[{"def":"To cut or whittle.","pos":""}]}