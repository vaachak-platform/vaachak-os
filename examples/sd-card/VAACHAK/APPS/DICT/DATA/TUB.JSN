{"TUB":[{"def":"An open wooden vessel formed with staves, bottom, and hoops; a kind of short cask, half barrel, or firkin, usually with but one head, -- used for various purposes.","pos":""},{"def":"The amount which a tub contains, as a measure of quantity; as, a tub of butter; a tub of camphor, which is about 1 cwt.","pos":""}],"TUBAL":[{"def":"Of or pertaining to a tube; specifically, of or pertaining to one of the Fallopian tubes; as, tubal pregnancy.","pos":""}],"TUBBING":[{"def":"The forming of a tub; also, collectively, materials for tubs.","pos":""},{"def":"A lining of timber or metal around the shaft of a mine; especially, a series of cast-iron cylinders bolted together, used to enable those who sink a shaft to penetrate quicksand, water, etc.","pos":""}],"TUBBY":[{"def":"Resembling a tub; specifically sounding dull and without resonance, like a tub; wanting elasticity or freedom of sound; as, a tubby violin.","pos":""}],"TUBE":[{"def":"The narrow, hollow part of a gamopetalous corolla.","pos":""},{"def":"A priming tube, or friction primer.","pos":""}],"TUBE-SHELL":[{"def":"Any bivalve mollusk which secretes a shelly tube around its siphon, as the watering-shell.","pos":""}],"TUBEFORM":[{"def":"In the form of a tube; tubular; tubiform.","pos":""}],"TUBER":[{"def":"A tuberosity; a tubercle.","pos":"noun"}],"TUBERCLE":[{"def":"A small mass or aggregation of morbid matter; especially, the deposit which accompanies scrofula or phthisis.","pos":""}],"TUBERCLED":[{"def":"Having tubercles; affected with, tubercles; tuberculate; as, a tubercled lung or stalk.","pos":""}],"TUBERCULAR":[{"def":"Characterized by the development of tubercles; as, tubercular diathesis.","pos":""}],"TUBERCULARIZE":[{"def":"To infect with tuberculosis.","pos":""},{"def":"Tubercled; tubercular.","pos":""}],"TUBERCULIN":[{"def":"A fluid containing the products formed by the growth of the tubercle bacillus in a suitable culture medium.","pos":""}],"TUBERCULIN TEST":[{"def":"The hypodermic injection of tuberculin, which has little or no effect with healthy cattle, but causes a marked rise in temperature in tuberculous animals.","pos":""}],"TUBERCULIZATION":[{"def":"The development of tubercles; the condition of one who is affected with tubercles.","pos":""}],"TUBERCULOCIDIN":[{"def":"A special substance contained in tuberculin, supposed to be the active agent of the latter freed from various impurities.","pos":""}],"TUBERCULOID":[{"def":"Resembling a tubercle.","pos":""},{"def":"Having tubercles; affected with, or characterized by, tubercles; tubercular.","pos":""}],"TUBERCULOSED":[{"def":"Affected with tuberculosis.","pos":""}],"TUBERCULOSIS":[{"def":"A constitutional disease characterized by the production of tubercles in the internal organs, and especially in the lungs, where it constitutes the most common variety of pulmonary consumption.","pos":""}],"TUBERIFEROUS":[{"def":"Producing or bearing tubers.","pos":""}],"TUBEROSE":[{"def":"A plant (Polianthes tuberosa) with a tuberous root and a liliaceous flower.","pos":""}],"TUBEROSITY":[{"def":"The state of being tuberous.","pos":""},{"def":"An obtuse or knoblike prominence; a protuberance.","pos":""}],"TUBEROUS":[{"def":"Consisting of, or bearing, tubers; resembling a tuber.","pos":""}],"TUBEWORM":[{"def":"Any annelid which constructs a tube; one of the Tubicolæ.","pos":""}],"TUBFISH":[{"def":"The sapphirine gurnard (Trigla hirundo).","pos":""}],"TUBFUL":[{"def":"As much as a tub will hold; enough to fill a tub.","pos":""}],"TUBICINATE":[{"def":"To blow a trumpet.","pos":""}],"TUBICOLAE":[{"def":"A division of annelids including those which construct, and habitually live in, tubes.","pos":""}],"TUBICOLE":[{"def":"One of the Tubicolæ.","pos":""}],"TUBICOLOUS":[{"def":"Inhabiting a tube; as, tubicolous worms.","pos":""}],"TUBICORN":[{"def":"Any ruminant having horns composed of a bony axis covered with a horny sheath; a hollow-horned ruminant.","pos":""}],"TUBICORNOUS":[{"def":"Having hollow horns.","pos":""}],"TUBIFORM":[{"def":"Having the form of a tube; tubeform.","pos":""}],"TUBINARES":[{"def":"A tribe of sea birds comprising the petrels, shearwaters, albatrosses, hagdons, and allied birds having tubular horny nostrils.","pos":""}],"TUBING":[{"def":"The act of making tubes.","pos":""},{"def":"A series of tubes; tubes, collectively; a length or piece of a tube; material for tubes; as, leather tubing.","pos":""}],"TUBIPORA":[{"def":"A genus of halcyonoids in which the skeleton, or coral (called organ-pipe coral), consists of a mass of parallel cylindrical tubes united at intervals by transverse plates.","pos":""}],"TUBIPORE":[{"def":"Any species of the genus Tubipora.","pos":""}],"TUBIPORITE":[{"def":"Any fossil coral of the genus Syringopora consisting of a cluster of upright tubes united together by small transverse tubules.","pos":""}],"TUBIVALVE":[{"def":"A shell or tube formed by an annelid, as a serpula.","pos":""}],"TUBMAN":[{"def":"One of the two most experienced barristers in the Court of Exchequer.","pos":""}],"TUBULAR":[{"def":"Having the form of a tube, or pipe; consisting of a pipe; fistular; as, a tubular snout; a tubular calyx.","pos":""}],"TUBULARIA":[{"def":"A genus of hydroids having large, naked, flowerlike hydranths at the summits of long, slender, usually simple, stems.","pos":""}],"TUBULARIAN":[{"def":"Any hydroid belonging to the suborder Tubularida.","pos":""}],"TUBULARIDA":[{"def":"An extensive division of Hydroidea; the tubularians; -- called also Athecata, Gymnoblastea, and Tubulariæ.","pos":""}],"TUBULATE":[{"def":"Tubular; tubulated; tubulous.","pos":""}],"TUBULATED":[{"def":"Made in the form of a small tube; provided with a tube, or elongated opening.","pos":""}],"TUBULATION":[{"def":"The act of shaping or making a tube, or of providing with a tube; also, a tube or tubulure; as, the tubulation of a retort.","pos":""}],"TUBULE":[{"def":"A minute tube lined with glandular epithelium; as, the uriniferous tubules of the kidney.","pos":""}],"TUBULIBRANCHIAN":[{"def":"One of the Tubulibranchiata.","pos":""}],"TUBULIBRANCHIATA":[{"def":"A group of gastropod mollusks having a tubular shell.","pos":""}],"TUBULICOLE":[{"def":"Any hydroid which has tubular chitinous stems.","pos":""}],"TUBULIDENTATE":[{"def":"Having teeth traversed by canals; -- said of certain edentates.","pos":""}],"TUBULIFORM":[{"def":"Having the form of a small tube.","pos":""}],"TUBULIPORE":[{"def":"Any one of numerous species of Bryozoa belonging to Tubulipora and allied genera, having tubular calcareous calicles.","pos":""}],"TUBULURE":[{"def":"A short tubular opening at the top of a retort, or at the top or side of a bottle; a tubulation.","pos":""}]}