{"PERIDERM":[{"def":"The outer layer of bark.","pos":""},{"def":"The hard outer covering of hydroids and other marine animals; the perisarc.","pos":""}],"PERIDIASTOLE":[{"def":"The almost inappreciable time which elapses between the systole and the diastole of the heart.","pos":""}],"PERIDIUM":[{"def":"The envelope or coat of certain fungi, such as the puffballs and earthstars.","pos":""}],"PERIDOTITE":[{"def":"An eruptive rock characterized by the presence of chrysolite (peridot).","pos":""}],"PERIDROME":[{"def":"The space between the columns and the wall of the cella, in a Greek or a Roman temple.","pos":""}]}