{"ROT":[{"def":"To undergo a process common to organic substances by which they lose the cohesion of their parts and pass through certain chemical changes, giving off usually in some stages of the process more or less offensive odors; to become decomposed by a natural process; to putrefy; to decay.","pos":""},{"def":"Figuratively: To perish slowly; to decay; to die; to become corrupt.","pos":""}],"ROTA":[{"def":"A short-lived political club established in 1659 by J.","pos":""}],"ROTAL":[{"def":"Relating to wheels or to rotary motion; rotary.","pos":""}],"ROTALITE":[{"def":"Any fossil foraminifer of the genus Rotalia, abundant in the chalk formation.","pos":""}],"ROTARY":[{"def":"Turning, as a wheel on its axis; pertaining to, or resembling, the motion of a wheel on its axis; rotatory; as, rotary motion.","pos":""}],"ROTASCOPE":[{"def":"Same as Gyroscope, 1.","pos":""}],"ROTATE":[{"def":"Having the parts spreading out like a wheel; wheel-shaped; as, a rotate spicule or scale; a rotate corolla, i.","pos":""}],"ROTATED":[{"def":"Turned round, as a wheel; also, wheel-shaped; rotate.","pos":""}],"ROTATION":[{"def":"The act of turning, as a wheel or a solid body on its axis, as distinguished from the progressive motion of a revolving round another body or a distant point; thus, the daily turning of the earth on its axis is a rotation; its annual motion round the sun is a revolution.","pos":""},{"def":"Any return or succesion in a series.","pos":""}],"ROTATIVE":[{"def":"turning, as a wheel; rotary; rotational.","pos":""}],"ROTATOR":[{"def":"that which gives a rotary or rolling motion, as a muscle which partially rotates or turns some part on its axis.","pos":""},{"def":"A revolving reverberatory furnace.","pos":""}],"ROTATORIA":[{"def":"Same as Rotifera.","pos":""}],"ROTATORY":[{"def":"Producing rotation of the plane of polarization; as, the rotatory power of bodies on light.","pos":""}],"ROTCHE":[{"def":"A very small arctic sea bird (Mergulus alle, or Alle alle) common on both coasts of the Atlantic in winter; -- called also little auk, dovekie, rotch, rotchie, and sea dove.","pos":""}],"ROTCHET":[{"def":"The European red gurnard (Trigla pini).","pos":""}],"ROTE":[{"def":"A kind of guitar, the notes of which were produced by a small wheel or wheel-like arrangement; an instrument similar to the hurdy- gurdy.","pos":""}],"ROTELLA":[{"def":"Any one of numerous species of small, polished, brightcolored gastropods of the genus Rotella, native of tropical seas.","pos":""}],"ROTGUT":[{"def":"Any bad spirituous liquor, especially when adulterated so as to be very deleterious.","pos":""}],"ROTIFER":[{"def":"One of the Rotifera.","pos":""}],"ROTIFERA":[{"def":"An order of minute worms which usually have one or two groups of vibrating cilia on the head, which, when in motion, often give an appearance of rapidly revolving wheels.","pos":""}],"ROTIFORM":[{"def":"Wheel-shaped; as, rotiform appendages.","pos":""}],"ROTOGRAPH":[{"def":"A photograph printed by a process in which a strip or roll of sensitized paper is automatically fed over the negative so that a series of prints are made, and are then developed, fixed, cut apart, and washed at a very rapid rate.","pos":""}],"ROTOR":[{"def":"The rotating part of a generator or motor.","pos":""}],"ROTTEN":[{"def":"Having rotted; putrid; decayed; as, a rotten apple; rotten meat.","pos":""}],"ROTULA":[{"def":"The patella, or kneepan.","pos":""}],"ROTULAR":[{"def":"Of or pertaining to the rotula, or kneepan.","pos":""}],"ROTUND":[{"def":"orbicular, or nearly so.","pos":""}],"ROTUNDA":[{"def":"A round building; especially, one that is round both on the outside and inside, like the Pantheon at Rome.","pos":""}],"ROTUNDATE":[{"def":"Rounded; especially, rounded at the end or ends, or at the corners.","pos":""}],"ROTUNDIFOLIOUS":[{"def":"Having round leaves.","pos":""}],"ROTUNDITY":[{"def":"The state or quality of being rotu Smite flat the thick rotundity o'the world! Shak.","pos":""},{"def":"Hence, completeness; entirety; roundness.","pos":""}],"ROTUNDNESS":[{"def":"Roundness; rotundity.","pos":""}],"ROTURE":[{"def":"The condition of being a roturier.","pos":""}],"ROTURIER":[{"def":"A person who is not of noble birth; specif.","pos":""}],"ROTY":[{"def":"Well bet is rotten apple out of hoard, Than that it roty all the remenant.","pos":""}]}