{"NOB":[{"def":"A person in a superior position in life; a nobleman.","pos":""}],"NOBBILY":[{"def":"In a nobby manner.","pos":""}],"NOBBLER":[{"def":"A dram of spirits.","pos":""}],"NOBBY":[{"def":"Stylish; modish; elegant; showy; aristocratic; fashionable.","pos":""}],"NOBEL PRIZES":[{"def":"Prizes for the encouragement of men and women who work for the interests of humanity, established by the will of A.","pos":""}],"NOBERT'S LINES":[{"def":"Fine lines ruled on glass in a series of groups of different closeness of line, and used to test the power of a microscope.","pos":""}],"NOBILI'S RINGS":[{"def":"Colored rings formed upon a metal plate by the electrolytic disposition of copper, lead peroxide, etc.","pos":""}],"NOBILIARY":[{"def":"Of or pertaining to the nobility.","pos":""}],"NOBILIFY":[{"def":"To make noble; to nobiliate.","pos":""}],"NOBILITATE":[{"def":"To make noble; to ennoble; to exalt.","pos":""}],"NOBILITATION":[{"def":"The act of making noble.","pos":""}],"NOBILITY":[{"def":"The quality or state of being noble; superiority of mind or of character; commanding excellence; eminence.","pos":""},{"def":"The state of being of high rank or noble birth; patrician dignity; antiquity of family; distinction by rank, station, or title, whether inherited or conferred.","pos":""}],"NOBLE":[{"def":"Possessing eminence, elevation, dignity, etc.","pos":""},{"def":"Grand; stately; magnificent; splendid; as, a noble edifice.","pos":""}],"NOBLE-MINDED":[{"def":"Having a noble mind; honorable; magnanimous.","pos":""}],"NOBLEMAN":[{"def":"One of the nobility; a noble; a peer; one who enjoys rank above a commoner, either by virtue of birth, by office, or by patent.","pos":""}],"NOBLENESS":[{"def":"The quality or state of being noble; greatness; dignity; magnanimity; elevation of mind, character, or station; nobility; grandeur; stateliness.","pos":""}],"NOBLEWOMAN":[{"def":"A female of noble rank; a peeress.","pos":""}],"NOBLEY":[{"def":"The body of nobles; the nobility.","pos":""},{"def":"Noble birth; nobility; dignity.","pos":""}],"NOBLY":[{"def":"Of noble extraction; as, nobly born or descended.","pos":""},{"def":"In a noble manner; with greatness of soul; heroically; with magnanimity; as, a deed nobly done.","pos":""}],"NOBODY":[{"def":"No person; no one; not anybody.","pos":""},{"def":"Hence: A person of no influence or importance; an insignificant or contemptible person.","pos":""}]}