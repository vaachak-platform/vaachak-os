{"STEW":[{"def":"A small pond or pool where fish are kept for the table; a vivarium.","pos":""},{"def":"An artificial bed of oysters.","pos":""}],"STEWARD":[{"def":"A man employed in a large family, or on a large estate, to manage the domestic concerns, supervise other servants, collect the rents or income, keep accounts, and the like.","pos":""},{"def":"A person employed in a hotel, or a club, or on board a ship, to provide for the table, superintend the culinary affairs, etc.","pos":""}],"STEWARDESS":[{"def":"A female steward; specifically, a woman employed in passenger vessels to attend to the wants of female passengers.","pos":""}],"STEWARDLY":[{"def":"In a manner, or with the care, of a steward.","pos":""}],"STEWARDSHIP":[{"def":"The office of a steward.","pos":""}],"STEWARTRY":[{"def":"An overseer or superintendent.","pos":""},{"def":"The office of a steward; stewardship.","pos":""}],"STEWISH":[{"def":"Suiting a stew, or brothel.","pos":""}],"STEWPAN":[{"def":"A pan used for stewing.","pos":""}],"STEWPOT":[{"def":"A pot used for stewing.","pos":""}]}