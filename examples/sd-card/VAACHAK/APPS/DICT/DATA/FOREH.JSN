{"FOREHAND":[{"def":"All that part of a horse which is before the rider.","pos":""},{"def":"The chief or most important part.","pos":""}],"FOREHANDED":[{"def":"Early; timely; seasonable.","pos":""},{"def":"Beforehand with one's needs, or having resources in advance of one's necessities; in easy circumstances; as, a forehanded farmer.","pos":""}],"FOREHEAD":[{"def":"The front of that part of the head which incloses the brain; that part of the face above the eyes; the brow.","pos":""},{"def":"The aspect or countenance; assurance.","pos":""}],"FOREHEAR":[{"def":"To hear beforehand.","pos":""}],"FOREHEARTH":[{"def":"The forward extension of the hearth of a blast furnace under the tymp.","pos":""}],"FOREHEW":[{"def":"To hew or cut in front.","pos":""}],"FOREHOLD":[{"def":"The forward part of the hold of a ship.","pos":""}],"FOREHOLDING":[{"def":"Ominous foreboding; superstitious prognostication.","pos":""}],"FOREHOOK":[{"def":"A piece of timber placed across the stem, to unite the bows and strengthen the fore part of the ship; a breast hook.","pos":""}]}