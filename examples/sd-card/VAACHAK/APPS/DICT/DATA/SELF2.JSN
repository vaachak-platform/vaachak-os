{"SELF-LOVE":[{"def":"The love of one's self; desire of personal happiness; tendency to seek one's own benefit or advantage.","pos":""}],"SELF-LUMINOUS":[{"def":"Possessing in itself the property of emitting light.","pos":""}],"SELF-MADE":[{"def":"Made by one's self.","pos":""}],"SELF-METTLE":[{"def":"Inborn mettle or courage; one's own temper.","pos":""}],"SELF-MOTION":[{"def":"Motion given by inherent power, without external impulse; spontaneus or voluntary motion.","pos":""}],"SELF-MOVED":[{"def":"Moved by inherent power.","pos":""}],"SELF-MOVING":[{"def":"Moving by inherent power, without the aid of external impulse.","pos":""}],"SELF-NEGLECTING":[{"def":"A neglecting of one's self, or of one's own interests.","pos":""}],"SELF-OPINION":[{"def":"Opinion, especially high opinion, of one's self; an overweening estimate of one's self or of one's own opinion.","pos":""}],"SELF-OPINIONED":[{"def":"Having a high opinion of one's self; opinionated; conceited.","pos":""}],"SELF-ORIGINATING":[{"def":"Beginning wwith, or springing from, one's self.","pos":""}],"SELF-PARTIALITY":[{"def":"That partiality to himself by which a man overrates his own worth when compared with others.","pos":""}],"SELF-PERPLEXED":[{"def":"Perplexed by doubts originating in one's own mind.","pos":""}],"SELF-POSITED":[{"def":"Disposed or arranged by an action originating in one's self or in itself.","pos":""}],"SELF-POSITING":[{"def":"The act of disposing or arranging one's self or itself.","pos":""}],"SELF-POSSESSED":[{"def":"Composed or tranquill in mind, manner, etc.","pos":""}],"SELF-POSSESSION":[{"def":"The possession of one's powers; calmness; self-command; presence of mind; composure.","pos":""}],"SELF-PRAISE":[{"def":"Praise of one's self.","pos":""}],"SELF-PRESERVATION":[{"def":"The preservation of one's self from destruction or injury.","pos":""}],"SELF-PROPAGATING":[{"def":"Propagating by one's self or by itself.","pos":""}],"SELF-REGISTERING":[{"def":"Registering itself; -- said of any instrument so contrived as to record its own indications of phenomena, whether continuously or at stated times, as at the maxima and minima of variations; as, a self-registering anemometer or barometer.","pos":""}],"SELF-REGULATED":[{"def":"Regulated by one's self or by itself.","pos":""}],"SELF-REGULATIVE":[{"def":"Tending or serving to regulate one's self or itself.","pos":""}],"SELF-RELIANCE":[{"def":"Reliance on one's own powers or judgment; self-trust.","pos":""}],"SELF-RELIANT":[{"def":"Reliant upon one's self; trusting to one's own powers or judgment.","pos":""}],"SELF-RENUNCIATION":[{"def":"The act of renouncing, or setting aside, one's own wishes, claims, etc.","pos":""}],"SELF-REPELLENCY":[{"def":"The quality or state of being self-repelling.","pos":""}],"SELF-REPELLING":[{"def":"Made up of parts, as molecules or atoms, which mutually repel each other; as, gases are self-repelling.","pos":""}],"SELF-REPETITION":[{"def":"Repetition of one's self or of one's acts; the saying or doing what one has already said or done.","pos":""}],"SELF-REPROACH":[{"def":"The act of reproaching one's self; censure by one's own conscience.","pos":""}],"SELF-REPROACHED":[{"def":"Reproached by one's own conscience or judgment.","pos":""}],"SELF-REPROACHING":[{"def":"Reproaching one's self.","pos":""}],"SELF-REPROOF":[{"def":"The act of reproving one's self; censure of one's conduct by one's own judgment.","pos":""}],"SELF-REPROVED":[{"def":"Reproved by one's own conscience or one's own sense of guilt.","pos":""}],"SELF-REPROVING":[{"def":"Reproving one's self; reproving by consciousness of guilt.","pos":""}],"SELF-REPROVINGLY":[{"def":"In a self-reproving way.","pos":""}],"SELF-REPUGNANT":[{"def":"Self-contradictory; inconsistent.","pos":""}],"SELF-RESPECT":[{"def":"Respect for one's self; regard for one's character; laudable self-esteem.","pos":""}],"SELF-RESTRAINED":[{"def":"Restrained by one's self or itself; restrained by one's own power or will.","pos":""}],"SELF-RESTRAINT":[{"def":"Restraint over one's self; self-control; self-command.","pos":""}],"SELF-REVERENCE":[{"def":"A reverent respect for one's self.","pos":""}],"SELF-RIGHTEOUS":[{"def":"Righteous in one's own esteem; pharisaic.","pos":""}],"SELF-RIGHTEOUSNESS":[{"def":"The quality or state of being self-righteous; pharisaism.","pos":""}],"SELF-SACRIFICE":[{"def":"The act of sacrificing one's self, or one's interest, for others; self-devotion.","pos":""}],"SELF-SACRIFICING":[{"def":"Yielding up one's own interest, ffeelings, etc; sacrificing one's self.","pos":""}],"SELF-SATISFACTION":[{"def":"The quality or state of being self-satisfied.","pos":""}],"SELF-SATISFIED":[{"def":"Satisfied with one's self or one's actions; self-complacent.","pos":""}],"SELF-SATISFYING":[{"def":"Giving satisfaction to one's self.","pos":""}],"SELF-SEEKER":[{"def":"One who seeks only his own interest, advantage, or pleasure.","pos":""}],"SELF-SEEKING":[{"def":"Seeking one's own interest or happiness; selfish.","pos":""}],"SELF-STARTER":[{"def":"A mechanism (usually one operated by electricity, compressed air, a spring, or an explosive gas), attached to an internal- combustion engine, as on an automobile, and used as a means of starting the engine without cranking it by hand.","pos":""}],"SELF-SUFFICIENCY":[{"def":"The quality or state of being self-sufficient.","pos":""}],"SELF-SUFFICIENT":[{"def":"Sufficient for one's self without external aid or coöperation.","pos":""},{"def":"Having an overweening confidence in one's own abilities or worth; hence, haughty; overbearing.","pos":""}],"SELF-SUFFICING":[{"def":"Sufficing for one's self or for itself, without needing external aid; self-sufficient.","pos":""}],"SELF-SUSPENDED":[{"def":"Suspended by one's self or by itself; balanced.","pos":""}],"SELF-SUSPICIOUS":[{"def":"Suspicious or distrustful of one's self.","pos":""}],"SELF-TAUGHT":[{"def":"Taught by one's own efforts.","pos":""}],"SELF-TORMENTOR":[{"def":"One who torments himself.","pos":""}],"SELF-TORTURE":[{"def":"The act of inflicting pain on one's self; pain inflicted on one's self.","pos":""}],"SELF-TRUST":[{"def":"Faith in one's self; self-reliance.","pos":""}],"SELF-UNED":[{"def":"One with itself; separate from others.","pos":""}],"SELF-WILL":[{"def":"One's own will, esp.","pos":""}],"SELF-WILLED":[{"def":"Governed by one's own will; not yielding to the wishes of others; obstinate.","pos":""}],"SELF-WORSHIP":[{"def":"The idolizing of one's self; immoderate self-conceit.","pos":""}],"SELF-WRONG":[{"def":"Wrong done by a person himself.","pos":""}]}