{"INWALL":[{"def":"To inclose or fortify as with a wall.","pos":""}],"INWARD":[{"def":"Being or placed within; inner; interior; -- opposed to outward.","pos":""},{"def":"Seated in the mind, heart, spirit, or soul.","pos":""}],"INWARDLY":[{"def":"In the inner parts; internally.","pos":""},{"def":"Toward the center; inward; as, to curve inwardly.","pos":""}],"INWARDNESS":[{"def":"Internal or true state; essential nature; as, the inwardness of conduct.","pos":""},{"def":"Intimacy; familiarity.","pos":""}],"INWEAVE":[{"def":"To weave in or together; to intermix or intertwine by weaving; to interlace.","pos":""}],"INWIT":[{"def":"Inward sense; mind; understanding; conscience.","pos":""}],"INWITH":[{"def":"This purse hath she inwith her bosom hid.","pos":""}],"INWORK":[{"def":"To work in or within.","pos":""}],"INWORN":[{"def":"Worn, wrought, or stamped in.","pos":""}],"INWRAP":[{"def":"To cover by wrapping; to involve; to infold; as, to inwrap in a cloak, in smoke, etc.","pos":""},{"def":"To involve, as in difficulty or perplexity; to perplex.","pos":""}],"INWREATHE":[{"def":"To surround or encompass as with a wreath.","pos":""}],"INWROUGHT":[{"def":"Wrought or worked in or among other things; worked into any fabric so as to from a part of its texture; wrought or adorned, as with figures.","pos":""}]}