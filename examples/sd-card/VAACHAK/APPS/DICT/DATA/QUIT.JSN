{"QUIT":[{"def":"Any one of numerous species of small passerine birds native of tropical America.","pos":""}],"QUITCH":[{"def":"Same as Quitch grass.","pos":""}],"QUITCH GRASS":[{"def":"A perennial grass (Agropyrum repens) having long running rootstalks, by which it spreads rapidly and pertinaciously, and so becomes a troublesome weed.","pos":""}],"QUITCLAIM":[{"def":"To release or relinquish a claim to; to release a claim to by deed, without covenants of warranty against adverse and paramount titles.","pos":""}],"QUITE":[{"def":"Completely; wholly; entirely; totally; perfectly; as, the work is not quite done; the object is quite accomplished; to be quite mistaken.","pos":""},{"def":"To a great extent or degree; very; very much; considerably.","pos":""}],"QUITRENT":[{"def":"A rent reserved in grants of land, by the payment of which the tenant is quit from other service.","pos":""}],"QUITS":[{"def":"See the Note under Quit, a.","pos":""}],"QUITTABLE":[{"def":"Capable of being quitted.","pos":""}],"QUITTAL":[{"def":"Return; requital; quittance.","pos":""}],"QUITTANCE":[{"def":"Discharge from a debt or an obligation; acquittance.","pos":""},{"def":"Recompense; return; repayment.","pos":""}],"QUITTOR":[{"def":"A chronic abscess, or fistula of the coronet, in a horse's foot, resulting from inflammation of the tissues investing the coffin bone.","pos":""}],"QUITTURE":[{"def":"A discharge; an issue.","pos":""}]}