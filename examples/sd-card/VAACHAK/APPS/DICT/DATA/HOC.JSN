{"HOCCO":[{"def":"The crested curassow; -- called also royal pheasant.","pos":""}],"HOCK":[{"def":"A Rhenish wine, of a light yellow color, either sparkling or still.","pos":""}],"HOCKDAY":[{"def":"A holiday commemorating the expulsion of the Danes, formerly observed on the second Tuesday after Easter; -- called also hocktide.","pos":""}],"HOCKEY":[{"def":"A game in which two parties of players, armed with sticks curved or hooked at the end, attempt to drive any small object (as a ball or a bit of wood) toward opposite goals.","pos":""},{"def":"The stick used by the players.","pos":""}],"HOCKLE":[{"def":"To hamstring; to hock; to hough.","pos":""},{"def":"To mow, as stubble.","pos":""}],"HOCUS":[{"def":"To deceive or cheat.","pos":""},{"def":"To adulterate; to drug; as, liquor is said to be hocused for the purpose of stupefying the drinker.","pos":""}]}