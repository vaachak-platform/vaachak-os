{"CACAINE":[{"def":"The essential principle of cacao; -- now called theobromine.","pos":""}],"CACAJAO":[{"def":"A South American short-tailed monkey (Pithecia (or Brachyurus) melanocephala).","pos":""}],"CACAO":[{"def":"A small evergreen tree (Theobroma Cacao) of South America and the West Indies.","pos":""},{"def":"A degenerated or poisoned condition of the blood.","pos":""}],"CACHALOT":[{"def":"The sperm whale (Physeter macrocephalus).","pos":""}],"CACHE":[{"def":"A hole in the ground, or hiding place, for concealing and preserving provisions which it is inconvenient to carry.","pos":""},{"def":"Having, or pertaining to, cachexia; as, cachectic remedies; cachectical blood.","pos":""}],"CACHEPOT":[{"def":"An ornamental casing for a flowerpot, of porcelain, metal, paper, etc.","pos":""}],"CACHET":[{"def":"A seal, as of a letter.","pos":""},{"def":"A condition of ill health and impairment of nutrition due to impoverishment of the blood, esp.","pos":""}],"CACHINNATION":[{"def":"Loud or immoderate laughter; -- often a symptom of hysterical or maniacal affections.","pos":""}],"CACHINNATORY":[{"def":"Consisting of, or accompanied by, immoderate laughter.","pos":""}],"CACHIRI":[{"def":"A fermented liquor made in Cayenne from the grated root of the manioc, and resembling perry.","pos":""}],"CACHOLONG":[{"def":"An opaque or milk-white chalcedony, a variety of quartz; also, a similar variety of opal.","pos":""}],"CACHOU":[{"def":"A silvered aromatic pill, used to correct the odor of the breath.","pos":""}],"CACHUCHA":[{"def":"An Andalusian dance in three-four time, resembing the bolero.","pos":""}],"CACHUNDE":[{"def":"A pastil or troche, composed of various aromatic and other ingredients, highly celebrated in India as an antidote, and as a stomachic and antispasmodic.","pos":""}],"CACK":[{"def":"To ease the body by stool; to go to stool.","pos":""}],"CACKEREL":[{"def":"The mendole; a small worthless Mediterranean fish considered poisonous by the ancients.","pos":""}],"CACKLE":[{"def":"To make a sharp, broken noise or cry, as a hen or goose does.","pos":""},{"def":"To laugh with a broken noise, like the cackling of a hen or a goose; to giggle.","pos":""}],"CACKLER":[{"def":"A fowl that cackles.","pos":""},{"def":"One who prattles, or tells tales; a tattler.","pos":""}],"CACKLING":[{"def":"The broken noise of a goose or a hen.","pos":""},{"def":"A vitiated state of the humors, or fluids, of the body, especially of the blood.","pos":""}],"CACODEMON":[{"def":"An evil spirit; a devil or demon.","pos":""}],"CACODOXY":[{"def":"Erroneous doctrine; heresy; heterodoxy.","pos":""}],"CACODYL":[{"def":"Alkarsin; a colorless, poisonous, arsenical liquid, As2(CH3)4, spontaneously inflammable and possessing an intensely disagreeable odor.","pos":""}],"CACODYLIC":[{"def":"Of, pertaining to, or derived from, cacodyl.","pos":""}],"CACOETHES":[{"def":"A bad quality or disposition in a disease; an incurable ulcer.","pos":""}],"CACOGASTRIC":[{"def":"Troubled with bad digestion.","pos":""}],"CACOGRAPHIC":[{"def":"Pertaining to, or characterized by, cacography; badly written or spelled.","pos":""}],"CACOGRAPHY":[{"def":"Incorrect or bad writing or spelling.","pos":""}],"CACOLET":[{"def":"A chair, litter, or other contrivance fitted to the back or pack saddle of a mule for carrying travelers in mountainous districts, or for the transportation of the sick and wounded of an army.","pos":""}],"CACOLOGY":[{"def":"Bad speaking; bad choice or use of words.","pos":""},{"def":"A North American carnivore (Bassaris astuta), about the size of a cat, related to the raccoons.","pos":""}],"CACOON":[{"def":"One of the seeds or large beans of a tropical vine (Entada scandens) used for making purses, scent bottles, etc.","pos":""}],"CACOPHONY":[{"def":"An uncouth or disagreable sound of words, owing to the concurrence of harsh letters or syllables.","pos":""},{"def":"A combination of discordant sounds.","pos":""}],"CACOSTOMIA":[{"def":"Diseased or gangrenous condition of the mouth.","pos":""}],"CACOTECHNY":[{"def":"A corruption or corrupt state of art.","pos":""},{"def":"A hydrous phosphate of iron occurring in yellow radiated tufts.","pos":""}],"CACTACEOUS":[{"def":"Belonging to, or like, the family of plants of which the prickly pear is a common example.","pos":""}],"CACTUS":[{"def":"Any plant of the order Cactacæ, as the prickly pear and the night-blooming cereus.","pos":""}],"CACUMINAL":[{"def":"Pertaining to the top of the palate; cerebral; -- applied to certain consonants; as, cacuminal (or cerebral) letters.","pos":""}],"CACUMINATE":[{"def":"To make sharp or pointed.","pos":""}]}