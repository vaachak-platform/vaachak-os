{"MITE":[{"def":"A minute arachnid, of the order Acarina, of which there are many species; as, the cheese mite, sugar mite, harvest mite, etc.","pos":""},{"def":"A small coin formerly circulated in England, rated at about a third of a farthing.","pos":""}],"MITERWORT":[{"def":"Any plant of the genus Mitella, -- slender, perennial herbs with a pod slightly resembling a bishop's miter; bishop's cap.","pos":""}],"MITHRAS":[{"def":"The sun god of the Persians.","pos":""}],"MITHRIDATE":[{"def":"An antidote against poison, or a composition in form of an electuary, supposed to serve either as a remedy or a preservative against poison; an alexipharmic; -- so called from King Mithridates, its reputed inventor.","pos":""}],"MITHRIDATIC":[{"def":"Of or pertaining to King Mithridates, or to a mithridate.","pos":""}],"MITIGABLE":[{"def":"Admitting of mitigation; that may be mitigated.","pos":""}],"MITIGANT":[{"def":"Tending to mitigate; mitigating; lentitive.","pos":""}],"MITIGATE":[{"def":"To make less severe, intense, harsh, rigorous, painful, etc.","pos":""},{"def":"To make mild and accessible; to mollify; -- applied to persons.","pos":""}],"MITIGATION":[{"def":"The act of mitigating, or the state of being mitigated; abatement or diminution of anything painful, harsh, severe, afflictive, or calamitous; as, the mitigation of pain, grief, rigor, severity, punishment, or penalty.","pos":""}],"MITIGATIVE":[{"def":"Tending to mitigate; alleviating.","pos":""}],"MITIGATOR":[{"def":"One who, or that which, mitigates.","pos":""}],"MITIGATORY":[{"def":"Tending to mitigate or alleviate; mitigative.","pos":""}],"MITING":[{"def":"A little one; -- used as a term of endearment.","pos":""}],"MITIS CASTING":[{"def":"A process, invented by P.","pos":""}],"MITIS METAL":[{"def":"The malleable iron produced by mitis casting; -- called also simply mitis.","pos":""}],"MITOME":[{"def":"The denser part of the protoplasm of a cell.","pos":""}],"MITOSIS":[{"def":"See Karyokinesis.","pos":""}],"MITOTIC":[{"def":"Of or pertaining to mitosis; karyokinetic; as, mitotic cell division; -- opposed to amitotic.","pos":""}],"MITRAILLE":[{"def":"Shot or bits of iron used sometimes in loading cannon.","pos":""}],"MITRAILLEUR":[{"def":"One who serves a mitrailleuse.","pos":""}],"MITRAILLEUSE":[{"def":"A breech-loading machine gun consisting of a number of barrels fitted together, so arranged that the barrels can be fired simultaneously, or successively, and rapidly.","pos":""}],"MITRAL":[{"def":"Pertaining to a miter; resembling a miter; as, the mitral valve between the left auricle and left ventricle of the heart.","pos":""}],"MITRIFORM":[{"def":"Having the form of a miter, or a peaked cap; as, a mitriform calyptra.","pos":""}],"MITT":[{"def":"A mitten; also, a covering for the wrist and hand and not for the fingers.","pos":""}],"MITTEN":[{"def":"A covering for the hand, worn to defend it from cold or injury.","pos":""},{"def":"A cover for the wrist and forearm.","pos":""}],"MITTENED":[{"def":"Covered with a mitten or mittens.","pos":""}],"MITTENT":[{"def":"Sending forth; emitting.","pos":""}],"MITTLER'S GREEN":[{"def":"A pigment of a green color, the chief constituent of which is oxide of chromium.","pos":""}],"MITTY":[{"def":"The stormy petrel.","pos":""}],"MITU":[{"def":"A South American curassow of the genus Mitua.","pos":""}],"MITY":[{"def":"Having, or abounding with, mites.","pos":""}]}