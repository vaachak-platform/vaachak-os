{"QUARANTINE":[{"def":"The period of forty days during which the widow had the privilege of remaining in the mansion house of which her husband died seized.","pos":""}],"QUARL":[{"def":"A medusa, or jellyfish.","pos":""}],"QUARREL":[{"def":"Any small square or quadrangular member; as: (a) A square of glass, esp.","pos":""}],"QUARRELET":[{"def":"A little quarrel.","pos":""}],"QUARRELING":[{"def":"Engaged in a quarrel; apt or disposed to quarrel; as, quarreling factions; a quarreling mood.","pos":""}],"QUARRELSOME":[{"def":"Apt or disposed to quarrel; given to brawls and contention; easily irritated or provoked to contest; irascible; choleric.","pos":""}],"QUARRIED":[{"def":"Provided with prey.","pos":""}],"QUARRIER":[{"def":"A worker in a stone quarry.","pos":""}],"QUARRY":[{"def":"Same as 1st Quarrel.","pos":""}],"QUARRY-FACED":[{"def":"Having a face left as it comes from the quarry and not smoothed with the chisel or point; -- said of stones.","pos":""}],"QUARRY-MAN":[{"def":"A man who is engaged in quarrying stones; a quarrier.","pos":""}],"QUART":[{"def":"The fourth part; a quarter; hence, a region of the earth.","pos":""}],"QUARTAN":[{"def":"Of or pertaining to the fourth; occurring every fourth day, reckoning inclusively; as, a quartan ague, or fever.","pos":""}],"QUARTANE":[{"def":"Butane, each molecule of which has four carbon atoms.","pos":""}],"QUARTATION":[{"def":"The act, process, or result (in the process of parting) of alloying a button of nearly pure gold with enough silver to reduce the fineness so as to allow acids to attack and remove all metals except the gold; -- called also inquartation.","pos":""}],"QUARTE":[{"def":"Same as 2d Carte.","pos":""}],"QUARTENE":[{"def":"Same as Butylene.","pos":""}],"QUARTENYLIC":[{"def":"Pertaining to, or designating, an acid of the acrylic acid series, metameric with crotonic acid, and obtained as a colorless liquid; -- so called from having four carbon atoms in the molecule.","pos":""}],"QUARTER":[{"def":"The encampment on one of the principal passages round a place besieged, to prevent relief and intercept convoys.","pos":""},{"def":"A station or encampment occupied by troops; a place of lodging for soldiers or officers; as, winter quarters.","pos":""}],"QUARTER-DECK":[{"def":"That part of the upper deck abaft the mainmast, including the poop deck when there is one.","pos":""}],"QUARTER-SAW":[{"def":"To saw (a log) into quarters; specif.","pos":""}],"QUARTERAGE":[{"def":"A quarterly allowance.","pos":""}],"QUARTERED":[{"def":"Divided into four equal parts or quarters; separated into four parts or regions.","pos":""},{"def":"Furnished with quarters; provided with shelter or entertainment.","pos":""}],"QUARTERFOIL":[{"def":"An ornamental foliation having four lobes, or foils.","pos":""}],"QUARTERHUNG":[{"def":"Having trunnions the axes of which lie below the bore; -- said of a cannon.","pos":""}],"QUARTERING":[{"def":"Coming from a point well abaft the beam, but not directly astern; -- said of waves or any moving object.","pos":""},{"def":"At right angles, as the cranks of a locomotive, which are in planes forming a right angle with each other.","pos":""}],"QUARTERLY":[{"def":"Containing, or consisting of, a fourth part; as, quarterly seasons.","pos":""},{"def":"Recurring during, or at the end of, each quarter; as, quarterly payments of rent; a quarterly meeting.","pos":""}],"QUARTERMASTER":[{"def":"An officer whose duty is to provide quarters, provisions, storage, clothing, fuel, stationery, and transportation for a regiment or other body of troops, and superintend the supplies.","pos":""},{"def":"A petty officer who attends to the helm, binnacle, signals, and the like, under the direction of the master.","pos":""}],"QUARTERN":[{"def":"A loaf of bread weighing about four pounds; -- called also quartern loaf.","pos":"noun"}],"QUARTERON":[{"def":"QUARTERON; QUARTEROON Quar\"ter*on, Quar\"ter*oon, n.","pos":""}],"QUARTERPACE":[{"def":"A platform of a staircase where the stair turns at a right angle only.","pos":""}],"QUARTERSTAFF":[{"def":"A long and stout staff formerly used as a weapon of defense and offense; -- so called because in holding it one hand was placed in the middle, and the other between the middle and the end.","pos":""},{"def":"A stanza of four lines.","pos":""}],"QUARTIC":[{"def":"Of the fourth degree.","pos":""}],"QUARTILE":[{"def":"Same as Quadrate.","pos":""}],"QUARTINE":[{"def":"A supposed fourth integument of an ovule, counting from the outside.","pos":""}],"QUARTO":[{"def":"Having four leaves to the sheet; of the form or size of a quarto.","pos":""}],"QUARTZIFEROUS":[{"def":"Consisting chiefly of quartz; containing quartz.","pos":""}],"QUARTZITE":[{"def":"Massive quartz occurring as a rock; a metamorphosed sandstone; -- called also quartz rock.","pos":""}],"QUARTZOID":[{"def":"A form of crystal common with quartz, consisting of two six- sided pyramids, base to base.","pos":""}],"QUARTZOSE":[{"def":"Containing, or resembling, quartz; partaking of the nature or qualities of quartz.","pos":""}]}