{"INHABILE":[{"def":"Not apt or fit; unfit; not convenient; inappropriate; unsuitable; as, inhabile matter.","pos":""},{"def":"Unskilled; unready; awkward; incompetent; unqualified; -- said of person.","pos":""}],"INHABILITY":[{"def":"Unsuitableness; unaptness; unfitness; inability.","pos":""}],"INHABIT":[{"def":"To live or dwell in; to occupy, as a place of settled residence; as, wild beasts inhabit the forest; men inhabit cities and houses.","pos":""}],"INHABITABLE":[{"def":"Capable of being inhabited; habitable.","pos":""}],"INHABITANT":[{"def":"One who has a legal settlement in a town, city, or parish; a permanent resident.","pos":""}],"INHABITATION":[{"def":"The act of inhabiting, or the state of being inhabited; indwelling.","pos":""},{"def":"Abode; place of dwelling; residence.","pos":""}],"INHABITATIVENESS":[{"def":"A tendency or propensity to permanent residence in a place or abode; love of home and country.","pos":""}],"INHABITIVENESS":[{"def":"See Inhabitativeness.","pos":""}],"INHABITRESS":[{"def":"A female inhabitant.","pos":""}],"INHALANT":[{"def":"Inhaling; used for inhaling.","pos":""}],"INHALATION":[{"def":"The act of inhaling; also, that which is inhaled.","pos":""}],"INHALE":[{"def":"To breathe or draw into the lungs; to inspire; as, to inhale air; -- opposed to exhale.","pos":""}],"INHALENT":[{"def":"Used for inhaling; as, the inhalent end of a duct.","pos":""}],"INHALER":[{"def":"One who inhales.","pos":""},{"def":"An apparatus for inhaling any vapor or volatile substance, as ether or chloroform, for medicinal purposes.","pos":""}],"INHANCE":[{"def":"Not harmonic; inharmonious; discordant; dissonant.","pos":""}],"INHARMONIOUS":[{"def":"Not harmonious; unmusical; discordant; dissonant.","pos":""},{"def":"Conflicting; jarring; not in harmony.","pos":""}],"INHARMONIOUSLY":[{"def":"Without harmony.","pos":""}],"INHARMONIOUSNESS":[{"def":"The quality of being inharmonious; want of harmony; discord.","pos":""}],"INHARMONY":[{"def":"Want of harmony.","pos":""},{"def":"A rope used to draw in the jib boom, or flying jib boom.","pos":""}],"INHEARSE":[{"def":"To put in, or as in, a hearse or coffin.","pos":""}],"INHERE":[{"def":"To be inherent; to stick (in); to be fixed or permanently incorporated with something; to cleave (to); to belong, as attributes or qualities.","pos":""},{"def":"The state of inhering; permanent existence in something; innateness; inseparable and essential connection.","pos":""}],"INHERENT":[{"def":"Permanently existing in something; inseparably attached or connected; naturally pertaining to; innate; inalienable; as, polarity is an inherent quality of the magnet; the inherent right of men to life, liberty, and protection.","pos":""}],"INHERENTLY":[{"def":"By inherence; inseparably.","pos":""}],"INHERIT":[{"def":"To receive or take by birth; to have by nature; to derive or acquire from ancestors, as mental or physical qualities; as, he inherits a strong constitution, a tendency to disease, etc.","pos":""},{"def":"To come into possession of; to possess; to own; to enjoy as a possession.","pos":""}],"INHERITABILITY":[{"def":"The quality of being inheritable or descendible to heirs.","pos":""}],"INHERITABLE":[{"def":"Capable of taking by inheritance, or of receiving by descent; capable of succeeding to, as an heir.","pos":""}],"INHERITANCE":[{"def":"Transmission and reception by animal or plant generation.","pos":""},{"def":"A perpetual or continuing right which a man and his heirs have to an estate; an estate which a man has by descent as heir to another, or which he may transmit to another as his heir; an estate derived from an ancestor to an heir in course of law.","pos":""}],"INHERITOR":[{"def":"One who inherits; an heir.","pos":""}],"INHERITRIX":[{"def":"Same as Inheritress.","pos":""}],"INHESION":[{"def":"The state of existing, of being inherent, in something; inherence.","pos":""}],"INHIATION":[{"def":"A gaping after; eager desire; craving.","pos":""}],"INHIBIT":[{"def":"To check; to hold back; to restrain; to hinder.","pos":""},{"def":"To forbid; to prohibit; to interdict.","pos":""}],"INHIBITION":[{"def":"A stopping or checking of an already present action; a restraining of the function of an organ, or an agent, as a digestive fluid or ferment, etc.","pos":""},{"def":"A writ from a higher court forbidding an inferior judge from further proceedings in a cause before; esp.","pos":""}],"INHIBITOR":[{"def":"That which causes inhibitory action; esp.","pos":""}],"INHIBITORY":[{"def":"Of or pertaining to, or producing, inhibition; consisting in inhibition; tending or serving to inhibit; as, the inhibitory action of the pneumogastric on the respiratory center.","pos":""}],"INHIBITORY-MOTOR":[{"def":"A term applied to certain nerve centers which govern or restrain subsidiary centers, from which motor impressions issue.","pos":""}],"INHIVE":[{"def":"To place in a hive; to hive.","pos":""}],"INHOLD":[{"def":"To have inherent; to contain in itself; to possess.","pos":""}],"INHOOP":[{"def":"To inclose in a hoop, or as in a hoop.","pos":""}],"INHOSPITABLE":[{"def":"Not hospitable; not disposed to show hospitality to strangers or guests; as, an inhospitable person or people.","pos":""},{"def":"Affording no shelter or sustenance; barren; desert; bleak; cheerless; wild.","pos":""}],"INHOSPITALITY":[{"def":"The quality or state of being inhospitable; inhospitableness; lack of hospitality.","pos":""}],"INHUMAN":[{"def":"Destitute of the kindness and tenderness that belong to a human being; cruel; barbarous; savage; unfeeling; as, an inhuman person or people.","pos":""},{"def":"Characterized by, or attended with, cruelty; as, an inhuman act or punishment.","pos":""}],"INHUMANITY":[{"def":"The quality or state of being inhuman; cruelty; barbarity.","pos":""}],"INHUMANLY":[{"def":"In an inhuman manner; cruelly; barbarously.","pos":""}],"INHUMATE":[{"def":"To inhume; to bury; to inter.","pos":""}],"INHUMATION":[{"def":"The act of burying vessels in warm earth in order to expose their contents to a steady moderate heat; the state of being thus exposed.","pos":""}],"INHUME":[{"def":"To deposit, as a dead body, in the earth; to bury; to inter.","pos":""},{"def":"To bury or place in warm earth for chemical or medicinal purposes.","pos":""}]}