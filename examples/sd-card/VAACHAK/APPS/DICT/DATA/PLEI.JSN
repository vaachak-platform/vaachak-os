{"PLEIAD":[{"def":"One of the Pleiades.","pos":""}],"PLEIADES":[{"def":"The seven daughters of Atlas and the nymph Pleione, fabled to have been made by Jupiter a constellation in the sky.","pos":""},{"def":"A group of small stars in the neck of the constellation Taurus.","pos":""}],"PLEIOPHYLLOUS":[{"def":"Having several leaves; -- used especially when several leaves or leaflets appear where normally there should be only one.","pos":""}],"PLEIOSAURUS":[{"def":"Same as Pliosaurus.","pos":""}],"PLEISTOCENE":[{"def":"Of or pertaining to the epoch, or the deposits, following the Tertiary, and immediately preceding man.","pos":""},{"def":"The Pleistocene epoch, or deposits.","pos":""}]}