{"CAABA":[{"def":"The small and nearly cubical stone building, toward which all Mohammedans must pray.","pos":""}],"CAADA":[{"def":"A small cañon; a narrow valley or glen; also, but less frequently, an open valley.","pos":""}],"CAATINGA":[{"def":"A forest composed of stunted trees and thorny bushes, found in areas of small rainfall in Brazil.","pos":""}]}