{"OWE":[{"def":"To possess; to have, as the rightful owner; to own.","pos":""},{"def":"To have or possess, as something derived or bestowed; to be obliged to ascribe (something to some source); to be indebted or obliged for; as, he owed his wealth to his father; he owed his victoty to his lieutenants.","pos":""}],"OWELTY":[{"def":"Equality; -- sometimes written ovelty and ovealty.","pos":""}],"OWENITE":[{"def":"A follower of Robert Owen, who tried to reorganize society on a socialistic basis, and established an industrial community on the Clyde, Scotland, and, later, a similar one in Indiana.","pos":""}],"OWING":[{"def":"Had or held under obligation of paying; due.","pos":""},{"def":"Had or experienced as a consequence, result, issue, etc.","pos":""}],"OWL":[{"def":"Any cpecies of raptorial birds of the family Strigidæ.","pos":""},{"def":"A variety of the domestic pigeon.","pos":""}],"OWL-EYED":[{"def":"Having eyes like an owl's.","pos":""}],"OWLER":[{"def":"One who owls; esp.","pos":""}],"OWLERY":[{"def":"An abode or a haunt of owls.","pos":""}],"OWLET":[{"def":"A small owl; especially, the European species (Athene noctua), and the California flammulated owlet (Megascops flammeolus).","pos":""}],"OWLING":[{"def":"The offense of transporting wool or sheep out of England contrary to the statute formerly existing.","pos":""}],"OWLISH":[{"def":"Resembling, or characteristic of, an owl.","pos":""}],"OWLISM":[{"def":"Affected wisdom; pompous dellness.","pos":""}],"OWLLIGHT":[{"def":"Glimmering or imperfect [R.","pos":""}],"OWN":[{"def":"To grant; to acknowledge; to admit to be true; to confess; to recognize in a particular character; as, we own that we have forfeited your love.","pos":""}],"OWNER":[{"def":"One who owns; a rightful proprietor; one who has the legal or rightful title, whether he is the possessor or not.","pos":""}],"OWNERLESS":[{"def":"Without an owner.","pos":""}],"OWNERSHIP":[{"def":"The state of being an owner; the right to own; exclusive right of possession; legal or just claim or title; proprietorship.","pos":""}],"OWRE":[{"def":"OWSE; OWSER Owse, Ow\"ser, n.","pos":""}]}