{"WHACK":[{"def":"To strike; to beat; to give a heavy or resounding blow to; to thrash; to make with whacks.","pos":""}],"WHACKER":[{"def":"Anything very large; specif.","pos":""}],"WHACKING":[{"def":"Very large; whapping.","pos":""}],"WHAHOO":[{"def":"An American tree, the winged elm.","pos":""}],"WHALA":[{"def":"To lash with stripes; to wale; to thrash; to drub.","pos":""}],"WHALE":[{"def":"Any aquatic mammal of the order Cetacea, especially any one of the large species, some of which become nearly one hundred feet long.","pos":""}],"WHALEBACK":[{"def":"A form of vessel, often with steam power, having sharp ends and a very convex upper deck, much used on the Great Lakes, esp.","pos":""}],"WHALEBOAT":[{"def":"A long, narrow boat, sharp at both ends, used by whalemen.","pos":""}],"WHALEBONE":[{"def":"A firm, elastic substance resembling horn, taken from the upper jaw of the right whale; baleen.","pos":""}],"WHALEMAN":[{"def":"A man employed in the whale fishery.","pos":""}],"WHALER":[{"def":"A vessel or person employed in the whale fishery.","pos":""}],"WHALING":[{"def":"The hunting of whales.","pos":""}],"WHALL":[{"def":"A light color of the iris in horses; wall-eye.","pos":""}],"WHALLY":[{"def":"Having the iris of light color; -- said of horses.","pos":""}],"WHANG":[{"def":"A leather thong.","pos":""}],"WHANGDOODLE":[{"def":"An imaginary creature, of undefined character.","pos":""}],"WHANGHEE":[{"def":"To throw one's self quickly, or by an abrupt motion; to turn suddenly; as, she whapped down on the floor; the fish whapped over.","pos":""}],"WHARF":[{"def":"The bank of a river, or the shore of the sea.","pos":""}],"WHARFAGE":[{"def":"The fee or duty paid for the privilege of using a wharf for loading or unloading goods; pierage, collectively; quayage.","pos":""},{"def":"A wharf or wharfs, collectively; wharfing.","pos":""}],"WHARFING":[{"def":"A mode of facing sea walls and embankments with planks driven as piles and secured by ties.","pos":""}],"WHARFINGER":[{"def":"A man who owns, or has the care of, a wharf.","pos":""},{"def":"A guttural pronunciation of the letter r; a burr.","pos":""}],"WHARP":[{"def":"A kind of fine sand from the banks of the Trent, used as a polishing powder.","pos":""}],"WHAT":[{"def":"As an interrogative pronoun, used in asking questions regarding either persons or things; as, what is this what did you say what poem is this what child is lost What see'st thou in the ground Shak.","pos":""},{"def":"As an exclamatory word: -- (a) Used absolutely or independently; - - often with a question following.","pos":""}],"WHATE'ER":[{"def":"A contraction of what-ever; -- used in poetry.","pos":""}],"WHATEVER":[{"def":"Anything soever which; the thing or things of any kind; being this or that; of one nature or another; one thing or another; anything that may be; all that; the whole that; all particulars that; -- used both substantively and adjectively.","pos":""}],"WHATNOT":[{"def":"A kind of stand, or piece of furniture, having shelves for books, ornaments, etc.","pos":""}],"WHATSO":[{"def":"Whatsoever; whosoever; whatever; anything that.","pos":""}],"WHATSOE'ER":[{"def":"A contraction of whatsoever; -- used in poetry.","pos":""}],"WHATSOEVER":[{"def":"Whatsoever God hath said unto thee, do.","pos":""}]}