{"STIR":[{"def":"To change the place of in any manner; to move.","pos":""},{"def":"To disturb the relative position of the particles of, as of a liquid, by passing something through it; to agitate; as, to stir a pudding with a spoon.","pos":""}],"STIRABOUT":[{"def":"A dish formed of oatmeal boiled in water to a certain consistency and frequently stirred, or of oatmeal and dripping mixed together and stirred about in a pan; a hasty pudding.","pos":""}],"STIRIATED":[{"def":"Adorned with pendants like icicles.","pos":""}],"STIRIOUS":[{"def":"Resembling icicles.","pos":""}],"STIRK":[{"def":"A young bullock or heifer.","pos":""}],"STIRLESS":[{"def":"Without stirring; very quiet; motionless.","pos":""}],"STIRP":[{"def":"Stock; race; family.","pos":""}],"STIRPICULTURE":[{"def":"The breeding of special stocks or races.","pos":""}],"STIRPS":[{"def":"Stock; race; family.","pos":""},{"def":"A race, or a fixed and permanent variety.","pos":""}],"STIRRAGE":[{"def":"The act of stirring; stir; commotion.","pos":""}],"STIRRER":[{"def":"One who, or that which, stirs something; also, one who moves about, especially after sleep; as, an early stirrer.","pos":""}],"STIRRING":[{"def":"Putting in motion, or being in motion; active; active in business; habitually employed in some kind of business; accustomed to a busy life.","pos":""}],"STIRRUP":[{"def":"Any piece resembling in shape the stirrup of a saddle, and used as a support, clamp, etc.","pos":""},{"def":"A rope secured to a yard, with a thimble in its lower end for supporting a footrope.","pos":""}],"STIRT":[{"def":"Started; leaped.","pos":""}]}