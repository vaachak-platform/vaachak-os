{"INVADE":[{"def":"To go into or upon; to pass within the confines of; to enter; -- used of forcible or rude ingress.","pos":""},{"def":"To enter with hostile intentions; to enter with a view to conquest or plunder; to make an irruption into; to attack; as, the Romans invaded Great Britain.","pos":""}],"INVADER":[{"def":"One who invades; an assailant; an encroacher; an intruder.","pos":""}],"INVAGINATE":[{"def":"To insert as in a sheath; to pr INVAGINATE; INVAGINATED In*vag\"i*nate, In*vag\"i*na`ted, a.","pos":""}],"INVAGINATION":[{"def":"The condition of an invaginated organ or part.","pos":""},{"def":"One of the methods by which the various germinal layers of the ovum are differentiated.","pos":""}],"INVALESCENCE":[{"def":"Strength; health.","pos":""}],"INVALETUDINARY":[{"def":"Wanting health; valetudinary.","pos":""}],"INVALID":[{"def":"Having no force, effect, or efficacy; void; null; as, an invalid contract or agreement.","pos":""}],"INVALIDATE":[{"def":"To render invalid; to weaken or lessen the force of; to destroy the authority of; to render of no force or effect; to overthrow; as, to invalidate an agreement or argument.","pos":""}],"INVALIDATION":[{"def":"The act of inavlidating, or the state of being invalidated.","pos":""}],"INVALIDISM":[{"def":"The condition of an invalid; sickness; infirmity.","pos":""}],"INVALIDITY":[{"def":"Want of validity or cogency; want of legal force or efficacy; invalidness; as, the invalidity of an agreement or of a will.","pos":""},{"def":"Want of health; infirmity.","pos":""}],"INVALIDNESS":[{"def":"Invalidity; as, the invalidness of reasoning.","pos":""}],"INVALOROUS":[{"def":"Not valorous; cowardly.","pos":""}],"INVALUABLE":[{"def":"Valuable beyond estimation; inestimable; priceless; precious.","pos":""}],"INVARIABILITY":[{"def":"The quality of being invariable; invariableness; constancy; uniformity.","pos":""}],"INVARIABLE":[{"def":"Not given to variation or change; unalterable; unchangeable; always uniform.","pos":""}],"INVARIANCE":[{"def":"The property of remaining invariable under prescribed or implied conditions.","pos":""}],"INVARIANT":[{"def":"An invariable quantity; specifically, a function of the coefficients of one or more forms, which remains unaltered, when these undergo suitable linear transformations.","pos":""}],"INVASION":[{"def":"The act of invading; the act of encroaching upon the rights or possessions of another; encroachment; trespass.","pos":""},{"def":"A warlike or hostile entrance into the possessions or domains of another; the incursion of an army for conquest or plunder.","pos":""}],"INVASIVE":[{"def":"Tending to invade; characterized by invasion; aggressive.","pos":""}]}