{"LEVANA":[{"def":"A goddess who protected newborn infants.","pos":""}],"LEVANT":[{"def":"Rising or having risen from rest; -- said of cattle.","pos":""}],"LEVANTER":[{"def":"One who levants, or decamps.","pos":""}],"LEVANTINE":[{"def":"Of or pertaining to the Levant.","pos":""}],"LEVARI FACIAS":[{"def":"A writ of execution at common law.","pos":""}],"LEVATION":[{"def":"The act of raising; elevation; upward motion, as that produced by the action of a levator muscle.","pos":""}],"LEVATOR":[{"def":"A muscle that serves to raise some part, as the lip or the eyelid.","pos":""},{"def":"A surgical instrument used to raise a depressed part of the skull.","pos":""}],"LEVE":[{"def":"Same as 3d & 4th Leave.","pos":""}],"LEVECHE":[{"def":"A dry sirocco of Spain.","pos":""}],"LEVEE":[{"def":"The act of rising.","pos":""},{"def":"A morning assembly or reception of visitors, -- in distinction from a soirée, or evening assembly; a matinée; hence, also, any general or somewhat miscellaneous gathering of guests, whether in the daytime or evening; as, the president's levee.","pos":""}],"LEVEE EN MASSE":[{"def":"See Levy in mass, under Levy, n.","pos":""}],"LEVEFUL":[{"def":"Allowable; permissible; lawful.","pos":""}],"LEVEL":[{"def":"A horizontal line or plane; that is, a straight line or a plane which is tangent to a true level at a given point and hence parallel to the horizon at that point; -- this is the apparent level at the given point.","pos":""}],"LEVELER":[{"def":"One who, or that which, levels.","pos":""},{"def":"One who would remove social inequalities or distinctions; a socialist.","pos":""}],"LEVELING":[{"def":"The art or operation of using a leveling instrument for finding a horizontal line, for ascertaining the differences of level between different points of the earth's surface included in a survey, for establishing grades, etc.","pos":""}],"LEVELISM":[{"def":"The disposition or endeavor to level all distinctions of rank in society.","pos":""}],"LEVELLY":[{"def":"In an even or level manner.","pos":""}],"LEVELNESS":[{"def":"The state or quality of being level.","pos":""}],"LEVEN":[{"def":"Wild thunder dint and fiery leven.","pos":""}],"LEVER":[{"def":"More agreeable; more pleasing.","pos":""}],"LEVERAGE":[{"def":"The action of a lever; mechanical advantage gained by the lever.","pos":""}],"LEVERET":[{"def":"A hare in the first year of its age.","pos":""}],"LEVERWOOD":[{"def":"The American hop hornbeam (Ostrya Virginica), a small tree with very tough wood.","pos":""}],"LEVESEL":[{"def":"A leafy shelter; a place covered with foliage.","pos":""}],"LEVET":[{"def":"A trumpet call for rousing soldiers; a reveille.","pos":""}],"LEVIABLE":[{"def":"Fit to be levied; capable of being assessed and collected; as, sums leviable by course of law.","pos":""}],"LEVIATHAN":[{"def":"An aquatic animal, described in the book of Job, ch.","pos":""},{"def":"The whale, or a great whale.","pos":""}],"LEVIGABLE":[{"def":"Capable of being levigated.","pos":""}],"LEVIGATE":[{"def":"Made less harsh or burdensome; alleviated.","pos":""}],"LEVIGATION":[{"def":"The act or operation of levigating.","pos":""}],"LEVIR":[{"def":"A husband's brother; -- used in reference to levirate marriages.","pos":""},{"def":"Of, pertaining to, or in accordance with, a law of the ancient Israelites and other tribes and races, according to which a woman, whose husband died without issue, was married to the husband's brother.","pos":""}],"LEVIRATION":[{"def":"Levirate marriage or marriages.","pos":""}],"LEVIROSTRES":[{"def":"A group of birds, including the hornbills, kingfishers, and related forms.","pos":""}],"LEVITATE":[{"def":"To rise, or tend to rise, as if lighter than the surrounding medium; to become buoyant; -- opposed to gravitate.","pos":""}],"LEVITATION":[{"def":"Lightness; buoyancy; act of making light.","pos":""},{"def":"The act or process of making buoyant.","pos":""}],"LEVITE":[{"def":"One of the tribe or family of Levi; a descendant of Levi; esp.","pos":""}],"LEVITICAL":[{"def":"Of or pertaining to a Levite or the Levites.","pos":""}],"LEVITICALLY":[{"def":"After the manner of the Levites; in accordance with the levitical law.","pos":""}],"LEVITICUS":[{"def":"The third canonical book of the Old Testament, containing the laws and regulations relating to the priests and Levites among the Hebrews, or the body of the ceremonial law.","pos":""}],"LEVITY":[{"def":"The quality of weighing less than something else of equal bulk; relative lightness, especially as shown by rising through, or floating upon, a contiguous substance; buoyancy; -- opposed to gravity.","pos":""},{"def":"Lack of gravity and earnestness in deportment or character; trifling gayety; frivolity; sportiveness; vanity.","pos":""}],"LEVO-":[{"def":"A prefix from L.","pos":""}],"LEVOGYRATE":[{"def":"Turning or twisting the plane of polarization towards the left, as levulose, levotartaric acid, etc.","pos":""}],"LEVOROTATION":[{"def":"Rotation in the direction of an outgoing right-handed screw; counter-clockwise rotation; -- applied chiefly to the turning of the plane of polarization of light.","pos":""}],"LEVOROTATORY":[{"def":"Turning or rotating the plane of polarization towards the left; levogyrate, as levulose, left handed quartz crystals, etc.","pos":""}],"LEVULIN":[{"def":"A substance resembling dextrin, obtained from the bulbs of the dahlia, the artichoke, and other sources, as a colorless, spongy, amorphous material.","pos":""}],"LEVULINIC":[{"def":"Pertaining to, or denoting, an acid (called also acetyl- propionic acid), C5H8O3, obtained by the action of dilute acids on various sugars (as levulose).","pos":""}],"LEVULOSAN":[{"def":"An unfermentable carbohydrate obtained by gently heating levulose.","pos":""}],"LEVULOSE":[{"def":"A sirupy variety of sugar, rarely obtained crystallized, occurring widely in honey, ripe fruits, etc.","pos":""}],"LEVY":[{"def":"The taking or seizure of property on executions to satisfy judgments, or on warrants for the collection of taxes; a collecting by execution.","pos":""}]}