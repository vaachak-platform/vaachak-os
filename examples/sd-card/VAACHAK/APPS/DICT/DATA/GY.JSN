{"GYALL":[{"def":"GYB; GYBE Gyb, Gybe (, n.","pos":""}],"GYBE":[{"def":"To shift from one side of a vessel to the other; -- said of the boom of a fore-and-aft sail when the vessel is steered off the wind until the sail fills on the opposite side.","pos":""}],"GYE":[{"def":"To guide; to govern.","pos":""}],"GYLE":[{"def":"Fermented wort used for making vinegar.","pos":""}],"GYMNASIARCH":[{"def":"An Athenian officer who superintended the gymnasia, and provided the oil and other necessaries at his own expense.","pos":""}],"GYMNASIUM":[{"def":"A place or building where athletic exercises are performed; a school for gymnastics.","pos":""},{"def":"A school for the higher branches of literature and science; a preparatory school for the university; -- used esp.","pos":""}],"GYMNAST":[{"def":"One who teaches or practices gymnastic exercises; the manager of a gymnasium; an athlete.","pos":""},{"def":"Pertaining to athletic exercises intended for health, defense, or diversion; -- said of games or exercises, as running, leaping, wrestling, throwing the discus, the javelin, etc.","pos":""}],"GYMNASTICALLY":[{"def":"In a gymnastic manner.","pos":""}],"GYMNASTICS":[{"def":"Athletic or disciplinary exercises; the art of performing gymnastic exercises; also, disciplinary exercises for the intellect or character.","pos":""},{"def":"Athletic; gymnastic.","pos":""}],"GYMNIC":[{"def":"Athletic exercise.","pos":""}],"GYMNITE":[{"def":"A hydrous silicate of magnesia.","pos":""}],"GYMNOBLASTEA":[{"def":"The Athecata; -- so called because the medusoid buds are not inclosed in a capsule.","pos":""}],"GYMNOBLASTIC":[{"def":"Of or pertaining to the Gymnoblastea.","pos":""}],"GYMNOCARPOUS":[{"def":"Naked-fruited, the fruit either smooth or not adherent to the perianth.","pos":""}],"GYMNOCHROA":[{"def":"A division of Hydroidea including the hydra.","pos":""}],"GYMNOCLADUS":[{"def":"A genus of leguminous plants; the Kentucky coffee tree.","pos":""}],"GYMNOCOPA":[{"def":"A group of transparent, free-swimming Annelida, having setae only in the cephalic appendages.","pos":""}],"GYMNOCYTODE":[{"def":"A cytode without either a cell wall or a nucleus.","pos":""}],"GYMNODONT":[{"def":"One of a group of plectognath fishes (Gymnodontes), having the teeth and jaws consolidated into one or two bony plates, on each jaw, as the diodonts and tetradonts.","pos":""}],"GYMNOGEN":[{"def":"One of a class of plants, so called by Lindley, because the ovules are fertilized by direct contact of the pollen.","pos":""}],"GYMNOGLOSSA":[{"def":"A division of gastropods in which the odontophore is without teeth.","pos":""},{"def":"An order of Bryozoa, having no epistome.","pos":""}],"GYMNONOTI":[{"def":"The order of fishes which includes the Gymnotus or electrical eel.","pos":""}],"GYMNOPAEDIC":[{"def":"Having young that are naked when hatched; psilopædic; -- said of certain birds.","pos":""}],"GYMNOPHIONA":[{"def":"An order of Amphibia, having a long, annulated, snakelike body.","pos":""}],"GYMNOPHTHALMATA":[{"def":"A group of acalephs, including the naked-eyed medusæ; the hydromedusæ.","pos":""}],"GYMNOPLAST":[{"def":"A cell or mass of protoplasm devoid of an envelope, as a white blood corpuscle.","pos":""}],"GYMNORHINAL":[{"def":"Having unfeathered nostrils, as certain birds.","pos":""}],"GYMNOSOMATA":[{"def":"One of the orders of Pteropoda.","pos":""}],"GYMNOSOPHIST":[{"def":"One of a sect of philosophers, said to have been found in India by Alexander the Great, who went almost naked, denied themselves the use of flesh, renounced bodily pleasures, and employed themselves in the contemplation of nature.","pos":""}],"GYMNOSOPHY":[{"def":"The doctrines of the Gymnosophists.","pos":""}],"GYMNOSPERM":[{"def":"A plant that bears naked seeds (i.","pos":""}],"GYMNOTUS":[{"def":"A genus of South American fresh-water fishes, including the Gymnotus electricus, or electric eel.","pos":""}],"GYN":[{"def":"The part of a large house, among the ancients, exclusively appropriated to women.","pos":""}],"GYNAECIAN":[{"def":"The same as Gynecian.","pos":""}],"GYNAECOPHORE":[{"def":"A ventral canal or groove, in which the males of some dioecious trematodes carry the female.","pos":""}],"GYNANDER":[{"def":"A plant having the stamens inserted in the pistil.","pos":""}],"GYNANDRIA":[{"def":"A class of plants in the Linnaean system, whose stamens grow out of, or are united with, the pistil.","pos":""},{"def":"Having stamens inserted in the pistil; belonging to the class Gynandria.","pos":""}],"GYNANDROMORPHISM":[{"def":"An abnormal condition of certain animals, in which one side has the external characters of the male, and the other those of the female.","pos":""}],"GYNANDROMORPHOUS":[{"def":"Affected, with gynandromorphism.","pos":""}],"GYNANTHEROUS":[{"def":"Pertaining to an abnormal condition of the flower, in which the stamens are converted into pistils.","pos":""}],"GYNARCHY":[{"def":"Government by a woman.","pos":""}],"GYNECIAN":[{"def":"Of or relating to women.","pos":""}],"GYNECOCRACY":[{"def":"Government by a woman, female power; gyneocracy.","pos":""}],"GYNECOLOGICAL":[{"def":"Of or pertaining to gynecology.","pos":""}],"GYNECOLOGY":[{"def":"The science which treats of the structure and diseases of women.","pos":""}],"GYNEOCRACY":[{"def":"See Gynecocracy.","pos":""}],"GYNEOLATRY":[{"def":"The adoration or worship of woman.","pos":""}],"GYNEPHOBIA":[{"def":"Hatred of women; repugnance to the society of women.","pos":""}],"GYNOBASE":[{"def":"A dilated base or receptacle, supporting a multilocular ovary.","pos":""}],"GYNOBASIC":[{"def":"Pertaining to, or having, a gynobase.","pos":""}],"GYNOCRACY":[{"def":"Female government; gynecocracy.","pos":""}],"GYNODIOECIOUS":[{"def":"Dioecious, but having some hermaphrodite or perfect flowers on an individual plant which bears mostly pistillate flowers.","pos":""}],"GYNOECIUM":[{"def":"The pistils of a flower, taken collectively.","pos":""}],"GYNOPHORE":[{"def":"The pedicel raising the pistil or ovary above the stamens, as in the passion flower.","pos":""},{"def":"One of the branches bearing the female gonophores, in certain Siphonophora.","pos":""}],"GYP":[{"def":"A college servant; -- so called in Cambridge, England; at Oxford called a scout.","pos":""}],"GYPSEOUS":[{"def":"Resembling or containing gypsum; partaking of the qualities of gypsum.","pos":""}],"GYPSIFEROUS":[{"def":"Containing gypsum.","pos":""}],"GYPSOGRAPHY":[{"def":"The act or art of engraving on gypsum.","pos":""}],"GYPSOPLAST":[{"def":"A cast taken in plaster of Paris, or in white lime.","pos":""}],"GYPSUM":[{"def":"A mineral consisting of the hydrous sulphate of lime (calcium).","pos":""}],"GYPSY":[{"def":"One of a vagabond race, whose tribes, coming originally from India, entered Europe in 14th or 15th centry, and are now scattered over Turkey, Russia, Hungary, Spain, England, etc.","pos":""},{"def":"The language used by the gypsies.","pos":""}],"GYPSYISM":[{"def":"A tussock moth (Ocneria dispar) native of the Old World, but accidentally introduced into eastern Massachusetts about 1869, where its caterpillars have done great damage to fruit, shade, and forest trees of many kinds.","pos":""}],"GYPSYWORT":[{"def":"A labiate plant (the Lycopus Europæus).","pos":""}],"GYRACANTHUS":[{"def":"A genus of fossil fishes, found in Devonian and carboniferous strata; -- so named from their round, sculptured spines.","pos":""}],"GYRAL":[{"def":"Pertaining to a gyrus, or convolution.","pos":""}],"GYRATE":[{"def":"Winding or coiled round; curved into a circle; taking a circular course.","pos":""}],"GYRATION":[{"def":"One of the whorls of a spiral univalve shell.","pos":""}],"GYRATORY":[{"def":"Moving in a circle, or spirally; revolving; whirling around.","pos":""}],"GYRE":[{"def":"A circular motion, or a circle described by a moving body; a turn or revolution; a circuit.","pos":""}],"GYREFUL":[{"def":"Abounding in gyres.","pos":""}],"GYRENCEPHALA":[{"def":"The higher orders of Mammalia, in which the cerebrum is convoluted.","pos":""}],"GYRFALCON":[{"def":"One of several species and varieties of large Arctic falcons, esp.","pos":""}],"GYRODUS":[{"def":"A genus of extinct oölitic fishes, having rounded teeth in several rows adapted for crushing.","pos":""}],"GYROGONITE":[{"def":"The petrified fruit of the Chara hispida, a species of stonewort.","pos":""}],"GYROIDAL":[{"def":"Having the planes arranged spirally, so that they incline all to the right (or left) of a vertical line; -- said of certain hemihedral forms.","pos":""},{"def":"Turning the plane of polarization circularly or spirally to the right or left.","pos":""}],"GYROLEPIS":[{"def":"A genus of ganoid fishes, found in strata of the new red sandetone, and the lias bone beds.","pos":""}],"GYROMA":[{"def":"A turning round.","pos":""}],"GYROMANCY":[{"def":"A kind of divination performed by drawing a ring or circle, and walking in or around it.","pos":""}],"GYRON":[{"def":"A subordinary of triangular form having one of its angles at the fess point and the opposite aide at the edge of the escutcheon.","pos":""}],"GYRONNY":[{"def":"Covered with gyrons, or divided so as to form several gyrons; - - said of an escutcheon.","pos":""},{"def":"A flying object simulating a pigeon in flight, when projected from a spring trap.","pos":""}],"GYROSCOPE":[{"def":"A rotating wheel, mounted in a ring or rings, for illustrating the dynamics of rotating bodies, the composition of rotations, etc.","pos":""},{"def":"A form of the above apparatus, invented by M.","pos":""}],"GYROSCOPIC":[{"def":"Pertaining to the gyroscope; resembling the motion of the gyroscope.","pos":""}],"GYROSE":[{"def":"Turned round like a crook, or bent to and fro.","pos":""}],"GYROSTAT":[{"def":"A modification of the gyroscope, consisting essentially of a fly wheel fixed inside a rigid case to which is attached a thin flange of metal for supporting the instrument.","pos":""}],"GYROSTATIC":[{"def":"Of or pertaining to the gyrostat or to gyrostatics.","pos":""}],"GYROSTATICS":[{"def":"The doctrine or theory of the gyrostat, or of the phenomena of rotating bodies.","pos":""}],"GYRUS":[{"def":"A convoluted ridge between grooves; a convolution; as, the gyri of the brain; the gyri of brain coral.","pos":""}],"GYTE":[{"def":"Delirious; senselessly extravagant; as, the man is clean gyte.","pos":""}],"GYVE":[{"def":"A shackle; especially, one to confine the legs; a fetter.","pos":""}]}