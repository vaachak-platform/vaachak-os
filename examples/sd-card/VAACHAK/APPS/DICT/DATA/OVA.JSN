{"OVAL":[{"def":"Broadly elliptical.","pos":""}],"OVALIFORM":[{"def":"Having the form of an egg; having a figure such that any section in the direction of the shorter diameter will be circular, and any in the direction of the longer diameter will be oval.","pos":""}],"OVALLY":[{"def":"In an oval form.","pos":""}],"OVANT":[{"def":"Of or pertaining to an ovary.","pos":""}],"OVARIOLE":[{"def":"One of the tubes of which the ovaries of most insects are composed.","pos":""}],"OVARIOTOMIST":[{"def":"One who performs, or is skilled in, ovariotomy.","pos":""}],"OVARIOTOMY":[{"def":"The operation of removing one or both of the ovaries; oöphorectomy.","pos":""}],"OVARIOUS":[{"def":"Consisting of eggs; as, ovarious food.","pos":""}],"OVARITIS":[{"def":"Inflammation of the ovaries.","pos":""}],"OVARY":[{"def":"That part of the pistil which contains the seed, and in most flowering plants develops into the fruit.","pos":""},{"def":"The essential female reproductive organ in which the ova are produced.","pos":""}],"OVATE":[{"def":"Having the shape of an egg, or of the longitudinal sectior of an egg, with the broader end basal.","pos":""}],"OVATE-ACUMINATE":[{"def":"Having an ovate form, but narrowed at the end into a slender point.","pos":""}],"OVATE-CYLINDRACEOUS":[{"def":"Having a form intermediate between ovate and cylindraceous.","pos":""}],"OVATE-LANCEOLATE":[{"def":"Having a form intermediate between ovate and lanceolate.","pos":""}],"OVATE-ROTUNDATE":[{"def":"Having a form intermediate between that of an egg and a sphere; roundly ovate.","pos":""}],"OVATE-SUBULATE":[{"def":"Having an ovate form, but with a subulate tip or extremity.","pos":""}],"OVATION":[{"def":"A lesser kind of triumph allowed to a commander for an easy, bloodless victory, or a victory over slaves.","pos":""}],"OVATO-ACUMINATE":[{"def":"Same as Ovate-acuminate.","pos":""}],"OVATO-CYLINDRACEOUS":[{"def":"Same as Ovate-cylindraceous.","pos":""}],"OVATO-OBLONG":[{"def":"Same as Ovate-oblong.","pos":""}],"OVATO-ROTUNDATE":[{"def":"Same as Ovate-rotundate.","pos":""}]}