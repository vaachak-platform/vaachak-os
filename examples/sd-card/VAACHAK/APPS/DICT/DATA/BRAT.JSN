{"BRAT":[{"def":"A coarse garnment or cloak; also, coarse clothing, in general.","pos":""},{"def":"A coarse kind of apron for keeping the clothes clean; a bib.","pos":""}],"BRATSCHE":[{"def":"The tenor viola, or viola.","pos":""}],"BRATTISHING":[{"def":"Carved openwork, as of a shrine, battlement, or parapet.","pos":""}]}