{"CNEMIAL":[{"def":"Pertaining to the shin bone.","pos":""}],"CNIDA":[{"def":"One of the peculiar stinging, cells found in Coelenterata; a nematocyst; a lasso cell.","pos":""}],"CNIDARIA":[{"def":"A comprehensive group equivalent to the true Coelenterata, i.","pos":""}],"CNIDOBLAST":[{"def":"One of the cells which, in the Coelenterata, develop into cnidæ.","pos":""}],"CNIDOCIL":[{"def":"The fine filiform process of a cnidoblast.","pos":""}]}