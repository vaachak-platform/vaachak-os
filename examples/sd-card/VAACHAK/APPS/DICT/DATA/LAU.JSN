{"LAUD":[{"def":"High commendation; praise; honor; exaltation; glory.","pos":""},{"def":"A part of divine worship, consisting chiefly of praise; -- usually in the pl.","pos":""}],"LAUDABILITY":[{"def":"Laudableness; praiseworthiness.","pos":""}],"LAUDABLE":[{"def":"Healthy; salubrious; normal; having a disposition to promote healing; not noxious; as, laudable juices of the body; laudable pus.","pos":""}],"LAUDABLENESS":[{"def":"The quality of being laudable; praiseworthiness; commendableness.","pos":""}],"LAUDABLY":[{"def":"In a laudable manner.","pos":""}],"LAUDANINE":[{"def":"A white organic base, resembling morphine, and obtained from certain varieties of opium.","pos":""}],"LAUDANUM":[{"def":"Tincture of opium, used for various medical purposes.","pos":""}],"LAUDATION":[{"def":"The act of lauding; praise; high commendation.","pos":""}],"LAUDATIVE":[{"def":"A panegyric; a eulogy.","pos":""}],"LAUDATORY":[{"def":"Of or pertaining praise, or to the expression of praise; as, laudatory verses; the laudatory powers of Dryden.","pos":""}],"LAUGH":[{"def":"To show mirth, satisfaction, or derision, by peculiar movement of the muscles of the face, particularly of the mouth, causing a lighting up of the face and eyes, and usually accompanied by the emission of explosive or chuckling sounds from the chest and throat; to indulge in laughter.","pos":""}],"LAUGHABLE":[{"def":"Fitted to excite laughter; as, a laughable story; a laughable scene.","pos":""}],"LAUGHER":[{"def":"A variety of the domestic pigeon.","pos":""}],"LAUGHING":[{"def":"New Zealand, said to be on the verge of extinction.","pos":""}],"LAUGHINGLY":[{"def":"With laughter or merriment.","pos":""}],"LAUGHINGSTOCK":[{"def":"An object of ridicule; a butt of sport.","pos":""}],"LAUGHSOME":[{"def":"Exciting laughter; also, addicted to laughter; merry.","pos":""}],"LAUGHTER":[{"def":"A movement (usually involuntary) of the muscles of the face, particularly of the lips, with a peculiar expression of the eyes, indicating merriment, satisfaction, or derision, and usually attended by a sonorous and interrupted expulsion of air from the lungs.","pos":""}],"LAUGHTERLESS":[{"def":"Not laughing; without laughter.","pos":""}],"LAUGHWORTHY":[{"def":"Deserving to be laughed at.","pos":""}],"LAUMONTITE":[{"def":"A mineral, of a white color and vitreous luster.","pos":""}],"LAUNCE":[{"def":"Fortune all in equal launce doth sway.","pos":""}],"LAUNCH":[{"def":"To throw, as a lance or dart; to hurl; to let fly.","pos":""},{"def":"To strike with, or as with, a lance; to pierce.","pos":""}],"LAUND":[{"def":"A plain sprinkled with trees or underbrush; a glade.","pos":""}],"LAUNDER":[{"def":"A trough used by miners to receive the powdered ore from the box where it is beaten, or for carrying water to the stamps, or other apparatus, for comminuting, or sorting, the ore.","pos":""}],"LAUNDERER":[{"def":"One who follows the business of laundering.","pos":""}],"LAUNDERING":[{"def":"The act, or occupation, of one who launders; washing and ironing.","pos":""}],"LAUNDRESS":[{"def":"A woman whose employment is laundering.","pos":""}],"LAUNDRY":[{"def":"A laundering; a washing.","pos":""},{"def":"A place or room where laundering is done.","pos":""}],"LAUNDRYMAN":[{"def":"A man who follows the business of laundering.","pos":""}],"LAURA":[{"def":"A number of hermitages or cells in the same neighborhood occupied by anchorites who were under the same superior.","pos":""}],"LAURACEOUS":[{"def":"Belonging to, or resembling, a natural order (Lauraceæ) of trees and shrubs having aromatic bark and foliage, and including the laurel, sassafras, cinnamon tree, true camphor tree, etc.","pos":""}],"LAURATE":[{"def":"A salt of lauric acid.","pos":""}],"LAUREATE":[{"def":"Crowned, or decked, with laurel.","pos":""}],"LAUREATESHIP":[{"def":"State, or office, of a laureate.","pos":""}],"LAUREATION":[{"def":"The act of crowning with laurel; the act of conferring an academic degree, or honorary title.","pos":""}],"LAUREL":[{"def":"An evergreen shrub, of the genus Laurus (L.","pos":""}],"LAURELED":[{"def":"Crowned with laurel, or with a laurel wreath; laureate.","pos":""}],"LAURENTIAN":[{"def":"Pertaining to, or near, the St.","pos":""}],"LAURESTINE":[{"def":"The Viburnum Tinus, an evergreen shrub or tree of the south of Europe, which flowers during the winter mouths.","pos":""}],"LAURIC":[{"def":"Pertaining to, or derived from, the European bay or laurel (Laurus nobilis).","pos":""}],"LAURIFEROUS":[{"def":"Producing, or bringing, laurel.","pos":""}],"LAURIN":[{"def":"A white crystalline substance extracted from the fruit of the bay (Laurus nobilis), and consisting of a complex mixture of glycerin ethers of several organic acids.","pos":""}],"LAURINOL":[{"def":"Ordinary camphor; -- so called in allusion to the family name (Lauraceæ) of the camphor trees.","pos":""}],"LAURITE":[{"def":"A rare sulphide of osmium and ruthenium found with platinum in Borneo and Oregon.","pos":""}],"LAURONE":[{"def":"The ketone of lauric acid.","pos":""}],"LAURUS":[{"def":"A genus of trees including, according to modern authors, only the true laurel (Laurus nobilis), and the larger L.","pos":""}],"LAUTVERSCHIEBUNG":[{"def":"Laut\"ver*schie`bung, n.","pos":""}]}