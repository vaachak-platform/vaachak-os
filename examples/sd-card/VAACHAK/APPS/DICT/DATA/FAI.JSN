{"FAIENCE":[{"def":"Glazed earthenware; esp.","pos":""}],"FAIL":[{"def":"To be wanting; to fall short; to be or become deficient in any measure or degree up to total absence; to cease to be furnished in the usual or expected manner, or to be altogether cut off from supply; to be lacking; as, streams fail; crops fail.","pos":""},{"def":"To be affected with want; to come short; to lack; to be deficient or unprovided; -- used with of.","pos":""}],"FAILANCE":[{"def":"Fault; failure; omission.","pos":""}],"FAILING":[{"def":"A failing short; a becoming deficient; failure; deficiency; imperfection; weakness; lapse; fault; infirmity; as, a mental failing.","pos":""},{"def":"The act of becoming insolvent of bankrupt.","pos":""}],"FAILLE":[{"def":"A soft silk, heavier than a foulard and not glossy.","pos":""}],"FAILURE":[{"def":"Cessation of supply, or total defect; a failing; deficiency; as, failure of rain; failure of crops.","pos":""},{"def":"Omission; nonperformance; as, the failure to keep a promise.","pos":""}],"FAIN":[{"def":"Well-pleased; glad; apt; wont; fond; inclined.","pos":""},{"def":"Satisfied; contented; also, constrained.","pos":""}],"FAINEANT":[{"def":"Doing nothing; shiftless.","pos":""},{"def":"A do-nothing; an idle fellow; a sluggard.","pos":""}],"FAINEANT DEITY":[{"def":"A deity recognized as real but conceived as not acting in human affairs, hence not worshiped.","pos":""}],"FAINT":[{"def":"Lacking strength; weak; languid; inclined to swoon; as, faint with fatigue, hunger, or thirst.","pos":""},{"def":"Wanting in courage, spirit, or energy; timorous; cowardly; dejected; depressed; as, \"Faint heart ne'er won fair lady.","pos":""}],"FAINTING":[{"def":"Syncope, or loss of consciousness owing to a sudden arrest of the blood supply to the brain, the face becoming pallid, the respiration feeble, and the heat's beat weak.","pos":""}],"FAINTISH":[{"def":"Slightly faint; somewhat faint.","pos":""}],"FAINTLING":[{"def":"Timorous; feeble-minded.","pos":""}],"FAINTLY":[{"def":"In a faint, weak, or timidmanner.","pos":""}],"FAINTNESS":[{"def":"The state of being faint; loss of strength, or of consciousness, and self-control.","pos":""},{"def":"Want of vigor or energy.","pos":""}],"FAINTS":[{"def":"The impure spirit which comes over first and last in the distillation of whisky; -- the former being called the strong faints, and the latter, which is much more abundant, the weak faints.","pos":"noun"}],"FAINTY":[{"def":"Feeble; languid.","pos":""}],"FAIR":[{"def":"Without sudden change of direction or curvature; smooth; fowing; -- said of the figure of a vessel, and of surfaces, water lines, and other lines.","pos":""}],"FAIR CATCH":[{"def":"A catch made by a player on side who makes a prescribed signal that he will not attempt to advance the ball when caught.","pos":""}],"FAIR-HAIRED":[{"def":"Having fair or light-colored hair.","pos":""}],"FAIR-LEADER":[{"def":"A block, or ring, serving as a guide for the running rigging or for any rope.","pos":""}],"FAIR-MINDED":[{"def":"Unprejudiced; just; judicial; honest.","pos":""}],"FAIR-SPOKEN":[{"def":"Using fair speech, or uttered with fairness; bland; civil; courteous; plausible.","pos":""}],"FAIR-WEATHER":[{"def":"Made or done in pleasant weather, or in circumstances involving but little exposure or sacrifice; as, a fair-weather voyage.","pos":""},{"def":"Appearing only when times or circumstances are prosperous; as, a fair-weather friend.","pos":""}],"FAIR-WORLD":[{"def":"State of prosperity.","pos":""}],"FAIRHOOD":[{"def":"Fairness; beauty.","pos":""}],"FAIRILY":[{"def":"In the manner of a fairy.","pos":""}],"FAIRING":[{"def":"A present; originally, one given or purchased at a fair.","pos":""}],"FAIRLY":[{"def":"In a fairmanner; clearly; openly; plainly; fully; distinctly; frankly.","pos":""},{"def":"Favorably; auspiciously; commodiously; as, a town fairly situated for foreign traade.","pos":""}],"FAIRNESS":[{"def":"The state of being fair, or free form spots or stains, as of the skin; honesty, as of dealing; candor, as of an argument, etc.","pos":""}],"FAIRWAY":[{"def":"The navigable part of a river, bay, etc.","pos":""}],"FAIRY":[{"def":"Enchantment; illusion.","pos":""},{"def":"The country of the fays; land of illusions.","pos":""}],"FAIRYLAND":[{"def":"The imaginary land or abode of fairies.","pos":""}],"FAIRYLIKE":[{"def":"Resembling a fairy, or what is made or done be fairies; as, fairylike music.","pos":""}],"FAITH":[{"def":"Belief; the assent of the mind to the truth of what is declared by another, resting solely and implicitly on his authority and veracity; reliance on testimony.","pos":""},{"def":"The assent of the mind to the statement or proposition of another, on the ground of the manifest truth of what he utters; firm and earnest belief, on probable evidence of any kind, especially in regard to important moral truth.","pos":""}],"FAITHED":[{"def":"Having faith or a faith; honest; sincere.","pos":""}],"FAITHFUL":[{"def":"Full of faith, or having faith; disposed to believe, especially in the declarations and promises of God.","pos":""},{"def":"Firm in adherence to promises, oaths, contracts, treaties, or other engagements.","pos":""}],"FAITHLESS":[{"def":"Not believing; not giving credit.","pos":""},{"def":"Not believing on God or religion; specifically, not believing in the Christian religion.","pos":""}],"FAITOUR":[{"def":"A doer or actor; particularly, an evil doer; a scoundrel.","pos":""}]}