{"DIT":[{"def":"A word; a decree.","pos":""},{"def":"A ditty; a song.","pos":""}],"DITATION":[{"def":"The act of making rich; enrichment.","pos":""}],"DITCH":[{"def":"A trench made in the earth by digging, particularly a trench for draining wet land, for guarding or fencing inclosures, or for preventing an approach to a town or fortress.","pos":""},{"def":"Any long, narrow receptacle for water on the surface of the earth.","pos":""}],"DITCHER":[{"def":"One who digs ditches.","pos":""}],"DITE":[{"def":"To prepare for action or use; to make ready; to dight.","pos":""}],"DITEREBENE":[{"def":"Having two thecæ, cells, or compartments.","pos":""}],"DITHEISM":[{"def":"The doctrine of those who maintain the existence of two gods or of two original principles (as in Manicheism), one good and one evil; dualism.","pos":""}],"DITHEIST":[{"def":"One who holds the doctrine of ditheism; a dualist.","pos":""},{"def":"Pertaining to ditheism; dualistic.","pos":""}],"DITHIONIC":[{"def":"Containing two equivalents of sulphur; as, dithionic acid.","pos":""}],"DITHYRAMB":[{"def":"A kind of lyric poetry in honor of Bacchus, usually sung by a band of revelers to a flute accompaniment; hence, in general, a poem written in a wild irregular strain.","pos":""}],"DITHYRAMBIC":[{"def":"Pertaining to, or resembling, a dithyramb; wild and boisterous.","pos":""},{"def":"A dithyrambic poem; a dithyramb.","pos":""}],"DITIONARY":[{"def":"Under rule; subject; tributary.","pos":""}],"DITOLYL":[{"def":"A white, crystalline, aromatic hydrocarbon, C14H14, consisting of two radicals or residues of toluene.","pos":""}],"DITONE":[{"def":"The Greek major third, which comprehend two major tones (the modern major third contains one major and one minor whole tone).","pos":""}],"DITRICHOTOMOUS":[{"def":"Dividing into double or treble ramifications; -- said of a leaf or stem.","pos":""}],"DITROCHEAN":[{"def":"Containing two trochees.","pos":""}],"DITROCHEE":[{"def":"A double trochee; a foot made up of two trochees.","pos":""}],"DITROITE":[{"def":"An igneous rock composed of orthoclase, elæolite, and sodalite.","pos":""}],"DITTANDER":[{"def":"A kind of peppergrass (Lepidium latifolium).","pos":""}],"DITTIED":[{"def":"Set, sung, or composed as a ditty; -- usually in composition.","pos":""}],"DITTO":[{"def":"The aforesaid thing; the same (as before).","pos":""}],"DITTOLOGY":[{"def":"A double reading, or twofold interpretation, as of a Scripture text.","pos":""}],"DITTY":[{"def":"A saying or utterance; especially, one that is short and frequently repeated; a theme.","pos":""},{"def":"A song; a lay; a little poem intended to be sung.","pos":""}],"DITTY-BAG":[{"def":"A sailor's small bag to hold thread, needles, tape, etc.","pos":""}],"DITTY-BOX":[{"def":"A small box to hold a sailor's thread, needless, comb, etc.","pos":""}]}