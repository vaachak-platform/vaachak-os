{"STEVE":[{"def":"To pack or stow, as cargo in a ship's hold.","pos":""}],"STEVEDORE":[{"def":"One whose occupation is to load and unload vessels in port; one who stows a cargo in a hold.","pos":""}],"STEVEN":[{"def":"Voice; speech; language.","pos":""},{"def":"An outcry; a loud call; a clamor.","pos":""}]}