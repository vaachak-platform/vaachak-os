{"UNWARE":[{"def":"Unaware; not foreseeing; being off one's guard.","pos":""},{"def":"Happening unexpectedly; unforeseen.","pos":""}],"UNWARES":[{"def":"Unawares; unexpectedly; -- sometimes preceded by at.","pos":""}],"UNWARILY":[{"def":"In an unwary manner.","pos":""}],"UNWARINESS":[{"def":"The quality or state of being unwary; carelessness; heedlessness.","pos":""}],"UNWARM":[{"def":"To lose warmth; to grow cold.","pos":""}],"UNWARP":[{"def":"To restore from a warped state; to cause to be linger warped.","pos":""}],"UNWARPED":[{"def":"Not warped; hence, not biased; impartial.","pos":""}],"UNWARRANTABLE":[{"def":"Not warrantable; indefensible; not vindicable; not justifiable; illegal; unjust; improper.","pos":""}],"UNWARRANTED":[{"def":"Not warranted; being without warrant, authority, or guaranty; unwarrantable.","pos":""}],"UNWARY":[{"def":"Not vigilant against danger; not wary or cautious; unguarded; precipitate; heedless; careless.","pos":""},{"def":"Unexpected; unforeseen; unware.","pos":""}],"UNWASHED":[{"def":"Not washed or cleansed; filthy; unclean.","pos":""}],"UNWAYED":[{"def":"Not used to travel; as, colts that are unwayed.","pos":""},{"def":"Having no ways or roads; pathless.","pos":""}],"UNWEARIED":[{"def":"Not wearied; not fatigued or tired; hence, persistent; not tiring or wearying; indefatigable.","pos":""}],"UNWEARY":[{"def":"To cause to cease being weary; to refresh.","pos":""}],"UNWEAVE":[{"def":"To unfold; to undo; to ravel, as what has been woven.","pos":""}],"UNWEDGEABLE":[{"def":"Not to be split with wedges.","pos":""}],"UNWEIGHED":[{"def":"Not weighed; not pondered or considered; as, an unweighed statement.","pos":""}],"UNWEIGHING":[{"def":"Not weighing or pondering; inconsiderate.","pos":""},{"def":"Unwieldy; unmanageable; clumsy.","pos":""}],"UNWELL":[{"def":"Specifically, ill from menstruation; affected with, or having, catamenial; menstruant.","pos":""}],"UNWELLNESS":[{"def":"Un*well\"ness Defn: , n.","pos":""}],"UNWEMMED":[{"def":"Not blemished; undefiled; pure.","pos":""}],"UNWHOLE":[{"def":"Not whole; unsound.","pos":""}],"UNWIELDY":[{"def":"Not easily wielded or carried; unmanageable; bulky; ponderous.","pos":""}],"UNWILD":[{"def":"To tame; to subdue.","pos":""}],"UNWILL":[{"def":"To annul or reverse by an act of the will.","pos":""}],"UNWILLED":[{"def":"Deprived of the faculty of will or volition.","pos":""}],"UNWILLING":[{"def":"Not willing; loath; disinclined; reluctant; as, an unwilling servant.","pos":""}],"UNWIND":[{"def":"To wind off; to loose or separate, as what or convolved; to untwist; to untwine; as, to unwind thread; to unwind a ball of yarn.","pos":""}],"UNWISDOM":[{"def":"Want of wisdom; unwise conduct or action; folly; simplicity; ignorance.","pos":""}],"UNWISE":[{"def":"Not wise; defective in wisdom; injudicious; indiscreet; foolish; as, an unwise man; unwise kings; unwise measures.","pos":""}],"UNWISELY":[{"def":"In an unwise manner; foolishly.","pos":""}],"UNWISH":[{"def":"To wish not to be; to destroy by wishing.","pos":""}],"UNWIST":[{"def":"Not known; unknown.","pos":""},{"def":"Not knowing; unwitting.","pos":""}],"UNWIT":[{"def":"To deprive of wit.","pos":""}],"UNWITCH":[{"def":"To free from a witch or witches; to fee from witchcraft.","pos":""}],"UNWITTING":[{"def":"Not knowing; unconscious; ignorant.","pos":""}],"UNWOMAN":[{"def":"To deprive of the qualities of a woman; to unsex.","pos":""}],"UNWONDER":[{"def":"To divest of the quality of wonder or mystery; to interpret; to explain.","pos":""}],"UNWONT":[{"def":"Unwonted; unused; unaccustomed.","pos":""}],"UNWONTED":[{"def":"Not wonted; unaccustomed; unused; not made familiar by practice; as, a child unwonted to strangers.","pos":""},{"def":"Uncommon; unusual; infrequent; rare; as, unwonted changes.","pos":""}],"UNWORK":[{"def":"To undo or destroy, as work previously done.","pos":""}],"UNWORLDLY":[{"def":"Not worldly; spiritual; holy.","pos":""}],"UNWORMED":[{"def":"Not wormed; not having had the worm, or lytta, under the tongue cut out; -- said of a dog.","pos":""}],"UNWORSHIP":[{"def":"To deprive of worship or due honor; to dishonor.","pos":""}],"UNWORTHY":[{"def":"Not worthy; wanting merit, value, or fitness; undeserving; worthless; unbecoming; -- often with of.","pos":""}],"UNWRAP":[{"def":"To open or undo, as what is wrapped or folded.","pos":""}],"UNWREATHE":[{"def":"To untwist, uncoil, or untwine, as anything wreathed.","pos":""}],"UNWRINKLE":[{"def":"To reduce from a wrinkled state; to smooth.","pos":""}],"UNWRITE":[{"def":"To cancel, as what is written; to erase.","pos":""}],"UNWRITTEN":[{"def":"Not written; not reduced to writing; oral; as, unwritten agreements.","pos":""},{"def":"Containing no writing; blank; as, unwritten paper.","pos":""}],"UNWROKEN":[{"def":"Not revenged; unavenged.","pos":""}]}