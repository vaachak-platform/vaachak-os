{"NEGATION":[{"def":"Description or definition by denial, exclusion, or exception; statement of what a thing is not, or has not, from which may be inferred what it is or has.","pos":""}],"NEGATIVE":[{"def":"Asserting absence of connection between a subject and a predicate; as, a negative proposition.","pos":""},{"def":"Of or pertaining to a picture upon glass or other material, in which the lights and shades of the original, and the relations of right and left, are reversed.","pos":""}],"NEGATIVELY":[{"def":"The quality or state of being negative.","pos":""}],"NEGATORY":[{"def":"Expressing denial; belonging to negation; negative.","pos":""}],"NEGINOTH":[{"def":"Stringed instruments.","pos":""}],"NEGLECT":[{"def":"Not to attend to with due care or attention; to forbear one's duty in regard to; to suffer to pass unimproved, unheeded, undone, etc.","pos":""},{"def":"To omit to notice; to forbear to treat with attention or respect; to slight; as, to neglect strangers.","pos":""}],"NEGLECTEDNESS":[{"def":"The state of being neglected.","pos":""}],"NEGLECTER":[{"def":"One who neglects.","pos":""}],"NEGLECTFUL":[{"def":"Full of neglect; heedless; careless; negligent; inattentive; indifferent.","pos":""}],"NEGLECTINGLY":[{"def":"Carelessly; heedlessly.","pos":""}],"NEGLECTION":[{"def":"The state of being negligent; negligence.","pos":""}],"NEGLIGEE":[{"def":"An easy, unceremonious attire; undress; also, a kind of easy robe or dressing gown worn by women.","pos":""}],"NEGLIGENCE":[{"def":"The quality or state of being negligent; lack of due diligence or care; omission of duty; habitual neglect; heedlessness.","pos":""},{"def":"The omission of the care usual under the circumstances, being convertible with the Roman culpa.","pos":""}],"NEGLIGENT":[{"def":"Apt to neglect; customarily neglectful; characterized by negligence; careless; heedless; culpably careless; showing lack of attention; as, disposed in negligent order.","pos":""}],"NEGLIGENTLY":[{"def":"In a negligent manner.","pos":""}],"NEGLIGIBLE":[{"def":"That may neglicted, disregarded, or left out of consideration.","pos":""}],"NEGOCE":[{"def":"Business; occupation.","pos":""}],"NEGOTIABILITY":[{"def":"The quality of being negotiable or transferable by indorsement.","pos":""}],"NEGOTIABLE":[{"def":"Capable of being negotiated; transferable by assigment or indorsement to another person; as, a negotiable note or bill of exchange.","pos":""}],"NEGOTIATE":[{"def":"To transact business; to carry on trade.","pos":""},{"def":"To treat with another respecting purchase and sale or some business affair; to bargain or trade; as, to negotiate with a man for the purchase of goods or a farm.","pos":""}],"NEGOTIATION":[{"def":"The act or process of negotiating; a treating with another respecting sale or purchase.","pos":""},{"def":"Hence, mercantile business; trading.","pos":""}],"NEGOTIATOR":[{"def":"One who negotiates; a person who treats with others, either as principal or agent, in respect to purchase and sale, or public compacts.","pos":""}],"NEGOTIATORY":[{"def":"Of or pertaining to negotiation.","pos":""}],"NEGOTIATRIX":[{"def":"A woman who negotiates.","pos":""}],"NEGOTIOSITY":[{"def":"The state of being busy; multitude of business.","pos":""}],"NEGOTIOUS":[{"def":"Very busy; attentive to business; active.","pos":""}],"NEGOTIOUSNESS":[{"def":"The state of being busily occupied; activity.","pos":""}],"NEGRESS":[{"def":"A black woman; a female negro.","pos":""}],"NEGRITA":[{"def":"A blackish fish (Hypoplectrus nigricans), of the Sea-bass family.","pos":""}],"NEGRITIC":[{"def":"Of or pertaining to negroes; composed of negroes.","pos":""}],"NEGRITOS":[{"def":"A degraded Papuan race, inhabiting Luzon and some of the other east Indian Islands.","pos":""}],"NEGRO":[{"def":"A black man; especially, one of a race of black or very dark persons who inhabit the greater part of tropical Africa, and are distinguished by crisped or curly hair, flat noses, and thick protruding lips; also, any black person of unmixed African blood, wherever found.","pos":""}],"NEGROHEAD":[{"def":"An inferior commercial variety of India rubber made up into round masses.","pos":""}],"NEGROID":[{"def":"Characteristic of the negro.","pos":""},{"def":"Resembling the negro or negroes; of or pertaining to those who resemble the negro.","pos":""}],"NEGUS":[{"def":"A beverage made of wine, water, sugar, nutmeg, and lemon juice; -- so called, it is said, from its first maker, Colonel Negus.","pos":""}]}