{"DEMAGNETIZE":[{"def":"To deprive of magnetic properties.","pos":""},{"def":"To free from mesmeric influence; to demesmerize.","pos":""}],"DEMAGOG":[{"def":"Relating to, or like, a demagogue; factious.","pos":""}],"DEMAGOGISM":[{"def":"The practices of a demagogue.","pos":""}],"DEMAGOGUE":[{"def":"A leader of the rabble; one who attempts to control the multitude by specious or deceitful arts; an unprincipled and factious mob orator or political leader.","pos":""}],"DEMAIN":[{"def":"Rule; management.","pos":""}],"DEMAND":[{"def":"To call into court; to summon.","pos":""}],"DEMANDABLE":[{"def":"That may be demanded or claimed.","pos":""}],"DEMANDANT":[{"def":"One who demands; the plaintiff in a real action; any plaintiff.","pos":""}],"DEMANDER":[{"def":"One who demands.","pos":""}],"DEMANDRESS":[{"def":"A woman who demands.","pos":""}],"DEMANTOID":[{"def":"A yellow-green, transparent variety of garnet found in the Urals.","pos":""}],"DEMARCATE":[{"def":"To mark by bounds; to set the limits of; to separate; to discriminate.","pos":""}],"DEMARCATION":[{"def":"The act of marking, or of ascertaining and setting a limit; separation; distinction.","pos":""}],"DEMARCH":[{"def":"March; walk; gait.","pos":""}],"DEMARKATION":[{"def":"Same as Demarcation.","pos":""}],"DEMATERIALIZE":[{"def":"To deprive of material or physical qualities or characteristics.","pos":""}]}