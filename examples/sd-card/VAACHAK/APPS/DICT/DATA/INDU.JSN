{"INDUBIOUS":[{"def":"Not dubious or doubtful; certain.","pos":""},{"def":"Not doubting; unsuspecting.","pos":""}],"INDUBITABLE":[{"def":"Not dubitable or doubtful; too evident to admit of doubt; unquestionable; evident; apparently certain; as, an indubitable conclusion.","pos":""},{"def":"That which is indubitable.","pos":""}],"INDUBITABLENESS":[{"def":"The state or quality of being indubitable.","pos":""}],"INDUBITABLY":[{"def":"Undoubtedly; unquestionably; in a manner to remove all doubt.","pos":""}],"INDUBITATE":[{"def":"Not questioned or doubtful; evident; certain.","pos":""}],"INDUCE":[{"def":"To produce, or cause, by proximity without contact or transmission, as a particular electric or magnetic condition in a body, by the approach of another body in an opposite electric or magnetic state.","pos":""},{"def":"To generalize or conclude as an inference from all the particulars; -- the opposite of deduce.","pos":""}],"INDUCED CURRENT":[{"def":"A current due to variation in the magnetic field surrounding its conductor.","pos":""}],"INDUCEMENT":[{"def":"Matter stated by way of explanatory preamble or introduction to the main allegations of a pleading; a leading to.","pos":""}],"INDUCER":[{"def":"One who, or that which, induces or incites.","pos":""}],"INDUCIBLE":[{"def":"Capable of being induced, caused, or made to take place.","pos":""},{"def":"Obtainable by induction; derivable; inferable.","pos":""}],"INDUCT":[{"def":"To bring in; to introduce; to usher in.","pos":""},{"def":"To introduce, as to a benefice or office; to put in actual possession of the temporal rights of an ecclesiastical living, or of any other office, with the customary forms and ceremonies.","pos":""}],"INDUCTANCE":[{"def":"Capacity for induction; the coefficient of self-induction.","pos":""}],"INDUCTEOUS":[{"def":"Rendered electro-polar by induction, or brought into the opposite electrical state by the influence of inductive bodies.","pos":""}],"INDUCTILE":[{"def":"Not ductile; incapable of being drawn into threads, as a metal; inelastic; tough.","pos":""}],"INDUCTILITY":[{"def":"The quality or state of being inductile.","pos":""}],"INDUCTION":[{"def":"The act or process of reasoning from a part to a whole, from particulars to generals, or from the individual to the universal; also, the result or inference so reached.","pos":""},{"def":"A process of demonstration in which a general truth is gathered from an examination of particular cases, one of which is known to be true, the examination being so conducted that each case is made to depend on the preceding one; -- called also successive induction.","pos":""}],"INDUCTION GENERATOR":[{"def":"A machine built as an induction motor and driven above synchronous speed, thus acting as an alternating-current generator; - - called also asynchronous generator.","pos":""}],"INDUCTION MOTOR":[{"def":"A type of alternating-current motor comprising two wound members, one stationary, called the stator, and the other rotating, called the rotor, these two members corresponding to a certain extent to the field and armature of a direct-current motor.","pos":""}],"INDUCTIONAL":[{"def":"Pertaining to, or proceeding by, induction; inductive.","pos":""}],"INDUCTIVE":[{"def":"Leading or drawing; persuasive; tempting; -- usually followed by to.","pos":""},{"def":"Tending to induce or cause.","pos":""}],"INDUCTIVELY":[{"def":"By induction or inference.","pos":""}],"INDUCTOMETER":[{"def":"An instrument for measuring or ascertaining the degree or rate of electrical induction.","pos":""}],"INDUCTOR":[{"def":"That portion of an electrical apparatus, in which is the inducing charge or current.","pos":""}],"INDUCTORIUM":[{"def":"An induction coil.","pos":""},{"def":"Acting by, or in a state of, induction; relating to electrical induction.","pos":""}],"INDUE":[{"def":"To put on, as clothes; to draw on.","pos":""},{"def":"To clothe; to invest; hence, to endow; to furnish; to supply with moral or mental qualities.","pos":""}],"INDUEMENT":[{"def":"The act of induing, or state of being indued; investment; endowment.","pos":""}],"INDULGE":[{"def":"To be complacent toward; to give way to; not to oppose or restrain; (a) when said of a habit, desire, etc.","pos":""},{"def":"To grant as by favor; to bestow in concession, or in compliance with a wish or request.","pos":""}],"INDULGENCE":[{"def":"Remission of the temporal punishment due to sins, after the guilt of sin has been remitted by sincere repentance; absolution from the censures and public penances of the church.","pos":""}],"INDULGENT":[{"def":"Prone to indulge; yielding to the wishes, humor, or appetites of those under one's care; compliant; not opposing or restraining; tolerant; mild; favorable; not severe; as, an indulgent parent.","pos":""}],"INDULGENTIAL":[{"def":"Relating to the indulgences of the Roman Catholic Church.","pos":""}],"INDULGENTLY":[{"def":"In an indulgent manner; mildly; favorably.","pos":""}],"INDULGER":[{"def":"One who indulges.","pos":""}],"INDULINE":[{"def":"A duty levied on all importations.","pos":""}],"INDUMENT":[{"def":"Plumage; feathers.","pos":""}],"INDURATE":[{"def":"Hardened; not soft; indurated.","pos":""},{"def":"Without sensibility; unfeeling; obdurate.","pos":""}],"INDURATED":[{"def":"Hardened; as, indurated clay; an indurated heart.","pos":""}],"INDURATION":[{"def":"The act of hardening, or the process of growing hard.","pos":""},{"def":"State of being indurated, or of having become hard.","pos":""}],"INDUSIAL":[{"def":"Of, pertaining to, or containing, the petrified cases of the larvæ of certain insects.","pos":""},{"def":"Furnished with an indusium.","pos":""}],"INDUSTRIAL":[{"def":"Consisting in industry; pertaining to industry, or the arts and products of industry; concerning those employed in labor, especially in manual labor, and their wages, duties, and rights.","pos":""}],"INDUSTRIALISM":[{"def":"Devotion to industrial pursuits; labor; industry.","pos":""},{"def":"The principles or policy applicable to industrial pursuits or organized labor.","pos":""}],"INDUSTRIALLY":[{"def":"With reference to industry.","pos":""}],"INDUSTRIOUS":[{"def":"Given to industry; characterized by diligence; constantly, regularly, or habitually occupied; busy; assiduous; not slothful or idle; -- commonly implying devotion to lawful and useful labor.","pos":""},{"def":"Steadily and perseveringly active in a particular pursuit or aim; as, he was negligent in business, but industrious in pleasure; an industrious mischief maker.","pos":""}],"INDUSTRY":[{"def":"Human exertion of any kind employed for the creation of value, and regarded by some as a species of capital or wealth; labor.","pos":""}],"INDUTIVE":[{"def":"Covered; -- applied to seeds which have the usual integumentary covering.","pos":""}],"INDUVIAE":[{"def":"Persistent portions of a calyx or corolla; also, leaves which do not disarticulate from the stem, and hence remain for a long time.","pos":""}],"INDUVIATE":[{"def":"Covered with induviæ, as the upper part of the trunk of a palm tree.","pos":""}]}