{"SERE":[{"def":"But with its sound it shook the sails That were so thin and sere.","pos":""}],"SEREIN":[{"def":"A mist, or very fine rain, which sometimes falls from a clear sky a few moments after sunset.","pos":""}],"SERENADE":[{"def":"To entertain with a serenade.","pos":""}],"SERENADER":[{"def":"One who serenades.","pos":""},{"def":"A piece of vocal music, especially one on an amoreus subject; a serenade.","pos":""}],"SERENE":[{"def":"Bright; clear; unabscured; as, a serene sky.","pos":""},{"def":"Calm; placid; undisturbed; unruffled; as, a serene aspect; a serene soul.","pos":""}],"SERENELY":[{"def":"In a serene manner; clearly.","pos":""},{"def":"With unruffled temper; coolly; calmly.","pos":""}],"SERENITY":[{"def":"The quality or state of being serene; clearness and calmness; quietness; stillness; peace.","pos":""},{"def":"Calmness of mind; eveness of temper; undisturbed state; coolness; composure.","pos":""}]}