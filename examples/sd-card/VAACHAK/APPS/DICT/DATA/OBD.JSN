{"OBDIPLOSTEMONOUS":[{"def":"Having twice as many stamens as petals, those of the outer set being opposite the petals; -- said of flowers.","pos":""}],"OBDIPLOSTEMONY":[{"def":"The condition of being obdiplostemonous.","pos":""}],"OBDUCE":[{"def":"To draw over, as a covering.","pos":""}],"OBDUCT":[{"def":"To draw over; to cover.","pos":""}],"OBDURACY":[{"def":"The duality or state of being obdurate; invincible hardness of heart; obstinacy.","pos":""}],"OBDURATE":[{"def":"Hardened in feelings, esp.","pos":""},{"def":"Hard; harsh; rugged; rough; intractable.","pos":""}],"OBDURATION":[{"def":"A hardening of the heart; hardness of heart.","pos":""}],"OBDURE":[{"def":"OBDURE; OBDURED Ob*dure\", Ob*dured\", a.","pos":""}]}