{"DAM":[{"def":"A female parent; -- used of beasts, especially of quadrupeds; sometimes applied in contempt to a human mother.","pos":""},{"def":"A kind or crowned piece in the game of draughts.","pos":""}],"DAMAGE":[{"def":"The estimated reparation in money for detriment or injury sustained; a compensation, recompense, or satisfaction to one party, for a wrong or injury actually done to him by another.","pos":""}],"DAMAGE FEASANT":[{"def":"Doing injury; trespassing, as cattle.","pos":""}],"DAMAGEABLE":[{"def":"Capable of being injured or impaired; liable to, or susceptible of, damage; as, a damageable cargo.","pos":""},{"def":"Hurtful; pernicious.","pos":""}],"DAMAN":[{"def":"A small herbivorous mammal of the genus Hyrax.","pos":""}],"DAMARA":[{"def":"A native of Damaraland, German Southwest Africa.","pos":""}],"DAMASCENE":[{"def":"Of or relating to Damascus.","pos":""}],"DAMASCUS":[{"def":"A city of Syria.","pos":""}],"DAMASCUS STEEL":[{"def":"See Damask steel, under Damask.","pos":""}],"DAMASK":[{"def":"Damask silk; silk woven with an elaborate pattern of flowers and the like.","pos":""},{"def":"Linen so woven that a pattern in produced by the different directions of the thread, without contrast of color.","pos":""}],"DAMASKIN":[{"def":"A sword of Damask steel.","pos":""}],"DAMASSE":[{"def":"Woven like damask.","pos":""},{"def":"A damassé fabric, esp.","pos":""}],"DAMASSIN":[{"def":"A kind of modified damask or blocade.","pos":""}],"DAMBONITE":[{"def":"A white crystalline, sugary substance obtained from an African caotchouc.","pos":""}],"DAMBOSE":[{"def":"A crystalline vari ety of fruit sugar obtained from dambonite.","pos":""}],"DAME":[{"def":"A mistress of a family, who is a lady; a womam in authority; especially, a lady.","pos":""},{"def":"The mistress of a family in common life, or the mistress of a common school; as, a dame's school.","pos":""}],"DAMEWORT":[{"def":"A cruciferrous plant (Hesperis matronalis), remarkable for its fragrance, especially toward the close of the day; -- called also rocket and dame's violet.","pos":""}],"DAMIANA":[{"def":"A Mexican drug, used as an aphrodisiac.","pos":""}],"DAMIANIST":[{"def":"A follower of Damian, patriarch of Alexandria in the 6th century, who held heretical opinions on the doctrine of the Holy Trinity.","pos":""},{"def":"An oleoresin used in making varnishes; dammar gum; dammara resin.","pos":""}],"DAMMARA":[{"def":"A large tree of the order Coniferæ, indigenous to the East Indies and Australasia; -- called also Agathis.","pos":""}],"DAMN":[{"def":"To doom to punishment in the future world; to consign to perdition; to curse.","pos":""}],"DAMNABILITY":[{"def":"The quality of being damnable; damnableness.","pos":""}],"DAMNABLE":[{"def":"Liable to damnation; deserving, or for which one deserves, to be damned; of a damning nature.","pos":""},{"def":"Odious; pernicious; detestable.","pos":""}],"DAMNABLENESS":[{"def":"The state or quality of deserving damnation; execrableness.","pos":""}],"DAMNABLY":[{"def":"In a manner to incur sever 2.","pos":""}],"DAMNATION":[{"def":"Condemnation to everlasting punishment in the future state, or the punishment itself.","pos":""}],"DAMNATORY":[{"def":"Doo \"Damnatory invectives.","pos":""}],"DAMNED":[{"def":"Sentenced to punishment in a future state; condemned; consigned to perdition.","pos":""},{"def":"Hateful; detestable; abominable.","pos":""}],"DAMNIFIC":[{"def":"Procuring or causing loss; mischievous; injurious.","pos":""}],"DAMNIFICATION":[{"def":"That which causes damage or loss.","pos":""}],"DAMNIFY":[{"def":"To cause loss or damage to; to injure; to imparir.","pos":""}],"DAMNING":[{"def":"That damns; damnable; as, damning evidence of guilt.","pos":""}],"DAMNINGNESS":[{"def":"Tendency to bring damnation.","pos":""}],"DAMNUM":[{"def":"Harm; detriment, either to character or property.","pos":""}],"DAMOURITE":[{"def":"A kind of Muscovite, or potash mica, containing water.","pos":""}],"DAMP":[{"def":"A gaseous prodact, formed in coal mines, old wells, pints, etc.","pos":""}],"DAMP OFF":[{"def":"To decay and perish through excessive moisture.","pos":""}],"DAMPEN":[{"def":"To make damp or moist; to make slightly wet.","pos":""},{"def":"To depress; to check; to make dull; to lessen.","pos":""}],"DAMPER":[{"def":"That which damps or checks; as: (a) A valve or movable plate in the flue or other part of a stove, furnace, etc.","pos":""}],"DAMPISH":[{"def":"Moderately damp or moist.","pos":""}],"DAMPNESS":[{"def":"Moderate humidity; moisture; fogginess; moistness.","pos":""}],"DAMPY":[{"def":"Dejected; gloomy; sorrowful.","pos":""}],"DAMSEL":[{"def":"A young person, either male or female, of noble or gentle extraction; as, Damsel Pepin; Damsel Richard, Prince of Wales.","pos":""},{"def":"A young unmarried woman; a gerl; a maiden.","pos":""}],"DAMSON":[{"def":"A small oval plum of a blue color, the fruit of a variety of the Prunus domestica; -- called also damask plum.","pos":""}]}