{"SUBULICORNES":[{"def":"A division of insects having slender or subulate antennæ.","pos":""}],"SUBULIPALP":[{"def":"One of a group of carabid beetles having slender palpi.","pos":""}],"SUBUMBONAL":[{"def":"Beneath or forward of the umbos of a bivalve shell.","pos":""}],"SUBUMBRELLA":[{"def":"The integument of the under surface of the bell, or disk-shaped body, of a jellyfish.","pos":""}],"SUBUNDATION":[{"def":"A flood; a deluge.","pos":""}],"SUBUNGUAL":[{"def":"Under the nail or hoof.","pos":""}],"SUBURB":[{"def":"An outlying part of a city or town; a smaller place immediately adjacent to a city; in the plural, the region which is on the confines of any city or large town; as, a house stands in the suburbs; a garden situated in the suburbs of Paris.","pos":""},{"def":"Hence, the confines; the outer part; the environment.","pos":""}],"SUBURBAN":[{"def":"Of or pertaining to suburbs; inhabiting, or being in, the suburbs of a city.","pos":""}],"SUBURBED":[{"def":"Having a suburb or suburbs on its outer part.","pos":""}],"SUBURETHRAL":[{"def":"Situated under the urethra, or under its orifice.","pos":""}]}