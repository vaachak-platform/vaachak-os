{"EVICT":[{"def":"To dispossess by a judicial process; to dispossess by paramount right or claim of such right; to eject; to oust.","pos":""}],"EVICTION":[{"def":"The act or process of evicting; or state of being evicted; the recovery of lands, tenements, etc.","pos":""},{"def":"Conclusive evidence; proof.","pos":""}],"EVIDENCE":[{"def":"That which is legally submitted to competent tribunal, as a means of ascertaining the truth of any alleged matter of fact under investigation before it; means of making proof; -- the latter, strictly speaking, not being synonymous with evidence, but rather the effect of it.","pos":""}],"EVIDENCER":[{"def":"One whi gives evidence.","pos":""}],"EVIDENT":[{"def":"Clear to the vision; especially, clear to the understanding, and satisfactory to the judgment; as, the figure or color of a body is evident to the senses; the guilt of an offender can not always be made evident.","pos":""}],"EVIDENTIAL":[{"def":"Relating to, or affording, evidence; indicative; especially, relating to the evidences of Christianity.","pos":""}],"EVIDENTIARY":[{"def":"Furnishing evidence; asserting; proving; evidential.","pos":""}],"EVIDENTLY":[{"def":"In an evident manner; clearly; plainly.","pos":""}],"EVIDENTNESS":[{"def":"State of being evident.","pos":""}],"EVIGILATION":[{"def":"A waking up or awakening.","pos":""}],"EVIL":[{"def":"Having qualities tending to injury and mischief; having a nature or properties which tend to badness; mischievous; not good; worthless or deleterious; poor; as, an evil beast; and evil plant; an evil crop.","pos":""},{"def":"Having or exhibiting bad moral qualities; morally corrupt; wicked; wrong; vicious; as, evil conduct, thoughts, heart, words, and the like.","pos":""}],"EVIL-EYED":[{"def":"Possessed of the supposed evil eye; also, looking with envy, jealousy, or bad design; malicious.","pos":""}],"EVIL-FAVORED":[{"def":"Having a bad countenance or appearance; ill-favored; blemished; deformed.","pos":""}],"EVIL-MINDED":[{"def":"Having evil dispositions or intentions; disposed to mischief or sin; malicious; malignant; wicked.","pos":""}],"EVILLY":[{"def":"In an evil manner; not well; ill.","pos":""}],"EVILNESS":[{"def":"The condition or quality of being evil; badness; viciousness; malignity; vileness; as, evilness of heart; the evilness of sin.","pos":""}],"EVINCE":[{"def":"To conquer; to subdue.","pos":""},{"def":"To show in a clear manner; to prove beyond any reasonable doubt; to manifest; to make evident; to bring to light; to evidence.","pos":""}],"EVINCEMENT":[{"def":"The act of evincing or proving, or the state of being evinced.","pos":""}],"EVINCIBLE":[{"def":"Capable of being proved or clearly brought to light; demonstrable.","pos":""}],"EVINCIVE":[{"def":"Tending to prove; having the power to demonstrate; demonstrative; indicative.","pos":""}],"EVIRATE":[{"def":"To emasculate; to dispossess of manhood.","pos":""}],"EVISCERATE":[{"def":"To take out the entrails of; to disembowel; to gut.","pos":""}],"EVISCERATION":[{"def":"A disemboweling.","pos":""}],"EVITATE":[{"def":"To shun; to avoid.","pos":""}],"EVITATION":[{"def":"A shunning; avoidance.","pos":""}],"EVITERNAL":[{"def":"Eternal; everlasting.","pos":""}]}