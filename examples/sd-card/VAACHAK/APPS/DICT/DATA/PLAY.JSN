{"PLAY":[{"def":"To engage in sport or lively recreation; to exercise for the sake of amusement; to frolic; to spot.","pos":""},{"def":"To act with levity or thoughtlessness; to trifle; to be careless.","pos":""}],"PLAYA":[{"def":"A beach; a strand; in the plains and deserts of Texas, New Mexico, and Arizona, a broad, level spot, on which subsequently becomes dry by evaporation.","pos":""}],"PLAYBILL":[{"def":"A printed programme of a play, with the parts assigned to the actors.","pos":""}],"PLAYBOOK":[{"def":"A book of dramatic compositions; a book of the play.","pos":""}],"PLAYDAY":[{"def":"A day given to play or diversion; a holiday.","pos":""}],"PLAYER":[{"def":"One who plays, or amuses himself; one without serious aims; an idler; a trifler.","pos":""},{"def":"One who plays any game.","pos":""}],"PLAYFELLOW":[{"def":"A companion in amusements or sports; a playmate.","pos":""}],"PLAYFUL":[{"def":"Sportive; gamboling; frolicsome; indulging a sportive fancy; humorous; merry; as, a playful child; a playful writer.","pos":""}],"PLAYGAME":[{"def":"Play of children.","pos":""}],"PLAYGOER":[{"def":"One who frequents playhouses, or attends dramatic performances.","pos":""}],"PLAYGOING":[{"def":"Frequenting playhouses; as, the playgoing public.","pos":""},{"def":"The practice of going to plays.","pos":""}],"PLAYGROUND":[{"def":"A piece of ground used for recreation; as, the playground of a school.","pos":""}],"PLAYHOUSE":[{"def":"A building used for dramatic exhibitions; a theater.","pos":""},{"def":"A house for children to play in; a toyhouse.","pos":""}],"PLAYMATE":[{"def":"A companion in diversions; a playfellow.","pos":""}],"PLAYSOME":[{"def":"Playful; wanton; sportive.","pos":""}],"PLAYTHING":[{"def":"A thing to play with; a toy; anything that serves to amuse.","pos":""}],"PLAYTIME":[{"def":"Time for play or diversion.","pos":""}],"PLAYWRIGHT":[{"def":"A maker or adapter of plays.","pos":""}],"PLAYWRITER":[{"def":"A writer of plays; a dramatist; a playwright.","pos":""}]}