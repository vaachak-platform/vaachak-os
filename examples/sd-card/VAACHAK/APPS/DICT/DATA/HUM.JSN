{"HUM":[{"def":"To make an inarticulate sound, like h'm, through the nose in the process of speaking, from embarrassment or a affectation; to hem.","pos":""}],"HUMAN":[{"def":"Belonging to man or mankind; having the qualities or attributes of a man; of or pertaining to man or to the race of man; as, a human voice; human shape; human nature; human sacrifices.","pos":""}],"HUMANATE":[{"def":"Indued with humanity.","pos":""}],"HUMANE":[{"def":"Pertaining to man; human.","pos":""},{"def":"Having the feelings and inclinations creditable to man; having a disposition to treat other human beings or animals with kindness; kind; benevolent.","pos":""}],"HUMANICS":[{"def":"The study of human nature.","pos":""}],"HUMANIFY":[{"def":"To make human; to invest with a human personality; to incarnate.","pos":""}],"HUMANISM":[{"def":"Human nature or disposition; humanity.","pos":""},{"def":"The study of the humanities; polite learning.","pos":""}],"HUMANIST":[{"def":"One of the scholars who in the field of literature proper represented the movement of the Renaissance, and early in the 16th century adopted the name Humanist as their distinctive title.","pos":""},{"def":"One who purposes the study of the humanities, or polite literature.","pos":""}],"HUMANISTIC":[{"def":"Of or pertaining to humanity; as, humanistic devotion.","pos":""},{"def":"Pertaining to polite kiterature.","pos":""}],"HUMANITARIAN":[{"def":"Pertaining to humanitarians, or to humanitarianism; as, a humanitarian view of Christ's nature.","pos":""},{"def":"Content with right affections and actions toward man; ethical, as distinguished from religious; believing in the perfectibility of man's nature without supernatural aid.","pos":""}],"HUMANITARIANISM":[{"def":"The distinctive tenet of the humanitarians in denying the divinity of Christ; also, the whole system of doctrine based upon this view of Christ.","pos":""},{"def":"The doctrine that man's obligations are limited to, and dependent alone upon, man and the human relations.","pos":""}],"HUMANITY":[{"def":"The branches of polite or elegant learning; as language, rhetoric, poetry, and the ancient classics; belles-letters.","pos":""}],"HUMANIZATION":[{"def":"The act of humanizing.","pos":""}],"HUMANIZE":[{"def":"To convert into something human or belonging to man; as, to humanize vaccine lymph.","pos":""}],"HUMANIZER":[{"def":"One who renders humane.","pos":""}],"HUMANLY":[{"def":"In a human manner; after the manner of men; according to the knowledge or wisdom of men; as, the present prospects, humanly speaking, promise a happy issue.","pos":""},{"def":"Kindly; humanely.","pos":""}],"HUMANNESS":[{"def":"The quality or state of being human.","pos":""}],"HUMATE":[{"def":"A salt of humic acid.","pos":""}],"HUMATION":[{"def":"Interment; inhumation.","pos":""}],"HUMBLE":[{"def":"Near the ground; not high or lofty; not pretentious or magnificent; unpretending; unassuming; as, a humble cottage.","pos":""},{"def":"Thinking lowly of one's self; claiming little for one's self; not proud, arrogant, or assuming; thinking one's self ill-deserving or unworthy, when judged by the demands of God; lowly; waek; modest.","pos":""}],"HUMBLEHEAD":[{"def":"Humble condition or estate; humility.","pos":""}],"HUMBLENESS":[{"def":"The quality of being humble; humility; meekness.","pos":""}],"HUMBLER":[{"def":"One who, or that which, humbles some one.","pos":""}],"HUMBLES":[{"def":"Entrails of a deer.","pos":""}],"HUMBLESSE":[{"def":"Humbleness; abasement; low obeisance.","pos":""}],"HUMBLY":[{"def":"With humility; lowly.","pos":""}],"HUMBUG":[{"def":"An imposition under fair pretenses; something contrived in order to deceive and mislead; a trick by cajolery; a hoax.","pos":""},{"def":"A spirit of deception; cajolery; trickishness.","pos":""}],"HUMBUGGER":[{"def":"One who humbugs.","pos":""}],"HUMBUGGERY":[{"def":"The practice of imposition.","pos":""}],"HUMDRUM":[{"def":"Monotonous; dull; commonplace.","pos":""}],"HUMECTANT":[{"def":"A diluent drink or medicine.","pos":""}],"HUMECTIVE":[{"def":"Tending to moisten.","pos":""}],"HUMERAL":[{"def":"Of or pertaining to the humerus, or upper part of the arm; brachial.","pos":""}],"HUMIC":[{"def":"Pertaining to, or derived from, vegetable mold; as, humic acid.","pos":""}],"HUMICUBATION":[{"def":"The act or practice of lying on the ground.","pos":""}],"HUMID":[{"def":"Containing sensible moisture; damp; moist; as, a humidair or atmosphere; somewhat wet or watery; as, humid earth; consisting of water or vapor.","pos":""}],"HUMIDITY":[{"def":"Moisture; dampness; a moderate degree of wetness, which is perceptible to the eye or touch; -- used especially of the atmosphere, or of anything which has absorbed moisture from the atmosphere, as clothing.","pos":""}],"HUMIFUSE":[{"def":"Spread over the surface of the ground; procumbent.","pos":""}],"HUMILIANT":[{"def":"Humiliating; humbling.","pos":""}],"HUMILIATE":[{"def":"To reduce to a lower position in one's own eyes, or in the eyes of others; to humble; to mortify.","pos":""}],"HUMILIATION":[{"def":"The act of humiliating or humbling; abasement of pride; mortification.","pos":""},{"def":"The state of being humiliated, humbled, or reduced to lowliness or submission.","pos":""}],"HUMILITY":[{"def":"The state or quality of being humble; freedom from pride and arrogance; lowliness of mind; a modest estimate of one's own worth; a sense of one's own unworthiness through imperfection and sinfulness; self-abasement; humbleness.","pos":""},{"def":"An act of submission or courtesy.","pos":""}],"HUMIN":[{"def":"A bitter, brownish yellow, amorphous substance, extracted from vegetable mold, and also produced by the action of acids on certain sugars and carbohydrates; -- called also humic acid, ulmin, gein, ulmic or geic acid, etc.","pos":""}],"HUMIRI":[{"def":"A fragrant balsam obtained from Brazilian trees of the genus Humirium.","pos":""}],"HUMITE":[{"def":"A mineral of a transparent vitreous brown color, found in the ejected masses of Vesuvius.","pos":""}],"HUMMEL":[{"def":"To separate from the awns; -- said of barley.","pos":""}],"HUMMELER":[{"def":"One who, or a machine which, hummels.","pos":""}],"HUMMER":[{"def":"One who, or that which, hums; one who applauds by humming.","pos":""}],"HUMMING":[{"def":"Emitting a murmuring sound; droning; murmuring; buzzing.","pos":""}],"HUMMOCK":[{"def":"A rounded knoll or hillock; a rise of ground of no great extent, above a level surface.","pos":""},{"def":"A ridge or pile of ice on an ice field.","pos":""}],"HUMMOCKING":[{"def":"The process of forming hummocks in the collision of Arctic ice.","pos":""}],"HUMMOCKY":[{"def":"Abounding in hummocks.","pos":""}],"HUMMUM":[{"def":"A sweating bath or place for sweating.","pos":""}],"HUMOR":[{"def":"A vitiated or morbid animal fluid, such as often causes an eruption on the skin.","pos":""},{"def":"Changing and uncertain states of mind; caprices; freaks; vagaries; whims.","pos":""}],"HUMORAL":[{"def":"Pertaining to, or proceeding from, the humors; as, a humoral fever.","pos":""}],"HUMORALISM":[{"def":"The state or quality of being humoral.","pos":""},{"def":"The doctrine that diseases proceed from the humors; humorism.","pos":""}],"HUMORALIST":[{"def":"One who favors the humoral pathology or believes in humoralism.","pos":""}],"HUMORISM":[{"def":"The theory founded on the influence which the humors were supposed to have in the production of disease; Galenism.","pos":""}],"HUMORIST":[{"def":"One who attributes diseases of the state of the humors.","pos":""}],"HUMORISTIC":[{"def":"Of, pertaining to, or resembling, a humorist.","pos":""}],"HUMORLESS":[{"def":"Destitute of humor.","pos":""}],"HUMOROUS":[{"def":"Moist; humid; watery.","pos":""},{"def":"Subject to be governed by humor or caprice; irregular; capricious; whimsical.","pos":""}],"HUMOROUSLY":[{"def":"Capriciously; whimsically.","pos":""},{"def":"Facetiously; wittily.","pos":""}],"HUMOROUSNESS":[{"def":"Moodiness; capriciousness.","pos":""},{"def":"Facetiousness; jocularity.","pos":""}],"HUMORSOME":[{"def":"Moody; whimsical; capricious.","pos":""},{"def":"Jocose; witty; humorous.","pos":""}],"HUMORSOMELY":[{"def":"Pleasantly; humorously.","pos":""}],"HUMORSOMENESS":[{"def":"Quality of being humorsome.","pos":""}],"HUMP":[{"def":"A fleshy protuberance on the back of an animal, as a camel or whale.","pos":""}],"HUMP-SHOULDERED":[{"def":"Having high, hunched shoulders.","pos":""}],"HUMPBACK":[{"def":"A crooked back; a humped back.","pos":""},{"def":"A humpbacked person; a hunchback.","pos":""}],"HUMPBACKED":[{"def":"Having a humped back.","pos":""}],"HUMPBACKED SALMON":[{"def":"A small salmon (Oncorhynchus gorbuscha) which ascends the rivers of the Pacific coast from California to Alaska, and also on the Asiatic side.","pos":""}],"HUMPED":[{"def":"Having a hump, as the back.","pos":""}],"HUMPH":[{"def":"An exclamation denoting surprise, or contempt, doubt, etc.","pos":""}],"HUMPY":[{"def":"Full of humps or bunches; covered with protuberances; humped.","pos":""}],"HUMSTRUM":[{"def":"An instrument out of tune or rudely constructed; music badly played.","pos":""}],"HUMULIN":[{"def":"An extract of hops.","pos":""}],"HUMUS":[{"def":"That portion of the soil formed by the decomposition of animal or vegetable matter.","pos":""}]}