{"DIRADIATION":[{"def":"The emission and diffusion of rays of light.","pos":""}],"DIRE":[{"def":"Ill-boding; portentous; as, dire omens.","pos":""},{"def":"Evil in great degree; dreadful; dismal; horrible; terrible; lamentable.","pos":""}],"DIRECT":[{"def":"In the direction of the general planetary motion, or from west to east; in the order of the signs; not retrograde; -- said of the motion of a celestial body.","pos":""}],"DIRECT ACTION":[{"def":"See Syndicalism, below.","pos":""}],"DIRECT NOMINATION":[{"def":"The nomination or designation of candidates for public office by direct popular vote rather than through the action of a convention or body of elected nominating representatives or delegates.","pos":""}],"DIRECT PRIMARY":[{"def":"A primary by which direct nominations of candidates for office are made.","pos":""}],"DIRECT-ACTING":[{"def":"Acting directly, as one part upon another, without the intervention of other working parts.","pos":""}],"DIRECT-COUPLED":[{"def":"Coupled without intermediate connections, as an engine and a dynamo.","pos":""}],"DIRECTER":[{"def":"One who directs; a director.","pos":""}],"DIRECTION":[{"def":"The pointing of a piece with reference to an imaginary vertical axis; -- distinguished from elevation.","pos":""}],"DIRECTIVE":[{"def":"Having power to direct; tending to direct, guide, or govern; showing the way.","pos":""},{"def":"Able to be directed; manageable.","pos":""}],"DIRECTLY":[{"def":"In a direct manner; in a straight line or course.","pos":""},{"def":"In a straightforward way; without anything intervening; not by secondary, but by direct, means.","pos":""}],"DIRECTNESS":[{"def":"The quality of being direct; straightness; straightforwardness; immediateness.","pos":""}],"DIRECTOIRE STYLE":[{"def":"A style of dress prevalent at the time of the French Directory, characterized by great extravagance of design and imitating the Greek and Roman costumes.","pos":""}],"DIRECTOR":[{"def":"A part of a machine or instrument which directs its motion or action.","pos":""},{"def":"A slender grooved instrument upon which a knife is made to slide when it is wished to limit the extent of motion of the latter, or prevent its injuring the parts beneath.","pos":""}],"DIRECTORATE":[{"def":"The office of director; also, a body of directors taken jointly.","pos":""}],"DIRECTORIAL":[{"def":"Having the quality of a director, or authoritative guide; directive.","pos":""},{"def":"Pertaining to: director or directory; specifically, relating to the Directory of France under the first republic.","pos":""}],"DIRECTORSHIP":[{"def":"The condition or office of a director; directorate.","pos":""}],"DIRECTORY":[{"def":"Containing directions; enjoining; instructing; directorial.","pos":""}],"DIRECTRESS":[{"def":"A woman who directs.","pos":""}],"DIREFUL":[{"def":"Dire; dreadful; terrible; calamitous; woeful; as, a direful fiend; a direful day.","pos":""}],"DIRELY":[{"def":"In a dire manner.","pos":""}],"DIREMPT":[{"def":"Divided; separated.","pos":""}],"DIREMPTION":[{"def":"A tearing apart; violent separation.","pos":""}],"DIRENESS":[{"def":"Terribleness; horror; woefulness.","pos":""}],"DIREPTION":[{"def":"The act of plundering, despoiling, or snatching away.","pos":""}],"DIREPTITIOUS":[{"def":"Characterized by direption.","pos":""}],"DIREPTITIOUSLY":[{"def":"With plundering violence; by violent injustice.","pos":""}],"DIRGE":[{"def":"A piece of music of a mournful character, to accompany funeral rites; a funeral hymn.","pos":""}],"DIRGEFUL":[{"def":"Funereal; moaning.","pos":""}],"DIRIGE":[{"def":"A service for the dead, in the Roman Catholic Church, being the first antiphon of Matins for the dead, of which Dirige is the first word; a dirge.","pos":""}],"DIRIGENT":[{"def":"The line of motion along which a describent line or surface is carried in the genesis of any plane or solid figure; a directrix.","pos":""}],"DIRIGIBLE":[{"def":"Capable of being directed; steerable; as, a dirigible balloon.","pos":""}],"DIRK":[{"def":"A kind of dagger or poniard; -- formerly much used by the Scottish Highlander.","pos":""}],"DIRL":[{"def":"To thrill; to vibrate; to penetrate.","pos":""}],"DIRT":[{"def":"Any foul of filthy substance, as excrement, mud, dust, etc.","pos":""},{"def":"Meanness; sordidness.","pos":""}],"DIRTILY":[{"def":"In a dirty manner; foully; nastily; filthily; meanly; sordidly.","pos":""}],"DIRTINESS":[{"def":"The state of being dirty; filthiness; foulness; nastiness; baseness; sordidness.","pos":""}],"DIRTY":[{"def":"Defiled with dirt; foul; nasty; filthy; not clean or pure; serving to defile; as, dirty hands; dirty water; a dirty white.","pos":""},{"def":"Sullied; clouded; -- applied to color.","pos":""}]}