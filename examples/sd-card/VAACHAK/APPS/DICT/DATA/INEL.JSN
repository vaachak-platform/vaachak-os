{"INELABORATE":[{"def":"Not elaborate; not wrought with care; unpolished; crude; unfinished.","pos":""}],"INELASTICITY":[{"def":"Want of elasticity.","pos":""}],"INELEGANT":[{"def":"Not elegant; deficient in beauty, polish, refinement, grave, or ornament; wanting in anything which correct taste requires.","pos":""}],"INELEGANTLY":[{"def":"In an inelegant manner.","pos":""}],"INELIGIBILITY":[{"def":"The state or quality of being ineligible.","pos":""}],"INELIGIBLE":[{"def":"Not eligible; not qualified to be chos Burke.","pos":""}],"INELLIGIBLY":[{"def":"In an ineligible manner.","pos":""}],"INELOQUENT":[{"def":"Not eloquent; not fluent, graceful, or pathetic; not persuasive; as, ineloquent language.","pos":""}],"INELOQUENTLY":[{"def":"Without eloquence.","pos":""}],"INELUCTABLE":[{"def":"Not to be overcome by struggling; irresistible; inevitable.","pos":""}],"INELUDIBLE":[{"def":"Incapable of being eluded or evaded; unvoidable.","pos":""}]}