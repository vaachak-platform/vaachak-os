{"SHORAGE":[{"def":"Duty paid for goods brought on shore.","pos":""}],"SHORE":[{"def":"A prop, as a timber, placed as a brace or support against the side of a building or other structure; a prop placed beneath anything, as a beam, to prevent it from sinking or sagging.","pos":""}],"SHORELESS":[{"def":"Having no shore or coast; of indefinite or unlimited extent; as, a shoreless ocean.","pos":""}],"SHORER":[{"def":"One who, or that which, shores or props; a prop; a shore.","pos":""}],"SHOREWARD":[{"def":"Toward the shore.","pos":""}],"SHORING":[{"def":"See Schorl, Schorlaceous.","pos":""}],"SHORLING":[{"def":"The skin of a sheen after the fleece is shorn off, as distinct from the morling, or skin taken from the dead sheep; also, a sheep of the first year's shearing.","pos":""},{"def":"A person who is shorn; a shaveling; hence, in contempt, a priest.","pos":""}],"SHORT":[{"def":"Breaking or crumbling readily in the mouth; crisp; as, short pastry.","pos":""}],"SHORT CIRCUIT":[{"def":"A circuit formed or closed by a conductor of relatively low resistance because shorter or of relatively great conductivity.","pos":""}],"SHORT-BREATHED":[{"def":"Having short-breath, or quick respiration.","pos":""},{"def":"Having short life.","pos":""}],"SHORT-CIRCUIT":[{"def":"To join, as the electrodes of a battery or dynamo or any two points of a circuit, by a conductor of low resistance.","pos":""}],"SHORT-DATED":[{"def":"Having little time to run from the date.","pos":""}],"SHORT-HANDED":[{"def":"Short of, or lacking the regular number of, servants or helpers.","pos":""}],"SHORT-JOINTED":[{"def":"Having short intervals between the joints; -- said of a plant or an animal, especially of a horse whose pastern is too short.","pos":""}],"SHORT-LIVED":[{"def":"Not living or lasting long; being of short continuance; as, a short-lived race of beings; short-lived pleasure; short-lived passion.","pos":""}],"SHORT-SPOKEN":[{"def":"Speaking in a quick or short manner; hence, gruff; curt.","pos":""}],"SHORT-WAISTED":[{"def":"Having a short waist.","pos":""}],"SHORT-WINDED":[{"def":"Affected with shortness of breath; having a quick, difficult respiration, as dyspnoic and asthmatic persons.","pos":""}],"SHORT-WITED":[{"def":"Having little wit; not wise; having scanty intellect or judgment.","pos":""}],"SHORTAGE":[{"def":"Amount or extent of deficiency, as determined by some requirement or standard; as, a shortage in money accounts.","pos":""}],"SHORTCAKE":[{"def":"An unsweetened breakfast cake shortened with butter or lard, rolled thin, and baked.","pos":""}],"SHORTCLOTHES":[{"def":"Coverings for the legs of men or boys, consisting of trousers which reach only to the knees, -- worn with long stockings.","pos":""}],"SHORTCOMING":[{"def":"The act of falling, or coming short; as: (a) The failure of a crop, or the like.","pos":""}],"SHORTEN":[{"def":"To make short or shorter in measure, extent, or time; as, to shorten distance; to shorten a road; to shorten days of calamity.","pos":""},{"def":"To reduce or diminish in amount, quantity, or extent; to lessen; to abridge; to curtail; to contract; as, to shorten work, an allowance of food, etc.","pos":""}],"SHORTENER":[{"def":"One who, or that which, shortens.","pos":""}],"SHORTENING":[{"def":"That which renders pastry short or friable, as butter, lard, etc.","pos":""}],"SHORTHAND":[{"def":"A compendious and rapid method or writing by substituting characters, abbreviations, or symbols, for letters, words, etc.","pos":""}],"SHORTHEAD":[{"def":"A sucking whale less than one year old; -- so called by sailors.","pos":""}],"SHORTHORN":[{"def":"One of a breed of large, heavy domestic cattle having short horns.","pos":""}],"SHORTLY":[{"def":"In a short or brief time or manner; soon; quickly.","pos":""},{"def":"In few words; briefly; abruptly; curtly; as, to express ideas more shortly in verse than in prose.","pos":""}],"SHORTNESS":[{"def":"The quality or state of being short; want of reach or extension; brevity; deficiency; as, the shortness of a journey; the shortness of the days in winter; the shortness of an essay; the shortness of the memory; a shortness of provisions; shortness of breath.","pos":""}],"SHORTSIGHTED":[{"def":"Not able to see far; nearsighted; myopic.","pos":""}],"SHORTSTOP":[{"def":"The player stationed in the field bewtween the second and third bases.","pos":""}],"SHORTWING":[{"def":"Any one of several species of small wrenlike Asiatic birds having short wings and a short tail.","pos":""}],"SHORY":[{"def":"Lying near the shore.","pos":""}]}