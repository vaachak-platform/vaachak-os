{"TIC":[{"def":"A local and habitual convulsive motion of certain muscles; especially, such a motion of some of the muscles of the face; twitching; velication; -- called also spasmodic tic.","pos":""}],"TICAL":[{"def":"A bean-shaped coin of Siam, worth about sixty cents; also, a weight equal to 236 grains troy.","pos":""},{"def":"A money of account in China, reckoning at about $1.","pos":""}],"TICE":[{"def":"A ball bowled to strike the ground about a bat's length in front of the wicket.","pos":""}],"TICHORRHINE":[{"def":"A fossil rhinoceros with a vertical bony medial septum supporting the nose; the hairy rhinoceros.","pos":""}],"TICK":[{"def":"Credit; trust; as, to buy on, or upon, tick.","pos":""}],"TICKER":[{"def":"One who, or that which, ticks, or produces a ticking sound, as a watch or clock, a telegraphic sounder, etc.","pos":""}],"TICKET":[{"def":"A small piece of paper, cardboard, or the like, serving as a notice, certificate, or distinguishing token of something.","pos":""}],"TICKETING":[{"def":"A periodical sale of ore in the English mining districts; -- so called from the tickets upon which are written the bids of the buyers.","pos":""}],"TICKING":[{"def":"A strong, closely woven linen or cotton fabric, of which ticks for beds are made.","pos":""}],"TICKLE":[{"def":"To touch lightly, so as to produce a peculiar thrilling sensation, which commonly causes laughter, and a kind of spasm which become dengerous if too long protracted.","pos":""},{"def":"To please; to gratify; to make joyous.","pos":""}],"TICKLE-FOOTED":[{"def":"Uncertain; inconstant; slippery.","pos":""}],"TICKLENBURG":[{"def":"A coarse, mixed linen fabric made to be sold in the West Indies.","pos":""}],"TICKLENESS":[{"def":"For hoard hath hate, and climbing tickleness.","pos":""}],"TICKLER":[{"def":"One who, or that which, tickles.","pos":""},{"def":"Something puzzling or difficult.","pos":""}],"TICKLISH":[{"def":"Sensible to slight touches; easily tickled; as, the sole of the foot is very ticklish; the hardened palm of the hand is not ticklish.","pos":""},{"def":"Standing so as to be liable to totter and fall at the slightest touch; unfixed; easily affected; unstable.","pos":""}],"TICKSEED":[{"def":"A seed or fruit resembling in shape an insect, as that of certain plants.","pos":""}],"TICKTACK":[{"def":"A noise like that made by a clock or a watch.","pos":""},{"def":"A kind of backgammon played both with men and pegs; tricktrack.","pos":""}],"TICPOLONGA":[{"def":"A very venomous viper (Daboia Russellii), native of Ceylon and India; -- called also cobra monil.","pos":""}]}