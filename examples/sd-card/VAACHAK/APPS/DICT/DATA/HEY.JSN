{"HEY":[{"def":"An exclamation of joy, surprise, or encouragement.","pos":""},{"def":"A cry to set dogs on.","pos":""}],"HEYDAY":[{"def":"An expression of frolic and exultation, and sometimes of wonder.","pos":""}],"HEYDEGUY":[{"def":"A kind of country-dance or round.","pos":""}],"HEYNE":[{"def":"A wretch; a rascal.","pos":""}]}