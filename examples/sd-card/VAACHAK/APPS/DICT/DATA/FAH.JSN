{"FAHAM":[{"def":"The leaves of an orchid (Angraecum fragrans), of the islands of Bourbon and Mauritius, used (in France) as a substitute for Chinese tea.","pos":""}],"FAHLBAND":[{"def":"A stratum in crystalline rock, containing metallic sulphides.","pos":""},{"def":"Same as Tetrahedrite.","pos":""}],"FAHLUNITE":[{"def":"A hydration of iolite.","pos":""}],"FAHRENHEIT":[{"def":"Conforming to the scale used by Gabriel Daniel Fahrenheit in the graduation of his thermometer; of or relating to Fahrenheit's thermometric scale.","pos":""},{"def":"The Fahrenheit termometer or scale.","pos":""}]}