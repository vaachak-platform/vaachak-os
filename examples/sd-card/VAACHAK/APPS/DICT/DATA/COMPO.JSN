{"COMPO":[{"def":"Short for Composition; -- used, esp.","pos":""}],"COMPONE":[{"def":"To compose; to settle; to arrange.","pos":""}],"COMPONENT":[{"def":"Serving, or helping, to form; composing; constituting; constituent.","pos":""}],"COMPORT":[{"def":"To bear or endure; to put up (with); as, to comport with an injury.","pos":""},{"def":"To agree; to accord; to suit; -- sometimes followed by with.","pos":""}],"COMPORTABLE":[{"def":"Suitable; consistent.","pos":""}],"COMPORTANCE":[{"def":"Behavior; comport.","pos":""}],"COMPORTATION":[{"def":"A bringing together.","pos":""}],"COMPORTMENT":[{"def":"Manner of acting; behavior; bearing.","pos":""}],"COMPOS-MENTIS":[{"def":"One who is compos mentis.","pos":""}],"COMPOSE":[{"def":"To arrange (types) in a composing stick in order for printing; to set (type).","pos":""}],"COMPOSED":[{"def":"Free from agitation; calm; sedate; quiet; tranquil; self- possessed.","pos":""}],"COMPOSER":[{"def":"One who composes; an author.","pos":""},{"def":"One who, or that which, quits or calms; one who adjust a difference.","pos":""}],"COMPOSING":[{"def":"Tending to compose or soothe.","pos":""},{"def":"Pertaining to, or used in, composition.","pos":""}],"COMPOSITAE":[{"def":"A large family of dicotyledonous plants, having their flowers arranged in dense heads of many small florets and their anthers united in a tube.","pos":""}],"COMPOSITE":[{"def":"Belonging to a certain order which is composed of the Ionic order grafted upon the Corinthian.","pos":""},{"def":"Belonging to the order Compositæ; bearing involucrate heads of many small florets, as the daisy, thistle, and dandelion.","pos":""}],"COMPOSITION":[{"def":"The adjustment of a debt, or avoidance of an obligation, by some form of compensation agreed on between the parties; also, the sum or amount of compensation agreed upon in the adjustment.","pos":""},{"def":"Having the quality of entering into composition; compounded.","pos":""}],"COMPOSITIVE":[{"def":"Having the quality of entering into composition; compounded.","pos":""}],"COMPOSITOR":[{"def":"One who sets type and arranges it for use.","pos":""}],"COMPOSITOUS":[{"def":"Belonging to the Compositæ; composite.","pos":""}],"COMPOSSIBLE":[{"def":"Able to exist with another thing; consistent.","pos":""}],"COMPOST":[{"def":"A mixture for fertilizing land; esp.","pos":"noun"}],"COMPOSTURE":[{"def":"Manure; compost.","pos":""}],"COMPOSURE":[{"def":"The act of composing, or that which is composed; a composition.","pos":""},{"def":"Orderly adjustment; disposition.","pos":""}],"COMPOTATION":[{"def":"The act of drinking or tippling together.","pos":""}],"COMPOTATOR":[{"def":"One who drinks with another.","pos":""}],"COMPOTE":[{"def":"A preparation of fruit in sirup in such a manner as to preserve its form, either whole, halved, or quartered; as, a compote of pears.","pos":""}],"COMPOTIER":[{"def":"A dish for holding compotes, fruit, etc.","pos":""}],"COMPOUND":[{"def":"In the East Indies, an inclosure containing a house, outbuildings, etc.","pos":""}],"COMPOUND CONTROL":[{"def":"A system of control in which a separate manipulation, as of a rudder, may be effected by either of two movements, in different directions, of a single lever, etc.","pos":""}],"COMPOUNDABLE":[{"def":"That may be compounded.","pos":""}],"COMPOUNDER":[{"def":"A Jacobite who favored the restoration of James II, on condition of a general amnesty and of guarantees for the security of the civil and ecclesiastical constitution of the realm.","pos":""}]}