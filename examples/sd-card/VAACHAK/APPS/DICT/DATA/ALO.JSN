{"ALOE":[{"def":"The wood of the agalloch.","pos":""},{"def":"A genus of succulent plants, some classed as trees, others as shrubs, but the greater number having the habit and appearance of evergreen herbaceous plants; from some of which are prepared articles for medicine and the arts.","pos":""}],"ALOETIC":[{"def":"Consisting chiefly of aloes; of the nature of aloes.","pos":""}],"ALOFT":[{"def":"In the top; at the mast head, or on the higher yards or rigging; overhead; hence (Fig.","pos":""}],"ALOGIAN":[{"def":"One of an ancient sect who rejected St.","pos":""}],"ALOGY":[{"def":"Unreasonableness; absurdity.","pos":""}],"ALOIN":[{"def":"A bitter purgative principle in aloes.","pos":""}],"ALOMANCY":[{"def":"Divination by means of salt.","pos":""}],"ALONE":[{"def":"Quite by one's self; apart from, or exclusive of, others; single; solitary; -- applied to a person or thing.","pos":""},{"def":"Of or by itself; by themselves; without any thing more or any one else; without a sharer; only.","pos":""}],"ALONELY":[{"def":"Only; merely; singly.","pos":""}],"ALONENESS":[{"def":"A state of being alone, or without company; solitariness.","pos":""}],"ALONG":[{"def":"By the length; in a line with the length; lengthwise.","pos":""},{"def":"In a line, or with a progressive motion; onward; forward.","pos":""}],"ALONGSHORE":[{"def":"Along the shore or coast.","pos":""}],"ALONGSHOREMAN":[{"def":"See Longshoreman.","pos":""}],"ALONGSIDE":[{"def":"Along or by the side; side by side with; -- often with of; as, bring the boat alongside; alongside of him; alongside of the tree.","pos":""}],"ALOOF":[{"def":"Same as Alewife.","pos":""}],"ALOOFNESS":[{"def":"State of being aloof.","pos":""},{"def":"Loss of the hair; baldness.","pos":""}],"ALOPECIST":[{"def":"A practitioner who tries to prevent or cure baldness.","pos":""}],"ALOSE":[{"def":"The European shad (Clupea alosa); -- called also allice shad or allis shad.","pos":""}],"ALOUATTE":[{"def":"One of the several species of howling monkeys of South America.","pos":""}],"ALOUD":[{"def":"With a loud voice, or great noise; loudly; audibly.","pos":""}],"ALOW":[{"def":"Below; in a lower part.","pos":""}]}