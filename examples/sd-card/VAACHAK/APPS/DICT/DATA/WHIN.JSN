{"WHIN":[{"def":"Same as Whinstone.","pos":""}],"WHINBERRY":[{"def":"The English bilberry; -- so called because it grows on moors among the whins, or furze.","pos":""}],"WHINCHAT":[{"def":"A small warbler (Pratincola rubetra) common in Europe; -- called also whinchacker, whincheck, whin-clocharet.","pos":""}],"WHINE":[{"def":"To utter a plaintive cry, as some animals; to mean with a childish noise; to complain, or to tell of sorrow, distress, or the like, in a plaintive, nasal tone; hence, to complain or to beg in a mean, unmanly way; to moan basely.","pos":""}],"WHINER":[{"def":"One who, or that which, whines.","pos":""}],"WHINGER":[{"def":"A kind of hanger or sword used as a knife at meals and as a weapon.","pos":""}],"WHININGLY":[{"def":"In a whining manner; in a tone of mean complaint.","pos":""}],"WHINNY":[{"def":"To utter the ordinary call or cry of a horse; to neigh.","pos":""}],"WHINOCK":[{"def":"The small pig of a litter.","pos":""}],"WHINSTONE":[{"def":"A provincial name given in England to basaltic rocks, and applied by miners to other kind of dark-colored unstratified rocks which resist the point of the pick.","pos":""}],"WHINYARD":[{"def":"A sword, or hanger.","pos":""},{"def":"Etym: [From the shape of the bill.","pos":""}]}