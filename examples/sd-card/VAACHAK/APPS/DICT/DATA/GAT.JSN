{"GAT-TOOTHED":[{"def":"Goat-toothed; having a lickerish tooth; lustful; wanton.","pos":""}],"GATCH":[{"def":"Plaster as used in Persian architecture and decorative art.","pos":""}],"GATE":[{"def":"The places which command the entrances or access; hence, place of vantage; power; might.","pos":""}],"GATEHOUSE":[{"def":"A house connected or associated with a gate.","pos":""}],"GATEMAN":[{"def":"A gate keeper; a gate tender.","pos":""}],"GATEPOST":[{"def":"A post to which a gate is hung; -- called also swinging or hinging post.","pos":""},{"def":"A post against which a gate closes; -- called also shutting post.","pos":""}],"GATEWAY":[{"def":"A passage through a fence or wall; a gate; also, a frame, arch, etc.","pos":""}],"GATEWISE":[{"def":"In the manner of a gate.","pos":""}],"GATHER":[{"def":"To bring together, or nearer together, in masonry, as where the width of a fireplace is rapidly diminished to the width of the flue, or the like.","pos":""},{"def":"To haul in; to take up; as, to gather the slack of a rope.","pos":""}],"GATHERABLE":[{"def":"Capable of being gathered or collected; deducible from premises.","pos":""}],"GATHERER":[{"def":"An attachment for making gathers in the cloth.","pos":""}],"GATHERING":[{"def":"The act of collecting or bringing together.","pos":""},{"def":"That which is gathered, collected, or brought together; as: (a) A crowd; an assembly; a congregation.","pos":""}],"GATLING GUN":[{"def":"An American machine gun, consisting of a cluster of barrels which, being revolved by a crank, are automatically loaded and fired.","pos":""}],"GATTEN TREE":[{"def":"A name given to the small trees called guelder-rose (Viburnum Opulus), cornel (Cornus sanguinea), and spindle tree (Euonymus Europæus).","pos":""}]}