{"NAB":[{"def":"The cock of a gunlock.","pos":""},{"def":"The keeper, or box into which the lock is shot.","pos":""}],"NABIT":[{"def":"Pulverized sugar candy.","pos":""}],"NABK":[{"def":"The edible berries of the Zizyphys Lotus, a tree of Northern Africa, and Southwestern Europe.","pos":""}],"NABOB":[{"def":"A deputy or viceroy in India; a governor of a province of the ancient Mogul empire.","pos":""},{"def":"One who returns to Europe from the East with immense riches: hence, any man of great wealth.","pos":""}]}