{"OX":[{"def":"The male of bovine quadrupeds, especially the domestic animal when castrated and grown to its full size, or nearly so.","pos":""}],"OXALAN":[{"def":"A complex nitrogenous substance C3N3H5O3 obtained from alloxan (or when urea is fused with ethyl oxamate), as a stable white crystalline powder; -- called also oxaluramide.","pos":""}],"OXALANTIN":[{"def":"A white crystalline nitrogenous substance (C6H4N4O5) obtained by the reduction of parabanic acid; -- called also leucoturic acid.","pos":""}],"OXALATE":[{"def":"A salt of oxalic acid.","pos":""}],"OXALDEHYDE":[{"def":"Same as Glyoxal.","pos":""}],"OXALETHYLINE":[{"def":"A poisonous nitrogenous base (C6H10N2) obtained indirectly from oxamide as a thick transparent oil which has a strong narcotic odor, and a physiological action resembling that of atropine.","pos":""}],"OXALIC":[{"def":"Pertaining to, derived from, or contained in, sorrel, or oxalis; specifically, designating an acid found in, and characteristic of, oxalis, and also certain plant of the Buckwheat family.","pos":""}],"OXALIS":[{"def":"A genus of plants,mostly herbs, with acid-tasting trifoliolate or multifoliolate leaves; -- called also wood sorrel.","pos":""}],"OXALITE":[{"def":"A yellow mineral consisting of oxalate of iron.","pos":""}],"OXALURATE":[{"def":"A salt of oxaluric acid.","pos":""}],"OXALURIC":[{"def":"Pertaining to, or designating, a complex nitrogenous acid related to the ureids, and obtained from parabanic acid as a white silky crystalline substance.","pos":""}],"OXAMATE":[{"def":"A salt of oxamic acid.","pos":""}],"OXAMETHANE":[{"def":"Ethyl oxamate, obtained as a white scaly crystalline powder.","pos":""}],"OXAMETHYLANE":[{"def":"Methyl oxamate, obtained as a pearly white crystalline substance.","pos":""}],"OXAMIC":[{"def":"Pertaining to, or designating, an acid NH2.","pos":""}],"OXAMIDE":[{"def":"A white crystalline neutral substance (C2O2(NH2)2) obtained by treating ethyl oxalate with ammonia.","pos":""}],"OXAMIDINE":[{"def":"One of a series of bases containing the amido and the isonitroso groups united to the same carbon atom.","pos":""},{"def":"A white crystalline nitrogenous substance, obtained indirectly by the action of cyanogen on aniline, and regarded as an anilide of oxamic acid; -- called also phenyl oxamide.","pos":""}],"OXANILATE":[{"def":"A salt of oxanilic acid.","pos":""}],"OXANILIC":[{"def":"Pertaining to, or derived from, oxalic acid and aniline; -- used to designate an acid obtained in white crystalline scales by heating these substances together.","pos":""}],"OXANILIDE":[{"def":"a white crystalline substance, resembling oxanilamide, obtained by heating aniline oxalate, and regarded as a double anilide of oxalic acid; -- called also diphenyl oxamide.","pos":""}],"OXBANE":[{"def":"A poisonous bulbous plant (Buphane toxicaria) of the Cape of Good Hope.","pos":""}],"OXBITER":[{"def":"The cow blackbird.","pos":""}],"OXBOW":[{"def":"A frame of wood, bent into the shape of the letter U, and embracing an ox's neck as a kind of collar, the upper ends passing through the bar of the yoke; also, anything so shaped, as a bend in a river.","pos":""}],"OXEYED":[{"def":"Having large, full eyes, like those of an ox.","pos":""}],"OXFLY":[{"def":"The gadfly of cattle.","pos":""}],"OXFORD":[{"def":"Of or pertaining to the city or university of Oxford, England.","pos":""}],"OXGOAD":[{"def":"A goad for driving oxen.","pos":""}],"OXHEAD":[{"def":"Literally, the head of an ox (emblem of cuckoldom); hence, a dolt; a blockhead.","pos":""}],"OXHEAL":[{"def":"Same as Bear's-foot.","pos":""}],"OXHEART":[{"def":"A large heart-shaped cherry, either black, red, or white.","pos":""}],"OXHIDE":[{"def":"A measure of land.","pos":""}],"OXIDABILITY":[{"def":"Capability of being converted into an oxide.","pos":""}],"OXIDABLE":[{"def":"Capable of being converted into an oxide.","pos":""}],"OXIDATION":[{"def":"The act or process of oxidizing, or the state or result of being oxidized.","pos":""}],"OXIDATOR":[{"def":"A contrivance for causing a current of air to impinge on the flame of the Argand lamp; -- called also oxygenator.","pos":""}],"OXIDE":[{"def":"A binary compound of oxygen with an atom or radical, or a compound which is regarded as binary; as, iron oxide, ethyl oxide, nitrogen oxide, etc.","pos":""}],"OXIDIZABLE":[{"def":"Capable of being oxidized.","pos":""}],"OXIDIZE":[{"def":"To combine with oxygen, or subject to the action of oxygen, or of an oxidizing agent.","pos":""}],"OXIDIZER":[{"def":"An agent employed in oxidation, or which facilitates or brings about combination with oxygen; as, nitric acid, chlorine, bromine, etc.","pos":""}],"OXIDULATED":[{"def":"Existing in the state of a protoxide; -- said of an oxide.","pos":""}],"OXIME":[{"def":"One of a series of isonitroso derivatives obtained by the action of hydroxylamine on aldehydes or ketones.","pos":""}],"OXINDOL":[{"def":"A white crystalline nitrogenous substance (C8H7NO) of the indol group, obtained by the reduction of dioxindol.","pos":""}],"OXIODIC":[{"def":"Pertaining to, or designating, certain compounds of iodine and oxygen.","pos":""}],"OXLIKE":[{"def":"Characteristic of, or like, an ox.","pos":""}],"OXLIP":[{"def":"The great cowslip (Primula veris, var.","pos":""}],"OXONATE":[{"def":"A salt of oxonic acid.","pos":""}],"OXONIAN":[{"def":"Of or relating to the city or the university of Oxford, England.","pos":""}],"OXONIC":[{"def":"Pertaining to, or designating, a complex nitrogenous acid (C4H5N3O4) not known in the free state, but obtained, in combination with its salts, by a slow oxidation of uric acid, to which it is related.","pos":""}],"OXPECKER":[{"def":"An African bird of the genus Buphaga; the beefeater.","pos":""}],"OXSHOE":[{"def":"A shoe for oxen, consisting of a flat piece of iron nailed to the hoof.","pos":""}],"OXTER":[{"def":"The armpit; also, the arm.","pos":""}],"OXTONGUE":[{"def":"A name given to several plants, from the shape and roughness of their leaves; as, Anchusa officinalis, a kind of bugloss, and Helminthia echioides, both European herbs.","pos":""}],"OXY-":[{"def":"A prefix, also used adjectively, designating: (a) A compound containing oxygen.","pos":""}],"OXYACETIC":[{"def":"Hydroxyacetic; designating an acid called also glycolic acid.","pos":""}],"OXYACID":[{"def":"An acid containing oxygen, as chloric acid or sulphuric acid; - - contrasted with the hydracids, which contain no oxygen, as hydrochloric acid.","pos":""}],"OXYAMMONIA":[{"def":"Same as Hydroxylamine.","pos":""}],"OXYBENZENE":[{"def":"Hydroxy benzene.","pos":""}],"OXYBENZOIC":[{"def":"Hydroxybenzoic; pertaining to, or designating, any one of several hydroxyl derivatives of benzonic acid, of which the commonest is salicylic acid.","pos":""}],"OXYBROMIC":[{"def":"Pertaining to, or designating, certain compounds of oxygen and bromine.","pos":""}],"OXYBUTYRIC":[{"def":"Hydroxybutyric; designating any one of a group of metameric acids (C3H6.","pos":""}],"OXYCALCIUM":[{"def":"Of or pertaining to oxygen and calcium; as, the oxycalcium light.","pos":""}],"OXYCHLORIDE":[{"def":"A ternary compound of oxygen and chlorine; as, plumbic oxychloride.","pos":""}],"OXYCRATE":[{"def":"A Mixture of water and vinegar.","pos":""}],"OXYGEN":[{"def":"A colorless, tasteless, odorless, gaseous element occurring in the free state in the atmosphere, of which it forms about 23 per cent by weight and about 21 per cent by volume, being slightly heavier than nitrogen.","pos":""}],"OXYGENATE":[{"def":"To unite, or cause to combine, with oxygen; to treat with oxygen; to oxidize; as, oxygenated water (hydrogen dioxide).","pos":""}],"OXYGENATION":[{"def":"The act or process of combining or of treating with oxygen; oxidation.","pos":""}],"OXYGENIC":[{"def":"Pertaining to, containing, or resembling, oxygen; producing oxygen.","pos":""}],"OXYGENIUM":[{"def":"The technical name of oxygen.","pos":""}],"OXYGON":[{"def":"A triangle having three acute angles.","pos":""},{"def":"Having acute angles.","pos":""}],"OXYHYDROGEN":[{"def":"Of or pertaining to a mixture of oxygen and hydrogen; as, oxyhydrogen gas.","pos":""}],"OXYHYDROGEN LIGHT":[{"def":"A light produced by the incandescence of some substances, esp.","pos":""}],"OXYMEL":[{"def":"A mixture of honey, water, vinegar, and spice, boiled to a sirup.","pos":""}],"OXYMETHYLENE":[{"def":"Formic aldehyde, regarded as a methylene derivative.","pos":""}],"OXYMORON":[{"def":"A figure in which an epithet of a contrary signification is added to a word; e.","pos":""}],"OXYMURIATE":[{"def":"A salt of the supposed oxymuriatic acid; a chloride.","pos":""}],"OXYMURIATIC":[{"def":"Pertaining to, or consisting of, oxygen and muriatic acid, that is, hydrochloric acid.","pos":""}],"OXYNTIC":[{"def":"Acid; producing acid; -applied especially to certain glands and cells in the stomach.","pos":""},{"def":"Excessive acuteness of sight.","pos":""}],"OXYPHENIC":[{"def":"Pertaining to, or designating, the phenol formerly called oxyphenic acid, and now oxyphenol and pyrocatechin.","pos":""}],"OXYPHENOL":[{"def":"A phenol, oxyphenic acid, and now pyrocatechin.","pos":""}],"OXYPHONY":[{"def":"Acuteness or shrillness of voice.","pos":""}],"OXYQUINOLINE":[{"def":"Hydroxy quinoline; a phenol derivative of quinoline, -- called also carbostyril.","pos":""}],"OXYRHYNCHA":[{"def":"The maioid crabs.","pos":""}],"OXYRRHODINE":[{"def":"A mixture of two parts of the oil of roses with one of the vinegar of roses.","pos":""}],"OXYSALT":[{"def":"A salt of an oxyacid, as a sulphate.","pos":""}],"OXYSULPHIDE":[{"def":"A ternary compound of oxygen and sulphur.","pos":""}],"OXYTOCIC":[{"def":"Promoting uterine contractions, or parturition.","pos":""},{"def":"An oxytocic medicine or agent.","pos":""}],"OXYTOLUENE":[{"def":"One of three hydroxy derivatives of toluene, called the cresols.","pos":""}],"OXYTONE":[{"def":"Having an acute sound; (Gr.","pos":""}]}