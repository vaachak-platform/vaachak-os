{"GRADATE":[{"def":"To bring to a certain strength or grade of concentration; as, to gradate a saline solution.","pos":""}],"GRADATION":[{"def":"A gradual passing from one tint to another or from a darker to a lighter shade, as in painting or drawing.","pos":""},{"def":"A diatonic ascending or descending succession of chords.","pos":""}],"GRADATIONAL":[{"def":"By regular steps or gradations; of or pertaining to gradation.","pos":""}],"GRADATORY":[{"def":"Suitable for walking; -- said of the limbs of an animal when adapted for walking on land.","pos":""}],"GRADE":[{"def":"The result of crossing a native stock with some better breed.","pos":""}],"GRADELY":[{"def":"Decent; orderly.","pos":""},{"def":"Decently; in order.","pos":""}],"GRADIENT":[{"def":"Moving by steps; walking; as, gradient automata.","pos":""},{"def":"Rising or descending by regular degrees of inclination; as, the gradient line of a railroad.","pos":""}],"GRADINE":[{"def":"A toothed chised by sculptors.","pos":""}],"GRADING":[{"def":"The act or method of arranging in or by grade, or of bringing, as the surface of land or a road, to the desired level or grade.","pos":""}],"GRADINO":[{"def":"A step or raised shelf, as above a sideboard or altar.","pos":""}],"GRADUAL":[{"def":"Proceeding by steps or degrees; advancing, step by step, as in ascent or descent or from one state to another; regularly progressive; slow; as, a gradual increase of knowledge; a gradual decline.","pos":""}],"GRADUALITY":[{"def":"The state of being gradual; gradualness.","pos":""}],"GRADUALLY":[{"def":"In a gradual manner.","pos":""}],"GRADUALNESS":[{"def":"The quality or state of being gradual; regular progression or gradation; slowness.","pos":""}],"GRADUATE":[{"def":"To bring to a certain degree of consistency, by evaporation, as a fluid.","pos":""}],"GRADUATED":[{"def":"Tapered; -- said of a bird's tail when the outer feathers are shortest, and the others successively longer.","pos":""}],"GRADUATESHIP":[{"def":"State of being a graduate.","pos":""}],"GRADUATION":[{"def":"The act of graduating, or the state of being graduated; as, graduation of a scale; graduation at a college; graduation in color; graduation by evaporation; the graduation of a bird's tail, etc.","pos":""},{"def":"The marks on an instrument or vessel to indicate degrees or quantity; a scale.","pos":""}],"GRADUATOR":[{"def":"One who determines or indicates graduation; as, a graduator of instruments.","pos":""},{"def":"An instrument for dividing any line, right or curve, into small, regular intervals.","pos":""}],"GRADUS":[{"def":"A dictionary of prosody, designed as an aid in writing Greek or Latin poetry.","pos":""}]}