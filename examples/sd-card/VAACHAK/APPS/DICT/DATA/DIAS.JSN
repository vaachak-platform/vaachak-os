{"DIASPORA":[{"def":"Old World, and afterwards to Jewish Christians living among heathen.","pos":""}],"DIASPORE":[{"def":"A hydrate of alumina, often occurring in white lamellar masses with brilliant pearly luster; -- so named on account of its decrepitating when heated before the blowpipe.","pos":""}],"DIASTASE":[{"def":"A soluble, nitrogenous ferment, capable of converting starch and dextrin into sugar.","pos":""}],"DIASTASIC":[{"def":"Pertaining to, or consisting of, diastase; as, diastasic ferment.","pos":""}],"DIASTASIS":[{"def":"A forcible of bones without fracture.","pos":""}],"DIASTATIC":[{"def":"Relating to diastase; having the properties of diastase; effecting the conversion of starch into sugar.","pos":""}],"DIASTEMA":[{"def":"A vacant space, or gap, esp.","pos":""}],"DIASTER":[{"def":"A double star; -- applied to the nucleus of a cell, when, during cell division, the loops of the nuclear network separate into two groups, preparatory to the formation of two daughter nuclei.","pos":""}],"DIASTOLE":[{"def":"The rhythmical expansion or dilatation of the heart and arteries; -- correlative to systole, or contraction.","pos":""},{"def":"A figure by which a syllable naturally short is made long.","pos":""}],"DIASTOLIC":[{"def":"Of or pertaining to diastole.","pos":""}],"DIASTYLE":[{"def":"See under Intercolumniation.","pos":""}]}