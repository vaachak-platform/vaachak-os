{"ENTHEASM":[{"def":"Inspiration; enthusiasm.","pos":""}],"ENTHEASTIC":[{"def":"Of godlike energy; inspired.","pos":""}],"ENTHEAT":[{"def":"Divinely inspired.","pos":""},{"def":"Intestinal worms.","pos":""}],"ENTHETIC":[{"def":"Caused by a morbifie virus implanted in the system; as, an enthetic disease like syphilis.","pos":""}],"ENTHRALL":[{"def":"To hold in thrall; to enslave.","pos":""}],"ENTHRALLMENT":[{"def":"The act of enthralling, or state of being enthralled.","pos":""}],"ENTHRILL":[{"def":"To pierce; to thrill.","pos":""}],"ENTHRONE":[{"def":"To induct, as a bishop, into the powers and privileges of a vacant see.","pos":""}],"ENTHRONEMENT":[{"def":"The act of enthroning, or state of being enthroned.","pos":""}],"ENTHRONIZATION":[{"def":"The act of enthroning; hence, the admission of a bishop to his stall or throne in his cathedral.","pos":""}],"ENTHRONIZE":[{"def":"To place on a throne; hence, to induct into office, as a bishop.","pos":""}],"ENTHUSE":[{"def":"To make or become enthusiastic.","pos":""}],"ENTHUSIASM":[{"def":"Inspiration as if by a divine or superhuman power; ecstasy; hence, a conceit of divine possession and revelation, or of being directly subject to some divine impulse.","pos":""},{"def":"A state of impassioned emotion; transport; elevation of fancy; exaltation of soul; as, the poetry of enthusiasm.","pos":""}],"ENTHUSIAST":[{"def":"One moved or actuated by enthusiasm; as: (a) One who imagines himself divinely inspired, or possessed of some special revelation; a religious madman; a fanatic.","pos":""},{"def":"Filled with enthusiasm; characterized by enthusiasm; zealous; as, an enthusiastic lover of art.","pos":""}],"ENTHUSIASTIC":[{"def":"An enthusiast; a zealot.","pos":""},{"def":"Pertaining to, or of the form of, an enthymeme.","pos":""}],"ENTHYMEME":[{"def":"An argument consisting of only two propositions, an antecedent and consequent deduced from it; a syllogism with one premise omitted; as, We are dependent; therefore we should be humble.","pos":""}]}