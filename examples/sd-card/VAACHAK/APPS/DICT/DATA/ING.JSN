{"ING":[{"def":"A pasture or meadow; generally one lying low, near a river.","pos":""}],"INGANNATION":[{"def":"Cheat; deception.","pos":""}],"INGATE":[{"def":"The aperture in a mold for pouring in the metal; the gate.","pos":""}],"INGATHERING":[{"def":"The act or business of gathering or collecting anything; especially, the gathering of the fruits of the earth; harvest.","pos":""}],"INGELABLE":[{"def":"Not congealable.","pos":""}],"INGEMINATE":[{"def":"Redoubled; repeated.","pos":""}],"INGEMINATION":[{"def":"Repetition; reduplication; reiteration.","pos":""}],"INGENERABILLTY":[{"def":"Incapacity of being engendered or produced.","pos":""}],"INGENERABLE":[{"def":"Incapble of being engendered or produced; original.","pos":""}],"INGENERABLY":[{"def":"In an ingenerable manner.","pos":""}],"INGENERATE":[{"def":"Generated within; inborn; innate; as, ingenerate powers of body.","pos":""}],"INGENERATION":[{"def":"Act of ingenerating.","pos":""}],"INGENIATE":[{"def":"To invent; to contrive.","pos":""}],"INGENIOSITY":[{"def":"Ingenuity; skill; cunning.","pos":""}],"INGENIOUS":[{"def":"Possessed of genius, or the faculty of invention; skillful or promp to invent; having an aptitude to contrive, or to form new combinations; as, an ingenious author, mechanic.","pos":""},{"def":"Proseeding from, pertaining to, or characterized by, genius or ingenuity; of curious design, structure, or mechanism; as, an ingenious model, or machine; an ingenious scheme, contrivance, etc.","pos":""}],"INGENIOUSLY":[{"def":"In an ingenious manner; with ingenuity; skillfully; wittily; cleverly.","pos":""}],"INGENIOUSNESS":[{"def":"The quality or state of being ingenious; ingenuity.","pos":""},{"def":"Innate; inborn; inbred; inherent; native; ingenerate.","pos":""}],"INGENUE":[{"def":"An ingenuous or naïve girl or young woman, or an actress representing such a person.","pos":""}],"INGENUITY":[{"def":"The quality or power of ready invention; quickness or acuteness in forming new combinations; ingeniousness; skill in devising or combining.","pos":""},{"def":"Curiousness, or cleverness in design or contrivance; as, the ingenuity of a plan, or of mechanism.","pos":""}],"INGENUOUS":[{"def":"Of honorable extraction; freeborn; noble; as, ingenuous blood of birth.","pos":""},{"def":"Noble; generous; magnanimous; honorable; uprigth; high-minded; as, an ingenuous ardor or zeal.","pos":""}],"INGENUOUSLY":[{"def":"In an ingenuous manner; openly; fairly; candidly; artlessly.","pos":""}],"INGENUOUSNESS":[{"def":"The state or quality of being ingenuous; openness of heart; frankness.","pos":""}],"INGENY":[{"def":"Natural gift or talent; ability; wit; ingenuity.","pos":""}],"INGERMINATE":[{"def":"To cause to germinate.","pos":""}],"INGEST":[{"def":"To take into, or as into, the stomach or alimentary canal.","pos":""}],"INGESTA":[{"def":"That which is introduced into the body by the stomach or alimentary canal; -- opposed to egesta.","pos":""}],"INGESTION":[{"def":"The act of taking or putting into the stomach; as, the ingestion of milk or other food.","pos":""}],"INGHALLA":[{"def":"The reedbuck of South Africa.","pos":""}],"INGIRT":[{"def":"To encircle to gird; to engirt.","pos":""}],"INGLE":[{"def":"Flame; blaze; a fire; a fireplace.","pos":""}],"INGLOBATE":[{"def":"In the form of a globe or sphere; -- applied to nebulous matter collected into a sphere by the force of gravitation.","pos":""}],"INGLOBE":[{"def":"To infix, as in a globe; to fix or secure firmly.","pos":""}],"INGLORIOUS":[{"def":"Not glorious; not bringing honor or glory; not accompanied with fame, honor, or celebrity; obscure; humble; as, an inglorious life of ease.","pos":""},{"def":"Shameful; disgraceful; ignominious; as, inglorious flight, defeat, etc.","pos":""}],"INGLORIOUSLY":[{"def":"In an inglorious manner; dishonorably; with shame; ignominiously; obscurely.","pos":""}],"INGLORIOUSNESS":[{"def":"The state of being inglorious.","pos":""}],"INGLUVIAL":[{"def":"Of or pertaining to the indulges or crop of birds.","pos":""}],"INGLUVIES":[{"def":"The crop, or craw, of birds.","pos":""}],"INGOT":[{"def":"That in which metal is cast; a mold.","pos":""},{"def":"A bar or wedge of steel, gold, or other malleable metal, cast in a mold; a mass of unwrought cast metal.","pos":""}],"INGOT STEEL":[{"def":"Steel cast in ingots from the Bessemer converter or open-hearth furnace.","pos":""}],"INGRACIOUS":[{"def":"Ungracious; unkind.","pos":""}],"INGRAFT":[{"def":"To insert, as a scion of one tree, shrub, or plant in another for propagation; as, to ingraft a peach scion on a plum tree; figuratively, to insert or introduce in such a way as to make a part of something.","pos":""},{"def":"To subject to the process of grafting; to furnish with grafts or scions; to graft; as, to ingraft a tree.","pos":""}],"INGRAFTER":[{"def":"A person who ingrafts.","pos":""}],"INGRAFTMENT":[{"def":"The act of ingrafting.","pos":""},{"def":"The thing ingrafted; a scion.","pos":""}],"INGRAIN":[{"def":"Dyed with grain, or kermes.","pos":""},{"def":"Dyed before manufacture, -- said of the material of a textile fabric; hence, in general, thoroughly inwrought; forming an essential part of the substance.","pos":""}],"INGRAPPLE":[{"def":"To seize; to clutch; to grapple.","pos":""}],"INGRATE":[{"def":"An ungrateful person.","pos":""}],"INGRATEFUL":[{"def":"Ungrateful; thankless; unappreciative.","pos":""},{"def":"Unpleasing to the sense; distasteful; offensive.","pos":""}],"INGRATIATE":[{"def":"To introduce or commend to the favor of another; to bring into favor; to insinuate; -- used reflexively, and followed by with before the person whose favor is sought.","pos":""},{"def":"To recommend; to render easy or agreeable; -- followed by to.","pos":""}],"INGRATITUDE":[{"def":"Want of gratitude; insensibility to, forgetfulness of, or ill return for, kindness or favors received; unthankfulness; ungratefulness.","pos":""}],"INGRAVIDATION":[{"def":"The state of being pregnant or impregnated.","pos":""}],"INGREAT":[{"def":"To make great; to enlarge; to magnify.","pos":""}],"INGREDIENT":[{"def":"That which enters into a compound, or is a component part of any combination or mixture; an element; a constituent.","pos":""}],"INGRESS":[{"def":"The entrance of the moon into the shadow of the earth in eclipses, the sun's entrance into a sign, etc.","pos":""}],"INGRESSION":[{"def":"Act of entering; entrance.","pos":""}],"INGRIEVE":[{"def":"To render more grievous; to aggravate.","pos":""}],"INGROOVE":[{"def":"To groove in; to join in or with a groove.","pos":""}],"INGROWING":[{"def":"Growing or appearing to grow into some other substance.","pos":""}],"INGROWTH":[{"def":"A growth or development inward.","pos":""}],"INGUINAL":[{"def":"Of or pertaining to, or in the region of, the inguen or groin; as, an inguinal canal or ligament; inguinal hernia.","pos":""}],"INGULF":[{"def":"To swallow up or overwhelm in, or as in, a gulf; to cast into a gulf.","pos":""}],"INGULFMENT":[{"def":"The act of ingulfing, or the state of being ingulfed.","pos":""}],"INGURGITATE":[{"def":"To swallow, devour, or drink greedily or in large quantity; to guzzle.","pos":""},{"def":"To swallow up, as in a gulf.","pos":""}],"INGURGITATION":[{"def":"The act of swallowing greedily or immoderately; that which is so swallowed.","pos":""}],"INGUSTABLE":[{"def":"Tasteless; insipid.","pos":""}]}