{"SAKE":[{"def":"Will he draw out, For anger's sake, finite to infinite Milton.","pos":""}],"SAKER":[{"def":"A small piece of artillery.","pos":""}],"SAKERET":[{"def":"The male of the saker (a).","pos":""}],"SAKI":[{"def":"Any one of several species of South American monkeys of the genus Pithecia.","pos":""}],"SAKTI":[{"def":"The divine energy, personified as the wife of a deity (Brahma, Vishnu, Siva, etc.","pos":""}]}