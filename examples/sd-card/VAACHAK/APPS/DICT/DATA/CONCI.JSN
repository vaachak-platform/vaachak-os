{"CONCIATOR":[{"def":"The person who weighs and proportions the materials to be made into glass, and who works and tempers them.","pos":""}],"CONCIERGE":[{"def":"One who keeps the entrance to an edifice, public or private; a doorkeeper; a janitor, male or female.","pos":""}],"CONCIERGERIE":[{"def":"The office or lodge of a concierge or janitor.","pos":""},{"def":"A celebrated prison, attached to the Palais de Justice in Paris.","pos":""}],"CONCILIABLE":[{"def":"A small or private assembly, especially of an ecclesiastical nature.","pos":""}],"CONCILIABULE":[{"def":"An obscure ecclesiastical council; a conciliable.","pos":""},{"def":"Of or pertaining to, or issued by, a council.","pos":""}],"CONCILIATE":[{"def":"To win ower; to gain from a state of hostility; to gain the good will or favor of; to make friendly; to mollify; to propitiate; to appease.","pos":""}],"CONCILIATION":[{"def":"The act or process of conciliating; the state of being conciliated.","pos":""}],"CONCILIATOR":[{"def":"One who conciliates.","pos":""}],"CONCILIATORY":[{"def":"Tending to conciliate; pacific; mollifying; propitiating.","pos":""}],"CONCINNATE":[{"def":"To place fitly together; to adapt; to clear.","pos":""}],"CONCINNITY":[{"def":"Internal harmony or fitness; mutual adaptation of parts; elegance; -- used chiefly of style of discourse.","pos":""}],"CONCINNOUS":[{"def":"Characterized by concinnity; neat; elegant.","pos":""}],"CONCIONATOR":[{"def":"A common councilman.","pos":""}],"CONCIONATORY":[{"def":"Of or pertaining to preaching or public addresses.","pos":""}],"CONCISE":[{"def":"Expressing much in a few words; condensed; brief and compacted; -- used of style in writing or speaking.","pos":"verb"}],"CONCISELY":[{"def":"In a concise manner; briefly.","pos":""}],"CONCISENESS":[{"def":"The quality of being concise.","pos":""}],"CONCISION":[{"def":"A cutting off; a division; a schism; a faction.","pos":""}],"CONCITATION":[{"def":"The act of stirring up, exciting, or agitating.","pos":""}],"CONCITE":[{"def":"To excite or stir up.","pos":""}]}