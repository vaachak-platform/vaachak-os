{"BARN":[{"def":"A covered building used chiefly for storing grain, hay, and other productions of a farm.","pos":""}],"BARNABITE":[{"def":"A member of a religious order, named from St.","pos":""}],"BARNACLE":[{"def":"Any cirriped crustacean adhering to rocks, floating timber, ships, etc.","pos":""}],"BARNBURNER":[{"def":"A member of the radical section of the Democratic party in New York, about the middle of the 19th century, which was hostile to extension of slavery, public debts, corporate privileges, etc.","pos":""}],"BARNSTORMER":[{"def":"An itinerant theatrical player who plays in barns when a theatre is lacking; hence, an inferior actor, or one who plays in the country away from the larger cities.","pos":""}],"BARNYARD":[{"def":"A yard belonging to a barn.","pos":""}]}