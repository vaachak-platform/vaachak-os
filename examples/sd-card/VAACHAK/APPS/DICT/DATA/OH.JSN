{"OH":[{"def":"An exclamation expressing various emotions, according to the tone and manner, especially surprise, pain, sorrow, anxiety, or a wish.","pos":""}],"OHM":[{"def":"The standard unit in the measure of electrical resistance, being the resistance of a circuit in which a potential difference of one volt produces a current of one ampére.","pos":""}],"OHMMETER":[{"def":"An instrument for indicating directly resistance in ohms.","pos":""}],"OHO":[{"def":"An exclamation of surprise, etc.","pos":""},{"def":"A suffix or combining form meaning like, resembling, in the form of; as in anthropoid, asteroid, spheroid.","pos":""}]}