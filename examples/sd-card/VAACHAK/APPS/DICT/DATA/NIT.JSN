{"NIT":[{"def":"The egg of a louse or other small insect.","pos":""}],"NITENCY":[{"def":"Brightness; luster.","pos":""}],"NITID":[{"def":"Bright; lustrous; shining.","pos":""},{"def":"Gay; spruce; fine; -- said of persons.","pos":""}],"NITRANILIC":[{"def":"Of, pertaining to, or designating, a complex organic acid produced as a white crystalline substance by the action of nitrous acid on hydroquinone.","pos":""}],"NITRANILINE":[{"def":"Any one of a series of nitro derivatives of aniline.","pos":""}],"NITRATE":[{"def":"A salt of nitric acid.","pos":""}],"NITRATED":[{"def":"Combined, or impregnated, with nitric acid, or some of its compounds.","pos":""},{"def":"Prepared with nitrate of silver.","pos":""}],"NITRATINE":[{"def":"A mineral occurring in transparent crystals, usually of a white, sometimes of a reddish gray, or lemon-yellow, color; native sodium nitrate.","pos":""}],"NITRIARY":[{"def":"An artificial bed of animal matter for the manufacture of niter by nitrification.","pos":""}],"NITRIC":[{"def":"Of, pertaining to, or containing, nitrogen; specifically, designating any one of those compounds in which, as contrasted with nitrous compounds, the element has a higher valence; as, nitric oxide; nitric acid.","pos":""}],"NITRIDE":[{"def":"A binary compound of nitrogen with a more metallic element or radical; as, boric nitride.","pos":""}],"NITRIFEROUS":[{"def":"Bearing niter; yielding, or containing, niter.","pos":""}],"NITRIFICATION":[{"def":"A process of oxidation, in which nitrogenous vegetable and animal matter in the presence of air, moisture, and some basic substances, as lime or alkali carbonate, is converted into nitrates.","pos":""}],"NITRIFIER":[{"def":"An agent employed in nitrification.","pos":""}],"NITRIFY":[{"def":"To combine or impregnate with nitrogen; to convert, by oxidation, into nitrous or nitric acid; to subject to, or produce by, nitrification.","pos":""}],"NITRILE":[{"def":"Any one of a series of cyanogen compounds; particularly, one of those cyanides of alcohol radicals which, by boiling with acids or alkalies, produce a carboxyl acid, with the elimination of the nitrogen as ammonia.","pos":""}],"NITRITE":[{"def":"A salt of nitrous acid.","pos":""}],"NITRO-":[{"def":"A combining form (used also adjectively) designating certain compounds of nitrogen or of its acids, as nitrohydrochloric, nitrocalcite; also, designating the group or radical NO2, or its compounds, as nitrobenzene.","pos":""}],"NITRO-CHLOROFORM":[{"def":"Same as Chlorpicrin.","pos":""}],"NITROBENZENE":[{"def":"A yellow aromatic liquid (C6H5.","pos":""},{"def":"See Nitrobenzene.","pos":""}],"NITROCALCITE":[{"def":"Nitrate of calcium, a substance having a grayish white color, occuring in efforescences on old walls, and in limestone caves, especially where there exists decaying animal matter.","pos":""}],"NITROCARBOL":[{"def":"See Nitromethane.","pos":""}],"NITROCELLULOSE":[{"def":"See Gun cotton, under Gun.","pos":""}],"NITROFORM":[{"def":"A nitro derivative of methane, analogous to chloroform, obtained as a colorless oily or crystalline substance, CH.","pos":""}],"NITROGELATIN":[{"def":"An explosive consisting of gun cotton and camphor dissolved in nitroglycerin.","pos":""}],"NITROGEN":[{"def":"A colorless nonmetallic element, tasteless and odorless, comprising four fifths of the atmosphere by volume.","pos":""}],"NITROGENIZE":[{"def":"To combine, or impregnate, with nitrogen or its compounds.","pos":""}],"NITROGENOUS":[{"def":"of, pertaining to, or resembling, nitrogen; as, a nitrogenous principle; nitrogenous compounds.","pos":""}],"NITROGLYCERIN":[{"def":"A liquid appearing like a heavy oil, colorless or yellowish, and consisting of a mixture of several glycerin salts of nitric acid, and hence more properly called glycerin nitrate.","pos":""}],"NITROHYDROCHLORIC":[{"def":"Of, pertaining to, or containing, nitric and hydrochloric acids.","pos":""}],"NITROL":[{"def":"Any one of a series of hydrocarbons containing the nitro and the nitroso or isonitroso group united to the same carbon atom.","pos":""}],"NITROLIC":[{"def":"of, derived from, or designating, a nitrol; as, a nitrolic acid.","pos":""}],"NITROMAGNESITE":[{"def":"Nitrate of magnesium, a saline efflorescence closely resembling nitrate of calcium.","pos":""}],"NITROMETER":[{"def":"An apparatus for determining the amount of nitrogen or some of its compounds in any substance subjected to analysis; an azotometer.","pos":""}],"NITROMETHANE":[{"def":"A nitro derivative of methane obtained as a mobile liquid; -- called also nitrocarbol.","pos":""}],"NITROMURIATIC":[{"def":"Of, pertaining to, or composed of, nitric acid and muriatic acid; nitrohydrochloric.","pos":""}],"NITROPHNOL":[{"def":"Any one of a series of nitro derivatives of phenol.","pos":""}],"NITROPRUSSIC":[{"def":"Pertaining to, derived from, or designating, a complex acid called nitroprussic acid, obtained indirectly by the action of nitric acid on potassium ferrocyanide (yellow prussiate), as a red crystalline unstable substance.","pos":""}],"NITROPRUSSIDE":[{"def":"See Nitroprussic.","pos":""}],"NITROQUINOL":[{"def":"A hypothetical nitro derivative of quinol or hydroquinone, not known in the free state, but forming a well defined series of derivatives.","pos":""}],"NITROSACCHARIN":[{"def":"An explosive nitro derivative of certain sugars, analogous to nitroglycerin, gun cotton, etc.","pos":""}],"NITROSALICYLIC":[{"def":"Of, pertaining to, or designating, a nitro derivative of salicylic acid, called also anilic acid.","pos":""}],"NITROSO-":[{"def":"Ni*tro\"so- Defn: (.","pos":""}],"NITROSYL":[{"def":"the radical NO, called also the nitroso group.","pos":""}],"NITROSYLIC":[{"def":"Of, pertaining to, or containing, nitrosyl; as, nitrosylic acid.","pos":""}],"NITROUS":[{"def":"Of, pertaining to, or designating, any one of those compounds in which nitrogen has a relatively lower valence as contrasted with nitric compounds.","pos":""}],"NITROXYL":[{"def":"The group NO2, usually called the nitro group.","pos":""}],"NITRYL":[{"def":"A name sometimes given to the nitro group or radical.","pos":""}],"NITTER":[{"def":"The horselouse; an insect that deposits nits on horses.","pos":""}],"NITTINGS":[{"def":"The refuse of good ore.","pos":""}],"NITTY":[{"def":"Shining; elegant; spruce.","pos":""}]}