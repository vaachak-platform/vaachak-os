{"BRISK":[{"def":"Full of liveliness and activity; characterized by quickness of motion or action; lively; spirited; quick.","pos":""},{"def":"Full of spirit of life; effervescas, brick cider.","pos":""}],"BRISKET":[{"def":"That part of the breast of an animal which extends from the fore legs back beneath the ribs; also applied to the fore part of a horse, from the shoulders to the bottom of the chest.","pos":""}],"BRISKLY":[{"def":"In a brisk manner; nimbly.","pos":""}],"BRISKNESS":[{"def":"Liveliness; vigor in action; quickness; gayety; vivacity; effervescence.","pos":""}],"BRISTLE":[{"def":"A stiff, sharp, roundish hair.","pos":""}],"BRISTLE-POINTED":[{"def":"Terminating in a very fine, sharp point, as some leaves.","pos":""}],"BRISTLE-SHAPED":[{"def":"Resembling a bristle in form; as, a bristle-shaped leaf.","pos":""}],"BRISTLETAIL":[{"def":"An insect of the genera Lepisma, Campodea, etc.","pos":""}],"BRISTLINESS":[{"def":"The quality or state of having bristles.","pos":""}],"BRISTLY":[{"def":"THick set with bristles, or with hairs resembling bristles; rough.","pos":""}],"BRISTOL":[{"def":"A seaport city in the west of England.","pos":""}],"BRISURE":[{"def":"Any part of a rampart or parapet which deviates from the general direction.","pos":""},{"def":"A mark of cadency or difference.","pos":""}]}