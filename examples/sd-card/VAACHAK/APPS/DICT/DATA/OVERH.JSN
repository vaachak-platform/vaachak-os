{"OVERHAND":[{"def":"The upper hand; advantage; superiority; mastery.","pos":""}],"OVERHANDLE":[{"def":"To handle, or use, too much; to mention too often.","pos":""}],"OVERHANG":[{"def":"To impend or hang over.","pos":""},{"def":"To hang over; to jut or project over.","pos":""}],"OVERHAPPY":[{"def":"Exceedingly happy.","pos":""}],"OVERHARDEN":[{"def":"To harden too much; to make too hard.","pos":""}],"OVERHARDY":[{"def":"Too hardy; overbold.","pos":""}],"OVERHASTE":[{"def":"Too great haste.","pos":""}],"OVERHASTY":[{"def":"Too hasty; precipitate; rash.","pos":""}],"OVERHAUL":[{"def":"To gain upon in a chase; to overtake.","pos":""},{"def":"A strict examination with a view to correction or repairs.","pos":""}],"OVERHEAD":[{"def":"Aloft; above; in or attached to the ceiling or roof; in the story or upon the floor above; in the zenith.","pos":""}],"OVERHEAR":[{"def":"To hear more of (anything) than was intended to be heard; to hear by accident or artifice.","pos":""}],"OVERHEAT":[{"def":"To heat to excess; to superheat.","pos":""}],"OVERHEAVY":[{"def":"Excessively heavy.","pos":""}],"OVERHELE":[{"def":"To hele or cover over.","pos":""}],"OVERHENT":[{"def":"So forth he went and soon them overhent.","pos":""}],"OVERHIGHLY":[{"def":"Too highly; too greatly.","pos":""}],"OVERHIP":[{"def":"To pass over by, or as by a hop; to skip over; hence, to overpass.","pos":""}],"OVERHOLD":[{"def":"To hold or value too highly; to estimate at too dear a rate.","pos":""}],"OVERHUNG":[{"def":"Covered over; ornamented with hangings.","pos":""},{"def":"Suspended from above or from the top.","pos":""}]}