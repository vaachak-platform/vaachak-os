{"HYLARCHICAL":[{"def":"Presiding over matter.","pos":""}],"HYLEOSAUR":[{"def":"Same as Hylæosaur.","pos":""}],"HYLIC":[{"def":"Of or pertaining to matter; material; corporeal; as, hylic influences.","pos":""}],"HYLICIST":[{"def":"A philosopher who treats chiefly of matter; one who adopts or teaches hylism.","pos":""}],"HYLISM":[{"def":"A theory which regards matter as the original principle of evil.","pos":""}],"HYLOBATE":[{"def":"Any species of the genus Hylobates; a gibbon, or long-armed ape.","pos":""}],"HYLODES":[{"def":"The piping frog (Hyla Pickeringii), a small American tree frog, which in early spring, while breeding in swamps and ditches, sings with high, shrill, but musical, notes.","pos":""}],"HYLOISM":[{"def":"Same as Hylotheism.","pos":""}],"HYLOIST":[{"def":"Same as Hylotheist.","pos":""}],"HYLOPATHISM":[{"def":"The doctrine that matter is sentient.","pos":""}],"HYLOPATHIST":[{"def":"One who believes in hylopathism.","pos":""}],"HYLOPHAGOUS":[{"def":"Eating green shoots, as certain insects do.","pos":""}],"HYLOTHEISM":[{"def":"The doctrine of belief that matter is God, or that there is no God except matter and the universe; pantheism.","pos":""}],"HYLOTHEIST":[{"def":"One who believes in hylotheism.","pos":""}],"HYLOZOIC":[{"def":"Of or pertaining to hylozoism.","pos":""}],"HYLOZOISM":[{"def":"The doctrine that matter possesses a species of life and sensation, or that matter and life are inseparable.","pos":""}],"HYLOZOIST":[{"def":"A believer in hylozoism.","pos":""}]}