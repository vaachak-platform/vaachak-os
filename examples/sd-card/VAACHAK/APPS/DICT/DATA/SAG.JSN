{"SAG":[{"def":"To cause to bend or give way; to load.","pos":""}],"SAGA":[{"def":"A Scandinavian legend, or heroic or mythic tradition, among the Norsemen and kindred people; a northern European popular historical or religious tale of olden time.","pos":""}],"SAGACIOUS":[{"def":"Of quick sense perceptions; keen-scented; skilled in following a trail.","pos":""},{"def":"Hence, of quick intellectual perceptions; of keen penetration and judgment; discerning and judicious; knowing; far-sighted; shrewd; sage; wise; as, a sagacious man; a sagacious remark.","pos":""}],"SAGACITY":[{"def":"The quality of being sagacious; quickness or acuteness of sense perceptions; keenness of discernment or penetration with soundness of judgment; shrewdness.","pos":""}],"SAGAMORE":[{"def":"The head of a tribe among the American Indians; a chief; -- generally used as synonymous with sachem, but some writters distinguished between them, making the sachem a chief of the first rank, and a sagamore one of the second rank.","pos":""}],"SAGAPENUM":[{"def":"A fetid gum resin obtained from a species of Ferula.","pos":""}],"SAGATHY":[{"def":"A mixed woven fabric of silk and cotton; or silk and wool; sayette; also, a light woolen fabric.","pos":""}],"SAGE":[{"def":"Nuttalli, or artemisia) which inhabits the regions of Western North America and lives among sagebrush.","pos":""}],"SAGEBRUSH":[{"def":"A low irregular shrub (Artemisia tridentata), of the order Compositæ, covering vast tracts of the dry alkaline regions of the American plains; -- called also sagebush, and wild sage.","pos":""}],"SAGEBRUSH STATE":[{"def":"Nevada; -- a nickname.","pos":""}],"SAGELY":[{"def":"In a sage manner; wisely.","pos":""}],"SAGENE":[{"def":"A Russian measure of length equal to about seven English feet.","pos":""}],"SAGENESS":[{"def":"The quality or state of being sage; wisdom; sagacity; prudence; gravity.","pos":""}],"SAGENITE":[{"def":"Acicular rutile occurring in reticulated forms imbedded in quartz.","pos":""}],"SAGENITIC":[{"def":"Resembling sagenite; -- applied to quartz when containing acicular crystals of other minerals, most commonly rutile, also tourmaline, actinolite, and the like.","pos":""}],"SAGGER":[{"def":"A pot or case of fire clay, in which fine stoneware is inclosed while baking in the kiln; a segga.","pos":""},{"def":"The clay of which such pots or cases are made.","pos":""}],"SAGGING":[{"def":"A bending or sinking between the ends of a thing, in consequence of its own, or an imposed, weight; an arching downward in the middle, as of a ship after straining.","pos":""}],"SAGINATE":[{"def":"To make fat; to pamper.","pos":""}],"SAGINATION":[{"def":"The act of fettening or pampering.","pos":""}],"SAGITTA":[{"def":"A small constellation north of Aquila; the Arrow.","pos":""},{"def":"The keystone of an arch.","pos":""}],"SAGITTAL":[{"def":"Of or pertaining to an arrow; resembling an arrow; furnished with an arowlike appendage.","pos":""}],"SAGITTARY":[{"def":"A centaur; a fabulous being, half man, half horse, armed with a bow and quiver.","pos":""}],"SAGITTATE":[{"def":"Shaped like an arrowhead; triangular, with the two basal angles prolonged downward.","pos":""}],"SAGITTATED":[{"def":"Sagittal; sagittate.","pos":""}],"SAGITTOCYST":[{"def":"A defensive cell containing a minute rodlike structure which may be expelled.","pos":""}],"SAGO":[{"def":"A dry granulated starch imported from the East Indies, much used for making puddings and as an article of diet for the sick; also, as starch, for stiffening textile fabrics.","pos":""}],"SAGOIN":[{"def":"A marmoset; -- called also sagouin.","pos":""}],"SAGUM":[{"def":"The military cloak of the Roman soldiers.","pos":""}],"SAGUS":[{"def":"A genus of palms from which sago is obtained.","pos":""}],"SAGY":[{"def":"Full of sage; seasoned with sage.","pos":""},{"def":"A respectful title or appelation given to Europeans of rank.","pos":""}]}