{"MYXA":[{"def":"The distal end of the mandibles of a bird.","pos":""}],"MYXINE":[{"def":"A genus of marsipobranchs, including the hagfish.","pos":""}],"MYXINOID":[{"def":"Like, or pertaining to, the genus Myxine.","pos":""}],"MYXOCYSTODEA":[{"def":"A division of Infusoria including the Noctiluca.","pos":""}],"MYXOEDEMA":[{"def":"A disease producing a peculiar cretinoid appearance of the face, slow speech, and dullness of intellect, and due to failure of the functions of the thyroid gland.","pos":""}],"MYXOMA":[{"def":"A tumor made up of a gelatinous tissue resembling that found in the umbilical cord.","pos":""}],"MYXOMYCETES":[{"def":"A class of peculiar organisms, the slime molds, formerly regarded as animals (Mycetozoa), but now generally thought to be plants and often separated as a distinct phylum (Myxophyta).","pos":""}],"MYXOPHYTA":[{"def":"A phylum of the vegetable kingdom consisting of the class Myxomycetes.","pos":""}],"MYXOPOD":[{"def":"A rhizopod or moneran.","pos":""}]}