{"PIT":[{"def":"A large cavity or hole in the ground, either natural or artificial; a cavity in the surface of a body; an indentation; specifically: (a) The shaft of a coal mine; a coal pit.","pos":""},{"def":"Any abyss; especially, the grave, or hades.","pos":""}],"PIT-HOLE":[{"def":"A pit; a pockmark.","pos":""}],"PITAHAYA":[{"def":"A cactaceous shrub (Cereus Pitajaya) of tropical America, which yields a delicious fruit.","pos":""}],"PITAPAT":[{"def":"In a flutter; with palpitation or quick succession of beats.","pos":""}],"PITCH":[{"def":"A thick, black, lustrous, and sticky substance obtained by boiling down tar.","pos":""}],"PITCH-BLACK":[{"def":"Black as pitch or tar.","pos":""}],"PITCH-DARK":[{"def":"Dark as a pitch; pitch-black.","pos":""}],"PITCH-FACED":[{"def":"Having the arris defined by a line beyond which the rock is cut away, so as to give nearly true edges; -- said of squared stones that are otherwise quarry-faced.","pos":""}],"PITCHBLENDE":[{"def":"A pitch-black mineral consisting chiefly of the oxide of uranium; uraninite.","pos":""}],"PITCHER":[{"def":"One who pitches anything, as hay, quoits, a ball, etc.","pos":""},{"def":"A sort of crowbar for digging.","pos":""}],"PITCHERFUL":[{"def":"The quantity a pitcher will hold.","pos":""}],"PITCHFORK":[{"def":"A fork, or farming utensil, used in pitching hay, sheaves of grain, or the like.","pos":""}],"PITCHINESS":[{"def":"Blackness, as of pitch; darkness.","pos":""}],"PITCHING":[{"def":"A facing of stone laid upon a bank to prevent wear by tides or currents.","pos":""}],"PITCHSTONE":[{"def":"An igneous rock of semiglassy nature, having a luster like pitch.","pos":""}],"PITCHWORK":[{"def":"The work of a coal miner who is paid by a share of his product.","pos":""}],"PITCHY":[{"def":"Partaking of the qualities of pitch; resembling pitch.","pos":""},{"def":"Smeared with pitch.","pos":""}],"PITEOUS":[{"def":"Evincing pity, compassion, or sympathy; compassionate; tender.","pos":""}],"PITFALL":[{"def":"A pit deceitfully covered to entrap wild beasts or men; a trap of any kind.","pos":""}],"PITFALLING":[{"def":"Entrapping; insnaring.","pos":""}],"PITH":[{"def":"The soft spongy substance in the center of the stems of many plants and trees, especially those of the dicotyledonous or exogenous classes.","pos":""}],"PITHECANTHROPUS":[{"def":"an animal of this genus.","pos":""}],"PITHECI":[{"def":"A division of mammals including the apes and monkeys.","pos":""}],"PITHECOID":[{"def":"Of or pertaining to the genus Pithecia, or subfamily Pithecinæ, which includes the saki, ouakari, and other allied South American monkeys.","pos":""},{"def":"Of or pertaining to the anthropoid apes in particular, or to the higher apes of the Old World, collectively.","pos":""}],"PITHILY":[{"def":"In a pithy manner.","pos":""}],"PITHINESS":[{"def":"The quality or state of being pithy.","pos":""}],"PITHLESS":[{"def":"Destitute of pith, or of strength; feeble.","pos":""}],"PITHY":[{"def":"Consisting wholly, or in part, of pith; abounding in pith; as, a pithy stem; a pithy fruit.","pos":""},{"def":"Having nervous energy; forceful; cogent.","pos":""}],"PITIABLE":[{"def":"Deserving pity; wworthy of, or exciting, compassion; miserable; lamentable; piteous; as, pitiable persons; a pitiable condition; pitiable wretchedness.","pos":""}],"PITIFUL":[{"def":"Full of pity; tender-hearted; compassionate; kind; merciful; sympathetic.","pos":""},{"def":"Piteous; lamentable; eliciting compassion.","pos":""}],"PITILESS":[{"def":"Destitute of pity; hard-hearted; merciless; as, a pitilessmaster; pitiless elements.","pos":""},{"def":"Exciting no pity; as, a pitiless condition.","pos":""}],"PITMAN":[{"def":"The connecting rod in a sawmill; also, sometimes, a connecting rod in other machinery.","pos":""}],"PITOT'S TUBE":[{"def":"A bent tube used to determine the velocity of running water, by placing the curved end under water, and observing the height to which the fluid rises in the tube; a kind of current meter.","pos":""}],"PITPAN":[{"def":"A long, flat-bottomed canoe, used for the navigation of rivers and lagoons in Central America.","pos":""}],"PITTA":[{"def":"Any one of a large group of bright-colored clamatorial birds belonging to Pitta, and allied genera of the family Pittidæ.","pos":""}],"PITTACAL":[{"def":"A dark blue substance obtained from wood tar.","pos":""}],"PITTANCE":[{"def":"An allowance of food bestowed in charity; a mess of victuals; hence, a small charity gift; a dole.","pos":""},{"def":"A meager portion, quality, or allowance; an inconsiderable salary or compensation.","pos":""}],"PITTED":[{"def":"Having minute thin spots; as, pitted ducts in the vascular parts of vegetable tissue.","pos":""}],"PITTER":[{"def":"A contrivance for removing the pits from peaches, plums, and other stone fruit.","pos":""}],"PITTER-PATTER":[{"def":"A sound like that of alternating light beats.","pos":""}],"PITTLE-PATTLE":[{"def":"To talk unmeaningly; to chatter or prattle.","pos":""}],"PITUITARY":[{"def":"Pituitary body or gland (Anat.","pos":""}],"PITUITOUS":[{"def":"Consisting of, or resembling, pituite or mucus; full of mucus; discharging mucus.","pos":""}],"PITUITRIN":[{"def":"A substance or extract from the pituitary body.","pos":""}],"PITY":[{"def":"A feeling for the sufferings or distresses of another or others; sympathy with the grief or misery of another; compassion; fellow- feeling; commiseration.","pos":""}],"PITYING":[{"def":"Expressing pity; as, a pitying eye, glance, or word.","pos":""}],"PITYRIASIS":[{"def":"A superficial affection of the skin, characterized by irregular patches of thin scales which are shed in branlike particles.","pos":""}],"PITYROID":[{"def":"Having the form of, or resembling, bran.","pos":""}]}