{"BROMA":[{"def":"A light form of prepared cocoa (or cacao), or the drink made from it.","pos":""}],"BROMALIN":[{"def":"A colorless or white crystalline compound, (CH2)6N4C2H5Br, used as a sedative in epilepsy.","pos":""}],"BROMANIL":[{"def":"A substance analogous to chloranil but containing bromine in place of chlorine.","pos":""}],"BROMATE":[{"def":"A salt of bromic acid.","pos":""}],"BROMATOLOGIST":[{"def":"One versed in the science of foods.","pos":""}],"BROMATOLOGY":[{"def":"The science of aliments.","pos":""}],"BROME GRASS":[{"def":"A genus (Bromus) of grasses, one species of which is the chess or cheat.","pos":""}],"BROMELIACEOUS":[{"def":"Pertaining to, or resembling, a family of endogenous and mostly epiphytic or saxicolous plants of which the genera Tillandsia and Billbergia are examples.","pos":""}],"BROMIC":[{"def":"Of, pertaining to, or containing, bromine; -- said of those compounds of bromine in which this element has a valence of five, or the next to its highest; as, bromic acid.","pos":""}],"BROMIDE":[{"def":"A compound of bromine with a positive radical.","pos":""},{"def":"A sensitized paper coated with gelatin impregnated with bromide of silver, used in contact printing and in enlarging.","pos":""}],"BROMIDIOM":[{"def":"A conventional comment or saying, such as those characteristic of bromides.","pos":""}],"BROMINE":[{"def":"One of the elements, related in its chemical qualities to chlorine and iodine.","pos":""}],"BROMISM":[{"def":"A diseased condition produced by the excessive use of bromine or one of its compounds.","pos":""}],"BROMIZE":[{"def":"To prepare or treat with bromine; as, to bromize a silvered plate.","pos":""}],"BROMLIFE":[{"def":"A carbonate of baryta and lime, intermediate between witherite and strontianite; -- called also alstonite.","pos":""}],"BROMOFORM":[{"def":"A colorless liquid, CHBr3, having an agreeable odor and sweetish taste.","pos":""}],"BROMOGELATIN":[{"def":"Designating or pertaining to, a process of preparing dry plates with an emulsion of bromides and silver nitrate in gelatin.","pos":""}],"BROMOIODISM":[{"def":"Poisoning induced by large doses of bromine and iodine or of their compounds.","pos":""}],"BROMOIODIZED":[{"def":"Treated with bromides and iodides.","pos":""}],"BROMOL":[{"def":"A crystalline substance (chemically, tribromophenol, C6H2Br3OH), used as an antiseptic and disinfectant.","pos":""}],"BROMPICRIN":[{"def":"A pungent colorless explosive liquid, CNO2Br3, analogous to and resembling chlorpicrin.","pos":""}],"BROMYRITE":[{"def":"Silver bromide, a rare mineral; -- called also bromargyrite.","pos":""}]}