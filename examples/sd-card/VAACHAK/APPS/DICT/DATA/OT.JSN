{"OTACOUSTIC":[{"def":"Assisting the sense of hearing; as, an otacoustic instrument.","pos":""},{"def":"An instrument to facilitate hearing, as an ear trumpet.","pos":""}],"OTALGIA":[{"def":"Pain in the ear; earache.","pos":""}],"OTALGIC":[{"def":"Of or pertaining to otalgia.","pos":""},{"def":"A remedy for otalgia.","pos":""}],"OTALGY":[{"def":"Pain in the ear; otalgia.","pos":""}],"OTHEOSCOPE":[{"def":"An instrument for exhibiting the repulsive action produced by light or heat in an exhausted vessel; a modification of the radoimeter.","pos":""}],"OTHER":[{"def":"Either; -- used with other or or for its correlative (as either .","pos":""}],"OTHERGATES":[{"def":"In another manner.","pos":""},{"def":"Of another kind or sort; in another way.","pos":""}],"OTHERNESS":[{"def":"The quality or state of being other or different; alterity; oppositeness.","pos":""}],"OTHERWHERE":[{"def":"In or to some other place, or places; elsewhere.","pos":""},{"def":"At another time, or other times; sometimes; [Archaic] Weighing otherwhiles ten pounds and more.","pos":""}],"OTHERWISE":[{"def":"In a different manner; in another way, or in other ways; differently; contrarily.","pos":""},{"def":"In other respects.","pos":""}],"OTIC":[{"def":"Of, pertaining to, or in the region of, the ear; auricular; auditory.","pos":""}],"OTIOSE":[{"def":"Being at leisure or ease; unemployed; indolent; idle.","pos":""}],"OTIOSITY":[{"def":"Leisure; indolence; idleness; ease.","pos":""}],"OTIS":[{"def":"A genus of birds including the bustards.","pos":""}],"OTITIS":[{"def":"Inflammation of the ear.","pos":""}],"OTO-":[{"def":"A combining form denoting relation to, or situation near or in, the ear.","pos":""}],"OTOBA FAT":[{"def":"A colorless buttery substance obtained from the fruit of Myristica otoba, a species of nutmeg tree.","pos":""}],"OTOCRANE":[{"def":"The cavity in the skull in which the parts of the internal ear are lodged.","pos":""}],"OTOCRANIAL":[{"def":"Of or pertaining to the otocrane.","pos":""}],"OTOCYST":[{"def":"An auditory cyst or vesicle; one of the simple auditory organs of many invertebrates, containing a fluid and otoliths; also, the embryonic vesicle from which the parts of the internal ear of vertebrates are developed.","pos":""}],"OTOGRAPHY":[{"def":"A description of the ear.","pos":""},{"def":"One of the small bones or particles of calcareous or other hard substance in the internal ear of vertebrates, and in the auditory organs of many invertebrates; an ear stone.","pos":""}],"OTOLOGICAL":[{"def":"Of or pertaining tootology.","pos":""}],"OTOLOGIST":[{"def":"One skilled in otology; an aurist.","pos":""}],"OTOLOGY":[{"def":"The branch of science which treats of the ear and its diseases.","pos":""}],"OTOPATHY":[{"def":"A diseased condition of the ear.","pos":""},{"def":"A flow or running from the ear, esp.","pos":""}],"OTOSCOPE":[{"def":"An instrument for examining the condition of the ear.","pos":""}],"OTOSCOPEIC":[{"def":"Of or pertaining to the otoscope or to otoscopy.","pos":""}],"OTOSCOPY":[{"def":"The examination of the ear; the art of using the otoscope.","pos":""}],"OTOSTEAL":[{"def":"An auditory ossicle.","pos":""}],"OTOZOUM":[{"def":"An extinct genus of huge vertebrates, probably dinosaurs, known only from four-toed tracks in Triassic sandstones.","pos":""}],"OTTAVA RIMA":[{"def":"A stanza of eight lines of heroic verse, with three rhymes, the first six lines rhyming alternately and the last two forming a couplet.","pos":""}],"OTTAWAS":[{"def":"A tribe of Indians who, when first known, lived on the Ottawa River.","pos":""}],"OTTER":[{"def":"Any carnivorous animal of the genus Lutra, and related genera.","pos":""},{"def":"The larva of the ghost moth.","pos":""}],"OTTO CYCLE":[{"def":"Otto-Crossley gas engine, the first commercially successful internal- combustion engine made.","pos":""}],"OTTO ENGINE":[{"def":"An engine using the Otto cycle.","pos":""}],"OTTOMAN":[{"def":"Of or pertaining to the Turks; as, the Ottoman power or empire.","pos":""}],"OTTRELITE":[{"def":"A micaceous mineral occurring in small scales.","pos":""}]}