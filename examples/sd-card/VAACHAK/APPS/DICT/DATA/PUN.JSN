{"PUN":[{"def":"He would pun thee into shivers with his fist.","pos":""}],"PUNA":[{"def":"A cold arid table-land, as in the Andes of Peru.","pos":""}],"PUNCH":[{"def":"A beverage composed of wine or distilled liquor, water (or milk), sugar, and the juice of lemon, with spice or mint; -- specifically named from the kind of spirit used; as rum punch, claret punch, champagne punch, etc.","pos":""}],"PUNCHEON":[{"def":"A short, upright piece of timber in framing; a short post; an intermediate stud.","pos":""},{"def":"A cask containing, sometimes 84, sometimes 120, gallons.","pos":""}],"PUNCHER":[{"def":"One who, or that which, punches.","pos":""}],"PUNCHINELLO":[{"def":"A punch; a buffoon; originally, in a puppet show, a character represented as fat, short, and humpbacked.","pos":""}],"PUNCHY":[{"def":"Short and thick, or fat.","pos":""},{"def":"Dotted with small spots of color, or with minute depressions or pits.","pos":""}],"PUNCTATOR":[{"def":"One who marks with points.","pos":""}],"PUNCTICULAR":[{"def":"Comprised in, or like, a point; exact.","pos":""}],"PUNCTIFORM":[{"def":"Having the form of a point.","pos":""}],"PUNCTILIO":[{"def":"A nice point of exactness in conduct, ceremony, or proceeding; particularity or exactness in forms; as, the punctilios of a public ceremony.","pos":""}],"PUNCTILIOUS":[{"def":"Attentive to punctilio; very nice or exact in the forms of behavior, etiquette, or mutual intercourse; precise; exact in the smallest particulars.","pos":""}],"PUNCTION":[{"def":"A puncturing, or pricking; a puncture.","pos":""}],"PUNCTO":[{"def":"A nice point of form or ceremony.","pos":""},{"def":"A term applied to the point in fencing.","pos":""}],"PUNCTUAL":[{"def":"Consisting in a point; limited to a point; unextended.","pos":""},{"def":"Observant of nice points; punctilious; precise.","pos":""}],"PUNCTUALIST":[{"def":"One who is very exact in observing forms and ceremonies.","pos":""}],"PUNCTUALITY":[{"def":"The quality or state of being punctual; especially, adherence to the exact time of an engagement; exactness.","pos":""}],"PUNCTUALLY":[{"def":"In a punctual manner; promptly; exactly.","pos":""}],"PUNCTUALNESS":[{"def":"Punctuality; exactness.","pos":""}],"PUNCTUATE":[{"def":"To mark with points; to separate into sentences, clauses, etc.","pos":""}],"PUNCTUATION":[{"def":"The act or art of punctuating or pointing a writing or discourse; the art or mode of dividing literary composition into sentences, and members of a sentence, by means of points, so as to elucidate the author's meaning.","pos":""}],"PUNCTUATIVE":[{"def":"Of or belonging to points of division; relating to punctuation.","pos":""}],"PUNCTUATOR":[{"def":"One who punctuates, as in writing; specifically, a punctator.","pos":""}],"PUNCTUIST":[{"def":"Marked with small spots.","pos":""}],"PUNCTURATION":[{"def":"The act or process of puncturing.","pos":""}],"PUNCTURE":[{"def":"The act of puncturing; perforating with something pointed.","pos":""},{"def":"A small hole made by a point; a slight wound, bite, or sting; as, the puncture of a nail, needle, or pin.","pos":""}],"PUNCTURED":[{"def":"Produced by puncture; having the characteristics of a puncture; as, a punctured wound.","pos":""}],"PUNDIT":[{"def":"A learned man; a teacher; esp.","pos":""}],"PUNDLE":[{"def":"A short and fat woman; a squab.","pos":""}],"PUNG":[{"def":"A kind of plain sleigh drawn by one horse; originally, a rude oblong box on runners.","pos":""}],"PUNGENCY":[{"def":"The quality or state of being pungent or piercing; keenness; sharpness; piquancy; as, the pungency of ammonia.","pos":""}],"PUNGENT":[{"def":"Prickly-pointed; hard and sharp.","pos":""}],"PUNGENTLY":[{"def":"In a pungent manner; sharply.","pos":""}],"PUNGLED":[{"def":"Shriveled or shrunken; -- said especially of grain which has lost its juices from the ravages of insects, such as the wheat midge, or Trips (Thrips cerealium).","pos":""}],"PUNGY":[{"def":"A small sloop or shallop, or a large boat with sails.","pos":""}],"PUNIC":[{"def":"Of or pertaining to the ancient Carthaginians.","pos":""},{"def":"Characteristic of the ancient Carthaginians; faithless; treacherous; as, Punic faith.","pos":""}],"PUNICE":[{"def":"Of a bright red or purple color.","pos":""}],"PUNINESS":[{"def":"The quality or state of being puny; littleness; pettiness; feebleness.","pos":""}],"PUNISH":[{"def":"To impose a penalty upon; to afflict with pain, loss, or suffering for a crime or fault, either with or without a view to the offender's amendment; to cause to suffer in retribution; to chasten; as, to punish traitors with death; a father punishes his child for willful disobedience.","pos":""},{"def":"To inflict a penalty for (an offense) upon the offender; to repay, as a fault, crime, etc.","pos":""}],"PUNISHABLE":[{"def":"Deserving of, or liable to, punishment; capable of being punished by law or right; -- said of person or offenses.","pos":""}],"PUNISHER":[{"def":"One who inflicts punishment.","pos":""}],"PUNISHMENT":[{"def":"A penalty inflicted by a court of justice on a convicted offender as a just retribution, and incidentally for the purposes of reformation and prevention.","pos":""}],"PUNITIVE":[{"def":"Of or pertaining to punishment; involving, awarding, or inflicting punishment; as, punitive law or justice.","pos":""}],"PUNITORY":[{"def":"Punishing; tending to punishment; punitive.","pos":""}],"PUNK":[{"def":"Wood so decayed as to be dry, crumbly, and useful for tinder; touchwood.","pos":""},{"def":"A fungus (Polyporus fomentarius, etc.","pos":""}],"PUNKA":[{"def":"A machine for fanning a room, usually a movable fanlike frame covered with canvas, and suspended from the ceiling.","pos":""}],"PUNKIE":[{"def":"A minute biting fly of the genus Ceratopogon or allied genus of the family Chironomidæ, found in swarms in various densely wooded or mountaneous regions.","pos":""}],"PUNKLING":[{"def":"A young strumpet.","pos":""}],"PUNNET":[{"def":"A broad, shallow basket, for displaying fruit or flowers.","pos":""}],"PUNNOLOGY":[{"def":"The art or practice of punning; paronomasia.","pos":""}],"PUNSTER":[{"def":"One who puns, or is skilled in, or given to, punning; a quibbler; a low wit.","pos":""}],"PUNT":[{"def":"To play at basset, baccara, faro.","pos":""}],"PUNT-OUT":[{"def":"A punt made from the goal line by a player of the side which has made a touchdown to one of his own side for a fair catch, from which an attempt to kick a goal may be made.","pos":""}],"PUNTELLO":[{"def":"One of the points sometimes drilled as guides for cutting away superfluous stone.","pos":""}],"PUNTER":[{"def":"One who punts; specifically, one who plays against the banker or dealer, as in baccara and faro.","pos":"noun"}],"PUNY":[{"def":"Imperfectly developed in size or vigor; small and feeble; inferior; petty.","pos":""}]}