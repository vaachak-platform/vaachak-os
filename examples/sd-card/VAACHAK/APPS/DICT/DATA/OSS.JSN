{"OSS":[{"def":"To prophesy; to presage.","pos":""}],"OSSE":[{"def":"A prophetic or ominous utterance.","pos":""}],"OSSEAN":[{"def":"A fish having a bony skeleton; a teleost.","pos":""}],"OSSEIN":[{"def":"The organic basis of bone tissue; the residue after removal of the mineral matters from bone by dilute acid; in embryonic tissue, the substance in which the mineral salts are deposited to form bone; -- called also ostein.","pos":""}],"OSSELET":[{"def":"The internal bone, or shell, of a cuttlefish.","pos":""}],"OSSEOUS":[{"def":"Composed of bone; resembling bone; capable of forming bone; bony; ossific.","pos":""}],"OSSETER":[{"def":"A species of sturgeon.","pos":""}],"OSSIANIC":[{"def":"Of or pertaining to, or characteristic of, Ossian, a legendary Erse or Celtic bard.","pos":""}],"OSSICLE":[{"def":"One of numerous small calcareous structures forming the skeleton of certain echinoderms, as the starfishes.","pos":""}],"OSSICULATED":[{"def":"Having small bones.","pos":""}],"OSSICULUM":[{"def":"Same as Ossicle.","pos":""}],"OSSIFEROUS":[{"def":"Containing or yielding bone.","pos":""}],"OSSIFIC":[{"def":"Capable of producing bone; having the power to change cartilage or other tissue into bone.","pos":""}],"OSSIFICATION":[{"def":"The formation of bone; the process, in the growth of an animal, by which inorganic material (mainly lime salts) is deposited in cartilage or membrane, forming bony tissue; ostosis.","pos":""}],"OSSIFIED":[{"def":"Changed to bone or something resembling bone; hardened by deposits of mineral matter of any kind; -- said of tissues.","pos":""}],"OSSIFRAGOUS":[{"def":"Serving to break bones; bone-breaking.","pos":""}],"OSSIFY":[{"def":"To form into bone; to change from a soft animal substance into bone, as by the deposition of lime salts.","pos":""}],"OSSIFYING":[{"def":"Changing into bone; becoming bone; as, the ossifying process.","pos":""}],"OSSIVOROUS":[{"def":"Feeding on bones; eating bones; as, ossivorous quadrupeds.","pos":""}],"OSSUARIUM":[{"def":"A charnel house; an ossuary.","pos":""}],"OSSUARY":[{"def":"A place where the bones of the dead are deposited; a charnel house.","pos":""}]}