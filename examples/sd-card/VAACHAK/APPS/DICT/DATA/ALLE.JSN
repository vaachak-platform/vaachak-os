{"ALLECRET":[{"def":"A kind of light armor used in the sixteenth century, esp.","pos":""}],"ALLECT":[{"def":"To allure; to entice.","pos":""}],"ALLECTATION":[{"def":"Enticement; allurement.","pos":""}],"ALLEDGE":[{"def":"Note: This spelling, corresponding to abridge, was once the prevailing one.","pos":""}],"ALLEGATION":[{"def":"A statement by a party of what he undertakes to prove, -- usually applied to each separate averment; the charge or matter undertaken to be proved.","pos":""}],"ALLEGE":[{"def":"To bring forward with positiveness; to declare; to affirm; to assert; as, to allege a fact.","pos":""},{"def":"To cite or quote; as, to allege the authority of a judge.","pos":""}],"ALLEGEABLE":[{"def":"Capable of being alleged or affirmed.","pos":""}],"ALLEGEMENT":[{"def":"With many complaints and allegements.","pos":""}],"ALLEGER":[{"def":"One who affirms or declares.","pos":""}],"ALLEGGE":[{"def":"See Alegge and Allay.","pos":""},{"def":"Pertaining to or designating the humid division of the Transition zone extending across the northern United States from New England to eastern Dakota, and including also most of Pennsylvania and the mountainous region as far south as northern Georgia.","pos":""}],"ALLEGIANCE":[{"def":"The tie or obligation, implied or expressed, which a subject owes to his sovereign or government; the duty of fidelity to one's king, government, or state.","pos":""},{"def":"Devotion; loyalty; as, allegiance to science.","pos":""}],"ALLEGIANT":[{"def":"Belonging to, or consisting of, allegory; of the nature of an allegory; describing by resemblances; figurative.","pos":""}],"ALLEGORIST":[{"def":"One who allegorizes; a writer of allegory.","pos":""}],"ALLEGORIZATION":[{"def":"The act of turning into allegory, or of understanding in an allegorical sense.","pos":""}],"ALLEGORIZE":[{"def":"To form or turn into allegory; as, to allegorize the history of a people.","pos":""},{"def":"To treat as allegorical; to understand in an allegorical sense; as, when a passage in a writer may understood literally or figuratively, he who gives it a figurative sense is said to allegorize it.","pos":""}],"ALLEGORIZER":[{"def":"One who allegorizes, or turns things into allegory; an allegorist.","pos":""}],"ALLEGORY":[{"def":"A figure representation which has a meaning beyond notion directly conveyed by the object painted or sculptured.","pos":""}],"ALLEGRESSE":[{"def":"Joy; gladsomeness.","pos":""}],"ALLEGRETTO":[{"def":"Quicker than andante, but not so quick as allegro.","pos":""},{"def":"A movement in this time.","pos":""}],"ALLEGRO":[{"def":"An allegro movement; a quick, sprightly strain or piece.","pos":""}],"ALLELOMORPH":[{"def":"One of the pure unit characters commonly existing singly or in pairs in the germ cells of Mendelian hybrids, and exhibited in varying proportion among the organisms themselves.","pos":""},{"def":"An exclamation signifying Praise ye Jehovah.","pos":""}],"ALLEMANDE":[{"def":"A dance in moderate twofold time, invented by the French in the reign of Louis XIV.","pos":""}],"ALLER":[{"def":"Same as Alder, of all.","pos":""}],"ALLERION":[{"def":"Am eagle without beak or feet, with expanded wings.","pos":""}],"ALLEVIATE":[{"def":"To lighten or lessen the force or weight of.","pos":""},{"def":"To lighten or lessen (physical or mental troubles); to mitigate, or make easier to be endured; as, to alleviate sorrow, pain, care, etc.","pos":""}],"ALLEVIATION":[{"def":"The act of alleviating; a lightening of weight or severity; mitigation; relief.","pos":""},{"def":"That which mitigates, or makes more tolerable.","pos":""}],"ALLEVIATIVE":[{"def":"Tending to alleviate.","pos":""},{"def":"That which alleviates.","pos":""}],"ALLEVIATOR":[{"def":"One who, or that which, alleviaties.","pos":""}],"ALLEY":[{"def":"Any passage having the entrance represented as wider than the exit, so as to give the appearance of length.","pos":""}],"ALLEYED":[{"def":"Furnished with alleys; forming an alley.","pos":""}]}