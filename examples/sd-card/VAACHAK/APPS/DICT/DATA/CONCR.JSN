{"CONCREATE":[{"def":"To create at the same time.","pos":""}],"CONCREMATION":[{"def":"The act of burning different things together.","pos":""}],"CONCREMENT":[{"def":"A growing together; the collection or mass formed by concretion, or natural union.","pos":""}],"CONCRESCENCE":[{"def":"Coalescence of particles; growth; increase by the addition of particles.","pos":""}],"CONCRESCIBLE":[{"def":"Capable of being changed from a liquid to a solid state.","pos":""}],"CONCRESCIVE":[{"def":"Growing together, or into union; uniting.","pos":""}],"CONCRETE":[{"def":"United in growth; hence, formed by coalition of separate particles into one mass; united in a solid form.","pos":""}],"CONCRETELY":[{"def":"In a concrete manner.","pos":""}],"CONCRETENESS":[{"def":"The quality of being concrete.","pos":""}],"CONCRETION":[{"def":"A rounded mass or nodule produced by an aggregation of the material around a center; as, the calcareous concretions common in beds of clay.","pos":""}],"CONCRETIONARY":[{"def":"Pertaining to, or formed by, concretion or aggregation; producing or containing concretions.","pos":""}],"CONCRETIVE":[{"def":"Promoting concretion.","pos":""}],"CONCRETIVELY":[{"def":"In a concrete manner.","pos":""}],"CONCRETURE":[{"def":"A mass formed by concretion.","pos":""}],"CONCREW":[{"def":"To grow together.","pos":""}],"CONCRIMINATION":[{"def":"A joint accusation.","pos":""}]}