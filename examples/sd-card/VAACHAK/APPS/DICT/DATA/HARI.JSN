{"HARIALI GRASS":[{"def":"The East Indian name of the Cynodon Dactylon; dog's-grass.","pos":""}],"HARICOT":[{"def":"A ragout or stew of meat with beans and other vegetables.","pos":""},{"def":"The ripe seeds, or the unripe pod, of the common string bean (Phaseolus vulgaris), used as a vegetable.","pos":""}],"HARIOLATION":[{"def":"Prognostication; soothsaying.","pos":""}]}