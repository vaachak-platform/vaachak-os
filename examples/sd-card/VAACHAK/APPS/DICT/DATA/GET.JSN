{"GET":[{"def":"Jet, the mineral.","pos":""}],"GET-PENNY":[{"def":"Something which gets or gains money; a successful affair.","pos":""}],"GET-UP":[{"def":"General composition or structure; manner in which the parts of a thing are combined; make-up; style of dress, etc.","pos":""}],"GETH":[{"def":"the original third pers.","pos":""}],"GETTABLE":[{"def":"That may be obtained.","pos":""}],"GETTER":[{"def":"One who gets, gains, obtains, acquires, begets, or procreates.","pos":""}],"GETTERUP":[{"def":"One who contrives, makes, or arranges for, anything, as a book, a machine, etc.","pos":""}],"GETTING":[{"def":"The act of obtaining or acquiring; acquisition.","pos":""},{"def":"That which is got or obtained; gain; profit.","pos":""}]}