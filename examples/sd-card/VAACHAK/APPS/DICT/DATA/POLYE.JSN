{"POLYEIDIC":[{"def":"Passing through several distinct larval forms; -- having several distinct kinds of young.","pos":""}],"POLYEIDISM":[{"def":"The quality or state of being polyeidic.","pos":""}],"POLYEMBRYONATE":[{"def":"Consisting of, or having, several embryos; polyembryonic.","pos":""}],"POLYEMBRYONIC":[{"def":"Pol`y*em`bry*on\"ic, a.","pos":""}],"POLYEMBRYONY":[{"def":"The production of two or more embryos in one seed, due either to the existence and fertilization of more than one embryonic sac or to the origination of embryos outside of the embryonic sac.","pos":""}]}