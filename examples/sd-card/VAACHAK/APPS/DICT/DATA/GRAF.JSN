{"GRAF":[{"def":"A German title of nobility, equivalent to earl in English, or count in French.","pos":""}],"GRAFF":[{"def":"A steward; an overseer.","pos":""}],"GRAFFAGE":[{"def":"The scarp of a ditch or moat.","pos":""}],"GRAFFER":[{"def":"a notary or scrivener.","pos":""}],"GRAFFITI":[{"def":"Inscriptions, figure drawings, etc.","pos":""}],"GRAFFITO":[{"def":"Production of decorative designs by scratching them through a surface of layer plaster, glazing, etc.","pos":""}],"GRAFT":[{"def":"To implant a portion of (living flesh or akin) in a lesion so as to form an organic union.","pos":""},{"def":"To join (one thing) to another as if by grafting, so as to bring about a close union.","pos":""}],"GRAFTAGE":[{"def":"The science of grafting, including the various methods of practice and details of operation.","pos":""}],"GRAFTER":[{"def":"An instrument by which grafting is facilitated.","pos":""}],"GRAFTING":[{"def":"The act or method of weaving a cover for a ring, rope end, etc.","pos":""},{"def":"The transplanting of a portion of flesh or skin to a denuded surface; autoplasty.","pos":""}]}