{"AMEBEAN":[{"def":"One of the Mohammedan nobility of Afghanistan and Scinde.","pos":""}],"AMEL":[{"def":"Enlightened all with stars, And richly ameled.","pos":""}],"AMELCORN":[{"def":"A variety of wheat from which starch is produced; -- called also French rice.","pos":""}],"AMELIORABLE":[{"def":"Capable of being ameliorated.","pos":""}],"AMELIORATE":[{"def":"To make better; to improve; to meliorate.","pos":""}],"AMELIORATION":[{"def":"The act of ameliorating, or the state of being ameliorated; making or becoming better; improvement; melioration.","pos":""}],"AMELIORATIVE":[{"def":"Tending to ameliorate; producing amelioration or improvement; as, ameliorative remedies, efforts.","pos":""}],"AMELIORATOR":[{"def":"One who ameliorates.","pos":""}],"AMEN":[{"def":"An expression used at the end of prayers, and meaning, So be it.","pos":""}],"AMENABILITY":[{"def":"The quality of being amenable; amenableness.","pos":""}],"AMENABLE":[{"def":"Easy to be led; governable, as a woman by her husband.","pos":""}],"AMENABLENESS":[{"def":"The quality or state of being amenable; liability to answer charges; answerableness.","pos":""}],"AMENABLY":[{"def":"In an amenable manner.","pos":""}],"AMENANCE":[{"def":"Behavior; bearing.","pos":""}],"AMEND":[{"def":"To change or modify in any way for the better; as, (a) by simply removing what is erroneous, corrupt, superfluous, faulty, and the like; (b) by supplying deficiencies; (c) by substituting something else in the place of what is removed; to rectify.","pos":""}],"AMENDABLE":[{"def":"Capable of being amended; as, an amendable writ or error.","pos":""}],"AMENDATORY":[{"def":"Supplying amendment; corrective; emendatory.","pos":""}],"AMENDE":[{"def":"A pecuniary punishment or fine; a reparation or recantation.","pos":""}],"AMENDMENT":[{"def":"Correction of an error in a writ or process.","pos":""}],"AMENDS":[{"def":"Compensation for a loss or injury; recompense; reparation.","pos":""}],"AMENITY":[{"def":"The quality of being pleasant or agreeable, whether in respect to situation, climate, manners, or disposition; pleasantness; civility; suavity; gentleness.","pos":""}],"AMENORRHOEA":[{"def":"Retention or suppression of the menstrual discharge.","pos":""}],"AMENORRHOEAL":[{"def":"Pertaining to amenorrhoea.","pos":""}],"AMENT":[{"def":"A species of inflorescence; a catkin.","pos":""}],"AMENTIA":[{"def":"Imbecility; total want of understanding.","pos":""}],"AMENTIFEROUS":[{"def":"Bearing catkins.","pos":""}],"AMENTIFORM":[{"def":"Shaped like a catkin.","pos":""}],"AMERCE":[{"def":"To punish by a pecuniary penalty, the amount of which is not fixed by law, but left to the discretion of the court; as, the amerced the criminal in the sum on the hundred dollars.","pos":""},{"def":"To punish, in general; to mulct.","pos":""}],"AMERCEABLE":[{"def":"Liable to be amerced.","pos":""}],"AMERCEMENT":[{"def":"The infliction of a penalty at the discretion of the court; also, a mulct or penalty thus imposed.","pos":""}],"AMERCER":[{"def":"One who amerces.","pos":""}],"AMERCIAMENT":[{"def":"Same as Amercement.","pos":""}],"AMERICAN":[{"def":"Of or pertaining to America; as, the American continent: American Indians.","pos":""},{"def":"Of or pertaining to the United States.","pos":""}],"AMERICAN PLAN":[{"def":"In hotels, aplan upon which guests pay for both room and board by the day, week, or other convenient period; -- contrasted with European plan.","pos":""},{"def":"A secret organization in the United States, formed in Iowa in 1887, ostensibly for the protection of American institutions by keeping Roman Catholics out of public office.","pos":""}],"AMERICANISM":[{"def":"Attachment to the United States.","pos":""},{"def":"A custom peculiar to the United States or to America; an American characteristic or idea.","pos":""}],"AMERICANIZATION":[{"def":"The process of Americanizing.","pos":""}],"AMERICANIZE":[{"def":"To render American; to assimilate to the Americans in customs, ideas, etc.","pos":""}],"AMES-ACE":[{"def":"Same as Ambs-ace.","pos":""}],"AMESS":[{"def":"Amice, a hood or cape.","pos":""}],"AMETABOLA":[{"def":"A group of insects which do not undergo any metamorphosis.","pos":""}],"AMETABOLIAN":[{"def":"Of or pertaining to insects that do undergo any metamorphosis.","pos":""},{"def":"Not undergoing any metamorphosis; as, ametabolic insects.","pos":""}],"AMETHODIST":[{"def":"One without method; a quack.","pos":""}],"AMETHYST":[{"def":"A variety of crystallized quartz, of a purple or bluish violet color, of different shades.","pos":""},{"def":"A purple color in a nobleman's escutcheon, or coat of arms.","pos":""}],"AMETHYSTINE":[{"def":"Resembling amethyst, especially in color; bluish violet.","pos":""},{"def":"Composed of, or containing, amethyst.","pos":""}],"AMETROPIA":[{"def":"Any abnormal condition of the refracting powers of the eye.","pos":""}]}