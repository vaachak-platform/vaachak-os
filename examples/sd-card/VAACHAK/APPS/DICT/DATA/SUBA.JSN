{"SUBACETATE":[{"def":"An acetate containing an excess of the basic constituent.","pos":""}],"SUBACID":[{"def":"Moderately acid or sour; as, some plants have subacid juices.","pos":""},{"def":"A substance moderately acid.","pos":""}],"SUBACRID":[{"def":"Moderalely acrid or harsh.","pos":""}],"SUBACROMIAL":[{"def":"Situated beneath the acromial process of the scapula.","pos":""}],"SUBACT":[{"def":"To reduce; to subdue.","pos":""}],"SUBACTION":[{"def":"The act of reducing to any state, as of mixing two bodies combletely.","pos":""}],"SUBACUTE":[{"def":"Moderalely acute.","pos":""}],"SUBADUNCATE":[{"def":"Somewhat hooked or curved.","pos":""}],"SUBADVOCATE":[{"def":"An under or subordinate advocate.","pos":""}],"SUBAERIAL":[{"def":"Beneath the sky; in the open air; specifically (Geol.","pos":""}],"SUBAGENCY":[{"def":"A subordinate agency.","pos":""}],"SUBAGENT":[{"def":"A person employed by an agent to transact the whole, or a part, of the business intrusted to the latter.","pos":""}],"SUBAGITATION":[{"def":"Unlawful sexual intercourse.","pos":""}],"SUBAH":[{"def":"A province; a government, as of a viceroy; also, a subahdar.","pos":""}],"SUBAHDAR":[{"def":"A viceroy; a governor of a subah; also, a native captain in the British native army.","pos":""},{"def":"The office or jurisdiction of a subahdar.","pos":""}],"SUBAID":[{"def":"To aid secretly; to assist in a private manner, or indirectly.","pos":""}],"SUBALMONER":[{"def":"An under almoner.","pos":""}],"SUBALPINE":[{"def":"Inhabiting the somewhat high slopes and summits of mountains, but considerably below the snow line.","pos":""}],"SUBALTERN":[{"def":"Asserting only a part of what is asserted in a related proposition.","pos":""}],"SUBALTERNANT":[{"def":"A universal proposition.","pos":""}],"SUBALTERNATE":[{"def":"Succeeding by turns; successive.","pos":""},{"def":"Subordinate; subaltern; inferior.","pos":""}],"SUBALTERNATING":[{"def":"Subalternate; successive.","pos":""}],"SUBALTERNATION":[{"def":"The state of being subalternate; succession of turns; subordination.","pos":""}],"SUBANGULAR":[{"def":"Slightly angular.","pos":""}],"SUBAPENNINE":[{"def":"Under, or at the foot of, the Apennine mountains; -- applied, in geology, to a series of Tertiary strata of the older Pliocene period.","pos":""}],"SUBAPICAL":[{"def":"Being under the apex; of or pertaining to the part just below the apex.","pos":""}],"SUBAQUANEOUS":[{"def":"Formed in or under water; as, subaqueous deposits.","pos":""}],"SUBARCTIC":[{"def":"Approximately arctic; belonging to a region just without the arctic circle.","pos":""},{"def":"Having a figure resembling that of a bow; somewhat curved or arched.","pos":""}],"SUBARRATION":[{"def":"The ancient custom of betrothing by the bestowal, on the part of the man, of marriage gifts or tokens, as money, rings, or other presents, upon the woman.","pos":""}],"SUBARYTENOID":[{"def":"Situated under the arytenoid cartilage of the larynx.","pos":""}],"SUBASTRAL":[{"def":"Beneath the stars or heavens; terrestrial.","pos":""}],"SUBASTRINGENT":[{"def":"Somewhat astringent.","pos":""}],"SUBATOM":[{"def":"A hypothetical component of a chemical atom, on the theory that the elements themselves are complex substances; -- called also atomicule.","pos":""}],"SUBAUD":[{"def":"To understand or supply in an ellipsis.","pos":""}],"SUBAUDITION":[{"def":"The act of understanding, or supplying, something not expressed; also, that which is so understood or supplied.","pos":""}],"SUBAXILLARY":[{"def":"Situated under the axilla, or armpit.","pos":""},{"def":"Placed under the axil, or angle formed by the branch of a plant with the stem, or a leaf with the branch.","pos":""}]}