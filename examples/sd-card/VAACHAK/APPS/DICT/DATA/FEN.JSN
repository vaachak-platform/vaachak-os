{"FEN":[{"def":"Low land overflowed, or covered wholly or partially with water, but producing sedge, coarse grasses, or other aquatic plants; boggy land; moor; marsh.","pos":""}],"FEN CRICKET":[{"def":"The mole cricket.","pos":""}],"FEN-SUCKED":[{"def":"Sucked out of marches.","pos":""}],"FENCE":[{"def":"A projection on the bolt, which passes through the tumbler gates in locking and unlocking.","pos":""}],"FENCE MONTH":[{"def":"the month in which female deer are fawning, when hunting is prohibited.","pos":""}],"FENCEFUL":[{"def":"Affording defense; defensive.","pos":""}],"FENCELESS":[{"def":"Without a fence; uninclosed; open; unguarded; defenseless.","pos":""}],"FENCER":[{"def":"One who fences; one who teaches or practices the art of fencing with sword or foil.","pos":""}],"FENCI-BLE":[{"def":"Capable of being defended, or of making or affording defense.","pos":""}],"FENCIBLE":[{"def":"A soldier enlisted for home service only; -- usually in the pl.","pos":""}],"FENCING":[{"def":"The art or practice of attack and defense with the sword, esp.","pos":""},{"def":"Disputing or debating in a manner resembling the art of fencers.","pos":""}],"FEND":[{"def":"To keep off; to prevent from entering or hitting; to ward off; to shut out; -- often with off; as, to fend off blows.","pos":""}],"FENDER":[{"def":"One who or that which defends or protects by warding off harm; as: (a) A screen to prevent coals or sparks of an open fire from escaping to the floor.","pos":""}],"FENERATE":[{"def":"To put money to usury; to lend on interest.","pos":""}],"FENERATION":[{"def":"The act of fenerating; interest.","pos":""}],"FENES-TELLA":[{"def":"Any small windowlike opening or recess, esp.","pos":""}],"FENESTRA":[{"def":"A small opening; esp.","pos":""}],"FENESTRAL":[{"def":"Pertaining to a window or to windows.","pos":""},{"def":"Of or pertaining to a fenestra.","pos":""}],"FENESTRATE":[{"def":"Having transparent spots, as the wings of certain butterflies.","pos":""}],"FENESTRATED":[{"def":"Having windows; characterized by windows.","pos":""}],"FENESTRATION":[{"def":"The arrangement and proportioning of windows; -- used by modern writers for the decorating of an architectural composition by means of the window (and door) openings, their ornaments, and proportions.","pos":""},{"def":"The state or condition of being fenestrated.","pos":""}],"FENESTRULE":[{"def":"One of the openings in a fenestrated structure.","pos":""}],"FENG-HWANG":[{"def":"A pheasantlike bird of rich plumage and graceful form and movement, fabled to appear in the land on the accession of a sage to the throne, or when right principles are about to prevail.","pos":""}],"FENG-SHUI":[{"def":"A system of spirit influences for good and evil believed by the Chinese to attend the natural features of landscape; also, a kind of geomancy dealing with these influences, used in determining sites for graves, houses, etc.","pos":""}],"FENGITE":[{"def":"A kind of marble or alabaster, sometimes used for windows on account of its transparency.","pos":""}],"FENIAN":[{"def":"A member of a secret organization, consisting mainly of Irishment, having for its aim the overthrow of English rule in ireland.","pos":""}],"FENIANISM":[{"def":"The principles, purposes, and methods of the Fenians.","pos":""}],"FENKS":[{"def":"The refuse whale blubber, used as a manure, and in the manufacture of Prussian blue.","pos":""}],"FENNEC":[{"def":"A small, African, foxlike animal (Vulpes zerda) of a pale fawn color, remarkable for the large size of its ears.","pos":""}],"FENNEL":[{"def":"A perennial plant of the genus Fæniculum (F.","pos":""}],"FENNISH":[{"def":"Abounding in fens; fenny.","pos":""}],"FENNY":[{"def":"Pertaining to, or inhabiting, a fen; abounding in fens; swampy; boggy.","pos":""}],"FENOWED":[{"def":"Corrupted; decayed; moldy.","pos":""}],"FENUGREEK":[{"def":"A plant (trigonella Foenum Græcum) cultivated for its strong- smelling seeds, which are \"now only used for giving false importance to horse medicine and damaged hay.","pos":""}]}