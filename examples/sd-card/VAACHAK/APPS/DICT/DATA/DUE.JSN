{"DUE":[{"def":"Owed, as a debt; that ought to be paid or done to or for another; payable; owing and demandable.","pos":""},{"def":"Justly claimed as a right or property; proper; suitable; becoming; appropriate; fit.","pos":""}],"DUEBILL":[{"def":"A brief written acknowledgment of a debt, not made payable to order, like a promissory note.","pos":""}],"DUEL":[{"def":"A combat between two persons, fought with deadly weapons, by agreement.","pos":""}],"DUELER":[{"def":"One who engages in a duel.","pos":""}],"DUELING":[{"def":"e act or practice of fighting in single combat.","pos":""}],"DUELIST":[{"def":"One who fights in single combat.","pos":""}],"DUELO":[{"def":"A duel; also, the rules of dueling.","pos":""}],"DUENESS":[{"def":"Quality of being due; debt; what is due or becoming.","pos":""}],"DUENNA":[{"def":"The chief lady in waiting on the queen of Spain.","pos":""},{"def":"An elderly lady holding a station between a governess and companion, and appointed to have charge over the younger ladies in a Spanish or a Portuguese family.","pos":""}],"DUET":[{"def":"A composition for two performers, whether vocal or instrumental.","pos":""}],"DUETTINO":[{"def":"A duet of short extent and concise form.","pos":""}]}