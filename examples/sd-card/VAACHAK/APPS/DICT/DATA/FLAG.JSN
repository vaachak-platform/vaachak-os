{"FLAG":[{"def":"To hang loose without stiffness; to bend down, as flexible bodies; to be loose, yielding, limp.","pos":""},{"def":"To droop; to grow spiritless; to lose vigor; to languish; as, the spirits flag; the streugth flags.","pos":""}],"FLAGELLANT":[{"def":"One of a fanatical sect which flourished in Europe in the 13th and 14th centuries, and maintained that flagellation was of equal virtue with baptism and the sacrament; -- called also disciplinant.","pos":""}],"FLAGELLATA":[{"def":"An order of Infusoria, having one or two long, whiplike cilia, at the anterior end.","pos":""}],"FLAGELLATE":[{"def":"To whip; to scourge; to flog.","pos":""}],"FLAGELLATION":[{"def":"A beating or flogging; a whipping; a scourging.","pos":""}],"FLAGELLATOR":[{"def":"One who practices flagellation; one who whips or scourges.","pos":""}],"FLAGELLIFORM":[{"def":"Shaped like a whiplash; long, slender, round, flexible, and (comming) tapering.","pos":""}],"FLAGELLUM":[{"def":"A young, flexible shoot of a plant; esp.","pos":""}],"FLAGEOLET":[{"def":"A small wooden pipe, having six or more holes, and a mouthpiece inserted at one end.","pos":""}],"FLAGGINESS":[{"def":"The condition of being flaggy; laxity; limberness.","pos":""}],"FLAGGING":[{"def":"A pavement or sidewalk of flagstones; flagstones, collectively.","pos":""}],"FLAGGY":[{"def":"Weak; flexible; limber.","pos":""},{"def":"Tasteless; insipid; as, a flaggy apple.","pos":""}],"FLAGITATE":[{"def":"To importune; to demand fiercely or with passion.","pos":""}],"FLAGITATION":[{"def":"Importunity; urgent demand.","pos":""}],"FLAGITIOUS":[{"def":"Disgracefully or shamefully criminal; grossly wicked; scandalous; shameful; -- said of acts, crimes, etc.","pos":""},{"def":"Guilty of enormous crimes; corrupt; profligate; -- said of persons.","pos":""}],"FLAGMAN":[{"def":"One who makes signals with a flag.","pos":""}],"FLAGON":[{"def":"A vessel with a narrow mouth, used for holding and conveying liquors.","pos":""}],"FLAGRANCY":[{"def":"A burning; great heat; inflammation.","pos":""},{"def":"The condition or quality of being flagrant; atrocity; heiniousness; enormity; excess.","pos":""}],"FLAGRANT":[{"def":"Flaming; inflamed; glowing; burning; ardent.","pos":""},{"def":"Actually in preparation, execution, or performance; carried on hotly; raging.","pos":""}],"FLAGRANTLY":[{"def":"In a flagrant manner.","pos":""}],"FLAGRATION":[{"def":"A conflagration.","pos":""}],"FLAGSHIP":[{"def":"The vessel which carries the commanding officer of a fleet or squadron and flies his distinctive flag or pennant.","pos":""}],"FLAGSTAFF":[{"def":"A staff on which a flag is hoisted.","pos":""}],"FLAGSTONE":[{"def":"A flat stone used in paving, or any rock which will split into such stones.","pos":""}],"FLAGWORM":[{"def":"A worm or grub found among flags and sedge.","pos":""}]}