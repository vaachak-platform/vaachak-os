{"TAI":[{"def":"Designating, or pertaining to, the chief linguistic stock of Indo-China, including the peoples of Siamese and Shan speech.","pos":""}],"TAIL":[{"def":"Limitation; abridgment.","pos":""}],"TAIL-BAY":[{"def":"One of the joists which rest one end on the wall and the other on a girder; also, the space between a wall and the nearest girder of a floor.","pos":""}],"TAIL-WATER":[{"def":"Water in a tailrace.","pos":""}],"TAILBLOCK":[{"def":"A block with a tail.","pos":""}],"TAILBOARD":[{"def":"The board at the rear end of a cart or wagon, which can be removed or let down, for convenience in loading or unloading.","pos":""}],"TAILED":[{"def":"Having a tail; having (such) a tail or (so many) tails; -- chiefly used in composition; as, bobtailed, longtailed, etc.","pos":""}],"TAILING":[{"def":"The part of a projecting stone or brick inserted in a wall.","pos":""},{"def":"Same as Tail, n.","pos":""}],"TAILLE":[{"def":"Any imposition levied by the king, or any other lord, upon his subjects.","pos":""},{"def":"The French name for the tenor voice or part; also, for the tenor viol or viola.","pos":""}],"TAILLIE":[{"def":"Same as Tailzie.","pos":""}],"TAILOR":[{"def":"One whose occupation is to cut out and make men's garments; also, one who cuts out and makes ladies' outer garments.","pos":""}],"TAILOR-MADE":[{"def":"Made by a tailor or according to a tailor's fashion; -- said specif.","pos":""}],"TAILORESS":[{"def":"A female tailor.","pos":""}],"TAILORING":[{"def":"The business or the work of a tailor or a tailoress.","pos":""}],"TAILPIECE":[{"def":"One of the timbers which tail into a header, in floor framing.","pos":""},{"def":"An ornament placed at the bottom of a short page to fill up the space, or at the end of a book.","pos":""}],"TAILPIN":[{"def":"The center in the spindle of a turning lathe.","pos":""}],"TAILRACE":[{"def":"The channel in which tailings, suspended in water, are conducted away.","pos":""}],"TAILSTOCK":[{"def":"The sliding block or support, in a lathe, which carries the dead spindle, or adjustable center.","pos":""}],"TAILZIE":[{"def":"An entailment or deed whereby the legal course of succession is cut off, and an arbitrary one substituted.","pos":""}],"TAIN":[{"def":"Thin tin plate; also, tin foil for mirrors.","pos":""}],"TAINT":[{"def":"A thrust with a lance, which fails of its intended effect.","pos":""},{"def":"An injury done to a lance in an encounter, without its being broken; also, a breaking of a lance in an encounter in a dishonorable or unscientific manner.","pos":""}],"TAINTLESS":[{"def":"Free from taint or infection; pure.","pos":""}],"TAINTLESSLY":[{"def":"In a taintless manner.","pos":""}],"TAINTURE":[{"def":"Taint; tinge; difilement; stain; spot.","pos":""}],"TAINTWORM":[{"def":"A destructive parasitic worm or insect larva.","pos":""},{"def":"Pertaining to or designating a dynasty with which one Hung-Siu- Chuen, a half-religious, half-political enthusiast, attempted to supplant the Manchu dynasty by the Taiping rebellion, incited by him in 1850 and suppressed by General Gordon about 1864.","pos":""}],"TAIT":[{"def":"A small nocturnal and arboreal Australian marsupial (Tarsipes rostratus) about the size of a mouse.","pos":""},{"def":"The common, or collared, peccary.","pos":""}]}