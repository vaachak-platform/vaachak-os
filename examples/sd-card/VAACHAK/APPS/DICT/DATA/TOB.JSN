{"TOBACCO":[{"def":"An American plant (Nicotiana Tabacum) of the Nightshade family, much used for smoking and chewing, and as snuff.","pos":""}],"TOBACCONING":[{"def":"Smoking tobacco.","pos":""}],"TOBACCONIST":[{"def":"A dealer in tobacco; also, a manufacturer of tobacco.","pos":""},{"def":"A smoker of tobacco.","pos":""}],"TOBIAS FISH":[{"def":"The lant, or sand eel.","pos":""}],"TOBIE":[{"def":"A kind of inferior cigar of a long slender shape, tapered at one end.","pos":""}],"TOBINE":[{"def":"A stout twilled silk used for dresses.","pos":""}],"TOBIT":[{"def":"A book of the Apocrypha.","pos":""}],"TOBOGGAN":[{"def":"A kind of sledge made of pliable board, turned up at one or both ends, used for coasting down hills or prepared inclined planes; also, a sleigh or sledge, to be drawn by dogs, or by hand, over soft and deep snow.","pos":""}],"TOBY":[{"def":"A small jug, pitcher, or mug, generally used for ale, shaped somewhat like a stout man, with a cocked hat forming the brim.","pos":""}]}