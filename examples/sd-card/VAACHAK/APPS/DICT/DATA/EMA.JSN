{"EMACERATE":[{"def":"To make lean or to become lean; to emaciate.","pos":""}],"EMACIATE":[{"def":"To lose flesh gradually and become very lean; to waste away in flesh.","pos":""}],"EMACIATION":[{"def":"The act of making very lean.","pos":""},{"def":"The state of being emaciated or reduced to excessive leanness; an excessively lean condition.","pos":""}],"EMACULATE":[{"def":"To clear from spots or stains, or from any imperfection.","pos":""}],"EMACULATION":[{"def":"The act of clearing from spots.","pos":""},{"def":"An art or process of flooding transparent colored glaze over designs stamped or molded on earthenware or porcelain.","pos":""}],"EMANANT":[{"def":"Issuing or flowing forth; emanating; passing forth into an act, or making itself apparent by an effect; -- said of mental acts; as, an emanant volition.","pos":""}],"EMANATE":[{"def":"To issue forth from a source; to flow out from more or less constantly; as, fragrance emanates from flowers.","pos":""},{"def":"To proceed from, as a source or fountain; to take origin; to arise, to originate.","pos":""}],"EMANATION":[{"def":"The act of flowing or proceeding from a fountain head or origin.","pos":""},{"def":"That which issues, flows, or proceeds from any object as a source; efflux; an effluence; as, perfume is an emanation from a flower.","pos":""}],"EMANATIVE":[{"def":"Issuing forth; effluent.","pos":""}],"EMANATIVELY":[{"def":"By an emanation.","pos":""}],"EMANATORY":[{"def":"Emanative; of the nature of an emanation.","pos":""}],"EMANCIPATE":[{"def":"To set free from the power of another; to liberate; as: (a) To set free, as a minor from a parent; as, a father may emancipate a child.","pos":""}],"EMANCIPATIONIST":[{"def":"An advocate of emancipation, esp.","pos":""}],"EMANCIPATOR":[{"def":"One who emancipates.","pos":""}],"EMANCIPATORY":[{"def":"Pertaining to emancipation, or tending to effect emancipation.","pos":""}],"EMANCIPIST":[{"def":"A freed convict.","pos":""}],"EMARGINATE":[{"def":"To take away the margin of.","pos":""},{"def":"Notched at the summit.","pos":""}],"EMARGINATELY":[{"def":"In an emarginate manner.","pos":""}],"EMARGINATION":[{"def":"The act of notching or indenting the margin, or the state of being so notched; also, a notch or shallow sinus in a margin.","pos":""}],"EMASCULATE":[{"def":"To deprive of virile or procreative power; to castrate power; to castrate; to geld.","pos":""},{"def":"To deprive of masculine vigor or spirit; to weaken; to render effeminate; to vitiate by unmanly softness.","pos":""}],"EMASCULATION":[{"def":"The act of depriving of virility, or the state of being so deprived; castration.","pos":""},{"def":"The act of depriving, or state of being deprived, of vigor or strength; unmanly weakness.","pos":""}],"EMASCULATOR":[{"def":"One who, or that which, emasculates.","pos":""}],"EMASCULATORY":[{"def":"Serving or tending to emasculate.","pos":""}]}