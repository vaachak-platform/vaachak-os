{"POP":[{"def":"The European redwing.","pos":""}],"POPE":[{"def":"A fish; the ruff.","pos":""}],"POPE'S HEAD":[{"def":"A long-handled brush for dusting ceilings, etc.","pos":""}],"POPEDOM":[{"def":"The place, office, or dignity of the pope; papal dignity.","pos":""},{"def":"The jurisdiction of the pope.","pos":""}],"POPELING":[{"def":"A petty or deputy pope.","pos":""},{"def":"An adherent of the pope.","pos":""}],"POPELOTE":[{"def":"A word variously explained as \"a little puppet,\" \"a little doll,\" or \"a young butterfly.","pos":""}],"POPERY":[{"def":"The religion of the Roman Catholic Church, comprehending doctrines and practices; -- generally used in an opprobrious sense.","pos":""}],"POPGUN":[{"def":"A child's gun; a tube and rammer for shooting pellets, with a popping noise, by compression of air.","pos":""}],"POPINJAY":[{"def":"A target in the form of a parrot.","pos":""},{"def":"A trifling, chattering, fop or coxcomb.","pos":""}],"POPISH":[{"def":"Of or pertaining to the pope; taught or ordained by the pope; hence, of or pertaining to the Roman Catholic Church; -- often used opprobriously.","pos":""}],"POPLAR":[{"def":"Any tree of the genus Populus; also, the timber, which is soft, and capable of many uses.","pos":""},{"def":"The timber of the tulip tree; -- called also white poplar.","pos":""}],"POPLIN":[{"def":"A fabric of many varieties, usually made of silk and worsted, - - used especially for women's dresses.","pos":""}],"POPLITEAL":[{"def":"Of or pertaining to the ham; in the region of the ham, or behind the knee joint; as, the popliteal space.","pos":""}],"POPPER":[{"def":"A utensil for popping corn, usually a wire basket with a long handle.","pos":""}],"POPPET":[{"def":"One of certain upright timbers on the bilge ways, used to support a vessel in launching.","pos":""},{"def":"An upright support or guide fastened at the bottom only.","pos":""}],"POPPIED":[{"def":"Mingled or interspersed with poppies.","pos":""},{"def":"Affected with poppy juice; hence, figuratively, drugged; drowsy; listless; inactive.","pos":""}],"POPPLE":[{"def":"To move quickly up and down; to bob up and down, as a cork on rough water; also, to bubble.","pos":""}],"POPPY":[{"def":"Any plant or species of the genus Papaver, herbs with showy polypetalous flowers and a milky juice.","pos":""},{"def":"A raised ornament frequently having the form of a final.","pos":""}],"POPULACE":[{"def":"The common people; the vulgar; the multitude, -- comprehending all persons not distinguished by rank, office, education, or profession.","pos":""}],"POPULAR":[{"def":"Of or pertaining to the common people, or to the whole body of the people, as distinguished from a select portion; as, the popular voice; popular elections.","pos":""},{"def":"Suitable to common people; easy to be comprehended; not abstruse; familiar; plain.","pos":""}],"POPULARES":[{"def":"The people or the people's party, in ancient Rome, as opposed to the optimates.","pos":""}],"POPULARITY":[{"def":"The quality or state of being popular; especially, the state of being esteemed by, or of being in favor with, the people at large; good will or favor proceeding from the people; as, the popularity of a law, statesman, or a book.","pos":""},{"def":"The quality or state of being adapted or pleasing to common, poor, or vulgar people; hence, cheapness; inferiority; vulgarity.","pos":""}],"POPULARIZATION":[{"def":"The act of making popular, or of introducing among the people.","pos":""}],"POPULARIZE":[{"def":"To make popular; to make suitable or acceptable to the common people; to make generally known; as, to popularize philosophy.","pos":""}],"POPULARIZER":[{"def":"One who popularizes.","pos":""}],"POPULARLY":[{"def":"In a popular manner; so as to be generally favored or accepted by the people; commonly; currently; as, the story was popularity reported.","pos":""}],"POPULARNESS":[{"def":"The quality or state of being popular; popularity.","pos":""}],"POPULATE":[{"def":"To furnish with inhabitants, either by natural increase or by immigration or colonization; to cause to be inhabited; to people.","pos":""}],"POPULATION":[{"def":"The act or process of populating; multiplication of inhabitants.","pos":""},{"def":"The whole number of people, or inhabitants, in a country, or portion of a country; as, a population of ten millions.","pos":""}],"POPULATOR":[{"def":"One who populates.","pos":""}],"POPULICIDE":[{"def":"Slaughter of the people.","pos":""}],"POPULIN":[{"def":"A glycoside, related to salicin, found in the bark of certain species of the poplar (Populus), and extracted as a sweet white crystalline substance.","pos":""}],"POPULISM":[{"def":"The political doctrines advocated by the People's party.","pos":""}],"POPULIST":[{"def":"A member of the People's party.","pos":""}],"POPULOUS":[{"def":"Abounding in people; full of inhabitants; containing many inhabitants in proportion to the extent of the country.","pos":""},{"def":"Popular; famous.","pos":""}]}