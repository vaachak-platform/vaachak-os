{"WULFENITE":[{"def":"Native lead molybdate occurring in tetragonal crystals, usually tabular, and of a bright orange-yellow to red, gray, or brown color; -- also called yellow lead ore.","pos":""}],"WULL":[{"def":"Pour out to all that wull.","pos":""}],"WUNG-OUT":[{"def":"Having the sails set in the manner called wing-and-wing.","pos":""}],"WURBAGOOL":[{"def":"A fruit bat (Pteropus medius) native of India.","pos":""}],"WURRALUH":[{"def":"The Australian white-quilled honey eater (Entomyza albipennis).","pos":""}]}