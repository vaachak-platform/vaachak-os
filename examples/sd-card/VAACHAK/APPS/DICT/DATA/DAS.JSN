{"DASEWE":[{"def":"To become dim-sighted; to become dazed or dazzled.","pos":""}],"DASH":[{"def":"To throw with violence or haste; to cause to strike violently or hastily; -- often used with against.","pos":""},{"def":"To break, as by throwing or by collision; to shatter; to crust; to frustrate; to ruin.","pos":""}],"DASHBOARD":[{"def":"A board placed on the fore part of a carriage, sleigh, or other vechicle, to intercept water, mud, or snow, thrown up by the heels of the horses; -- in England commonly called splashboard.","pos":""}],"DASHEEN":[{"def":"A tropical aroid (of the genus Caladium, syn.","pos":""}],"DASHER":[{"def":"That which dashes or agitates; as, the dasher of a churn.","pos":""},{"def":"A dashboard or splashboard.","pos":""}],"DASHING":[{"def":"Bold; spirited; showy.","pos":""}],"DASHINGLY":[{"def":"Conspicuously; showily.","pos":""}],"DASHISM":[{"def":"The character of making ostentatious or blustering parade or show.","pos":""}],"DASHPOT":[{"def":"A pneumatic or hydraulic cushion for a falling weight, as in the valve gear of a steam engine, to prevent shock.","pos":""}],"DASHY":[{"def":"Calculated to arrest attention; ostentatiously fashionable; showy.","pos":""}],"DASTARD":[{"def":"One who meanly shrinks from danger; an arrant coward; a poltroon.","pos":""}],"DASTARDIZE":[{"def":"To make cowardly; to intimidate; to dispirit; as, to dastardize my courage.","pos":""}],"DASTARDLINESS":[{"def":"The quality of being dastardly; cowardice; base fear.","pos":""}],"DASTARDLY":[{"def":"Meanly timid; cowardly; base; as, a dastardly outrage.","pos":""}],"DASTARDY":[{"def":"Base timidity; cowardliness.","pos":""}],"DASWE":[{"def":"See Dasewe [Obs.","pos":""}],"DASYMETER":[{"def":"An instrument for testing the density of gases, consisting of a thin glass globe, which is weighed in the gas or gases, and then in an atmosphere of known density.","pos":""}],"DASYPAEDES":[{"def":"Those birds whose young are covered with down when hatched.","pos":""}],"DASYPAEDIC":[{"def":"Pertaining to the Dasypædes; ptilopædic.","pos":""}],"DASYURE":[{"def":"A carnivorous marsupial quadruped of Australia, belonging to the genus Dasyurus.","pos":""}],"DASYURINE":[{"def":"Pertaining to, or like, the dasyures.","pos":""}]}