{"ERG":[{"def":"The unit of work or energy in the C.","pos":""}],"ERGAL":[{"def":"Potential energy; negative value of the force function.","pos":""}],"ERGAT":[{"def":"To deduce logically, as conclusions.","pos":""}],"ERGMETER":[{"def":"An instrument for measuring energy in ergs.","pos":""}],"ERGO":[{"def":"Therefore; consequently; -- often used in a jocular way.","pos":""}],"ERGOGRAPH":[{"def":"An instrument for measuring and recording the work done by a single muscle or set of muscles, the rate of fatigue, etc.","pos":""}],"ERGOMETER":[{"def":"A device for measuring, or an instrument for indicating, energy expended or work done; a dynamometer.","pos":""}],"ERGOT":[{"def":"A stub, like soft horn, about the size of a chestnut, situated behind and below the pastern joint.","pos":""},{"def":"See 2d Calcar, 3 (b).","pos":""}],"ERGOTIC":[{"def":"Pertaining to, or derived from, ergot; as, ergotic acid.","pos":""}],"ERGOTIN":[{"def":"An extract made from ergot.","pos":""}],"ERGOTINE":[{"def":"A powerful astringent alkaloid extracted from ergot as a brown, amorphous, bitter substance.","pos":""}],"ERGOTISM":[{"def":"A logical deduction.","pos":""}],"ERGOTIZED":[{"def":"Affected with the ergot fungus; as, ergotized rye.","pos":""},{"def":"A recompense formerly given by a murderer to the relatives of the murdered person.","pos":""}]}