{"DICACIOUS":[{"def":"Talkative; pert; saucy.","pos":""}],"DICACITY":[{"def":"Pertness; sauciness.","pos":""}],"DICALCIC":[{"def":"Having two atoms or equivalents of calcium to the molecule.","pos":""}],"DICARBONIC":[{"def":"Containing two carbon residues, or two carboxyl or radicals; as, oxalic acid is a dicarbonic acid.","pos":""}],"DICAST":[{"def":"A functionary in ancient Athens answering nearly to the modern juryman.","pos":""}],"DICASTERY":[{"def":"A court of justice; judgment hall.","pos":""}],"DICE":[{"def":"Small cubes used in gaming or in determining by chance; also, the game played with dice.","pos":""}],"DICEBOX":[{"def":"A box from which dice are thrown in gaming.","pos":""}],"DICENTRA":[{"def":"A genus of herbaceous plants, with racemes of two-spurred or heart-shaped flowers, including the Dutchman's breeches, and the more showy Bleeding heart (D.","pos":""}],"DICEPHALOUS":[{"def":"Having two heads on one body; double-headed.","pos":""}],"DICER":[{"def":"A player at dice; a dice player; a gamester.","pos":""}],"DICHASTIC":[{"def":"Capable of subdividing spontaneously.","pos":""}],"DICHLAMYDEOUS":[{"def":"Having two coverings, a calyx and in corolla.","pos":""}],"DICHLORIDE":[{"def":"Same as Bichloride.","pos":""}],"DICHOGAMOUS":[{"def":"Manifesting dichogamy.","pos":""}],"DICHOGAMY":[{"def":"The condition of certain species of plants, in which the stamens and pistil do not mature simultaneously, so that these plants can never fertilize themselves.","pos":""}],"DICHOTOMIST":[{"def":"One who dichotomizes.","pos":""}],"DICHOTOMIZE":[{"def":"To exhibit as a half disk.","pos":""}],"DICHOTOMOUS":[{"def":"Regularly dividing by pairs from bottom to top; as, a dichotomous stem.","pos":""}],"DICHOTOMY":[{"def":"That phase of the moon in which it appears bisected, or shows only half its disk, as at the quadratures.","pos":""},{"def":"Successive division and subdivision, as of a stem of a plant or a vein of the body, into two parts as it proceeds from its origin; successive bifurcation.","pos":""}],"DICHROIC":[{"def":"Having the property of dichroism; as, a dichroic crystal.","pos":""}],"DICHROISCOPE":[{"def":"Same as Dichroscope.","pos":""}],"DICHROISM":[{"def":"The property of presenting different colors by transmitted light, when viewed in two different directions, the colors being unlike in the direction of unlike or unequal axes.","pos":""}],"DICHROITE":[{"def":"Iolite; -- so called from its presenting two different colors when viewed in two different directions.","pos":""}],"DICHROMATE":[{"def":"A salt of chromic acid containing two equivalents of the acid radical to one of the base; -- called also bichromate.","pos":""}],"DICHROMATIC":[{"def":"Having two color varieties, or two phases differing in color, independently of age or sex, as in certain birds and insects.","pos":""}],"DICHROMATISM":[{"def":"The state of being dichromatic.","pos":""}],"DICHROMIC":[{"def":"Furnishing or giving two colors; -- said of defective vision, in which all the compound colors are resolvable into two elements instead of three.","pos":""}],"DICHROSCOPE":[{"def":"An instrument for examining the dichroism of crystals.","pos":""}],"DICHROSCOPIC":[{"def":"Pertaining to the dichroscope, or to observations with it.","pos":""}],"DICING":[{"def":"An ornamenting in squares or cubes.","pos":""},{"def":"Gambling with dice.","pos":""}],"DICKCISSEL":[{"def":"The American black-throated bunting (Spiza Americana).","pos":""}],"DICKENS":[{"def":"I can not tell what the dickens his name is.","pos":""}],"DICKER":[{"def":"The number or quantity of ten, particularly ten hides or skins; a dakir; as, a dicker of gloves.","pos":""},{"def":"A chaffering, barter, or exchange, of small wares; as, to make a dicker.","pos":""}],"DICLINIC":[{"def":"Having two of the intersections between the three axes oblique.","pos":""}],"DICLINOUS":[{"def":"Having the stamens and pistils in separate flowers.","pos":""}],"DICOCCOUS":[{"def":"Composed pf two coherent, one-seeded carpels; as, a dicoccous capsule.","pos":""}],"DICOTYLEDON":[{"def":"A plant whose seeds divide into two seed lobes, or cotyledons, in germinating.","pos":""}],"DICOTYLEDONOUS":[{"def":"Having two cotyledons or seed lobes; as, a dicotyledonous plant.","pos":""}],"DICROTISM":[{"def":"A condition in which there are two beats or waves of the arterial pulse to each beat of the heart.","pos":""}],"DICTAMEN":[{"def":"A dictation or dictate.","pos":""}],"DICTAMNUS":[{"def":"A suffrutescent, D.","pos":""}],"DICTAPHONE":[{"def":"A form of phonographic recorder and reproducer adapted for use in dictation, as in business.","pos":""}],"DICTATE":[{"def":"To tell or utter so that another may write down; to inspire; to compose; as, to dictate a letter to an amanuensis.","pos":""},{"def":"To say; to utter; to communicate authoritatively; to deliver (a command) to a subordinate; to declare with authority; to impose; as, to dictate the terms of a treaty; a general dictates orders to his troops.","pos":""}],"DICTATION":[{"def":"The act of dictating; the act or practice of prescribing; also that which is dictated.","pos":""},{"def":"The speaking to, or the giving orders to, in an overbearing manner; authoritative utterance; as, his habit, even with friends, was that of dictatio.","pos":""}],"DICTATOR":[{"def":"One who dictates; one who prescribes rules and maxims authoritatively for the direction of others.","pos":""},{"def":"One invested with absolute authority; especially, a magistrate created in times of exigence and distress, and invested with unlimited power.","pos":""}],"DICTATORIAL":[{"def":"Pertaining or suited to a dictator; absolute.","pos":""},{"def":"Characteristic of a dictator; imperious; dogmatical; overbearing; as, a dictatorial tone or manner.","pos":""}],"DICTATORSHIP":[{"def":"The office, or the term of office, of a dictator; hence, absolute power.","pos":""}],"DICTATORY":[{"def":"Dogmatical; overbearing; dictatorial.","pos":""}],"DICTATRESS":[{"def":"A woman who dictates or commands.","pos":""}],"DICTATURE":[{"def":"Office of a dictator; dictatorship.","pos":""}],"DICTION":[{"def":"Choice of words for the expression of ideas; the construction, disposition, and application of words in discourse, with regard to clearness, accuracy, variety, etc.","pos":""}],"DICTIONALRIAN":[{"def":"A lexicographer.","pos":""}],"DICTIONARY":[{"def":"A book containing the words of a language, arranged alphabetically, with explanations of their meanings; a lexicon; a vocabulary; a wordbook.","pos":""},{"def":"Hence, a book containing the words belonging to any system or province of knowledge, arranged alphabetically; as, a dictionary of medicine or of botany; a biographical dictionary.","pos":""}],"DICTOGRAPH":[{"def":"A telephonic instrument for office or other similar use, having a sound-magnifying device enabling the ordinary mouthpiece to be dispensed with.","pos":""}],"DICTUM":[{"def":"An authoritative statement; a dogmatic saying; an apothegm.","pos":""}],"DICTYOGEN":[{"def":"A plant with netveined leaves, and monocotyledonous embryos, belonging to the class Dictyogenæ, proposed by Lindley for the orders Dioscoreaceæ, Smilaceæ, Trilliaceæ, etc.","pos":""}],"DICYANIDE":[{"def":"A compound of a binary type containing two cyanogen groups or radicals; -- called also bicyanide.","pos":""}],"DICYEMATA":[{"def":"An order of worms parasitic in cephalopods.","pos":""}],"DICYEMID":[{"def":"Like or belonging to the Dicyemata.","pos":""},{"def":"One of the Dicyemata.","pos":""}],"DICYNODONT":[{"def":"One of a group of extinct reptiles having the jaws armed with a horny beak, as in turtles, and in the genus Dicynodon, supporting also a pair of powerful tusks.","pos":""}]}