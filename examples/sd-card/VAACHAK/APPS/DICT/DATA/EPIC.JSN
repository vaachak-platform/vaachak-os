{"EPIC":[{"def":"Narrated in a grand style; pertaining to or designating a kind of narrative poem, usually called an heroic poem, in which real or fictitious events, usually the achievements of some hero, are narrated in an elevated style.","pos":""}],"EPICAL":[{"def":"Poems which have an epical character.","pos":""}],"EPICARDIAC":[{"def":"Of or relating to the epicardium.","pos":""}],"EPICARDIUM":[{"def":"That of the pericardium which forms the outer surface of the heart; the cardiac pericardium.","pos":""}],"EPICARICAN":[{"def":"An isopod crustacean, parasitic on shrimps.","pos":""}],"EPICARP":[{"def":"The external or outermost layer of a fructified or ripened ovary.","pos":""}],"EPICEDE":[{"def":"A funeral song or discourse; an elegy.","pos":""}],"EPICEDIAL":[{"def":"Elegiac; funereal.","pos":""}],"EPICENE":[{"def":"Common to both sexes; -- a term applied, in grammar, to such nouns as have but one form of gender, either the masculine or feminine, to indicate animals of both sexes; as bos, for the ox and cow; sometimes applied to eunuchs and hermaphrodites.","pos":""}],"EPICENTRAL":[{"def":"Arising from the centrum of a vertebra.","pos":""}],"EPICERASTIC":[{"def":"Lenient; assuaging.","pos":""}],"EPICHIREMA":[{"def":"A syllogism in which the proof of the major or minor premise, or both, is introduced with the premises themselves, and the conclusion is derived in the ordinary manner.","pos":""}],"EPICHORDAL":[{"def":"Upon or above the notochord; -- applied esp.","pos":""}],"EPICHORIAL":[{"def":"In or of the country.","pos":""}],"EPICLEIDIUM":[{"def":"A projection, formed by a separate ossification, at the scapular end of the clavicle of many birds.","pos":""}],"EPICLINAL":[{"def":"Situated on the receptacle or disk of a flower.","pos":""},{"def":"A cavity formed by the invagination of the outer wall of the body, as the atrium of an amphioxus and possibly the body cavity of vertebrates.","pos":""}],"EPICOLIC":[{"def":"Situated upon or over the colon; -- applied to the region of the abdomen adjacent to the colon.","pos":""}],"EPICONDYLAR":[{"def":"Pertaining to, or resembling, an epicondyle.","pos":""}],"EPICONDYLE":[{"def":"A projection on the inner side of the distal end of the numerus; the internal condyle.","pos":""}],"EPICORACOID":[{"def":"A ventral cartilaginous or bony element of the coracoid in the shoulder girdle of some vertebrates.","pos":""}],"EPICRANIAL":[{"def":"Pertaining to the epicranium; as epicranial muscles.","pos":""}],"EPICRANIUM":[{"def":"The upper and superficial part of the head, including the scalp, muscles, etc.","pos":""},{"def":"The dorsal wall of the head of insects.","pos":""}],"EPICURE":[{"def":"A follower of Epicurus; an Epicurean.","pos":""},{"def":"One devoted to dainty or luxurious sensual enjoyments, esp.","pos":""}],"EPICUREAN":[{"def":"Pertaining to Epicurus, or following his philosophy.","pos":""},{"def":"Given to luxury; adapted to luxurious tastes; luxurious; pertaining to good eating.","pos":""}],"EPICUREANISM":[{"def":"Attachment to the doctrines of Epicurus; the principles or belief of Epicurus.","pos":""}],"EPICURISM":[{"def":"The doctrines of Epicurus.","pos":""},{"def":"Epicurean habits of living; luxury.","pos":""}],"EPICURIZE":[{"def":"To profess or tend towards the doctrines of Epicurus.","pos":""},{"def":"To feed or indulge like an epicure.","pos":""}],"EPICYCLE":[{"def":"A circle, whose center moves round in the circumference of a greater circle; or a small circle, whose center, being fixed in the deferent of a planet, is carried along with the deferent, and yet, by its own peculiar motion, carries the body of the planet fastened to it round its proper center.","pos":""},{"def":"A circle which rolls on the circumference of another circle, either externally or internally.","pos":""}],"EPICYCLIC":[{"def":"Pertaining to, resembling, or having the motion of, an epicycle.","pos":""}],"EPICYCLOID":[{"def":"A curve traced by a point in the circumference of a circle which rolls on the convex side of a fixed circle.","pos":""}],"EPICYCLOIDAL":[{"def":"Pertaining to the epicycloid, or having its properties.","pos":""}]}