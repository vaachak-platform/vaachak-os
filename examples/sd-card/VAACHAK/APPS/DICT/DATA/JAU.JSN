{"JAUNCE":[{"def":"To ride hard; to jounce.","pos":""}],"JAUNDICE":[{"def":"A morbid condition, characterized by yellowness of the eyes, skin, and urine, whiteness of the fæces, constipation, uneasiness in the region of the stomach, loss of appetite, and general languor and lassitude.","pos":""}],"JAUNDICED":[{"def":"Prejudiced; envious; as, a jaundiced judgment.","pos":""}],"JAUNT":[{"def":"To ramble here and there; to stroll; to make an excursion.","pos":""},{"def":"To ride on a jaunting car.","pos":""}],"JAUNTILY":[{"def":"In a jaunty manner.","pos":""}],"JAUNTINESS":[{"def":"The quality of being jaunty.","pos":""}],"JAUNTY":[{"def":"Airy; showy; finical; hence, characterized by an affected or fantastical manner.","pos":""}]}