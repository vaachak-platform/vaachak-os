{"HEAD":[{"def":"Tiles laid at the eaves of a house.","pos":""}],"HEAD-CHEESE":[{"def":"A dish made of portions of the head, or head and feet, of swine, cut up fine, seasoned, and pressed into a cheeselike mass.","pos":""}],"HEAD-HUNTER":[{"def":"A member of any tribe or race of savages who have the custom of decapitating human beings and preserving their heads as trophies.","pos":""}],"HEAD-LUGGED":[{"def":"Lugged or dragged by the head.","pos":""}],"HEADACHE":[{"def":"Pain in the head; ceph \"Headaches and shivering fits.","pos":""}],"HEADACHY":[{"def":"Afflicted with headache.","pos":""}],"HEADBAND":[{"def":"A fillet; a band for the head.","pos":""},{"def":"The band at each end of the back of a book.","pos":""}],"HEADBOARD":[{"def":"A board or boarding which marks or forms the head of anything; as, the headboard of a bed; the headboard of a grave.","pos":""},{"def":"A petty constable.","pos":""}],"HEADDRESS":[{"def":"A covering or ornament for the head; a headtire.","pos":""},{"def":"A manner of dressing the hair or of adorning it, whether with or without a veil, ribbons, combs, etc.","pos":""}],"HEADED":[{"def":"Furnished with a head (commonly as denoting intellectual faculties); -- used in composition; as, clear-headed, long-headed, thick-headed; a many-headed monster.","pos":""},{"def":"Formed into a head; as, a headed cabbage.","pos":""}],"HEADER":[{"def":"With the head foremost.","pos":""}],"HEADFISH":[{"def":"The sunfish (Mola).","pos":""}],"HEADILY":[{"def":"In a heady or rash manner; hastily; rashly; obstinately.","pos":""}],"HEADINESS":[{"def":"The quality of being heady.","pos":""}],"HEADING":[{"def":"A gallery, drift, or adit in a mine; also, the end of a drift or gallery; the vein above a drift.","pos":""},{"def":"The extension of a line ruffling above the line of stitch.","pos":""}],"HEADLAND":[{"def":"A cape; a promontory; a point of land projecting into the sea or other expanse of water.","pos":""},{"def":"A ridge or strip of unplowed at the ends of furrows, or near a fence.","pos":""}],"HEADLESS":[{"def":"Having no head; beheaded; as, a headless body, neck, or carcass.","pos":""},{"def":"Destitute of a chief or leader.","pos":""}],"HEADLIGHT":[{"def":"A light, with a powerful reflector, placed at the head of a locomotive, or in front of it, to throw light on the track at night, or in going through a dark tunnel.","pos":""}],"HEADLINE":[{"def":"The line at the head or top of a page.","pos":""}],"HEADLONG":[{"def":"With the head foremost; as, to fall headlong.","pos":""},{"def":"Rashly; precipitately; without deliberation.","pos":""}],"HEADMAN":[{"def":"A head or leading man, especially of a village community.","pos":""},{"def":"An old name for the condition of the skull, in which the bones ride, or are shot, over each other at the sutures.","pos":""}],"HEADMOST":[{"def":"Most advanced; most forward; as, the headmost ship in a fleet.","pos":""}],"HEADNOTE":[{"def":"A note at the head of a page or chapter; in law reports, an abstract of a case, showing the principles involved and the opinion of the court.","pos":""}],"HEADPIECE":[{"def":"A cap of defense; especially, an open one, as distinguished from the closed helmet of the Middle Ages.","pos":""}],"HEADQUARTERS":[{"def":"The quarters or place of residence of any chief officer, as the general in command of an army, or the head of a police force; the place from which orders or instructions are issued; hence, the center of authority or order.","pos":""}],"HEADRACE":[{"def":"See Race, a water course.","pos":""}],"HEADROPE":[{"def":"That part of a boltrope which is sewed to the upper edge or head of a sail.","pos":""}],"HEADSAIL":[{"def":"Any sail set forward of the foremast.","pos":""}],"HEADSHAKE":[{"def":"A significant shake of the head, commonly as a signal of denial.","pos":""}],"HEADSHIP":[{"def":"Authority or dignity; chief place.","pos":""}],"HEADSMAN":[{"def":"An executioner who cuts off heads.","pos":""}],"HEADSPRING":[{"def":"Fountain; source.","pos":""}],"HEADSTALL":[{"def":"That part of a bridle or halter which encompasses the head.","pos":""}],"HEADSTOCK":[{"def":"A part (usually separate from the bed or frame) for supporting some of the principal working parts of a machine; as: (a) The part of a lathe that holds the revolving spindle and its attachments; -- also called poppet head, the opposite corresponding part being called a tailstock.","pos":""}],"HEADSTONE":[{"def":"The principal stone in a foundation; the chief or corner stone.","pos":""},{"def":"The stone at the head of a grave.","pos":""}],"HEADSTRONG":[{"def":"Not easily restrained; ungovernable; obstinate; stubborn.","pos":""},{"def":"Directed by ungovernable will, or proceeding from obstinacy.","pos":""}],"HEADTIRE":[{"def":"The manner of dressing the head, as at a particular time and place.","pos":""}],"HEADWATER":[{"def":"The source and upper part of a stream; -- commonly used in the plural; as, the headwaters of the Missouri.","pos":""}],"HEADWAY":[{"def":"Clear space under an arch, girder, and the like, sufficient to allow of easy passing underneath.","pos":""}],"HEADY":[{"def":"Willful; rash; precipitate; hurried on by will or passion; ungovernable.","pos":""},{"def":"Apt to affect the head; intoxicating; strong.","pos":""}]}