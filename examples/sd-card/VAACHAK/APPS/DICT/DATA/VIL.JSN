{"VILAYET":[{"def":"One of the chief administrative divisions or provinces of the Ottoman Empire; -- formerly called eyalet.","pos":""}],"VILE":[{"def":"Low; base; worthless; mean; despicable.","pos":""},{"def":"Morally base or impure; depraved by sin; hateful; in the sight of God and men; sinful; wicked; bad.","pos":""}],"VILED":[{"def":"Abusive; scurrilous; defamatory; vile.","pos":""}],"VILIFICATION":[{"def":"The act of vilifying or defaming; abuse.","pos":""}],"VILIFIER":[{"def":"One who vilifies or defames.","pos":""}],"VILIFY":[{"def":"To make vile; to debase; to degrade; to disgrace.","pos":""},{"def":"To degrade or debase by report; to defame; to traduce; to calumniate.","pos":""}],"VILIPEND":[{"def":"To value lightly; to depreciate; to slight; to despise.","pos":""}],"VILIPENDENCY":[{"def":"Disesteem; slight; disparagement.","pos":""}],"VILITY":[{"def":"Vileness; baseness.","pos":""}],"VILL":[{"def":"A small collection of houses; a village.","pos":""}],"VILLA":[{"def":"A country seat; a country or suburban residence of some pretensions to elegance.","pos":""}],"VILLAGE":[{"def":"A small assemblage of houses in the country, less than a town or city.","pos":""}],"VILLAGER":[{"def":"An inhabitant of a village.","pos":""}],"VILLAGERY":[{"def":"Villages; a district of villages.","pos":""}],"VILLAIN":[{"def":"One who holds lands by a base, or servile, tenure, or in villenage; a feudal tenant of the lowest class, a bondman or servant.","pos":""}],"VILLAINOUS":[{"def":"Base; vile; mean; depraved; as, a villainous person or wretch.","pos":""},{"def":"Proceeding from, or showing, extreme depravity; suited to a villain; as, a villainous action.","pos":""}],"VILLAINY":[{"def":"The quality or state of being a villain, or villainous; extreme depravity; atrocious wickedness; as, the villainy of the seducer.","pos":""},{"def":"Abusive, reproachful language; discourteous speech; foul talk.","pos":""}],"VILLANAGE":[{"def":"The state of a villain, or serf; base servitude; tenure on condition of doing the meanest services for the lord.","pos":""}],"VILLANELLA":[{"def":"An old rustic dance, accompanied with singing.","pos":""}],"VILLANELLE":[{"def":"A poem written in tercets with but two rhymes, the first and third verse of the first stanza alternating as the third verse in each successive stanza and forming a couplet at the close.","pos":""}],"VILLANIZE":[{"def":"To make vile; to debase; to degrade; to revile.","pos":""}],"VILLANIZER":[{"def":"One who villanizes.","pos":""},{"def":"See Villainous, etc.","pos":""}],"VILLATIC":[{"def":"Of or pertaining to a farm or a village; rural.","pos":""}],"VILLENOUS":[{"def":"Of or pertaining to a villein.","pos":""}],"VILLIFORM":[{"def":"Having the form or appearance of villi; like close-set fibers, either hard or soft; as, the teeth of perch are villiform.","pos":""}],"VILLOSITY":[{"def":"A coating of long, slender hairs.","pos":""}],"VILLOUS":[{"def":"Furnished or clothed with villi.","pos":""}],"VILLUS":[{"def":"One of the minute papillary processes on certain vascular membranes; a villosity; as, villi cover the lining of the small intestines of many animals and serve to increase the absorbing surface.","pos":""},{"def":"Fine hairs on plants, resembling the pile of velvet.","pos":""}]}