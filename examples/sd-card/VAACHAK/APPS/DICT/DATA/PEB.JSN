{"PEBA":[{"def":"An armadillo (Tatusia novemcincta) which is found from Texas to Paraguay; -- called also tatouhou.","pos":""}],"PEBBLE":[{"def":"A small roundish stone or bowlder; especially, a stone worn and rounded by the action of water; a pebblestone.","pos":""},{"def":"Transparent and colorless rock crystal; as, Brazilian pebble; -- so called by opticians.","pos":""}],"PEBBLED":[{"def":"Abounding in pebbles.","pos":""}],"PEBBLESTONE":[{"def":"A pebble; also, pebbles collectively.","pos":""}],"PEBBLY":[{"def":"Full of pebbles; pebbled.","pos":""}],"PEBRINE":[{"def":"An epidemic disease of the silkworm, characterized by the presence of minute vibratory corpuscles in the blood.","pos":""}]}