{"EXPOLIATION":[{"def":"See Exspoliation.","pos":""}],"EXPOLISH":[{"def":"To polish thoroughly.","pos":""}],"EXPONE":[{"def":"To expound; to explain; also, to expose; to imperil.","pos":""}],"EXPONENT":[{"def":"A number, letter, or any quantity written on the right hand of and above another quantity, and denoting how many times the latter is repeated as a factor to produce the power indicated; Note: thus a2 denotes the second power, and an the xth power, of a (2 and x being the exponents).","pos":""}],"EXPONENTIAL":[{"def":"Pertaining to exponents; involving variable exponents; as, an exponential expression; exponential calculus; an exponential function.","pos":""}],"EXPORT":[{"def":"To carry away; to remove.","pos":""},{"def":"To carry or send abroad, or out of a country, especially to foreign countries, as merchandise or commodities in the way of commerce; -- the opposite of import; as, to export grain, cotton, cattle, goods, etc.","pos":""}],"EXPORTABILITY":[{"def":"The quality or state of being suitable for exportation.","pos":""}],"EXPORTABLE":[{"def":"Suitable for exportation; as, exportable products.","pos":""}],"EXPORTATION":[{"def":"The act of exporting; the act of conveying or sending commodities abroad or to another country, in the course of commerce.","pos":""},{"def":"Commodity exported; an export.","pos":""}],"EXPORTER":[{"def":"One who exports; the person who sends goods or commodities to a foreign country, in the way of commerce; -- opposed to importer.","pos":""}],"EXPOSE":[{"def":"To set forth; to set out to public view; to exhibit; to show; to display; as, to expose goods for sale; to expose pictures to public inspection.","pos":""},{"def":"To lay bare; to lay open to attack, danger, or anything objectionable; to render accessible to anything which may affect, especially detrimentally; to make liable; as, to expose one's self to the heat of the sun, or to cold, insult, danger, or ridicule; to expose an army to destruction or defeat.","pos":""}],"EXPOSEDNESS":[{"def":"The state of being exposed, laid open, or unprotected; as, an exposedness to sin or temptation.","pos":""}],"EXPOSER":[{"def":"One who exposes or discloses.","pos":""}],"EXPOSITION":[{"def":"The act of exposing or laying open; a setting out or displaying to public view.","pos":""},{"def":"The act of expounding or of laying open the sense or meaning of an author, or a passage; explanation; interpretation; the sense put upon a passage; a law, or the like, by an interpreter; hence, a work containing explanations or interpretations; a commentary.","pos":""}],"EXPOSITIVE":[{"def":"Serving to explain; expository.","pos":""}],"EXPOSITOR":[{"def":"One who, or that which, expounds or explains; an expounder; a commentator.","pos":""}],"EXPOSITORY":[{"def":"Pertaining to, or containing, exposition; serving to explain; explanatory; illustrative; exegetical.","pos":""},{"def":"From or by an after act, or thing done afterward; in consequence of a subsequent act; retrospective.","pos":""}],"EXPOSTULATE":[{"def":"To reason earnestly with a person on some impropriety of his conduct, representing the wrong he has done or intends, and urging him to make redress or to desist; to remonstrate; -- followed by with.","pos":""}],"EXPOSTULATION":[{"def":"The act of expostulating or reasoning with a person in opposition to some impropriety of conduct; remonstrance; earnest and kindly protest; dissuasion.","pos":""}],"EXPOSTULATOR":[{"def":"One who expostulates.","pos":""}],"EXPOSTULATORY":[{"def":"Containing expostulation or remonstrance; as, an expostulatory discourse or letter.","pos":""}],"EXPOSTURE":[{"def":"Ex*pos\"ture (;135), n.","pos":""}],"EXPOSURE":[{"def":"The exposing of a sensitized plate to the action of light.","pos":""}],"EXPOUND":[{"def":"To lay open; to expose to view; to examine.","pos":""},{"def":"To lay open the meaning of; to explain; to clear of obscurity; to interpret; as, to expound a text of Scripture, a law, a word, a meaning, or a riddle.","pos":""}],"EXPOUNDER":[{"def":"One who expounds or explains; an interpreter.","pos":""}]}