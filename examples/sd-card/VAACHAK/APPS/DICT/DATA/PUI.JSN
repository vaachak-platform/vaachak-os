{"PUISNE":[{"def":"Younger or inferior in rank; junior; associate; as, a chief justice and three puisne justices of the Court of Common Pleas; the puisne barons of the Court of Exchequer.","pos":""}],"PUISNY":[{"def":"Puisne; younger; inferior; petty; unskilled.","pos":""}],"PUISSANCE":[{"def":"Power; strength; might; force; potency.","pos":""}],"PUISSANT":[{"def":"Powerful; strong; mighty; forcible; as, a puissant prince or empire.","pos":""}],"PUISSANTLY":[{"def":"In a puissant manner; powerfully; with great strength.","pos":""}],"PUISSANTNESS":[{"def":"The state or quality of being puissant; puissance; power.","pos":""}],"PUIT":[{"def":"A well; a small stream; a fountain; a spring.","pos":""}]}