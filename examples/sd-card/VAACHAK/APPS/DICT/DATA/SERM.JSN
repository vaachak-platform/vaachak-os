{"SERMOCINATION":[{"def":"The making of speeches or sermons; sermonizing.","pos":""}],"SERMOCINATOR":[{"def":"One who makes sermons or speeches.","pos":""}],"SERMON":[{"def":"A discourse or address; a talk; a writing; as, the sermens of Chaucer.","pos":""},{"def":"Specifically, a discourse delivered in public, usually by a clergyman, for the purpose of religious instruction and grounded on some text or passage of Scripture.","pos":""}],"SERMONER":[{"def":"A preacher; a sermonizer.","pos":""}],"SERMONET":[{"def":"Like, or appropriate to, a sermon; grave and didactic.","pos":""}],"SERMONING":[{"def":"The act of discoursing; discourse; instruction; preaching.","pos":""}],"SERMONISH":[{"def":"Resembling a sermon.","pos":""}],"SERMONIZE":[{"def":"To compose or write a sermon or sermons; to preach.","pos":""},{"def":"To inculcate rigid rules.","pos":""}],"SERMONIZER":[{"def":"One who sermonizes.","pos":""}]}