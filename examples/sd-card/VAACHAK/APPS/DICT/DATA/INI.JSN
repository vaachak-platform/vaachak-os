{"INIA":[{"def":"A South American freshwater dolphin (Inia Boliviensis).","pos":""}],"INIAL":[{"def":"Pertaining to the inion.","pos":""}],"INIMAGINABLE":[{"def":"Unimaginable; inconceivable.","pos":""}],"INIMICAL":[{"def":"Having the disposition or temper of an enemy; unfriendly; unfavorable; -- chiefly applied to private, as hostile is to public, enmity.","pos":""},{"def":"Opposed in tendency, influence, or effects; antagonistic; inconsistent; incompatible; adverse; repugnant.","pos":""}],"INIMICALITY":[{"def":"The state or quality of being inimical or hostile; hostility; unfriendliness.","pos":""}],"INIMICALLY":[{"def":"In an inimical manner.","pos":""}],"INIMICITIOUS":[{"def":"Inimical; unfriendly.","pos":""}],"INIMICOUS":[{"def":"Inimical; hurtful.","pos":""}],"INIMITABILITY":[{"def":"The quality or state of being inimitable; inimitableness.","pos":""}],"INIMITABLE":[{"def":"Not capable of being imitated, copied, or counterfeited; beyond imitation; surpassingly excellent; matchless; unrivaled; exceptional; unique; as, an inimitable style; inimitable eloquence.","pos":""}],"INION":[{"def":"The external occipital protuberance of the skull.","pos":""}],"INIQUITOUS":[{"def":"Characterized by iniquity; unjust; wicked; as, an iniquitous bargain; an iniquitous proceeding.","pos":""}],"INIQUITOUSLY":[{"def":"In an iniquitous manner; unjustly; wickedly.","pos":""}],"INIQUITY":[{"def":"Absence of, or deviation from, just dealing; want of rectitude or uprightness; gross injustice; unrighteousness; wickedness; as, the iniquity of bribery; the iniquity of an unjust judge.","pos":""},{"def":"An iniquitous act or thing; a deed of injustice o Milton.","pos":""}],"INIRRITABLE":[{"def":"Not irritable; esp.","pos":""}],"INIRRITATIVE":[{"def":"Not accompanied with excitement; as, an inirritative fever.","pos":""}],"INISLE":[{"def":"To form into an island; to surround.","pos":""}],"INITIAL":[{"def":"Of or pertaining to the beginning; marking the commencement; incipient; commencing; as, the initial symptoms of a disease.","pos":""},{"def":"Placed at the beginning; standing at the head, as of a list or series; as, the initial letters of a name.","pos":""}],"INITIALLY":[{"def":"In an initial or incipient manner or degree; at the beginning.","pos":""}],"INITIATE":[{"def":"To introduce by a first act; to make a beginning with; to set afoot; to originate; to commence; to begin or enter upon.","pos":""},{"def":"To acquaint with the beginnings; to instruct in the rudiments or principles; to introduce.","pos":""}],"INITIATION":[{"def":"The act of initiating, or the process of being initiated or introduced; as, initiation into a society, into business, literature, etc.","pos":""},{"def":"The form or ceremony by which a person is introduced into any society; mode of entrance into an organized body; especially, the rite of admission into a secret society or order.","pos":""}],"INITIATIVE":[{"def":"Serving to initiate; inceptive; initiatory; introductory; preliminary.","pos":""}],"INITIATOR":[{"def":"One who initiates.","pos":""}],"INITIATORY":[{"def":"Suitable for an introduction or beginning; introductory; prefatory; as, an initiatory step.","pos":""},{"def":"Tending or serving to initiate; introducing by instruction, or by the use and application of symbols or ceremonies; elementary; rudimentary.","pos":""}],"INITION":[{"def":"Initiation; beginning.","pos":""}]}