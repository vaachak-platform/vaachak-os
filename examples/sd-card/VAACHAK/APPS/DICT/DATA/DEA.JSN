{"DEACON":[{"def":"An officer in Christian churches appointed to perform certain subordinate duties varying in different communions.","pos":""}],"DEACONESS":[{"def":"A female deacon; as: (a) (Primitive Ch.","pos":""},{"def":"A woman set apart for church work by a bishop.","pos":""}],"DEACONHOOD":[{"def":"The state of being a deacon; office of a deacon; deaconship.","pos":""}],"DEACONSHIP":[{"def":"The office or ministry of a deacon or deaconess.","pos":""}],"DEAD":[{"def":"Cut off from the rights of a citizen; deprived of the power of enjoying the rights of property; as, one banished or becoming a monk is civilly dead.","pos":""},{"def":"Not imparting motion or power; as, the dead spindle of a lathe, etc.","pos":""}],"DEAD-EYE":[{"def":"A round, flattish, wooden block, encircled by a rope, or an iron band, and pierced with three holes to receive the lanyard; -- used to extend the shrouds and stays, and for other purposes.","pos":""}],"DEAD-PAY":[{"def":"Pay drawn for soldiers, or others, really dead, whose names are kept on the rolls.","pos":""}],"DEAD-RECKONING":[{"def":"See under Dead, a.","pos":""}],"DEAD-STROKE":[{"def":"Making a stroke without recoil; deadbeat.","pos":""}],"DEADBEAT":[{"def":"Making a beat without recoil; giving indications by a single beat or excursion; -- said of galvanometers and other instruments in which the needle or index moves to the extent of its deflection and stops with little or no further oscillation.","pos":""}],"DEADEN":[{"def":"To make as dead; to impair in vigor, force, activity, or sensation; to lessen the force or acuteness of; to blunt; as, to deaden the natural powers or feelings; to deaden a sound.","pos":""},{"def":"To lessen the velocity or momentum of; to retard; as, to deaden a ship's headway.","pos":""}],"DEADENER":[{"def":"One who, or that which, deadens or checks.","pos":""}],"DEADHEAD":[{"def":"Having a dull, faint heart; spiritless; listless.","pos":""}],"DEADHOUSE":[{"def":"A morgue; a place for the temporary reception and exposure of dead bodies.","pos":""}],"DEADISH":[{"def":"Somewhat dead, dull, or lifeless; deathlike.","pos":""}],"DEADLATCH":[{"def":"A kind of latch whose bolt may be so locked by a detent that it can not be opened from the inside by the handle, or from the outside by the latch key.","pos":""}],"DEADLIGHT":[{"def":"A strong shutter, made to fit open ports and keep out water in a storm.","pos":""}],"DEADLIHOOD":[{"def":"State of the dead.","pos":""}],"DEADLINESS":[{"def":"The quality of being deadly.","pos":""}],"DEADLOCK":[{"def":"A lock which is not self-latching, but requires a key to throw the bolt forward.","pos":""},{"def":"A counteraction of things, which produces an entire stoppage; a complete obstruction of action.","pos":""}],"DEADLY":[{"def":"Capable of causing death; mortal; fatal; destructive; certain or likely to cause death; as, a deadly blow or wound.","pos":""},{"def":"Aiming or willing to destroy; implacable; desperately hostile; flagitious; as, deadly enemies.","pos":""}],"DEADNESS":[{"def":"The state of being destitute of life, vigor, spirit, activity, etc.","pos":""}],"DEADS":[{"def":"The substances which inclose the ore on every side.","pos":""}],"DEADWOOD":[{"def":"A mass of timbers built into the bow and stern of a vessel to give solidity.","pos":""}],"DEADWORKS":[{"def":"The parts of a ship above the water when she is laden.","pos":""}],"DEAF":[{"def":"Wanting the sense of hearing, either wholly or in part; unable to perceive sounds; hard of hearing; as, a deaf man.","pos":""},{"def":"Unwilling to hear or listen; determinedly inattentive; regardless; not to be persuaded as to facts, argument, or exhortation; -- with to; as, deaf to reason.","pos":""}],"DEAF-MUTE":[{"def":"A person who is deaf and dumb; one who, through deprivation or defect of hearing, has either failed the acquire the power of speech, or has lost it.","pos":""}],"DEAF-MUTISM":[{"def":"The condition of being a deaf-mute.","pos":""}],"DEAFEN":[{"def":"To render impervious to sound, as a partition or floor, by filling the space within with mortar, by lining with paper, etc.","pos":""}],"DEAFENING":[{"def":"The act or process of rendering impervious to sound, as a floor or wall; also, the material with which the spaces are filled in this process; pugging.","pos":""}],"DEAFLY":[{"def":"Without sense of sounds; obscurely.","pos":""}],"DEAFNESS":[{"def":"Incapacity of perceiving sounds; the state of the organs which prevents the impression which constitute hearing; want of the sense of hearing.","pos":""},{"def":"Unwillingness to hear; voluntary rejection of what is addressed to the understanding.","pos":""}],"DEAL":[{"def":"The division of a piece of timber made by sawing; a board or plank; particularly, a board or plank of fir or pine above seven inches in width, and exceeding six feet in length.","pos":""}],"DEALBATION":[{"def":"Act of bleaching; a whitening.","pos":""}],"DEALER":[{"def":"One who deals; one who has to do, or has concern, with others; esp.","pos":""},{"def":"One who distributes cards to the players.","pos":""}],"DEALFISH":[{"def":"A long, thin fish of the arctic seas (Trachypterus arcticus).","pos":""}],"DEALING":[{"def":"The act of one who deals; distribution of anything, as of cards to the players; method of business; traffic; intercourse; transaction; as, to have dealings with a person.","pos":""}],"DEAMBULATION":[{"def":"A walking abroad; a promenading.","pos":""}],"DEAMBULATORY":[{"def":"Going about from place to place; wandering; of or pertaining to a deambulatory.","pos":""}],"DEAN":[{"def":"A dignitary or presiding officer in certain ecclesiastical and lay bodies; esp.","pos":""},{"def":"The collegiate officer in the universities of Oxford and Cambridge, England, who, besides other duties, has regard to the moral condition of the college.","pos":""}],"DEANERY":[{"def":"The office or the revenue of a dean.","pos":""},{"def":"The residence of a dean.","pos":""}],"DEANSHIP":[{"def":"The office of a dean.","pos":""}],"DEAR":[{"def":"Bearing a high price; high-priced; costly; expensive.","pos":""},{"def":"Marked by scarcity or dearth, and exorbitance of price; as, a dear year.","pos":""}],"DEAR-BOUGHT":[{"def":"Bought at a high price; as, dear-bought experience.","pos":""}],"DEAR-LOVED":[{"def":"Greatly beloved.","pos":""}],"DEARBORN":[{"def":"A four-wheeled carriage, with curtained sides.","pos":""}],"DEARE":[{"def":"variant of Dere, v.","pos":""}],"DEARLY":[{"def":"In a dear manner; with affection; heartily; earnestly; as, to love one dearly.","pos":""},{"def":"At a high rate or price; grievously.","pos":""}],"DEARN":[{"def":"Secret; lonely; solitary; dreadful.","pos":""}],"DEARNESS":[{"def":"The quality or state of being dear; costliness; excess of price.","pos":""},{"def":"Fondness; preciousness; love; tenderness.","pos":""}],"DEARTH":[{"def":"Scarcity which renders dear; want; lack; specifically, lack of food on account of failure of crops; famine.","pos":""}],"DEARY":[{"def":"A dear; a darling.","pos":""}],"DEATH":[{"def":"Loss of spiritual life.","pos":""}],"DEATH'S-HEAD":[{"def":"A naked human skull as the emblem of death; the head of the conventional personification of death.","pos":""}],"DEATH'S-HERB":[{"def":"The deadly nightshade (Atropa belladonna).","pos":""}],"DEATHBED":[{"def":"The bed in which a person dies; hence, the closing hours of life of one who dies by sickness or the like; the last sickness.","pos":""}],"DEATHBIRD":[{"def":"Tengmalm's or Richardson's owl (Nyctale Tengmalmi); -- so called from a superstition of the North American Indians that its note presages death.","pos":""}],"DEATHBLOW":[{"def":"A mortal or crushing blow; a stroke or event which kills or destroys.","pos":""}],"DEATHFUL":[{"def":"Full of death or slaughter; murderous; destructive; bloody.","pos":""},{"def":"Liable to undergo death; mortal.","pos":""}],"DEATHFULNESS":[{"def":"Appearance of death.","pos":""}],"DEATHLESS":[{"def":"Not subject to death, destruction, or extinction; immortal; undying; imperishable; as, deathless beings; deathless fame.","pos":""}],"DEATHLIKE":[{"def":"Resembling death.","pos":""}],"DEATHLINESS":[{"def":"The quality of being deathly; deadliness.","pos":""}],"DEATHLY":[{"def":"Deadly; fatal; mortal; destructive.","pos":""}],"DEATHSMAN":[{"def":"An executioner; a headsman or hangman.","pos":""}],"DEATHWATCH":[{"def":"The guard set over a criminal before his execution.","pos":""}],"DEAVE":[{"def":"To stun or stupefy with noise; to deafen.","pos":""}]}