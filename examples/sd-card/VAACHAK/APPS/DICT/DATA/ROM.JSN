{"ROMAIC":[{"def":"Of or relating to modern Greece, and especially to its language.","pos":""},{"def":"The modern Greek language, now usually called by the Greeks Hellenic or Neo-Hellenic.","pos":""}],"ROMAJIKAI":[{"def":"An association, including both Japanese and Europeans, having for its object the changing of the Japanese method of writing by substituting Roman letters for Japanese characters.","pos":""}],"ROMAN":[{"def":"Of or pertaining to Rome, or the Roman people; like or characteristic of Rome, the Roman people, or things done by Romans; as, Roman fortitude; a Roman aqueduct; Roman art.","pos":""},{"def":"Of or pertaining to the Roman Catholic religion; professing that religion.","pos":""}],"ROMAN CALENDAR":[{"def":"The calendar of the ancient Romans, from which our modern calendars are derived.","pos":""}],"ROMANCE":[{"def":"A short lyric tale set to music; a song or short instrumental piece in ballad style; a romanza.","pos":""}],"ROMANCER":[{"def":"One who romances.","pos":""}],"ROMANESQUE":[{"def":"Somewhat resembling the Roman; -- applied sometimes to the debased style of the later Roman empire, but esp.","pos":""}],"ROMANIC":[{"def":"Of or pertaining to Rome or its people.","pos":""},{"def":"Of or pertaining to any or all of the various languages which, during the Middle Ages, sprung out of the old Roman, or popular form of Latin, as the Italian, Spanish, Portuguese, French, Provencal, etc.","pos":""}],"ROMANISH":[{"def":"Pertaining to Romanism.","pos":""}],"ROMANISM":[{"def":"The tenets of the Church of Rome; the Roman Catholic religion.","pos":""}],"ROMANIST":[{"def":"One who adheres to Romanism.","pos":""}],"ROMANIZE":[{"def":"To Latinize; to fill with Latin words or idioms.","pos":""},{"def":"To convert to the Roman Catholic religion.","pos":""}],"ROMANIZER":[{"def":"One who Romanizes.","pos":""}],"ROMANSCH":[{"def":"The language of the Grisons in Switzerland, a corruption of the Latin.","pos":""}],"ROMANTIC":[{"def":"Of or pertaining to romance; involving or resembling romance; hence, fanciful; marvelous; extravagant; unreal; as, a romantic tale; a romantic notion; a romantic undertaking.","pos":""},{"def":"Entertaining ideas and expectations suited to a romance; as, a romantic person; a romantic mind.","pos":""}],"ROMANTICALY":[{"def":"In a romantic manner.","pos":""}],"ROMANTICISM":[{"def":"He [Lessing] may be said to have begun the revolt from pseudo- classicism in poetry, and to have been thus unconsciously the founder of romanticism.","pos":""}],"ROMANTICIST":[{"def":"One who advocates romanticism in modern literature.","pos":""}],"ROMANTICNESS":[{"def":"The state or quality of being romantic; widness; fancifulness.","pos":""}],"ROMANY":[{"def":"The language spoken among themselves by the gypsies.","pos":""}],"ROMAUNT":[{"def":"A romantic story in verse; as, the \"Romaunt of the Rose.","pos":""}],"ROMBOWLINE":[{"def":"Old, condemned canvas, rope, etc.","pos":""},{"def":"A mineral of a hyacinth or honey-yellow color, occuring in square octahedrons.","pos":""}],"ROMEKIN":[{"def":"See Peter pence, under Peter.","pos":""}],"ROMEWARD":[{"def":"Toward Rome, or toward the Roman Catholic Church.","pos":""}],"ROMIC":[{"def":"A method of notation for all spoken sounds, proposed by Mr.","pos":""}],"ROMISH":[{"def":"Belonging or relating to Rome, or to the Roman Catholic Church; -- frequently used in a disparaging sense; as, the Romish church; the Romish religion, ritual, or ceremonies.","pos":""}],"ROMIST":[{"def":"A Roman Catholic.","pos":""}],"ROMP":[{"def":"To play rudely and boisterously; to leap and frisk about in play.","pos":""}],"ROMPING":[{"def":"Inclined to romp; indulging in romps.","pos":""}],"ROMPINGLY":[{"def":"In a romping manner.","pos":""}],"ROMPISH":[{"def":"Given to rude play; inclined to romp.","pos":""}],"ROMPU":[{"def":"Broken, as an ordinary; cut off, or broken at the top, as a chevron, a bend, or the like.","pos":""}]}