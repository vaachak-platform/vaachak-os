{"ILEAC":[{"def":"Pertaining to the ileum.","pos":""}],"ILEOCAECAL":[{"def":"Pertaining to the ileum and cæcum.","pos":""}],"ILEOCOLIC":[{"def":"Pertaining to the ileum and colon; as, the ileocolic, or ileocæcal, valve, a valve where the ileum opens into the large intestine.","pos":""}],"ILEUM":[{"def":"The last, and usually the longest, division of the small intestine; the part between the jejunum and large intestine.","pos":""}],"ILEUS":[{"def":"A morbid condition due to intestinal obstruction.","pos":""}],"ILIAC":[{"def":"Pertaining to ancient Ilium, or Troy.","pos":""}],"ILIAD":[{"def":"A celebrated Greek epic poem, in twenty-four books, on the destruction of Ilium, the ancient Troy.","pos":""}],"ILIAL":[{"def":"Pertaining to the ilium; iliac.","pos":""}],"ILICIC":[{"def":"Pertaining to, or derived from, the holly (Ilex), and allied plants; as, ilicic acid.","pos":""}],"ILICIN":[{"def":"The bitter principle of the holly.","pos":""}],"ILIO-":[{"def":"A combining form used in anatomy to denote connection with, or relation to, the ilium; as, ilio-femoral, ilio-lumbar, ilio-psoas, etc.","pos":""}],"ILIOFEMORAL":[{"def":"Pertaining to the ilium and femur; as, iliofemoral ligaments.","pos":""}],"ILIOLUMBAR":[{"def":"Pertaining to the iliac and lumbar regions; as, the iliolumbar artery.","pos":""}],"ILIOPSOAS":[{"def":"The great flexor muscle of the hip joint, divisible into two parts, the iliac and great psoas, -- often regarded as distinct muscles.","pos":""}],"ILIUM":[{"def":"The dorsal one of the three principal bones comprising either lateral half of the pelvis; the dorsal or upper part of the hip bone.","pos":""}],"ILIXANTHIN":[{"def":"A yellow dye obtained from the leaves of the holly.","pos":""}],"ILK":[{"def":"Same; each; every.","pos":""}],"ILKE":[{"def":"Each one; every one.","pos":""}],"ILL":[{"def":"Contrary to good, in a physical sense; contrary or opposed to advantage, happiness, etc.","pos":""},{"def":"Contrary to good, in a moral sense; evil; wicked; wrong; iniquitious; naughtly; bad; improper.","pos":""}],"ILL-BODING":[{"def":"Boding evil; inauspicious; ill-omened.","pos":""}],"ILL-BRED":[{"def":"Badly educated or brought up; impolite; incivil; rude.","pos":""}],"ILL-FAVORED":[{"def":"Wanting beauty or attractiveness; deformed; ugly; ill-looking.","pos":""}],"ILL-JUDGED":[{"def":"Not well judged; unwise.","pos":""}],"ILL-LIVED":[{"def":"Leading a wicked life.","pos":""}],"ILL-LOOKING":[{"def":"Having a bad look; threatening; ugly.","pos":""}],"ILL-NATURED":[{"def":"Of habitual bad temper; peevish; fractious; cross; crabbed; surly; as, an ill-natured person.","pos":""},{"def":"Dictated by, or indicating, ill nature; spiteful.","pos":""}],"ILL-OMENED":[{"def":"Having unlucky omens; inauspicious.","pos":""}],"ILL-STARRED":[{"def":"Fated to be unfortunate; unlucky; as, an ill-starred man or day.","pos":""}],"ILL-TEMPERED":[{"def":"Of bad temper; morose; crabbed; sour; peevish; fretful; quarrelsome.","pos":""},{"def":"Unhealthy; ill-conditioned.","pos":""}],"ILL-TIMED":[{"def":"Done, attempted, or said, at an unsuitable or unpropitious time.","pos":""}],"ILL-USED":[{"def":"Misapplied; treated badly.","pos":""}],"ILL-WISHER":[{"def":"One who wishes ill to another; an enemy.","pos":""}],"ILLABILE":[{"def":"Incapable of falling or erring; infalliable.","pos":""}],"ILLACERABLE":[{"def":"Not lacerable; incapable of being torn or rent.","pos":""}],"ILLACRYMABLE":[{"def":"Incapable of weeping.","pos":""}],"ILLAPSABLE":[{"def":"Incapable of slipping, or of error.","pos":""}],"ILLAPSE":[{"def":"To fall or glide; to pass; -- usually followed by into.","pos":""}],"ILLAQUEABLE":[{"def":"Capable of being insnared or entrapped.","pos":""}],"ILLAQUEATE":[{"def":"To insnare; to entrap; to entangle; to catch.","pos":""}],"ILLAQUEATION":[{"def":"The act of catching or insnaring.","pos":""},{"def":"A snare; a trap.","pos":""}],"ILLATION":[{"def":"The act or process of inferring from premises or reasons; perception of the connection between ideas; that which is inferred; inference; deduction; conclusion.","pos":""}],"ILLATIVE":[{"def":"Relating to, dependent on, or denoting, illation; inferential; conclusive; as, an illative consequence or proposition; an illative word, as then, therefore, etc.","pos":""}],"ILLATIVELY":[{"def":"By inference; as an illative; in an illative manner.","pos":""}],"ILLAUDABLE":[{"def":"Not laudable; not praise-worthy; worthy of censure or disapprobation.","pos":""}],"ILLECEBROUS":[{"def":"Alluring; attractive; enticing.","pos":""}],"ILLEGAL":[{"def":"Not according to, or authorized by, law; specif.","pos":""}],"ILLEGALITY":[{"def":"The quality or condition of being illegal; unlawfulness; as, the illegality of trespass or of false imprisonment; also, an illegal act.","pos":""}],"ILLEGALIZE":[{"def":"To make or declare illegal or unlawful.","pos":""}],"ILLEGALLY":[{"def":"In a illegal manner; unlawfully.","pos":""}],"ILLEGALNESS":[{"def":"Illegality, unlawfulness.","pos":""}],"ILLEGIBILITY":[{"def":"The state or quality of being illegible.","pos":""}],"ILLEGIBLE":[{"def":"Incapable of being read; not legible; as, illegible handwriting; an illegible inscription.","pos":""}],"ILLEGITIMACY":[{"def":"The state of being illegitimate.","pos":""}],"ILLEGITIMATE":[{"def":"Not according to law; not regular or authorized; unlawful; improper.","pos":""},{"def":"Unlawfully begotten; born out of wedlock; bastard; as, an illegitimate child.","pos":""}],"ILLEGITIMATELY":[{"def":"In a illegitimate manner; unlawfully.","pos":""}],"ILLEGITIMATION":[{"def":"The act of illegitimating; bastardizing.","pos":""},{"def":"The state of being illegitimate; illegitimacy.","pos":""}],"ILLEGITIMATIZE":[{"def":"To render illegitimate; to bastardize.","pos":""}],"ILLESIVE":[{"def":"Not injurious; harmless.","pos":""}],"ILLEVIABLE":[{"def":"Not leviable; incapable of being imposed, or collected.","pos":""}],"ILLIBERAL":[{"def":"Not liberal; not free or generous; close; niggardly; mean; sordid.","pos":""},{"def":"Indicating a lack of breeding, culture, and the like; ignoble; rude; narrow-minded; disingenuous.","pos":""}],"ILLIBERALITY":[{"def":"The state or quality of being illiberal; narrowness of mind; meanness; niggardliness.","pos":""}],"ILLIBERALIZE":[{"def":"To make illiberal.","pos":""}],"ILLIBERALLY":[{"def":"In a illiberal manner, ungenerously; uncharitably; parsimoniously.","pos":""}],"ILLIBERALNESS":[{"def":"The state of being illiberal; illiberality.","pos":""}],"ILLICIT":[{"def":"Not permitted or allowed; prohibited; unlawful; as, illicit trade; illicit intercourse; illicit pleasure.","pos":""}],"ILLICIUM":[{"def":"A genus of Asiatic and American magnoliaceous trees, having star-shaped fruit; star anise.","pos":""}],"ILLIMITABLE":[{"def":"Incapable of being limited or bounded; immeasurable; limitless; boundless; as, illimitable space.","pos":""}],"ILLIMITATION":[{"def":"State of being illimitable; want of, or freedom from, limitation.","pos":""}],"ILLIMITED":[{"def":"Not limited; interminable.","pos":""}],"ILLINITION":[{"def":"A smearing or rubbing in or on; also, that which is smeared or rubbed on, as ointment or liniment.","pos":""},{"def":"A thin crust of some extraneous substance formed on minerals.","pos":""}],"ILLINOIS":[{"def":"A tribe of North American Indians, which formerly occupied the region between the Wabash and Mississippi rivers.","pos":"noun"}],"ILLIQUATION":[{"def":"The melting or dissolving of one thing into another.","pos":""}],"ILLISION":[{"def":"The act of dashing or striking against.","pos":""}],"ILLITERACY":[{"def":"The state of being illiterate, or uneducated; want of learning, or knowledge; ignorance; specifically, inability to read and write; as, the illiteracy shown by the last census.","pos":""},{"def":"An instance of ignorance; a literary blunder.","pos":""}],"ILLITERATE":[{"def":"Ignorant of letters or books; unlettered; uninstructed; uneducated; as, an illiterate man, or people.","pos":""}],"ILLITERATURE":[{"def":"Want of learning; illiteracy.","pos":""}],"ILLNESS":[{"def":"The condition of being ill, evil, or bad; badness; unfavorableness.","pos":""},{"def":"Disease; indisposition; malady; disorder of health; sickness; as, a short or a severe illness.","pos":""}],"ILLOCALITY":[{"def":"Want of locality or place.","pos":""}],"ILLOGICAL":[{"def":"Ignorant or negligent of the rules of logic or correct reasoning; as, an illogical disputant; contrary of the rules of logic or sound reasoning; as, an illogical inference.","pos":""}],"ILLTREAT":[{"def":"To treat cruelly or improperly; to ill use; to maltreat.","pos":""}],"ILLUDE":[{"def":"To play upon by artifice; to deceive; to mock; to excite and disappoint the hopes of.","pos":""}],"ILLUME":[{"def":"To throw or spread light upon; to make light or bright; to illuminate; to illumine.","pos":""}],"ILLUMINABLE":[{"def":"Capable of being illuminated.","pos":""}],"ILLUMINANT":[{"def":"That which illuminates or affords light; as, gas and petroleum are illuminants.","pos":""}],"ILLUMINATE":[{"def":"To make light; to throw light on; to supply with light, literally or figuratively; to brighten.","pos":""},{"def":"To light up; to decorate with artificial lights, as a building or city, in token of rejoicing or respect.","pos":""}],"ILLUMINATI":[{"def":"Literally, those who are enlightened; -- variously applied as follows: - 1.","pos":""},{"def":"Persons in the early church who had received baptism; in which ceremony a lighted taper was given them, as a symbol of the spiritual illumination they has received by that sacrament.","pos":""}],"ILLUMINATING":[{"def":"Giving or producing light; used for illumination.","pos":""}],"ILLUMINATION":[{"def":"The special communication of knowledge to the mind by God; inspiration.","pos":""}],"ILLUMINATIVE":[{"def":"Tending to illuminate or illustrate; throwing light; illustrative.","pos":""}],"ILLUMINATOR":[{"def":"One whose occupation is to adorn books, especially manuscripts, with miniatures, borders, etc.","pos":""},{"def":"A condenser or reflector of light in optical apparatus; also, an illuminant.","pos":""}],"ILLUMINE":[{"def":"To illuminate; to light up; to adorn.","pos":""}],"ILLUMINEE":[{"def":"One of the Illuminati.","pos":""}],"ILLUMINER":[{"def":"One who, or that which, illuminates.","pos":""}],"ILLUMINISM":[{"def":"The principles of the Illuminati.","pos":""}],"ILLUMINISTIC":[{"def":"Of or pertaining to illuminism, or the Illuminati.","pos":""}],"ILLUMINIZE":[{"def":"To initiate the doctrines or principles of the Illuminati.","pos":""}],"ILLURE":[{"def":"To deceive; to entice; to lure.","pos":""}],"ILLUSION":[{"def":"A sensation originated by some external object, but so modified as in any way to lead to an erroneous perception; as when the rolling of a wagon is mistaken for thunder.","pos":""}],"ILLUSIONABLE":[{"def":"Liable to illusion.","pos":""}],"ILLUSIONIST":[{"def":"One given to illusion; a visionary dreamer.","pos":""}],"ILLUSIVE":[{"def":"Deceiving by false show; deceitful; deceptive; false; illusory; unreal.","pos":""}],"ILLUSIVELY":[{"def":"In a illusive manner; falsely.","pos":""}],"ILLUSIVENESS":[{"def":"The quality of being illusive; deceptiveness; false show.","pos":""}],"ILLUSORY":[{"def":"Deceiving, or tending of deceive; fallacious; illusive; as, illusory promises or hopes.","pos":""}],"ILLUSTRABLE":[{"def":"Capable of illustration.","pos":""}],"ILLUSTRATE":[{"def":"To make clear, bright, or luminous.","pos":""},{"def":"To set in a clear light; to exhibit distinctly or conspicuously.","pos":""}],"ILLUSTRATION":[{"def":"The act of illustrating; the act of making clear and distinct; education; also, the state of being illustrated, or of being made clear and distinct.","pos":""},{"def":"That which illustrates; a comparison or example intended to make clear or apprehensible, or to remove obscurity.","pos":""}],"ILLUSTRATIVE":[{"def":"Tending or designed to illustrate, exemplify, or elucidate.","pos":""},{"def":"Making illustrious.","pos":""}],"ILLUSTRATIVELY":[{"def":"By way of illustration or elucidation.","pos":""}],"ILLUSTRATOR":[{"def":"One who illustrates.","pos":""}],"ILLUSTRATORY":[{"def":"Serving to illustrate.","pos":""}],"ILLUSTRIOUS":[{"def":"Possessing luster or brightness; brilliant; luminous; splendid.","pos":""},{"def":"Characterized by greatness, nobleness, etc.","pos":""}],"ILLUSTRIOUSLY":[{"def":"In a illustrious manner; conspicuously; eminently; famously.","pos":""}],"ILLUSTRIOUSNESS":[{"def":"The state or quality of being eminent; greatness; grandeur; glory; fame.","pos":""}],"ILLUTATION":[{"def":"The act or operation of smearing the body with mud, especially with the sediment from mineral springs; a mud bath.","pos":""}],"ILLY":[{"def":"Etym: [A word not fully approved, but sometimes used for the adverb ill.","pos":""}],"ILMENIUM":[{"def":"A supposed element claimed to have been discovered by R.","pos":""}],"ILVAITE":[{"def":"A silicate of iron and lime occurring in black prismatic crystals and columnar masses.","pos":""}]}