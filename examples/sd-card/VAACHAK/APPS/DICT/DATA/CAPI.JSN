{"CAPIAS":[{"def":"A writ or process commanding the officer to take the body of the person named in it, that is, to arrest him; -- also called writ of capias.","pos":""}],"CAPILLACEOUS":[{"def":"Having long filaments; resembling a hair; slender.","pos":""}],"CAPILLAIRE":[{"def":"A sirup prepared from the maiden-hair, formerly supposed to have medicinal properties.","pos":""},{"def":"Any simple sirup flavored with orange flowers.","pos":""}],"CAPILLAMENT":[{"def":"Any villous or hairy covering; a fine fiber or filament, as of the nerves.","pos":""}],"CAPILLARINESS":[{"def":"The quality of being capillary.","pos":""}],"CAPILLARITY":[{"def":"The peculiar action by which the surface of a liquid, where it is in contact with a solid (as in a capillary tube), is elevated or depressed; capillary attraction.","pos":""}],"CAPILLARY":[{"def":"Resembling a hair; fine; minute; very slender; having minute tubes or interspaces; having very small bore; as, the capillary vessels of animals and plants.","pos":""},{"def":"Pertaining to capillary tubes or vessels; as, capillary action.","pos":""}],"CAPILLATION":[{"def":"A capillary blood vessel.","pos":""}],"CAPILLATURE":[{"def":"A bush of hair; frizzing of the hair.","pos":""}],"CAPILLIFORM":[{"def":"In the shape or form of, a hair, or of hairs.","pos":""}],"CAPILLOSE":[{"def":"Having much hair; hairy.","pos":""}],"CAPITAL":[{"def":"Of or pertaining to the head.","pos":""},{"def":"Having reference to, or involving, the forfeiture of the head or life; affecting life; punishable with death; as, capital trials; capital punishment.","pos":""}],"CAPITALIST":[{"def":"One who has capital; one who has money for investment, or money invested; esp.","pos":""}],"CAPITALIZATION":[{"def":"The act or process of capitalizing.","pos":""}],"CAPITALIZE":[{"def":"To convert into capital, or to use as capital.","pos":""},{"def":"To compute, appraise, or assess the capital value of (a patent right, an annuity, etc.","pos":""}],"CAPITALLY":[{"def":"In a way involving the forfeiture of the head or life; as, to punish capitally.","pos":""},{"def":"In a capital manner; excellently.","pos":""}],"CAPITALNESS":[{"def":"The quality of being capital; preeminence.","pos":""},{"def":"The chief admiral of the Turkish fleet.","pos":""}],"CAPITATE":[{"def":"Having the flowers gathered into a head.","pos":""}],"CAPITATIM":[{"def":"Of so much per head; as, a capitatim tax; a capitatim grant.","pos":""}],"CAPITATION":[{"def":"A numbering of heads or individuals.","pos":""},{"def":"A tax upon each head or person, without reference to property; a poll tax.","pos":""}],"CAPITE":[{"def":"See under Tenant.","pos":""}],"CAPITELLATE":[{"def":"Having a very small knoblike termination, or collected into minute capitula.","pos":""}],"CAPITIBRANCHIATA":[{"def":"A division of annelids in which the gills arise from or near the head.","pos":""}],"CAPITOL":[{"def":"Of or pertaining to the Capitol in Rome.","pos":""}],"CAPITULAR":[{"def":"An act passed in a chapter.","pos":""},{"def":"A member of a chapter.","pos":""}],"CAPITULARLY":[{"def":"In the manner or form of an ecclesiastical chapter.","pos":""}],"CAPITULARY":[{"def":"The body of laws or statutes of a chapter, or of an ecclesiastical council.","pos":""}],"CAPITULATE":[{"def":"To settle or draw up the heads or terms of an agreement, as in chapters or articles; to agree.","pos":""},{"def":"To surrender on terms agreed upon (usually, drawn up under several heads); as, an army or a garrison capitulates.","pos":""}],"CAPITULATION":[{"def":"A reducing to heads or articles; a formal agreement.","pos":""},{"def":"The act of capitulating or surrendering to an emeny upon stipulated terms.","pos":""}],"CAPITULATOR":[{"def":"One who capitulates.","pos":""}],"CAPITULUM":[{"def":"A knobike protuberance of any part, esp.","pos":""}],"CAPIVI":[{"def":"A balsam of the Spanish West Indies.","pos":""}]}