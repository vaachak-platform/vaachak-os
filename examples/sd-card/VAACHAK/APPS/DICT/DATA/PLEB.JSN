{"PLEBE":[{"def":"A member of the lowest class in the military academy at West Point.","pos":""}],"PLEBEIAN":[{"def":"Of or pertaining to the Roman plebs, or common people.","pos":""},{"def":"Of or pertaining to the common people; vulgar; common; as, plebeian sports; a plebeian throng.","pos":""}],"PLEBEIANCE":[{"def":"Plebeians, collectively.","pos":""}],"PLEBEIANISM":[{"def":"The quality or state of being plebeian.","pos":""},{"def":"The conduct or manners of plebeians; vulgarity.","pos":""}],"PLEBEIANIZE":[{"def":"To render plebeian, common, or vulgar.","pos":""}],"PLEBICOLIST":[{"def":"One who flatters, or courts the favor of, the common people; a demagogue.","pos":""}],"PLEBIFICATION":[{"def":"A rendering plebeian; the act of vulgarizing.","pos":""}],"PLEBISCITARY":[{"def":"Of or pertaining to plebiscite.","pos":""}],"PLEBISCITE":[{"def":"A vote by universal male suffrage; especially, in France, a popular vote, as first sanctioned by the National Constitution of 1791.","pos":""}],"PLEBISCITUM":[{"def":"A law enacted by the common people, under the superintendence of a tribune or some subordinate plebeian magistrate, without the intervention of the senate.","pos":""}],"PLEBS":[{"def":"The commonalty of ancient Rome who were citizens without the usual political rights; the plebeians; -- distinguished from the patricians.","pos":""},{"def":"Hence, the common people; the populace; --construed as a pl.","pos":""}]}