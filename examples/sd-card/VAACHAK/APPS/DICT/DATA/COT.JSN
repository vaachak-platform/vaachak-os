{"COT":[{"def":"A small, rudely-formed boat.","pos":""}],"COTANGENT":[{"def":"The tangent of the complement of an arc or angle.","pos":""}],"COTARNINE":[{"def":"A white, crystalline substance, C12H13NO3, obtained as a product of the decomposition of narcotine.","pos":""}],"COTE":[{"def":"A cottage or hut.","pos":""},{"def":"A shed, shelter, or inclosure for small domestic animals, as for sheep or doves.","pos":""}],"COTEAU":[{"def":"A hilly upland including the divide between two valleys; a divide.","pos":""},{"def":"The side of a valley.","pos":""}],"COTEMPORANEOUS":[{"def":"Living or being at the same time; contemporaneous.","pos":""}],"COTEMPORARY":[{"def":"Living or being at the same time; contemporary.","pos":""}],"COTENANT":[{"def":"A tenant in common, or a joint tenant.","pos":""}],"COTERIE":[{"def":"A set or circle of persons who meet familiarly, as for social, literary, or other purposes; a clique.","pos":""}],"COTERMINOUS":[{"def":"Bordering; conterminous; -- followed by with.","pos":""}],"COTGARE":[{"def":"Cot\"gare` (kt\"gr`), n.","pos":""}],"COTHURN":[{"def":"A buskin anciently used by tragic actors on the stage; hence, tragedy in general.","pos":""}],"COTHURNUS":[{"def":"Same as Cothurn.","pos":""}],"COTICULAR":[{"def":"Pertaining to whetstones; like or suitable for whetstones.","pos":""}],"COTIDAL":[{"def":"Marking an equality in the tides; having high tide at the same time.","pos":""}],"COTINGA":[{"def":"A bird of the family Cotingidæ, including numerous bright- colored South American species; -- called also chatterers.","pos":""}],"COTLAND":[{"def":"Land appendant to a cot or cottage, or held by a cottager or cotter.","pos":""}],"COTQUEAN":[{"def":"A man who busies himself with affairs which properly belong to women.","pos":""},{"def":"A she-cuckold; a cucquean; a henhussy.","pos":""}],"COTQUEANITY":[{"def":"The condition, character, or conduct of a cotquean.","pos":""}],"COTRUSTEE":[{"def":"A joint trustee.","pos":""}],"COTSWOLD":[{"def":"An open country abounding in sheepcotes, as in the Cotswold hills, in Gloucestershire, England.","pos":""}],"COTTA":[{"def":"A surplice, in England and America usually one shorter and less full than the ordinary surplice and with short sleeves, or sometimes none.","pos":""}],"COTTAGE":[{"def":"A small house; a cot; a hut.","pos":""}],"COTTAGED":[{"def":"Set or covered with cottages.","pos":""}],"COTTAGELY":[{"def":"Cottagelike; suitable for a cottage; rustic.","pos":""}],"COTTAGER":[{"def":"One who lives on the common, without paying any rent, or having land of his own.","pos":""},{"def":"A cottager; a cottier.","pos":""}],"COTTER":[{"def":"A piece of wood or metal, commonly wedge-shaped, used for fastening together parts of a machine or structure.","pos":""}],"COTTIER":[{"def":"In Great Britain and Ireland, a person who hires a small cottage, with or without a plot of land.","pos":""}],"COTTISE":[{"def":"A diminutive of the bendlet, containing one half its area or one quarter the area of the bend.","pos":""}],"COTTISED":[{"def":"Set between two cottises, -- said of a bend; or between two barrulets, -- said of a bar or fess.","pos":""}],"COTTOID":[{"def":"Like a fish of the genus Cottus.","pos":""},{"def":"A fish belonging to, or resembling, the genus Cottus.","pos":""}],"COTTOLENE":[{"def":"A product from cottonseed, used as lard.","pos":""}],"COTTON":[{"def":"A soft, downy substance, resembling fine wool, consisting of the unicellular twisted hairs which grow on the seeds of the cotton plant.","pos":""},{"def":"The cotton plant.","pos":""}],"COTTON BATTING":[{"def":"Cotton prepared in sheets or rolls for quilting, upholstering, and similar purposes.","pos":""}],"COTTON STATE":[{"def":"Alabama; -- a nickname.","pos":""}],"COTTONADE":[{"def":"A somewhat stoun and thick fabric of cotton.","pos":""}],"COTTONARY":[{"def":"Relating to, or composed of, cotton; cottony.","pos":""}],"COTTONOUS":[{"def":"Resembling cotton.","pos":""},{"def":"The seed of the cotton plant.","pos":""}],"COTTONSEED MEAL":[{"def":"A meal made from hulled cotton seeds after the oil has been expressed.","pos":""}],"COTTONSEED OIL":[{"def":"A fixed, semidrying oil extracted from cottonseed.","pos":""}],"COTTONTAIL":[{"def":"The American wood rabbit (Lepus sylvaticus); -- also called Molly cottontail.","pos":""}],"COTTONWEED":[{"def":"Cot\"ton*weed` (-wd`), n.","pos":""}],"COTTONWOOD":[{"def":"An American tree of the genus Populus or polar, having the seeds covered with abundant cottonlike hairs; esp.","pos":""}],"COTTONY":[{"def":"Covered with hairs or pubescence, like cotton; downy; nappy; woolly.","pos":""},{"def":"Of or pertaining to cotton; resembling cotton in appearance or character; soft, like cotton.","pos":""}],"COTTREL":[{"def":"A trammel, or hook to support a pot over a fire.","pos":""},{"def":"A cuplike cavity or organ.","pos":""}],"COTYLEDON":[{"def":"One of the patches of villi found in some forms of placenta.","pos":""},{"def":"A leaf borne by the caulicle or radicle of an embryo; a seed leaf.","pos":""}],"COTYLEDONAL":[{"def":"Of, pertaining to, or resembling, a cotyledon.","pos":""}],"COTYLEDONARY":[{"def":"Having a cotyledon; tufted; as, the cotyledonary placenta of the cow.","pos":""}],"COTYLEDONOUS":[{"def":"Of or pertaining to a cotyledon or cotyledons; having a seed lobe.","pos":""}],"COTYLIFORM":[{"def":"Shaped like a cotyle or a cup.","pos":""}],"COTYLIGEROUS":[{"def":"Cot`y*lig\"er*ous (kt`-lj\"r-s), a.","pos":""}],"COTYLOID":[{"def":"Cot\"y*loid (kt\"-loid), a.","pos":""}]}