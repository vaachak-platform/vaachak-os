{"SIT":[{"def":"To rest upon the haunches, or the lower extremity of the trunk of the body; -- said of human beings, and sometimes of other animals; as, to sit on a sofa, on a chair, or on the ground.","pos":""},{"def":"To perch; to rest with the feet drawn up, as birds do on a branch, pole, etc.","pos":""}],"SITE":[{"def":"The place where anything is fixed; situation; local position; as, the site of a city or of a house.","pos":""},{"def":"A place fitted or chosen for any certain permanent use or occupation; as, a site for a church.","pos":""}],"SITED":[{"def":"Having a site; situated.","pos":""}],"SITFAST":[{"def":"Fixed; stationary; immovable.","pos":""}],"SITH":[{"def":"Since; afterwards; seeing that.","pos":""}],"SITHE":[{"def":"Note: [A spelling of a corrupt and provincial pronunciation.","pos":""}],"SITHEN":[{"def":"Since; afterwards.","pos":""}],"SITHTHEN":[{"def":"Siththen that the world began.","pos":""}],"SITOLOGY":[{"def":"A treatise on the regulation of the diet; dietetics.","pos":""}],"SITOPHOBIA":[{"def":"A version to food; refusal to take nourishment.","pos":""}],"SITTER":[{"def":"One who sits; esp.","pos":""},{"def":"A bird that sits or incubates.","pos":""}],"SITTINE":[{"def":"Of or pertaining to the family Sittidæ, or nuthatches.","pos":""}],"SITTING":[{"def":"Being in the state, or the position, of one who, or that which, sits.","pos":""}],"SITUATION":[{"def":"Manner in which an object is placed; location, esp.","pos":""},{"def":"Position, as regards the conditions and circumstances of the case.","pos":""}],"SITUS":[{"def":"The method in which the parts of a plant are arranged; also, the position of the parts.","pos":""}],"SITZ BATH":[{"def":"A tub in which one bathes in a sitting posture; also, a bath so taken; a hip bath.","pos":""}]}