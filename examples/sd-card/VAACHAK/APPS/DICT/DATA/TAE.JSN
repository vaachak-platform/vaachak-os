{"TAEL":[{"def":"A denomination of money, in China, worth nearly six shillings sterling, or about a dollar and forty cents; also, a weight of one ounce and a third.","pos":""}],"TAENIA":[{"def":"A genus of intestinal worms which includes the common tapeworms of man.","pos":""},{"def":"A band; a structural line; -- applied to several bands and lines of nervous matter in the brain.","pos":""}],"TAENIADA":[{"def":"Same as Tænioidea.","pos":""},{"def":"A remedy to expel tapeworms.","pos":""}],"TAENIATA":[{"def":"A division of Ctenophora including those which have a long, ribbonlike body.","pos":""}],"TAENIDIUM":[{"def":"The chitinous fiber forming the spiral thread of the tracheæ of insects.","pos":""}],"TAENIOGLOSSA":[{"def":"An extensive division of gastropod mollusks in which the odontophore is long and narrow, and usually bears seven rows of teeth.","pos":""}],"TAENIOGLOSSATE":[{"def":"Of or pertaining to the Tænioglossa.","pos":""}],"TAENIOID":[{"def":"Like or pertaining to Tænia.","pos":""}],"TAENIOIDEA":[{"def":"The division of cestode worms which comprises the tapeworms.","pos":""}],"TAENIOLA":[{"def":"One of the radial partitions which separate the internal cavities of certain medusæ.","pos":""}],"TAENIOSOMI":[{"def":"An order of fishes remarkable for their long and compressed form.","pos":""}]}