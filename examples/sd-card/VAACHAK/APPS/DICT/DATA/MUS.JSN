{"MUS":[{"def":"A genus of small rodents, including the common mouse and rat.","pos":""}],"MUSA":[{"def":"A genus of perennial, herbaceous, endogenous plants of great size, including the banana (Musa sapientum), the plantain (M.","pos":""}],"MUSACEOUS":[{"def":"Of, pertaining to, or resembling, plants of the genus Musa.","pos":""}],"MUSAL":[{"def":"Of or pertaining to the Muses, or to Poetry.","pos":""}],"MUSANG":[{"def":"A small animal of Java (Paradoxirus fasciatus), allied to the civets.","pos":""}],"MUSAR":[{"def":"An itinerant player on the musette, an instrument formerly common in Europe.","pos":""}],"MUSARD":[{"def":"A dreamer; an absent-minded person.","pos":""}],"MUSCA":[{"def":"A genus of dipterous insects, including the common house fly, and numerous allied species.","pos":""},{"def":"A small constellation situated between the Southern Cross and the Pole.","pos":""}],"MUSCADEL":[{"def":"See Muscatel, n.","pos":""}],"MUSCADINE":[{"def":"A name given to several very different kinds of grapes, but in America used chiefly for the scuppernong, or southern fox grape, which is said to be the parent stock of the Catawba.","pos":""},{"def":"A fragrant and delicious pear.","pos":""}],"MUSCALES":[{"def":"An old name for mosses in the widest sense, including the true mosses and also hepaticæ and sphagna.","pos":""}],"MUSCALLONGE":[{"def":"See Muskellunge.","pos":""}],"MUSCARDIN":[{"def":"The common European dormouse; -- so named from its odor.","pos":""}],"MUSCARDINE":[{"def":"A disease which is very destructive to silkworms, and which sometimes extends to other insects.","pos":""}],"MUSCARIFORM":[{"def":"Having the form of a brush.","pos":""}],"MUSCARIN":[{"def":"A solid crystalline substance, C5H13NO2, found in the toadstool (Agaricus muscarius), and in putrid fish.","pos":""}],"MUSCAT":[{"def":"A name given to several varieties of Old World grapes, differing in color, size, etc.","pos":""}],"MUSCATEL":[{"def":"Of, pertaining to, or designating, or derived from, a muscat grapes or similar grapes; a muscatel grapes; muscatel wine, etc.","pos":""}],"MUSCHELKALK":[{"def":"A kind of shell limestone, whose strata form the middle one of the three divisions of the Triassic formation in Germany.","pos":""}],"MUSCI":[{"def":"An order or subclass of cryptogamous plants; the mosses.","pos":""}],"MUSCICAPINE":[{"def":"Of or pertaining to the Muscicapidæ, a family of birds that includes the true flycatchers.","pos":""}],"MUSCID":[{"def":"Any fly of the genus Musca, or family Muscidæ.","pos":""}],"MUSCIFORM":[{"def":"Having the form or structure of flies of the genus Musca, or family Muscidæ.","pos":""}],"MUSCLE":[{"def":"Muscular strength or development; as, to show one's muscle by lifting a heavy weight.","pos":""}],"MUSCLE READING":[{"def":"The art of making discriminations between objects of choice, of discovering the whereabouts of hidden objects, etc.","pos":""}],"MUSCLED":[{"def":"Furnished with muscles; having muscles; as, things well muscled.","pos":""}],"MUSCLING":[{"def":"Exhibition or representation of the muscles.","pos":""}],"MUSCOID":[{"def":"Mosslike; resembling moss.","pos":""}],"MUSCOVADO":[{"def":"Pertaining to, or of the nature of, unrefined or raw sugar, obtained from the juice of the sugar cane by evaporating and draining off the molasses.","pos":""}],"MUSCOVITE":[{"def":"Common potash mica.","pos":""}],"MUSCOVY DUCK":[{"def":"A duck (Cairina moschata), larger than the common duck, often raised in poultry yards.","pos":""}],"MUSCOVY GLASS":[{"def":"Mica; muscovite.","pos":""}],"MUSCULAR":[{"def":"Of or pertaining to a muscle, or to a system of muscles; consisting of, or constituting, a muscle or muscles; as, muscular fiber.","pos":""},{"def":"Performed by, or dependent on, a muscle or the muscles.","pos":""}],"MUSCULARITY":[{"def":"The state or quality of being muscular.","pos":""}],"MUSCULARIZE":[{"def":"To make muscular.","pos":""}],"MUSCULARLY":[{"def":"In a muscular manner.","pos":""}],"MUSCULATION":[{"def":"The muscular system of an animal, or of any of its parts.","pos":""}],"MUSCULE":[{"def":"A long movable shed used by besiegers in ancient times in attacking the walls of a fortified town.","pos":""}],"MUSCULOCUTANEOUS":[{"def":"Pertaining both to muscles and skin; as, the musculocutaneous nerve.","pos":""}],"MUSCULOPHRENIC":[{"def":"Pertaining to the muscles and the diaphragm; as, the musculophrenic artery.","pos":""}],"MUSCULOSITY":[{"def":"The quality or state of being musculous; muscularity.","pos":""}],"MUSCULOSPIRAL":[{"def":"Of or pertaining to the muscles, and taking a spiral course; -- applied esp.","pos":""}],"MUSE":[{"def":"A gap or hole in a hedge, hence, wall, or the like, through which a wild animal is accustomed to pass; a muset.","pos":""}],"MUSEFUL":[{"def":"Meditative; thoughtfully silent.","pos":""}],"MUSELESS":[{"def":"Unregardful of the Muses; disregarding the power of poetry; unpoetical.","pos":""}],"MUSET":[{"def":"A small hole or gap through which a wild animal passes; a muse.","pos":""}],"MUSETTE":[{"def":"A small bagpipe formerly in use, having a soft and sweet tone.","pos":""},{"def":"An air adapted to this instrument; also, a kind of rustic dance.","pos":""}],"MUSEUM":[{"def":"A repository or a collection of natural, scientific, or literary curiosities, or of works of art.","pos":""}],"MUSH":[{"def":"To notch, cut, or indent, as cloth, with a stamp.","pos":""}],"MUSHROOM":[{"def":"One who rises suddenly from a low condition in life; an upstart.","pos":""}],"MUSHROOM-HEADED":[{"def":"Having a cylindrical body with a convex head of larger diameter; having a head like that of a mushroom.","pos":""}],"MUSHY":[{"def":"Soft like mush; figuratively, good-naturedly weak and effusive; weakly sentimental.","pos":""}],"MUSIC":[{"def":"A more or less musical sound made by many of the lower animals.","pos":""}],"MUSIC DRAMA":[{"def":"An opera in which the text and action are not interrupted by set arias, duets, etc.","pos":""}],"MUSIC HALL":[{"def":"A place for public musical entertainments; specif.","pos":""}],"MUSICAL":[{"def":"Of or pertaining to music; having the qualities of music; or the power of producing music; devoted to music; melodious; harmonious; as, musical proportion; a musical voice; musical instruments; a musical sentence; musical persons.","pos":""}],"MUSICALE":[{"def":"A social musical party.","pos":""}],"MUSICALLY":[{"def":"In a musical manner.","pos":""}],"MUSICALNESS":[{"def":"The quality of being musical.","pos":""}],"MUSICIAN":[{"def":"One skilled in the art or science of music; esp.","pos":""}],"MUSICOMANIA":[{"def":"A kind of monomania in which the passion for music becomes so strong as to derange the intellectual faculties.","pos":""}],"MUSINGLY":[{"def":"In a musing manner.","pos":""}],"MUSK":[{"def":"A substance of a reddish brown color, and when fresh of the consistence of honey, obtained from a bag being behind the navel of the male musk deer.","pos":""},{"def":"The perfume emitted by musk, or any perfume somewhat similar.","pos":""}],"MUSKELLUNGE":[{"def":"A large American pike (Esox nobilitor) found in the Great Lakes, and other Northern lakes, and in the St.","pos":""}],"MUSKET":[{"def":"The male of the sparrow hawk.","pos":""}],"MUSKETEER":[{"def":"A soldier armed with a musket.","pos":""}],"MUSKETOON":[{"def":"One who is armed with such a musket.","pos":""}],"MUSKETRY":[{"def":"Muskets, collectively.","pos":""},{"def":"The fire of muskets.","pos":""}],"MUSKINESS":[{"def":"The quality or state of being musky; the scent of musk.","pos":""}],"MUSKMELON":[{"def":"The fruit of a cucubritaceous plant (Cicumis Melo), having a peculiar aromatic flavor, and cultivated in many varieties, the principal sorts being the cantaloupe, of oval form and yellowish flesh, and the smaller nutmeg melon with greenish flesh.","pos":""}],"MUSKOGEES":[{"def":"A powerful tribe of North American Indians that formerly occupied the region of Georgia, Florida, and Alabama.","pos":""}],"MUSKRAT":[{"def":"A North American aquatic fur-bearing rodent (Fiber zibethicus).","pos":""}],"MUSKY":[{"def":"Having an odor of musk, or somewhat the like.","pos":""}],"MUSLIN":[{"def":"A thin cotton, white, dyed, or printed.","pos":""}],"MUSLINET":[{"def":"A sort of coarse or light cotton cloth.","pos":""}],"MUSOMANIA":[{"def":"See Musicomania.","pos":""}],"MUSQUAW":[{"def":"The American black bear.","pos":""}],"MUSQUITO":[{"def":"The nose band of a horse's bridle.","pos":""}],"MUSS":[{"def":"A scramble, as when small objects are thrown down, to be taken by those who can seize them; a confused struggle.","pos":""}],"MUSSEL":[{"def":"Any one of many species of marine bivalve shells of the genus Mytilus, and related genera, of the family Mytidæ.","pos":""},{"def":"Any one of numerous species of Unio, and related fresh-water genera; -- called also river mussel.","pos":""}],"MUSSITATION":[{"def":"A speaking in a low tone; mumbling.","pos":""}],"MUSSITE":[{"def":"A variety of pyroxene, from the Mussa Alp in Piedmont; diopside.","pos":""}],"MUSSULMAN":[{"def":"A Mohammedan; a Moslem.","pos":""}],"MUSSULMANIC":[{"def":"Of, pertaining to, or like, the Mussulmans, or their customs: Mohammedan.","pos":""}],"MUSSULMANLY":[{"def":"In the manner of Moslems.","pos":""}],"MUSSY":[{"def":"Disarranged; rumpled.","pos":""}],"MUST":[{"def":"To be obliged; to be necessitated; -- expressing either physical or moral necessity; as, a man must eat for nourishment; we must submit to the laws.","pos":""},{"def":"To be morally required; to be necessary or essential to a certain quality, character, end, or result; as, he must reconsider the matter; he must have been insane.","pos":""}],"MUSTAC":[{"def":"A small tufted monkey.","pos":""}],"MUSTACHE":[{"def":"A West African monkey (Cercopithecus cephus).","pos":""},{"def":"Any conspicuous stripe of color on the side of the head, beneath the eye of a bird.","pos":""}],"MUSTACHOED":[{"def":"Having mustachios.","pos":""}],"MUSTAHFIZ":[{"def":"See Army organization, above.","pos":""}],"MUSTAIBA":[{"def":"A close-grained, neavy wood of a brownish color, brought from Brazil, and used in turning, for making the handles of tools, and the like.","pos":""}],"MUSTANG":[{"def":"The half-wild horse of the plains in Mexico, California, etc.","pos":""}],"MUSTARD":[{"def":"The name of several cruciferous plants of the genus Brassica (formerly Sinapis), as white mustard (B.","pos":""}],"MUSTELINE":[{"def":"Like or pertaining to the family Mustelidæ, or the weasels and martens.","pos":""}],"MUSTER":[{"def":"Something shown for imitation; a pattern.","pos":""},{"def":"A show; a display.","pos":""}],"MUSTILY":[{"def":"In a musty state.","pos":""}],"MUSTINESS":[{"def":"The quality or state of being musty.","pos":""}],"MUSTY":[{"def":"Having the rank, pungent, offencive odor and taste which substances of organic origin acquire during warm, moist weather; foul or sour and fetid; moldy; as, musty corn; musty books.","pos":""},{"def":"Spoiled by age; rank; stale.","pos":""}]}