{"HAIDINGERITE":[{"def":"A mineral consisting of the arseniate of lime; -- so named in honor of W.","pos":""}],"HAIDUCK":[{"def":"Formerly, a mercenary foot soldier in Hungary, now, a halberdier of a Hungarian noble, or an attendant in German or Hungarian courts.","pos":""}],"HAIK":[{"def":"A large piece of woolen or cotton cloth worn by Arabs as an outer garment.","pos":""}],"HAIKAL":[{"def":"The central chapel of the three forming the sanctuary of a Coptic church.","pos":""}],"HAIKWAN":[{"def":"Chinese maritime customs.","pos":""}],"HAIKWAN TAEL":[{"def":"A Chinese weight ( 1/10 catty) equivalent to 1 1/3 oz.","pos":""}],"HAIL":[{"def":"Small roundish masses of ice precipitated from the clouds, where they are formed by the congelation of vapor.","pos":""}],"HAIL-FELLOW":[{"def":"An intimate companion.","pos":""}],"HAILSE":[{"def":"To greet; to salute.","pos":""}],"HAILSHOT":[{"def":"Small shot which scatter like hailstones.","pos":""}],"HAILSTONE":[{"def":"A single particle of ice falling from a cloud; a frozen raindrop; a pellet of hail.","pos":""}],"HAILSTORM":[{"def":"A storm accompanied with hail; a shower of hail.","pos":""}],"HAIN":[{"def":"To inclose for mowing; to set aside for grass.","pos":""}],"HAIR":[{"def":"A slender outgrowth from the chitinous cuticle of insects, spiders, crustaceans, and other invertebrates.","pos":""}],"HAIR GRASS":[{"def":"A grass with very slender leaves or branches; as the Agrostis scabra, and several species of Aira or Deschampsia.","pos":""}],"HAIR-BROWN":[{"def":"Of a clear tint of brown, resembling brown human hair.","pos":""}],"HAIR-SALT":[{"def":"A variety of native Epsom salt occurring in silky fibers.","pos":""}],"HAIRBIRD":[{"def":"The chipping sparrow.","pos":""}],"HAIRBRAINED":[{"def":"See Harebrained.","pos":""},{"def":"The diameter or breadth of a hair; a very small distance; sometimes, definitely, the forty-eighth part of an inch.","pos":""}],"HAIRBREADTH":[{"def":"Having the breadth of a hair; very narrow; as, a hairbreadth escape.","pos":""}],"HAIRBRUSH":[{"def":"A brush for cleansing and smoothing the hair.","pos":""}],"HAIRCLOTH":[{"def":"Stuff or cloth made wholly or in part of hair.","pos":""}],"HAIRDRESSER":[{"def":"One who dresses or cuts hair; a barber.","pos":""}],"HAIRED":[{"def":"In composition: Having (such) hair; as, red-haired.","pos":""}],"HAIREN":[{"def":"His hairen shirt and his ascetic diet.","pos":""}],"HAIRINESS":[{"def":"The state of abounding, or being covered, with hair.","pos":""}],"HAIRLESS":[{"def":"Destitute of hair.","pos":""}],"HAIRPIN":[{"def":"A pin, usually forked, or of bent wire, for fastening the hair in place, -- used by women.","pos":""}],"HAIRSPLITTER":[{"def":"One who makes excessively nice or needless distinctions in reasoning; one who quibbles.","pos":""}],"HAIRSPLITTING":[{"def":"Making excessively nice or trivial distinctions in reasoning; subtle.","pos":""},{"def":"The act or practice of making trivial distinctions.","pos":""}],"HAIRSPRING":[{"def":"The slender recoil spring which regulates the motion of the balance in a timepiece.","pos":""}],"HAIRSTREAK":[{"def":"A butterfly of the genus Thecla; as, the green hairstreak (T.","pos":""}],"HAIRTAIL":[{"def":"Any species of marine fishes of the genus Trichiurus; esp.","pos":""}],"HAIRWORM":[{"def":"A nematoid worm of the genus Gordius, resembling a hair.","pos":""}],"HAIRY":[{"def":"Bearing or covered with hair; made of or resembling hair; rough with hair; rough with hair; rough with hair; hirsute.","pos":""}]}