{"DISPEED":[{"def":"To send off with speed; to dispatch.","pos":""}],"DISPEL":[{"def":"To drive away by scattering, or so to cause to vanish; to clear away; to banish; to dissipate; as, to dispel a cloud, vapors, cares, doubts, illusions.","pos":""}],"DISPEND":[{"def":"To spend; to lay out; to expend.","pos":""}],"DISPENDER":[{"def":"One who dispends or expends; a steward.","pos":""}],"DISPENSABLE":[{"def":"Capable of being dispensed or administered.","pos":""},{"def":"Capable of being dispensed with.","pos":""}],"DISPENSABLENESS":[{"def":"Quality of being dispensable.","pos":""}],"DISPENSARY":[{"def":"A place where medicines are prepared and dispensed; esp.","pos":""}],"DISPENSATION":[{"def":"a system of principles, promises, and rules ordained and administered; scheme; economy; as, the Patriarchal, Mosaic, and Christian dispensations.","pos":""}],"DISPENSATIVE":[{"def":"Granting dispensation.","pos":""}],"DISPENSATIVELY":[{"def":"By dispensation.","pos":""}],"DISPENSATOR":[{"def":"A distributer; a dispenser.","pos":""}],"DISPENSATORILY":[{"def":"In the way of dispensation; dispensatively.","pos":""}],"DISPENSATORY":[{"def":"Granting, or authorized to grant, dispensations.","pos":""}],"DISPENSE":[{"def":"To deal out in portions; to distribute; to give; as, the steward dispenses provisions according directions; Nature dispenses her bounties; to dispense medicines.","pos":""},{"def":"To apply, as laws to particular cases; to administer; to execute; to manage; to direct.","pos":""}],"DISPENSER":[{"def":"One who, or that which, dispenses; a distributer; as, a dispenser of favors.","pos":""}],"DISPEOPLE":[{"def":"To deprive of inhabitants; to depopulate.","pos":""}],"DISPEOPLER":[{"def":"One who, or that which, dispeoples; a depopulator.","pos":""}],"DISPERMOUS":[{"def":"Containing only two seeds; two-seeded.","pos":""}],"DISPERPLE":[{"def":"To scatter; to sprinkle.","pos":""}],"DISPERSAL":[{"def":"The act or result of dispersing or scattering; dispersion.","pos":""}],"DISPERSE":[{"def":"To scatter abroad; to drive to different parts; to distribute; to diffuse; to spread; as, the Jews are dispersed among all nations.","pos":""},{"def":"To scatter, so as to cause to vanish; to dissipate; as, to disperse vapors.","pos":""}],"DISPERSER":[{"def":"One that disperses.","pos":""}],"DISPERSION":[{"def":"The separation of light into its different colored rays, arising from their different refrangibilities.","pos":""}],"DISPERSIVE":[{"def":"Tending to disperse.","pos":""}],"DISPERSONATE":[{"def":"To deprive of personality or individuality.","pos":""}]}