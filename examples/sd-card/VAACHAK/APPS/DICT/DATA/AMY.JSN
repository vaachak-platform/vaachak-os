{"AMYELOUS":[{"def":"Wanting the spinal cord.","pos":""}],"AMYGDALA":[{"def":"A*myg\"da*la (a*mig\"da*la), n.","pos":""}],"AMYGDALACEOUS":[{"def":"Akin to, or derived from, the almond.","pos":""}],"AMYGDALATE":[{"def":"Pertaining to, resembling, or made of, almonds.","pos":""}],"AMYGDALIC":[{"def":"Of or pertaining to almonds; derived from amygdalin; as, amygdalic acid.","pos":""}],"AMYGDALIFEROUS":[{"def":"A*myg`da*lif\"er*ous, a.","pos":""}],"AMYGDALIN":[{"def":"A glucoside extracted from bitter almonds as a white, crystalline substance.","pos":""}],"AMYGDALINE":[{"def":"Of, pertaining to, or resembling, almonds.","pos":""}],"AMYGDALOID":[{"def":"A variety of trap or basaltic rock, containing small cavities, occupied, wholly or in part, by nodules or geodes of different minerals, esp.","pos":""}],"AMYL":[{"def":"A hydrocarbon radical, C5H11, of the paraffine series found in amyl alcohol or fusel oil, etc.","pos":""}],"AMYL ALCOHOL":[{"def":"Any of eight isomeric liquid compounds, C5H11OH; ordinarily, a mixture of two of these forming a colorless liquid with a peculiar cough-exciting odor and burning taste, the chief constituent of fusel oil.","pos":""}],"AMYL NITRITE":[{"def":"A yellowish oily volatile liquid, C5H11NO2, used in medicine as a heart stimulant and a vasodilator.","pos":""}],"AMYLACEOUS":[{"def":"Pertaining to starch; of the nature of starch; starchy.","pos":""}],"AMYLATE":[{"def":"A compound of the radical amyl with oxygen and a positive atom or radical.","pos":""}],"AMYLENE":[{"def":"One of a group of metameric hydrocarbons, C5H10, of the ethylene series.","pos":""}],"AMYLIC":[{"def":"Pertaining to, or derived from, amyl; as, amylic ether.","pos":""}],"AMYLOBACTER":[{"def":"A microörganism (Bacillus amylobacter) which develops in vegetable tissue during putrefaction.","pos":""}],"AMYLOGEN":[{"def":"That part of the starch granule or granulose which is soluble in water.","pos":""}],"AMYLOGENESIS":[{"def":"The formation of starch.","pos":""}],"AMYLOGENIC":[{"def":"Forming starch; -- applied specif.","pos":""}],"AMYLOID":[{"def":"The substance deposited in the organs in amyloid degeneration.","pos":""},{"def":"Resembling or containing amyl; starchlike.","pos":""}],"AMYLOLYSIS":[{"def":"The conversion of starch into soluble products, as dextrins and sugar, esp.","pos":""}],"AMYLOLYTIC":[{"def":"Effecting the conversion of starch into soluble dextrin and sugar; as, an amylolytic ferment.","pos":""}],"AMYLOMETER":[{"def":"Instrument for determining the amount of starch in a substance.","pos":""}],"AMYLOPLASTIC":[{"def":"Starch-forming; amylogenic.","pos":""}],"AMYLOPSIN":[{"def":"The diastase of the pancreatic juice.","pos":""}],"AMYLOSE":[{"def":"One of the starch group (C6H10O5)n of the carbohydrates; as, starch, arabin, dextrin, cellulose, etc.","pos":""}],"AMYOUS":[{"def":"Wanting in muscle; without flesh.","pos":""}],"AMYSS":[{"def":"Same as Amice, a hood or cape.","pos":""}]}