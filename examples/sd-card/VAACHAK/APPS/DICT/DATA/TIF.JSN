{"TIFF":[{"def":"Liquor; especially, a small draught of liquor.","pos":""},{"def":"A fit of anger or peevishness; a slight altercation or contention.","pos":""}],"TIFFANY":[{"def":"A species of gause, or very silk.","pos":""}],"TIFFIN":[{"def":"A lunch, or slight repast between breakfast and dinner; -- originally, a Provincial English word, but introduced into India, and brought back to England in a special sense.","pos":""}],"TIFFISH":[{"def":"Inclined to tiffs; peevish; petulant.","pos":""}],"TIFT":[{"def":"A fit of pettishness, or slight anger; a tiff.","pos":""}]}