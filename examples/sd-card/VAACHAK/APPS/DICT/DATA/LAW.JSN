{"LAW":[{"def":"In general, a rule of being or of conduct, established by an authority able to enforce its will; a controlling regulation; the mode or order according to which an agent or a power acts.","pos":""},{"def":"In morals: The will of God as the rule for the disposition and conduct of all responsible beings toward him and toward each other; a rule of living, conformable to righteousness; the rule of action as obligatory on the conscience or moral nature.","pos":""}],"LAW-ABIDING":[{"def":"Abiding the law; waiting for the operation of law for the enforcement of rights; also, abiding by the law; obedient to the law; as, law-abiding people.","pos":""}],"LAWBREAKER":[{"def":"One who disobeys the law; a criminal.","pos":""}],"LAWE":[{"def":"To cut off the claws and balls of, as of a dog's fore feet.","pos":""}],"LAWFUL":[{"def":"Conformable to law; allowed by law; legitimate; competent.","pos":""},{"def":"Constituted or authorized by law; rightful; as, the lawful owner of lands.","pos":""}],"LAWGIVER":[{"def":"One who makes or enacts a law or system of laws; a legislator.","pos":""}],"LAWGIVING":[{"def":"Enacting laws; legislative.","pos":""}],"LAWING":[{"def":"Going to law; litigation.","pos":""}],"LAWLESS":[{"def":"Contrary to, or unauthorized by, law; illegal; as, a lawless claim.","pos":""},{"def":"Not subject to, or restrained by, the law of morality or of society; as, lawless men or behavior.","pos":""}],"LAWMAKER":[{"def":"A legislator; a lawgiver.","pos":""}],"LAWMAKING":[{"def":"Enacting laws; legislative.","pos":""},{"def":"The enacting of laws; legislation.","pos":""}],"LAWMONGER":[{"def":"A trader in law; one who practices law as if it were a trade.","pos":""}],"LAWN":[{"def":"An open space between woods.","pos":""},{"def":"Ground (generally in front of or around a house) covered with grass kept closely mown.","pos":""}],"LAWNY":[{"def":"Having a lawn; characterized by a lawn or by lawns; like a lawn.","pos":""}],"LAWSONIA":[{"def":"An Asiatic and North African shrub (Lawsonia inermis), with smooth oval leaves, and fragrant white flowers.","pos":""}],"LAWSUIT":[{"def":"An action at law; a suit in equity or admiralty; any legal proceeding before a court for the enforcement of a claim.","pos":""}],"LAWYER":[{"def":"Like, or becoming, a lawyer; as, lawyerlike sagacity.","pos":""}]}