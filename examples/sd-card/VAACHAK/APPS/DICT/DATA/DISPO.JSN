{"DISPOLINE":[{"def":"One of several isomeric organic bases of the quinoline series of alkaloids.","pos":""}],"DISPONDEE":[{"def":"A double spondee; a foot consisting of four long syllables.","pos":""}],"DISPONE":[{"def":"To make over, or convey, legally.","pos":""}],"DISPONEE":[{"def":"The person to whom any property is legally conveyed.","pos":""}],"DISPONER":[{"def":"One who legally transfers property from himself to another.","pos":""}],"DISPONGE":[{"def":"To sprinkle, as with water from a sponge.","pos":""}],"DISPOPE":[{"def":"To refuse to consider as pope; to depose from the popedom.","pos":""}],"DISPOROUS":[{"def":"Having two spores.","pos":""}],"DISPORT":[{"def":"Play; sport; pastime; diversion; playfulness.","pos":""}],"DISPORTMENT":[{"def":"Act of disporting; diversion; play.","pos":""}],"DISPOSABLE":[{"def":"Subject to disposal; free to be used or employed as occasion may require; not assigned to any service or use.","pos":""}],"DISPOSAL":[{"def":"The act of disposing, or disposing of, anything; arrangement; orderly distribution; a putting in order; as, the disposal of the troops in two lines.","pos":""},{"def":"Ordering; regulation; adjustment; management; government; direction.","pos":""}],"DISPOSE":[{"def":"To distribute and put in place; to arrange; to set in order; as, to dispose the ships in the form of a crescent.","pos":""},{"def":"To regulate; to adjust; to settle; to determine.","pos":""}],"DISPOSED":[{"def":"Inclined; minded.","pos":""},{"def":"Inclined to mirth; jolly.","pos":""}],"DISPOSEDNESS":[{"def":"The state of being disposed or inclined; inclination; propensity.","pos":""}],"DISPOSER":[{"def":"One who, or that which, disposes; a regulator; a director; a bestower.","pos":""}],"DISPOSINGLY":[{"def":"In a manner to dispose.","pos":""}],"DISPOSITION":[{"def":"The act of disposing, arranging, ordering, regulating, or transferring; application; disposal; as, the disposition of a man's property by will.","pos":""},{"def":"The state or the manner of being disposed or arranged; distribution; arrangement; order; as, the disposition of the trees in an orchard; the disposition of the several parts of an edifice.","pos":""}],"DISPOSITIONAL":[{"def":"Pertaining to disposition.","pos":""}],"DISPOSITIONED":[{"def":"Having (such) a disposition; -- used in compounds; as, well- dispositioned.","pos":""}],"DISPOSITIVE":[{"def":"Disposing; tending to regulate; decretive.","pos":""},{"def":"Belonging to disposition or natural, tendency.","pos":""}],"DISPOSITIVELY":[{"def":"In a dispositive manner; by natural or moral disposition.","pos":""}],"DISPOSITOR":[{"def":"The planet which is lord of the sign where another planet is.","pos":""}],"DISPOSSESS":[{"def":"To put out of possession; to deprive of the actual occupancy of, particularly of land or real estate; to disseize; to eject; -- usually followed by of before the thing taken away; as, to dispossess a king of his crown.","pos":""}],"DISPOSSESSION":[{"def":"The putting out of possession, wrongfully or otherwise, of one who is in possession of a freehold, no matter in what title; -- called also ouster.","pos":""}],"DISPOSSESSOR":[{"def":"One who dispossesses.","pos":""}],"DISPOST":[{"def":"To eject from a post; to displace.","pos":""}],"DISPOSURE":[{"def":"The act of disposing; power to dispose of; disposal; direction.","pos":""},{"def":"Disposition; arrangement; position; posture.","pos":""}]}