{"SEICHES":[{"def":"Local oscillations in level observed in the case of some lakes, as Lake Geneva.","pos":""}],"SEID":[{"def":"A descendant of Mohammed through his daughter Fatima and nephew Ali.","pos":""}],"SEIDLITZ":[{"def":"Of or pertaining to Seidlitz, a village in Bohemia.","pos":""}],"SEIGNEURIAL":[{"def":"Of or pertaining to the lord of a manor; manorial.","pos":""},{"def":"Vested with large powers; independent.","pos":""}],"SEIGNIOR":[{"def":"A lord; the lord of a manor.","pos":""},{"def":"A title of honor or of address in the South of Europe, corresponding to Sir or Mr.","pos":""}],"SEIGNIORAGE":[{"def":"Something claimed or taken by virtue of sovereign prerogative; specifically, a charge or toll deducted from bullion brought to a mint to be coined; the difference between the cost of a mass of bullion and the value as money of the pieces coined from it.","pos":""},{"def":"A share of the receipts of a business taken in payment for the use of a right, as a copyright or a patent.","pos":""}],"SEIGNIORAL":[{"def":"Of or pertaining to a seignior; seigneurial.","pos":""}],"SEIGNIORALTY":[{"def":"The territory or authority of a seignior, or lord.","pos":""}],"SEIGNIORIAL":[{"def":"Same as Seigneurial.","pos":""}],"SEIGNIORIZE":[{"def":"To lord it over.","pos":""}],"SEIGNIORY":[{"def":"The power or authority of a lord; dominion.","pos":""},{"def":"The territory over which a lord holds jurisdiction; a manor.","pos":""}],"SEINE":[{"def":"A large net, one edge of which is provided with sinkers, and the other with floats.","pos":""}],"SEINER":[{"def":"One who fishes with a seine.","pos":""}],"SEINING":[{"def":"Fishing with a seine.","pos":""}],"SEIRFISH":[{"def":"Same as Seerfish.","pos":""}],"SEIROSPORE":[{"def":"One of several spores arranged in a chain as in certain algæ of the genus Callithamnion.","pos":""}],"SEISE":[{"def":"Note: This is the common spelling in the law phrase to be seised of (an estate).","pos":""}],"SEISIN":[{"def":"Of or pertaining to an earthquake; caused by an earthquake.","pos":""}],"SEISMOGRAM":[{"def":"The trace or record of an earth tremor, made by means of a seismograph.","pos":""}],"SEISMOGRAPH":[{"def":"An apparatus for registering the shocks and undulatory motions of earthquakes.","pos":""}],"SEISMOGRAPHIC":[{"def":"Of or pertaining to a seismograph; indicated by a seismograph.","pos":""}],"SEISMOGRAPHY":[{"def":"A writing about, or a description of, earthquakes.","pos":""},{"def":"The art of registering the shocks and undulatory movements of earthquakes.","pos":""}],"SEISMOLOGICAL":[{"def":"Of or pertaining to seismology.","pos":""}],"SEISMOLOGY":[{"def":"The science of earthquakes.","pos":""}],"SEISMOMETER":[{"def":"An instrument for measuring the direction, duration, and force of earthquakes and like concussions.","pos":""}],"SEISMOMETRIC":[{"def":"Of or pertaining to seismometry, or seismometer; as, seismometric instruments; seismometric measurements.","pos":""}],"SEISMOMETRY":[{"def":"The mensuration of such phenomena of earthquakes as can be expressed in numbers, or by their relation to the coördinates of space.","pos":""}],"SEITY":[{"def":"Something peculiar to one's self.","pos":""}],"SEIZABLE":[{"def":"That may be seized.","pos":""}],"SEIZE":[{"def":"To take possession of by virtue of a warrant or other legal authority; as, the sheriff seized the debtor's goods.","pos":""},{"def":"To bind or fasten together with a lashing of small stuff, as yarn or marline; as, to seize ropes.","pos":""}],"SEIZER":[{"def":"One who, or that which, seizes.","pos":""}],"SEIZIN":[{"def":"Possession; possession of an estate of froehold.","pos":""}],"SEIZING":[{"def":"The act of taking or grasping suddenly.","pos":""}],"SEIZOR":[{"def":"One who seizes, or takes possession.","pos":""}],"SEIZURE":[{"def":"Sitting, as a lion or other beast.","pos":""}]}