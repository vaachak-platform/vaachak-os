{"WIT":[{"def":"To know; to learn.","pos":""}],"WIT-CRACKER":[{"def":"One who breaks jests; a joker.","pos":""}],"WIT-SNAPPER":[{"def":"One who affects repartee; a wit-cracker.","pos":""}],"WIT-STARVED":[{"def":"Barren of wit; destitute of genius.","pos":""}],"WITAN":[{"def":"the members of the national, or king's, council which sat to assist the king in administrative and judicial matters; also, the council.","pos":""}],"WITCH":[{"def":"A cone of paper which is placed in a vessel of lard or other fat, and used as a taper.","pos":""}],"WITCH-TREE":[{"def":"The witch-hazel.","pos":""}],"WITCHCRAFT":[{"def":"The practices or art of witches; sorcery; enchantments; intercourse with evil spirits.","pos":""},{"def":"Power more than natural; irresistible influence.","pos":""}],"WITCHERY":[{"def":"Sorcery; enchantment; witchcraft.","pos":""},{"def":"Fascination; irresistible influence; enchantment.","pos":""}],"WITCHING":[{"def":"That witches or enchants; suited to enchantment or witchcraft; bewitching.","pos":""}],"WITCHUCK":[{"def":"The sand martin, or bank swallow.","pos":""}],"WITCRAFT":[{"def":"Art or skill of the mind; contrivance; invention; wit.","pos":""},{"def":"The art of reasoning; logic.","pos":""}],"WITE":[{"def":"To reproach; to blame; to censure; also, to impute as blame.","pos":""}],"WITENAGEMOTE":[{"def":"A meeting of wise men; the national council, or legislature, of England in the days of the Anglo-Saxons, before the Norman Conquest.","pos":""}],"WITFISH":[{"def":"The ladyfish (a).","pos":""}],"WITH":[{"def":"With denotes or expresses some situation or relation of nearness, proximity, association, connection, or the like.","pos":""}],"WITHAL":[{"def":"With this; with that.","pos":""},{"def":"Together with this; likewise; at the same time; in addition; also.","pos":""}],"WITHAMITE":[{"def":"A variety of epidote, of a reddish color, found in Scotland.","pos":""}],"WITHDRAW":[{"def":"To take back or away, as what has been bestowed or enjoyed; to draw back; to cause to move away or retire; as, to withdraw aid, favor, capital, or the like.","pos":""},{"def":"To take back; to recall or retract; as, to withdraw false charges.","pos":""}],"WITHDRAWAL":[{"def":"The act of withdrawing; withdrawment; retreat; retraction.","pos":""}],"WITHDRAWER":[{"def":"One who withdraws; one who takes back, or retracts.","pos":""}],"WITHDRAWING-ROOM":[{"def":"A room for retirement from another room, as from a dining room; a drawing-room.","pos":""}],"WITHDRAWMENT":[{"def":"The act of withdrawing; withdrawal.","pos":""}],"WITHE":[{"def":"An iron attachment on one end of a mast or boom, with a ring, through which another mast or boom is rigged out and secured; a wythe.","pos":""},{"def":"A partition between flues in a chimney.","pos":""}],"WITHE-ROD":[{"def":"A North American shrub (Viburnum nudum) whose tough osierlike shoots are sometimes used for binding sheaves.","pos":""}],"WITHER":[{"def":"To fade; to lose freshness; to become sapless; to become sapless; to dry or shrivel up.","pos":""},{"def":"To lose or want animal moisture; to waste; to pin This is man, old, wrinkled, faded, withered.","pos":""}],"WITHER-WRUNG":[{"def":"Injured or hurt in the withers, as a horse.","pos":""}],"WITHERBAND":[{"def":"A piece of iron in a saddle near a horse's withers, to strengthen the bow.","pos":""}],"WITHERED":[{"def":"Faded; dried up; shriveled; wilted; wasted; wasted away.","pos":""}],"WITHERING":[{"def":"Tending to wither; causing to shrink or fade.","pos":""}],"WITHERITE":[{"def":"Barium carbonate occurring in white or gray six-sided twin crystals, and also in columnar or granular masses.","pos":""}],"WITHERLING":[{"def":"A withered person; one who is decrepit.","pos":""}],"WITHERS":[{"def":"The ridge between the shoulder bones of a horse, at the base of the neck.","pos":""}],"WITHHOLD":[{"def":"To hold back; to restrain; to keep from action.","pos":""},{"def":"To retain; to keep back; not to grant; as, to withhold assent to a proposition.","pos":""}],"WITHHOLDER":[{"def":"One who withholds.","pos":""}],"WITHHOLDMENT":[{"def":"The act of withholding.","pos":""}],"WITHIN":[{"def":"In the inner or interior part of; inside of; not without; as, within doors.","pos":""},{"def":"In the limits or compass of; not further in length than; as, within five miles; not longer in time than; as, within an hour; not exceeding in quantity; as, expenses kept within one's income.","pos":""}],"WITHINFORTH":[{"def":"Within; inside; inwardly.","pos":""}],"WITHINSIDE":[{"def":"In the inner parts; inside.","pos":""}],"WITHOUT":[{"def":"On or at the outside of; out of; not within; as, without doors.","pos":""},{"def":"Out of the limits of; out of reach of; beyond.","pos":""}],"WITHOUT-DOOR":[{"def":"Outdoor; exterior.","pos":""}],"WITHOUTFORTH":[{"def":"Without; outside' outwardly.","pos":""}],"WITHSAY":[{"def":"To contradict; to gainsay; to deny; to renounce.","pos":""}],"WITHSET":[{"def":"To set against; to oppose.","pos":""}],"WITHSTAND":[{"def":"To stand against; to oppose; to resist, either with physical or moral force; as, to withstand an attack of troops; to withstand eloquence or arguments.","pos":""}],"WITHSTANDER":[{"def":"One who withstands, or opposes; an opponent; a resisting power.","pos":""}],"WITHWIND":[{"def":"A kind of bindweed (Convolvulus arvensis).","pos":""}],"WITHWINE":[{"def":"Same as Withvine.","pos":""}],"WITHY":[{"def":"The osier willow (Salix viminalis).","pos":""}],"WITLESS":[{"def":"Destitute of wit or understanding; wanting thought; hence, indiscreet; not under the guidance of judgment.","pos":""}],"WITLING":[{"def":"A person who has little wit or understanding; a pretender to wit or smartness.","pos":""}],"WITNESS":[{"def":"Attestation of a fact or an event; testimony.","pos":""},{"def":"That which furnishes evidence or proof.","pos":""}],"WITNESSER":[{"def":"One who witness.","pos":""}],"WITTED":[{"def":"Having (such) a wit or understanding; as, a quick-witted boy.","pos":""}],"WITTICISM":[{"def":"A witty saying; a sentence or phrase which is affectedly witty; an attempt at wit; a conceit.","pos":""}],"WITTIFIED":[{"def":"Possessed of wit; witty.","pos":""}],"WITTILY":[{"def":"In a witty manner; wisely; ingeniously; artfully; with it; with a delicate turn or phrase, or with an ingenious association of ideas.","pos":""}],"WITTINESS":[{"def":"The quality of being witty.","pos":""}],"WITTINGLY":[{"def":"Knowingly; with knowledge; by design.","pos":""}],"WITTOL":[{"def":"A man who knows his wife's infidelity and submits to it; a tame cuckold; -- so called because the cuckoo lays its eggs in the wittol's nest.","pos":""}],"WITTOLLY":[{"def":"Like a wittol; cuckoldly.","pos":""}],"WITTS":[{"def":"Tin ore freed from earthy matter by stamping.","pos":""}],"WITTY":[{"def":"Possessed of wit; knowing; wise; skillful; judicious; clever; cunning.","pos":""},{"def":"Especially, possessing wit or humor; good at repartee; droll; facetious; sometimes, sarcastic; as, a witty remark, poem, and the like.","pos":""}],"WITWORM":[{"def":"One who, or that which, feeds on or destroys wit.","pos":""}]}