{"COCA":[{"def":"The dried leaf of a South American shrub (Erythroxylon Coca).","pos":""}],"COCAGNE":[{"def":"An imaginary country of idleness and luxury.","pos":""},{"def":"The land of cockneys; cockneydom; -- a term applied to London and its suburbs.","pos":""}],"COCAINE":[{"def":"A powerful alkaloid, C17H21NO4, obtained from the leaves of coca.","pos":""}],"COCAINISM":[{"def":"A morbid condition produced by the habitual and excessive use of cocaine.","pos":""}],"COCAINIZE":[{"def":"To treat or anæsthetize with cocaine.","pos":""}],"COCCIFEROUS":[{"def":"Bearing or producing berries; bacciferous; as, cocciferrous trees or plants.","pos":""}],"COCCINELLA":[{"def":"A genus of small beetles of many species.","pos":""}],"COCCOBACTERIUM":[{"def":"One of the round variety of bacteria, a vegetable organism, generally less than a thousandth of a millimeter in diameter.","pos":""}],"COCCOLITE":[{"def":"A granular variety of pyroxene, green or white in color.","pos":""}],"COCCOLITH":[{"def":"One of a kind of minute, calcareous bodies, probably vegetable, often abundant in deep-sea mud.","pos":""}],"COCCOSPHERE":[{"def":"A small, rounded, marine organism, capable of braking up into coccoliths.","pos":""}],"COCCOSTEUS":[{"def":"An extinct genus of Devonian ganoid fishes, having the broad plates about the head studded with berrylike tubercles.","pos":""}],"COCCULUS INDICUS":[{"def":"The fruit or berry of the Anamirta Cocculus, a climbing plant of the East Indies.","pos":""}],"COCCUS":[{"def":"One of the separable carpels of a dry fruit.","pos":""},{"def":"A genus of hemipterous insects, including scale insects, and the cochineal insect (Coccus cacti).","pos":""}],"COCCYGEAL":[{"def":"Of or pertaining to the coccyx; as, the coccygeal vertebræ.","pos":""}],"COCCYX":[{"def":"The end of the vertebral column beyond the sacrum in man and tailless monkeys.","pos":""}],"COCHIN FOWL":[{"def":"A large variety of the domestic fowl, originally from Cochin China (Anam).","pos":""}],"COCHINEAL":[{"def":"A dyestuff consisting of the dried bodies of females of the Coccus cacti, an insect native in Mexico, Central America, etc.","pos":""}],"COCHINEAL FIG":[{"def":"A plant of Central and Southern Anerica, of the Cactus familly, extensively cultivated for the sake of the cochineal insect, which lives on it.","pos":""}],"COCHLEA":[{"def":"An appendage of the labyrinth of the internal ear, which is elongated and coiled into a spiral in mammals.","pos":""}],"COCHLEAR":[{"def":"Of or pertaining to the cochlea.","pos":""}],"COCHLEARY":[{"def":"Same as Cochleate.","pos":""},{"def":"Having the form of a snail shell; spiral; turbinated.","pos":""}],"COCK":[{"def":"The male of birds, particulary of gallinaceous or domestic fowls.","pos":""},{"def":"A vane in the shape of a cock; a weathercock.","pos":""}],"COCK-A-HOOP":[{"def":"Boastful; defiant; exulting.","pos":""}],"COCKADE":[{"def":"A badge, usually in the form of a rosette, or knot, and generally worn upon the hat; -- used as an indication of military or naval service, or party allegiance, and in England as a part of the livery to indicate that the wearer is the servant of a military or naval officer.","pos":""}],"COCKADED":[{"def":"Wearing a cockade.","pos":""}],"COCKAL":[{"def":"A game played with sheep's bones instead of dice [Obs.","pos":""},{"def":"The bone used in playing the game; -- called also huckle bone.","pos":""}],"COCKALEEKIE":[{"def":"A favorite soup in Scotland, made from a capon highly seasoned, and boiled with leeks and prunes.","pos":""}],"COCKAMAROO":[{"def":"The Russian variety of bagatelle.","pos":""}],"COCKATEEL":[{"def":"An Australian parrot (Calopsitta Novæ-Hollandiæ); -- so called from its note.","pos":""}],"COCKATOO":[{"def":"A bird of the Parrot family, of the subfamily Cacatuinæ, having a short, strong, and much curved beak, and the head ornamented with a crest, which can be raised or depressed at will.","pos":""},{"def":"A representation of this serpent.","pos":""}],"COCKATRICE":[{"def":"A fabulous serpent whose breath and look were said to be fatal.","pos":""},{"def":"Any venomous or deadly thing.","pos":""}],"COCKBILL":[{"def":"To tilt up one end of so as to make almost vertical; as, to cockbill the yards as a sign of mourning.","pos":""}],"COCKBOAT":[{"def":"A small boat, esp.","pos":""}],"COCKCHAFER":[{"def":"A beetle of the genus Melolontha (esp.","pos":""},{"def":"The time at which cooks first crow; the early morning.","pos":""}],"COCKER":[{"def":"Th treat with too great tenderness; to fondle; to indulge; to pamper.","pos":""}],"COCKER SPANIEL":[{"def":"One of a breed of small or medium-sized spaniels kept for hunting or retrieving game or for household pets.","pos":""}],"COCKET":[{"def":"A customhouse seal; a certified document given to a shopper as a warrant that his goods have been duly enstered and have paid duty.","pos":""}],"COCKEYE":[{"def":"A squinting eye.","pos":""}],"COCKFIGHT":[{"def":"A match or contest of gamecocks.","pos":""}],"COCKFIGHTING":[{"def":"The act or practice of pitting gamecocks to fight.","pos":""}],"COCKHEAD":[{"def":"The rounded or pointed top of a grinding mill spindle, forming a pivot on which the stone is balanced.","pos":""}],"COCKHORSE":[{"def":"A child's rocking-horse.","pos":""},{"def":"A high or tall horse.","pos":""}],"COCKIELEEKIE":[{"def":"Same as Cockaleekie.","pos":""}],"COCKLE":[{"def":"A bivalve mollusk, with radiating ribs, of the genus Cardium, especially C.","pos":""}],"COCKLEBUR":[{"def":"A coarse, composite weed, having a rough or prickly fruit; one of several species of the genus Xanthium; -- called also clotbur.","pos":""}],"COCKLED":[{"def":"Inclosed in a shell.","pos":""}],"COCKLER":[{"def":"One who takes and sells cockles.","pos":""}],"COCKLESHELL":[{"def":"One of the shells or valves of a cockle.","pos":""}],"COCKLOFT":[{"def":"An upper loft; a garret; the highest room in a building.","pos":""}],"COCKMASTER":[{"def":"One who breeds gamecocks.","pos":""}],"COCKNEY":[{"def":"An effeminate person; a spoilt child.","pos":""},{"def":"A native or resident of the city of London; -- used contemptuosly.","pos":""}],"COCKNEYDOM":[{"def":"The region or home of cockneys; cockneys, collectively.","pos":""}],"COCKNEYFY":[{"def":"To form with the manners or character of a cockney.","pos":""}],"COCKNEYISH":[{"def":"Characteristic of, or resembling, cockneys.","pos":""}],"COCKNEYISM":[{"def":"The charasteristics, manners, or dialect, of a cockney.","pos":""}],"COCKPIT":[{"def":"A pit, or inclosed area, for cockfights.","pos":""},{"def":"The Privy Council room at Westminster; -- so called because built on the site of the cockpit of Whitehall palace.","pos":""}],"COCKROACH":[{"def":"An orthopterus insect of the genus Blatta, and allied genera.","pos":""}],"COCKSCOMB":[{"def":"A plant (Celosia cristata), of many varieties, cultivated for its broad, fantastic spikes of brilliant flowers; -- sometimes called garden cockscomb.","pos":""}],"COCKSHUT":[{"def":"A kind of net to catch woodcock.","pos":""}],"COCKSHY":[{"def":"A game in which trinkets are set upon sticks, to be thrown at by the players; -- so called from an ancient popular sport which consisted in \"shying\" or throwing cudgels at live cocks.","pos":""},{"def":"An object at which stones are flung.","pos":""}],"COCKSPUR":[{"def":"A variety of Cratægus, or hawthorn (C.","pos":""}],"COCKSURE":[{"def":"We steal as in a castle, cocksure: .","pos":""}],"COCKSWAIN":[{"def":"The steersman of a boat; a petty officer who has charge of a boat and its crew.","pos":""}],"COCKTAIL":[{"def":"A horse, not of pure breed, but having only one eighth or one sixteenth impure blood in his veins.","pos":""},{"def":"A species of rove beetle; -- so called from its habit of elevating the tail.","pos":""}],"COCKUP":[{"def":"A large, highly esteemed, edible fish of India (Lates calcarifer); -- also called begti.","pos":""}],"COCKY":[{"def":"A pet name for any small bird.","pos":""}],"COCOA":[{"def":"A preparation made from the seeds of the chocolate tree, and used in making, a beverage; also the beverage made from cocoa or cocoa shells.","pos":""}],"COCOANUT":[{"def":"The large, hard-shelled nut of the cocoa palm.","pos":""},{"def":"A very beautiful and hard wood, obtained in the West India Islands.","pos":""}],"COCOON":[{"def":"An oblong case in which the silkworn lies in its chrysalis state.","pos":""}],"COCOONERY":[{"def":"A building or apartment for silkworms, when feeding and forming cocoons.","pos":""}],"COCTIBLE":[{"def":"Capable of being cooked.","pos":""}],"COCTILE":[{"def":"Made by baking, or exposing to heat, as a brick.","pos":""}],"COCUS WOOD":[{"def":"A West Indian wood, used for making flutes and other musical instruments.","pos":""}]}