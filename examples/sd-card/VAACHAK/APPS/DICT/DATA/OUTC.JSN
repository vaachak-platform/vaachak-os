{"OUTCANT":[{"def":"To surpass in canting.","pos":""}],"OUTCAST":[{"def":"Cast out; degraded.","pos":""}],"OUTCASTING":[{"def":"That which is cast out.","pos":""}],"OUTCHEAT":[{"def":"To exceed in cheating.","pos":""}],"OUTCLIMB":[{"def":"To climb bevond; to surpass in climbing.","pos":""}],"OUTCOME":[{"def":"That which comes out of, or follows from, something else; issue; result; consequence; upshot.","pos":""}],"OUTCOMPASS":[{"def":"To exceed the compass or limits of.","pos":""}],"OUTCOURT":[{"def":"An outer or exterior court.","pos":""}],"OUTCRAFTY":[{"def":"To exceed in cunning.","pos":""}],"OUTCRIER":[{"def":"One who cries out or proclaims; a herald or crier.","pos":""}],"OUTCROP":[{"def":"To come out to the surface of the ground; -- said of strata.","pos":""}],"OUTCRY":[{"def":"A vehement or loud cry; a cry of distress, alarm, opposition, or detestation; clamor.","pos":""},{"def":"Sale at public auction.","pos":""}]}