{"PANSHON":[{"def":"An earthen vessel wider at the top than at the bottom, -- used for holding milk and for various other purposes.","pos":""}],"PANSIED":[{"def":"Covered or adorned with pansies.","pos":""}],"PANSLAVIC":[{"def":"Pertaining to all the Slavic races.","pos":""}],"PANSLAVISM":[{"def":"A scheme or desire to unite all the Slavic races into one confederacy.","pos":""}],"PANSLAVIST":[{"def":"One who favors Panslavism.","pos":""}],"PANSOPHICAL":[{"def":"All-wise; claiming universal knowledge; as, pansophical pretenders.","pos":""}],"PANSOPHY":[{"def":"Universal wisdom; esp.","pos":""},{"def":"A believer in panspermy; one who rejects the theory of spontaneous generation; a biogenist.","pos":""}],"PANSPERMIC":[{"def":"Of or pertaining to panspermy; as, the panspermic hypothesis.","pos":""}],"PANSTEREORAMA":[{"def":"A model of a town or country, in relief, executed in wood, cork, pasteboard, or the like.","pos":""}],"PANSY":[{"def":"A plant of the genus Viola (V.","pos":""}]}