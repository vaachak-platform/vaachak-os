{"JAB":[{"def":"To thrust; to stab; to punch.","pos":""}],"JABBER":[{"def":"To talk rapidly, indistinctly, or unintelligibly; to utter gibberish or nonsense; to chatter.","pos":""}],"JABBERER":[{"def":"One who jabbers.","pos":""}],"JABBERINGLY":[{"def":"In a jabbering manner.","pos":""}],"JABBERNOWL":[{"def":"Same as Jobbernowl.","pos":""}],"JABIRU":[{"def":"One of several large wading birds of the genera Mycteria and Xenorhynchus, allied to the storks in form and habits.","pos":""}],"JABORANDI":[{"def":"The native name of a South American rutaceous shrub (Pilocarpus pennatifolius).","pos":""}],"JABORINE":[{"def":"An alkaloid found in jaborandi leaves, from which it is extracted as a white amorphous substance.","pos":""}],"JABOT":[{"def":"Originally, a kind of ruffle worn by men on the bosom of the shirt.","pos":""},{"def":"An arrangement of lace or tulle, looped ornamentally, and worn by women on the front of the dress.","pos":""}]}