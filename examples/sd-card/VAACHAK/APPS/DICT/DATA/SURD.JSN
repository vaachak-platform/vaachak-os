{"SURD":[{"def":"Involving surds; not capable of being expressed in rational numbers; radical; irrational; as, a surd expression or quantity; a surd number.","pos":""},{"def":"Uttered, as an element of speech, without tone, or proper vocal sound; voiceless; unintonated; nonvocal; atonic; whispered; aspirated; sharp; hard, as f, p, s, etc.","pos":""}],"SURDAL":[{"def":"Same as Surd, a.","pos":""}]}