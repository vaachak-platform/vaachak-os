{"BED":[{"def":"A layer or seam, or a horizontal stratum between layers; as, a bed of coal, iron, etc.","pos":""},{"def":"See Gun carriage, and Mortar bed.","pos":""}],"BED ROCK":[{"def":"The solid rock underlying superficial formations.","pos":""}],"BED SCREW":[{"def":"A long screw formerly used to fasten a bedpost to one of the adjacent side pieces.","pos":""}],"BED STEPS":[{"def":"Steps for mounting a bed of unusual height.","pos":""}],"BEDABBLE":[{"def":"To dabble; to sprinkle or wet.","pos":""}],"BEDAFF":[{"def":"To make a daff or fool of.","pos":""}],"BEDAGAT":[{"def":"The sacred books of the Buddhists in Burmah.","pos":""}],"BEDASH":[{"def":"To wet by dashing or throwing water or other liquid upon; to bespatter.","pos":""}],"BEDAUB":[{"def":"To daub over; to besmear or soil with anything thick and dirty.","pos":""}],"BEDAZZLE":[{"def":"To dazzle or make dim by a strong light.","pos":""}],"BEDBUG":[{"def":"A wingless, bloodsucking, hemipterous insect (Cimex Lectularius), sometimes infesting houses and especially beds.","pos":""}],"BEDCHAIR":[{"def":"A chair with adjustable back, for the sick, to support them while sitting up in bed.","pos":""}],"BEDCHAMBER":[{"def":"A chamber for a bed; an apartment form sleeping in.","pos":""}],"BEDCLOTHES":[{"def":"Blankets, sheets, coverlets, etc.","pos":""}],"BEDCORD":[{"def":"A cord or rope interwoven in a bedstead so as to support the bed.","pos":""}],"BEDDED":[{"def":"Provided with a bed; as, double-bedded room; placed or arranged in a bed or beds.","pos":""}],"BEDDING":[{"def":"The state or position of beds and layers.","pos":""}],"BEDE":[{"def":"To pray; also, to offer; to proffer.","pos":""}],"BEDECK":[{"def":"To deck, ornament, or adorn; to grace.","pos":""},{"def":"A gall produced on rosebushes, esp.","pos":""}],"BEDEHOUSE":[{"def":"Bede\"house` Defn: ,n.","pos":"noun"}],"BEDEN":[{"def":"The Abyssinian or Arabian ibex (Capra Nubiana).","pos":""}],"BEDESMAN":[{"def":"Same as Beadsman.","pos":""}],"BEDEVIL":[{"def":"To throw into utter disorder and confusion, as if by the agency of evil spirits; to bring under diabolical influence; to torment.","pos":""},{"def":"To spoil; to corrupt.","pos":""}],"BEDEVILMENT":[{"def":"The state of being bedeviled; bewildering confusion; vexatious trouble.","pos":""}],"BEDEW":[{"def":"To moisten with dew, or as with dew.","pos":""}],"BEDEWER":[{"def":"One who, or that which, bedews.","pos":""}],"BEDEWY":[{"def":"Moist with dew; dewy.","pos":""}],"BEDFELLOW":[{"def":"One who lies with another in the same bed; a person who shares one's couch.","pos":""}],"BEDIGHT":[{"def":"To bedeck; to array or equip; to adorn.","pos":""}],"BEDIM":[{"def":"To make dim; to obscure or darken.","pos":""}],"BEDIZEN":[{"def":"To dress or adorn tawdrily or with false taste.","pos":""}],"BEDIZENMENT":[{"def":"That which bedizens; the act of dressing, or the state of being dressed, tawdrily.","pos":""}],"BEDKEY":[{"def":"An instrument for tightening the parts of a bedstead.","pos":""}],"BEDLAM":[{"def":"A place appropriated to the confinement and care of the insane; a madhouse.","pos":""},{"def":"An insane person; a lunatic; a madman.","pos":""}],"BEDLAMITE":[{"def":"An inhabitant of a madhouse; a madman.","pos":""}],"BEDMAKER":[{"def":"One who makes beds.","pos":""},{"def":"The molding of a cornice immediately below the corona.","pos":""}],"BEDOTE":[{"def":"To cause to dote; to deceive.","pos":""}],"BEDOUIN":[{"def":"One of the nomadic Arabs who live in tents, and are scattered over Arabia, Syria, and northern Africa, esp.","pos":""}],"BEDPAN":[{"def":"A pan for warming beds.","pos":""},{"def":"A shallow chamber vessel, so constructed that it can be used by a sick person in bed.","pos":""}],"BEDPHERE":[{"def":"The foundation framing or piece, by which the other parts are supported and held in place; the bed; -- called also baseplate and soleplate.","pos":""}],"BEDPOST":[{"def":"One of the four standards that support a bedstead or the canopy over a bedstead.","pos":""},{"def":"Anciently, a post or pin on each side of the bed to keep the clothes from falling off.","pos":""}],"BEDQUILT":[{"def":"A quilt for a bed; a coverlet.","pos":""}],"BEDRABBLE":[{"def":"To befoul with rain and mud; to drabble.","pos":""}],"BEDRAGGLE":[{"def":"To draggle; to soil, as garments which, in walking, are suffered to drag in dust, mud, etc.","pos":""}],"BEDRENCH":[{"def":"To drench; to saturate with moisture; to soak.","pos":""}],"BEDRIBBLE":[{"def":"To dribble upon.","pos":""},{"def":"Confined to the bed by sickness or infirmity.","pos":""}],"BEDRIZZLE":[{"def":"To drizzle upon.","pos":""}],"BEDROOM":[{"def":"A room or apartment intended or used for a bed; a lodging room.","pos":""}],"BEDROP":[{"def":"To sprinkle, as with drops.","pos":""}],"BEDRUG":[{"def":"To drug abundantly or excessively.","pos":""}],"BEDSIDE":[{"def":"The side of a bed.","pos":""}],"BEDSITE":[{"def":"A recess in a room for a bed.","pos":""}],"BEDSORE":[{"def":"A sore on the back or hips caused by lying for a long time in bed.","pos":""}],"BEDSPREAD":[{"def":"A bedquilt; a counterpane; a coverlet.","pos":""}],"BEDSTAFF":[{"def":"\"A wooden pin stuck anciently on the sides of the bedstead, to hold the clothes from slipping on either side.","pos":""}],"BEDSTEAD":[{"def":"A framework for supporting a bed.","pos":""}],"BEDSTOCK":[{"def":"The front or the back part of the frame of a bedstead.","pos":""}],"BEDSTRAW":[{"def":"A genus of slender herbs, usually with square stems, whorled leaves, and small white flowers.","pos":""}],"BEDSWERVER":[{"def":"One who swerves from and is unfaithful to the marriage vow.","pos":""}],"BEDTICK":[{"def":"A tick or bag made of cloth, used for inclosing the materials of a bed.","pos":""}],"BEDTIME":[{"def":"The time to go to bed.","pos":""}],"BEDUCK":[{"def":"To duck; to put the head under water; to immerse.","pos":""}],"BEDUNG":[{"def":"To cover with dung, as for manuring; to bedaub or defile, literally or figuratively.","pos":""}],"BEDUST":[{"def":"To sprinkle, soil, or cover with dust.","pos":""}],"BEDWARF":[{"def":"To make a dwarf of; to stunt or hinder the growth of; to dwarf.","pos":""}],"BEDYE":[{"def":"To dye or stain.","pos":""}]}