{"ALFALFA":[{"def":"The lucern (Medicago sativa); -- so called in California, Texas, etc.","pos":""}],"ALFENIDE":[{"def":"An alloy of nickel and silver electroplated with silver.","pos":""}],"ALFERES":[{"def":"An ensign; a standard bearer.","pos":""}],"ALFET":[{"def":"A caldron of boiling water into which an accused person plunged his forearm as a test of innocence or guilt.","pos":""}],"ALFILARIA":[{"def":"The pin grass (Erodium cicutarium), a weed in California.","pos":""},{"def":"Same as Alfilaria.","pos":""}],"ALFIONE":[{"def":"An edible marine fish of California (Rhacochilus toxotes).","pos":""}],"ALFRESCO":[{"def":"In the open-air.","pos":""}]}