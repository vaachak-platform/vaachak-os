{"PERMANABLE":[{"def":"Permanent; durable.","pos":""},{"def":"The quality or state of being permanent; continuance in the same state or place; duration; fixedness; as, the permanence of institutions; the permanence of nature.","pos":""}],"PERMANENT":[{"def":"Continuing in the same state, or without any change that destroys form or character; remaining unaltered or unremoved; abiding; durable; fixed; stable; lasting; as, a permanent impression.","pos":""}],"PERMANENTLY":[{"def":"In a permanent manner.","pos":""}],"PERMANGANATE":[{"def":"A salt of permanganic acid.","pos":""}],"PERMANGANIC":[{"def":"Pertaining to, or designating, one of the higher acids of manganese, HMnO4, which forms salts called permanganates.","pos":""}],"PERMEABILITY":[{"def":"The quality or state of being permeable.","pos":""}],"PERMEABLE":[{"def":"Capable of being permeated, or passed through; yielding passage; passable; penetrable; -- used especially of substances which allow the passage of fluids; as, wood is permeable to oil; glass is permeable to light.","pos":""}],"PERMEABLY":[{"def":"In a permeable manner.","pos":""}],"PERMEANCE":[{"def":"Permeation; specif.","pos":""},{"def":"the reciprocal of reluctance.","pos":""}],"PERMEANT":[{"def":"Passing through; permeating.","pos":""}],"PERMEATE":[{"def":"To pass through the pores or interstices of; to penetrate and pass through without causing rupture or displacement; -- applied especially to fluids which pass through substances of loose texture; as, water permeates sand.","pos":""},{"def":"To enter and spread through; to pervade.","pos":""}],"PERMEATION":[{"def":"The act of permeating, passing through, or spreading throughout, the pores or interstices of any substance.","pos":""}],"PERMIAN":[{"def":"Belonging or relating to the period, and also to the formation, next following the Carboniferous, and regarded as closing the Carboniferous age and Paleozoic era.","pos":""},{"def":"The Permian period.","pos":""}],"PERMIANS":[{"def":"A tribe belonging to the Finnic race, and inhabiting a portion of Russia.","pos":""}],"PERMISCIBLE":[{"def":"Capable of being mixed.","pos":""}],"PERMISS":[{"def":"A permitted choice; a rhetorical figure in which a thing is committed to the decision of one's opponent.","pos":""}],"PERMISSIBILITY":[{"def":"The quality of being permissible; permissibleness; allowableness.","pos":""}],"PERMISSIBLE":[{"def":"That may be permitted; allowable; admissible.","pos":""}],"PERMISSION":[{"def":"The act of permitting or allowing; formal consent; authorization; leave; license or liberty granted.","pos":""}],"PERMISSIVE":[{"def":"Permitting; granting leave or liberty.","pos":""},{"def":"Permitted; tolerated; suffered.","pos":""}],"PERMISSIVELY":[{"def":"In a permissive manner.","pos":""}],"PERMISTION":[{"def":"The act of mixing; the state of being mingled; mixture.","pos":""}],"PERMIT":[{"def":"To consent to; to allow or suffer to be done; to tolerate; to put up with.","pos":""},{"def":"To grant (one) express license or liberty to do an act; to authorize; to give leave; -- followed by an infinitive.","pos":""}],"PERMITTANCE":[{"def":"The act of permitting; allowance; permission; leave.","pos":""}],"PERMITTEE":[{"def":"One to whom a permission or permit is given.","pos":""}],"PERMITTER":[{"def":"One who permits.","pos":""}],"PERMIX":[{"def":"To mix; to mingle.","pos":""}],"PERMULATOR":[{"def":"A special form of rotary converter with stationary commutator and rotating brushes, in which the exciting field is induced by the alternating current in a short-circuited magnetic core instead of being produced by an external magnet.","pos":""}],"PERMUTABLE":[{"def":"Capable of being permuted; exchangeable.","pos":""}],"PERMUTATION":[{"def":"Barter; exchange.","pos":""}],"PERMUTE":[{"def":"To interchange; to transfer reciprocally.","pos":""},{"def":"To exchange; to barter; to traffic.","pos":""}],"PERMUTER":[{"def":"One who permutes.","pos":""}]}