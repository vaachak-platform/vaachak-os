{"DISCRADLE":[{"def":"To take from a cradle.","pos":""}],"DISCREDIT":[{"def":"The act of discrediting or disbelieving, or the state of being discredited or disbelieved; as, later accounts have brought the story into discredit.","pos":""},{"def":"Hence, some degree of dishonor or disesteem; ill repute; reproach; -- applied to persons or things.","pos":""}],"DISCREDITABLE":[{"def":"Not creditable; injurious to reputation; disgraceful; disreputable.","pos":""}],"DISCREDITOR":[{"def":"One who discredits.","pos":""}],"DISCREET":[{"def":"The state or quality of being discrepant; disagreement; variance; discordance; dissimilarity; contrariety.","pos":""}],"DISCREPANT":[{"def":"Discordant; at variance; disagreeing; contrary; different.","pos":""}],"DISCRETE":[{"def":"Separate; not coalescent; -- said of things usually coalescent.","pos":""}],"DISCRETELY":[{"def":"Separately; disjunctively.","pos":""}],"DISCRETION":[{"def":"Left to discretion; unrestrained except by discretion or judgment; as, an ambassador with discretionary powers.","pos":""},{"def":"At discretion; according to one's discretion or judgment.","pos":""}],"DISCRETIVE":[{"def":"Marking distinction or separation; disjunctive.","pos":""}],"DISCRETIVELY":[{"def":"In a discretive manner.","pos":""}],"DISCRIMINABLE":[{"def":"Capable of being discriminated.","pos":""}],"DISCRIMINAL":[{"def":"In palmistry, applied to the line which marks the separation between the hand and the arm.","pos":""}],"DISCRIMINANT":[{"def":"The eliminant of the n partial differentials of any homogenous function of n variables.","pos":""}],"DISCRIMINATE":[{"def":"Having the difference marked; distinguished by certain tokens.","pos":""}],"DISCRIMINATELY":[{"def":"In a discriminating manner; distinctly.","pos":""}],"DISCRIMINATENESS":[{"def":"The state of being discriminated; distinctness.","pos":""}],"DISCRIMINATING":[{"def":"Marking a difference; distinguishing.","pos":""}],"DISCRIMINATION":[{"def":"The arbitrary imposition of unequal tariffs for substantially the same service.","pos":""}],"DISCRIMINATIVE":[{"def":"Marking a difference; distinguishing; distinctive; characteristic.","pos":""},{"def":"Observing distinctions; making differences; discriminating.","pos":""}],"DISCRIMINATIVELY":[{"def":"With discrimination or distinction.","pos":""}],"DISCRIMINATOR":[{"def":"One who discriminates.","pos":""}],"DISCRIMINATORY":[{"def":"Dis*crim\"i*na*to*ry, a.","pos":""}],"DISCRIMINOUS":[{"def":"Hazardous; dangerous.","pos":""}],"DISCROWN":[{"def":"To deprive of a crown.","pos":""}],"DISCRUCIATE":[{"def":"To torture; to excruciate.","pos":""}]}