{"ALLUDE":[{"def":"To refer to something indirectly or by suggestion; to have reference to a subject not specifically and plainly mentioned; -- followed by to; as, the story alludes to a recent transaction.","pos":""}],"ALLUMETTE":[{"def":"A match for lighting candles, lamps, etc.","pos":""}],"ALLUMINOR":[{"def":"An illuminator of manuscripts and books; a limner.","pos":""}],"ALLURE":[{"def":"To attempt to draw; to tempt by a lure or bait, that is, by the offer of some good, real or apparent; to invite by something flattering or acceptable; to entice; to attract.","pos":""}],"ALLUREMENT":[{"def":"The act alluring; temptation; enticement.","pos":""},{"def":"That which allures; any real or apparent good held forth, or operating, as a motive to action; as, the allurements of pleasure, or of honor.","pos":""}],"ALLURER":[{"def":"One who, or that which, allures.","pos":""}],"ALLURING":[{"def":"That allures; attracting; charming; tempting.","pos":""}],"ALLUSION":[{"def":"A figurative or symbolical reference.","pos":""},{"def":"A reference to something supposed to be known, but not explicitly mentioned; a covert indication; indirect reference; a hint.","pos":""}],"ALLUSIVE":[{"def":"Figurative; symbolical.","pos":""},{"def":"Having reference to something not fully expressed; containing an allusion.","pos":""}],"ALLUSIVELY":[{"def":"Figuratively [Obs.","pos":""}],"ALLUSIVENESS":[{"def":"The quality of being allusive.","pos":""}],"ALLUVIAL":[{"def":"Pertaining to, contained in, or composed of, alluvium; relating to the deposits made by flowing water; washed away from one place and deposited in another; as, alluvial soil, mud, accumulations, deposits.","pos":""}],"ALLUVION":[{"def":"An accession of land gradually washed to the shore or bank by the flowing of water.","pos":""}],"ALLUVIUM":[{"def":"Deposits of earth, sand, gravel, and other transported matter, made by rivers, floods, or other causes, upon land not permanently submerged beneath the waters of lakes or seas.","pos":""}]}