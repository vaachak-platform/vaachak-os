{"INDO-":[{"def":"A prefix signifying Indian (i.","pos":""}],"INDO-ARYAN":[{"def":"A member of one of the native races of India of Aryan speech and blood, characterized by tall stature, dolichocephaly, fair complexion with dark hair and eyes, plentiful beard, and narrow and prominent nose.","pos":""}],"INDO-BRITON":[{"def":"A person born in India, of mixed Indian and British blood; a half-caste.","pos":""}],"INDO-CHINESE":[{"def":"Of or pertaining to Indo-China (i.","pos":""}],"INDO-DO-CHINESE LANGUAGES":[{"def":"A family of languages, mostly of the isolating type, although some are agglutinative, spoken in the great area extending from northern India in the west to Formosa in the east and from Central Asia in the north to the Malay Peninsula in the south.","pos":""}],"INDO-ENGLISH":[{"def":"Of or relating to the English who are born or reside in India; Anglo-Indian.","pos":""}],"INDO-EUROPEAN":[{"def":"Aryan; -- applied to the languages of India and Europe which are derived from the prehistoric Aryan language; also, pertaining to the people or nations who speak these languages; as, the Indo- European or Aryan family.","pos":""}],"INDO-GERMANIC":[{"def":"Same as Aryan, and Indo-European.","pos":""},{"def":"Pertaining to or denoting the Teutonic family of languages as related to the Sanskrit, or derived from the ancient Aryan language.","pos":""}],"INDOANILINE":[{"def":"Any one of a series of artificial blue dyes, in appearance resembling indigo, for which they are often used as substitutes.","pos":""}],"INDOCIBILITY":[{"def":"The state of being indocible; indocibleness; indocility.","pos":""}],"INDOCIBLE":[{"def":"Incapable of being taught, or not easily instructed; dull in intellect; intractable; unteachable; indocile.","pos":""}],"INDOCILE":[{"def":"Not teachable; indisposed to be taught, trained, or disciplined; not easily instructed or governed; dull; intractable.","pos":""}],"INDOCILITY":[{"def":"The quality or state of being indocile; dullness of intellect; unteachableness; intractableness.","pos":""}],"INDOCTRINATE":[{"def":"To instruct in the rudiments or principles of learning, or of a branch of learning; to imbue with learning; to instruct in, or imbue with, principles or doctrines; to teach; -- often followed by in.","pos":""}],"INDOCTRINATION":[{"def":"The act of indoctrinating, or the condition of being indoctrinated; instruction in the rudiments and principles of any science or system of belief; information.","pos":""}],"INDOGEN":[{"def":"A complex, nitrogenous radical, C8H5NO, regarded as the essential nucleus of indigo.","pos":""}],"INDOGENIDE":[{"def":"Any one of the derivatives of indogen, which contain that group as a nucleus.","pos":""}],"INDOIN":[{"def":"A substance resembling indigo blue, obtained artificially from certain isatogen compounds.","pos":""}],"INDOL":[{"def":"A white, crystalline substance, C8H7N, obtained from blue indigo, and almost all indigo derivatives, by a process of reduction.","pos":""}],"INDOLENCE":[{"def":"Freedom from that which pains, or harasses, as toil, care, grief, etc.","pos":""},{"def":"The quality or condition of being indolent; inaction, or want of exertion of body or mind, proceeding from love of ease or aversion to toil; habitual idleness; indisposition to labor; laziness; sloth; inactivity.","pos":""}],"INDOLENT":[{"def":"Causing little or no pain or annoyance; as, an indolent tumor.","pos":""}],"INDOLENTLY":[{"def":"In an indolent manner.","pos":""}],"INDOLES":[{"def":"Natural disposition; natural quality or abilities.","pos":""}],"INDOLIN":[{"def":"A dark resinous substance, polymeric with indol, and obtained by the reduction of indigo white.","pos":""}],"INDOMITABLE":[{"def":"Not to be subdued; untamable; invincible; as, an indomitable will, courage, animal.","pos":""}],"INDOMITE":[{"def":"Not tamed; untamed; savage; wild.","pos":""}],"INDONESIAN":[{"def":"Of or pertaining to Indonesia or Indonesians.","pos":""}],"INDOOR":[{"def":"Done or being within doors; within a house or institution; domestic; as, indoor work.","pos":""}],"INDOORS":[{"def":"Within the house; -- usually separated, in doors.","pos":""}],"INDOPHENOL":[{"def":"Any one of a series of artificial blue dyestuffs, resembling indigo in appearance, and obtained by the action of phenol on certain nitrogenous derivatives of quinone.","pos":""}],"INDORSABLE":[{"def":"Capable of being indorsed; transferable; convertible.","pos":""}],"INDORSE":[{"def":"To write one's name, alone or with other words, upon the back of (a paper), for the purpose of transferring it, or to secure the payment of a 4.","pos":""}],"INDORSEE":[{"def":"The person to whom a note or bill is indorsed, or assigned by indorsement.","pos":""}],"INDORSEMENT":[{"def":"The person who indorses.","pos":""}],"INDOXYL":[{"def":"A nitrogenous substance, C8H7NO, isomeric with oxindol, obtained as an oily liquid.","pos":""}],"INDOXYLIC":[{"def":"Of or pertaining to, or producing, indoxyl; as, indoxylic acid.","pos":""}]}