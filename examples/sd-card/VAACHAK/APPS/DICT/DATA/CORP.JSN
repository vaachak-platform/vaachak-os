{"CORPORACE":[{"def":"Cor\"po*race (kr\"p-rs), n.","pos":""}],"CORPORAL":[{"def":"A noncommissioned officer, next below a sergeant.","pos":""}],"CORPORALITY":[{"def":"The state of being or having a body; bodily existence; corporeality; -- opposed to spirituality.","pos":""},{"def":"A confraternity; a guild.","pos":""}],"CORPORALLY":[{"def":"In or with the body; bodily; as, to be corporally present.","pos":""}],"CORPORALSHIP":[{"def":"A corporal's office.","pos":""}],"CORPORAS":[{"def":"The corporal, or communion cloth.","pos":""}],"CORPORATE":[{"def":"Formed into a body by legal enactment; united in an association, and endowed by law with the rights and liabilities of an individual; incorporated; as, a corporate town.","pos":""},{"def":"Belonging to a corporation or incorporated body.","pos":""}],"CORPORATELY":[{"def":"In a corporate capacity; acting as a coprporate body.","pos":""},{"def":"In, or as regarda, the body.","pos":""}],"CORPORATION":[{"def":"A body politic or corporate, formed and authorized by law to act as a single person, and endowed by law with the capacity of succession; a society having the capacity of transacting business as an individual.","pos":""}],"CORPORATOR":[{"def":"A member of a corporation, esp.","pos":""}],"CORPORATURE":[{"def":"The state of being embodied; bodily existence.","pos":""}],"CORPOREAL":[{"def":"Having a body; consisting of, or pertaining to, a material body or substance; material; -- opposed to spiritual or immaterial.","pos":""}],"CORPOREALISM":[{"def":"Cor*po\"re*al*ism (-z'm), n.","pos":""}],"CORPOREALIST":[{"def":"One who denies the reality of spiritual existences; a materialist.","pos":""}],"CORPOREALITY":[{"def":"The state of being corporeal; corporeal existence.","pos":""}],"CORPOREALLY":[{"def":"In the body; in a bodily form or manner.","pos":""}],"CORPOREALNESS":[{"def":"Corporeality; corporeity.","pos":""}],"CORPOREITY":[{"def":"The state of having a body; the state of being corporeal; materiality.","pos":""}],"CORPORIFY":[{"def":"To embody; to form into a body.","pos":""}],"CORPOSANT":[{"def":"Cor\"po*sant (kr\"p-znt), n.","pos":""}],"CORPS":[{"def":"The land with which a prebend or other ecclesiastical office is endowed.","pos":""}],"CORPSE":[{"def":"A human body in general, whether living or dead; -- sometimes contemptuosly.","pos":""},{"def":"The dead body of a human being; -- used also Fig.","pos":""}],"CORPULENT":[{"def":"Very fat; obese.","pos":""},{"def":"Solid; gross; opaque.","pos":""}],"CORPULENTLY":[{"def":"In a corpulent manner.","pos":""}],"CORPUS":[{"def":"A body, living or dead; the corporeal substance of a thing.","pos":""}],"CORPUSCLE":[{"def":"A protoplasmic animal cell; esp.","pos":""}],"CORPUSCULAR":[{"def":"Pertaining to, or composed of, corpuscles, or small particles.","pos":""}],"CORPUSCULARIAN":[{"def":"Cor*pus`cu*la\"ri*an (-l\"r-an), a.","pos":""}],"CORPUSCULE":[{"def":"Cor*pus\"cule (kr-ps\"kl), n.","pos":""}],"CORPUSCULOUS":[{"def":"Cor*pus\"cu*lous (-k-ls), a.","pos":""}]}