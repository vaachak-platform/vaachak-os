{"INSPAN":[{"def":"To yoke or harness, as oxen to a vehicle.","pos":""}],"INSPECT":[{"def":"To look upon; to view closely and critically, esp.","pos":""},{"def":"To view and examine officially, as troops, arms, goods offered, work done for the public, etc.","pos":""}],"INSPECTION":[{"def":"The act or process of inspecting or looking at carefully; a strict or prying examination; close or careful scrutiny; investigation.","pos":""},{"def":"The act of overseeing; official examination or superintendence.","pos":""}],"INSPECTIVE":[{"def":"Engaged in inspection; inspecting; involving inspection.","pos":""}],"INSPECTOR":[{"def":"One who inspects, views, or oversees; one to whom the supervision of any work is committed; one who makes an official view or examination, as a military or civil officer; a superintendent; a supervisor; an overseer.","pos":""}],"INSPECTORIAL":[{"def":"Of or pertaining to an inspector or to inspection.","pos":""}],"INSPECTORSHIP":[{"def":"The office of an inspector.","pos":""},{"def":"The district embraced by an inspector's jurisdiction.","pos":""}],"INSPECTRESS":[{"def":"A female inspector.","pos":""}],"INSPERSE":[{"def":"To sprinkle; to scatter.","pos":""}],"INSPERSION":[{"def":"The act of sprinkling.","pos":""}],"INSPEXIMUS":[{"def":"The first word of ancient charters in England, confirming a grant made by a former king; hence, a royal grant.","pos":""}],"INSPHERE":[{"def":"To place in, or as in, an orb a sphere.","pos":""}],"INSPIRABLE":[{"def":"Capable of being inspired or drawn into the lungs; inhalable; respirable; admitting inspiration.","pos":""}],"INSPIRATION":[{"def":"A supernatural divine influence on the prophets, apostles, or sacred writers, by which they were qualified to communicate moral or religious truth with authority; a supernatural influence which qualifies men to receive and communicate divine truth; also, the truth communicated.","pos":""}],"INSPIRATIONAL":[{"def":"Pertaining to inspiration.","pos":""}],"INSPIRATIONIST":[{"def":"One who holds to inspiration.","pos":""}],"INSPIRATOR":[{"def":"A kind of injector for forcing water by steam.","pos":""}],"INSPIRATORY":[{"def":"Pertaining to, or aiding, inspiration; as, the inspiratory muscles.","pos":""}],"INSPIRE":[{"def":"To breathe into; to fill with the breath; to animate.","pos":""},{"def":"To infuse by breathing, or as if by breathing.","pos":""}],"INSPIRED":[{"def":"Breathed in; inhaled.","pos":""},{"def":"Moved or animated by, or as by, a supernatural influence; affected by divine inspiration; as, the inspired prophets; the inspired writers.","pos":""}],"INSPIRER":[{"def":"One who, or that which, inspirer.","pos":""}],"INSPIRING":[{"def":"Animating; cheering; moving; exhilarating; as, an inspiring or scene.","pos":""}],"INSPIRIT":[{"def":"To infuse new life or spirit into; to animate; to encourage; to invigorate.","pos":""}],"INSPISSATE":[{"def":"To thicken or bring to greater consistence, as fluids by evaporation.","pos":""}],"INSPISSATION":[{"def":"The act or the process of inspissating, or thickening a fluid substance, as by evaporation; also, the state of being so thickened.","pos":""}]}