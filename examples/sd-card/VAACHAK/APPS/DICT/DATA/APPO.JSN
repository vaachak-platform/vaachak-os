{"APPOGGIATURA":[{"def":"A passing tone preceding an essential tone, and borrowing the time it occupies from that; a short auxiliary or grace note one degree above or below the principal note unless it be of the same harmony; -- generally indicated by a note of smaller size, as in the illustration above.","pos":""}],"APPOINT":[{"def":"To direct, designate, or limit; to make or direct a new disposition of, by virtue of a power contained in a conveyance; -- said of an estate already conveyed.","pos":""}],"APPOINTABLE":[{"def":"Capable of being appointed or constituted.","pos":""}],"APPOINTEE":[{"def":"A person in whose favor a power of appointment is executed.","pos":""}],"APPOINTER":[{"def":"One who appoints, or executes a power of appointment.","pos":""}],"APPOINTIVE":[{"def":"Subject to appointment; as, an appointive office.","pos":""}],"APPOINTMENT":[{"def":"The exercise of the power of designating (under a \"power of appointment\") a person to enjoy an estate or other specific property; also, the instrument by which the designation is made.","pos":""}],"APPOINTOR":[{"def":"The person who selects the appointee.","pos":""}],"APPORTER":[{"def":"A bringer in; an importer.","pos":""}],"APPORTION":[{"def":"To divide and assign in just proportion; to divide and distribute proportionally; to portion out; to allot; as, to apportion undivided rights; to apportion time among various employments.","pos":""}],"APPORTIONATENESS":[{"def":"The quality of being apportioned or in proportion.","pos":""}],"APPORTIONER":[{"def":"One who apportions.","pos":""}],"APPORTIONMENT":[{"def":"The act of apportioning; a dividing into just proportions or shares; a division or shares; a division and assignment, to each proprietor, of his just portion of an undivided right or property.","pos":""}],"APPOSABLE":[{"def":"Capable of being apposed, or applied one to another, as the thumb to the fingers of the hand.","pos":""}],"APPOSE":[{"def":"To place opposite or before; to put or apply (one thing to another).","pos":""},{"def":"To place in juxtaposition or proximity.","pos":""}],"APPOSED":[{"def":"Placed in apposition; mutually fitting, as the mandibles of a bird's beak.","pos":""}],"APPOSER":[{"def":"An examiner; one whose business is to put questions.","pos":""}],"APPOSITE":[{"def":"Very applicable; well adapted; suitable or fit; relevant; pat; -- followed by to; as, this argument is very apposite to the case.","pos":""}],"APPOSITION":[{"def":"The state of two nouns or pronouns, put in the same case, without a connecting word between them; as, I admire Cicero, the orator.","pos":""}],"APPOSITIONAL":[{"def":"Pertaining to apposition; put in apposition syntactically.","pos":""}],"APPOSITIVE":[{"def":"Of or relating to apposition; in apposition.","pos":""},{"def":"A noun in apposition.","pos":""}]}