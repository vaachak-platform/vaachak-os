{"RUCERVINE":[{"def":"Of, like, or pertaining to, a deer of the genus Rucervus, which includes the swamp deer of India.","pos":""}],"RUCHE":[{"def":"A plaited, quilled, or goffered strip of lace, net, ribbon, or other material, -- used in place of collars or cuffs, and as a trimming for women's dresses and bonnets.","pos":""},{"def":"A pile of arched tiles, used to catch and retain oyster spawn.","pos":""}],"RUCHING":[{"def":"A ruche, or ruches collectively.","pos":""}],"RUCK":[{"def":"To draw into wrinkles or unsightly folds; to crease; as, to ruck up a carpet.","pos":""}],"RUCTATION":[{"def":"The act of belching wind.","pos":""}],"RUCTION":[{"def":"An uproar; a quarrel; a noisy outbreak.","pos":""}]}