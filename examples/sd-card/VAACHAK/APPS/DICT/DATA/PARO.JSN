{"PAROCCIPITAL":[{"def":"Situated near or beside the occipital condyle or the occipital bone; paramastoid; -- applied especially to a process of the skull in some animals.","pos":""}],"PAROCHIAL":[{"def":"Of or pertaining to a parish; restricted to a parish; as, parochial duties.","pos":""}],"PAROCHIALISM":[{"def":"The quality or state of being parochial in form or nature; a system of management peculiar to parishes.","pos":""}],"PAROCHIALITY":[{"def":"The state of being parochial.","pos":""}],"PAROCHIALIZE":[{"def":"To render parochial; to form into parishes.","pos":""}],"PAROCHIALLY":[{"def":"In a parochial manner; by the parish, or by parishes.","pos":""}],"PAROCHIAN":[{"def":"Having the character of parody.","pos":""}],"PARODIST":[{"def":"One who writes a parody; one who parodies.","pos":""}],"PARODY":[{"def":"A writing in which the language or sentiment of an author is mimicked; especially, a kind of literary pleasantry, in which what is written on one subject is altered, and applied to another by way of burlesque; travesty.","pos":""},{"def":"A popular maxim, adage, or proverb.","pos":""}],"PAROL":[{"def":"Oral declaration; word of mouth; also, a writing not under seal.","pos":""}],"PAROLE":[{"def":"A watchword given only to officers of guards; -- distinguished from countersign, which is given to all guards.","pos":""},{"def":"Oral declaration.","pos":""}],"PAROMOLOGY":[{"def":"A concession to an adversary in order to strengthen one's own argument.","pos":""}],"PARONOMASIA":[{"def":"A play upon words; a figure by which the same word is used in different senses, or words similar in sound are set in opposition to each other, so as to give antithetical force to the sentence; punning.","pos":""},{"def":"Of or pertaining to paronomasia; consisting in a play upon words.","pos":""}],"PARONYCHIA":[{"def":"A whitlow, or felon.","pos":""}],"PARONYM":[{"def":"A paronymous word.","pos":""}],"PARONYMOUS":[{"def":"Having the same derivation; allied radically; conjugate; -- said of certain words, as man, mankind, manhood, etc.","pos":""},{"def":"Having a similar sound, but different orthography and different meaning; -- said of certain words, as al and awl; hair and hare, etc.","pos":""}],"PARONYMY":[{"def":"The quality of being paronymous; also, the use of paronymous words.","pos":""},{"def":"A small mass of tubules near the ovary in some animals, and corresponding with the parepididymis of the male.","pos":""}],"PAROQUET":[{"def":"Same as Parrakeet.","pos":""}],"PARORCHIS":[{"def":"The part of the epididymis; or the corresponding part of the excretory duct of the testicle, which is derived from the Wolffian body.","pos":""}],"PAROSTEAL":[{"def":"Of or pertaining to parostosis; as, parosteal ossification.","pos":""}],"PAROSTOSIS":[{"def":"Ossification which takes place in purely fibrous tracts; the formation of bone outside of the periosteum.","pos":""}],"PAROSTOTIC":[{"def":"Pertaining to parostosis.","pos":""}],"PAROTIC":[{"def":"On the side of the auditory capsule; near the external ear.","pos":""}],"PAROTID":[{"def":"The parotid gland.","pos":""}],"PAROTITIS":[{"def":"Inflammation of the parotid glands.","pos":""}],"PAROTOID":[{"def":"Resembling the parotid gland; -- applied especially to cutaneous glandular elevations above the ear in many toads and frogs.","pos":""},{"def":"A parotoid gland.","pos":""}],"PAROVARIUM":[{"def":"A group of tubules, a remnant of the Wolffian body, often found near the ovary or oviduct; the epoöphoron.","pos":""}],"PAROXYSM":[{"def":"The fit, attack, or exacerbation, of a disease that occurs at intervals, or has decided remissions or intermissions.","pos":""}],"PAROXYSMAL":[{"def":"Of the nature of a paroxysm; characterized or accompanied by paroxysms; as, a paroxysmal pain; paroxysmal temper.","pos":""}],"PAROXYTONE":[{"def":"A word having an acute accent on the penultimate syllable.","pos":""}]}