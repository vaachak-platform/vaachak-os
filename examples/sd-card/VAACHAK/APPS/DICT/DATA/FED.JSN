{"FEDERAL":[{"def":"Pertaining to a league or treaty; derived from an agreement or covenant between parties, especially between nations; constituted by a compact between parties, usually governments or their representatives.","pos":""},{"def":"Specifically: (a) Composed of states or districts which retain only a subordinate and limited sovereignty, as the Union of the United States, or the Sonderbund of Switzerland.","pos":""}],"FEDERALISM":[{"def":"the principles of Federalists or of federal union.","pos":""}],"FEDERALIST":[{"def":"An advocate of confederation; specifically (Amer.","pos":""}],"FEDERALIZE":[{"def":"To unite in compact, as different States; to confederate for political purposes; to unite by or under the Federal Constitution.","pos":""}],"FEDERARY":[{"def":"A partner; a confederate; an accomplice.","pos":""}],"FEDERATE":[{"def":"United by compact, as sovereignties, states, or nations; joined in confederacy; leagued; confederate; as, federate nations.","pos":""}],"FEDERATION":[{"def":"The act of uniting in a league; confederation.","pos":""},{"def":"A league; a confederacy; a federal or confederated government.","pos":""}],"FEDERATIVE":[{"def":"Uniting in a league; forming a confederacy; federal.","pos":""}],"FEDITY":[{"def":"Turpitude; vileness.","pos":""}]}