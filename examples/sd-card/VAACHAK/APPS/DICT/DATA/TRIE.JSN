{"TRIED":[{"def":"Proved; tested; faithful; trustworthy; as, a tried friend.","pos":""}],"TRIENNIAL":[{"def":"Continuing three years; as, triennial parliaments; a triennial reign.","pos":""},{"def":"Happening, coming about, or appearing once in every three years; as, triennial elections; a triennial catalogue; a triennial visitation.","pos":""}],"TRIENNIALLY":[{"def":"Once in three years.","pos":""}],"TRIENS":[{"def":"A Roman copper coin, equal to one third of the as.","pos":""}],"TRIER":[{"def":"A person appointed according to law to try challenges of jurors; a trior.","pos":""}],"TRIERARCHY":[{"def":"The office duty of a trierarch.","pos":""}],"TRIETERICAL":[{"def":"Kept or occurring once in three years; triennial.","pos":""}],"TRIETERICS":[{"def":"Festival games celebrated once in three years.","pos":""}],"TRIETHYLAMINE":[{"def":"A tertiary amine analogous to trimethylamine.","pos":""}]}