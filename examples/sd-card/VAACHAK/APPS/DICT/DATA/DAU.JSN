{"DAUB":[{"def":"To smear with soft, adhesive matter, as pitch, slime, mud, etc.","pos":""},{"def":"To paint in a coarse or unskillful manner.","pos":""}],"DAUBER":[{"def":"A pad or ball of rags, covered over with canvas, for inking plates; a dabber.","pos":""},{"def":"The mud wasp; the mud dauber.","pos":""}],"DAUBING":[{"def":"The act of one who daubs; that which is daubed.","pos":""},{"def":"A rough coat of mortar put upon a wall to give it the appearance of stone; rough-cast.","pos":""}],"DAUBREELITE":[{"def":"A sulphide of chromium observed in some meteoric irons.","pos":""}],"DAUBY":[{"def":"Smeary; viscous; glutinous; adhesive.","pos":""}],"DAUGHTER":[{"def":"The female offspring of the human species; a female child of any age; -- applied also to the lower animals.","pos":""},{"def":"A female descendant; a woman.","pos":""}],"DAUGHTER-IN-LAW":[{"def":"The wife of one's son.","pos":""}],"DAUGHTERLINESS":[{"def":"The state of a daughter, or the conduct becoming a daughter.","pos":""}],"DAUGHTERLY":[{"def":"Becoming a daughter; filial.","pos":""}],"DAUN":[{"def":"A variant of Dan, a title of honor.","pos":""}],"DAUNT":[{"def":"To overcome; to conquer.","pos":""},{"def":"To repress or subdue the courage of; to check by fear of danger; to cow; to intimidate; to dishearten.","pos":""}],"DAUNTLESS":[{"def":"Incapable of being daunted; undaunted; bold; fearless; intrepid.","pos":""}],"DAUPHIN":[{"def":"The title of the eldest son of the king of France, and heir to the crown.","pos":""},{"def":"The title of the wife of the dauphin.","pos":""}],"DAUW":[{"def":"The striped quagga, or Burchell's zebra, of South Africa (Asinus Burchellii); -- called also peechi, or peetsi.","pos":""}]}