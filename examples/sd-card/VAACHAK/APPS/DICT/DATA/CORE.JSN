{"CORE":[{"def":"A body of individuals; an assemblage.","pos":""}],"CORE LOSS":[{"def":"Energy wasted by hysteresis or eddy currents in the core of an armature, transformer, etc.","pos":""}],"COREOPSIS":[{"def":"A genus of herbaceous composite plants, having the achenes two- horned and remotely resembling some insect; tickseed.","pos":""}],"COREPLASTY":[{"def":"A plastic operation on the pupil, as for forming an artificial pupil.","pos":""}],"CORER":[{"def":"That which cores; an instrument for coring fruit; as, an apple corer.","pos":""}]}