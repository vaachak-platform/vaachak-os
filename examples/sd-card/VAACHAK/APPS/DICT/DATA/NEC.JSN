{"NECESSARIAN":[{"def":"An advocate of the doctrine of philosophical necessity; a nacessitarian.","pos":""}],"NECESSARIANISM":[{"def":"The doctrine of philosophical necessity; necessitarianism.","pos":""}],"NECESSARILY":[{"def":"In a necessary manner; by necessity; unavoidably; indispensably.","pos":""}],"NECESSARINESS":[{"def":"The quality of being necessary.","pos":""}],"NECESSARY":[{"def":"Such as must be; impossible to be otherwise; not to be avoided; inevitable.","pos":""},{"def":"Impossible to be otherwise, or to be dispensed with, without preventing the attainment of a desired result; indispensable; requiste; essential.","pos":""}],"NECESSITARIAN":[{"def":"Of or pertaining to the doctrine of philosophical necessity in regard to the origin and existence of things, especially as applied to the actings or choices of the will; -- opposed to libertarian.","pos":""}],"NECESSITARIANISM":[{"def":"The doctrine of philosophical necessity; the doctrine that results follow by invariable sequence from causes, and esp.","pos":""}],"NECESSITATE":[{"def":"To make necessary or indispensable; to render unaviolable.","pos":""},{"def":"To reduce to the necessity of; to force; to compel.","pos":""}],"NECESSITATTION":[{"def":"The act of making necessary, or the state of being made necessary; compulsion.","pos":""}],"NECESSITIED":[{"def":"In a state of want; necessitous.","pos":""}],"NECESSITOUS":[{"def":"Very needy or indigent; pressed with poverty.","pos":""},{"def":"Narrow; destitute; pinching; pinched; as, necessitous circumstances.","pos":""}],"NECESSITUDE":[{"def":"Necessitousness; want.","pos":""},{"def":"Necessary connection or relation.","pos":""}],"NECESSITY":[{"def":"The negation of freedom in voluntary action; the subjection of all phenomena, whether material or spiritual, to inevitable causation; necessitarianism.","pos":""}],"NECK":[{"def":"A reduction in size near the end of an object, formed by a groove around it; as, a neck forming the journal of a shaft.","pos":""},{"def":"the point where the base of the stem of a plant arises from the root.","pos":""}],"NECKBAND":[{"def":"A band which goes around the neck; often, the part at the top of a garment.","pos":""}],"NECKCLOTH":[{"def":"A piece of any fabric worn around the neck.","pos":""}],"NECKED":[{"def":"Cracked; -- said of a treenail.","pos":""}],"NECKERCHIEF":[{"def":"A kerchief for the neck; -- called also neck handkerchief.","pos":""}],"NECKING":[{"def":"Same as Neckmold.","pos":""}],"NECKLACE":[{"def":"A rope or chain fitted around the masthead to hold hanging blocks for jibs and stays.","pos":""}],"NECKLACED":[{"def":"Wearing a necklace; marked as with a necklace.","pos":""}],"NECKLET":[{"def":"A small convex molding surrounding a column at the jinction of the shaft and capital.","pos":""}],"NECKPLATE":[{"def":"See Gorget, 1 and 2.","pos":""}],"NECKTIE":[{"def":"A scarf, band, or kerchief of silk, etc.","pos":""}],"NECKWEAR":[{"def":"A collective term for cravats, collars, etc.","pos":""}],"NECROBIOSIS":[{"def":"The death of a part by molecular disintegration and without loss of continuity, as in the processes of degeneration and atrophy.","pos":""}],"NECROBIOTIC":[{"def":"Of or pertaining to necrobiosis; as, a necrobiotic metamorphosis.","pos":""}],"NECROLATRY":[{"def":"The worship of the dead; manes worship.","pos":""}],"NECROLITE":[{"def":"Same as Necronite.","pos":""},{"def":"Of or pertaining to necrology; of the nature of necrology; relating to, or giving, an account of the dead, or of deaths.","pos":""}],"NECROLOGIST":[{"def":"One who gives an account of deaths.","pos":""}],"NECROLOGY":[{"def":"An account of deaths, or of the dead; a register of deaths; a collection of obituary notices.","pos":""}],"NECROMANCER":[{"def":"One who practices necromancy; a sorcerer; a wizard.","pos":""}],"NECROMANCY":[{"def":"The art of revealing future events by means of a pretended communication with the dead; the black art; hence, magic in general; conjuration; enchantment.","pos":""}],"NECROMANTIC":[{"def":"Of or pertaining to necromancy; performed by necromancy.","pos":""}],"NECRONITE":[{"def":"Fetid feldspar, a mineral which, when struck, exhales a fetid odor.","pos":""}],"NECROPHAGAN":[{"def":"Any species of a tribe (Necrophaga) of beetles which, in the larval state, feed on carrion; a burying beetle.","pos":""}],"NECROPHAGOUS":[{"def":"Of or pertaining to the Necrophaga; eating carrion.","pos":""}],"NECROPHOBIA":[{"def":"An exaggerated fear of death or horror of dead bodies.","pos":""}],"NECROPHORE":[{"def":"Any one of numerous species of beetles of the genus Necrophorus and allied genera; -- called also burying beetle, carrion beetle, sexton beetle.","pos":""}],"NECROPOLIS":[{"def":"A city of the dead; a name given by the ancients to their cemeteries, and sometimes applied to modern burial places; a graveyard.","pos":""}],"NECROPSY":[{"def":"A post-mortem examination or inspection; an autopsy.","pos":""},{"def":"Or or relating to post-mortem examinations.","pos":""}],"NECROSE":[{"def":"To affect with necrosis; to unergo necrosis.","pos":""}],"NECROSED":[{"def":"Affected by necrosis; dead; as, a necrosed bone.","pos":""}],"NECROSIS":[{"def":"Mortification or gangrene of bone, or the death of a bone or portion of a bone in mass, as opposed to its death by molecular disintegration.","pos":""},{"def":"A disease of trees, in which the branches gradually dry up from the bark to the center.","pos":""}],"NECROTIC":[{"def":"Affected with necrosis; as, necrotic tissue; characterized by, or producing, necrosis; as, a necrotic process.","pos":""}],"NECROTOMY":[{"def":"The dissection of dead bodies; also, excision of necrosed bone.","pos":""}],"NECTAR":[{"def":"The drink of the gods (as ambrosia was their food); hence, any delicious or inspiring beverage.","pos":""},{"def":"A sweetish secretion of blossoms from which bees make honey.","pos":""}],"NECTAREAL":[{"def":"Of or pertaining to a nectary.","pos":""}],"NECTAREAN":[{"def":"Resembling nectar; very sweet and pleasant.","pos":""}],"NECTARED":[{"def":"Imbued with nectar; mingled with nectar; abounding with nectar.","pos":""}],"NECTAREOUS":[{"def":"Of, pertaining to, containing, or resembling nectar; delicious; nectarean.","pos":""}],"NECTARIAL":[{"def":"Of or pertaining to the nectary of a plant.","pos":""}],"NECTARIED":[{"def":"Having a nectary.","pos":""}],"NECTARIFEROUS":[{"def":"Secreting nectar; -- said of blossoms or their parts.","pos":""}],"NECTARINE":[{"def":"A smooth-skinned variety of peach.","pos":""}],"NECTARIZE":[{"def":"To mingle or infuse with nectar; to sweeten.","pos":""}],"NECTARY":[{"def":"That part of a blossom which secretes nectar, usually the base of the corolla or petals; also, the spur of such flowers as the larkspur and columbine, whether nectariferous or not.","pos":""}],"NECTOCALYX":[{"def":"The cavity of a nectocalyx.","pos":""}],"NECTOSTEM":[{"def":"That portion of the axis which bears the nectocalyces in the Siphonophora.","pos":""}]}