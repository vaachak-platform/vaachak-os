{"GAFF":[{"def":"The spar upon which the upper edge of a fore-and-aft sail is extended.","pos":""}],"GAFF-TOPSAIL":[{"def":"A small triangular sail having its foot extended upon the gaff and its luff upon the topmast.","pos":""}],"GAFFER":[{"def":"An old fellow; an aged rustic.","pos":""},{"def":"A foreman or overseer of a gang of laborers.","pos":""}],"GAFFLE":[{"def":"An artificial spur or gaff for gamecocks.","pos":""},{"def":"A lever to bend crossbows.","pos":""}]}