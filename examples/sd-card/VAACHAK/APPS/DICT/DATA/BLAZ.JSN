{"BLAZE":[{"def":"A white spot on the forehead of a horse.","pos":""}],"BLAZER":[{"def":"One who spreads reports or blazes matters abroad.","pos":""}],"BLAZING":[{"def":"Burning with a blaze; as, a blazing fire; blazing torches.","pos":""}],"BLAZON":[{"def":"An heraldic shield; a coat of arms, or a bearing on a coat of arms; armorial bearings.","pos":""}],"BLAZONER":[{"def":"One who gives publicity, proclaims, or blazons; esp.","pos":""}],"BLAZONMENT":[{"def":"The act or blazoning; blazoning; emblazonment.","pos":""}],"BLAZONRY":[{"def":"Same as Blazon, 3.","pos":""},{"def":"A coat of arms; an armorial bearing or bearings.","pos":""}]}