{"OVERLABOR":[{"def":"To cause to labor excessively; to overwork.","pos":""},{"def":"To labor upon excessively; to refine unduly.","pos":""}],"OVERLADE":[{"def":"To load with too great a cargo; to overburden; to overload.","pos":""}],"OVERLAND":[{"def":"Being, or accomplished, over the land, instead of by sea; as, an overland journey.","pos":""}],"OVERLANDER":[{"def":"One who travels over lands or countries; one who travels overland.","pos":""}],"OVERLANGUAGED":[{"def":"Employing too many words; diffuse.","pos":""}],"OVERLAP":[{"def":"To lap over; to lap.","pos":""}],"OVERLARGE":[{"def":"Too large; too great.","pos":""}],"OVERLARGENESS":[{"def":"Excess of size or bulk.","pos":""}],"OVERLASH":[{"def":"To drive on rashly; to go to excess; hence, to exaggerate; to boast.","pos":""}],"OVERLASHING":[{"def":"Excess; exaggeration.","pos":""}],"OVERLATE":[{"def":"Too late; exceedingly late.","pos":""}],"OVERLAVE":[{"def":"To lave or bathe over.","pos":""}],"OVERLAVISH":[{"def":"Lavish to excess.","pos":""}],"OVERLAY":[{"def":"To put an overlay on.","pos":""}],"OVERLAYER":[{"def":"One who overlays; that with which anything is overlaid.","pos":""}],"OVERLAYING":[{"def":"A superficial covering; a coating.","pos":""}],"OVERLEAD":[{"def":"To domineer over; to affront; to treat with indignity.","pos":""}],"OVERLEAP":[{"def":"To leap over or across; hence, to omit; to ignore.","pos":""}],"OVERLEAVEN":[{"def":"To leaven too much; hence, to change excessively; to spoil.","pos":""}],"OVERLIBERALLY":[{"def":"In an overliberal manner.","pos":""}],"OVERLIE":[{"def":"To lie over or upon; specifically, to suffocate by lying upon; as, to overlie an infant.","pos":""}],"OVERLIGHT":[{"def":"Too strong a light.","pos":""}],"OVERLINESS":[{"def":"The quality or state of being overly; carelessness.","pos":""}],"OVERLINGER":[{"def":"To cause to linger; to detain too long.","pos":""}],"OVERLIVE":[{"def":"The culture of Northumbria overlived the term of its political supermacy.","pos":""}],"OVERLOAD":[{"def":"To load or fill to excess; to load too heavily.","pos":""}],"OVERLOGICAL":[{"def":"Excessively logical; adhering too closely to the forms or rules of logic.","pos":""}],"OVERLOOK":[{"def":"To look down upon from a place that is over or above; to look over or view from a higher position; to rise above, so as to command a view of; as, to overlook a valley from a hill.","pos":""},{"def":"Hence: To supervise; to watch over; sometimes, to observe secretly; as, to overlook a gang of laborers; to overlook one who is writing a letter.","pos":""}],"OVERLOOKER":[{"def":"One who overlooks.","pos":""}],"OVERLORD":[{"def":"One who is lord over another or others; a superior lord; a master.","pos":""}],"OVERLORDSHIP":[{"def":"Lordship or supremacy of a person or a people over others.","pos":""}],"OVERLOUD":[{"def":"Too loud; noisy.","pos":""}],"OVERLOVE":[{"def":"To love to excess.","pos":""}],"OVERLUSCIOUS":[{"def":"Excessively luscious.","pos":""}],"OVERLUSTY":[{"def":"Too lusty, or lively.","pos":""}],"OVERLY":[{"def":"Careless; negligent; inattentive; superfical; not thorough.","pos":""},{"def":"Excessive; too much.","pos":""}],"OVERLYING":[{"def":"Lying over or upon something; as, overlying rocks.","pos":""}]}