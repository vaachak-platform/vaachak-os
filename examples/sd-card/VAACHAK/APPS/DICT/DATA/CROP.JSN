{"CROP":[{"def":"A projecting ornament in carved stone.","pos":""}],"CROP-EAR":[{"def":"A person or animal whose ears are cropped.","pos":""}],"CROP-EARED":[{"def":"Having the ears cropped.","pos":""}],"CROP-TAILED":[{"def":"Having the tail cropped.","pos":""}],"CROPFUL":[{"def":"Having a full crop or belly; satiated.","pos":""}],"CROPPER":[{"def":"A machine for cropping, as for shearing off bolts or rod iron, or for facing cloth.","pos":""}],"CROPSICK":[{"def":"Sick from excess in eating or drinking.","pos":""}]}