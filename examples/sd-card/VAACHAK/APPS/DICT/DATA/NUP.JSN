{"NUPHAR":[{"def":"A genus of plants found in the fresh-water ponds or lakes of Europe, Asia, and North America; the yellow water lily.","pos":""}],"NUPSON":[{"def":"A simpleton; a fool.","pos":""}],"NUPTIAL":[{"def":"Of or pertaining to marriage; done or used at a wedding; as, nuptial rites and ceremonies.","pos":""}]}