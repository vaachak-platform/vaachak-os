{"INFLAME":[{"def":"To put in a state of inflammation; to produce morbid heat, congestion, or swelling, of; as, to inflame the eyes by overwork.","pos":""}],"INFLAMED":[{"def":"Represented as burning, or as adorned with tongues of flame.","pos":""}],"INFLAMER":[{"def":"The person or thing that inflames.","pos":""}],"INFLAMMABILLTY":[{"def":"Susceptibility of taking fire readily; the state or quality of being inflammable.","pos":""}],"INFLAMMABLE":[{"def":"Capable of being easily set fire; easily enkindled; combustible; as, inflammable oils or spirits.","pos":""},{"def":"Excitable; irritable; irascible; easily provoked; as, an inflammable temper.","pos":""}],"INFLAMMABLENESS":[{"def":"The quality or state of being inflammable; inflammability.","pos":""}],"INFLAMMABLY":[{"def":"In an inflammable manner.","pos":""}],"INFLAMMATION":[{"def":"A morbid condition of any part of the body, consisting in congestion of the blood vessels, with obstruction of the blood current, and growth of morbid tissue.","pos":""}],"INFLAMMATORY":[{"def":"Accompanied with, or tending to cause, preternatural heat and excitement of arterial action; as, an inflammatory disease.","pos":""}],"INFLATABLE":[{"def":"That may be inflated.","pos":""}],"INFLATE":[{"def":"Blown in; inflated.","pos":""}],"INFLATED":[{"def":"Hollow and distended, as a perianth, corolla, nectary, or pericarp.","pos":""}],"INFLATER":[{"def":"One who, or that which, inflates; as, the inflaters of the stock exchange.","pos":""}],"INFLATINGLY":[{"def":"In a manner tending to inflate.","pos":""}],"INFLATION":[{"def":"The act or process of inflating, or the state of being inflated, as with air or gas; distention; expansion; enlargement.","pos":""},{"def":"The state of being puffed up, as with pride; conceit; vanity.","pos":""}],"INFLATIONIST":[{"def":"One who favors an increased or very large issue of paper money.","pos":""}],"INFLATUS":[{"def":"A blowing or breathing into; inflation; inspiration.","pos":""}],"INFLECT":[{"def":"To vary, as a noun or a verb in its terminations; to decline, as a noun or adjective, or to conjugate, as a verb.","pos":""}],"INFLECTED":[{"def":"Having inflections; capable of, or subject to, inflection; inflective.","pos":""}],"INFLECTION":[{"def":"The variation or change which words undergo to mark case, gender, number, comparison, tense, person, mood, voice, etc.","pos":""},{"def":"Same as Diffraction.","pos":""}],"INFLECTIONAL":[{"def":"Of or pertaining to inflection; having, or characterized by, inflection.","pos":""}],"INFLECTIVE":[{"def":"Inflectional; characterized by variation, or change in form, to mark case, tense, etc.","pos":""}],"INFLEX":[{"def":"To bend; to cause to become curved; to make crooked; to deflect.","pos":""}],"INFLEXED":[{"def":"Bent or turned abruptly inwards, or toward the axis, as the petals of a flower.","pos":""}],"INFLEXIBILITY":[{"def":"The quality or state of being inflexible, or not capable of being bent or changed; unyielding stiffness; inflexibleness; rigidity; firmness of will or purpose; unbending pertinacity; steadfastness; resoluteness; unchangeableness; obstinacy.","pos":""}],"INFLEXIBLE":[{"def":"Not capable of being bent; stiff; rigid; firm; unyielding.","pos":""},{"def":"Firm in will or purpose; not to be turned, changed, or altered; resolute; determined; unyieding; inexorable; stubborn.","pos":""}],"INFLEXIBLENESS":[{"def":"The quality or state of being inflexible; inflexibility; rigidity; firmness.","pos":""}],"INFLEXIBLY":[{"def":"In an inflexible manner.","pos":""}],"INFLEXURE":[{"def":"An inflection; a bend or fold.","pos":""}],"INFLICT":[{"def":"What heart could wish, what hand inflict, this dire disgrace Drygen.","pos":""}],"INFLICTER":[{"def":"One who inflicts.","pos":""}],"INFLICTION":[{"def":"The act of inflicting or imposing; as, the infliction of torment, or of punishment.","pos":""},{"def":"That which is inflicted or imposed, as punishment, disgrace, calamity, etc.","pos":""}],"INFLICTIVE":[{"def":"Causing infliction; acting as an infliction.","pos":""}],"INFLORESCENCE":[{"def":"A flowering; the putting forth and unfolding of blossoms.","pos":""}],"INFLUENCE":[{"def":"A flowing in or upon; influx.","pos":""}],"INFLUENCER":[{"def":"One who, or that which, influences.","pos":""}],"INFLUENCIVE":[{"def":"Tending toinfluence; influential.","pos":""}],"INFLUENT":[{"def":"Exerting influence; influential.","pos":""}],"INFLUENTIAL":[{"def":"Exerting or possessing influence or power; potent; efficacious; effective; strong; having authority or ascendency; as, an influential man, station, argument, etc.","pos":""}],"INFLUENTIALLY":[{"def":"In an influential manner.","pos":""}],"INFLUENZA":[{"def":"An epidemic affection characterized by acute nasal catarrh, or by inflammation of the throat or the bronchi, and usually accompanied by fever.","pos":""}],"INFLUX":[{"def":"The act of flowing in; as, an influx of light.","pos":""},{"def":"A coming in; infusion; intromission; introduction; importation in abundance; also, that which flows or comes in; as, a great influx of goods into a country, or an influx of gold and silver.","pos":""}],"INFLUXION":[{"def":"A flowing in; infusion.","pos":""}],"INFLUXIVE":[{"def":"Having a tendency to flow in; having influence; influential.","pos":""}]}