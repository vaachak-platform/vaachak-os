{"JASEY":[{"def":"A wig; -- so called, perhaps, from being made of, or resembling, Jersey yarn.","pos":""}],"JASMINE":[{"def":"A shrubby plant of the genus Jasminum, bearing flowers of a peculiarly fragrant odor.","pos":""}],"JASPE":[{"def":"Having the surface decorated with cloudings and streaks, somewhat as if imitating jasper.","pos":""}],"JASPER":[{"def":"An opaque, impure variety of quartz, of red, yellow, and other dull colors, breaking with a smooth surface.","pos":""}],"JASPERATED":[{"def":"mixed with jasper; containing particles of jasper; as, jasperated agate.","pos":""}],"JASPERIZE":[{"def":"To convert into, or make to resemble, jasper.","pos":""}],"JASPERY":[{"def":"Of the nature of jasper; mixed with jasper.","pos":""},{"def":"Consisting of jasper, or containing jasper; jaspery; jasperlike.","pos":""}],"JASPILITE":[{"def":"A compact siliceous rock resembling jasper.","pos":""}],"JASPOID":[{"def":"Resembling jasper.","pos":""}],"JASPONYX":[{"def":"An onyx, part or all of whose layers consist of jasper.","pos":""}]}