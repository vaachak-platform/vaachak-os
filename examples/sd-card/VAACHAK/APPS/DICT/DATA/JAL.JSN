{"JALAP":[{"def":"The tubers of the Mexican plant Ipomoea purga (or Exogonium purga), a climber much like the morning-glory.","pos":""}],"JALAPIC":[{"def":"Of or pertaining to jalap.","pos":""}],"JALAPIN":[{"def":"A glucoside found in the stems of the jalap plant and scammony.","pos":""}],"JALONS":[{"def":"Long poles, topped with wisps of straw, used as landmarks and signals.","pos":""}],"JALOUSIE":[{"def":"A Venetian or slatted inside window blind.","pos":""}],"JALOUSIED":[{"def":"Furnished with jalousies; as, jalousied porches.","pos":""}]}