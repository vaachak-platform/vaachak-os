{"MANE":[{"def":"The long and heavy hair growing on the upper side of, or about, the neck of some quadrupedal animals, as the horse, the lion, etc.","pos":""}],"MANEGE":[{"def":"Art of horsemanship, or of training horses 2.","pos":""}],"MANEH":[{"def":"A Hebrew weight for gold or silver, being one hundred shekels of gold and sixty shekels of silver.","pos":""}],"MANEQUIN":[{"def":"An artist's model of wood or other material.","pos":""}],"MANES":[{"def":"The benevolent spirits of the dead, especially of dead ancestors, regarded as family deities and protectors.","pos":""}],"MANESHEET":[{"def":"A covering placed over the upper part of a horse's head.","pos":""},{"def":"To change the positions of, as of troops of ships.","pos":""}]}