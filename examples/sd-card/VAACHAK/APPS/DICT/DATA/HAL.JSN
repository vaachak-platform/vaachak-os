{"HALACHA":[{"def":"The general term for the Hebrew oral or traditional law; one of two branches of exposition in the Midrash.","pos":""}],"HALBERD":[{"def":"An ancient long-handled weapon, of which the head had a point and several long, sharp edges, curved or straight, and sometimes additional points.","pos":""}],"HALBERDIER":[{"def":"One who is armed with a halberd.","pos":""}],"HALCYON":[{"def":"Amidst our arms as quiet you shall be As halcyons brooding on a winter sea.","pos":""}],"HALE":[{"def":"Sound; entire; healthy; robust; not impaired; as, a hale body.","pos":""}],"HALESIA":[{"def":"A genus of American shrubs containing several species, called snowdrop trees, or silver-bell trees.","pos":""}],"HALF":[{"def":"Consisting of a moiety, or half; as, a half bushel; a half hour; a half dollar; a half view.","pos":""},{"def":"Consisting of some indefinite portion resembling a half; approximately a half, whether more or less; partial; imperfect; as, a half dream; half knowledge.","pos":""}],"HALF BLOOD":[{"def":"The relation between persons born of the same father or of the same mother, but not of both; as, a brother or sister of the half blood.","pos":""},{"def":"A person so related to another.","pos":""}],"HALF NELSON":[{"def":"A hold in which one arm is thrust under the corresponding arm of the opponent, generally behind, and the hand placed upon the back of his neck.","pos":""}],"HALF-AND-HALF":[{"def":"A mixture of two malt liquors, esp.","pos":""}],"HALF-BLOODED":[{"def":"Proceeding from a male and female of different breeds or races; having only one parent of good stock; as, a half-blooded sheep.","pos":""},{"def":"Degenerate; mean.","pos":""}],"HALF-BOOT":[{"def":"A boot with a short top covering only the ankle.","pos":""}],"HALF-BOUND":[{"def":"Having only the back and corners in leather, as a book.","pos":""}],"HALF-BRED":[{"def":"Imperfectly acquainted with the rules of good-breeding; not well trained.","pos":""}],"HALF-BREED":[{"def":"A person who is blooded; the offspring of parents of different races, especially of the American Indian and the white race.","pos":""}],"HALF-BROTHER":[{"def":"A brother by one parent, but not by both.","pos":""}],"HALF-CASTE":[{"def":"One born of a European parent on the one side, and of a Hindoo or Mohammedan on the other.","pos":""}],"HALF-CLAMMED":[{"def":"Lions' half-clammed entrails roar food.","pos":""}],"HALF-CRACKED":[{"def":"Half-demented; half-witted.","pos":""}],"HALF-DECK":[{"def":"A shell of the genus Crepidula; a boat shell.","pos":""}],"HALF-DECKED":[{"def":"Partially decked.","pos":""}],"HALF-FACED":[{"def":"Showing only part of the face; wretched looking; meager.","pos":""}],"HALF-FISH":[{"def":"A salmon in its fifth year of growth.","pos":""}],"HALF-HATCHED":[{"def":"Imperfectly hatched; as, half-hatched eggs.","pos":""}],"HALF-HEARD":[{"def":"Imperfectly or partly heard to the end.","pos":""}],"HALF-HEARTED":[{"def":"Wanting in heart or spirit; ungenerous; unkind.","pos":""},{"def":"Lacking zeal or courage; lukewarm.","pos":""}],"HALF-HOURLY":[{"def":"Done or happening at intervals of half an hour.","pos":""}],"HALF-LEARNED":[{"def":"Imperfectly learned.","pos":""}],"HALF-LENGTH":[{"def":"Of half the whole or ordinary length, as a picture.","pos":""}],"HALF-MAST":[{"def":"A point some distance below the top of a mast or staff; as, a flag a half-mast (a token of mourning, etc.","pos":""}],"HALF-MOON":[{"def":"An outwork composed of two faces, forming a salient angle whose gorge resembles a half-moon; -- now called a ravelin.","pos":""},{"def":"A marine, sparoid, food fish of California (Cæsiosoma Californiense).","pos":""}],"HALF-PENNY":[{"def":"An English coin of the value of half a penny; also, the value of half a penny.","pos":""}],"HALF-PIKE":[{"def":"A short pike, sometimes carried by officers of infantry, sometimes used in boarding ships; a spontoon.","pos":""}],"HALF-PORT":[{"def":"One half of a shutter made in two parts for closing a porthole.","pos":""}],"HALF-RAY":[{"def":"A straight line considered as drawn from a center to an indefinite distance in one direction, the complete ray being the whole line drawn to an indefinite distance in both directions.","pos":""}],"HALF-READ":[{"def":"Informed by insufficient reading; superficial; shallow.","pos":""}],"HALF-SIGHTED":[{"def":"Seeing imperfectly; having weak discernment.","pos":""}],"HALF-SISTER":[{"def":"A sister by one parent only.","pos":""}],"HALF-STRAINED":[{"def":"Half-bred; imperfect.","pos":""}],"HALF-SWORD":[{"def":"Half the length of a sword; close fight.","pos":""}],"HALF-TIMBERED":[{"def":"Constructed of a timber frame, having the spaces filled in with masonry; -- said of buildings.","pos":""}],"HALF-TONE":[{"def":"Having, consisting of, or pertaining to, half tones; specif.","pos":""}],"HALF-TONGUE":[{"def":"A jury, for the trial of a fore foreigner, composed equally of citizens and aliens.","pos":""}],"HALF-WIT":[{"def":"A foolish; a dolt; a blockhead; a dunce.","pos":""}],"HALF-WITTED":[{"def":"Weak in intellect; silly.","pos":""}],"HALF-YEARLY":[{"def":"Two in a year; semiannual.","pos":""}],"HALFBEAK":[{"def":"Any slender, marine fish of the genus Hemirhamphus, having the upper jaw much shorter than the lower; -- called also balahoo.","pos":""}],"HALFCOCK":[{"def":"To set the cock of (a firearm) at the first notch.","pos":""}],"HALFEN":[{"def":"Wanting half its due qualities.","pos":""}],"HALFENDEAL":[{"def":"Half; by the part.","pos":""}],"HALFER":[{"def":"One who possesses or gives half only; one who shares.","pos":""},{"def":"A male fallow deer gelded.","pos":""}],"HALFNESS":[{"def":"The quality of being half; incompleteness.","pos":""}],"HALFPACE":[{"def":"A platform of a staircase where the stair turns back in exactly the reverse direction of the lower flight.","pos":""}],"HALFWAY":[{"def":"In the middle; at half the distance; imperfectly; partially; as, he halfway yielded.","pos":""}],"HALIBUT":[{"def":"A large, northern, marine flatfish (Hippoglossus vulgaris), of the family Pleuronectidæ.","pos":""}],"HALICHONDRIAE":[{"def":"An order of sponges, having simple siliceous spicules and keratose fibers; -- called also Keratosilicoidea.","pos":""}],"HALIDOM":[{"def":"Holiness; sanctity; sacred oath; sacred things; sanctuary; -- used chiefly in oaths.","pos":""},{"def":"Holy doom; the Last Day.","pos":""}],"HALIEUTICS":[{"def":"A treatise upon fish or the art of fishing; ichthyology.","pos":""},{"def":"The feast of All Saints; Hallowmas.","pos":""}],"HALIOGRAPHER":[{"def":"One who writes about or describes the sea.","pos":""}],"HALIOGRAPHY":[{"def":"Description of the sea; the science that treats of the sea.","pos":""}],"HALIOTIS":[{"def":"A genus of marine shells; the ear-shells.","pos":""}],"HALIOTOID":[{"def":"Like or pertaining to the genus Haliotis; ear-shaped.","pos":""}],"HALISAURIA":[{"def":"The Enaliosauria.","pos":""}],"HALITE":[{"def":"Native salt; sodium chloride.","pos":""}],"HALITUOUS":[{"def":"Produced by, or like, breath; vaporous.","pos":""}],"HALK":[{"def":"A nook; a corner.","pos":""}],"HALL":[{"def":"A building or room of considerable size and stateliness, used for public purposes; as, Westminster Hall, in London.","pos":""},{"def":"A name given to many manor houses because the magistrate's court was held in the hall of his mansion; a chief mansion house.","pos":""}],"HALL-MARK":[{"def":"The official stamp of the Goldsmiths' Company and other assay offices, in the United Kingdom, on gold and silver articles, attesting their purity.","pos":""}],"HALLAGE":[{"def":"A fee or toll paid for goods sold in a hall.","pos":""},{"def":"Praise ye Jehovah; praise ye the Lord; -- an exclamation used chiefly in songs of praise or thanksgiving to God, and as an expression of gratitude or adoration.","pos":""}],"HALLELUJATIC":[{"def":"Pertaining to, or containing, hallelujahs.","pos":""}],"HALLIDOME":[{"def":"Same as Halidom.","pos":""}],"HALLIER":[{"def":"A kind of net for catching birds.","pos":""}],"HALLOO":[{"def":"A loud exclamation; a call to invite attention or to incite a person or an animal; a shout.","pos":""}],"HALLOW":[{"def":"To make holy; to set apart for holy or religious use; to consecrate; to treat or keep as sacred; to reverence.","pos":""}],"HALLOWEEN":[{"def":"The evening preceding Allhallows or All Saints' Day.","pos":""}],"HALLOWMAS":[{"def":"The feast of All Saints, or Allhallows.","pos":""}],"HALLOYSITE":[{"def":"A claylike mineral, occurring in soft, smooth, amorphous masses, of a whitish color.","pos":""}],"HALLUCAL":[{"def":"Of or pertaining to the hallux.","pos":""}],"HALLUCINATE":[{"def":"To wander; to go astray; to err; to blunder; -- used of mental processes.","pos":""}],"HALLUCINATION":[{"def":"The perception of objects which have no reality, or of sensations which have no corresponding external cause, arising from disorder or the nervous system, as in delirium tremens; delusion.","pos":""}],"HALLUCINATOR":[{"def":"One whose judgment and acts are affected by hallucinations; one who errs on account of his hallucinations.","pos":""}],"HALLUCINATORY":[{"def":"Partaking of, or tending to produce, hallucination.","pos":""}],"HALLUX":[{"def":"The first, or preaxial, digit of the hind limb, corresponding to the pollux in the fore limb; the great toe; the hind toe of birds.","pos":""}],"HALMA":[{"def":"The long jump, with weights in the hands, -- the most important of the exercises of the Pentathlon.","pos":""}],"HALO":[{"def":"A luminous circle, usually prismatically colored, round the sun or moon, and supposed to be caused by the refraction of light through crystals of ice in the atmosphere.","pos":""},{"def":"A circle of light; especially, the bright ring represented in painting as surrounding the heads of saints and other holy persons; a glory; a nimbus.","pos":""}],"HALOED":[{"def":"Surrounded with a halo; invested with an ideal glory; glorified.","pos":""}],"HALOGEN":[{"def":"An electro-negative element or radical, which, by combination with a metal, forms a haloid salt; especially, chlorine, bromine, and iodine; sometimes, also, fluorine and cyanogen.","pos":""}],"HALOGENOUS":[{"def":"Of the nature of a halogen.","pos":""}],"HALOID":[{"def":"Resembling salt; -- said of certain binary compounds consisting of a metal united to a negative element or radical, and now chiefly applied to the chlorides, bromides, iodides, and sometimes also to the fluorides and cyanides.","pos":""},{"def":"A haloid substance.","pos":""}],"HALOMETER":[{"def":"An instrument for measuring the forms and angles of salts and crystals; a goniometer.","pos":""}],"HALONES":[{"def":"Alternating transparent and opaque white rings which are seen outside the blastoderm, on the surface of the developing egg of the hen and other birds.","pos":""}],"HALOPHYTE":[{"def":"A plant found growing in salt marshes, or in the sea.","pos":""}],"HALOSCOPE":[{"def":"An instrument for exhibition or illustration of the phenomena of halos, parhelia, and the like.","pos":""}],"HALOTRICHITE":[{"def":"An iron alum occurring in silky fibrous aggregates of a yellowish white color.","pos":""}],"HALOXYLINE":[{"def":"An explosive mixture, consisting of sawdust, charcoal, niter, and ferrocyanide of potassium, used as a substitute for gunpowder.","pos":""}],"HALS":[{"def":"The neck or throat.","pos":""}],"HALSE":[{"def":"To embrace about the neck; to salute; to greet.","pos":""},{"def":"To adjure; to beseech; to entreat.","pos":""}],"HALSENING":[{"def":"Sounding harshly in the throat; inharmonious; rough.","pos":""}],"HALT":[{"def":"Halt, Defn: 3d pers.","pos":""}],"HALTER":[{"def":"A strong strap or cord.","pos":""}],"HALTER-SACK":[{"def":"A term of reproach, implying that one is fit to be hanged.","pos":""}],"HALTERES":[{"def":"Balancers; the rudimentary hind wings of Diptera.","pos":""}],"HALTINGLY":[{"def":"In a halting or limping manner.","pos":""}],"HALVANS":[{"def":"Impure ore; dirty ore.","pos":""}],"HALVE":[{"def":"To join, as two pieces of timber, by cutting away each for half its thickness at the joining place, and fitting together.","pos":""}],"HALVED":[{"def":"Appearing as if one side, or one half, were cut away; dimidiate.","pos":""}],"HALVES":[{"def":"I can not believe by halves; either I have faith, or I have it not.","pos":""}],"HALWE":[{"def":"A rope or tackle for hoisting or lowering yards, sails, flags, etc.","pos":""}],"HALYSITES":[{"def":"A genus of Silurian fossil corals; the chain corals.","pos":""}]}