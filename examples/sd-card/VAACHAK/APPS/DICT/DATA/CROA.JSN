{"CROAK":[{"def":"To make a low, hoarse noise in the throat, as a frog, a raven, or a crow; hence, to make any hoarse, dismal sound.","pos":""},{"def":"To complain; especially, to grumble; to forebode evil; to utter complaints or forebodings habitually.","pos":""}],"CROAKER":[{"def":"One who croaks, murmurs, grumbles, or complains unreasonably; one who habitually forebodes evil.","pos":""}],"CROAT":[{"def":"A native of Croatia, in Austria; esp.","pos":""},{"def":"An irregular soldier, generally from Croatia.","pos":""}],"CROATIAN":[{"def":"Of or pertaining to Croatia.","pos":""}]}