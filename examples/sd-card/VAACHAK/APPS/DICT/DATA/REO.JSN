{"REOBTAIN":[{"def":"To obtain again.","pos":""}],"REOBTAINABLE":[{"def":"That may be reobtained.","pos":""}],"REOCCUPY":[{"def":"To occupy again.","pos":""}],"REOMETER":[{"def":"Same as Rheometer.","pos":""}],"REOPPOSE":[{"def":"To oppose again.","pos":""}],"REORDAIN":[{"def":"To ordain again, as when the first ordination is considered defective.","pos":""}],"REORDER":[{"def":"To order a second time.","pos":""}],"REORDINATION":[{"def":"A second ordination.","pos":""}],"REORGANIZATION":[{"def":"The act of reorganizing; a reorganized existence; as, reorganization of the troops.","pos":""}],"REORGANIZE":[{"def":"To organize again or anew; as, to reorganize a society or an army.","pos":""}],"REORIENT":[{"def":"Re*o\"ri*ent (r-\"r-ent), a.","pos":""}],"REOSTAT":[{"def":"Re\"o*stat (r\"-stt), n.","pos":""}]}