{"THECA":[{"def":"A sheath; a case; as, the theca, or cell, of an anther; the theca, or spore case, of a fungus; the theca of the spinal cord.","pos":""}],"THECAL":[{"def":"Of or pertaining to a theca; as, a thecal abscess.","pos":""}],"THECASPOROUS":[{"def":"Having the spores in thecæ, or cases.","pos":""}],"THECATA":[{"def":"Same as Thecophora.","pos":""}],"THECLA":[{"def":"Any one of many species of small delicately colored butterflies belonging to Thecla and allied genera; -- called also hairstreak, and elfin.","pos":""}],"THECODACTYL":[{"def":"Any one of a group of lizards of the Gecko tribe, having the toes broad, and furnished with a groove in which the claws can be concealed.","pos":""}],"THECODONT":[{"def":"Having the teeth inserted in sockets in the alveoli of the jaws.","pos":""},{"def":"Of or pertaining to the thecodonts.","pos":""}],"THECODONTIA":[{"def":"A group of fossil saurians having biconcave vertebræ and the teeth implanted in sockets.","pos":""}],"THECOPHORA":[{"def":"A division of hydroids comprising those which have the hydranths in thecæ and the gonophores in capsules.","pos":""}],"THECOSOMATA":[{"def":"An order of Pteropoda comprising those species which have a shell.","pos":""}]}