{"PAID":[{"def":"Receiving pay; compensated; hired; as, a paid attorney.","pos":""},{"def":"Satisfied; contented.","pos":""}],"PAIDEUTICS":[{"def":"The science or art of teaching.","pos":""}],"PAIGLE":[{"def":"A species of Primula, either the cowslip or the primrose.","pos":""}],"PAIL":[{"def":"A vessel of wood or tin, etc.","pos":""}],"PAILFUL":[{"def":"The quantity that a pail will hold.","pos":""}],"PAILLASSE":[{"def":"An under bed or mattress of straw.","pos":""}],"PAILLON":[{"def":"A thin leaf of metal, as for use in gilding or enameling, or to show through a translucent medium.","pos":""}],"PAIN":[{"def":"Specifically, the throes or travail of childbirth.","pos":""}],"PAINABLE":[{"def":"Causing pain; painful.","pos":""}],"PAINFUL":[{"def":"Full of pain; causing uneasiness or distress, either physical or mental; afflictive; disquieting; distressing Addison.","pos":""},{"def":"Requiring labor or toil; difficult; executed with laborious effort; as a painful service; a painful march.","pos":""}],"PAINIM":[{"def":"A pagan; an infidel; -- used also adjectively.","pos":"noun"}],"PAINLESS":[{"def":"Free from pain; without pain.","pos":""}],"PAINS":[{"def":"Labor; toilsome effort; care or trouble taken; -- plural in form, but used with a singular or plural verb, commonly the former.","pos":""}],"PAINSTAKER":[{"def":"One who takes pains; one careful and faithful in all work.","pos":""}],"PAINSTAKING":[{"def":"Careful in doing; diligent; faithful; attentive.","pos":""}],"PAINT":[{"def":"To cover with coloring matter; to apply paint to; as, to paint a house, a signboard, etc.","pos":""}],"PAINTED":[{"def":"Marked with bright colors; as, the painted turtle; painted bunting.","pos":""}],"PAINTER":[{"def":"A rope at the bow of a boat, used to fasten it to anything.","pos":""}],"PAINTERLY":[{"def":"Like a painter's work.","pos":""}],"PAINTERSHIP":[{"def":"The state or position of being a painter.","pos":""}],"PAINTING":[{"def":"The work of the painter; also, any work of art in which objects are represented in color on a flat surface; a colored representation of any object or scene; a picture.","pos":""}],"PAINTLESS":[{"def":"Not capable of being painted or described.","pos":""}],"PAINTURE":[{"def":"The art of painting.","pos":""}],"PAINTY":[{"def":"Unskillfully painted, so that the painter's method of work is too obvious; also, having too much pigment applied to the surface.","pos":""}],"PAIR":[{"def":"In a mechanism, two elements, or bodies, which are so applied to each other as to mutually constrain relative motion.","pos":""}],"PAIRER":[{"def":"One who impairs.","pos":""}],"PAIRING":[{"def":"The act or process of uniting or arranging in pairs or couples.","pos":""},{"def":"See To pair off, under Pair, v.","pos":""}],"PAIS":[{"def":"The country; the people of the neighborhood.","pos":""}],"PAISANO":[{"def":"The chaparral cock.","pos":""}]}