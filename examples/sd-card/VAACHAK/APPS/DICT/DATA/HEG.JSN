{"HEGELIAN":[{"def":"Pertaining to Hegelianism.","pos":""},{"def":"A follower of Hegel.","pos":""}],"HEGEMONY":[{"def":"Leadership; preponderant influence or authority; -- usually applied to the relation of a government or state to its neighbors or confederates.","pos":""}],"HEGIRA":[{"def":"The flight of Mohammed from Mecca, September 13, A.","pos":""}]}