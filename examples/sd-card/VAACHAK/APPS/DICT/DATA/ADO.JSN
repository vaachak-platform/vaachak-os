{"ADO":[{"def":"To do; in doing; as, there is nothing.","pos":""},{"def":"Doing; trouble; difficulty; troublesome business; fuss; bustle; as, to make a great ado about trifles.","pos":""}],"ADOBE":[{"def":"An unburnt brick dried in the sun; also used as an adjective, as, an adobe house, in Texas or New Mexico.","pos":""}],"ADOLESCENCE":[{"def":"The state of growing up from childhood to manhood or womanhood; youth, or the period of life between puberty and maturity, generally considered to be, in the male sex, from fourteen to twenty-one.","pos":""}],"ADOLESCENCY":[{"def":"The quality of being adolescent; youthfulness.","pos":""}],"ADOLESCENT":[{"def":"Growing; advancing from childhood to maturity.","pos":""}],"ADONAI":[{"def":"A Hebrew name for God, usually translated in the Old Testament by the word \"Lord\".","pos":""}],"ADONEAN":[{"def":"Pertaining to Adonis; Adonic.","pos":""}],"ADONIC":[{"def":"Relating to Adonis, famed for his beauty.","pos":""},{"def":"An Adonic verse.","pos":""}],"ADONIS":[{"def":"A youth beloved by Venus for his beauty.","pos":""},{"def":"A genus of plants of the family Ranunculaceæ, containing the pheasaut's eye (Adonis autumnalis); -- named from Adonis, whose blood was fabled to have stained the flower.","pos":""}],"ADONIST":[{"def":"One who maintains that points of the Hebrew word translated \"Jehovah\" are really the vowel points of the word \"Adonai.","pos":""}],"ADONIZE":[{"def":"To beautify; to dandify.","pos":""},{"def":"At the door; of the door; as, out adoors.","pos":""}],"ADOPT":[{"def":"To take by choice into relationship, as, child, heir, friend, citizen, etc.","pos":""},{"def":"To take or receive as one's own what is not so naturally; to select and take or approve; as, to adopt the view or policy of another; these resolutions were adopted.","pos":""}],"ADOPTABLE":[{"def":"Capable of being adopted.","pos":""}],"ADOPTED":[{"def":"Taken by adoption; taken up as one's own; as, an adopted son, citizen, country, word.","pos":""}],"ADOPTER":[{"def":"A receiver, with two necks, opposite to each other, one of which admits the neck of a retort, and the other is joined to another receiver.","pos":""}],"ADOPTION":[{"def":"The act of adopting, or state of being adopted; voluntary acceptance of a child of other parents to be the same as one's own child.","pos":""},{"def":"Admission to a more intimate relation; reception; as, the adoption of persons into hospitals or monasteries, or of one society into another.","pos":""}],"ADOPTIONIST":[{"def":"One of a sect which maintained that Christ was the Son of God not by nature but by adoption.","pos":""}],"ADOPTIVE":[{"def":"Pertaining to adoption; made or acquired by adoption; fitted to adopt; as, an adoptive father, an child; an adoptive language.","pos":""}],"ADORABLE":[{"def":"Deserving to be adored; worthy of divine honors.","pos":""},{"def":"Worthy of the utmost love or respect.","pos":""}],"ADORABLENESS":[{"def":"The quality of being adorable, or worthy of adoration.","pos":""}],"ADORABLY":[{"def":"In an adorable manner.","pos":""}],"ADORATION":[{"def":"The act of playing honor to a divine being; the worship paid to God; the act of addressing as a god.","pos":""},{"def":"Homage paid to one in high esteem; profound veneration; intense regard and love; fervent devotion.","pos":""}],"ADORE":[{"def":"To worship with profound reverence; to pay divine honors to; to honor as deity or as divine.","pos":""},{"def":"To love in the highest degree; to regard with the utmost esteem and affection; to idolize.","pos":""}],"ADOREMENT":[{"def":"The act of adoring; adoration.","pos":""}],"ADORER":[{"def":"One who adores; a worshiper; one who admires or loves greatly; an ardent admirer.","pos":""}],"ADORN":[{"def":"To deck or dress with ornaments; to embellish; to set off to advantage; to render pleasing or attractive.","pos":""}],"ADORNER":[{"def":"He who, or that which, adorns; a beautifier.","pos":""}],"ADORNINGLY":[{"def":"By adorning; decoratively.","pos":""}],"ADORNMENT":[{"def":"An adorning; an ornament; a decoration.","pos":""}],"ADOSCULATION":[{"def":"Impregnation by external contact, without intromission.","pos":""}],"ADOWN":[{"def":"From a higher to a lower situation; downward; down, to or on the ground.","pos":""}]}