{"UNSHACKLE":[{"def":"To loose from shackles or bonds; to set free from restraint; to unfetter.","pos":""}],"UNSHAKABLE":[{"def":"Not capable of being shaken; firm; fixed.","pos":""}],"UNSHALE":[{"def":"To strip the shale, or husk, from; to uncover.","pos":""}],"UNSHAPE":[{"def":"To deprive of shape, or of proper shape; to disorder; to confound; to derange.","pos":""},{"def":"Not shaped; shapeless; misshapen; deformed; ugly.","pos":""}],"UNSHEATHE":[{"def":"To deprive of a sheath; to draw from the sheath or scabbard, as a sword.","pos":""}],"UNSHED":[{"def":"Not parted or divided, as the hair.","pos":""},{"def":"Not spilt, or made to flow, as blood or tears.","pos":""}],"UNSHELL":[{"def":"To strip the shell from; to take out of the shell; to hatch.","pos":""}],"UNSHELVE":[{"def":"To remove from, or as from, a shelf.","pos":""}],"UNSHENT":[{"def":"Not shent; not disgraced; blameless.","pos":""}],"UNSHERIFF":[{"def":"To depose from the office of sheriff.","pos":""}],"UNSHIP":[{"def":"To remove or detach, as any part or implement, from its proper position or connection when in use; as, to unship an oar; to unship capstan bars; to unship the tiller.","pos":""}],"UNSHIPMENT":[{"def":"The act of unshipping, or the state of being unshipped; displacement.","pos":""}],"UNSHOT":[{"def":"To remove the shot from, as from a shotted gun; to unload.","pos":""}],"UNSHOUT":[{"def":"To recall what is done by shouting.","pos":""}],"UNSHROUD":[{"def":"To remove the shroud from; to uncover.","pos":""}],"UNSHRUBBED":[{"def":"Being without shrubs.","pos":""}],"UNSHUT":[{"def":"To open, or throw open.","pos":""}],"UNSHUTTER":[{"def":"To open or remove the shutters of.","pos":""}]}