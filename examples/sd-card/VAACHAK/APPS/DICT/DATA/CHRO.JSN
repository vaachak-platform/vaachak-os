{"CHROMASCOPE":[{"def":"An instrument for showing the optical effects of color.","pos":""}],"CHROMATE":[{"def":"A salt of chromic acid.","pos":""}],"CHROMATIC":[{"def":"Proceeding by the smaller intervals (half steps or semitones) of the scale, instead of the regular intervals of the diatonic scale.","pos":""}],"CHROMATICALLY":[{"def":"In a chromatic manner.","pos":""}],"CHROMATICS":[{"def":"The science of colors; that part of optics which treats of the properties of colors.","pos":""}],"CHROMATIN":[{"def":"Tissue which is capable of being stained by dyes.","pos":""}],"CHROMATISM":[{"def":"The state of being colored, as in the case of images formed by a lens.","pos":""},{"def":"An abnormal coloring of plants.","pos":""}],"CHROMATOGENOUS":[{"def":"Producing color.","pos":""}],"CHROMATOGRAPHY":[{"def":"Chro`ma*tog\"ra*phy, n.","pos":""}],"CHROMATOLOGY":[{"def":"A treatise on colors.","pos":""}],"CHROMATOPHORE":[{"def":"A contractile cell or vesicle containing liquid pigment and capable of changing its form or size, thus causing changes of color in the translucent skin of such animals as possess them.","pos":""},{"def":"One of the granules of protoplasm, which in mass give color to the part of the plant containing them.","pos":""}],"CHROMATOSCOPE":[{"def":"A reflecting telescope, part of which is made to rotate eccentrically, so as to produce a ringlike image of a star, instead of a point; -- used in studying the scintillation of the stars.","pos":""}],"CHROMATOSPHERE":[{"def":"Chro\"ma*to*sphere`, n.","pos":""}],"CHROMATROPE":[{"def":"An instrument for exhibiting certain chromatic effects of light (depending upon the persistence of vision and mixture of colors) by means of rapidly rotating disks variously colored.","pos":""}],"CHROMATYPE":[{"def":"A colored photographic picture taken upon paper made sensitive with potassium bichromate or some other salt of chromium.","pos":""}],"CHROME":[{"def":"Same as Chromium.","pos":""}],"CHROME STEEL":[{"def":"Same as Chromium steel, under Steel.","pos":""}],"CHROMIC":[{"def":"Pertaining to, or obtained from, chromium; -- said of the compounds of chromium in which it has its higher valence.","pos":""}],"CHROMID":[{"def":"One of the Chromidæ, a family of fresh-water fishes abundant in the tropical parts of America and Africa.","pos":""}],"CHROMIDROSIS":[{"def":"Secretion of abnormally colored perspiration.","pos":""}],"CHROMISM":[{"def":"Same as Chromatism.","pos":""}],"CHROMITE":[{"def":"A black submetallic mineral consisting of oxide of chromium and iron; -- called also chromic iron.","pos":""},{"def":"A compound or salt of chromous hydroxide regarded as an acid.","pos":""}],"CHROMIUM":[{"def":"A comparatively rare element occurring most abundantly in the mineral chromite.","pos":""}],"CHROMO":[{"def":"A chromolithograph.","pos":""}],"CHROMOBLAST":[{"def":"An embryonic cell which develops into a pigment cell.","pos":""}],"CHROMOGEN":[{"def":"Vegetable coloring matter other than green; chromule.","pos":""},{"def":"Any colored compound, supposed to contain one or more chromophores.","pos":""}],"CHROMOGENIC":[{"def":"Containing, or capable of forming, chromogen; as, chromogenic bacteria.","pos":""}],"CHROMOGRAPH":[{"def":"An apparatus by which a number of copies of written matter, maps, plans, etc.","pos":""}],"CHROMOLEUCITE":[{"def":"A chromoplastid.","pos":""}],"CHROMOLITHOGRAPH":[{"def":"A picture printed in tints and colors by repeated impressions from a series of stones prepared by the lithographic process.","pos":""}],"CHROMOLITHOGRAPHER":[{"def":"One who is engaged in chromolithography.","pos":""}],"CHROMOLITHOGRAPHIC":[{"def":"Pertaining to, or made by, chromolithography.","pos":""}],"CHROMOLITHOGRAPHY":[{"def":"Lithography adapted to printing in inks of various colors.","pos":""}],"CHROMOPHANE":[{"def":"A general name for the several coloring matters, red, green, yellow, etc.","pos":""}],"CHROMOPHOTOGRAPH":[{"def":"A picture made by any of the processes for reproducing photographs in colors.","pos":""}],"CHROMOPHOTOGRAPHY":[{"def":"The art of producing photographs in colors.","pos":""}],"CHROMOPHOTOLITHOGRAPH":[{"def":"A photolithograph printed in colors.","pos":""}],"CHROMOPLASTID":[{"def":"A protoplasmic granule of some other color than green; -- also called chromoleucite.","pos":""}],"CHROMOSOME":[{"def":"One of the minute bodies into which the chromatin of the nucleus is resolved during mitotic cell division; the idant of Weismann.","pos":""}],"CHROMOSPHERE":[{"def":"An atmosphere of rare matter, composed principally of incandescent hydrogen gas, surrounding the sun and enveloping the photosphere.","pos":""}],"CHROMOSPHERIC":[{"def":"Of or pertaining to the chromosphere.","pos":""}],"CHROMOTYPE":[{"def":"A sheet printed in colors by any process, as a chromolithograph.","pos":""},{"def":"A photographic picture in the natural colors.","pos":""}],"CHROMOUS":[{"def":"Of, pertaining to, or derived from, chromium, when this element has a valence lower than that in chromic compounds.","pos":""}],"CHROMULE":[{"def":"A general name for coloring matter of plants other than chlorophyll, especially that of petals.","pos":""}],"CHRONIC":[{"def":"Relating to time; according to time.","pos":""},{"def":"Continuing for a long time; lingering; habitual.","pos":""}],"CHRONICAL":[{"def":"Partly on a chronical, and partly on a topical method.","pos":""}],"CHRONICLE":[{"def":"The two canonical books of the Old Testament in which immediately follow 2 Kings.","pos":""}],"CHRONICLER":[{"def":"A writer of a chronicle; a recorder of events in the order of time; an historian.","pos":""}],"CHRONOGRAM":[{"def":"Belonging to a chronogram, or containing one.","pos":""}],"CHRONOGRAMMATIST":[{"def":"A writer of chronograms.","pos":""}],"CHRONOGRAPH":[{"def":"An instrument for measuring or recording intervals of time, upon a revolving drum or strip of paper moved by clockwork.","pos":""},{"def":"Same as Chronogram, 1.","pos":""}],"CHRONOGRAPHER":[{"def":"One who writes a chronography; a chronologer.","pos":""}],"CHRONOGRAPHIC":[{"def":"Of or pertaining to a chronograph.","pos":""}],"CHRONOGRAPHY":[{"def":"A description or record of past time; history.","pos":""}],"CHRONOLOGER":[{"def":"Same as Chronologist.","pos":""},{"def":"Relating to chronology; containing an account of events in the order of time; according to the order of time; as, chronological tables.","pos":""}],"CHRONOLOGY":[{"def":"The science which treats of measuring time by regular divisions or periods, and which assigns to events or transactions their proper dates.","pos":""}],"CHRONOMETER":[{"def":"Pertaining to a chronometer; measured by a chronometer.","pos":""}],"CHRONOMETRY":[{"def":"The art of measuring time; the measuring of time by periods or divisions.","pos":""}],"CHRONOPHER":[{"def":"An instrument signaling the correct time to distant points by electricity.","pos":""}],"CHRONOPHOTOGRAPH":[{"def":"One of a set of photographs of a moving object, taken for the purpose of recording and exhibiting successive phases of the motion.","pos":""}],"CHRONOSCOPE":[{"def":"An instrument for measuring minute intervals of time; used in determining the velocity of projectiles, the duration of short-lived luminous phenomena, etc.","pos":""}]}