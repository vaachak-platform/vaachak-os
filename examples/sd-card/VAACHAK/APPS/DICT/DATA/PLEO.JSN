{"PLEOCHROIC":[{"def":"Having the property of pleochroism.","pos":""}],"PLEOCHROISM":[{"def":"The property possessed by some crystals, of showing different colors when viewed in the direction of different axes.","pos":""}],"PLEOCHROMATISM":[{"def":"Ple`o*chro\"ma*tism, n.","pos":""}],"PLEOMORPHIC":[{"def":"Pertaining to pleomorphism; as, the pleomorphic character of bacteria.","pos":""}],"PLEOMORPHISM":[{"def":"The property of crystallizing under two or more distinct fundamental forms, including dimorphism and trimorphism.","pos":""},{"def":"The theory that the various genera of bacteria are phases or variations of growth of a number of Protean species, each of which may exhibit, according to undetermined conditions, all or some of the forms characteristic of the different genera and species.","pos":""}],"PLEOMORPHOUS":[{"def":"Having the property of pleomorphism.","pos":""}],"PLEONASM":[{"def":"Redundancy of language in speaking or writing; the use of more words than are necessary to express the idea; as, I saw it with my own eyes.","pos":""}],"PLEONAST":[{"def":"One who is addicted to pleonasm.","pos":""}],"PLEONASTE":[{"def":"A black variety of spinel.","pos":""},{"def":"Of or pertaining to pleonasm; of the nature of pleonasm; redundant.","pos":""}],"PLEONASTICALLY":[{"def":"In a pleonastic manner.","pos":""}],"PLEOPOD":[{"def":"One of the abdominal legs of a crustacean.","pos":""}]}