{"TOG":[{"def":"To put toggery, or togs, on; to dress; -- usually with out, implying care, elaborateness, or the like.","pos":""}],"TOGA":[{"def":"The loose outer garment worn by the ancient Romans, consisting of a single broad piece of woolen cloth of a shape approaching a semicircle.","pos":""}],"TOGATED":[{"def":"Dressed in a toga or gown; wearing a gown; gowned.","pos":""}],"TOGETHER":[{"def":"In company or association with respect to place or time; as, to live together in one house; to live together in the same age; they walked together to the town.","pos":""},{"def":"In or into union; into junction; as, to sew, knit, or fasten two things together; to mix things together.","pos":""}],"TOGGERY":[{"def":"Clothes; garments; dress; as, fishing toggery.","pos":""}],"TOGGLE":[{"def":"A wooden pin tapering toward both ends with a groove around its middle, fixed transversely in the eye of a rope to be secured to any other loop or bight or ring; a kind of button or frog capable of being readily engaged and disengaged for temporary purposes.","pos":""},{"def":"Two rods or plates connected by a toggle joint.","pos":""}],"TOGHT":[{"def":"TOGIDER; TOGIDRES To*gid\"er, To*gid\"res, adv.","pos":""}],"TOGS":[{"def":"Clothes; garments; toggery.","pos":""}]}