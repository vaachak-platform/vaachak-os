{"COD":[{"def":"A husk; a pod; as, a peascod.","pos":""},{"def":"A small bag or pouch.","pos":""}],"COD LIVER":[{"def":"The liver of the common cod and allied species.","pos":""}],"CODA":[{"def":"A few measures added beyond the natural termination of a composition.","pos":""}],"CODDER":[{"def":"A gatherer of cods or peas.","pos":""}],"CODDLE":[{"def":"To parboil, or soften by boiling.","pos":""},{"def":"To treat with excessive tenderness; to pamper.","pos":""}],"CODDYMODDY":[{"def":"A gull in the plumage of its first year.","pos":""}],"CODE":[{"def":"A body of law, sanctioned by legislation, in which the rules of law to be specifically applied by the courts are set forth in systematic form; a compilation of laws by public authority; a digest.","pos":""},{"def":"Any system of rules or regulations relating to one subject; as, the medical code, a system of rules for the regulation of the professional conduct of physicians; the naval code, a system of rules for making communications at sea means of signals.","pos":""}],"CODEFENDANT":[{"def":"A joint defendant.","pos":""}],"CODEINE":[{"def":"One of the opium alkaloids; a white crystalline substance, C18H21NO3, similar to and regarded as a derivative of morphine, but much feebler in its action; -- called also codeia.","pos":""}],"CODETTA":[{"def":"A short passage connecting two sections, but not forming part of either; a short coda.","pos":""}],"CODEX":[{"def":"A book; a manuscript.","pos":""},{"def":"A collection or digest of laws; a code.","pos":""}],"CODGER":[{"def":"A miser or mean person.","pos":""},{"def":"A singular or odd person; -- a familiar, humorous, or depreciatory appellation.","pos":""}],"CODICAL":[{"def":"Ralating to a codex, or a code.","pos":""}],"CODICIL":[{"def":"A clause added to a will.","pos":""}],"CODICILLARY":[{"def":"Of the nature of a codicil.","pos":""}],"CODIFICATION":[{"def":"The act or process of codifying or reducing laws to a code.","pos":""}],"CODIFIER":[{"def":"One who codifies.","pos":""}],"CODIFY":[{"def":"To reduce to a code, as laws.","pos":""}],"CODILLA":[{"def":"The coarse tow of flax and hemp.","pos":""}],"CODILLE":[{"def":"A term at omber, signifying that the game is won.","pos":""}],"CODIST":[{"def":"A codifier; a maker of codes.","pos":""}],"CODLE":[{"def":"CODLIN; CODLING Cod\"lin, Cod\"ling, n.","pos":""}],"CODLING":[{"def":"A young cod; also, a hake.","pos":""}],"CODPIECE":[{"def":"A part of male dress in front of the breeches, formerly made very conspicuous.","pos":""}]}