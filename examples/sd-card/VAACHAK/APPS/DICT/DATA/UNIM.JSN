{"UNIMPAIRABLE":[{"def":"That can not be impaired.","pos":""}],"UNIMPEACHABLE":[{"def":"Not impeachable; not to be called in question; exempt from liability to accusation; free from stain, guilt, or fault; irreproachable; blameless; as, an unimpeachable reputation; unimpeachable testimony.","pos":""}],"UNIMPORTANCE":[{"def":"Want of importance; triviality.","pos":""}],"UNIMPROVED":[{"def":"Not improved; not made better or wiser; not advanced in knowledge, manners, or excellence.","pos":""},{"def":"Not used; not employed; especially, not used or employed for a valuable purpose; as, unimproved opportunities; unimproved blessings.","pos":""}],"UNIMUSCULAR":[{"def":"Having only one adductor muscle, and one muscular impression on each valve, as the oyster; monomyarian.","pos":""}]}