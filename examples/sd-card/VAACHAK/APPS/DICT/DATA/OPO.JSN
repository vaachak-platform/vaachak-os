{"OPODELDOC":[{"def":"A kind of plaster, said to have been invented by Mindererus, -- used for external injuries.","pos":""},{"def":"A saponaceous, camphorated liniment; a solution of soap in alcohol, with the addition of camphor and essential oils; soap liniment.","pos":""}],"OPOLCHENIE":[{"def":"See Army organization, above.","pos":""}],"OPOPANAX":[{"def":"The inspissated juice of an umbelliferous plant (the Opoponax Chironum), brought from Turkey and the East Indies in loose granules, or sometimes in larger masses, of a reddish yellow color, with specks of white.","pos":""}],"OPOSSUM":[{"def":"Any American marsupial of the genera Didelphys and Chironectes.","pos":""}]}