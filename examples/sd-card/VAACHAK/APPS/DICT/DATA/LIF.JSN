{"LIF":[{"def":"The fiber by which the petioles of the date palm are bound together, from which various kinds of cordage are made.","pos":""}],"LIFE":[{"def":"The potential principle, or force, by which the organs of animals and plants are started and continued in the performance of their several and coöperative functions; the vital force, whether regarded as physical or spiritual.","pos":""}],"LIFE-GIVING":[{"def":"Giving life or spirit; having power to give life; inspiriting; invigorating.","pos":""}],"LIFE-PRESERVER":[{"def":"An apparatus, made in very various forms, and of various materials, for saving one from drowning by buoying up the body while in the water.","pos":""}],"LIFE-SAVING":[{"def":"That saves life, or is suited to save life, esp.","pos":""}],"LIFE-SIZE":[{"def":"Of full size; of the natural size.","pos":""}],"LIFE-WEARY":[{"def":"Weary of living.","pos":""}],"LIFEBLOOD":[{"def":"The blood necessary to life; vital blood.","pos":""}],"LIFEBOAT":[{"def":"A strong, buoyant boat especially designed for saving the lives of shipwrecked people.","pos":""}],"LIFEFUL":[{"def":"Full of vitality.","pos":""}],"LIFEHOLD":[{"def":"Land held by a life estate.","pos":""}],"LIFELESS":[{"def":"Destitute of life, or deprived of life; not containing, or inhabited by, living beings or vegetation; dead, or apparently dead; spiritless; powerless; dull; as, a lifeless carcass; lifeless matter; a lifeless desert; a lifeless wine; a lifeless story.","pos":""}],"LIFELIKE":[{"def":"Like a living being; resembling life; giving an accurate representation; as, a lifelike portrait.","pos":""}],"LIFELONG":[{"def":"Lasting or continuing through life.","pos":""}],"LIFELY":[{"def":"In a lifelike manner.","pos":""}],"LIFEMATE":[{"def":"Companion for life.","pos":""}],"LIFESOME":[{"def":"Animated; sprightly.","pos":""}],"LIFESPRING":[{"def":"Spring or source of life.","pos":""}],"LIFESTRING":[{"def":"A nerve, or string, that is imagined to be essential to life.","pos":""}],"LIFETIME":[{"def":"The time that life continues.","pos":""}],"LIFT":[{"def":"The sky; the atmosphere; the firmament.","pos":"noun"}],"LIFTABLE":[{"def":"Such as can be lifted.","pos":""}],"LIFTER":[{"def":"A tool for lifting loose sand from the mold; also, a contrivance attached to a cope, to hold the sand together when the cope is lifted.","pos":""}],"LIFTING":[{"def":"Used in, or for, or by, lifting.","pos":""}]}