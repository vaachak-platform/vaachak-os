{"SEMITA":[{"def":"A fasciole of a spatangoid sea urchin.","pos":""}],"SEMITANGENT":[{"def":"The tangent of half an arc.","pos":""}],"SEMITE":[{"def":"One belonging to the Semitic race.","pos":""}],"SEMITERTIAN":[{"def":"Having the characteristics of both a tertian and a quotidian intermittent.","pos":""},{"def":"An intermittent combining the characteristics of a tertian and a quotidian.","pos":""}],"SEMITIC":[{"def":"Of or pertaining to Shem or his descendants; belonging to that division of the Caucasian race which includes the Arabs, Jews, and related races.","pos":""}],"SEMITISM":[{"def":"A Semitic idiom; a word of Semitic origin.","pos":""}],"SEMITONE":[{"def":"Half a tone; -- the name commonly applied to the smaller intervals of the diatonic scale.","pos":""}],"SEMITONIC":[{"def":"Of or pertaining to a semitone; consisting of a semitone, or of semitones.","pos":""}],"SEMITRANSEPT":[{"def":"The half of a transept; as, the north semitransept of a church.","pos":""}],"SEMITRANSLUCENT":[{"def":"Slightly clear; transmitting light in a slight degree.","pos":""}],"SEMITRANSPARENCY":[{"def":"Imperfect or partial transparency.","pos":""}],"SEMITRANSPARENT":[{"def":"Half or imperfectly transparent.","pos":""}]}