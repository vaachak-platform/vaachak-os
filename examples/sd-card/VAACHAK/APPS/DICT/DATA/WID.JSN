{"WIDDY":[{"def":"A rope or halter made of flexible twigs, or withes, as of birch.","pos":""}],"WIDE":[{"def":"Made, as a vowel, with a less tense, and more open and relaxed, condition of the mouth organs; -- opposed to primary as used by Mr.","pos":""}],"WIDE-ANGLE":[{"def":"Having or covering an angle wider than the ordinary; -- applied to certain lenses of relatively short focus.","pos":""}],"WIDE-AWAKE":[{"def":"Fully awake; not Dickens.","pos":""}],"WIDEGAP":[{"def":"The angler; -- called also widegab, and widegut.","pos":""}],"WIDELY":[{"def":"In a wide manner; to a wide degree or extent; far; extensively; as, the gospel was widely disseminated by the apostles.","pos":""},{"def":"Very much; to a great degree or extent; as, to differ widely in opinion.","pos":""}],"WIDEN":[{"def":"To make wide or wider; to extend in breadth; to increase the width of; as, to widen a field; to widen a breach; to widen a stocking.","pos":""}],"WIDENESS":[{"def":"The quality or state of being wide; breadth; width; great extent from side to side; as, the wideness of a room.","pos":""},{"def":"Large extent in all directions; broadness; greatness; as, the wideness of the sea or ocean.","pos":""}],"WIDESPREAD":[{"def":"Spread to a great distance; widely extended; extending far and wide; as, widespread wings; a widespread movement.","pos":""}],"WIDEWHERE":[{"def":"Widely; far and wide.","pos":""}],"WIDGEON":[{"def":"Any one of several species of fresh-water ducks, especially those belonging to the subgenus Mareca, of the genus Anas.","pos":""}],"WIDISH":[{"def":"Moderately wide.","pos":""},{"def":"Certain figures appearing on etched meteoric iron; -- so called after A.","pos":""}],"WIDOW":[{"def":"A woman who has lost her husband by death, and has not married again; one living bereaved of a husband.","pos":""}],"WIDOW BIRD":[{"def":"See Whidan bird.","pos":""}],"WIDOW-HUNTER":[{"def":"One who courts widows, seeking to marry one with a fortune.","pos":""}],"WIDOW-MAKER":[{"def":"One who makes widows by destroying husbands.","pos":""}],"WIDOW-WAIL":[{"def":"A low, narrowleaved evergreen shrub (Cneorum tricoccon) found in Southern Europe.","pos":""}],"WIDOWER":[{"def":"A man who has lost his wife by death, and has not married again.","pos":""}],"WIDOWERHOOD":[{"def":"The state of being a widower.","pos":""}],"WIDOWHOOD":[{"def":"The state of being a widow; the time during which a woman is widow; also, rarely, the state of being a widower.","pos":""},{"def":"Estate settled on a widow.","pos":""}],"WIDOWLY":[{"def":"Becoming or like a widow.","pos":""}],"WIDTH":[{"def":"The quality of being wide; extent from side to side; breadth; wideness; as, the width of cloth; the width of a door.","pos":""}],"WIDUAL":[{"def":"Of or pertaining to a widow; vidual.","pos":""}]}