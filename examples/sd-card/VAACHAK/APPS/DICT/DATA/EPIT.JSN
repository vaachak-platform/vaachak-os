{"EPITAPH":[{"def":"An inscription on, or at, a tomb, or a grave, in memory or commendation of the one buried there; a sepulchral inscription.","pos":""},{"def":"A brief writing formed as if to be inscribed on a monument, as that concerning Alexander: \"Sufficit huic tumulus, cui non sufficeret orbis.","pos":""}],"EPITAPHER":[{"def":"A writer of epitaphs.","pos":""},{"def":"Relating to, or of the nature of, an epitaph.","pos":""}],"EPITAPHIC":[{"def":"Pertaining to an epitaph; epitaphian.","pos":""}],"EPITASIS":[{"def":"The period of violence in a fever or disease; paroxysm.","pos":""}],"EPITHALAMIC":[{"def":"Belonging to, or designed for, an epithalamium.","pos":""}],"EPITHALAMIUM":[{"def":"A nuptial song, or poem in honor of the bride and bridegroom.","pos":""}],"EPITHECA":[{"def":"A continuous and, usually, structureless layer which covers more or less of the exterior of many corals.","pos":""}],"EPITHELIAL":[{"def":"Of or pertaining to epithelium; as, epithelial cells; epithelial cancer.","pos":""}],"EPITHELIOID":[{"def":"Like epithelium; as, epithelioid cells.","pos":""}],"EPITHELIOMA":[{"def":"A malignant growth containing epithelial cells; -- called also epithelial cancer.","pos":""}],"EPITHELIUM":[{"def":"The superficial layer of cells lining the alimentary canal and all its appendages, all glands and their ducts, blood vessels and lymphatics, serous cavities, etc.","pos":""}],"EPITHEM":[{"def":"Any external topical application to the body, except ointments and plasters, as a poultice, lotion, etc.","pos":""}],"EPITHEMA":[{"def":"A horny excrescence upon the beak of birds.","pos":""}],"EPITHESIS":[{"def":"The addition of a letter at the end of a word, without changing its sense; as, numb for num, whilst for whiles.","pos":""}],"EPITHET":[{"def":"An adjective expressing some quality, attribute, or relation, that is properly or specially appropriate to a person or thing; as, a just man; a verdant lawn.","pos":""},{"def":"Term; expression; phrase.","pos":""}],"EPITHITE":[{"def":"A lazy, worthless fellow; a vagrant.","pos":""}],"EPITHUMETICAL":[{"def":"Pertaining to sexual desire; sensual.","pos":""}],"EPITITHIDES":[{"def":"The uppermost member of the cornice of an entablature.","pos":""}],"EPITOME":[{"def":"A work in which the contents of a former work are reduced within a smaller space by curtailment and condensation; a brief summary; an abridgement.","pos":""},{"def":"A compact or condensed representation of anything.","pos":""}],"EPITOMIST":[{"def":"One who makes an epitome; one who abridges; an epitomizer.","pos":""}],"EPITOMIZE":[{"def":"To make an epitome of; to shorten or abridge, as a writing or discourse; to reduce within a smaller space; as, to epitomize the works of Justin.","pos":""},{"def":"To diminish, as by cutting off something; to curtail; as, to epitomize words.","pos":""}],"EPITRITE":[{"def":"A foot consisting of three long syllables and one short syllable.","pos":""}],"EPITROCHLEA":[{"def":"A projection on the outer side of the distal end of the humerus; the external condyle.","pos":""}],"EPITROCHLEAR":[{"def":"Relating to the epitrochlea.","pos":""}],"EPITROCHOID":[{"def":"A kind of curve.","pos":""}],"EPITROPE":[{"def":"A figure by which permission is either seriously or ironically granted to some one, to do what he proposes to do; e.","pos":""}]}