{"TRY":[{"def":"To examine or investigate judicially; to examine by witnesses or other judicial evidence and the principles of law; as, to try a cause, or a criminal.","pos":""}],"TRY COCK":[{"def":"A cock for withdrawing a small quantity of liquid, as for testing.","pos":""}],"TRY-SQUARE":[{"def":"An instrument used by carpenters, joiners, etc.","pos":""}],"TRYGON":[{"def":"Any one of several species of large sting rays belonging to Trygon and allied genera.","pos":""}],"TRYING":[{"def":"Adapted to try, or put to severe trial; severe; afflictive; as, a trying occasion or position.","pos":""}],"TRYOUT":[{"def":"A test by which the fitness of a player or contestant to remain in a certain class is determined.","pos":""}],"TRYPSIN":[{"def":"A proteolytic ferment, or enzyme, present in the pancreatic juice.","pos":""}],"TRYPSINOGEN":[{"def":"The antecedent of trypsin, a substance which is contained in the cells of the pancreas and gives rise to the trypsin.","pos":""}],"TRYPTIC":[{"def":"Relating to trypsin or to its action; produced by trypsin; as, trypsin digestion.","pos":""}],"TRYPTONE":[{"def":"The peptone formed by pancreatic digestion; -- so called because it is formed through the agency of the ferment trypsin.","pos":""}],"TRYSAIL":[{"def":"A fore-and-aft sail, bent to a gaff, and hoisted on a lower mast or on a small mast, called the trysail mast, close abaft a lower mast; -- used chiefly as a storm sail.","pos":""}],"TRYST":[{"def":"An appointment to meet; also, an appointed place or time of meeting; as, to keep tryst; to break tryst.","pos":""}],"TRYSTER":[{"def":"One who makes an appointment, or tryst; one who meets with another.","pos":""}],"TRYSTING":[{"def":"An appointment; a tryst.","pos":""}]}