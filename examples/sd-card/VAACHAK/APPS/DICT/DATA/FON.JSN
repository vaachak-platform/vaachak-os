{"FON":[{"def":"A fool; an idiot.","pos":""}],"FOND":[{"def":"Foolish; silly; simple; weak.","pos":""},{"def":"Foolishly tender and loving; weakly indulgent; over-affectionate.","pos":""}],"FONDANT":[{"def":"A kind of soft sweetmeat made by boiling solutions to the point of crystallization, usually molded; as, cherry fondant.","pos":""}],"FONDE":[{"def":"To endeavor; to strive; to try.","pos":""}],"FONDLE":[{"def":"To treat or handle with tenderness or in a loving manner; to caress; as, a nurse fondles a child.","pos":""}],"FONDLER":[{"def":"One who fondles.","pos":""}],"FONDLING":[{"def":"The act of caressing; manifestation of tenderness.","pos":""}],"FONDLY":[{"def":"In a fond manner; affectionately; tenderly.","pos":""}],"FONDNESS":[{"def":"The quality or state of being fond; foolishness.","pos":""},{"def":"Doting affection; tender liking; strong appetite, propensity, or relish; as, he had a fondness for truffles.","pos":""}],"FONDON":[{"def":"A large copper vessel used for hot amalgamation.","pos":""}],"FONDU":[{"def":"Blended; passing into each other by subtle gradations; -- said of colors or of the surface or material on which the colors are laid.","pos":""},{"def":"A dish made of cheese, eggs, butter, etc.","pos":""}],"FONDUS":[{"def":"A style of printing calico, paper hangings, etc.","pos":""}],"FONGE":[{"def":"To take; to receive.","pos":""}],"FONLY":[{"def":"Foolishly; fondly.","pos":""}],"FONT":[{"def":"A complete assortment of printing type of one size, including a due proportion of all the letters in the alphabet, large and small, points, accents, and whatever else is necessary for printing with that variety of types; a fount.","pos":""}],"FONTAL":[{"def":"Pertaining to a font, fountain, source, or origin; original; primitive.","pos":""}],"FONTANEL":[{"def":"An issue or artificial ulcer for the discharge of humors from the body.","pos":""},{"def":"One of the membranous intervals between the incompleted angles of the parietal and neighboring bones of a fetal or young skull; -- so called because it exhibits a rhythmical pulsation.","pos":""}],"FONTANELLE":[{"def":"Same as Fontanel, 2.","pos":""}],"FONTANGE":[{"def":"A kind of tall headdress formerly worn.","pos":""}]}