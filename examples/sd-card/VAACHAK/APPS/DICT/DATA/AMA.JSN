{"AMABILITY":[{"def":"Note: The New English Dictionary (Murray) says this word is \"usefully distinct from Amiability.","pos":""}],"AMADAVAT":[{"def":"The strawberry finch, a small Indian song bird (Estrelda amandava), commonly caged and kept for fighting.","pos":""}],"AMADOU":[{"def":"A spongy, combustible substance, prepared from fungus (Boletus and Polyporus) which grows on old trees; German tinder; punk.","pos":""}],"AMAIN":[{"def":"With might; with full force; vigorously; violently; exceedingly.","pos":""},{"def":"At full speed; in great haste; also, at once.","pos":""}],"AMALGAM":[{"def":"A native compound of mercury and silver.","pos":""}],"AMALGAMA":[{"def":"Same as Amalgam.","pos":""}],"AMALGAMATE":[{"def":"To compound or mix, as quicksilver, with another metal; to unite, combine, or alloy with mercury.","pos":""},{"def":"To mix, so as to make a uniform compound; to unite or combine; as, to amalgamate two races; to amalgamate one race with another.","pos":""}],"AMALGAMATION":[{"def":"The act or operation of compounding mercury with another metal; -- applied particularly to the process of separating gold and silver from their ores by mixing them with mercury.","pos":""},{"def":"The mixing or blending of different elements, races, societies, etc.","pos":""}],"AMALGAMATIVE":[{"def":"Characterized by amalgamation.","pos":""}],"AMALGAMATOR":[{"def":"One who, or that which, amalgamates.","pos":""}],"AMANDINE":[{"def":"The vegetable casein of almonds.","pos":""},{"def":"A kind of cold cream prepared from almonds, for chapped hands, etc.","pos":""}],"AMANITA":[{"def":"A genus of poisonous fungi of the family Agaricaceæ, characterized by having a volva, an annulus, and white spores.","pos":""}],"AMANITINE":[{"def":"The poisonous principle of some fungi.","pos":""}],"AMANUENSIS":[{"def":"A person whose employment is to write what another dictates, or to copy what another has written.","pos":""}],"AMARACUS":[{"def":"A fragrant flower.","pos":""}],"AMARANTACEOUS":[{"def":"Of, pertaining to, or resembling, the family of plants of which the amaranth is the type.","pos":""}],"AMARANTH":[{"def":"A genus of ornamental annual plants (Amaranthus) of many species, with green, purplish, or crimson flowers.","pos":""}],"AMARANTHINE":[{"def":"Same as Amaranth.","pos":""}],"AMARINE":[{"def":"A characteristic crystalline substance, obtained from oil of bitter almonds.","pos":""}],"AMARITUDE":[{"def":"AMARYLLIDACEOUS; AMARYLLIDEOUS Am`a*ryl`li*da\"ceous, Am`a*ryl*lid\"e*ous, a.","pos":""}],"AMARYLLIS":[{"def":"A pastoral sweetheart.","pos":""}],"AMASS":[{"def":"To collect into a mass or heap; to gather a great quantity of; to accumulate; as, to amass a treasure or a fortune; to amass words or phrases.","pos":""}],"AMASSABLE":[{"def":"Capable of being amassed.","pos":""}],"AMASSER":[{"def":"One who amasses.","pos":""}],"AMASSETTE":[{"def":"An instrument of horn used for collecting painters' colors on the stone in the process of grinding.","pos":""}],"AMASSMENT":[{"def":"An amassing; a heap collected; a large quantity or number brought together; an accumulation.","pos":""}],"AMASTHENIC":[{"def":"Uniting the chemical rays of light into one focus, as a certain kind of lens; amacratic.","pos":""}],"AMATE":[{"def":"To dismay; to dishearten; to daunt.","pos":""}],"AMATEUR":[{"def":"A person attached to a particular pursuit, study, or science as to music or painting; esp.","pos":""}],"AMATEURISH":[{"def":"In the style of an amateur; superficial or defective like the work of an amateur.","pos":""}],"AMATEURISM":[{"def":"The practice, habit, or work of an amateur.","pos":""}],"AMATEURSHIP":[{"def":"The quality or character of an amateur.","pos":""}],"AMATIVE":[{"def":"Full of love; amatory.","pos":""}],"AMATIVENESS":[{"def":"The faculty supposed to influence sexual desire; propensity to love.","pos":""}],"AMATORIAL":[{"def":"Of or pertaining to a lover or to love making; amatory; as, amatorial verses.","pos":""}],"AMATORIALLY":[{"def":"In an amatorial manner.","pos":""}],"AMATORY":[{"def":"Pertaining to, producing, or expressing, sexual love; as, amatory potions.","pos":""}],"AMAUROSIS":[{"def":"A loss or decay of sight, from loss of power in the optic nerve, without any perceptible external change in the eye; -- called also gutta serena, the \"drop serene\" of Milton.","pos":""}],"AMAUROTIC":[{"def":"Affected with amaurosis; having the characteristics of amaurosis.","pos":""}],"AMAZE":[{"def":"To bewilder; to stupefy; to bring into a maze.","pos":""},{"def":"To confound, as by fear, wonder, extreme surprise; to overwhelm with wonder; to astound; to astonish greatly.","pos":""}],"AMAZEDLY":[{"def":"In amazement; with confusion or astonishment.","pos":""}],"AMAZEDNESS":[{"def":"The state of being amazed, or confounded with fear, surprise, or wonder.","pos":""}],"AMAZEFUL":[{"def":"Full of amazement.","pos":""}],"AMAZEMENT":[{"def":"The condition of being amazed; bewilderment [Obs.","pos":""},{"def":"Frenzy; madness.","pos":""}],"AMAZING":[{"def":"Causing amazement; very wonderful; as, amazing grace.","pos":""}],"AMAZON":[{"def":"A name numerous species of South American parrots of the genus Chrysotis Amazon ant (Zoöl.","pos":""}],"AMAZONIAN":[{"def":"A variety of feldspar, having a verdigris-green color.","pos":""},{"def":"A prefix meaning about, around; -- used in words derived from the Latin.","pos":""}]}