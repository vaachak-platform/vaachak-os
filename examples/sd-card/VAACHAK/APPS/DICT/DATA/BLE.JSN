{"BLEA":[{"def":"The part of a tree which lies immediately under the bark; the alburnum or sapwood.","pos":""}],"BLEACH":[{"def":"To make white, or whiter; to remove the color, or stains, from; to blanch; to whiten.","pos":""}],"BLEACHED":[{"def":"Whitened; make white.","pos":""}],"BLEACHER":[{"def":"One who whitens, or whose occupation is to whiten, by bleaching.","pos":""}],"BLEACHERY":[{"def":"A place or an establishment where bleaching is done.","pos":""}],"BLEACHING":[{"def":"The act or process of whitening, by removing color or stains; esp.","pos":""}],"BLEAK":[{"def":"Without color; pale; pallid.","pos":""},{"def":"Desolate and exposed; swept by cold winds.","pos":""}],"BLEAR":[{"def":"Dim or sore with water or rheum; -- said of the eyes.","pos":""},{"def":"Causing or caused by dimness of sight; dim.","pos":""}],"BLEAR-EYED":[{"def":"Having sore eyes; having the eyes dim with rheum; dim-sighted.","pos":""},{"def":"Lacking in perception or penetration; short-sighted; as, a blear- eyed bigot.","pos":""}],"BLEARED":[{"def":"Dimmed, as by a watery humor; affected with rheum.","pos":""}],"BLEAREYE":[{"def":"A disease of the eyelids, consisting in chronic inflammation of the margins, with a gummy secretion of sebaceous matter.","pos":""}],"BLEAREYEDNESS":[{"def":"The state of being blear-eyed.","pos":""}],"BLEAT":[{"def":"To make the noise of, or one like that of, a sheep; to cry like a sheep or calf.","pos":""}],"BLEATER":[{"def":"One who bleats; a sheep.","pos":""}],"BLEATING":[{"def":"Crying as a sheep does.","pos":""}],"BLEB":[{"def":"A large vesicle or bulla, usually containing a serous fluid; a blister; a bubble, as in water, glass, etc.","pos":""}],"BLEBBY":[{"def":"Containing blebs, or characterized by blebs; as, blebby glass.","pos":""},{"def":"To blacken; also, to defile.","pos":""}],"BLEE":[{"def":"Complexion; color; hue; likeness; form.","pos":""}],"BLEED":[{"def":"To emit blood; to lose blood; to run with blood, by whatever means; as, the arm bleeds; the wound bled freely; to bleed at the nose.","pos":""},{"def":"To withdraw blood from the body; to let blood; as, Dr.","pos":""}],"BLEEDING":[{"def":"Emitting, or appearing to emit, blood or sap, etc.","pos":""}],"BLEMISH":[{"def":"To mark with deformity; to injure or impair, as anything which is well formed, or excellent; to mar, or make defective, either the body or mind.","pos":""},{"def":"To tarnish, as reputation or character; to defame.","pos":""}],"BLEMISHLESS":[{"def":"Without blemish; spotless.","pos":""}],"BLEMISHMENT":[{"def":"The state of being blemished; blemish; disgrace; damage; impairment.","pos":""}],"BLENCH":[{"def":"To shrink; to start back; to draw back, from lack of courage or resolution; to flinch; to quail.","pos":""},{"def":"To fly off; to turn aside.","pos":""}],"BLENCH HOLDING":[{"def":"See Blanch holding.","pos":""}],"BLENCHER":[{"def":"One who, or that which, scares another; specifically, a person stationed to prevent the escape of the deer, at a hunt.","pos":""},{"def":"One who blenches, flinches, or shrinks back.","pos":""}],"BLEND":[{"def":"To mix or mingle together; esp.","pos":""},{"def":"To pollute by mixture or association; to spoil or corrupt; to blot; to stain.","pos":""}],"BLENDER":[{"def":"One who, or that which, blends; an instrument, as a brush, used in blending.","pos":""}],"BLENDING":[{"def":"The method of laying on different tints so that they may mingle together while wet, and shade into each other insensibly.","pos":""}],"BLENDOUS":[{"def":"Pertaining to, consisting of, or containing, blende.","pos":""}],"BLENDWATER":[{"def":"A distemper incident to cattle, in which their livers are affected.","pos":""}],"BLENHEIM SPANIEL":[{"def":"A small variety of spaniel, kept as a pet.","pos":""}],"BLENK":[{"def":"To blink; to shine; to look.","pos":""},{"def":"Of, pertaining to, or resembling, the blennies.","pos":""}],"BLENNOGENOUS":[{"def":"Generating mucus.","pos":""}],"BLENNY":[{"def":"A marine fish of the genus Blennius or family Blenniidæ; -- so called from its coating of mucus.","pos":""}],"BLENT":[{"def":"Mingled; mixed; blended; also, polluted; stained.","pos":""}],"BLEPHARITIS":[{"def":"Inflammation of the eyelids.","pos":""}],"BLESBOK":[{"def":"A South African antelope (Alcelaphus albifrons), having a large white spot on the forehead.","pos":""}],"BLESS":[{"def":"To make or pronounce holy; to consecrate And God blessed the seventh day, and sanctified it.","pos":""},{"def":"To make happy, blithesome, or joyous; to confer prosperity or happiness upon; to grant divine favor to.","pos":""}],"BLESSED":[{"def":"Hallowed; consecrated; worthy of blessing or adoration; heavenly; holy.","pos":""},{"def":"Enjoying happiness or bliss; favored with blessings; happy; highly favored.","pos":""}],"BLESSED THISTLE":[{"def":"See under Thistle.","pos":""}],"BLESSEDLY":[{"def":"Happily; fortunately; joyfully.","pos":""}],"BLESSEDNESS":[{"def":"The state of being blessed; happiness; felicity; bliss; heavenly joys; the favor of God.","pos":""}],"BLESSER":[{"def":"One who blesses; one who bestows or invokes a blessing.","pos":""}],"BLESSING":[{"def":"The act of one who blesses.","pos":""},{"def":"A declaration of divine favor, or an invocation imploring divine favor on some or something; a benediction; a wish of happiness pronounces.","pos":""}],"BLEST":[{"def":"White these blest sounds my ravished ear assail.","pos":""}],"BLET":[{"def":"A form of decay in fruit which is overripe.","pos":""}],"BLETONISM":[{"def":"The supposed faculty of perceiving subterraneous springs and currents by sensation; -- so called from one Bleton, of France.","pos":""}],"BLETTING":[{"def":"A form of decay seen in fleshy, overripe fruit.","pos":""}],"BLEYME":[{"def":"An inflammation in the foot of a horse, between the sole and the bone.","pos":""}]}