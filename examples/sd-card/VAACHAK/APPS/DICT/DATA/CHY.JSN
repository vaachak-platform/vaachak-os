{"CHYLACEOUS":[{"def":"Possessed of the properties of chyle; consisting of chyle.","pos":""}],"CHYLAQUEOUS":[{"def":"Consisting of chyle much diluted with water; -- said of a liquid which forms the circulating fluid of some inferior animals.","pos":""}],"CHYLE":[{"def":"A milky fluid containing the fatty matter of the food in a state of emulsion, or fine mechanical division; formed from chyme by the action of the intestinal juices.","pos":""}],"CHYLIFACTION":[{"def":"The act or process by which chyle is formed from food in animal bodies; chylification, -- a digestive process.","pos":""}],"CHYLIFACTIVE":[{"def":"Producing, or converting into, chyle; having the power to form chyle.","pos":""}],"CHYLIFEROUS":[{"def":"[Chyle + -ferous: cf.","pos":""}],"CHYLIFICATION":[{"def":"The formation of chyle.","pos":""}],"CHYLIFICATORY":[{"def":"Chy*lif\"i*ca*to*ry ( or ), a.","pos":""}],"CHYLIFY":[{"def":"To make chyle of; to be converted into chyle.","pos":""}],"CHYLOPOETIC":[{"def":"Concerned in the formation of chyle; as, the chylopoetic organs.","pos":""}],"CHYLOUS":[{"def":"Consisting of, or similar to, chyle.","pos":""}],"CHYLURIA":[{"def":"A morbid condition in which the urine contains chyle or fatty matter, giving it a milky appearance.","pos":""}],"CHYME":[{"def":"The pulpy mass of semi-digested food in the small intestines just after its passage from the stomach.","pos":""},{"def":"See Chemic, Chemist, Chemistry.","pos":""}],"CHYMIFEROUS":[{"def":"Bearing or containing chyme.","pos":""}],"CHYMIFICATION":[{"def":"The conversion of food into chyme by the digestive action of gastric juice.","pos":""}],"CHYMIFY":[{"def":"To form into chyme.","pos":""}],"CHYMOUS":[{"def":"Of or pertaining to chyme.","pos":""}],"CHYOMETER":[{"def":"An instrument for measuring liquids.","pos":""}]}