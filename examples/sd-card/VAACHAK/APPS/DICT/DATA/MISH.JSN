{"MISHANDLE":[{"def":"To handle ill or wrongly; to maltreat.","pos":""}],"MISHAP":[{"def":"Evil accident; ill luck; misfortune; mischance.","pos":""}],"MISHAPPEN":[{"def":"To happen ill or unluckily.","pos":""}],"MISHEAR":[{"def":"To hear incorrectly.","pos":""}],"MISHNA":[{"def":"A collection or digest of Jewish traditions and explanations of Scripture, forming the text of the Talmud.","pos":""}],"MISHNIC":[{"def":"Of or pertaining to the Mishna.","pos":""}]}