{"POLYTECHNIC":[{"def":"Comprehending, or relating to, many arts and sciences; -- applied particularly to schools in which many branches of art and science are taught with especial reference to their practical application; also to exhibitions of machinery and industrial products.","pos":""}],"POLYTECHNICS":[{"def":"The science of the mechanic arts.","pos":""}],"POLYTHALAMIA":[{"def":"A division of Foraminifera including those having a manychambered shell.","pos":""}],"POLYTHALAMOUS":[{"def":"Many-chambered; -- applied to shells of Foraminifera and cephalopods.","pos":""}],"POLYTHEISM":[{"def":"The doctrine of, or belief in, a plurality of gods.","pos":""}],"POLYTHEIST":[{"def":"One who believes in, or maintains the doctrine of, a plurality of gods.","pos":""},{"def":"Of or pertaining to polytheism; characterized by polytheism; professing or advocating polytheism; as, polytheistic worship; a polytheistic author, or nation.","pos":""}],"POLYTHEIZE":[{"def":"To adhere to, advocate, or inculcate, the doctrine of polytheism.","pos":""}],"POLYTHELISM":[{"def":"The condition of having more than two teats, or nipples.","pos":""}],"POLYTOCOUS":[{"def":"Bearing fruit repeatedly, as most perennial plants; polycarpic.","pos":""},{"def":"Producing many or young.","pos":""}],"POLYTOMOUS":[{"def":"Subdivided into many distinct subordinate parts, which, however, not being jointed to the petiole, are not true leaflets; -- said of leaves.","pos":""}],"POLYTOMY":[{"def":"A division into many members.","pos":""}],"POLYTUNGSTATE":[{"def":"A salt of polytungstic acid.","pos":""}],"POLYTUNGSTIC":[{"def":"Containing several tungsten atoms or radicals; as, polytungstic acid.","pos":""}],"POLYTYPE":[{"def":"A cast, or facsimile copy, of an engraved block, matter in type, etc.","pos":""}]}