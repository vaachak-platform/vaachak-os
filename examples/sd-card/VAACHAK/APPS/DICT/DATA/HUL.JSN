{"HULCHY":[{"def":"Swollen; gibbous.","pos":""}],"HULK":[{"def":"The body of a ship or decked vessel of any kind; esp.","pos":""},{"def":"A heavy ship of clumsy build.","pos":""}],"HULL":[{"def":"The frame or body of a vessel, exclusive of her masts, yards, sails, and rigging.","pos":""}],"HULLABALOO":[{"def":"A confused noise; uproar; tumult.","pos":""}],"HULLED":[{"def":"Deprived of the hulls.","pos":""}],"HULLER":[{"def":"One who, or that which, hulls; especially, an agricultural machine for removing the hulls from grain; a hulling machine.","pos":""}],"HULLY":[{"def":"Having or containing hulls.","pos":""}],"HULVER":[{"def":"Holly, an evergreen shrub or tree.","pos":""}]}