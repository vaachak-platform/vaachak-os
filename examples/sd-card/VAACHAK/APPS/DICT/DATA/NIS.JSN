{"NISAN":[{"def":"The first month of the jewish ecclesiastical year, formerly answering nearly to the month of April, now to March, of the Christian calendar.","pos":""}],"NISI":[{"def":"Note: In legal proceedings, this word is used to indicate that any order, etc.","pos":""}],"NISTE":[{"def":"Wist not; knew not.","pos":""}],"NISUS":[{"def":"A striving; an effort; a conatus.","pos":""}]}