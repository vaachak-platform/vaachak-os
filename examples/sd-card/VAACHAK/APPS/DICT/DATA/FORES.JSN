{"FORESAID":[{"def":"Mentioned before; aforesaid.","pos":""}],"FORESAY":[{"def":"Her danger nigh that sudden change foresaid.","pos":""}],"FORESEE":[{"def":"To see beforehand; to have prescience of; to foreknow.","pos":""}],"FORESEEN":[{"def":", or (strictly) p.","pos":""}],"FORESEER":[{"def":"One who foresees or foreknows.","pos":""}],"FORESEIZE":[{"def":"To seize beforehand.","pos":""}],"FORESHADOW":[{"def":"To shadow or typi Dryden.","pos":""}],"FORESHIP":[{"def":"The fore part of a ship.","pos":""}],"FORESHORTEN":[{"def":"To represent on a plane surface, as if extended in a direction toward the spectator or nearly so; to shorten by drawing in perspective.","pos":""}],"FORESHORTENING":[{"def":"Representation in a foreshortened mode or way.","pos":""}],"FORESHOT":[{"def":"In distillation of low wines, the first portion of spirit that comes over, being a fluid abounding in fusel oil.","pos":""}],"FORESHOW":[{"def":"To show or exhibit beforehand; to give foreknowledge of; to prognosticate; to foretell.","pos":""}],"FORESHOWER":[{"def":"One who predicts.","pos":""}],"FORESIDE":[{"def":"The front side; the front; esp.","pos":""},{"def":"The outside or external covering.","pos":""}],"FORESIGHT":[{"def":"Any sight or reading of the leveling staff, except the backsight; any sight or bearing taken by a compass or theodolite in a forward direction.","pos":""}],"FORESIGHTED":[{"def":"Sagacious; prudent; provident for the future.","pos":""}],"FORESIGNIFY":[{"def":"To signify beforehand; to foreshow; to typify.","pos":""}],"FORESKIN":[{"def":"The fold of skin which covers the glans of the penis; the prepuce.","pos":""}],"FORESKIRT":[{"def":"The front skirt of a garment, in distinction from the train.","pos":""}],"FORESLEEVE":[{"def":"The sleeve below the elbow.","pos":""}],"FORESLOW":[{"def":"To make slow; to hinder; to obstruct.","pos":""}],"FORESPEAK":[{"def":"To foretell; to predict.","pos":""}],"FORESPEAKING":[{"def":"A prediction; also, a preface.","pos":""}],"FORESPENT":[{"def":"Already spent; gone by; past.","pos":""}],"FORESPURRER":[{"def":"One who rides before; a harbinger.","pos":""}],"FOREST":[{"def":"A large extent or precinct of country, generally waste and woody, belonging to the sovereign, set apart for the keeping of game for his use, not inclosed, but distinguished by certain limits, and protected by certain laws, courts, and officers of its own.","pos":""}],"FORESTAFF":[{"def":"An instrument formerly used at sea for taking the altitudes of heavenly bodies, now superseded by the sextant; -- called also cross- staff.","pos":""}],"FORESTAL":[{"def":"Of or pertaining to forests; as, forestal rights.","pos":""}],"FORESTALL":[{"def":"To obstruct or stop up, as a way; to stop the passage of on highway; to intercept on the road, as goods on the way to market.","pos":""}],"FORESTALLER":[{"def":"One who forestalls; esp.","pos":""}],"FORESTAY":[{"def":"A large, strong rope, reaching from the foremast head to the bowsprit, to support the mast.","pos":""}],"FORESTER":[{"def":"A lepidopterous insect belonging to Alypia and allied genera; as, the eight-spotted forester (A.","pos":""}],"FORESTICK":[{"def":"Front stick of a hearth fire.","pos":""}],"FORESTRY":[{"def":"The art of forming or of cultivating forests; the management of growing timber.","pos":""}]}