{"SAX":[{"def":"A kind of chopping instrument for trimming the edges of roofing slates.","pos":""}],"SAX-TUBA":[{"def":"A powerful instrument of brass, curved somewhat like the Roman buccina, or tuba.","pos":""}],"SAXATILE":[{"def":"Of or pertaining to rocks; living among rocks; as, a saxatile plant.","pos":""}],"SAXHORN":[{"def":"A name given to a numerous family of brass wind instruments with valves, invented by Antoine Joseph Sax (known as Adolphe Sax), of Belgium and Paris, and much used in military bands and in orchestras.","pos":""}],"SAXICAVA":[{"def":"Any species of marine bivalve shells of the genus Saxicava.","pos":""}],"SAXICAVID":[{"def":"Of or pertaining to the saxicavas.","pos":""}],"SAXICAVOUS":[{"def":"Boring, or hollowing out, rocks; -- said of certain mollusks which live in holes which they burrow in rocks.","pos":""}],"SAXICOLINE":[{"def":"Stone-inhabiting; pertaining to, or having the characteristics of, the stonechats.","pos":""}],"SAXICOLOUS":[{"def":"Growing on rocks.","pos":""}],"SAXIFRAGA":[{"def":"A genus of exogenous polypetalous plants, embracing about one hundred and eighty species.","pos":""}],"SAXIFRAGACEOUS":[{"def":"Of or pertaining to a natural order of plants (Saxifragaceæ) of which saxifrage is the type.","pos":""}],"SAXIFRAGANT":[{"def":"Breaking or destroying stones; saxifragous.","pos":""},{"def":"That which breaks or destroys stones.","pos":""}],"SAXIFRAGE":[{"def":"Any plant of the genus Saxifraga, mostly perennial herbs growing in crevices of rocks in mountainous regions.","pos":""}],"SAXIFRAGOUS":[{"def":"Dissolving stone, especially dissolving stone in the bladder.","pos":""}],"SAXON":[{"def":"The language of the Saxons; Anglo-Saxon.","pos":""}],"SAXONIC":[{"def":"relating to the saxons or Anglo-Saxons.","pos":""}],"SAXONISM":[{"def":"An idiom of the Saxon or Anglo-Saxon language.","pos":""}],"SAXONIST":[{"def":"One versed in the Saxon language.","pos":""}],"SAXONITE":[{"def":"See Mountain soap, under Mountain.","pos":""}],"SAXONY":[{"def":"A kind of glossy woolen cloth formerly much used.","pos":""},{"def":"Saxony yarn, or flannel made of it or similar yarn.","pos":""}],"SAXONY YARN":[{"def":"A fine grade of woolen yarn twisted somewhat harder and smoother than zephyr yarn.","pos":""}],"SAXOPHONE":[{"def":"A wind instrument of brass, containing a reed, and partaking of the qualities both of a brass instrument and of a clarinet.","pos":""}]}