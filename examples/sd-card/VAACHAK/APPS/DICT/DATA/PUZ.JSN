{"PUZZEL":[{"def":"A harlot; a drab; a hussy.","pos":""}],"PUZZLE":[{"def":"Something which perplexes or embarrasses; especially, a toy or a problem contrived for testing ingenuity; also, something exhibiting marvelous skill in making.","pos":""},{"def":"The state of being puzzled; perplexity; as, to be in a puzzle.","pos":""}],"PUZZLE-HEADED":[{"def":"Having the head full of confused notions.","pos":""}],"PUZZLEDOM":[{"def":"The domain of puzzles; puzzles, collectively.","pos":""}],"PUZZLEMENT":[{"def":"The state of being puzzled; perplexity.","pos":""}],"PUZZLER":[{"def":"One who, or that which, puzzles or perplexes.","pos":""}],"PUZZLINGLY":[{"def":"In a puzzling manner.","pos":""}]}