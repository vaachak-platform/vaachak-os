{"ANTIQUARIAN":[{"def":"Pertaining to antiquaries, or to antiquity; as, antiquarian literature.","pos":""}],"ANTIQUARIANISM":[{"def":"Character of an antiquary; study or love of antiquities.","pos":""}],"ANTIQUARIANIZE":[{"def":"To act the part of an antiquary.","pos":""}],"ANTIQUARY":[{"def":"Pertaining to antiquity.","pos":""}],"ANTIQUATE":[{"def":"To make old, or obsolete; to make antique; to make old in such a degree as to put out of use; hence, to make void, or abrogate.","pos":""}],"ANTIQUATED":[{"def":"Old Janet, for so he understood his antiquated attendant was denominated.","pos":""}],"ANTIQUATEDNESS":[{"def":"Quality of being antiquated.","pos":""}],"ANTIQUATION":[{"def":"The act of making antiquated, or the state of being antiquated.","pos":""}],"ANTIQUE":[{"def":"Old; ancient; of genuine antiquity; as, an antique statue.","pos":""},{"def":"Old, as respects the present age, or a modern period of time; of old fashion; antiquated; as, an antique robe.","pos":""}],"ANTIQUELY":[{"def":"In an antique manner.","pos":""}],"ANTIQUENESS":[{"def":"The quality of being antique; an appearance of ancient origin and workmanship.","pos":""}],"ANTIQUIST":[{"def":"An antiquary; a collector of antiques.","pos":""}],"ANTIQUITARIAN":[{"def":"An admirer of antiquity.","pos":""}],"ANTIQUITY":[{"def":"The quality of being ancient; ancientness; great age; as, a statue of remarkable antiquity; a family of great antiquity.","pos":""}]}