{"FIE":[{"def":"An exclamation denoting contempt or dislike.","pos":""}],"FIEF":[{"def":"An estate held of a superior on condition of military service; a fee; a feud.","pos":""}],"FIELD":[{"def":"The whole surface of an escutcheon; also, so much of it is shown unconcealed by the different bearings upon it.","pos":""},{"def":"That part of the grounds reserved for the players which is outside of the diamond; -- called also outfield.","pos":""}],"FIELDED":[{"def":"Engaged in the field; encamped.","pos":""}],"FIELDEN":[{"def":"Consisting of fields.","pos":""}],"FIELDER":[{"def":"A ball payer who stands out in the field to catch or stop balls.","pos":""}],"FIELDFARE":[{"def":"a small thrush (Turdus pilaris) which breeds in northern Europe and winters in Great Britain.","pos":""}],"FIELDING":[{"def":"The act of playing as a fielder.","pos":""}],"FIELDPIECE":[{"def":"A cannon mounted on wheels, for the use of a marching army; a piece of field artillery; -- called also field gun.","pos":""}],"FIELDWORK":[{"def":"Any temporary fortification thrown up by an army in the field; -- commonly in the plural.","pos":""}],"FIELDY":[{"def":"Open, like a field.","pos":""}],"FIEND":[{"def":"An implacable or malicious foe; one who is diabolically wicked or cruel; an infernal being; -- applied specifically to the devil or a demon.","pos":""}],"FIENDFUL":[{"def":"Full of fiendish spirit or arts.","pos":""}],"FIENDISH":[{"def":"Like a fiend; diabolically wicked or cruel; infernal; malignant; devilish; hellish.","pos":""}],"FIENDLIKE":[{"def":"Fiendish; diabolical.","pos":""}],"FIENDLY":[{"def":"Fiendlike; monstrous; devilish.","pos":""}],"FIERASFER":[{"def":"A genus of small, slender fishes, remarkable for their habit of living as commensals in other animals.","pos":""}],"FIERCE":[{"def":"Furious; violent; unrestrained; impetuous; as, a fierce wind.","pos":""},{"def":"Vehement in anger or cruelty; ready or eager to kill or injure; of a nature to inspire terror; ferocious.","pos":""}],"FIERI FACIAS":[{"def":"A judicial writ that lies for one who has recovered in debt or damages, commanding the sheriff that he cause to be made of the goods, chattels, or real estate of the defendant, the sum claimed.","pos":""}],"FIERINESS":[{"def":"The quality of being fiery; heat; acrimony; irritability; as, a fieriness of temper.","pos":""}],"FIERY":[{"def":"Consisting of, containing, or resembling, fire; as, the fiery gulf of Etna; a fiery appearance.","pos":""},{"def":"Vehement; ardent; very active; impetuous.","pos":""}],"FIESTA":[{"def":"Among Spanish, a religious festival; a saint's day or holiday; also, a holiday or festivity.","pos":""}]}