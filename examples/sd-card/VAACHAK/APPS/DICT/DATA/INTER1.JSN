{"INTER":[{"def":"To deposit and cover in the earth; to bury; to inhume; as, to inter a dead body.","pos":""}],"INTER-":[{"def":"A prefix signifying among, between, amid; as, interact, interarticular, intermit.","pos":""}],"INTERACT":[{"def":"A short act or piece between others, as in a play; an interlude; hence, intermediate employment or time.","pos":""}],"INTERACTION":[{"def":"Intermediate action.","pos":""},{"def":"Mutual or reciprocal action or influence; as, the interaction of the heart and lungs on each other.","pos":""}],"INTERADDITIVE":[{"def":"Added or placed between the parts of another thing, as a clause inserted parenthetically in a sentence.","pos":""}],"INTERAGENCY":[{"def":"Intermediate agency.","pos":""}],"INTERAGENT":[{"def":"An intermediate agent.","pos":""}],"INTERALL":[{"def":"Entrail or inside.","pos":""}],"INTERALVEOLAR":[{"def":"Between alveoli; as, the interalveolar septa between adjacent air cells in the lungs.","pos":""}],"INTERAMBULACRAL":[{"def":"Of or pertaining to the interambulacra.","pos":""}],"INTERAMBULACRUM":[{"def":"In echinoderms, one of the areas or zones intervening between two ambulacra.","pos":""}],"INTERAMNIAN":[{"def":"Situated between rivers.","pos":""}],"INTERANIMATE":[{"def":"To animate or inspire mutually.","pos":""}],"INTERARBORATION":[{"def":"The interweaving of branches of trees.","pos":""}],"INTERARTICULAR":[{"def":"Situated between joints or articulations; as, interarticular cartilages and ligaments.","pos":""}],"INTERATOMIC":[{"def":"Between atoms; situated, or acting, between the atoms of bodies; as, interatomic forces.","pos":""}],"INTERAULIC":[{"def":"Existing between royal courts.","pos":""}],"INTERAURICULAR":[{"def":"Between the auricles; as, the interauricular partition of the heart.","pos":""}],"INTERAXAL":[{"def":"Situated in an interaxis.","pos":""}],"INTERAXILLARY":[{"def":"Situated within or between the axils of leaves.","pos":""}],"INTERAXIS":[{"def":"The space between two axes.","pos":""}],"INTERBASTATION":[{"def":"In`ter*bas*ta\"tion, n.","pos":""}],"INTERBRACHIAL":[{"def":"Between the arms.","pos":""}],"INTERBRAIN":[{"def":"See Thalamencephalon.","pos":""}],"INTERBRANCHIAL":[{"def":"Between the branchiæ.","pos":""}],"INTERBREED":[{"def":"To breed by crossing different stocks of animals or plants.","pos":""}],"INTERCALARY":[{"def":"Inserted or introduced among others in the calendar; as, an intercalary month, day, etc.","pos":""}],"INTERCALATE":[{"def":"To insert, as a day or other portion of time, in a calendar.","pos":""}],"INTERCALATION":[{"def":"The insertion of a day, or other portion of time, in a calendar.","pos":""}],"INTERCAROTID":[{"def":"Situated between the external and internal carotid arteries; as, an intercarotid ganglion.","pos":""}],"INTERCARPAL":[{"def":"Between the carpal bone; as, intercarpal articulations, ligaments.","pos":""}],"INTERCARTILAGINOUS":[{"def":"Within cartilage; endochondral; as, intercartilaginous ossification.","pos":""}],"INTERCAVERNOUS":[{"def":"Between the cavernous sinuses; as, the intercavernous sinuses connecting the cavernous sinuses at the base of the brain.","pos":""}],"INTERCEDE":[{"def":"To pass between; to intervene.","pos":""},{"def":"To act between parties with a view to reconcile differences; to make intercession; to beg or plead in behalf of another; to mediate; -- usually followed by with and for; as, I will intercede with him for you.","pos":""}],"INTERCEDENCE":[{"def":"The act of interceding; intercession; intervention.","pos":""}],"INTERCEDENT":[{"def":"Passing between; mediating; pleading.","pos":""}],"INTERCEDER":[{"def":"One who intercedes; an intercessor; a mediator.","pos":""}],"INTERCELLULAR":[{"def":"Lying between cells or cellules; as, intercellular substance, space, or fluids; intercellular blood channels.","pos":""}],"INTERCENTRAL":[{"def":"Between centers.","pos":""}],"INTERCENTRUM":[{"def":"The median of the three elements composing the centra of the vertebræ in some fossil batrachians.","pos":""}],"INTERCEPT":[{"def":"To include between; as, that part of the intercepted between the points A and B.","pos":""}],"INTERCEPTER":[{"def":"One who, or that which, intercepts.","pos":""}],"INTERCEPTION":[{"def":"The act of intercepting; as, interception of a letter; interception of the enemy.","pos":""}],"INTERCEPTIVE":[{"def":"Intercepting or tending to intercept.","pos":""}],"INTERCESSION":[{"def":"The act of interceding; mediation; interposition between parties at variance, with a view to reconcilation; prayer, petition, or entreaty in favor of, or (less often) against, another or others.","pos":""}],"INTERCESSIONAL":[{"def":"Pertaining to, of the nature of, or characterized by, intercession or entreaty.","pos":""}],"INTERCESSIONATE":[{"def":"In`ter*ces\"sion*ate, v.","pos":""}],"INTERCESSOR":[{"def":"A bishop, who, during a vacancy of the see, administers the bishopric till a successor is installed.","pos":""}],"INTERCESSORIAL":[{"def":"In`ter*ces*so\"ri*al, a.","pos":""}],"INTERCESSORY":[{"def":"Pertaining to, of the nature of, or characterized by, intercession; interceding; as, intercessory prayer.","pos":""}],"INTERCHAIN":[{"def":"To link together; to unite closely or firmly, as by a chain.","pos":""}],"INTERCHANGE":[{"def":"To put each in the place of the other; to give and take mutually; to exchange; to reciprocate; as, to interchange places; they interchanged friendly offices and services.","pos":""},{"def":"To cause to follow alternately; to intermingle; to vary; as, to interchange cares with pleasures.","pos":""}],"INTERCHANGEABILITY":[{"def":"The state or quality of being interchangeable; interchangeableness.","pos":""}],"INTERCHANGEABLE":[{"def":"Admitting of exchange or mutual substitution.","pos":""},{"def":"Following each other in alternate succession; as, the four interchangeable seasons.","pos":""}],"INTERCHANGEMENT":[{"def":"Mutual transfer; exchange.","pos":""}],"INTERCHAPTER":[{"def":"An intervening or inserted chapter.","pos":""}],"INTERCIDENCE":[{"def":"The act or state of coming or falling between; occurrence; incident.","pos":""}],"INTERCIDENT":[{"def":"Falling or coming between; happening accidentally.","pos":""}],"INTERCIPIENT":[{"def":"Intercepting; stopping.","pos":""},{"def":"One who, or that which, intercepts or stops anything on the passage.","pos":""}],"INTERCISION":[{"def":"A cutting off, through, or asunder; interruption.","pos":""}],"INTERCITIZENSHIP":[{"def":"The mutual right to civic privileges, in the different States.","pos":""}],"INTERCLAVICULAR":[{"def":"In`ter*cla*vic\"u*lar, a.","pos":""}],"INTERCLOSE":[{"def":"To shut in; to inclose.","pos":""}],"INTERCLUDE":[{"def":"To shut off or out from a place or course, by something intervening; to intercept; to cut off; to interrupt.","pos":""}],"INTERCOLLEGIATE":[{"def":"Existing or carried on between colleges or universities; as, intercollegiate relations, rivalry, games, etc.","pos":""}],"INTERCOLLINE":[{"def":"Situated between hills; -- applied especially to valleys lying between volcanic cones.","pos":""}],"INTERCOLONIAL":[{"def":"Between or among colonies; pertaining to the intercourse or mutual relations of colonies; as, intercolonial trade.","pos":""}],"INTERCOLUMNAR":[{"def":"Between columns or pillars; as, the intercolumnar fibers of Poupart's ligament; an intercolumnar statue.","pos":""}],"INTERCOLUMNIATION":[{"def":"The clear space between two columns, measured at the bottom of their shafts.","pos":""}],"INTERCOMING":[{"def":"The act of coming between; intervention; interference.","pos":""}],"INTERCOMMON":[{"def":"To graze cattle promiscuously in the commons of each other, as the inhabitants of adjoining townships, manors, etc.","pos":""}],"INTERCOMMONAGE":[{"def":"The right or privilege of intercommoning.","pos":""}],"INTERCOMMUNE":[{"def":"To intercommunicate.","pos":""},{"def":"To have mutual communication or intercourse by conservation.","pos":""}],"INTERCOMMUNICABLE":[{"def":"Capable of being mutually communicated.","pos":""}],"INTERCOMMUNICATE":[{"def":"To communicate mutually; to hold mutual communication.","pos":""}],"INTERCOMMUNICATION":[{"def":"Mutual communication.","pos":""}],"INTERCOMMUNION":[{"def":"Mutual communion; as, an intercommunion of deities.","pos":""}],"INTERCOMMUNITY":[{"def":"Intercommunication; community of possessions, religion, etc.","pos":""}],"INTERCOMPARISON":[{"def":"Mutual comparison of corresponding parts.","pos":""},{"def":"Between condyles; as, the intercondylar fossa or notch of the femur.","pos":""}],"INTERCONNECT":[{"def":"To join together.","pos":""}],"INTERCONNECTION":[{"def":"Connection between; mutual connection.","pos":""}],"INTERCONTINENTAL":[{"def":"Between or among continents; subsisting or carried on between continents; as, intercontinental relations or commerce.","pos":""}],"INTERCONVERTIBLE":[{"def":"Convertible the one into the other; as, coin and bank notes are interconvertible.","pos":""}],"INTERCOSTAL":[{"def":"Between the ribs; pertaining to, or produced by, the parts between the ribs; as, intercostal respiration, in which the chest is alternately enlarged and contracted by the intercostal muscles.","pos":""}],"INTERCOURSE":[{"def":"A This sweet intercourse Of looks and smiles.","pos":""}],"INTERCROP":[{"def":"To cultivate by planting simultaneous crops in alternate rows; as, to intercrop an orchard.","pos":""}],"INTERCROSS":[{"def":"To fertilize by the impregnation of one species or variety by another; to impregnate by a different species or variety.","pos":""}],"INTERCRURAL":[{"def":"Between crura; -- applied especially to the interneural plates in the vertebral column of many cartilaginous fishes.","pos":""}],"INTERCUR":[{"def":"To intervene; to come or occur in the meantime.","pos":""}],"INTERCURRENCE":[{"def":"A passing or running between; occurrence.","pos":""}],"INTERCURRENT":[{"def":"Running between or among; intervening.","pos":""}],"INTERCUTANEOUS":[{"def":"In`ter*cu*ta\"ne*ous, a.","pos":""}],"INTERDASH":[{"def":"To dash between or among; to intersperse.","pos":""}],"INTERDENOMINATIONAL":[{"def":"Occurring between or among, or common to, different denominations; as, interdenominational fellowship or belief.","pos":""}],"INTERDENTAL":[{"def":"Formed between the upper and lower teeth; as, interdental consonants.","pos":""}],"INTERDENTIL":[{"def":"The space between two dentils.","pos":""}],"INTERDEPENDENCE":[{"def":"Mutual dependence.","pos":""}],"INTERDEPENDENCY":[{"def":"Mutual dependence; as, interdependency of interests.","pos":""}],"INTERDEPENDENT":[{"def":"Mutually dependent.","pos":""}],"INTERDICT":[{"def":"To lay under an interdict; to cut off from the enjoyment of religious privileges, as a city, a church, an individual.","pos":""}],"INTERDICTION":[{"def":"The act of interdicting; prohibition; prohibiting decree; curse; interdict.","pos":""}],"INTERDICTIVE":[{"def":"Having the power to prohibit; as, an interdictive sentence.","pos":""}],"INTERDICTORY":[{"def":"Belonging to an interdiction; prohibitory.","pos":""}],"INTERDIGITAL":[{"def":"Between the fingers or toes; as, interdigital space.","pos":""}],"INTERDIGITATE":[{"def":"To interlock, as the fingers of two hands that are joined; to be interwoven; to commingle.","pos":""}],"INTERDIGITATION":[{"def":"The state of interdigitating; interdigital space.","pos":""}],"INTERDOME":[{"def":"The open space between the inner and outer shells of a dome or cupola of masonry.","pos":""}],"INTEREPIMERAL":[{"def":"Between the epimeral plates of insects and crustaceans.","pos":""}],"INTEREQUINOCTIAL":[{"def":"Coming between the equinoxes.","pos":""}],"INTERESS":[{"def":"To interest or affect.","pos":""}],"INTEREST":[{"def":"To engage the attention of; to awaken interest in; to excite emotion or passion in, in behalf of a person or thing; as, the subject did not interest him; to interest one in charitable work.","pos":""},{"def":"To be concerned with or engaged in; to affect; to concern; to excite; -- often used impersonally.","pos":""}],"INTERESTED":[{"def":"Having the attention engaged; having emotion or passion excited; as, an interested listener.","pos":""},{"def":"Having an interest; concerned in a cause or in consequences; liable to be affected or prejudiced; as, an interested witness.","pos":""}],"INTERESTEDNESS":[{"def":"The state or quality of being interested; selfishness.","pos":""}],"INTERESTING":[{"def":"Engaging the attention; exciting, or adapted to excite, interest, curiosity, or emotion; as, an interesting story; interesting news.","pos":""}],"INTERESTINGLY":[{"def":"In an interesting manner.","pos":""}],"INTERESTINGNESS":[{"def":"The condition or quality of being interesting.","pos":""}],"INTERFACIAL":[{"def":"Included between two plane surfaces or faces; as, an interfacial angle.","pos":""}],"INTERFASCICULAR":[{"def":"Between fascicles or bundles; as, the interfascicular spaces of connective tissue.","pos":""}],"INTERFERANT":[{"def":"One of the contestants in interference before the Patent Office.","pos":""}],"INTERFERE":[{"def":"To act reciprocally, so as to augment, diminish, or otherwise affect one another; -- said of waves, rays of light, heat, etc.","pos":""},{"def":"To cover the same ground; to claim the same invention.","pos":""}],"INTERFERENCE":[{"def":"The act or state of interfering, or of claiming a right to the same invention.","pos":""}],"INTERFERER":[{"def":"One who interferes.","pos":""}],"INTERFERINGLY":[{"def":"By or with interference.","pos":""}],"INTERFEROMETER":[{"def":"An instrument for measuring small movements, distances, or displacements by means of the interference of two beams of light; -- called also refractometer.","pos":""}],"INTERFLOW":[{"def":"Flowing between or among; intervening.","pos":""}],"INTERFOLDED":[{"def":"Intertwined; interlocked; clasped together.","pos":""}],"INTERFOLIACEOUS":[{"def":"At the same node with opposite or whorled leaves, but occupying a position between their places of attachment.","pos":""}],"INTERFOLLICULAR":[{"def":"Between follicles; as, the interfollicular septa in a lymphatic gland.","pos":""}],"INTERFRETTED":[{"def":"Interlaced; linked together; -- said of charges or bearings.","pos":""}],"INTERFULGENT":[{"def":"Shining between.","pos":""}]}