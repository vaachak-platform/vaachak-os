{"FIB":[{"def":"A falsehood; a lie; -- used euphemistically.","pos":""}],"FIBBER":[{"def":"One who tells fibs.","pos":""},{"def":"Having fibers; made up of fibers.","pos":""}],"FIBRIFORM":[{"def":"Having the form of a fiber or fibers; resembling a fiber.","pos":""}],"FIBRIL":[{"def":"A small fiber; the branch of a fiber; a very slender thread; a fibrilla.","pos":""}],"FIBRILLA":[{"def":"A minute thread of fiber, as one of the fibrous elements of a muscular fiber; a fibril.","pos":""}],"FIBRILLAR":[{"def":"Of or pertaining to fibrils or fibers; as, fibrillar twitchings.","pos":""}],"FIBRILLARY":[{"def":"Of of pertaining to fibrils.","pos":""}],"FIBRILLATED":[{"def":"Furnished with fibrils; fringed.","pos":""}],"FIBRILLATION":[{"def":"The state of being reduced to fibers.","pos":""}],"FIBRILLOSE":[{"def":"Covered with hairlike appendages, as the under surface of some lichens; also, composed of little strings or fibers; as, fibrillose appendages.","pos":""}],"FIBRILLOUS":[{"def":"Pertaining to, or composed of, fibers.","pos":""}],"FIBRIN":[{"def":"A white, albuminous, fibrous substance, formed in the coagulation of the blood either by decomposition of fibrinogen, or from the union of fibrinogen and paraglobulin which exist separately in the blood.","pos":""},{"def":"The white, albuminous mass remaining after washing lean beef or other meat with water until all coloring matter is removed; the fibrous portion of the muscle tissue; flesh fibrin.","pos":""}],"FIBRINATION":[{"def":"The state of acquiring or having an excess of fibrin.","pos":""}],"FIBRINE":[{"def":"Belonging to the fibers of plants.","pos":""}],"FIBRINOGEN":[{"def":"An albuminous substance existing in the blood, and in other animal fluids, which either alone or with fibrinoplastin or paraglobulin forms fibrin, and thus causes coagulation.","pos":""}],"FIBRINOGENOUS":[{"def":"Possessed of properties similar to fibrinogen; capable of forming fibrin.","pos":""}],"FIBRINOPLASTIC":[{"def":"Like fibrinoplastin; capable of forming fibrin when brought in contact with fibrinogen.","pos":""}],"FIBRINOPLASTIN":[{"def":"An albuminous substance, existing in the blood, which in combination with fibrinogen forms fibrin; -- called also paraglobulin.","pos":""}],"FIBRINOUS":[{"def":"Having, or partaking of the properties of, fibrin; as, fibrious exudation.","pos":""}],"FIBROCARTILAGE":[{"def":"A kind of cartilage with a fibrous matrix and approaching fibrous connective tissue in structure.","pos":""}],"FIBROCHONDROSTEAL":[{"def":"Partly fibrous, partly cartilaginous, and partly osseous.","pos":""}],"FIBROID":[{"def":"Resembling or forming fibrous tissue; made up of fibers; as, fibroid tumors.","pos":""},{"def":"A fibroid tumor; a fibroma.","pos":""}],"FIBROIN":[{"def":"A variety of gelatin; the chief ingredient of raw silk, extracted as a white amorphous mass.","pos":""}],"FIBROLITE":[{"def":"A silicate of alumina, of fibrous or columnar structure.","pos":""}],"FIBROMA":[{"def":"A tumor consisting mainly of fibrous tissue, or of same modification of such tissue.","pos":""}],"FIBROSPONGIAE":[{"def":"An order of sponges having a fibrous skeleton, including the commercial sponges.","pos":""}],"FIBROUS":[{"def":"Containing, or consisting of, fibers; as, the fibrous coat of the cocoanut; the fibrous roots of grasses.","pos":""}],"FIBROVASCULAR":[{"def":"Containing woody fiber and ducts, as the stems of all flowering plants and ferns; -- opposed to cellular.","pos":""}],"FIBSTER":[{"def":"One who tells fibs.","pos":""}],"FIBU-LAR":[{"def":"Pertaining to the fibula.","pos":""}],"FIBULA":[{"def":"The outer and usually the smaller of the two bones of the leg, or hind limb, below the knee.","pos":""},{"def":"A needle for sewing up wounds.","pos":""}],"FIBULARE":[{"def":"The bone or cartilage of the tarsus, which articulates with the fibula, and corresponds to the calcaneum in man and most mammals.","pos":""}]}