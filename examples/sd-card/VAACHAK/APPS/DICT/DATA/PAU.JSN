{"PAUCILOQUENT":[{"def":"Uttering few words; brief in speech.","pos":""}],"PAUCILOQUY":[{"def":"Brevity in speech.","pos":""}],"PAUCISPIRAL":[{"def":"Having few spirals, or whorls; as, a paucispiral operculum or shell.","pos":""}],"PAUCITY":[{"def":"Fewness; smallness of number; scarcity.","pos":""},{"def":"Smallnes of quantity; exiguity; insufficiency; as, paucity of blood.","pos":""}],"PAUHAUGEN":[{"def":"The menhaden; -- called also poghaden.","pos":""}],"PAUL":[{"def":"An Italian silver coin.","pos":""}],"PAULDRON":[{"def":"A piece of armor covering the shoulder at the junction of the body piece and arm piece.","pos":""},{"def":"A follower of Paul of Samosata, a bishop of Antioch in the third century, who was deposed for denying the divinity of Christ.","pos":""}],"PAULICIAN":[{"def":"One of a sect of Christian dualists originating in Armenia in the seventh century.","pos":""}],"PAULINE":[{"def":"Of or pertaining to the apostle Paul, or his writings; resembling, or conforming to, the writings of Paul; as, the Pauline epistles; Pauline doctrine.","pos":""}],"PAULIST":[{"def":"A member of The Institute of the Missionary Priests of St.","pos":""}],"PAULOWNIA":[{"def":"A genus of trees of the order Scrophulariaceæ, consisting of one species, Paulownia imperialis.","pos":""}],"PAUM":[{"def":"To palm off by fraud; to cheat at cards.","pos":""}],"PAUNCH":[{"def":"The belly and its contents; the abdomen; also, the first stomach, or rumen, of ruminants.","pos":""},{"def":"A paunch mat; -- called also panch.","pos":""}],"PAUNE":[{"def":"A kind of bread.","pos":""}],"PAUPER":[{"def":"A poor person; especially, one development on private or public charity.","pos":""}],"PAUPERISM":[{"def":"The state of being a pauper; the state of indigent persons requiring support from the community.","pos":""}],"PAUPERIZATION":[{"def":"The act or process of reducing to pauperism.","pos":""}],"PAUPERIZE":[{"def":"To reduce to pauperism; as, to pauperize the peasantry.","pos":""}],"PAUROPODA":[{"def":"An order of small myriapods having only nine pairs of legs and destitute of tracheæ.","pos":""}],"PAUSE":[{"def":"A temporary stop or rest; an intermission of action; interruption; suspension; cessation.","pos":""},{"def":"Temporary inaction or waiting; hesitation; suspence; doubt.","pos":""}],"PAUSINGLY":[{"def":"With pauses; haltingly.","pos":""}],"PAUXI":[{"def":"A curassow (Ourax pauxi), which, in South America, is often domesticated.","pos":""}]}