{"BRAZE":[{"def":"To solder with hard solder, esp.","pos":""}],"BRAZEN":[{"def":"Pertaining to, made of, or resembling, brass.","pos":""},{"def":"Sounding harsh and loud, like resounding brass.","pos":""}],"BRAZEN-BROWED":[{"def":"Shamelessly impudent.","pos":""}],"BRAZENFACE":[{"def":"An impudent of shameless person.","pos":""}],"BRAZENFACED":[{"def":"Impudent; shameless.","pos":""}],"BRAZENLY":[{"def":"In a bold, impudent manner.","pos":""}],"BRAZENNESS":[{"def":"The quality or state of being brazen.","pos":""}],"BRAZIER":[{"def":"Same as Brasier.","pos":""}],"BRAZIL NUT":[{"def":"An oily, three-sided nut, the seed of the Bertholletia excelsa; the cream nut.","pos":""}],"BRAZIL WOOD":[{"def":"The wood of the oriental Cæsalpinia Sapan; -- so called before the discovery of America.","pos":""},{"def":"A very heavy wood of a reddish color, imported from Brazil and other tropical countries, for cabinet-work, and for dyeing.","pos":""}],"BRAZILETTO":[{"def":"See Brazil wood.","pos":""}],"BRAZILIAN":[{"def":"Of or pertaining to Brasil.","pos":""},{"def":"A native or an inhabitant of Brazil.","pos":""}],"BRAZILIN":[{"def":"A substance contained in both Brazil wood and Sapan wood, from which it is extracted as a yellow crystalline substance which is white when pure.","pos":""}]}