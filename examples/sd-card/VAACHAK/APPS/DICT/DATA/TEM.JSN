{"TEMERARIOUS":[{"def":"Unreasonably adventurous; despising danger; rash; headstrong; audacious; reckless; heedless.","pos":""}],"TEMERITY":[{"def":"Unreasonable contempt of danger; extreme venturesomeness; rashness; as, the temerity of a commander in war.","pos":""}],"TEMPEAN":[{"def":"Of or pertaining to Temple, a valley in Thessaly, celebrated by Greek poets on account of its beautiful scenery; resembling Temple; hence, beautiful; delightful; charming.","pos":""}],"TEMPER":[{"def":"To bring to a proper degree of hardness; as, to temper iron or steel.","pos":""},{"def":"To adjust, as the mathematical scale to the actual scale, or to that in actual use.","pos":""}],"TEMPER SCREW":[{"def":"A screw link, to which is attached the rope of a rope-drilling apparatus, for feeding and slightly turning the drill jar at each stroke.","pos":""},{"def":"A set screw used for adjusting.","pos":""}],"TEMPERA":[{"def":"A mode or process of painting; distemper.","pos":""}],"TEMPERABLE":[{"def":"Capable of being tempered.","pos":""}],"TEMPERAMENT":[{"def":"A system of compromises in the tuning of organs, pianofortes, and the like, whereby the tones generated with the vibrations of a ground tone are mutually modified and in part canceled, until their number reduced to the actual practicable scale of twelve tones to the octave.","pos":""},{"def":"The peculiar physical and mental character of an individual, in olden times erroneously supposed to be due to individual variation in the relations and proportions of the constituent parts of the body, especially of the fluids, as the bile, blood, lymph, etc.","pos":""}],"TEMPERAMENTAL":[{"def":"Of or pertaining to temperament; constitutional.","pos":""}],"TEMPERANCE":[{"def":"Moderation of passion; patience; calmness; sedateness.","pos":""}],"TEMPERATE":[{"def":"Moderate; not excessive; as, temperate heat; a temperate climate.","pos":""},{"def":"Not marked with passion; not violent; cool; calm; as, temperate language.","pos":""}],"TEMPERATELY":[{"def":"In a temperate manner.","pos":""}],"TEMPERATENESS":[{"def":"The quality or state of being temperate; moderateness; temperance.","pos":""}],"TEMPERATIVE":[{"def":"Having power to temper.","pos":""}],"TEMPERATURE":[{"def":"Condition with respect to heat or cold, especially as indicated by the sensation produced, or by the thermometer or pyrometer; degree of heat or cold; as, the temperature of the air; high temperature; low temperature; temperature of freezing or of boiling.","pos":""}],"TEMPERED":[{"def":"Brought to a proper temper; as, tempered steel; having (such) a temper; -- chiefly used in composition; as, a good-tempered or bad- tempered man; a well-tempered sword.","pos":""}],"TEMPERER":[{"def":"One who, or that which, tempers; specifically, a machine in which lime, cement, stone, etc.","pos":""}],"TEMPEST":[{"def":"An extensive current of wind, rushing with great velocity and violence, and commonly attended with rain, hail, or snow; a furious storm.","pos":""}],"TEMPESTIVE":[{"def":"Seasonable; timely; as, tempestive showers.","pos":""}],"TEMPESTIVILY":[{"def":"The quality, or state, of being tempestive; seasonableness.","pos":""}],"TEMPESTUOUS":[{"def":"Of or pertaining to a tempest; involving or resembling a tempest; turbulent; violent; stormy; as, tempestuous weather; a tempestuous night; a tempestuous debate.","pos":""}],"TEMPLAR":[{"def":"One of a religious and military order first established at Jerusalem, in the early part of the 12th century, for the protection of pilgrims and of the Holy Sepulcher.","pos":""},{"def":"A student of law, so called from having apartments in the Temple at London, the original buildings having belonged to the Knights Templars.","pos":""}],"TEMPLATE":[{"def":"Same as Templet.","pos":""}],"TEMPLE":[{"def":"A contrivence used in a loom for keeping the web stretched transversely.","pos":""}],"TEMPLED":[{"def":"Supplied with a temple or temples, or with churches; inclosed in a temple.","pos":""}],"TEMPLET":[{"def":"A short piece of timber, iron, or stone, placed in a wall under a girder or other beam, to distribute the weight or pressure.","pos":""}],"TEMPO":[{"def":"The rate or degree of movement in time.","pos":""}],"TEMPORAL":[{"def":"Of or pertaining to the temple or temples; as, the temporal bone; a temporal artery.","pos":""}],"TEMPORALITY":[{"def":"The state or quality of being temporary; -- opposed to perpetuity.","pos":""},{"def":"The laity; temporality.","pos":""}],"TEMPORALLY":[{"def":"In a temporal manner; secularly.","pos":""}],"TEMPORALTY":[{"def":"The laity; secular people.","pos":""},{"def":"A secular possession; a temporality.","pos":""}],"TEMPORARILY":[{"def":"In a temporary manner; for a time.","pos":""}],"TEMPORARINESS":[{"def":"The quality or state of being temporary; -- opposed to perpetuity.","pos":""}],"TEMPORARY":[{"def":"Lasting for a time only; existing or continuing for a limited time; not permanent; as, the patient has obtained temporary relief.","pos":""}],"TEMPORIST":[{"def":"Why, turn a temporist, row with the tide.","pos":""}],"TEMPORIZATION":[{"def":"The act of temporizing.","pos":""}],"TEMPORIZE":[{"def":"To comply with the time or occasion; to humor, or yield to, the current of opinion or circumstances; also, to trim, as between two parties.","pos":""},{"def":"To delay; to procrastinate.","pos":""}],"TEMPORIZER":[{"def":"One who temporizes; one who yields to the time, or complies with the prevailing opinions, fashions, or occasions; a trimmer.","pos":""}],"TEMPORIZINGLY":[{"def":"In a temporizing or yielding manner.","pos":""}],"TEMPORO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the temple, or temporal bone; as, temporofacial.","pos":""}],"TEMPORO-AURICULAR":[{"def":"Of or pertaining to both the temple and the ear; as, the temporo-auricular nerve.","pos":""}],"TEMPOROFACIAL":[{"def":"Of or pertaining to both the temple and the face.","pos":""}],"TEMPOROMALAR":[{"def":"Of or pertaining to both the temple and the region of the malar bone; as, the temporomalar nerve.","pos":""}],"TEMPOROMAXILLARY":[{"def":"Of or pertaining to both the temple or the temporal bone and the maxilla.","pos":""}],"TEMPT":[{"def":"To put to trial; to prove; to test; to try.","pos":""},{"def":"To lead, or endeavor to lead, into evil; to entice to what is wrong; to seduce.","pos":""}],"TEMPTABILITY":[{"def":"The quality or state of being temptable; lability to temptation.","pos":""}],"TEMPTABLE":[{"def":"Capable of being tempted; liable to be tempted.","pos":""}],"TEMPTATION":[{"def":"The act of tempting, or enticing to evil; seduction.","pos":""},{"def":"The state of being tempted, or enticed to evil.","pos":""}],"TEMPTATIONLESS":[{"def":"Having no temptation or motive; as, a temptationless sin.","pos":""}],"TEMPTER":[{"def":"One who tempts or entices; especially, Satan, or the Devil, regarded as the great enticer to evil.","pos":""}],"TEMPTING":[{"def":"Adapted to entice or allure; attractive; alluring; seductive; enticing; as, tempting pleasures.","pos":""}],"TEMPTRESS":[{"def":"A woman who entices.","pos":""}],"TEMSE":[{"def":"Intoxication; inebriation; drunkenness.","pos":""}],"TEMULENT":[{"def":"Intoxicated; drunken.","pos":""}],"TEMULENTIVE":[{"def":"Somewhat temulent; addicted to drink.","pos":""}]}