{"OUTNAME":[{"def":"To exceed in naming or describing.","pos":""},{"def":"To exceed in name, fame, or degree.","pos":""}],"OUTNESS":[{"def":"The state or quality of being distanguishable from the perceiving mind, by being in space, and possessing marerial quality; externality; objectivity.","pos":""}],"OUTNOISE":[{"def":"To exceed in noise; to surpass in noisiness.","pos":""}],"OUTNUMBER":[{"def":"To exceed in number.","pos":""}]}