{"SYNAGOGICAL":[{"def":"Of or pertaining to a synagogue.","pos":""}],"SYNAGOGUE":[{"def":"A congregation or assembly of Jews met for the purpose of worship, or the performance of religious rites.","pos":""},{"def":"The building or place appropriated to the religious worship of the Jews.","pos":""}],"SYNALEPHA":[{"def":"A contraction of syllables by suppressing some vowel or diphthong at the end of a word, before another vowel or diphthong; as, th' army, for the army.","pos":""}],"SYNALLAGMATIC":[{"def":"Imposing reciprocal obligations upon the parties; as, a synallagmatic contract.","pos":""}],"SYNALLAXINE":[{"def":"Having the outer and middle toes partially united; -- said of certain birds related to the creepers.","pos":""}],"SYNALOEPHA":[{"def":"Same as Synalepha.","pos":""}],"SYNANGIUM":[{"def":"The divided part beyond the pylangium in the aortic trunk of the amphibian heart.","pos":""}],"SYNANTHEROUS":[{"def":"Having the stamens united by their anthers; as, synantherous flowers.","pos":""}],"SYNANTHESIS":[{"def":"The simultaneous maturity of the anthers and stigmas of a blossom.","pos":""}],"SYNANTHOUS":[{"def":"Having flowers and leaves which appear at the same time; -- said of certain plants.","pos":""}],"SYNANTHROSE":[{"def":"A variety of sugar, isomeric with sucrose, found in the tubers of the Jerusalem artichoke (Helianthus tuberosus), in the dahlia, and other Compositæ.","pos":""}],"SYNAPTA":[{"def":"A genus of slender, transparent holothurians which have delicate calcareous anchors attached to the dermal plates.","pos":""}],"SYNAPTASE":[{"def":"A ferment resembling diastase, found in bitter almonds.","pos":""}],"SYNAPTICULA":[{"def":"One of numerous calcareous processes which extend between, and unite, the adjacent septa of certain corals, especially of the fungian corals.","pos":""}],"SYNARCHY":[{"def":"Joint rule or sovereignity.","pos":""}],"SYNARTESIS":[{"def":"A fastening or knitting together; the state of being closely jointed; close union.","pos":""}],"SYNARTHROSIS":[{"def":"Immovable articulation by close union, as in sutures.","pos":""}],"SYNASTRY":[{"def":"Concurrence of starry position or influence; hence, similarity of condition, fortune, etc.","pos":""}],"SYNAXIS":[{"def":"A congregation; also, formerly, the Lord's Supper.","pos":""}]}