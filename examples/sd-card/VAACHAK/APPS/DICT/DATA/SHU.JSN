{"SHUCK":[{"def":"A shock of grain.","pos":""}],"SHUDDER":[{"def":"To tremble or shake with fear, horrer, or aversion; to shiver with cold; to quake.","pos":""}],"SHUDDERINGLY":[{"def":"In a shuddering manner.","pos":""}],"SHUDE":[{"def":"The husks and other refuse of rice mills, used to adulterate oil cake, or linseed cake.","pos":""}],"SHUFFLE":[{"def":"To shove one way and the other; to push from one to another; as, to shuffle money from hand to hand.","pos":""},{"def":"To mix by pushing or shoving; to confuse; to throw into disorder; especially, to change the relative positions of, as of the cards in a pack.","pos":""}],"SHUFFLEBOARD":[{"def":"See Shovelboard.","pos":""}],"SHUFFLECAP":[{"def":"Shuf\"fle*cap` Defn: ,.","pos":""}],"SHUFFLER":[{"def":"Either one of the three common American scaup ducks.","pos":""}],"SHUFFLEWING":[{"def":"The hedg sparrow.","pos":""}],"SHUFFLING":[{"def":"Moving with a dragging, scraping step.","pos":""},{"def":"Evasive; as, a shuffling excuse.","pos":""}],"SHUG":[{"def":"To writhe the body so as to produce friction against one's clothes, as do those who have the itch.","pos":""},{"def":"Hence, to crawl; to sneak.","pos":""}],"SHUN":[{"def":"To avoid; to keep clear of; to get out of the way of; to escape from; to eschew; as, to shun rocks, shoals, vice.","pos":""}],"SHUNLESS":[{"def":"Not to be shunned; inevitable; unavoidable.","pos":""}],"SHUNT":[{"def":"To provide with a shunt; as, to shunt a galvanometer.","pos":""}],"SHUNT VALVE":[{"def":"A valve permitting a fluid under pressure an easier avenue of escape than normally; specif.","pos":""}],"SHUNT WINDING":[{"def":"A winding so arranged as to divide the armature current and lead a portion of it around the field-magnet coils; -- opposed to series winding.","pos":""}],"SHUNTER":[{"def":"A person employed to shunt cars from one track to another.","pos":""}],"SHUT":[{"def":"To close so as to hinder ingress or egress; as, to shut a door or a gate; to shut one's eyes or mouth.","pos":""},{"def":"To forbid entrance into; to prohibit; to bar; as, to shut the ports of a country by a blockade.","pos":""}],"SHUTE":[{"def":"Same as Chute, or Shoot.","pos":""}],"SHUTTER":[{"def":"One who shuts or closes.","pos":""},{"def":"A movable cover or screen for a window, designed to shut out the light, to obstruct the view, or to be of some strength as a defense; a blind.","pos":""}],"SHUTTERED":[{"def":"Furnished with shutters.","pos":""}],"SHUTTLE":[{"def":"An instrument used in weaving for passing or shooting the thread of the woof from one side of the cloth to the other between the threads of the warp.","pos":""},{"def":"The sliding thread holder in a sewing machine, which carries the lower thread through a loop of the upper thread, to make a lock stitch.","pos":""}],"SHUTTLECOCK":[{"def":"A cork stuck with feathers, which is to be struck by a battledoor in play; also, the play itself.","pos":""}],"SHUTTLECORK":[{"def":"See Shuttlecock.","pos":""}],"SHUTTLEWISE":[{"def":"Back and forth, like the movement of a shuttle.","pos":""}]}