{"SAY":[{"def":"Trial by sample; assay; sample; specimen; smack.","pos":""},{"def":"Tried quality; temper; proof.","pos":""}],"SAYER":[{"def":"One who says; an utterer.","pos":""}],"SAYETTE":[{"def":"A mixed stuff, called also sagathy.","pos":""}],"SAYING":[{"def":"That which is said; a declaration; a statement, especially a proverbial one; an aphorism; a proverb.","pos":""}],"SAYMASTER":[{"def":"A master of assay; one who tries or proves.","pos":""}],"SAYND":[{"def":"An abbreviation of God's blood; -- used as an oath.","pos":""}]}