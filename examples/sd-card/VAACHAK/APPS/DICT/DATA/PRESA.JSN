{"PRESAGE":[{"def":"Something which foreshows or portends a future event; a prognostic; an omen; an augury.","pos":""},{"def":"Power to look the future, or the exercise of that power; foreknowledge; presentiment.","pos":""}],"PRESAGEFUL":[{"def":"Full of presages; ominous.","pos":""}],"PRESAGEMENT":[{"def":"The act or art of presaging; a foreboding.","pos":""},{"def":"That which is presaged, or foretold.","pos":""}],"PRESAGER":[{"def":"One who, or that which, presages; a foreteller; a foreboder.","pos":""}],"PRESAGIOUS":[{"def":"Foreboding; ominous.","pos":""}]}