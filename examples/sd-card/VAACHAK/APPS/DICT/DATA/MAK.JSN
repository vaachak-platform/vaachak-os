{"MAKABLE":[{"def":"Capable of being made.","pos":""}],"MAKARON":[{"def":"See Macaroon, 2.","pos":""}],"MAKE":[{"def":"A companion; a mate; often, a husband or a wife.","pos":""}],"MAKE AND BREAK":[{"def":"Any apparatus for making and breaking an electric circuit; a circuit breaker.","pos":""}],"MAKE-BELIEF":[{"def":"A feigning to believe; make believe.","pos":""}],"MAKE-BELIEVE":[{"def":"A feigning to believe, as in the play of children; a mere pretense; a fiction; an invention.","pos":""}],"MAKE-GAME":[{"def":"An object of ridicule; a butt.","pos":""}],"MAKE-PEACE":[{"def":"Make\"-peace` (-pes`) n.","pos":""}],"MAKE-UP":[{"def":"The way in which the parts of anything are put together; often, the way in which an actor is dressed, painted, etc.","pos":""}],"MAKEBATE":[{"def":"One who excites contentions and quarrels.","pos":""}],"MAKER":[{"def":"The person who makes a promissory note.","pos":""}],"MAKESHIFT":[{"def":"That with which one makes shift; a temporary expedient.","pos":""}],"MAKEWEIGHT":[{"def":"That which is thrown into a scale to make weight; something of little account added to supply a deficiency or fill a gap.","pos":""}],"MAKING":[{"def":"The act of one who makes; workmanship; fabrication; construction; as, this is cloth of your own making; the making of peace or war was in his power.","pos":""},{"def":"Composition, or structure.","pos":""}],"MAKING-IRON":[{"def":"A tool somewhat like a chisel with a groove in it, used by calkers of ships to finish the seams after the oakum has been driven in.","pos":""}],"MAKING-UP":[{"def":"The act of bringing spirits to a certain degree of strength, called proof.","pos":""},{"def":"The act of becoming reconciled or friendly.","pos":""}]}