{"WAS":[{"def":"The first and third persons singular of the verb be, in the indicative mood, preterit (imperfect) tense; as, I was; he was.","pos":""}],"WASE":[{"def":"A bundle of straw, or other material, to relieve the pressure of burdens carried upon the head.","pos":""}],"WASH":[{"def":"To cleanse by ablution, or dipping or rubbing in water; to apply water or other liquid to for the purpose of cleansing; to scrub with water, etc.","pos":""},{"def":"To cover with water or any liquid; to wet; to fall on and moisten; hence, to overflow or dash against; as, waves wash the shore.","pos":""}],"WASH DRAWING":[{"def":"In water-color painting, work in, or a work done chiefly in, washes, as distinguished from that done in stipple, in body color, etc.","pos":""}],"WASH SALE":[{"def":"A sale made in washing.","pos":""}],"WASH STAND":[{"def":"In a stable or garage, a place in the floor prepared so that carriages or automobiles may be washed there and the water run off.","pos":""}],"WASH-OFF":[{"def":"Capable of being washed off; not permanent or durable; -- said of colors not fixed by steaming or otherwise.","pos":""}],"WASHABLE":[{"def":"Capable of being washed without damage to fabric or color.","pos":""}],"WASHBOARD":[{"def":"A broad, thin plank, fixed along the gunwale of boat to keep the sea from breaking inboard; also, a plank on the sill of a lower deck port, for the same purpose; -- called also wasteboard.","pos":""}],"WASHBOWL":[{"def":"A basin, or bowl, to hold water for washing one's hands, face, etc.","pos":""}],"WASHDISH":[{"def":"Same as Washerwoman, 2.","pos":""}],"WASHED":[{"def":"Appearing as if overlaid with a thin layer of different color; -- said of the colors of certain birds and insects.","pos":""}],"WASHED SALE":[{"def":"Same as Wash sale.","pos":""}],"WASHER":[{"def":"A fitting, usually having a plug, applied to a cistern, tub, sink, or the like, and forming the outlet opening.","pos":""},{"def":"The common raccoon.","pos":""}],"WASHERMAN":[{"def":"A man who washes clothes, esp.","pos":""}],"WASHERWOMAN":[{"def":"The pied wagtail; -- so called in allusion to its beating the water with its tail while tripping along the leaves of water plants.","pos":""}],"WASHHOUSE":[{"def":"An outbuilding for washing, esp.","pos":""}],"WASHINESS":[{"def":"The quality or state of being washy, watery, or weak.","pos":""}],"WASHING":[{"def":"The act of one who washes; the act of cleansing with water; ablution.","pos":""},{"def":"The clothes washed, esp.","pos":""}],"WASHINGTONIAN":[{"def":"A member of the Washingtonian Society.","pos":""}],"WASHOE PROCESS":[{"def":"The process of treating silver ores by grinding in pans or tubs with the addition of mercury, and sometimes of chemicals such as blue vitriol and salt.","pos":""}],"WASHOUT":[{"def":"The washing out or away of earth, etc.","pos":""}],"WASHPOT":[{"def":"A pot containing melted tin into which the plates are dipped to be coated.","pos":""}],"WASHSTAND":[{"def":"A piece of furniture holding the ewer or pitcher, basin, and other requisites for washing the person.","pos":""}],"WASHTUB":[{"def":"A tub in which clothes are washed.","pos":""}],"WASHY":[{"def":"Watery; damp; soft.","pos":""},{"def":"Lacking substance or strength; weak; thin; dilute; feeble; as, washy tea; washy resolutions.","pos":""}],"WASITE":[{"def":"A variety of allanite from Sweden supposed to contain wasium.","pos":""}],"WASIUM":[{"def":"A rare element supposed by Bahr to have been extracted from wasite, but now identified with thorium.","pos":""}],"WASP":[{"def":"Any one of numerous species of stinging hymenopterous insects, esp.","pos":""}],"WASPISH":[{"def":"Resembling a wasp in form; having a slender waist, like a wasp.","pos":""},{"def":"Quick to resent a trifling affront; characterized by snappishness; irritable; irascible; petulant; snappish.","pos":""}],"WASSAIL":[{"def":"An ancient expression of good wishes on a festive occasion, especially in drinking to some one.","pos":""},{"def":"An occasion on which such good wishes are expressed in drinking; a drinking bout; a carouse.","pos":""}],"WASSAILER":[{"def":"One who drinks wassail; one who engages in festivity, especially in drinking; a reveler.","pos":""}],"WAST":[{"def":"The second person singular of the verb be, in the indicative mood, imperfect tense; -- now used only in solemn or poetical style.","pos":""}],"WASTAGE":[{"def":"Loss by use, decay, evaporation, leakage, or the like; waste.","pos":""}],"WASTE":[{"def":"Desolate; devastated; stripped; bare; hence, dreary; dismal; gloomy; cheerless.","pos":""},{"def":"Lying unused; unproductive; worthless; valueless; refuse; rejected; as, waste land; waste paper.","pos":""}],"WASTEBASKET":[{"def":"A basket used in offices, libraries, etc.","pos":""}],"WASTEBOARD":[{"def":"See Washboard, 3.","pos":""}],"WASTEBOOK":[{"def":"A book in which rough entries of transactions are made, previous to their being carried into the journal.","pos":""}],"WASTEFUL":[{"def":"Full of waste; destructive to property; ruinous; as; wasteful practices or negligence; wasteful expenses.","pos":""},{"def":"Expending, or tending to expend, property, or that which is valuable, in a needless or useless manner; lavish; prodigal; as, a wasteful person; a wasteful disposition.","pos":""}],"WASTEL":[{"def":"A kind of white and fine bread or cake; -- called also wastel bread, and wastel cake.","pos":""}],"WASTENESS":[{"def":"The quality or state of being waste; a desolate state or condition; desolation.","pos":""},{"def":"That which is waste; a desert; a waste.","pos":""}],"WASTER":[{"def":"One who, or that which, wastes; one who squanders; one who consumes or expends extravagantly; a spendthrift; a prodigal.","pos":""},{"def":"An imperfection in the wick of a candle, causing it to waste; -- called also a thief.","pos":""}],"WASTEWEIR":[{"def":"An overfall, or weir, for the escape, or overflow, of superfluous water from a canal, reservoir, pond, or the like.","pos":""}],"WASTING":[{"def":"Causing waste; also, undergoing waste; diminishing; as, a wasting disease; a wasting fortune.","pos":""}],"WASTOR":[{"def":"A waster; a thief.","pos":""}],"WASTREL":[{"def":"Any waste thing or substance; as: (a) Waste land or common land.","pos":""},{"def":"Anything cast away as bad or useless, as imperfect bricks, china, etc.","pos":""}]}