{"CONVALESCE":[{"def":"To recover health and strength gradually, after sickness or weakness; as, a patient begins to convalesce.","pos":""}],"CONVALESCED":[{"def":"The recovery of heath and strength after disease; the state of a body renewing its vigor after sickness or weakness; the time between the subsidence of a disease and complete restoration to health.","pos":""}],"CONVALESCENT":[{"def":"Recovering from siclness or debility; partially restored to health or strength.","pos":""},{"def":"Of or pertaining to convalescence.","pos":""}],"CONVALESCENTLY":[{"def":"In the manner of a convalescent; with increasing strength or vigor.","pos":""}],"CONVALLAMARIN":[{"def":"A white, crystalline, poisonous substance, regarded as a glucoside, extracted from the lily of the valley (Convallaria Majalis).","pos":""}],"CONVALLARIA":[{"def":"The lily of the valley.","pos":""}],"CONVALLARIN":[{"def":"A white, crystalline glucoside, of an irritating taste, extracted from the convallaria or lily of the valley.","pos":""}]}