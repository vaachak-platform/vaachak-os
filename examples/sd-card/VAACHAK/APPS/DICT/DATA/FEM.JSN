{"FEMALE":[{"def":"A plant which produces only that kind of reproductive organs which are capable of developing into fruit after impregnation or fertilization; a pistillate plant.","pos":""}],"FEMALE FERN":[{"def":"a common species of fern with large decompound fronds (Asplenium Filixfæmina), growing in many countries; lady fern.","pos":""}],"FEMALE RHYMES":[{"def":"double rhymes, or rhymes (called in French feminine rhymes because they end in e weak, or feminine) in which two syllables, an accented and an unaccented one, correspond at the end of each line.","pos":""}],"FEMALIST":[{"def":"Courting her smoothly like a femalist.","pos":""}],"FEMALIZE":[{"def":"To make, or to describe as, female or feminine.","pos":""}],"FEMERELL":[{"def":"A lantern, or louver covering, placed on a roof, for ventilation or escape of smoke.","pos":""}],"FEMINEITY":[{"def":"Womanliness; femininity.","pos":""}],"FEMININE":[{"def":"Of or pertaining to a woman, or to women; characteristic of a woman; womanish; womanly.","pos":""},{"def":"Having the qualities of a woman; becoming or appropriate to the female sex; as, in a good sense, modest, graceful, affectionate, confiding; or, in a bad sense, weak, nerveless, timid, pleasure- loving, effeminate.","pos":""}],"FEMININE RHYME":[{"def":"See Female rhyme, under Female, a.","pos":""}],"FEMININELY":[{"def":"In a feminine manner.","pos":""}],"FEMININENESS":[{"def":"The quality of being feminine; womanliness; womanishness.","pos":""}],"FEMININITY":[{"def":"The quality or nature of the female sex; womanliness.","pos":""},{"def":"The female form.","pos":""}],"FEMINITY":[{"def":"Womanliness; femininity.","pos":""}],"FEMINIZATION":[{"def":"The act of feminizing, or the state of being feminized.","pos":""}],"FEMINIZE":[{"def":"To make womanish or effeminate.","pos":""}],"FEMINYE":[{"def":"The people called Amazons.","pos":""}],"FEMORAL":[{"def":"Pertaining to the femur or thigh; as, the femoral artery.","pos":""}]}