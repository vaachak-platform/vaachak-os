{"AMIA":[{"def":"A genus of fresh-water ganoid fishes, exclusively confined to North America; called bowfin in Lake Champlain, dogfish in Lake Erie, and mudfish in South Carolina, etc.","pos":""}],"AMIABILITY":[{"def":"The quality of being amiable; amiableness; sweetness of disposition.","pos":""}],"AMIABLE":[{"def":"Lovable; lovely; pleasing.","pos":""},{"def":"Friendly; kindly; sweet; gracious; as, an amiable temper or mood; amiable ideas.","pos":""}],"AMIABLENESS":[{"def":"The quality of being amiable; amiability.","pos":""}],"AMIABLY":[{"def":"In an amiable manner.","pos":""}],"AMIANTHIFORM":[{"def":"Resembling amianthus in form.","pos":""}],"AMIANTHOID":[{"def":"Resembling amianthus.","pos":""}],"AMIANTHUS":[{"def":"Earth flax, or mountain flax; a soft silky variety of asbestus.","pos":""}],"AMIC":[{"def":"Related to, or derived, ammonia; -- used chiefly as a suffix; as, amic acid; phosphamic acid.","pos":""}],"AMICABILITY":[{"def":"The quality of being amicable; friendliness; amicableness.","pos":""}],"AMICABLE":[{"def":"Friendly; proceeding from, or exhibiting, friendliness; after the manner of friends; peaceable; as, an amicable disposition, or arrangement.","pos":""}],"AMICABLENESS":[{"def":"The quality of being amicable; amicability.","pos":""}],"AMICABLY":[{"def":"In an amicable manner.","pos":""}],"AMICE":[{"def":"A square of white linen worn at first on the head, but now about the neck and shoulders, by priests of the Roman Catholic Church while saying Mass.","pos":""}],"AMIDE":[{"def":"A compound formed by the union of amidogen with an acid element or radical.","pos":""}],"AMIDIN":[{"def":"Start modified by heat so as to become a transparent mass, like horn.","pos":""}],"AMIDO":[{"def":"Containing, or derived from, amidogen.","pos":""}],"AMIDOGEN":[{"def":"A compound radical, NH2, not yet obtained in a separate state, which may be regarded as ammonia from the molecule of which one of its hydrogen atoms has been removed; -- called also the amido group, and in composition represented by the form amido.","pos":""}],"AMIDOL":[{"def":"A salt of a diamino phenol, C6H3(OH)(NH2)2, used as a developer.","pos":""}],"AMIDSHIPS":[{"def":"In the middle of a ship, with regard to her length, and sometimes also her breadth.","pos":""},{"def":"In the midst or middle of; surrounded or encompassed by; among.","pos":""}],"AMIGO":[{"def":"A friend; -- a Spanish term applied in the Philippine Islands to friendly natives.","pos":""}],"AMINE":[{"def":"One of a class of strongly basic substances derived from ammonia by replacement of one or more hydrogen atoms by a basic atom or radical.","pos":""}],"AMINOL":[{"def":"A colorless liquid prepared from herring brine and containing amines, used as a local antiseptic.","pos":""}],"AMIOID":[{"def":"Like or pertaining to the Amioidei.","pos":""},{"def":"One of the Amioidei.","pos":""}],"AMIOIDEI":[{"def":"An order of ganoid fishes of which Amis is type.","pos":""}],"AMISH":[{"def":"The Amish Mennonites.","pos":""}],"AMISS":[{"def":"Astray; faultily; improperly; wrongly; ill.","pos":""}],"AMISSIBILITY":[{"def":"The quality of being amissible; possibility of being lost.","pos":""}],"AMISSIBLE":[{"def":"Liable to be lost.","pos":""}],"AMISSION":[{"def":"Deprivation; loss.","pos":""}],"AMIT":[{"def":"A lodestone fired doth presently amit its proper virtue.","pos":""}],"AMITOSIS":[{"def":"Cell division in which there is first a simple cleavage of the nucleus without change in its structure (such as the formation of chromosomes), followed by the division of the cytoplasm; direct cell division; -- opposed to mitosis.","pos":""}],"AMITOTIC":[{"def":"Of or pertaining to amitosis; karyostenotic; -- opposed to mitotic.","pos":""}],"AMITY":[{"def":"Friendship, in a general sense, between individuals, societies, or nations; friendly relations; good understanding; as, a treaty of amity and commerce; the amity of the Whigs and Tories.","pos":""}]}