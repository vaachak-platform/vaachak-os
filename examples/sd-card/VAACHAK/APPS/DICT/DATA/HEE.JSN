{"HEED":[{"def":"To mind; to regard with care; to take notice of; to attend to; to observe.","pos":""}],"HEEDFUL":[{"def":"Full of heed; regarding with care; cautious; circumspect; attentive; vigilant.","pos":""}],"HEEDLESS":[{"def":"Without heed or care; inattentive; careless; thoughtless; unobservant.","pos":""}],"HEEL":[{"def":"To lean or tip to one side, as a ship; as, the ship heels aport; the boat heeled over when the squall struck it.","pos":""}],"HEELBALL":[{"def":"A composition of wax and lampblack, used by shoemakers for polishing, and by antiquaries in copying inscriptions.","pos":""}],"HEELER":[{"def":"A cock that strikes well with his heels or spurs.","pos":""},{"def":"A dependent and subservient hanger-on of a political patron.","pos":""}],"HEELPATH":[{"def":"The bank of a canal opposite, and corresponding to, that of the towpath; berm.","pos":""}],"HEELPIECE":[{"def":"A piece of armor to protect the heels.","pos":""},{"def":"A piece of leather fixed on the heel of a shoe.","pos":""}],"HEELPOST":[{"def":"The post to which a gate or door is hinged.","pos":""},{"def":"The quoin post of a lock gate.","pos":""}],"HEELSPUR":[{"def":"A slender bony or cartilaginous process developed from the heel bone of bats.","pos":""}],"HEELTAP":[{"def":"One of the segments of leather in the heel of a shoe.","pos":""},{"def":"A small portion of liquor left in a glass after drinking.","pos":""}],"HEELTOOL":[{"def":"A tool used by turners in metal, having a bend forming a heel near the cutting end.","pos":""}],"HEEMRAAD":[{"def":"In Holland, and, until the 19th century, also in Cape Colony, a council to assist a local magistrate in the government of rural districts; hence, also, a member of such a council.","pos":""}],"HEEP":[{"def":"The hip of the dog-rose.","pos":""}],"HEER":[{"def":"A yarn measure of six hundred yards or of a spindle.","pos":"noun"}]}