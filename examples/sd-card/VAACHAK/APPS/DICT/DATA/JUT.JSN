{"JUT":[{"def":"To shoot out or forward; to project beyond the main body; as, the jutting part of a building.","pos":""}],"JUTE":[{"def":"The coarse, strong fiber of the East Indian Corchorus olitorius, and C.","pos":""}],"JUTES":[{"def":"Jutlanders; one of the Low German tribes, a portion of which settled in Kent, England, in the 5th century.","pos":""}],"JUTLANDER":[{"def":"A native or inhabitant of Jutland in Denmark.","pos":""}],"JUTLANDISH":[{"def":"Of or pertaining to Jutland, or to the people of Jutland.","pos":""}],"JUTTING":[{"def":"Projecting, as corbels, cornices, etc.","pos":""}],"JUTTY":[{"def":"A projection in a building; also, a pier or mole; a jetty.","pos":""}]}