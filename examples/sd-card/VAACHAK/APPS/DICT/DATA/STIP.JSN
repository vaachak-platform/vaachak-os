{"STIPEL":[{"def":"The stipule of a leaflet.","pos":""}],"STIPEND":[{"def":"Settled pay or compensation for services, whether paid daily, monthly, or annually.","pos":""}],"STIPENDIARIAN":[{"def":"Acting from mercenary considerations; stipendiary.","pos":""}],"STIPENDIARY":[{"def":"Receiving wages, or salary; performing services for a stated price or compensation.","pos":""}],"STIPENDIATE":[{"def":"To provide with a stipend, or salary; to support; to pay.","pos":""}],"STIPENDLESS":[{"def":"Having no stipend.","pos":""}],"STIPITATE":[{"def":"Supported by a stipe; elevated on a stipe, as the fronds of most ferns, or the pod of certain cruciferous plants.","pos":""}],"STIPITIFORM":[{"def":"Having the shape of a stalk; stalklike.","pos":""}],"STIPPLE":[{"def":"A mode of execution which produces the effect by dots or small points instead of lines.","pos":""},{"def":"A mode of execution in which a flat or even tint is produced by many small touches.","pos":""}],"STIPULA":[{"def":"A newly sprouted feather.","pos":""}],"STIPULARY":[{"def":"Of or pertaining to stipules; stipular.","pos":""}],"STIPULATE":[{"def":"Furnished with stipules; as, a stipulate leaf.","pos":""}],"STIPULATION":[{"def":"A material article of an agreement; an undertaking in the nature of bail taken in the admiralty courts; a bargain.","pos":""}],"STIPULATOR":[{"def":"One who stipulates, contracts, or covenants.","pos":""}],"STIPULE":[{"def":"An appendage at the base of petioles or leaves, usually somewhat resembling a small leaf in texture and appearance.","pos":""}],"STIPULED":[{"def":"Furnished with stipules, or leafy appendages.","pos":""}]}