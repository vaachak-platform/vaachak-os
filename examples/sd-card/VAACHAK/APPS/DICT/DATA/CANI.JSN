{"CANICULAR":[{"def":"Pertaining to, or measured, by the rising of the Dog Star.","pos":""}],"CANINE":[{"def":"Of or pertaining to the pointed tooth on each side the incisors.","pos":""}],"CANIS":[{"def":"A genus of carnivorous mammals, of the family Canidæ, including the dogs and wolves.","pos":""}],"CANISTER":[{"def":"A small basket of rushes, or wilow twigs, etc.","pos":""},{"def":"A small box or case for holding tea, coffee, etc.","pos":""}]}