{"ANTIGALASTIC":[{"def":"Causing a diminution or a suppression of the secretion of milk.","pos":""}],"ANTIGRAPH":[{"def":"A copy or transcript.","pos":""}],"ANTIGUGGLER":[{"def":"A crooked tube of metal, to be introduced into the neck of a bottle for drawing out the liquid without disturbing the sediment or causing a gurgling noise.","pos":""}]}