{"DOOB GRASS":[{"def":"A perennial, creeping grass (Cynodon dactylon), highly prized, in Hindostan, as food for cattle, and acclimated in the United States.","pos":""}],"DOODLE":[{"def":"A trifler; a simple fellow.","pos":""}],"DOODLESACK":[{"def":"The Scotch bagpipe.","pos":""}],"DOOLY":[{"def":"A kind of litter suspended from men's shoulders, for carrying persons or things; a palanquin.","pos":""}],"DOOM":[{"def":"Judgment; judicial sentence; penal decree; condemnation.","pos":""},{"def":"That to which one is doomed or sentenced; destiny or fate, esp.","pos":""}],"DOOM PALM":[{"def":"A species of palm tree (Hyphæne Thebaica), highly valued for the fibrous pulp of its fruit, which has the flavor of gingerbread, and is largely eaten in Egypt and Abyssinia.","pos":""}],"DOOMAGE":[{"def":"A penalty or fine for neglect.","pos":""}],"DOOMFUL":[{"def":"Full of condemnation or destructive power.","pos":""}],"DOOMSDAY":[{"def":"A day of sentence or condemnation; day of death.","pos":""},{"def":"The day of the final judgment.","pos":""}],"DOOMSMAN":[{"def":"A judge; an umpire.","pos":""}],"DOOMSTER":[{"def":"Same as Dempster.","pos":""}],"DOOR":[{"def":"An opening in the wall of a house or of an apartment, by which to go in and out; an entrance way.","pos":""},{"def":"The frame or barrier of boards, or other material, usually turning on hinges, by which an entrance way into a house or apartment is closed and opened.","pos":""}],"DOORCASE":[{"def":"The surrounding frame into which a door shuts.","pos":""}],"DOORCHEEK":[{"def":"The jamb or sidepiece of a door.","pos":""}],"DOORGA":[{"def":"A Hindoo divinity, the consort of Siva, represented with ten arms.","pos":""}],"DOORING":[{"def":"The frame of a door.","pos":""}],"DOORKEEPER":[{"def":"One who guards the entrance of a house or apartment; a porter; a janitor.","pos":""}],"DOORNAIL":[{"def":"The nail or knob on which in ancient doors the knocker struck; -- hence the old saying, \"As dead as a doornail.","pos":""}],"DOORPLANE":[{"def":"A plane on a door, giving the name, and sometimes the employment, of the occupant.","pos":""}],"DOORPOST":[{"def":"The jamb or sidepiece of a doorway.","pos":""}],"DOORSILL":[{"def":"The sill or threshold of a door.","pos":""}],"DOORSTEAD":[{"def":"Entrance or place of a door.","pos":""}],"DOORSTEP":[{"def":"The stone or plank forming a step before an outer door.","pos":""}],"DOORSTONE":[{"def":"The stone forming a threshold.","pos":""}],"DOORSTOP":[{"def":"The block or strip of wood or similar material which stops, at the right place, the shutting of a door.","pos":""}],"DOORWAY":[{"def":"The passage of a door; entrance way into a house or a room.","pos":""}],"DOORYARD":[{"def":"A yard in front of a house or around the door of a house.","pos":""},{"def":"A little copper cup in which a diamond is held while being cut.","pos":""}]}