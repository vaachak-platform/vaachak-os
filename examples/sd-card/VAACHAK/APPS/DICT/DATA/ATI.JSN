{"ATILT":[{"def":"In the manner of a tilter; in the position, or with the action, of one making a thrust.","pos":""},{"def":"In the position of a cask tilted, or with one end raised.","pos":""}],"ATIMY":[{"def":"Public disgrace or stigma; infamy; loss of civil rights.","pos":""},{"def":"A suffix forming nouns of action, and often equivalent to the verbal substantive in -ing.","pos":""}]}