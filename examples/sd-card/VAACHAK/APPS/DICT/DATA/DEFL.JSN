{"DEFLAGRABILITY":[{"def":"The state or quality of being deflagrable.","pos":""}],"DEFLAGRABLE":[{"def":"Burning with a sudden and sparkling combustion, as niter; hence, slightly explosive; liable to snap and crackle when heated, as salt.","pos":""}],"DEFLAGRATE":[{"def":"To burn with a sudden and sparkling combustion, as niter; also, to snap and crackle with slight explosions when heated, as salt.","pos":""}],"DEFLAGRATION":[{"def":"The act or process of deflagrating.","pos":""}],"DEFLAGRATOR":[{"def":"A form of the voltaic battery having large plates, used for producing rapid and powerful combustion.","pos":""}],"DEFLATE":[{"def":"To reduce from an inflated condition.","pos":""}],"DEFLECT":[{"def":"To cause to turn aside; to bend; as, rays of light are often deflected.","pos":""}],"DEFLECTABLE":[{"def":"Capable of being deflected.","pos":""}],"DEFLECTED":[{"def":"Turned aside; deviating from a direct line or course.","pos":""},{"def":"Bent downward; deflexed.","pos":""}],"DEFLECTION":[{"def":"The deviation of a shot or ball from its true course.","pos":""},{"def":"A deviation of the rays of light toward the surface of an opaque body; inflection; diffraction.","pos":""}],"DEFLECTIONIZATION":[{"def":"The act of freeing from inflections.","pos":""}],"DEFLECTIONIZE":[{"def":"To free from inflections.","pos":""}],"DEFLECTIVE":[{"def":"Causing deflection.","pos":""}],"DEFLECTOR":[{"def":"That which deflects, as a diaphragm in a furnace, or a come in a lamp (to deflect and mingle air and gases and help combustion).","pos":""}],"DEFLEXED":[{"def":"Bent abruptly downward.","pos":""}],"DEFLEXURE":[{"def":"A bending or turning aside; deflection.","pos":""}],"DEFLORATE":[{"def":"Past the flowering state; having shed its pollen.","pos":""}],"DEFLORATION":[{"def":"The act of deflouring; as, the defloration if a virgin.","pos":""},{"def":"That which is chosen as the flower or choicest part; careful culling or selection.","pos":""}],"DEFLOUR":[{"def":"To deprive of flowers.","pos":""},{"def":"To take away the prime beauty and grace of; to rob of the choicest ornament.","pos":""}],"DEFLOURER":[{"def":"One who deflours; a ravisher.","pos":""}],"DEFLOWER":[{"def":"Same as Deflour.","pos":""}],"DEFLUOUS":[{"def":"Flowing down; falling off.","pos":""}],"DEFLUXION":[{"def":"A discharge or flowing of humors or fluid matter, as from the nose in catarrh; -- sometimes used synonymously with inflammation.","pos":""}]}