{"PANPHARMACON":[{"def":"A medicine for all diseases; a panacea.","pos":""}],"PANPRESBYTERIAN":[{"def":"Belonging to, or representative of, those who hold Presbyterian views in all parts of the world; as, a Panpresbyterian council.","pos":""}],"PANPSYCHISM":[{"def":"The theory that all nature is psychical or has a psychical aspect; the theory that every particle of matter has a psychical character or aspect.","pos":""},{"def":"See Panslavic, Panslavism, etc.","pos":""}]}