{"COMMIGRATE":[{"def":"To migrate together.","pos":""}],"COMMIGRATION":[{"def":"Migration together.","pos":""}],"COMMINATION":[{"def":"A threat or threatening; a denunciation of punishment or vengeance.","pos":""},{"def":"An office in the liturgy of the Church of England, used on Ash Wednesday, containing a recital of God's anger and judgments against sinners.","pos":""}],"COMMINATORY":[{"def":"Threatening or denouncing punishment; as, comminatory terms.","pos":""}],"COMMINGLE":[{"def":"To mingle together; to mix in one mass, or intimately; to blend.","pos":""}],"COMMINGLER":[{"def":"One that commingles; specif.","pos":""}],"COMMINUTE":[{"def":"To reduce to minute particles, or to a fine powder; to pulverize; to triturate; to grind; as, to comminute chalk or bones; to comminute food with the teeth.","pos":""}],"COMMINUTION":[{"def":"Fracture (of a bone) into a number of pieces.","pos":""}],"COMMISERATE":[{"def":"To feel sorrow, pain, or regret for; to pity.","pos":""}],"COMMISERATION":[{"def":"The act of commiserating; sorrow for the wants, afflictions, or distresses of another; pity; compassion.","pos":""}],"COMMISERATIVE":[{"def":"Feeling or expressing commiseration.","pos":""}],"COMMISSARIAL":[{"def":"Of or pertaining to a commissary.","pos":""}],"COMMISSARY":[{"def":"An officer on the bishop, who exercises ecclesiastical jurisdiction in parts of the diocese at a distance from the residence of the bishop.","pos":""}],"COMMISSARYSHIP":[{"def":"The office or employment of a commissary.","pos":""}],"COMMISSION":[{"def":"The act of committing, doing, or performing; the act of perpetrating.","pos":""},{"def":"The act of intrusting; a charge; instructions as to how a trust shall be executed.","pos":""}],"COMMISSIONAIRE":[{"def":"Of pertaining to, or conferring, a commission; conferred by a commission or warrant.","pos":""}],"COMMISSIONATE":[{"def":"To commission [Obs.","pos":""}],"COMMISSIONER":[{"def":"A person who has a commission or warrant to perform some office, or execute some bussiness, for the goverment, corporation, or person employing him; as, a commissioner to take affidavits or to adjust claims.","pos":""},{"def":"An officer having charge of some department or bureau of the public service.","pos":""}],"COMMISSIONNAIRE":[{"def":"An agent or factor; a commission merchant.","pos":""},{"def":"One of a class of attendants, in some European cities, who perform miscellaneous services for travelers.","pos":""}],"COMMISSIONSHIP":[{"def":"The office of commissioner.","pos":""}],"COMMISSIVE":[{"def":"Relating to commission; of the nature of, or involving, commission.","pos":""}],"COMMISSURAL":[{"def":"Of or pertaining to a commissure.","pos":""}],"COMMISSURE":[{"def":"The line of junction or cohering face of two carpels, as in the parsnip, caraway, etc.","pos":""}],"COMMIT":[{"def":"To give in trust; to put into charge or keeping; to intrust; to consign; -- used with to, unto.","pos":""},{"def":"To put in charge of a jailor; to imprison.","pos":""}],"COMMITMENT":[{"def":"The act of commiting, or putting in charge, keeping, or trust; consigment; esp.","pos":""},{"def":"A warrant or order for the imprisonment of a person; -- more frequently termed a mittimus.","pos":""}],"COMMITTABLE":[{"def":"Capable of being committed.","pos":""}],"COMMITTAL":[{"def":"The act of commiting, or the state of being committed; commitment.","pos":""}],"COMMITTEE":[{"def":"One or more persons elected or appointed, to whom any matter or bussiness is referred, either by a legislative body, or by a court, or by any collective body of men acting together.","pos":""}],"COMMITTEEMAN":[{"def":"A member of a committee.","pos":""}],"COMMITTER":[{"def":"One who commits; one who does or perpetrates.","pos":""}],"COMMITTIBLE":[{"def":"Capable of being committed; liable to be committed.","pos":""}],"COMMIX":[{"def":"To mix or mingle together; to blend.","pos":""}],"COMMIXTION":[{"def":"Commixture; mingling.","pos":""}],"COMMIXTURE":[{"def":"The act or process of mixing; the state of being mingled; the blending of ingredients in one mass or compound.","pos":""},{"def":"The mass formed by mingling different things; a compound; a mixture.","pos":""}]}