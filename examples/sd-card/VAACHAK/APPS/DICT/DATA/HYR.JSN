{"HYRACOID":[{"def":"Of or pertaining to the Hyracoidea.","pos":""},{"def":"One of the Hyracoidea.","pos":""}],"HYRACOIDEA":[{"def":"An order of small hoofed mammals, comprising the single living genus Hyrax.","pos":""}],"HYRAX":[{"def":"Any animal of the genus Hyrax, of which about four species are known.","pos":""},{"def":"Of or pertaining to Hyrcania, an ancient country or province of Asia, southeast of the Caspian (which was also called the Hyracanian) Sea.","pos":""}]}