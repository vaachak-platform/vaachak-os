{"UNKE":[{"def":"A European aquatic toad (Bombinator igneus).","pos":""}],"UNKED":[{"def":"Odd; strange; ugly; old; uncouth.","pos":""},{"def":"Lonely; dreary; unkard.","pos":""}],"UNKEMPT":[{"def":"Not combed; disheveled; as, an urchin with unkempt hair.","pos":""}],"UNKENNEL":[{"def":"To drive from a kennel or hole; as, to unkennel a fox.","pos":""}],"UNKENT":[{"def":"Unknown; strange.","pos":""}],"UNKIND":[{"def":"Having no race or kindred; childless.","pos":""}],"UNKINDLY":[{"def":"Not kindly; unkind; ungracious.","pos":""},{"def":"Unnatural; contrary to nature.","pos":""}],"UNKINDRED":[{"def":"Not kindred; not of the same kin.","pos":""}],"UNKING":[{"def":"To cause to cease to be a king.","pos":""}],"UNKINGSHIP":[{"def":"The quality or condition of being unkinged; abolition of monarchy.","pos":""}],"UNKISS":[{"def":"To cancel or annul what was done or sealed by a kiss; to cancel by a kiss.","pos":""}],"UNKNIGHT":[{"def":"To deprive of knighthood.","pos":""}],"UNKNIT":[{"def":"To undo or unravel what is knitted together.","pos":""}],"UNKNOT":[{"def":"To free from knots; to untie.","pos":""}],"UNKNOW":[{"def":"To cease to know; to lose the knowledge of.","pos":""},{"def":"To fail of knowing; to be ignorant of.","pos":""}],"UNKNOWLEDGED":[{"def":"Not acknowledged or recognized.","pos":""}],"UNKNOWN":[{"def":"Not known; not apprehended.","pos":""}]}