{"BAFF":[{"def":"A blow; a stroke.","pos":""}],"BAFFLE":[{"def":"To cause to undergo a disgraceful punishment, as a recreant knight.","pos":""},{"def":"To check by shifts and turns; to elude; to foil.","pos":""}],"BAFFLEMENT":[{"def":"The process or act of baffling, or of being baffled; frustration; check.","pos":""}],"BAFFLER":[{"def":"One who, or that which, baffles.","pos":""}],"BAFFLING":[{"def":"Frustrating; discomfiting; disconcerting; as, baffling currents, winds, tasks.","pos":""}],"BAFFY":[{"def":"A short wooden club having a deeply concave face, seldom used.","pos":""}],"BAFTA":[{"def":"A coarse stuff, usually of cotton, originally made in India.","pos":""}]}