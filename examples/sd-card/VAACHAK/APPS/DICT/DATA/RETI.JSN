{"RETIARIUS":[{"def":"A gladiator armed with a net for entangling his adversary and a trident for despatching him.","pos":""}],"RETIARY":[{"def":"Any spider which spins webs to catch its prey.","pos":""}],"RETICENCE":[{"def":"A figure by which a person really speaks of a thing while he makes a show as if he would say nothingon the subject.","pos":""}],"RETICENT":[{"def":"Inclined to keep silent; reserved; uncommunicative.","pos":""}],"RETICULAR":[{"def":"Of or pertaining to a reticulum.","pos":""}],"RETICULARIA":[{"def":"An extensive division of rhizopods in which the pseudopodia are more or less slender and coalesce at certain points, forming irregular meshes.","pos":"noun"}],"RETICULARIAN":[{"def":"One of the Reticularia.","pos":""}],"RETICULARLY":[{"def":"In a reticular manner.","pos":""}],"RETICULATION":[{"def":"The quality or state of being reticulated, or netlike; that which is reticulated; network; an organization resembling a net.","pos":""}],"RETICULE":[{"def":"A little bag, originally of network; a woman's workbag, or a little bag to be carried in the hand.","pos":""},{"def":"A system of wires or lines in the focus of a telescope or other instrument; a reticle.","pos":""}],"RETICULOSA":[{"def":"Same as Reticularia.","pos":"noun"}],"RETICULOSE":[{"def":"Forming a network; characterized by a reticulated sructure.","pos":""}],"RETIFORM":[{"def":"Composed of crossing lines and interstices; reticular; netlike; as, the retiform coat of the eye.","pos":""}],"RETINA":[{"def":"The delicate membrane by which the back part of the globe of the eye is lined, and in which the fibers of the optic nerve terminate.","pos":""}],"RETINACULUM":[{"def":"One of the retractor muscles of the proboscis of certain worms.","pos":""},{"def":"A small gland or process to which bodies are attached; as, the glandular retinacula to which the pollinia of orchids are attached, or the hooks which support the seeds in many acanthaceous plants.","pos":""}],"RETINAL":[{"def":"Of or pertaining to the retina.","pos":""}],"RETINALITE":[{"def":"A translucent variety of serpentine, of a honey yellow or greenish yellow color, having a waxy resinlike luster.","pos":""}],"RETINERVED":[{"def":"Having reticulated veins.","pos":""}],"RETINEUM":[{"def":"That part of the eye of an invertebrate which corresponds in function with the retina of a vertebrate.","pos":""}],"RETINIC":[{"def":"Of or pertaining to resin; derived from resin; specifically, designating an acid found in certain fossil resins and hydrocarbons.","pos":""}],"RETINITE":[{"def":"An inflammable mineral resin, usually of a yellowish brown color, found in roundish masses, sometimes with coal.","pos":""}],"RETINITIS":[{"def":"Inflammation of the retina.","pos":""}],"RETINOID":[{"def":"Resinlike, or resinform; resembling a resin without being such.","pos":""}],"RETINOL":[{"def":"A hydrocarbon oil obtained by the distillation of resin, -- used in printer's ink.","pos":""}],"RETINOPHORA":[{"def":"One of group of two to four united cells which occupy the axial part of the ocelli, or ommatidia, of the eyes of invertebrates, and contain the terminal nerve fibrillæ.","pos":""}],"RETINOPHORAL":[{"def":"Of or pertaining to retinophoræ.","pos":""}],"RETINOSCOPY":[{"def":"The study of the retina of the eye by means of the ophthalmoscope.","pos":""}],"RETINUE":[{"def":"The body of retainers who follow a prince or other distinguished person; a train of attendants; a suite.","pos":""}],"RETINULA":[{"def":"One of the group of pigmented cells which surround the retinophoræ of invertebrates.","pos":""}],"RETIPED":[{"def":"A bird having small polygonal scales covering the tarsi.","pos":""}],"RETIRACY":[{"def":"Retirement; -- mostly used in a jocose or burlesque way.","pos":""}],"RETIRADE":[{"def":"A kind of retrenchment, as in the body of a bastion, which may be disputed inch by inch after the defenses are dismantled.","pos":""}],"RETIRE":[{"def":"To withdraw; to take away; -- sometimes used reflexively.","pos":""},{"def":"To withdraw from circulation, or from the market; to take up and pay; as, to retire bonds; to retire a note.","pos":""}],"RETIRED":[{"def":"Private; secluded; quiet; as, a retired life; a person of retired habits.","pos":""},{"def":"Withdrawn from active duty or business; as, a retired officer; a retired physician.","pos":""}],"RETIREMENT":[{"def":"The act of retiring, or the state of being retired; withdrawal; seclusion; as, the retirement of an officer.","pos":""},{"def":"A place of seclusion or privacy; a place to which one withdraws or retreats; a private abode.","pos":""}],"RETIRER":[{"def":"One who retires.","pos":""}],"RETIRING":[{"def":"Reserved; shy; not forward or obtrusive; as, retiring modesty; retiring manners.","pos":""},{"def":"Of or pertaining to retirement; causing retirement; suited to, or belonging to, retirement.","pos":""}],"RETISTENE":[{"def":"A white crystalline hydrocarbon produced indirectly from retene.","pos":""}],"RETITELAE":[{"def":"A group of spiders which spin irregular webs; -- called also Retitelariæ.","pos":""}]}