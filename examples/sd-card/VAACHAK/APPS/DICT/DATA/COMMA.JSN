{"COMMA":[{"def":"A small interval (the difference beyween a major and minor half step), seldom used except by tuners.","pos":""}],"COMMAND":[{"def":"To order with authority; to lay injunction upon; to direct; to bid; to charge.","pos":""},{"def":"To exercise direct authority over; to have control of; to have at one's disposal; to lead.","pos":""}],"COMMANDABLE":[{"def":"Capable of being commanded.","pos":""}],"COMMANDANT":[{"def":"A commander; the commanding officer of a place, or of a body of men; as, the commandant of a navy-yard.","pos":""}],"COMMANDATORY":[{"def":"Mandatory; as, commandatory authority.","pos":""}],"COMMANDEER":[{"def":"To compel to perform military service; to seize for military purposes; -- orig.","pos":""}],"COMMANDER":[{"def":"An officer who ranks next below a captain, -- ranking with a lieutenant colonel in the army.","pos":""}],"COMMANDERSHIP":[{"def":"The office of a commander.","pos":""}],"COMMANDERY":[{"def":"The office or rank of a commander.","pos":""},{"def":"A district or a manor with lands and tenements appertaining thereto, under the control of a member of an order of knights who was called a commander; -- called also a preceptory.","pos":""}],"COMMANDING":[{"def":"Exercising authority; actually in command; as, a commanding officer.","pos":""},{"def":"Fitted to impress or control; as, a commanding look or presence.","pos":""}],"COMMANDINGLY":[{"def":"In a commanding manner.","pos":""}],"COMMANDMENT":[{"def":"One of the ten laws or precepts given by God to the Israelites at Mount Sinai.","pos":""},{"def":"The offense of commanding or inducing another to violate the law.","pos":""}],"COMMANDO":[{"def":"In South Africa, a military body or command; also, sometimes, an expedition or raid; as, a commando of a hundred Boers.","pos":""}],"COMMANDRESS":[{"def":"A woman invested with authority to command.","pos":""}],"COMMARK":[{"def":"The frontier of a country; confines.","pos":""}],"COMMATERIAL":[{"def":"Consisting of the same material.","pos":""}],"COMMATIC":[{"def":"Having short clauses or sentences; brief; concise.","pos":""}],"COMMATISM":[{"def":"Conciseness in writing.","pos":""}]}