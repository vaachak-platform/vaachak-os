{"TAX":[{"def":"A charge, especially a pecuniary burden which is imposed by authority.","pos":""},{"def":"A task exacted from one who is under control; a contribution or service, the rendering of which is imposed upon a subject.","pos":""}],"TAXABILITY":[{"def":"The quality or state of being taxable; taxableness.","pos":""}],"TAXABLE":[{"def":"That may be legally charged by a court against the plaintiff of defendant in a suit; as, taxable costs.","pos":""}],"TAXASPIDEAN":[{"def":"Having the posterior tarsal scales, or scutella, rectangular and arranged in regular rows; -- said of certain birds.","pos":""}],"TAXATION":[{"def":"The act of taxing, or assessing a bill of cost.","pos":""}],"TAXEL":[{"def":"The American badger.","pos":""}],"TAXEOPODA":[{"def":"An order of extinct Mammalia found in the Tertiary formations.","pos":""}],"TAXER":[{"def":"One of two officers chosen yearly to regulate the assize of bread, and to see the true gauge of weights and measures is observed.","pos":""}],"TAXGATHERER":[{"def":"One who collects taxes or revenues.","pos":""}],"TAXIARCH":[{"def":"An Athenian military officer commanding a certain division of an army.","pos":""}],"TAXICORN":[{"def":"One of a family of beetles (Taxicornes) whose antennæ are largest at the tip.","pos":""}],"TAXIDERMIC":[{"def":"Of or pertaining to the art of preparing and preserving the skins of animals.","pos":""}],"TAXIDERMIST":[{"def":"A person skilled in taxidermy.","pos":""}],"TAXIDERMY":[{"def":"The art of preparing, preserving, and mounting the skins of animals so as to represent their natural appearance, as for cabinets.","pos":""}],"TAXINE":[{"def":"A poisonous alkaloid of bitter taste extracted from the leaves and seeds of the European yew (Taxus baccata).","pos":""}],"TAXIS":[{"def":"Manipulation applied to a hernial tumor, or to an intestinal obstruction, for the purpose of reducing it.","pos":""}],"TAXLESS":[{"def":"Free from taxation.","pos":""}],"TAXOLOGY":[{"def":"Same as Taxonomy.","pos":""}],"TAXONOMIC":[{"def":"Pertaining to, or involving, taxonomy, or the laws and principles of classification; classificatory.","pos":""}],"TAXONOMIST":[{"def":"One skilled in taxonomy.","pos":""}],"TAXONOMY":[{"def":"That division of the natural sciences which treats of the classification of animals and plants; the laws or principles of classification.","pos":""}],"TAXOR":[{"def":"Same as Taxer, n.","pos":""}],"TAXPAYER":[{"def":"One who is assessed and pays a tax.","pos":""}]}