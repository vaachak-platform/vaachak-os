{"DAK":[{"def":"Post; mail; also, the mail or postal arrangements; -- spelt also dawk, and dauk.","pos":""},{"def":"A measure of certain commodities by number, usually ten or twelve, but sometimes twenty; as, a daker of hides consisted of ten skins; a daker of gloves of ten pairs.","pos":""}],"DAKER HEN":[{"def":"The corncrake or land rail.","pos":""},{"def":"See Dacoit, Dacoity.","pos":""}],"DAKOTA GROUP":[{"def":"A subdivision at the base of the cretaceous formation in Western North America; -- so named from the region where the strata were first studied.","pos":""}],"DAKOTAS":[{"def":"An extensive race or stock of Indians, including many tribes, mostly dwelling west of the Mississippi River; -- also, in part, called Sioux.","pos":""}]}