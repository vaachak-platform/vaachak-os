{"PARAM":[{"def":"A white crystalline nitrogenous substance (C2H4N4); -- called also dicyandiamide.","pos":""}],"PARAMAGNETIC":[{"def":"Magnetic, as opposed to Ant: diamagnetic.","pos":""},{"def":"A paramagnetic substance.","pos":""}],"PARAMAGNETISM":[{"def":"Magnetism, as opposed to diamagnetism.","pos":""}],"PARAMALEIC":[{"def":"Pertaining to, or designating, an acid obtained from malic acid, and now called fumaric acid.","pos":""}],"PARAMALIC":[{"def":"Pertaining to, or designating, an organic acid metameric with malic acid.","pos":""}],"PARAMASTOID":[{"def":"Situated beside, or near, the mastoid portion of the temporal bone; paroccipital; -- applied especially to a process of the skull in some animals.","pos":""}],"PARAMATTA":[{"def":"A light fabric of cotton and worsted, resembling bombazine or merino.","pos":""}],"PARAMENT":[{"def":"Ornamental hangings, furniture, etc.","pos":""}],"PARAMENTO":[{"def":"Ornament; decoration.","pos":""}],"PARAMERE":[{"def":"One of the symmetrical halves of any one of the radii, or spheromeres, of a radiate animal, as a starfish.","pos":""}],"PARAMETER":[{"def":"The ratio of the three crystallographic axes which determines the position of any plane; also, the fundamental axial ratio for a given species.","pos":""}],"PARAMETRITIS":[{"def":"Inflammation of the cellular tissue in the vicinity of the uterus.","pos":""}],"PARAMIOGRAPHER":[{"def":"A collector or writer of proverbs.","pos":""}],"PARAMITOME":[{"def":"The fluid portion of the protoplasm of a cell.","pos":""}],"PARAMO":[{"def":"A high, bleak plateau or district, with stunted trees, and cold, damp atmosphere, as in the Andes, in South America.","pos":""}],"PARAMORPH":[{"def":"A kind of pseudomorph, in which there has been a change of physical characters without alteration of chemical composition, as the change of aragonite to calcite.","pos":""}],"PARAMORPHISM":[{"def":"The change of one mineral species to another, so as to involve a change in physical characters without alteration of chemical composition.","pos":""}],"PARAMORPHOUS":[{"def":"Relating to paramorphism; exhibiting paramorphism.","pos":""}],"PARAMOUNT":[{"def":"Having the highest rank or jurisdiction; superior to all others; chief; supreme; preëminent; as, a paramount duty.","pos":""}],"PARAMOUNTLY":[{"def":"In a paramount manner.","pos":""}],"PARAMOUR":[{"def":"By or with love, esp.","pos":""}],"PARAMYLUM":[{"def":"A substance resembling starch, found in the green frothy scum formed on the surface of stagnant water.","pos":""}]}