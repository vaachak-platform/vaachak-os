{"CLARE":[{"def":"A nun of the order of St.","pos":""}],"CLARE-OBSCURE":[{"def":"See Chiaroscuro.","pos":""}],"CLARENCE":[{"def":"A close four-wheeled carriage, with one seat inside, and a seat for the driver.","pos":""},{"def":"See King-at-arms.","pos":""}],"CLARENDON":[{"def":"A style of type having a narrow and heave face.","pos":""}],"CLARIBELLA":[{"def":"A soft, sweet stop, or set of open wood pipes in an organ.","pos":""}],"CLARICHORD":[{"def":"A musical instrument, formerly in use, in form of a spinet; -- called also manichord and clavichord.","pos":""}],"CLARIFICATION":[{"def":"The act or process of making clear or transparent, by freeing visible impurities; as, the clarification of wine.","pos":""},{"def":"The act of freeing from obscurities.","pos":""}],"CLARIFIER":[{"def":"That which clarifies.","pos":""},{"def":"A vessel in which the process of clarification is conducted; as, the clarifier in sugar works.","pos":""}],"CLARIFY":[{"def":"To make clear or bright by freeing from feculent matter; to defecate; to fine; -- said of liquids, as wine or sirup.","pos":""},{"def":"To make clear; to free from obscurities; to brighten or illuminate.","pos":""}],"CLARIGATE":[{"def":"To declare war with certain ceremonies.","pos":""}],"CLARINET":[{"def":"A wind instrument, blown by a single reed, of richer and fuller tone than the oboe, which has a double reed.","pos":""}],"CLARINO":[{"def":"A reed stop in an organ.","pos":""}],"CLARION":[{"def":"A kind of trumpet, whose note is clear and shrill.","pos":""}],"CLARISONUS":[{"def":"Having a clear sound.","pos":""}],"CLARITUDE":[{"def":"Clearness; splendor.","pos":""}],"CLARITY":[{"def":"Clearness; brightness; splendor.","pos":""}],"CLARO-OBSCURO":[{"def":"See Chiaroscuro.","pos":""}],"CLARRE":[{"def":"Wine with a mixture of honey and species.","pos":""}],"CLART":[{"def":"To daub, smear, or spread, as with mud, etc.","pos":""}],"CLARTY":[{"def":"Sticky and foul; muddy; filthy; dirty.","pos":""}],"CLARY":[{"def":"To make a loud or shrill noise.","pos":""}]}