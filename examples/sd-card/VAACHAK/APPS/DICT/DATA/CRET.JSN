{"CRETACEOUS":[{"def":"Having the qualities of chalk;abounding with chalk; chalky; as, cretaceous rocks and formations.","pos":""},{"def":"Of, pertaining to, or designating, the period of time following the Jurassic and preceding the Eocene.","pos":""}],"CRETACEOUSLY":[{"def":"In a chalky manner; as chalk.","pos":""}],"CRETAN":[{"def":"Pertaining to Crete, or Candia.","pos":""},{"def":"A native or inhabitant of Crete or Candia.","pos":""}],"CRETIAN":[{"def":"Cre\"tian (kr\"shan), a.","pos":""}],"CRETIC":[{"def":"A poetic foot, composed of one short syllable between two long ones (-Bentley.","pos":""}],"CRETICISM":[{"def":"Falsehood; lying; cretism.","pos":""}],"CRETIN":[{"def":"One afflicted with cretinism.","pos":""}],"CRETINISM":[{"def":"A condition of endemic or inherited idiocy, accompanied by physical degeneracy and deformity (usually with goiter), frequent in certain mountain valleys, esp.","pos":""}],"CRETINOUS":[{"def":"Having the characteristics of a cretin.","pos":""}],"CRETISM":[{"def":"A Cretan practice; iying; a falsehood.","pos":""}],"CRETONNE":[{"def":"A strong white fabric with warp of hemp and welt of flax.","pos":""},{"def":"A fabric with cotton warp and woolen weft.","pos":""}],"CRETOSE":[{"def":"Chalky; cretaceous.","pos":""}]}