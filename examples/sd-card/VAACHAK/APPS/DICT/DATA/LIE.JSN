{"LIE":[{"def":"A falsehood uttered or acted for the purpose of deception; an intentional violation of truth; an untruth spoken with the intention to deceive.","pos":""},{"def":"A fiction; a fable; an untruth.","pos":""}],"LIED":[{"def":"A lay; a German song.","pos":""}],"LIEDERTAFEL":[{"def":"A popular name for any society or club which meets for the practice of male part songs.","pos":""}],"LIEF":[{"def":"Pleasing; agreeable; acceptable; preferable.","pos":""}],"LIEFSOME":[{"def":"Pleasing; delightful.","pos":""}],"LIEGANCE":[{"def":"Same as Ligeance.","pos":""}],"LIEGE":[{"def":"Full; perfect; complete; pure.","pos":""}],"LIEGEMAN":[{"def":"Same as Liege, n.","pos":""}],"LIEGER":[{"def":"A resident ambassador.","pos":""}],"LIEN":[{"def":"A legal claim; a charge upon real or personal property for the satisfaction of some debt or duty; a right in one to control or hold and retain the property of another until some claim of the former is paid or satisfied.","pos":""}],"LIENAL":[{"def":"Of or pertaining to the spleen; splenic.","pos":""}],"LIENCULUS":[{"def":"One of the small nodules sometimes found in the neighborhood of the spleen; an accessory or supplementary spleen.","pos":""}],"LIENO-INTESTINAL":[{"def":"Of or pertaining to the spleen and intestine; as, the lieno- intestinal vein of the frog.","pos":""}],"LIENTERIC":[{"def":"Of or pertaining to, or of the nature of, a lientery.","pos":""}],"LIENTERY":[{"def":"A diarrhea, in which the food is discharged imperfectly digested, or with but little change.","pos":""}],"LIER":[{"def":"One who lies down; one who rests or remains, as in concealment.","pos":""}],"LIERNE RIB":[{"def":"In Gothic vaulting, any rib which does not spring from the impost and is not a ridge rib, but passes from one boss or intersection of the principal ribs to another.","pos":""}],"LIEU":[{"def":"Place; room; stead; -- used only in the phrase in lieu of, that is, instead of.","pos":""}],"LIEUTENANCY":[{"def":"The office, rank, or commission, of a lieutenant.","pos":""},{"def":"The body of lieutenants or subordinates.","pos":""}],"LIEUTENANT":[{"def":"An officer who supplies the place of a superior in his absence; a representative of, or substitute for, another in the performance of any duty.","pos":""}],"LIEUTENANT GENERAL":[{"def":"Lieu*ten\"ant gen\"er*al Defn: .","pos":""}],"LIEUTENANTRY":[{"def":"See Lieutenancy.","pos":""}],"LIEUTENANTSHIP":[{"def":"Same as Lieutenancy, 1.","pos":""}]}