{"FUD":[{"def":"The tail of a hare, coney, etc.","pos":""},{"def":"Woolen waste, for mixing with mungo and shoddy.","pos":""}],"FUDDER":[{"def":"See Fodder, a weight.","pos":""}],"FUDDLE":[{"def":"To make foolish by drink; to cause to become intoxicated.","pos":""}],"FUDGE":[{"def":"A made-up story; stuff; nonsense; humbug; -- often an exclamation of contempt.","pos":""}],"FUDGE WHEEL":[{"def":"A tool for ornamenting the edge of a sole.","pos":""}]}