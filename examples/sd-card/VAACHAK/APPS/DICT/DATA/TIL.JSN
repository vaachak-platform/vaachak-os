{"TILBURY":[{"def":"A kind of gig or two-wheeled carriage, without a top or cover.","pos":""}],"TILDE":[{"def":"The accentual mark placed over n, and sometimes over l, in Spanish words [thus, ñ, l], indicating that, in pronunciation, the sound of the following vowel is to be preceded by that of the initial, or consonantal, y.","pos":""}],"TILE":[{"def":"To protect from the intrusion of the uninitiated; as, to tile a Masonic lodge.","pos":""}],"TILE-DRAIN":[{"def":"To drain by means of tiles; to furnish with a tile drain.","pos":""}],"TILEFISH":[{"def":"A large, edible, deep-water food fish (Lopholatilus chamæleonticeps) more or less thickly covered with large, round, yellow spots.","pos":""}],"TILER":[{"def":"A man whose occupation is to cover buildings with tiles.","pos":""}],"TILERY":[{"def":"A place where tiles are made or burned; a tile kiln.","pos":""}],"TILESEED":[{"def":"Any plant of the genus Geissois, having seeds overlapping like tiles on a roof.","pos":""}],"TILESTONE":[{"def":"A kind of laminated shale or sandstone belonging to some of the layers of the Upper Silurian.","pos":""}],"TILIA":[{"def":"A genus of trees, the lindens, the type of the family Tiliaceæ, distinguished by the winglike bract coalescent with the peduncle, and by the indehiscent fruit having one or two seeds.","pos":""}],"TILIACEOUS":[{"def":"Of, pertaining to, or resembling, a natural order of plants (Tiliaceæ) of which the linden (Tilia) is the type.","pos":""}],"TILING":[{"def":"A surface covered with tiles, or composed of tiles.","pos":""},{"def":"Tiles, collectively.","pos":""}],"TILL":[{"def":"A vetch; a tare.","pos":""}],"TILLABLE":[{"def":"Capable of being tilled; fit for the plow; arable.","pos":""}],"TILLAGE":[{"def":"The operation, practice, or art of tilling or preparing land for seed, and keeping the ground in a proper state for the growth of crops.","pos":""},{"def":"A place tilled or cultivated; cultivated land.","pos":""}],"TILLANDSIA":[{"def":"A genus of epiphytic endogenous plants found in the Southern United States and in tropical America.","pos":""}],"TILLER":[{"def":"One who tills; a husbandman; a cultivator; a plowman.","pos":""}],"TILLMAN":[{"def":"A man who tills the earth; a husbandman.","pos":""}],"TILLODONT":[{"def":"One of the Tillodontia.","pos":""}],"TILLODONTIA":[{"def":"An extinct group of Mammalia found fossil in the Eocene formation.","pos":""}],"TILLOT":[{"def":"A bag made of thin glazed muslin, used as a wrapper for dress goods.","pos":""}],"TILLY-VALLY":[{"def":"A word of unknown origin and signification, formerly used as expressive of contempt, or when anything said was reject as trifling or impertinent.","pos":""}],"TILT":[{"def":"A cloth cover of a boat; a small canopy or awning extended over the sternsheets of a boat.","pos":""}],"TILT HAMMER":[{"def":"A tilted hammer; a heavy hammer, used in iron works, which is lifted or tilted by projections or wipers on a revolving shaft; a trip hammer.","pos":""}],"TILT-MILL":[{"def":"A mill where a tilt hammer is used, or where the process of tilting is carried on.","pos":""}],"TILT-YARD":[{"def":"A yard or place for tilting.","pos":""}],"TILTER":[{"def":"One who tilts, or jousts; hence, one who fights.","pos":""},{"def":"One who operates a tilt hammer.","pos":""}],"TILTH":[{"def":"The state of being tilled, or prepared for a crop; culture; as, land is good tilth.","pos":""},{"def":"That which is tilled; tillage ground.","pos":""}],"TILTING":[{"def":"The act of one who tilts; a tilt.","pos":""},{"def":"The process by which blister steel is rendered ductile by being forged with a tilt hammer.","pos":""}]}