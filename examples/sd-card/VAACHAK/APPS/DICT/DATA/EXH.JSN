{"EXHALABLE":[{"def":"Capable of being exhaled or evaporated.","pos":""}],"EXHALANT":[{"def":"Having the quality of exhaling or evaporating.","pos":""}],"EXHALATION":[{"def":"The act or process of exhaling, or sending forth in the form of steam or vapor; evaporation.","pos":""},{"def":"That which is exhaled, or which rises in the form of vapor, fume, or steam; effluvium; emanation; as, exhalations from the earth or flowers, decaying matter, etc.","pos":""}],"EXHALE":[{"def":"To draw out; to cause to be emitted in vapor; as, the sum exhales the moisture of the earth.","pos":""}],"EXHAUST":[{"def":"To subject to the action of various solvents in order to remove all soluble substances or extractives; as, to exhaust a drug successively with water, alcohol, and ether.","pos":""}],"EXHAUSTER":[{"def":"One who, or that which, exhausts or draws out.","pos":""}],"EXHAUSTIBILITY":[{"def":"Capability of being exhausted.","pos":""}],"EXHAUSTIBLE":[{"def":"Capable of being exhausted, drained off, or expended.","pos":""}],"EXHAUSTING":[{"def":"Producing exhaustion; as, exhausting labors.","pos":""}],"EXHAUSTION":[{"def":"An ancient geometrical method in which an exhaustive process was employed.","pos":""}],"EXHAUSTIVE":[{"def":"Serving or tending to exhaust; exhibiting all the facts or arguments; as, an exhaustive method.","pos":""}],"EXHAUSTLESS":[{"def":"Not be exhausted; inexhaustible; as, an exhaustless fund or store.","pos":""}],"EXHAUSTMENT":[{"def":"Exhaustion; drain.","pos":""}],"EXHEREDATION":[{"def":"A disinheriting; disherisor.","pos":""}],"EXHEREDITATION":[{"def":"A disinheriting; disherison.","pos":""}],"EXHIBIT":[{"def":"To submit, as a document, to a court or officer, in course of proceedings; also, to present or offer officially or in legal form; to bring, as a charge.","pos":""},{"def":"To administer as a remedy; as, to exhibit calomel.","pos":""}],"EXHIBITER":[{"def":"One who exhibits; one who presents a petition, charge or bill.","pos":""}],"EXHIBITION":[{"def":"The act of administering a remedy.","pos":""}],"EXHIBITIONER":[{"def":"One who has a pension or allowance granted for support.","pos":""}],"EXHIBITIVE":[{"def":"Serving for exhibition; representative; exhibitory.","pos":""}],"EXHIBITOR":[{"def":"One who exhibits.","pos":""}],"EXHIBITORY":[{"def":"Exhibiting; publicly showing.","pos":""}],"EXHILARANT":[{"def":"Exciting joy, mirth, or pleasure.","pos":""},{"def":"That which exhilarates.","pos":""}],"EXHILARATE":[{"def":"To make merry or jolly; to enliven; to animate; to gladden greatly; to cheer; as, good news exhilarates the mind; wine exhilarates a man.","pos":""}],"EXHILARATING":[{"def":"That exhilarates; cheering; gladdening.","pos":""}],"EXHILARATION":[{"def":"The act of enlivening the spirits; the act of making glad or cheerful; a gladdening.","pos":""},{"def":"The state of being enlivened or cheerful.","pos":""}],"EXHORT":[{"def":"To incite by words or advice; to animate or urge by arguments, as to a good deed or laudable conduct; to address exhortation to; to urge strongly; hence, to advise, warn, or caution.","pos":""}],"EXHORTATION":[{"def":"The act of practice of exhorting; the act of inciting to laudable deeds; incitement to that which is good or commendable.","pos":""},{"def":"Language intended to incite and encourage; advice; counsel; admonition.","pos":""}],"EXHORTATIVE":[{"def":"Serving to exhort; exhortatory; hortative.","pos":""}],"EXHORTATORY":[{"def":"Of or pertaining to exhortation; hortatory.","pos":""}],"EXHORTER":[{"def":"One who exhorts or incites.","pos":""}],"EXHUMATION":[{"def":"The act of exhuming that which has been buried; as, the exhumation of a body.","pos":""}],"EXHUME":[{"def":"To dig out of the ground; to take out of a place of burial; to disinter.","pos":""}]}