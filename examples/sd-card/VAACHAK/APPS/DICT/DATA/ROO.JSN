{"ROOD":[{"def":"A representation in sculpture or in painting of the cross with Christ hanging on it.","pos":""},{"def":"A measure of five and a half yards in length; a red; a perch; a pole.","pos":""}],"ROOF":[{"def":"The cover of any building, including the roofing (see Roofing) and all the materials and construction necessary to carry and maintain the same upon the walls or other uprights.","pos":""},{"def":"The surface or bed of rock immediately overlying a bed of coal or a flat vein.","pos":""}],"ROOFER":[{"def":"One who puts on roofs.","pos":""}],"ROOFING":[{"def":"The wedging, as of a horse or car, against the top of an underground passage.","pos":""}],"ROOFLESS":[{"def":"Having no roof; as, a roofless house.","pos":""},{"def":"Having no house or home; shelterless; homeless.","pos":""}],"ROOFLET":[{"def":"A small roof, covering, or shelter.","pos":""}],"ROOFTREE":[{"def":"The beam in the angle of a roof; hence, the roof itself.","pos":""}],"ROOK":[{"def":"To squat; to ruck.","pos":""}],"ROOKERY":[{"def":"The breeding place of a colony of rooks; also, the birds themselves.","pos":""},{"def":"A breeding place of other gregarious birds, as of herons, penguins, etc.","pos":""}],"ROOKY":[{"def":"Light thickens, and the crow Makes wing to the rooky wood.","pos":""}],"ROOM":[{"def":"Unobstructed spase; space which may be occupied by or devoted to any object; compass; extent of place, great or small; as, there is not room for a house; the table takes up too much room.","pos":""},{"def":"A particular portion of space appropriated for occupancy; a place to sit, stand, or lie; a seat.","pos":""}],"ROOMAGE":[{"def":"Space; place; room.","pos":""}],"ROOMER":[{"def":"At a greater distance; farther off.","pos":""}],"ROOMFUL":[{"def":"Abounding with room or rooms; roomy.","pos":""}],"ROOMINESS":[{"def":"The quality or state of being roomy; spaciousness; as, the roominess of a hall.","pos":""}],"ROOMLESS":[{"def":"Being without room or rooms.","pos":""}],"ROOMMATE":[{"def":"One of twe or more occupying the same room or rooms; one who shares the occupancy of a room or rooms; a chum.","pos":""}],"ROOMTHY":[{"def":"Roomy; spacious.","pos":""}],"ROOMY":[{"def":"Having ample room; spacious; large; as, a roomy mansion; a roomy deck.","pos":""}],"ROON":[{"def":"Vermilion red; red.","pos":""}],"ROOP":[{"def":"A defamatory forgery or falsehood published for purposes of political intrigue.","pos":""}],"ROOSA OIL":[{"def":"The East Indian name for grass oil.","pos":""}],"ROOST":[{"def":"The pole or other support on which fowls rest at night; a perch.","pos":""},{"def":"A collection of fowls roosting together.","pos":""}],"ROOSTCOCK":[{"def":"The male of the domestic fowl; a cock.","pos":""}],"ROOSTER":[{"def":"The male of the domestic fowl; a cock.","pos":""}],"ROOT":[{"def":"To turn up the earth with the snout, as swine.","pos":""},{"def":"Hence, to seek for favor or advancement by low arts or groveling servility; to fawn servilely.","pos":""}],"ROOTED":[{"def":"Having taken root; firmly implanted; fixed in the heart.","pos":""}],"ROOTER":[{"def":"One who, or that which, roots; one that tears up by the roots.","pos":""}],"ROOTERY":[{"def":"A pile of roots, set with plants, mosses, etc.","pos":""}],"ROOTLESS":[{"def":"Destitute of roots.","pos":""}],"ROOTLET":[{"def":"A radicle; a little root.","pos":""}],"ROOTY":[{"def":"Full of roots; as, rooty ground.","pos":""}]}