{"WOO":[{"def":"To solicit in love; to court.","pos":""},{"def":"To court solicitously; to invite with importunity.","pos":""}],"WOOD":[{"def":"Mad; insane; possessed; rabid; furious; frantic.","pos":""}],"WOOD GUM":[{"def":"WOODHACK; WOODHACKER Wood\"hack`, Wood\"hack`er, n.","pos":""}],"WOOD HYACINTH":[{"def":"A European squill (Scilla nonscripta) having a scape bearing a raceme of drooping blue, purple, white, or sometimes pink, bell- shaped flowers.","pos":""}],"WOOD TICK":[{"def":"Any one of several species of ticks of the genus Ixodes whose young cling to bushes, but quickly fasten themselves upon the bodies of any animal with which they come in contact.","pos":""}],"WOOD'S METAL":[{"def":"A fusible alloy consisting of one or two parts of cadmium, two parts of tin, four of lead, with seven or eight part of bismuth.","pos":""}],"WOOD-BOUND":[{"def":"Incumbered with tall, woody hedgerows.","pos":""}],"WOOD-LAYER":[{"def":"A young oak, or other timber plant, laid down in a hedge among the whitethorn or other plants used in hedges.","pos":""}],"WOOD-NOTE":[{"def":"A wild or natural note, as of a forest bird.","pos":""}],"WOOD-SARE":[{"def":"A kind of froth seen on herbs.","pos":""}],"WOOD-SERE":[{"def":"The time when there no sap in the trees; the winter season.","pos":""}],"WOODBINE":[{"def":"Periclymenum); the honeysuckle.","pos":""}],"WOODBURY-TYPE":[{"def":"A process in photographic printing, in which a relief pattern in gelatin, which has been hardened after certain operations, is pressed upon a plate of lead or other soft metal.","pos":""},{"def":"A print from such a plate.","pos":""}],"WOODCHUCK":[{"def":"A common large North American marmot (Arctomys monax).","pos":""},{"def":"The yaffle, or green woodpecker.","pos":""}],"WOODCOCK":[{"def":"Any one of several species of long-billed limicoline birds belonging to the genera Scolopax and Philohela.","pos":""}],"WOODCRAFT":[{"def":"Skill and practice in anything pertaining to the woods, especially in shooting, and other sports in the woods.","pos":""}],"WOODCUT":[{"def":"An engraving on wood; also, a print from it.","pos":""}],"WOODCUTTER":[{"def":"A person who cuts wood.","pos":""},{"def":"An engraver on wood.","pos":""}],"WOODCUTTING":[{"def":"The act or employment of cutting wood or timber.","pos":""},{"def":"The act or art of engraving on wood.","pos":""}],"WOODED":[{"def":"Supplied or covered with wood, or trees; as, land wooded and watered.","pos":""}],"WOODEN":[{"def":"Made or consisting of wood; pertaining to, or resembling, wood; as, a wooden box; a wooden leg; a wooden wedding.","pos":""},{"def":"Clumsy; awkward; ungainly; stiff; spiritless.","pos":""}],"WOODENLY":[{"def":"Clumsily; stupidly; blockishly.","pos":""}],"WOODENNESS":[{"def":"Quality of being wooden; clumsiness; stupidity; blockishness.","pos":""}],"WOODHOLE":[{"def":"A place where wood is stored.","pos":""}],"WOODHOUSE":[{"def":"A house or shed in which wood is stored, and sheltered from the weather.","pos":""}],"WOODINESS":[{"def":"The quality or state of being woody.","pos":""}],"WOODLAND":[{"def":"Land covered with wood or trees; forest; land on which trees are suffered to grow, either for fuel or timber.","pos":""}],"WOODLANDER":[{"def":"A dweller in a woodland.","pos":""}],"WOODLESS":[{"def":"Having no wood; destitute of wood.","pos":""}],"WOODLY":[{"def":"In a wood, mad, or raving manner; madly; furiously.","pos":""}],"WOODMAN":[{"def":"A forest officer appointed to take care of the king's woods; a forester.","pos":""},{"def":"A sportsman; a hunter.","pos":""}],"WOODNESS":[{"def":"Anger; madness; insanity; rage.","pos":""}],"WOODPECKER":[{"def":"Any one of numerous species of scansorial birds belonging to Picus and many allied genera of the family Picidæ.","pos":""}],"WOODROCK":[{"def":"A compact woodlike variety of asbestus.","pos":""},{"def":"A little European herb (Asperula odorata) having a pleasant taste.","pos":""}],"WOODSMAN":[{"def":"A woodman; especially, one who lives in the forest.","pos":""}],"WOODSTONE":[{"def":"A striped variety of hornstone, resembling wood in appearance.","pos":""}],"WOODSY":[{"def":"Of or pertaining to the woods or forest.","pos":""}],"WOODWARD":[{"def":"An officer of the forest, whose duty it was to guard the woods.","pos":""}],"WOODWARDIA":[{"def":"A genus of ferns, one species of which (Woodwardia radicans) is a showy plant in California, the Azores, etc.","pos":""},{"def":"Same as Woadwaxen.","pos":""}],"WOODWORK":[{"def":"Work made of wood; that part of any structure which is wrought of wood.","pos":""}],"WOODWORM":[{"def":"See Wood worm, under Wood.","pos":""}],"WOODY":[{"def":"Abounding with wood or woods; as, woody land.","pos":""},{"def":"Consisting of, or containing, wood or woody fiber; ligneous; as, the woody parts of plants.","pos":""}],"WOOER":[{"def":"One who wooes; one who courts or solicits in love; a suitor.","pos":""}],"WOOF":[{"def":"The threads that cross the warp in a woven fabric; the weft; the filling; the thread usually carried by the shuttle in weaving.","pos":""},{"def":"Texture; cloth; as, a pall of softest woof.","pos":""}],"WOOFELL":[{"def":"The European blackbird.","pos":""}],"WOOFY":[{"def":"Having a close texture; dense; as, a woofy cloud.","pos":""}],"WOOINGLY":[{"def":"In a wooing manner; enticingly; with persuasiveness.","pos":""}],"WOOL":[{"def":"A sort of pubescence, or a clothing of dense, curling hairs on the surface of certain plants.","pos":""}],"WOOL-DYED":[{"def":"Dyed before being made into cloth, in distinction from piece- dyed; ingrain.","pos":""}],"WOOL-HALL":[{"def":"A trade market in the woolen districts.","pos":""}],"WOOLD":[{"def":"To wind, or wrap; especially, to wind a rope round, as a mast or yard made of two or more pieces, at the place where it has been fished or scarfed, in order to strengthen it.","pos":""}],"WOOLDER":[{"def":"A stick used to tighten the rope in woolding.","pos":""},{"def":"One of the handles of the top, formed by a wooden pin passing through it.","pos":""}],"WOOLED":[{"def":"Having (such) wool; as, a fine-wooled sheep.","pos":""}],"WOOLEN":[{"def":"Made of wool; consisting of wool; as, woolen goods.","pos":""},{"def":"Of or pertaining to wool or woolen cloths; as, woolen manufactures; a woolen mill; a woolen draper.","pos":""}],"WOOLENET":[{"def":"A thin, light fabric of wool.","pos":""}],"WOOLFELL":[{"def":"A skin with the wool; a skin from which the wool has not been sheared or pulled.","pos":""}],"WOOLGATHERING":[{"def":"Indulging in a vagrant or idle exercise of the imagination; roaming upon a fruitless quest; idly fanciful.","pos":""}],"WOOLGROWER":[{"def":"One who raises sheep for the production of wool.","pos":""}],"WOOLHEAD":[{"def":"The buffel duck.","pos":""}],"WOOLLINESS":[{"def":"The quality or state of being woolly.","pos":""}],"WOOLLY":[{"def":"Clothed with a fine, curly pubescence resembling wool.","pos":""}],"WOOLMAN":[{"def":"One who deals in wool.","pos":""}],"WOOLPACK":[{"def":"A pack or bag of wool weighing two hundred and forty pounds.","pos":""}],"WOOLSACK":[{"def":"A sack or bag of wool; specifically, the seat of the lord chancellor of England in the House of Lords, being a large, square sack of wool resembling a divan in form.","pos":""}],"WOOLSTOCK":[{"def":"A heavy wooden hammer for milling cloth.","pos":""}],"WOOLWARD":[{"def":"In wool; with woolen raiment next the skin.","pos":""}],"WOOLWARD-GOING":[{"def":"A wearing of woolen clothes next the skin as a matter of penance.","pos":""}],"WOOTZ":[{"def":"A species of steel imported from the East Indies, valued for making edge tools; Indian steel.","pos":""}]}