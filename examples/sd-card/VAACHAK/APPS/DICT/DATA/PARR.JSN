{"PARR":[{"def":"Any one of numerous species of small parrots having a graduated tail, which is frequently very long; -- called also paroquet and paraquet.","pos":""},{"def":"The rope or collar by which a yard or spar is held to the mast in such a way that it may be hoisted or lowered at pleasure.","pos":""}],"PARRAQUA":[{"def":"A curassow of the genus Ortalida, allied to the guan.","pos":""}],"PARRHESIA":[{"def":"Boldness or freedom of speech.","pos":""}],"PARRICIDAL":[{"def":"Of or pertaining to parricide; guilty of parricide.","pos":""}],"PARRICIDE":[{"def":"The act or crime of murdering one's own father or any ancestor.","pos":""}],"PARROCK":[{"def":"A croft, or small field; a paddock.","pos":""}],"PARROT":[{"def":"In a general sense, any bird of the order Psittaci.","pos":""},{"def":"Any species of Psittacus, Chrysotis, Pionus, and other genera of the family Psittacidæ, as distinguished from the parrakeets, macaws, and lories.","pos":""}],"PARROTER":[{"def":"One who simply repeats what he has heard.","pos":""}],"PARROTRY":[{"def":"Servile imitation or repetition.","pos":""}],"PARRY":[{"def":"To ward off; to stop, or to turn aside; as, to parry a thrust, a blow, or anything that means or threatens harm.","pos":""},{"def":"To avoid; to shift or put off; to evade.","pos":""}]}