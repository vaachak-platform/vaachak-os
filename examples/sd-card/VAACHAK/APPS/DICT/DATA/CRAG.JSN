{"CRAG":[{"def":"A partially compacted bed of gravel mixed with shells, of the Tertiary age.","pos":""}],"CRAGGED":[{"def":"Full of crags, or steep, broken Into its cragged rents descend.","pos":""}],"CRAGGEDNESS":[{"def":"The quality or state of being cragged; cragginess.","pos":""}],"CRAGGINESS":[{"def":"The state of being craggy.","pos":""}],"CRAGGY":[{"def":"Full of crags; rugged with projecting points of rocks; as, the craggy side of a mountain.","pos":""}],"CRAGSMAN":[{"def":"One accustomed to climb rocks or crags; esp.","pos":""}]}