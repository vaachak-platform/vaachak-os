{"CALEDONIA":[{"def":"The ancient Latin name of Scotland; -- still used in poetry.","pos":""}],"CALEDONIAN":[{"def":"Of or pertaining to Caledonia or Scotland; Scottish; Scotch.","pos":""},{"def":"A native or inhabitant of Caledonia or Scotland.","pos":""}],"CALEDONITE":[{"def":"A hydrous sulphate of copper and lead, found in some parts of Caledonia or Scotland.","pos":""}],"CALEFACIENT":[{"def":"Making warm; heating.","pos":""}],"CALEFACTION":[{"def":"The act of warming or heating; the production of heat in a body by the action of fire, or by communication of heat from other bodies.","pos":""},{"def":"The state of being heated.","pos":""}],"CALEFACTIVE":[{"def":"See Calefactory.","pos":""}],"CALEFACTOR":[{"def":"A heater; one who, or that which, makes hot, as a stove, etc.","pos":""}],"CALEFACTORY":[{"def":"Making hot; producing or communicating heat.","pos":""}],"CALEFY":[{"def":"To make warm or hot.","pos":""}],"CALENDAR":[{"def":"A tabular statement of the dates of feasts, offices, saints' days, etc.","pos":""}],"CALENDARIAL":[{"def":"Of or pertaining to the calendar or a calendar.","pos":""}],"CALENDER":[{"def":"A machine, used for the purpose of giving cloth, paper, etc.","pos":""},{"def":"One who pursues the business of calendering.","pos":""}],"CALENDOGRAPHER":[{"def":"One who makes calendars.","pos":""}],"CALENDRER":[{"def":"A person who calenders cloth; a calender.","pos":""},{"def":"Of or pertaining to a calendar.","pos":""}],"CALENDS":[{"def":"The first day of each month in the ancient Roman calendar.","pos":""}],"CALENDULA":[{"def":"A genus of composite herbaceous plants.","pos":""}],"CALENDULIN":[{"def":"A gummy or mucilaginous tasteless substance obtained from the marigold or calendula, and analogous to bassorin.","pos":""}],"CALENTURE":[{"def":"A name formerly given to various fevers occuring in tropics; esp.","pos":""}],"CALESCENCE":[{"def":"Growing warmth; increasing heat.","pos":""}]}