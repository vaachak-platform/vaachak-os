{"IMPEACH":[{"def":"To challenge or discredit the credibility of, as of a witness, or the validity of, as of commercial paper.","pos":""}],"IMPEACHABLE":[{"def":"That may be impeached; liable to impeachment; chargeable with a crime.","pos":""}],"IMPEACHER":[{"def":"One who impeaches.","pos":""}],"IMPEACHMENT":[{"def":"The act of impeaching, or the state of being impeached; as: (a) Hindrance; impediment; obstruction.","pos":""}],"IMPEARL":[{"def":"To form into pearls, or into that which resembles pearls.","pos":""},{"def":"To decorate as with pearls or with anything resembling pearls.","pos":""}],"IMPECCABILITY":[{"def":"the quality of being impeccable; exemption from sin, error, or offense.","pos":""}],"IMPECCABLE":[{"def":"Not liable to sin; exempt from the possibility of doing wrong.","pos":""},{"def":"One who is impeccable; esp.","pos":""}],"IMPECCANT":[{"def":"Sinless; impeccable.","pos":""}],"IMPECUNIOSITY":[{"def":"The state of being impecunious.","pos":""}],"IMPECUNIOUS":[{"def":"Not having money; habitually without money; poor.","pos":""}],"IMPEDANCE":[{"def":"The apparent resistance in an electric circuit to the flow of an alternating current, analogous to the actual electrical resistance to a direct current, being the ratio of electromotive force to the current.","pos":""}],"IMPEDE":[{"def":"To hinder; to stop in progress; to obstruct; as, to impede the advance of troops.","pos":""}],"IMPEDIBLE":[{"def":"Capable of being impeded or hindered.","pos":""}],"IMPEDIMENT":[{"def":"That which impedes or hinders progress, motion, activity, or effect.","pos":""}],"IMPEDIMENTA":[{"def":"Things which impede or hinder progress; incumbrances; baggage; specif.","pos":""},{"def":"the supply trains which must accompany an army.","pos":""}],"IMPEDIMENTAL":[{"def":"Of the nature of an impediment; hindering; obstructing; impeditive.","pos":""}],"IMPEDITE":[{"def":"Hindered; obstructed.","pos":""}],"IMPEDITION":[{"def":"A hindering; a hindrance.","pos":""}],"IMPEDITIVE":[{"def":"Causing hindrance; impeding.","pos":""}],"IMPEL":[{"def":"To drive or urge forward or on; to press on; to incite to action or motion in any way.","pos":""}],"IMPELLENT":[{"def":"Having the quality of impelling.","pos":""}],"IMPELLER":[{"def":"One who, or that which, impels.","pos":""}],"IMPEN":[{"def":"To shut up or inclose, as in a pen.","pos":""}],"IMPEND":[{"def":"To hang over; to be suspended above; to threaten frome near at hand; to menace; to be imminent.","pos":""},{"def":"The state of impending; also, that which impends.","pos":""}],"IMPENDENT":[{"def":"Impending; threatening.","pos":""}],"IMPENDING":[{"def":"Hanging over; overhanging; suspended so as to menace; imminet; threatening.","pos":""}],"IMPENETRABILITY":[{"def":"That property in virtue of which two portions of matter can not at the same time occupy the same portion of space.","pos":""}],"IMPENETRABLE":[{"def":"Having the property of preventing any other substance from occupying the same space at the same time.","pos":""}],"IMPENETRABLENESS":[{"def":"The quality of being impenetrable; impenetrability.","pos":""}],"IMPENETRABLY":[{"def":"In an impenetrable manner or state; imperviously.","pos":""}],"IMPENITENCE":[{"def":"The condition of being impenitent; failure or refusal to repent; hardness of heart.","pos":""}],"IMPENITENT":[{"def":"Not penitent; not repenting of sin; not contrite; of a hard heart.","pos":""}],"IMPENITENTLY":[{"def":"Without repentance.","pos":""}],"IMPENNATE":[{"def":"Characterized by short wings covered with feathers resembling scales, as the penguins.","pos":""},{"def":"One of the Impennes.","pos":""}],"IMPENNES":[{"def":"An order of birds, including only the penguins, in which the wings are without quills, and not suited for flight.","pos":""}],"IMPENNOUS":[{"def":"Having no wings, as some insects.","pos":""}],"IMPEOPLE":[{"def":"To people; to give a population to.","pos":""}],"IMPERATE":[{"def":"Done by express direction; not involuntary; communded.","pos":""}],"IMPERATIVAL":[{"def":"Of or pertaining to the imperative mood.","pos":""}],"IMPERATIVE":[{"def":"Expressive of commund, entreaty, advice, or exhortation; as, the imperative mood.","pos":""}],"IMPERATIVELY":[{"def":"In an imperative manner.","pos":""}],"IMPERATOR":[{"def":"A commander; a leader; an emperor; -- originally an appellation of honor by which Roman soldiers saluted their general after an important victory.","pos":""}],"IMPERATORIAL":[{"def":"Commanding; imperative; authoritative.","pos":""},{"def":"Of or pertaining to the title or office of imperator.","pos":""}],"IMPERCEPTIBILITY":[{"def":"The state or quality of being imperceptible.","pos":""}],"IMPERCEPTIBLE":[{"def":"Not perceptible; not to be apprehended or cognized by the souses; not discernible by the mind; not easily apprehended.","pos":""}],"IMPERCEPTION":[{"def":"Want of perception.","pos":""}],"IMPERCEPTIVE":[{"def":"Unable to perceive.","pos":""}],"IMPERCIPIENT":[{"def":"Not perceiving, or not able to perceive.","pos":""}],"IMPERDIBILITY":[{"def":"The state or quality of being imperdible.","pos":""}],"IMPERDIBLE":[{"def":"Not destructible.","pos":""}],"IMPERFECT":[{"def":"Not perfect; not complete in all its parts; wanting a part; deective; deficient.","pos":""},{"def":"Wanting in some elementary organ that is essential to successful or normal activity.","pos":""}],"IMPERFECTIBILITY":[{"def":"The state or quality of being imperfectible.","pos":""}],"IMPERFECTIBLE":[{"def":"Incapable of being mad perfect.","pos":""}],"IMPERFECTION":[{"def":"The quality or condition of being imperfect; want of perfection; incompleteness; deficiency; fault or blemish.","pos":""}],"IMPERFECTNESS":[{"def":"The state of being imperfect.","pos":""}],"IMPERFORABLE":[{"def":"Incapable of being perforated, or bored through.","pos":""}],"IMPERFORATA":[{"def":"A division of Foraminifera, including those in which the shell is not porous.","pos":""},{"def":"Not perforated; having no opening or aperture.","pos":""}],"IMPERFORATION":[{"def":"The state of being without perforation.","pos":""}],"IMPERIAL":[{"def":"Of or pertaining to an empire, or to an emperor; as, an imperial government; imperial authority or edict.","pos":""},{"def":"Belonging to, or suitable to, supreme authority, or one who wields it; royal; sovereign; supreme.","pos":""}],"IMPERIALISM":[{"def":"The power or character of an emperor; imperial authority; the spirit of empire.","pos":""}],"IMPERIALIST":[{"def":"One who serves an emperor; one who favors imperialism.","pos":""}],"IMPERIALITY":[{"def":"An imperial right or privilegs.","pos":""}],"IMPERIALIZE":[{"def":"To invest with imperial authority, character, or style; to bring to the form of an empire.","pos":""}],"IMPERIALLY":[{"def":"In an imperial manner.","pos":""}],"IMPERIL":[{"def":"To bring into peril; to endanger.","pos":""}],"IMPERILMENT":[{"def":"The act of imperiling, or the state of being imperiled.","pos":""}],"IMPERIOUS":[{"def":"Commanding; ascendant; imperial; lordly; majestic.","pos":""},{"def":"Haughly; arrogant; overbearing; as, an imperious tyrant; an imperious manner.","pos":""}],"IMPERIOUSLY":[{"def":"In an imperious manner.","pos":""}],"IMPERIOUSNESS":[{"def":"The quality or state of being imperious; arrogance; haughtiness.","pos":""}],"IMPERISHABILITY":[{"def":"The quality of being imperishable: indstructibility.","pos":""}],"IMPERISHABLE":[{"def":"Not perisha ble; not subject to decay; indestructible; enduringpermanently; as, an imperishable monument; imperishable renown.","pos":""}],"IMPERIUM":[{"def":"Supreme power; absolute dominion; empire.","pos":""}],"IMPERIWIGGED":[{"def":"Wearing a periwig.","pos":""},{"def":"Want of permanence.","pos":""}],"IMPERMEABILITY":[{"def":"The quality of being impermeable.","pos":""}],"IMPERMEABLE":[{"def":"Not permeable; not permitting passage, as of a fluid.","pos":""}],"IMPERMISSIBLE":[{"def":"Not permissible.","pos":""}],"IMPERSCRUTABLE":[{"def":"Not capable of being searched out; inscrutable.","pos":""}],"IMPERSEVERANT":[{"def":"Not persevering; fickle; thoughtless.","pos":""}],"IMPERSONAL":[{"def":"Not personal; not representing a person; not having personality.","pos":""}],"IMPERSONALITY":[{"def":"The quality of being impersonal; want or absence of personality.","pos":""}],"IMPERSONALLY":[{"def":"In an impersonal manner.","pos":""}],"IMPERSONATE":[{"def":"The act of impersonating; personification; investment with personality; representation in a personal form.","pos":""}],"IMPERSONATOR":[{"def":"One who impersonates; an actor; a mimic.","pos":""}],"IMPERSPICUITY":[{"def":"Want of perspicuity or clearness; vaguness; ambiguity.","pos":""}],"IMPERSPICUOUS":[{"def":"Not perspicuous; not clear; obscure; vague; ambeguous.","pos":""}],"IMPERSUADABLE":[{"def":"Not to be persuaded; obstinate; unyielding; impersuasible.","pos":""}],"IMPERSUASIBLE":[{"def":"Not persuasible; not to be moved by persuasion; inflexible; impersuadable.","pos":""}],"IMPERTINENCE":[{"def":"The condition or quality of being impertnent; absence of pertinence, or of adaptedness; irrelevance; unfitness.","pos":""},{"def":"Conduct or language unbecoming the person, the society, or the circumstances; rudeness; incivility.","pos":""}],"IMPERTINENCY":[{"def":"O, matter and impertinency mixed! Reason in madness! Shak.","pos":""}],"IMPERTINENT":[{"def":"Not pertinent; not pertaining to the matter in hand; having no bearing on the subject; not to the point; irrelevant; inapplicable.","pos":""},{"def":"Contrary to, or offending against, the rules of propriety or good breeding; guilty of, or prone to, rude, unbecoming, or uncivil words or actions; as, an impertient coxcomb; an impertient remark.","pos":""}],"IMPERTINENTLY":[{"def":"In an impertinent manner.","pos":""}],"IMPERTRANSIBILITY":[{"def":"The quality or state of being impertransible.","pos":""}],"IMPERTRANSIBLE":[{"def":"Incapable of being passed through.","pos":""}],"IMPERTURBABILITY":[{"def":"The state or quality of being imperturbable.","pos":""}],"IMPERTURBABLE":[{"def":"Incapable of being disturbed or disconcerted; as, imperturbable gravity.","pos":""}],"IMPERTURBABLY":[{"def":"In an imperturbable manner; calmly.","pos":""}],"IMPERTURBATION":[{"def":"Freedom from agitation of mind; calmness; quietude.","pos":""}],"IMPERVIABILITY":[{"def":"The quality of being imperviable.","pos":""}],"IMPERVIABLE":[{"def":"Not pervious; impervious.","pos":""}],"IMPERVIOUS":[{"def":"Not pervious; not admitting of entrance or passage through; as, a substance impervious to water or air.","pos":""}],"IMPEST":[{"def":"To affict with pestilence; to infect, as with plague.","pos":""}],"IMPETIGINOUS":[{"def":"Of the nature of, or pertaining to, impetigo.","pos":""}],"IMPETIGO":[{"def":"A cutaneous, pustular eruption, not attended with fever; usually, a kind of eczema with pustulation.","pos":""}],"IMPETRABLE":[{"def":"Capable of being obtained or moved by petition.","pos":""}],"IMPETRATE":[{"def":"Obtained by entreaty.","pos":""}],"IMPETRATION":[{"def":"The obtaining of benefice from Rome by solicitation, which benefice belonged to the disposal of the king or other lay patron of the realm.","pos":""}],"IMPETRATIVE":[{"def":"Of the nature of impetration; getting, or tending to get, by entreaty.","pos":""}],"IMPETRATORY":[{"def":"Containing or expressing entreaty.","pos":""}],"IMPETUOSITY":[{"def":"The condition or quality of being impetuous; fury; violence.","pos":""},{"def":"Vehemence, or furiousnes of temper.","pos":""}],"IMPETUOUS":[{"def":"Rushing with force and violence; moving with impetus; furious; forcible; violent; as, an impetuous wind; an impetuous torrent.","pos":""},{"def":"Vehement in feeling; hasty; passionate; violent; as, a man of impetuous temper.","pos":""}],"IMPETUS":[{"def":"The aititude through which a heavy body must fall to acquire a velocity equal to that with which a ball is discharged from a piece.","pos":""}],"IMPEYAN PHEASANT":[{"def":"An Indian crested pheasant of the genus Lophophorus.","pos":""}]}