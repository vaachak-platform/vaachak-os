{"DISABILITY":[{"def":"State of being disabled; deprivation or want of ability; absence of competent physical, intellectual, or moral power, means, fitness, and the like.","pos":""},{"def":"Want of legal qualification to do a thing; legal incapacity or incompetency.","pos":""}],"DISABLE":[{"def":"Lacking ability; unable.","pos":""}],"DISABLEMENT":[{"def":"Deprivation of ability; incapacity.","pos":""}],"DISABUSE":[{"def":"To set free from mistakes; to undeceive; to disengage from fallacy or deception; to set right.","pos":""}],"DISACCOMMODATE":[{"def":"To put to inconvenience; to incommode.","pos":""}],"DISACCOMMODATION":[{"def":"A state of being unaccommodated or unsuited.","pos":""}],"DISACCORD":[{"def":"To refuse to assent.","pos":""}],"DISACCUSTOM":[{"def":"To destroy the force of habit in; to wean from a custom.","pos":""}],"DISACIDIFY":[{"def":"To free from acid.","pos":""}],"DISACKNOWLEDGE":[{"def":"To refuse to acknowledge; to deny; to disown.","pos":""}],"DISACQUAINT":[{"def":"To render unacquainted; to make unfamiliar.","pos":""}],"DISACQUAINTANCE":[{"def":"Neglect of disuse of familiarity, or familiar acquaintance.","pos":""}],"DISACRYL":[{"def":"A white amorphous substance obtained as a polymeric modification of acrolein.","pos":""}],"DISADORN":[{"def":"To deprive of ornaments.","pos":""}],"DISADVANCE":[{"def":"To draw back, or cause to draw back.","pos":""}],"DISADVANTAGE":[{"def":"Deprivation of advantage; unfavorable or prejudicial quality, condition, circumstance, or the like; that which hinders success, or causes loss or injury.","pos":""},{"def":"Loss; detriment; hindrance; prejudice to interest, fame, credit, profit, or other good.","pos":""}],"DISADVANTAGEABLE":[{"def":"Injurious; disadvantageous.","pos":""}],"DISADVANTAGEOUS":[{"def":"Attended with disadvantage; unfavorable to success or prosperity; inconvenient; prejudicial; -- opposed to advantageous; as, the situation of an army is disadvantageous for attack or defense.","pos":""}],"DISADVENTURE":[{"def":"Misfortune; mishap.","pos":""}],"DISADVENTUROUS":[{"def":"Unprosperous; unfortunate.","pos":""}],"DISADVISE":[{"def":"To advise against; to dissuade from.","pos":""}],"DISAFFECT":[{"def":"To alienate or diminish the affection of; to make unfriendly or less friendly; to fill with discontent and unfriendliness.","pos":""},{"def":"To disturb the functions of; to disorder.","pos":""}],"DISAFFECTED":[{"def":"Alienated in feeling; not wholly loyal.","pos":""}],"DISAFFECTION":[{"def":"State of being disaffected; alienation or want of affection or good will, esp.","pos":""},{"def":"Disorder; bad constitution.","pos":""}],"DISAFFECTIONATE":[{"def":"Not disposed to affection; unfriendly; disaffected.","pos":""}],"DISAFFIRM":[{"def":"To refuse to confirm; to annul, as a judicial decision, by a contrary judgment of a superior tribunal.","pos":""}],"DISAFFIRMANCE":[{"def":"Overthrow or annulment by the decision of a superior tribunal; as, disaffirmance of judgment.","pos":""}],"DISAFFIRMATION":[{"def":"The act of disaffirming; negation; refutation.","pos":""}],"DISAFFOREST":[{"def":"To reduce from the privileges of a forest to the state of common ground; to exempt from forest laws.","pos":""}],"DISAGGREGATE":[{"def":"To destroy the aggregation of; to separate into component parts, as an aggregate mass.","pos":""}],"DISAGGREGATION":[{"def":"The separation of an aggregate body into its component parts.","pos":""}],"DISAGREE":[{"def":"To fail to accord; not to agree; to lack harmony; to differ; to be unlike; to be at variance.","pos":""},{"def":"To differ in opinion; to hold discordant views; to be at controversy; to quarrel.","pos":""}],"DISAGREEABLE":[{"def":"Not agreeable, conformable, or congruous; Preach you truly the doctrine which you have received, and each nothing that is disagreeable thereunto.","pos":""},{"def":"Exciting repugnance; offensive to the feelings or That which is disagreeable to one is many times agreeable to another, or disagreeable in a less degree.","pos":""}],"DISAGREEABLENESS":[{"def":"The state or quality of being; disagreeable; unpleasantness.","pos":""}],"DISAGREEABLY":[{"def":"In a disagreeable manner; unsuitably; offensively.","pos":""}],"DISAGREEMENT":[{"def":"The state of disagreeing; a being at variance; dissimilitude; diversity.","pos":""},{"def":"Unsuitableness; unadaptedness.","pos":""}],"DISAGREER":[{"def":"One who disagrees.","pos":""}],"DISALLIEGE":[{"def":"To alienate from allegiance.","pos":""}],"DISALLOW":[{"def":"To refuse to allow; to deny the force or validity of; to disown and reject; as, the judge disallowed the executor's charge.","pos":""}],"DISALLOWABLE":[{"def":"Not allowable; not to be suffered.","pos":""}],"DISALLOWANCE":[{"def":"The act of disallowing; refusal to admit or permit; rejection.","pos":""}],"DISALLY":[{"def":"To part, as an alliance; to sunder.","pos":""}],"DISANCHOR":[{"def":"To raise the anchor of, as a ship; to weigh anchor.","pos":""}],"DISANIMATE":[{"def":"To deprive of life.","pos":""},{"def":"To deprive of spirit; to dishearten.","pos":""}],"DISANIMATION":[{"def":"Privation of life.","pos":""},{"def":"The state of being disanimated or discouraged; depression of spirits.","pos":""}],"DISANNEX":[{"def":"To disunite; to undo or repeal the annexation of.","pos":""}],"DISANNUL":[{"def":"To annul completely; to render void or of no effect.","pos":""}],"DISANNULLER":[{"def":"One who disannuls.","pos":""}],"DISANNULMENT":[{"def":"Complete annulment.","pos":""}],"DISANOINT":[{"def":"To invalidate the consecration of; as, to disanoint a king.","pos":""}],"DISAPPAREL":[{"def":"To disrobe; to strip of apparel; to make naked.","pos":""}],"DISAPPEAR":[{"def":"To cease to appear or to be perceived; to pass from view, gradually or suddenly; to vanish; to be no longer seen; as, darkness disappears at the approach of light; a ship disappears as she sails from port.","pos":""},{"def":"To cease to be or exist; as, the epidemic has disappeared.","pos":""}],"DISAPPEARANCE":[{"def":"The act of disappearing; cessation of appearance; removal from sight; vanishing.","pos":""}],"DISAPPEARING":[{"def":"Dis`ap*pear\"ing, Defn: p.","pos":""}],"DISAPPENDENCY":[{"def":"A detachment or separation from a former connection.","pos":""}],"DISAPPENDENT":[{"def":"Freed from a former connection or dependence; disconnected.","pos":""}],"DISAPPOINT":[{"def":"To frustrate; to fail; to hinder of result.","pos":""}],"DISAPPOINTED":[{"def":"Defeated of expectation or hope; balked; as, a disappointed person or hope.","pos":""},{"def":"Unprepared; unequipped.","pos":""}],"DISAPPOINTMENT":[{"def":"The act of disappointing, or the state of being disappointed; defeat or failure of expectation or hope; miscarriage of design or plan; frustration.","pos":""},{"def":"That which disappoints.","pos":""}],"DISAPPRECIATE":[{"def":"To undervalue; not to esteem.","pos":""}],"DISAPPROBATION":[{"def":"The act of disapproving; mental condemnation of what is judged wrong, unsuitable, or inexpedient; feeling of censure.","pos":""}],"DISAPPROBATORY":[{"def":"Containing disapprobation; serving to disapprove.","pos":""}],"DISAPPROPRIATE":[{"def":"Severed from the appropriation or possession of a spiritual corporation.","pos":""}],"DISAPPROPRIATION":[{"def":"The act of disappropriating.","pos":""}],"DISAPPROVAL":[{"def":"Disapprobation; dislike; censure; adverse judgment.","pos":""}],"DISAPPROVE":[{"def":"To pass unfavorable judgment upon; to condemn by an act of the judgment; to regard as wrong, unsuitable, or inexpedient; to censure; as, to disapprove the conduct of others.","pos":""},{"def":"To refuse official approbation to; to disallow; to decline to sanction; as, the sentence of the court-martial was disapproved by the commander in chief.","pos":""}],"DISAPPROVER":[{"def":"One who disapproves.","pos":""}],"DISAPPROVINGLY":[{"def":"In a disapproving manner.","pos":""}],"DISARM":[{"def":"To deprive of arms; to take away the weapons of; to deprive of the means of attack or defense; to render defenseless.","pos":""},{"def":"To deprive of the means or the disposition to harm; to render harmless or innocuous; as, to disarm a man's wrath.","pos":""}],"DISARMAMENT":[{"def":"The act of disarming.","pos":""}],"DISARMATURE":[{"def":"The act of divesting of armature.","pos":""}],"DISARMED":[{"def":"Deprived of claws, and teeth or beaks.","pos":""}],"DISARMER":[{"def":"One who disarms.","pos":""}],"DISARRANGE":[{"def":"To unsettle or disturb the order or due arrangement of; to throw out of order.","pos":""}],"DISARRANGEMENT":[{"def":"The act of disarranging, or the state of being disarranged; confusion; disorder.","pos":""}],"DISARRAY":[{"def":"To throw into disorder; to break the array of.","pos":""},{"def":"To take off the dress of; to unrobe.","pos":""}],"DISARTICULATE":[{"def":"To sunder; to separate, as joints.","pos":""}],"DISARTICULATOR":[{"def":"One who disarticulates and prepares skeletons.","pos":""}],"DISASSENTER":[{"def":"One who disassents; a dissenter.","pos":""}],"DISASSIDUITY":[{"def":"Want of as siduity or care.","pos":""}],"DISASSIMILATE":[{"def":"To subject to disassimilation.","pos":""}],"DISASSIMILATION":[{"def":"The decomposition of complex substances, within the organism, into simpler ones suitable only for excretion, with evolution of energy, -- a normal nutritional process the reverse of assimilation; downward metabolism.","pos":""}],"DISASSIMILATIVE":[{"def":"Having power to disassimilate; of the nature of disassimilation.","pos":""}],"DISASSOCIATE":[{"def":"To disconnect from things associated; to disunite; to dissociate.","pos":""}],"DISASTER":[{"def":"An unpropitious or baleful aspect of a planet or star; malevolent influence of a heavenly body; hence, an ill portent.","pos":""},{"def":"An adverse or unfortunate event, esp.","pos":""}],"DISASTROUS":[{"def":"Full of unpropitious stellar influences; unpropitious; ill-boding.","pos":""},{"def":"Attended with suffering or disaster; very unfortunate; calamitous; ill-fated; as, a disastrous day; a disastrous termination of an undertaking.","pos":""}],"DISATTIRE":[{"def":"To unrobe; to undress.","pos":""}],"DISAUTHORIZE":[{"def":"To deprive of credit or authority; to discredit.","pos":""}],"DISAVAUNCE":[{"def":"To retard; to repel; to do damage to.","pos":""}],"DISAVENTUROUS":[{"def":"Misadventurous; unfortunate.","pos":""}],"DISAVOW":[{"def":"To refuse strongly and solemnly to own or acknowledge; to deny responsibility for, approbation of, an the like; to disclaim; to disown; as, he was charged with embezzlement, but he disavows the crime.","pos":""},{"def":"To deny; to show the contrary of; to disprove.","pos":""}],"DISAVOWAL":[{"def":"The act of disavowing, disclaiming, or disowning; rejection and denial.","pos":""}],"DISAVOWER":[{"def":"One who disavows.","pos":""}]}