{"BUILD":[{"def":"To erect or construct, as an edifice or fabric of any kind; to form by uniting materials into a regular structure; to fabricate; to make; to raise.","pos":""},{"def":"To raise or place on a foundation; to form, establish, or produce by using appropriate means.","pos":""}],"BUILDER":[{"def":"One who builds; one whose occupation is to build, as a carpenter, a shipwright, or a mason.","pos":""}],"BUILDING":[{"def":"The act of constructing, erecting, or establishing.","pos":""},{"def":"The art of constructing edifices, or the practice of civil architecture.","pos":""}],"BUILT":[{"def":"Shape; build; form of structure; as, the built of a ship.","pos":""}]}