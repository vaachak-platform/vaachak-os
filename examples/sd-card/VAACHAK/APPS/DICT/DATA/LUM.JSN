{"LUM":[{"def":"A grayish brown limestone, containing fossil shells, which reflect a beautiful play of colors.","pos":""}],"LUMBAGINOUS":[{"def":"Of or pertaining to lumbago.","pos":""}],"LUMBAGO":[{"def":"A rheumatic pain in the loins and the small of the back.","pos":""},{"def":"Of, pertaining to, or near, the loins; as, the lumbar arteries.","pos":""}],"LUMBER":[{"def":"A pawnbroker's shop, or room for storing articles put in pawn; hence, a pledge, or pawn.","pos":""},{"def":"Old or refuse household stuff; things cumbrous, or bulky and useless, or of small value.","pos":""}],"LUMBER STATE":[{"def":"Maine; -- a nickname.","pos":""}],"LUMBERER":[{"def":"One employed in lumbering, cutting, and getting logs from the forest for lumber; a lumberman.","pos":""}],"LUMBERING":[{"def":"The business of cutting or getting timber or logs from the forest for lumber.","pos":""}],"LUMBERMAN":[{"def":"One who is engaged in lumbering as a business or employment.","pos":""}],"LUMBOSACRAL":[{"def":"Of or pertaining to the loins and sacrum; as, the lumbosacral nerve, a branch of one of the lumber nerves which passes over the sacrum.","pos":""}],"LUMBRIC":[{"def":"An earthworm, or a worm resembling an earthworm.","pos":""}],"LUMBRICAL":[{"def":"Resembling a worm; as, the lumbrical muscles of the hands of the hands and feet.","pos":""},{"def":"A lumbrical muscle.","pos":""}],"LUMBRICIFORM":[{"def":"Resembling an earthworm; vermiform.","pos":""}],"LUMBRICOID":[{"def":"Like an earthworm; belonging to the genus Lumbricus, or family Lumbricidæ.","pos":""}],"LUMBRICUS":[{"def":"A genus of annelids, belonging to the Oligochæta, and including the common earthworms.","pos":""}],"LUMINARY":[{"def":"Any body that gives light, especially one of the heavenly bodies.","pos":""},{"def":"One who illustrates any subject, or enlightens mankind; as, Newton was a distinguished luminary.","pos":""}],"LUMINESCENT":[{"def":"Shining with a light due to any of the various causes which produce luminescence.","pos":""}],"LUMINIFEROUS":[{"def":"Producing light; yielding light; transmitting light; as, the luminiferous ether.","pos":""}],"LUMINOSITY":[{"def":"The quality or state of being luminous; luminousness.","pos":""}],"LUMINOUS":[{"def":"Shining; emitting or reflecting light; brilliant; bright; as, the is a luminous body; a luminous color.","pos":""},{"def":"Illuminated; full of light; bright; as, many candles made the room luminous.","pos":""}],"LUMMOX":[{"def":"A fat, ungainly, stupid person; an awkward bungler.","pos":""}],"LUMP":[{"def":"A projection beneath the breech end of a gun barrel.","pos":""}],"LUMPER":[{"def":"The European eelpout; -- called also lumpen.","pos":""}],"LUMPFISH":[{"def":"A large, thick, clumsy, marine fish (Cyclopterus lumpus) of Europe and America.","pos":""}],"LUMPISH":[{"def":"Like a lump; inert; gross; heavy; dull; spiritless.","pos":""}],"LUMPY":[{"def":"Full of lumps, or small compact masses.","pos":""}]}