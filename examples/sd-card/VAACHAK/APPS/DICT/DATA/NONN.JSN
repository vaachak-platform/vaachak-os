{"NONNATURAL":[{"def":"Not natural; unnatural.","pos":""}],"NONNECESSITY":[{"def":"Absence of necessity; the quality or state of being unnecessary.","pos":""}],"NONNITROGNOUS":[{"def":"Devoid of nitrogen; as, a nonnitrogenous principle; a nonnitrogenous food.","pos":""}],"NONNUCLEATED":[{"def":"Without a nucleus.","pos":""}],"NONNY":[{"def":"A silly fellow; a ninny.","pos":""}]}