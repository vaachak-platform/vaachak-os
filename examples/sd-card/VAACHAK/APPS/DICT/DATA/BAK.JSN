{"BAKE":[{"def":"To prepare, as food, by cooking in a dry heat, either in an oven or under coals, or on heated stone or metal; as, to bake bread, meat, apples.","pos":""},{"def":"To dry or harden (anything) by subjecting to heat, as, to bake bricks; the sun bakes the ground.","pos":""}],"BAKEHOUSE":[{"def":"A house for baking; a bakery.","pos":""},{"def":"A pie; baked food.","pos":""}],"BAKER":[{"def":"One whose business it is to bake bread, biscuit, etc.","pos":""},{"def":"A portable oven in which baking is done.","pos":""}],"BAKER-LEGGED":[{"def":"Having legs that bend inward at the knees.","pos":""}],"BAKERY":[{"def":"The trade of a baker.","pos":""},{"def":"The place for baking bread; a bakehouse.","pos":""}],"BAKING":[{"def":"The act or process of cooking in an oven, or of drying and hardening by heat or cold.","pos":""},{"def":"The quantity baked at once; a batch; as, a baking of bread.","pos":""}],"BAKINGLY":[{"def":"In a hot or baking manner.","pos":""}],"BAKISTRE":[{"def":"Same as Backsheesh.","pos":""}]}