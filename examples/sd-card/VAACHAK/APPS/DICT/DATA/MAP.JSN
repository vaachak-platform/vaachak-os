{"MAP":[{"def":"A representation of the surface of the earth, or of some portion of it, showing the relative position of the parts represented; -- usually on a flat surface.","pos":""},{"def":"Anything which represents graphically a succession of events, states, or acts; as, an historical map.","pos":""}],"MAPLE":[{"def":"A tree of the genus Acer, including about fifty species.","pos":""}],"MAPLIKE":[{"def":"Having or consisting of lines resembling a map; as, the maplike figures in which certain lichens grow.","pos":""}],"MAPPERY":[{"def":"The making, or study, of maps.","pos":""}]}