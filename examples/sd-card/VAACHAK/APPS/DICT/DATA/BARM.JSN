{"BARM":[{"def":"Foam rising upon beer, or other malt liquors, when fermenting, and used as leaven in making bread and in brewing; yeast.","pos":""}],"BARMAID":[{"def":"A girl or woman who attends the customers of a bar, as in a tavern or beershop.","pos":""}],"BARMASTER":[{"def":"Formerly, a local judge among miners; now, an officer of the barmote.","pos":""}],"BARMECIDAL":[{"def":"Unreal; illusory.","pos":""}],"BARMECIDE":[{"def":"One who proffers some illusory advantage or benefit.","pos":""}],"BARMOTE":[{"def":"A court held in Derbyshire, in England, for deciding controversies between miners.","pos":""}],"BARMY":[{"def":"Full of barm or froth; in a ferment.","pos":""}]}