{"MERACIOUS":[{"def":"Being without mixture or adulteration; hence, strong; racy.","pos":""}],"MERCABLE":[{"def":"Capable of being bought or sold.","pos":""}],"MERCANTILE":[{"def":"Of or pertaining to merchants, or the business of merchants; having to do with trade, or the buying and selling of commodities; commercial.","pos":""}],"MERCAPTAL":[{"def":"Any one of a series of compounds of mercaptans with aldehydes.","pos":""}],"MERCAPTAN":[{"def":"Any one of series of compounds, hydrosulphides of alcohol radicals, in composition resembling the alcohols, but containing sulphur in place of oxygen, and hence called also the sulphur alcohols.","pos":""}],"MERCAPTIDE":[{"def":"A compound of mercaptan formed by replacing its sulphur hydrogen by a metal; as, potassium mercaptide, C2H5SK.","pos":""}],"MERCATANTE":[{"def":"A foreign trader.","pos":""}],"MERCATOR'S CHART":[{"def":"See under Chart, and see Mercator's projection, under Projection.","pos":""}],"MERCATURE":[{"def":"Commerce; traffic; trade.","pos":""}],"MERCE":[{"def":"To subject to fine or amercement; to mulct; to amerce.","pos":""}],"MERCENARIAN":[{"def":"Mer`ce*na\"ri*an (-an), n.","pos":""}],"MERCENARILY":[{"def":"In a mercenary manner.","pos":""}],"MERCENARINESS":[{"def":"The quality or state of being mercenary; venality.","pos":""}],"MERCENARY":[{"def":"Acting for reward; serving for pay; paid; hired; hireling; venal; as, mercenary soldiers.","pos":""},{"def":"Hence: Moved by considerations of pay or profit; greedy of gain; sordid; selfish.","pos":""}],"MERCER":[{"def":"Originally, a dealer in any kind of goods or wares; now restricted to a dealer in textile fabrics, as silks or woolens.","pos":""}],"MERCERIZE":[{"def":"To treat (cotton fiber or fabrics) with a solution of caustic alkali.","pos":""}],"MERCERSHIP":[{"def":"The business of a mercer.","pos":""}],"MERCERY":[{"def":"The trade of mercers; the goods in which a mercer deals.","pos":""}],"MERCHANDISABLE":[{"def":"Such as can be used or transferred as merchandise.","pos":""}],"MERCHANDISE":[{"def":"The objects of commerce; whatever is usually bought or sold in trade, or market, or by merchants; wares; goods; commodities.","pos":""},{"def":"The act or business of trading; trade; traffic.","pos":""}],"MERCHANDRY":[{"def":"Trade; commerce.","pos":""}],"MERCHANT":[{"def":"One who traffics on a large scale, especially with foreign countries; a trafficker; a trader.","pos":""},{"def":"A trading vessel; a merchantman.","pos":""}],"MERCHANTABLE":[{"def":"Fit for market; such as is usually sold in market, or such as will bring the ordinary price; as, merchantable wheat; sometimes, a technical designation for a particular kind or class.","pos":""}],"MERCHANTLY":[{"def":"Merchantlike; suitable to the character or business of a merchant.","pos":""}],"MERCHANTMAN":[{"def":"A trading vessel; a ship employed in the transportation of goods, as, distinguished from a man-of-war.","pos":""}],"MERCHANTRY":[{"def":"The body of merchants taken collectively; as, the merchantry of a country.","pos":""},{"def":"The business of a merchant; merchandise.","pos":""}],"MERCIFUL":[{"def":"Full of mercy; having or exercising mercy; disposed to pity and spare offenders; unwilling to punish.","pos":""},{"def":"Unwilling to give pain; compassionate.","pos":""}],"MERCILESS":[{"def":"Destitute of mercy; cruel; unsparing; -- said of animate beings, and also, figuratively, of things; as, a merciless tyrant; merciless waves.","pos":""}],"MERCURAMMONIUM":[{"def":"A radical regarded as derived from ammonium by the substitution of mercury for a portion of the hydrogen.","pos":""}],"MERCURIAL":[{"def":"Caused by the use of mercury; as, mercurial sore mouth.","pos":""}],"MERCURIALISM":[{"def":"The morbid condition produced by the excessive use of mercury, or by exposure to its fumes, as in mining or smelting.","pos":""}],"MERCURIALIST":[{"def":"A physician who uses much mercury, in any of its forms, in his practice.","pos":""}],"MERCURIALIZE":[{"def":"To affect with mercury.","pos":""},{"def":"To treat with mercury; to expose to the vapor of mercury.","pos":""}],"MERCURIALLY":[{"def":"In a mercurial manner.","pos":""}],"MERCURIC":[{"def":"Of, pertaining to, or derived from, mercury; containing mercury; -- said of those compounds of mercury into which this element enters in its lowest proportion.","pos":""}],"MERCURIFICATION":[{"def":"The process or operation of obtaining the mercury, in its fluid form, from mercuric minerals.","pos":""},{"def":"The act or process of compounding, or the state of being compounded, with mercury.","pos":""}],"MERCURIFY":[{"def":"To obtain mercury from, as mercuric minerals, which may be done by any application of intense heat that expels the mercury in fumes, which are afterward condensed.","pos":""},{"def":"To combine or mingle mercury with; to impregnate with mercury; to mercurialize.","pos":""}],"MERCURISM":[{"def":"A communication of news; an announcement.","pos":""}],"MERCUROUS":[{"def":"Of, pertaining to, or derived from, mercury; containing mercury; -- said of those compounds of mercury in which it is present in its highest proportion.","pos":""}],"MERCURY":[{"def":"A Latin god of commerce and gain; -- treated by the poets as identical with the Greek Hermes, messenger of the gods, conductor of souls to the lower world, and god of eloquence.","pos":""},{"def":"A metallic element mostly obtained by reduction from cinnabar, one of its ores.","pos":""}],"MERCY":[{"def":"Forbearance to inflict harm under circumstances of provocation, when one has the power to inflict it; compassionate treatment of an offender or adversary; clemency.","pos":""},{"def":"Compassionate treatment of the unfortunate and helpless; sometimes, favor, beneficence.","pos":""}],"MERD":[{"def":"A combining form meaning part, portion; as, blastomere, epimere.","pos":""}],"MERE":[{"def":"To divide, limit, or bound.","pos":""}],"MERELY":[{"def":"Purely; unmixedly; absolutely.","pos":""},{"def":"Not otherwise than; simply; barely; only.","pos":""}],"MERENCHYMA":[{"def":"Tissue composed of spheroidal cells.","pos":""}],"MERESMAN":[{"def":"An officer who ascertains meres or boundaries.","pos":""}],"MERESTEAD":[{"def":"The land within the boundaries of a farm; a farmstead or farm.","pos":""}],"MERESTONE":[{"def":"A stone designating a limit or boundary; a landmark.","pos":""}],"MERETRICIOUS":[{"def":"Of or pertaining to prostitutes; having to do with harlots; lustful; as, meretricious traffic.","pos":""},{"def":"Resembling the arts of a harlot; alluring by false show; gaudily and deceitfully ornamental; tawdry; as, meretricious dress or ornaments.","pos":""}],"MERGANSER":[{"def":"Any bird of the genus Merganser, and allied genera.","pos":""}],"MERGE":[{"def":"To cause to be swallowed up; to immerse; to sink; to absorb.","pos":""}],"MERGER":[{"def":"An absorption of one estate, or one contract, in another, or of a minor offense in a greater.","pos":""}],"MERICARP":[{"def":"One carpel of an umbelliferous fruit.","pos":""}],"MERIDE":[{"def":"A permanent colony of cells or plastids which may remain isolated, like Rotifer, or may multiply by gemmation to form higher aggregates, termed zoides.","pos":""}],"MERIDIAN":[{"def":"Being at, or pertaining to, midday; belonging to, or passing through, the highest point attained by the sun in his diurnal course.","pos":""},{"def":"Pertaining to the highest point or culmination; as, meridian splendor.","pos":""}],"MERIDIONAL":[{"def":"Of or pertaining to the meridian.","pos":""},{"def":"Having a southern aspect; southern; southerly.","pos":""}],"MERIDIONALITY":[{"def":"The state of being in the meridian.","pos":""},{"def":"Position in the south; aspect toward the south.","pos":""}],"MERIDIONALLY":[{"def":"In the direction of the meridian.","pos":""}],"MERILS":[{"def":"A boy's play, called also fivepenny morris.","pos":""}],"MERINGUE":[{"def":"A delicate pastry made of powdered sugar and the whites of eggs whipped up, -- with jam or cream added.","pos":""}],"MERINO":[{"def":"Of or pertaining to a variety of sheep with very fine wool, originally bred in Spain.","pos":""},{"def":"Made of the wool of the merino sheep.","pos":""}],"MERISMATIC":[{"def":"Dividing into cells or segments; characterized by separation into two or more parts or sections by the formation of internal partitions; as, merismatic growth, where one cell divides into many.","pos":""}],"MERISTEM":[{"def":"A tissue of growing cells, or cells capable of further division.","pos":""}],"MERIT":[{"def":"The quality or state of deserving well or ill; desert.","pos":""}],"MERITABLE":[{"def":"Deserving of reward.","pos":""}],"MERITEDLY":[{"def":"By merit; deservedly.","pos":""},{"def":"Same as Internode.","pos":""}],"MERITMONGER":[{"def":"One who depends on merit for salvation.","pos":""}],"MERITORIOUS":[{"def":"Possessing merit; deserving of reward or honor; worthy of recompense; valuable.","pos":""}],"MERITOT":[{"def":"A play of children, in swinging on ropes, or the like, till they are dizzy.","pos":""}],"MERK":[{"def":"An old Scotch silver coin; a mark or marc.","pos":""}],"MERKIN":[{"def":"Originally, a wig; afterwards, a mop for cleaning cannon.","pos":""},{"def":"The European blackbird.","pos":""}],"MERLIN":[{"def":"A small European falcon (Falco lithofalco, or F.","pos":""}],"MERLING":[{"def":"The European whiting.","pos":""}],"MERLON":[{"def":"One of the solid parts of a battlemented parapet; a battlement.","pos":""}],"MERLUCE":[{"def":"The European hake; -- called also herring hake and sea pike.","pos":""}],"MERMAID":[{"def":"A fabled marine creature, typically represented as having the upper part like that of a woman, and the lower like a fish; a sea nymph, sea woman, or woman fish.","pos":""}],"MERMAN":[{"def":"The male corresponding to mermaid; a sea man, or man fish.","pos":""},{"def":"Any of several large groupers of warm seas, esp.","pos":""}],"MEROBLAST":[{"def":"An ovum, as that of a mammal, only partially composed of germinal matter, that is, consisting of both a germinal portion and an albuminous or nutritive one; -- opposed to holoblast.","pos":""}],"MEROBLASTIC":[{"def":"Consisting only in part of germinal matter; characterized by partial segmentation only; as, meroblastic ova, in which a portion of the yolk only undergoes fission; meroblastic segmentation; -- opposed to holoblastic.","pos":""}],"MEROCELE":[{"def":"Hernia in the thigh; femoral hernia .","pos":""}],"MEROISTIC":[{"def":"Applied to the ovaries of insects when they secrete vitelligenous cells, as well as ova.","pos":""}],"MEROPIDAN":[{"def":"One of a family of birds (Meropidæ), including the bee-eaters.","pos":""}],"MEROPODITE":[{"def":"The fourth joint of a typical appendage of Crustacea.","pos":""}],"MERORGANIZATION":[{"def":"Organization in part.","pos":""}],"MEROS":[{"def":"The plain surface between the channels of a triglyph.","pos":""}],"MEROSOME":[{"def":"One of the serial segments, or metameres, of which the bodies of vertebrate and articulate animals are composed.","pos":""}],"MEROSTOMATA":[{"def":"A class of Arthropoda, allied to the Crustacea.","pos":""}],"MEROU":[{"def":"See Jack, 8 (c).","pos":""}],"MEROVINGIAN":[{"def":"Of or pertaining to the first Frankish dynasty in Gaul or France.","pos":""},{"def":"One of the kings of this dynasty.","pos":""}],"MEROZOITE":[{"def":"A form of spore, usually elongate or falciform, and somewhat amoboid, produced by segmentation of the schizonts of certain Sporozoa, as the malaria parasite.","pos":""}],"MERRILY":[{"def":"In a merry manner; with mirth; with gayety and laughter; jovially.","pos":""}],"MERRIMAKE":[{"def":"See Merrymake, n.","pos":""}],"MERRIMENT":[{"def":"Gayety, with laughter; mirth; frolic.","pos":""}],"MERRINESS":[{"def":"The quality or state of being merry; merriment; mirth; gayety, with laughter.","pos":""}],"MERRY":[{"def":"Laughingly gay; overflowing with good humor and good spirits; jovial; inclined to laughter or play ; sportive.","pos":""},{"def":"Cheerful; joyous; not sad; happy.","pos":""}],"MERRY-ANDREW":[{"def":"One whose business is to make sport for others; a buffoon; a zany; especially, one who attends a mountebank or quack doctor.","pos":""}],"MERRY-GO-ROUND":[{"def":"Any revolving contrivance for affording amusement; esp.","pos":""}],"MERRYMAKE":[{"def":"Mirth; frolic; a meeting for mirth; a festival.","pos":""}],"MERRYMAKER":[{"def":"One who makes merriment or indulges in conviviality; a jovial comrade.","pos":""}],"MERRYMAKING":[{"def":"Making or producing mirth; convivial; jolly.","pos":""}],"MERRYMEETING":[{"def":"A meeting for mirth.","pos":""}],"MERRYTHOUGHT":[{"def":"The forked bone of a fowl's breast; -- called also wishbone.","pos":""}],"MERULIDAN":[{"def":"A bird of the Thrush family.","pos":""}]}