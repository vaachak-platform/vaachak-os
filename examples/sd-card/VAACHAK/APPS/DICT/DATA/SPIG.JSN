{"SPIGNEL":[{"def":"Same as Spickenel.","pos":""}],"SPIGNET":[{"def":"An aromatic plant of America.","pos":""}],"SPIGOT":[{"def":"A pin or peg used to stop the vent in a cask; also, the plug of a faucet or cock.","pos":""}],"SPIGURNEL":[{"def":"Formerly the title of the sealer of writs in chancery.","pos":""}]}