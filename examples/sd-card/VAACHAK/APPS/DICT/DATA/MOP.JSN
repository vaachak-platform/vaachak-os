{"MOP":[{"def":"A made-up face; a grimace.","pos":""}],"MOPBOARD":[{"def":"A narrow board nailed against the wall of a room next to the floor; skirting board; baseboard.","pos":""}],"MOPE":[{"def":"To be dull and spiritless.","pos":""}],"MOPE-EYED":[{"def":"Shortsighted; purblind.","pos":""}],"MOPISH":[{"def":"Dull; spiritless; dejected.","pos":""}],"MOPLAH":[{"def":"One of a class of Mohammedans in Malabar.","pos":""}],"MOPPET":[{"def":"A long-haired pet dog.","pos":""}],"MOPSICAL":[{"def":"Shortsighted; mope-eyed.","pos":""}],"MOPSTICK":[{"def":"The long handle of a mop.","pos":""}],"MOPUS":[{"def":"A mope; a drone.","pos":""}]}