{"DISMAIL":[{"def":"To divest of coat of mail.","pos":""}],"DISMAL":[{"def":"Fatal; ill-omened; unlucky.","pos":""},{"def":"Gloomy to the eye or ear; sorrowful and depressing to the feelings; foreboding; cheerless; dull; dreary; as, a dismal outlook; dismal stories; a dismal place.","pos":""}],"DISMALLY":[{"def":"In a dismal manner; gloomily; sorrowfully; uncomfortably.","pos":""}],"DISMALNESS":[{"def":"The quality of being dismal; gloominess.","pos":""}],"DISMANTLE":[{"def":"To strip or deprive of dress; to divest.","pos":""},{"def":"To strip of furniture and equipments, guns, etc.","pos":""}],"DISMARRY":[{"def":"To free from the bonds of marriage; to divorce.","pos":""}],"DISMARSHAL":[{"def":"To disarrange; to derange; to put in disorder.","pos":""}],"DISMASK":[{"def":"To divest of a mask.","pos":""}],"DISMAST":[{"def":"To deprive of a mast of masts; to break and carry away the masts from; as, a storm dismasted the ship.","pos":""}],"DISMASTMENT":[{"def":"The act of dismasting; the state of being dismasted.","pos":""}],"DISMAW":[{"def":"To eject from the maw; to disgorge.","pos":""}],"DISMAY":[{"def":"To disable with alarm or apprehensions; to depress the spirits or courage of; to deprive or firmness and energy through fear; to daunt; to appall; to terrify.","pos":""},{"def":"To render lifeless; to subdue; to disquiet.","pos":""}],"DISMAYEDNESS":[{"def":"A state of being dismayed; dejection of courage; dispiritedness.","pos":""}],"DISME":[{"def":"A tenth; a tenth part; a tithe.","pos":""}],"DISMEMBER":[{"def":"To tear limb from limb; to dilacerate; to disjoin member from member; to tear or cut in pieces; to break up.","pos":""},{"def":"To deprive of membership.","pos":""}],"DISMEMBERMENT":[{"def":"The act of dismembering, or the state of being dismembered; cutting in piece; m The Castilians would doubtless have resented the dismemberment of the unwieldy body of which they formed the head.","pos":""}],"DISMETTLED":[{"def":"Destitute of mettle, that is, or fire or spirit.","pos":""}],"DISMISS":[{"def":"To send away; to give leave of departure; to cause or permit to go; to put away.","pos":""},{"def":"To discard; to remove or discharge from office, service, or employment; as, the king dismisses his ministers; the matter dismisses his servant.","pos":""}],"DISMISSAL":[{"def":"Dismission; discharge.","pos":""}],"DISMISSION":[{"def":"The act dismissing or sending away; permission to leave; leave to depart; dismissal; as, the dismission of the grand jury.","pos":""},{"def":"Removal from office or employment; discharge, either with honor or with disgrace.","pos":""}],"DISMISSIVE":[{"def":"Giving dismission.","pos":""}],"DISMORTGAGE":[{"def":"To redeem from mortgage.","pos":""}],"DISMOUNT":[{"def":"To come down; to descend.","pos":""},{"def":"To alight from a horse; to descend or get off, as a rider from his beast; as, the troops dismounted.","pos":""}]}