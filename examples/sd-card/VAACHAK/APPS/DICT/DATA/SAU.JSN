{"SAUBA ANT":[{"def":"A South American ant (Ecodoma cephalotes) remarkable for having two large kinds of workers besides the ordinary ones, and for the immense size of its formicaries.","pos":""}],"SAUCE":[{"def":"A composition of condiments and appetizing ingredients eaten with food as a relish; especially, a dressing for meat or fish or for puddings; as, mint sauce; sweet sauce, etc.","pos":""},{"def":"Any garden vegetables eaten with meat.","pos":""}],"SAUCE-ALONE":[{"def":"Jack-by-the-hedge.","pos":""}],"SAUCEBOX":[{"def":"A saucy, impudent person; especially, a pert child.","pos":""}],"SAUCEPAN":[{"def":"A small pan with a handle, in which sauce is prepared over a fire; a stewpan.","pos":""}],"SAUCER":[{"def":"A small pan or vessel in which sauce was set on a table.","pos":""},{"def":"A small dish, commonly deeper than a plate, in which a cup is set at table.","pos":""}],"SAUCILY":[{"def":"In a saucy manner; impudently; with impertinent boldness.","pos":""}],"SAUCINESS":[{"def":"The quality or state of being saucy; that which is saucy; impertinent boldness; contempt of superiors; impudence.","pos":""},{"def":"A long and slender pipe or bag, made of cloth well pitched, or of leather, filled with powder, and used to communicate fire to mines, caissons, bomb chests, etc.","pos":""}],"SAUCY":[{"def":"Showing impertinent boldness or pertness; transgressing the rules of decorum; treating superiors with contempt; impudent; insolent; as, a saucy fellow.","pos":""},{"def":"Expressive of, or characterized by, impudence; impertinent; as, a saucy eye; saucy looks.","pos":""}],"SAUERKRAUT":[{"def":"Cabbage cut fine and allowed to ferment in a brine made of its own juice with salt, -- a German dish.","pos":""}],"SAUGER":[{"def":"An American fresh-water food fish (Stizostedion Canadense); -- called also gray pike, blue pike, hornfish, land pike, sand pike, pickering, and pickerel.","pos":""}],"SAUL":[{"def":"Same as Sal, the tree.","pos":""}],"SAULIE":[{"def":"A hired mourner at a funeral.","pos":""}],"SAULT":[{"def":"A rapid in some rivers; as, the Sault Ste.","pos":""}],"SAUNDERS-BLUE":[{"def":"A kind of color prepared from calcined lapis lazuli; ultramarine; also, a blue prepared from carbonate of copper.","pos":""}],"SAUNTER":[{"def":"To wander or walk about idly and in a leisurely or lazy manner; to lounge; to stroll; to loiter.","pos":""}],"SAUNTERER":[{"def":"One who saunters.","pos":""}],"SAUR":[{"def":"Soil; dirt; dirty water; urine from a cowhouse.","pos":""}],"SAUREL":[{"def":"Any carangoid fish of the genus Trachurus, especially T.","pos":""}],"SAURIA":[{"def":"A division of Reptilia formerly established to include the Lacertilia, Crocodilia, Dinosauria, and other groups.","pos":""}],"SAURIAN":[{"def":"Of or pertaining to, or of the nature of, the Sauria.","pos":""},{"def":"One of the Sauria.","pos":""}],"SAURIOID":[{"def":"Same as Sauroid.","pos":""}],"SAUROBATRACHIA":[{"def":"Sau\"ro*ba*tra\"chi*a, n.","pos":""}],"SAUROGNATHOUS":[{"def":"Having the bones of the palate arranged as in saurians, the vomer consisting of two lateral halves, as in the woodpeckers.","pos":""}],"SAUROIDICHNITE":[{"def":"The fossil track of a saurian.","pos":""}],"SAUROPODA":[{"def":"An extinct order of herbivorous dinosaurs having the feet of a saurian type, instead of birdlike, as they are in many dinosaurs.","pos":""}],"SAUROPSIDA":[{"def":"A comprehensive group of vertebrates, comprising the reptiles and birds.","pos":""}],"SAUROPTERYGIA":[{"def":"Same as Plesiosauria.","pos":""}],"SAURURAE":[{"def":"An extinct order of birds having a long vertebrated tail with quills along each side of it.","pos":""}],"SAURY":[{"def":"A slender marine fish (Scombresox saurus) of Europe and America.","pos":""}],"SAUSAGE":[{"def":"An article of food consisting of meat (esp.","pos":""}],"SAUSEFLEM":[{"def":"Having a red, pimpled face.","pos":""}],"SAUSSURITE":[{"def":"A tough, compact mineral, of a white, greenish, or grayish color.","pos":""}],"SAUTER":[{"def":"To fry lightly and quickly, as meat, by turning ot tossing it over frequently in a hot pan greased with a little fat.","pos":""}],"SAUTERELLE":[{"def":"An instrument used by masons and others to trace and form angles.","pos":""}],"SAUTERNE":[{"def":"A white wine made in the district of sauterne, France.","pos":""}]}