{"CONSANGUINEAL":[{"def":"Of the same blood; related by birth.","pos":""}],"CONSANGUINED":[{"def":"Of kin blood; related.","pos":""}],"CONSANGUINEOUS":[{"def":"Of the same blood; related by birth; descended from the same parent or ancestor.","pos":""}],"CONSANGUINITY":[{"def":"The relation of person by blood, is distinction from affinity or relation by marriage; blood relationship; as, lineal consanguinity; collateral consanguinity.","pos":""}],"CONSARCINATION":[{"def":"A patching together; patchwork.","pos":""}]}