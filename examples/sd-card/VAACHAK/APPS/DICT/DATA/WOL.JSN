{"WOLD":[{"def":"A wood; a forest.","pos":""},{"def":"A plain, or low hill; a country without wood, whether hilly or not.","pos":""}],"WOLF":[{"def":"Any one of several species of wild and savage carnivores belonging to the genus Canis and closely allied to the common dog.","pos":""},{"def":"One of the destructive, and usually hairy, larvæ of several species of beetles and grain moths; as, the bee wolf.","pos":""}],"WOLF'S-CLAW":[{"def":"A kind of club moss.","pos":""}],"WOLF'S-MILK":[{"def":"Any kind of spurge (Euphorbia); -- so called from its acrid milky juice.","pos":""}],"WOLFBERRY":[{"def":"An American shrub (Symphoricarpus occidentalis) which bears soft white berries.","pos":""}],"WOLFFIAN":[{"def":"Discovered, or first described, by Caspar Friedrich Wolff (1733-1794), the founder of modern embryology.","pos":""}],"WOLFHOUND":[{"def":"Originally, a large hound used in hunting wolves; now, any one of certain breeds of large dogs, some of which are nearly identical with the great Danes.","pos":""}],"WOLFISH":[{"def":"Like a wolf; having the qualities or form of a wolf; as, a wolfish visage; wolfish designs.","pos":""}],"WOLFKIN":[{"def":"A little or young wolf.","pos":""}],"WOLFRAM":[{"def":"Same as Wolframite.","pos":""}],"WOLFRAM STEEL":[{"def":"Same as Tungsten steel.","pos":""}],"WOLFRAMATE":[{"def":"A salt of wolframic acid; a tungstate.","pos":""}],"WOLFRAMIC":[{"def":"Of or pertaining to wolframium.","pos":""}],"WOLFRAMITE":[{"def":"Tungstate of iron and manganese, generally of a brownish or grayish black color, submetallic luster, and high specific gravity.","pos":""}],"WOLFRAMIUM":[{"def":"The technical name of the element tungsten.","pos":""}],"WOLFSBANE":[{"def":"A poisonous plant (Aconitum Lycoctonum), a kind of monkshood; also, by extension, any plant or species of the genus Aconitum.","pos":""}],"WOLLASTON'S DOUBLET":[{"def":"A magnifying glass consisting of two plano-convex lenses.","pos":""}],"WOLLASTONITE":[{"def":"A silicate of lime of a white to gray, red, or yellow color, occurring generally in cleavable masses, rarely in tabular crystals; tabular spar.","pos":""}],"WOLLE":[{"def":"A nickname for an inhabitant of Michigan.","pos":""}],"WOLVERENE STATE":[{"def":"Michigan; -- a nickname.","pos":""}]}