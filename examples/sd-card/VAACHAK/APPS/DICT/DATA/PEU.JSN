{"PEUCEDANIN":[{"def":"A tasteless white crystalline substance, extracted from the roots of the sulphurwort (Peucedanum), masterwort (Imperatoria), and other related plants; -- called also imperatorin.","pos":""}],"PEUCIL":[{"def":"A liquid resembling camphene, obtained by treating turpentine hydrochloride with lime.","pos":""}]}