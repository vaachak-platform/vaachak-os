{"MAHA":[{"def":"A kind of baboon; the wanderoo.","pos":""},{"def":"A celebrated epic poem of the Hindoos.","pos":""}],"MAHARAJAH":[{"def":"A sovereign prince in India; -- a title given also to other persons of high rank.","pos":""}],"MAHARIF":[{"def":"An African antelope (Hippotragus Bakeri).","pos":""}],"MAHARMAH":[{"def":"A muslin wrapper for the head and the lower part of the face, worn by Turkish and Armenian women when they go abroad.","pos":""}],"MAHATMA":[{"def":"One of a class of sages, or \"adepts,\" reputed to have knowledge and powers of a higher order than those of ordinary men.","pos":""}],"MAHDI":[{"def":"Among Mohammedans, the last imam or leader of the faithful.","pos":""}],"MAHDISM":[{"def":"Belief in the coming of the Mahdi; fanatical devotion to the cause of the Mahdi or a pretender to that title.","pos":""}],"MAHOE":[{"def":"A name given to several malvaceous trees (species of Hibiscus, Ochroma, etc.","pos":""}],"MAHOGANY":[{"def":"A large tree of the genus Swietenia (S.","pos":""}],"MAHOLI":[{"def":"A South African lemur (Galago maholi), having very large ears.","pos":""}],"MAHOMETANISM":[{"def":"See Mohammedanism.","pos":""}],"MAHOMETANIZE":[{"def":"To convert to the religion of Mohammed; to Mohammedanize.","pos":""}],"MAHOMETISM":[{"def":"See Mohammedanism.","pos":""}],"MAHON STOCK":[{"def":"An annual cruciferous plant with reddish purple or white flowers (Malcolmia maritima).","pos":""}],"MAHONE":[{"def":"A large Turkish ship.","pos":""}],"MAHONIA":[{"def":"The Oregon grape, a species of barberry (Berberis Aquifolium), often cultivated for its hollylike foliage.","pos":""}],"MAHOOHOO":[{"def":"The African white two-horned rhinoceros (Atelodus simus).","pos":""}],"MAHORI":[{"def":"One of the dark race inhabiting principally the islands of Eastern Polynesia.","pos":""}],"MAHOUND":[{"def":"A contemptuous name for Mohammed; hence, an evil spirit; a devil.","pos":""}],"MAHOUT":[{"def":"The keeper and driver of an elephant.","pos":""}],"MAHOVO":[{"def":"A device for saving power in stopping and starting a railroad car, by means of a heavy fly wheel.","pos":""}],"MAHRATI":[{"def":"The language of the Mahrattas; the language spoken in the Deccan and Concan.","pos":""}],"MAHRATTA":[{"def":"One of a numerous people inhabiting the southwestern part of India.","pos":""},{"def":"Of or pertaining to the Mahrattas.","pos":""}],"MAHWA TREE":[{"def":"An East Indian sapotaceous tree (Bassia latifolia, and also B.","pos":""}]}