{"ASH":[{"def":"A genus of trees of the Olive family, having opposite pinnate leaves, many of the species furnishing valuable timber, as the European ash (Fraxinus excelsior) and the white ash (F.","pos":""}],"ASH WEDNESDAY":[{"def":"The first day of Lent; -- so called from a custom in the Roman Catholic church of putting ashes, on that day, upon the foreheads of penitents.","pos":""}],"ASH-COLORED":[{"def":"Of the color of ashes; a whitish gray or brownish gray.","pos":""}],"ASH-FIRE":[{"def":"A low fire used in chemical operations.","pos":""},{"def":"A furnace or oven for fritting materials for glass making.","pos":""}],"ASHAMED":[{"def":"Affected by shame; abashed or confused by guilt, or a conviction or consciousness of some wrong action or impropriety.","pos":""}],"ASHANTEE":[{"def":"A native or an inhabitant of Ashantee in Western Africa.","pos":""}],"ASHEN":[{"def":"Of or pertaining to the ash tree.","pos":""}],"ASHERY":[{"def":"A depository for ashes.","pos":""},{"def":"A place where potash is made.","pos":""}],"ASHES":[{"def":"The earthy or mineral particles of combustible substances remaining after combustion, as of wood or coal.","pos":""},{"def":"Specifically: The remains of the human body when burnt, or when \"returned to dust\" by natural decay.","pos":""}],"ASHINE":[{"def":"Shining; radiant.","pos":""},{"def":"The short upright pieces between the floor beams and rafters in garrets.","pos":""}],"ASHORE":[{"def":"On shore or on land; on the land adjacent to water; to the shore; to the land; aground (when applied to a ship); -- sometimes opposed to aboard or afloat.","pos":""}],"ASHTORETH":[{"def":"The principal female divinity of the Phoenicians, as Baal was the principal male divinity.","pos":""}],"ASHY":[{"def":"Pertaining to, or composed of, ashes; filled, or strewed with, ashes.","pos":""},{"def":"Ash-colored; whitish gray; deadly pale.","pos":""}]}