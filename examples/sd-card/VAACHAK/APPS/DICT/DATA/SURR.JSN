{"SURREBOUND":[{"def":"To give back echoes; to reëcho.","pos":""}],"SURREBUT":[{"def":"To reply, as a plaintiff to a defendant's rebutter.","pos":""}],"SURREBUTER":[{"def":"The reply of a plaintiff to a defendant's rebutter.","pos":""}],"SURREIN":[{"def":"To override; to exhaust by riding.","pos":""}],"SURREJOIN":[{"def":"To reply, as a plaintiff to a defendant's rejoinder.","pos":""}],"SURREJOINDER":[{"def":"The answer of a plaintiff to a defendant's rejoinder.","pos":""}],"SURRENDER":[{"def":"To yield; to render or deliver up; to give up; as, a principal surrendered by his bail, a fugitive from justice by a foreign state, or a particular estate by the tenant thereof to him in remainder or reversion.","pos":""}],"SURRENDEREE":[{"def":"The person to whom a surrender is made.","pos":""}],"SURRENDERER":[{"def":"One who surrenders.","pos":""}],"SURRENDEROR":[{"def":"One who makes a surrender, as of an estate.","pos":""}],"SURREPTION":[{"def":"The act or process of getting in a surreptitious manner, or by craft or stealth.","pos":""},{"def":"A coming unperceived or suddenly.","pos":""}],"SURREPTITIOUS":[{"def":"Done or made by stealth, or without proper authority; made or introduced fraudulently; clandestine; stealthy; as, a surreptitious passage in an old manuscript; a surreptitious removal of goods.","pos":""}],"SURREY":[{"def":"A four-wheeled pleasure carriage, (commonly two-seated) somewhat like a phaeton, but having a straight bottom.","pos":""}],"SURROGATE":[{"def":"A deputy; a delegate; a substitute.","pos":""},{"def":"The deputy of an ecclesiastical judge, most commonly of a bishop or his chancellor, especially a deputy who grants marriage licenses.","pos":""}],"SURROGATESHIP":[{"def":"The office of a surrogate.","pos":""}],"SURROGATION":[{"def":"The act of substituting one person in the place of another.","pos":""}],"SURROUND":[{"def":"To inclose, as a body of troops, between hostile forces, so as to cut off means of communication or retreat; to invest, as a city.","pos":""}],"SURROUNDING":[{"def":"Inclosing; encircling.","pos":""}],"SURROYAL":[{"def":"One of the terminal branches or divisions of the beam of the antler of the stag or other large deer.","pos":""}]}