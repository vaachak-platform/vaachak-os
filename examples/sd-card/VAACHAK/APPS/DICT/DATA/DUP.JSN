{"DUP":[{"def":"To open; as, to dup the door.","pos":""}],"DUPABLE":[{"def":"Capable of being duped.","pos":""}],"DUPE":[{"def":"One who has been deceived or who is easily deceived; a gull; as, the dupe of a schemer.","pos":""}],"DUPER":[{"def":"One who dupes another.","pos":""}],"DUPERY":[{"def":"The act or practice of duping.","pos":""}],"DUPION":[{"def":"A double cocoon, made by two silkworms.","pos":""}],"DUPLEX":[{"def":"Double; twofold.","pos":""}],"DUPLICATE":[{"def":"Double; twofold.","pos":""}],"DUPLICATION":[{"def":"The act or process of dividing by natural growth or spontaneous action; as, the duplication of cartilage cells.","pos":""}],"DUPLICATIVE":[{"def":"Having the quality of subdividing into two by natural growth.","pos":""}],"DUPLICATURE":[{"def":"A doubling; a fold, as of a membrane.","pos":""}],"DUPLICITY":[{"def":"Doubleness; a twofold state.","pos":""},{"def":"Doubleness of heart or speech; insincerity; a sustained form of deception which consists in entertaining or pretending to entertain one of feelings, and acting as if influenced by another; bad faith.","pos":""}]}