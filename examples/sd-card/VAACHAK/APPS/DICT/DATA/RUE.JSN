{"RUE":[{"def":"A perennial suffrutescent plant (Ruta graveolens), having a strong, heavy odor and a bitter taste; herb of grace.","pos":""}],"RUEFUL":[{"def":"Causing one to rue or lament; woeful; mournful; sorrowful.","pos":""},{"def":"Expressing sorrow.","pos":""}],"RUELLE":[{"def":"A private circle or assembly at a private house; a circle.","pos":""}]}