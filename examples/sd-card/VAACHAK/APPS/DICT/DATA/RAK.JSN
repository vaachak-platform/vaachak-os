{"RAKE":[{"def":"A fissure or mineral vein traversing the strata vertically, or nearly so; -- called also rake-vein.","pos":""}],"RAKE-VEIN":[{"def":"See Rake, a mineral vein.","pos":""},{"def":"A kind of ardent spirits used in southern Europe and the East, distilled from grape juice, grain, etc.","pos":""}],"RAKEHELL":[{"def":"A lewd, dissolute fellow; a debauchee; a rake.","pos":""},{"def":"Dissolute; wild; lewd; rakish.","pos":""}],"RAKEL":[{"def":"Hasty; reckless; rash.","pos":""}],"RAKER":[{"def":"See Gill rakers, under 1st Gill.","pos":""}],"RAKERY":[{"def":"Debauchery; lewdness.","pos":""}],"RAKESHAME":[{"def":"A vile, dissolute wretch.","pos":""}],"RAKESTALE":[{"def":"The handle of a rake.","pos":""}],"RAKING":[{"def":"The act or process of using a rake; the going over a space with a rake.","pos":""},{"def":"A space gone over with a rake; also, the work done, or the quantity of hay, grain, etc.","pos":""}],"RAKISH":[{"def":"Dissolute; lewd; debauched.","pos":""}],"RAKISHLY":[{"def":"In a rakish manner.","pos":""}],"RAKISHNESS":[{"def":"The quality or state of being rakish.","pos":""}],"RAKU WARE":[{"def":"A kind of earthenware made in Japan, resembling Satsuma ware, but having a paler color.","pos":""}]}