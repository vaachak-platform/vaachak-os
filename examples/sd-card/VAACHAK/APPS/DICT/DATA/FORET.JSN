{"FORETASTE":[{"def":"A taste beforehand; enjoyment in advance; anticipation.","pos":""}],"FORETASTER":[{"def":"One who tastes beforehand, or before another.","pos":""}],"FORETEACH":[{"def":"To teach beforehand.","pos":""}],"FORETELL":[{"def":"To predict; to tell before occurence; to prophesy; to foreshow.","pos":""}],"FORETELLER":[{"def":"One who predicts.","pos":""}],"FORETHINK":[{"def":"To think beforehand; to anticipate in the mind; to prognosticate.","pos":""},{"def":"To contrive (something) beforehend.","pos":""}],"FORETHOUGHT":[{"def":"Thought of, or planned, beforehand; aforethought; prepense; hence, deliberate.","pos":""}],"FORETHOUGHTFUL":[{"def":"Having forethought.","pos":""}],"FORETIME":[{"def":"The past; the time before the present.","pos":""}],"FORETOKEN":[{"def":"Prognostic; previous omen.","pos":""}],"FORETOP":[{"def":"The platform at the head of the foremast.","pos":""}]}