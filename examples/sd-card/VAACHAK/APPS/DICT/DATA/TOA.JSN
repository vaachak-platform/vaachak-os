{"TOAD":[{"def":"Any one of numerous species of batrachians belonging to the genus Bufo and allied genera, especially those of the family Bufonidæ.","pos":""}],"TOADEATER":[{"def":"A fawning, obsequious parasite; a mean sycophant; a flatterer; a toady.","pos":""}],"TOADFISH":[{"def":"American species (Batrachus tau) is very common in shallow water.","pos":""}],"TOADFLAX":[{"def":"An herb (Linaria vulgaris) of the Figwort family, having narrow leaves and showy orange and yellow flowers; -- called also butter and eggs, flaxweed, and ramsted.","pos":""}],"TOADHEAD":[{"def":"The golden plover.","pos":""}],"TOADSTONE":[{"def":"A local name for the igneous rocks of Derbyshire, England; -- said by some to be derived from the German todter stein, meaning dead stone, that is, stone which contains no ores.","pos":""}],"TOADSTOOL":[{"def":"A name given to many umbrella-shaped fungi, mostly of the genus Agaricus.","pos":""}],"TOADY":[{"def":"A mean flatterer; a toadeater; a sycophant.","pos":""},{"def":"A coarse, rustic woman.","pos":""}],"TOADYISM":[{"def":"The practice of meanly fawning on another; base sycophancy; servile adulation.","pos":""}],"TOAST":[{"def":"To dry and brown by the heat of a fire; as, to toast bread.","pos":""},{"def":"To warm thoroughly; as, to toast the feet.","pos":""}],"TOASTER":[{"def":"A kitchen utensil for toasting bread, cheese, etc.","pos":""}],"TOASTING":[{"def":"Toast\"ing, Defn: a.","pos":""}],"TOASTMASTER":[{"def":"A person who presides at a public dinner or banquet, and announces the toasts.","pos":""}],"TOAT":[{"def":"The handle of a joiner's plane.","pos":""}]}