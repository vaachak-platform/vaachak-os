{"GALA":[{"def":"Pomp, show, or festivity.","pos":""}],"GALACTA-GOGUE":[{"def":"An agent exciting secretion of milk.","pos":""}],"GALACTIC":[{"def":"Of or pertaining to milk; got from milk; as, galactic acid.","pos":""},{"def":"Of or pertaining to the galaxy or Milky Way.","pos":""}],"GALACTODENSIMETER":[{"def":"Same as Galactometer.","pos":""}],"GALACTOMETER":[{"def":"An instrument for ascertaining the quality of milk (i.","pos":""}],"GALACTOPHAGIST":[{"def":"One who eats, or subsists on, milk.","pos":""}],"GALACTOPHAGOUS":[{"def":"Feeding on milk.","pos":""}],"GALACTOPHOROUS":[{"def":"Milk-carrying; lactiferous; -- applied to the ducts of mammary glands.","pos":""}],"GALACTOPOIETIC":[{"def":"Increasing the flow of milk; milk-producing.","pos":""}],"GALACTOSE":[{"def":"A white, crystalline sugar, C6H12O6, isomeric with dextrose, obtained by the decomposition of milk sugar, and also from certain gums.","pos":""}],"GALAGO":[{"def":"A genus of African lemurs, including numerous species.","pos":""},{"def":"The pungent aromatic rhizome or tuber of certain East Indian or Chinese species of Alpinia (A.","pos":""}],"GALANTINE":[{"def":"A dish of veal, chickens, or other white meat, freed from bones, tied up, boiled, and served cold.","pos":""}],"GALAPEE TREE":[{"def":"The West Indian Sciadophyllum Brownei, a tree with very large digitate leaves.","pos":""}],"GALATEA":[{"def":"A kind of striped cotton fabric, usually of superior quality and striped with blue or red on white.","pos":""}],"GALATIAN":[{"def":"Of or pertaining to Galatia or its inhabitants.","pos":""}],"GALAXY":[{"def":"The Milky Way; that luminous tract, or belt, which is seen at night stretching across the heavens, and which is composed of innumerable stars, so distant and blended as to be distinguishable only with the telescope.","pos":""},{"def":"A gum resin exuding from the stems of certain Asiatic umbelliferous plants, mostly species of Ferula.","pos":""}]}