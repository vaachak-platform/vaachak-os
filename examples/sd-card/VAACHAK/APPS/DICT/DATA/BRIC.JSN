{"BRICK":[{"def":"A block or clay tempered with water, sand, etc.","pos":""},{"def":"Bricks, collectively, as designating that kind of material; as, a load of brick; a thousand of brick.","pos":""}],"BRICKBAT":[{"def":"A piece or fragment of a brick.","pos":""}],"BRICKFIELDER":[{"def":"By confusion, a midsummer hot wind from the north.","pos":""}],"BRICKKILN":[{"def":"A kiln, or furnace, in which bricks are baked or burnt; or a pile of green bricks, laid loose, with arches underneath to receive the wood or fuel for burning them.","pos":""}],"BRICKLAYER":[{"def":"One whose pccupation is to build with bricks.","pos":""}],"BRICKLAYING":[{"def":"The art of building with bricks, or of uniting them by cement or mortar into various forms; the act or occupation of laying bricks.","pos":""}],"BRICKLE":[{"def":"Brittle; easily broken.","pos":""}],"BRICKMAKER":[{"def":"One whose occupation is to make bricks.","pos":""}],"BRICKWORK":[{"def":"Anything made of bricks.","pos":""},{"def":"The act of building with or laying bricks.","pos":""}],"BRICKY":[{"def":"Full of bricks; formed of bricks; resembling bricks or brick dust.","pos":""}],"BRICKYARD":[{"def":"A place where bricks are made, especially an inclosed place.","pos":""}],"BRICOLE":[{"def":"A kind of traces with hooks and rings, with which men drag and maneuver guns where horses can not be used.","pos":""}]}