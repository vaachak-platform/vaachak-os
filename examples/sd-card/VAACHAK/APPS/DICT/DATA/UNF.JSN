{"UNFACE":[{"def":"To remove the face or cover from; to unmask; to expose.","pos":""}],"UNFAILING":[{"def":"Not failing; not liable to fail; inexhaustible; certain; sure.","pos":""}],"UNFAIR":[{"def":"To deprive of fairness or beauty.","pos":""}],"UNFAITH":[{"def":"Absence or want of faith; faithlessness; distrust; unbelief.","pos":""}],"UNFAITHFUL":[{"def":"Not faithful; not observant of promises, vows, allegiance, or duty; violating trust or confidence; treacherous; perfidious; as, an unfaithful subject; an unfaithful agent or servant.","pos":""},{"def":"Not possessing faith; infidel.","pos":""}],"UNFALCATED":[{"def":"Not falcated, or hooked.","pos":""},{"def":"Having no deductions; not curtailed, or shortened; undiminished.","pos":""}],"UNFASTEN":[{"def":"To loose; to unfix; to unbind; to untie.","pos":""}],"UNFATHERED":[{"def":"Having no father; fatherless; hence, born contrary to nature.","pos":""},{"def":"Having no acknowledged father; hence, illegitimate; spurious; bastard.","pos":""}],"UNFAVORABLE":[{"def":"Not favorable; not propitious; adverse; contrary; discouraging.","pos":""}],"UNFEATHER":[{"def":"To deprive of feathers; to strip.","pos":""}],"UNFEATURED":[{"def":"Wanting regular features; deformed.","pos":""}],"UNFEATY":[{"def":"Not feat; not dexterous; unskillful; clumsy.","pos":""}],"UNFEELING":[{"def":"Destitute of feeling; void of sensibility; insensible; insensate.","pos":""},{"def":"Without kind feelings; cruel; hard-hearted.","pos":""}],"UNFEIGNED":[{"def":"Not feigned; not counterfeit; not hypocritical; real; sincere; genuine; as, unfeigned piety; unfeigned love to man.","pos":""}],"UNFELLOW":[{"def":"To prevent from being a fellow or companion; to separate from one's fellows; to dissever.","pos":""}],"UNFELLOWED":[{"def":"Being without a fellow; unmatched; unmated.","pos":""}],"UNFENCE":[{"def":"To strip of a fence; to remove a fence from.","pos":""}],"UNFERTILE":[{"def":"Not fertile; infertile; barren.","pos":""}],"UNFESTLICH":[{"def":"Unfit for a feast; hence, jaded; worn.","pos":""}],"UNFETTER":[{"def":"To loose from fetters or from restraint; to unchain; to unshackle; to liberate; as, to unfetter the mind.","pos":""}],"UNFEUDALIZE":[{"def":"To free from feudal customs or character; to make not feudal.","pos":""}],"UNFILE":[{"def":"To remove from a file or record.","pos":""}],"UNFILED":[{"def":"Not defiled; pure.","pos":""}],"UNFILIAL":[{"def":"Unsuitable to a son or a daughter; undutiful; not becoming a child.","pos":""}],"UNFINISHED":[{"def":"Not finished, not brought to an end; imperfect; incomplete; left in the rough; wanting the last hand or touch; as, an unfinished house; an unfinished picture; an unfinished iron casting.","pos":""}],"UNFIT":[{"def":"To make unsuitable or incompetent; to deprive of the strength, skill, or proper qualities for anything; to disable; to incapacitate; to disqualify; as, sickness unfits a man for labor; sin unfits us for the society of holy beings.","pos":""}],"UNFIX":[{"def":"To loosen from a fastening; to detach from anything that holds; to unsettle; as, to unfix a bayonet; to unfix the mind or affections.","pos":""},{"def":"To make fluid; to dissolve.","pos":""}],"UNFLEDGED":[{"def":"Not fledged; not feathered; hence, not fully developed; immature.","pos":""}],"UNFLESH":[{"def":"To deprive of flesh; to reduce a skeleton.","pos":""}],"UNFLESHLY":[{"def":"Not pertaining to the flesh; spiritual.","pos":""}],"UNFLINCHING":[{"def":"Not flinching or shrinking; unyielding.","pos":""}],"UNFLOWER":[{"def":"To strip of flowers.","pos":""}],"UNFOLD":[{"def":"To open the folds of; to expand; to spread out; as, to unfold a tablecloth.","pos":""},{"def":"To open, as anything covered or close; to lay open to view or contemplation; to bring out in all the details, or by successive development; to display; to disclose; to reveal; to elucidate; to explain; as, to unfold one's designs; to unfold the principles of a science.","pos":""}],"UNFOLDER":[{"def":"One who, or that which, unfolds.","pos":""}],"UNFOLDMENT":[{"def":"The acct of unfolding, or the state of being unfolded.","pos":""}],"UNFOOL":[{"def":"To restore from folly, or from being a fool.","pos":""}],"UNFORESEE":[{"def":"To fail to foresee.","pos":""}],"UNFORESEEABLE":[{"def":"Incapable of being foreseen.","pos":""}],"UNFORESKINNED":[{"def":"Deprived of the foreskin; circumcised.","pos":""}],"UNFORGETTABLE":[{"def":"Not forgettable; enduring in memory.","pos":""}],"UNFORM":[{"def":"To decompose, or resolve into parts; to destroy the form of; to unmake.","pos":""}],"UNFORMED":[{"def":"Unorganized; without definite shape or structure; as, an unformed, or unorganized, ferment.","pos":""}],"UNFORTUNATE":[{"def":"Not fortunate; unsuccessful; not prosperous; unlucky; attended with misfortune; unhappy; as, an unfortunate adventure; an unfortunate man; an unfortunate commander; unfortunate business.","pos":""},{"def":"An unfortunate person.","pos":""}],"UNFOUNDED":[{"def":"Not founded; not built or established.","pos":""},{"def":"Having no foundation; baseless; vain; idle; as, unfounded expectations.","pos":""}],"UNFRAME":[{"def":"To take apart, or destroy the frame of.","pos":""}],"UNFRANKABLE":[{"def":"Not frankable; incapable of being sent free by public conveyance.","pos":""}],"UNFRAUGHT":[{"def":"Not fraught; not burdened.","pos":""},{"def":"Removed, as a burden; unloaded.","pos":""}],"UNFREE":[{"def":"Not free; held in bondage.","pos":""}],"UNFREQUENT":[{"def":"To cease to frequent.","pos":""}],"UNFREQUENTED":[{"def":"Rarely visited; seldom or never resorted to by human beings; as, an unfrequented place or forest.","pos":""}],"UNFRET":[{"def":"To smooth after being fretted.","pos":""}],"UNFRIEND":[{"def":"One not a friend; an enemy.","pos":""}],"UNFRIENDED":[{"def":"Wanting friends; not befriended; not countenanced or supported.","pos":""}],"UNFRIENDLY":[{"def":"Not friendly; not kind or benevolent; hostile; as, an unfriendly neighbor.","pos":""},{"def":"Not favorable; not adapted to promote or support any object; as, weather unfriendly to health.","pos":""}],"UNFRIENDSHIP":[{"def":"The state or quality of being unfriendly; unfriendliness; enmity.","pos":""}],"UNFROCK":[{"def":"To deprive or divest or a frock; specifically, to deprive of priestly character or privilege; as, to unfrock a priest.","pos":""}],"UNFRUITFUL":[{"def":"Not producing fruit or offspring; unproductive; infertile; barren; sterile; as, an unfruitful tree or animal; unfruitful soil; an unfruitful life or effort.","pos":""}],"UNFUMED":[{"def":"Not exposed to fumes; not fumigated.","pos":""}],"UNFURL":[{"def":"To loose from a furled state; to unfold; to expand; to open or spread; as, to unfurl sails; to unfurl a flag.","pos":""}],"UNFURNISH":[{"def":"To strip of furniture; to divest; to strip.","pos":""}]}