{"STIBIAL":[{"def":"Like, or having the qualities of, antimony; antimonial.","pos":""}],"STIBIALISM":[{"def":"Antimonial intoxication or poisoning.","pos":""}],"STIBIATED":[{"def":"Combined or impregnated with antimony (stibium).","pos":""}],"STIBIC":[{"def":"Antimonic; -- used with reference to certain compounds of antimony.","pos":""}],"STIBICONITE":[{"def":"A native oxide of antimony occurring in masses of a yellow color.","pos":""}],"STIBINE":[{"def":"Antimony hydride, or hydrogen antimonide, a colorless gas produced by the action of nascent hydrogen on antimony.","pos":""}],"STIBIUM":[{"def":"The technical name of antimony.","pos":""}],"STIBNITE":[{"def":"A mineral of a lead-gray color and brilliant metallic luster, occurring in prismatic crystals; sulphide of antimony; -- called also antimony glance, and gray antimony.","pos":""}],"STIBONIUM":[{"def":"The hypothetical radical SbH4, analogous to ammonium; -- called also antimonium.","pos":""}]}