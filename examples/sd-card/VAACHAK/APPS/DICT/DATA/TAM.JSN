{"TAM-'-SHANTER":[{"def":"A kind of Scotch cap of wool, worsted, or the like, having a round, flattish top much wider than the band which fits the head, and usually having a tassel in the center.","pos":""}],"TAMABILITY":[{"def":"The quality or state of being tamable; tamableness.","pos":""}],"TAMABLE":[{"def":"Capable of being tamed, subdued, or reclaimed from wildness or savage ferociousness.","pos":""}],"TAMALE":[{"def":"A Mexican dish made of crushed maize mixed with minced meat, seasoned with red pepper, dipped in oil, and steamed.","pos":""}],"TAMANDU":[{"def":"A small ant-eater (Tamandua tetradactyla) native of the tropical parts of South America.","pos":""}],"TAMARACK":[{"def":"Columbia (Larix occidentalis).","pos":""}],"TAMARIC":[{"def":"A shrub or tree supposed to be the tamarisk, or perhaps some kind of heath.","pos":""}],"TAMARIN":[{"def":"Any one of several species of small squirrel-like South American monkeys of the genus Midas, especially M.","pos":""}],"TAMARIND":[{"def":"A leguminous tree (Tamarindus Indica) cultivated both the Indies, and the other tropical countries, for the sake of its shade, and for its fruit.","pos":""},{"def":"One of the preserved seed pods of the tamarind, which contain an acid pulp, and are used medicinally and for preparing a pleasant drink.","pos":""}],"TAMARISK":[{"def":"Any shrub or tree of the genus Tamarix, the species of which are European and Asiatic.","pos":""}],"TAMBOUR":[{"def":"A kind of small flat drum; a tambourine.","pos":""},{"def":"Same as Drum, n.","pos":""}],"TAMBOURIN":[{"def":"An old Provençal dance of a lively character, common on the stage.","pos":""}],"TAMBOURINE":[{"def":"A small drum, especially a shallow drum with only one skin, played on with the hand, and having bells at the sides; a timbrel.","pos":""}],"TAME":[{"def":"To broach or enter upon; to taste, as a liquor; to divide; to distribute; to deal out.","pos":""}],"TAMELESS":[{"def":"Incapable of being tamed; wild; untamed; untamable.","pos":""}],"TAMELY":[{"def":"In a tame manner.","pos":""}],"TAMENESS":[{"def":"The quality or state of being tame.","pos":""}],"TAMER":[{"def":"One who tames or subdues.","pos":""}],"TAMIAS":[{"def":"A genus of ground squirrels, including the chipmunk.","pos":""}],"TAMIL":[{"def":"Of or pertaining to the Tamils, or to their language.","pos":""}],"TAMILIAN":[{"def":"A kind of woolen cloth; tammy.","pos":""}],"TAMIS":[{"def":"A sieve, or strainer, made of a kind of woolen cloth.","pos":""},{"def":"The cloth itself; tammy.","pos":""}],"TAMMY":[{"def":"A kind of woolen, or woolen and cotton, cloth, often highly glazed, -- used for curtains, sieves, strainers, etc.","pos":""},{"def":"A sieve, or strainer, made of this material; a tamis.","pos":""}],"TAMP":[{"def":"In blasting, to plug up with clay, earth, dry sand, sod, or other material, as a hole bored in a rock, in order to prevent the force of the explosion from being misdirected.","pos":""},{"def":"To drive in or down by frequent gentle strokes; as, to tamp earth so as to make a smooth place.","pos":""}],"TAMPAN":[{"def":"A venomous South African tick.","pos":""}],"TAMPER":[{"def":"One who tamps; specifically, one who prepares for blasting, by filling the hole in which the charge is placed.","pos":""},{"def":"An instrument used in tamping; a tamping iron.","pos":""}],"TAMPERER":[{"def":"One who tampers; one who deals unfairly.","pos":""},{"def":"A tough vegetable fiber used as a substitute for bristles in making brushes.","pos":""}],"TAMPING":[{"def":"The act of one who tamps; specifically, the act of filling up a hole in a rock, or the branch of a mine, for the purpose of blasting the rock or exploding the mine.","pos":""},{"def":"The material used in tamping.","pos":""}],"TAMPION":[{"def":"A plug for upper end of an organ pipe.","pos":""}],"TAMPOE":[{"def":"The edible fruit of an East Indian tree (Baccaurea Malayana) of the Spurge family.","pos":""}],"TAMPON":[{"def":"A plug introduced into a natural or artificial cavity of the body in order to arrest hemorrhage, or for the application of medicine.","pos":""}],"TAMPOON":[{"def":"The stopper of a barrel; a bung.","pos":""}],"TAMWORTH":[{"def":"One of a long-established English breed of large pigs.","pos":""}]}