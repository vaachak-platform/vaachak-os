{"TOR":[{"def":"To scratch to pieces.","pos":""},{"def":"A gateway, commonly of wood, but sometimes of stone, consisting of two upright pillars carrying one to three transverse lintels.","pos":""}],"TORBERNITE":[{"def":"A mineral occurring in emerald-green tabular crystals having a micaceous structure.","pos":""}],"TORC":[{"def":"Same as Torque, 1.","pos":""}],"TORCH":[{"def":"A light or luminary formed of some combustible substance, as of resinous wood; a large candle or flambeau, or a lamp giving a large, flaring flame.","pos":""}],"TORCH RACE":[{"def":"A race by men carrying torches, as in ancient Greece.","pos":""}],"TORCHBEARER":[{"def":"One whose office it is to carry a torch.","pos":""}],"TORCHER":[{"def":"One who gives light with a torch, or as if with a torch.","pos":""}],"TORCHLIGHT":[{"def":"The light of a torch, or of torches.","pos":""}],"TORCHON LACE":[{"def":"a simple thread lace worked upon a pillow with coarse thread; also, a similar lace made by machinery.","pos":""}],"TORCHON PAPER":[{"def":"Paper with a rough surface; esp.","pos":""}],"TORCHWOOD":[{"def":"The inflammable wood of certain trees (Amyris balsamifera, A.","pos":""}],"TORCHWORT":[{"def":"The common mullein, the stalks of which, dipped in suet, anciently served for torches.","pos":""}],"TORE":[{"def":"The dead grass that remains on mowing land in winter and spring.","pos":""}],"TORET":[{"def":"A ring for fastening a hawk's leash to the jesses; also, a ring affixed to the collar of a dog, etc.","pos":""}],"TOREUMATOGRAPHY":[{"def":"A description of sculpture such as bas-relief in metal.","pos":""}],"TOREUMATOLOGY":[{"def":"The art or the description of scupture such as bas-relief in metal; toreumatography.","pos":""}],"TOREUTIC":[{"def":"In relief; pertaining to sculpture in relief, especially of metal; also, pertaining to chasing such as surface ornamentation in metal.","pos":""}],"TORILTO":[{"def":"A species of Turnix (Turnix sylvatica) native of Spain and Northen Africa.","pos":""}],"TORINESE":[{"def":"Of or pertaining to Turin.","pos":""},{"def":"A native or inhabitant of Turin; collectively, the people of Turin.","pos":""}],"TORMENT":[{"def":"An engine for casting stones.","pos":""}],"TORMENTER":[{"def":"One who, or that which, torments; a tormentor.","pos":""}],"TORMENTFUL":[{"def":"Full of torment; causing, or accompainied by, torment; excruciating.","pos":""}],"TORMENTIL":[{"def":"A rosaceous herb (Potentilla Tormentilla), the root of which is used as a powerful astringent, and for alleviating gripes, or tormina, in diarrhea.","pos":""}],"TORMENTING":[{"def":"Causing torment; as, a tormenting dream.","pos":""}],"TORMENTISE":[{"def":"Torture; torment.","pos":""}],"TORMENTOR":[{"def":"An implement for reducing a stiff soil, resembling a harrow, but running upon wheels.","pos":""}],"TORMENTRESS":[{"def":"A woman who torments.","pos":""}],"TORMENTRY":[{"def":"Anything producing torment, annoyance, or pain.","pos":""}],"TORMINA":[{"def":"acute, colicky pains; gripes.","pos":""}],"TORMINOUS":[{"def":"Affected with tormina; griping.","pos":""}],"TORNADO":[{"def":"A violent whirling wind; specifically (Meteorol.","pos":""}],"TORNARIA":[{"def":"The peculiar free swimming larva of Balanoglossus.","pos":""}],"TOROSE":[{"def":"Cylindrical with alternate swellings and contractions; having the surface covered with rounded prominences.","pos":""}],"TOROSITY":[{"def":"The quality or state of being torose.","pos":""}],"TORPEDINOUS":[{"def":"Of or pertaining to a torpedo; resembling a torpedo; exerting a benumbing influence; stupefying; dull; torpid.","pos":""}],"TORPEDO":[{"def":"Any one of numerous species of elasmobranch fishes belonging to Torpedo and allied genera.","pos":""},{"def":"A kind of shell or cartridge buried in earth, to be exploded by electricity or by stepping on it.","pos":""}],"TORPEDO BODY":[{"def":"An automobile body which is built so that the side surfaces are flush.","pos":""}],"TORPEDO BOOM":[{"def":"A spar formerly carried by men-of-war, having a torpedo on its end.","pos":""}],"TORPEDO CATCHER":[{"def":"A small fast vessel for pursuing and destroying torpedo boats.","pos":""}],"TORPEDO SHELL":[{"def":"A shell longer than a deck-piercing shell, with thinner walls and a larger cavity for the bursting charge, which consists of about 130 pounds of high explosive.","pos":""}],"TORPEDO STATION":[{"def":"A headquarters for torpedo vessels and their supplies, usually having facilities for repairs and for instruction and experiments.","pos":""}],"TORPEDO STERN":[{"def":"A broad stern without overhang, flattened on the bottom, used in some torpedo and fast power boats.","pos":""}],"TORPEDO TUBE":[{"def":"A tube fixed below or near the water line through which a torpedo is fired, usually by a small charge of gunpowder.","pos":""}],"TORPEDO-BOAT DESTROYER":[{"def":"A larger, swifter, and more powerful armed type of torpedo boat, originally intended principally for the destruction of torpedo boats, but later used also as a more formidable torpedo boat.","pos":""}],"TORPEDOIST":[{"def":"One skilled in the theory or use of torpedoes; also, one who favors the use of torpedoes.","pos":""}],"TORPENT":[{"def":"Having no motion or activity; incapable of motion; benumbed; torpid.","pos":""}],"TORPESCENCE":[{"def":"The quality or state or being torpescent; torpidness; numbness; stupidity.","pos":""}],"TORPESCENT":[{"def":"Becoming torpid or numb.","pos":""}],"TORPID":[{"def":"Having lost motion, or the power of exertion and feeling; numb; benumbed; as, a torpid limb.","pos":""},{"def":"Dull; stupid; sluggish; inactive.","pos":""}],"TORPIDITY":[{"def":"Same as Torpidness.","pos":""}],"TORPIDLY":[{"def":"In a torpid manner.","pos":""}],"TORPIDNESS":[{"def":"The qualityy or state of being torpid.","pos":""}],"TORPIFY":[{"def":"To make torpid; to numb, or benumb.","pos":""}],"TORPOR":[{"def":"Loss of motion, or of the motion; a state of inactivity with partial or total insensibility; numbness.","pos":""},{"def":"Dullness; sluggishness; inactivity; as, a torpor of the mental faculties.","pos":""}],"TORPORIFIC":[{"def":"Tending to produce torpor.","pos":""}],"TORQUATE":[{"def":"Collared; having a torques, or distinct colored ring around the neck.","pos":""}],"TORQUATED":[{"def":"Having or wearing a torque, or neck chain.","pos":""}],"TORQUE":[{"def":"That which tends to produce torsion; a couple of forces.","pos":""},{"def":"A turning or twisting; tendency to turn, or cause to turn, about an axis.","pos":""}],"TORQUED":[{"def":"Twisted; bent; -- said of a dolphin haurient, which forms a figure like the letter S.","pos":""}],"TORQUES":[{"def":"A cervical ring of hair or feathers, distinguished by its color or structure; a collar.","pos":""}],"TORREFACTION":[{"def":"The act or process of torrefying, or the state of being torrefied.","pos":""}],"TORREFY":[{"def":"To subject to scorching heat, so as to drive off volatile ingredients; to roast, as ores.","pos":""},{"def":"To dry or parch, as drugs, on a metallic plate till they are friable, or are reduced to the state desired.","pos":""}],"TORRENS SYSTEM":[{"def":"A system of registration of titles to land (as distinct from registration of deeds) introduced into South Australia by the Real Property (or Torrens) Act (act 15 of 1857-58), drafted by Sir Robert Torrens (1814-84).","pos":""}],"TORRENT":[{"def":"A violent stream, as of water, lava, or the like; a stream suddenly raised and running rapidly, as down a precipice.","pos":""}],"TORRICELLIAN":[{"def":"Of or pertaining to Torricelli, an Italian philosopher and mathematician, who, in 1643, discovered that the rise of a liquid in a tube, as in the barometer, is due to atmospheric pressure.","pos":""}],"TORRID":[{"def":"Parched; dried with heat; as, a torrid plain or desert.","pos":""},{"def":"Violenty hot; drying or scorching with heat; burning; parching.","pos":""}],"TORRIDNESS":[{"def":"The quality or state of being torrid or parched.","pos":""}],"TORRIL":[{"def":"A worthless woman; also, a worthless horse.","pos":""}],"TORSADE":[{"def":"A twisted cord; also, a molded or worked ornament of similar form.","pos":""}],"TORSE":[{"def":"A developable surface.","pos":""}],"TORSEL":[{"def":"A plate of timber for the end of a beam or joist to rest on.","pos":""}],"TORSIBILLTY":[{"def":"The tendency, as of a rope, to untwist after being twisted.","pos":""}],"TORSION":[{"def":"That force with which a thread, wire, or rod of any material, returns, or tends to return, to a state of rest after it has been twisted; torsibility.","pos":""}],"TORSION ELECTROMETER":[{"def":"A torsion balance used for measuring electric attraction or repulsion.","pos":""}],"TORSION GALVANOMETER":[{"def":"A galvanometer in which current is measured by torsion.","pos":""}],"TORSION HEAD":[{"def":"That part of a torsion balance from which the wire or filament is suspended.","pos":""}],"TORSION INDICATOR":[{"def":"An autographic torsion meter.","pos":""}],"TORSION METER":[{"def":"An instrument for determining the torque on a shaft, and hence the horse power of an engine, esp.","pos":""}],"TORSIONAL":[{"def":"Of or pertaining to torsion; resulting from torsion, or the force with which a thread or wire returns to a state of rest after having been twisted round its axis; as, torsional force.","pos":""}],"TORSO":[{"def":"The human body, as distinguished from the head and limbs; in sculpture, the trunk of a statue, mutilated of head and limbs; as, the torso of Hercules.","pos":""}],"TORT":[{"def":"Any civil wrong or injury; a wrongful act (not involving a breach of contract) for which an action will lie; a form of action, in some parts of the United States, for a wrong or injury.","pos":""}],"TORTA":[{"def":"a flat heap of moist, crushed silver ore, prepared for the patio process.","pos":""}],"TORTEAU":[{"def":"A roundel of a red color.","pos":""}],"TORTILE":[{"def":"Twisted; wreathed; coiled.","pos":""}],"TORTILITY":[{"def":"The quality or state of being tortile, twisted, or wreathed.","pos":""}],"TORTILLA":[{"def":"An unleavened cake, as of maize flour, baked on a heated iron or stone.","pos":""}],"TORTIOUS":[{"def":"Imploying tort, or privat injury for which the law gives damages; involing tort.","pos":""}],"TORTIOUSLY":[{"def":"In a tortous manner.","pos":""}],"TORTIVE":[{"def":"Twisted; wreathed.","pos":""}],"TORTOISE":[{"def":"Any one of numerous species of reptiles of the order Testudinata.","pos":""},{"def":"Same as Testudo, 2.","pos":""}],"TORTRICID":[{"def":"Of or pertaining to Tortix, or the family Tortricidæ.","pos":""}],"TORTRIX":[{"def":"Any one of numerous species of small moths of the family Tortricidæ, the larvæ of which usually roll up the leaves of plants on which they live; -- also called leaf roller.","pos":""},{"def":"A genus of tropical short-tailed snakes, which are not venomous.","pos":""}],"TORTULOUS":[{"def":"Swelled out at intervals like a knotted cord.","pos":""}],"TORTUOSE":[{"def":"Wreathed; twisted; winding.","pos":""}],"TORTUOSLTY":[{"def":"the quality or state of being tortuous.","pos":""}],"TORTUOUS":[{"def":"Oblique; -- applied to the six signs of the zodiac (from Capricorn to Gemini) which ascend most rapidly and obliquely.","pos":""}],"TORTURABLE":[{"def":"Capable of being tortured.","pos":""}],"TORTURE":[{"def":"Extreme pain; anguish of body or mind; pang; agony; torment; as, torture of mind.","pos":""},{"def":"Especially, severe pain inflicted judicially, either as punishment for a crime, or for the purpose of extorting a confession from an accused person, as by water or fire, by the boot or thumbkin, or by the rack or wheel.","pos":""}],"TORTURER":[{"def":"One who tortures; a tormentor.","pos":""}],"TORTURINGLY":[{"def":"So as to torture.","pos":""}],"TORTUROUS":[{"def":"Involving, or pertaining to, torture.","pos":""}],"TORULAFORM":[{"def":"Having the appearance of a torula; in the form of a little chain; as, a torulaform string of micrococci.","pos":""}],"TORUS":[{"def":"A lage molding used in the bases of columns.","pos":""},{"def":"One of the ventral parapodia of tubicolous annelids.","pos":""}],"TORVED":[{"def":"But yesterday his breath Awed Rome, and his least torved frown was death.","pos":""}],"TORVITY":[{"def":"Sourness or severity of countenance; sterness.","pos":""}],"TORVOUS":[{"def":"Sour of aspect; of a severe countenance; stern; grim.","pos":""}],"TORY":[{"def":"A member of the conservative party, as opposed to the progressive party which was formerly called the Whig, and is now called the Liberal, party; an earnest supporter of exsisting royal and ecclesiastical authority.","pos":""},{"def":"One who, in the time of the Revolution, favored submitting tothe claims of Great Britain against the colonies; an adherent tothe crown.","pos":""}],"TORYISM":[{"def":"The principles of the Tories.","pos":""}]}