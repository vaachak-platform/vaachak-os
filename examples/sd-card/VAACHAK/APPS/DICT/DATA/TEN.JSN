{"TEN":[{"def":"One more than nine; twice five.","pos":""}],"TEN-O'CLOCK":[{"def":"A plant, the star-of-Bethlehem.","pos":""}],"TEN-POUNDER":[{"def":"A large oceanic fish (Elops saurus) found in the tropical parts of all the oceans.","pos":""}],"TEN-STRIKE":[{"def":"A knocking down of all ten pins at one delivery of the ball.","pos":""}]}