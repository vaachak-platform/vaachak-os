{"SCHADE":[{"def":"Note: English words now beginning with sh, like shade, were formerly often spelled with a c between the s and h; as, schade; schame; schape; schort, etc.","pos":""}],"SCHAPPE":[{"def":"A silk yarn or fabric made out of carded spun silk.","pos":""}],"SCHATCHEN":[{"def":"A person whose business is marriage brokage; a marriage broker, esp.","pos":""}],"SCHEDIASM":[{"def":"Cursory writing on a loose sheet.","pos":""}],"SCHEDULE":[{"def":"A written or printed scroll or sheet of paper; a document; especially, a formal list or inventory; a list or catalogue annexed to a larger document, as to a will, a lease, a statute, etc.","pos":""}],"SCHEELE'S GREEN":[{"def":"See under Green.","pos":""}],"SCHEELITE":[{"def":"Calcium tungstate, a mineral of a white or pale yellowish color and of the tetragonal system of crystallization.","pos":""}],"SCHEELIUM":[{"def":"The metal tungsten.","pos":""}],"SCHEIK":[{"def":"Scheik (shek or shak), n.","pos":""}],"SCHEMA":[{"def":"An outline or image universally applicable to a general conception, under which it is likely to be presented to the mind; as, five dots in a line are a schema of the number five; a preceding and succeeding event are a schema of cause and effect.","pos":""}],"SCHEMATIC":[{"def":"Of or pertaining to a scheme or a schema.","pos":""}],"SCHEMATISM":[{"def":"Combination of the aspects of heavenly bodies.","pos":""}],"SCHEMATIST":[{"def":"One given to forming schemes; a projector; a schemer.","pos":""}],"SCHEMATIZE":[{"def":"To form a scheme or schemes.","pos":""}],"SCHEME":[{"def":"A representation of the aspects of the celestial bodies for any moment o at a given event.","pos":""}],"SCHEMEFUL":[{"def":"Full of schemes or plans.","pos":""}],"SCHEMER":[{"def":"One who forms schemes; a projector; esp.","pos":""}],"SCHEMING":[{"def":"Given to forming schemes; artful; intriguing.","pos":""}],"SCHENE":[{"def":"An Egyptian or Persian measure of length, varying from thirthy- two to sixty stadia.","pos":""}],"SCHENKBEER":[{"def":"A mild German beer.","pos":""}],"SCHERZANDO":[{"def":"In a playful or sportive manner.","pos":""}],"SCHERZO":[{"def":"A playful, humorous movement, commonly in 3-4 measure, which often takes the place of the old minuet and trio in a sonata or a symphony.","pos":""}],"SCHESIS":[{"def":"A figure of speech whereby the mental habitude of an adversary or opponent is feigned for the purpose of arguing against him.","pos":""},{"def":"Of or pertaining to the habit of the body; constitutional.","pos":""}],"SCHIEDAM":[{"def":"Holland gin made at Schiedam in the Netherlands.","pos":""}],"SCHILLER":[{"def":"The peculiar bronzelike luster observed in certain minerals, as hypersthene, schiller spar, etc.","pos":""}],"SCHILLERIZATION":[{"def":"The act or process of producing schiller in a mineral mass.","pos":""}],"SCHILLING":[{"def":"Any one of several small German and Dutch coins, worth from about one and a half cents to about five cents.","pos":""}],"SCHINDYLESIS":[{"def":"A form of articulation in which one bone is received into a groove or slit in another.","pos":""}],"SCHISM":[{"def":"Division or separation; specifically (Eccl.","pos":"verb"}],"SCHISMA":[{"def":"An interval equal to half a comma.","pos":""}],"SCHISMATIC":[{"def":"Of or pertaining to schism; implying schism; partaking of the nature of schism; tending to schism; as, schismatic opinions or proposals.","pos":""}],"SCHISMATICAL":[{"def":"Same as Schismatic.","pos":""}],"SCHISMATIZE":[{"def":"To make part in schism; to make a breach of communion in the church.","pos":""}],"SCHISMLESS":[{"def":"Free from schism.","pos":""}],"SCHIST":[{"def":"Any crystalline rock having a foliated structure (see Foliation) and hence admitting of ready division into slabs or slates.","pos":""}],"SCHISTACEOUS":[{"def":"Of a slate color.","pos":""}],"SCHISTIC":[{"def":"Of or pertaining to schist; having the structure of a schist.","pos":""}],"SCHISTOSITY":[{"def":"The quality or state of being schistose.","pos":""}],"SCHIZO-":[{"def":"A combining form denoting division or cleavage; as, schizogenesis, reproduction by fission or cell division.","pos":""}],"SCHIZOCARP":[{"def":"A dry fruit which splits at maturity into several closed one- seeded portions.","pos":""}],"SCHIZOCOELE":[{"def":"See Enterocoele.","pos":""}],"SCHIZOCOELOUS":[{"def":"Pertaining to, or of the nature of, a schizocoele.","pos":""}],"SCHIZOGENESIS":[{"def":"reproduction by fission.","pos":""}],"SCHIZOGNATH":[{"def":"Any bird with a schizognathous palate.","pos":""}],"SCHIZOGNATHAE":[{"def":"The schizognathous birds.","pos":""}],"SCHIZOGNATHISM":[{"def":"the condition of having a schizognathous palate.","pos":""}],"SCHIZOGNATHOUS":[{"def":"Having the maxillo-palatine bones separate from each other and from the vomer, which is pointed in front, as in the gulls, snipes, grouse, and many other birds.","pos":""}],"SCHIZOMYCETES":[{"def":"An order of Schizophyta, including the so-called fission fungi, or bacteria.","pos":""}],"SCHIZONEMERTEA":[{"def":"A group of nemerteans comprising those having a deep slit along each side of the head.","pos":""}],"SCHIZONT":[{"def":"In certain Sporozoa, a cell formed by the growth of a sporozoite or merozoite (in a cell or corpuscle of the host) which segment by superficial cleavage, without encystment or conjugation, into merozoites.","pos":""}],"SCHIZOPELMOUS":[{"def":"Having the two flexor tendons of the toes entirely separate, and the flexor hallicus going to the first toe only.","pos":""}],"SCHIZOPHYTE":[{"def":"One of a class of vegetable organisms, in the classification of Cohn, which includes all of the inferior forms that multiply by fission, whether they contain chlorophyll or not.","pos":""}],"SCHIZOPOD":[{"def":"one of the Schizopoda.","pos":""},{"def":"Of or pertaining to a schizopod, or the Schizopoda.","pos":""}],"SCHIZOPODA":[{"def":"A division of shrimplike Thoracostraca in which each of the thoracic legs has a long fringed upper branch (exopodite) for swimming.","pos":""}],"SCHIZORHINAL":[{"def":"Having the nasal bones separate.","pos":""},{"def":"Having the anterior nostrils prolonged backward in the form of a slit.","pos":""}],"SCHLICH":[{"def":"The finer portion of a crushed ore, as of gold, lead, or tin, separated by the water in certain wet processes.","pos":""}],"SCHMELZE":[{"def":"A kind of glass of a red or ruby color, made in Bohemia.","pos":""}],"SCHNEIDERIAN":[{"def":"Discovered or described by C.","pos":""}],"SCHNORRER":[{"def":"Among the Jews, a beggar.","pos":""}],"SCHOHARIE GRIT":[{"def":"The formation belonging to the middle of the three subdivisions of the Corniferous period in the American Devonian system; -- so called from Schoharie, in New York, where it occurs.","pos":""}],"SCHOLAR":[{"def":"One who attends a school; one who learns of a teacher; one under the tuition of a preceptor; a pupil; a disciple; a learner; a student.","pos":""},{"def":"One engaged in the pursuits of learning; a learned person; one versed in many branches, of knowledge; a person of high literary or scientific attainments; a savant.","pos":""}],"SCHOLARLY":[{"def":"Like a scholar, or learned person; showing the qualities of a scholar; as, a scholarly essay or critique.","pos":""},{"def":"In a scholarly manner.","pos":""}],"SCHOLARSHIP":[{"def":"The character and qualities of a scholar; attainments in science or literature; erudition; learning.","pos":""},{"def":"Literary education.","pos":""}],"SCHOLASTIC":[{"def":"Pertaining to, or suiting, a scholar, a school, or schools; scholarlike; as, scholastic manners or pride; scholastic learning.","pos":""},{"def":"Of or pertaining to the schoolmen and divines of the Middle Ages (see Schoolman); as, scholastic divinity or theology; scholastic philosophy.","pos":""}],"SCHOLASTICALLY":[{"def":"In a scholastic manner.","pos":""}],"SCHOLASTICISM":[{"def":"The method or subtitles the schools of philosophy; scholastic formality; scholastic doctrines or philosophy.","pos":""}],"SCHOLIAST":[{"def":"A maker of scholia; a commentator or annotator.","pos":""}],"SCHOLIASTIC":[{"def":"Of or pertaining to a scholiast, or his pursuits.","pos":""}],"SCHOLIAZE":[{"def":"To write scholia.","pos":""}],"SCHOLION":[{"def":"A judgment which follows immediately from another is sometimes called a corollary, or consectary .","pos":""}],"SCHOLIUM":[{"def":"Marginal anotation; an explanatory remark or comment; specifically, an explanatory comment on the text of a classic author by an early grammarian.","pos":""},{"def":"A remark or observation subjoined to a demonstration or a train of reasoning.","pos":""}],"SCHOLY":[{"def":"To write scholia; to annotate.","pos":""}],"SCHOOL":[{"def":"A shoal; a multitude; as, a school of fish.","pos":""}],"SCHOOL-TEACHER":[{"def":"One who teaches or instructs a school.","pos":""}],"SCHOOLBOOK":[{"def":"A book used in schools for learning lessons.","pos":""}],"SCHOOLBOY":[{"def":"A boy belonging to, or attending, a school.","pos":""}],"SCHOOLDAME":[{"def":"A schoolmistress.","pos":""}],"SCHOOLERY":[{"def":"Something taught; precepts; schooling.","pos":""}],"SCHOOLFELLOW":[{"def":"One bred at the same school; an associate in school.","pos":""}],"SCHOOLGIRL":[{"def":"A girl belonging to, or attending, a school.","pos":""}],"SCHOOLHOUSE":[{"def":"A house appropriated for the use of a school or schools, or for instruction.","pos":""}],"SCHOOLING":[{"def":"Instruction in school; tuition; education in an institution of learning; act of teaching.","pos":""},{"def":"Discipline; reproof; reprimand; as, he gave his son a good schooling.","pos":""}],"SCHOOLMA'AM":[{"def":"A schoolmistress.","pos":""}],"SCHOOLMAN":[{"def":"One versed in the niceties of academical disputation or of school divinity.","pos":""}],"SCHOOLMASTER":[{"def":"The man who presides over and teaches a school; a male teacher of a school.","pos":""},{"def":"One who, or that which, disciplines and directs.","pos":""}],"SCHOOLMATE":[{"def":"A pupil who attends the same school as another.","pos":""}],"SCHOOLMISTRESS":[{"def":"A woman who governs and teaches a school; a female school- teacher.","pos":""}],"SCHOOLROOM":[{"def":"A room in which pupils are taught.","pos":""}],"SCHOOLSHIP":[{"def":"A vessel employed as a nautical training school, in which naval apprentices receive their education at the expense of the state, and are trained for service as sailors.","pos":""}],"SCHOONER":[{"def":"Originally, a small, sharp-built vessel, with two topsails on one or both masts and was called a topsail schooner.","pos":""}],"SCHORL":[{"def":"Black tourmaline.","pos":""}],"SCHORLACEOUS":[{"def":"Partaking of the nature and character of schorl; resembling schorl.","pos":""}],"SCHORLY":[{"def":"Pertaining to, or containing, schorl; as, schorly granite.","pos":""},{"def":"A Scotch round dance in 2-4 time, similar to the polka, only slower; also, the music for such a dance; -- not to be confounded with the Écossaise.","pos":""}],"SCHREIBERSITE":[{"def":"A mineral occurring in steel-gray flexible folia.","pos":""}],"SCHWANN'S WHITE SUBSTANCE":[{"def":"The substance of the medullary sheath.","pos":""}],"SCHWANPAN":[{"def":"SCHWEITZERKASE; SCHWEITZERKAESE Schweit\"zer*kä\"se, n.","pos":""}]}