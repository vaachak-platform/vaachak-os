{"CIT":[{"def":"A citizen; an inhabitant of a city; a pert townsman; -- used contemptuously.","pos":""}],"CITABLE":[{"def":"Capable of being cited.","pos":""}],"CITADEL":[{"def":"A fortress in or near a fortified city, commanding the city and fortifications, and intended as a final point of defense.","pos":""}],"CITAL":[{"def":"Summons to appear, as before a judge.","pos":""},{"def":"Citation; quotation [R.","pos":""}],"CITATION":[{"def":"A reference to decided cases, or books of authority, to prove a point in law.","pos":""}],"CITATORY":[{"def":"Having the power or form of a citation; as, letters citatory.","pos":""}],"CITE":[{"def":"To notify of a proceeding in court.","pos":""}],"CITESS":[{"def":"A city woman [R.","pos":""}],"CITHARA":[{"def":"An ancient instrument resembling the harp.","pos":""}],"CITHARISTIC":[{"def":"Pertaining, or adapted, to the cithara.","pos":""}],"CITICISM":[{"def":"The manners of a cit or citizen.","pos":""}],"CITIED":[{"def":"Belonging to, or resembling, a city.","pos":""},{"def":"Containing, or covered with, cities.","pos":""}],"CITIFIED":[{"def":"Aping, or having, the manners of a city.","pos":""}],"CITIGRADAE":[{"def":"A suborder of Arachnoidea, including the European tarantula and the wolf spiders (Lycosidae) and their allies, which capture their prey by rapidly running and jumping.","pos":""}],"CITIGRADE":[{"def":"Pertaining to the Citigradæ.","pos":""},{"def":"One of the Citigradæ.","pos":""}],"CITINER":[{"def":"One who is born or bred in a city; a citizen.","pos":""}],"CITIZEN":[{"def":"One who enjoys the freedom and privileges of a city; a freeman of a city, as distinguished from a foreigner, or one not entitled to its franchises.","pos":""},{"def":"An inhabitant of a city; a townsman.","pos":""}],"CITIZENESS":[{"def":"A female citizen.","pos":""}],"CITIZENSHIP":[{"def":"The state of being a citizen; the status of a citizen.","pos":""}],"CITOLE":[{"def":"A musical instrument; a kind of dulcimer.","pos":""}],"CITRACONIC":[{"def":"Pertaining to, derived from, or having certain characteristics of, citric and aconitic acids.","pos":""}],"CITRANGE":[{"def":"A citrous fruit produced by a cross between the sweet orange and the trifoliate orange (Citrus trifoliata).","pos":""}],"CITRATE":[{"def":"A salt of citric acid.","pos":""}],"CITRIC":[{"def":"Of, pertaining to, or derived from, the citron or lemon; as, citric acid.","pos":""}],"CITRINATION":[{"def":"The process by which anything becomes of the color of a lemon; esp.","pos":""}],"CITRINE":[{"def":"Like a citron or lemon; of a lemon color; greenish yellow.","pos":""}],"CITRON":[{"def":"A fruit resembling a lemon, but larger, and pleasantly aromatic.","pos":""}],"CITRUS":[{"def":"A genus of trees including the orange, lemon, citron, etc.","pos":""}],"CITTERN":[{"def":"An instrument shaped like a lute, but strung with wire and played with a quill or plectrum.","pos":""}],"CITTERN-HEAD":[{"def":"Blockhead; dunce; -- so called because the handle of a cittern usually ended with a carved head.","pos":""}],"CITY":[{"def":"A city is a town incorporated; which is, or has been, the see of a bishop; and though the bishopric has been dissolved, as at Westminster, it yet remaineth a city.","pos":""}]}