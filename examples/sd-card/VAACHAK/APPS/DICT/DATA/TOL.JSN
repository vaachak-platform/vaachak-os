{"TOLA":[{"def":"A weight of British India.","pos":""}],"TOLANE":[{"def":"A hydrocarbon, C14H10, related both to the acetylene and the aromatic series, and produced artificially as a white crystalline substance; -- called also diphenyl acetylene.","pos":""}],"TOLE":[{"def":"To draw, or cause to follow, by displaying something pleasing or desirable; to allure by some bait.","pos":""}],"TOLEDO":[{"def":"A sword or sword blade made at Toledo in Spain, which city was famous in the 16th and 17th centuries for the excellence of its weapons.","pos":""}],"TOLERABILITY":[{"def":"The quality or state of being tolerable.","pos":""}],"TOLERABLE":[{"def":"Capable of being borne or endured; supportable, either physically or mentally.","pos":""},{"def":"Moderately good or agreeable; not contemptible; not very excellent or pleasing, but such as can be borne or received without disgust, resentment, or opposition; passable; as, a tolerable administration; a tolerable entertainment; a tolerable translation.","pos":""}],"TOLERANCE":[{"def":"The power possessed or acquired by some persons of bearing doses of medicine which in ordinary cases would prove injurious or fatal.","pos":""}],"TOLERANT":[{"def":"Inclined to tolerate; favoring toleration; forbearing; ingulgent.","pos":""}],"TOLERATE":[{"def":"To suffer to be, or to be done, without prohibition or hindrance; to allow or permit negatively, by not preventing; not to restrain; to put up with; as, to tolerate doubtful practices.","pos":""}],"TOLERATION":[{"def":"The act of tolerating; the allowance of that which is not wholly approved.","pos":""},{"def":"Specifically, the allowance of religious opinions and modes of worship in a state when contrary to, or different from, those of the established church or belief.","pos":""}],"TOLL":[{"def":"To take away; to vacate; to annul.","pos":""}],"TOLLABLE":[{"def":"Subject to the payment of toll; as, tollable goods.","pos":""}],"TOLLAGE":[{"def":"Payment of toll; also, the amount or quantity paid as toll.","pos":""}],"TOLLBOOTH":[{"def":"A place where goods are weighed to ascertain the duties or toll.","pos":""},{"def":"In Scotland, a burgh jail; hence, any prison, especially a town jail.","pos":""}],"TOLLER":[{"def":"A toll gatherer.","pos":""}],"TOLLETANE":[{"def":"Of or pertaining to Toledo in Spain; made in Toledo.","pos":""}],"TOLLGATE":[{"def":"A gate where toll is taken.","pos":""}],"TOLLHOUSE":[{"def":"A house occupied by a receiver of tolls.","pos":""}],"TOLLMAN":[{"def":"One who receives or collects toll; a toll gatherer.","pos":""}],"TOLSESTER":[{"def":"A toll or tribute of a sextary of ale, paid to the lords of some manors by their tenants, for liberty to brew and sell ale.","pos":""}],"TOLSEY":[{"def":"A tollbooth; also, a merchants' meeting place, or exchange.","pos":""},{"def":"Of or pertaining to Tolstoy (1828-1910).","pos":""}],"TOLT":[{"def":"A writ by which a cause pending in a court baron was removed into a country court.","pos":""}],"TOLTEC":[{"def":"One of a race which formerly occupied Mexico.","pos":""}],"TOLU":[{"def":"A fragrant balsam said to have been first brought from Santiago de Tolu, in New Granada.","pos":""}],"TOLUATE":[{"def":"A salt of any one of the toluic acids.","pos":""}],"TOLUENE":[{"def":"A hydrocarbon, C6H5.","pos":""}],"TOLUIC":[{"def":"Pertaining to, or designating, one of three metameric acids, CH3.","pos":""}],"TOLUID":[{"def":"A complex double tolyl and toluidine derivative of glycocoll, obtained as a white crystalline substance.","pos":""}],"TOLUIDINE":[{"def":"Any one of three metameric amido derivatives of toluene analogous to aniline, and called respectively orthtoluidine, metatoluidine, and paratoluidine; especially, the commonest one, or paratoluidine, which is obtained as a white crystalline substance.","pos":""},{"def":"Same as Toluene.","pos":""}],"TOLURIC":[{"def":"Of, pertaining to, or designating, any one of three isomeric crystalline acids, C9H10ON.","pos":""}],"TOLUTATION":[{"def":"A pacing or ambling.","pos":""}],"TOLUYL":[{"def":"Any one of the three hypothetical radicals corresponding to the three toluic acids.","pos":""}],"TOLYL":[{"def":"The hydrocarbon radical, CH3.","pos":""}],"TOLYLENE":[{"def":"A hydrocarbon radical, C6H4.","pos":""}]}