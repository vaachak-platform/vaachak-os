{"CLUB":[{"def":"Any card of the suit of cards having a figure like the trefoil or clover leaf.","pos":""}],"CLUB-RUSH":[{"def":"A rushlike plant, the reed mace or cat-tail, or some species of the genus Scirpus.","pos":""}],"CLUB-SHAPED":[{"def":"Enlarged gradually at the end, as the antennæ of certain insects.","pos":""}],"CLUBBABLE":[{"def":"Suitable for membership in a club; sociable.","pos":""}],"CLUBBED":[{"def":"Shaped like a club; grasped like, or used as, a club.","pos":""}],"CLUBBER":[{"def":"A member of a club.","pos":""}],"CLUBBISH":[{"def":"Disposed to club together; as, a clubbish set.","pos":""}],"CLUBBIST":[{"def":"A member of a club; a frequenter of clubs.","pos":""}],"CLUBFIST":[{"def":"A large, heavy fist.","pos":""},{"def":"A coarse, brutal fellow.","pos":""}],"CLUBFISTED":[{"def":"Having a large fist.","pos":""}],"CLUBFOOT":[{"def":"A short, variously distorted foot; also, the deformity, usually congenital, which such a foot exhibits; talipes.","pos":""}],"CLUBFOOTED":[{"def":"Having a clubfoot.","pos":""}],"CLUBHAND":[{"def":"A short, distorted hand; also, the deformity of having such a hand.","pos":""}],"CLUBHAUL":[{"def":"To put on the other tack by dropping the lee anchor as soon as the wind is out of the sails (which brings the vessel's head to the wind), and by cutting the cable as soon as she pays off on the other tack.","pos":""}],"CLUBHOUSE":[{"def":"A house occupied by a club.","pos":""}],"CLUBROOM":[{"def":"The apartment in which a club meets.","pos":""}],"CLUCK":[{"def":"To make the noise, or utter the call, of a brooding hen.","pos":""}],"CLUCKING":[{"def":"The noise or call of a brooding hen.","pos":""}],"CLUE":[{"def":"A ball of thread; a thread or other means of guidance.","pos":""}],"CLUMBER":[{"def":"A kind of field spaniel, with short legs and stout body, which, unlike other spaniels, hunts silently.","pos":""}],"CLUMP":[{"def":"An unshaped piece or mass of wood or other substance.","pos":""},{"def":"A cluster; a group; a thicket.","pos":""}],"CLUMPER":[{"def":"To form into clumps or masses.","pos":""}],"CLUMPS":[{"def":"A game in which questions are asked for the purpose of enabling the questioners to discover a word or thing previously selected by two persons who answer the questions; -- so called because the players take sides in two \"clumps\" or groups, the \"clump\" which guesses the word winning the game.","pos":""}],"CLUMPY":[{"def":"Composed of clumps; massive; shapeless.","pos":""}],"CLUMSILY":[{"def":"In a clumsy manner; awkwardly; as, to walk clumsily.","pos":""}],"CLUMSINESS":[{"def":"The quality of being clusy.","pos":""}],"CLUMSY":[{"def":"Stiff or benumbed, as with cold.","pos":""},{"def":"Without skill or grace; wanting dexterity, nimbleness, or readiness; stiff; awkward, as if benumbed; unwieldy; unhandy; hence; ill-made, misshapen, or inappropriate; as, a clumsy person; a clumsy workman; clumsy fingers; a clumsy gesture; a clumsy excuse.","pos":""}],"CLUNCH":[{"def":"One of the hard beds of the lower chalk.","pos":""}],"CLUNG":[{"def":"Wasted away; shrunken.","pos":""}],"CLUNIAC":[{"def":"A monk of the reformed branch of the Benedictine Order, founded in 912 at Cluny (or Clugny) in France.","pos":""}],"CLUPEOID":[{"def":"Of or pertaining to the Herring family.","pos":""}],"CLUSTER":[{"def":"A number of things of the same kind growing together; a bunch.","pos":""},{"def":"A number of similar things collected together or lying contiguous; a group; as, a cluster of islands.","pos":""}],"CLUSTERY":[{"def":"Growing in, or full of, clusters; like clusters.","pos":""}],"CLUTCH":[{"def":"The hands, claws, or talons, in the act of grasping firmly; -- often figuratively, for power, rapacity, or cruelty; as, to fall into the clutches of an adversary.","pos":""},{"def":"A device which is used for coupling shafting, etc.","pos":""}],"CLUTTER":[{"def":"A confused collection; hence, confusion; disorder; as, the room is in a clutter.","pos":""},{"def":"Clatter; confused noise.","pos":""}]}