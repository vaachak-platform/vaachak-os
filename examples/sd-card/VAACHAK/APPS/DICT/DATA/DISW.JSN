{"DISWARN":[{"def":"To dissuade from by previous warning.","pos":""}],"DISWITTED":[{"def":"Deprived of wits or understanding; distracted.","pos":""}],"DISWONT":[{"def":"To deprive of wonted usage; to disaccustom.","pos":""}],"DISWORKMANSHIP":[{"def":"Bad workmanship.","pos":""}],"DISWORSHIP":[{"def":"To refuse to worship; to treat as unworthy.","pos":""}],"DISWORTH":[{"def":"To deprive of worth; to degrade.","pos":""}]}