{"CLAM":[{"def":"A bivalve mollusk of many kinds, especially those that are edible; as, the long clam (Mya arenaria), the quahog or round clam (Venus mercenaria), the sea clam or hen clam (Spisula solidissima), and other species of the United States.","pos":""},{"def":"Strong pinchers or forceps.","pos":""}],"CLAMANT":[{"def":"Crying earnestly, beseeching clamorousky.","pos":""}],"CLAMATION":[{"def":"The act of crying out.","pos":""}],"CLAMATORES":[{"def":"A division of passerine birds in which the vocal muscles are but little developed, so that they lack the power of singing.","pos":""}],"CLAMATORIAL":[{"def":"Like or pertaining to the Clamatores.","pos":""}],"CLAMBAKE":[{"def":"The backing or steaming of clams on heated stones, between layers of seaweed; hence, a picnic party, gathered on such an occasion.","pos":""}],"CLAMBER":[{"def":"To climb with difficulty, or with hands and feet; -- also used figuratively.","pos":""}],"CLAMJAMPHRIE":[{"def":"Low, worthless people; the rabble.","pos":""}],"CLAMMILY":[{"def":"In a clammy manner.","pos":""}],"CLAMMINESS":[{"def":"State of being clammy or viscous.","pos":""}],"CLAMMY":[{"def":"Having the quality of being viscous or adhesive; soft and sticky; glutinous; damp and adhesive, as if covered with a cold perspiration.","pos":""}],"CLAMOR":[{"def":"A great outcry or vociferation; loud and continued shouting or exclamation.","pos":""},{"def":"Any loud and continued noise.","pos":""}],"CLAMORER":[{"def":"One who clamors.","pos":""}],"CLAMOROUS":[{"def":"Speaking and repeating loud words; full of clamor; calling or demanding loudly or urgently; vociferous; noisy; bawling; loud; turbulent.","pos":""}],"CLAMP":[{"def":"A thick plank on the inner part of a ship's side, used to sustuan the ends of beams.","pos":""}],"CLAMPER":[{"def":"An instrument of iron, with sharp prongs, attached to a boot or shoe to enable the wearer to walk securely upon ice; a creeper.","pos":""}]}