{"ASSOBER":[{"def":"To make or keep sober.","pos":""}],"ASSOCIABILITY":[{"def":"The quality of being associable, or capable of association; associableness.","pos":""}],"ASSOCIABLE":[{"def":"Liable to be affected by sympathy with other parts; -- said of organs, nerves, muscles, etc.","pos":""}],"ASSOCIABLENESS":[{"def":"As*so\"cia*ble*ness, n.","pos":""}],"ASSOCIATE":[{"def":"To join with one, as a friend, companion, partner, or confederate; as, to associate others with .","pos":""},{"def":"To join or connect; to combine in acting; as, particles of gold associated with other substances.","pos":""}],"ASSOCIATED":[{"def":"Joined as a companion; brought into association; accompanying; combined.","pos":""}],"ASSOCIATESHIP":[{"def":"The state of an associate, as in Academy or an office.","pos":""}],"ASSOCIATION":[{"def":"The act of associating, or state of being associated; union; connection, whether of persons of things.","pos":""},{"def":"Mental connection, or that which is mentally linked or associated with a thing.","pos":""}],"ASSOCIATIONAL":[{"def":"Of or pertaining to association, or to an association.","pos":""},{"def":"Pertaining to the theory held by the associationists.","pos":""}],"ASSOCIATIONISM":[{"def":"The doctrine or theory held by associationists.","pos":""}],"ASSOCIATIONIST":[{"def":"One who explains the higher functions and relations of the soul by the association of ideas; e.","pos":""}],"ASSOCIATIVE":[{"def":"Having the quality of associating; tending or leading to association; as, the associative faculty.","pos":""}],"ASSOCIATOR":[{"def":"An associate; a confederate or partner in any scheme.","pos":""}],"ASSOIL":[{"def":"To set free; to release.","pos":""},{"def":"To solve; to clear up.","pos":""}],"ASSOILMENT":[{"def":"Act of assoiling, or state of being assoiled; absolution; acquittal.","pos":""}],"ASSONANCE":[{"def":"A peculiar species of rhyme, in which the last accented vowel and those which follow it in one word correspond in sound with the vowels of another word, while the consonants of the two words are unlike in sound; as, calamo and platano, baby and chary.","pos":""}],"ASSONANT":[{"def":"Pertaining to the peculiar species of rhyme called assonance; not consonant.","pos":""}],"ASSONATE":[{"def":"To correspond in sound.","pos":""}],"ASSORT":[{"def":"To separate and distribute into classes, as things of a like kind, nature, or quality, or which are suited to a like purpose; to classify; as, to assort goods.","pos":""},{"def":"To furnish with, or make up of, various sorts or a variety of goods; as, to assort a cargo.","pos":""}],"ASSORTED":[{"def":"Selected; culled.","pos":""}],"ASSORTMENT":[{"def":"Act of assorting, or distributing into sorts, kinds, or classes.","pos":""},{"def":"A collection or quantity of things distributed into kinds or sorts; a number of things assorted.","pos":""}],"ASSOT":[{"def":"To besot; to befool; to beguile; to infatuate.","pos":""}]}