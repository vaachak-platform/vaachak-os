{"GENOA CAKE":[{"def":"A rich glazed cake, with almonds, pistachios, filberts, or other nuts; also, a rich currant cake with almonds on the top.","pos":""}],"GENOESE":[{"def":"Of or pertaining to Genoa, a city of Italy.","pos":""},{"def":"A native or inhabitant of Genoa; collectively, the people of Genoa.","pos":""}],"GENOUILLERE":[{"def":"A metal plate covering the knee.","pos":""},{"def":"That part of a parapet which lies between the gun platform and the bottom of an embrasure.","pos":""}]}