{"EXCECATION":[{"def":"The act of making blind.","pos":""}],"EXCEED":[{"def":"To go beyond; to proceed beyond the given or supposed limit or measure of; to outgo; to surpass; -- used both in a good and a bad sense; as, one man exceeds another in bulk, stature, weight, power, skill, etc.","pos":""}],"EXCEEDABLE":[{"def":"Capable of exceeding or surpassing.","pos":""}],"EXCEEDER":[{"def":"One who exceeds.","pos":""}],"EXCEEDING":[{"def":"More than usual; extraordinary; more than sufficient; measureless.","pos":""}],"EXCEEDINGLY":[{"def":"To a very great degree; beyond what is usual; surpassingly.","pos":""}],"EXCEL":[{"def":"To go beyond or surpass in good qualities or laudable deeds; to outdo or outgo, in a good sense.","pos":""},{"def":"To exceed or go beyond; to surpass.","pos":""}],"EXCELLENCE":[{"def":"The quality of being excellent; state of possessing good qualities in an eminent degree; exalted merit; superiority in virtue.","pos":""},{"def":"An excellent or valuable quality; that by which any one excels or is eminent; a virtue.","pos":""}],"EXCELLENCY":[{"def":"Excellence; virtue; dignity; worth; superiority.","pos":""},{"def":"A title of honor given to certain high dignitaries, esp.","pos":""}],"EXCELLENT":[{"def":"Excelling; surpassing others in some good quality or the sum of qualities; of great worth; eminent, in a good sense; superior; as, an excellent man, artist, citizen, husband, discourse, book, song, etc.","pos":""},{"def":"Superior in kind or degree, irrespective of moral quality; -- used with words of a bad significance.","pos":""}],"EXCELLENTLY":[{"def":"In an excellent manner; well in a high degree.","pos":""},{"def":"In a high or superior degree; -- in this literal use, not implying worthiness.","pos":""}],"EXCELSIOR":[{"def":"More lofty; still higher; ever upward.","pos":""}],"EXCENTRAL":[{"def":"Out of the center.","pos":""},{"def":"One-sided; having the normally central portion not in the true center.","pos":""}],"EXCENTRICITY":[{"def":"Ex`cen*tric\"i*ty Defn: .","pos":""}],"EXCEPT":[{"def":"To take or leave out (anything) from a number or a whole as not belonging to it; to exclude; to omit.","pos":""},{"def":"To object to; to protest against.","pos":""}],"EXCEPTANT":[{"def":"Making exception.","pos":""}],"EXCEPTING":[{"def":", but properly a participle.","pos":""}],"EXCEPTION":[{"def":"The act of excepting or excluding; exclusion; restriction by taking out something which would otherwise be included, as in a class, statement, rule.","pos":""},{"def":"That which is excepted or taken out from others; a person, thing, or case, specified as distinct, or not included; as, almost every general rule has its exceptions.","pos":""}],"EXCEPTIONABLE":[{"def":"Liable to exception or objection; objectionable.","pos":""}],"EXCEPTIONAL":[{"def":"Forming an exception; not ordinary; uncommon; rare; hence, better than the average; superior.","pos":""}],"EXCEPTIONER":[{"def":"One who takes exceptions or makes objections.","pos":""}],"EXCEPTIONLESS":[{"def":"Without exception.","pos":""}],"EXCEPTIOUS":[{"def":"Disposed or apt to take exceptions, or to object; captious.","pos":""}],"EXCEPTIVE":[{"def":"That excepts; including an exception; as, an exceptive proposition.","pos":""}],"EXCEPTLESS":[{"def":"Not exceptional; usual.","pos":""}],"EXCEPTOR":[{"def":"One who takes exceptions.","pos":""}],"EXCEREBRATION":[{"def":"The act of removing or beating out the brains.","pos":""}],"EXCERN":[{"def":"To excrete; to throw off through the pores; as, fluids are excerned in perspiration.","pos":""}],"EXCERNENT":[{"def":"Connected with, or pertaining to, excretion.","pos":""}],"EXCERPT":[{"def":"To select; to extract; to cite; to quote.","pos":""}],"EXCERPTION":[{"def":"The act of excerpting or selecting.","pos":""},{"def":"That which is selected or gleaned; an extract.","pos":""}],"EXCERPTIVE":[{"def":"That excerpts, selects, or chooses.","pos":""}],"EXCERPTOR":[{"def":"One who makes excerpts; a picker; a culler.","pos":""}],"EXCESS":[{"def":"The state of surpassing or going beyond limits; the being of a measure beyond sufficiency, necessity, or duty; that which exceeds what is usual or prover; immoderateness; superfluity; superabundance; extravagance; as, an excess of provisions or of light.","pos":""},{"def":"An undue indulgence of the appetite; transgression of proper moderation in natural gratifications; intemperance; dissipation.","pos":""}],"EXCESSIVE":[{"def":"Characterized by, or exhibiting, excess; overmuch.","pos":""}]}