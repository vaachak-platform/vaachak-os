{"OBVENTION":[{"def":"The act of happening incidentally; that which happens casually; an incidental advantage; an occasional offering.","pos":""}],"OBVERSANT":[{"def":"Conversant; familiar.","pos":""}],"OBVERSE":[{"def":"Having the base, or end next the attachment, narrower than the top, as a leaf.","pos":""}],"OBVERSELY":[{"def":"In an obverse manner.","pos":""}],"OBVERSION":[{"def":"The act of immediate inference, by which we deny the opposite of anything which has been affirmed; as, all men are mortal; then, by obversion, no men are immortal.","pos":""}],"OBVERT":[{"def":"If its base be obverted towards us.","pos":""}],"OBVIATE":[{"def":"To meet in the way.","pos":""},{"def":"To anticipate; to prevent by interception; to remove from the way or path; to make unnecessary; as, to obviate the necessity of going.","pos":""}],"OBVIATION":[{"def":"The act of obviating, or the state of being obviated.","pos":""}],"OBVIOUS":[{"def":"Overlapping; contorted; convolute; -- applied primarily, in botany, to two opposite leaves, each of which has one edge overlapping the nearest edge of the other, and secondarily to a circle of several leaves or petals which thus overlap.","pos":""}]}