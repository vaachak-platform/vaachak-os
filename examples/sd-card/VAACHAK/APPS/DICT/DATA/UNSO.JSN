{"UNSOCIABILITY":[{"def":"The quality or state of being unsociable; unsociableness.","pos":""}],"UNSOCIABLE":[{"def":"Not sociable; not inclined to society; averse to companionship or conversation; solitary; reserved; as, an unsociable person or temper.","pos":""}],"UNSOCKET":[{"def":"To loose or take from a socket.","pos":""}],"UNSOFT":[{"def":"Not soft; hard; coarse; rough.","pos":""}],"UNSOLDER":[{"def":"To separate or disunite, as what has been soldered; hence, to divide; to sunder.","pos":""}],"UNSOLDIERED":[{"def":"Not equipped like a soldier; unsoldierlike.","pos":""}],"UNSOLEMNIZE":[{"def":"To divest of solemnity.","pos":""}],"UNSONABLE":[{"def":"Incapable of being sounded.","pos":""}],"UNSONSY":[{"def":"Not soncy (sonsy); not fortunate.","pos":""}],"UNSOOT":[{"def":"Not sophisticated; pure; innocent; genuine.","pos":""}],"UNSORROWED":[{"def":"Not sorrowed for; unlamented.","pos":""}],"UNSORTED":[{"def":"Not sorted; not classified; as, a lot of unsorted goods.","pos":""},{"def":"Not well selected; ill-chosen.","pos":""}],"UNSOUL":[{"def":"To deprive of soul, spirit, or principle.","pos":""}],"UNSOUND":[{"def":"Not sound; not whole; not solid; defective; infirm; diseased.","pos":""}]}