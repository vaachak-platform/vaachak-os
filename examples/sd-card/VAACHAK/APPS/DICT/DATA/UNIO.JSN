{"UNIO":[{"def":"Any one of numerous species of fresh-water mussels belonging to Unio and many allied genera.","pos":""}],"UNIOCULAR":[{"def":"Of, pertaining to, or seated in, one eye; monocular.","pos":""}],"UNION":[{"def":"A joint or other connection uniting parts of machinery, or the like, as the elastic pipe of a tender connecting it with the feed pipe of a locomotive engine; especially, a pipe fitting for connecting pipes, or pipes and fittings, in such a way as to facilitate disconnection.","pos":""},{"def":"A cask suspended on trunnions, in which fermentation is carried on.","pos":""}],"UNIONISM":[{"def":"The sentiment of attachment to a federal union, especially to the federal union of the United States.","pos":""},{"def":"The principles, or the system, of combination among workmen engaged in the same occupation or trade.","pos":""}],"UNIONIST":[{"def":"One who advocates or promotes union; especially a loyal supporter of a federal union, as that of the United States.","pos":""},{"def":"A member or supporter of a trades union.","pos":""}],"UNIONISTIC":[{"def":"Of or pertaining to union or unionists; tending to promote or preserve union.","pos":""}],"UNIOVULATE":[{"def":"Containing but one ovule.","pos":""}]}