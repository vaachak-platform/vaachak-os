{"EXTILL":[{"def":"To drop or distill.","pos":""}],"EXTILLATION":[{"def":"An exudation or extillation of petrifying juices.","pos":""}],"EXTIMULATION":[{"def":"Things insipid, and without any extimulation.","pos":""}],"EXTINCT":[{"def":"Extinguished; put out; quenched; as, a fire, a light, or a lamp, is extinct; an extinct volcano.","pos":""},{"def":"Without a survivor; without force; dead; as, a family becomes extinct; an extinct feud or law.","pos":""}],"EXTINCTION":[{"def":"The act of extinguishing or making extinct; a putting an end to; the act of putting out or destroying light, fire, life, activity, influence, etc.","pos":""},{"def":"State of being extinguished or of ceasing to be; destruction; suppression; as, the extinction of life, of a family, of a quarrel, of claim.","pos":""}],"EXTINE":[{"def":"The outer membrane of the grains of pollen of flowering plants.","pos":""}],"EXTINGUISH":[{"def":"To quench; to put out, as a light or fire; to stifle; to cause to die out; to put an end to; to destroy; as, to extinguish a flame, or life, or love, or hope, a pretense or a right.","pos":""},{"def":"To obscure; to eclipse, as by superior splendor.","pos":""}],"EXTINGUISHABLE":[{"def":"Capable of being quenched, destroyed, or suppressed.","pos":""}],"EXTINGUISHER":[{"def":"One who, or that which, extinguishes; esp.","pos":""}],"EXTINGUISHMENT":[{"def":"The annihilation or extinction of a right or obligation.","pos":""}],"EXTIRP":[{"def":"It is impossible to extirp it quite, friar.","pos":""}],"EXTIRPABLE":[{"def":"Capable of being extirpated or eradicated; as, an extirpable plant.","pos":""}],"EXTIRPATE":[{"def":"To pluck up by the stem or root; to root out; to eradicate, literally or figuratively; to destroy wholly; as, to extirpate weeds; to extirpate a tumor; to extirpate a sect; to extirpate error or heresy.","pos":""}],"EXTIRPATION":[{"def":"The act of extirpating or rooting out, or the state of being extirpated; eradication; excision; total destruction; as, the extirpation of weeds from land, of evil from the heart, of a race of men, of heresy.","pos":""}],"EXTIRPATIVE":[{"def":"Capable of rooting out, or tending to root out.","pos":""}],"EXTIRPATOR":[{"def":"One who extirpates or roots out; a destroyer.","pos":""}],"EXTISPICIOUS":[{"def":"Relating to the inspection of entrails for prognostication.","pos":""}]}