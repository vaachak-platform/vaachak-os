{"PARNASSIA":[{"def":"A genus of herbs growing in wet places, and having white flowers; grass of Parnassus.","pos":""}],"PARNASSIAN":[{"def":"Of or pertaining to Parnassus.","pos":""}],"PARNASSIEN":[{"def":"Same as Parnassian.","pos":""}],"PARNASSUS":[{"def":"A mountain in Greece, sacred to Apollo and the Muses, and famous for a temple of Apollo and for the Castalian spring.","pos":""}],"PARNELLISM":[{"def":"The policy or principles of the Parnellites.","pos":""}],"PARNELLITE":[{"def":"One of the adherents of Charles Stewart Parnell (1846-91) in his advocacy of home rule for Ireland.","pos":""}]}