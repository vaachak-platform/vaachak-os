{"CREED":[{"def":"A definite summary of what is believed; esp.","pos":""},{"def":"Any summary of principles or opinions professed or adhered to.","pos":""}],"CREEDLESS":[{"def":"Without a creed.","pos":""}],"CREEK":[{"def":"A small inlet or bay, narrower and extending further into the land than a cove; a recess in the shore of the sea, or of a river.","pos":""},{"def":"A stream of water smaller than a river and larger than a brook.","pos":""}],"CREEKFISH":[{"def":"The chub sucker.","pos":""}],"CREEKS":[{"def":"A tribe or confederacy of North American Indians, including the Muskogees, Seminoles, Uchees, and other subordinate tribes.","pos":""}],"CREEKY":[{"def":"Containing, or abounding in, creeks; characterized by creeks; like a creek; winding.","pos":""}],"CREEL":[{"def":"A bar or set of bars with skewers for holding paying-off bobbins, as in the roving machine, throstle, and mule.","pos":""}],"CREEP":[{"def":"To move along the ground, or on any other surface, on the belly, as a worm or reptile; to move as a child on the hands and knees; to crawl.","pos":""},{"def":"To move slowly, feebly, or timorously, as from unwillingness, fear, or weakness.","pos":""}],"CREEPER":[{"def":"A plant that clings by rootlets, or by tendrils, to the ground, or to trees, etc.","pos":""},{"def":"A small bird of the genus Certhia, allied to the wrens.","pos":""}],"CREEPHOLE":[{"def":"A hole or retreat onto which an animal may creep, to escape notice or danger.","pos":""},{"def":"A subterfuge; an excuse.","pos":""}],"CREEPINESS":[{"def":"An uneasy sensation as of insects creeping on the skin.","pos":""}],"CREEPING":[{"def":"Crawling, or moving close to the ground.","pos":""},{"def":"Growing along, and clinging to, the ground, or to a wall, etc.","pos":""}],"CREEPING CHARLIE":[{"def":"The stonecrop (Sedum acre).","pos":""}],"CREEPINGLY":[{"def":"by creeping slowly; in the manner of a reptile; insidiously; cunningly.","pos":""}],"CREEPLE":[{"def":"A creeping creature; a reptile.","pos":""},{"def":"One who is lame; a cripple.","pos":""}],"CREEPY":[{"def":"Crawly; having or producing a sensation like that caused by insects creeping on the skin.","pos":""}],"CREES":[{"def":"An Algonquin tribe of Indians, inhabiting a large part of British America east of the Rocky Mountains and south of Hudson's Bay.","pos":""}],"CREESE":[{"def":"A dagger or short sword used by the Malays, commonly having a serpentine blade.","pos":""}]}