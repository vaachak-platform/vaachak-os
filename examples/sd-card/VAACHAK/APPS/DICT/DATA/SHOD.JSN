{"SHODDY":[{"def":"A fibrous material obtained by \"deviling,\" or tearing into fibers, refuse woolen goods, old stockings, rags, druggets, etc.","pos":""},{"def":"A fabric of inferior quality made of, or containing a large amount of, shoddy.","pos":""}],"SHODDY FEVER":[{"def":"A febrile disease characterized by dyspnoa and bronchitis caused by inhaling dust.","pos":""}],"SHODDYISM":[{"def":"The quality or state of being shoddy.","pos":""}],"SHODE":[{"def":"See Shoad, Shoading.","pos":""}],"SHODER":[{"def":"A package of gold beater's skins in which gold is subjected to the second process of beating.","pos":""}]}