{"CIMA":[{"def":"A kind of molding.","pos":""}],"CIMBAL":[{"def":"A kind of confectionery or cake.","pos":""}],"CIMBIA":[{"def":"A fillet or band placed around the shaft of a column as if to strengthen it.","pos":""}],"CIMBRIAN":[{"def":"Of or pertaining to the Cimbri.","pos":""},{"def":"One of the Cimbri.","pos":""}],"CIMBRIC":[{"def":"Pertaining to the Cimbri, an ancient tribe inhabiting Northern Germany.","pos":""},{"def":"The language of the Cimbri.","pos":""}],"CIMELIARCH":[{"def":"A superintendent or keeper of a church's valuables; a churchwarden.","pos":""}],"CIMEX":[{"def":"A genus of hemipterous insects of which the bedbug is the best known example.","pos":""}],"CIMMERIAN":[{"def":"Pertaining to the Cimmerii, a fabulous people, said to have lived, in very ancient times, in profound and perpetual darkness.","pos":""},{"def":"Without any light; intensely dark.","pos":""}],"CIMOLITE":[{"def":"A soft, earthy, clayey mineral, of whitish or grayish color.","pos":""}]}