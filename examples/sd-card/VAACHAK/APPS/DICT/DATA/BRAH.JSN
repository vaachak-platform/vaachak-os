{"BRAHMA":[{"def":"The One First Cause; also, one of the triad of Hindoo gods.","pos":""},{"def":"A valuable variety of large, domestic fowl, peculiar in having the comb divided lengthwise into three parts, and the legs well feathered.","pos":""}],"BRAHMANI":[{"def":"Any Brahman woman.","pos":""}],"BRAHMIN-ICAL":[{"def":"Of or pertaining to the Brahmans or to their doctrines and worship.","pos":""},{"def":"The religion or system of doctrines of the Brahmans; the religion of Brahma.","pos":""}],"BRAHMO-SOMAJ":[{"def":"A modern reforming theistic sect among the Hindos.","pos":""}],"BRAHMOISM":[{"def":"The religious system of Brahmo-somaj.","pos":""}]}