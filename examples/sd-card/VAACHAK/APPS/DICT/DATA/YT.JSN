{"YT":[{"def":", an old method of printing that (AS.","pos":""},{"def":"an old method of printing that (AS.","pos":""}],"YTTERBIC":[{"def":"Pertaining to, or derived from, ytterbium; containing ytterbium.","pos":""}],"YTTERBIUM":[{"def":"A rare element of the boron group, sometimes associated with yttrium or other related elements, as in euxenite and gadolinite.","pos":""}],"YTTRIA":[{"def":"The oxide, Y2O3, or earth, of yttrium.","pos":""}],"YTTRIC":[{"def":"Pertaining to, derived from, or containing, yttrium.","pos":""}],"YTTRIFEROUS":[{"def":"Bearing or containing yttrium or the allied elements; as, gadolinite is one of the yttriferous minerals.","pos":""}],"YTTRIUM":[{"def":"A rare metallic element of the boron-aluminium group, found in gadolinite and other rare minerals, and extracted as a dark gray powder.","pos":""}],"YTTRO-CERITE":[{"def":"A mineral of a violet-blue color, inclining to gray and white.","pos":""},{"def":"A tantalate of uranium, yttrium, and calcium, of a brown or black color.","pos":""}]}