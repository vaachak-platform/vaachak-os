{"VETCH":[{"def":"Any leguminous plant of the genus Vicia, some species of which are valuable for fodder.","pos":""}],"VETCHLING":[{"def":"Any small leguminous plant of the genus Lathyrus, especially L.","pos":""}],"VETCHY":[{"def":"Consisting of vetches or of pea straw.","pos":""},{"def":"Abounding with vetches.","pos":""}],"VETERAN":[{"def":"Long exercised in anything, especially in military life and the duties of a soldier; long practiced or experienced; as, a veteran officer or soldier; veteran skill.","pos":""}],"VETERANIZE":[{"def":"To reënlist for service as a soldier.","pos":""}],"VETERINARIAN":[{"def":"One skilled in the diseases of cattle or domestic animals; a veterinary surgeon.","pos":""}],"VETERINARY":[{"def":"Of or pertaining to the art of healing or treating the diseases of domestic animals, as oxen, horses, sheep, etc.","pos":""}],"VETIVER":[{"def":"An East Indian grass (Andropogon muricatus); also, its fragrant roots which are much used for making mats and screens.","pos":""}],"VETO":[{"def":"An authoritative prohibition or negative; a forbidding; an interdiction.","pos":""}],"VETOIST":[{"def":"One who uses, or sustains the use of, the veto.","pos":""}],"VETTURA":[{"def":"An Italian four-wheeled carriage, esp.","pos":""}],"VETTURINO":[{"def":"One who lets or drives a vettura.","pos":""}],"VETUST":[{"def":"Venerable from antiquity; ancient; old.","pos":""}]}