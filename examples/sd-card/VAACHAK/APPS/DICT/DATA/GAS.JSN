{"GAS":[{"def":"An aëriform fluid; -- a term used at first by chemists as synonymous with air, but since restricted to fluids supposed to be permanently elastic, as oxygen, hydrogen, etc.","pos":""}],"GAS ENGINE":[{"def":"A kind of internal-combustion engine (which see) using fixed gas; also, broadly, any internal-combustion engine.","pos":""}],"GAS-BURNER":[{"def":"The jet piece of a gas fixture where the gas is burned as it escapes from one or more minute orifices.","pos":""}],"GASALIER":[{"def":"A chandelier arranged to burn gas.","pos":""}],"GASCON":[{"def":"Of or pertaining to Gascony, in France, or to the Gascons; also, braggart; swaggering.","pos":""},{"def":"A native of Gascony; a boaster; a bully.","pos":""}],"GASCONADE":[{"def":"A boast or boasting; a vaunt; a bravado; a bragging; braggodocio.","pos":""}],"GASCONADER":[{"def":"A great boaster; a blusterer.","pos":""}],"GASEITY":[{"def":"State of being gaseous.","pos":""}],"GASELIER":[{"def":"A chandelier arranged to burn gas.","pos":""}],"GASEOUS":[{"def":"In the form, or of the nature, of gas, or of an aëriform fluid.","pos":""},{"def":"Lacking substance or solidity; tenuous.","pos":""}],"GASH":[{"def":"To make a gash, or long, deep incision in; -- applied chiefly to incisions in flesh.","pos":""}],"GASHFUL":[{"def":"Full of gashes; hideous; frightful.","pos":""}],"GASIFICATION":[{"def":"The act or process of converting into gas.","pos":""}],"GASIFORM":[{"def":"Having a form of gas; gaseous.","pos":""}],"GASIFY":[{"def":"To convert into gas, or an aëriform fluid, as by the application of heat, or by chemical processes.","pos":""}],"GASKET":[{"def":"A line or band used to lash a furled sail securely.","pos":""}],"GASKINS":[{"def":"Loose hose or breeches; galligaskins.","pos":"noun"},{"def":"Packing of hemp.","pos":"noun"}],"GASLIGHT":[{"def":"The light yielded by the combustion of illuminating gas.","pos":""},{"def":"A gas jet or burner.","pos":""}],"GASOGEN":[{"def":"An apparatus for the generation of gases, or for impregnating a liquid with a gas, or a gas with a volatile liquid.","pos":""},{"def":"A volatile hydrocarbon, used as an illuminant, or for charging illuminating gas.","pos":""}],"GASOLIER":[{"def":"Same as Gasalier.","pos":""}],"GASOLINE":[{"def":"A highly volatile mixture of fluid hydrocarbons, obtained from petroleum, as also by the distillation of bituminous coal.","pos":""},{"def":"A kind of internal-combustion engine; -- in British countries called usually petrol engine.","pos":""}],"GASOMETER":[{"def":"An apparatus for holding and measuring of gas; in gas works, a huge iron cylinder closed at one end and having the other end immersed in water, in which it is made to rise or fall, according to the volume of gas it contains, or the pressure required.","pos":""},{"def":"Of or pertaining to the measurement of gases; as, gasometric analysis.","pos":""}],"GASOMETRY":[{"def":"The art or practice of measuring gases; also, the science which treats of the nature and properties of these elastic fluids.","pos":""}],"GASOSCOPE":[{"def":"An apparatus for detecting the presence of any dangerous gas, from a gas leak in a coal mine or a dwelling house.","pos":""}],"GASP":[{"def":"To open the mouth wide in catching the breath, or in laborious respiration; to labor for breath; to respire convulsively; to pant violently.","pos":""},{"def":"To pant with eagerness; to show vehement desire.","pos":""}],"GASSERIAN":[{"def":"Relating to Casserio (L.","pos":""}],"GASSING":[{"def":"The process of passing cotton goods between two rollers and exposing them to numerous minute jets of gas to burn off the small fibers; any similar process of singeing.","pos":""}],"GASSY":[{"def":"Full of gas; like gas.","pos":""}],"GAST":[{"def":"To make aghast; to frighten; to terrify.","pos":""}],"GASTEROMYCETES":[{"def":"An order of fungi, in which the spores are borne inside a sac called the peridium, as in the puffballs.","pos":""}],"GASTEROPOD":[{"def":"Same as Gastropod.","pos":""}],"GASTEROPODA":[{"def":"Same as Gastropoda.","pos":""}],"GASTEROPODOUS":[{"def":"Same as Gastropodous.","pos":""},{"def":"See Ghastful, Ghastly.","pos":""}],"GASTIGHT":[{"def":"So tightly fitted as to preclude the escape of gas; impervious to gas.","pos":""}],"GASTORNIS":[{"def":"A genus of large eocene birds from the Paris basin.","pos":""}],"GASTRAEA":[{"def":"A primeval larval form; a double-walled sac from which, according to the hypothesis of Haeckel, man and all other animals, that in the first stages of their individual evolution pass through a two-layered structural stage, or gastrula form, must have descended.","pos":""}],"GASTRALGIA":[{"def":"Pain in the stomach or epigastrium, as in gastric disorders.","pos":""}],"GASTRIC":[{"def":"Of, pertaining to, or situated near, the stomach; as, the gastric artery.","pos":""}],"GASTRILOQUIST":[{"def":"One who appears to speak from his stomach; a ventriloquist.","pos":""}],"GASTRILOQUY":[{"def":"A voice or utterance which appears to proceed from the stomach; ventriloquy.","pos":""}],"GASTRITIS":[{"def":"Inflammation of the stomach, esp.","pos":""}],"GASTRO-":[{"def":"A combining form from the Gr.","pos":""}],"GASTROCNEMIUS":[{"def":"The muscle which makes the greater part of the calf of the leg.","pos":""}],"GASTROCOLIC":[{"def":"Pertaining to both the stomach and the colon; as, the gastrocolic, or great, omentum.","pos":""}],"GASTRODISC":[{"def":"That part of blastoderm where the hypoblast appears like a small disk on the inner face of the epibladst.","pos":""}],"GASTRODUODENAL":[{"def":"Pertaining to the stomach and duodenum; as, the gastroduodenal artery.","pos":""}],"GASTRODUODENITIS":[{"def":"Inflammation of the stomach and duodenum.","pos":""}],"GASTROELYTROTOMY":[{"def":"The operation of cutting into the upper part of the vagina, through the abdomen (without opening the peritoneum), for the purpose of removing a fetus.","pos":""}],"GASTROENTERIC":[{"def":"Gastrointestinal.","pos":""}],"GASTROENTERITIS":[{"def":"Inflammation of the lining membrane of the stomach and the intestines.","pos":""}],"GASTROEPIPLOIC":[{"def":"Of or pertaining to the stomach and omentum.","pos":""}],"GASTROHEPATIC":[{"def":"Pertaining to the stomach and liver; hepatogastric; as, the gastrohepatic, or lesser, omentum.","pos":""}],"GASTROHYSTEROTOMY":[{"def":"Cæsarean section.","pos":""}],"GASTROINTESTINAL":[{"def":"Of or pertaining to the stomach and intestines; gastroenteric.","pos":""}],"GASTROLITH":[{"def":"See Crab's eyes, under Crab.","pos":""}],"GASTROLOGY":[{"def":"The science which treats of the structure and functions of the stomach; a treatise of the stomach.","pos":""}],"GASTROMALACIA":[{"def":"A softening of the coats of the stomach; -- usually a post- morten change.","pos":""}],"GASTROMYCES":[{"def":"The fungoid growths sometimes found in the stomach; such as Torula, etc.","pos":""}],"GASTROMYTH":[{"def":"One whose voice appears to proceed from the stomach; a ventriloquist.","pos":""},{"def":"One fond of good living; an epicure.","pos":""}],"GASTRONOMY":[{"def":"The art or science of good eating; epicurism; the art of good cheer.","pos":""}],"GASTROPHRENIC":[{"def":"Pertaining to the stomach and diaphragm; as, the gastrophrenic ligament.","pos":""}],"GASTROPNEUMATIC":[{"def":"Pertaining to the alimentary canal and air passages, and to the cavities connected with them; as, the gastropneumatic mucuos membranes.","pos":""}],"GASTROPOD":[{"def":"One of the Gastropoda.","pos":""}],"GASTROPODA":[{"def":"One of the classes of Mollusca, of great extent.","pos":""}],"GASTROPODOUS":[{"def":"Of or pertaining to the Gastropoda.","pos":""}],"GASTRORAPHY":[{"def":"The operation of sewing up wounds of the abdomen.","pos":""}],"GASTROSCOPE":[{"def":"An instrument for viewing or examining the interior of the stomach.","pos":""}],"GASTROSCOPIC":[{"def":"Of or pertaining to gastroscopy.","pos":""}],"GASTROSCOPY":[{"def":"Examination of the abdomen or stomach, as with the gastroscope.","pos":""}],"GASTROSPLENIC":[{"def":"Pertaining to the stomach and spleen; as, the gastrosplenic ligament.","pos":""}],"GASTROSTEGE":[{"def":"One of the large scales on the belly of a serpent.","pos":""}],"GASTROSTOMY":[{"def":"The operation of making a permanent opening into the stomach, for the introduction of food.","pos":""}],"GASTROTOMY":[{"def":"A cutting into, or opening of, the abdomen or the stomach.","pos":""}],"GASTROTRICHA":[{"def":"A group of small wormlike animals, having cilia on the ventral side.","pos":""}],"GASTROTROCHA":[{"def":"A form of annelid larva having cilia on the ventral side.","pos":""}],"GASTROVASCULAR":[{"def":"Having the structure, or performing the functions, both of digestive and circulatory organs; as, the gastrovascular cavity of coelenterates.","pos":""}],"GASTRULA":[{"def":"Of or pertaining to a gastrula.","pos":""}],"GASTRULATION":[{"def":"The process of invagination, in embryonic development, by which a gastrula is formed.","pos":""}],"GASTRURA":[{"def":"See Stomatopoda.","pos":""}],"GASTRUROUS":[{"def":"Pertaining to the Gastrura.","pos":""}]}