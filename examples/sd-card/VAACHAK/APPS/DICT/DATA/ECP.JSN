{"ECPHASIS":[{"def":"An explicit declaration.","pos":""}],"ECPHONEMA":[{"def":"A breaking out with some interjectional particle.","pos":""}],"ECPHONEME":[{"def":"A mark (!) used to indicate an exclamation.","pos":""}],"ECPHONESIS":[{"def":"An animated or passionate exclamation.","pos":""}],"ECPHRACTIC":[{"def":"Serving to dissolve or attenuate viscid matter, and so to remove obstructions; deobstruent.","pos":""},{"def":"An ecphractic medicine.","pos":""}]}