{"JADE":[{"def":"A stone, commonly of a pale to dark green color but sometimes whitish.","pos":""}],"JADEITE":[{"def":"See Jade, the stone.","pos":""}],"JADERY":[{"def":"The tricks of a jade.","pos":""}],"JADISH":[{"def":"Vicious; ill-tempered; resembling a jade; -- applied to a horse.","pos":""},{"def":"Unchaste; -- applied to a woman.","pos":""}]}