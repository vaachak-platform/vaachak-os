{"SOLA":[{"def":"A leguminous plant (Æschynomene aspera) growing in moist places in Southern India and the East Indies.","pos":""}],"SOLACE":[{"def":"Comfort in grief; alleviation of grief or anxiety; also, that which relieves in distress; that which cheers or consoles; relief.","pos":""},{"def":"Rest; relaxation; ease.","pos":""}],"SOLACEMENT":[{"def":"The act of solacing, or the state of being solaced; also, that which solaces.","pos":""}],"SOLACIOUS":[{"def":"Affording solace; as, a solacious voice.","pos":""}],"SOLAN GOOSE":[{"def":"The common gannet.","pos":""}],"SOLANACEOUS":[{"def":"Of or pertaining to plants of the natural order Solanaceæ, of which the nightshade (Solanum) is the type.","pos":""}],"SOLANICINE":[{"def":"An alkaloid produced by the action of hydrochloric acid on solanidine, as a tasteless yellow crystalline substance.","pos":""}],"SOLANIDINE":[{"def":"An alkaloid produced by the decomposition of solanine, as a white crystalline substance having a harsh bitter taste.","pos":""}],"SOLANINE":[{"def":"A poisonous alkaloid glucoside extracted from the berries of common nightshade (Solanum nigrum), and of bittersweet, and from potato sprouts, as a white crystalline substance having an acrid, burning taste; -- called also solonia, and solanina.","pos":""}],"SOLANO":[{"def":"A hot, oppressive wind which sometimes blows in the Mediterranean, particularly on the eastern coast of Spain.","pos":""}],"SOLANOID":[{"def":"Resembling a potato; -- said of a kind of cancer.","pos":""}],"SOLANUM":[{"def":"A genus of plants comprehending the potato (S.","pos":""}],"SOLAR":[{"def":"A loft or upper chamber; a garret room.","pos":""}],"SOLAR MYTH":[{"def":"A myth which essentially consists of allegory based upon ideas as to the sun's course, motion, influence, or the like.","pos":""}],"SOLAR PARALLAX":[{"def":"The parallax of the sun, that is, the angle subtended at the sun by the semidiameter of the earth.","pos":""}],"SOLARIUM":[{"def":"Any one of several species of handsome marine spiral shells of the genus Solarium and allied genera.","pos":""}],"SOLARIZATION":[{"def":"Injury of a photographic picture caused by exposing it for too long a time to the sun's light in the camera; burning; excessive insolation.","pos":""}],"SOLARIZE":[{"def":"To injure by too long exposure to the light of the sun in the camera; to burn.","pos":""}],"SOLATIUM":[{"def":"Anything which alleviates or compensates for suffering or loss; a compensation; esp.","pos":""}]}