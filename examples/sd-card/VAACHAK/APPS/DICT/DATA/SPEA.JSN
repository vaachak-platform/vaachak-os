{"SPEAK":[{"def":"To utter words or articulate sounds, as human beings; to express thoughts by words; as, the organs may be so obstructed that a man may not be able to speak.","pos":""},{"def":"To express opinions; to say; to talk; to converse.","pos":""}],"SPEAKABLE":[{"def":"Capable of being spoken; fit to be spoken.","pos":""}],"SPEAKER":[{"def":"A book of selections for declamation.","pos":""}],"SPEAKERSHIP":[{"def":"The office of speaker; as, the speakership of the House of Representatives.","pos":""}],"SPEAKING":[{"def":"Uttering speech; used for conveying speech; as, man is a speaking animal; a speaking tube.","pos":""},{"def":"Seeming to be capable of speech; hence, lifelike; as, a speaking likeness.","pos":""}],"SPEAR":[{"def":"A long, pointed weapon, used in war and hunting, by thrusting or throwing; a weapon with a long shaft and a sharp head or blade; a lance.","pos":""}],"SPEARER":[{"def":"One who uses a spear; as, a spearer of fish.","pos":""}],"SPEARFISH":[{"def":"American coast and the Mediterranean.","pos":""}],"SPEARHEAD":[{"def":"The pointed head, or end, of a spear.","pos":""}],"SPEARMAN":[{"def":"One who is armed with a spear.","pos":""}],"SPEARMINT":[{"def":"A species of mint (Mentha viridis) growing in moist soil.","pos":""}],"SPEARWOOD":[{"def":"An Australian tree (Acacia Doratoxylon), and its tough wood, used by the natives for spears.","pos":""}],"SPEARWORT":[{"def":"A name given to several species of crowfoot (Ranunculus) which have spear-shaped leaves.","pos":""}],"SPEARY":[{"def":"Having the form of a spear.","pos":""}]}