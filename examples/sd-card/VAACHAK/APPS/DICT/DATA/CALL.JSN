{"CALL":[{"def":"To command or request to come or be present; to summon; as, to call a servant.","pos":""},{"def":"To summon to the discharge of a particular duty; to designate for an office, or employment, especially of a religious character; -- often used of a divine summons; as, to be called to the ministry; sometimes, to invite; as, to call a minister to be the pastor of a church.","pos":""}],"CALLA":[{"def":"A genus of plants, of the order Araceæ.","pos":""}],"CALLAT":[{"def":"A callat of boundless tongue.","pos":""}],"CALLE":[{"def":"A kind of head covering; a caul.","pos":""}],"CALLER":[{"def":"Cool; refreshing; fresh; as, a caller day; the caller air.","pos":""},{"def":"Fresh; in good condition; as, caller berrings.","pos":""}],"CALLET":[{"def":"A trull or prostitute; a scold or gossip.","pos":""}],"CALLID":[{"def":"Characterized by cunning or shrewdness; crafty.","pos":""}],"CALLIDITY":[{"def":"Acuteness of discernment; cunningness; shrewdness.","pos":""}],"CALLIGRAPHER":[{"def":"One skilled in calligraphy; a good penman.","pos":""},{"def":"Of or pertaining to calligraphy.","pos":""}],"CALLIGRAPHY":[{"def":"Fair or elegant penmanship.","pos":""}],"CALLING":[{"def":"The act of one who calls; a crying aloud, esp.","pos":""},{"def":"A summoning or convocation, as of Parliament.","pos":""}],"CALLIOPE":[{"def":"The Muse that presides over eloquence and heroic poetry; mother of Orpheus, and chief of the nine Muses.","pos":""},{"def":"One of the astreids.","pos":""}],"CALLIOPSIS":[{"def":"A popular name given to a few species of the genus Careopsis, especially to C.","pos":""}],"CALLISECTION":[{"def":"Painless vivisection; -- opposed to sentisection.","pos":""},{"def":"See Calisthenic, Calisthenics.","pos":""}],"CALLITHUMP":[{"def":"A somewhat riotous parade, accompanied with the blowing of tin horus, and other discordant noises; also, a burlesque serenade; a charivari.","pos":""}],"CALLITHUMPIAN":[{"def":"Of, pertaining to, or resembling, a callithump.","pos":""}],"CALLOSAN":[{"def":"Of the callosum.","pos":""}],"CALLOSE":[{"def":"Furnished with protuberant or hardened spots.","pos":""}],"CALLOSITY":[{"def":"A hard or thickened spot or protuberance; a hardening and thickening of the skin or bark of a part, eps.","pos":""}],"CALLOSUM":[{"def":"The great band commissural fibers which unites the two cerebral hemispheres.","pos":""}],"CALLOT":[{"def":"A plant coif or skullcap.","pos":""}],"CALLOUS":[{"def":"Hardenes; indurated.","pos":""},{"def":"Hardened in mind; insensible; unfeeling; unsusceptible.","pos":""}],"CALLOW":[{"def":"Destitute of feathers; naked; unfledged.","pos":""},{"def":"Immature; boyish; \"green\"; as, a callow youth.","pos":""}],"CALLUS":[{"def":"The material of repair in fractures of bone; a substance exuded at the site of fracture, which is at first soft or cartilaginous in consistence, but is ultimately converted into true bone and unites the fragments into a single piece.","pos":""},{"def":"The new formation over the end of a cutting, before it puts out rootlets.","pos":""}]}