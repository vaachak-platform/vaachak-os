{"NATAL":[{"def":"Presiding over nativity; as, natal Jove.","pos":""}],"NATAL BOIL":[{"def":"Of or pertaining to one's birth or birthday, or one's nativity.","pos":""}],"NATAL PLUM":[{"def":"The drupaceous fruit of two South African shrubs of the genus Arduina (A.","pos":""}],"NATALOIN":[{"def":"A bitter crystalline substance constituting the essential principle of Natal aloes.","pos":""}],"NATALS":[{"def":"One's birth, or the circumstances attending it.","pos":""}],"NATANT":[{"def":"Floating in water, as the leaves of water lilies, or submersed, as those of many aquatic plants.","pos":""},{"def":"Placed horizontally across the field, as if swimmimg toward the dexter side; said of all sorts of fishes except the flying fish.","pos":""}],"NATANTLY":[{"def":"In a floating manner; swimmingly.","pos":""}],"NATATION":[{"def":"The act of floating on the water; swimming.","pos":""}],"NATATORES":[{"def":"The swimming birds.","pos":""}],"NATATORIAL":[{"def":"Inclined or adapted to swim; swimming; as, natatorial birds.","pos":""}],"NATATORIOUS":[{"def":"Adapted for swimming; -- said of the legs of certain insects.","pos":""}],"NATATORIUM":[{"def":"A swimming bath.","pos":""}],"NATATORY":[{"def":"Adapted for swimming or floating; as, natatory organs.","pos":""}],"NATCH":[{"def":"The rump of beef; esp.","pos":""}],"NATCHEZ":[{"def":"A tribe of Indians who formerly lived near the site of the city of Natchez, Mississippi.","pos":""}],"NATCHNEE":[{"def":"An annual grass (Eleusine coracona), cultivated in India as a food plant.","pos":""}],"NATES":[{"def":"The umbones of a bivalve shell.","pos":""}],"NATHMORE":[{"def":"Not the more; never the more.","pos":""}],"NATICA":[{"def":"Any one of numerous species of marine gastropods belonging to Natica, Lunatia, Neverita, and other allied genera (family Naticidæ.","pos":""}],"NATICOID":[{"def":"Like or belonging to Natica, or the family Naticæ.","pos":""}],"NATION":[{"def":"A part, or division, of the people of the earth, distinguished from the rest by common descent, language, or institutions; a race; a stock.","pos":""}],"NATIONAL":[{"def":"Of or pertaining to a nation; common to a whole people or race; public; general; as, a national government, language, dress, custom, calamity, etc.","pos":""},{"def":"Attached to one's own country or nation.","pos":""}],"NATIONALISM":[{"def":"The state of being national; national attachment; nationality.","pos":""},{"def":"An idiom, trait, or character peculiar to any nation.","pos":""}],"NATIONALIST":[{"def":"One who advocates national unity and independence; one of a party favoring Irish independence.","pos":""}],"NATIONALITY":[{"def":"The quality of being national, or strongly attached to one's own nation; patriotism.","pos":""},{"def":"The sum of the qualities which distinguish a nation; national character.","pos":""}],"NATIONALIZATION":[{"def":"The act of nationalizing, or the state of being nationalized.","pos":""}],"NATIONALIZE":[{"def":"To make national; to make a nation of; to endow with the character and habits of a nation, or the peculiar sentiments and attachment of citizens of a nation.","pos":""}],"NATIONALLY":[{"def":"In a national manner or way; as a nation.","pos":""}],"NATIONALNESS":[{"def":"The quality or state of being national; nationality.","pos":""}],"NATIONALRATH":[{"def":"See Legislature.","pos":""}],"NATIVE":[{"def":"Arising by birth; having an origin; born.","pos":""},{"def":"Of or pertaining to one's birth; natal; belonging to the place or the circumstances in which one is born; -- opposed to foreign; as, native land, language, color, etc.","pos":""}],"NATIVE STEEL":[{"def":"A sort of steel which has been found where a burning coal seam had reduced and carbonized adjacent iron ore.","pos":""}],"NATIVELY":[{"def":"By natural or original condition; naturally; originally.","pos":""}],"NATIVENESS":[{"def":"The quality or state of being native.","pos":""}],"NATIVISM":[{"def":"The doctrine of innate ideas, or that the mind possesses forms of thought independent of sensation.","pos":""}],"NATIVIST":[{"def":"An advocate of nativism.","pos":""}],"NATIVISTIC":[{"def":"Relating to nativism.","pos":""}],"NATIVITY":[{"def":"A picture representing or symbolizing the early infancy of Christ.","pos":""},{"def":"A representation of the positions of the heavenly bodies as the moment of one's birth, supposed to indicate his future destinies; a horoscope.","pos":""}],"NATKA":[{"def":"A species of shrike.","pos":""}],"NATRIUM":[{"def":"The technical name for sodium.","pos":""}],"NATROLITE":[{"def":"A zeolite occuring in groups of glassy acicular crystals, and in masses which often have a radiated structure.","pos":""}],"NATRON":[{"def":"Native sodium carbonate.","pos":""}],"NATTER":[{"def":"To find fault; to be peevish.","pos":""}],"NATTERJACK":[{"def":"A European toad (Bufo calamita), having a yellow line along its back.","pos":""}],"NATTY":[{"def":"Neat; tidy; spruce.","pos":""}],"NATURAL":[{"def":"Belonging to, to be taken in, or referred to, some system, in which the base is 1; -- said or certain functions or numbers; as, natural numbers, those commencing at 1; natural sines, cosines, etc.","pos":""}],"NATURAL STEEL":[{"def":"Steel made by the direct refining of cast iron in a finery, or, as wootz, by a direct process from the ore.","pos":""}],"NATURALISM":[{"def":"A state of nature; conformity to nature.","pos":""}],"NATURALIST":[{"def":"One versed in natural science; a student of natural history, esp.","pos":""},{"def":"One who holds or maintains the doctrine of naturalism in religion.","pos":""}],"NATURALISTIC":[{"def":"Belonging to the doctrines of naturalism.","pos":""},{"def":"Closely resembling nature; realistic.","pos":""}],"NATURALITY":[{"def":"Nature; naturalness.","pos":""}],"NATURALIZATION":[{"def":"The act or process of naturalizing, esp.","pos":""}],"NATURALIZE":[{"def":"To make natural; as, custom naturalizes labor or study.","pos":""},{"def":"To confer the rights and privileges of a native subject or citizen on; to make as if native; to adopt, as a foreigner into a nation or state, and place in the condition of a native subject.","pos":""}],"NATURALLY":[{"def":"In a natural manner or way; according to the usual course of things; spontaneously.","pos":""}],"NATURALNESS":[{"def":"The state or quality of being natural; conformity to nature.","pos":""}],"NATURE":[{"def":"The existing system of things; the world of matter, or of matter and mind; the creation; the universe.","pos":""}],"NATURED":[{"def":"Having (such) a nature, temper, or disposition; disposed; -- used in composition; as, good-natured, ill-natured, etc.","pos":""}],"NATURELESS":[{"def":"Not in accordance with nature; unnatural.","pos":""}],"NATURISM":[{"def":"The belief or doctrine that attributes everything to nature as a sanative agent.","pos":""}],"NATURIST":[{"def":"One who believes in, or conforms to, the theory of naturism.","pos":""}],"NATURITY":[{"def":"The quality or state of being produced by nature.","pos":""}],"NATURIZE":[{"def":"To endow with a nature or qualities; to refer to nature.","pos":""}]}