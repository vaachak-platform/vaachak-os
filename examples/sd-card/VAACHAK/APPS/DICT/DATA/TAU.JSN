{"TAU":[{"def":"The common American toadfish; -- so called from a marking resembling the Greek letter tau (t).","pos":""}],"TAUNT":[{"def":"Very high or tall; as, a ship with taunt masts.","pos":""}],"TAUNTING":[{"def":"Every kind of insolent and taunting reflection.","pos":""}],"TAUNTINGLY":[{"def":"In a taunting manner.","pos":""}],"TAUNTRESS":[{"def":"A woman who taunts.","pos":""},{"def":"A foolish or thoughtless young person, esp.","pos":""}],"TAUR":[{"def":"The constellation Taurus.","pos":""}],"TAURICORNOUS":[{"def":"Having horns like those of a bull.","pos":""}],"TAURID":[{"def":"Any of a group of meteors appearing November 20-23; -- so called because they appear to radiate from a point in Taurus.","pos":""}],"TAURIFORM":[{"def":"Having the form of a bull.","pos":""}],"TAURINE":[{"def":"Of or pertaining to the genus Taurus, or cattle.","pos":""}],"TAUROCHOLATE":[{"def":"A salt of taurocholic acid; as, sodium taurocholate, which occurs in human bile.","pos":""}],"TAUROCHOLIC":[{"def":"Pertaining to, or designating, a conjugate acid (called taurocholic acid) composed of taurine and cholic acid, present abundantly in human bile and in that of carnivora.","pos":""},{"def":"Glue made from a bull's hide.","pos":""}],"TAUROMACHIAN":[{"def":"Of or pertaining to bullfights.","pos":""}],"TAURUS":[{"def":"A genus of ruminants comprising the common domestic cattle.","pos":""}],"TAURYLIC":[{"def":"Pertaining to, or designating, an acid found of a urine of neat cattle, and probably identical with cresol.","pos":""}],"TAUT":[{"def":"Tight; stretched; not slack; -- said esp.","pos":""}],"TAUTEGORICAL":[{"def":"Expressing the same thing with different words; -- opposed to allegorical.","pos":""}],"TAUTOCHRONE":[{"def":"A curved line, such that a heavy body, descending along it by the action of gravity, will always arrive at the lowest point in the same time, wherever in the curve it may begin to fall; as, an inverted cycloid with its base horizontal is a tautochrone.","pos":""}],"TAUTOCHRONOUS":[{"def":"Occupying the same time; pertaining to, or having the properties of, a tautochrone.","pos":""}],"TAUTOG":[{"def":"An edible labroid fish (Haitula onitis, or Tautoga onitis) of the Atlantic coast of the United States.","pos":""}],"TAUTOLOGICAL":[{"def":"Involving tautology; having the same signification; as, tautological expression.","pos":""}],"TAUTOLOGIST":[{"def":"One who uses tautological words or phrases.","pos":""}],"TAUTOLOGIZE":[{"def":"To repeat the same thing in different words.","pos":""}],"TAUTOLOGOUS":[{"def":"Repeating the same thing in different words; tautological.","pos":""}],"TAUTOLOGY":[{"def":"The dawn is overcast, the morning lowers, And heavily in clouds brings on the day.","pos":""}],"TAUTOMERIC":[{"def":"Relating to, or characterized by, tautomerism.","pos":""}],"TAUTOMERISM":[{"def":"The condition, quality, or relation of metameric substances, or their respective derivatives, which are more or less interchangeable, according as one form or the other is the more stable.","pos":""},{"def":"Having the same essence; being identically of the same nature.","pos":""}],"TAUTOPHONICAL":[{"def":"Pertaining to, or characterized by, tautophony; repeating the same sound.","pos":""}],"TAUTOPHONY":[{"def":"Repetition of the same sound.","pos":""}],"TAUTOZONAL":[{"def":"Belonging to the same zone; as, tautozonal planes.","pos":""}]}