{"PHEASANT":[{"def":"Any one of numerous species of large gallinaceous birds of the genus Phasianus, and many other genera of the family Phasianidæ, found chiefly in Asia.","pos":""},{"def":"The ruffed grouse.","pos":""}],"PHEASANTRY":[{"def":"A place for keeping and rearing pheasants.","pos":""}],"PHEESE":[{"def":"To comb; also, to beat; to worry.","pos":""}],"PHELLODERM":[{"def":"A layer of green parenchimatous cells formed on the inner side of the phellogen.","pos":""}],"PHELLOGEN":[{"def":"The tissue of young cells which produces cork cells.","pos":""}],"PHELLOPLASTICS":[{"def":"Art of modeling in cork.","pos":""},{"def":"A white, crystalline compound, C10H13O2N, used in medicine principally as an antipyretic.","pos":""}],"PHENACITE":[{"def":"A glassy colorless mineral occurring in rhombohedral crystals, sometimes used as a gem.","pos":""}],"PHENAKISTOSCOPE":[{"def":"A revolving disk on which figures drawn in different relative attitudes are seen successively, so as to produce the appearance of an object in actual motion, as an animal leaping, etc.","pos":""}],"PHENALGIN":[{"def":"An ammoniated compound of phenyl and acetamide, used as an analgesic and antipyretic.","pos":""}],"PHENANTHRENE":[{"def":"A complex hydrocarbon, C14H10, found in coal tar, and obtained as a white crystalline substance with a bluish fluorescence.","pos":""}],"PHENANTHRIDINE":[{"def":"A nitrogenous hydrocarbon base, C13H9N, analogous to phenanthrene and quinoline.","pos":""}],"PHENANTHROLINE":[{"def":"Either of two metameric nitrogenous hydrocarbon bases, C12H8N2, analogous to phenanthridine, but more highly nitrogenized.","pos":""}],"PHENETOL":[{"def":"The ethyl ether of phenol, obtained as an aromatic liquid, C6H5.","pos":""}],"PHENIC":[{"def":"Of, pertaining to, derived from, or resembling, phenyl or phenol.","pos":""}],"PHENICIOUS":[{"def":"Of a red color with a slight mixture of gray.","pos":""}],"PHENIX":[{"def":"A bird fabled to exist single, to be consumed by fire by its own act, and to rise again from its ashes.","pos":""},{"def":"A southern constellation.","pos":""}],"PHENOCRYST":[{"def":"One of the prominent embedded crystals of a porphyry.","pos":""}],"PHENOGAMIA":[{"def":"Same as Phænogamia.","pos":""},{"def":"Same as Phænogamian, Phænogamic, etc.","pos":""}],"PHENOL":[{"def":"A white or pinkish crystalline substance, C6H5OH, produced by the destructive distillation of many organic bodies, as wood, coal, etc.","pos":""},{"def":"Any one of the series of hydroxyl derivatives of which phenol proper is the type.","pos":""}],"PHENOLATE":[{"def":"A compound of phenol analogous to a salt.","pos":""}],"PHENOLOGY":[{"def":"The science of the relations between climate and periodic biological phenomena, as the migrations and breeding of birds, the flowering and fruiting of plants, etc.","pos":""},{"def":"A white or yellowish white crystalline substance, C20H14O4, formed by condensation of the anhydride of phthalic acid and phenol.","pos":""}],"PHENOMENAL":[{"def":"Relating to, or of the nature of, a phenomenon; hence, extraordinary; wonderful; as, a phenomenal memory.","pos":""}],"PHENOMENALISM":[{"def":"That theory which limits positive or scientific knowledge to phenomena only, whether material or spiritual.","pos":""}],"PHENOMENIST":[{"def":"One who believes in the theory of phenomenalism.","pos":""}],"PHENOMENOLOGY":[{"def":"A description, history, or explanation of phenomena.","pos":""}],"PHENOMENON":[{"def":"An appearance; anything visible; whatever, in matter or spirit, is apparent to, or is apprehended by, observation; as, the phenomena of heat, light, or electricity; phenomena of imagination or memory.","pos":""},{"def":"That which strikes one as strange, unusual, or unaccountable; an extraordinary or very remarkable person, thing, or occurrence; as, a musical phenomenon.","pos":""}],"PHENOSE":[{"def":"A sweet amorphous deliquescent substance obtained indirectly from benzene, and isometric with, and resembling, dextrose.","pos":""}],"PHENYL":[{"def":"A hydrocarbon radical (C6H5) regarded as the essential residue of benzene, and the basis of an immense number of aromatic derivatives.","pos":""}],"PHENYLAMINE":[{"def":"Any one of certain class of organic bases regarded as formed from ammonia by the substitution of phenyl for hydrogen.","pos":""}],"PHENYLENE":[{"def":"A hypothetic radical (C6H4) occurring in certain derivatives of benzene; as, phenylene diamine.","pos":""}],"PHENYLIC":[{"def":"Pertaining to, derived from, or containing, phenyl.","pos":""}],"PHEON":[{"def":"A bearing representing the head of a dart or javelin, with long barbs which are engrailed on the inner edge.","pos":""}]}