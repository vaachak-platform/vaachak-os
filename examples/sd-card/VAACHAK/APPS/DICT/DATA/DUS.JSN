{"DUSE":[{"def":"A demon or spirit.","pos":""}],"DUSK":[{"def":"Tending to darkness or blackness; moderately dark or black; dusky.","pos":""}],"DUSKEN":[{"def":"To make dusk or obscure.","pos":""}],"DUSKILY":[{"def":"In a dusky manner.","pos":""}],"DUSKINESS":[{"def":"The state of being dusky.","pos":""}],"DUSKY":[{"def":"Partially dark or obscure; not luminous; dusk; as, a dusky valley.","pos":""},{"def":"Tending to blackness in color; partially black; dark-colored; not bright; as, a dusky brown.","pos":""}],"DUST":[{"def":"Coined money; cash.","pos":""}],"DUST-POINT":[{"def":"An old rural game.","pos":""}],"DUSTBRUSH":[{"def":"A brush of feathers, bristles, or hair, for removing dust from furniture.","pos":""}],"DUSTER":[{"def":"A blowing machine for separating the flour from the bran.","pos":""}],"DUSTINESS":[{"def":"The state of being dusty.","pos":""}],"DUSTLESS":[{"def":"Without dust; as a dustless path.","pos":""}],"DUSTMAN":[{"def":"One whose employment is to remove dirt and defuse.","pos":""}],"DUSTPAN":[{"def":"A shovel-like utensil for conveying away dust brushed from the floor.","pos":""}],"DUSTY":[{"def":"Filled, covered, or sprinkled with dust; clouded with dust; as, a dusty table; also, reducing to dust.","pos":""},{"def":"Like dust; of the color of dust; as a dusty white.","pos":""}]}