{"OROGRAPH":[{"def":"A machine for use in making topographical maps.","pos":""},{"def":"Of or pertaining to orography.","pos":""}],"OROGRAPHY":[{"def":"That branch of science which treats of mountains and mountain systems; orology; as, the orography of Western Europe.","pos":""}],"OROHELIOGRAPH":[{"def":"A camera for obtaining a circular panoramic view of the horizon.","pos":""}],"OROHIPPUS":[{"def":"A genus of American Eocene mammals allied to the horse, but having four toes in front and three behind.","pos":""}],"OROIDE":[{"def":"An alloy, chiefly of copper and zinc or tin, resembling gold in color and brilliancy.","pos":""}],"OROLOGICAL":[{"def":"Of or pertaining to orology.","pos":""}],"OROLOGIST":[{"def":"One versed in orology.","pos":""}],"OROLOGY":[{"def":"The science or description of mountains.","pos":""}],"OROMETER":[{"def":"An aneroid barometer having a second scale that gives the approximate elevation above sea level of the place where the observation is made.","pos":""}],"OROTUND":[{"def":"Characterized by fullness, clearness, strength, and smoothness; ringing and musical; -- said of the voice or manner of utterance.","pos":""},{"def":"The orotund voice or utterance Rush.","pos":""}],"OROTUNDITY":[{"def":"The orotund mode of intonation.","pos":""}]}