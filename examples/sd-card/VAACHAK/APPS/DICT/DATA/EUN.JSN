{"EUNOMIAN":[{"def":"A follower of Eunomius, bishop of Cyzicus (4th century A.","pos":""},{"def":"Of or pertaining to Eunomius or his doctrine.","pos":""}],"EUNOMY":[{"def":"Equal law, or a well-adjusted constitution of government.","pos":""}],"EUNUCH":[{"def":"A male of the human species castrated; commonly, one of a class of such persons, in Oriental countries, having charge of the women's apartments.","pos":""},{"def":"To make a eunuch of; to castrate.","pos":""}],"EUNUCHISM":[{"def":"The state of being eunuch.","pos":""}]}