{"UNIPARA":[{"def":"A woman who has borne one child.","pos":""}],"UNIPAROUS":[{"def":"Producing but one egg or young at a time.","pos":""},{"def":"Producing but one axis of inflorescence; -- said of the scorpioid cyme.","pos":""}],"UNIPED":[{"def":"Having only one foot.","pos":""}],"UNIPERSONAL":[{"def":"Used in only one person, especially only in the third person, as some verbs; impersonal.","pos":""}],"UNIPERSONALIST":[{"def":"One who believes that the Deity is unipersonal.","pos":""}],"UNIPHONOUS":[{"def":"Having but one sound, as the drum.","pos":""}],"UNIPLICATE":[{"def":"Having, or consisting of, but one fold.","pos":""}],"UNIPOLAR":[{"def":"Having, or acting by means of, one pole only.","pos":""},{"def":"Having but one pole or process; -- applied to those ganglionic nerve cells which have but one radiating process; -- opposed to multipolar.","pos":""}]}