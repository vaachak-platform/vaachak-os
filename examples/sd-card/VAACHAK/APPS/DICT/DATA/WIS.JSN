{"WIS":[{"def":"Certainly; really; indeed.","pos":""}],"WISDOM":[{"def":"The quality of being wise; knowledge, and the capacity to make due use of it; knowledge of the best ends and the best means; discernment and judgment; discretion; sagacity; skill; dexterity.","pos":""},{"def":"The results of wise judgments; scientific or practical truth; acquired knowledge; erudition.","pos":""}],"WISDOM LITERATURE":[{"def":"The class of ancient Hebrew writings which deal reflectively with general ethical and religious topics, as distinguished from the prophetic and liturgical literature, and from the law.","pos":""}],"WISE":[{"def":"Having knowledge; knowing; enlightened; of extensive information; erudite; learned.","pos":""},{"def":"Hence, especially, making due use of knowledge; discerning and judging soundly concerning what is true or false, proper or improper; choosing the best ends and the best means for accomplishing them; sagacious.","pos":""}],"WISE-HEARTED":[{"def":"Wise; knowing; skillful; sapient; erudite; prudent.","pos":""}],"WISE-LIKE":[{"def":"Resembling that which is wise or sensible; judicious.","pos":""}],"WISEACRE":[{"def":"A learned or wise man.","pos":""},{"def":"One who makes undue pretensions to wisdom; a would-be-wise person; hence, in contempt, a simpleton; a dunce.","pos":""}],"WISELING":[{"def":"One who pretends to be wise; a wiseacre; a witling.","pos":""}],"WISELY":[{"def":"In a wise manner; prudently; judiciously; discreetly; with wisdom.","pos":""}],"WISH":[{"def":"To have a desire or yearning; to long; to hanker.","pos":""}],"WISH-WASH":[{"def":"Any weak, thin drink.","pos":""}],"WISHABLE":[{"def":"Capable or worthy of being wished for; desirable.","pos":""}],"WISHBONE":[{"def":"The forked bone in front of the breastbone in birds; -- called also merrythought, and wishing bone.","pos":""}],"WISHEDLY":[{"def":"According to wish; conformably to desire.","pos":""}],"WISHER":[{"def":"One who wishes or desires; one who expresses a wish.","pos":""}],"WISHFUL":[{"def":"Having desire, or ardent desire; longing.","pos":""},{"def":"Showing desire; as, wishful eyes.","pos":""}],"WISHLY":[{"def":"According to desire; longingly; with wishes.","pos":""}],"WISHTONWISH":[{"def":"The prairie dog.","pos":""}],"WISHY-WASHY":[{"def":"Thin and pale; weak; without strength or substance; -- originally said of liquids.","pos":""}],"WISKET":[{"def":"A whisket, or basket.","pos":""}],"WISP":[{"def":"A small bundle, as of straw or other like substance.","pos":""},{"def":"A whisk, or small broom.","pos":""}],"WISPEN":[{"def":"Formed of a wisp, or of wisp; as, a wispen broom.","pos":""}],"WISSE":[{"def":"To show; to teach; to inform; to guide; to direct.","pos":""}],"WISTARIA":[{"def":"A genus of climbing leguminous plants bearing long, pendulous clusters of pale bluish flowers.","pos":""}],"WISTFUL":[{"def":"Longing; wishful; desirous.","pos":""},{"def":"Full of thought; eagerly attentive; meditative; musing; pensive; contemplative.","pos":""}],"WISTIT":[{"def":"A small South American monkey; a marmoset.","pos":""}],"WISTLY":[{"def":"Attentively; observingly.","pos":""}],"WISTONWISH":[{"def":"See Wishtonwish.","pos":""}]}