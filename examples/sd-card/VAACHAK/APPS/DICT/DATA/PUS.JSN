{"PUS":[{"def":"The yellowish white opaque creamy matter produced by the process of suppuration.","pos":""}],"PUSANE":[{"def":"A piece of armor for the breast; often, an addition to, or reënforcement of.","pos":""}],"PUSEYISM":[{"def":"The principles of Dr.","pos":""},{"def":"Of or pertaining to Puseyism.","pos":""}],"PUSEYITE":[{"def":"One who holds the principles of Puseyism; -- often used opprobriously.","pos":""}],"PUSH":[{"def":"A pustule; a pimple.","pos":""}],"PUSH BUTTON":[{"def":"A simple device, resembling a button in form, so arranged that pushing it closes an electric circuit, as of an electric bell.","pos":""}],"PUSHER":[{"def":"One who, or that which, pushes.","pos":""}],"PUSHING":[{"def":"Pressing forward in business; enterprising; driving; energetic; also, forward; officious, intrusive.","pos":""}],"PUSHPIN":[{"def":"A child's game played with pins.","pos":""}],"PUSIL":[{"def":"Very small; little; petty.","pos":""}],"PUSILLANIMITY":[{"def":"The quality of being pusillanimous; weakness of spirit; cowardliness.","pos":""}],"PUSILLANIMOUS":[{"def":"Destitute of a manly or courageous strength and firmness of mind; of weak spirit; mean-spirited; spiritless; cowardly; -- said of persons, as, a pussillanimous prince.","pos":""},{"def":"Evincing, or characterized by, weakness of mind, and want of courage; feeble; as, pusillanimous counsels.","pos":""}],"PUSILLANIMOUSLY":[{"def":"With pusillanimity.","pos":""}],"PUSS":[{"def":"A cat; -- a fondling appellation.","pos":""},{"def":"A hare; -- so called by sportsmen.","pos":""}],"PUSSY":[{"def":"A pet name for a cat; also, an endearing name for a girl.","pos":""},{"def":"A catkin of the pussy willow.","pos":""}],"PUSTULANT":[{"def":"Producing pustules.","pos":""},{"def":"A medicine that produces pustules, as croton oil.","pos":""}],"PUSTULAR":[{"def":"Covered with pustulelike prominences; pustulate.","pos":""}],"PUSTULATE":[{"def":"To form into pustules, or blisters.","pos":""},{"def":"Covered with pustulelike prominences; pustular; pustulous; as, a pustulate leaf; a pustulate shell or coral.","pos":""}],"PUSTULATION":[{"def":"The act of producing pustules; the state of being pustulated.","pos":""}],"PUSTULE":[{"def":"A vesicle or an elevation of the cuticle with an inflamed base, containing pus.","pos":""}],"PUSTULOUS":[{"def":"Resembling, or covered with, pustules; pustulate; pustular.","pos":""}]}