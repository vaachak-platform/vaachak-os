{"TERM":[{"def":"A point, line, or superficies, that limits; as, a line is the term of a superficies, and a superficies is the term of a solid.","pos":""},{"def":"A fixed period of time; a prescribed duration; as: (a) The limitation of an estate; or rather, the whole time for which an estate is granted, as for the term of a life or lives, or for a term of years.","pos":""}],"TERM DAY":[{"def":"A day which is a term (as for payment of rent), or is a day in a term, as of the sitting of a court; esp.","pos":""}],"TERM INSURANCE":[{"def":"Insurance for a specified term providing for no payment to the insured except upon losses during the term, and becoming void upon its expiration.","pos":""}],"TERM POLICY":[{"def":"A policy of term insurance.","pos":""}],"TERMA":[{"def":"The terminal lamina, or thin ventral part, of the anterior wall of the third ventricle of the brain.","pos":""}],"TERMAGANCY":[{"def":"The quality or state of being termagant; turbulence; tumultuousness; as, a violent termagancy of temper.","pos":""}],"TERMAGANT":[{"def":"An imaginary being supposed by the Christians to be a Mohammedan deity or false god.","pos":""},{"def":"A boisterous, brawling, turbulent person; -- formerly applied to both sexes, now only to women.","pos":""}],"TERMATARIUM":[{"def":"Any nest or dwelling of termes, or white ants.","pos":""}],"TERMATARY":[{"def":"Same as Termatarium.","pos":""}],"TERMER":[{"def":"One who has an estate for a term of years or for life.","pos":""}],"TERMES":[{"def":"A genus of Pseudoneuroptera including the white ants, or termites.","pos":""}],"TERMINABLE":[{"def":"Capable of being terminated or bounded; limitable.","pos":""}],"TERMINAL":[{"def":"Growing at the end of a branch or stem; terminating; as, a terminal bud, flower, or spike.","pos":""}],"TERMINALIA":[{"def":"A festival celebrated annually by the Romans on February 23 in honor of Terminus, the god of boundaries.","pos":""}],"TERMINANT":[{"def":"Termination; ending.","pos":""}],"TERMINATE":[{"def":"To set a term or limit to; to form the extreme point or side of; to bound; to limit; as, to terminate a surface by a line.","pos":""},{"def":"To put an end to; to make to cease; as, to terminate an effort, or a controversy.","pos":""}],"TERMINATION":[{"def":"The ending of a word; a final syllable or letter; the part added to a stem in inflection.","pos":""}],"TERMINATIONAL":[{"def":"Of or pertaining to termination; forming a termination.","pos":""}],"TERMINATIVE":[{"def":"Tending or serving to terminate; terminating; determining; definitive.","pos":""}],"TERMINATOR":[{"def":"The dividing line between the illuminated and the unilluminated part of the moon.","pos":""}],"TERMINER":[{"def":"A determining; as, in oyer and terminer.","pos":""}],"TERMINISM":[{"def":"The doctrine held by the Terminists.","pos":""}],"TERMINIST":[{"def":"One of a class of theologians who maintain that God has fixed a certain term for the probation of individual persons, during which period, and no longer, they have the offer to grace.","pos":""}],"TERMINOLOGICAL":[{"def":"Of or pertaining to terminology.","pos":""}],"TERMINOLOGY":[{"def":"The doctrine of terms; a theory of terms or appellations; a treatise on terms.","pos":""},{"def":"The terms actually used in any business, art, science, or the like; nomenclature; technical terms; as, the terminology of chemistry.","pos":""}],"TERMINUS":[{"def":"The Roman divinity who presided over boundaries, whose statue was properly a short pillar terminating in the bust of a man, woman, satyr, or the like, but often merely a post or stone stuck in the ground on a boundary line.","pos":""}],"TERMITE":[{"def":"Any one of numerous species of pseudoneoropterous insects belonging to Termes and allied genera; -- called also white ant.","pos":""}],"TERMLESS":[{"def":"Having no term or end; unlimited; boundless; unending; as, termless time.","pos":""},{"def":"Inexpressible; indescribable.","pos":""}],"TERMLY":[{"def":"Occurring every term; as, a termly fee.","pos":""}],"TERMOR":[{"def":"Same as Termer, 2.","pos":""}]}