{"LANT":[{"def":"Any one of several species of small, slender, marine fishes of the genus Ammedytes.","pos":""}],"LANTANURIC":[{"def":"Pertaining to, or designating, a nitrogenous organic acid of the uric acid group, obtained by the decomposition of allantoin, and usually called allanturic acid.","pos":""}],"LANTERLOO":[{"def":"An old name of loo (a).","pos":""}],"LANTERN":[{"def":"A lantern pinion or trundle wheel.","pos":""},{"def":"A kind of cage inserted in a stuffing box and surrounding a piston rod, to separate the packing into two parts and form a chamber between for the reception of steam, etc.","pos":""}],"LANTERN-JAWED":[{"def":"Having lantern jaws or long, thin jaws; as, a lantern-jawed person.","pos":""}],"LANTHANITE":[{"def":"Hydrous carbonate of lanthanum, found in tabular while crystals.","pos":""}],"LANTHANUM":[{"def":"A rare element of the group of the earth metals, allied to aluminium.","pos":""}],"LANTHOPINE":[{"def":"An alkaloid found in opium in small quantities, and extracted as a white crystalline substance.","pos":""}],"LANTHORN":[{"def":"Covered with down, or fine soft hair; downy.","pos":""}]}