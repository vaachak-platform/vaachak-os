{"DIAL":[{"def":"An instrument, formerly much used for showing the time of day from the shadow of a style or gnomon on a graduated arc or surface; esp.","pos":""},{"def":"The graduated face of a timepiece, on which the time of day is shown by pointers or hands.","pos":""}],"DIALECT":[{"def":"Means or mode of expressing thoughts; language; tongue; form of speech.","pos":""}],"DIALECTAL":[{"def":"Relating to a dialect; dialectical; as, a dialectical variant.","pos":""}],"DIALECTIC":[{"def":"Same as Dialectics.","pos":""}],"DIALECTICALLY":[{"def":"In a dialectical manner.","pos":""}],"DIALECTICIAN":[{"def":"One versed in dialectics; a logician; a reasoner.","pos":""}],"DIALECTICS":[{"def":"That branch of logic which teaches the rules and modes of reasoning; the application of logical principles to discursive reasoning; the science or art of discriminating truth from error; logical discussion.","pos":""}],"DIALECTOLOGY":[{"def":"That branch of philology which is devoted to the consideration of dialects.","pos":""}],"DIALECTOR":[{"def":"One skilled in dialectics.","pos":""}],"DIALING":[{"def":"The art of constructing dials; the science which treats of measuring time by dials.","pos":""},{"def":"A method of surveying, especially in mines, in which the bearings of the courses, or the angles which they make with each other, are determined by means of the circumferentor.","pos":""}],"DIALIST":[{"def":"A maker of dials; one skilled in dialing.","pos":""}],"DIALLAGE":[{"def":"A figure by which arguments are placed in various points of view, and then turned to one point.","pos":""}],"DIALLEL":[{"def":"Meeting and intersecting, as lines; not parallel; -- opposed to parallel.","pos":""}],"DIALLYL":[{"def":"A volatile, pungent, liquid hydrocarbon, C6H10, consisting of two allyl radicals, and belonging to the acetylene series.","pos":""}],"DIALOGICAL":[{"def":"Relating to a dialogue; dialogistical.","pos":""}],"DIALOGICALLY":[{"def":"In the manner or nature of a dialogue.","pos":""}],"DIALOGISM":[{"def":"An imaginary speech or discussion between two or more; dialogue.","pos":""}],"DIALOGIST":[{"def":"Pertaining to a dialogue; having the form or nature of a dialogue.","pos":""}],"DIALOGITE":[{"def":"Native carbonate of manganese; rhodochrosite.","pos":""}],"DIALOGIZE":[{"def":"To discourse in dialogue.","pos":""}],"DIALOGUE":[{"def":"A conversation between two or more persons; particularly, a formal conservation in theatrical performances or in scholastic exercises.","pos":""},{"def":"A written composition in which two or more persons are represented as conversing or reasoning on some topic; as, the Dialogues of Plato.","pos":""}],"DIALYPETALOUS":[{"def":"Having separate petals; polypetalous.","pos":""}],"DIALYSIS":[{"def":"Same as Asyndeton.","pos":""}],"DIALYTIC":[{"def":"Having the quality of unloosing or separating.","pos":""}],"DIALYZATE":[{"def":"The material subjected to dialysis.","pos":""}],"DIALYZATION":[{"def":"The act or process of dialysis.","pos":""}],"DIALYZE":[{"def":"To separate, prepare, or obtain, by dialysis or osmose; to pass through an animal membrane; to subject to dialysis.","pos":""}],"DIALYZED":[{"def":"Prepared by diffusion through an animal membrane; as, dialyzed iron.","pos":""}],"DIALYZER":[{"def":"The instrument or medium used to effect chemical dialysis.","pos":""}]}