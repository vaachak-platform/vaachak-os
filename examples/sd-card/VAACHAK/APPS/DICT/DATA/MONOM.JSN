{"MONOMACHIST":[{"def":"One who fights in single combat; a duelist.","pos":""}],"MONOMANIA":[{"def":"Derangement of the mind in regard of a single subject only; also, such a concentration of interest upon one particular subject or train of ideas to show mental derangement.","pos":""}],"MONOMANIAC":[{"def":"A person affected by monomania.","pos":""},{"def":"Affected with monomania, or partial derangement of intellect; caused by, or resulting from, monomania; as, a monomaniacal delusion.","pos":""}],"MONOMEROUS":[{"def":"Composed of solitary parts, as a flower with one sepal, one petal, one stamen, and one pistil.","pos":""},{"def":"Having but one joint; -- said of the foot of certain insects.","pos":""}],"MONOMETALLIC":[{"def":"Consisting of one metal; of or pertaining to monometallism.","pos":""}],"MONOMETALLISM":[{"def":"The legalized use of one metal only, as gold, or silver, in the standard currency of a country, or as a standard of money values.","pos":""}],"MONOMETALLIST":[{"def":"One who believes in monometallism as opposed to bimetallism, etc.","pos":""}],"MONOMETER":[{"def":"A rhythmic series, consisting of a single meter.","pos":""}],"MONOMETRIC":[{"def":"Same as Isometric.","pos":""}],"MONOMIAL":[{"def":"A single algebraic expression; that is, an expression unconnected with any other by the sign of addition, substraction, equality, or inequality.","pos":""}],"MONOMPHALUS":[{"def":"A form of double monster, in which two individuals are united by a common umbilicus.","pos":"noun"},{"def":"An order of lamellibranchs having but one muscle for closing the shell, as the oyster.","pos":"noun"}]}