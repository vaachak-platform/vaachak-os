{"RED":[{"def":"To put on order; to make tidy; also, to free from entanglement or embarrassement; -- generally with up; as, to red up a house.","pos":""}],"RED CROSS":[{"def":"The crusaders or the cause they represented.","pos":""}],"RED-GUM":[{"def":"An eruption of red pimples upon the face, neck, and arms, in early infancy; tooth rash; strophulus.","pos":""},{"def":"Having hands red with blood; in the very act, as if with red or bloody hands; -- said of a person taken in the act of homicide; hence, fresh from the commission of crime; as, he was taken red-hand or red-handed.","pos":""}],"RED-HOT":[{"def":"Red with heat; heated to redness; as, red-hot iron; red-hot balls.","pos":""}],"RED-LETTER":[{"def":"Of or pertaining to a red letter; marked by red letters.","pos":""}],"RED-LIGHT DISTRICT":[{"def":"A district or neighborhood in which disorderly resorts are frequent; -- so called in allusion to the red light kept in front of many such resorts at night.","pos":""}],"RED-RIBAND":[{"def":"The European red band fish, or fireflame.","pos":""}],"RED-SHORT":[{"def":"Hot-short; brittle when red-hot; -- said of certain kinds of iron.","pos":""}],"RED-TAILED":[{"def":"Having a red tail.","pos":""}],"RED-TAPE":[{"def":"Pertaining to, or characterized by, official formality.","pos":""}],"RED-TAPISM":[{"def":"Strict adherence to official formalities.","pos":""}],"RED-TAPIST":[{"def":"One who is tenacious of a strict adherence to official formalities.","pos":""}]}