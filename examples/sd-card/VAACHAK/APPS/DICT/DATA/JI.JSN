{"JIB":[{"def":"A triangular sail set upon a stay or halyard extending from the foremast or fore-topmast to the bowsprit or the jib boom.","pos":""},{"def":"The projecting arm of a crane, from which the load is suspended.","pos":""}],"JIBBER":[{"def":"A horse that jibs.","pos":""}],"JIBE":[{"def":"To shift, as the boom of a fore-and-aft sail, from one side of a vessel to the other when the wind is aft or on the quarter.","pos":""}],"JIFFY":[{"def":"A moment; an instant; as, I will be ready in a jiffy.","pos":""}],"JIG":[{"def":"A light, brisk musical movement.","pos":""},{"def":"A contrivance fastened to or inclosing a piece of work, and having hard steel surfaces to guide a tool, as a drill, or to form a shield or templet to work to, as in filing.","pos":""}],"JIGGER":[{"def":"A species of flea (Sarcopsylla, or Pulex, penetrans), which burrows beneath the skin.","pos":""}],"JIGGING":[{"def":"The act or using a jig; the act of separating ore with a jigger, or wire-bottomed sieve, which is moved up and down in water.","pos":""}],"JIGGISH":[{"def":"Resembling, or suitable for, a jig, or lively movement.","pos":""},{"def":"Playful; frisky.","pos":""}],"JIGGLE":[{"def":"To wriggle or frisk about; to move awkwardly; to shake up and down.","pos":""}],"JIGJOG":[{"def":"A jolting motion; a jogging pace.","pos":""}],"JILL":[{"def":"A young woman; a sweetheart.","pos":""}],"JILL-FLIRT":[{"def":"A light, giddy, or wanton girl or woman.","pos":""}],"JILT":[{"def":"A woman who capriciously deceives her lover; a coquette; a flirt.","pos":""}],"JIM CROW":[{"def":"A negro; -- said to be so called from a popular negro song and dance, the refrain of which is \"Wheel about and turn about and jump Jim Crow,\" produced in 1835 by T.","pos":""}],"JIM-CROW":[{"def":"A machine for bending or straightening rails.","pos":""},{"def":"A planing machine with a reversing tool, to plane both ways.","pos":""}],"JIMMY":[{"def":"A short crowbar used by burglars in breaking open doors.","pos":""}],"JIMP":[{"def":"Neat; handsome; elegant.","pos":""}],"JIMSON WEED":[{"def":"Jim\"son weed` Defn: .","pos":""}],"JINGAL":[{"def":"A small portable piece of ordnance, mounted on a swivel.","pos":""}],"JINGLE":[{"def":"To sound with a fine, sharp, rattling, clinking, or tinkling sound; as, sleigh bells jingle.","pos":""},{"def":"To rhyme or sound with a jingling effect.","pos":""}],"JINGLER":[{"def":"One who, or that which, jingles.","pos":""}],"JINGLING":[{"def":"The act or process of producing a jingle; also, the sound itself; a chink.","pos":""}],"JINGLINGLY":[{"def":"So as to jingle.","pos":""}],"JINGO":[{"def":"A word used as a jocular oath.","pos":""},{"def":"A statesman who pursues, or who favors, aggressive, domineering policy in foreign affairs.","pos":""}],"JINGOISM":[{"def":"The policy of the Jingoes, so called.","pos":""}],"JINK":[{"def":"To move quickly, esp.","pos":""}],"JINNEE":[{"def":"A genius or demon; one of the fabled genii, good and evil spirits, supposed to be the children of fire, and to have the power of assuming various forms.","pos":""}],"JINNY ROAD":[{"def":"An inclined road in a coal mine, on which loaded cars descend by gravity, drawing up empty ones.","pos":""}],"JINRIKISHA":[{"def":"A small, two-wheeled, hooded vehicle drawn by one more men.","pos":""}],"JINX":[{"def":"A person, object, influence, or supernatural being which is supposed to bring bad luck or to cause things to go wrong.","pos":""}],"JIPPO":[{"def":"A waistcoat or kind of stays for women.","pos":""}]}