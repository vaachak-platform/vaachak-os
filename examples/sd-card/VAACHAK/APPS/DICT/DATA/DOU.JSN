{"DOUANIER":[{"def":"An officer of the French customs.","pos":""}],"DOUAR":[{"def":"A village composed of Arab tents arranged in streets.","pos":""}],"DOUAY BIBLE":[{"def":"A translation of the Scriptures into the English language for the use of English-speaking Roman Catholics; -- done from the Latin Vulgate by English scholars resident in France.","pos":""}],"DOUBLE":[{"def":"Having the petals in a flower considerably increased beyond the natural number, usually as the result of cultivation and the expense of the stamens, or stamens and pistils.","pos":""}],"DOUBLE DEALER":[{"def":"One who practices double dealing; a deceitful, trickish person.","pos":""}],"DOUBLE DEALING":[{"def":"False or deceitful dealing.","pos":""}],"DOUBLE PEDRO":[{"def":"Cinch (the game).","pos":""}],"DOUBLE-ACTING":[{"def":"Acting or operating in two directions or with both motions; producing a twofold result; as, a double-acting engine or pump.","pos":""}],"DOUBLE-BANK":[{"def":"To row by rowers sitting side by side in twos on a bank or thwart.","pos":""}],"DOUBLE-BANKED":[{"def":"Applied to a kind of rowing in which the rowers sit side by side in twos, a pair of oars being worked from each bank or thwart.","pos":""},{"def":"Having two barrels; -- applied to a gun.","pos":""}],"DOUBLE-BEAT VALVE":[{"def":"See under Valve.","pos":""}],"DOUBLE-BREASTED":[{"def":"Folding or lapping over on the breast, with a row of buttons and buttonholes on each side; as, a double-breasted coat.","pos":""}],"DOUBLE-CHARGE":[{"def":"To load with a double charge, as of gunpowder.","pos":""}],"DOUBLE-DECKER":[{"def":"A man-of-war having two gun decks.","pos":""}],"DOUBLE-DYE":[{"def":"To dye again or twice over.","pos":""}],"DOUBLE-DYED":[{"def":"Dyed twice; thoroughly or intensely colored; hence; firmly fixed in opinions or habits; as, a double-dyed villain.","pos":""}],"DOUBLE-ENDER":[{"def":"A locomotive with pilot at each end.","pos":""}],"DOUBLE-ENTENDRE":[{"def":"A word or expression admitting of a double interpretation, one of which is often obscure or indelicate.","pos":""}],"DOUBLE-EYED":[{"def":"Having a deceitful look.","pos":""}],"DOUBLE-FACED":[{"def":"Having two faces designed for use; as, a double-faced hammer.","pos":""},{"def":"Deceitful; hypocritical; treacherous.","pos":""}],"DOUBLE-HANDED":[{"def":"Having two hands.","pos":""},{"def":"Deceitful; deceptive.","pos":""}],"DOUBLE-HEADED":[{"def":"Having two heads; bicipital.","pos":""}],"DOUBLE-HUNG":[{"def":"Having both sashes hung with weights and cords; -- said of a window.","pos":""}],"DOUBLE-LOCK":[{"def":"To lock with two bolts; to fasten with double security.","pos":""}],"DOUBLE-MILLED":[{"def":"Twice milled or fulled, to render more compact or fine; -- said of cloth; as, double-milled kerseymere.","pos":""}],"DOUBLE-QUICK":[{"def":"Of, or performed in, the fastest time or step in marching, next to the run; as, a double-quick step or march.","pos":""}],"DOUBLE-RIPPER":[{"def":"A kind of coasting sled, made of two sleds fastened together with a board, one before the other.","pos":""}],"DOUBLE-SHADE":[{"def":"To double the natural darkness of (a place).","pos":""}],"DOUBLE-SURFACED":[{"def":"Having two surfaces; -- said specif.","pos":""}],"DOUBLE-TONGUE":[{"def":"Deceit; duplicity.","pos":""}],"DOUBLE-TONGUED":[{"def":"Making contrary declarations on the same subject; deceitful.","pos":""}],"DOUBLE-TONGUING":[{"def":"A peculiar action of the tongue by flute players in articulating staccato notes; also, the rapid repetition of notes in cornet playing.","pos":""}],"DOUBLEGANGER":[{"def":"An apparition or double of a living person; a doppelgänger.","pos":""}],"DOUBLEHEARTED":[{"def":"Having a false heart; deceitful; treacherous.","pos":""}],"DOUBLEMINDED":[{"def":"Having different minds at different times; unsettled; undetermined.","pos":""}],"DOUBLENESS":[{"def":"The state of being double or doubled.","pos":""},{"def":"Duplicity; insincerity.","pos":""}],"DOUBLER":[{"def":"An instrument for augmenting a very small quantity of electricity, so as to render it manifest by sparks or the electroscope.","pos":""}],"DOUBLET":[{"def":"A word or words unintentionally doubled or set up a second time.","pos":""},{"def":"A counterfeit gem, composed of two pieces of crystal, with a color them, and thus giving the appearance of a naturally colored gem.","pos":""}],"DOUBLETHREADED":[{"def":"Having two screw threads instead of one; -- said of a screw in which the pitch is equal to twice the distance between the centers of adjacent threads.","pos":""}],"DOUBLETREE":[{"def":"The bar, or crosspiece, of a carriage, to which the singletrees are attached.","pos":""}],"DOUBLETS":[{"def":"See Doublet, 6 and 7.","pos":""}],"DOUBLING":[{"def":"The lining of the mantle borne about the shield or escutcheon.","pos":""}],"DOUBLOON":[{"def":"A Spanish gold coin, no longer issued, varying in value at different times from over fifteen dollars to about five.","pos":""}],"DOUBLY":[{"def":"In twice the quantity; to twice the degree; as, doubly wise or good; to be doubly sensible of an obligation.","pos":""}],"DOUBT":[{"def":"To waver in opinion or judgment; to be in uncertainty as to belief respecting anything; to hesitate in belief; to be undecided as to the truth of the negative or the affirmative proposition; to b e undetermined.","pos":""},{"def":"To suspect; to fear; to be apprehensive.","pos":""}],"DOUBTABLE":[{"def":"Capable of being doubted; questionable.","pos":""},{"def":"Worthy of being feared; redoubtable.","pos":""}],"DOUBTANCE":[{"def":"State of being in doubt; uncertainty; doubt.","pos":""}],"DOUBTER":[{"def":"One who doubts; one whose opinion is unsettled; one who scruples.","pos":""}],"DOUBTFUL":[{"def":"Not settled in opinion; undetermined; wavering; hesitating in belief; also used, metaphorically, of the body when its action is affected by such a state of mind; as, we are doubtful of a fact, or of the propriety of a measure.","pos":""},{"def":"Admitting of doubt; not obvious, clear, or certain; questionable; not decided; not easy to be defined, classed, or named; as, a doubtful case, hue, claim, title, species, and the like.","pos":""}],"DOUBTFULLY":[{"def":"In a doubtful manner.","pos":""}],"DOUBTFULNESS":[{"def":"State of being doubtful.","pos":""},{"def":"Uncertainty of meaning; ambiguity; indefiniteness.","pos":""}],"DOUBTING":[{"def":"That is uncertain; that distrusts or hesitates; having doubts.","pos":""}],"DOUBTLESS":[{"def":"Free from fear or suspicion.","pos":""}],"DOUC":[{"def":"A monkey (Semnopithecus nemæus), remarkable for its varied and brilliant colors.","pos":""}],"DOUCE":[{"def":"Sweet; pleasant.","pos":""},{"def":"Sober; prudent; sedate; modest.","pos":""}],"DOUCEPERE":[{"def":"One of the twelve peers of France, companions of Charlemagne in war.","pos":""}],"DOUCEUR":[{"def":"Gentleness and sweetness of manner; agreeableness.","pos":""},{"def":"A gift for service done or to be done; an honorarium; a present; sometimes, a bribe.","pos":""}],"DOUCHE":[{"def":"A jet or current of water or vapor directed upon some part of the body to benefit it medicinally; a douche bath.","pos":""}],"DOUCINE":[{"def":"Same as Cyma, under Cyma.","pos":""}],"DOUCKER":[{"def":"A grebe or diver; -- applied also to the golden-eye, pochard, scoter, and other ducks.","pos":""}],"DOUGH":[{"def":"Paste of bread; a soft mass of moistened flour or meal, kneaded or unkneaded, but not yet baked; as, to knead dough.","pos":""},{"def":"Anything of the consistency of such paste.","pos":""}],"DOUGH-BAKED":[{"def":"Imperfectly baked; hence, not brought to perfection; unfinished; also, of weak or dull understanding.","pos":""}],"DOUGH-FACED":[{"def":"Easily molded; pliable.","pos":""}],"DOUGH-KNEADED":[{"def":"Like dough; soft.","pos":""}],"DOUGHBIRD":[{"def":"The Eskimo curlew (Numenius borealis).","pos":""}],"DOUGHFACE":[{"def":"A contemptuous nickname for a timid, yielding politician, or one who is easily molded.","pos":""}],"DOUGHFACEISM":[{"def":"The character of a doughface; truckling pliability.","pos":""}],"DOUGHINESS":[{"def":"The quality or state of being doughy.","pos":""}],"DOUGHNUT":[{"def":"A small cake (usually sweetened) fried in a kettle of boiling lard.","pos":""}],"DOUGHTILY":[{"def":"In a doughty manner.","pos":""}],"DOUGHTINESS":[{"def":"The quality of being doughty; valor; bravery.","pos":""}],"DOUGHTY":[{"def":"Able; strong; valiant; redoubtable; as, a doughty hero.","pos":""}],"DOUGHY":[{"def":"Like dough; soft and heavy; pasty; crude; flabby and pale; as, a doughy complexion.","pos":""}],"DOULOCRACY":[{"def":"A government by slaves.","pos":""}],"DOUM PALM":[{"def":"Doum\" palm` (doom\" päm`).","pos":""}],"DOUPE":[{"def":"The carrion crow.","pos":""}],"DOUR":[{"def":"Hard; inflexible; obstinate; sour in aspect; hardy; bold.","pos":""}],"DOURA":[{"def":"A kind of millet.","pos":""}],"DOUSE":[{"def":"To strike or lower in haste; to slacken suddenly; as, douse the topsail.","pos":""}],"DOUSING-CHOCK":[{"def":"One of several pieces fayed across the apron and lapped in the knightheads, or inside planking above the upper deck.","pos":""}],"DOUTER":[{"def":"An extinguisher for candles.","pos":""}]}