{"NET":[{"def":"A figure made up of a large number of straight lines or curves, which are connected at certain points and related to each other by some specified law.","pos":""}],"NET-VEINED":[{"def":"Having veins, or nerves, reticulated or netted; as, a net- veined wing or leaf.","pos":""}],"NETHER":[{"def":"Situated down or below; lying beneath, or in the lower part; having a lower position; belonging to the region below; lower; under; -- opposed to upper.","pos":""}],"NETHERMOST":[{"def":"Lowest; as, the nethermost abyss.","pos":""}],"NETHINIM":[{"def":"Servants of the priests and Levites in the menial services about the tabernacle and temple.","pos":""}],"NETIFY":[{"def":"To render neat; to clean; to put in order.","pos":""}],"NETSUKE":[{"def":"In Japanese costume and decorative art, a small object carved in wood, ivory, bone, or horn, or wrought in metal, and pierced with holes for cords by which it is connected, for convenience, with the inro, the smoking pouch (tabako-ire), and similar objects carried in the girdle.","pos":""}],"NETTING":[{"def":"A network of ropes used for various purposes, as for holding the hammocks when not in use, also for stowing sails, and for hoisting from the gunwale to the rigging to hinder an enemy from boarding.","pos":""}],"NETTLE":[{"def":"A plant of the genus Urtica, covered with minute sharp hairs containing a poison that produces a stinging sensation.","pos":""}],"NETTLEBIRD":[{"def":"the European whitethroat.","pos":""}],"NETTLER":[{"def":"One who nettles.","pos":""}],"NETTLING":[{"def":"Stinging; irritating.","pos":""}],"NETTY":[{"def":"Like a net, or network; netted.","pos":""}],"NETWORK":[{"def":"A fabric of threads, cords, or wires crossing each other at certain intervals, and knotted or secured at the crossings, thus leaving spaces or meshes between them.","pos":""},{"def":"Any system of lines or channels interlacing or crossing like the fabric of a net; as, a network of veins; a network of railroads.","pos":""}]}