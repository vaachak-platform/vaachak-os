{"SHARD":[{"def":"The hard wing case of a beetle.","pos":""}],"SHARD-BORNE":[{"def":"Borne on shards or scaly wing cases.","pos":""}],"SHARDED":[{"def":"Having elytra, as a beetle.","pos":""}],"SHARDY":[{"def":"Having, or consisting of, shards.","pos":""}],"SHARE":[{"def":"The part (usually an iron or steel plate) of a plow which cuts the ground at the bottom of a furrow; a plowshare.","pos":""},{"def":"The part which opens the ground for the reception of the seed, in a machine for sowing seed.","pos":""}],"SHAREBEAM":[{"def":"The part of the plow to which the share is attached.","pos":""}],"SHAREBONE":[{"def":"The public bone.","pos":""}],"SHAREBROKER":[{"def":"A broker who deals in railway or other shares and securities.","pos":""}],"SHAREHOLDER":[{"def":"One who holds or owns a share or shares in a joint fund or property.","pos":""}],"SHARER":[{"def":"One who shares; a participator; a partaker; also, a divider; a distributer.","pos":""}],"SHAREWORT":[{"def":"A composite plant (Aster Tripolium) growing along the seacoast of Europe.","pos":""}],"SHARK":[{"def":"Any one of numerous species of elasmobranch fishes of the order Plagiostomi, found in all seas.","pos":""}],"SHARKER":[{"def":"One who lives by sharking.","pos":""}],"SHARKING":[{"def":"Petty rapine; trick; also, seeking a livelihood by shifts and dishonest devices.","pos":""}],"SHARP":[{"def":"Uttered in a whisper, or with the breath alone, without voice, as certain consonants, such as p, k, t, f; surd; nonvocal; aspirated.","pos":""}],"SHARP-CUT":[{"def":"Cut sharply or definitely, or so as to make a clear, well- defined impression, as the lines of an engraved plate, and the like; clear-cut; hence, having great distinctness; well-defined; clear.","pos":""}],"SHARP-SET":[{"def":"Eager in appetite or desire of gratification; affected by keen hunger; ravenous; as, an eagle or a lion sharp-set.","pos":""}],"SHARP-SIGHTED":[{"def":"Having quick or acute sight; -- used literally and figuratively.","pos":""}],"SHARP-WITTED":[{"def":"Having an acute or nicely discerning mind.","pos":""}],"SHARPEN":[{"def":"He that wrestles with us strengthens our nerves and sharpens our skill.","pos":""}],"SHARPER":[{"def":"A person who bargains closely, especially, one who cheats in bargains; a swinder; also, a cheating gamester.","pos":""}],"SHARPIE":[{"def":"A long, sharp, flat-bottomed boat, with one or two masts carrying a triangular sail.","pos":""}],"SHARPLY":[{"def":"In a sharp manner,; keenly; acutely.","pos":""}],"SHARPNESS":[{"def":"The quality or condition of being sharp; keenness; acuteness.","pos":""}],"SHARPSAW":[{"def":"The great titmouse; -- so called from its harsh call notes.","pos":""}],"SHARPSHOOTER":[{"def":"One skilled in shooting at an object with exactness; a good marksman.","pos":""}],"SHARPSHOOTING":[{"def":"A shooting with great precision and effect; hence, a keen contest of wit or argument.","pos":""}]}