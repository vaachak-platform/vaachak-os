{"KIT":[{"def":"Prince Turveydrop then tinkled the strings of his kit with his fingers, and the young ladies stood up to dance.","pos":""}],"KITCAT":[{"def":"Designating a club in London, to which Addison and Steele belonged; -- so called from Christopher Cat, a pastry cook, who served the club with mutton pies.","pos":""},{"def":"Designating a canvas used for portraits of a peculiar size, viz.","pos":""}],"KITCHEN":[{"def":"A cookroom; the room of a house appropriated to cookery.","pos":""},{"def":"A utensil for roasting meat; as, a tin kitchen.","pos":""}],"KITCHEN MIDDENS":[{"def":"Relics of neolithic man found on the coast of Denmark, consisting of shell mounds, some of which are ten feet high, one thousand feet long, and two hundred feet wide.","pos":""}],"KITCHEN-RY":[{"def":"The body of servants employed in the kitchen.","pos":""}],"KITCHENER":[{"def":"A kitchen servant; a cook.","pos":""}],"KITCHENETTE":[{"def":"A room combining a very small kitchen and a pantry, with the kitchen conveniences compactly arranged, sometimes so that they fold up out of sight and allow the kitchen to be made a part of the adjoining room by opening folding doors.","pos":""}],"KITCHENMAID":[{"def":"A woman employed in the kitchen.","pos":""}],"KITE":[{"def":"Any raptorial bird of the subfamily Milvinæ, of which many species are known.","pos":""},{"def":"A lofty sail, carried only when the wind is light.","pos":""}],"KITH":[{"def":"Acquaintance; kindred.","pos":""}],"KITISH":[{"def":"Like or relating to a kite.","pos":""}],"KITLING":[{"def":"A young kitten; a whelp.","pos":""}],"KITTEN":[{"def":"To bring forth young, as a cat; to bring forth, as kittens.","pos":""}],"KITTENISH":[{"def":"Resembling a kitten; playful; as, a kittenish disposition.","pos":""}],"KITTIWAKE":[{"def":"A northern gull (Rissa tridactyla), inhabiting the coasts of Europe and America.","pos":""}],"KITTLE":[{"def":"To bring forth young, as a cat; to kitten; to litter.","pos":""}],"KITTLISH":[{"def":"Ticklish; kittle.","pos":""}],"KITTY":[{"def":"A kitten; also, a pet name or calling name for the cat.","pos":""}],"KITTYSOL":[{"def":"The Chinese paper parasol.","pos":""}]}