{"QUAS":[{"def":"The brown coati.","pos":""}],"QUASH":[{"def":"To abate, annul, overthrow, or make void; as, to quash an indictment.","pos":""}],"QUASHEE":[{"def":"A negro of the West Indies.","pos":""}],"QUASI CORPORATION":[{"def":"A corporation consisting of a person or body of persons invested with some of the qualities of an artificial person, though not expressly incorporated, esp.","pos":""}],"QUASIMODO":[{"def":"The first Sunday after Easter; Low Sunday.","pos":""}],"QUASS":[{"def":"A thin, sour beer, made by pouring warm water on rye or barley meal and letting it ferment, -- much used by the Russians.","pos":""}],"QUASSATION":[{"def":"The act of shaking, or the state of being shaken.","pos":""}],"QUASSIA":[{"def":"The wood of several tropical American trees of the order Simarubeæ, as Quassia amara, Picræna excelsa, and Simaruba amara.","pos":""}],"QUASSIN":[{"def":"The bitter principle of quassia, extracted as a white crystalline substance; -- formerly called quassite.","pos":""}]}