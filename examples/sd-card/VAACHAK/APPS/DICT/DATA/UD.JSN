{"UDAL":[{"def":"In Shetland and Orkney, a freehold; property held by udal, or allodial, right.","pos":""}],"UDDER":[{"def":"The glandular organ in which milk is secreted and stored; -- popularly called the bag in cows and other quadrupeds.","pos":""}],"UDDERED":[{"def":"Having an udder or udders.","pos":""}],"UDDERLESS":[{"def":"Destitute or deprived of an udder.","pos":""},{"def":"Hence, without mother's milk; motherless; as, udderless lambs.","pos":""}]}