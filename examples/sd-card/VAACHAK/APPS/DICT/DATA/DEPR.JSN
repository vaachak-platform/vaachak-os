{"DEPRAVATION":[{"def":"Change for the worse; deterioration; morbid perversion.","pos":""}],"DEPRAVE":[{"def":"To speak ill of; to depreciate; to malign; to revile.","pos":""},{"def":"To make bad or worse; to vitiate; to corrupt.","pos":""}],"DEPRAVEDLY":[{"def":"In a depraved manner.","pos":""}],"DEPRAVER":[{"def":"One who deprave or corrupts.","pos":""}],"DEPRAVINGLY":[{"def":"In a depraving manner.","pos":""}],"DEPRAVITY":[{"def":"The stae of being depraved or corrupted; a vitiated state of moral character; general badness of character; wickedness of mind or heart; absence of religious feeling and principle.","pos":""}],"DEPRECABLE":[{"def":"That may or should be deprecated.","pos":""}],"DEPRECATE":[{"def":"To pray against, as an evil; to seek to avert by player; to desire the removal of; to seek deliverance from; to express deep regret for; to disapprove of strongly.","pos":""}],"DEPRECATINGLY":[{"def":"In a deprecating manner.","pos":""}],"DEPRECATION":[{"def":"The act of deprecating; a praying against evil; prayer that an evil may be removed or prevented; strong expression of disapprobation.","pos":""},{"def":"Entreaty for pardon; petitioning.","pos":""}],"DEPRECATIVE":[{"def":"Serving to deprecate; deprecatory.","pos":""}],"DEPRECATOR":[{"def":"One who deprecates.","pos":""}],"DEPRECATORY":[{"def":"Serving to deprecate; tending to remove or avert evil by prayer; apologetic.","pos":""}],"DEPRECIATE":[{"def":"To lessen in price or estimated value; to lower the worth of; to represent as of little value or claim to esteem; to undervalue.","pos":""}],"DEPRECIATION":[{"def":"The act of lessening, or seeking to lessen, price, value, or reputation.","pos":""},{"def":"The falling of value; reduction of worth.","pos":""}],"DEPRECIATIVE":[{"def":"Tending, or intended, to depreciate; expressing depreciation; undervaluing.","pos":""}],"DEPRECIATOR":[{"def":"One who depreciates.","pos":""}],"DEPRECIATORY":[{"def":"Tending to depreciate; undervaluing; depreciative.","pos":""}],"DEPREDABLE":[{"def":"Liable to depredation.","pos":""}],"DEPREDATE":[{"def":"To subject to plunder and pillage; to despoil; to lay waste; to prey upon.","pos":""}],"DEPREDATION":[{"def":"The act of depredating, or the state of being depredated; the act of despoiling or making inroads; as, the sea often makes depredation on the land.","pos":""}],"DEPREDATOR":[{"def":"One who plunders or pillages; a spoiler; a robber.","pos":""}],"DEPREDATORY":[{"def":"Tending or designed to depredate; characterized by depredation; plundering; as, a depredatory incursion.","pos":""}],"DEPREDICATE":[{"def":"To proclaim; to celebrate.","pos":""}],"DEPREHEND":[{"def":"To take unwares or by surprise; to seize, as a person commiting an unlawful act; to catch; to apprehend.","pos":""},{"def":"To detect; to discover; to find out.","pos":""}],"DEPREHENSIBLE":[{"def":"That may be caught or discovered; apprehensible.","pos":""}],"DEPREHENSION":[{"def":"A catching; discovery.","pos":""}],"DEPRESS":[{"def":"To reduce (an equation) in a lower degree.","pos":""}],"DEPRESSANT":[{"def":"An agent or remedy which lowers the vital powers.","pos":""}],"DEPRESSED":[{"def":"Having the vertical diameter shorter than the horizontal or transverse; -- said of the bodies of animals, or of parts of the bodies.","pos":""}],"DEPRESSINGLY":[{"def":"In a depressing manner.","pos":""}],"DEPRESSION":[{"def":"The angular distance of a celestial object below the horizon.","pos":""},{"def":"The operation of reducing to a lower degree; -- said of equations.","pos":""}],"DEPRESSIVE":[{"def":"Able or tending to depress or cast down.","pos":""}],"DEPRESSOMOTOR":[{"def":"Depressing or diminishing the capacity for movement, as depressomotor nerves, which lower or inhibit muscular activity.","pos":""},{"def":"Any agent that depresses the activity of the motor centers, as bromides, etc.","pos":""}],"DEPRESSOR":[{"def":"A muscle that depresses or tends to draw down a part.","pos":""}],"DEPRIMENT":[{"def":"Serving to depress.","pos":""}],"DEPRISURE":[{"def":"Low estimation; disesteem; contempt.","pos":""}],"DEPRIVABLE":[{"def":"Capable of being, or liable to be, deprived; liable to be deposed.","pos":""}],"DEPRIVATION":[{"def":"the taking away from a clergyman his benefice, or other spiritual promotion or dignity.","pos":""}],"DEPRIVE":[{"def":"To take away; to put an end; to destroy.","pos":""},{"def":"To dispossess; to bereave; to divest; to hinder from possessing; to debar; to shut out from; -- with a remoter object, usually preceded by of.","pos":""}],"DEPRIVER":[{"def":"One who, or that which, deprives.","pos":""}],"DEPROSTRATE":[{"def":"Fully prostrate; humble; low; rude.","pos":""}],"DEPROVINCIALIZE":[{"def":"To divest of provincial quality or characteristics.","pos":""}]}