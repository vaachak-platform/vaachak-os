{"TIN":[{"def":"An elementary substance found as an oxide in the mineral cassiterite, and reduced as a soft white crystalline metal, malleable at ordinary temperatures, but brittle when heated.","pos":""}],"TINAMIDES":[{"def":"A division of struthious birds, including the tinamous.","pos":""}],"TINAMOU":[{"def":"Any one of several species of South American birds belonging to Tinamus and allied genera.","pos":""}],"TINCAL":[{"def":"Crude native borax, formerly imported from Thibet.","pos":""}],"TINCHEL":[{"def":"A circle of sportsmen, who, by surrounding an extensive space and gradually closing in, bring a number of deer and game within a narrow compass.","pos":""}],"TINCT":[{"def":"Color; tinge; tincture; tint.","pos":""}],"TINCTORIAL":[{"def":"Of or relating to color or colors; imparting a color; as, tinctorial matter.","pos":""}],"TINCTURE":[{"def":"One of the metals, colors, or furs used in armory.","pos":""},{"def":"A solution (commonly colored) of medicinal substance in alcohol, usually more or less diluted; spirit containing medicinal substances in solution.","pos":""}],"TINDAL":[{"def":"A petty officer among lascars, or native East Indian sailors; a boatswain's mate; a cockswain.","pos":""},{"def":"An attendant on an army.","pos":""}],"TINDER":[{"def":"Something very inflammable, used for kindling fire from a spark, as scorched linen.","pos":""}],"TINE":[{"def":"Trouble; distress; teen.","pos":""}],"TINEA":[{"def":"A name applied to various skin diseases, but especially to ringworm.","pos":""},{"def":"A genus of small Lepidoptera, including the clothes moths and carpet moths.","pos":""}],"TINEAN":[{"def":"Any species of Tinea, or of the family Tineidæ, which includes numerous small moths, many of which are injurious to woolen and fur goods and to cultivated plants.","pos":""}],"TINED":[{"def":"Furnished with tines; as, a three-tined fork.","pos":""}],"TINEMAN":[{"def":"An officer of the forest who had the care of vert and venison by night.","pos":""}],"TINET":[{"def":"Brushwood and thorns for making and repairing hedges.","pos":""}],"TING":[{"def":"A sharp sound, as of a bell; a tinkling.","pos":""}],"TINGE":[{"def":"His [Sir Roger's] virtues, as well as imperfections, are tinged by a certain extravagance.","pos":""}],"TINGENT":[{"def":"Having the power to tinge.","pos":""}],"TINGER":[{"def":"One who, or that which, tinges.","pos":""}],"TINGID":[{"def":"Of or pertaining to the genus Tingis.","pos":""}],"TINGIS":[{"def":"A genus of small hemipterous insects which injure trees by sucking the sap from the leaves.","pos":""}],"TINGLE":[{"def":"To feel a kind of thrilling sensation, as in hearing a shrill sound.","pos":""},{"def":"To feel a sharp, thrilling pain.","pos":""}],"TINK":[{"def":"To make a sharp, shrill noise; to tinkle.","pos":""}],"TINKER":[{"def":"A small mortar on the end of a staff.","pos":""},{"def":"The razor-billed auk.","pos":""}],"TINKERING":[{"def":"The act or work of a tinker.","pos":""}],"TINKERLY":[{"def":"After the manner of a tinker.","pos":""},{"def":"The common guillemot.","pos":""}],"TINKLE":[{"def":"To make, or give forth, small, quick, sharp sounds, as a piece of metal does when struck; to clink.","pos":""},{"def":"To hear, or resound with, a small, sharp sound.","pos":""}],"TINKLING":[{"def":"A grackle (Quiscalus crassirostris) native of Jamaica.","pos":""}],"TINMAN":[{"def":"A manufacturer of tin vessels; a dealer in tinware.","pos":""}],"TINNED":[{"def":"Covered, or plated, with tin; as, a tinned roof; tinned iron.","pos":""},{"def":"Packed in tin cases; canned; as, tinned meats.","pos":""}],"TINNEN":[{"def":"Made or consisting of tin.","pos":""}],"TINNER":[{"def":"One who works in a tin mine.","pos":""},{"def":"One who makes, or works in, tinware; a tinman.","pos":""}],"TINNIENT":[{"def":"Emitting a clear sound.","pos":""}],"TINNING":[{"def":"The act, art, or process of covering or coating anything with melted tin, or with tin foil, as kitchen utensils, locks, and the like.","pos":""},{"def":"The covering or lining of tin thus put on.","pos":""}],"TINNITUS":[{"def":"A ringing, whistling, or other imaginary noise perceived in the ears; -- called also tinnitus aurium.","pos":""}],"TINNOCK":[{"def":"The blue titmouse.","pos":""}],"TINNY":[{"def":"Pertaining to, abounding with, or resembling, tin.","pos":""}],"TINSEL":[{"def":"A shining material used for ornamental purposes; especially, a very thin, gauzelike cloth with much gold or silver woven into it; also, very thin metal overlaid with a thin coating of gold or silver, brass foil, or the like.","pos":""},{"def":"Something shining and gaudy; something superficially shining and showy, or having a false luster, and more gay than valuable.","pos":""}],"TINSELLY":[{"def":"Like tinsel; gaudy; showy, but cheap.","pos":""}],"TINSMITH":[{"def":"One who works in tin; a tinner.","pos":""}],"TINT":[{"def":"A slight coloring.","pos":""}],"TINTAMAR":[{"def":"A hideous or confused noise; an uproar.","pos":""}],"TINTERNELL":[{"def":"A certain old dance.","pos":""}],"TINTIE":[{"def":"Having or making the sound of a bell; tinkling.","pos":""}],"TINTINNABULATION":[{"def":"A tinkling sound, as of a bell or bells.","pos":""}],"TINTINNABULOUS":[{"def":"Of, pertaining to, or resembling, the tinkling of a bell; having a tinkling sound; tintinnabular.","pos":""}],"TINTINNABULUM":[{"def":"A bell; also, a set or combination of bells or metal plates used as a musical instrument or as a toy.","pos":""}],"TINTO":[{"def":"A red Madeira wine, wanting the high aroma of the white sorts, and, when old, resembling tawny port.","pos":""}],"TINTOMETER":[{"def":"An apparatus for the determination of colors by comparison with arbitrary standards; a colorimeter.","pos":""}],"TINTYPE":[{"def":"Same as Ferrotype.","pos":""}],"TINWARE":[{"def":"Articles made of tinned iron.","pos":""}],"TINY":[{"def":"Very small; little; puny.","pos":""}]}