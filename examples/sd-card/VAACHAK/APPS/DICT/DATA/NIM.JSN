{"NIM":[{"def":"To take; to steal; to filch.","pos":""}],"NIMBIFEROUS":[{"def":"Serving to bring clouds or stormy weather.","pos":""}],"NIMBLE":[{"def":"Light and quick in motion; moving with ease and celerity; lively; swift.","pos":""}],"NIMBLENESS":[{"def":"The quality of being nimble; lightness and quickness in motion; agility; swiftness.","pos":""}],"NIMBLY":[{"def":"In a nimble manner; with agility; with light, quick motion.","pos":""}],"NIMBOSE":[{"def":"Cloudy; stormy; tempestuous.","pos":""}],"NIMBUS":[{"def":"A circle, or disk, or any indication of radiant light around the heads of divinities, saints, and sovereigns, upon medals, pictures, etc.","pos":""},{"def":"A rain cloud; one of the four principal varieties of clouds.","pos":""}],"NIMIETY":[{"def":"State of being in excess.","pos":""}],"NIMIOUS":[{"def":"Excessive; extravagant; inordinate.","pos":""}]}