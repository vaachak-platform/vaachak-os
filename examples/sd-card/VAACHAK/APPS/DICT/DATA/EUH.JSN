{"EUHARMONIC":[{"def":"Producing mathematically perfect harmony or concord; sweetly or perfectly harmonious.","pos":""}],"EUHEMERISM":[{"def":"The theory, held by Euhemerus, that the gods of mythology were but deified mortals, and their deeds only the amplification in imagination of human acts.","pos":""}],"EUHEMERIST":[{"def":"One who advocates euhemerism.","pos":""}],"EUHEMERISTIC":[{"def":"Of or pertaining to euhemerism.","pos":""}],"EUHEMERIZE":[{"def":"To interpret (mythology) on the theory of euhemerism.","pos":""}]}