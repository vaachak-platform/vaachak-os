{"EXTRA":[{"def":"Beyond what is due, usual, expected, or necessary; additional; supernumerary; also, extraordinarily good; superior; as, extra work; extra pay.","pos":""}],"EXTRA-":[{"def":"A Latin preposition, denoting beyond, outside of; -- often used in composition as a prefix signifying outside of, beyond, besides, or in addition to what is denoted by the word to which it is prefixed.","pos":""}],"EXTRA-OCULAR":[{"def":"Inserted exterior to the eyes; -- said of the antennæ of certain insects.","pos":""}],"EXTRA-OFFICIAL":[{"def":"Not prescribed by official duty.","pos":""}],"EXTRA-UTERINE":[{"def":"Outside of the uterus, or womb.","pos":""}],"EXTRAARTICULAR":[{"def":"Situated outside of a joint.","pos":""},{"def":"Growing outside of the axils; as, an extra-axillary bud.","pos":""}],"EXTRABRANCHIAL":[{"def":"Outside of the branchial arches; -- said of the cartilages thus placed in some fishes.","pos":""}],"EXTRACAPSULAR":[{"def":"Situated outside of a capsule, esp.","pos":""}],"EXTRACT":[{"def":"To draw out or forth; to pull out; to remove forcibly from a fixed position, as by traction or suction, etc.","pos":""},{"def":"To withdraw by expression, distillation, or other mechanical or chemical process; as, to extract an essence.","pos":""}],"EXTRACTIFORM":[{"def":"Having the form, appearance, or nature, of an extract.","pos":""}],"EXTRACTION":[{"def":"The act of extracting, or drawing out; as, the extraction of a tooth, of a bone or an arrow from the body, of a stump from earth, of a passage from a book, of an essence or tincture.","pos":""},{"def":"Derivation from a stock or family; lineage; descent; birth; the stock from which one has descended.","pos":""}],"EXTRACTIVE":[{"def":"Capable of being extracted.","pos":""},{"def":"Tending or serving to extract or draw out.","pos":""}],"EXTRACTOR":[{"def":"One who, or that which, extracts; as: (a) (Surg.","pos":""}],"EXTRADICTIONARY":[{"def":"Consisting not in words, but in realities.","pos":""}],"EXTRADITABLE":[{"def":"Subject, or liable, to extradition, as a fugitive from justice.","pos":""},{"def":"Making liable to extradition; as, extraditable offenses.","pos":""}],"EXTRADITE":[{"def":"To deliver up by one government to another, as a fugitive from justice.","pos":""}],"EXTRADITION":[{"def":"The surrender or delivery of an alleged criminal by one State or sovereignty to another having jurisdiction to try charge.","pos":""}],"EXTRADOS":[{"def":"The exterior curve of an arch; esp.","pos":""}],"EXTRADOTAL":[{"def":"Forming no part of the dowry; as, extradotal property.","pos":""}],"EXTRAFOLIACEOUS":[{"def":"Away from the leaves, or inserted in a different place from them; as, extrafoliaceous prickles.","pos":""}],"EXTRAFORANEOUS":[{"def":"Pertaining to that which is out of doors.","pos":""}],"EXTRAGENEOUS":[{"def":"Belonging to another race or kind.","pos":""}],"EXTRAJUDICIAL":[{"def":"Out of or beyond the proper authority of a court or judge; beyond jurisdiction; not legally required.","pos":""}],"EXTRAJUDICIAL CONVEYANCE":[{"def":"A conveyance, as by deed, effected by the act of the parties and not involving, as in the fine and recovery, judicial proceedings.","pos":""}],"EXTRALIMITARY":[{"def":"Being beyond the limit or bounds; as, extraliminary land.","pos":""}],"EXTRALOGICAL":[{"def":"Lying outside of the domain of logic.","pos":""}],"EXTRAMISSION":[{"def":"A sending out; emission.","pos":""}],"EXTRAMUNDANE":[{"def":"Beyond the material world.","pos":""}],"EXTRAMURAL":[{"def":"Outside of the walls, as of a fortified or walled city.","pos":""}],"EXTRANEITY":[{"def":"State of being without or beyond a thing; foreignness.","pos":""}],"EXTRANEOUS":[{"def":"Not belonging to, or dependent upon, a thing; without or beyond a thing; not essential or intrinsic; foreign; as, to separate gold from extraneous matter.","pos":""}],"EXTRAORDINARILY":[{"def":"In an extraordinary manner or degree.","pos":""}],"EXTRAORDINARINESS":[{"def":"The quality of being extraordinary.","pos":""}],"EXTRAORDINARY":[{"def":"Beyond or out of the common order or method; not usual, customary, regular, or ordinary; as, extraordinary evils; extraordinary remedies.","pos":""},{"def":"Exceeding the common degree, measure.","pos":""}],"EXTRAPAROCHIAL":[{"def":"Beyond the limits of a parish.","pos":""}],"EXTRAPHYSICAL":[{"def":"Not subject to physical laws or methods.","pos":""}],"EXTRAPROFESSIONAL":[{"def":"Foreign to a profession; not within the ordinary limits of professional duty or business.","pos":""}],"EXTRAPROVINCIAL":[{"def":"Not within of pertaining to the same province or jurisdiction.","pos":""}],"EXTRAREGULAR":[{"def":"Not comprehended within a rule or rules.","pos":""}],"EXTRASTAPEDIAL":[{"def":"Pertaining to a part of the columella of the ear, which, in many animals, projects beyond the connection with the stapes.","pos":""},{"def":"The extrastapedial part of columella.","pos":""}],"EXTRATERRITORIAL":[{"def":"Beyond the limits of a territory or particular jurisdiction; exterritorial.","pos":""}],"EXTRATERRITORIALITY":[{"def":"The state of being beyond the limits of a particular territory; esp.","pos":""},{"def":"a fiction by which a public minister, though actually in a foreign country, is supposed still to remain within the territory of his own sovereign or nation.","pos":""}],"EXTRATROPICAL":[{"def":"Beyond or outside of the tropics.","pos":""}],"EXTRAUGHT":[{"def":"Extracted; descended.","pos":""}],"EXTRAVAGANCE":[{"def":"A wandering beyond proper limits; an excursion or sally from the usual way, course, or limit.","pos":""},{"def":"The state of being extravagant, wild, or prodigal beyond bounds of propriety or duty; want of moderation; excess; especially, undue expenditure of money; vaid and superfluous expense; prodigality; as, extravagance of anger, love, expression, imagination, demands.","pos":""}],"EXTRAVAGANT":[{"def":"Wandering beyond one's bounds; roving; hence, foreign.","pos":""},{"def":"Exceeding due bounds; wild; excessive; unrestrained; as, extravagant acts, wishes, praise, abuse.","pos":""}],"EXTRAVAGANTLY":[{"def":"In an extravagant manner; wildly; excessively; profusely.","pos":""}],"EXTRAVAGANTNESS":[{"def":"The state of being extravagant or in excess; excess; extravagance.","pos":""}],"EXTRAVAGANZA":[{"def":"A composition, as in music, or in the drama, designed to produce effect by its wild irregularity; esp.","pos":""},{"def":"An extravagant flight of sentiment or language.","pos":""}],"EXTRAVAGATION":[{"def":"A wandering beyond limits; excess.","pos":""}],"EXTRAVASATE":[{"def":"To force or let out of the proper vessels or arteries, as blood.","pos":""}],"EXTRAVASATION":[{"def":"The act of forcing or letting out of its proper vessels or ducts, as a fluid; effusion; as, an extravasation of blood after a rupture of the vessels.","pos":""}],"EXTRAVENATE":[{"def":"Let out of the veins.","pos":""}],"EXTRAVERSION":[{"def":"The act of throwing out; the state of being turned or thrown out.","pos":""}],"EXTREME":[{"def":"Extended or contracted as much as possible; -- said of intervals; as, an extreme sharp second; an extreme flat forth.","pos":""}],"EXTREMELESS":[{"def":"Having no extremes; infinite.","pos":""}],"EXTREMELY":[{"def":"In an extreme manner or state; in the utmost degree; to the utmost point; exceedingly; as, extremely hot or cold.","pos":""}],"EXTREMIST":[{"def":"A supporter of extreme doctrines or practice; one who holds extreme opinions.","pos":""}],"EXTREMITY":[{"def":"One of locomotive appendages of an animal; a limb; a leg or an arm of man.","pos":""}],"EXTRICABLE":[{"def":"Capable of being extricated.","pos":""}],"EXTRICATE":[{"def":"To free, as from difficulties or perplexities; to disentangle; to disembarrass; as, to extricate a person from debt, peril, etc.","pos":""},{"def":"To cause to be emitted or evolved; as, to extricate heat or moisture.","pos":""}],"EXTRICATION":[{"def":"The act or process of extricating or disentangling; a freeing from perplexities; disentanglement.","pos":""},{"def":"The act of sending out or evolving.","pos":""}],"EXTRINSIC":[{"def":"Attached partly to an organ or limb and partly to some other partintrinsic.","pos":""}],"EXTRINSICAL":[{"def":"The state or quality of being extrinsic.","pos":""}],"EXTROITIVE":[{"def":"Seeking or going out after external objects.","pos":""}],"EXTRORSE":[{"def":"Facing outwards, or away from the axis of growth; -- said esp.","pos":""}],"EXTROVERSION":[{"def":"The condition of being turned wrong side out; as, extroversion of the bladder.","pos":""}],"EXTRUCTION":[{"def":"A building up; construction.","pos":""}],"EXTRUDE":[{"def":"To thrust out; to force, press, or push out; to expel; to drive off or away.","pos":""}],"EXTRUSION":[{"def":"The act of thrusting or pushing out; a driving out; expulsion.","pos":""}],"EXTRUSIVE":[{"def":"Forced out at the surface; as, extrusive rocks; -- contrasted with intrusive.","pos":""}]}