{"CROCEIN":[{"def":"A name given to any one of several yellow or scarlet dyestuffs of artificial production and complex structure.","pos":""}],"CROCEOUS":[{"def":"Of, pertaining to, or like, saffron; deep reddish yellow.","pos":""}],"CROCETIN":[{"def":"A dyestuff, obtained from the Chinese croicin, which produces a brilliant yellow.","pos":""}],"CROCHE":[{"def":"A little bud or knob at the top of a deer's antler.","pos":""}],"CROCHET":[{"def":"A kind of knitting done by means of a hooked needle, with worsted, silk, or cotton; crochet work.","pos":""}],"CROCIARY":[{"def":"One who carries the cross before an archbishop.","pos":""}],"CROCIDOLITE":[{"def":"A mineral occuring in silky fibers of a lavender blue color.","pos":""}],"CROCK":[{"def":"The loose black particles collected from combustion, as on pots and kettles, or in a chimney; soot; smut; also, coloring matter which rubs off from cloth.","pos":""}],"CROCKERY":[{"def":"Earthenware; vessels formed of baked clay, especially the coarser kinds.","pos":""}],"CROCKET":[{"def":"An ornament often resembling curved and bent foliage, projecting from the sloping edge of a gable, spire, etc.","pos":""}],"CROCKETED":[{"def":"Ornamented with crockets.","pos":""}],"CROCKETING":[{"def":"Ornamentation with crockets.","pos":""}],"CROCODILE":[{"def":"A large reptile of the genus Crocodilus, of several species.","pos":""},{"def":"A fallacious dilemma, mythically supposed to have been first used by a crocodile.","pos":""}],"CROCODILIA":[{"def":"An order of reptiles including the crocodiles, gavials, alligators, and many extinct kinds.","pos":""}],"CROCODILIAN":[{"def":"Like, or pertaining to, the crocodile; characteristic of the crocodile.","pos":""},{"def":"One of the Crocodilia.","pos":""}],"CROCODILITY":[{"def":"A caption or sophistical mode of arguing.","pos":""}],"CROCOISITE":[{"def":"Same as Crocoite.","pos":""}],"CROCOITE":[{"def":"Lead chromate occuring in crystals of a bright hyacinth red color; -- called also red lead ore.","pos":""}],"CROCONATE":[{"def":"A salt formed by the union of croconic acid with a base.","pos":""}],"CROCONIC":[{"def":"Of, pertaining to, or resembling saffron; having the color of saffron; as, croconic acid.","pos":""},{"def":"Pertaining to, or derived from, croconic acid.","pos":""}],"CROCOSE":[{"def":"A white crystalline sugar, metameric with glucose, obtained from the coloring matter of saffron.","pos":""}],"CROCUS":[{"def":"A genus of iridaceous plants, with pretty blossoms rising separately from the bulb or corm.","pos":""},{"def":"A deep yellow powder; the oxide of some metal calcined to a red or deep yellow color; esp.","pos":""}]}