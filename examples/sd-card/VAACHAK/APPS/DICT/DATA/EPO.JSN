{"EPOCH":[{"def":"A division of time characterized by the prevalence of similar conditions of the earth; commonly a minor division or part of a period.","pos":""}],"EPOCHAL":[{"def":"Belonging to an epoch; of the nature of an epoch.","pos":""}],"EPODE":[{"def":"It does not include the elegiac distich.","pos":""}],"EPODIC":[{"def":"Pertaining to, or resembling, an epode.","pos":""}],"EPONYMIC":[{"def":"Same as Eponymous.","pos":""}],"EPONYMIST":[{"def":"One from whom a race, tribe, city, or the like, took its name; an eponym.","pos":""}],"EPONYMOUS":[{"def":"Relating to an eponym; giving one's name to a tribe, people, country, and the like.","pos":""}],"EPONYMY":[{"def":"The derivation of the name of a race, tribe, etc.","pos":""}],"EPOPT":[{"def":"One instructed in the mysteries of a secret system.","pos":""}],"EPOTATION":[{"def":"A drinking up; a quaffing.","pos":""}]}