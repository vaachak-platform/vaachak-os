{"KNAB":[{"def":"To seize with the teeth; to gnaw.","pos":""}],"KNABBLE":[{"def":"To bite or nibble.","pos":""}],"KNACK":[{"def":"To crack; to make a sharp, abrupt noise to chink.","pos":""},{"def":"To speak affectedly.","pos":""}],"KNACK-KNEED":[{"def":"See Knock-kneed.","pos":""}],"KNACKER":[{"def":"One who makes knickknacks, toys, etc.","pos":""},{"def":"One of two or more pieces of bone or wood held loosely between the fingers, and struck together by moving the hand; -- called also clapper.","pos":""}],"KNACKISH":[{"def":"Trickish; artful.","pos":""}],"KNACKY":[{"def":"Having a knack; cunning; crafty; trickish.","pos":""}],"KNAG":[{"def":"A knot in wood; a protuberance.","pos":""},{"def":"A wooden peg for hanging things on.","pos":""}],"KNAGGED":[{"def":"Full of knots; knaggy.","pos":""}],"KNAGGY":[{"def":"Knotty; rough; figuratively, rough in temper.","pos":""}],"KNAP":[{"def":"A protuberance; a swelling; a knob; a button; hence, rising ground; a summit.","pos":""}],"KNAPBOTTLE":[{"def":"The bladder campion (Silene inflata).","pos":""}],"KNAPPISH":[{"def":"Snappish; peevish.","pos":""}],"KNAPPLE":[{"def":"To break off with an abrupt, sharp noise; to bite; to nibble.","pos":""}],"KNAPPY":[{"def":"Having knaps; full of protuberances or humps; knobby.","pos":""}],"KNAPSACK":[{"def":"A case of canvas or leather, for carrying on the back a soldier's necessaries, or the clothing, etc.","pos":""}],"KNAPWEED":[{"def":"The black centaury (Centaurea nigra); -- so called from the knoblike heads of flowers.","pos":""}],"KNARRED":[{"def":"Knotty; gnarled.","pos":""}],"KNARRY":[{"def":"Knotty; gnarled.","pos":""}],"KNAVE":[{"def":"A boy; especially, a boy servant.","pos":""},{"def":"Any male servant; a menial.","pos":""}],"KNAVERY":[{"def":"Roguish or mischievous tricks.","pos":""}],"KNAVESHIP":[{"def":"A small due, in meal, established by usage, which is paid to the under miller.","pos":""}],"KNAVESS":[{"def":"A knavish woman.","pos":""}],"KNAVISH":[{"def":"Like or characteristic of a knave; given to knavery; trickish; fraudulent; dishonest; villainous; as, a knavish fellow, or a knavish trick.","pos":""},{"def":"Mischievous; roguish; waggish.","pos":""}],"KNAVISHLY":[{"def":"In a knavish manner; dishonestly; fraudulently.","pos":""},{"def":"Mischievously; waggishly; roguishly.","pos":""}],"KNAVISHNESS":[{"def":"The quality or state of being knavish; knavery; dishonesty.","pos":""}],"KNAWEL":[{"def":"A low, spreading weed (Scleranthus annuus), common in sandy soil.","pos":""}]}