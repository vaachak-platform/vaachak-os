{"EMBLAZE":[{"def":"To adorn with glittering embellishments.","pos":""},{"def":"To paint or adorn with armorial figures; to blazon, or emblazon.","pos":""}],"EMBLAZON":[{"def":"To depict or represent; -- said of heraldic bearings.","pos":""},{"def":"To deck in glaring colors; to set off conspicuously; to display pompously; to decorate.","pos":""}],"EMBLAZONER":[{"def":"One who emblazons; also, one who publishes and displays anything with pomp.","pos":""}],"EMBLAZONING":[{"def":"The act or art of heraldic decoration; delineation of armorial bearings.","pos":""}],"EMBLAZONRY":[{"def":"The act or art of an emblazoner; heraldic or ornamental decoration, as pictures or figures on shields, standards, etc.","pos":""}],"EMBLEM":[{"def":"Inlay; inlaid or mosaic work; something ornamental inserted in a surface.","pos":""}],"EMBLEMATICCIZE":[{"def":"To render emblematic; as, to emblematicize a picture.","pos":""}],"EMBLEMATIST":[{"def":"A writer or inventor of emblems.","pos":""}],"EMBLEMATIZE":[{"def":"To represent by, or as by, an emblem; to symbolize.","pos":""}],"EMBLEMENT":[{"def":"The growing crop, or profits of a crop which has been sown or planted; -- used especially in the plural.","pos":""}],"EMBLEMIZE":[{"def":"To represent by an emblem; to emblematize.","pos":""}],"EMBLOSSOM":[{"def":"To cover or adorn with blossoms.","pos":""}]}