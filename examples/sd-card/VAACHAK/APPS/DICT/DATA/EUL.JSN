{"EULERIAN":[{"def":"Pertaining Euler, a German mathematician of the 18th century.","pos":""},{"def":"Bestowing praise of eulogy; commendatory; eulogistic.","pos":""}],"EULOGIST":[{"def":"One who eulogizes or praises; panegyrist; encomiast.","pos":""},{"def":"Of or pertaining to eulogy; characterized by eulogy; bestowing praise; panegyrical; commendatory; laudatory; as, eulogistic speech or discourse.","pos":""}],"EULOGIUM":[{"def":"A formal eulogy.","pos":""}],"EULOGIZE":[{"def":"To speak or write in commendation of (another); to extol in speech or writing; to praise.","pos":""}],"EULOGY":[{"def":"A speech or writing in commendation of the character or services of a person; as, a fitting eulogy to worth.","pos":""}],"EULYTITE":[{"def":"a mineral, consisting chiefly of the silicate of bismuth, found at Freiberg; -- called also culytine.","pos":""}]}