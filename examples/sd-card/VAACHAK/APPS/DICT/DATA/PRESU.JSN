{"PRESULTOR":[{"def":"A leader in the dance.","pos":""}],"PRESUMABLE":[{"def":"Such as may be presumed or supposed to be true; that seems entitled to belief without direct evidence.","pos":""}],"PRESUMABLY":[{"def":"In a presumable manner; by, or according to, presumption.","pos":""}],"PRESUME":[{"def":"To assume or take beforehand; esp.","pos":""},{"def":"To take or suppose to be true, or entitled to belief, without examination or proof, or on the strength of probability; to take for granted; to infer; to suppose.","pos":""}],"PRESUMER":[{"def":"One who presumes; also, an arrogant person.","pos":""}],"PRESUMINGLY":[{"def":"Confidently; arrogantly.","pos":""}],"PRESUMPTION":[{"def":"The act of presuming, or believing upon probable evidence; the act of assuming or taking for granted; belief upon incomplete proof.","pos":""},{"def":"Ground for presuming; evidence probable, but not conclusive; strong probability; reasonable supposition; as, the presumption is that an event has taken place.","pos":""}],"PRESUMPTIVE":[{"def":"Based on presumption or probability; grounded on probable evidence; probable; as, presumptive proof.","pos":""},{"def":"Presumptuous; arrogant.","pos":""}],"PRESUMPTIVELY":[{"def":"By presumption, or supposition grounded or probability; presumably.","pos":""}],"PRESUMPTUOUS":[{"def":"Full of presumption; presuming; overconfident or venturesome; audacious; rash; taking liberties unduly; arrogant; insolent; as, a presumptuous commander; presumptuous conduct.","pos":""},{"def":"Founded on presumption; as, a presumptuous idea.","pos":""}],"PRESUMPTUOUSLY":[{"def":"In a presumptuous manner; arrogantly.","pos":""}],"PRESUMPTUOUSNESS":[{"def":"The quality or state of being presumptuous.","pos":""}],"PRESUPPOSE":[{"def":"To suppose beforehand; to imply as antecedent; to take for granted; to assume; as, creation presupposes a creator.","pos":""}],"PRESUPPOSITION":[{"def":"The act of presupposing; an antecedent implication; presumption.","pos":""},{"def":"That which is presupposed; a previous supposition or surmise.","pos":""}],"PRESURMISE":[{"def":"A surmise previously formed.","pos":""}]}