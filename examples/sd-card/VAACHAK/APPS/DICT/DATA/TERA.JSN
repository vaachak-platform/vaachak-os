{"TERACONIC":[{"def":"Pertaining to, or designating, an acid obtained by the distillation of terebic acid, and homologous with citraconic acid.","pos":""}],"TERACRYLIC":[{"def":"Of, pertaining to, or designating, an acid of the acrylic series, obtained by the distillation of terpenylic acid, as an only substance having a peculiar cheesy odor.","pos":""}],"TERAPHIM":[{"def":"Images connected with the magical rites used by those Israelites who added corrupt practices to the patriarchal religion.","pos":""}],"TERATICAL":[{"def":"Wonderful; ominous; prodigious.","pos":""}],"TERATOGENY":[{"def":"The formation of monsters.","pos":""}],"TERATOID":[{"def":"Resembling a monster; abnormal; of a pathological growth, exceedingly complex or highly organized.","pos":""}],"TERATOLOGICAL":[{"def":"Of or pertaining to teratology; as, teratological changes.","pos":""}],"TERATOLOGY":[{"def":"That branch of biological science which treats of monstrosities, malformations, or deviations from the normal type of structure, either in plants or animals.","pos":""},{"def":"Affectation of sublimity; bombast.","pos":""}],"TERATOMA":[{"def":"A tumor, sometimes found in newborn children, which is made up of a heterigenous mixture of tissues, as of bone, cartilage and muscle.","pos":""}]}