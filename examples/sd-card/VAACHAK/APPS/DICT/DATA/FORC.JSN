{"FORCARVE":[{"def":"To cut completely; to cut off.","pos":""}],"FORCE":[{"def":"To stuff; to lard; to farce.","pos":""}],"FORCED":[{"def":"Done or produced with force or great labor, or by extraordinary exertion; hurried; strained; produced by unnatural effort or pressure; as, a forced style; a forced laugh.","pos":""}],"FORCEFUL":[{"def":"Full of or processing force; exerting force; mighty.","pos":""}],"FORCELESS":[{"def":"Having little or no force; feeble.","pos":""}],"FORCEMEAT":[{"def":"Meat chopped fine and highly seasoned, either served up alone, or used as a stuffing.","pos":""}],"FORCEMENT":[{"def":"The act of forcing; compulsion.","pos":""}],"FORCEPS":[{"def":"The caudal forceps-shaped appendage of earwigs and some other insects.","pos":""}],"FORCER":[{"def":"One who, or that which, forces or drives.","pos":""}],"FORCIBLE":[{"def":"Possessing force; characterized by force, efficiency, or energy; powerful; efficacious; impressive; influential.","pos":""},{"def":"Violent; impetuous.","pos":""}],"FORCIBLE-FEEBLE":[{"def":"Seemingly vigorous, but really weak or insipid.","pos":""}],"FORCIBLENESS":[{"def":"The quality of being forcible.","pos":""}],"FORCIBLY":[{"def":"In a forcible manner.","pos":""}],"FORCING":[{"def":"The art of raising plants, flowers, and fruits at an earlier season than the natural one, as in a hitbed or by the use of artificial heat.","pos":""}],"FORCIPAL":[{"def":"Forked or branched like a pair of forceps; constructed so as to open and shut like a pair of forceps.","pos":""},{"def":"Like a pair of forceps; as, a forcipated mouth.","pos":""}],"FORCIPATION":[{"def":"Torture by pinching with forceps or pinchers.","pos":""}],"FORCITE":[{"def":"A gelatin dynamite in which the dope is composed largely of sodium nitrate.","pos":""}],"FORCUT":[{"def":"To cut completely; to cut off.","pos":""}]}