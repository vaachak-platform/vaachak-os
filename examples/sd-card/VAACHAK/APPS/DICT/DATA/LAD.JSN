{"LAD":[{"def":"of Lead, to guide Chaucer.","pos":""}],"LADANUM":[{"def":"A gum resin gathered from certain Oriental species of Cistus.","pos":""}],"LADDE":[{"def":"of Lead, to guide.","pos":""}],"LADDER":[{"def":"A frame usually portable, of wood, metal, or rope, for ascent and descent, consisting of two side pieces to which are fastened cross strips or rounds forming steps.","pos":""},{"def":"That which resembles a ladder in form or use; hence, that by means of which one attains to eminence.","pos":""}],"LADDIE":[{"def":"A lad; a male sweetheart.","pos":""}],"LADE":[{"def":"To transfer (the molten glass) from the pot to the forming table.","pos":""}],"LADEMAN":[{"def":"One who leads a pack horse; a miller's servant.","pos":""}],"LADEN":[{"def":"Loaded; freighted; burdened; as, a laden vessel; a laden heart.","pos":""}],"LADIED":[{"def":"Ladylike; not rough; gentle.","pos":""}],"LADIES' EARDROPS":[{"def":"The small-flowered Fuchsia (F.","pos":""}],"LADIFY":[{"def":"To make a lady of; to make ladylike.","pos":""}],"LADIN":[{"def":"A Romansch dialect spoken in some parts of Switzerland and the Tyrol.","pos":""}],"LADING":[{"def":"The act of loading.","pos":""},{"def":"That which lades or constitutes a load or cargo; freight; burden; as, the lading of a ship.","pos":""}],"LADINO":[{"def":"One of the half-breed descendants of whites and Indians; a mestizo; -- so called throughout Central America.","pos":""}],"LADLE":[{"def":"A vessel to carry liquid metal from the furnace to the mold.","pos":""}],"LADLEFUL":[{"def":"A quantity sufficient to fill a ladle.","pos":""}],"LADRONE":[{"def":"A robber; a pirate; hence, loosely, a rogue or rascal.","pos":""}],"LADY":[{"def":"The triturating apparatus in the stomach of a lobster; -- so called from a fancied resemblance to a seated female figure.","pos":""}],"LADY DAY":[{"def":"The day of the annunciation of the Virgin Mary, March 25.","pos":""}],"LADY'S BEDSTRAW":[{"def":"The common bedstraw (Galium verum); also, a slender-leaved East Indian shrub (Pharnaceum Mollugo), with white flowers in umbels.","pos":""}],"LADY'S BOWER":[{"def":"A climbing plant with fragrant blossoms (Clematis vitalba).","pos":""}],"LADY'S CLOTH":[{"def":"A kind of broadcloth of light weight, used for women's dresses, cloaks, etc.","pos":""}],"LADY'S COMB":[{"def":"An umbelliferous plant (Scandix Pecten-Veneris), its clusters of long slender fruits remotely resembling a comb.","pos":""}],"LADY'S CUSHION":[{"def":"An herb growing in dense tufts; the thrift (Armeria vulgaris).","pos":""}],"LADY'S FINGER":[{"def":"The kidney vetch.","pos":""},{"def":"A variety of small cake of about the dimensions of a finger.","pos":""}],"LADY'S HAIR":[{"def":"A plant of the genus Briza (B.","pos":""}],"LADY'S LACES":[{"def":"A slender climbing plant; dodder.","pos":""}],"LADY'S LOOKING-GLASS":[{"def":"See Venus's looking-glass, under Venus.","pos":""}],"LADY'S MANTLE":[{"def":"A genus of rosaceous herbs (Alchemilla), esp.","pos":""}],"LADY'S SLIPPER":[{"def":"Any orchidaceous plant of the genus Cypripedium, the labellum of which resembles a slipper.","pos":""}],"LADY'S SMOCK":[{"def":"A plant of the genus Cardamine (C.","pos":""}],"LADY'S THUMB":[{"def":"An annual weed (Polygonum Persicaria), having a lanceolate leaf with a dark spot in the middle.","pos":""},{"def":"A name given to several species of the orchidaceous genus Spiranthes, in which the white flowers are set in spirals about a slender axis and remotely resemble braided hair.","pos":""}],"LADY-KILLER":[{"def":"A gallant who captivates the hearts of women.","pos":""}],"LADY-KILLING":[{"def":"The art or practice of captivating the hearts of women.","pos":""}],"LADYBIRD":[{"def":"Any one of numerous species of small beetles of the genus Coccinella and allied genera (family Coccinellidæ); -- called also ladybug, ladyclock, lady cow, lady fly, and lady beetle.","pos":""}],"LADYBUG":[{"def":"Same as Ladybird.","pos":""}],"LADYFISH":[{"def":"Atlantic and Pacific oceans; -- called also bonefish, grubber, French mullet, and macabé.","pos":""}],"LADYHOOD":[{"def":"The state or quality of being a lady; the personality of a lady.","pos":""}],"LADYKIN":[{"def":"A little lady; -- applied by the writers of Queen Elizabeth's time, in the abbreviated form Lakin, to the Virgin Mary.","pos":""}],"LADYLIKE":[{"def":"Like a lady in appearance or manners; well-bred.","pos":""},{"def":"Becoming or suitable to a lady; as, ladylike manners.","pos":""}],"LADYLIKENESS":[{"def":"The quality or state of being ladylike.","pos":""}],"LADYLOVE":[{"def":"A sweetheart or mistress.","pos":""}],"LADYSHIP":[{"def":"The rank or position of a lady; -- given as a title (preceded by her or your.","pos":""}]}