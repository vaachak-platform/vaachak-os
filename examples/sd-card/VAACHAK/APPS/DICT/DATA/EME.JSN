{"EMENAGOGUE":[{"def":"See Emmenagogue.","pos":""}],"EMEND":[{"def":"To purge of faults; to make better; to correct; esp.","pos":""}],"EMENDABLE":[{"def":"Corrigible; amendable.","pos":""}],"EMENDATELY":[{"def":"Without fault; correctly.","pos":""}],"EMENDATION":[{"def":"The act of altering for the better, or correcting what is erroneous or faulty; correction; improvement.","pos":""},{"def":"Alteration by editorial criticism, as of a text so as to give a better reading; removal of errors or corruptions from a document; as, the book might be improved by judicious emendations.","pos":""}],"EMENDATOR":[{"def":"One who emends or critically edits.","pos":""}],"EMENDATORY":[{"def":"Pertaining to emendation; corrective.","pos":""}],"EMERALD":[{"def":"A precious stone of a rich green color, a variety of beryl.","pos":""},{"def":"A kind of type, in size between minion and nonpare Note: * This line is printed in the type called emerald.","pos":""}],"EMERALDINE":[{"def":"A green compound used as a dyestuff, produced from aniline blue when acted upon by acid.","pos":""}],"EMERGE":[{"def":"To rise out of a fluid; to come forth from that in which anything has been plunged, enveloped, or concealed; to issue and appear; as, to emerge from the water or the ocean; the sun emerges from behind the moon in an eclipse; to emerge from poverty or obscurity.","pos":""}],"EMERGENCE":[{"def":"The act of rising out of a fluid, or coming forth from envelopment or concealment, or of rising into view; sudden uprisal or appearance.","pos":""}],"EMERGENCY":[{"def":"Sudden or unexpected appearance; an unforeseen occurrence; a sudden occasion.","pos":""},{"def":"An unforeseen occurrence or combination of circumstances which calls for immediate action or remedy; pressing necessity; exigency.","pos":""}],"EMERGENT":[{"def":"Rising or emerging out of a fluid or anything that covers or conceals; issuing; coming to light.","pos":""},{"def":"Suddenly appearing; arising unexpectedly; Protection granted in emergent danger.","pos":""}],"EMERIL":[{"def":"A glazier's diamond.","pos":""}],"EMERITED":[{"def":"Considered as having done sufficient public service, and therefore honorably discharged.","pos":""}],"EMERITUS":[{"def":"Honorably discharged from the performance of public duty on account of age, infirmity, or long and faithful services; -- said of an officer of a college or pastor of a church.","pos":""}],"EMERSED":[{"def":"Standing out of, or rising above, water.","pos":""}],"EMERSION":[{"def":"The reappearance of a heavenly body after an eclipse or occultation; as, the emersion of the moon from the shadow of the earth; the emersion of a star from behind the moon.","pos":""}],"EMERY":[{"def":"Corundum in the form of grains or powder, used in the arts for grinding and polishing hard substances.","pos":""}],"EMETIC":[{"def":"Inducing to vomit; exciting the stomach to discharge its contents by the mouth.","pos":""},{"def":"A medicine which causes vomiting.","pos":""}],"EMETICAL":[{"def":"Inducing to vomit; producing vomiting; emetic.","pos":""}],"EMETINE":[{"def":"A white crystalline bitter alkaloid extracted from ipecacuanha root, and regarded as its peculiar emetic principle.","pos":""}],"EMETO-CATHARTIC":[{"def":"Producing vomiting and purging at the same time.","pos":""}],"EMEUTE":[{"def":"A seditious tumult; an outbreak.","pos":""},{"def":"An abbreviation for electro-motive force.","pos":""}]}