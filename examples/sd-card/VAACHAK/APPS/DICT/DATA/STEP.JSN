{"STEP":[{"def":"To move the foot in walking; to advance or recede by raising and moving one of the feet to another resting place, or by moving both feet in succession.","pos":""},{"def":"To walk; to go on foot; esp.","pos":""}],"STEP-":[{"def":"A prefix used before father, mother, brother, sister, son, daughter, child, etc.","pos":""}],"STEP-DOWN":[{"def":"Transforming or converting a current of high potential or pressure into one of low pressure; as, a step-down transformer.","pos":""}],"STEP-UP":[{"def":"Transforming or converting a low-pressure current into one of high pressure; as, a step-up transformer.","pos":""},{"def":"A suffix denoting the agent (originally a woman), especially a person who does something with skill or as an occupation; as in spinster (originally, a woman who spins), songster, baxter (= bakester), youngster.","pos":""}],"STEPBROTHER":[{"def":"A brother by the marriage of one's father with the mother of another, or of one's mother with the father of another.","pos":""}],"STEPCHILD":[{"def":"A bereaved child; one who has lost father or mother.","pos":""},{"def":"A son or daughter of one's wife or husband by a former marriage.","pos":""}],"STEPDAUGHTER":[{"def":"A daughter of one's wife or husband by a former marriage.","pos":""}],"STEPFATHER":[{"def":"The husband of one's mother by a subsequent marriage.","pos":""}],"STEPHANION":[{"def":"The point on the side of the skull where the temporal line, or upper edge of the temporal fossa, crosses the coronal suture.","pos":""}],"STEPHANITE":[{"def":"A sulphide of antimony and silver of an iron-black color and metallic luster; called also black silver, and brittle silver ore.","pos":""}],"STEPHANOTIS":[{"def":"A genus of climbing asclepiadaceous shrubs, of Madagascar, Malaya, etc.","pos":""}],"STEPLADDER":[{"def":"A portable set of steps.","pos":""}],"STEPMOTHER":[{"def":"The wife of one's father by a subsequent marriage.","pos":""}],"STEPPARENT":[{"def":"Stepfather or stepmother.","pos":""}],"STEPPE":[{"def":"One of the vast plains in Southeastern Europe and in Asia, generally elevated, and free from wood, analogous to many of the prairies in Western North America.","pos":""}],"STEPPED":[{"def":"Provided with a step or steps; having a series of offsets or parts resembling the steps of stairs; as, a stepped key.","pos":""}],"STEPPER":[{"def":"One who, or that which, steps; as, a quick stepper.","pos":""}],"STEPPING-STONE":[{"def":"A stone to raise the feet above the surface of water or mud in walking.","pos":""}],"STEPSISTER":[{"def":"A daughter of one's stepfather or stepmother by a former marriage.","pos":""}],"STEPSON":[{"def":"A son of one's husband or wife by a former marriage.","pos":""}],"STEPSTONE":[{"def":"A stone laid before a door as a stair to rise on in entering the house.","pos":""}]}