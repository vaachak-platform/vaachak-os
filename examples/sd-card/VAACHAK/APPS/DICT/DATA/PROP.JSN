{"PROP":[{"def":"A shell, used as a die.","pos":""}],"PROPAEDEUTICS":[{"def":"The preliminary learning connected with any art or science; preparatory instruction.","pos":""}],"PROPAGABLE":[{"def":"Capable of being propagated, or of being continued or multiplied by natural generation or production.","pos":""},{"def":"Capable of being spread or extended by any means; -- said of tenets, doctrines, or principles.","pos":""}],"PROPAGANDA":[{"def":"Hence, any organization or plan for spreading a particular doctrine or a system of principles.","pos":""}],"PROPAGANDISM":[{"def":"The art or practice of propagating tenets or principles; zeal in propagating one's opinions.","pos":""}],"PROPAGANDIST":[{"def":"A person who devotes himself to the spread of any system of principles.","pos":""}],"PROPAGATE":[{"def":"To cause to continue or multiply by generation, or successive production; -- applied to animals and plants; as, to propagate a breed of horses or sheep; to propagate a species of fruit tree.","pos":""},{"def":"To cause to spread to extend; to impel or continue forward in space; as, to propagate sound or light.","pos":""}],"PROPAGATION":[{"def":"The act of propagating; continuance or multiplication of the kind by generation or successive production; as, the propagation of animals or plants.","pos":""},{"def":"The spreading abroad, or extension, of anything; diffusion; dissemination; as, the propagation of sound; the propagation of the gospel.","pos":""}],"PROPAGATIVE":[{"def":"Producing by propagation, or by a process of growth.","pos":""}],"PROPAGATOR":[{"def":"One who propagates; one who continues or multiplies.","pos":""}],"PROPAGULUM":[{"def":"A runner terminated by a germinating bud.","pos":""}],"PROPANE":[{"def":"A heavy gaseous hydrocarbon, C3H8, of the paraffin series, occurring naturally dissolved in crude petroleum, and also made artificially; -- called also propyl hydride.","pos":""}],"PROPARGYL":[{"def":"Same as Propinyl.","pos":""}],"PROPAROXYTONE":[{"def":"A word which has the acute accent on the antepenult.","pos":""}],"PROPEL":[{"def":"To drive forward; to urge or press onward by force; to move, or cause to move; as, the wind or steam propels ships; balls are propelled by gunpowder.","pos":""}],"PROPELLER":[{"def":"One who, or that which, propels.","pos":""},{"def":"A contrivance for propelling a steam vessel, usually consisting of a screw placed in the stern under water, and made to revolve by an engine; a propeller wheel.","pos":""}],"PROPEND":[{"def":"To lean toward a thing; to be favorably inclined or disposed; to incline; to tend.","pos":""}],"PROPENDENCY":[{"def":"Attentive deliberation.","pos":""}],"PROPENDENT":[{"def":"Inclining forward or toward.","pos":""}],"PROPENE":[{"def":"Same as Propylene.","pos":""}],"PROPENSE":[{"def":"Leaning toward, in a moral sense; inclined; disposed; prone; as, women propense to holiness.","pos":""}],"PROPENSION":[{"def":"The quality or state of being propense; propensity.","pos":""}],"PROPENSITY":[{"def":"The quality or state of being propense; natural inclination; disposition to do good or evil; bias; bent; tendency.","pos":""}],"PROPENYL":[{"def":"A hypothetical hydrocarbon radical, C3H5, isomeric with allyl and glyceryl, and regarded as the essential residue of glycerin.","pos":""}],"PROPEPTONE":[{"def":"A product of gastric digestion intermediate between albumin and peptone, identical with hemialbumose.","pos":""}],"PROPER":[{"def":"Represented in its natural color; -- said of any object used as a charge.","pos":""}],"PROPERATE":[{"def":"To hasten, or press forward.","pos":""}],"PROPERATION":[{"def":"The act of hastening; haste.","pos":""}],"PROPERISPOME":[{"def":"Properispomenon.","pos":""}],"PROPERISPOMENON":[{"def":"A word which has the circumflex accent on the penult.","pos":""}],"PROPERLY":[{"def":"In a proper manner; suitably; fitly; strictly; rightly; as, a word properly applied; a dress properly adjusted.","pos":""},{"def":"Individually; after one's own manner.","pos":""}],"PROPERNESS":[{"def":"The quality of being proper.","pos":""},{"def":"Tallness; comeliness.","pos":""}],"PROPERTIED":[{"def":"Possessing property; holding real estate, or other investments of money.","pos":""}],"PROPERTY":[{"def":"All the adjuncts of a play except the scenery and the dresses of the actors; stage requisites.","pos":""}],"PROPHASIS":[{"def":"Foreknowledge of a disease; prognosis.","pos":""}],"PROPHECY":[{"def":"A book of prophecies; a history; as, the prophecy of Ahijah.","pos":""}],"PROPHESY":[{"def":"To foretell; to predict; to prognosticate.","pos":""},{"def":"To foreshow; to herald; to prefigure.","pos":""}],"PROPHET":[{"def":"One who prophesies, or foretells events; a predicter; a foreteller.","pos":""},{"def":"One inspired or instructed by God to speak in his name, or announce future events, as, Moses, Elijah, etc.","pos":""}],"PROPHETESS":[{"def":"A female prophet.","pos":""},{"def":"Containing, or pertaining to, prophecy; foretelling events; as, prophetic writings; prophetic dreams; -- used with of before the thing foretold.","pos":""}],"PROPHETICALITY":[{"def":"Propheticalness.","pos":""}],"PROPHETICALLY":[{"def":"In a prophetical manner; by way of prediction.","pos":""}],"PROPHETICALNESS":[{"def":"The quality or state of being prophetical; power or capacity to foretell.","pos":""}],"PROPHETIZE":[{"def":"To give predictions; to foreshow events; to prophesy.","pos":""}],"PROPHRAGMA":[{"def":"An internal dorsal chitinous process between the first two divisions of the thorax of insects.","pos":""}],"PROPHYLACTIC":[{"def":"A medicine which preserves or defends against disease; a preventive.","pos":""},{"def":"Defending or preserving from disease; preventive.","pos":""}],"PROPHYLAXIS":[{"def":"The art of preserving from, or of preventing, disease; the observance of the rules necessary for the preservation of health; preservative or preventive treatment.","pos":""}],"PROPICE":[{"def":"Fit; propitious.","pos":""}],"PROPIDENE":[{"def":"The unsymmetrical hypothetical hydrocarbon radical, CH3.","pos":""}],"PROPINATION":[{"def":"The act of pledging, or drinking first, and then offering the cup to another.","pos":""}],"PROPINE":[{"def":"To pledge; to offer as a toast or a health in the manner of drinking, that is, by drinking first and passing the cup.","pos":""},{"def":"Hence, to give in token of friendship.","pos":""}],"PROPINQUITY":[{"def":"Nearness in place; neighborhood; proximity.","pos":""},{"def":"Nearness in time.","pos":""}],"PROPINYL":[{"def":"A hydrocarbon radical regarded as an essential residue of propine and allied compounds.","pos":""}],"PROPIOLATE":[{"def":"A salt of propiolic acid.","pos":""}],"PROPIOLIC":[{"def":"Pertaining to, or designating, an organic acid (called also propargylic acid) of the acetylene or tetrolic series, analogous to propionic acid, and obtained as a white crystalline substance.","pos":""}],"PROPIONATE":[{"def":"A salt of propionic acid.","pos":""}],"PROPIONE":[{"def":"The ketone of propionic acid, obtained as a colorless fragrant liquid.","pos":""}],"PROPIONIC":[{"def":"Pertaining to, derived from, or designating, an organic acid which is produced in the distillation of wood, in the fermentation of various organic substances, as glycerin, calcium lactate, etc.","pos":""}],"PROPIONYL":[{"def":"The hypothetical radical C3H5O, regarded as the essential residue of propionic acid and certain related compounds.","pos":""}],"PROPITHECUS":[{"def":"A genus including the long-tailed, or diadem, indris.","pos":""}],"PROPITIABLE":[{"def":"Capable of being propitiated.","pos":""}],"PROPITIATE":[{"def":"To appease to render favorable; to make propitious; to conciliate.","pos":""}],"PROPITIATION":[{"def":"That which propitiates; atonement or atoning sacrifice; specifically, the influence or effects of the death of Christ in appeasing the divine justice, and conciliating the divine favor.","pos":""}],"PROPITIATOR":[{"def":"One who propitiates or appeases.","pos":""}],"PROPITIATORILY":[{"def":"By way of propitiation.","pos":""}],"PROPITIATORY":[{"def":"Having the power to make propitious; pertaining to, or employed in, propitiation; expiatory; as, a propitiatory sacrifice.","pos":""}],"PROPITIOUS":[{"def":"Convenient; auspicious; favorable; kind; as, a propitious season; a propitious breeze.","pos":""},{"def":"Hence, kind; gracious; merciful; helpful; -- said of a person or a divinity.","pos":""}],"PROPLASM":[{"def":"A mold; a matrix.","pos":""}],"PROPLASTICS":[{"def":"The art of making molds for castings.","pos":""}],"PROPODIAL":[{"def":"Of or pertaining to the propodialia, or the parts of the limbs to which they belong.","pos":""}],"PROPODIALE":[{"def":"The bone of either the upper arm or the thing, the propodialia being the humerus and femur.","pos":""}],"PROPODITE":[{"def":"The sixth joint of a typical leg of a crustacean; usually, the penultimate joint.","pos":""}],"PROPOLIS":[{"def":"Same as Bee glue, under Bee.","pos":""}],"PROPONE":[{"def":"To propose; to bring forward.","pos":""}],"PROPONENT":[{"def":"Making proposals; proposing.","pos":""}],"PROPORTION":[{"def":"The relation or adaptation of one portion to another, or to the whole, as respect magnitude, quantity, or degree; comparative relation; ratio; as, the proportion of the parts of a building, or of the body.","pos":""},{"def":"Harmonic relation between parts, or between different things of the same kind; symmetrical arrangement or adjustment; symmetry; as, to be out of proportion.","pos":""}],"PROPORTIONABLE":[{"def":"Capable of being proportioned, or made proportional; also, proportional; proportionate.","pos":""}],"PROPORTIONABLY":[{"def":"Pro*por\"tion*a*bly, adv.","pos":""}],"PROPORTIONAL":[{"def":"Having a due proportion, or comparative relation; being in suitable proportion or degree; as, the parts of an edifice are proportional.","pos":""},{"def":"Relating to, or securing, proportion.","pos":""}],"PROPORTIONALITY":[{"def":"The state of being in proportion.","pos":""}],"PROPORTIONALLY":[{"def":"In proportion; in due degree; adapted relatively; as, all parts of the building are proportionally large.","pos":""}],"PROPORTIONATE":[{"def":"Adjusted to something else according to a proportion; proportional.","pos":""}],"PROPORTIONATELY":[{"def":"In a proportionate manner; with due proportion; proportionally.","pos":""}],"PROPORTIONATENESS":[{"def":"The quality or state of being proportionate.","pos":""}],"PROPORTIONLESS":[{"def":"Without proportion; unsymmetrical.","pos":""}],"PROPORTIONMENT":[{"def":"The act or process of dividing out proportionally.","pos":""}],"PROPOSAL":[{"def":"The offer by a party of what he has in view as to an intended business transaction, which, with acceptance, constitutes a contract.","pos":""}],"PROPOSE":[{"def":"To offer for consideration, discussion, acceptance, or adoption; as, to propose terms of peace; to propose a question for discussion; to propose an alliance; to propose a person for office.","pos":""}],"PROPOSER":[{"def":"One who proposes or offers anything for consideration or adoption.","pos":""},{"def":"A speaker; an orator.","pos":""}],"PROPOSITION":[{"def":"A complete sentence, or part of a sentence consisting of a subject and predicate united by a copula; a thought expressed or propounded in language; a from of speech in which a predicate is affirmed or denied of a subject; as, snow is white.","pos":""},{"def":"A statement in terms of a truth to be demonstrated, or of an operation to be performed.","pos":""}],"PROPOSITIONAL":[{"def":"Pertaining to, or in the nature of, a proposition; considered as a proposition; as, a propositional sense.","pos":""}],"PROPOUND":[{"def":"To propose or name as a candidate for admission to communion with a church.","pos":""}],"PROPOUNDER":[{"def":"One who propounds, proposes, or offers for consideration.","pos":""}],"PROPRETOR":[{"def":"A magistrate who, having been pretor at home, was appointed to the government of a province.","pos":""}],"PROPRIETARY":[{"def":"A monk who had reserved goods and effects to himself, notwithstanding his renunciation of all at the time of profession.","pos":""}],"PROPRIETOR":[{"def":"One who has the legal right or exclusive title to anything, whether in possession or not; an owner; as, the proprietor of farm or of a mill.","pos":""}],"PROPRIETORIAL":[{"def":"Of or pertaining to ownership; proprietary; as, proprietorial rights.","pos":""}],"PROPRIETORSHIP":[{"def":"The state of being proprietor; ownership.","pos":""}],"PROPRIETRESS":[{"def":"A female proprietor.","pos":""}],"PROPRIETY":[{"def":"Individual right to hold property; ownership by personal title; property.","pos":""},{"def":"That which is proper or peculiar; an inherent property or quality; peculiarity.","pos":""}],"PROPROCTOR":[{"def":"A assistant proctor.","pos":""}],"PROPS":[{"def":"A game of chance, in which four sea shells, each called a prop, are used instead of dice.","pos":""}],"PROPTERYGIUM":[{"def":"The anterior of three principal cartilages in the fins of some fishes.","pos":""}],"PROPUGN":[{"def":"To contend for; to defend; to vindicate.","pos":""}],"PROPUGNATION":[{"def":"Means of defense; defense.","pos":""}],"PROPUGNER":[{"def":"A defender; a vindicator.","pos":""}],"PROPULSATION":[{"def":"The act of driving away or repelling; a keeping at a distance.","pos":""}],"PROPULSE":[{"def":"To repel; to drive off or away.","pos":""}],"PROPULSION":[{"def":"The act driving forward or away; the act or process of propelling; as, steam propulsion.","pos":""},{"def":"An impelling act or movement.","pos":""}],"PROPULSIVE":[{"def":"Tending, or having power, to propel; driving on; urging.","pos":""}],"PROPYL":[{"def":"The hypothetical radical C3H7, regarded as the essential residue of propane and related compounds.","pos":""}],"PROPYLAEUM":[{"def":"Any court or vestibule before a building or leading into any inclosure.","pos":""}],"PROPYLENE":[{"def":"A colorless gaseous hydrocarbon (C3H6) of the ethylene series, having a garlic odor.","pos":""}],"PROPYLIC":[{"def":"Pertaining to, derived from, or containing, propyl; as, propylic alcohol.","pos":""}],"PROPYLON":[{"def":"The porch, vestibule, or entrance of an edifice.","pos":""}]}