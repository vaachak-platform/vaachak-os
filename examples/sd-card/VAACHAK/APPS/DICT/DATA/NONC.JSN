{"NONCE":[{"def":"The one or single occasion; the present call or purpose; -- chiefly used in the phrase for the nonce.","pos":""}],"NONCHALANCE":[{"def":"Indifference; carelessness; coolness.","pos":""}],"NONCHALANT":[{"def":"Indifferent; careless; cool.","pos":""}],"NONCHALANTLY":[{"def":"In a nonchalant, indifferent, or careless manner; coolly.","pos":""}],"NONCLAIM":[{"def":"A failure to make claim within the time limited by law; omission of claim.","pos":""}],"NONCOHESION":[{"def":"Want of cohesion.","pos":""}],"NONCOINCIDENCE":[{"def":"Lack of coincidence.","pos":""}],"NONCOMMISSIONED":[{"def":"Not having a commission.","pos":""}],"NONCOMMITTAL":[{"def":"A state of not being committed or pledged; forbearance or refusal to commit one's self.","pos":""}],"NONCOMMUNION":[{"def":"Neglect or failure of communion.","pos":""}],"NONCOMPLETION":[{"def":"Lack of completion; failure to complete.","pos":""}],"NONCOMPLIANCE":[{"def":"Neglect of compliance; failure to comply.","pos":""}],"NONCOMPLYING":[{"def":"Neglecting or refusing to comply.","pos":""},{"def":"Not of sound mind; not having the regular use of reason; hence, also, as a noun, an idiot; a lunati NONCON.","pos":""}],"NONCONCUR":[{"def":"To dissent or refuse to concur.","pos":""}],"NONCONCURRENCE":[{"def":"Refusal to concur.","pos":""}],"NONCONDENSIBLE":[{"def":"Not condensible; incapable of being liquefied; -- said of gases.","pos":""}],"NONCONDENSING":[{"def":"Not condensing; discharging the steam from the cylinder at a pressure nearly equal to or above that of the atmosphere and not into a condenser.","pos":""}],"NONCONDUCTING":[{"def":"Not conducting; not transmitting a fluid or force; thus, in electricity, wax is a nonconducting substance.","pos":""}],"NONCONDUCTION":[{"def":"The quality of not being able to conduct or transmit; failure to conduct.","pos":""}],"NONCONDUCTOR":[{"def":"A substance which does not conduct, that is, convey or transmit, heat, electricity, sound, vibration, or the like, or which transmits them with difficulty; an insulator; as, wool is a nonconductor of heat; glass and dry wood are nonconductors of electricity.","pos":""}],"NONCONFORMING":[{"def":"Not conforming; declining conformity; especially, not conforming to the established church of a country.","pos":""}],"NONCONFORMIST":[{"def":"One who does not conform to an established church; especially, one who does not conform to the established church of England; a dissenter.","pos":""}],"NONCONFORMITY":[{"def":"Neglect or failure of conformity; especially, in England, the neglect or refusal to unite with the established church in its rites and modes of worship.","pos":""}],"NONCONSTAT":[{"def":"It does not appear; it is not plain or clear; it does not follow.","pos":""}],"NONCONTAGIOUS":[{"def":"Not contagious; not catching; not communicable by contact.","pos":""}],"NONCONTENT":[{"def":"One who gives a negative vote; -- sometimes abridged into noncon.","pos":""},{"def":"Not contributing.","pos":""}]}