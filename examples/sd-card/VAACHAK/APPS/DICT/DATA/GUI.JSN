{"GUIACOL":[{"def":"A colorless liquid, C6H4,OCH3.","pos":""}],"GUIACUM":[{"def":"Same as Guaiacum.","pos":""}],"GUIB":[{"def":"A West African antelope (Tragelaphus scriptus), curiously marked with white stripes and spots on a reddish fawn ground, and hence called harnessed antelope; -- called also guiba.","pos":""}],"GUICOWAR":[{"def":"[Mahratta gaekwar, prop.","pos":""}],"GUIDABLE":[{"def":"Capable of being guided; willing to be guided or counseled.","pos":""}],"GUIDAGE":[{"def":"The reward given to a guide for services.","pos":""},{"def":"Guidance; lead; direction.","pos":""}],"GUIDANCE":[{"def":"The act or result of guiding; the superintendence or assistance of a guide; direction; government; a leading.","pos":""}],"GUIDE":[{"def":"To lead or direct in a way; to conduct in a course or path; to pilot; as, to guide a traveler.","pos":""},{"def":"To regulate and manage; to direct; to order; to superintend the training or education of; to instruct and influence intellectually or morally; to train.","pos":""}],"GUIDE ROPE":[{"def":"A rope hung from a balloon or dirigible so as trail along the ground for about half its length, used to preserve altitude automatically, by variation of the length dragging on the ground, without loss of ballast or gas.","pos":""}],"GUIDEBOARD":[{"def":"A board, as upon a guidepost having upon it directions or information as to the road.","pos":""}],"GUIDEBOOK":[{"def":"A book of directions and information for travelers, tourists, etc.","pos":""}],"GUIDELESS":[{"def":"Without a guide.","pos":""}],"GUIDEPOST":[{"def":"A post at the fork of a road, with a guideboard on it, to direct travelers.","pos":""}],"GUIDER":[{"def":"A guide; a director.","pos":""}],"GUIDGUID":[{"def":"A South American ant bird of the genus Hylactes; -- called also barking bird.","pos":""}],"GUIDON":[{"def":"A small flag or streamer, as that carried by cavalry, which is broad at one end and nearly pointed at the other, or that used to direct the movements of a body of infantry, or to make signals at sea; also, the flag of a guild or fraternity.","pos":""},{"def":"One who carries a flag.","pos":""}],"GUILD":[{"def":"An association of men belonging to the same class, or engaged in kindred pursuits, formed for mutual aid and protection; a business fraternity or corporation; as, the Stationers' Guild; the Ironmongers' Guild.","pos":""}],"GUILDABLE":[{"def":"Liable to a tax.","pos":""}],"GUILDER":[{"def":"A Dutch silver coin worth about forty cents; -- called also florin and gulden.","pos":""}],"GUILDHALL":[{"def":"The hall where a guild or corporation usually assembles; a townhall.","pos":""}],"GUILE":[{"def":"Craft; deceitful cunning; artifice; duplicity; wile; deceit; treachery.","pos":""}],"GUILEFUL":[{"def":"Full of guile; characterized by cunning, deceit, or treachery; guilty.","pos":""}],"GUILELESS":[{"def":"Free from guile; artless.","pos":""}],"GUILLEMET":[{"def":"A quotation mark.","pos":""}],"GUILLEMOT":[{"def":"One of several northern sea birds, allied to the auks.","pos":""}],"GUILLEVAT":[{"def":"A vat for fermenting liquors.","pos":""}],"GUILLOCHE":[{"def":"An ornament in the form of two or more bands or strings twisted over each other in a continued series, leaving circular openings which are filled with round ornaments.","pos":""}],"GUILLOCHED":[{"def":"Waved or engine-turned.","pos":""}],"GUILLOTINE":[{"def":"A machine for beheading a person by one stroke of a heavy ax or blade, which slides in vertical guides, is raised by a cord, and let fall upon the neck of the victim.","pos":""},{"def":"Any machine or instrument for cutting or shearing, resembling in its action a guillotine.","pos":""}],"GUILOR":[{"def":"A deceiver; one who deludes, or uses guile.","pos":""}],"GUILT":[{"def":"The criminality and consequent exposure to punishment resulting from willful disobedience of law, or from morally wrong action; teh state of one who has broken a moral or political law; crime; criminality; offense against right.","pos":""},{"def":"Exposure to any legal penalty or forfeiture.","pos":""}],"GUILT-SICK":[{"def":"Made sick by consciousness of guilt.","pos":""}],"GUILTILY":[{"def":"In a guilty manner.","pos":""}],"GUILTINESS":[{"def":"The quality or state of being guilty.","pos":""}],"GUILTLESS":[{"def":"Free from guilt; innocent.","pos":""},{"def":"Without experience or trial; unacquainted (with).","pos":""}],"GUILTY":[{"def":"Having incurred guilt; criminal; morally delinquent; wicked; chargeable with, or responsible for, something censurable; justly exposed to penalty; -- used with of, and usually followed by the crime, sometimes by the punishment.","pos":""},{"def":"Evincing or indicating guilt; involving guilt; as, a guilty look; a guilty act; a guilty feeling.","pos":""}],"GUIMPE":[{"def":"A kind of short chemisette, worn with a low-necked dress.","pos":""}],"GUINEA":[{"def":"A district on the west coast of Africa (formerly noted for its export of gold and slaves) after which the Guinea fowl, Guinea grass, Guinea peach, etc.","pos":""},{"def":"A gold coin of England current for twenty-one shillings sterling, or about five dollars, but not coined since the issue of sovereigns in 1817.","pos":""}],"GUINEA-PIG DIRECTOR":[{"def":"A director (usually one holding a number of directorships) who serves merely or mainly for the fee (in England, often a guinea) paid for attendance.","pos":""}],"GUIPURE":[{"def":"A term used for lace of different kinds; most properly for a lace of large pattern and heavy material which has no ground or mesh, but has the pattern held together by connecting threads called bars or brides.","pos":""}],"GUISE":[{"def":"Customary way of speaking or acting; custom; fashion; manner; behavior; mien; mode; practice; -- often used formerly in such phrases as: at his own guise; that is, in his own fashion, to suit himself.","pos":""},{"def":"External appearance in manner or dress; appropriate indication or expression; garb; shape.","pos":""}],"GUISER":[{"def":"A person in disguise; a masker; a mummer.","pos":""}],"GUITAR":[{"def":"A stringed instrument of music resembling the lute or the violin, but larger, and having six strings, three of silk covered with silver wire, and three of catgut, -- played upon with the fingers.","pos":""}],"GUITGUIT":[{"def":"One of several species of small tropical American birds of the family Coerebidæ, allied to the creepers; -- called also quit.","pos":""}]}