{"PERIMETER":[{"def":"The outer boundary of a body or figure, or the sum of all the sides.","pos":""},{"def":"Of or pertaining to the perimeter, or to perimetry; as, a perimetric chart of the eye.","pos":""}],"PERIMETRY":[{"def":"The art of using the perimeter; measurement of the field of vision.","pos":""}],"PERIMORPH":[{"def":"A crystal of one species inclosing one of another species.","pos":""}],"PERIMYSIUM":[{"def":"The connective tissue sheath which surrounds a muscle, and sends partitions inwards between the bundles of muscular fibers.","pos":""}]}