{"MORRICE":[{"def":"Same as 1st Morris.","pos":""}],"MORRICER":[{"def":"A morris dancer.","pos":""}],"MORRIS":[{"def":"A Moorish dance, usually performed by a single dancer, who accompanies the dance with castanets.","pos":""},{"def":"A dance formerly common in England, often performed in pagenats, processions, and May games.","pos":""}],"MORRIS-CHAIR":[{"def":"A kind of easy-chair with a back which may be lowered or raised.","pos":""}],"MORRO":[{"def":"A round hill or point of land; hence, Morro castle, a castle on a hill.","pos":""}],"MORROW":[{"def":"The next following day; the day subsequent to any day specified or understood.","pos":""}]}