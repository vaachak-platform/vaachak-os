{"HARP":[{"def":"A constellation; Lyra, or the Lyre.","pos":""}],"HARPA":[{"def":"A genus of marine univalve shells; the harp shells; -- so called from the form of the shells, and their ornamental ribs.","pos":""}],"HARPAGON":[{"def":"A grappling iron.","pos":""}],"HARPER":[{"def":"A player on the harp; a minstrel.","pos":""},{"def":"A brass coin bearing the emblem of a harp, -- formerly current in Ireland.","pos":""}],"HARPING":[{"def":"Pertaining to the harp; as, harping symphonies.","pos":""}],"HARPINGS":[{"def":"The fore parts of the wales, which encompass the bow of a vessel, and are fastened to the stem.","pos":""}],"HARPIST":[{"def":"A player on the harp; a harper.","pos":""}],"HARPOON":[{"def":"A spear or javelin used to strike and kill large fish, as whales; a harping iron.","pos":""}],"HARPOONER":[{"def":"One who throws the harpoon.","pos":""}],"HARPRESS":[{"def":"A female harper.","pos":""}],"HARPSICHORD":[{"def":"A harp-shaped instrument of music set horizontally on legs, like the grand piano, with strings of wire, played by the fingers, by means of keys provided with quills, instead of hammers, for striking the strings.","pos":""}],"HARPY":[{"def":"A fabulous winged monster, ravenous and filthy, having the face of a woman and the body of a vulture, with long claws, and the face pale with hunger.","pos":""},{"def":"A firearm with match holder, trigger, and tumbler, made in the second half of the 15th century.","pos":""}]}