{"GRAZE":[{"def":"To feed or supply (cattle, sheep, etc.","pos":""},{"def":"To feed on; to eat (growing herbage); to eat grass from (a pasture); to browse.","pos":""}],"GRAZER":[{"def":"One that grazes; a creature which feeds on growing grass or herbage.","pos":""}],"GRAZIER":[{"def":"One who pastures cattle, and rears them for market.","pos":""}],"GRAZING":[{"def":"The act of one who, or that which, grazes.","pos":""},{"def":"A pasture; growing grass.","pos":""}],"GRAZIOSO":[{"def":"Gracefully; smoothly; elegantly.","pos":""}]}