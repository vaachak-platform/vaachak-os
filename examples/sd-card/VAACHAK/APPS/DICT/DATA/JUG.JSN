{"JUG":[{"def":"A vessel, usually of coarse earthenware, with a swelling belly and narrow mouth, and having a handle on one side.","pos":""},{"def":"A pitcher; a ewer.","pos":""}],"JUGAL":[{"def":"Pertaining to, or in the region of, the malar, or cheek bone.","pos":""}],"JUGATA":[{"def":"The figures of two heads on a medal or coin, either side by side or joined.","pos":""}],"JUGATED":[{"def":"Coupled together.","pos":""}],"JUGER":[{"def":"A Roman measure of land, measuring 28,800 square feet, or 240 feet in length by 120 in breadth.","pos":""}],"JUGGER":[{"def":"An East Indian falcon.","pos":""}],"JUGGERNAUT":[{"def":"One of the names under which Vishnu, in his incarnation as Krishna, is worshiped by the Hindoos.","pos":""}],"JUGGLE":[{"def":"To play tricks by sleight of hand; to cause amusement and sport by tricks of skill; to conjure.","pos":""},{"def":"To practice artifice or imposture.","pos":""}],"JUGGLER":[{"def":"One who practices or exhibits tricks by sleight of hand; one skilled in legerdemain; a conjurer.","pos":""},{"def":"A deceiver; a cheat.","pos":""}],"JUGGLERESS":[{"def":"A female juggler.","pos":""}],"JUGGLERY":[{"def":"The art or act of a juggler; sleight of hand.","pos":""},{"def":"Trickery; imposture; as, political jugglery.","pos":""}],"JUGGLING":[{"def":"Cheating; tricky.","pos":""}],"JUGLANDIN":[{"def":"An extractive matter contained in the juice of the green shucks of the walnut (Juglans regia).","pos":""}],"JUGLANDINE":[{"def":"An alkaloid found in the leaves of the walnut (Juglans regia).","pos":""}],"JUGLANS":[{"def":"A genus of valuable trees, including the true walnut of Europe, and the America black walnut, and butternut.","pos":""}],"JUGLONE":[{"def":"A yellow crystalline substance resembling quinone, extracted from green shucks of the walnut (Juglans regia); -- called also nucin.","pos":""}],"JUGULAR":[{"def":"Having the ventral fins beneath the throat; -- said of certain fishes.","pos":""}],"JUGULATE":[{"def":"To cut the throat of.","pos":""}],"JUGULUM":[{"def":"The lower throat, or that part of the neck just above the breast.","pos":""}]}