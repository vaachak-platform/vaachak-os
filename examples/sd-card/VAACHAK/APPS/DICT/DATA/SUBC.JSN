{"SUBCALIBER":[{"def":"Smaller than the caliber of a firearm.","pos":""}],"SUBCARBONATE":[{"def":"A carbonate containing an excess of the basic constituent.","pos":""}],"SUBCARBONIFEROUS":[{"def":"Of or pertaining to the lowest division of the Carboniferous formations underlying the proper coal measures.","pos":""},{"def":"The Subcarboniferous period or formation.","pos":""}],"SUBCARBURETED":[{"def":"United with, or containing, carbon in less than the normal proportion.","pos":""}],"SUBCARTILAGINOUS":[{"def":"Sub*car`ti*lag\"i*nous, a.","pos":""}],"SUBCAUDAL":[{"def":"Situated under, or on the ventral side of, the tail; as, the subcaudal, or chevron, bones.","pos":""}],"SUBCELESTIAL":[{"def":"Being beneath the heavens; as, subcelestial glories.","pos":""}],"SUBCELLAR":[{"def":"A cellar beneath another story wholly or partly underground; usually, a cellar under a cellar.","pos":""}],"SUBCENTRAL":[{"def":"Under the center.","pos":""},{"def":"Nearly central; not quite central.","pos":""}],"SUBCHANTER":[{"def":"An underchanter; a precentor's deputy in a cathedral; a succentor.","pos":""}],"SUBCIRCULAR":[{"def":"Nearly circular.","pos":""}],"SUBCLASS":[{"def":"One of the natural groups, more important than an order, into which some classes are divided; as, the angiospermous subclass of exogens.","pos":""}],"SUBCLAVIAN":[{"def":"Situated under the clavicle, or collar bone; as, the subclavian arteries.","pos":""}],"SUBCOLUMNAR":[{"def":"Having an imperfect or interrupted columnar structure.","pos":""}],"SUBCOMMITTEE":[{"def":"An under committee; a part or division of a committee.","pos":""}],"SUBCOMPRESSED":[{"def":"Not fully compressed; partially or somewhat compressed.","pos":""}],"SUBCONCAVE":[{"def":"Slightly concave.","pos":""}],"SUBCONFORMABLE":[{"def":"Partially conformable.","pos":""}],"SUBCONICAL":[{"def":"Slightly conical.","pos":""}],"SUBCONJUNCTIVAL":[{"def":"Situated under the conjunctiva.","pos":""}],"SUBCONSCIOUS":[{"def":"Occurring without the possibility or the fact of an attendant consciousness; -- said of states of the soul.","pos":""},{"def":"Partially conscious; feebly conscious.","pos":""}],"SUBCONSCIOUSNESS":[{"def":"The state or quality of being subconscious; a state of mind in which perception and other mental processes occur without distinct consciousness.","pos":""}],"SUBCONSTELLATION":[{"def":"A subordinate constellation.","pos":""}],"SUBCONTRACT":[{"def":"A contract under, or subordinate to, a previous contract.","pos":""}],"SUBCONTRACTED":[{"def":"Contracted after a former contract.","pos":""},{"def":"Betrothed for the second time.","pos":""}],"SUBCONTRACTOR":[{"def":"One who takes a portion of a contract, as for work, from the principal contractor.","pos":""}],"SUBCONTRARY":[{"def":"Denoting the relation of opposition between the particular affirmative and particular negative.","pos":""}],"SUBCORACOID":[{"def":"Situated under the coracoid process of the scapula; as, the subcoracoid dislocation of the humerus.","pos":""}],"SUBCORDATE":[{"def":"Somewhat cordate; somewhat like a heart in shape.","pos":""}],"SUBCOSTAL":[{"def":"Situated below the costas, or ribs; as, the subcostal muscles.","pos":""}],"SUBCRANIAL":[{"def":"Situated under, or on the ventral side of, the cranium; facial.","pos":""}],"SUBCRUSTACEOUS":[{"def":"Occurring beneath a crust or scab; as, a subcrustaceous cicatrization.","pos":""}],"SUBCRYSTALLINE":[{"def":"Imperfectly crystallized.","pos":""},{"def":"Having a form resembling that of a colter, or straight on one side and curved on the other.","pos":""}],"SUBCUTANEOUS":[{"def":"Situated under the skin; hypodermic.","pos":""}],"SUBCUTICULAR":[{"def":"Situated under the cuticle, or scarfskin.","pos":""},{"def":"Imperfectly cylindrical; approximately cylindrical.","pos":""}]}