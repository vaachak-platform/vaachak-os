{"HERD":[{"def":"A number of beasts assembled together; as, a herd of horses, oxen, cattle, camels, elephants, deer, or swine; a particular stock or family of cattle.","pos":""},{"def":"A crowd of low people; a rabble.","pos":""}],"HERDBOOK":[{"def":"A book containing the list and pedigrees of one or more herds of choice breeds of cattle; -- also called herd record, or herd register.","pos":""}],"HERDERITE":[{"def":"A rare fluophosphate of glucina, in small white crystals.","pos":""}],"HERDESS":[{"def":"A shepherdess; a female herder.","pos":""}],"HERDIC":[{"def":"A kind of low-hung cab.","pos":""},{"def":"The owner or keeper of a herd or of herds; one employed in tending a herd of cattle.","pos":""}],"HERDSWOMAN":[{"def":"A woman who tends a herd.","pos":""}]}