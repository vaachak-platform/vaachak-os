{"NESCIENCE":[{"def":"Want of knowledge; ignorance; agnosticism.","pos":""}],"NESH":[{"def":"Soft; tender; delicate.","pos":""}],"NESS":[{"def":"A promontory; a cape; a headland.","pos":""},{"def":"A suffix used to form abstract nouns expressive of quality or state; as, goodness, greatness.","pos":""}],"NESSLERIZE":[{"def":"To treat or test, as a liquid, with a solution of mercuric iodide in potassium iodide and potassium hydroxide, which is called Nessler's solution or Nessler's test, and is used to detect the presence of ammonia.","pos":""}],"NEST":[{"def":"An aggregated mass of any ore or mineral, in an isolated state, within a rock.","pos":""},{"def":"A compact group of pulleys, gears, springs, etc.","pos":""}],"NESTFUL":[{"def":"As much or many as will fill a nest.","pos":""}],"NESTLE":[{"def":"To make and occupy a nest; to nest.","pos":""},{"def":"To lie close and snug, as a bird in her nest; to cuddle up; to settle, as in a nest; to harbor; to take shelter.","pos":""}],"NESTLING":[{"def":"A young bird which has not abandoned the nest.","pos":""},{"def":"A nest; a receptacle.","pos":""}],"NESTOR":[{"def":"A genus of parrots with gray heads.","pos":""}],"NESTORIAN":[{"def":"Mary the mother of Christ; also, one of the sect established by the followers of Nestorius in Persia, india, and other Oriental countries, and still in existence.","pos":""}],"NESTORIANISM":[{"def":"The doctrines of the nestorian Christians, or of Nestorius.","pos":""}]}