{"APE":[{"def":"A quadrumanous mammal, esp.","pos":""}],"APEAK":[{"def":"In a vertical line.","pos":""}],"APEHOOD":[{"def":"The state of being an ape.","pos":""}],"APELLOUS":[{"def":"Destitute of skin.","pos":""}],"APENNINE":[{"def":"Of, pertaining to, or designating, the Apennines, a chain of mountains extending through Italy.","pos":""}],"APEPSY":[{"def":"Defective digestion, indigestion.","pos":""}],"APERCU":[{"def":"A first view or glance, or the perception or estimation so obtained; an immediate apprehension or insight, appreciative rather than analytic.","pos":""}],"APEREA":[{"def":"The wild Guinea pig of Brazil (Cavia aperea).","pos":""}],"APERIENT":[{"def":"Gently opening the bowels; laxative.","pos":""},{"def":"An aperient medicine or food.","pos":""}],"APERITIVE":[{"def":"Serving to open; aperient.","pos":""}],"APERT":[{"def":"Open; ev [Archaic] Fotherby.","pos":""}],"APERTION":[{"def":"The act of opening; an opening; an aperture.","pos":""}],"APERTLY":[{"def":"Openly; clearly.","pos":""}],"APERTNESS":[{"def":"Openness; frankness.","pos":""}],"APERTURE":[{"def":"The diameter of the exposed part of the object glass of a telescope or other optical instrument; as, a telescope of four-inch aperture.","pos":""}],"APERY":[{"def":"A place where apes are kept.","pos":""},{"def":"The practice of aping; an apish action.","pos":""}],"APETALOUS":[{"def":"Having no petals, or flower leaves.","pos":""}],"APETALOUSNESS":[{"def":"The state of being apetalous.","pos":""}],"APEX":[{"def":"The end or edge of a vein nearest the surface.","pos":""}]}