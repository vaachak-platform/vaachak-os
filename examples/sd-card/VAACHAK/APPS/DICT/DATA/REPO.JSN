{"REPOLISH":[{"def":"To polish again.","pos":""}],"REPOPULATION":[{"def":"The act of repeopling; act of furnishing with a population anew.","pos":""}],"REPORT":[{"def":"To return or present as the result of an examination or consideration of any matter officially referred; as, the committee reported the bill witth amendments, or reported a new bill, or reported the results of an inquiry.","pos":""}],"REPORTABLE":[{"def":"Capable or admitting of being reported.","pos":""}],"REPORTER":[{"def":"One who reports.","pos":""}],"REPORTINGLY":[{"def":"By report or common fame.","pos":""}],"REPORTORIAL":[{"def":"Of or pertaining to a reporter or reporters; as, the reportorial staff of a newspaper.","pos":""}],"REPOSAL":[{"def":"The act or state of reposing; as, the reposal of a trust.","pos":""},{"def":"That on which one reposes.","pos":""}],"REPOSANCE":[{"def":"Re*pos\"ance (-ans), n.","pos":""}],"REPOSE":[{"def":"To cause to stop or to rest after motion; hence, to deposit; to lay down; to lodge; to reposit.","pos":""},{"def":"To lay at rest; to cause to be calm or quiet; to compose; to rest, -- often reflexive; as, to repose one's self on a couch.","pos":""}],"REPOSED":[{"def":"Composed; calm; tranquil; at rest.","pos":""}],"REPOSEFUL":[{"def":"Full of repose; quiet.","pos":""}],"REPOSER":[{"def":"One who reposes.","pos":""}],"REPOSIT":[{"def":"To cause to rest or stay; to lay away; to lodge, as for safety or preservation; to place; to store.","pos":""}],"REPOSITION":[{"def":"The act of repositing; a laying up.","pos":""}],"REPOSITOR":[{"def":"An instrument employed for replacing a displaced organ or part.","pos":""}],"REPOSITORY":[{"def":"A place where things are or may be reposited, or laid up, for safety or preservation; a depository.","pos":""}],"REPOSSESS":[{"def":"To possess again; as, to repossess the land.","pos":""}],"REPOSSESSION":[{"def":"The act or the state of possessing again.","pos":""}],"REPOSURE":[{"def":"Re*po\"sure (r-p\"shr; 135), n.","pos":""}],"REPOUSSAGE":[{"def":"Art or process of hammering out or pressing thin metal from the reverse side: (1) in producing repoussé work; (2) in leveling up any part of an etched plate that has been worked so as to cause a depression.","pos":""}],"REPOUSSE":[{"def":"Re*pous`sé\" (re -p`s\"), a.","pos":""}]}