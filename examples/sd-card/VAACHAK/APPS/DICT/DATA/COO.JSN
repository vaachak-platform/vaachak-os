{"COO":[{"def":"A peculiar whistling sound made by the Australian aborigenes as a call or signal.","pos":""}],"COOK":[{"def":"To make the noise of the cuckoo.","pos":""}],"COOKBOOK":[{"def":"A book of directions and receipts for cooking; a cookery book.","pos":""}],"COOKERY":[{"def":"The art or process of preparing food for the table, by dressing, compounding, and the application of heat.","pos":""},{"def":"A delicacy; a dainty.","pos":""}],"COOKMAID":[{"def":"A female servant or maid who dresses provisions and assists the cook.","pos":""}],"COOKROOM":[{"def":"A room for cookery; a kitchen; the galley or caboose of a ship.","pos":""}],"COOKSHOP":[{"def":"An eating house.","pos":""}],"COOKY":[{"def":"A small, flat, sweetened cake of various kinds.","pos":""}],"COOL":[{"def":"Moderately cold; between warm and cold; lacking in warmth; producing or promoting coolness.","pos":""},{"def":"Not ardent, warm, fond, or passionate; not hasty; deliberate; exercising self-control; self-possessed; dispassionate; indifferent; as, a cool lover; a cool debater.","pos":""}],"COOL-HEADED":[{"def":"Having a temper not easily excited; free from passion.","pos":""}],"COOLER":[{"def":"That which cools, or abates heat or excitement.","pos":""}],"COOLING":[{"def":"Adapted to cool and refresh; allaying heat.","pos":""}],"COOLISH":[{"def":"The nights began to grow a little coolish.","pos":""}],"COOLLY":[{"def":"In a cool manner; without heat or excessive cold; without passion or ardor; calmly; deliberately; with indifference; impudently.","pos":""}],"COOLNESS":[{"def":"The state of being cool; a moderate degree of cold; a moderate degree, or a want, of passion; want of ardor, zeal, or affection; calmness.","pos":""},{"def":"Calm impudence; self-possession.","pos":""}],"COOLUNG":[{"def":"The great gray crane of India (Grus cinerea).","pos":""},{"def":"An East Indian porter or carrier; a laborer transported from the East Indies, China, or Japan, for service in some other country.","pos":""}],"COOM":[{"def":"Soot; coal dust; refuse matter, as the dirty grease which comes from axle boxes, or the refuse at the mouth of an oven.","pos":""}],"COOMB":[{"def":"A dry measure of four bushels, or half a quarter.","pos":""},{"def":"A hollow in a hillside.","pos":""}],"COONCAN":[{"def":"A game of cards derived from conquian, played by two or more players with one or two full packs of cards.","pos":""}],"COONTIE":[{"def":"A cycadaceous plant of Florida and the West Indies, the Zamia integrifolia, from the stems of which a kind of sago is prepared.","pos":""}],"COOP":[{"def":"A barrel or cask for liquor.","pos":""},{"def":"An inclosure for keeping small animals; a pen; especially, a grated box for confining poultry.","pos":""}],"COOPER":[{"def":"One who makes barrels, hogsheads, casks, etc.","pos":""}],"COOPERAGE":[{"def":"Work done by a cooper.","pos":""},{"def":"The price paid for coopers; work.","pos":""}],"COOPERANT":[{"def":"Operating together; as, coöperant forces.","pos":""}],"COOPERATE":[{"def":"To act or operate jointly with another or others; to concur in action, effort, or effect.","pos":""}],"COOPERATION":[{"def":"The association of a number of persons for their benefit.","pos":""}],"COOPERATIVE":[{"def":"Operating jointly to the same end.","pos":""}],"COOPERATOR":[{"def":"One who labors jointly with others to promote the same end.","pos":""}],"COOPERING":[{"def":"Work done by a cooper in making or repairing barrels, casks, etc.","pos":""}],"COOPERY":[{"def":"Relating to a cooper; coopered.","pos":""}],"COOPT":[{"def":"To choose or elect in concert with another.","pos":""}],"COOPTATE":[{"def":"To choose; to elect; to coöpt.","pos":""}],"COOPTATION":[{"def":"The act of choosing; selection; choice.","pos":""}],"COORDAIN":[{"def":"To ordain or appoint for some purpose along with another.","pos":""}],"COORDINANCE":[{"def":"Joint ordinance.","pos":""}],"COORDINATE":[{"def":"Equal in rank or order; not subordinate.","pos":""}],"COORDINATELY":[{"def":"In a coördinate manner.","pos":""}],"COORDINATENESS":[{"def":"The state of being coördinate; equality of rank or authority.","pos":""}],"COORDINATION":[{"def":"The act of coördinating; the act of putting in the same order, class, rank, dignity, etc.","pos":""},{"def":"The state of being coördinate, or of equal rank, dignity, power, etc.","pos":""}],"COORDINATIVE":[{"def":"Expressing coördination.","pos":""}],"COOT":[{"def":"A stupid fellow; a simpleton; as, a silly coot.","pos":""}],"COOTFOOT":[{"def":"The pharalope; -- so called because its toes are like the coot's.","pos":""}],"COOTHAY":[{"def":"A striped satin made in India.","pos":""}]}