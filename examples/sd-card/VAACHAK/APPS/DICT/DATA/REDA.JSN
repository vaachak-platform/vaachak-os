{"REDACT":[{"def":"To reduce to form, as literary matter; to digest and put in shape (matter for publication); to edit.","pos":""}],"REDACTEUR":[{"def":"Ré`dac`teur\" (ray`dak`ter\"), n.","pos":""}],"REDACTION":[{"def":"The act of redacting; work produced by redacting; a digest.","pos":""}],"REDACTOR":[{"def":"One who redacts; one who prepares matter for publication; an editor.","pos":""}],"REDAN":[{"def":"A work having two parapets whose faces unite so as to form a salient angle toward the enemy.","pos":""}],"REDARGUE":[{"def":"To disprove; to refute; toconfute; to reprove; to convict.","pos":""}],"REDARGUTION":[{"def":"The act of redarguing; refutation.","pos":""}],"REDARGUTORY":[{"def":"Pertaining to, or containing, redargution; refutatory.","pos":""}]}