{"SHAVE":[{"def":"His beard was shave as nigh as ever he can.","pos":""}],"SHAVELING":[{"def":"A man shaved; hence, a monk, or other religious; -- used in contempt.","pos":""}],"SHAVER":[{"def":"A tool or machine for shaving.","pos":""}],"SHAVING":[{"def":"The act of one who, or that which, shaves; specifically, the act of cutting off the beard with a razor.","pos":""},{"def":"That which is shaved off; a thin slice or strip pared off with a shave, a knife, a plane, or other cutting instrument.","pos":""}]}