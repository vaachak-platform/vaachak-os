{"GLOAM":[{"def":"To be sullen or morose.","pos":""}],"GLOAMING":[{"def":"Twilight; dusk; the fall of the evening.","pos":""},{"def":"Sullenness; melancholy.","pos":""}],"GLOAR":[{"def":"To squint; to stare.","pos":""}],"GLOAT":[{"def":"To look steadfastly; to gaz In vengeance gloating on another's pain.","pos":""}],"GLOBARD":[{"def":"Having the form of a globe; spherical.","pos":""}],"GLOBE":[{"def":"A round or spherical body, solid or hollow; a body whose surface is in every part equidistant from the center; a ball; a sphere.","pos":""},{"def":"Anything which is nearly spherical or globular in shape; as, the globe of the eye; the globe of a lamp.","pos":""}],"GLOBE-SHAPED":[{"def":"Shaped like a globe.","pos":""}],"GLOBEFISH":[{"def":"A plectognath fish of the genera Diodon, Tetrodon, and allied genera.","pos":""}],"GLOBIFEROUS":[{"def":"Having a round or globular tip.","pos":""}],"GLOBIGERINA":[{"def":"A genus of small Foraminifera, which live abundantly at or near the surface of the sea.","pos":""}],"GLOBOSE":[{"def":"Having a rounded form resembling that of a globe; globular, or nearly so; spherical.","pos":""}],"GLOBOSELY":[{"def":"In a globular manner; globularly.","pos":""}],"GLOBULAR":[{"def":"Globe-shaped; having the form of a ball or sphere; spherical, or nearly so; as, globular atoms.","pos":""}],"GLOBULARITY":[{"def":"The state of being globular; globosity; sphericity.","pos":""}],"GLOBULARNESS":[{"def":"Sphericity; globosity.","pos":""}],"GLOBULE":[{"def":"A minute spherical or rounded structure; as blood, lymph, and pus corpuscles, minute fungi, spores, etc.","pos":""}],"GLOBULET":[{"def":"A little globule.","pos":""}],"GLOBULIFEROUS":[{"def":"Bearing globules; in geology, used of rocks, and denoting a variety of concretionary structure, where the concretions are isolated globules and evenly distributed through the texture of the rock.","pos":""}],"GLOBULIMETER":[{"def":"An instrument for measuring the number of red blood corpuscles in the blood.","pos":""}],"GLOBULIN":[{"def":"An albuminous body, insoluble in water, but soluble in dilute solutions of salt.","pos":""}],"GLOBULITE":[{"def":"A rudimentary form of crystallite, spherical in shape.","pos":""}],"GLOBULOUS":[{"def":"Globular; spherical; orbicular.","pos":""}],"GLOBY":[{"def":"Resembling, or pertaining to, a globe; round; orbicular.","pos":""}],"GLOCHIDIATE":[{"def":"Having barbs; as, glochidiate bristles.","pos":""}],"GLOCHIDIUM":[{"def":"The larva or young of the mussel, formerly thought to be a parasite upon the parent's gills.","pos":""}],"GLOCKENSPIEL":[{"def":"An instrument, originally a series of bells on an iron rod, now a set of flat metal bars, diatonically tuned, giving a bell-like tone when played with a mallet; a carillon.","pos":""}],"GLODE":[{"def":"To gloom; to look gloomy, morose, or sullen.","pos":""}],"GLOME":[{"def":"One of the two prominences at the posterior extremity of the frog of the horse's foot.","pos":""}],"GLOMERATE":[{"def":"Gathered together in a roundish mass or dense cluster; conglomerate.","pos":""}],"GLOMERATION":[{"def":"The act of forming or gathering into a ball or round mass; the state of being gathered into a ball; conglomeration.","pos":""},{"def":"That which is formed into a ball; a ball.","pos":""}],"GLOMEROUS":[{"def":"Gathered or formed into a ball or round mass.","pos":""}],"GLOMERULE":[{"def":"A head or dense cluster of flowers, formed by condensation of a cyme, as in the flowering dogwood.","pos":""}],"GLOMERULUS":[{"def":"The bunch of looped capillary blood vessels in a Malpighian capsule of the kidney.","pos":""}],"GLOMULIFEROUS":[{"def":"Having small clusters of minutely branched coral-like excrescences.","pos":""},{"def":"A dilute solution of nitroglycerin used as a neurotic.","pos":""}],"GLOOM":[{"def":"Partial or total darkness; thick shade; obscurity; as, the gloom of a forest, or of midnight.","pos":""},{"def":"A shady, gloomy, or dark place or grove.","pos":""}],"GLOOMILY":[{"def":"In a gloomy manner.","pos":""}],"GLOOMINESS":[{"def":"State of being gloomy.","pos":""}],"GLOOMING":[{"def":"Twilight (of morning or evening); the gloaming.","pos":""}],"GLOOMY":[{"def":"Imperfectly illuminated; dismal through obscurity or darkness; dusky; dim; clouded; as, the cavern was gloomy.","pos":""},{"def":"Affected with, or expressing, gloom; melancholy; dejected; as, a gloomy temper or countenance.","pos":""}],"GLOPPEN":[{"def":"To surprise or astonish; to be startled or astonished.","pos":""}],"GLORE":[{"def":"To glare; to glower.","pos":""}],"GLORIA":[{"def":"Episcopal Church the version in English is used.","pos":""}],"GLORIATION":[{"def":"Boast; a triumphing.","pos":""}],"GLORIED":[{"def":"Illustrious; honorable; noble.","pos":""}],"GLORIFICATION":[{"def":"The act of glorifyng or of giving glory to.","pos":""},{"def":"The state of being glorifed; as, the glorification of Christ after his resurrection.","pos":""}],"GLORIFY":[{"def":"To make glorious by bestowing glory upon; to confer honor and distinction upon; to elevate to power or happiness, or to celestial glory.","pos":""},{"def":"To make glorious in thought or with the heart, by ascribing glory to; to asknowledge the excellence of; to render homage to; to magnify in worship; to adore.","pos":""}],"GLORIOSA":[{"def":"A genus of climbing plants with very showy lilylike blossoms, natives of India.","pos":""}],"GLORIOUS":[{"def":"Exhibiting attributes, qualities, or acts that are worthy of or receive glory; noble; praiseworthy; excellent; splendid; illustrious; inspiring admiration; as, glorious deeds.","pos":""},{"def":"Eager for glory or distinction; haughty; boastful; ostentatious; vainglorious.","pos":""}],"GLORY":[{"def":"Praise, honor, admiration, or distinction, accorded by common consent to a person or thing; high reputation; honorable fame; renown.","pos":""},{"def":"That quality in a person or thing which secures general praise or honor; that which brings or gives renown; an object of pride or boast; the occasion of praise; excellency; brilliancy; splendor.","pos":""}],"GLOSS":[{"def":"Bbrightness or luster of a body proceeding from a smooth surface; polish; as, the gloss of silk; cloth is calendered to give it a gloss.","pos":""},{"def":"A specious appearance; superficial quality or show.","pos":""}],"GLOSSA":[{"def":"The tongue, or lingua, of an insect.","pos":""}],"GLOSSAL":[{"def":"Of or pertaining to the tongue; lingual.","pos":""}],"GLOSSANTHRAX":[{"def":"A disease of horses and cattle accompanied by carbuncles in the mouth and on the tongue.","pos":""}],"GLOSSARIAL":[{"def":"Of or pertaining to glosses or to a glossary; containing a glossary.","pos":""}],"GLOSSARIALLY":[{"def":"In the manner of a glossary.","pos":""}],"GLOSSARIST":[{"def":"A writer of glosses or of a glossary; a commentator; a scholiast.","pos":""}],"GLOSSARY":[{"def":"A collection of glosses or explanations of words and passages of a work or author; a partial dictionary of a work, an author, a dialect, art, or science, explaining archaic, technical, or other uncommon words.","pos":""}],"GLOSSATA":[{"def":"The Lepidoptera.","pos":""}],"GLOSSATOR":[{"def":"A writer of glosses or comments; a commentator.","pos":""}],"GLOSSER":[{"def":"A polisher; one who gives a luster.","pos":""}],"GLOSSIC":[{"def":"A system of phonetic spelling based upon the present values of English letters, but invariably using one symbol to represent one sound only.","pos":""}],"GLOSSILY":[{"def":"In a glossy manner.","pos":""}],"GLOSSINESS":[{"def":"The condition or quality of being glossy; the luster or brightness of a smooth surface.","pos":""}],"GLOSSIST":[{"def":"A writer of comments.","pos":""}],"GLOSSITIS":[{"def":"Inflammation of the tongue.","pos":""}],"GLOSSLY":[{"def":"Like gloss; specious.","pos":""}],"GLOSSOCOMON":[{"def":"A kind of hoisting winch.","pos":"noun"}],"GLOSSOEPIGLOTTIC":[{"def":"Pertaining to both tongue and epiglottis; as, glossoepiglottic folds.","pos":""}],"GLOSSOGRAPHER":[{"def":"A writer of a glossary; a commentator; a scholiast.","pos":""}],"GLOSSOGRAPHICAL":[{"def":"Of or pertaining to glossography.","pos":""}],"GLOSSOGRAPHY":[{"def":"The writing of glossaries, glosses, or comments for illustrating an author.","pos":""}],"GLOSSOHYAL":[{"def":"Pertaining to both the hyoidean arch and the tongue; -- applied to the anterior segment of the hyoidean arch in many fishes.","pos":""},{"def":"The gift of tongues.","pos":""}],"GLOSSOLOGICAL":[{"def":"Of or pertaining to glossology.","pos":""}],"GLOSSOLOGIST":[{"def":"One who defines and explains terms; one who is versed in glossology.","pos":""}],"GLOSSOLOGY":[{"def":"The definition and explanation of terms; a glossary.","pos":""},{"def":"The science of language; comparative philology; linguistics; glottology.","pos":""}],"GLOSSOPHARYNGEAL":[{"def":"Pertaining to both the tongue and the pharynx; -- applied especially to the ninth pair of cranial nerves, which are distributed to the pharynx and tongue.","pos":""}],"GLOSSY":[{"def":"Smooth and shining; reflecting luster from a smooth surface; highly polished; lustrous; as, glossy silk; a glossy surface.","pos":""},{"def":"Smooth; specious; plausible; as, glossy deceit.","pos":""}],"GLOST OVEN":[{"def":"An oven in which glazed pottery is fired; -- also called glaze kiln, or glaze.","pos":""}],"GLOTTAL":[{"def":"Of or pertaining to, or produced by, the glottis; glottic.","pos":""},{"def":"Of or pertaining to the glottis; glottal.","pos":""}],"GLOTTIS":[{"def":"The opening from the pharynx into the larynx or into the trachea.","pos":""}],"GLOTTOLOGICAL":[{"def":"Of or pertaining to glottology.","pos":""}],"GLOTTOLOGIST":[{"def":"A linguist; a philologist.","pos":""}],"GLOTTOLOGY":[{"def":"The science of tongues or languages; comparative philology; glossology.","pos":""}],"GLOUT":[{"def":"To pout; to look sullen.","pos":""}],"GLOVE":[{"def":"A cover for the hand, or for the hand and wrist, with a separate sheath for each finder.","pos":""}],"GLOVER":[{"def":"One whose trade it is to make or sell gloves.","pos":""}],"GLOW":[{"def":"To shine with an intense or white heat; to give forth vivid light and heat; to be incandenscent.","pos":""},{"def":"To exhibit a strong, bright color; to be brilliant, as if with heat; to be bright or red with heat or animation, with blushes, etc.","pos":""}],"GLOWER":[{"def":"to look intently; to stare angrily or with a scowl.","pos":""}],"GLOWINGLY":[{"def":"In a glowing manner; with ardent heat or passion.","pos":""}],"GLOWLAMP":[{"def":"An aphlogistic lamp.","pos":""},{"def":"An incandescent lamp.","pos":""}],"GLOWWORM":[{"def":"A coleopterous insect of the genus Lampyris; esp.","pos":""}],"GLOXINIA":[{"def":"American genus of herbaceous plants with very handsome bell- shaped blossoms; -- named after B.","pos":""}],"GLOZE":[{"def":"To flatter; to wheedle; to fawn; to talk smoothly.","pos":""},{"def":"To give a specious or false meaning; to ministerpret.","pos":""}]}