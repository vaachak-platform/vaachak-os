{"TAT":[{"def":"Gunny cloth made from the fiber of the Corchorus olitorius, or jute.","pos":""}],"TATAUPA":[{"def":"A South American tinamou (Crypturus tataupa).","pos":""}],"TATCH":[{"def":"A spot or stain; also, a trick.","pos":""}],"TATH":[{"def":"Dung, or droppings of cattle.","pos":""},{"def":"The luxuriant grass growing about the droppings of cattle in a pasture.","pos":""}],"TATOU":[{"def":"The giant armadillo (Priodontes gigas) of tropical South America.","pos":""}],"TATOUAY":[{"def":"An armadillo (Xenurus unicinctus), native of the tropical parts of South America.","pos":""}],"TATT":[{"def":"To make (anything) by tatting; to work at tatting; as, tatted edging.","pos":""}],"TATTA":[{"def":"A bamboo frame or trellis hung at a door or window of a house, over which water is suffered to trickle, in order to moisten and cool the air as it enters.","pos":""}],"TATTER":[{"def":"One who makes tatting.","pos":""}],"TATTERDEMALION":[{"def":"A ragged fellow; a ragamuffin.","pos":""}],"TATTERSALL'S":[{"def":"A famous horse market in London, established in 1766 by Richard Tattersall, also used as the headquarters of credit betting on English horse races; hence, a large horse market elsewhere.","pos":""}],"TATTING":[{"def":"A kind of lace made from common sewing thread, with a peculiar stitch.","pos":""}],"TATTLE":[{"def":"To prate; to talk idly; to use many words with little meaning; to chat.","pos":""},{"def":"To tell tales; to communicate secrets; to be a talebearer; as, a tattling girl.","pos":""}],"TATTLER":[{"def":"Any one of several species of large, long-legged sandpipers belonging to the genus Totanus.","pos":""}],"TATTLERY":[{"def":"Idle talk or chat; tittle-tattle.","pos":""}],"TATTLING":[{"def":"Given to idle talk; apt to tell tales.","pos":""}],"TATTOO":[{"def":"A beat of drum, or sound of a trumpet or bugle, at night, giving notice to soldiers to retreat, or to repair to their quarters in garrison, or to their tents in camp.","pos":""}],"TATTY":[{"def":"A mat or screen of fibers, as of the kuskus grass, hung at a door or window and kept wet to moisten and cool the air as it enters.","pos":""}],"TATUSIID":[{"def":"Any armadillo of the family Tatusiidæ, of which the peba and mule armadillo are examples.","pos":""}]}