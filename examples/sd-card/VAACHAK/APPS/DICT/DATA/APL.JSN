{"APLACENTAL":[{"def":"Belonging to the Aplacentata; without placenta.","pos":""}],"APLACENTATA":[{"def":"Mammals which have no placenta.","pos":""}],"APLACOPHORA":[{"def":"A division of Amphineura in which the body is naked or covered with slender spines or setæ, but is without shelly plates.","pos":""}],"APLANATIC":[{"def":"Having two or more parts of different curvatures, so combined as to remove spherical aberration; -- said of a lens.","pos":""}],"APLANATISM":[{"def":"Freedom from spherical aberration.","pos":""}],"APLANOGAMETE":[{"def":"A nonmotile gamete, found in certain lower algæ.","pos":""}],"APLASIA":[{"def":"Incomplete or faulty development.","pos":""}],"APLASTIC":[{"def":"Not plastic or easily molded.","pos":""}],"APLOMB":[{"def":"Assurance of manner or of action; self-possession.","pos":""}],"APLOTOMY":[{"def":"Simple incision.","pos":""}],"APLUSTRE":[{"def":"An ornamental appendage of wood at the ship's stern, usually spreading like a fan and curved like a bird's feather.","pos":""}],"APLYSIA":[{"def":"A genus of marine mollusks of the order Tectibranchiata; the sea hare.","pos":""}]}