{"BIOBLAST":[{"def":"Same as Bioplast.","pos":""}],"BIOCELLATE":[{"def":"Having two ocelli (eyelike spots); -- said of a wing, etc.","pos":""}],"BIOCHEMISTRY":[{"def":"The chemistry of living organisms; the chemistry of the processes incidental to, and characteristic of, life.","pos":""},{"def":"Of or pertaining to biodynamics, or the doctrine of vital forces or energy.","pos":""}],"BIODYNAMICS":[{"def":"The doctrine of vital forces or energy.","pos":""}],"BIOGEN":[{"def":"BIOGENESIS; BIOGENY Bi`o*gen\"e*sis, Bi*og\"e*ny, n.","pos":""}],"BIOGENETIC":[{"def":"Pertaining to biogenesis.","pos":""}],"BIOGENIST":[{"def":"A believer in the theory of biogenesis.","pos":""}],"BIOGEOGRAPHY":[{"def":"The branch of biology which deals with the geographical distribution of animals and plants.","pos":""}],"BIOGNOSIS":[{"def":"The investigation of life.","pos":""}],"BIOGRAPH":[{"def":"An animated picture machine for screen projection; a cinematograph.","pos":""}],"BIOGRAPHER":[{"def":"One who writes an account or history of the life of a particular person; a writer of lives, as Plutarch.","pos":""},{"def":"Of or pertaining to biography; containing biography.","pos":""}],"BIOGRAPHIZE":[{"def":"To write a history of the life of.","pos":""}],"BIOGRAPHY":[{"def":"Of or relating to biology.","pos":""}],"BIOLOGIST":[{"def":"A student of biology; one versed in the science of biology.","pos":""}],"BIOLOGY":[{"def":"The science of life; that branch of knowledge which treats of living matter as distinct from matter which is not living; the study of living tissue.","pos":""}],"BIOLYSIS":[{"def":"The destruction of life.","pos":""}],"BIOLYTIC":[{"def":"Relating to the destruction of life.","pos":""}],"BIOMAGNETIC":[{"def":"Relating to biomagnetism.","pos":""}],"BIOMAGNETISM":[{"def":"Animal magnetism.","pos":""}],"BIOMETRY":[{"def":"Measurement of life; calculation of the probable duration of human life.","pos":""}],"BION":[{"def":"The physiological individual, characterized by definiteness and independence of function, in distinction from the morphological individual or morphon.","pos":""}],"BIONOMY":[{"def":"One of the smaller vital units of a cell, the bearer of vitality and heredity.","pos":""}],"BIOPHOTOPHONE":[{"def":"An instrument combining a cinematograph and a phonograph so that the moving figures on the screen are accompanied by the appropriate sounds.","pos":""}],"BIOPLASM":[{"def":"A name suggested by Dr.","pos":""}],"BIOPLASMIC":[{"def":"Pertaining to, or consisting of, bioplasm.","pos":""}],"BIOPLAST":[{"def":"A tiny mass of bioplasm, in itself a living unit and having formative power, as a living white blood corpuscle; bioblast.","pos":""}],"BIOPLASTIC":[{"def":"Pertaining to psychical phenomena in their relation to the living organism or to the general phenomena of life.","pos":""}],"BIORGAN":[{"def":"A physiological organ; a living organ; an organ endowed with function; -- distinguished from idorgan.","pos":""}],"BIOSCOPE":[{"def":"A view of life; that which gives such a view.","pos":""}],"BIOSTATICS":[{"def":"The physical phenomena of organized bodies, in opposition to their organic or vital phenomena.","pos":""}],"BIOSTATISTICS":[{"def":"Vital statistics.","pos":""}],"BIOTAXY":[{"def":"The classification of living organisms according to their structural character; taxonomy.","pos":""}],"BIOTIC":[{"def":"Relating to life; as, the biotic principle.","pos":""}],"BIOTITE":[{"def":"Mica containing iron and magnesia, generally of a black or dark green color; -- a common constituent of crystalline rocks.","pos":""}]}