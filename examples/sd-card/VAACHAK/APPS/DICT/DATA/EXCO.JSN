{"EXCOCT":[{"def":"To boil out; to produce by boiling.","pos":""}],"EXCOCTION":[{"def":"The act of excocting or boiling out.","pos":""}],"EXCOGITATE":[{"def":"To think out; to find out or discover by thinking; to devise; to contrive.","pos":""}],"EXCOGITATION":[{"def":"The act of excogitating; a devising in the thoughts; invention; contrivance.","pos":""}],"EXCOMMUNE":[{"def":"To exclude from participation in; to excommunicate.","pos":""}],"EXCOMMUNICABLE":[{"def":"Liable or deserving to be excommunicated; making excommunication possible or proper.","pos":""}],"EXCOMMUNICANT":[{"def":"One who has been excommunicated.","pos":""}],"EXCOMMUNICATE":[{"def":"Excommunicated; interdicted from the rites of the church.","pos":""},{"def":"One excommunicated.","pos":""}],"EXCOMMUNICATION":[{"def":"The act of communicating or ejecting; esp.","pos":""}],"EXCOMMUNICATOR":[{"def":"One who excommunicates.","pos":""}],"EXCOMMUNION":[{"def":"Ex`com*mun\"ion Defn: .","pos":""}],"EXCORIABLE":[{"def":"Ex*co\"ri*a*ble Defn: .","pos":""}],"EXCORIATE":[{"def":"To strip or wear off the skin of; to abrade; to gall; to break and remove the cuticle of, in any manner, as by rubbing, beating, or by the action of acrid substances.","pos":""}],"EXCORIATION":[{"def":"The act of excoriating or flaying, or state of being excoriated, or stripped of the skin; abrasion.","pos":""},{"def":"Stripping of possession; spoliation.","pos":""}],"EXCORTICATE":[{"def":"To strip of bark or skin; to decorticate.","pos":""}],"EXCORTICATION":[{"def":"The act of stripping off bark, or the state of being thus stripped; decortication.","pos":""}]}