{"DISDAIN":[{"def":"A feeling of contempt and aversion; the regarding anything as unworthy of or beneath one; scorn.","pos":""},{"def":"That which is worthy to be disdained or regarded with contempt and aversion.","pos":""}],"DISDAINED":[{"def":"Revenge the jeering and disdained contempt Of this proud king.","pos":""}],"DISDAINFUL":[{"def":"Full of disdain; expressing disdain; scornful; contemptuous; haughty.","pos":""}],"DISDEIFY":[{"def":"To divest or deprive of deity or of a deific rank or condition.","pos":""}],"DISDEIGN":[{"def":"Guyon much disdeigned so loathly sight.","pos":""}],"DISDIACLAST":[{"def":"One of the dark particles forming the doubly refracting disks of muscle fibers.","pos":""}],"DISDIAPASON":[{"def":"An interval of two octaves, or a fifteenth; -- called also bisdiapason.","pos":""}]}