{"FABACEOUS":[{"def":"Having the nature of a bean; like a bean.","pos":""}],"FABELLA":[{"def":"One of the small sesamoid bones situated behind the condyles of the femur, in some mammals.","pos":""}],"FABIAN":[{"def":"Of, pertaining to, or in the manner of, the Roman general, Quintus Fabius Maximus Verrucosus; cautious; dilatory; avoiding a decisive contest.","pos":""}],"FABLE":[{"def":"A Feigned story or tale, intended to instruct or amuse; a fictitious narration intended to enforce some useful truth or precept; an apologue.","pos":""},{"def":"The plot, story, or connected series of events, forming the subject of an epic or dramatic poem.","pos":""}],"FABLER":[{"def":"A writer of fables; a fabulist; a dealer in untruths or falsehoods.","pos":""}],"FABLIAU":[{"def":"One of the metrical tales of the Trouvères, or early poets of the north of France.","pos":""}],"FABRIC":[{"def":"The structure of anything; the manner in which the parts of a thing are united; workmanship; texture; make; as cloth of a beautiful fabric.","pos":""},{"def":"That which is fabricated; as : (a) Framework; structure; edifice; building.","pos":""}],"FABRICANT":[{"def":"One who fabricates; a manufacturer.","pos":""}],"FABRICATE":[{"def":"To form into a whole by uniting its parts; to frame; to construct; to build; as, to fabricate a bridge or ship.","pos":""},{"def":"To form by art and labor; to manufacture; to produce; as, to fabricate woolens.","pos":""}],"FABRICATION":[{"def":"The act of fabricating, framing, or constructing; construction; manufacture; as, the fabrication of a bridge, a church, or a government.","pos":""},{"def":"That which is fabricated; a falsehood; as, the story is doubtless a fabrication.","pos":""}],"FABRICATOR":[{"def":"One who fabricates; one who constructs or makes.","pos":""}],"FABRICATRESS":[{"def":"A woman who fabricates.","pos":""}],"FABRILE":[{"def":"Pertaining to a workman, or to work in stone, metal, wood etc.","pos":""}],"FABULIST":[{"def":"One who invents or writes fables.","pos":""}],"FABULIZE":[{"def":"To invent, compose, or relate fables or fictions.","pos":""}],"FABULOSITY":[{"def":"A fabulous or fictitious story.","pos":""}],"FABULOUS":[{"def":"Feigned, as a story or fable; related in fable; devised; invented; not real; fictitious; as, a fabulous description; a fabulous hero.","pos":""},{"def":"Passing belief; exceedingly great; as, a fabulous price.","pos":""}],"FABURDEN":[{"def":"A monotonous refrain.","pos":""}]}