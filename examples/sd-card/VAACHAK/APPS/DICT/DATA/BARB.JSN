{"BARB":[{"def":"Paps, or little projections, of the mucous membrane, which mark the opening of the submaxillary glands under the tongue in horses and cattle.","pos":""},{"def":"One of the side branches of a feather, which collectively constitute the vane.","pos":""}],"BARBACANAGE":[{"def":"See Barbicanage.","pos":""}],"BARBADIAN":[{"def":"Of or pertaining to Barbados.","pos":""},{"def":"A native of Barbados.","pos":""}],"BARBARA":[{"def":"The first word in certain mnemonic lines which represent the various forms of the syllogism.","pos":""}],"BARBARESQUE":[{"def":"Barbaric in form or style; as, barbaresque architecture.","pos":""}],"BARBARIAN":[{"def":"A man in a rule, savage, or uncivilized state.","pos":""}],"BARBARIC":[{"def":"Of, or from, barbarian nations; foreign; -- often with reference to barbarous nations of east.","pos":""},{"def":"Of or pertaining to, or resembling, an uncivilized person or people; barbarous; barbarian; destitute of refinement.","pos":""}],"BARBARISM":[{"def":"An uncivilized state or condition; rudeness of manners; ignorance of arts, learning, and literature; barbarousness.","pos":""},{"def":"A barbarous, cruel, or brutal action; an outrage.","pos":""}],"BARBARITY":[{"def":"The state or manner of a barbarian; lack of civilization.","pos":""}],"BARBARIZE":[{"def":"To become barbarous.","pos":""},{"def":"To adopt a foreign or barbarous mode of speech.","pos":""}],"BARBAROUS":[{"def":"Being in the state of a barbarian; uncivilized; rude; peopled with barbarians; as, a barbarous people; a barbarous country.","pos":""},{"def":"Foreign; adapted to a barbaric taste.","pos":""}],"BARBAROUSLY":[{"def":"In a barbarous manner.","pos":""}],"BARBAROUSNESS":[{"def":"The quality or state of being barbarous; barbarity; barbarism.","pos":""}],"BARBARY":[{"def":"The countries on the north coast of Africa from Egypt to the Atlantic.","pos":""}],"BARBASTEL":[{"def":"A European bat (Barbastellus communis), with hairy lips.","pos":""}],"BARBATE":[{"def":"Bearded; beset with long and weak hairs.","pos":""}],"BARBATED":[{"def":"Having barbed points.","pos":""}],"BARBECUE":[{"def":"A hog, ox, or other large animal roasted or broiled whole for a feast.","pos":""},{"def":"A social entertainment, where many people assemble, usually in the open air, at which one or more large animals are roasted or broiled whole.","pos":""}],"BARBED":[{"def":"Accoutered with defensive armor; -- said of a horse.","pos":""}],"BARBEL":[{"def":"A slender tactile organ on the lips of certain fished.","pos":"noun"},{"def":"A large fresh-water fish ( Barbus vulgaris) found in many European rivers.","pos":"noun"}],"BARBELLATE":[{"def":"Having short, stiff hairs, often barbed at the point.","pos":""}],"BARBELLULATE":[{"def":"Barbellate with diminutive hairs or barbs.","pos":""}],"BARBER":[{"def":"One whose occupation it is to shave or trim the beard, and to cut and dress the hair of his patrons.","pos":""}],"BARBER FISH":[{"def":"See Surgeon fish.","pos":""}],"BARBERRY":[{"def":"A shrub of the genus Berberis, common along roadsides and in neglected fields.","pos":""}],"BARBETTE":[{"def":"A mound of earth or a platform in a fortification, on which guns are mounted to fire over the parapet.","pos":""},{"def":"Money paid for the support of a barbican.","pos":""}],"BARBICEL":[{"def":"One of the small hooklike processes on the barbules of feathers.","pos":""}],"BARBIERS":[{"def":"A variety of paralysis, peculiar to India and the Malabar coast; -- considered by many to be the same as beriberi in chronic form.","pos":""}],"BARBIGEROUS":[{"def":"Having a beard; bearded; hairy.","pos":""}],"BARBITON":[{"def":"An ancient Greek instrument resembling a lyre.","pos":""}],"BARBITURIC ACID":[{"def":"A white, crystalline substance, BARBIZON SCHOOL; BARBISON SCHOOL Bar`bi`zon\" school or Bar`bi`son\" school.","pos":""},{"def":"A French school of the middle of the 19th century centering in the village of Barbizon near the forest of Fontainebleau.","pos":""}],"BARBOTINE":[{"def":"A paste of clay used in decorating coarse pottery in relief.","pos":""}],"BARBULE":[{"def":"One of the processes along the edges of the barbs of a feather, by which adjacent barbs interlock.","pos":""}]}