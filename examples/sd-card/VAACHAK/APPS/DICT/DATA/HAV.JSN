{"HAVANA":[{"def":"Of or pertaining to Havana, the capital of the island of Cuba; as, an Havana cigar; -- formerly sometimes written Havannah.","pos":""},{"def":"An Havana cigar.","pos":""}],"HAVANESE":[{"def":"Of or pertaining to Havana, in Cuba.","pos":""},{"def":"A native or inhabitant, or the people, of Havana.","pos":""}],"HAVE":[{"def":"To hold in possession or control; to own; as, he has a farm.","pos":""},{"def":"To possess, as something which appertains to, is connected with, or affects, one.","pos":""}],"HAVELESS":[{"def":"Having little or nothing.","pos":""}],"HAVELOCK":[{"def":"A light cloth covering for the head and neck, used by soldiers as a protection from sunstroke.","pos":""}],"HAVEN":[{"def":"A bay, recess, or inlet of the sea, or the mouth of a river, which affords anchorage and shelter for shipping; a harbor; a port.","pos":""},{"def":"A place of safety; a shelter; an asylum.","pos":""}],"HAVENAGE":[{"def":"Harbor dues; port dues.","pos":""}],"HAVENED":[{"def":"Sheltered in a haven.","pos":""}],"HAVENER":[{"def":"A harbor master.","pos":""}],"HAVER":[{"def":"A possessor; a holder.","pos":""}],"HAVERSACK":[{"def":"A bag for oats or oatmeal.","pos":""},{"def":"A bag or case, usually of stout cloth, in which a soldier carries his rations when on a march; -- distinguished from knapsack.","pos":""}],"HAVERSIAN":[{"def":"Pertaining to, or discovered by, Clopton Havers, an English physician of the seventeenth century.","pos":""}],"HAVIER":[{"def":"A castrated deer.","pos":""}],"HAVILDAR":[{"def":"In the British Indian armies, a noncommissioned officer of native soldiers, corresponding to a sergeant.","pos":""}],"HAVING":[{"def":"Possession; goods; estate.","pos":""}],"HAVIOR":[{"def":"Behavior; demeanor.","pos":""}],"HAVOC":[{"def":"Wide and general destruction; devastation; waste.","pos":""}]}