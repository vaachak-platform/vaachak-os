{"CAST":[{"def":"To stereotype or electrotype.","pos":""}],"CAST IRON":[{"def":"Highly carbonized iron, the direct product of the blast furnace; -- used for making castings, and for conversion into wrought iron and steel.","pos":""}],"CAST STEEL":[{"def":"See Cast steel, under Steel.","pos":""}],"CAST-IRON":[{"def":"Made of cast iron.","pos":""}],"CAST-OFF":[{"def":"Cast or laid aside; as, cast-off clothes.","pos":""}],"CASTALIAN":[{"def":"Of or pertaining to Castalia, a mythical fountain of inspiration on Mt.","pos":""}],"CASTANEA":[{"def":"A genus of nut-bearing trees or shrubs including the chestnut and chinquapin.","pos":""}],"CASTANETS":[{"def":"Two small, concave shells of ivory or hard wood, shaped like spoons, fastened to the thumb, and beaten together with the middle finger; -- used by the Spaniards and Moors as an accompaniment to their dance and guitars.","pos":""}],"CASTAWAY":[{"def":"One who, or that which, is cast away or shipwrecked.","pos":""},{"def":"One who is ruined; one who has made moral shipwreck; a reprobate.","pos":""}],"CASTE":[{"def":"One of the hereditary classes into which the Hindoos are divided according to the laws of Brahmanism.","pos":""},{"def":"A separate and fixed order or class of persons in society who chiefly hold intercourse among themselves.","pos":""}],"CASTELLAN":[{"def":"A goveror or warden of a castle.","pos":""}],"CASTELLANY":[{"def":"The lordship of a castle; the extent of land and jurisdiction appertaining to a castle.","pos":""}],"CASTELLATED":[{"def":"Inclosed within a building; as, a fountain or cistern castellated.","pos":""},{"def":"Furnished with turrets and battlements, like a castle; built in the style of a castle.","pos":""}],"CASTELLATION":[{"def":"The act of making into a castle.","pos":""}],"CASTER":[{"def":"One who casts; as, caster of stones, etc.","pos":""},{"def":"A vial, cruet, or other small vessel, used to contain condiments at the table; as, a set of casters.","pos":""}],"CASTIGATE":[{"def":"To punish by stripes; to chastise by blows; to chasten; also, to chastise verbally; to reprove; to criticise severely.","pos":""},{"def":"To emend; to correct.","pos":""}],"CASTIGATION":[{"def":"Corrective punishment; chastisement; reproof; pungent criticism.","pos":""},{"def":"Emendation; correction.","pos":""}],"CASTIGATOR":[{"def":"One who castigates or corrects.","pos":""}],"CASTIGATORY":[{"def":"Punitive in order to amendment; corrective.","pos":""}],"CASTILE SOAP":[{"def":"A kind of fine, hard, white or mottled soap, made with olive and soda; also, a soap made in imitation of the above-described soap.","pos":""}],"CASTILIAN":[{"def":"An inhabitant or native of Castile, in Spain.","pos":""},{"def":"The Spanish language as spoken in Castile.","pos":""}],"CASTILLAN":[{"def":"Of or pertaining to Castile, in Spain.","pos":""}],"CASTING":[{"def":"The act of one who casts or throws, as in fishing.","pos":""},{"def":"The act or process of making cast or impressions, or of shaping metal or plaster in a mold; the act or the process of pouring molten metal into a mold.","pos":""}],"CASTLE":[{"def":"A fortified residence, especially that of a prince or nobleman; a fortress.","pos":""},{"def":"Any strong, imposing, and stately mansion.","pos":""}],"CASTLE-GUARD":[{"def":"A tax or imposition an a dwelling within a certain distance of a castle, for the purpose of maintaining watch and ward in it; castle-ward.","pos":""}],"CASTLED":[{"def":"Having a castle or castles; supporting a castle; as, a castled height or crag.","pos":""}],"CASTLERY":[{"def":"The government of a castle.","pos":""}],"CASTLEWARD":[{"def":"Same as Castleguard.","pos":""}],"CASTLING":[{"def":"That which is cast or brought forth prematurely; an abortion.","pos":""}],"CASTOR":[{"def":"A genus of rodents, including the beaver.","pos":""}],"CASTOR AND POLLUX":[{"def":"See Saint Elmo's fire, under Saint.","pos":""}],"CASTOR BEAN":[{"def":"The bean or seed of the castor-oil plant (Ricinus communis, or Palma Christi.","pos":""}],"CASTOR OIL":[{"def":"A mild cathartic oil, expressed or extracted from the seeds of the Ricinus communis, or Palma Christi.","pos":""}],"CASTOREUM":[{"def":"A peculiar bitter orange-brown substance, with strong, penetrating odor, found in two sacs between the anus and external genitals of the beaver; castor; -- used in medicine as an antispasmodic, and by perfumers.","pos":""}],"CASTORIN":[{"def":"A white crystalline substance obtained from castoreum.","pos":""}],"CASTRAMETATION":[{"def":"The art or act of encamping; the making or laying out of a camp.","pos":""}],"CASTRATE":[{"def":"To deprive of the testicles; to emasculate; to geld; to alter.","pos":""},{"def":"To cut or take out; esp.","pos":""}],"CASTRATION":[{"def":"The act of castrating.","pos":""}],"CASTRATO":[{"def":"A male person castrated for the purpose of improving his voice for singing; an artificial, or male, soprano.","pos":""}],"CASTRENSIAL":[{"def":"Belonging to a camp.","pos":""}]}