{"CORTEGE":[{"def":"A train of attendants; a procession.","pos":""}],"CORTES":[{"def":"The legislative assembly, composed of nobility, clergy, and representatives of cities, which in Spain and in Portugal answers, in some measure, to the Parliament of Great Britain.","pos":""}],"CORTES GERAES":[{"def":"See Legislature, Portugal.","pos":""}],"CORTEX":[{"def":"Bark; rind; specifically, cinchona bark.","pos":""},{"def":"The outer or superficial part of an organ; as, the cortex or gray exterior substance of the brain.","pos":""}],"CORTICAL":[{"def":"Belonging to, or consisting of, bark or rind; resembling bark or rind; external; outer; superficial; as, the cortical substance of the kidney.","pos":""},{"def":"Having a special outer covering of a nature unlike the interior part.","pos":""}],"CORTICIFER":[{"def":"One of the Gorgoniacea; -- so called because the fleshy part surrounds a solid axis, like a bark.","pos":""}],"CORTICIFEROUS":[{"def":"Producing bark or something that resembling that resembles bark.","pos":""}],"CORTICIFORM":[{"def":"Resembling, or having the form of, bark or rind.","pos":""}],"CORTICINE":[{"def":"A material for carpeting or floor covering, made of ground cork and caoutchouc or India rubber.","pos":""}],"CORTICOSE":[{"def":"Abounding in bark; resembling bark; barky.","pos":""}],"CORTICOUS":[{"def":"Relating to, or resembling, bark; corticose.","pos":""}],"CORTILE":[{"def":"An open internal courtyard inclosed by the walls of a large dwelling house or other large and stately building.","pos":""}]}