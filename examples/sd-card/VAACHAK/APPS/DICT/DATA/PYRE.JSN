{"PYRE":[{"def":"A funeral pile; a combustible heap on which the dead are burned; hence, any pile to be burnt.","pos":""}],"PYRENA":[{"def":"A nutlet resembling a seed, or the kernel of a drupe.","pos":""}],"PYRENE":[{"def":"One of the less volatile hydrocarbons of coal tar, obtained as a white crystalline substance, C16H10.","pos":""}],"PYRENEAN":[{"def":"Of or pertaining to the Pyrenees, a range of mountains separating France and Spain.","pos":""}],"PYRENOID":[{"def":"A transparent body found in the chromatophores of certain Infusoria.","pos":""}],"PYRETHRIN":[{"def":"A substance resembling, and isomeric with, ordinary camphor, and extracted from the essential oil of feverfew; -- called also Pyrethrum camphor.","pos":""}],"PYRETHRINE":[{"def":"An alkaloid extracted from the root of the pellitory of Spain (Anacyclus pyrethrum).","pos":""}],"PYRETIC":[{"def":"Of or pertaining to fever; febrile.","pos":""}],"PYRETOLOGY":[{"def":"A discourse or treatise on fevers; the doctrine of fevers.","pos":""}],"PYREXIA":[{"def":"The febrile condition.","pos":""},{"def":"Of or pertaining to fever; feverish.","pos":""}]}