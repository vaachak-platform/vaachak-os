{"FOREDATE":[{"def":"To date before the true time; to antendate.","pos":""}],"FOREDECK":[{"def":"The fore part of a deck, or of a ship.","pos":""}],"FOREDEEM":[{"def":"To recognize or judge in advance; to forebode.","pos":""}],"FOREDESIGN":[{"def":"To plan beforehand; to intend previously.","pos":""}],"FOREDETERMINE":[{"def":"To determine or decree beforehand.","pos":""}],"FOREDISPOSE":[{"def":"To bestow beforehand.","pos":""}],"FOREDOOM":[{"def":"To doom beforehand; to predestinate.","pos":""}]}