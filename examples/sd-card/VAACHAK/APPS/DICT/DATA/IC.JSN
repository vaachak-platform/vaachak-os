{"ICARIAN":[{"def":"Soaring too high for safety, like Icarus; adventurous in flight.","pos":""}],"ICE":[{"def":"Water or other fluid frozen or reduced to the solid state by cold; frozen water.","pos":""},{"def":"Concreted sugar.","pos":""}],"ICE PLANT":[{"def":"A plant (Mesembryanthemum crystallinum), sprinkled with pellucid, watery vesicles, which glisten like ice.","pos":""}],"ICE-BUILT":[{"def":"Composed of ice.","pos":""},{"def":"Loaded with ice.","pos":""}],"ICEBERG":[{"def":"A large mass of ice, generally floating in the ocean.","pos":""}],"ICEBIRD":[{"def":"An Arctic sea bird, as the Arctic fulmar.","pos":""}],"ICEBOUND":[{"def":"Totally surrounded with ice, so as to be incapable of advancing; as, an icebound vessel; also, surrounded by or fringed with ice so as to hinder easy access; as, an icebound coast.","pos":""}],"ICED":[{"def":"Covered with ice; chilled with ice; as, iced water.","pos":""},{"def":"Covered with something resembling ice, as sugar icing; frosted; as, iced cake.","pos":""}],"ICEFALL":[{"def":"A frozen waterfall, or mass of ice resembling a frozen waterfall.","pos":""}],"ICELAND MOSS":[{"def":"A kind of lichen (Cetraria Icelandica) found from the Arctic regions to the North Temperate zone.","pos":""}],"ICELAND SPAR":[{"def":"A transparent variety of calcite, the best of which is obtained in Iceland.","pos":""}],"ICELANDER":[{"def":"A native, or one of the Scandinavian people, of Iceland.","pos":""}],"ICELANDIC":[{"def":"Of or pertaining to Iceland; relating to, or resembling, the Icelanders.","pos":""}],"ICEMAN":[{"def":"A man who is skilled in traveling upon ice, as among glaciers.","pos":""},{"def":"One who deals in ice; one who retails or delivers ice.","pos":""}],"ICEQUAKE":[{"def":"The crash or concussion attending the breaking up of masses of ice, -- often due to contraction from extreme cold.","pos":""}],"ICH":[{"def":"Note: In the Southern dialect of Early English this is the regular form.","pos":""}],"ICHNEUMON":[{"def":"Any carnivorous mammal of the genus Herpestes, and family Viverridæ.","pos":""},{"def":"Any hymenopterous insect of the family Ichneumonidæ, of which several thousand species are known, belonging to numerous genera.","pos":""}],"ICHNEUMONIDAN":[{"def":"Of or pertaining to the Ichneumonidæ, or ichneumon flies.","pos":""},{"def":"One of the Ichneumonidæ.","pos":""}],"ICHNEUMONIDES":[{"def":"The ichneumon flies.","pos":""}],"ICHNITE":[{"def":"A fossil footprint; as, the ichnites in the Triassic sandstone.","pos":""},{"def":"Of or pertaining to ichonography; describing a ground plot.","pos":""}],"ICHNOGRAPHY":[{"def":"A horizontal section of a building or other object, showing its true dimensions according to a geometric scale; a ground plan; a map; also, the art of making such plans.","pos":""}],"ICHNOLITE":[{"def":"A fossil footprint; an ichnite.","pos":""}],"ICHNOLITHOLOGY":[{"def":"Same as Ichnology.","pos":""}],"ICHNOLOGICAL":[{"def":"Of or pertaining to ichnology.","pos":""}],"ICHNOLOGY":[{"def":"The branch of science which treats of fossil footprints.","pos":""}],"ICHNOSCOPY":[{"def":"The search for the traces of anything.","pos":""}],"ICHOR":[{"def":"An ethereal fluid that supplied the place of blood in the veins of the gods.","pos":""}],"ICHORHAEMIA":[{"def":"Infection of the blood with ichorous or putrid substances.","pos":""}],"ICHOROUS":[{"def":"Of or like ichor; thin; watery; serous; sanious.","pos":""}],"ICHTHIDIN":[{"def":"A substance from the egg yolk of osseous fishes.","pos":""}],"ICHTHIN":[{"def":"A nitrogenous substance resembling vitellin, present in the egg yolk of cartilaginous fishes.","pos":""}],"ICHTHULIN":[{"def":"A substance from the yolk of salmon's egg.","pos":""}],"ICHTHYIC":[{"def":"Like, or pertaining to, fishes.","pos":""},{"def":"Fish glue; isinglass; a glue prepared from the sounds of certain fishes.","pos":""}],"ICHTHYOCOPROLITE":[{"def":"Fossil dung of fishes.","pos":""}],"ICHTHYODORULITE":[{"def":"One of the spiny plates foundon the back and tail of certain skates.","pos":""}],"ICHTHYOGRAPHY":[{"def":"A treatise on fishes.","pos":""},{"def":"Somewhat like a fish; having some of the characteristics of fishes; -- said of some amphibians.","pos":""}],"ICHTHYOL":[{"def":"An oily substance prepared by the dry distillation of a bituminous mineral containing fossil fishes.","pos":""}],"ICHTHYOLATRY":[{"def":"Worship of fishes, or of fish-shaped idols.","pos":""}],"ICHTHYOLITE":[{"def":"A fossil fish, or fragment of a fish.","pos":""},{"def":"Of or pertaining to ichthyology.","pos":""}],"ICHTHYOLOGIST":[{"def":"One versed in, or who studies, ichthyology.","pos":""}],"ICHTHYOLOGY":[{"def":"The natural history of fishes; that branch of zoölogy which relates to fishes, including their structure, classification, and habits.","pos":""}],"ICHTHYOMANCY":[{"def":"Divination by the heads or the entrails of fishes.","pos":""}],"ICHTHYOMORPHA":[{"def":"Fish-shaped; as, the ichthyomorphic idols of ancient Assyria.","pos":""}],"ICHTHYOPHAGIST":[{"def":"One who eats, or subsists on, fish.","pos":""}],"ICHTHYOPHAGOUS":[{"def":"Eating, or subsisting on, fish.","pos":""}],"ICHTHYOPHAGY":[{"def":"The practice of eating, or living upon, fish.","pos":""}],"ICHTHYOPHTHALMITE":[{"def":"See Apophyllite.","pos":""}],"ICHTHYOPHTHIRA":[{"def":"A division of copepod crustaceans, including numerous species parasitic on fishes.","pos":""}],"ICHTHYOPSIDA":[{"def":"A grand division of the Vertebrata, including the Amphibia and Fishes.","pos":""}],"ICHTHYOPTERYGIA":[{"def":"See Ichthyosauria.","pos":""}],"ICHTHYOPTERYGIUM":[{"def":"The typical limb, or lateral fin, of fishes.","pos":""}],"ICHTHYORNIS":[{"def":"An extinct genus of toothed birds found in the American Cretaceous formation.","pos":""}],"ICHTHYOSAUR":[{"def":"One of the Ichthyosaura.","pos":""}],"ICHTHYOSAURIA":[{"def":"An extinct order of marine reptiles, including Ichthyosaurus and allied forms; -- called also Ichthyopterygia.","pos":""}],"ICHTHYOSAURIAN":[{"def":"Of or pertaining to the Ichthyosauria.","pos":""},{"def":"One of the Ichthyosauria.","pos":""}],"ICHTHYOSAURUS":[{"def":"An extinct genus of marine reptiles; -- so named from their short, biconcave vertebræ, resembling those of fishes.","pos":""}],"ICHTHYOSIS":[{"def":"A disease in which the skin is thick, rough, and scaly; -- called also fishskin.","pos":""}],"ICHTHYOTOMIST":[{"def":"One skilled in ichthyotomy.","pos":""}],"ICHTHYOTOMY":[{"def":"The anatomy or dissection of fishes.","pos":""}],"ICHTHYS":[{"def":"Same as Ichthus.","pos":""}],"ICICLE":[{"def":"A pendent, and usually conical, mass of ice, formed by freezing of dripping water; as, the icicles on the eaves of a house.","pos":""}],"ICICLED":[{"def":"Having icicles attached.","pos":""}],"ICILY":[{"def":"In an icy manner; coldly.","pos":""}],"ICINESS":[{"def":"The state or quality of being icy or very cold; frigidity.","pos":""}],"ICING":[{"def":"A coating or covering resembling ice, as of sugar and milk or white of egg; frosting.","pos":""}],"ICON":[{"def":"An image or representation; a portrait or pretended portrait.","pos":""}],"ICONICAL":[{"def":"Pertaining to, or consisting of, images, pictures, or representations of any kind.","pos":""}],"ICONISM":[{"def":"The formation of a figure, representation, or semblance; a delineation or description.","pos":""}],"ICONIZE":[{"def":"To form an image or likeness of.","pos":""}],"ICONOCLASM":[{"def":"The doctrine or practice of the iconoclasts; image breaking.","pos":""}],"ICONOCLAST":[{"def":"A breaker or destroyer of images or idols; a determined enemy of idol worship.","pos":""},{"def":"One who exposes or destroys impositions or shams; one who attacks cherished beliefs; a radical.","pos":""}],"ICONOCLASTIC":[{"def":"Of or pertaining to the iconoclasts, or to image breaking.","pos":""},{"def":"One who serves images; -- opposed to an iconoclast.","pos":""}],"ICONOGRAPH":[{"def":"An engraving or other picture or illustration for a book.","pos":""}],"ICONOGRAPHER":[{"def":"A maker of images.","pos":""}],"ICONOGRAPHIC":[{"def":"Of or pertaining to iconography.","pos":""},{"def":"Representing by means of pictures or diagrams; as, an icongraphic encyclopædia.","pos":""}],"ICONOGRAPHY":[{"def":"The art or representation by pictures or images; the description or study of portraiture or representation, as of persons; as, the iconography of the ancients.","pos":""},{"def":"The study of representative art in general.","pos":""}],"ICONOLATER":[{"def":"One who worships images.","pos":""}],"ICONOLATRY":[{"def":"The worship of images as symbols; -- distinguished from idolatry, the worship of images themselves.","pos":""}],"ICONOLOGY":[{"def":"The discussion or description of portraiture or of representative images.","pos":""}],"ICONOMACHY":[{"def":"Hostility to images as objects of worship.","pos":""}],"ICONOMANIA":[{"def":"A mania or infatuation for icons, whether as objects of devotion, bric-a-brac, or curios.","pos":""}],"ICONOMICAL":[{"def":"Opposed to pictures or images as objects of worship.","pos":""}],"ICONOPHILIST":[{"def":"A student, or lover of the study, of iconography.","pos":""}],"ICOSAHEDRAL":[{"def":"Having twenty equal sides or faces.","pos":""}],"ICOSAHEDRON":[{"def":"A solid bounded by twenty sides or faces.","pos":""}],"ICOSANDRIA":[{"def":"A Linnæan class of plants, having twenty or more stamens inserted in the calyx.","pos":""},{"def":"Pertaining to the class Icosandria; having twenty or more stamens inserted in the calyx.","pos":""}],"ICOSITETRAHEDRON":[{"def":"A twenty-four-sided solid; a tetragonal trisoctahedron or trapezohedron.","pos":""}],"ICTERIC":[{"def":"A remedy for the jaundice.","pos":""},{"def":"Yellow; of the color of the skin when it is affected by the jaundice.","pos":""}],"ICTEROID":[{"def":"Of a tint resembling that produced by jaundice; yellow; as, an icteroid tint or complexion.","pos":""}],"ICTIC":[{"def":"Pertaining to, or caused by, a blow; sudden; abrupt.","pos":""}],"ICTUS":[{"def":"The stress of voice laid upon accented syllable of a word.","pos":""},{"def":"A stroke or blow, as in a sunstroke, the sting of an insect, pulsation of an artery, etc.","pos":""}],"ICY":[{"def":"Pertaining to, resembling, or abounding in, ice; cold; frosty.","pos":""},{"def":"Characterized by coldness, as of manner, influence, etc.","pos":""}],"ICY-PEARLED":[{"def":"Spangled with ice.","pos":""}]}