{"CYLINDER":[{"def":"Any hollow body of cylindrical form, as: (a) The chamber of a steam engine in which the piston is moved by the force of steam.","pos":""},{"def":"The revolving square prism carryng the cards in a Jacquard loom.","pos":""}],"CYLINDRACEOUS":[{"def":"Cylindrical, or approaching a cylindrical form.","pos":""},{"def":"Having the form of a cylinder, or of a section of its convex surface; partaking of the properties of the cylinder.","pos":""}],"CYLINDRICALLY":[{"def":"In the manner or shape of a cylinder; so as to be cylindrical.","pos":""}],"CYLINDRICITY":[{"def":"The quality or condition of being cylindrical.","pos":""}],"CYLINDRIFORM":[{"def":"Having the form of a cylinder.","pos":""}],"CYLINDROID":[{"def":"A certain surface of the third degree, described by a moving straight line; -- used to illustrate the motions of a rigid body and also the forces acting on the body.","pos":""}],"CYLINDROMETRIC":[{"def":"Belonging to a scale used in measuring cylinders.","pos":""}]}