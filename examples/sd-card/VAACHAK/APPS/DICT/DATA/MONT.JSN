{"MONT DE PIETE":[{"def":"One of certain public pawnbroking establishments which originated in Italy in the 15th century, the object of which was to lend money at a low rate of interest to poor people in need; -- called also mount of piety.","pos":""}],"MONTANIC":[{"def":"Of or pertaining to mountains; consisting of mountains.","pos":""}],"MONTANIST":[{"def":"A follower of Mintanus, a Phrygian enthusiast of the second century, who claimed that the Holy Spirit, the Paraclete, dwelt in him, and employed him as an instrument for purifying and guiding men in the Christian life.","pos":""}],"MONTANT":[{"def":"An upward thrust or blow.","pos":""},{"def":"An upright piece in any framework; a mullion or muntin; a stile.","pos":""}],"MONTE":[{"def":"A favorite gambling game among Spaniards, played with dice or cards.","pos":""}],"MONTE-ACID":[{"def":"An acid elevator, as a tube through which acid is forced to some height in a sulphuric acid manufactory.","pos":""}],"MONTE-JUS":[{"def":"An apparatus for raising a liquid by pressure of air or steam in a reservoir containing the liquid.","pos":""}],"MONTEM":[{"def":"A custom, formerly practiced by the scholars at Eton school, England, of giing every third year, on Whittuesday, to a hillock near the Bath road, and exacting money from all passers-by, to support at the university the senior scholar of the school.","pos":""}],"MONTERO":[{"def":"An ancient kind of cap worn by horsemen or huntsmen.","pos":""}],"MONTESSORI METHOD":[{"def":"A system of training and instruction, primarily for use with normal children aged from three to six years, devised by Dr.","pos":""},{"def":"A vessel in which glasses are washed; -- so called from the name of the inventor.","pos":""}],"MONTGOLFIER":[{"def":"A balloon which ascends by the buoyancy of air heated by a fire; a fire balloon; -- so called from two brothers, Stephen and Joseph Montgolfier, of France, who first constructed and sent up a fire balloon.","pos":""}],"MONTH":[{"def":"One of the twelve portions into which the year is divided; the twelfth part of a year, corresponding nearly to the length of a synodic revolution of the moon, -- whence the name.","pos":""}],"MONTHLING":[{"def":"That which is a month old, or which lives for a month.","pos":""}],"MONTHLY":[{"def":"Continued a month, or a performed in a month; as, the monthly revolution of the moon.","pos":""},{"def":"Done, happening, payable, published, etc.","pos":""}],"MONTICLE":[{"def":"A little mount; a hillock; a small elevation or prominence.","pos":""}],"MONTICULATE":[{"def":"Furnished with monticles or little elevations.","pos":""}],"MONTIFORM":[{"def":"Resembling a mountain in form.","pos":""}],"MONTIGENOUS":[{"def":"Produced on a mountain.","pos":""}],"MONTOIR":[{"def":"A stone used in mounting a horse; a horse block.","pos":""}],"MONTON":[{"def":"A heap of ore; a mass undergoing the process of amalgamation.","pos":""}],"MONTRE":[{"def":"A hole in the wall of a pottery kiln, by which the state of the pieces within can be judged.","pos":""}],"MONTRUE":[{"def":"That on which anything is mounted; a setting; hence, a saddle horse.","pos":""}]}