{"BOD VEAL":[{"def":"Veal too immature to be suitable for food.","pos":""}],"BODE":[{"def":"To indicate by signs, as future events; to be the omen of; to portend to presage; to foreshow.","pos":""}],"BODEFUL":[{"def":"Portentous; ominous.","pos":""}],"BODEMENT":[{"def":"An omen; a prognostic.","pos":""}],"BODGE":[{"def":"A botch; a patch.","pos":""}],"BODIAN":[{"def":"A large food fish (Diagramma lineatum), native of the East Indies.","pos":""}],"BODICE":[{"def":"A kind of under waist stiffened with whalebone, etc.","pos":""},{"def":"A close-fitting outer waist or vest forming the upper part of a woman's dress, or a portion of it.","pos":""}],"BODICED":[{"def":"Wearing a bodice.","pos":""}],"BODIED":[{"def":"Having a body; -- usually in composition; as, able-bodied.","pos":""}],"BODILESS":[{"def":"Without material form; incorporeal.","pos":""}],"BODILY":[{"def":"Having a body or material form; physical; corporeal; consisting of matter.","pos":""},{"def":"Of or pertaining to the body, in distinction from the mind.","pos":""}],"BODING":[{"def":"Foreshowing; presaging; ominous.","pos":""}],"BODKIN":[{"def":"An implement of steel, bone, ivory, etc.","pos":""},{"def":"A sharp tool, like an awl, used for picking 4.","pos":""}],"BODLE":[{"def":"A small Scotch coin worth about one sixth of an English penny.","pos":""}],"BODLEIAN":[{"def":"Of or pertaining to Sir Thomas Bodley, or to the celebrated library at Oxford, founded by him in the sixteenth century.","pos":""}],"BODOCK":[{"def":"The Osage orange.","pos":""}],"BODY":[{"def":"The shank of a type, or the depth of the shank (by which the size is indicated); as, a nonpareil face on an agate body.","pos":""},{"def":"A figure that has length, breadth, and thickness; any solid figure.","pos":""}],"BODYGUARD":[{"def":"A guard to protect or defend the person; a lifeguard.","pos":""},{"def":"Retinue; attendance; following.","pos":""}]}