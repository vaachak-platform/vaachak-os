{"MONOCARBONIC":[{"def":"Containing one carboxyl group; as, acetic acid is a monocarbonic acid.","pos":""}],"MONOCARDIAN":[{"def":"Having a single heart, as fishes and amphibians.","pos":""},{"def":"An animal having a single heart.","pos":""}],"MONOCARP":[{"def":"A monocarpic plant.","pos":""}],"MONOCARPELLARY":[{"def":"Consisting of a single carpel, as the fruit of the pea, cherry, and almond.","pos":""},{"def":"Bearing fruit but once, and dying after fructification, as beans, maize, mustard, etc.","pos":""}],"MONOCEPHALOUS":[{"def":"Having a solitary head; -- said of unbranched composite plants.","pos":""}],"MONOCEROS":[{"def":"The Unicorn, a constellation situated to the east Orion.","pos":""}],"MONOCHLAMYDEOUS":[{"def":"Having a single floral envelope, that is, a calyx without a corolla, or, possibly, in rare cases, a corolla without a calyx.","pos":""}],"MONOCHORD":[{"def":"An instrument for experimenting upon the mathematical relations of musical sounds.","pos":""}],"MONOCHROMATIC":[{"def":"Consisting of one color, or presenting rays of light of one color only.","pos":""}],"MONOCHROME":[{"def":"A painting or drawing in a single color; a picture made with a single color.","pos":""}],"MONOCHROMIC":[{"def":"Made, or done, with a single color; as, a monochromic picture.","pos":""}],"MONOCHROMY":[{"def":"The art of painting or drawing in monochrome.","pos":""}],"MONOCHRONIC":[{"def":"Existing at the same time; contemporaneous.","pos":""}],"MONOCILIATED":[{"def":"Having but one cilium.","pos":""}],"MONOCLE":[{"def":"An eyeglass for one eye.","pos":""}],"MONOCLINAL":[{"def":"Having one oblique inclination; -- applied to strata that dip in only one direction from the axis of elevation.","pos":""}],"MONOCLINE":[{"def":"A monoclinal fold.","pos":""}],"MONOCLINIC":[{"def":"Having one oblique intersection; -- said of that system of crystallization in which the vertical axis is inclined to one, but at right angles to the other, lateral axis.","pos":""}],"MONOCLINOUS":[{"def":"Hermaphrodite, or having both stamens and pistils in every flower.","pos":""}],"MONOCONDYLA":[{"def":"A group of vertebrates, including the birds and reptiles, or those that have only one occipital condyle; the Sauropsida.","pos":""}],"MONOCOTYL":[{"def":"Any monocotyledonous plant.","pos":""}],"MONOCOTYLE":[{"def":"Monocotyledonous.","pos":""}],"MONOCOTYLEDON":[{"def":"A plant with only one cotyledon, or seed lobe.","pos":""}],"MONOCOTYLEDONOUS":[{"def":"Having only one cotyledon, seed lobe, or seminal leaf.","pos":""}],"MONOCRACY":[{"def":"Government by a single person; undivided rule.","pos":""}],"MONOCRAT":[{"def":"One who governs alone.","pos":""}],"MONOCROTIC":[{"def":"Of, pertaining to, or showing, monocrotism; as, a monocrotic pulse; a pulse of the monocrotic type.","pos":""}],"MONOCROTISM":[{"def":"That condition of the pulse in which the pulse curve or sphygmogram shows but a single crest, the dicrotic elevation entirely disappearing.","pos":""}],"MONOCULAR":[{"def":"Having only one eye; with one eye only; as, monocular vision.","pos":""},{"def":"Adapted to be used with only one eye at a time; as, a monocular microscope.","pos":""}],"MONOCULE":[{"def":"A small crustacean with one median eye.","pos":""}],"MONOCYSTIC":[{"def":"Of or pertaining to a division (Monocystidea) of Gregarinida, in which the body consists of one sac.","pos":""}]}