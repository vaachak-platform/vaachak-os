{"FLACCID":[{"def":"Yielding to pressure for want of firmness and stiffness; soft and weak; limber; lax; drooping; flabby; as, a flaccid muscle; flaccid flesh.","pos":""}],"FLACCIDITY":[{"def":"The state of being flaccid.","pos":""}],"FLACHERIE":[{"def":"A bacterial disease of silkworms, supposed to be due to eating contaminated mulberry leaves.","pos":""}],"FLACKER":[{"def":"To flutter, as a bird.","pos":""}],"FLACKET":[{"def":"A barrel-shaped bottle; a flagon.","pos":""}],"FLACON":[{"def":"A small glass bottle; as, a flacon for perfume.","pos":""}]}