{"LUCARNE":[{"def":"A dormer window.","pos":""}],"LUCCHESE":[{"def":"A native or inhabitant of Lucca, in Tuscany; in the plural, the people of Lucca.","pos":""}],"LUCE":[{"def":"A pike when full grown.","pos":""}],"LUCENCY":[{"def":"The quality of being lucent.","pos":""}],"LUCENT":[{"def":"Shining; bright; resplendent.","pos":""}],"LUCERN":[{"def":"A sort of hunting dog; -- perhaps from Lucerne, in Switzerland.","pos":""},{"def":"An animal whose fur was formerly much in req [Written also lusern and luzern.","pos":""}],"LUCERNAL":[{"def":"Of or pertaining to a lamp.","pos":""}],"LUCERNARIA":[{"def":"A genus of acalephs, having a bell-shaped body with eight groups of short tentacles around the margin.","pos":""}],"LUCERNARIAN":[{"def":"Of or pertaining to the Lucernarida.","pos":""},{"def":"One of the Lucernarida.","pos":""}],"LUCERNE":[{"def":"See Lucern, the plant.","pos":""}],"LUCID":[{"def":"Shining; bright; resplendent; as, the lucid orbs of heaven.","pos":""},{"def":"Clear; transparent.","pos":""}],"LUCIDITY":[{"def":"The quality or state of being lucid.","pos":""}],"LUCIDLY":[{"def":"In a lucid manner.","pos":""}],"LUCIDNESS":[{"def":"The quality of being lucid; lucidity.","pos":""}],"LUCIFER":[{"def":"A genus of free-swimming macruran Crustacea, having a slender body and long appendages.","pos":""}],"LUCIFERIAN":[{"def":"Of or pertaining to Lucifer; having the pride of Lucifer; satanic; devilish.","pos":""},{"def":"Of or pertaining to the Luciferians or their leader.","pos":""}],"LUCIFEROUS":[{"def":"Giving light; affording light or means of discovery.","pos":""}],"LUCIFEROUSLY":[{"def":"In a luciferous manner.","pos":""}],"LUCIFIC":[{"def":"Producing light.","pos":""}],"LUCIFORM":[{"def":"Having, in some respects, the nature of light; resembling light.","pos":""}],"LUCIFRIAN":[{"def":"Luciferian; satanic.","pos":""}],"LUCIMETER":[{"def":"an instrument for measuring the intensity of light; a photometer.","pos":""}],"LUCK":[{"def":"If thou dost play with him at any game, Thou art sure to lose; and of that natural luck, He beats thee 'gainst the odds.","pos":""}],"LUCKILY":[{"def":"In a lucky manner; by good fortune; fortunately; -- used in a good sense; as, they luckily escaped injury.","pos":""}],"LUCKINESS":[{"def":"The state or quality of being lucky; as, the luckiness of a man or of an event.","pos":""},{"def":"Good fortune; favorable issue or event.","pos":""}],"LUCKLESS":[{"def":"Being without luck; unpropitious; unfortunate; unlucky; meeting with ill success or bad fortune; as, a luckless gamester; a luckless maid.","pos":""}],"LUCKY":[{"def":"Favored by luck; fortunate; meeting with good success or good fortune; -- said of persons; as, a lucky adventurer.","pos":""},{"def":"Producing, or resulting in, good by chance, or unexpectedly; favorable; auspicious; fortunate; as, a lucky mistake; a lucky cast; a lucky hour.","pos":""}],"LUCKY PROACH":[{"def":"See Fatherlasher.","pos":""}],"LUCRATIVE":[{"def":"Yielding lucre; gainful; profitable; making increase of money or goods; as, a lucrative business or office.","pos":""},{"def":"Greedy of gain [Obs.","pos":""}],"LUCRATIVELY":[{"def":"In a lucrative manner.","pos":""}],"LUCRE":[{"def":"Gain in money or goods; profit; riches; -- often in an ill sense.","pos":""}],"LUCRIFEROUS":[{"def":"Gainful; profitable.","pos":""}],"LUCRIFIC":[{"def":"Producing profit; gainful.","pos":""}],"LUCTATION":[{"def":"Effort to overcome in contest; struggle; endeavor.","pos":""}],"LUCTUAL":[{"def":"Producing grief; saddening.","pos":""}],"LUCUBRATE":[{"def":"To study by candlelight or a lamp; to study by night.","pos":""}],"LUCUBRATION":[{"def":"The act of lucubrating, or studying by candlelight; nocturnal study; meditation.","pos":""},{"def":"That which is composed by night; that which is produced by meditation in retirement; hence (loosely) any literary composition.","pos":""}],"LUCUBRATOR":[{"def":"One who studies by night; also, one who produces lucubrations.","pos":""}],"LUCUBRATORY":[{"def":"Composed by candlelight, or by night; of or pertaining to night studies; laborious or painstaking.","pos":""}],"LUCULE":[{"def":"A spot or fleck on the sun brighter than the surrounding surface.","pos":""}],"LUCULENT":[{"def":"Lucid; clear; transparent.","pos":""},{"def":"Clear; evident; luminous.","pos":""}],"LUCULENTLY":[{"def":"In a luculent manner; clearly.","pos":""}],"LUCULLITE":[{"def":"A variety of black limestone, often polished for ornamental purposes.","pos":""}],"LUCUMA":[{"def":"An American genus of sapotaceous trees bearing sweet and edible fruits.","pos":""}]}