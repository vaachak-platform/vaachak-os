{"PRESEANCE":[{"def":"Priority of place in sitting.","pos":""}],"PRESELECT":[{"def":"To select beforehand.","pos":""}],"PRESENCE":[{"def":"The state of being present, or of being within sight or call, or at hand; -- opposed to absence.","pos":""},{"def":"The place in which one is present; the part of space within one's ken, call, influence, etc.","pos":""}],"PRESENSATION":[{"def":"Previous sensation, notion, or idea.","pos":""}],"PRESENSION":[{"def":"Previous perception.","pos":""}],"PRESENT":[{"def":"Being at hand, within reach or call, within certain contemplated limits; -- opposed to absent.","pos":""},{"def":"Now existing, or in process; begun but not ended; now in view, or under consideration; being at this time; not past or future; as, the present session of Congress; the present state of affairs; the present instance.","pos":""}],"PRESENTABLE":[{"def":"Capable or admitting of being presented; suitable to be exhibited, represented, or offered; fit to be brought forward or set forth; hence, fitted to be introduced to another, or to go into society; as, ideas that are presentable in simple language; she is not presentable in such a gown.","pos":""},{"def":"Admitting of the presentation of a clergiman; as, a church presentable.","pos":""}],"PRESENTANEOUS":[{"def":"Ready; quick; immediate in effect; as, presentaneous poison.","pos":""}],"PRESENTATION":[{"def":"exhibition; representation; display; appearance; semblance; show.","pos":""},{"def":"The act of offering a clergyman to the bishop or ordinary for institution in a benefice; the right of presenting a clergyman.","pos":""}],"PRESENTATIVE":[{"def":"Having the right of presentation, or offering a clergyman to the bishop for institution; as, advowsons are presentative, collative, or donative.","pos":""},{"def":"Capable of being directly known by, or presented to, the mind; intuitive; directly apprehensible, as objects; capable of apprehending, as faculties.","pos":""}],"PRESENTEE":[{"def":"One to whom something is presented; also, one who is presented; specifically (Eccl.","pos":""}],"PRESENTER":[{"def":"One who presents.","pos":""}],"PRESENTIAL":[{"def":"Implying actual presence; present, immediate.","pos":""}],"PRESENTIALITY":[{"def":"State of being actually present.","pos":""}],"PRESENTIATE":[{"def":"To make present.","pos":""}],"PRESENTIENT":[{"def":"Feeling or perceiving beforehand.","pos":""}],"PRESENTIMENT":[{"def":"Previous sentiment, conception, or opinion; previous apprehension; especially, an antecedent impression or conviction of something unpleasant, distressing, or calamitous, about to happen; anticipation of evil; foreboding.","pos":""}],"PRESENTIMENTAL":[{"def":"Of nature of a presentiment; foreboding.","pos":""}],"PRESENTIVE":[{"def":"Bringing a conception or notion directly before the mind; presenting an object to the memory of imagination; -- distinguished from symbolic.","pos":""}],"PRESENTLY":[{"def":"At present; at this time; now.","pos":""},{"def":"At once; without delay; forthwith; also, less definitely, soon; shortly; before long; after a little while; by and by.","pos":""}],"PRESENTMENT":[{"def":"The act of presenting, or the state of being presented; presentation.","pos":""},{"def":"Setting forth to view; delineation; appearance; representation; exhibition.","pos":""}],"PRESENTNESS":[{"def":"The quality or state of being present; presence.","pos":""}],"PRESENTOIR":[{"def":"An ornamental tray, dish, or the like, used as a salver.","pos":""},{"def":"The principal which, drawing interest at a given rate, will amount to the given sum at the date on which this is to be paid; thus, interest being at 6%, the present value of $106 due one year hence is $100.","pos":""}],"PRESERVABLE":[{"def":"Capable of being preserved; admitting of preservation.","pos":""}],"PRESERVATION":[{"def":"The act or process of preserving, or keeping safe; the state of being preserved, or kept from injury, destruction, or decay; security; safety; as, preservation of life, fruit, game, etc.","pos":""}],"PRESERVATIVE":[{"def":"Having the power or quality of preserving; tending to preserve, or to keep from injury, decay, etc.","pos":""}],"PRESERVATORY":[{"def":"A room, or apparatus, in which perishable things, as fruit, vegetables, etc.","pos":""}],"PRESERVE":[{"def":"To keep or save from injury or destruction; to guard or defend from evil, harm, danger, etc.","pos":""},{"def":"To save from decay by the use of some preservative substance, as sugar, salt, etc.","pos":""}],"PRESERVER":[{"def":"One who, or that which, preserves, saves, or defends, from destruction, injury, or decay; esp.","pos":""},{"def":"One who makes preserves of fruit.","pos":""}]}