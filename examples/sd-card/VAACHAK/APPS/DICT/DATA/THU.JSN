{"THUD":[{"def":"A dull sound without resonance, like that produced by striking with, or striking against, some comparatively soft substance; also, the stroke or blow producing such sound; as, the thrud of a cannon ball striking the earth.","pos":""}],"THUG":[{"def":"One of an association of robbers and murderers in India who practiced murder by stealthy approaches, and from religious motives.","pos":""}],"THUGGEE":[{"def":"The practice of secret or stealthy murder by Thugs.","pos":""}],"THUJA":[{"def":"A genus of evergreen trees, thickly branched, remarkable for the distichous arrangement of their branches, and having scalelike, closely imbricated, or compressed leaves.","pos":""}],"THULE":[{"def":"The name given by ancient geographers to the northernmost part of the habitable world.","pos":""}],"THULIA":[{"def":"Oxide of thulium.","pos":""}],"THULIUM":[{"def":"A rare metallic element of uncertain properties and identity, said to have been found in the mineral gadolinite.","pos":""}],"THUMB":[{"def":"The short, thick first digit of the human hand, differing from the other fingers in having but two phalanges; the pollex.","pos":""}],"THUMBED":[{"def":"Soiled by handling.","pos":""}],"THUMBKIN":[{"def":"An instrument of torture for compressing the thumb; a thumbscrew.","pos":""}],"THUMBLESS":[{"def":"Without a thumb.","pos":""}],"THUMBSCREW":[{"def":"A screw having a flat-sided or knurled head, so that it may be turned by the thumb and forefinger.","pos":""},{"def":"An old instrument of torture for compressing the thumb by a screw; a thumbkin.","pos":""}],"THUMMIE":[{"def":"The chiff-chaff.","pos":""}],"THUMMIM":[{"def":"A mysterious part or decoration of the breastplate of the Jewish high priest.","pos":""}],"THUMP":[{"def":"The sound made by the sudden fall or blow of a heavy body, as of a hammer, or the like.","pos":"verb"},{"def":"A blow or knock, as with something blunt or heavy; a heavy fall.","pos":"verb"}],"THUMPER":[{"def":"One who, or that which, thumps.","pos":""}],"THUNDER":[{"def":"The sound which follows a flash of lightning; the report of a discharge of atmospheric electricity.","pos":""},{"def":"The discharge of electricity; a thunderbolt.","pos":""}],"THUNDERBIRD":[{"def":"An Australian insectivorous singing bird (Pachycephala gutturalis).","pos":""}],"THUNDERBOLT":[{"def":"A belemnite, or thunderstone.","pos":""}],"THUNDERBURST":[{"def":"A burst of thunder.","pos":""}],"THUNDERCLAP":[{"def":"A sharp burst of thunder; a sudden report of a discharge of atmospheric electricity.","pos":""}],"THUNDERCLOUD":[{"def":"A cloud charged with electricity, and producing lightning and thunder.","pos":""}],"THUNDERER":[{"def":"One who thunders; -- used especially as a translation of L.","pos":""}],"THUNDERFISH":[{"def":"A large European loach (Misgurnus fossilis).","pos":""}],"THUNDERHEAD":[{"def":"A rounded mass of cloud, with shining white edges; a cumulus, - - often appearing before a thunderstorm.","pos":""}],"THUNDERING":[{"def":"Emitting thunder.","pos":""},{"def":"Very great; -- often adverbially.","pos":""}],"THUNDERLESS":[{"def":"Without thunder or noise.","pos":""}],"THUNDEROUS":[{"def":"Producing thunder.","pos":""},{"def":"Making a noise like thunder; sounding loud and deep; sonorous.","pos":""}],"THUNDERPROOF":[{"def":"Secure against the effects of thunder or lightning.","pos":""}],"THUNDERSHOWER":[{"def":"A shower accompanied with lightning and thunder.","pos":""}],"THUNDERSTONE":[{"def":"A thunderbolt, -- formerly believed to be a stone.","pos":""}],"THUNDERSTORM":[{"def":"A storm accompanied with lightning and thunder.","pos":""}],"THUNDERSTRIKE":[{"def":"To strike, blast, or injure by, or as by, lightning.","pos":""},{"def":"To astonish, or strike dumb, as with something terrible; -- rarely used except in the past participle.","pos":""}],"THUNDERWORM":[{"def":"A small, footless, burrowing, snakelike lizard (Rhineura Floridana) allied to Amphisbæna, native of Florida; -- so called because it leaves its burrows after a thundershower.","pos":""}],"THUNDERY":[{"def":"Accompanied with thunder; thunderous.","pos":""}],"THUNDROUS":[{"def":"Thunderous; sonorous.","pos":""}],"THURGHFARE":[{"def":"This world is but a thurghfare full of woe.","pos":""}],"THURIBLE":[{"def":"A censer of metal, for burning incense, having various forms, held in the hand or suspended by chains; -- used especially at mass, vespers, and other solemn services.","pos":""}],"THURIFEROUS":[{"def":"Producing or bearing frankincense.","pos":""}],"THURIFICATION":[{"def":"The act of fuming with incense, or the act of burning incense.","pos":""}],"THURINGIAN":[{"def":"Of or pertaining to Thuringia, a country in Germany, or its people.","pos":""},{"def":"A native, or inhabitant of Thuringia.","pos":""}],"THURINGITE":[{"def":"A mineral occurring as an aggregation of minute scales having an olive-green color and pearly luster.","pos":""}],"THURL":[{"def":"A hole; an aperture.","pos":""}],"THURLING":[{"def":"Same as Thurl, n.","pos":""}],"THURROK":[{"def":"The hold of a ship; a sink.","pos":""}],"THURSDAY":[{"def":"The fifth day of the week, following Wednesday and preceding Friday.","pos":""}],"THURST":[{"def":"The ruins of the fallen roof resulting from the removal of the pillars and stalls.","pos":""}],"THUS":[{"def":"The commoner kind of frankincense, or that obtained from the Norway spruce, the long-leaved pine, and other conifers.","pos":""}],"THUYIN":[{"def":"A substance extracted from trees of the genus Thuja, or Thuya, and probably identical with quercitrin.","pos":""}]}