{"COMB":[{"def":"An instrument with teeth, for straightening, cleansing, and adjusting the hair, or for keeping it in place.","pos":""},{"def":"An instrument for currying hairy animals, or cleansing and smoothing their coats; a currycomb.","pos":""}],"COMBAT":[{"def":"To struggle or contend, as with an opposing force; to fight.","pos":""}],"COMBATABLE":[{"def":"Such as can be, or is liable to be, combated; as, combatable foes, evils, or arguments.","pos":""}],"COMBATANT":[{"def":"Contending; disposed to contend.","pos":""}],"COMBATER":[{"def":"One who combats.","pos":""}],"COMBATIVENESS":[{"def":"A cranial development supposed to indicate a combative disposition.","pos":""}],"COMBATTANT":[{"def":"In the position of fighting; -- said of two lions set face to face, each rampant.","pos":""}],"COMBBROACH":[{"def":"A tooth of a wool comb.","pos":""}],"COMBER":[{"def":"One who combs; one whose occupation it is to comb wool, flax, etc.","pos":""},{"def":"A long, curling wave.","pos":""}],"COMBINABLE":[{"def":"Capable of combinding; consistent with.","pos":""}],"COMBINATE":[{"def":"United; joined; betrothed.","pos":""}],"COMBINATION":[{"def":"The act or process of uniting by chemical affinity, by which substances unite with each other in definite proportions by weight to form distinct compounds.","pos":""},{"def":"The different arrangements of a number of objects, as letters, into groups.","pos":""}],"COMBINE":[{"def":"To unite or join; to link closely together; to bring into harmonious union; to cause or unite so as to form a homogeneous, as by chemical union.","pos":""},{"def":"To bind; to hold by a moral tie.","pos":""}],"COMBINED":[{"def":"United closely; confederated; chemically united.","pos":""}],"COMBINER":[{"def":"One who, or that which, combines.","pos":""}],"COMBING":[{"def":"The act or process of using a comb or a number of combs; as, the combing of one's hair; the combing of wool.","pos":""}],"COMBLESS":[{"def":"Without a comb or crest; as, a combless ceck.","pos":""}],"COMBOLOIO":[{"def":"A Mohammedan rosary, consisting of ninety-nine beads.","pos":""}],"COMBUST":[{"def":"So near the sun as to be obscured or eclipsed by his light, as the moon or planets when not more than eight degrees and a half from the sun.","pos":""}],"COMBUSTIBILITY":[{"def":"The quality of being combustible.","pos":""}],"COMBUSTIBLE":[{"def":"Capable of taking fire and burning; apt to catch fire; inflammable.","pos":""},{"def":"Ea Arnold was a combustible character.","pos":""}],"COMBUSTIBLENESS":[{"def":"Com*bus\"ti*ble*ness, n.","pos":""}],"COMBUSTION":[{"def":"The combination of a combustible with a supporter of combustion, producing heat, and sometimes both light and heat.","pos":""}],"COMBUSTION CHAMBER":[{"def":"Com*bus\"tion cham`ber.","pos":""}]}