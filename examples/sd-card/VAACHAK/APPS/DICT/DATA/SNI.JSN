{"SNIB":[{"def":"To check; to sneap; to sneb.","pos":""}],"SNICK":[{"def":"A slight hit or tip of the ball, often unintentional.","pos":""},{"def":"A knot or irregularity in yarn.","pos":""}],"SNICKER":[{"def":"To laugh slyly; to laugh in one's sleeve.","pos":""},{"def":"To laugh with audible catches of voice, as when persons attempt to suppress loud laughter.","pos":""}],"SNIDE":[{"def":"Tricky; deceptive; contemptible; as, a snide lawyer; snide goods.","pos":""},{"def":"A breech-loading rifle formerly used in the British service; -- so called from the inventor.","pos":""}],"SNIFF":[{"def":"To draw air audibly up the nose; to snuff; -- sometimes done as a gesture of suspicion, offense, or contempt.","pos":""}],"SNIFFING":[{"def":"A rapid inspiratory act, in which the mouth is kept shut and the air drawn in through the nose.","pos":""}],"SNIFFLE":[{"def":"To snuffle, as one does with a catarrh.","pos":""}],"SNIFT":[{"def":"To sniff; to snuff; to smell.","pos":""}],"SNIG":[{"def":"To chop off; to cut.","pos":""}],"SNIGGLE":[{"def":"To fish for eels by thrusting the baited hook into their holes or hiding places.","pos":""}],"SNIP":[{"def":"To cut off the nip or neb of, or to cut off at once with shears or scissors; to clip off suddenly; to nip; hence, to break off; to snatch away.","pos":""}],"SNIP-SNAP":[{"def":"A tart dialogue with quick replies.","pos":""}],"SNIPE":[{"def":"Any one of numerous species of limicoline game birds of the family Scolopacidæ, having a long, slender, nearly straight beak.","pos":""}],"SNIPEBILL":[{"def":"A plane for cutting deep grooves in moldings.","pos":""},{"def":"A bolt by which the body of a cart is fastened to the axle.","pos":""}],"SNIPPACK":[{"def":"The common snipe.","pos":""}],"SNIPPER-SNAPER":[{"def":"A small, insignificant fellow.","pos":""}],"SNIPPET":[{"def":"A small part or piece.","pos":""}],"SNIPPETY":[{"def":"Ridiculously small; petty.","pos":""}],"SNITE":[{"def":"To blow, as the nose; to snuff, as a candle.","pos":""},{"def":"Sharp; piercing; cutting; -- applied to the wind.","pos":""}],"SNIVEL":[{"def":"To run at the nose; to make a snuffling noise.","pos":""},{"def":"To cry or whine with snuffling, as children; to cry weakly or whiningly.","pos":""}],"SNIVELER":[{"def":"One who snivels, esp.","pos":""}],"SNIVELY":[{"def":"Running at the nose; sniveling pitiful; whining.","pos":""}]}