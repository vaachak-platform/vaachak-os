{"LOSABLE":[{"def":"Such as can be lost.","pos":""}],"LOSE":[{"def":"To part with unintentionally or unwillingly, as by accident, misfortune, negligence, penalty, forfeit, etc.","pos":""},{"def":"To cease to have; to possess no longer; to suffer diminution of; as, to lose one's relish for anything; to lose one's health.","pos":""}],"LOSEL":[{"def":"One who loses by sloth or neglect; a worthless person; a lorel.","pos":""}],"LOSENGER":[{"def":"A flatterer; a deceiver; a cozener.","pos":""}],"LOSENGERIE":[{"def":"Flattery; deceit; trickery.","pos":""}],"LOSING":[{"def":"Given to flattery or deceit; flattering; cozening.","pos":""}],"LOSINGLY":[{"def":"In a manner to incur loss.","pos":""}],"LOSS":[{"def":"Killed, wounded, and captured persons, or captured property.","pos":""}],"LOST":[{"def":"Parted with unwillingly or unintentionally; not to be found; missing; as, a lost book or sheep.","pos":""},{"def":"Parted with; no longer held or possessed; as, a lost limb; lost honor.","pos":""}]}