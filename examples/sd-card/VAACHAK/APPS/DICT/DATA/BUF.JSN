{"BUFF":[{"def":"The grayish viscid substance constituting the buffy coat.","pos":""},{"def":"A wheel covered with buff leather, and used in polishing cutlery, spoons, etc.","pos":""}],"BUFFA":[{"def":"The comic actress in an opera.","pos":""},{"def":"Comic, farcical.","pos":""}],"BUFFALO":[{"def":"A species of the genus Bos or Bubalus (B.","pos":""},{"def":"A very large and savage species of the same genus (B.","pos":""}],"BUFFEL DUCK":[{"def":"A small duck (Charitonetta albeola); the spirit duck, or butterball.","pos":""}],"BUFFER":[{"def":"One who polishes with a buff.","pos":""},{"def":"A wheel for buffing; a buff.","pos":""}],"BUFFERHEAD":[{"def":"The head of a buffer, which recieves the concussion, in railroad carriages.","pos":""}],"BUFFET":[{"def":"A cupboard or set of shelves, either movable or fixed at one side of a room, for the display of plate, china, etc.","pos":""},{"def":"A counter for refreshments; a restaurant at a railroad station, or place of public gathering.","pos":""}],"BUFFETER":[{"def":"One who buffets; a boxer.","pos":""}],"BUFFETING":[{"def":"A striking with the hand.","pos":""},{"def":"A succession of blows; continued violence, as of winds or waves; afflictions; adversity.","pos":""}],"BUFFIN":[{"def":"A sort of coarse stuff; as, buffin gowns.","pos":""}],"BUFFING APPARATUS":[{"def":"Buff\"ing ap`pa*ra\"tus.","pos":""}],"BUFFLE":[{"def":"To puzzle; to be at a loss.","pos":""}],"BUFFLE-HEADED":[{"def":"Having a large head, like a buffalo; dull; stupid; blundering.","pos":""}],"BUFFLEHEAD":[{"def":"The buffel duck.","pos":""}],"BUFFO":[{"def":"The comic actor in an opera.","pos":"noun"}],"BUFFOON":[{"def":"A man who makes a practice of amusing others by low tricks, antic gestures, etc.","pos":""}],"BUFFOONERY":[{"def":"The arts and practices of a buffoon, as low jests, ridiculous pranks, vulgar tricks and postures.","pos":""}],"BUFFOONISH":[{"def":"Like a buffoon; consisting in low jests or gestures.","pos":""}],"BUFFOONISM":[{"def":"The practices of a buffoon; buffoonery.","pos":""}],"BUFFOONLY":[{"def":"Apish tricks and buffoonly discourse.","pos":""}],"BUFFY":[{"def":"Resembling, or characterized by, buff.","pos":""}],"BUFO":[{"def":"A genus of Amphibia including various species of toads.","pos":""}],"BUFONITE":[{"def":"An old name for a fossil consisting of the petrified teeth and palatal bones of fishes belonging to the family of Pycnodonts (thick teeth), whose remains occur in the oölite and chalk formations; toadstone; -- so named from a notion that it was originally formed in the head of a toad.","pos":""}]}