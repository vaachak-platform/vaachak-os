{"GOVE":[{"def":"A mow; a rick for hay.","pos":""}],"GOVERN":[{"def":"To require to be in a particular case; as, a transitive verb governs a noun in the objective case; or to require (a particular case); as, a transitive verb governs the objective case.","pos":""}],"GOVERNABILITY":[{"def":"Gov\"ern*a*bil\"i*ty, n.","pos":""}],"GOVERNABLE":[{"def":"Capable of being governed, or subjected to authority; controllable; manageable; obedient.","pos":""}],"GOVERNABLENESS":[{"def":"The quality of being governable; manageableness.","pos":""},{"def":"Management; mastery.","pos":""}],"GOVERNANCE":[{"def":"Exercise of authority; control; government; arrangement.","pos":""}],"GOVERNESS":[{"def":"A female governor; a woman invested with authority to control and direct; especially, one intrusted with the care and instruction of children, -- usually in their homes.","pos":""}],"GOVERNING":[{"def":"Requiring a particular case.","pos":""}],"GOVERNMENT":[{"def":"The influence of a word in regard to construction, requiring that another word should be in a particular case.","pos":""}],"GOVERNMENTAL":[{"def":"Pertaining to government; made by government; as, governmental duties.","pos":""}],"GOVERNOR":[{"def":"A pilot; a steersman.","pos":""},{"def":"A contrivance applied to steam engines, water wheels, and other machinery, to maintain nearly uniform speed when the resistances and motive force are variable.","pos":""}],"GOVERNOR GENERAL":[{"def":"A governor who has lieutenant or deputy governors under him; as, the governor general of Canada, of India.","pos":""}],"GOVERNORSHIP":[{"def":"The office of a governor.","pos":""}]}