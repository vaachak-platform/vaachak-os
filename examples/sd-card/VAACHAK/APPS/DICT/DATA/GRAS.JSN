{"GRASP":[{"def":"To seize and hold by clasping or embracing with the fingers or arms; to catch to take possession of.","pos":""},{"def":"To lay hold of with the mind; to become thoroughly acquainted or conversant with; to comprehend.","pos":""}],"GRASPABLE":[{"def":"Capable of being grasped.","pos":""}],"GRASPER":[{"def":"One who grasps or seizes; one who catches or holds.","pos":""}],"GRASPING":[{"def":"Seizing; embracing; catching.","pos":""},{"def":"Avaricious; greedy of gain; covetous; close; miserly; as, he is a grasping man.","pos":""}],"GRASPLESS":[{"def":"Without a grasp; relaxed.","pos":""}],"GRASS":[{"def":"An endogenous plant having simple leaves, a stem generally jointed and tubular, the husks or glumes in pairs, and the seed single.","pos":""}],"GRASS-GREEN":[{"def":"Green with grass.","pos":""},{"def":"Of the color of grass; clear and vivid green.","pos":""}],"GRASS-GROWN":[{"def":"Overgrown with grass; as, a grass-grown road.","pos":""}],"GRASSATION":[{"def":"A wandering about with evil intentions; a rioting.","pos":""}],"GRASSHOPPER":[{"def":"Any jumping, orthopterous insect, of the families Acrididæ and Locustidæ.","pos":""}],"GRASSINESS":[{"def":"The state of abounding with grass; a grassy state.","pos":""}],"GRASSLESS":[{"def":"Destitute of grass.","pos":""}],"GRASSPLOT":[{"def":"A plot or space covered with grass; a lawn.","pos":""}],"GRASSY":[{"def":"Covered with grass; abounding with grass; as, a grassy lawn.","pos":""},{"def":"Resembling grass; green.","pos":""}]}