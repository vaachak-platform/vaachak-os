{"EFFABLE":[{"def":"Capable of being uttered or explained; utterable.","pos":""}],"EFFACE":[{"def":"To cause to disappear (as anything impresses or inscribed upon a surface) by rubbing out, striking out, etc.","pos":""},{"def":"To destroy, as a mental impression; to wear away.","pos":""}],"EFFACEABLE":[{"def":"Capable of being effaced.","pos":""}],"EFFACEMENT":[{"def":"The act if effacing; also, the result of the act.","pos":""}],"EFFASCINATE":[{"def":"To charm; to bewitch.","pos":""}],"EFFASCINATION":[{"def":"A charming; state of being bewitched or deluded.","pos":""}],"EFFECT":[{"def":"Goods; movables; personal estate; -- sometimes used to embrace real as well as personal property; as, the people escaped from the town with their effects.","pos":""}],"EFFECTER":[{"def":"One who effects.","pos":""}],"EFFECTIBLE":[{"def":"Capable of being done or achieved; practicable; feasible.","pos":""}],"EFFECTION":[{"def":"Creation; a doing.","pos":""}],"EFFECTIVE":[{"def":"Having the power to produce an effect or effects; producing a decided or decisive effect; efficient; serviceable; operative; as, an effective force, remedy, speech; the effective men in a regiment.","pos":""}],"EFFECTIVELY":[{"def":"With effect; powerfully; completely; thoroughly.","pos":""}],"EFFECTIVENESS":[{"def":"The quality of being effective.","pos":""}],"EFFECTLESS":[{"def":"Without effect or advantage; useless; bootless.","pos":""}],"EFFECTUAL":[{"def":"Producing, or having adequate power or force to produce, an intended effect; adequate; efficient; operative; decisive.","pos":""}],"EFFECTUALLY":[{"def":"With effect; efficaciously.","pos":""},{"def":"Actually; in effect.","pos":""}],"EFFECTUALNESS":[{"def":"The quality of being effectual.","pos":""}],"EFFECTUATE":[{"def":"To bring to pass; to effect; to achieve; to accomplish; to fulfill.","pos":""}],"EFFECTUATION":[{"def":"Act of effectuating.","pos":""}],"EFFECTUOUSLY":[{"def":"Ef*fec\"tu*ous*ly, adv.","pos":""}],"EFFEMINACY":[{"def":"Characteristic quality of a woman, such as softness, luxuriousness, delicacy, or weakness, which is unbecoming a man; womanish delicacy or softness; -- used reproachfully of men.","pos":""}],"EFFEMINATE":[{"def":"Having some characteristic of a woman, as delicacy, luxuriousness, etc.","pos":""},{"def":"Womanlike; womanly; tender; -- in a good sense.","pos":""}],"EFFEMINATELY":[{"def":"In an effeminate or womanish manner; weakly; softly; delicately.","pos":""},{"def":"By means of a woman; by the power or art of a woman.","pos":""}],"EFFEMINATENESS":[{"def":"The state of being effeminate; unmanly softness.","pos":""}],"EFFEMINATION":[{"def":"Effeminacy; womanishness.","pos":""}],"EFFEMINIZE":[{"def":"To make effeminate.","pos":""}],"EFFENDI":[{"def":"Master; sir; -- a title of a Turkish state official and man of learning, especially one learned in the law.","pos":""}],"EFFERENT":[{"def":"An efferent duct or stream.","pos":""}],"EFFEROUS":[{"def":"Like a wild beast; fierce.","pos":""}],"EFFERVESCE":[{"def":"A kind of natural ebullition; that commotion of a fluid which takes place when some part of the mass flies off in a gaseous form, producing innumerable small bubbles; as, the effervescence of a carbonate with citric acid.","pos":""}],"EFFERVESCIBLE":[{"def":"Capable of effervescing.","pos":""}],"EFFERVESCIVE":[{"def":"Tending to produce effervescence.","pos":""}],"EFFET":[{"def":"The common newt; -- called also asker, eft, evat, and ewt.","pos":""}],"EFFETE":[{"def":"No longer capable of producing young, as an animal, or fruit, as the earth; hence, worn out with age; exhausted of energy; incapable of efficient action; no longer productive; barren; sterile.","pos":""}],"EFFICACIOUS":[{"def":"Possessing the quality of being effective; productive of, or powerful to produce, the effect intended; as, an efficacious law.","pos":""}],"EFFICACY":[{"def":"Power to produce effects; operation or energy of an agent or force; production of the effect intended; as, the efficacy of medicine in counteracting disease; the efficacy of prayer.","pos":""},{"def":"The ratio of useful work to energy expended.","pos":""}],"EFFICIENT":[{"def":"Causing effects; producing results; that makes the effect to be what it is; actively operative; not inactive, slack, or incapable; characterized by energetic and useful activity; as, an efficient officer, power.","pos":""}],"EFFICIENTLY":[{"def":"With effect; effectively.","pos":""}],"EFFIGIAL":[{"def":"Relating to an effigy.","pos":""}],"EFFIGIATE":[{"def":"To form as an effigy; hence, to fashion; to adapt.","pos":""}],"EFFIGIATION":[{"def":"The act of forming in resemblance; an effigy.","pos":""}],"EFFIGY":[{"def":"The image, likeness, or representation of a person, whether a full figure, or a part; an imitative figure; -- commonly applied to sculptured likenesses, as those on monuments, or to those of the heads of princes on coins and medals, sometimes applied to portraits.","pos":""}],"EFFLAGITATE":[{"def":"To ask urgently.","pos":""}],"EFFLATE":[{"def":"To fill with breath; to puff up.","pos":""}],"EFFLATION":[{"def":"The act of filling with wind; a breathing or puffing out; a puff, as of wind.","pos":""}],"EFFLORESCE":[{"def":"To change on the surface, or throughout, to a whitish, mealy, or crystalline powder, from a gradual decomposition, esp.","pos":""}],"EFFLORESCENCE":[{"def":"Flowering, or state of flowering; the blooming of flowers; blowth.","pos":""},{"def":"A redness of the skin; eruption, as in rash, measles, smallpox, scarlatina, etc.","pos":""}],"EFFLORESCENCY":[{"def":"The state or quality of being efflorescent; efflorescence.","pos":""}],"EFFLORESCENT":[{"def":"That effloresces, or is liable to effloresce on exposure; as, an efflorescent salt.","pos":""},{"def":"Covered with an efflorescence.","pos":""}],"EFFLOWER":[{"def":"To remove the epidermis of (a skin) with a concave knife, blunt in its middle part, -- as in making chamois leather.","pos":""}],"EFFLUENCE":[{"def":"A flowing out, or emanation.","pos":""},{"def":"That which flows or issues from any body or substance; issue; efflux.","pos":""}],"EFFLUENT":[{"def":"Flowing out; as, effluent beams.","pos":""}],"EFFLUVIABLE":[{"def":"Capable of being given off as an effluvium.","pos":""}],"EFFLUVIAL":[{"def":"Belonging to effluvia.","pos":""}],"EFFLUVIATE":[{"def":"To give forth effluvium.","pos":""}],"EFFLUVIUM":[{"def":"Subtile or invisible emanation; exhalation perceived by the sense of smell; especially, noisome or noxious exhalation; as, the effluvium from diseased or putrefying bodies, or from ill drainage.","pos":""}],"EFFLUX":[{"def":"The act or process of flowing out, or issuing forth; effusion; outflow; as, the efflux of matter from an ulcer; the efflux of men's piety.","pos":""},{"def":"That which flows out; emanation; effluence.","pos":""}],"EFFLUXION":[{"def":"The act of flowing out; effusion.","pos":""},{"def":"That which flows out; effluvium; emanation.","pos":""}],"EFFORCE":[{"def":"To force; to constrain; to compel to yield.","pos":""}],"EFFORM":[{"def":"To form; to shape.","pos":""}],"EFFORMATION":[{"def":"The act of giving shape or form.","pos":""}],"EFFORT":[{"def":"A force acting on a body in the direction of its motion.","pos":""}],"EFFORTLESS":[{"def":"Making no effort.","pos":""}],"EFFOSSION":[{"def":"A digging out or up.","pos":""}],"EFFRAY":[{"def":"To frighten; to scare.","pos":""}],"EFFRENATION":[{"def":"Unbridled license; unruliness.","pos":""}],"EFFRONT":[{"def":"To give assurance to.","pos":""}],"EFFRONTERY":[{"def":"Impudence or boldness in confronting or in transgressing the bounds of duty or decorum; insulting presumptuousness; shameless boldness; barefaced assurance.","pos":""}],"EFFRONTIT":[{"def":"Marked by impudence.","pos":""}],"EFFRONTUOUSLY":[{"def":"Ef*fron\"tu*ous*ly, adv.","pos":""}],"EFFULGE":[{"def":"To cause to shine with abundance of light; to radiate; to beam.","pos":""}],"EFFULGENCE":[{"def":"The state of being effulgent; extreme brilliancy; a flood of light; great luster or brightness; splendor.","pos":""}],"EFFULGENT":[{"def":"Diffusing a flood of light; shining; luminous; beaming; bright; splendid.","pos":""}],"EFFULGENTLY":[{"def":"In an effulgent manner.","pos":""}],"EFFUMABILITY":[{"def":"The capability of flying off in fumes or vapor.","pos":""}],"EFFUME":[{"def":"To breathe or puff out.","pos":""}],"EFFUSE":[{"def":"Spreading loosely, especially on one side; as, an effuse inflorescence.","pos":""},{"def":"Having the lips, or edges, of the aperture abruptly spreading; -- said of certain shells.","pos":""}],"EFFUSION":[{"def":"The act of pouring out; as, effusion of water, of blood, of grace, of words, and the like.","pos":""},{"def":"That which is poured out, literally or figuratively.","pos":""}],"EFFUSIVE":[{"def":"Pouring out; pouring forth freely.","pos":""}],"EFT":[{"def":"Again; afterwards; soon; quickly.","pos":""},{"def":"Again; anew; a second time; at once; speedily.","pos":""}]}