{"COMPEAR":[{"def":"To appear in court personally or by attorney.","pos":""}],"COMPEER":[{"def":"An equal, as in rank, age, prowess, etc.","pos":""}],"COMPEL":[{"def":"To drive or urge with force, or irresistibly; to force; to constrain; to oblige; to necessitate, either by physical or moral force.","pos":""},{"def":"To take by force or violence; to seize; to exact; to extort.","pos":""}],"COMPELLABLE":[{"def":"Capable of being compelled or constrained.","pos":""}],"COMPELLATION":[{"def":"Style of address or salutation; an appellation.","pos":""}],"COMPELLATIVE":[{"def":"The name by which a person is addressed; an appellative.","pos":""}],"COMPELLATORY":[{"def":"Serving to compel; compulsory.","pos":""}],"COMPELLER":[{"def":"One who compels or constrains.","pos":""}],"COMPEND":[{"def":"A compendium; an epitome; a summary.","pos":""}],"COMPENDIARIOUS":[{"def":"Short; compendious.","pos":""}],"COMPENDIATE":[{"def":"To sum or collect together.","pos":""}],"COMPENDIOUS":[{"def":"Containing the substance oe general principles of a subject or work in a narrow compass; abridged; summarized.","pos":""}],"COMPENDIOUSLY":[{"def":"In a compendious manner.","pos":""}],"COMPENDIOUSNESS":[{"def":"The state or quality of being compendious.","pos":""}],"COMPENDIUM":[{"def":"A brief compilation or composition, containing the principal heads, or general principles, of a larger work or system; an abridgment; an epitome; a compend; a condensed summary.","pos":""}],"COMPENSATE":[{"def":"To make equal return to; to remunerate; to recompence; to give an equivalent to; to requite suitably; as, to compensate a laborer for his work, or a merchant for his losses.","pos":""},{"def":"To be equivalent in value or effect to; to counterbalance; to make up for; to make amends for.","pos":""}],"COMPENSATION":[{"def":"The act or principle of compensating.","pos":""},{"def":"That which constitutes, or is regarded as, an equivalent; that which makes good the lack or variation of something else; that which compensates for loss or privation; amends; remuneration; recompense.","pos":""}],"COMPENSATIVE":[{"def":"Affording compensation.","pos":""}],"COMPENSATOR":[{"def":"An iron plate or magnet placed near the compass on iron vessels to neutralize the effect of the ship's attraction on the needle.","pos":""}],"COMPENSATORY":[{"def":"Serving for compensation; making amends.","pos":""}],"COMPERENDINATE":[{"def":"Com`pe*ren\"di*nate, v.","pos":""}],"COMPESCE":[{"def":"To hold in check; to restrain.","pos":""}],"COMPETE":[{"def":"To contend emulously; to seek or strive for the same thing, position, or reward for which another is striving; to contend in rivalry, as for a prize or in business; as, tradesmen compete with one another.","pos":""}],"COMPETENT":[{"def":"Answering to all requirements; adeqouate; sufficient; suitable; capable; legally qualified; fit.","pos":""},{"def":"Rightfully or properly belonging; incident; -- followed by to.","pos":""}],"COMPETENTLY":[{"def":"In a competent manner; adequately; suitably.","pos":""}],"COMPETIBLE":[{"def":"Compatible; suitable; consistent.","pos":""}],"COMPETITION":[{"def":"Competition to the crown there is none, nor can be.","pos":""}],"COMPETITIVE":[{"def":"Of or pertaining to competition; producing competition; competitory; as, a competitive examination.","pos":""}],"COMPETITOR":[{"def":"One who seeks what another seeks, or claims what another claims; one who competes; a rival.","pos":""},{"def":"An associate; a confederate.","pos":""}],"COMPETITORY":[{"def":"Acting in competition; competing; rival.","pos":""}],"COMPETITRESS":[{"def":"A woman who competes.","pos":""}]}