{"REPREFE":[{"def":"Re*prefe\" (r-prf\"), n.","pos":""}],"REPREHEND":[{"def":"To reprove or reprimand with a view of restraining, checking, or preventing; to make charge of fault against; to disapprove of; to chide; to blame; to censure.","pos":""}],"REPREHENDER":[{"def":"One who reprehends.","pos":""}],"REPREHENSIBLE":[{"def":"Worthy of reprehension; culpable; censurable; blamable.","pos":""}],"REPREHENSION":[{"def":"Reproof; censure; blame; disapproval.","pos":""}],"REPREHENSIVE":[{"def":"Containing reprehension; conveying reproof.","pos":""}],"REPREHENSORY":[{"def":"Containing reproof; reprehensive; as, reprehensory complaint.","pos":""}],"REPRESENT":[{"def":"To form or image again in consciousness, as an object of cognition or apprehension (something which was originally apprehended by direct presentation).","pos":""}],"REPRESENTABLE":[{"def":"Capable of being represented.","pos":""}],"REPRESENTANCE":[{"def":"Representation; likeness.","pos":""}],"REPRESENTANT":[{"def":"Appearing or acting for another; representing.","pos":""}],"REPRESENTATION":[{"def":"The act of representing, in any sense of the verb.","pos":""},{"def":"That which represents.","pos":""}],"REPRESENTATIONARY":[{"def":"Implying representation; representative.","pos":""}],"REPRESENTATIVE":[{"def":"Giving, or existing as, a transcript of what was originally presentative knowledge; as, representative faculties; representative knowledge.","pos":""}],"REPRESENTATIVELY":[{"def":"In a representative manner; vicariously.","pos":""}],"REPRESENTATIVENESS":[{"def":"The quality or state of being representative.","pos":""}],"REPRESENTER":[{"def":"One who shows, exhibits, or describes.","pos":""},{"def":"A representative.","pos":""}],"REPRESENTMENT":[{"def":"Rep`re*sent\"ment (-ment), n.","pos":""}],"REPRESS":[{"def":"Re*press\" (r-prs\"), v.","pos":""}],"REPRESSER":[{"def":"One who, or that which, represses.","pos":""}],"REPRESSIBLE":[{"def":"Capable of being repressed.","pos":""}],"REPRESSION":[{"def":"The act of repressing, or state of being repressed; as, the repression of evil and evil doers.","pos":""},{"def":"That which represses; check; restraint.","pos":""}],"REPRESSIVE":[{"def":"Having power, or tending, to repress; as, repressive acts or measures.","pos":""}],"REPREVABLE":[{"def":"Re*prev\"a*ble (r-prv\"-b'l), a.","pos":""}],"REPREVE":[{"def":"Re*preve\" (r-prv\"), v.","pos":""}],"REPRIEFE":[{"def":"Re*priefe\" (r-prf\"), n.","pos":""}],"REPRIEVAL":[{"def":"Re*priev\"al (r-prv\"al), n.","pos":""}],"REPRIEVE":[{"def":"To delay the punishment of; to suspend the execution of sentence on; to give a respite to; to respite; as, to reprieve a criminal for thirty days.","pos":""},{"def":"To relieve for a time, or temporarily.","pos":""}],"REPRIMAND":[{"def":"Severe or formal reproof; reprehension, private or public.","pos":""}],"REPRIMANDER":[{"def":"One who reprimands.","pos":""}],"REPRIMER":[{"def":"A machine or implement for applying fresh primers to spent cartridge shells, so that the shells be used again.","pos":""}],"REPRINT":[{"def":"To print again; to print a second or a new edition of.","pos":""},{"def":"To renew the impression of.","pos":""}],"REPRINTER":[{"def":"One who reprints.","pos":""}],"REPRISAL":[{"def":"The act of taking from an enemy by way of reteliation or indemnity.","pos":""},{"def":"Anything taken from an enemy in retaliation.","pos":""}],"REPRISE":[{"def":"Deductions and duties paid yearly out of a manor and lands, as rent charge, rent seck, pensions, annuities, and the like.","pos":""}],"REPRISTINATE":[{"def":"To restore to an original state.","pos":""}],"REPRISTINATION":[{"def":"Restoration to an original state; renewal of purity.","pos":""}],"REPRIVE":[{"def":"To take back or away.","pos":""}],"REPRIZES":[{"def":"Re*priz\"es (-prz\"z), n.","pos":"noun"}],"REPROACH":[{"def":"To come back to, or come home to, as a matter of blame; to bring shame or disgrace upon; to disgrace.","pos":""},{"def":"To attribute blame to; to allege something disgracefull against; to charge with a fault; to censure severely or contemptuously; to upbraid.","pos":""}],"REPROACHABLR":[{"def":"Deserving reproach; censurable.","pos":""},{"def":"Opprobrius; scurrilous.","pos":""}],"REPROACHER":[{"def":"One who reproaches.","pos":""}],"REPROACHFUL":[{"def":"Expressing or containing reproach; upbraiding; opprobrious; abusive.","pos":""},{"def":"Occasioning or deserving reproach; shameful; base; as, a reproachful life.","pos":""}],"REPROACHLESS":[{"def":"Being without reproach.","pos":""}],"REPROBACY":[{"def":"Rep\"ro*ba*cy (rp\"r-b-c), n.","pos":""}],"REPROBANCE":[{"def":"Rep\"ro*bance (-bans), n.","pos":""}],"REPROBATE":[{"def":"Not enduring proof or trial; not of standard purity or fineness; disallowed; rejected.","pos":""},{"def":"Abandoned to punishment; hence, morally abandoned and lost; given up to vice; depraved.","pos":""}],"REPROBATENESS":[{"def":"The state of being reprobate.","pos":""}],"REPROBATER":[{"def":"One who reprobates.","pos":""}],"REPROBATION":[{"def":"The predestination of a certain number of the human race as reprobates, or objects of condemnation and punishment.","pos":""}],"REPROBATIONER":[{"def":"One who believes in reprobation.","pos":""}],"REPROBATIVE":[{"def":"Of or pertaining to reprobation; expressing reprobation.","pos":""}],"REPROBATORY":[{"def":"Rep\"ro*ba`to*ry (-b`t-r), a.","pos":""}],"REPRODUCE":[{"def":"To produce again.","pos":""}],"REPRODUCER":[{"def":"One who, or that which, reproduces.","pos":""}],"REPRODUCTION":[{"def":"the process by which plants and animals give rise to offspring.","pos":""}],"REPRODUCTIVE":[{"def":"Tending, or pertaining, to reproduction; employed in reproduction.","pos":""}],"REPRODUCTORY":[{"def":"Re`pro*duc\"to*ry (-t-r), a.","pos":""}],"REPROOF":[{"def":"Refutation; confutation; contradiction.","pos":""},{"def":"An expression of blame or censure; especially, blame expressed to the face; censure for a fault; chiding; reproach.","pos":""}],"REPROVABLE":[{"def":"Worthy of reproof or censure.","pos":""}],"REPROVE":[{"def":"To disprove; to refute.","pos":""}],"REPROVER":[{"def":"One who, or that which, reproves.","pos":""}],"REPROVINGLY":[{"def":"In a reproving manner.","pos":""}],"REPRUNE":[{"def":"To prune again or anew.","pos":""}]}