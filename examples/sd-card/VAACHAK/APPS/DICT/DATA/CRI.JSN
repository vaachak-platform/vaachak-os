{"CRIB":[{"def":"A structure or frame of timber for a foundation, or for supporting a roof, or for lining a shaft.","pos":""},{"def":"The discarded cards which the dealer can use in scoring points in cribbage.","pos":""}],"CRIB-BITING":[{"def":"Same as Cribbing, 4.","pos":""}],"CRIBBAGE":[{"def":"A game of cards, played by two or four persons, in which there is a crib.","pos":""},{"def":"A horse that has the habit of cribbing.","pos":""}],"CRIBBING":[{"def":"A framework of timbers and plank backing for a shaft lining, to prevent caving, percolation of water, etc.","pos":""}],"CRIBBLE":[{"def":"A coarse sieve or screen.","pos":""},{"def":"Coarse flour or meal.","pos":""}],"CRIBELLUM":[{"def":"A peculiar perforated organ of certain spiders (Ciniflonidæ), used for spinning a special kind of silk.","pos":""}],"CRIBRATE":[{"def":"Crib\"rate (krb\"rt), a.","pos":""}],"CRIBRATION":[{"def":"The act or process of separating the finer parts of drugs from the coarser by sifting.","pos":""}],"CRIBRIFORM":[{"def":"Resembling, or having the form of, a sieve; pierced with hokes; as, the cribriform plate of the ethmoid bone; a cribriform compress.","pos":""}],"CRIBROSE":[{"def":"Perforated like a sieve; cribriform.","pos":""}],"CRIC":[{"def":"The ring which turns inward and condenses the flame of a lamp.","pos":""}],"CRICK":[{"def":"The creaking of a door, or a noise resembling it.","pos":""}],"CRICKET":[{"def":"An orthopterous insect of the genus Gryllus, and allied genera.","pos":""}],"CRICKETER":[{"def":"One who plays at cricket.","pos":""}],"CRICOID":[{"def":"Resembling a ring; -- said esp.","pos":""}],"CRICOTHYROID":[{"def":"Of or pertaining both to the cricoid and the thyroid cartilages.","pos":""}],"CRIED":[{"def":"Cried (krd), Defn: imp.","pos":""}],"CRIER":[{"def":"One who cries; one who makes proclamation.","pos":""}],"CRIME":[{"def":"Any violation of law, either divine or human; an omission of a duty commanded, or the commission of an act forbidden by law.","pos":"noun"},{"def":"Gross violation of human law, in distinction from a misdemeanor or trespass, or other slight offense.","pos":"noun"}],"CRIMEFUL":[{"def":"Criminal; wicked; contrary to law, right, or dury.","pos":""}],"CRIMELESS":[{"def":"Free from crime; innocent.","pos":""}],"CRIMINAL":[{"def":"Guilty of crime or sin.","pos":""},{"def":"Involving a crime; of the nature of a crime; -- said of an act or of conduct; as, criminal carelessness.","pos":""}],"CRIMINALIST":[{"def":"One versed in criminal law.","pos":""}],"CRIMINALITY":[{"def":"The quality or state of being criminal; that which constitutes a crime; guiltiness; guilt.","pos":""}],"CRIMINALLY":[{"def":"In violation of law; wickedly.","pos":""}],"CRIMINATE":[{"def":"To accuse of, or charge with, a crime.","pos":""},{"def":"To involve in a crime or in its consequences; to render liable to a criminal charge.","pos":""}],"CRIMINATION":[{"def":"The act of accusing; accusation; charge; complaint.","pos":""}],"CRIMINATIVE":[{"def":"Charging with crime; accusing; criminatory.","pos":""}],"CRIMINATORY":[{"def":"Relating to, or involving, crimination; accusing; as, a criminatory conscience.","pos":""}],"CRIMINOLOGY":[{"def":"A treatise on crime or the criminal population.","pos":""}],"CRIMINOUS":[{"def":"Criminal; involving great crime or grave charges; very wicked; heinous.","pos":""}],"CRIMOSIN":[{"def":"Crim\"o*sin (krm\"-zn), n.","pos":""}],"CRIMP":[{"def":"To cause to contract, or to render more crisp, as the flesh of a fish, by gashing it, when living, with a knife; as, to crimp skate, etc.","pos":""}],"CRIMPAGE":[{"def":"The act or practice of crimping; money paid to a crimp for shipping or enlisting men.","pos":""}],"CRIMPER":[{"def":"One who, or that which, crimps; as: (a) A curved board or frame over which the upper of a boot or shoe is stretched to the required shape.","pos":""}],"CRIMPLE":[{"def":"To cause to shrink or draw together; to contract; to curl.","pos":""}],"CRIMPY":[{"def":"Having a crimped appearance; frizzly; as, the crimpy wool of the Saxony sheep.","pos":""}],"CRIMSON":[{"def":"A deep red color tinged with blue; also, red color in general.","pos":""}],"CRINAL":[{"def":"Of or pertaining to the hair.","pos":""}],"CRINATED":[{"def":"Having hair; hairy.","pos":""}],"CRINATORY":[{"def":"Cri\"na*to*ry (kr\"n-t-r), a.","pos":""}],"CRINCUM":[{"def":"A twist or bend; a turn; a whimsey.","pos":""}],"CRINCUM-CRANCUM":[{"def":"A twist; a whimsey or whim.","pos":""}],"CRINED":[{"def":"Having the hair of a different tincture from the rest of the body; as, a charge crined of a red tincture.","pos":""},{"def":"A very fine, hairlike feather.","pos":""}],"CRINGE":[{"def":"To draw one's self together as in fear or servility; to bend or crouch with base humility; to wince; hence; to make court in a degrading manner; to fawn.","pos":""}],"CRINGELING":[{"def":"One who cringes meanly; a fawner.","pos":""}],"CRINGER":[{"def":"One who cringes.","pos":""}],"CRINGINGLY":[{"def":"In a cringing manner.","pos":""}],"CRINGLE":[{"def":"An iron or pope thimble or grommet worked into or attached to the edges and corners of a sail; -- usually in the plural.","pos":""}],"CRINICULTURAL":[{"def":"Relating to the growth of hair.","pos":""}],"CRINIGEROUS":[{"def":"Bearing hair; hairy.","pos":""}],"CRINITAL":[{"def":"Same as Crinite, 1.","pos":""}],"CRINITE":[{"def":"Bearded or tufted with hairs.","pos":""}],"CRINITORY":[{"def":"Of or relating to hair; as, a crinitory covering.","pos":""}],"CRINKLE":[{"def":"To form with short turns, bends, or wrinkles; to mold into inequalites or sinuosities; to cause to wrinkle or curl.","pos":""}],"CRINKLED":[{"def":"Having short bends, turns, or wrinkles; wrinkled; wavy; zigzag.","pos":""}],"CRINKLY":[{"def":"Having crinkles; wavy; wrinkly.","pos":""}],"CRINOID":[{"def":"One of the Crinoidea.","pos":""}],"CRINOIDAL":[{"def":"Of pertaining to crinoids; consisting of, or containing, crinoids.","pos":""}],"CRINOIDEA":[{"def":"A large class of Echinodermata, including numerous extinct families and genera, but comparatively few living ones.","pos":""}],"CRINOIDEAN":[{"def":"One of the Crinoidea.","pos":""}],"CRINOLINE":[{"def":"A kind of stiff cloth, used chiefly by women, for underskirts, to expand the gown worn over it; -- so called because originally made of hair.","pos":""},{"def":"A lady's skirt made of any stiff material; latterly, a hoop skirt.","pos":""}],"CRINOSE":[{"def":"Cri*nose\" (kr-ns\"), a.","pos":""}],"CRINOSITY":[{"def":"Cri*nos\"i*ty (kr-ns\"-t), n.","pos":""}],"CRINUM":[{"def":"A genus of bulbous plants, of the order Amaryllidace, cultivated as greenhouse plants on account of their beauty.","pos":""}],"CRIOSPHINX":[{"def":"A sphinx with the head of a ram.","pos":""}],"CRIPPLE":[{"def":"One who creeps, halts, or limps; one who has lost, or never had, the use of a limb or limbs; a lame person; hence, one who is partially disabled.","pos":""}],"CRIPPLED":[{"def":"Lamed; lame; disabled; impeded.","pos":""}],"CRIPPLER":[{"def":"A wooden tool used in graining leather.","pos":""}],"CRIPPLING":[{"def":"Spars or timbers set up as a support against the side of a building.","pos":""}],"CRIPPLY":[{"def":"Lame; disabled; in a crippled condition.","pos":""}],"CRISIS":[{"def":"That change in a disease which indicates whether the result is to be recovery or death; sometimes, also, a striking change of symptoms attended by an outward manifestation, as by an eruption or sweat.","pos":""}],"CRISP":[{"def":"Curling in stiff curls or ringlets; as, crisp hair.","pos":""},{"def":"Curled with the ripple of the water.","pos":""}],"CRISPATION":[{"def":"The act or process of curling, or the state of being curled.","pos":""},{"def":"A very slight convulsive or spasmodic contraction of certain muscles, external or internal.","pos":""}],"CRISPATURE":[{"def":"The state of being crispate.","pos":""}],"CRISPER":[{"def":"One who, or that which, crisps or curls; an instrument for making little curls in the nap of cloth, as in chinchilla.","pos":""}],"CRISPIN":[{"def":"A shoemaker; -- jocularly so called from the patron sant of the craft.","pos":""},{"def":"A member of a union or association of shoemakers.","pos":""}],"CRISPLY":[{"def":"In a crisp manner.","pos":""}],"CRISPNESS":[{"def":"The state or quality of being crisp.","pos":""}],"CRISPY":[{"def":"Formed into short, close ringlets; frizzed; crisp; as, crispy locks.","pos":""},{"def":"Crisp; brittle; as.","pos":""}],"CRISSAL":[{"def":"Pertaining to the crissum; as, crissal feathers.","pos":""},{"def":"Having highly colored under tail coverts; as, the crissal thrasher.","pos":""}],"CRISSCROSS":[{"def":"A mark or cross, as the signature of a person who is unable to write.","pos":""},{"def":"A child's game played on paper or on a slate, consisting of lines arranged in the form of a cross.","pos":""}],"CRISSCROSS-ROW":[{"def":"See Christcross-row.","pos":""}],"CRISSUM":[{"def":"That part of a bird, or the feathers, surrounding the cloacal opening; the under tail coverts.","pos":""}],"CRISTATE":[{"def":"Cris\"tate (krs\"tt), a.","pos":""}],"CRITERION":[{"def":"A standard of judging; any approved or established rule or test, by which facts, principles opinions, and conduct are tried in forming a correct judgment respecting them.","pos":""}],"CRITHOMANCY":[{"def":"A kind of divination by means of the dough of the cakes offered in the ancient sacrifices, and the meal strewed over the victims.","pos":""}],"CRITIC":[{"def":"One skilled in judging of the merits of literary or artistic works; a connoisseur; an adept; hence, one who examines literary or artistic works, etc.","pos":""},{"def":"One who passes a rigorous or captious judgment; one who censures or finds fault; a harsh examiner or judge; a caviler; a carper.","pos":""}],"CRITICAL":[{"def":"Pertaining to, or indicating, a crisis, turning point, or specially important juncture; important as regards consequences; hence, of doubtful issue; attended with risk; dangerous; as, the critical stage of a fever; a critical situation.","pos":""}],"CRITICALLY":[{"def":"In a critical manner; with nice discernment; accurately; exactly.","pos":""},{"def":"At a crisis; at a critical time; in a situation.","pos":""}],"CRITICALNESS":[{"def":"The state or quality of being critical, or of occurring at a critical time.","pos":""},{"def":"Accuracy in examination or decision; exactness.","pos":""}],"CRITICASTER":[{"def":"A contemptible or vicious critic.","pos":""}],"CRITICISABLE":[{"def":"Capable of being criticised.","pos":""}],"CRITICISE":[{"def":"To examine and judge as a critic; to pass literary or artistic judgment upon; as, to criticise an author; to criticise a picture.","pos":""},{"def":"To express one's views as to the merit or demerit of; esp.","pos":""}],"CRITICISER":[{"def":"One who criticises; a critic.","pos":""}],"CRITICISM":[{"def":"The rules and principles which regulate the practice of the critic; the art of judging with knowledge and propriety of the beauties and faults of a literary performance, or of a production in the fine arts; as, dramatic criticism.","pos":""},{"def":"The act of criticising; a critical judgment passed or expressed; a critical observation or detailed examination and review; a critique; animadversion; censure.","pos":""}],"CRITIQUE":[{"def":"The art of criticism.","pos":""},{"def":"A critical examination or estimate of a work of literature or art; a critical dissertation or essay; a careful and through analysis of any subject; a criticism; as, Kant's \"Critique of Pure Reason.","pos":""}],"CRIZZEL":[{"def":"A kind of roughness on the surface of glass, which clouds its transparency.","pos":""}]}