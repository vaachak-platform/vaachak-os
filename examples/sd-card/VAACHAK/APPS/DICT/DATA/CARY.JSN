{"CARYATIDES":[{"def":"Note: Corresponding male figures were called Atlantes, Telamones, and Persians.","pos":""}],"CARYOPHYLLACEOUS":[{"def":"Car`y*o*phyl*la\"ceous, a.","pos":""}],"CARYOPHYLLIN":[{"def":"A tasteless and odorless crystalline substance, extracted from cloves, polymeric with common camphor.","pos":""}],"CARYOPHYLLOUS":[{"def":"Caryophyllaceous.","pos":""}],"CARYOPSIS":[{"def":"A one-celled, dry, indehiscent fruit, with a thin membranous pericarp, adhering closely to the seed, so that fruit and seed are incorporated in one body, forming a single grain, as of wheat, barley, etc.","pos":""}]}