{"HUN":[{"def":"One of a warlike nomadic people of Northern Asia who, in the 5th century, under Atilla, invaded and conquered a great part of Europe.","pos":""}],"HUNCH":[{"def":"A hump; a protuberance.","pos":""},{"def":"A lump; a thick piece; as, a hunch of bread.","pos":""}],"HUNCHBACK":[{"def":"A back with a hunch or hump; also, a hunchbacked person.","pos":""}],"HUNCHBACKED":[{"def":"Having a humped back.","pos":""}],"HUNDRED":[{"def":"The product of ten mulitplied by ten, or the number of ten times ten; a collection or sum, consisting of ten times ten units or objects; five score.","pos":""},{"def":"A division of a country in England, supposed to have originally contained a hundred families, or freemen.","pos":""}],"HUNDREDER":[{"def":"A person competent to serve on a jury, in an action for land in the hundred to which he belongs.","pos":""}],"HUNDREDFOLD":[{"def":"A hundred times as much or as many.","pos":""}],"HUNDREDTH":[{"def":"Coming last of a hundred successive individuals or units.","pos":""},{"def":"Forming one of a hundred equal parts into which anything is divided; the tenth of a tenth.","pos":""}],"HUNDREDWEIGHT":[{"def":"A denomination of weight, containing 100, 112, or 120 pounds avoirdupois, according to differing laws or customs.","pos":""}],"HUNGARIAN":[{"def":"Of or pertaining to Hungary or to the people of Hungary.","pos":""},{"def":"A native or one of the people of Hungary.","pos":""}],"HUNGARY":[{"def":"A country in Central Europe, now a part of the Austro-Hungarian Empire.","pos":""}],"HUNGER":[{"def":"An uneasy sensation occasioned normally by the want of food; a craving or desire for food.","pos":""},{"def":"Any strong eager desire.","pos":""}],"HUNGER-STARVE":[{"def":"To starve with hunger; to famish.","pos":""}],"HUNGERED":[{"def":"Hungry; pinched for food.","pos":""}],"HUNGERER":[{"def":"One who hungers; one who longs.","pos":""}],"HUNGERLY":[{"def":"Wanting food; starved.","pos":""}],"HUNGRED":[{"def":"Hungered; hungry.","pos":""}],"HUNGRILY":[{"def":"In a hungry manner; voraciously.","pos":""}],"HUNGRY":[{"def":"Feeling hunger; having a keen appetite; feeling uneasiness or distress from want of food; hence, having an eager desire.","pos":""},{"def":"Showing hunger or a craving desire; voracious.","pos":""}],"HUNK":[{"def":"A large lump or piece; a hunch; as, a hunk of bread.","pos":""}],"HUNKER":[{"def":"Originally, a nickname for a member of the conservative section of the Democratic party in New York; hence, one opposed to progress in general; a fogy.","pos":""}],"HUNKERISM":[{"def":"Excessive conservatism; hostility to progress.","pos":""}],"HUNKERS":[{"def":"In the phrase on one's hunkers, in a squatting or crouching position.","pos":""}],"HUNKS":[{"def":"A covetous, sordid man; a miser; a niggard.","pos":""}],"HUNKY":[{"def":"All right; in a good condition; also, even; square.","pos":""}],"HUNT":[{"def":"To search for or follow after, as game or wild animals; to chase; to pursue for the purpose of catching or killing; to follow with dogs or guns for sport or exercise; as, to hunt a deer.","pos":""},{"def":"To search diligently after; to seek; to pursue; to follow; -- often with out or up; as, to hunt up the facts; to hunt out evidence.","pos":""}],"HUNT'S-UP":[{"def":"A tune played on the horn very early in the morning to call out the hunters; hence, any arousing sound or call.","pos":""}],"HUNT-COUNTER":[{"def":"A worthless dog that runs back on the scent; a blunderer.","pos":""}],"HUNTER":[{"def":"A kind of spider.","pos":""}],"HUNTERIAN":[{"def":"Discovered or described by John Hunter, an English surgeon; as, the Hunterian chancre.","pos":""}],"HUNTING":[{"def":"The pursuit of game or of wild animals.","pos":""}],"HUNTRESS":[{"def":"A woman who hunts or follows the chase; as, the huntress Diana.","pos":""}],"HUNTSMAN":[{"def":"One who hunts, or who practices hunting.","pos":""},{"def":"The person whose office it is to manage the chase or to look after the hounds.","pos":""}],"HUNTSMANSHIP":[{"def":"The art or practice of hunting, or the qualification of a hunter.","pos":""}]}