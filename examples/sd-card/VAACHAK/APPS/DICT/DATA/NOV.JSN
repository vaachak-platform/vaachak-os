{"NOVA":[{"def":"A new star, usually appearing suddenly, shining for a brief period, and then sinking into obscurity.","pos":""}],"NOVACULITE":[{"def":"A variety of siliceous slate, of which hones are made; razor stone; Turkey stone; hone stone; whet slate.","pos":""}],"NOVATIAN":[{"def":"One of the sect of Novatius, or Novatianus, who held that the lapsed might not be received again into communion with the church, and that second marriages are unlawful.","pos":""}],"NOVATIANISM":[{"def":"The doctrines or principles of the Novatians.","pos":""}],"NOVATION":[{"def":"A substitution of a new debt for an old one; also, the remodeling of an old obligation.","pos":""}],"NOVEL":[{"def":"Of recent origin or introduction; not ancient; new; hence, out of the ordinary course; unusual; strange; surprising.","pos":""}],"NOVELIST":[{"def":"A writer of news.","pos":""},{"def":"A writer of a novel or novels.","pos":""}],"NOVELIZE":[{"def":"To put into the form of novels; to represent by fiction.","pos":""}],"NOVELRY":[{"def":"Novelty; new things.","pos":""}],"NOVELTY":[{"def":"The quality or state of being novel; newness; freshness; recentness of origin or introduction.","pos":""},{"def":"Something novel; a new or strange thing.","pos":""}],"NOVEMBER":[{"def":"The eleventh month of the year, containing thirty days.","pos":""}],"NOVENARY":[{"def":"Of or pertaining to the number nine.","pos":""}],"NOVENE":[{"def":"Relating to, or dependent on, the number nine; novenary.","pos":""}],"NOVENNIAL":[{"def":"Done or recurring every ninth year.","pos":""}],"NOVERCAL":[{"def":"Done or recurring every ninth year.","pos":""}],"NOVICE":[{"def":"One who enters a religious house, whether of monks or nuns, as a probationist.","pos":""}],"NOVICESHIP":[{"def":"The state of being a novice; novitiate.","pos":""}],"NOVILUNAR":[{"def":"Of or pertaining to the new moon.","pos":""}],"NOVITIATE":[{"def":"The state of being a novice; time of initiation or instruction in rudiments.","pos":""},{"def":"Hence: Time of probation in a religious house before taking the vows.","pos":""}],"NOVITIOUS":[{"def":"Newly invented; recent; new.","pos":""}],"NOVITY":[{"def":"Newness; novelty.","pos":""}],"NOVUM":[{"def":"A game at dice, properly called novem quinque (L.","pos":""}]}