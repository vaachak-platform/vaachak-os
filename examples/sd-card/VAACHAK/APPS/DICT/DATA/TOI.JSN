{"TOIL":[{"def":"A net or snare; any thread, web, or string spread for taking prey; -- usually in the plural.","pos":""}],"TOILER":[{"def":"One who toils, or labors painfully.","pos":""}],"TOILET":[{"def":"A covering of linen, silk, or tapestry, spread over a table in a chamber or a dressing room.","pos":""},{"def":"A dressing table.","pos":""}],"TOILFUL":[{"def":"Producing or involving much toil; laborious; toilsome; as, toilful care.","pos":""}],"TOILSOME":[{"def":"Attended with toil, or fatigue and pain; laborious; wearisome; as, toilsome work.","pos":""}],"TOISE":[{"def":"An old measure of length in France, containing six French feet, or about 6.","pos":""}],"TOISON":[{"def":"A sheep's fleece.","pos":""}],"TOISON D'OR":[{"def":"Toi`son\" d'or\" (dor\").","pos":""}]}