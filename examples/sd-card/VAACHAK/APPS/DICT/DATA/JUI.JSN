{"JUICE":[{"def":"The characteristic fluid of any vegetable or animal substance; the sap or part which can be expressed from fruit, etc.","pos":""}],"JUICELESS":[{"def":"Lacking juice; dry.","pos":""}],"JUICINESS":[{"def":"The state or quality of being juicy; succulence plants.","pos":""}],"JUICY":[{"def":"A bounding with juice; succulent.","pos":""}],"JUISE":[{"def":"Judgment; justice; sentence.","pos":""}]}