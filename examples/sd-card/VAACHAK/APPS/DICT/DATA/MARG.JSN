{"MARGARATE":[{"def":"A compound of the so-called margaric acid with a base.","pos":""}],"MARGARIC":[{"def":"Pertaining to, or resembling, pearl; pearly.","pos":""}],"MARGARIN":[{"def":"A fatty substance, extracted from animal fats and certain vegetable oils, formerly supposed to be a definite compound of glycerin and margaric acid, but now known to be simply a mixture or combination of tristearin and teipalmitin.","pos":""}],"MARGARINE":[{"def":"Artificial butter; oleomargarine.","pos":""}],"MARGARITACEOUS":[{"def":"Pertaining to, or resembling, pearl; pearly.","pos":""}],"MARGARITE":[{"def":"A mineral related to the micas, but low in silica and yielding brittle folia with pearly luster.","pos":""}],"MARGARITIFEROUS":[{"def":"Producing pearls.","pos":""}],"MARGARODITE":[{"def":"A hidrous potash mica related to muscovite.","pos":""}],"MARGARONE":[{"def":"The ketone of margaric acid.","pos":""}],"MARGAROUS":[{"def":"Margaric; -- formerly designating a supposed acid.","pos":""},{"def":"To impregnate (wood) with a preservative solution of copper sulphate (often called Mar\"ga*ry's flu\"id [-riz]).","pos":""}],"MARGATE FISH":[{"def":"A sparoid fish (Diabasis aurolineatus) of the Gulf of Mexico, esteemed as a food fish; -- called also red-mouth grunt.","pos":""}],"MARGAY":[{"def":"An American wild cat (Felis tigrina), ranging from Mexico to Brazil.","pos":""}],"MARGE":[{"def":"Border; margin; edge; verge.","pos":""}],"MARGENT":[{"def":"A margin; border; brink; edge.","pos":""}],"MARGIN":[{"def":"The difference between the cost and the selling price of an article.","pos":""},{"def":"Collateral security deposited with a broker to secure him from loss on contracts entered into by him on behalf of his principial, as in the speculative buying and selling of stocks, wheat, etc.","pos":""}],"MARGINAL":[{"def":"Of or pertaining to a margin.","pos":""},{"def":"Written or printed in the margin; as, a marginal note or gloss.","pos":""}],"MARGINALLY":[{"def":"In the margin of a book.","pos":""}],"MARGINATE":[{"def":"Having a margin distinct in appearance or structure.","pos":""}],"MARGINATED":[{"def":"Same as Marginate, a.","pos":""}],"MARGINED":[{"def":"Bordered with a distinct line of color.","pos":""}],"MARGINELLA":[{"def":"A genus of small, polished, marine univalve shells, native of all warm seas.","pos":""}],"MARGINICIDAL":[{"def":"Dehiscent by the separation of united carpels; -- said of fruits.","pos":""}],"MARGOSA":[{"def":"A large tree of genus Melia (M.","pos":""},{"def":"The territory or jurisdiction of a margrave.","pos":""}],"MARGRAVE":[{"def":"Originally, a lord or keeper of the borders or marches in Germany.","pos":""},{"def":"The English equivalent of the German title of nobility, markgraf; a marquis.","pos":""}],"MARGRAVINE":[{"def":"The wife of a margrave.","pos":""}],"MARGUERITE":[{"def":"The daisy (Bellis perennis).","pos":""}]}