{"CAGE":[{"def":"An outer framework of timber, inclosing something within it; as the cage of a staircase.","pos":""},{"def":"The drum on which the rope is wound in a hoisting whim.","pos":""}],"CAGED":[{"def":"Confined in, or as in, a cage; like a cage or prison.","pos":""}],"CAGELING":[{"def":"A bird confined in a cage; esp.","pos":""}],"CAGIT":[{"def":"A king of parrot, of a beautiful green color, found in the Philippine Islands.","pos":""}],"CAGMAG":[{"def":"A tough old goose; hence, coarse, bad food of any kind.","pos":""}],"CAGOT":[{"def":"One of a race inhabiting the valleys of the Pyrenees, who until 1793 were political and social outcasts (Christian Pariahs).","pos":""}]}