{"AUSCULTATE":[{"def":"To practice auscultation; to examine by auscultation.","pos":""}],"AUSCULTATION":[{"def":"An examination by listening either directly with the ear (immediate auscultation) applied to parts of the body, as the abdomen; or with the stethoscope (mediate ~), in order to distinguish sounds recognized as a sign of health or of disease.","pos":""}],"AUSCULTATOR":[{"def":"One who practices auscultation.","pos":""}],"AUSCULTATORY":[{"def":"Of or pertaining to auscultation.","pos":""}],"AUSPICATE":[{"def":"To foreshow; to foretoken.","pos":""},{"def":"To give a favorable turn to in commencing; to inaugurate; -- a sense derived from the Roman practice of taking the auspicium, or inspection of birds, before undertaking any important business.","pos":""}],"AUSPICE":[{"def":"A divining or taking of omens by observing birds; an omen as to an undertaking, drawn from birds; an augury; an omen or sign in general; an indication as to the future.","pos":""},{"def":"Protection; patronage and care; guidance.","pos":""}],"AUSPICIAL":[{"def":"Of or pertaining to auspices; auspicious.","pos":""}],"AUSPICIOUS":[{"def":"Having omens or tokens of a favorable issue; giving promise of success, prosperity, or happiness; predicting good; as, an auspicious beginning.","pos":""},{"def":"Prosperous; fortunate; as, auspicious years.","pos":""}],"AUSTERE":[{"def":"Sour and astringent; rough to the state; having acerbity; as, an austere crab apple; austere wine.","pos":""},{"def":"Severe in modes of judging, or living, or acting; rigid; rigorous; stern; as, an austere man, look, life.","pos":""}],"AUSTERELY":[{"def":"Severely; rigidly; sternly.","pos":""}],"AUSTERENESS":[{"def":"Harshness or astringent sourness to the taste; acerbity.","pos":""},{"def":"Severity; strictness; austerity.","pos":""}],"AUSTERITY":[{"def":"Sourness and harshness to the taste.","pos":""},{"def":"Severity of manners or life; extreme rigor or strictness; harsh discipline.","pos":""}],"AUSTIN":[{"def":"Augustinian; as, Austin friars.","pos":""}],"AUSTRAL":[{"def":"Southern; lying or being in the south; as, austral land; austral ocean.","pos":""}],"AUSTRALASIAN":[{"def":"Of or pertaining to Australasia; as, Australasian regions.","pos":""},{"def":"A native or an inhabitant of Australasia.","pos":""}],"AUSTRALIAN":[{"def":"Of or pertaining to Australia.","pos":""},{"def":"A native or an inhabitant of Australia.","pos":""}],"AUSTRALIAN BALLOT":[{"def":"A system of balloting or voting in public elections, originally used in South Australia, in which there is such an arrangement for polling votes that secrecy is compulsorily maintained, and the ballot used is an official ballot printed and distributed by the government.","pos":""}],"AUSTRALIZE":[{"def":"To tend toward the south pole, as a magnet.","pos":""}],"AUSTRIAN":[{"def":"Of or pertaining to Austria, or to its inhabitants.","pos":""},{"def":"A native or an inhabitant of Austria.","pos":""}],"AUSTRINE":[{"def":"Southern; southerly; austral.","pos":""}],"AUSTRO-HUNGARIAN":[{"def":"Of or pertaining to the monarchy composed of Austria and Hungary.","pos":""}],"AUSTROMANCY":[{"def":"Soothsaying, or prediction of events, from observation of the winds.","pos":""}],"AUSZUG":[{"def":"See Army organization, Switzerland.","pos":""}]}