{"WHIFF":[{"def":"The marysole, or sail fluke.","pos":""}],"WHIFFET":[{"def":"A little whiff or puff.","pos":""}],"WHIFFING":[{"def":"The act of one who, or that which, whiffs.","pos":""},{"def":"A mode of fishing with a hand line for pollack, mackerel, and the like.","pos":""}],"WHIFFLE":[{"def":"To waver, or shake, as if moved by gusts of wind; to shift, turn, or veer about.","pos":""},{"def":"To change from one opinion or course to another; to use evasions; to prevaricate; to be fickle.","pos":""}],"WHIFFLER":[{"def":"One who whiffles, or frequently changes his opinion or course; one who uses shifts and evasions in argument; hence, a trifler.","pos":""},{"def":"One who plays on a whiffle; a fifer or piper.","pos":""}],"WHIFFLETREE":[{"def":"Same as Whippletree.","pos":""}]}