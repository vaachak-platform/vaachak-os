{"SYNGENESIA":[{"def":"A Linnæan class of plants in which the stamens are united by the anthers.","pos":""},{"def":"Having the stamens united by the anthers; of or pertaining to the Syngenesia.","pos":""}],"SYNGENESIS":[{"def":"A theory of generation in which each germ is supposed to contain the germs of all subsequent generations; -- the opposite of epigenesis.","pos":""}],"SYNGNATHI":[{"def":"A suborder of lophobranch fishes which have an elongated snout and lack the ventral and first dorsal fins.","pos":""}],"SYNGRAPH":[{"def":"A writing signed by both or all the parties to a contract or bond.","pos":""}]}