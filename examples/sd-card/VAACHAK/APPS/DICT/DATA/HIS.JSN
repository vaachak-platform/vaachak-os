{"HIS":[{"def":"Belonging or pertaining to him; -- used as a pronominal adjective or adjective pronoun; as, tell John his papers are ready; formerly used also for its, but this use is now obsolete.","pos":""},{"def":"The possessive of he; as, the book is his.","pos":""}],"HISINGERITE":[{"def":"A soft black, iron ore, nearly earthy, a hydrous silicate of iron.","pos":""}],"HISPANIC":[{"def":"Of or pertaining to Spain or its language; as, Hispanic words.","pos":""}],"HISPANICISM":[{"def":"A Spanish idiom or mode of speech.","pos":""}],"HISPANICIZE":[{"def":"To give a Spanish form or character to; as, to Hispanicize Latin words.","pos":""}],"HISPID":[{"def":"Beset with stiff hairs or bristles.","pos":""}],"HISPIDULOUS":[{"def":"Minutely hispid.","pos":""}],"HISS":[{"def":"To make with the mouth a prolonged sound like that of the letter s, by driving the breath between the tongue and the teeth; to make with the mouth a sound like that made by a goose or a snake when angered; esp.","pos":""},{"def":"To make a similar noise by any means; to pass with a sibilant sound; as, the arrow hissed as it flew.","pos":""}],"HISSING":[{"def":"The act of emitting a hiss or hisses.","pos":""},{"def":"The occasion of contempt; the object of scorn and derision.","pos":""}],"HISSINGLY":[{"def":"With a hissing sound.","pos":""}],"HIST":[{"def":"Hush; be silent; -- a signal for silence.","pos":""}],"HISTIOLOGY":[{"def":"Same as Histology.","pos":""}],"HISTOGENETIC":[{"def":"Tissue-producing; connected with the formation and development of the organic tissues.","pos":""}],"HISTOGENY":[{"def":"Same as Histogenesis.","pos":""}],"HISTOGRAPHER":[{"def":"One who describes organic tissues; an histologist.","pos":""}],"HISTOGRAPHICAL":[{"def":"Of or pertaining to histography.","pos":""}],"HISTOGRAPHY":[{"def":"A description of, or treatise on, organic tissues.","pos":""}],"HISTOHAEMATIN":[{"def":"One of a class of respiratory pigments, widely distributed in the animal kingdom, capable of ready oxidation and reduction.","pos":""}],"HISTOID":[{"def":"Resembling the normal tissues; as, histoid tumors.","pos":""},{"def":"Pertaining to histology, or to the microscopic structure of the tissues of living organisms.","pos":""}],"HISTOLOGIST":[{"def":"One versed in histology.","pos":""}],"HISTOLOGY":[{"def":"That branch of biological science, which treats of the minute (microscopic) structure of animal and vegetable tissues; -- called also histiology.","pos":""}],"HISTOLYSIS":[{"def":"The decay and dissolution of the organic tissues and of the blood.","pos":""}],"HISTOLYTIC":[{"def":"Of or pertaining to histolysis, or the degeneration of tissues.","pos":""}],"HISTONOMY":[{"def":"The science which treats of the laws relating to organic tissues, their formation, development, functions, etc.","pos":""}],"HISTOPHYLY":[{"def":"The tribal history of cells, a division of morphophyly.","pos":""}],"HISTORIAN":[{"def":"Of or pertaining to history, or the record of past events; as, an historical poem; the historic page.","pos":""}],"HISTORICALLY":[{"def":"In the manner of, or in accordance with, history.","pos":""}],"HISTORICIZE":[{"def":"To record or narrate in the manner of a history; to chronicle.","pos":""}],"HISTORIED":[{"def":"Related in history.","pos":""}],"HISTORIETTE":[{"def":"Historical narration on a small scale; a brief recital; a story.","pos":""}],"HISTORIFY":[{"def":"To record in or as history.","pos":""}],"HISTORIOGRAPHER":[{"def":"An historian; a writer of history; especially, one appointed or designated to write a history; also, a title bestowed by some governments upon historians of distinction.","pos":""}],"HISTORIOGRAPHERSHIP":[{"def":"The office of an historiographer.","pos":""}],"HISTORIOGRAPHY":[{"def":"The art of employment of an historiographer.","pos":""}],"HISTORIOLOGY":[{"def":"A discourse on history.","pos":""}],"HISTORIONOMER":[{"def":"One versed in the phenomena of history and the laws controlling them.","pos":""}],"HISTORIZE":[{"def":"To relate as history; to chronicle; to historicize.","pos":""}],"HISTORY":[{"def":"A learning or knowing by inquiry; the knowledge of facts and events, so obtained; hence, a formal statement of such information; a narrative; a description; a written record; as, the history of a patient's case; the history of a legislative bill.","pos":""}],"HISTOTOMY":[{"def":"The dissection of organic tissues.","pos":""}],"HISTOZYME":[{"def":"A soluble ferment occurring in the animal body, to the presence of which many normal decompositions and synthetical processes are supposed to be due.","pos":""}],"HISTRION":[{"def":"Of or relating to the stage or a stageplayer; befitting a theatre; theatrical; -- sometimes in a bad sense.","pos":""}],"HISTRIONICISM":[{"def":"The histronic art; stageplaying.","pos":""}],"HISTRIONISM":[{"def":"Theatrical representation; acting; affectation.","pos":""}],"HISTRIONIZE":[{"def":"To act; to represent on the stage, or theatrically.","pos":""}]}