{"EPISCOPACY":[{"def":"Government of the church by bishops; church government by three distinct orders of ministers -- bishops, priests, and deacons -- of whom the bishops have an authority superior and of a different kind.","pos":""}],"EPISCOPAL":[{"def":"Governed by bishops; as, an episcopal church.","pos":""},{"def":"Belonging to, or vested in, bishops; as, episcopal jurisdiction or authority; the episcopal system.","pos":""}],"EPISCOPALIAN":[{"def":"Pertaining to bishops, or government by bishops; episcopal; specifically, of or relating to the Protestant Episcopal Church.","pos":""}],"EPISCOPALIANISM":[{"def":"The doctrine and usages of Episcopalians; episcopacy.","pos":""}],"EPISCOPALLY":[{"def":"By episcopal authority; in an episcopal manner.","pos":""}],"EPISCOPATE":[{"def":"A bishopric; the office and dignity of a bishop.","pos":""},{"def":"The collective body of bishops.","pos":""}],"EPISCOPICIDE":[{"def":"The killing of a bishop.","pos":""}],"EPISCOPIZE":[{"def":"To make a bishop of by consecration.","pos":""}],"EPISCOPY":[{"def":"Survey; superintendence.","pos":""}],"EPISEPALOUS":[{"def":"Growing on the sepals or adnate to them.","pos":""}],"EPISKELETAL":[{"def":"Above or outside of the endoskeleton; epaxial.","pos":""}],"EPISODAL":[{"def":"Same as Episodic.","pos":""}],"EPISODE":[{"def":"A separate incident, story, or action, introduced for the purpose of giving a greater variety to the events related; an incidental narrative, or digression, separable from the main subject, but naturally arising from it.","pos":""}],"EPISODIAL":[{"def":"Pertaining to an episode; by way of episode; episodic.","pos":""},{"def":"Of or pertaining to an episode; adventitious.","pos":""}],"EPISPADIAS":[{"def":"A deformity in which the urethra opens upon the top of the penis, instead of at its extremity.","pos":""}],"EPISPASTIC":[{"def":"Attracting the humors to the skin; exciting action in the skin; blistering.","pos":""}],"EPISPERM":[{"def":"The skin or coat of a seed, especially the outer coat.","pos":""}],"EPISPERMIC":[{"def":"Pertaining, or belonging, to the episperm, or covering of a seed.","pos":""}],"EPISPORE":[{"def":"The thickish outer coat of certain spores.","pos":""}],"EPISTAXIS":[{"def":"Bleeding at the nose.","pos":""}],"EPISTEMOLOGY":[{"def":"The theory or science of the method or grounds of knowledge.","pos":""}],"EPISTERNAL":[{"def":"Of or pertaining to the episternum.","pos":""}],"EPISTERNUM":[{"def":"One of the lateral pieces next to the sternum in the thorax of insects.","pos":""}],"EPISTILBITE":[{"def":"A crystallized, transparent mineral of the Zeolite family.","pos":""}],"EPISTLE":[{"def":"One of the letters in the New Testament which were addressed to their Christian brethren by Apostles.","pos":""}],"EPISTLER":[{"def":"The ecclesiastic who reads the epistle at the communion service.","pos":""}],"EPISTOLARY":[{"def":"Pertaining to epistles or letters; suitable to letters and correspondence; as, an epistolary style.","pos":""},{"def":"Contained in letters; carried on by letters.","pos":""}],"EPISTOLEAN":[{"def":"One who writes epistles; a correspondent.","pos":""}],"EPISTOLER":[{"def":"One of the clergy who reads the epistle at the communion service; an epistler.","pos":""}],"EPISTOLET":[{"def":"A little epistle.","pos":""},{"def":"Pertaining to letters or epistles; in the form or style of letters; epistolary.","pos":""}],"EPISTOLIZE":[{"def":"To write epistles.","pos":""}],"EPISTOLIZER":[{"def":"A writer of epistles.","pos":""}],"EPISTOLOGRAPHIC":[{"def":"Pertaining to the writing of letters; used in writing letters; epistolary.","pos":""}],"EPISTOLOGRAPHY":[{"def":"The art or practice of writing epistles.","pos":""}],"EPISTROPHE":[{"def":"A figure in which successive clauses end with the same word or affirmation; e.","pos":""}],"EPISTYLE":[{"def":"A massive piece of stone or wood laid immediately on the abacus of the capital of a column or pillar; -- now called architrave.","pos":""}],"EPISYLLOGISM":[{"def":"A syllogism which assumes as one of its premises a proposition which was the conclusion of a preceding syllogism, called, in relation to this, the prosyllogism.","pos":""}]}