{"OBREPTION":[{"def":"The obtaining gifts of escheat by fraud or surprise.","pos":""}],"OBREPTITIOUS":[{"def":"Done or obtained by surprise; with secrecy, or by concealment of the truth.","pos":""}],"OBROGATE":[{"def":"To annul indirectly by enacting a new and contrary law, instead of by expressly abrogating or repealing the old one.","pos":""}]}