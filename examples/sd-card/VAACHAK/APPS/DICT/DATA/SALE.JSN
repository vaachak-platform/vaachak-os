{"SALE":[{"def":"See Salable, Salably, etc.","pos":""}],"SALEBROSITY":[{"def":"Roughness or ruggedness.","pos":""}],"SALEP":[{"def":"The dried tubers of various species of Orchis, and Eulophia.","pos":""}],"SALERATUS":[{"def":"Aërated salt; a white crystalline substance having an alkaline taste and reaction, consisting of sodium bicarbonate (see under Sodium.","pos":""}],"SALESMAN":[{"def":"One who sells anything; one whose occupation is to sell goods or merchandise.","pos":""}],"SALESWOMAN":[{"def":"A woman whose occupation is to sell goods or merchandise.","pos":""}],"SALEWORK":[{"def":"Work or things made for sale; hence, work done carelessly or slightingly.","pos":""}]}