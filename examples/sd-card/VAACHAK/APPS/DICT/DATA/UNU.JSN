{"UNUSAGE":[{"def":"Want or lack of usage.","pos":""}],"UNUSED":[{"def":"Not used; as, an unused book; an unused apartment.","pos":""},{"def":"Not habituated; unaccustomed.","pos":""}],"UNUSUAL":[{"def":"Not usual; uncommon; rare; as, an unusual season; a person of unusual grace or erudition.","pos":""}],"UNUTTERABLE":[{"def":"Not utterable; incapable of being spoken or voiced; inexpressible; ineffable; unspeakable; as, unutterable anguish.","pos":""}]}