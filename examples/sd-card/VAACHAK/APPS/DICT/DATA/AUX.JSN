{"AUXANOMETER":[{"def":"An instrument to measure the growth of plants.","pos":""}],"AUXESIS":[{"def":"A figure by which a grave and magnificent word is put for the proper word; amplification; hyperbole.","pos":""}],"AUXETIC":[{"def":"Pertaining to, or containing, auxesis; amplifying.","pos":""}],"AUXETOPHONE":[{"def":"A pneumatic reproducer for a phonograph, controlled by the recording stylus on the principle of the relay.","pos":""}],"AUXILIAR":[{"def":"The auxiliar troops and Trojan hosts appear.","pos":""}],"AUXILIARY":[{"def":"Conferring aid or help; helping; aiding; assisting; subsidiary; as auxiliary troops.","pos":""}],"AUXILIATORY":[{"def":"Auxiliary; helping.","pos":""}],"AUXOMETER":[{"def":"An instrument for measuring the magnifying power of a lens or system of lenses.","pos":""}]}