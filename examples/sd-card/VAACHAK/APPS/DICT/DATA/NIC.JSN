{"NICAGUA":[{"def":"The laughing falcon.","pos":""}],"NICCOLITE":[{"def":"A mineral of a copper-red color and metallic luster; an arsenide of nickel; -- called also coppernickel, kupfernickel.","pos":""}],"NICE":[{"def":"Foolish; silly; simple; ignorant; also, weak; effeminate.","pos":""},{"def":"Of trifling moment; nimportant; trivial.","pos":""}],"NICELY":[{"def":"In a nice manner.","pos":""}],"NICENE":[{"def":"Of or pertaining to Nice, a town of Asia Minor, or to the ecumenial council held there A.","pos":""}],"NICENESS":[{"def":"Quality or state of being nice.","pos":""}],"NICETY":[{"def":"The quality or state of being nice (in any of the senses of that word.","pos":""},{"def":"Delicacy or exactness of perception; minuteness of observation or of discrimination; precision.","pos":""}],"NICHE":[{"def":"A cavity, hollow, or recess, generally within the thickness of a wall, for a statue, bust, or other erect ornament.","pos":""}],"NICHED":[{"def":"Placed in a niche.","pos":""}],"NICK":[{"def":"An evil spirit of the waters.","pos":""}],"NICKEL":[{"def":"A bright silver-white metallic element.","pos":""}],"NICKEL STEEL":[{"def":"A kind of cast steel containing nickel, which greatly increases its strength.","pos":""}],"NICKELIC":[{"def":"Pertaining to, or containing, nickel; specifically, designating compounds in which, as contrasted with the nickelous compounds, the metal has a higher valence; as nickelic oxide.","pos":""}],"NICKELIFEROUS":[{"def":"Containing nickel; as, nickelferous iron.","pos":""}],"NICKELINE":[{"def":"An alloy of nickel, a variety of German silver.","pos":""}],"NICKELODEON":[{"def":"A place of entertainment, as for moving picture exhibition, charging a fee or admission price of five cents.","pos":""}],"NICKELOUS":[{"def":"Of, pertaining to, or designating, those compounds of nickel in which, as contrasted with the nickelic compounds, the metal has a lower valence; as, nickelous oxide.","pos":""}],"NICKER":[{"def":"One of the night brawlers of London formerly noted for breaking windows with half-pence.","pos":"verb"},{"def":"The cutting lip which projects downward at the edge of a boring bit and cuts a circular groove in the wood to limit the size of the hole that is bored.","pos":"verb"}],"NICKER NUT":[{"def":"A rounded seed, rather smaller than a nutmeg, having a hard smooth shell, and a yellowish or bluish color.","pos":""}],"NICKER TREE":[{"def":"The plant producing nicker nuts.","pos":""}],"NICKING":[{"def":"Small coal produced in making the nicking.","pos":""}],"NICKLE":[{"def":"The European woodpecker, or yaffle; -- called also nicker pecker.","pos":""}],"NICKNACKERY":[{"def":"See Knickknackery.","pos":""}],"NICKNAME":[{"def":"A name given in contempt, derision, or sportive familiarity; a familiar or an opprobrious appellation.","pos":""}],"NICOLAITAN":[{"def":"One of certain corrupt persons in the early church at Ephesus, who are censured in rev.","pos":""}],"NICOTIAN":[{"def":"Pertaining to, or derived from, tobacco.","pos":""}],"NICOTIANA":[{"def":"A genus of American and Asiatic solanaceous herbs, with viscid foliage and funnel-shaped blossoms.","pos":""}],"NICOTIANINE":[{"def":"A white waxy substance having a hot, bitter taste, extracted from tobacco leaves and called also tobacco camphor.","pos":""}],"NICOTIDINE":[{"def":"A complex, oily, nitrogenous base, isomeric with nicotine, and obtained by the reduction of certain derivatives of the pyridine group.","pos":""}],"NICOTINE":[{"def":"An alkaloid which is the active principle of tobacco.","pos":""}],"NICOTINIC":[{"def":"Pertaining to, or derived from, nicotine; nicotic; -- used specifically to designate an acid related to pyridine, obtained by the oxidation of nicotine, and called nicotinic acid.","pos":""}],"NICOTINISM":[{"def":"The morbid condition produced by the excessive use of tobacco.","pos":""}],"NICTATE":[{"def":"To wink; to nictitate.","pos":""}],"NICTATION":[{"def":"the act of winking; nictitation.","pos":""}],"NICTITATE":[{"def":"To wink; to nictate.","pos":""}],"NICTITATION":[{"def":"The act of winking.","pos":""}]}