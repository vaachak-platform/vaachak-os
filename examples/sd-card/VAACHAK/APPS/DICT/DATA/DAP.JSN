{"DAP":[{"def":"To drop the bait gently on the surface of the water.","pos":""}],"DAPATICAL":[{"def":"Sumptuous in cheer.","pos":""}],"DAPHNE":[{"def":"A genus of diminutive Shrubs, mostly evergreen, and with fragrant blossoms.","pos":""},{"def":"A nymph of Diana, fabled to have been changed into a laurel tree.","pos":""}],"DAPHNETIN":[{"def":"A colorless crystalline substance, C9H6O4, extracted from daphnin.","pos":""}],"DAPHNIA":[{"def":"A genus of the genus Daphnia.","pos":""}],"DAPHNOMANCY":[{"def":"Divination by means of the laurel.","pos":""}],"DAPIFER":[{"def":"One who brings meat to the table; hence, in some countries, the official title of the grand master or steward of the king's or a nobleman's household.","pos":""}],"DAPPER":[{"def":"Little and active; spruce; trim; smart; neat in dress or appearance; lively.","pos":""}],"DAPPERLING":[{"def":"A dwarf; a dandiprat.","pos":""}],"DAPPLE":[{"def":"One of the spots on a dappled animal.","pos":""},{"def":"Marked with spots of different shades of color; spotted; variegated; as, a dapple horse.","pos":""}]}