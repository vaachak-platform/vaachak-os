{"PATE":[{"def":"A kind of platform with a parapet, usually of an oval form, and generally erected in marshy grounds to cover a gate of a fortified place.","pos":""}],"PATED":[{"def":"Having a pate; -- used only in composition; as, long-pated; shallow-pated.","pos":""}],"PATEFACTION":[{"def":"The act of opening, disclosing, or manifesting; open declaration.","pos":""}],"PATELA":[{"def":"A large flat-bottomed trading boat peculiar to the river Ganges; -- called also puteli.","pos":""}],"PATELLA":[{"def":"The kneepan; the cap of the knee.","pos":""},{"def":"A genus of marine gastropods, including many species of limpets.","pos":""}],"PATELLAR":[{"def":"Of or pertaining to the patella, or kneepan.","pos":""}],"PATELLIFORM":[{"def":"Resembling a limpet of the genus Patella.","pos":""}],"PATELLULA":[{"def":"A cuplike sucker on the feet of certain insects.","pos":""}],"PATEN":[{"def":"The place on which the consecrated bread is placed in the Eucharist, or on which the host is placed during the Mass.","pos":""}],"PATENA":[{"def":"A grassy expanse in the hill region of Ceylon.","pos":""}],"PATENCY":[{"def":"The condition of being open, enlarged, or spread.","pos":""},{"def":"The state of being patent or evident.","pos":""}],"PATENT":[{"def":"Open; expanded; evident; apparent; unconcealed; manifest; public; conspicuous.","pos":""},{"def":"Spreading; forming a nearly right angle with the steam or branch; as, a patent leaf.","pos":""}],"PATENT-HAMMERED":[{"def":"Having a surface dressed by cutting with a hammer the head of which consists of broad thin chisels clamped together.","pos":""}],"PATENTABLE":[{"def":"Suitable to be patented; capable of being patented.","pos":""}],"PATENTEE":[{"def":"One to whom a grant is made, or a privilege secured, by patent.","pos":""}],"PATENTLY":[{"def":"Openly; evidently.","pos":""}],"PATERA":[{"def":"A circular ornament, resembling a dish, often worked in relief on friezes, and the like.","pos":""}],"PATERFAMILIAS":[{"def":"The head of a family; in a large sense, the proprietor of an estate; one who is his own master.","pos":""}],"PATERNAL":[{"def":"Of or pertaining to a father; fatherly; showing the disposition of a father; guiding or instructing as a father; as, paternal care.","pos":""},{"def":"Received or derived from a father; hereditary; as, a paternal estate.","pos":""}],"PATERNALISM":[{"def":"The theory or practice of paternal government.","pos":""}],"PATERNALLY":[{"def":"In a paternal manner.","pos":""}],"PATERNITY":[{"def":"The relation of a father to his child; fathership; fatherhood; family headship; as, the divine paternity.","pos":""},{"def":"Derivation or descent from a father; male parentage; as, the paternity of a child.","pos":""}],"PATERNOSTER":[{"def":"A beadlike ornament in moldings.","pos":""},{"def":"A line with a row of hooks and bead Paternoster pump, Paternoster wheel, a chain pump; a noria.","pos":""}],"PATESI":[{"def":"A religious as well as a secular designation applied to rulers of some of the city states of ancient Chaldea, as Lagash or Shirpurla, who were conceived to be direct representatives of the tutelary god of the place.","pos":""}]}