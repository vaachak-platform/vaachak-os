{"HYPE":[{"def":"Intense publicity for a future event, performed in a showy or excessively dramatic manner suggesting an importance not justified by the event; as, the hype surrounding the superbowl is usually ludicrous.","pos":""}],"HYPER-":[{"def":"A prefix equivalent to super- or per-; as hyperoxide, or peroxide.","pos":""}],"HYPERAEMIA":[{"def":"A superabundance or congestion of blood in an organ or part of the body.","pos":""}],"HYPERAESTHESIA":[{"def":"A state of exalted or morbidly increased sensibility of the body, or of a part of it.","pos":""}],"HYPERAPOPHYSIS":[{"def":"A lateral and backward-projecting process on the dorsal side of a vertebra.","pos":""}],"HYPERASPIST":[{"def":"One who holds a shield over another; hence, a defender.","pos":""}],"HYPERBATIC":[{"def":"Of or pertaining to an hyperbaton; transposed; inverted.","pos":""}],"HYPERBATON":[{"def":"A figurative construction, changing or inverting the natural order of words or clauses; as, \"echoed the hills\" for \"the hills echoed.","pos":""}],"HYPERBOLA":[{"def":"A curve formed by a section of a cone, when the cutting plane makes a greater angle with the base than the side of the cone makes.","pos":""}],"HYPERBOLE":[{"def":"A figure of speech in which the expression is an evident exaggeration of the meaning intended to be conveyed, or by which things are represented as much greater or less, better or worse, than they really are; a statement exaggerated fancifully, through excitement, or for effect.","pos":""},{"def":"Belonging to the hyperbola; having the nature of the hyperbola.","pos":""}],"HYPERBOLICALLY":[{"def":"In the form of an hyperbola.","pos":""},{"def":"With exaggeration; in a manner to express more or less than the truth.","pos":""}],"HYPERBOLIFORM":[{"def":"Having the form, or nearly the form, of an hyperbola.","pos":""}],"HYPERBOLISM":[{"def":"The use of hyperbole.","pos":""}],"HYPERBOLIST":[{"def":"One who uses hyperboles.","pos":""}],"HYPERBOLIZE":[{"def":"To speak or write with exaggeration.","pos":""}],"HYPERBOLOID":[{"def":"A surface of the second order, which is cut by certain planes in hyperbolas; also, the solid, bounded in part by such a surface.","pos":""}],"HYPERBOREAN":[{"def":"Of or pertaining to the region beyond the North wind, or to its inhabitants.","pos":""}],"HYPERCARBURETED":[{"def":"Having an excessive proportion of carbonic acid; -- said of bicarbonates or acid carbonates.","pos":""}],"HYPERCATALECTIC":[{"def":"Having a syllable or two beyond measure; as, a hypercatalectic verse.","pos":""}],"HYPERCHROMATISM":[{"def":"The condition of having an unusual intensity of color.","pos":""}],"HYPERCRITIC":[{"def":"One who is critical beyond measure or reason; a carping critic; a captious censor.","pos":""}],"HYPERCRITICAL":[{"def":"Over critical; unreasonably or unjustly critical; carping; captious.","pos":""},{"def":"Excessively nice or exact.","pos":""}],"HYPERCRITICALLY":[{"def":"In a hypercritical manner.","pos":""}],"HYPERCRITICISE":[{"def":"To criticise with unjust severity; to criticise captiously.","pos":""}],"HYPERCRITICISM":[{"def":"Excessive criticism, or unjust severity or rigor of criticism; zoilism.","pos":""}],"HYPERDICROTIC":[{"def":"Excessive dicrotic; as, a hyperdicrotic pulse.","pos":""}],"HYPERDICROTISM":[{"def":"A hyperdicrotic condition.","pos":""}],"HYPERDICROTOUS":[{"def":"Hy`per*di\"cro*tous, a.","pos":""}],"HYPERDULIA":[{"def":"Veneration or worship given to the Virgin Mary as the most exalted of mere creatures; higher veneration than dulia.","pos":""}],"HYPERESTHESIA":[{"def":"Same as Hyperæsthesia.","pos":""}],"HYPERICUM":[{"def":"A genus of plants, generally with dotted leaves and yellow flowers; -- called also St.","pos":""}],"HYPERINOSIS":[{"def":"A condition of the blood, characterized by an abnormally large amount of fibrin, as in many inflammatory diseases.","pos":""}],"HYPERION":[{"def":"The god of the sun; in the later mythology identified with Apollo, and distinguished for his beauty.","pos":""}],"HYPERKINESIS":[{"def":"Abnormally increased muscular movement; spasm.","pos":""}],"HYPERKINETIC":[{"def":"Of or pertaining to hyperkinesis.","pos":""}],"HYPERMETAMORPHOSIS":[{"def":"A kind of metamorphosis, in certain insects, in which the larva itself undergoes remarkable changes of form and structure during its growth.","pos":""}],"HYPERMETER":[{"def":"A verse which has a redundant syllable or foot; a hypercatalectic verse.","pos":""}],"HYPERMETRICAL":[{"def":"Having a redundant syllable; exceeding the common measure.","pos":""},{"def":"A condition of the eye in which, through shortness of the eyeball or fault of the refractive media, the rays of light come to a focus behind the retina; farsightedness; -- called also hyperopia.","pos":""}],"HYPERMYRIORAMA":[{"def":"A show or exhibition having a great number of scenes or views.","pos":""}],"HYPERNOEA":[{"def":"Abnormal breathing, due to slightly deficient arterialization of the blood; -- in distinction from eupnoea.","pos":""}],"HYPEROARTIA":[{"def":"An order of marsipobranchs including the lampreys.","pos":""}],"HYPERORGANIC":[{"def":"Higher than, or beyond the sphere of, the organic.","pos":""}],"HYPERORTHODOXY":[{"def":"Orthodoxy pushed to excess.","pos":""}],"HYPEROTRETA":[{"def":"An order of marsipobranchs, including the Myxine or hagfish and the genus Bdellostoma.","pos":""}],"HYPEROXIDE":[{"def":"A compound having a relatively large percentage of oxygen; a peroxide.","pos":""},{"def":"Combined with a relatively large amount of oxygen; -- said of higher oxides.","pos":""}],"HYPEROXYMURIATE":[{"def":"Hy`per*ox`y*mu\"ri*ate, n.","pos":""}],"HYPEROXYMURIATIC":[{"def":"Perchloric; as, hyperoxymuriatic acid.","pos":""}],"HYPERPHYSICAL":[{"def":"Above or transcending physical laws; supernatural.","pos":""}],"HYPERPLASIA":[{"def":"An increase in, or excessive growth of, the normal elements of any part.","pos":""}],"HYPERPLASTIC":[{"def":"Tending to excess of formative action.","pos":""}],"HYPERPYREXIA":[{"def":"A condition of excessive fever; an elevation of temperature in a disease, in excess of the limit usually observed in that disease.","pos":""}],"HYPERSECRETION":[{"def":"Morbid or excessive secretion, as in catarrh.","pos":""}],"HYPERSENSIBILITY":[{"def":"See Hyperæsthesia.","pos":""}],"HYPERSPACE":[{"def":"An imagined space having more than three dimensions.","pos":""}],"HYPERSTHENE":[{"def":"An orthorhombic mineral of the pyroxene group, of a grayish or greenish black color, often with a peculiar bronzelike luster (schiller) on the cleavage surface.","pos":""}],"HYPERSTHENIC":[{"def":"Composed of, or containing, hypersthene.","pos":""}],"HYPERTHETICAL":[{"def":"Exaggerated; excessive; hyperbolical.","pos":""}],"HYPERTHYRION":[{"def":"That part of the architrave which is over a door or window.","pos":""},{"def":"Of or pertaining to hypertrophy; affected with, or tending to, hypertrophy.","pos":""}],"HYPERTROPHIED":[{"def":"Excessively developed; characterized by hypertrophy.","pos":""}],"HYPERTROPHY":[{"def":"A condition of overgrowth or excessive development of an organ or part; -- the opposite of atrophy.","pos":""}]}