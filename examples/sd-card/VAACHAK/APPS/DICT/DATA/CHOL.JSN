{"CHOLAEMAA":[{"def":"A disease characterized by severe nervous symptoms, dependent upon the presence of the constituents of the bile in the blood.","pos":""}],"CHOLAGOGUE":[{"def":"Promoting the discharge of bile from the system.","pos":""},{"def":"An agent which promotes the discharge of bile from the system.","pos":""}],"CHOLATE":[{"def":"A salt of cholic acid; as, sodium cholate.","pos":""}],"CHOLECYSTIS":[{"def":"The gall bladder.","pos":""}],"CHOLECYSTOTOMY":[{"def":"The operation of making an opening in the gall bladder, as for the removal of a gallstone.","pos":""}],"CHOLEDOLOGY":[{"def":"A treatise on the bile and bilary organs.","pos":""}],"CHOLEIC":[{"def":"Pertaining to, or obtained from, bile; as, choleic acid.","pos":""}],"CHOLER":[{"def":"The bile; -- formerly supposed to be the seat and cause of irascibility.","pos":""},{"def":"Irritation of the passions; anger; wrath.","pos":""}],"CHOLERA":[{"def":"One of several diseases affecting the digestive and intestinal tract and more or less dangerous to life, esp.","pos":""}],"CHOLERAIC":[{"def":"Relating to, or resulting from, or resembling, cholera.","pos":""}],"CHOLERIC":[{"def":"Abounding with, or producing choler, or bile.","pos":""},{"def":"Easily irritated; irascible; inclined to anger.","pos":""}],"CHOLERICLY":[{"def":"In a choleric manner; angrily.","pos":""}],"CHOLERIFORM":[{"def":"Resembling cholera.","pos":""}],"CHOLESTERIC":[{"def":"Pertaining to cholesterin, or obtained from it; as, cholesteric acid.","pos":""}],"CHOLESTERIN":[{"def":"A white, fatty, crystalline substance, tasteless and odorless, found in animal and plant products and tissue, and especially in nerve tissue, in the bile, and in gallstones.","pos":""},{"def":"A verse having an iambus in the fifth place, and a spondee in the sixth or last.","pos":""}],"CHOLTRY":[{"def":"A Hindoo caravansary.","pos":""}]}