{"IMPLACABILITY":[{"def":"The quality or state of being implacable.","pos":""}],"IMPLACABLE":[{"def":"Not placable; not to be appeased; incapable of being pacified; inexorable; as, an implacable prince.","pos":""},{"def":"Incapable of ebign relieved or assuaged; inextinguishable.","pos":""}],"IMPLACABLENESS":[{"def":"The quality of being implacable; implacability.","pos":""}],"IMPLACABLY":[{"def":"In an implacable manner.","pos":""}],"IMPLACENTAL":[{"def":"Without a placenta, as marsupials and monotremes.","pos":""},{"def":"A mammal having no placenta.","pos":""}],"IMPLACENTALIA":[{"def":"A primary division of the Mammalia, including the monotremes and marsupials, in which no placenta is formed.","pos":""}],"IMPLANT":[{"def":"To plant, or infix, for the purpose of growth; to fix deeply; to instill; to inculate; to introduce; as, to implant the seeds of virtue, or the principles of knowledge, in the minds of youth.","pos":""}],"IMPLANTATION":[{"def":"The act or process of implantating.","pos":""}],"IMPLATE":[{"def":"To cover with plates; to sheathe; as, to implate a ship with iron.","pos":""}],"IMPLAUSIBILITY":[{"def":"Want of plausibility; the quality of being implausible.","pos":""}],"IMPLAUSIBLE":[{"def":"Not plausible; not wearing the appearance of truth or credibility, and not likely to be believed.","pos":""}],"IMPLEACH":[{"def":"To pleach; to interweave.","pos":""}],"IMPLEAD":[{"def":"To institute and prosecute a suit against, in court; to sue or prosecute at law; hence, to accuse; to impeach.","pos":""}],"IMPLEADABLE":[{"def":"Not admitting excuse, evasion, or plea; rigorous.","pos":""}],"IMPLEADER":[{"def":"One who prosecutes or sues another.","pos":""}],"IMPLEASING":[{"def":"Unpleasing; displeasing.","pos":""}],"IMPLEMENT":[{"def":"That which fulfills or supplies a want or use; esp.","pos":""}],"IMPLEMENTAL":[{"def":"Pertaining to, or characterized by, implements or their use; mechanical.","pos":""}],"IMPLETION":[{"def":"The act of filling, or the state of being full.","pos":""},{"def":"That which fills up; filling.","pos":""}],"IMPLEX":[{"def":"Intricate; entangled; complicated; complex.","pos":""}],"IMPLEXION":[{"def":"Act of involving, or state of being involved; involution.","pos":""}],"IMPLIABLE":[{"def":"Not pliable; inflexible; inyielding.","pos":""}],"IMPLICATE":[{"def":"To infold; to fold together; to interweave.","pos":""},{"def":"To bring into connection with; to involve; to connect; -- applied to persons, in an unfavorable sense; as, the evidence implicates many in this conspiracy; to be implicated in a crime, a discreditable transaction, a fault, etc.","pos":""}],"IMPLICATION":[{"def":"The act of implicating, or the state of being implicated.","pos":""},{"def":"An implying, or that which is implied, but not expressed; an inference, or something which may fairly be understood, though not expressed in words.","pos":""}],"IMPLICATIVE":[{"def":"Tending to implicate.","pos":""}],"IMPLICATIVELY":[{"def":"Im\"pli*ca*tive*ly, adv.","pos":""}],"IMPLICIT":[{"def":"Infolded; entangled; complicated; involved.","pos":""},{"def":"Tacitly comprised; fairly to be understood, though not expressed in words; implied; as, an implicit contract or agreement.","pos":""}],"IMPLICITLY":[{"def":"In an implicit manner; without reserve; with unreserved confidence.","pos":""},{"def":"By implication; impliedly; as, to deny the providence of God is implicitly to deny his existence.","pos":""}],"IMPLICITNESS":[{"def":"State or quality of being implicit.","pos":""}],"IMPLIED":[{"def":"Virtually involved or included; involved in substance; inferential; tacitly conceded; -- the correlative of express, or expressed.","pos":""}],"IMPLIEDLY":[{"def":"By implication or inference.","pos":""}],"IMPLODED":[{"def":"Formed by implosion.","pos":""}],"IMPLODENT":[{"def":"An implosive sound.","pos":""}],"IMPLORATION":[{"def":"The act of imploring; earnest supplication.","pos":""}],"IMPLORATOR":[{"def":"One who implores.","pos":""}],"IMPLORATORY":[{"def":"Supplicatory; entreating.","pos":""}],"IMPLORE":[{"def":"To call upon, or for, in supplication; to beseech; to prey to, or for, earnestly; to petition with urency; to entreat; to beg; -- followed directly by the word expressing the thing sought, or the person from whom it is sought.","pos":""}],"IMPLORER":[{"def":"One who implores.","pos":""}],"IMPLORING":[{"def":"That implores; beseeching; entreating.","pos":""}],"IMPLOSION":[{"def":"A burstion inwards, as of a vessel from which the air has been exhausted; -- contrasted with explosion.","pos":""}],"IMPLOSIVE":[{"def":"Formed by implosion.","pos":""},{"def":"An implosive sound, an implodent.","pos":""}],"IMPLUMED":[{"def":"Not plumed; without plumes or feathers; featherless.","pos":""}],"IMPLUVIUM":[{"def":"In Roman dwellings, a cistern or tank, set in the atrium or peristyle to recieve the water from the roof, by means of the compluvium; generally made ornamental with flowers and works of art around its birm.","pos":""}],"IMPLY":[{"def":"To infold or involve; to wrap up.","pos":""},{"def":"To involve in substance or essence, or by fair inference, or by construction of law, when not include virtually; as, war implies fighting.","pos":""}]}