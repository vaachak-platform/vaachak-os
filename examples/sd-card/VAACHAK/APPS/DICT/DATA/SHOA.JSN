{"SHOAD":[{"def":"A train of vein material mixed with rubbish; fragments of ore which have become separated by the action of water or the weather, and serve to direct in the discovery of mines.","pos":""}],"SHOADING":[{"def":"The tracing of veins of metal by shoads.","pos":""}],"SHOAL":[{"def":"A great multitude assembled; a crowd; a throng; -- said especially of fish; as, a shoal of bass.","pos":""}],"SHOALINESS":[{"def":"The quality or state of being shoaly; little depth of water; shallowness.","pos":""}],"SHOALING":[{"def":"Becoming shallow gradually.","pos":""}],"SHOALY":[{"def":"Full of shoals, or shallow places.","pos":""}]}