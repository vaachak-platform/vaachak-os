{"REPUBLIC":[{"def":"A state in which the sovereign power resides in the whole body of the people, and is exercised by representatives elected by them; a commonwealth.","pos":""}],"REPUBLICAN":[{"def":"Of or pertaining to a republic.","pos":""},{"def":"Consonant with the principles of a republic; as, republican sentiments or opinions; republican manners.","pos":""}],"REPUBLICANISM":[{"def":"A republican form or system of government; the principles or theory of republican government.","pos":""},{"def":"Attachment to, or political sympathy for, a republican form of government.","pos":""}],"REPUBLICANIZE":[{"def":"To change, as a state, into a republic; to republican principles; as, France was republicanized; to republicanize the rising generation.","pos":""}],"REPUBLICATE":[{"def":"To make public again; to republish.","pos":""}],"REPUBLICATION":[{"def":"A second publication, or a new publication of something before published, as of a former will, of a volume already published, or the like; specifically, the publication in one country of a work first issued in another; a reprint.","pos":""}],"REPUBLISH":[{"def":"To publish anew; specifically, to publish in one country (a work first published in another); also, to revive (a will) by re Subsecquent to the purchase or contract, the devisor republished his will.","pos":""}],"REPUBLISHER":[{"def":"One who republishes.","pos":""}],"REPUDIABLE":[{"def":"Admitting of repudiation; fit or proper to be put away.","pos":""}],"REPUDIATE":[{"def":"To cast off; to disavow; to have nothing to do with; to renounce; to reject.","pos":""},{"def":"To divorce, put away, or discard, as a wife, or a woman one has promised to marry.","pos":""}],"REPUDIATION":[{"def":"The act of repudiating, or the state of being repuddiated; as, the repudiation of a doctrine, a wife, a debt, etc.","pos":""}],"REPUDIATOR":[{"def":"One who repudiates.","pos":""}],"REPUGN":[{"def":"To fight against; to oppose; to resist.","pos":""}],"REPUGNABLE":[{"def":"Capable of being repugned or resisted.","pos":""},{"def":"The state or condition of being repugnant; opposition; contrariety; especially, a strong instinctive antagonism; aversion; reluctance; unwillingness, as of mind, passions, principles, qualities, and the like.","pos":""}],"REPUGNANT":[{"def":"Disposed to fight against; hostile; at war with; being at variance; contrary; inconsistent; refractory; disobedient; also, distasteful in a high degree; offensive; -- usually followed by to, rarely and less properly by with; as, all rudeness was repugnant to her nature.","pos":""}],"REPUGNANTLY":[{"def":"In a repugnant manner.","pos":""}],"REPUGNATE":[{"def":"To oppose; to fight against.","pos":""}],"REPUGNER":[{"def":"One who repugns.","pos":""}],"REPULLULATE":[{"def":"Re*pul\"lu*late (r-pl\"l-lt), v.","pos":""}],"REPULLULATION":[{"def":"The act of budding again; the state of having budded again.","pos":""}],"REPULSE":[{"def":"To repel; to beat or drive back; as, to repulse an assault; to repulse the enemy.","pos":""},{"def":"To repel by discourtesy, coldness, or denial; to reject; to send away; as, to repulse a suitor or a proffer.","pos":""}],"REPULSELESS":[{"def":"Not capable of being repulsed.","pos":""}],"REPULSER":[{"def":"One who repulses, or drives back.","pos":""}],"REPULSION":[{"def":"The power, either inherent or due to some physical action, by which bodies, or the particles of bodies, are made to recede from each other, or to resist each other's nearer approach; as, molecular repulsion; electrical repulsion.","pos":""}],"REPULSIVE":[{"def":"Serving, or able, to repulse; repellent; as, a repulsive force.","pos":""},{"def":"Cold; forbidding; offensive; as, repulsive manners.","pos":""}],"REPULSORY":[{"def":"Repulsive; driving back.","pos":""}],"REPURCHASE":[{"def":"To buy back or again; to regain by purchase.","pos":""}],"REPURIFY":[{"def":"To purify again.","pos":""}],"REPUTABLE":[{"def":"Having, or worthy of, good repute; held in esteem; honorable; praiseworthy; as, a reputable man or character; reputable conduct.","pos":""}],"REPUTATION":[{"def":"The character imputed to a person in the community in which he lives.","pos":""}],"REPUTATIVELY":[{"def":"Re*put\"a*tive*ly (r-pt\"-tv-l), adv.","pos":""}],"REPUTE":[{"def":"To hold in thought; to account; to estimate; to hold; to think; to reckon.","pos":""}],"REPUTEDLY":[{"def":"In common opinion or estimation; by repute.","pos":""}],"REPUTELESS":[{"def":"Not having good repute; disreputable; disgraceful; inglorius.","pos":""}]}