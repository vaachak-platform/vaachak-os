{"TRALATION":[{"def":"The use of a word in a figurative or extended sense; ametaphor; a trope.","pos":""}],"TRALATITION":[{"def":"A change, as in the use of words; a metaphor.","pos":""}],"TRALATITIOUS":[{"def":"Passed along; handed down; transmitted.","pos":""},{"def":"Metaphorical; figurative; not literal.","pos":""}],"TRALATITIOUSLY":[{"def":"Tral`a*ti\"tious*ly Defn: , adv.","pos":""}],"TRALINEATE":[{"def":"To deviate; to stray; to wander.","pos":""}],"TRALUCENCY":[{"def":"Translucency; as, the tralucency of a gem.","pos":""}],"TRALUCENT":[{"def":"The air's tralucent gallery.","pos":""}]}