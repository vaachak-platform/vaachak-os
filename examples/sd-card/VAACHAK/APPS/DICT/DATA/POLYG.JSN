{"POLYGALA":[{"def":"A genus of bitter herbs or shrubs having eight stamens and a two-celled ovary (as the Seneca snakeroot, the flowering wintergreen, etc.","pos":""}],"POLYGALACEOUS":[{"def":"Of or pertaining to a natural order of plants (Polygalaceæ) of which Polygala is the type.","pos":""}],"POLYGALIC":[{"def":"Of, pertaining to, or obtained from, Polygala; specifically, designating an acrid glucoside (called polygalic acid, senegin, etc.","pos":""}],"POLYGAMIST":[{"def":"One who practices polygamy, or maintains its lawfulness.","pos":""}],"POLYGAMIZE":[{"def":"To practice polygamy; to marry several wives.","pos":""}],"POLYGAMOUS":[{"def":"Pairing with more than one female.","pos":""},{"def":"Belonging to the Polygamia; bearing both hermaphrodite and unisexual flowers on the same plant.","pos":""}],"POLYGAMY":[{"def":"The state or habit of having more than one mate.","pos":""},{"def":"The condition or state of a plant which bears both perfect and unisexual flowers.","pos":""}],"POLYGASTRIAN":[{"def":"One of the Polygastrica.","pos":""}],"POLYGASTRIC":[{"def":"Having several bellies; -- applied to muscles which are made up of several bellies separated by short tendons.","pos":""},{"def":"Pertaining to the Polygastrica.","pos":""}],"POLYGASTRICA":[{"def":"The theory that living organisms originate in cells or embryos of different kinds, instead of coming from a single cell; -- opposed to monogenesis.","pos":""}],"POLYGENETIC":[{"def":"Having many distinct sources; originating at various places or times.","pos":""}],"POLYGENIC":[{"def":"Of or relating to polygeny; polygenetic.","pos":""}],"POLYGENISM":[{"def":"The doctrine that animals of the same species have sprung from more than one original pair.","pos":""}],"POLYGENIST":[{"def":"One who maintains that animals of the same species have sprung from more than one original pair; -- opposed to monogenist.","pos":""}],"POLYGENOUS":[{"def":"Consisting of, or containing, many kinds; as, a polygenous mountain.","pos":""}],"POLYGLOT":[{"def":"Containing, or made up, of, several languages; as, a polyglot lexicon, Bible.","pos":""},{"def":"Versed in, or speaking, many languages.","pos":""}],"POLYGLOTTOUS":[{"def":"Speaking many languages; polyglot.","pos":""}],"POLYGON":[{"def":"A plane figure having many angles, and consequently many sides; esp.","pos":""}],"POLYGONACEOUS":[{"def":"Of or pertaining to a natural order of apetalous plants (Polygonaceæ), of which the knotweeds (species of Polygonum) are the type, and which includes also the docks (Rumex), the buckwheat, rhubarb, sea grape (Coccoloba), and several other genera.","pos":""}],"POLYGONAL":[{"def":"Having many angles.","pos":""}],"POLYGONEUTIC":[{"def":"Having two or more broods in a season.","pos":""}],"POLYGONOMETRY":[{"def":"The doctrine of polygons; an extension of some of the principles of trigonometry to the case of polygons.","pos":""}],"POLYGONUM":[{"def":"A genus of plants embracing a large number of species, including bistort, knotweed, smartweed, etc.","pos":""}],"POLYGONY":[{"def":"Any plant of the genus Polygonum.","pos":""}],"POLYGORDIUS":[{"def":"A genus of marine annelids, believed to be an ancient or ancestral type.","pos":""}],"POLYGRAM":[{"def":"A figure consisting of many lines.","pos":""}],"POLYGRAPH":[{"def":"Pertaining to, or employed in, polygraphy; as, a polygraphic instrument.","pos":""}],"POLYGRAPHY":[{"def":"Much writing; writing of many books.","pos":""},{"def":"The art of writing in various ciphers, and of deciphering the same.","pos":""}],"POLYGROOVED":[{"def":"Having many grooves; as, a polygrooved rifle or gun (referring to the rifling).","pos":""}],"POLYGYN":[{"def":"A plant of the order Polygynia.","pos":""}],"POLYGYNIA":[{"def":"A Linnæan order of plants having many styles.","pos":""},{"def":"Having many styles; belonging to the order Polygynia.","pos":""}],"POLYGYNIST":[{"def":"One who practices or advocates polygyny.","pos":""}],"POLYGYNY":[{"def":"The state or practice of having several wives at the same time; marriage to several wives.","pos":""}]}