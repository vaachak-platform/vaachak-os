{"ALDEBARAN":[{"def":"A red star of the first magnitude, situated in the eye of Taurus; the Bull's Eye.","pos":""}],"ALDEHYDE":[{"def":"A colorless, mobile, and very volatile liquid obtained from alcohol by certain of oxidation.","pos":""}],"ALDEHYDIC":[{"def":"Of or pertaining to aldehyde; as, aldehydic acid.","pos":""}],"ALDER":[{"def":"A tree, usually growing in moist land, and belonging to the genus Alnus.","pos":""},{"def":"Of all; -- used in composition; as, alderbest, best of all, alderwisest, wisest of all.","pos":""}],"ALDER FLY":[{"def":"Any of numerous neuropterous insects of the genus Sialis or allied genera.","pos":""}],"ALDERMAN":[{"def":"A senior or superior; a person of rank or dignity.","pos":""},{"def":"One of a board or body of municipal officers next in order to the mayor and having a legislative function.","pos":""}],"ALDERMANCY":[{"def":"The office of an alderman.","pos":""}],"ALDERMANIC":[{"def":"Relating to, becoming to, or like, an alderman; characteristic of an alderman.","pos":""}],"ALDERMANITY":[{"def":"Aldermen collectively; the body of aldermen.","pos":""},{"def":"The state of being an alderman.","pos":""}],"ALDERMANLIKE":[{"def":"Like or suited to an alderman.","pos":""}],"ALDERMANLY":[{"def":"Pertaining to, or like, an alderman.","pos":""}],"ALDERMANRY":[{"def":"The district or ward of an alderman.","pos":""},{"def":"The office or rank of an alderman.","pos":""}],"ALDERMANSHIP":[{"def":"The condition, position, or office of an alderman.","pos":""}],"ALDERNEY":[{"def":"One of a breed of cattle raised in Alderney, one of the Channel Islands.","pos":""}],"ALDINE":[{"def":"An epithet applied to editions (chiefly of the classics) which proceeded from the press of Aldus Manitius, and his family, of Venice, for the most part in the 16th century and known by the sign of the anchor and the dolphin.","pos":""}],"ALDOL":[{"def":"A colorless liquid, C4H8O2, obtained by condensation of two molecules of acetaldehyde: CH3CHO + CH3CHO = H3CH(OH)CH2CO; also, any of various derivatives of this.","pos":""}]}