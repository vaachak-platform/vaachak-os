{"IMPACABLE":[{"def":"Not to be appeased or quieted.","pos":""}],"IMPACKMENT":[{"def":"The state of being closely surrounded, crowded, or pressed, as by ice.","pos":""}],"IMPACT":[{"def":"To drive close; to press firmly together: to wedge into a place.","pos":""}],"IMPACTED":[{"def":"Driven together or close.","pos":""}],"IMPACTION":[{"def":"The driving of one fragment of bone into another so that the fragments are not movable upon each other; as, impaction of the skull or of the hip.","pos":""}],"IMPAINT":[{"def":"To paint; to adorn with colors.","pos":""}],"IMPAIR":[{"def":"To make worse; to diminish in quantity, value, excellence, or strength; to deteriorate; as, to impair health, character, the mind, value.","pos":""}],"IMPAIRER":[{"def":"One who, or that which, impairs.","pos":""}],"IMPAIRMENT":[{"def":"The state of being impaired; injury.","pos":""}],"IMPALE":[{"def":"To join, as two coats of arms on one shield, palewise; hence, to join in honorable mention.","pos":""}],"IMPALEMENT":[{"def":"The division of a shield palewise, or by a vertical line, esp.","pos":""}],"IMPALLA":[{"def":"The pallah deer of South Africa.","pos":""}],"IMPALLID":[{"def":"To make pallid; to blanch.","pos":""}],"IMPALM":[{"def":"To grasp with or hold in the hand.","pos":""}],"IMPALPABILITY":[{"def":"The quality of being impalpable.","pos":""}],"IMPALPABLE":[{"def":"Not palpable; that cannot be felt; extremely fine, so that no grit can be perceived by touch.","pos":""},{"def":"Not material; intangible; incorporeal.","pos":""}],"IMPALPABLY":[{"def":"In an impalpable manner.","pos":""}],"IMPALSY":[{"def":"To palsy; to paralyze; to deaden.","pos":""}],"IMPANATE":[{"def":"Embodied in bread, esp.","pos":""}],"IMPANATION":[{"def":"Embodiment in bread; the supposed real presence and union of Christ's material body and blood with the substance of the elements of the eucharist without a change in their nature; -- distinguished from transubstantiation, which supposes a miraculous change of the substance of the elements.","pos":""}],"IMPANATOR":[{"def":"One who holds the doctrine of impanation.","pos":""}],"IMPANEL":[{"def":"To enter in a list, or on a piece of parchment, called a panel; to form or enroll, as a list of jurors in a court of justice.","pos":""}],"IMPANELMENT":[{"def":"The act or process of impaneling, or the state of being impaneled.","pos":""}],"IMPARADISE":[{"def":"To put in a state like paradise; to make supremely happy.","pos":""}],"IMPARIDIGITATE":[{"def":"Having an odd number of fingers or toes, either one, three, or five, as in the horse, tapir, rhinoceros, etc.","pos":""}],"IMPARIPINNATE":[{"def":"Pinnate with a single terminal leaflet.","pos":""}],"IMPARISYLLABIC":[{"def":"Not consisting of an equal number of syllables; as, an imparisyllabic noun, one which has not the same number of syllables in all the cases; as, lapis, lapidis; mens, mentis.","pos":""}],"IMPARITY":[{"def":"Inequality; disparity; disproportion; difference of degree, rank, excellence, number, etc.","pos":""},{"def":"Lack of comparison, correspondence, or suitableness; incongruity.","pos":""}],"IMPARK":[{"def":"To inclose for a park; to sever from a common; hence, to inclose or shut up.","pos":""}],"IMPARL":[{"def":"To have time before pleading; to have delay for mutual adjustment.","pos":""}],"IMPARLANCE":[{"def":"Mutual discourse; conference.","pos":""}],"IMPARSONEE":[{"def":"Presented, instituted, and inducted into a rectory, and in full possession.","pos":""},{"def":"A clergyman so inducted.","pos":""}],"IMPART":[{"def":"To bestow a share or portion of; to give, grant, or communicate; to allow another to partake in; as, to impart food to the poor; the sun imparts warmth.","pos":""},{"def":"To obtain a share of; to partake of.","pos":""}],"IMPARTATION":[{"def":"The act of imparting, or the thing imparted.","pos":""}],"IMPARTER":[{"def":"One who imparts.","pos":""}],"IMPARTIAL":[{"def":"Not partial; not favoring one more than another; treating all alike; unprejudiced; unbiased; disinterested; equitable; fair; just.","pos":""}],"IMPARTIALIST":[{"def":"One who is impartial.","pos":""}],"IMPARTIALITY":[{"def":"The quality of being impartial; freedom from bias or favoritism; disinterestedness; equitableness; fairness; as, impartiality of judgment, of treatment, etc.","pos":""}],"IMPARTIALLY":[{"def":"In an impartial manner.","pos":""}],"IMPARTIBILITY":[{"def":"The quality of being impartible; communicability.","pos":""}],"IMPARTIBLE":[{"def":"Capable of being imparted or communicated.","pos":""}],"IMPARTMENT":[{"def":"The act of imparting, or that which is imparted, communicated, or disclosed.","pos":""}],"IMPASSABLE":[{"def":"Incapable of being passed; not admitting a passage; as, an impassable road, mountain, or gulf.","pos":""}],"IMPASSE":[{"def":"An impassable road or way; a blind alley; cul-de-sac; fig.","pos":""}],"IMPASSIBILITY":[{"def":"The quality or condition of being impassible; insusceptibility of injury from external things.","pos":""}],"IMPASSIBLE":[{"def":"Incapable of suffering; inaccessible to harm or pain; not to be touched or moved to passion or sympathy; unfeeling, or not showing feeling; without sensation.","pos":""}],"IMPASSIBLENESS":[{"def":"Im*pas\"si*ble*ness, n.","pos":""}],"IMPASSION":[{"def":"To move or affect strongly with passion.","pos":""}],"IMPASSIONABLE":[{"def":"Excitable; susceptible of strong emotion.","pos":""}],"IMPASSIONATE":[{"def":"Strongly affected.","pos":""}],"IMPASSIONED":[{"def":"Actuated or characterized by passion or zeal; showing warmth of feeling; ardent; animated; excited; as, an impassioned orator or discourse.","pos":""}],"IMPASSIVE":[{"def":"Not susceptible of pain or suffering; apathetic; impassible; unmoved.","pos":""}],"IMPASSIVITY":[{"def":"The quality of being insusceptible of feeling, pain, or suffering; impassiveness.","pos":""}],"IMPASTATION":[{"def":"The act of making into paste; that which is formed into a paste or mixture; specifically, a combination of different substances by means of cements.","pos":""}],"IMPASTE":[{"def":"To lay color on canvas by uniting them skillfully together.","pos":""}],"IMPASTING":[{"def":"The laying on of colors to produce impasto.","pos":""}],"IMPASTO":[{"def":"The thickness of the layer or body of pigment applied by the painter to his canvas with especial reference to the juxtaposition of different colors and tints in forming a harmonious whole.","pos":""}],"IMPASTURE":[{"def":"To place in a pasture; to foster.","pos":""}],"IMPATIBLE":[{"def":"Not capable of being borne; impassible.","pos":""}],"IMPATIENCE":[{"def":"The quality of being impatient; want of endurance of pain, suffering, opposition, or delay; eagerness for change, or for something expected; restlessness; chafing of spirit; fretfulness; passion; as, the impatience of a child or an invalid.","pos":""}],"IMPATIENS":[{"def":"A genus of plants, several species of which have very beautiful flowers; -- so called because the elastic capsules burst when touched, and scatter the seeds with considerable force.","pos":""}],"IMPATIENT":[{"def":"Not patient; not bearing with composure; intolerant; uneasy; fretful; restless, because of pain, delay, or opposition; eager for change, or for something expected; hasty; passionate; -- often followed by at, for, of, and under.","pos":""},{"def":"Not to be borne; unendurable.","pos":""}],"IMPATIENTLY":[{"def":"In an impatient manner.","pos":""}],"IMPATRONIZATION":[{"def":"Absolute seignory or possession; the act of investing with such possession.","pos":""}],"IMPATRONIZE":[{"def":"To make lord or master; as, to impatronize one's self of a seigniory.","pos":""}],"IMPAVE":[{"def":"Impaved with rude fidelity Of art mosaic.","pos":""}],"IMPAWN":[{"def":"To put in pawn; to pledge.","pos":""}]}