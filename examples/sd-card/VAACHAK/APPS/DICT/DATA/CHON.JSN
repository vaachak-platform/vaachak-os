{"CHONDRIFICATION":[{"def":"Formation of, or conversion into, cartilage.","pos":""}],"CHONDRIFY":[{"def":"To convert, or be converted, into cartilage.","pos":""}],"CHONDRIGEN":[{"def":"The chemical basis of cartilage, converted by long boiling in water into a gelatinous body called chondrin.","pos":""}],"CHONDRIGENOUS":[{"def":"Affording chondrin.","pos":""}],"CHONDRIN":[{"def":"A colorless, amorphous, nitrogenous substance, tasteless and odorless, formed from cartilaginous tissue by long-continued action of boiling water.","pos":""}],"CHONDRITE":[{"def":"A meteoric stone characterized by the presence of chondrules.","pos":""}],"CHONDRITIC":[{"def":"Granular; pertaining to, or having the granular structure characteristic of, the class of meteorites called chondrites.","pos":""}],"CHONDRITIS":[{"def":"An inflammation of cartilage.","pos":""}],"CHONDRO-":[{"def":"A combining form meaning a grain, granular, granular cartilage, cartilaginous; as, the chondrocranium, the cartilaginous skull of the lower vertebrates and of embryos.","pos":""}],"CHONDRODITE":[{"def":"A fluosilicate of magnesia and iron, yellow to red in color, often occurring in granular form in a crystalline limestone.","pos":""}],"CHONDROGANOIDEA":[{"def":"An order of ganoid fishes, including the sturgeons; -- so called on account of their cartilaginous skeleton.","pos":""}],"CHONDROGEN":[{"def":"Same as Chondrigen.","pos":""}],"CHONDROGENESIS":[{"def":"The development of cartilage.","pos":""}],"CHONDROID":[{"def":"Resembling cartilage.","pos":""}],"CHONDROLOGY":[{"def":"The science which treats of cartilages.","pos":""}],"CHONDROMA":[{"def":"A cartilaginous tumor or growth.","pos":""}],"CHONDROMETER":[{"def":"A steelyard for weighting grain.","pos":""}],"CHONDROPTERYGIAN":[{"def":"Having a cartilaginous skeleton.","pos":""},{"def":"One of the Chondropterygii.","pos":""}],"CHONDROPTERYGII":[{"def":"A group of fishes, characterized by cartilaginous fins and skeleton.","pos":""}],"CHONDROSTEI":[{"def":"An order of fishes, including the sturgeons; -- so named because the skeleton is cartilaginous.","pos":""}],"CHONDROTOMY":[{"def":"The dissection of cartilages.","pos":""}],"CHONDRULE":[{"def":"A peculiar rounded granule of some mineral, usually enstatite or chrysolite, found imdedded more or less aboundantly in the mass of many meteoric stones, which are hence called chondrites.","pos":""}]}