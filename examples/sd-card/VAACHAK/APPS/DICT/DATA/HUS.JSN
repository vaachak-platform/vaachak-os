{"HUSBAND":[{"def":"The male head of a household; one who orders the economy of a family.","pos":""},{"def":"A cultivator; a tiller; a husbandman.","pos":""}],"HUSBANDABLE":[{"def":"Capable of being husbanded, or managed with economy.","pos":""}],"HUSBANDAGE":[{"def":"The commission or compensation allowed to a ship's husband.","pos":""}],"HUSBANDLESS":[{"def":"Destitute of a husband.","pos":""}],"HUSBANDLY":[{"def":"Frugal; thrifty.","pos":""}],"HUSBANDMAN":[{"def":"The master of a family.","pos":""},{"def":"A farmer; a cultivator or tiller of the ground.","pos":""}],"HUSBANDRY":[{"def":"Care of domestic affairs; economy; domestic management; thrift.","pos":""},{"def":"The business of a husbandman, comprehending the various branches of agriculture; farming.","pos":""}],"HUSH":[{"def":"To still; to silence; to calm; to make quiet; to repress the noise or clamor of.","pos":""},{"def":"To appease; to allay; to calm; to soothe.","pos":""}],"HUSHING":[{"def":"The process of washing ore, or of uncovering mineral veins, by a heavy discharge of water from a reservoir; flushing; -- also called booming.","pos":""}],"HUSK":[{"def":"The external covering or envelope of certain fruits or seeds; glume; hull; rind; in the United States, especially applied to the covering of the ears of maize.","pos":""},{"def":"The supporting frame of a run of millstones.","pos":""}],"HUSKED":[{"def":"Covered with a husk.","pos":""},{"def":"Stripped of husks; deprived of husks.","pos":""}],"HUSKILY":[{"def":"In a husky manner; dryly.","pos":""}],"HUSKINESS":[{"def":"The state of being husky.","pos":""},{"def":"Roughness of sound; harshness; hoarseness; as, huskiness of voice.","pos":""}],"HUSKING":[{"def":"The act or process of stripping off husks, as from Indian corn.","pos":""},{"def":"A meeting of neighbors or friends to assist in husking maize; -- called also husking bee.","pos":""}],"HUSKY":[{"def":"Abounding with husks; consisting of husks.","pos":""}],"HUSSAR":[{"def":"Originally, one of the national cavalry of Hungary and Croatia; now, one of the light cavalry of European armies.","pos":""}],"HUSSITE":[{"def":"A follower of John Huss, the Bohemian reformer, who was adjudged a heretic and burnt alive in 1415.","pos":""}],"HUSSY":[{"def":"A housewife or housekeeper.","pos":""},{"def":"A worthless woman or girl; a forward wench; a jade; -- used as a term of contempt or reproach.","pos":""}],"HUSTINGS":[{"def":"A court formerly held in several cities of England; specif.","pos":""},{"def":"Any one of the temporary courts held for the election of members of the British Parliament.","pos":""}],"HUSTLE":[{"def":"To shake together in confusion; to push, jostle, or crowd rudely; to handle roughly; as, to hustle a person out of a room.","pos":""}],"HUSWIFE":[{"def":"A case for sewing materials.","pos":""}],"HUSWIFELY":[{"def":"Like a huswife; capable; economical; prudent.","pos":""},{"def":"In a huswifely manner.","pos":""}],"HUSWIFERY":[{"def":"The business of a housewife; female domestic economy and skill.","pos":""}]}