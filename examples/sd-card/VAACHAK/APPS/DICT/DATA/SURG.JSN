{"SURGE":[{"def":"A spring; a fountain.","pos":""},{"def":"A large wave or billow; a great, rolling swell of water, produced generally by a high wind.","pos":""}],"SURGEFUL":[{"def":"Abounding in surges; surgy.","pos":""}],"SURGELESS":[{"def":"Free from surges; smooth; calm.","pos":""}],"SURGENT":[{"def":"Rising; swelling, as a flood.","pos":""}],"SURGEON":[{"def":"Any one of numerous species of chætodont fishes of the family Teuthidæ, or Acanthuridæ, which have one or two sharp lancelike spines on each side of the base of the tail.","pos":""}],"SURGEONCY":[{"def":"The office or employment of a surgeon, as in the naval or military service.","pos":""}],"SURGERY":[{"def":"The art of healing by manual operation; that branch of medical science which treats of manual operations for the healing of diseases or injuries of the body; that branch of medical science which has for its object the cure of local injuries or diseases, as wounds or fractures, tumors, etc.","pos":""},{"def":"A surgeon's operating room or laboratory.","pos":""}],"SURGICAL":[{"def":"Of or pertaining to surgeons or surgery; done by means of surgery; used in surgery; as, a surgical operation; surgical instruments.","pos":""}],"SURGICALLY":[{"def":"By means of surgery.","pos":""}],"SURGY":[{"def":"Rising in surges or billows; full of surges; resembling surges in motion or appearance; swelling.","pos":""}]}