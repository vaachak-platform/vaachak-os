{"LAICALITY":[{"def":"The state or quality of being laic; the state or condition of a layman.","pos":""}],"LAICALLY":[{"def":"As a layman; after the manner of a layman; as, to treat a matter laically.","pos":""}],"LAIDLY":[{"def":"Ugly; loathsome.","pos":""}],"LAIR":[{"def":"A place in which to lie or rest; especially, the bed or couch of a wild beast.","pos":""},{"def":"A burying place.","pos":""}],"LAIRD":[{"def":"A lord; a landholder, esp.","pos":""}],"LAIRDSHIP":[{"def":"The state of being a laird; an estate; landed property.","pos":""}],"LAISSEZ FAIRE":[{"def":"Noninterference; -- an axiom of some political economists, deprecating interference of government by attempts to foster or regulate commerce, manufactures, etc.","pos":""}],"LAITY":[{"def":"The people, as distinguished from the clergy; the body of the people not in orders.","pos":""},{"def":"The state of a layman.","pos":""}]}