{"RIP":[{"def":"A wicker fish basket.","pos":""}],"RIP CORD":[{"def":"A cord by which the gas bag of a balloon may be ripped open for a limited distance to release the gas quickly and so cause immediate descent.","pos":""}],"RIPARIAN":[{"def":"Of or pertaining to the bank of a river; as, riparian rights.","pos":""}],"RIPARIOUS":[{"def":"Growing along the banks of rivers; riparian.","pos":""}],"RIPE":[{"def":"The bank of a river.","pos":""}],"RIPELY":[{"def":"Maturely; at the fit time.","pos":""}],"RIPEN":[{"def":"To grow ripe; to become mature, as grain, fruit, flowers, and the like; as, grapes ripen in the sun.","pos":""},{"def":"To approach or come to perfection.","pos":""}],"RIPENESS":[{"def":"The state or quality of being ripe; maturity;; completeness; perfection; as, the ripeness of grain; ripeness of manhood; ripeness of judgment.","pos":""}],"RIPIDOLITE":[{"def":"A translucent mineral of a green color and micaceous structure, belonging to the chlorite group; a hydrous silicate of alumina, magnesia, and iron; -- called also clinochlore.","pos":""}],"RIPIENIST":[{"def":"A player in the ripieno portion of an orchestra.","pos":""}],"RIPIENO":[{"def":"Filling up; supplementary; supernumerary; -- a term applied to those instruments which only swell the mass or tutti of an orchestra, but are not obbligato.","pos":""},{"def":"One who brings fish from the seacoast to markets in inland towns.","pos":""}],"RIPOST":[{"def":"In fencing, a return thrust after a parry.","pos":""},{"def":"A quick and sharp refort; a repartee.","pos":""}],"RIPPER":[{"def":"An act or a bill conferring upon a chief executive, as a governor or mayor, large powers of appointment and removal of heads of departments or other subordinate officials.","pos":""}],"RIPPING PANEL":[{"def":"A long patch, on a balloon, to be ripped off, by the rip cord, at landing, in order to allow the immediate escape of gas and instant deflation of the bag.","pos":""}],"RIPPING STRIP":[{"def":"= Ripping panel.","pos":""}],"RIPPLE":[{"def":"An implement, with teeth like those of a comb, for removing the seeds and seed vessels from flax, broom corn, etc.","pos":""}],"RIPPLE-MARKED":[{"def":"HAving ripple marks.","pos":""}],"RIPPLINGLY":[{"def":"In a rippling manner.","pos":""}],"RIPPLY":[{"def":"Having ripples; as, ripply water; hence, resembling the sound of rippling water; as, ripply laughter; a ripply cove.","pos":""}],"RIPRAP":[{"def":"A foundation or sustaining wall of stones thrown together without order, as in deep water or on a soft bottom.","pos":""}],"RIPSAW":[{"def":"A handsaw with coarse teeth which have but a slight set, used for cutting wood in the direction of the fiber; -- called also ripping saw.","pos":""}],"RIPTOWEL":[{"def":"A gratuity given to tenants after they had reaped their lord's corn.","pos":""}]}