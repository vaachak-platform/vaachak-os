{"CONG":[{"def":"An abbreviation of Congius.","pos":""}],"CONGE":[{"def":"To take leave with the customary civilities; to bow or courtesy.","pos":""}],"CONGEABLE":[{"def":"Permissible; done lawfully; as, entry congeable.","pos":""}],"CONGEAL":[{"def":"To change from a fluid to a solid state by cold; to freeze.","pos":""},{"def":"To affect as if by freezing; to check the flow of, or cause to run cold; to chill.","pos":""}],"CONGEALABLE":[{"def":"Capable of being congealed.","pos":""}],"CONGEALEDNESS":[{"def":"The state of being congealed.","pos":""}],"CONGEALMENT":[{"def":"The act or the process of congealing; congeliation.","pos":""},{"def":"That which is formed by congelation; a clot.","pos":""}],"CONGEE":[{"def":"See Congé, Conge.","pos":""}],"CONGELATION":[{"def":"The act or process of passing, or causing to pass, from a fluid to a solid state, as by the abstraction of heat; the act or process of freezing.","pos":""},{"def":"The state of being congealed.","pos":""}],"CONGENER":[{"def":"A thing of the same genus, species, or kind; a thing allied in nature, character, or action.","pos":""}],"CONGENERACY":[{"def":"Similarity of origin; affinity.","pos":""},{"def":"Belonging to the same genus; allied in origin, nature, or action.","pos":""}],"CONGENEROUS":[{"def":"Allied in origin or cause; congeneric; as, congenerous diseases.","pos":""}],"CONGENIAL":[{"def":"Partaking of the same nature; allied by natural characteristics; kindred; sympathetic.","pos":""},{"def":"Naturally adapted; suited to the disposition.","pos":""}],"CONGENIALITY":[{"def":"The state or quality of being congenial; natural affinity; adaptation; suitableness.","pos":""}],"CONGENIALIZE":[{"def":"To make congenial.","pos":""}],"CONGENIALLY":[{"def":"In a congenial manner; as, congenially married or employed.","pos":""}],"CONGENITAL":[{"def":"Existing at, or dating from, birth; pertaining to one from birth; born with one; connate; constitutinal; natural; as, a congenital deformity.","pos":""}],"CONGENITALLY":[{"def":"In a congenital manner.","pos":""}],"CONGENITE":[{"def":"Congenital; connate; inborn.","pos":""}],"CONGER":[{"def":"The conger eel; -- called also congeree.","pos":""}],"CONGERIES":[{"def":"A collection of particles or bodies into one mass; a heap; an aggregation.","pos":""}],"CONGEST":[{"def":"To cause an overfullness of the blood vessels (esp.","pos":""}],"CONGESTED":[{"def":"Crowded together.","pos":""},{"def":"Containing an unnatural accumulation of blood; hyperæmic; -- said of any part of the body.","pos":""}],"CONGESTION":[{"def":"Overfullness of the capillary and other blood vessels, etc.","pos":""}],"CONGESTIVE":[{"def":"Pertaining to, indicating, or attended with, congestion in some part of the body; as, a congestive fever.","pos":""}],"CONGIARY":[{"def":"A present, as of corn, wine, or oil, made by a Roman emperor to the soldiers or the people; -- so called because measured to each in a congius.","pos":""}],"CONGIUS":[{"def":"A liquid measure containing about three quarts.","pos":""},{"def":"A gallon, or four quarts.","pos":""}],"CONGLACIATE":[{"def":"To turn to ice; to freeze.","pos":""}],"CONGLACIATION":[{"def":"The act or process of changing into ice, or the state of being converted to ice; a freezing; congelation; also, a frost.","pos":""}],"CONGLOBATE":[{"def":"Collected into, or forming, a rounded mass or ball; as, the conglobate [lymphatic] glands; conglobate flowers.","pos":""}],"CONGLOBATION":[{"def":"The act or process of forming into a ball.","pos":""}],"CONGLOBE":[{"def":"To gather into a ball; to collect into a round mass.","pos":""}],"CONGLOBULATE":[{"def":"To gather into a small round mass.","pos":""}],"CONGLOMERATE":[{"def":"Closely crowded together; densly clustered; as, conglomerate flowers.","pos":""},{"def":"Composed of stones, pebbles, or fragments of rocks, cemented together.","pos":""}],"CONGLOMERATION":[{"def":"The act or process of gathering into a mass; the state of being thus collected; collection; accumulation; that which is conglomerated; a mixed mass.","pos":""}],"CONGLUTIN":[{"def":"A variety of vegetable casein, resembling legumin, and found in almonds, rye, wheat, etc.","pos":""}],"CONGLUTINANT":[{"def":"Cementing together; uniting closely; causing to adhere; promoting healing, as of a wound or a broken bone, by adhesion of the parts.","pos":""}],"CONGLUTINATE":[{"def":"Glued together; united, as by some adhesive substance.","pos":""}],"CONGLUTINATION":[{"def":"A gluing together; a joining by means of some tenacious substance; junction; union.","pos":""}],"CONGLUTINATIVE":[{"def":"Black tea, of higher grade (finer leaf and less dusty) than the present bohea.","pos":""}],"CONGO GROUP":[{"def":"A group of artificial dyes with an affinity for vegetable fibers, so that no mordant is required.","pos":""}],"CONGO RED":[{"def":"An artificial red dye from which the Congo group received its name.","pos":""}],"CONGO SNAKE":[{"def":"An amphibian (Amphiuma means) of the order Urodela, found in the southern United States.","pos":""}],"CONGRATULANT":[{"def":"Rejoicing together; congratulatory.","pos":""}],"CONGRATULATE":[{"def":"To address with expressions of sympathetic pleasure on account of some happy event affecting the person addressed; to wish joy to.","pos":""}],"CONGRATULATION":[{"def":"The act of congratulating; an expression of sympathetic pleasure.","pos":""}],"CONGRATULATOR":[{"def":"One who offers congratulation.","pos":""}],"CONGRATULATORY":[{"def":"Expressive of sympathetic joy; as, a congratulatory letter.","pos":""}],"CONGREET":[{"def":"To salute mutually.","pos":""}],"CONGREGATE":[{"def":"Collected; compact; close.","pos":""}],"CONGREGATION":[{"def":"The whole body of the Jewish people; -- called also Congregation of the Lord.","pos":""},{"def":"the name assumed by the Protestant party under John Knox.","pos":""}],"CONGREGATIONAL":[{"def":"Of or pertaining to a congregation; conducted, or participated in, by a congregation; as, congregational singing.","pos":""},{"def":"Belonging to the system of Congregationalism, or to Congregationalist; holding to the faith and polity of Congregationalism; as, a Congregational church.","pos":""}],"CONGREGATIONALISM":[{"def":"That system of church organization which vests all ecclesiastical power in the assembled brotherhood of each local church.","pos":""},{"def":"The faith and polity of the Congregational churches, taken collectively.","pos":""}],"CONGREGATIONALIST":[{"def":"One who belongs to a Congregational church or society; one who holds to Congregationalism.","pos":""}],"CONGRESS":[{"def":"A meeting of individuals, whether friendly or hostile; an encounter.","pos":""},{"def":"A sudden encounter; a collision; a shock; -- said of things.","pos":""}],"CONGRESSION":[{"def":"A coming or bringing together, as in a public meeting, in a dispute, in the act of comparing, or in sexual intercourse.","pos":""}],"CONGRESSIONAL":[{"def":"Of or pertaining to a congress, especially, to the Congress of the United States; as, congressional debates.","pos":""}],"CONGRESSIVE":[{"def":"Encountering, or coming together.","pos":""}],"CONGRESSMAN":[{"def":"A member of the Congress of the United States, esp.","pos":""}],"CONGREVE ROCKET":[{"def":"See under Rocket.","pos":""}],"CONGRUE":[{"def":"To agree; to be suitable.","pos":""}],"CONGRUENCE":[{"def":"Suitableness of one thing to another; agreement; consistency.","pos":""}],"CONGRUENCY":[{"def":"Con\"gru*en*cy ( or ), n.","pos":""}],"CONGRUENT":[{"def":"Possessing congruity; suitable; agreeing; corresponding.","pos":""}],"CONGRUITY":[{"def":"Coincidence, as that of lines or figures laid over one another.","pos":""},{"def":"That, in an imperfectly good persons, which renders it suitable for God to bestow on him gifts of grace.","pos":""}],"CONGRUOUS":[{"def":"Suitable or concordant; accordant; fit; harmonious; correspondent; consistent.","pos":""}],"CONGRUOUSLY":[{"def":"In a congruous manner.","pos":""}]}