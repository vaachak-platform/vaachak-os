{"ORE":[{"def":"Honor; grace; favor; mercy; clemency; happy augry.","pos":""}],"OREAD":[{"def":"One of the nymphs of mountains and grottoes.","pos":""}],"OREADES":[{"def":"A group of butterflies which includes the satyrs.","pos":""}],"ORECTIC":[{"def":"Of or pertaining to the desires; hence, impelling to gratification; appetitive.","pos":""}],"OREGON GRAPE":[{"def":"An evergreen species of barberry (Berberis Aquifolium), of Oregon and California; also, its roundish, blue-black berries.","pos":""}],"OREODON":[{"def":"A genus of extinct herbivorous mammals, abundant in the Tertiary formation of the Rocky Mountains.","pos":""}],"OREODONT":[{"def":"Resembling, or allied to, the genus Oreodon.","pos":""}],"OREOGRAPHIC":[{"def":"Of or pertaining to oreography.","pos":""}],"OREOGRAPHY":[{"def":"The science of mountains; orography.","pos":""}],"OREOSELIN":[{"def":"A white crystalline substance which is obtained indirectly from the root of an umbelliferous plant (Imperatoria Oreoselinum), and yields resorcin on decomposition.","pos":""}],"OREOSOMA":[{"def":"A genus of small oceanic fishes, remarkable for the large conical tubercles which cover the under surface.","pos":""}],"OREWEED":[{"def":"Same as Oarweed.","pos":""}],"OREWOOD":[{"def":"Same as Oarweed.","pos":""},{"def":"A bright-colored domesticated variety of the id.","pos":""}]}