{"BEACH":[{"def":"Pebbles, collectively; shingle.","pos":""},{"def":"The shore of the sea, or of a lake, which is washed by the waves; especially, a sandy or pebbly shore; the strand.","pos":""}],"BEACH COMBER":[{"def":"A long, curling wave rolling in from the ocean.","pos":""}],"BEACHED":[{"def":"Bordered by a beach.","pos":""},{"def":"Driven on a beach; stranded; drawn up on a beach; as, the ship is beached.","pos":""}],"BEACHY":[{"def":"Having a beach or beaches; formed by a beach or beaches; shingly.","pos":""}],"BEACON":[{"def":"A signal fire to notify of the approach of an enemy, or to give any notice, commonly of warning.","pos":""},{"def":"A signal or conspicuous mark erected on an eminence near the shore, or moored in shoal water, as a guide to mariners.","pos":""}],"BEACONAGE":[{"def":"Money paid for the maintenance of a beacon; also, beacons, collectively.","pos":""}],"BEACONLESS":[{"def":"Having no beacon.","pos":""}],"BEAD":[{"def":"A little perforated ball, to be strung on a thread, and worn for ornament; or used in a rosary for counting prayers, as by Roman Catholics and Mohammedans, whence the phrases to tell beads, to at one's beads, to bid beads, etc.","pos":""}],"BEAD PROOF":[{"def":"Among distillers, a certain degree of strength in alcoholic liquor, as formerly ascertained by the floating or sinking of glass globules of different specific gravities thrown into it; now ascertained by more accurate meters.","pos":""},{"def":"A degree of strength in alcoholic liquor as shown by beads or small bubbles remaining on its surface, or at the side of the glass, when shaken.","pos":""}],"BEADING":[{"def":"Molding in imitation of beads.","pos":""}],"BEADLE":[{"def":"A messenger or crier of a court; a servitor; one who cites or bids persons to appear and answer; -- called also an apparitor or summoner.","pos":""},{"def":"An officer in a university, who precedes public processions of officers and students.","pos":""}],"BEADLERY":[{"def":"Office or jurisdiction of a beadle.","pos":""}],"BEADLESHIP":[{"def":"The state of being, or the personality of, a beadle.","pos":""}],"BEADROLL":[{"def":"A catalogue of persons, for the rest of whose souls a certain number of prayers are to be said or counted off on the beads of a chaplet; hence, a catalogue in general.","pos":""},{"def":"A poor man, supported in a beadhouse, and required to pray for the soul of its founder; an almsman.","pos":""}],"BEADSNAKE":[{"def":"A small poisonous snake of North America (Elaps fulvius), banded with yellow, red, and black.","pos":""}],"BEADWORK":[{"def":"Ornamental work in beads.","pos":""}],"BEADY":[{"def":"Resembling beads; small, round, and glistening.","pos":""},{"def":"Covered or ornamented with, or as with, beads.","pos":""}],"BEAGLE":[{"def":"A small hound, or hunting dog, twelve to fifteen inches high, used in hunting hares and other small game.","pos":""}],"BEAK":[{"def":"A beam, shod or armed at the end with a metal head or point, and projecting from the prow of an ancient galley, in order to pierce the vessel of an enemy; a beakhead.","pos":""}],"BEAKED":[{"def":"Furnished with a process or a mouth like a beak; rostrate.","pos":""}],"BEAKER":[{"def":"A large drinking cup, with a wide mouth, supported on a foot or standard.","pos":""},{"def":"An open-mouthed, thin glass vessel, having a projecting lip for pouring; -- used for holding solutions requiring heat.","pos":""}],"BEAKHEAD":[{"def":"An ornament used in rich Norman doorways, resembling a head with a beak.","pos":""}],"BEAKIRON":[{"def":"A bickern; a bench anvil with a long beak, adapted to reach the interior surface of sheet metal ware; the horn of an anvil.","pos":""}],"BEAL":[{"def":"A small inflammatory tumor; a pustule.","pos":""}],"BEAM":[{"def":"A heavy iron lever having an oscillating motion on a central axis, one end of which is connected with the piston rod from which it receives motion, and the other with the crank of the wheel shaft; -- called also working beam or walking beam.","pos":""}],"BEAM TREE":[{"def":"A tree (Pyrus aria) related to the apple.","pos":""}],"BEAMBIRD":[{"def":"A small European flycatcher (Muscicapa gricola), so called because it often nests on a beam in a building.","pos":""}],"BEAMED":[{"def":"Furnished with beams, as the head of a stag.","pos":""}],"BEAMILY":[{"def":"In a beaming manner.","pos":""}],"BEAMINESS":[{"def":"The state of being beamy.","pos":""}],"BEAMING":[{"def":"Emitting beams; radiant.","pos":""}],"BEAMINGLY":[{"def":"In a beaming manner; radiantly.","pos":""}],"BEAMLESS":[{"def":"Not having a beam.","pos":""},{"def":"Not emitting light.","pos":""}],"BEAMLET":[{"def":"A small beam of light.","pos":""}],"BEAMY":[{"def":"Emitting beams of light; radiant; shining.","pos":""},{"def":"Resembling a beam in size and weight; massy.","pos":""}],"BEAN":[{"def":"A name given to the seed of certain leguminous herbs, chiefly of the genera Faba, Phaseolus, and Dolichos; also, to the herbs.","pos":""}],"BEAN CAPER":[{"def":"A deciduous plant of warm climates, generally with fleshy leaves and flowers of a yellow or whitish yellow color, of the genus Zygophyllum.","pos":""}],"BEAN TREFOIL":[{"def":"A leguminous shrub of southern Europe, with trifoliate leaves (Anagyris foetida).","pos":""}],"BEAR":[{"def":"To support or sustain; to hold up.","pos":""},{"def":"To support and remove or carry; to convey.","pos":""}],"BEAR STATE":[{"def":"Arkansas; -- a nickname, from the many bears once inhabiting its forests.","pos":""}],"BEAR'S-EAR":[{"def":"A kind of primrose (Primula auricula), so called from the shape of the leaf.","pos":""}],"BEAR'S-FOOT":[{"def":"A species of hellebore (Helleborus foetidus), with digitate leaves.","pos":""}],"BEAR'S-PAW":[{"def":"A large bivalve shell of the East Indies (Hippopus maculatus), often used as an ornament.","pos":""}],"BEAR-TRAP DAM":[{"def":"A kind of movable dam, in one form consisting of two leaves resting against each other at the top when raised and folding down one over the other when lowered, for deepening shallow parts in a river.","pos":""}],"BEARABLE":[{"def":"Capable of being borne or endured; tolerable.","pos":""}],"BEARBERRY":[{"def":"A trailing plant of the heath family (Arctostaphylos uva-ursi), having leaves which are tonic and astringent, and glossy red berries of which bears are said to be fond.","pos":""}],"BEARBIND":[{"def":"The bindweed (Convolvulus arvensis).","pos":""}],"BEARD":[{"def":"Long or stiff hairs on a plant; the awn; as, the beard of grain.","pos":""},{"def":"That part of a type which is between the shoulder of the shank and the face.","pos":""}],"BEARDIE":[{"def":"The bearded loach (Nemachilus barbatus) of Europe.","pos":""}],"BEARDLESS":[{"def":"Without a beard.","pos":""},{"def":"Destitute of an awn; as, beardless wheat.","pos":""}],"BEARDLESSNESS":[{"def":"The state or quality of being destitute of beard.","pos":""}],"BEARER":[{"def":"One who holds a check, note, draft, or other order for the payment of money; as, pay to bearer.","pos":""},{"def":"A strip of reglet or other furniture to bear off the impression from a blank page; also, a type or type-high piece of metal interspersed in blank parts to support the plate when it is shaved.","pos":""}],"BEARHERD":[{"def":"A man who tends a bear.","pos":""}],"BEARHOUND":[{"def":"A hound for baiting or hunting bears.","pos":""}],"BEARING":[{"def":"Any single emblem or charge in an escutcheon or coat of arms -- commonly in the pl.","pos":""},{"def":"The widest part of a vessel below the plank-sheer.","pos":""}],"BEARING CLOTH":[{"def":"A cloth with which a child is covered when carried to be baptized.","pos":""}],"BEARING REIN":[{"def":"A short rein looped over the check hook or the hames to keep the horse's head up; -- called in the United States a checkrein.","pos":""}],"BEARING RING":[{"def":"In a balloon, the braced wooden ring attached to the suspension ropes at the bottom, functionally analogous to the keel of a ship.","pos":""}],"BEARISH":[{"def":"Partaking of the qualities of a bear; resembling a bear in temper or manners.","pos":""}],"BEARISHNESS":[{"def":"Behavior like that of a bear.","pos":""}],"BEARSKIN":[{"def":"The skin of a bear.","pos":""},{"def":"A coarse, shaggy, woolen cloth for overcoats.","pos":""}],"BEARWARD":[{"def":"A keeper of bears.","pos":""}],"BEAST":[{"def":"Any living creature; an animal; -- including man, insects, etc.","pos":""},{"def":"Any four-footed animal, that may be used for labor, food, or sport; as, a beast of burden.","pos":""}],"BEASTHOOD":[{"def":"State or nature of a beast.","pos":""}],"BEASTLINESS":[{"def":"The state or quality of being beastly.","pos":""}],"BEASTLY":[{"def":"Pertaining to, or having the form, nature, or habits of, a beast.","pos":""},{"def":"Characterizing the nature of a beast; contrary to the nature and dignity of man; brutal; filthy.","pos":""}],"BEAT":[{"def":"To give the signal for, by beat of drum; to sound by beat of drum; as, to beat an alarm, a charge, a parley, a retreat; to beat the general, the reveille, the tattoo.","pos":""}],"BEATEN":[{"def":"Made smooth by beating or treading; worn by use.","pos":""},{"def":"Vanquished; conquered; baffled.","pos":""}],"BEATER":[{"def":"One who, or that which, beats.","pos":""},{"def":"A person who beats up game for the hunters.","pos":""}],"BEATH":[{"def":"To bathe; also, to dry or heat, as unseasoned wood.","pos":""},{"def":"Having the power to impart or complete blissful enjoyment; blissful.","pos":""}],"BEATIFICATION":[{"def":"The act of beatifying, or the state of being beatified; esp.","pos":""}],"BEATIFY":[{"def":"To ascertain and declare, by a public process and decree, that a deceased person is one of \"the blessed\" and is to be reverenced as such, though not canonized.","pos":""}],"BEATING":[{"def":"Pulsative sounds.","pos":""},{"def":"The process of sailing against the wind by tacks in zigzag direction.","pos":""}],"BEATITUDE":[{"def":"Felicity of the highest kind; consummate bliss.","pos":""},{"def":"Any one of the nine declarations (called the Beatitudes), made in the Sermon on the Mount (Matt.","pos":""}],"BEAU":[{"def":"A man who takes great care to dress in the latest fashion; a dandy.","pos":""},{"def":"A man who escorts, or pays attentions to, a lady; an escort; a lover.","pos":""}],"BEAU IDEAL":[{"def":"A conception or image of consummate beauty, moral or physical, formed in the mind, free from all the deformities, defects, and blemishes seen in actual existence; an ideal or faultless standard or model.","pos":""}],"BEAU MONDE":[{"def":"The fashionable world; people of fashion and gayety.","pos":""}],"BEAUCATCHER":[{"def":"A small flat curl worn on the temple by women.","pos":""}],"BEAUFET":[{"def":"A niche, cupboard, or sideboard for plate, china, glass, etc.","pos":""}],"BEAUFORT'S SCALE":[{"def":"A scale of wind force devised by Sir F.","pos":""}],"BEAUISH":[{"def":"Like a beau; characteristic of a beau; foppish; fine.","pos":""}],"BEAUMONTAGUE":[{"def":"A cement used in making joints, filling cracks, etc.","pos":""}],"BEAUSEANT":[{"def":"The black and white standard of the Knights Templars.","pos":""}],"BEAUSHIP":[{"def":"The state of being a beau; the personality of a beau.","pos":""}],"BEAUTEOUS":[{"def":"Full of beauty; beautiful; very handsome.","pos":""},{"def":"Beau\"te*ous*ness, n.","pos":""}],"BEAUTIED":[{"def":"Beautiful; embellished.","pos":""}],"BEAUTIFIER":[{"def":"One who, or that which, beautifies or makes beautiful.","pos":""}],"BEAUTIFUL":[{"def":"Having the qualities which constitute beauty; pleasing to the sight or the mind.","pos":""}],"BEAUTIFY":[{"def":"To make or render beautiful; to add beauty to; to adorn; to deck; to grace; to embellish.","pos":""}],"BEAUTILESS":[{"def":"Destitute of beauty.","pos":""}],"BEAUTY":[{"def":"An assemblage or graces or properties pleasing to the eye, the ear, the intellect, the æsthetic faculty, or the moral sense.","pos":""},{"def":"A particular grace, feature, ornament, or excellence; anything beautiful; as, the beauties of nature.","pos":""}],"BEAVER":[{"def":"An amphibious rodent, of the genus Castor.","pos":""}],"BEAVER STATE":[{"def":"Oregon; -- a nickname.","pos":""}],"BEAVERED":[{"def":"Covered with, or wearing, a beaver or hat.","pos":""}],"BEAVERTEEN":[{"def":"A kind of fustian made of coarse twilled cotton, shorn after dyeing.","pos":""},{"def":"An alkaloid got from the bark of the bebeeru, or green heart of Guiana (Nectandra Rodioei).","pos":""}]}