{"MORSE":[{"def":"A clasp for fastening garments in front.","pos":""}],"MORSE ALPHABET":[{"def":"A telegraphic alphabet in very general use, inventing by Samuel F.","pos":""}],"MORSE CODE":[{"def":"The telegraphic code, consisting of dots, dashes, and spaces, invented by Samuel B.","pos":""}],"MORSEL":[{"def":"A little bite or bit of food.","pos":""},{"def":"A small quantity; a little piece; a fragment.","pos":""}],"MORSING HORN":[{"def":"A horn or flask for holding powder, as for priming.","pos":""}],"MORSITATION":[{"def":"The act of biting or gnawing.","pos":""}],"MORSURE":[{"def":"The act of biting.","pos":""}]}