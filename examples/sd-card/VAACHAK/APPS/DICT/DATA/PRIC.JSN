{"PRICE":[{"def":"The sum or amount of money at which a thing is valued, or the value which a seller sets on his goods in market; that for which something is bought or sold, or offered for sale; equivalent in money or other means of exchange; current value or rate paid or demanded in market or in barter; cost.","pos":""},{"def":"Value; estimation; excellence; worth.","pos":""}],"PRICED":[{"def":"Rated in price; valued; as, high-priced goods; low-priced labor.","pos":""}],"PRICEITE":[{"def":"A hydrous borate of lime, from Oregon.","pos":""}],"PRICELESS":[{"def":"Too valuable to admit of being appraised; of inestimable worth; invaluable.","pos":""},{"def":"Of no value; worthless.","pos":""}],"PRICK":[{"def":"A small roll; as, a prick of spun yarn; a prick of tobacco.","pos":""}],"PRICK-EARED":[{"def":"Having erect, pointed ears; -- said of certain dogs.","pos":""}],"PRICKER":[{"def":"A small marline spike having generally a wooden handle, -- used in sailmaking.","pos":""}],"PRICKET":[{"def":"A buck in his second year.","pos":""}],"PRICKING":[{"def":"The act of piercing or puncturing with a sharp point.","pos":""},{"def":"A sensation of being pricked.","pos":""}],"PRICKING-UP":[{"def":"The first coating of plaster in work of three coats upon laths.","pos":""}],"PRICKLE":[{"def":"A little prick; a small, sharp point; a fine, sharp process or projection, as from the skin of an animal, the bark of a plant, etc.","pos":""},{"def":"A kind of willow basket; -- a term still used in some branches of trade.","pos":""}],"PRICKLINESS":[{"def":"The quality of being prickly, or of having many prickles.","pos":""}],"PRICKLOUSE":[{"def":"A tailor; -- so called in contempt.","pos":""}],"PRICKLY":[{"def":"Full of sharp points or prickles; armed or covered with prickles; as, a prickly shrub.","pos":""}],"PRICKMADAM":[{"def":"A name given to several species of stonecrop, used as ingredients of vermifuge medicines.","pos":""}],"PRICKPUNCH":[{"def":"A pointed steel punch, to prick a mark on metal.","pos":""}],"PRICKSONG":[{"def":"Music written, or noted, with dots or points; -- so called from the points or dots with which it is noted down.","pos":""}],"PRICKWOOD":[{"def":"A shrub (Euonymus Europæus); -- so named from the use of its wood for goads, skewers, and shoe pegs.","pos":""}],"PRICKY":[{"def":"Stiff and sharp; prickly.","pos":""}]}