{"DOM":[{"def":"A title anciently given to the pope, and later to other church dignitaries and some monastic orders.","pos":""},{"def":"In Portugal and Brazil, the title given to a member of the higher classes.","pos":""}],"DOMABLE":[{"def":"Capable of being tamed; tamable.","pos":""}],"DOMAIN":[{"def":"Ownership of land; an estate or patrimony which one has in his own right; absolute proprietorship; paramount or sovereign ownership.","pos":""}],"DOMAL":[{"def":"Pertaining to a house.","pos":""}],"DOMANIAL":[{"def":"Of or relating to a domain or to domains.","pos":""}],"DOME":[{"def":"A cupola formed on a large scale.","pos":""},{"def":"A prism formed by planes parallel to a lateral axis which meet above in a horizontal edge, like the roof of a house; also, one of the planes of such a form.","pos":""}],"DOMEBOOK":[{"def":"A book said to have been compiled under the direction of King Alfred.","pos":""}],"DOMED":[{"def":"Furnished with a dome; shaped like a dome.","pos":""}],"DOMESDAY":[{"def":"A day of judgment.","pos":""}],"DOMESMAN":[{"def":"A judge; an umpire.","pos":""}],"DOMESTIC":[{"def":"Of or pertaining to one's house or home, or one's household or family; relating to home life; as, domestic concerns, life, duties, cares, happiness, worship, servants.","pos":""},{"def":"Of or pertaining to a nation considered as a family or home, or to one's own country; intestine; not foreign; as, foreign wars and domestic dissensions.","pos":""}],"DOMESTICAL":[{"def":"Our private and domestical matter.","pos":""}],"DOMESTICALLY":[{"def":"In a domestic manner; privately; with reference to domestic affairs.","pos":""}],"DOMESTICANT":[{"def":"Forming part of the same family.","pos":""}],"DOMESTICATE":[{"def":"To make domestic; to habituate to home life; as, to domesticate one's self.","pos":""},{"def":"To cause to be, as it were, of one's family or country; as, to domesticate a foreign custom or word.","pos":""}],"DOMESTICATION":[{"def":"The act of domesticating, or accustoming to home; the action of taming wild animals.","pos":""}],"DOMESTICATOR":[{"def":"One who domesticates.","pos":""}],"DOMESTICITY":[{"def":"The state of being domestic; domestic character; household life.","pos":""}],"DOMETT":[{"def":"A kind of baize of which the ward is cotton and the weft woolen.","pos":""}],"DOMEYKITE":[{"def":"A massive mineral of tin-white or steel-gray color, an arsenide of copper.","pos":""}],"DOMICAL":[{"def":"Relating to, or shaped like, a dome.","pos":""}],"DOMICILE":[{"def":"A residence at a particular place accompanied with an intention to remain there for an unlimited time; a residence accepted as a final abode.","pos":""}],"DOMICILIAR":[{"def":"A member of a household; a domestic.","pos":""}],"DOMICILIARY":[{"def":"Of or pertaining to a domicile, or the residence of a person or family.","pos":""}],"DOMICILIATE":[{"def":"To establish in a permanent residence; to domicile.","pos":""}],"DOMICILIATION":[{"def":"The act of domiciliating; permanent residence; inhabitancy.","pos":""}],"DOMICULTURE":[{"def":"The art of house-keeping, cookery, etc.","pos":""}],"DOMIFY":[{"def":"To divide, as the heavens, into twelve houses.","pos":""}],"DOMINA":[{"def":"Lady; a lady; -- a title formerly given to noble ladies who held a barony in their own right.","pos":""},{"def":"Predominance; ascendency; authority.","pos":""}],"DOMINANT":[{"def":"Ruling; governing; prevailing; controlling; predominant; as, the dominant party, church, spirit, power.","pos":""}],"DOMINATE":[{"def":"To predominate over; to rule; to govern.","pos":""}],"DOMINATION":[{"def":"A high order of angels in the celestial hierarchy; -- a meaning given by the schoolmen.","pos":""}],"DOMINATIVE":[{"def":"Governing; ruling; imperious.","pos":""}],"DOMINATOR":[{"def":"A ruler or ruling power.","pos":""}],"DOMINE":[{"def":"A West Indian fish (Epinula magistralis), of the family Trichiuridæ.","pos":""}],"DOMINEER":[{"def":"To rule with insolence or arbitrary sway; to play the master; to be overbearing; to tyrannize; to bluster; to swell with conscious superiority or haughtiness; -- often with over; as, to domineer over dependents.","pos":""}],"DOMINEERING":[{"def":"Ruling arrogantly; overbearing.","pos":""}],"DOMINICAL":[{"def":"Indicating, or pertaining to, the Lord's day, or Sunday.","pos":""},{"def":"Relating to, or given by, our Lord; as, the dominical (or Lord's) prayer.","pos":""}],"DOMINICAN":[{"def":"Of or pertaining to St.","pos":""}],"DOMINICIDE":[{"def":"The act of killing a master.","pos":""},{"def":"One who kills his master.","pos":""}],"DOMINIE":[{"def":"A schoolmaster; a pedagogue.","pos":""}],"DOMINION":[{"def":"A supposed high order of angels; dominations.","pos":""}],"DOMINION DAY":[{"def":"In Canada, a legal holiday, July lst, being the anniversary of the proclamation of the formation of the Dominion in 1867.","pos":""}],"DOMINO":[{"def":"A game played by two or more persons, with twenty-eight pieces of wood, bone, or ivory, of a flat, oblong shape, plain at the back, but on the face divided by a line in the middle, and either left blank or variously dotted after the manner of dice.","pos":""}],"DOMINO WHIST":[{"def":"A game of cards in which the suits are played in sequence, beginning with a 5 or 9, the player who gets rid of his cards first being the winner.","pos":""}],"DOMINUS":[{"def":"Master; sir; -- a title of respect formerly applied to a knight or a clergyman, and sometimes to the lord of a manor.","pos":""}],"DOMITABLE":[{"def":"That can be tamed.","pos":""}],"DOMITE":[{"def":"A grayish variety of trachyte; -- so called from the Puy-de- Dôme in Auvergne, France, where it is found.","pos":""}]}