{"HAD":[{"def":"Had better, under Better.","pos":""}],"HADDOCK":[{"def":"A marine food fish (Melanogrammus æglefinus), allied to the cod, inhabiting the northern coasts of Europe and America.","pos":""}],"HADE":[{"def":"The inclination or deviation from the vertical of any mineral vein.","pos":""}],"HADES":[{"def":"The nether world (according to classical mythology, the abode of the shades, ruled over by Hades or Pluto); the invisible world; the grave.","pos":""}],"HADJ":[{"def":"The pilgrimage to Mecca, performed by Mohammedans.","pos":""}],"HADJI":[{"def":"A Mohammedan pilgrim to Mecca; -- used among Orientals as a respectful salutation or a title of honor.","pos":""},{"def":"A Greek or Armenian who has visited the holy sepulcher at Jerusalem.","pos":""}],"HADROSAURUS":[{"def":"An American herbivorous dinosaur of great size, allied to the iguanodon.","pos":""}]}