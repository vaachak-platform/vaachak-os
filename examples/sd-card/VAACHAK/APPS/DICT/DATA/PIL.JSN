{"PILASTER":[{"def":"An upright architectural member right-angled in plan, constructionally a pier (See Pier, 1 (b)), but architecturally corresponding to a column, having capital, shaft, and base to agree with those of the columns of the same order.","pos":""}],"PILASTERED":[{"def":"Furnished with pilasters.","pos":""}],"PILCH":[{"def":"A gown or case of skin, or one trimmed or lined with fur.","pos":""}],"PILCHARD":[{"def":"A small European food fish (Clupea pilchardus) resembling the herring, but thicker and rounder.","pos":""}],"PILCHER":[{"def":"A scabbard, as of a sword.","pos":""}],"PILCROW":[{"def":"a paragraph mark, .","pos":""}],"PILE":[{"def":"A covering of hair or fur.","pos":""}],"PILE-WORN":[{"def":"Having the pile worn off; threadbare.","pos":""}],"PILED":[{"def":"Having a pile or point; pointed.","pos":""}],"PILEIFORM":[{"def":"Having the form of a pileus or cap; pileate.","pos":""}],"PILEMENT":[{"def":"An accumulation; a heap.","pos":""}],"PILENTUM":[{"def":"An easy chariot or carriage, used by Roman ladies, and in which the vessels, etc.","pos":""}],"PILEORHIZA":[{"def":"A cap of cells which covers the growing extremity of a root; a rootcap.","pos":""}],"PILEOUS":[{"def":"Consisting of, or covered with, hair; hairy; pilose.","pos":""}],"PILER":[{"def":"One who places things in a pile.","pos":""}],"PILES":[{"def":"The small, troublesome tumors or swellings about the anus and lower part of the rectum which are technically called hemorrhoids.","pos":""}],"PILEUS":[{"def":"A kind of skull cap of felt.","pos":""},{"def":"The expanded upper portion of many of the fungi.","pos":""}],"PILEWORT":[{"def":"A plant (Ranunculus Ficaria of Linnæus) whose tuberous roots have been used in poultices as a specific for the piles.","pos":""}],"PILFER":[{"def":"To steal in small quantities, or articles of small value; to practice petty theft.","pos":""}],"PILFERER":[{"def":"One who pilfers; a petty thief.","pos":""}],"PILFERING":[{"def":"Thieving in a small way.","pos":""}],"PILGARLIC":[{"def":"One who has lost his hair by disease; a sneaking fellow, or one who is hardly used.","pos":""}],"PILGRIM":[{"def":"A wayfarer; a wanderer; a traveler; a stranger.","pos":""},{"def":"One who travels far, or in strange lands, to visit some holy place or shrine as a devotee; as, a pilgrim to Loretto; Canterbury pilgrims.","pos":""}],"PILGRIMAGE":[{"def":"The journey of a pilgrim; a long journey; especially, a journey to a shrine or other sacred place.","pos":""},{"def":"A tedious and wearisome time.","pos":""}],"PILGRIMIZE":[{"def":"To wander as a pilgrim; to go on a pilgrimage.","pos":""}],"PILIDIUM":[{"def":"The free-swimming, hat-shaped larva of certain nemertean worms.","pos":""}],"PILIFERA":[{"def":"Same as Mammalia.","pos":""}],"PILIFEROUS":[{"def":"Bearing a single slender bristle, or hair.","pos":""},{"def":"Beset with hairs.","pos":""}],"PILIFORM":[{"def":"Resembling hairs or down.","pos":""}],"PILIGEROUS":[{"def":"Bearing hair; covered with hair or down; piliferous.","pos":""}],"PILING":[{"def":"The process of building up, heating, and working, fagots, or piles, to form bars, etc.","pos":""}],"PILL":[{"def":"The peel or skin.","pos":""}],"PILLAGE":[{"def":"The act of pillaging; robbery.","pos":""},{"def":"That which is taken from another or others by open force, particularly and chiefly from enemies in war; plunder; spoil; booty.","pos":""}],"PILLAGER":[{"def":"One who pillages.","pos":""}],"PILLAR":[{"def":"A portable ornamental column, formerly carried before a cardinal, as emblematic of his support to the church.","pos":""},{"def":"The center of the volta, ring, or manege ground, around which a horse turns.","pos":""}],"PILLAR-BLOCK":[{"def":"See under Pillow.","pos":""}],"PILLARED":[{"def":"Supported or ornamented by pillars; resembling a pillar, or pillars.","pos":""}],"PILLARET":[{"def":"A little pillar.","pos":""}],"PILLAU":[{"def":"An Oriental dish consisting of rice boiled with mutton, fat, or butter.","pos":""}],"PILLED":[{"def":"Stripped of hair; scant of hair; bald.","pos":""}],"PILLER":[{"def":"One who pills or plunders.","pos":""}],"PILLERY":[{"def":"Plunder; pillage.","pos":""}],"PILLION":[{"def":"A panel or cushion saddle; the under pad or cushion of saddle; esp.","pos":""}],"PILLORIZE":[{"def":"To set in, or punish with, the pillory; to pillory.","pos":""}],"PILLORY":[{"def":"A frame of adjustable boards erected on a post, and having holes through which the head and hands of an offender were thrust so as to be exposed in front of it.","pos":""}],"PILLOW":[{"def":"A piece of metal or wood, forming a support to equalize pressure; a brass; a pillow block.","pos":""},{"def":"A block under the inner end of a bowsprit.","pos":""}],"PILLOW LACE":[{"def":"Lace made by hand with bobbins on a pillow.","pos":""}],"PILLOWCASE":[{"def":"A removable case or covering for a pillow, usually of white linen or cotton cloth.","pos":""}],"PILLOWED":[{"def":"Provided with a pillow or pillows; having the head resting on, or as on, a pillow.","pos":""}],"PILLWORM":[{"def":"Any myriapod of the genus Iulus and allied genera which rolls up spirally; a galleyworm.","pos":""}],"PILLWORT":[{"def":"Any plant of the genus Pilularia; minute aquatic cryptograms, with small pill-shaped fruit; -- sometimes called peppergrass.","pos":""}],"PILOCARPINE":[{"def":"An alkaloid extracted from jaborandi (Pilocarpus pennatifolius) as a white amorphous or crystalline substance which has a peculiar effect on the vasomotor system.","pos":""}],"PILON":[{"def":"A conical loaf of sugar.","pos":""},{"def":"A gratuity given by tradesmen to customers settling their accounts.","pos":""}],"PILOSE":[{"def":"Clothed thickly with pile or soft down.","pos":""},{"def":"Covered with long, slender hairs; resembling long hairs; hairy; as, pilose pubescence.","pos":""}],"PILOSITY":[{"def":"The quality or state of being pilose; hairiness.","pos":""}],"PILOT":[{"def":"One employed to steer a vessel; a helmsman; a steersman.","pos":""}],"PILOT BALLOON":[{"def":"A small, unmanned balloon sent up to indicate the direction of air currents.","pos":""}],"PILOT FLAG":[{"def":"The flag hoisted at the fore by a vessel desiring a pilot, in the United States the union jack, in Great Britain the British union jack with a white border.","pos":""},{"def":"Pilotage; skill in the duties of a pilot.","pos":""}],"PILOT VALVE":[{"def":"A small hand-operated valve to admit liquid to operate a valve difficult to turn by hand.","pos":""}],"PILOT WHEEL":[{"def":"A wheel, usually with radial handles projecting from the rim, for traversing the saddle of a machine tool, esp.","pos":""}],"PILOTAGE":[{"def":"The pilot's skill or knowledge, as of coasts, rocks, bars, and channels.","pos":""},{"def":"The compensation made or allowed to a pilot.","pos":""}],"PILOUR":[{"def":"A piller; a plunderer.","pos":""}],"PILPUL":[{"def":"Among the Jews, penetrating investigation, disputation, and drawing of conclusions, esp.","pos":""}],"PILSER":[{"def":"An insect that flies into a flame.","pos":""}],"PILULAR":[{"def":"Of or pertaining to pills; resembling a pill or pills; as, a pilular mass.","pos":""}],"PILULOUS":[{"def":"Like a pill; small; insignificant.","pos":""}],"PILY":[{"def":"Like pile or wool.","pos":""}]}