{"PSALM":[{"def":"A sacred song; a poetical composition for use in the praise or worship of God.","pos":""},{"def":"Especially, one of the hymns by David and others, collected into one book of the Old Testament, or a modern metrical version of such a hymn for public worship.","pos":""}],"PSALMIST":[{"def":"A clerk, precentor, singer, or leader of music, in the church.","pos":""}],"PSALMISTRY":[{"def":"The use of psalms in devotion; psalmody.","pos":""},{"def":"Relating to psalmody.","pos":""}],"PSALMODIST":[{"def":"One who sings sacred songs; a psalmist.","pos":""}],"PSALMODIZE":[{"def":"To practice psalmody.","pos":""}],"PSALMODY":[{"def":"The act, practice, or art of singing psalms or sacred songs; also, psalms collectively, or a collection of psalms.","pos":""}],"PSALMOGRAPH":[{"def":"A writer of psalms; a psalmographer.","pos":""},{"def":"A writer of psalms, or sacred songs and hymns.","pos":""}],"PSALMOGRAPHY":[{"def":"The act or practice of writing psalms, or sacred songs.","pos":""}],"PSALTER":[{"def":"A rosary, consisting of a hundred and fifty beads, corresponding to the number of the psalms.","pos":""}],"PSALTERIAL":[{"def":"Of or pertaining to the psalterium.","pos":""}],"PSALTERY":[{"def":"A stringed instrument of music used by the Hebrews, the form of which is not known.","pos":""}],"PSAMMITE":[{"def":"A species of micaceous sandstone.","pos":""}],"PSAROLITE":[{"def":"A silicified stem of tree fern, found in abundance in the Triassic sandstone.","pos":""}],"PSELLISM":[{"def":"Indistinct pronunciation; stammering.","pos":""}],"PSEPHISM":[{"def":"A proposition adopted by a majority of votes; especially, one adopted by vote of the Athenian people; a statute.","pos":""}],"PSEUDAESTHESIA":[{"def":"False or imaginary feeling or sense perception such as occurs in hypochondriasis, or such as is referred to an organ that has been removed, as an amputated foot.","pos":""}],"PSEUDEMBRYO":[{"def":"Of or pertaining to pseudepigraphy.","pos":""}],"PSEUDEPIGRAPHOUS":[{"def":"Inscribed with a false name.","pos":""}],"PSEUDEPIGRAPHY":[{"def":"The ascription of false names of authors to works.","pos":""}],"PSEUDHAEMAL":[{"def":"Pertaining to the vascular system of annelids.","pos":""}],"PSEUDO-":[{"def":"A combining form or prefix signifying false, counterfeit, pretended, spurious; as, pseudo-apostle, a false apostle; pseudo- clergy, false or spurious clergy; pseudo-episcopacy, pseudo-form, pseudo-martyr, pseudo-philosopher.","pos":""}],"PSEUDO-BULB":[{"def":"An aërial corm, or thickened stem, as of some epiphytic orchidaceous plants.","pos":""}],"PSEUDO-CHINA":[{"def":"The false china root, a plant of the genus Smilax (S.","pos":""}],"PSEUDO-CONE":[{"def":"One of the soft gelatinous cones found in the compound eyes of certain insects, taking the place of the crystalline cones of others.","pos":""}],"PSEUDO-CUMENE":[{"def":"A hydrocarbon of the aromatic series, metameric with mesitylene and cumene, found in coal tar, and obtained as a colorless liquid.","pos":""}],"PSEUDO-DIPTERAL":[{"def":"Falsely or imperfectly dipteral, as a temple with the inner range of columns surrounding the cella omitted, so that the space between the cella wall and the columns is very great, being equal to two intercolumns and one column.","pos":""},{"def":"A pseudo-dipteral temple.","pos":""}],"PSEUDO-GALENA":[{"def":"False galena, or blende.","pos":""}],"PSEUDO-HEART":[{"def":"Any contractile vessel of invertebrates which is not of the nature of a real heart, especially one of those pertaining to the excretory system.","pos":""}],"PSEUDO-HYPERTHOPHIC":[{"def":"Falsely hypertrophic; as, pseudo-hypertrophic paralysis, a variety of paralysis in which the muscles are apparently enlarged, but are really degenerated and replaced by fat.","pos":""}],"PSEUDO-METALLIC":[{"def":"Falsely or imperfectly metallic; -- said of a kind of luster, as in minerals.","pos":""}],"PSEUDO-MONOCOTYLEDONOUS":[{"def":"Having two coalescent cotyledons, as the live oak and the horse-chestnut.","pos":""}],"PSEUDO-PERIPTERAL":[{"def":"Falsely or imperfectly peripteral, as a temple having the columns at the sides attached to the walls, and an ambulatory only at the ends or only at one end.","pos":""},{"def":"A pseudo-peripteral temple.","pos":""}],"PSEUDO-ROMANTIC":[{"def":"Falsely romantic.","pos":""}],"PSEUDO-SYMMETRIC":[{"def":"Exhibiting pseudo-symmetry.","pos":""}],"PSEUDO-SYMMETRY":[{"def":"A kind of symmetry characteristic of certain crystals which from twinning, or other causes, come to resemble forms of a system other than that to which they belong, as the apparently hexagonal prisms of aragonite.","pos":""}],"PSEUDOBACTERIA":[{"def":"Microscopic organic particles, molecular granules, powdered inorganic substances, etc.","pos":""}],"PSEUDOBLEPSIS":[{"def":"False or depraved sight; imaginary vision of objects.","pos":""}],"PSEUDOBRANCH":[{"def":"Same as Pseudobranchia.","pos":""}],"PSEUDOBRANCHIA":[{"def":"A rudimentary branchia, or gill.","pos":""}],"PSEUDOCARP":[{"def":"That portion of an anthocarpous fruit which is not derived from the ovary, as the soft part of a strawberry or of a fig.","pos":""}],"PSEUDOCOELE":[{"def":"Same as Pseudocoelia.","pos":""}],"PSEUDOCOELIA":[{"def":"The fifth ventricle in the mammalian brain.","pos":""}],"PSEUDODOX":[{"def":"Not true in opinion or doctrine; false.","pos":""},{"def":"A false opinion or doctrine.","pos":""}],"PSEUDOFILARIA":[{"def":"One of the two elongated vibratile young formed by fission of the embryo during the development of certain Gregarinæ.","pos":""}],"PSEUDOGRAPH":[{"def":"A false writing; a spurious document; a forgery.","pos":""}],"PSEUDOGRAPHY":[{"def":"False writing; forgery.","pos":""}],"PSEUDOHALTER":[{"def":"One of the rudimentary front wings of certain insects (Stylops).","pos":""}],"PSEUDOLOGIST":[{"def":"One who utters falsehoods; a liar.","pos":""}],"PSEUDOLOGY":[{"def":"Falsehood of speech.","pos":""}],"PSEUDOMORPH":[{"def":"A pseudomorphous crystal, as a crystal consisting of quartz, but having the cubic form of fluor spar, the fluor crystal having been changed to quartz by a process of substitution.","pos":""}],"PSEUDOMORPHISM":[{"def":"The state of having, or the property of taking, a crystalline form unlike that which belongs to the species.","pos":""}],"PSEUDOMORPHOUS":[{"def":"Not having the true form.","pos":""}],"PSEUDONAVICELLA":[{"def":"Same as Pseudonavicula.","pos":""}],"PSEUDONAVICULA":[{"def":"One of the minute spindle-shaped embryos of Gregarinæ and some other Protozoa.","pos":""}],"PSEUDONEUROPTERA":[{"def":"division of insects (Zoöl.","pos":""}],"PSEUDONEUROPTEROUS":[{"def":"Of or pertaining to the Pseudoneuroptera.","pos":""}],"PSEUDONYM":[{"def":"A fictitious name assumed for the time, as by an author; a pen name.","pos":""}],"PSEUDONYMITY":[{"def":"The using of fictitious names, as by authors.","pos":""}],"PSEUDONYMOUS":[{"def":"Bearing a false or fictitious name; as, a pseudonymous work.","pos":""}],"PSEUDOPOD":[{"def":"Any protoplasmic filament or irregular process projecting from any unicellular organism, or from any animal or plant call.","pos":""}],"PSEUDOPODIAL":[{"def":"Of or pertaining to a pseudopod, or to pseudopodia.","pos":""}],"PSEUDOPODIUM":[{"def":"Same as Pseudopod.","pos":""}],"PSEUDOPUPA":[{"def":"A stage intermediate between the larva and pupa of bees and certain other hymenopterous insects.","pos":""}],"PSEUDORHABDITE":[{"def":"One of the peculiar rodlike corpuscles found in the integument of certain Turbellaria.","pos":""}],"PSEUDOSCOPE":[{"def":"An instrument which exhibits objects with their proper relief reversed; -- an effect opposite to that produced by the stereoscope.","pos":""}],"PSEUDOSCOPIC":[{"def":"Of, pertaining to, or formed by, a pseudoscope; having its parts appearing with the relief reversed; as, a pseudoscopic image.","pos":""}],"PSEUDOSCORPIONES":[{"def":"An order of Arachnoidea having the palpi terminated by large claws, as in the scorpions, but destitute of a caudal sting; the false scorpions.","pos":""}],"PSEUDOSPHERE":[{"def":"The surface of constant negative curvature generated by the revolution of a tractrix.","pos":""}],"PSEUDOSPORE":[{"def":"A peculiar reproductive cell found in some fungi.","pos":""}],"PSEUDOSTELLA":[{"def":"Any starlike meteor or phenomenon.","pos":""}],"PSEUDOSTOMA":[{"def":"A group of cells resembling a stoma, but without any true aperture among them.","pos":""}],"PSEUDOTETRAMERA":[{"def":"A division of beetles having the fifth tarsal joint minute and obscure, so that there appear to be but four joints.","pos":""}],"PSEUDOTINEA":[{"def":"The bee moth, or wax moth (Galleria).","pos":""}],"PSEUDOTURBINAL":[{"def":"See under Turbinal.","pos":""}],"PSEUDOVARY":[{"def":"The organ in which pseudova are produced; -- called also pseudovarium.","pos":""}],"PSEUDOVUM":[{"def":"An egglike germ produced by the agamic females of some insects and other animals, and by the larvæ of certain insects.","pos":""}],"PSHAW":[{"def":"Pish! pooch! -- an exclamation used as an expression of contempt, disdain, dislike, etc.","pos":""}],"PSILANTHROPIC":[{"def":"Pertaining to, or embodying, psilanthropy.","pos":""}],"PSILANTHROPIST":[{"def":"One who believes that Christ was a mere man.","pos":""}],"PSILANTHROPY":[{"def":"The doctrine of the merely human existence of Christ.","pos":""}],"PSILOLOGY":[{"def":"Love of empty of empty talk or noise.","pos":""}],"PSILOMELANE":[{"def":"A hydrous oxide of manganese, occurring in smooth, botryoidal forms, and massive, and having an iron-black or steel-gray color.","pos":""}],"PSILOPAEDES":[{"def":"birds whose young at first have down on the pterylæ only; -- called also Gymnopædes.","pos":""}],"PSILOPAEDIC":[{"def":"Having down upon the pterylæ only; -- said of the young of certain birds.","pos":""}],"PSILOSOPHER":[{"def":"A superficial or narrow pretender to philosophy; a sham philosopher.","pos":""},{"def":"Of or pertaining to the parrots, or the Psittaci.","pos":""}],"PSITTA-CO-FULVINE":[{"def":"A yellow pigment found in the feathers of certain parrots.","pos":""}],"PSITTACI":[{"def":"The order of birds which comprises the parrots.","pos":""}],"PSOAS":[{"def":"An internal muscle arising from the lumbar vertebræ and inserted into the femur.","pos":""}],"PSORA":[{"def":"A cutaneous disease; especially, the itch.","pos":""}],"PSORIC":[{"def":"Of or pertaining to psora.","pos":""}],"PSOROSPERM":[{"def":"A minute parasite, usually the young of Gregarinæ, in the pseudonavicula stage.","pos":""}],"PSYCHAGOGIC":[{"def":"Attractive; persuasive.","pos":""}],"PSYCHAL":[{"def":"Of or pertaining to the soul; psychical.","pos":""}],"PSYCHANALYSIS":[{"def":"A method or process of psychotherapeutic analysis based on the work of Dr.","pos":""}],"PSYCHE":[{"def":"A lovely maiden, daughter of a king and mistress of Eros, or Cupid.","pos":""}],"PSYCHIAN":[{"def":"Any small moth of the genus Psyche and allied genera (family Psychidæ).","pos":""},{"def":"The application of the healing art to mental diseases.","pos":""}],"PSYCHIATRIC":[{"def":"Of or pertaining to psychiatria.","pos":""}],"PSYCHISM":[{"def":"The doctrine of Quesne, that there is a fluid universally diffused, end equally animating all living beings, the difference in their actions being due to the difference of the individual organizations.","pos":""}],"PSYCHO-":[{"def":"A combining form from Gr.","pos":""},{"def":"= Psychanalysis, Psychanalytic.","pos":""}],"PSYCHO-MOTOR":[{"def":"Of or pertaining to movement produced by action of the mind or will.","pos":""}],"PSYCHOGENESIS":[{"def":"Genesis through an internal force, as opposed to natural selection.","pos":""}],"PSYCHOGRAPHY":[{"def":"Of or pertaining to psychology.","pos":""}],"PSYCHOLOGIST":[{"def":"One who is versed in, devoted to, psychology.","pos":""}],"PSYCHOLOGY":[{"def":"The science of the human soul; specifically, the systematic or scientific knowledge of the powers and functions of the human soul, so far as they are known by consciousness; a treatise on the human soul.","pos":""}],"PSYCHOMACHY":[{"def":"A conflict of the soul with the body.","pos":""}],"PSYCHOMETRY":[{"def":"The art of measuring the duration of mental processes, or of determining the time relations of mental phenomena.","pos":""}],"PSYCHOPANNYCHISM":[{"def":"The doctrine that the soul falls asleep at death, and does not wake until the resurrection of the body.","pos":""}],"PSYCHOPHYSICAL":[{"def":"Of or pertaining to psychophysics; involving the action or mutual relations of the psychical and physical in man.","pos":""}],"PSYCHOPHYSICS":[{"def":"The science of the connection between nerve action and consciousness; the science which treats of the relations of the psychical and physical in their conjoint operation in man; the doctrine of the relation of function or dependence between body and soul.","pos":""}],"PSYCHOPOMP":[{"def":"A leader or guide of souls .","pos":""}],"PSYCHOSIS":[{"def":"A disease of the mind; especially, a functional mental disorder, that is, one unattended with evident organic changes.","pos":""}],"PSYCHOTHERAPEUTICS":[{"def":"The treatment of disease by acting on the mind, as by suggestion; mind cure; psychotherapy.","pos":""}],"PSYCHOTHERAPY":[{"def":"Psychotherapeutics.","pos":""}],"PSYCHOZOIC":[{"def":"Designating, or applied to the Era of man; as, the psychozoic era.","pos":""}],"PSYCHROMETER":[{"def":"An instrument for measuring the tension of the aqueous vapor in the atmosphere, being essentially a wet and dry bulb hygrometer.","pos":""}],"PSYCHROMETRICAL":[{"def":"Of or pertaining to the psychrometer or psychrometry.","pos":""}],"PSYLLA":[{"def":"Any leaping plant louse of the genus Psylla, or family Psyllidæ.","pos":""}]}