{"CLOACA":[{"def":"The common chamber into which the intestinal, urinary, and generative canals discharge in birds, reptiles, amphibians, and many fishes.","pos":""}],"CLOACAL":[{"def":"Of or pertaining to a cloaca.","pos":""}],"CLOAK":[{"def":"A loose outer garment, extending from the neck downwards, and commonly without sleeves.","pos":""},{"def":"That which conceals; a disguise or pretext; an excuse; a fair pretense; a mask; a cover.","pos":""}],"CLOAKEDLY":[{"def":"In a concealed manner.","pos":""}],"CLOAKING":[{"def":"The act of covering with a cloak; the act of concealing anything.","pos":""},{"def":"The material of which of which cloaks are made.","pos":""}],"CLOAKROOM":[{"def":"A room, attached to any place of public resort, where cloaks, overcoats, etc.","pos":""}],"CLOCHE":[{"def":"An apparatus used in controlling certain kinds of aëroplanes, and consisting principally of a steering column mounted with a universal joint at the base, which is bellshaped and has attached to it the cables for controlling the wing-warping devices, elevator planes, and the like.","pos":""}],"CLOCK":[{"def":"A machine for measuring time, indicating the hour and other divisions by means of hands moving on a dial plate.","pos":""}],"CLOCKLIKE":[{"def":"Like a clock or like clockwork; mechanical.","pos":""}],"CLOCKWISE":[{"def":"Like the motion of the hands of a clock; -- said of that direction of a rotation about an axis, or about a point in a plane, which is ordinarily reckoned negative.","pos":""}],"CLOCKWORK":[{"def":"The machinery of a clock, or machinary resembling that of a clock; machinery which produced regularity of movement.","pos":""}],"CLOD":[{"def":"A lump or mass, especially of earth, turf, or clay.","pos":""},{"def":"The ground; the earth; a spot of earth or turf.","pos":""}],"CLODDISH":[{"def":"Resembling clods; gross; low; stupid; boorish.","pos":""}],"CLODDY":[{"def":"Consisting of clods; full of clods.","pos":""}],"CLODHOPPER":[{"def":"A rude, rustic fellow.","pos":""}],"CLODPATE":[{"def":"A blockhead; a dolt.","pos":""}],"CLODPATED":[{"def":"Stupid; dull; doltish.","pos":""}],"CLODPOLL":[{"def":"A stupid fellow; a dolt.","pos":""}],"CLOFF":[{"def":"Formerly an allowance of two pounds in every three hundred weight after the tare and tret are subtracted; now used only in a general sense, of small deductions from the original weight.","pos":""}],"CLOG":[{"def":"That which hinders or impedes motion; hence, an encumbrance, restraint, or impediment, of any kind.","pos":""},{"def":"A weight, as a log or block of wood, attached to a man or an animal to hinder motion.","pos":""}],"CLOGGINESS":[{"def":"The state of being clogged.","pos":""}],"CLOGGING":[{"def":"Anything which clogs.","pos":""}],"CLOGGY":[{"def":"Clogging, or having power to clog.","pos":""}],"CLOISONNE":[{"def":"Inlaid between partitions: -- said of enamel when the lines which divide the different patches of fields are composed of a kind of metal wire secured to the ground; as distinguished from champlevé enamel, in which the ground is engraved or scooped out to receive the enamel.","pos":""}],"CLOISTER":[{"def":"An inclosed place.","pos":""},{"def":"A covered passage or ambulatory on one side of a court; (pl.","pos":""}],"CLOISTERED":[{"def":"Dwelling in cloisters; solitary.","pos":""},{"def":"Furnished with cloisters.","pos":""}],"CLOISTERER":[{"def":"One belonging to, or living in, a cloister; a recluse.","pos":""}],"CLOISTRAL":[{"def":"Of, pertaining to, or confined in, a cloister; recluse.","pos":""}],"CLOKE":[{"def":"CLOMB; CLOMBEN Clomb, Clomb\"en, Defn: imp.","pos":""}],"CLONIC":[{"def":"Having an irregular, convulsive motion.","pos":""}],"CLONUS":[{"def":"A series of muscular contractions due to sudden stretching of the muscle, -- a sign of certain neuropathies.","pos":""}],"CLOOM":[{"def":"To close with glutinous matter.","pos":""}],"CLOOP":[{"def":"The sound made when a cork is forcibly drawn from a bottle.","pos":""}],"CLOOT":[{"def":"One of the divisions of a cleft hoof, as in the ox; also, the whole hoof.","pos":""},{"def":"The Devil; Clootie; -- usually in the pl.","pos":""}],"CLOOTIE":[{"def":"Defn: A little hoof.","pos":""}],"CLOSE":[{"def":"To stop, or fill up, as an opening; to shut; as, to close the eyes; to close a door.","pos":""},{"def":"To bring together the parts of; to consolidate; as, to close the ranks of an army; -- often used with up.","pos":""}],"CLOSE-BARRED":[{"def":"Firmly barred or closed.","pos":""}],"CLOSE-BODIED":[{"def":"Fitting the body exactly; setting close, as a garment.","pos":""}],"CLOSE-FIGHTS":[{"def":"Barriers with loopholes, formerly erected on the deck of a vessel to shelter the men in a close engagement with an enemy's boarders; -- called also close quarters.","pos":""}],"CLOSE-STOOL":[{"def":"A utensil to hold a chamber vessel, for the use of the sick and infirm.","pos":""}],"CLOSE-TONGUED":[{"def":"Closemouthed; silent.","pos":""}],"CLOSEFISTED":[{"def":"Covetous; niggardly.","pos":""}],"CLOSEHANDED":[{"def":"Covetous; penurious; stingy; closefisted.","pos":""}],"CLOSEHAULED":[{"def":"Under way and moving as nearly as possible toward the direction from which the wind blows; -- said of a sailing vessel.","pos":""}],"CLOSELY":[{"def":"In a close manner.","pos":""},{"def":"Secretly; privately.","pos":""}],"CLOSEMOUTHED":[{"def":"Cautious in speaking; secret; wary; uncommunicative.","pos":""}],"CLOSENESS":[{"def":"The state of being close.","pos":""}],"CLOSER":[{"def":"The last stone in a horizontal course, if of a less size than the others, or a piece of brick finishing a course.","pos":""}],"CLOSEREEFED":[{"def":"Having all the reefs taken in; -- said of a sail.","pos":""}],"CLOSET":[{"def":"A small room or apartment for retirement; a room for privacy.","pos":""},{"def":"A small apartment, or recess in the side of a room, for household utensils, clothing, etc.","pos":""}],"CLOSH":[{"def":"A disease in the feet of cattle; laminitis.","pos":""}],"CLOSURE":[{"def":"A method of putting an end to debate and securing an immediate vote upon a measure before a legislative body.","pos":""}],"CLOT":[{"def":"A concretion or coagulation; esp.","pos":""}],"CLOTBUR":[{"def":"Same as Cocklebur.","pos":""}],"CLOTE":[{"def":"The common burdock; the clotbur.","pos":""}],"CLOTH":[{"def":"A fabric made of fibrous material (or sometimes of wire, as in wire cloth); commonly, a woven fabric of cotton, woolen, or linen, adapted to be made into garments; specifically, woolen fabrics, as distinguished from all others.","pos":""},{"def":"The dress; raiment.","pos":""}],"CLOTHE":[{"def":"To put garments on; to cover with clothing; to dress.","pos":""},{"def":"To provide with clothes; as, to feed and clothe a family; to clothe one's self extravagantly.","pos":""}],"CLOTHES":[{"def":"Covering for the human body; dress; vestments; vesture; -- a general term for whatever covering is worn, or is made to be worn, for decency or comfort.","pos":""},{"def":"The covering of a bed; bedclothes.","pos":""}],"CLOTHESHORSE":[{"def":"A frame to hang clothes on.","pos":""}],"CLOTHESLINE":[{"def":"A rope or wire on which clothes are hung to dry.","pos":""}],"CLOTHESPIN":[{"def":"A forked piece of wood, or a small spring clamp, used for fastening clothes on a line.","pos":""}],"CLOTHESPRESS":[{"def":"A receptacle for clothes.","pos":""}],"CLOTHIER":[{"def":"One who makes cloths; one who dresses or fulls cloth.","pos":""},{"def":"One who sells cloth or clothes, or who makes and sells clothes.","pos":""}],"CLOTHING":[{"def":"See Card clothing, under 3d Card.","pos":""}],"CLOTTED":[{"def":"Composed of clots or clods; having the quality or form of a clot; sticky; slimy; foul.","pos":""}],"CLOTTER":[{"def":"To concrete into lumps; to clot.","pos":""}],"CLOTTY":[{"def":"Full of clots, or clods.","pos":""}],"CLOUD":[{"def":"A collection of visible vapor, or watery particles, susponded in the upper atmosphere.","pos":""},{"def":"A mass or volume of smoke, or flying dust, resembling vapor.","pos":""}],"CLOUD-BUILT":[{"def":"Built of, or in, the clouds; airy; unsubstantial; imaginary.","pos":""}],"CLOUD-BURST":[{"def":"A sudden copious rainfall, as the whole cloud had been precipitated at once.","pos":""}],"CLOUD-CAPPED":[{"def":"Having clouds resting on the top or head; reaching to the clouds; as, cloud-capped mountains.","pos":""}],"CLOUD-COMPELLER":[{"def":"Cloud-gatherer; -- an epithet applied to Zeus.","pos":""}],"CLOUDAGE":[{"def":"Mass of clouds; cloudiness.","pos":""}],"CLOUDBERRY":[{"def":"A species of raspberry (Rubus Chamæmerous) growing in the northern regions, and bearing edible, amber-colored fruit.","pos":""}],"CLOUDILY":[{"def":"In a cloudy manner; darkly; obscurely.","pos":""}],"CLOUDINESS":[{"def":"The state of being cloudy.","pos":""}],"CLOUDING":[{"def":"A mottled appearance given to ribbons and silks in the process of dyeing.","pos":""},{"def":"A diversity of colors in yarn, recurring at regular intervals.","pos":""}],"CLOUDLESS":[{"def":"Without a cloud; clear; bright.","pos":""}],"CLOUDLET":[{"def":"Eve's first star through fleecy cloudlet peeping.","pos":""}],"CLOUDY":[{"def":"Overcast or obscured with clouds; clouded; as, a cloudy sky.","pos":""},{"def":"Consisting of a cloud or clouds.","pos":""}],"CLOUGH":[{"def":"A cleft in a hill; a ravine; a narrow valley.","pos":""},{"def":"A sluice used in returning water to a channel after depositing its sediment on the flooded land.","pos":""}],"CLOUT":[{"def":"A cloth; a piece of cloth or leather; a patch; a rag.","pos":""},{"def":"A swadding cloth.","pos":""}],"CLOUTERLY":[{"def":"Clumsy; awkward.","pos":""}],"CLOVE":[{"def":"A cleft; a gap; a ravine; -- rarely used except as part of a proper name; as, Kaaterskill Clove; Stone Clove.","pos":""}],"CLOVEN":[{"def":"Having the foot or hoof divided into two parts, as the ox.","pos":""}],"CLOVER":[{"def":"A plant of differend species of the genus Trifolium; as the common red clover, T.","pos":""}],"CLOVERED":[{"def":"Covered with growing clover.","pos":""}],"CLOWN":[{"def":"A man of coarse nature and manners; an awkward fellow; an illbred person; a boor.","pos":""},{"def":"One who works upon the soil; a rustic; a churl.","pos":""}],"CLOWNAGE":[{"def":"Behavior or manners of a clown; clownery.","pos":""}],"CLOWNISH":[{"def":"Of or resembling a clown, or characteristic of a clown; ungainly; awkward.","pos":""}],"CLOWNISHNESS":[{"def":"The manners of a clown; coarseness or rudeness of behavior.","pos":""}],"CLOY":[{"def":"To fill or choke up; to stop up; to clog.","pos":""},{"def":"To glut, or satisfy, as the appetite; to satiate; to fill to loathing; to surfeit.","pos":""}],"CLOYLESS":[{"def":"That does not cloy.","pos":""}]}