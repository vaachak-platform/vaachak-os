{"CHLAMYDATE":[{"def":"Having a mantle; -- applied to certain gastropods.","pos":""}],"CHLAMYPHORE":[{"def":"A small South American edentate (Chlamyphorus truncatus, and C.","pos":""}],"CHLAMYS":[{"def":"A loose and flowing outer garment, worn by the ancient Greeks; a kind of cloak.","pos":""}],"CHLOASMA":[{"def":"A cutaneous affection characterized by yellow or yellowish brown pigmented spots.","pos":""}],"CHLORAL":[{"def":"A colorless oily liquid, CCl3.","pos":""},{"def":"Chloral hydrate.","pos":""}],"CHLORALAMIDE":[{"def":"A compound of chloral and formic amide used to produce sleep.","pos":""}],"CHLORALISM":[{"def":"A morbid condition of the system resulting from excessive use of chloral.","pos":""}],"CHLORALUM":[{"def":"An impure aqueous solution of chloride of aluminium, used as an antiseptic and disinfectant.","pos":""}],"CHLORANIL":[{"def":"A yellow crystalline substance, C6Cl4.","pos":""}],"CHLORATE":[{"def":"A salt of chloric acid; as, chlorate of potassium.","pos":""}],"CHLORAURATE":[{"def":"See Aurochloride.","pos":""}],"CHLORHYDRIC":[{"def":"Same as Hydrochloric.","pos":""}],"CHLORHYDRIN":[{"def":"One of a class of compounds formed from certain polybasic alcohols (and especially glycerin) by the substitution of chlorine for one or more hydroxyl groups.","pos":""}],"CHLORIC":[{"def":"Pertaining to, or obtained from, chlorine; -- said of those compounds of chlorine in which this element has a valence of five, or the next to its highest; as, chloric acid, HClO3.","pos":""}],"CHLORIDATE":[{"def":"To treat or prepare with a chloride, as a plate with chloride of silver, for the purposes of photography.","pos":"verb"}],"CHLORIDE":[{"def":"A binary compound of chlorine with another element or radical; as, chloride of sodium (common salt).","pos":""}],"CHLORIDIC":[{"def":"Of or pertaining to a chloride; containing a chloride.","pos":""}],"CHLORIMETRY":[{"def":"See Chlorometry.","pos":""}],"CHLORINATE":[{"def":"To treat, or cause to combine, with chlorine.","pos":""}],"CHLORINATION":[{"def":"The act or process of subjecting anything to the action of chlorine; especially, a process for the extraction of gold by exposure of the auriferous material to chlorine gas.","pos":""}],"CHLORINE":[{"def":"One of the elementary substances, commonly isolated as a greenish yellow gas, two and one half times as heavy as air, of an intensely disagreeable suffocating odor, and exceedingly poisonous.","pos":""}],"CHLORIODIC":[{"def":"Compounded of chlorine and iodine; containing chlorine and iodine.","pos":""}],"CHLORIODINE":[{"def":"A compound of chlorine and iodine.","pos":""}],"CHLORITE":[{"def":"The name of a group of minerals, usually of a green color and micaceous to granular in structure.","pos":""}],"CHLORITIC":[{"def":"Pertaining to, or containing, chlorite; as, chloritic sand.","pos":""}],"CHLORMETHANE":[{"def":"A colorless gas, CH3Cl, of a sweet odor, easily condensed to a liquid; -- called also methyl chloride.","pos":""}],"CHLORO-":[{"def":"A prefix denoting that chlorine is an ingredient in the substance named.","pos":""}],"CHLOROCRUORIN":[{"def":"A green substance, supposed to be the cause of the green color of the blood in some species of worms.","pos":""}],"CHLORODYNE":[{"def":"A patent anodyne medicine, containing opium, chloroform, Indian hemp, etc.","pos":""}],"CHLOROFORM":[{"def":"A colorless volatile liquid, CHCl3, having an ethereal odor and a sweetish taste, formed by treating alcohol with chlorine and an alkali.","pos":""}],"CHLOROLEUCITE":[{"def":"Same as Chloroplastid.","pos":""}],"CHLOROMETER":[{"def":"An instrument to test the decoloring or bleaching power of chloride of lime.","pos":""}],"CHLOROMETRY":[{"def":"The process of testing the bleaching power of any combination of chlorine.","pos":""}],"CHLOROPAL":[{"def":"A massive mineral, greenish in color, and opal-like in appearance.","pos":""}],"CHLOROPEPTIC":[{"def":"Of or pertaining to an acid more generally called pepsin- hydrochloric acid.","pos":""}],"CHLOROPHANE":[{"def":"A variety of fluor spar, which, when heated, gives a beautiful emerald green light.","pos":""},{"def":"The yellowish green pigment in the inner segment of the cones of the retina.","pos":""}],"CHLOROPHYLL":[{"def":"Literally, leaf green; a green granular matter formed in the cells of the leaves (and other parts exposed to light) of plants, to which they owe their green color, and through which all ordinary assimilation of plant food takes place.","pos":""}],"CHLOROPLAST":[{"def":"A plastid containing chlorophyll, developed only in cells exposed to the light.","pos":""}],"CHLOROPLASTID":[{"def":"A granule of chlorophyll; -- also called chloroleucite.","pos":""}],"CHLOROPLATINIC":[{"def":"See Platinichloric.","pos":""}],"CHLOROSIS":[{"def":"The green sickness; an anæmic disease of young women, characterized by a greenish or grayish yellow hue of the skin, weakness, palpitation, etc.","pos":""},{"def":"A disease in plants, causing the flowers to turn green or the leaves to lose their normal green color.","pos":""}],"CHLOROTIC":[{"def":"Pertaining to, or affected by, chlorosis.","pos":""}],"CHLOROUS":[{"def":"Pertaining to, or resembling, the electro-negative character of chlorine; hence, electro-negative; -- opposed to basylous or zincous.","pos":""}],"CHLORPICRIN":[{"def":"A heavy, colorless liquid, CCl3.","pos":""}]}