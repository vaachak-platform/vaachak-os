{"OPPIDAN":[{"def":"Of or pertaining to a town.","pos":""}],"OPPIGNERATE":[{"def":"To pledge; to pawn.","pos":""}],"OPPILATE":[{"def":"To crowd together; to fill with obstructions; to block up.","pos":""}],"OPPILATION":[{"def":"The act of filling or crowding together; a stopping by redundant matter; obstruction, particularly in the lower intestines.","pos":""}],"OPPILATIVE":[{"def":"Filled; crowded.","pos":""}],"OPPLETION":[{"def":"The act of filling up, or the state of being filled up; fullness.","pos":""}],"OPPONENCY":[{"def":"The act of opening an academical disputation; the proposition of objections to a tenet, as an exercise for a degree.","pos":""}],"OPPONENT":[{"def":"Situated in front; opposite; hence, opposing; adverse; antagonistic.","pos":""}],"OPPORTUNE":[{"def":"Convenient; ready; hence, seasonable; timely.","pos":""}],"OPPORTUNISM":[{"def":"The art or practice of taking advantage of opportunities or circumstances, or of seeking immediate advantage with little regard for ultimate consequences.","pos":""}],"OPPORTUNIST":[{"def":"One who advocates or practices opportunism.","pos":""}],"OPPORTUNITY":[{"def":"Fit or convenient time; a time or place favorable for executing a purpose; a suitable combination of conditions; suitable occasion; chance.","pos":""},{"def":"Convenience of situation; fitness.","pos":""}],"OPPOSABILITY":[{"def":"The condition or quality of being opposable.","pos":""}],"OPPOSABLE":[{"def":"Capable of being opposed or resisted.","pos":""},{"def":"Capable of being placed opposite something else; as, the thumb is opposable to the forefinger.","pos":""}],"OPPOSE":[{"def":"To place in front of, or over against; to set opposite; to exhibit.","pos":""},{"def":"To put in opposition, with a view to counterbalance or countervail; to set against; to offer antagonistically.","pos":""}],"OPPOSELESS":[{"def":"Not to be effectually opposed; irresistible.","pos":""}],"OPPOSER":[{"def":"One who opposes; an opponent; an antagonist; an adversary.","pos":""}],"OPPOSITE":[{"def":"Placed over against; standing or situated over against or in front; facing; -- often with to; as, a house opposite to the Exchange.","pos":""},{"def":"Applied to the other of two things which are entirely different; other; as, the opposite sex; the opposite extreme.","pos":""}],"OPPOSITELY":[{"def":"In a situation to face each other; in an opposite manner or direction; adversely.","pos":""}],"OPPOSITENESS":[{"def":"The quality or state of being opposite.","pos":""}],"OPPOSITIFOLIOUS":[{"def":"Placed at the same node with a leaf, but separated from it by the whole diameter of the stem; as, an oppositifolious peduncle.","pos":""}],"OPPOSITION":[{"def":"The situation of a heavenly body with respect to another when in the part of the heavens directly opposite to it; especially, the position of a planet or satellite when its longitude differs from that of the sun 180º; -- signified by the symbol as, .","pos":""},{"def":"The relation between two propositions when, having the same subject and predicate, they differ in quantity, or in quality, or in both; or between two propositions which have the same matter but a different form.","pos":""}],"OPPOSITIONIST":[{"def":"One who belongs to the opposition party.","pos":""}],"OPPOSITIPETALOUS":[{"def":"Placed in front of a petal.","pos":""}],"OPPOSITISEPALOUS":[{"def":"Placed in front of a sepal.","pos":""}],"OPPOSITIVE":[{"def":"Capable of being put in opposition.","pos":""}],"OPPRESS":[{"def":"To impose excessive burdens upon; to overload; hence, to treat with unjust rigor or with cruelty.","pos":""},{"def":"To ravish; to violate.","pos":""}],"OPPRESSION":[{"def":"The act of oppressing, or state of being oppressed.","pos":""},{"def":"That which oppresses; a hardship or injustice; cruelty; severity; tyranny.","pos":""}],"OPPRESSIVE":[{"def":"Unreasonably burdensome; unjustly severe, rigorous, or harsh; as, oppressive taxes; oppressive exactions of service; an oppressive game law.","pos":""},{"def":"Using oppression; tyrannical; as, oppressive authority or commands.","pos":""}],"OPPRESSOR":[{"def":"One who oppresses; one who imposes unjust burdens on others; one who harasses others with unjust laws or unreasonable severity.","pos":""}],"OPPROBRIOUS":[{"def":"Expressive of opprobrium; attaching disgrace; reproachful; scurrilous; as, opprobrious language.","pos":""},{"def":"Infamous; despised; rendered hateful; as, an opprobrious name.","pos":""}],"OPPROBRIUM":[{"def":"Disgrace; infamy; reproach mingled with contempt; abusive language.","pos":""}],"OPPUGN":[{"def":"To fight against; to attack; to be in conflict with; to oppose; to resist.","pos":""}],"OPPUGNANCY":[{"def":"The act of oppugning; opposition; resistance.","pos":""}],"OPPUGNANT":[{"def":"Tending to awaken hostility; hostile; opposing; warring.","pos":""}],"OPPUGNER":[{"def":"One who opposes or attacks; that which opposes.","pos":""}]}