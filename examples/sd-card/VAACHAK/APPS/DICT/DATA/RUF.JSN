{"RUFESCENT":[{"def":"Reddish; tinged with red.","pos":""}],"RUFF":[{"def":"Playing) (a) A game similar to whist, and the predecessor of it.","pos":""}],"RUFFED":[{"def":"Furnished with a ruff.","pos":""}],"RUFFIAN":[{"def":"A pimp; a pander; also, a paramour.","pos":""},{"def":"A boisterous, cruel, brutal fellow; a desperate fellow ready for murderous or cruel deeds; a cutthroat.","pos":""}],"RUFFIANAGE":[{"def":"Ruffians, collectively; a body of ruffians.","pos":""}],"RUFFIANISH":[{"def":"Having the qualities or manners of a ruffian; ruffianly.","pos":""}],"RUFFIANLY":[{"def":"Like a ruffian; bold in crimes; characteristic of a ruffian; violent; brutal.","pos":""}],"RUFFIN":[{"def":"His ruffin rainment all was stained with blood.","pos":""}],"RUFFLE":[{"def":"To beat with the ruff or ruffle, as a drum.","pos":""}],"RUFFLELESS":[{"def":"Having no ruffle.","pos":""}],"RUFFLEMENT":[{"def":"The act of ruffling.","pos":""}],"RUFFLER":[{"def":"One who ruffles; a swaggerer; a bully; a ruffian.","pos":""},{"def":"That which ruffles; specifically, a sewing machine attachment for making ruffles.","pos":""}],"RUFIGALLIC":[{"def":"Pertaining to, or designating, an acid which is obtained from gallic acid as a brown or red crystalline substance, and is related to rufiopin and anthracene.","pos":""}],"RUFIOPIN":[{"def":"A yellowish red crystalline substance related to anthracene, and obtained from opianic acid.","pos":""}],"RUFOL":[{"def":"A phenol derivative of anthracene obtained as a white crystalline substance, which on oxidation produces a red dyestuff related to anthraquinone.","pos":""}],"RUFOUS":[{"def":"Reddish; of a yellowish red or brownish red color; tawny.","pos":""}],"RUFT":[{"def":"Eructation; belching.","pos":""}],"RUFTERHOOD":[{"def":"A kind of hood for a hawk.","pos":""}]}