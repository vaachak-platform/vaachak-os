{"MONOLATRY":[{"def":"Worship of a single deity.","pos":""}],"MONOLITH":[{"def":"A single stone, especially one of large size, shaped into a pillar, statue, or monument.","pos":""}],"MONOLITHIC":[{"def":"Of or pertaining to a monolith; consisting of a single stone.","pos":""}],"MONOLOGIST":[{"def":"One who soliloquizes; esp.","pos":""}],"MONOLOGUE":[{"def":"A speech uttered by a person alone; soliloquy; also, talk or discourse in company, in the strain of a soliloquy; as, an account in monologue.","pos":""},{"def":"A dramatic composition for a single performer.","pos":""}],"MONOLOGY":[{"def":"The habit of soliloquizing, or of monopolizing conversation.","pos":""},{"def":"A duel; single combat.","pos":""}]}