{"LET":[{"def":"To retard; to hinder; to impede; to oppose.","pos":""}],"LET-OFF":[{"def":"A device for letting off, releasing, or giving forth, as the warp from the cylinder of a loom.","pos":""}],"LET-UP":[{"def":"Abatement; also, cessation; as, it blew a gale for three days without any let-up.","pos":""}],"LETCH":[{"def":"Strong desire; passion.","pos":""}],"LETE":[{"def":"To let; to leave.","pos":""}],"LETHAL":[{"def":"One of the higher alcohols of the paraffine series obtained from spermaceti as a white crystalline solid.","pos":""}],"LETHALITY":[{"def":"The quality of being lethal; mortality.","pos":""},{"def":"Pertaining to, affected with, or resembling, lethargy; morbidly drowsy; dull; heavy.","pos":""}],"LETHARGIZE":[{"def":"To make lethargic.","pos":""}],"LETHARGY":[{"def":"Morbid drowsiness; continued or profound sleep, from which a person can scarcely be awaked.","pos":""},{"def":"A state of inaction or indifference.","pos":""}],"LETHE":[{"def":"A river of Hades whose waters when drunk caused forgetfulness of the past.","pos":""}],"LETHEAN":[{"def":"Of or pertaining to Lethe; resembling in effect the water of Lethe.","pos":""}],"LETHEED":[{"def":"Caused by Lethe.","pos":""}],"LETHEON":[{"def":"Sulphuric ether used as an anæsthetic agent.","pos":""}],"LETHEONIZE":[{"def":"To subject to the influence of letheon.","pos":""}],"LETHIFEROUS":[{"def":"Deadly; bringing death or destruction.","pos":""}],"LETTE":[{"def":"To let; to hinder.","pos":""}],"LETTER":[{"def":"One who lets or permits; one who lets anything for hire.","pos":""}],"LETTERED":[{"def":"Literate; educated; versed in literature.","pos":""},{"def":"Of or pertaining to learning or literature; learned.","pos":""}],"LETTERER":[{"def":"One who makes, inscribes, or engraves, alphabetical letters.","pos":""}],"LETTERGRAM":[{"def":"See Letter, above.","pos":""}],"LETTERING":[{"def":"The act or business of making, or marking with, letters, as by cutting or painting.","pos":""},{"def":"The letters made; as, the lettering of a sign.","pos":""}],"LETTERLESS":[{"def":"Not having a letter.","pos":""}],"LETTERPRESS":[{"def":"Print; letters and words impressed on paper or other material by types; -- often used of the reading matter in distinction from the illustrations.","pos":""}],"LETTERURE":[{"def":"Letters; literature.","pos":""}],"LETTERWOOD":[{"def":"The beautiful and highly elastic wood of a tree of the genus Brosimum (B.","pos":""}],"LETTISH":[{"def":"Of or pertaining to the Letts.","pos":""},{"def":"The language spoken by the Letts.","pos":""}],"LETTS":[{"def":"An Indo-European people, allied to the Lithuanians and Old Prussians, and inhabiting a part of the Baltic provinces of Russia.","pos":""}],"LETTUCE":[{"def":"A composite plant of the genus Lactuca (L.","pos":""}]}