{"LYCANTHROPE":[{"def":"A human being fabled to have been changed into a wolf; a werewolf.","pos":""},{"def":"One affected with lycanthropy.","pos":""}],"LYCANTHROPIA":[{"def":"See Lycanthropy, 2.","pos":""}],"LYCANTHROPIC":[{"def":"Pertaining to lycanthropy.","pos":""}],"LYCANTHROPIST":[{"def":"One affected by the disease lycanthropy.","pos":""}],"LYCANTHROPY":[{"def":"A kind of erratic melancholy, in which the patient imagines himself a wolf, and imitates the actions of that animal.","pos":""}],"LYCEE":[{"def":"A French lyceum, or secondary school supported by the French government, for preparing students for the university.","pos":""}],"LYCEUM":[{"def":"A place of exercise with covered walks, in the suburbs of Athens, where Aristotle taught philosophy.","pos":""},{"def":"A house or apartment appropriated to instruction by lectures or disquisitions.","pos":""}],"LYCH GATE":[{"def":"Lych\" gate` Defn: .","pos":""}],"LYCHNIS":[{"def":"A genus of Old World plants belonging to the Pink family (Caryophyllaceæ).","pos":""}],"LYCHNOBITE":[{"def":"One who labors at night and sleeps in the day.","pos":""}],"LYCHNOSCOPE":[{"def":"Same as Low side window, under Low, a.","pos":""}],"LYCINE":[{"def":"A weak base identical with betaine; -- so called because found in the boxthorn (Lycium barbarum).","pos":""}],"LYCOPERDON":[{"def":"A genus of fungi, remarkable for the great quantity of spores, forming a fine dust, which is thrown out like smoke when the plant is compressed or burst; puffball.","pos":""}],"LYCOPOD":[{"def":"A plant of the genus Lycopodium.","pos":""}],"LYCOPODE":[{"def":"Same as Lycopodium powder.","pos":""}],"LYCOPODIACEOUS":[{"def":"Belonging, or relating, to the Lycopodiaceæ, an order of cryptogamous plants (called also club mosses) with branching stems, and small, crowded, one-nerved, and usually pointed leaves.","pos":""}],"LYCOPODITE":[{"def":"An old name for a fossil club moss.","pos":""}],"LYCOPODIUM":[{"def":"A genus of mosslike plants, the type of the order Lycopodiaceæ; club moss.","pos":""}],"LYDDITE":[{"def":"A high explosive consisting principally of picric acid, used as a shell explosive in the British service; -- so named from the proving grounds at Lydd, England.","pos":""}],"LYDIAN":[{"def":"Of or pertaining to Lydia, a country of Asia Minor, or to its inhabitants; hence, soft; effeminate; -- said especially of one of the ancient Greek modes or keys, the music in which was of a soft, pathetic, or voluptuous character.","pos":""}],"LYDINE":[{"def":"A violet dye derived from aniline.","pos":""}],"LYE":[{"def":"A strong caustic alkaline solution of potassium salts, obtained by leaching wood ashes.","pos":""}],"LYENCEPHALA":[{"def":"A group of Mammalia, including the marsupials and monotremes; - - so called because the corpus callosum is rudimentary.","pos":""}],"LYENCEPHALOUS":[{"def":"Pertaining to, or characteristic of, the Lyencephala.","pos":""}],"LYGODIUM":[{"def":"A genus of ferns with twining or climbing fronds, bearing stalked and variously-lobed divisions in pairs.","pos":""}],"LYING":[{"def":"of Lie, to tell a falsehood.","pos":""}],"LYING-IN":[{"def":"The state attending, and consequent to, childbirth; confinement.","pos":""},{"def":"The act of bearing a child.","pos":""}],"LYINGLY":[{"def":"In a lying manner; falsely.","pos":""}],"LYKEN":[{"def":"To please; -- chiefly used impersonally.","pos":""},{"def":"A dog held in a leam; a bloodhound; a limehound.","pos":""}],"LYME GRASS":[{"def":"A coarse perennial grass of several species of Elymus, esp.","pos":""}],"LYMPH":[{"def":"An alkaline colorless fluid, contained in the lymphatic vessels, coagulable like blood, but free from red blood corpuscles.","pos":""},{"def":"A fibrinous material exuded from the blood vessels in inflammation.","pos":""}],"LYMPH NODE":[{"def":"A lymphatic gland.","pos":""}],"LYMPHADENITIS":[{"def":"Inflammation of the lymphatic glands; -- called also lymphitis.","pos":""}],"LYMPHANGEITIS":[{"def":"Inflammation of the lymphatic vessels.","pos":""}],"LYMPHANGIAL":[{"def":"Of or pertaining to the lymphatics, or lymphoid tissue; lymphatic.","pos":""},{"def":"Frightened into madness; raving.","pos":""}],"LYMPHATIC":[{"def":"pertaining to, containing, or conveying lymph.","pos":""}],"LYMPHITIS":[{"def":"See Lymphadenitis.","pos":""}],"LYMPHOGENIC":[{"def":"Connected with, or formed in, the lymphatic glands.","pos":""}],"LYMPHOGRAPHY":[{"def":"A description of the lymphatic vessels, their origin and uses.","pos":""}],"LYMPHOID":[{"def":"Resembling lymph; also, resembling a lymphatic gland; adenoid; as, lymphoid tissue.","pos":""}],"LYMPHOMA":[{"def":"A tumor having a structure resembling that of a lymphatic gland; -- called also lymphadenoma.","pos":""}],"LYMPHY":[{"def":"Containing, or like, lymph.","pos":""}],"LYNCEAN":[{"def":"Of or pertaining to the lynx.","pos":""}],"LYNCH":[{"def":"To inflict punishment upon, especially death, without the forms of law, as when a mob captures and hangs a suspected person.","pos":""}],"LYNCH LAW":[{"def":"Lynch\" law` Defn: .","pos":""}],"LYNCHER":[{"def":"One who assists in lynching.","pos":""}],"LYNX":[{"def":"Any one of several species of feline animals of the genus Felis, and subgenus Lynx.","pos":""},{"def":"One of the northern constellations.","pos":""}],"LYNX-EYED":[{"def":"Having acute sight.","pos":""}],"LYONNAISE":[{"def":"Applied to boiled potatoes cut into small pieces and heated in oil or butter.","pos":""}],"LYOPOMATA":[{"def":"An order of brachiopods, in which the valves of shell are not articulated by a hinge.","pos":""}],"LYRA":[{"def":"A northern constellation, the Harp, containing a white star of the first magnitude, called Alpha Lyræ, or Vega.","pos":""},{"def":"The middle portion of the ventral surface of the fornix of the brain; -- so called from the arrangement of the lines with which it is marked in the human brain.","pos":""}],"LYRAID":[{"def":"Lyre-shaped, or spatulate and oblong, with small lobes toward the base; as, a lyrate leaf.","pos":""}],"LYRE":[{"def":"A stringed instrument of music; a kind of harp much used by the ancients, as an accompaniment to poetry.","pos":""},{"def":"One of the constellations; Lyra.","pos":""}],"LYRE BIRD":[{"def":"Any one of two or three species of Australian birds of the genus Menura.","pos":""}],"LYRIC":[{"def":"The words of a song.","pos":""}],"LYRICALLY":[{"def":"In a lyrical manner.","pos":""}],"LYRICISM":[{"def":"A lyric composition.","pos":""}],"LYRID":[{"def":"One of the group of shooting stars which come into the air in certain years on or about the 19th of April; -- so called because the apparent path among the stars the stars if produced back wards crosses the constellation Lyra.","pos":""}],"LYRIE":[{"def":"A European fish (Peristethus cataphractum), having the body covered with bony plates, and having three spines projecting in front of the nose; -- called also noble, pluck, pogge, sea poacher, and armed bullhead.","pos":""}],"LYRIFEROUS":[{"def":"Having a lyre-shaped shoulder girdle, as certain fishes.","pos":""}],"LYRISM":[{"def":"The act of playing on a lyre or harp.","pos":""}],"LYRIST":[{"def":"A musician who plays on the harp or lyre; a composer of lyrical poetry.","pos":""}],"LYSIMETER":[{"def":"An instrument for measuring the water that percolates through a certain depth of soil.","pos":""}],"LYSIS":[{"def":"The resolution or favorable termination of a disease, coming on gradually and not marked by abrupt change.","pos":""}],"LYSSA":[{"def":"Note: The plural (Lyssæ) has been used to signify the pustules supposed to be developed under the tongue in hydrophobia.","pos":""}],"LYTERIAN":[{"def":"Termination a disease; indicating the end of a disease.","pos":""}],"LYTHE":[{"def":"The European pollack; -- called also laith, and leet.","pos":""}],"LYTTA":[{"def":"A fibrous and muscular band lying within the longitudinal axis of the tongue in many mammals, as the dog.","pos":""}]}