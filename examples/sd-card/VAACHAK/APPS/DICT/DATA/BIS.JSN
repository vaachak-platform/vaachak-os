{"BIS":[{"def":"Twice; -- a word showing that something is, or is to be, repeated; as a passage of music, or an item in accounts.","pos":""},{"def":"A form of Bi-, sometimes used before s, c, or a vowel.","pos":""}],"BISACCATE":[{"def":"Having two little bags, sacs, or pouches.","pos":""}],"BISCAYAN":[{"def":"Of or pertaining to Biscay in Spain.","pos":""},{"def":"A native or inhabitant of Biscay.","pos":""}],"BISCOTIN":[{"def":"A confection made of flour, sugar, marmalade, and eggs; a sweet biscuit.","pos":""}],"BISCUIT":[{"def":"A species of white, unglazed porcelain, in which vases, figures, and groups are formed in miniature.","pos":""}],"BISCUTATE":[{"def":"Resembling two bucklers placed side by side.","pos":""}],"BISE":[{"def":"A cold north wind which prevails on the northern coasts of the Mediterranean and in Switzerland, etc.","pos":""}],"BISECT":[{"def":"To divide into two equal parts.","pos":""}],"BISECTION":[{"def":"Division into two parts, esp.","pos":""}],"BISECTOR":[{"def":"One who, or that which, bisects; esp.","pos":""}],"BISECTRIX":[{"def":"The line bisecting the angle between the optic axes of a biaxial crystal.","pos":""}],"BISEGMENT":[{"def":"One of tow equal parts of a line, or other magnitude.","pos":""}],"BISEPTATE":[{"def":"With two partitions or septa.","pos":""},{"def":"In two rows or series.","pos":""}],"BISERRATE":[{"def":"Doubly serrate, or having the serratures serrate, as in some leaves.","pos":""},{"def":"Serrate on both sides, as some antennæ.","pos":""}],"BISEXUAL":[{"def":"Of both sexes; hermaphrodite; as a flower with stamens and pistil, or an animal having ovaries and testes.","pos":""}],"BISHOP":[{"def":"A spiritual overseer, superintendent, or director.","pos":""},{"def":"In the Roman Catholic, Greek, and Anglican or Protestant Episcopal churches, one ordained to the highest order of the ministry, superior to the priesthood, and generally claiming to be a successor of the Apostles.","pos":""}],"BISHOP SLEEVE":[{"def":"A wide sleeve, once worn by women.","pos":""}],"BISHOP'S CAP":[{"def":"A plant of the genus Mitella; miterwort.","pos":""}],"BISHOP'S LENGTH":[{"def":"A canvas for a portrait measuring 58 by 94 inches.","pos":""}],"BISHOP'S-WORT":[{"def":"Wood betony (Stachys betonica); also, the plant called fennel flower (Nigella Damascena), or devil-in-a-bush.","pos":""}],"BISHOP-STOOL":[{"def":"A bishop's seat or see.","pos":""}],"BISHOPDOM":[{"def":"Jurisdiction of a bishop; episcopate.","pos":""}],"BISHOPLIKE":[{"def":"Resembling a bishop; belonging to a bishop.","pos":""}],"BISHOPLY":[{"def":"Bishoplike; episcopal.","pos":""}],"BISHOPRIC":[{"def":"A diocese; the district over which the jurisdiction of a bishop extends.","pos":""},{"def":"The office of a spiritual overseer, as of an apostle, bishop, or presbyter.","pos":""}],"BISIE":[{"def":"To busy; to employ.","pos":""}],"BISILICATE":[{"def":"A salt of metasilicic acid; -- so called because the ratio of the oxygen of the silica to the oxygen of the base is as two to one.","pos":""}],"BISK":[{"def":"Soup or broth made by boiling several sorts of flesh together.","pos":""}],"BISMER":[{"def":"The fifteen-spined (Gasterosteus spinachia).","pos":""}],"BISMILLAH":[{"def":"An adjuration or exclamation common among the Mohammedans.","pos":""}],"BISMITE":[{"def":"Bismuth trioxide, or bismuth ocher.","pos":""}],"BISMUTH":[{"def":"One of the elements; a metal of a reddish white color, crystallizing in rhombohedrons.","pos":""}],"BISMUTHAL":[{"def":"Containing bismuth.","pos":""}],"BISMUTHIC":[{"def":"Of or pertaining to bismuth; containing bismuth, when this element has its higher valence; as, bismuthic oxide.","pos":""}],"BISMUTHIFEROUS":[{"def":"Containing bismuth.","pos":""},{"def":"Native bismuth sulphide; -- sometimes called bismuthite.","pos":""}],"BISMUTHOUS":[{"def":"Of, or containing, bismuth, when this element has its lower valence.","pos":""}],"BISMUTHYL":[{"def":"Hydrous carbonate of bismuth, an earthy mineral of a dull white or yellowish color.","pos":""}],"BISON":[{"def":"North America, but is now restricted to very limited districts in the region of the Rocky Mountains, and is rapidly decreasing in numbers.","pos":""}],"BISPINOSE":[{"def":"Having two spines.","pos":""}],"BISQUE":[{"def":"Unglazed white porcelain.","pos":""}],"BISSELL TRUCK":[{"def":"A truck for railroad rolling stock, consisting of two ordinary axle boxes sliding in guides attached to a triangular frame; -- called also pony truck.","pos":""}],"BISSEXTILE":[{"def":"Leap year; every fourth year, in which a day is added to the month of February on account of the excess of the tropical year (365 d.","pos":""}],"BISSON":[{"def":"Purblind; blinding.","pos":""},{"def":"A dark brown pigment extracted from the soot of wood.","pos":""}],"BISTIPULED":[{"def":"Having two stipules.","pos":""}],"BISTORT":[{"def":"An herbaceous plant of the genus Polygonum, section Bistorta; snakeweed; adderwort.","pos":""}],"BISTOURY":[{"def":"A surgical instrument consisting of a slender knife, either straight or curved, generally used by introducing it beneath the part to be divided, and cutting towards the surface.","pos":""}],"BISULCATE":[{"def":"Cloven; said of a foot or hoof.","pos":""}],"BISULPHATE":[{"def":"A sulphate in which but half the hydrogen of the acid is replaced by a positive element or radical, thus making the proportion of the acid to the positive or basic portion twice what it is in the normal sulphates; an acid sulphate.","pos":""}],"BISULPHIDE":[{"def":"A sulphide having two atoms of sulphur in the molecule; a disulphide, as in iron pyrites, FeS2; -- less frequently called bisulphuret.","pos":""}],"BISULPHITE":[{"def":"A salt of sulphurous acid in which the base replaces but half the hydrogen of the acid; an acid sulphite.","pos":""}]}