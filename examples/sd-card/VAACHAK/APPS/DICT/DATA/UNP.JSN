{"UNPACK":[{"def":"To separate and remove, as things packed; to open and remove the contents of; as, to unpack a trunk.","pos":""},{"def":"To relieve of a pack or burden.","pos":""}],"UNPACKER":[{"def":"One who unpacks.","pos":""}],"UNPAGANIZE":[{"def":"To cause to cease to be pagan; to divest of pagan character.","pos":""}],"UNPAINT":[{"def":"To remove the paint from; to efface, as a painting.","pos":""}],"UNPAIRED":[{"def":"Not paired; not suited or matched.","pos":""}],"UNPALPED":[{"def":"Destitute of a palp.","pos":""}],"UNPANNEL":[{"def":"To take the saddle off; to unsaddle.","pos":""}],"UNPARADISE":[{"def":"To deprive of happiness like that of paradise; to render unhappy.","pos":""}],"UNPARAGONED":[{"def":"Having no paragon or equal; matchless; peerless.","pos":""}],"UNPARALLELED":[{"def":"Having no parallel, or equal; unequaled; unmatched.","pos":""}],"UNPARCHED":[{"def":"Dried up; withered by heat.","pos":""}],"UNPARDONABLE":[{"def":"Not admitting of pardon or forgiveness; inexcusable.","pos":""}],"UNPARENTED":[{"def":"Having no parent, or no acknowledged parent.","pos":""}],"UNPARLIAMENTARY":[{"def":"Not parliamentary; contrary to the practice of parliamentary bodies.","pos":""}],"UNPASSIONATE":[{"def":"Not passionate; dispassionate.","pos":""}],"UNPASTOR":[{"def":"To cause to be no longer pastor; to deprive of pastorship.","pos":""}],"UNPATHED":[{"def":"Not having a path.","pos":""}],"UNPAVED":[{"def":"Not paved; not furnished with a pavement.","pos":""}],"UNPAY":[{"def":"To undo, take back, or annul, as a payment.","pos":""}],"UNPEACE":[{"def":"Absence or lack of peace.","pos":""}],"UNPEDIGREED":[{"def":"Not distinguished by a pedigree.","pos":""}],"UNPEELED":[{"def":"Thoroughly stripped; pillaged.","pos":""}],"UNPEERABLE":[{"def":"Incapable of having a peer, or equal.","pos":""}],"UNPEERED":[{"def":"Having no peer; unequaled; unparalleled.","pos":""}],"UNPEG":[{"def":"To remove a peg or pegs from; to unfasten; to open.","pos":""}],"UNPEN":[{"def":"To release from a pen or from confinement.","pos":""}],"UNPEOPLE":[{"def":"To deprive of inhabitants; to depopulate.","pos":""}],"UNPERFECT":[{"def":"To mar or destroy the perfection of.","pos":""}],"UNPERFECTION":[{"def":"Want of perfection; imperfection.","pos":""}],"UNPERISHABLY":[{"def":"Un*per\"ish*a*bly, adv.","pos":""}],"UNPERPLEX":[{"def":"To free from perplexity.","pos":""}],"UNPERSUASION":[{"def":"The state of not being persuaded; disbelief; doubt.","pos":""}],"UNPERVERT":[{"def":"To free from perversion; to deliver from being perverted; to reconvert.","pos":""}],"UNPHILOSOPHIZE":[{"def":"To degrade from the character of a philosopher.","pos":""}],"UNPICK":[{"def":"To pick out; to undo by picking.","pos":""}],"UNPICKED":[{"def":"Picked out; picked open.","pos":""}],"UNPIN":[{"def":"To loose from pins; to remove the pins from; to unfasten; as, to unpin a frock; to unpin a frame.","pos":""}],"UNPINION":[{"def":"To loose from pinions or manacles; to free from restraint.","pos":""}],"UNPITIED":[{"def":"Pitiless; merciless.","pos":""}],"UNPITIOUS":[{"def":"Impious; wicked.","pos":""},{"def":"Destitute of pity; pitiless.","pos":""}],"UNPLAID":[{"def":"To deprive of a plaid.","pos":""}],"UNPLAINED":[{"def":"Not deplored or bewailed; unlamented.","pos":""}],"UNPLAT":[{"def":"To take out the folds or twists of, as something previously platted; to unfold; to unwreathe.","pos":""}],"UNPLAUSIVE":[{"def":"Not approving; disapproving.","pos":""}],"UNPLEADED":[{"def":"Not used as a plea; not urged; as, an unpleaded excuse.","pos":""},{"def":"Not supported by pleas; undefended; as, an unpleaded suit.","pos":""}],"UNPLEASANT":[{"def":"Not pleasant; not amiable or agreeable; displeasing; offensive.","pos":""}],"UNPLEASANTRY":[{"def":"Want of pleasantry.","pos":""},{"def":"A state of disagreement; a falling out.","pos":""}],"UNPLEAT":[{"def":"To remove the plaits of; to smooth.","pos":""}],"UNPLIGHT":[{"def":"To unfold; to lay open; to explain.","pos":""}],"UNPLUMB":[{"def":"To deprive of lead, as of a leaden coffin.","pos":""}],"UNPLUME":[{"def":"To strip of plumes or feathers; hence, to humiliate.","pos":""}],"UNPOISED":[{"def":"Not poised or balanced.","pos":""},{"def":"Not poised or weighed; hence, regardless of consequences; unhesitating.","pos":""}],"UNPOISON":[{"def":"To remove or expel poison from.","pos":""}],"UNPOLICIED":[{"def":"Not having civil polity, or a regular form of government.","pos":""},{"def":"Impolitic; imprudent.","pos":""}],"UNPOLISH":[{"def":"To deprive of polish; to make impolite.","pos":""}],"UNPOLITE":[{"def":"Not polite; impolite; rude.","pos":""}],"UNPOLITIC":[{"def":"Impolitic; imprudent.","pos":""}],"UNPOPE":[{"def":"To divest of the character, office, or authority of a pope.","pos":""},{"def":"To deprive of a pope.","pos":""}],"UNPORTUNATE":[{"def":"Importunate; troublesome with requests.","pos":""}],"UNPORTUOUS":[{"def":"Having no ports.","pos":""}],"UNPOSSESS":[{"def":"To be without, or to resign, possession of.","pos":""}],"UNPOSSIBILITY":[{"def":"Un*pos`si*bil\"i*ty, n.","pos":""}],"UNPOWER":[{"def":"Want of power; weakness.","pos":""}],"UNPOWERFUL":[{"def":"Not powerful; weak.","pos":""}],"UNPRACTICABLE":[{"def":"Impracticable; not feasible.","pos":""}],"UNPRACTICAL":[{"def":"Not practical; impractical.","pos":""}],"UNPRAISE":[{"def":"To withhold praise from; to deprive of praise.","pos":""}],"UNPRAY":[{"def":"To revoke or annul by prayer, as something previously prayed for.","pos":""}],"UNPRAYABLE":[{"def":"Not to be influenced or moved by prayers; obdurate.","pos":""}],"UNPREACH":[{"def":"To undo or overthrow by preaching.","pos":""}],"UNPRECEDENTED":[{"def":"Having no precedent or example; not preceded by a like case; not having the authority of prior example; novel; new; unexampled.","pos":""}],"UNPREDICT":[{"def":"To retract or falsify a previous prediction.","pos":""}],"UNPREJUDICED":[{"def":"Not prejudiced; free from undue bias or prepossession; not preoccupied by opinion; impartial; as, an unprejudiced mind; an unprejudiced judge.","pos":""},{"def":"Not warped or biased by prejudice; as, an unprejudiced judgment.","pos":""}],"UNPRELATED":[{"def":"Deposed from the office of prelate.","pos":""}],"UNPREVENTED":[{"def":"Not prevented or hindered; as, unprevented sorrows.","pos":""},{"def":"Not preceded by anything.","pos":""}],"UNPRICED":[{"def":"Not priced; being without a fixed or certain value; also, priceless.","pos":""}],"UNPRIEST":[{"def":"To deprive of priesthood; to unfrock.","pos":""}],"UNPRINCE":[{"def":"To deprive of the character or authority of a prince; to divest of principality of sovereignty.","pos":""}],"UNPRINCIPLE":[{"def":"To destroy the moral principles of.","pos":""}],"UNPRINCIPLED":[{"def":"Being without principles; especially, being without right moral principles; also, characterized by absence of principle.","pos":""}],"UNPRISON":[{"def":"To take or deliver from prison.","pos":""}],"UNPRIZABLE":[{"def":"Not prized or valued; being without value.","pos":""},{"def":"Invaluable; being beyond estimation.","pos":""}],"UNPROBABLY":[{"def":"In a manner not to be approved of; improperly.","pos":""}],"UNPROFICIENCY":[{"def":"Want of proficiency or improvement.","pos":""}],"UNPROFIT":[{"def":"Want of profit; unprofitableness.","pos":""}],"UNPROMISE":[{"def":"To revoke or annul, as a promise.","pos":""}],"UNPROP":[{"def":"To remove a prop or props from; to deprive of support.","pos":""}],"UNPROPER":[{"def":"Not proper or peculiar; improper.","pos":""}],"UNPROSELYTE":[{"def":"To convert or recover from the state of a proselyte.","pos":""}],"UNPROTESTANTIZE":[{"def":"To render other than Protestant; to cause to change from Protestantism to some other form of religion; to deprive of some Protestant feature or characteristic.","pos":""}],"UNPROVIDE":[{"def":"To deprive of necessary provision; to unfurnish.","pos":""}],"UNPUCKER":[{"def":"To smooth away the puckers or wrinkles of.","pos":""}],"UNPURE":[{"def":"Not pure; impure.","pos":""}],"UNPURSED":[{"def":"Robbed of a purse, or of money.","pos":""},{"def":"Taken from the purse; expended.","pos":""}]}