{"CALYCIFORM":[{"def":"Having the form or appearance of a calyx.","pos":""},{"def":"Pertaining to a calyx; having the nature of a calyx.","pos":""}],"CALYCLE":[{"def":"A row of small bracts, at the base of the calyx, on the outside.","pos":""}],"CALYCOZOA":[{"def":"A group of acalephs of which Lucernaria is the type.","pos":""}],"CALYCULAR":[{"def":"Pertaining to, or resembling, the bracts of a calycle.","pos":""},{"def":"Having a set of bracts resembling a calyx.","pos":""}],"CALYMENE":[{"def":"A genus of trilobites characteristic of the Silurian age.","pos":""}],"CALYON":[{"def":"Flint or pebble stone, used in building walls, etc.","pos":""}],"CALYPSO":[{"def":"A small and beautiful species of orchid, having a flower variegated with purple, pink, and yellow.","pos":""}],"CALYPTRA":[{"def":"A little hood or veil, resembling an extinguisher in form and position, covering each of the small flaskike capsules which contain the spores of mosses; also, any similar covering body.","pos":""}],"CALYPTRIFORM":[{"def":"Having the form a calyptra, or extinguisher.","pos":""}],"CALYX":[{"def":"The covering of a flower.","pos":""},{"def":"A cuplike division of the pelvis of the kidney, which surrounds one or more of the renal papilæ.","pos":""}]}