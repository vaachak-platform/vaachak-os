{"STUB":[{"def":"The stump of a tree; that part of a tree or plant which remains fixed in the earth when the stem is cut down; -- applied especially to the stump of a small tree, or shrub.","pos":""},{"def":"A log; a block; a blockhead.","pos":""}],"STUBBED":[{"def":"Reduced to a stub; short and thick, like something truncated; blunt; obtuse.","pos":""},{"def":"Abounding in stubs; stubby.","pos":""}],"STUBBEDNESS":[{"def":"The quality or state of being stubbed.","pos":""}],"STUBBINESS":[{"def":"The state of being stubby.","pos":""}],"STUBBLE":[{"def":"The stumps of wheat, rye, barley, oats, or buckwheat, left in the ground; the part of the stalk left by the scythe or sickle.","pos":""}],"STUBBLED":[{"def":"Covered with stubble.","pos":""},{"def":"Stubbed; as, stubbled legs.","pos":""}],"STUBBLY":[{"def":"Covered with stubble; stubbled.","pos":""}],"STUBBORN":[{"def":"Firm as a stub or stump; stiff; unbending; unyielding; persistent; hence, unreasonably obstinate in will or opinion; not yielding to reason or persuasion; refractory; harsh; -- said of persons and things; as, stubborn wills; stubborn ore; a stubborn oak; as stubborn as a mule.","pos":""}],"STUBBY":[{"def":"Abounding with stubs.","pos":""},{"def":"Short and thick; short and strong, as bristles.","pos":""}],"STUCCO":[{"def":"Plaster of any kind used as a coating for walls, especially, a fine plaster, composed of lime or gypsum with sand and pounded marble, used for internal decorations and fine work.","pos":""},{"def":"Work made of stucco; stuccowork.","pos":""}],"STUCCOER":[{"def":"One who stuccoes.","pos":""}],"STUCCOWORK":[{"def":"Work done in stucco.","pos":""}],"STUCK-UP":[{"def":"Self-important and supercilious, [Colloq.","pos":""}],"STUCKLE":[{"def":"A number of sheaves set together in the field; a stook.","pos":""}],"STUD":[{"def":"A collection of breeding horses and mares, or the place where they are kept; also, a number of horses kept for a racing, riding, etc.","pos":""}],"STUD-HORSE":[{"def":"A stallion, esp.","pos":""}],"STUDBOOK":[{"def":"A genealogical register of a particular breed or stud of horses, esp.","pos":""}],"STUDDERY":[{"def":"A stud, or collection of breeding horses and mares; also, a place for keeping a stud.","pos":""}],"STUDDING":[{"def":"Material for studs, or joists; studs, or joists, collectively; studs.","pos":""}],"STUDDING SAIL":[{"def":"A light sail set at the side of a principal or square sail of a vessel in free winds, to increase her speed.","pos":""}],"STUDENT":[{"def":"A person engaged in study; one who is devoted to learning; a learner; a pupil; a scholar; especially, one who attends a school, or who seeks knowledge from professional teachers or from books; as, the students of an academy, a college, or a university; a medical student; a hard student.","pos":""},{"def":"One who studies or examines in any manner; an attentive and systematic observer; as, a student of human nature, or of physical nature.","pos":""}],"STUDENTRY":[{"def":"A body of students.","pos":""}],"STUDENTSHIP":[{"def":"The state of being a student.","pos":""}],"STUDFISH":[{"def":"Any one of several species of small American minnows of the genus Fundulus, as F.","pos":""}],"STUDIED":[{"def":"Closely examined; read with diligence and attention; made the subject of study; well considered; as, a studied lesson.","pos":""},{"def":"Well versed in any branch of learning; qualified by study; learned; as, a man well studied in geometry.","pos":""}],"STUDIEDLY":[{"def":"In a studied manner.","pos":""}],"STUDIER":[{"def":"Lipsius was a great studier of the stoical philosophy.","pos":""}],"STUDIO":[{"def":"The working room of an artist.","pos":""}],"STUDIOUS":[{"def":"Given to study; devoted to the acquisition of knowledge from books; as, a studious scholar.","pos":""},{"def":"Given to thought, or to the examination of subjects by contemplation; contemplative.","pos":""}],"STUDY":[{"def":"A representation or rendering of any object or scene intended, not for exhibition as an original work of art, but for the information, instruction, or assistance of the maker; as, a study of heads or of hands for a figure picture.","pos":""},{"def":"A piece for special practice.","pos":""}],"STUFA":[{"def":"A jet of steam issuing from a fissure in the earth.","pos":""}],"STUFF":[{"def":"A melted mass of turpentine, tallow, etc.","pos":"verb"}],"STUFFER":[{"def":"One who, or that which, stuffs.","pos":""}],"STUFFINESS":[{"def":"The quality of being stuffy.","pos":""}],"STUFFING":[{"def":"Any seasoning preparation used to stuff meat; especially, a composition of bread, condiments, spices, etc.","pos":""}],"STUFFY":[{"def":"Stout; mettlesome; resolute.","pos":""},{"def":"Angry and obstinate; sulky.","pos":""}],"STULL":[{"def":"A framework of timber covered with boards to support rubbish; also, a framework of boards to protect miners from falling stones.","pos":""}],"STULM":[{"def":"A shaft or gallery to drain a mine.","pos":""}],"STULP":[{"def":"A short, stout post used for any purpose, a to mark a boundary.","pos":""}],"STULTIFICATION":[{"def":"The act of stultifying, or the state of being stultified.","pos":""}],"STULTIFIER":[{"def":"One who stultifies.","pos":""}],"STULTIFY":[{"def":"To allege or prove to be of unsound mind, so that the performance of some act may be avoided.","pos":""}],"STULTILOQUENCE":[{"def":"Silly talk; babbling.","pos":""}],"STULTILOQUENT":[{"def":"Given to, or characterized by, silly talk; babbling.","pos":""}],"STULTILOQUY":[{"def":"Foolish talk; silly discource; babbling.","pos":""}],"STUM":[{"def":"Unfermented grape juice or wine, often used to raise fermentation in dead or vapid wines; must.","pos":""},{"def":"Wine revived by new fermentation, reulting from the admixture of must.","pos":""}],"STUMBLE":[{"def":"To trip in walking or in moving in any way with the legs; to strike the foot so as to fall, or to endanger a fall; to stagger because of a false step.","pos":""},{"def":"To walk in an unsteady or clumsy manner.","pos":""}],"STUMBLER":[{"def":"One who stumbles.","pos":""}],"STUMBLING-BLOCK":[{"def":"Any cause of stumbling, perplexity, or error.","pos":""}],"STUMBLING-STONE":[{"def":"A stumbling-block.","pos":""}],"STUMBLINGLY":[{"def":"In a stumbling manner.","pos":""}],"STUMP":[{"def":"The legs; as, to stir one's stumps.","pos":""},{"def":"One of the three pointed rods stuck in the ground to form a wicket and support the bails.","pos":""}],"STUMP-TAILED":[{"def":"Having a short, thick tail.","pos":""}],"STUMPAGE":[{"def":"Timber in standing trees, -- often sold without the land at a fixed price per tree or per stump, the stumps being counted when the land is cleared.","pos":""},{"def":"A tax on the amount of timber cut, regulated by the price of lumber.","pos":""}],"STUMPER":[{"def":"A boastful person.","pos":""}],"STUMPINESS":[{"def":"The state of being stumpy.","pos":""}],"STUMPY":[{"def":"Full of stumps; hard; strong.","pos":""},{"def":"Short and thick; stubby.","pos":""}],"STUN":[{"def":"To make senseless or dizzy by violence; to render senseless by a blow, as on the head.","pos":""},{"def":"To dull or deaden the sensibility of; to overcome; especially, to overpower one's sense of hearing.","pos":""}],"STUNDIST":[{"def":"One of a large sect of Russian dissenters founded, about 1860, in the village of Osnova, near Odessa, by a peasant, Onishchenko, who had apparently been influenced by a German sect settled near there.","pos":""}],"STUNNER":[{"def":"One who, or that which, stuns.","pos":""},{"def":"Something striking or amazing in quality; something of extraordinary excellence.","pos":""}],"STUNNING":[{"def":"Overpowering consciousness; overpowering the senses; especially, overpowering the sense of hearing; confounding with noise.","pos":""},{"def":"Striking or overpowering with astonishment, especially on account of excellence; as, stunning poetry.","pos":""}],"STUNSAIL":[{"def":"A contraction of Studding sail.","pos":""}],"STUNT":[{"def":"To hinder from growing to the natural size; to prevent the growth of; to stint, to dwarf; as, to stunt a child; to stunt a plant.","pos":""}],"STUNTNESS":[{"def":"Stuntedness; brevity.","pos":""}],"STUPA":[{"def":"A mound or monument commemorative of Buddha.","pos":""}],"STUPE":[{"def":"Cloth or flax dipped in warm water or medicaments and applied to a hurt or sore.","pos":""}],"STUPEFACIENT":[{"def":"Producing stupefaction; stupefactive.","pos":""},{"def":"Anything promoting stupefaction; a narcotic.","pos":""}],"STUPEFACTION":[{"def":"The act of stupefying, or the state of being stupefied.","pos":""}],"STUPEFACTIVE":[{"def":"Same as Stupefacient.","pos":""}],"STUPEFIED":[{"def":"Having been made stupid.","pos":""}],"STUPEFIEDNESS":[{"def":"Quality of being stupid.","pos":""}],"STUPEFIER":[{"def":"One who, or that which, stupefies; a stupefying agent.","pos":""}],"STUPEFY":[{"def":"To make stupid; to make dull; to blunt the faculty of perception or understanding in; to deprive of sensibility; to make torpid.","pos":""},{"def":"To deprive of material mobility.","pos":""}],"STUPENDOUS":[{"def":"Astonishing; wonderful; amazing; especially, astonishing in magnitude or elevation; as, a stupendous pile.","pos":""}],"STUPEOUS":[{"def":"Resembling tow; having long, loose scales, or matted filaments, like tow; stupose.","pos":""}],"STUPID":[{"def":"Very dull; insensible; senseless; wanting in understanding; heavy; sluggish; in a state of stupor; -- said of persons.","pos":""},{"def":"Resulting from, or evincing, stupidity; formed without skill or genius; dull; heavy; -- said of things.","pos":""}],"STUPIDITY":[{"def":"The quality or state of being stupid; extreme dullness of perception or understanding; insensibility; sluggishness.","pos":""},{"def":"Stupor; astonishment; stupefaction.","pos":""}],"STUPOR":[{"def":"Great diminution or suspension of sensibility; suppression of sense or feeling; lethargy.","pos":""},{"def":"Intellectual insensibility; moral stupidity; heedlessness or inattention to one's interests.","pos":""}],"STUPOSE":[{"def":"Composed of, or having, tufted or matted filaments like tow; stupeous.","pos":""}],"STUPRATE":[{"def":"To ravish; to debauch.","pos":""}],"STUPRATION":[{"def":"Violation of chastity by force; rape.","pos":""}],"STURDILY":[{"def":"In a sturdy manner.","pos":""}],"STURDINESS":[{"def":"Quality of being sturdy.","pos":""}],"STURDY":[{"def":"Foolishly obstinate or resolute; stubborn; unrelenting; unfeeling; stern.","pos":""},{"def":"Resolute, in a good sense; or firm, unyielding quality; as, a man of sturdy piety or patriotism.","pos":""}],"STURGEON":[{"def":"Any one of numerous species of large cartilaginous ganoid fishes belonging to Acipenser and allied genera of the family Acipenseridæ.","pos":""}],"STURIONES":[{"def":"An order of fishes including the sturgeons.","pos":""}],"STURIONIAN":[{"def":"One of the family of fishes of which the sturgeon is the type.","pos":""}],"STURNOID":[{"def":"Like or pertaining to the starlings.","pos":""}],"STURT":[{"def":"To vex; to annoy; to startle.","pos":""}],"STURTION":[{"def":"A corruption of Nasturtion.","pos":""}],"STUTTER":[{"def":"To hesitate or stumble in uttering words; to speak with spasmodic repetition or pauses; to stammer.","pos":""}],"STUTTERER":[{"def":"One who stutters; a stammerer.","pos":""}],"STUTTERING":[{"def":"The act of one who stutters; -- restricted by some physiologists to defective speech due to inability to form the proper sounds, the breathing being normal, as distinguished from stammering.","pos":""}]}