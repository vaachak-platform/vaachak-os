{"SCALA":[{"def":"A machine formerly employed for reducing dislocations of the humerus.","pos":""},{"def":"A term applied to any one of the three canals of the cochlea.","pos":""}],"SCALABLE":[{"def":"Capable of being scaled.","pos":""}],"SCALAR":[{"def":"In the quaternion analysis, a quantity that has magnitude, but not direction; -- distinguished from a vector, which has both magnitude and direction.","pos":""}],"SCALARIA":[{"def":"Any one of numerous species of marine gastropods of the genus Scalaria, or family Scalaridæ, having elongated spiral turreted shells, with rounded whorls, usually crossed by ribs or varices.","pos":""}],"SCALARIFORM":[{"def":"Like or pertaining to a scalaria.","pos":""}],"SCALARY":[{"def":"Resembling a ladder; formed with steps.","pos":""}],"SCALAWAG":[{"def":"A scamp; a scapegrace.","pos":""}],"SCALD":[{"def":"To burn with hot liquid or steam; to pain or injure by contact with, or imersion in, any hot fluid; as, to scald the hand.","pos":""},{"def":"To expose to a boiling or violent heat over a fire, or in hot water or other liquor; as, to scald milk or meat.","pos":""}],"SCALDER":[{"def":"A Scandinavian poet; a scald.","pos":""}],"SCALDFISH":[{"def":"A European flounder (Arnoglosus laterna, or Psetta arnoglossa); -- called also megrin, and smooth sole.","pos":""}],"SCALDIC":[{"def":"Of or pertaining to the scalds of the Norsemen; as, scaldic poetry.","pos":""}],"SCALE":[{"def":"The sign or constellation Libra.","pos":""}],"SCALE-WINGED":[{"def":"Having the wings covered with small scalelike structures, as the lepidoptera; scaly-winged.","pos":""}],"SCALEBACK":[{"def":"Any one of numerous species of marine annelids of the family Polynoidæ, and allies, which have two rows of scales, or elytra, along the back.","pos":""}],"SCALEBEAM":[{"def":"The lever or beam of a balance; the lever of a platform scale, to which the poise for weighing is applied.","pos":""},{"def":"A weighing apparatus with a sliding weight, resembling a steelyard.","pos":""}],"SCALEBOARD":[{"def":"A thin slip of wood used to justify a page.","pos":""}],"SCALED":[{"def":"Having feathers which in form, color, or arrangement somewhat resemble scales; as, the scaled dove.","pos":""}],"SCALELESS":[{"def":"Destitute of scales.","pos":""}],"SCALENE":[{"def":"A triangle having its sides and angles unequal.","pos":""}],"SCALENOHEDRAL":[{"def":"Of or pertaining to a scalenohedron.","pos":""}],"SCALENOHEDRON":[{"def":"A pyramidal form under the rhombohedral system, inclosed by twelve faces, each a scalene triangle.","pos":""}],"SCALER":[{"def":"One who, or that which, scales; specifically, a dentist's instrument for removing tartar from the teeth.","pos":""}],"SCALINESS":[{"def":"The state of being scaly; roughness.","pos":""}],"SCALING":[{"def":"Adapted for removing scales, as from a fish; as, a scaling knife; adapted for removing scale, as from the interior of a steam boiler; as, a scaling hammer, bar, etc.","pos":""},{"def":"Serving as an aid in clambering; as, a scaling ladder, used in assaulting a fortified place.","pos":""}],"SCALIOLA":[{"def":"Same as Scagliola.","pos":""}],"SCALL":[{"def":"A scurf or scabby disease, especially of the scalp.","pos":""}],"SCALLED":[{"def":"Scabby; scurfy; scall.","pos":""}],"SCALLION":[{"def":"A kind of small onion (Allium Ascalonicum), native of Palestine; the eschalot, or shallot.","pos":""}],"SCALLOP":[{"def":"Any one of numerous species of marine bivalve mollusks of the genus Pecten and allied genera of the family Pectinidæ.","pos":""}],"SCALLOPED":[{"def":"Baked in a scallop; cooked with crumbs.","pos":""}],"SCALLOPER":[{"def":"One who fishes for scallops.","pos":""}],"SCALLOPING":[{"def":"Fishing for scallops.","pos":""}],"SCALP":[{"def":"A bed of oysters or mussels.","pos":""}],"SCALPEL":[{"def":"A small knife with a thin, keen blade, -- used by surgeons, and in dissecting.","pos":""}],"SCALPER":[{"def":"Same as Scalping iron, under Scalping.","pos":""}],"SCALPING":[{"def":"Scalp\"ing, Defn: a.","pos":""}],"SCALPRIFORM":[{"def":"Shaped like a chisel; as, the scalpriform incisors of rodents.","pos":""}],"SCALY":[{"def":"Composed of scales lying over each other; as, a scaly bulb; covered with scales; as, a scaly stem.","pos":""}]}