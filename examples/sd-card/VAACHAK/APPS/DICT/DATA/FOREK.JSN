{"FOREKNOW":[{"def":"To have previous knowledge of; to know beforehand.","pos":""}],"FOREKNOWABLE":[{"def":"That may be foreknown.","pos":""}],"FOREKNOWER":[{"def":"One who foreknows.","pos":""}],"FOREKNOWINGLY":[{"def":"With foreknowledge.","pos":""}],"FOREKNOWLEDGE":[{"def":"Knowledge of a thing before it happens, or of whatever is to happen; prescience.","pos":""}]}