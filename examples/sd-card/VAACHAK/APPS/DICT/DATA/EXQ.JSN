{"EXQUIRE":[{"def":"To search into or out.","pos":""}],"EXQUISITE":[{"def":"Carefully selected or sought out; hence, of distinguishing and surpassing quality; exceedingly nice; delightfully excellent; giving rare satisfaction; as, exquisite workmanship.","pos":""},{"def":"Exceeding; extreme; keen; -- used in a bad or a good sense; as, exquisite pain or pleasure.","pos":""}],"EXQUISITELY":[{"def":"In an exquisite manner or degree; as, lace exquisitely wrought.","pos":""}],"EXQUISITENESS":[{"def":"Quality of being exquisite.","pos":""}],"EXQUISITIVE":[{"def":"Eager to discover or learn; curious.","pos":""}]}