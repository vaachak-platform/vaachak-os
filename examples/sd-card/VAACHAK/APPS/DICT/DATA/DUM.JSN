{"DUMAL":[{"def":"Pertaining to, or set with, briers or bushes; brambly.","pos":""}],"DUMB":[{"def":"Destitute of the power of speech; unable; to utter articulate sounds; as, the dumb brutes.","pos":""},{"def":"Not willing to speak; mute; silent; not speaking; not accompanied by words; as, dumb show.","pos":""}],"DUMB-BELL":[{"def":"A weight, consisting of two spheres or spheroids, connected by a short bar for a handle; used (often in pairs) for gymnastic exercise.","pos":""}],"DUMB-WAITER":[{"def":"A framework on which dishes, food, etc.","pos":""}],"DUMBLEDOR":[{"def":"A bumblebee; also, a cockchafer.","pos":""}],"DUMBLY":[{"def":"In silence; mutely.","pos":""}],"DUMBNESS":[{"def":"The quality or state of being dumb; muteness; silence; inability to speak.","pos":""}],"DUMDUM BULLET":[{"def":"A kind of manstopping bullet; -- so named from Dumdum, in India, where bullets are manufactured for the Indian army.","pos":""}],"DUMFOUND":[{"def":"To strike dumb; to confuse with astonishment.","pos":""}],"DUMFOUNDER":[{"def":"To dumfound; to confound.","pos":""}],"DUMMERER":[{"def":"One who feigns dumbness.","pos":""}],"DUMMY":[{"def":"Silent; mute; noiseless; as a dummy engine.","pos":""},{"def":"Fictitious or sham; feigned; as, a dummy watch.","pos":""}],"DUMP":[{"def":"A thick, ill-shapen piece; a clumsy leaden counter used by boys in playing chuck farthing.","pos":""}],"DUMPAGE":[{"def":"The act of dumping loads from carts, especially loads of refuse matter; also, a heap of dumped matter.","pos":""},{"def":"A fee paid for the privilege of dumping loads.","pos":""}],"DUMPINESS":[{"def":"The state of being dumpy.","pos":""}],"DUMPISH":[{"def":"Dull; stupid; sad; moping; melancholy.","pos":""}],"DUMPLE":[{"def":"To make dumpy; to fold, or bend, as one part over another.","pos":""}],"DUMPLING":[{"def":"A roundish mass of dough boiled in soup, or as a sort of pudding; often, a cover of paste inclosing an apple or other fruit, and boiled or baked; as, an apple dumpling.","pos":""}],"DUMPY":[{"def":"From Dump a short ill-shapen piece.","pos":""},{"def":"From Dump sadness.","pos":""}],"DUMPY LEVEL":[{"def":"A level having a short telescope (hence its name) rigidly fixed to a table capable only of rotatory movement in a horizontal plane.","pos":""}]}