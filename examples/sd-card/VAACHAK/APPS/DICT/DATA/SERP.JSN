{"SERPENS":[{"def":"A constellation represented as a serpent held by Serpentarius.","pos":""}],"SERPENT":[{"def":"Any reptile of the order Ophidia; a snake, especially a large snake.","pos":""},{"def":"The constellation Serpens.","pos":""}],"SERPENT-TONGUED":[{"def":"Having a forked tongue, like a serpent.","pos":""}],"SERPENTARIA":[{"def":"The fibrous aromatic root of the Virginia snakeroot (Aristolochia Serpentaria).","pos":""}],"SERPENTARIUS":[{"def":"A constellation on the equator, lying between Scorpio and Hercules; -- called also Ophiuchus.","pos":"noun"}],"SERPENTIFORM":[{"def":"Having the form of a serpent.","pos":""}],"SERPENTIGENOUS":[{"def":"Bred of a serpent.","pos":""}],"SERPENTINE":[{"def":"Resembling a serpent; having the shape or qualities of a serpent; subtle; winding or turning one way and the other, like a moving serpent; anfractuous; meandering; sinuous; zigzag; as, serpentine braid.","pos":""}],"SERPENTINELY":[{"def":"In a serpentine manner.","pos":""}],"SERPENTINIZE":[{"def":"To convert (a magnesian silicate) into serpentine.","pos":""}],"SERPENTINOUS":[{"def":"Relating to, or like, serpentine; as, a rock serpentinous in character.","pos":""}],"SERPENTIZE":[{"def":"To turn or bend like a serpent, first in one direction and then in the opposite; to meander; to wind; to serpentine.","pos":""}],"SERPENTRY":[{"def":"A winding like a serpent's.","pos":""},{"def":"A place inhabited or infested by serpents.","pos":""}],"SERPETTE":[{"def":"A pruning knife with a curved blade.","pos":""}],"SERPIGINOUS":[{"def":"Creeping; -- said of lesions which heal over one portion while continuing to advance at another.","pos":""}],"SERPIGO":[{"def":"A dry, scaly eruption on the skin; especially, a ringworm.","pos":""}],"SERPULA":[{"def":"Any one of numerous species of tubicolous annelids of the genus Serpula and allied genera of the family Serpulidæ.","pos":""}],"SERPULITE":[{"def":"A fossil serpula shell.","pos":""}]}