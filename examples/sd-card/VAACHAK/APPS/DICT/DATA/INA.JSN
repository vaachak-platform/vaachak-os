{"INABILITY":[{"def":"The quality or state of being unable; lack of ability; want of sufficient power, strength, resources, or capacity.","pos":""}],"INABSTINENCE":[{"def":"Want of abstinence; indulgence.","pos":""}],"INACCESSIBILITY":[{"def":"The quality or state of being inaccessible; inaccessibleness.","pos":""}],"INACCESSIBLE":[{"def":"Not accessible; not to be reached, obtained, or approached; as, an inaccessible rock, fortress, document, prince, etc.","pos":""}],"INACCORDANT":[{"def":"Not accordant; discordant.","pos":""}],"INACCURACY":[{"def":"The quality of being inaccurate; want of accuracy or exactness.","pos":""},{"def":"That which is inaccurate or incorrect; mistake; fault; defect; error; as, in inaccuracy in speech, copying, calculation, etc.","pos":""}],"INACCURATE":[{"def":"Not accurate; not according to truth; inexact; incorrect; erroneous; as, in inaccurate man, narration, copy, judgment, calculation, etc.","pos":""}],"INACCURATELY":[{"def":"In an inaccurate manner; incorrectly; inexactly.","pos":""}],"INACQUAINTANCE":[{"def":"Want of acquaintance.","pos":""}],"INACQUIESCENT":[{"def":"Not acquiescent or acquiescing.","pos":""}],"INACTION":[{"def":"Want of action or activity; forbearance from labor; idleness; rest; inertness.","pos":""}],"INACTIVE":[{"def":"Not active; inert; esp.","pos":""}],"INACTIVELY":[{"def":"In an inactive manner.","pos":""}],"INACTIVITY":[{"def":"The state or quality of being inactive; inertness; as, the inactivity of matter.","pos":""},{"def":"Idleness; habitual indisposition to action or exertion; want of energy; sluggishness.","pos":""}],"INACTOSE":[{"def":"A variety of sugar, found in certain plants.","pos":""}],"INACTUATE":[{"def":"To put in action.","pos":""}],"INADAPTATION":[{"def":"Want of adaptation; unsuitableness.","pos":""}],"INADEQUACY":[{"def":"The quality or state of being inadequate or insufficient; defectiveness; insufficiency; inadequateness.","pos":""}],"INADEQUATE":[{"def":"Not adequate; unequal to the purpose; insufficient; deficient; as, inadequate resources, power, conceptions, representations, etc.","pos":""}],"INADEQUATION":[{"def":"Want of exact correspondence.","pos":""}],"INADHERENT":[{"def":"Free; not connected with the other organs.","pos":""}],"INADHESION":[{"def":"Want of adhesion.","pos":""}],"INADMISSIBILITY":[{"def":"The state or quality of being inadmissible, or not to be received.","pos":""}],"INADMISSIBLE":[{"def":"Not admissible; not proper to be admitted, allowed, or received; as, inadmissible testimony; an inadmissible proposition, or explanation.","pos":""}],"INADVERTENT":[{"def":"Not turning the mind to a matter; heedless; careless; negligent; inattentive.","pos":""}],"INAFFABILITY":[{"def":"Want of affability or sociability; reticence.","pos":""}],"INAFFABLE":[{"def":"Not affable; reserved in social intercourse.","pos":""}],"INAFFECTATION":[{"def":"Freedom from affectation; naturalness.","pos":""}],"INAIDABLE":[{"def":"Incapable of being assisted; helpless.","pos":""}],"INALIENABILITY":[{"def":"The quality or state of being inalienable.","pos":""}],"INALIENABLE":[{"def":"Incapable of being alienated, surrendered, or transferred to another; not alienable; as, in inalienable birthright.","pos":""}],"INALIENABLENESS":[{"def":"The quality or state of being inalienable; inalienability.","pos":""}],"INALIENABLY":[{"def":"In a manner that forbids alienation; as, rights inalienably vested.","pos":""}],"INALIMENTAL":[{"def":"Affording no aliment or nourishment.","pos":""}],"INALTERABILITY":[{"def":"The quality of being unalterable or unchangeable; permanence.","pos":""}],"INALTERABLE":[{"def":"Not alterable; incapable of being altered or changed; unalterable.","pos":""}],"INAMISSIBLE":[{"def":"Incapable of being lost.","pos":""}],"INAMORATA":[{"def":"A woman in love; a mistress.","pos":""}],"INAMOVABLE":[{"def":"Not amovable or removable.","pos":""}],"INANE":[{"def":"Without contents; empty; void of sense or intelligence; purposeless; pointless; characterless; useless.","pos":""}],"INANGULAR":[{"def":"Given to talking inanely; loquacious; garrulous.","pos":""}],"INANIMATE":[{"def":"Not animate; destitute of life or spirit; lifeless; dead; inactive; dull; as, stones and earth are inanimate substances.","pos":""}],"INANIMATED":[{"def":"Destitute of life; lacking animation; unanimated.","pos":""}],"INANIMATENESS":[{"def":"The quality or state of being inanimate.","pos":""}],"INANIMATION":[{"def":"Want of animation; lifeless; dullness.","pos":""}],"INANITIATE":[{"def":"To produce inanition in; to exhaust for want of nourishment.","pos":""}],"INANITION":[{"def":"The condition of being inane; emptiness; want of fullness, as in the vessels of the body; hence, specifically, exhaustion from want of food, either from partial or complete starvation, or from a disorder of the digestive apparatus, producing the same result.","pos":""}],"INANITY":[{"def":"Inanition; void space; vacuity; emptiness.","pos":""},{"def":"Want of seriousness; aimlessness; frivolity.","pos":""}],"INANTHERATE":[{"def":"Not bearing anthers; -- said of sterile stamens.","pos":""}],"INAPATHY":[{"def":"Sensibility; feeling; -- opposed to apathy.","pos":""}],"INAPPEALABLE":[{"def":"Not admitting of appeal; not appealable.","pos":""}],"INAPPEASABLE":[{"def":"Incapable of being appeased or satisfied; unappeasable.","pos":""}],"INAPPELLABILITY":[{"def":"The quality of being inappellable; finality.","pos":""}],"INAPPELLABLE":[{"def":"Inappealable; final.","pos":""},{"def":"Want of appetency; want of desire.","pos":""}],"INAPPLICABILITY":[{"def":"The quality of being inapplicable; unfitness; inapplicableness.","pos":""}],"INAPPLICABLE":[{"def":"Not applicable; incapable of being applied; not adapted; not suitable; as, the argument is inapplicable to the case.","pos":""}],"INAPPLICATION":[{"def":"Want of application, attention, or diligence; negligence; indolence.","pos":""}],"INAPPOSITE":[{"def":"Not apposite; not fit or suitable; not pertinent.","pos":""}],"INAPPRECIABLE":[{"def":"Not appreciable; too small to be perceived; incapable of being duly valued or estimated.","pos":""}],"INAPPRECIATION":[{"def":"Want of appreciation.","pos":""}],"INAPPREHENSIBLE":[{"def":"Not apprehensible; unintelligible; inconceivable.","pos":""}],"INAPPREHENSION":[{"def":"Want of apprehension.","pos":""}],"INAPPREHENSIVE":[{"def":"Not apprehensive; regardless; unconcerned.","pos":""}],"INAPPROACHABLE":[{"def":"Not approachable; unapproachable; inaccessible; unequaled.","pos":""}],"INAPPROPRIATE":[{"def":"Not instrument (to); not appropriate; unbecoming; unsuitable; not specially fitted; -- followed by to or for.","pos":""}],"INAPT":[{"def":"Unapt; not apt; unsuitable; inept.","pos":""}],"INAPTITUDE":[{"def":"Want of aptitude.","pos":""}],"INAQUATE":[{"def":"Embodied in, or changed into, water.","pos":""}],"INAQUATION":[{"def":"The state of being inaquate.","pos":""}],"INARCH":[{"def":"To graft by uniting, as a scion, to a stock, without separating either from its root before the union is complete; -- also called to graft by approach.","pos":""}],"INARCHING":[{"def":"A method of ingrafting.","pos":""}],"INARTICULATE":[{"def":"Not uttered with articulation or intelligible distinctness, as speech or words.","pos":""},{"def":"Incapable of articulating.","pos":""}],"INARTICULATED":[{"def":"Not articulated; not jointed or connected by a joint.","pos":""}],"INARTICULATELY":[{"def":"In an inarticulate manner.","pos":""}],"INARTICULATENESS":[{"def":"The state or quality of being inarticulate.","pos":""}],"INARTICULATION":[{"def":"Inarticulateness.","pos":""}],"INARTIFICIAL":[{"def":"Not artificial; not made or elaborated by art; natural; simple; artless; as, an inartificial argument; an inartificial character.","pos":""}],"INASMUCH":[{"def":"In like degree; in like manner; seeing that; considering that; since; -- followed by as.","pos":""}],"INATTENTION":[{"def":"Want of attention, or failure to pay attention; disregard; heedlessness; neglect.","pos":""}],"INATTENTIVE":[{"def":"Not attentive; not fixing the mind on an object; heedless; careless; negligent; regardless; as, an inattentive spectator or hearer; an inattentive habit.","pos":""}],"INAUDIBILITY":[{"def":"The quality of being inaudible; inaudibleness.","pos":""}],"INAUDIBLE":[{"def":"Not audible; incapable of being heard; silent.","pos":""}],"INAUGURAL":[{"def":"Pertaining to, or performed or pronounced at, an inauguration; as, an inaugural address; the inaugural exercises.","pos":""}],"INAUGURATE":[{"def":"Invested with office; inaugurated.","pos":""}],"INAUGURATION":[{"def":"The act of inuagurating, or inducting into office with solemnity; investiture by appropriate ceremonies.","pos":""},{"def":"The formal beginning or initiation of any movement, course of action, etc.","pos":""}],"INAUGURATION DAY":[{"def":"The day on which the President of the United States is inaugurated, the 4th of March in every year next after a year divisible by four.","pos":""}],"INAUGURATOR":[{"def":"One who inaugurates.","pos":""}],"INAUGURATORY":[{"def":"Suitable for, or pertaining to, inauguration.","pos":""}],"INAURATE":[{"def":"Covered with gold; gilded.","pos":""}],"INAURATION":[{"def":"The act or process of gilding or covering with gold.","pos":""}],"INAUSPICATE":[{"def":"Inauspicious [Obs.","pos":""}],"INAUSPICIOUS":[{"def":"Not auspicious; ill-omened; unfortunate; unlucky; unfavorable.","pos":""}],"INAUTHORITATIVE":[{"def":"Without authority; not authoritative.","pos":""}]}