{"TURN":[{"def":"To cause to present a different side uppermost or outmost; to make the upper side the lower, or the inside to be the outside of; to reverse the position of; as, to turn a box or a board; to turn a coat.","pos":""}],"TURN-OUT":[{"def":"The act of coming forth; a leaving of houses, shops, etc.","pos":""},{"def":"A short side track on a railroad, which may be occupied by one train while another is passing on a main track; a shunt; a siding; a switch.","pos":""}],"TURN-SICK":[{"def":"A disease with which sheep are sometimes affected; gid; sturdy.","pos":""}],"TURNBULL'S BLUE":[{"def":"The double cyanide of ferrous and ferric iron, a dark blue amorphous substance having a coppery luster, used in dyeing, calico printing, etc.","pos":""}],"TURNCOAT":[{"def":"One who forsakes his party or his principles; a renegade; an apostate.","pos":""}],"TURNDOWN":[{"def":"Capable of being turned down; specif.","pos":""},{"def":"Made to wear with the upper part turned down; as, a turndown collar.","pos":""}],"TURNER":[{"def":"A variety of pigeon; a tumbler.","pos":""}],"TURNERITE":[{"def":"A variety of monazite.","pos":""}],"TURNERY":[{"def":"The art of fashioning solid bodies into cylindrical or other forms by means of a lathe.","pos":""},{"def":"Things or forms made by a turner, or in the lathe.","pos":""}],"TURNHALLE":[{"def":"A building used as a school of gymnastics.","pos":""}],"TURNICIMORPHAE":[{"def":"A division of birds including Turnix and allied genera, resembling quails in appearance but differing from them anatomically.","pos":""}],"TURNING":[{"def":"The pieces, or chips, detached in the process of turning from the material turned.","pos":""},{"def":"A maneuver by which an enemy or a position is turned.","pos":""}],"TURNINGNESS":[{"def":"The quality of turning; instability; tergiversation.","pos":""}],"TURNIP":[{"def":"The edible, fleshy, roundish, or somewhat conical, root of a cruciferous plant (Brassica campestris, var.","pos":""}],"TURNIP-SHELL":[{"def":"Any one of several large, thick, spiral marine shells belonging to Rapa and allied genera, somewhat turnip-shaped.","pos":""}],"TURNIX":[{"def":"Any one of numerous species of birds belonging to Turnix or Hemipodius and allied genera of the family Turnicidæ.","pos":""}],"TURNKEY":[{"def":"An instrument with a hinged claw, -- used for extracting teeth with a twist.","pos":""}],"TURNOVER":[{"def":"The act or result of turning over; an upset; as, a bad turnover in a carriage.","pos":""},{"def":"A semicircular pie or tart made by turning one half of a circular crust over the other, inclosing the fruit or other materials.","pos":""}],"TURNPIKE":[{"def":"A beam filled with spikes to obstruct passage; a cheval-de- frise.","pos":""}],"TURNSPIT":[{"def":"A small breed of dogs having a long body and short crooked legs.","pos":""}],"TURNSTILE":[{"def":"A revolving frame in a footpath, preventing the passage of horses or cattle, but admitting that of persons; a turnpike.","pos":""},{"def":"A similar arrangement for registering the number of persons passing through a gateway, doorway, or the like.","pos":""}],"TURNSTONE":[{"def":"Any species of limicoline birds of the genera Strepsilas and Arenaria, allied to the plovers, especially the common American and European species (Strepsilas interpres).","pos":""}],"TURNTABLE":[{"def":"A large revolving platform, for turning railroad cars, locomotives, etc.","pos":""}],"TURNUS":[{"def":"A common, large, handsome, American swallowtail butterfly, now regarded as one of the forms of Papilio, or Jasoniades, glaucus.","pos":""}],"TURNVEREIN":[{"def":"A company or association of gymnasts and athletes.","pos":""}]}