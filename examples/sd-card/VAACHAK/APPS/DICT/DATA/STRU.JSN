{"STRUCTURAL":[{"def":"Of or pertaining to organit structure; as, a structural element or cell; the structural peculiarities of an animal or a plant.","pos":""}],"STRUCTURAL SHAPE":[{"def":"The shape of a member especially adapted to structural purposes, esp.","pos":""},{"def":"any steel or iron member of such shape, as channel irons, I beams, T beams, etc.","pos":""}],"STRUCTURE":[{"def":"Manner of organization; the arrangement of the different tissues or parts of animal and vegetable organisms; as, organic structure, or the structure of animals and plants; cellular structure.","pos":""}],"STRUCTURED":[{"def":"Having a definite organic structure; showing differentiation of parts.","pos":""}],"STRUCTURELESS":[{"def":"Without a definite structure, or arrangement of parts; without organization; devoid of cells; homogeneous; as, a structureless membrane.","pos":""}],"STRUCTURIST":[{"def":"One who forms structures; a builder; a constructor.","pos":""}],"STRUDE":[{"def":"A stock of breeding mares.","pos":""}],"STRUGGLE":[{"def":"To strive, or to make efforts, with a twisting, or with contortions of the body.","pos":""},{"def":"To use great efforts; to labor hard; to strive; to contend forcibly; as, to struggle to save one's life; to struggle with the waves; to struggle with adversity.","pos":""}],"STRUGGLER":[{"def":"One who struggles.","pos":""}],"STRULL":[{"def":"A bar so placed as to resist weight.","pos":""}],"STRUM":[{"def":"To play on an instrument of music, or as on an instrument, in an unskillful or noisy way; to thrum; as, to strum a piano.","pos":""}],"STRUMA":[{"def":"A cushionlike swelling on any organ; especially, that at the base of the capsule in many mosses.","pos":""}],"STRUMATIC":[{"def":"Scrofulous; strumous.","pos":""}],"STRUMOSE":[{"def":"Having a struma.","pos":""}],"STRUMOUS":[{"def":"Scrofulous; having struma.","pos":""}],"STRUMOUSNESS":[{"def":"The state of being strumous.","pos":""}],"STRUMPET":[{"def":"A prostitute; a harlot.","pos":""}],"STRUMSTRUM":[{"def":"A rude musical instrument somewhat like a cittern.","pos":""}],"STRUNT":[{"def":"Spirituous liquor.","pos":""}],"STRUNTIAN":[{"def":"A kind of worsted braid, about an inch broad.","pos":""}],"STRUSE":[{"def":"A Russian river craft used for transporting freight.","pos":""}],"STRUT":[{"def":"To swell; to bulge out.","pos":""},{"def":"To walk with a lofty, proud gait, and erect head; to walk with affected dignity.","pos":""}],"STRUTHIO":[{"def":"A genus of birds including the African ostriches.","pos":""}],"STRUTHIOIDEA":[{"def":"Same as Struthiones.","pos":""}],"STRUTHIOUS":[{"def":"Of or pertaining to the Struthiones, or Ostrich tribe.","pos":""}],"STRUVITE":[{"def":"A crystalline mineral found in guano.","pos":""}]}