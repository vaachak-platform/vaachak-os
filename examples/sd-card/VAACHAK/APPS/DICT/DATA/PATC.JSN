{"PATCH":[{"def":"A piece of greased cloth or leather used as wrapping for a rifle ball, to make it fit the bore.","pos":""},{"def":"A block on the muzzle of a gun, to do away with the effect of dispart, in sighting.","pos":""}],"PATCHER":[{"def":"One who patches or botches.","pos":""}],"PATCHERY":[{"def":"Botchery; covering of defects; bungling; hypocrisy.","pos":""}],"PATCHINGLY":[{"def":"Knavishy; deceitfully.","pos":""},{"def":"A mintlike plant (Pogostemon Patchouli) of the East Indies, yielding an essential oil from which a highly valued perfume is made.","pos":""}],"PATCHWORK":[{"def":"Work composed of pieces sewed together, esp.","pos":""}],"PATCHY":[{"def":"Full of, or covered with, patches; abounding in patches.","pos":""}]}