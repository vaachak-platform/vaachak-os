{"HAN":[{"def":"Him thanken all, and thus they han an end.","pos":""}],"HANAP":[{"def":"A rich goblet, esp.","pos":""}],"HANAPER":[{"def":"A kind of basket, usually of wickerwork, and adapted for the packing and carrying of articles; a hamper.","pos":""}],"HANCE":[{"def":"To raise; to elevate.","pos":""}],"HAND":[{"def":"The small part of a gunstock near the lock, which is grasped by the hand in taking aim.","pos":""}],"HAND-HOLE":[{"def":"A small hole in a boiler for the insertion of the hand in cleaning, etc.","pos":""}],"HAND-TIGHT":[{"def":"As tight as can be made by the hand.","pos":""}],"HAND-WINGED":[{"def":"Having wings that are like hands in the structure and arrangement of their bones; -- said of bats.","pos":""}],"HANDBALL":[{"def":"A ball for throwing or using with the hand.","pos":""},{"def":"A game played with such a ball, as by players striking it to and fro between them with the hands, or alternately against a wall, until one side or the other fails to return the ball.","pos":""}],"HANDBARROW":[{"def":"A frame or barrow, without a wheel, carried by hand.","pos":""}],"HANDBILL":[{"def":"A loose, printed sheet, to be distributed by hand.","pos":""}],"HANDBOOK":[{"def":"A book of reference, to be carried in the hand; a manual; a guidebook.","pos":""}],"HANDBREADTH":[{"def":"A space equal to the breadth of the hand; a palm.","pos":""}],"HANDCART":[{"def":"A cart drawn or pushed by hand.","pos":""}],"HANDCRAFT":[{"def":"Same as Handicraft.","pos":""}],"HANDCRAFTSMAN":[{"def":"A handicraftsman.","pos":""}],"HANDCUFF":[{"def":"A fastening, consisting of an iron ring around the wrist, usually connected by a chain with one on the other wrist; a manacle; -- usually in the plural.","pos":""}],"HANDED":[{"def":"With hands joined; hand in hand.","pos":""},{"def":"Having a peculiar or characteristic hand.","pos":""}],"HANDER":[{"def":"One who hands over or transmits; a conveyer in succession.","pos":""}],"HANDFAST":[{"def":"Hold; grasp; custody; power of confining or keeping.","pos":""},{"def":"Contract; specifically, espousal.","pos":""}],"HANDFASTLY":[{"def":"In a handfast or publicly pledged manner.","pos":""}],"HANDFUL":[{"def":"As much as the hand will grasp or contain.","pos":""},{"def":"A hand's breadth; four inches.","pos":""}],"HANDICAP":[{"def":"A race, for horses or men, or any contest of agility, strength, or skill, in which there is an allowance of time, distance, weight, or other advantage, to equalize the chances of the competitors.","pos":""}],"HANDICAPPER":[{"def":"One who determines the conditions of a handicap.","pos":""}],"HANDICRAFT":[{"def":"A trade requiring skill of hand; manual occupation; handcraft.","pos":""},{"def":"A man who earns his living by handicraft; a handicraftsman.","pos":""}],"HANDICRAFTSMAN":[{"def":"A man skilled or employed in handcraft.","pos":""}],"HANDILY":[{"def":"In a handy manner; skillfully; conveniently.","pos":""}],"HANDINESS":[{"def":"The quality or state of being handy.","pos":""}],"HANDIWORK":[{"def":"Work done by the hands; hence, any work done personally.","pos":""}],"HANDKERCHIEF":[{"def":"A piece of cloth, usually square and often fine and elegant, carried for wiping the face or hands.","pos":""},{"def":"A piece of cloth shaped like a handkerchief to be worn about the neck; a neckerchief; a neckcloth.","pos":""}],"HANDLE":[{"def":"To touch; to feel with the hand; to use or hold with the hand.","pos":""},{"def":"To manage in using, as a spade or a musket; to wield; often, to manage skillfully.","pos":""}],"HANDLEABLE":[{"def":"Capable of being handled.","pos":""}],"HANDLING":[{"def":"The mode of using the pencil or brush, etc.","pos":""}],"HANDMADE":[{"def":"Manufactured by hand; as, handmade shoes.","pos":""},{"def":"A maid that waits at hand; a female servant or attendant.","pos":""}],"HANDSAW":[{"def":"A saw used with one hand.","pos":""}],"HANDSEL":[{"def":"Their first good handsel of breath in this world.","pos":""}],"HANDSOME":[{"def":"Dexterous; skillful; handy; ready; convenient; -- applied to things as persons.","pos":""},{"def":"Agreeable to the eye or to correct taste; having a pleasing appearance or expression; attractive; having symmetry and dignity; comely; -- expressing more than pretty, and less than beautiful; as, a handsome man or woman; a handsome garment, house, tree, horse.","pos":""}],"HANDSOMELY":[{"def":"Carefully; in shipshape style.","pos":""}],"HANDSOMENESS":[{"def":"The quality of being handsome.","pos":""}],"HANDSPIKE":[{"def":"A bar or lever, generally of wood, used in a windlass or capstan, for heaving anchor, and, in modified forms, for various purposes.","pos":""}],"HANDSPRING":[{"def":"A somersault made with the assistance of the hands placed upon the ground.","pos":""}],"HANDWHEEL":[{"def":"Any wheel worked by hand; esp.","pos":""}],"HANDWRITING":[{"def":"The cast or form of writing peculiar to each hand or person; chirography.","pos":""},{"def":"That which is written by hand; manuscript.","pos":""}],"HANDY":[{"def":"Easily managed; obedient to the helm; -- said of a vessel.","pos":""}],"HANDY-DANDY":[{"def":"A child's play, one child guessing in which closed hand the other holds some small object, winning the object if right and forfeiting an equivalent if wrong; hence, forfeit.","pos":""}],"HANDYFIGHT":[{"def":"A fight with the hands; boxing.","pos":""}],"HANDYGRIPE":[{"def":"Seizure by, or grasp of, the hand; also, close quarters in fighting.","pos":""}],"HANDYSTROKE":[{"def":"A blow with the hand.","pos":""}],"HANG":[{"def":"To suspend; to fasten to some elevated point without support from below; -- often used with up or out; as, to hang a coat on a hook; to hang up a sign; to hang out a banner.","pos":""},{"def":"To fasten in a manner which will allow of free motion upon the point or points of suspension; -- said of a pendulum, a swing, a door, gate, etc.","pos":""}],"HANG-BY":[{"def":"A dependent; a hanger-on; -- so called in contempt.","pos":""}],"HANGBIRD":[{"def":"The Baltimore oriole (Icterus galbula); -- so called because its nest is suspended from the limb of a tree.","pos":""}],"HANGDOG":[{"def":"A base, degraded person; a sneak; a gallows bird.","pos":""}],"HANGER":[{"def":"One who hangs, or causes to be hanged; a hangman.","pos":""},{"def":"That by which a thing is suspended.","pos":""}],"HANGER-ON":[{"def":"One who hangs on, or sticks to, a person, place, or service; a dependent; one who adheres to others' society longer than he is wanted.","pos":""}],"HANGING":[{"def":"Requiring, deserving, or foreboding death by the halter.","pos":""},{"def":"Suspended from above; pendent; as, hanging shelves.","pos":""}],"HANGMAN":[{"def":"One who hangs another; esp.","pos":""}],"HANGMANSHIP":[{"def":"The office or character of a hangman.","pos":""}],"HANGNAIL":[{"def":"A small piece or silver of skin which hangs loose, near the root of finger nail.","pos":""}],"HANGNEST":[{"def":"A nest that hangs like a bag or pocket.","pos":""},{"def":"A bird which builds such a nest; a hangbird.","pos":""}],"HANK":[{"def":"A ring or eye of rope, wood, or iron, attached to the edge of a sail and running on a stay.","pos":""}],"HANKER":[{"def":"To long (for) with a keen appetite and uneasiness; to have a vehement desire; -- usually with for or after; as, to hanker after fruit; to hanker after the diversions of the town.","pos":""},{"def":"To linger in expectation or with desire.","pos":""}],"HANKERINGLY":[{"def":"In a hankering manner.","pos":""}],"HANKEY-PANKEY":[{"def":"Professional cant; the chatter of conjurers to divert attention from their tricks; hence, jugglery.","pos":""}],"HANOVERIAN":[{"def":"Of or pertaining to Hanover or its people, or to the House of Hanover in England.","pos":""}],"HANSARD":[{"def":"An official report of proceedings in the British Parliament; -- so called from the name of the publishers.","pos":""}],"HANSE":[{"def":"That part of an elliptical or many-centered arch which has the shorter radius and immediately adjoins the impost.","pos":""}],"HANSEATIC":[{"def":"Pertaining to the Hanse towns, or to their confederacy.","pos":""}],"HANSELINES":[{"def":"A sort of breeches.","pos":""},{"def":"A light, low, two-wheeled covered carriage with the driver's seat elevated behind, the reins being passed over the top.","pos":""}]}