{"ELENCHICAL":[{"def":"Pertaining to an elench.","pos":""}],"ELENCHICALLY":[{"def":"By means of an elench.","pos":""}],"ELENCHIZE":[{"def":"Same as Elenctic.","pos":""}],"ELENCHUS":[{"def":"Serving to refute; refutative; -- applied to indirect modes of proof, and opposed to deictic.","pos":""}],"ELENGE":[{"def":"Sorrowful; wretched; full of trouble.","pos":""}],"ELENGENESS":[{"def":"Loneliness; misery.","pos":""}]}