{"BRAMAH PRESS":[{"def":"A hydrostatic press of immense power, invented by Joseph Bramah of London.","pos":""}],"BRAMBLE":[{"def":"Any plant of the genus Rubus, including the raspberry and blackberry.","pos":""},{"def":"The brambling or bramble finch.","pos":""}],"BRAMBLE BUSH":[{"def":"The bramble, or a collection of brambles growing together.","pos":""}],"BRAMBLE NET":[{"def":"A net to catch birds.","pos":""}],"BRAMBLED":[{"def":"Overgrown with brambles.","pos":""}],"BRAMBLING":[{"def":"The European mountain finch (Fringilla montifringilla); -- called also bramble finch and bramble.","pos":""}],"BRAMBLY":[{"def":"Pertaining to, resembling, or full of, brambles.","pos":""}],"BRAME":[{"def":"Sharp passion; vexation.","pos":""}]}