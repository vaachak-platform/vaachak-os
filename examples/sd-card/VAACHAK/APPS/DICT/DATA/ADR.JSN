{"ADRAD":[{"def":"Put in dread; afraid.","pos":""}],"ADREAMED":[{"def":"Visited by a dream; -- used in the phrase, To be adreamed, to dream.","pos":""}],"ADRENAL":[{"def":"A crystalline substance, C9H13O3N, obtained from suprarenal extract, of which it is regarded as the active principle.","pos":""}],"ADRIAN":[{"def":"Pertaining to the Adriatic Sea; as, Adrian billows.","pos":""}],"ADRIATIC":[{"def":"Of or pertaining to a sea so named, the northwestern part of which is known as the Gulf of Venice.","pos":""}],"ADRIFT":[{"def":"Floating at random; in a drifting condition; at the mercy of wind and waves.","pos":""}],"ADRIP":[{"def":"In a dripping state; as, leaves all adrip.","pos":""}],"ADROGATE":[{"def":"To adopt (a person who is his own master).","pos":""}],"ADROGATION":[{"def":"A kind of adoption in ancient Rome.","pos":""}],"ADROIT":[{"def":"Dexterous in the use of the hands or in the exercise of the mental faculties; exhibiting skill and readiness in avoiding danger or escaping difficulty; ready in invention or execution; -- applied to persons and to acts; as, an adroit mechanic, an adroit reply.","pos":""}],"ADROITLY":[{"def":"In an adroit manner.","pos":""}],"ADROITNESS":[{"def":"The quality of being adroit; skill and readiness; dexterity.","pos":""}],"ADRY":[{"def":"In a dry or thirsty condition.","pos":""}]}