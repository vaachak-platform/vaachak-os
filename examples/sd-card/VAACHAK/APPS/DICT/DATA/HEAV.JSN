{"HEAVE":[{"def":"To cause to move upward or onward by a lifting effort; to lift; to raise; to hoist; -- often with up; as, the wave heaved the boat on land.","pos":""},{"def":"To throw; to cast; -- obsolete, provincial, or colloquial, except in certain nautical phrases; as, to heave the lead; to heave the log.","pos":""}],"HEAVE OFFERING":[{"def":"An offering or oblation heaved up or elevated before the altar, as the shoulder of the peace offering.","pos":""}],"HEAVEN":[{"def":"The expanse of space surrounding the earth; esp.","pos":""},{"def":"The dwelling place of the Deity; the abode of bliss; the place or state of the blessed after death.","pos":""}],"HEAVENIZE":[{"def":"To render like heaven or fit for heaven.","pos":""}],"HEAVENLINESS":[{"def":"The state or quality of being heavenly.","pos":""}],"HEAVENLY":[{"def":"Pertaining to, resembling, or inhabiting heaven; celestial; not earthly; as, heavenly regions; heavenly music.","pos":""},{"def":"Appropriate to heaven in character or happiness; perfect; pure; supremely blessed; as, a heavenly race; the heavenly, throng.","pos":""}],"HEAVENWARD":[{"def":"Heav\"en*ward, a & adv.","pos":""}],"HEAVER":[{"def":"A bar used as a lever.","pos":""}],"HEAVES":[{"def":"A disease of horses, characterized by difficult breathing, with heaving of the flank, wheezing, flatulency, and a peculiar cough; broken wind.","pos":""}],"HEAVILY":[{"def":"subject to much traffic or travel; as, the region's most heavily traveled highways.","pos":""}],"HEAVINESS":[{"def":"The state or quality of being heavy in its various senses; weight; sadness; sluggishness; oppression; thickness.","pos":""}],"HEAVING":[{"def":"A lifting or rising; a swell; a panting or deep sighing.","pos":""}],"HEAVY":[{"def":"Having the heaves.","pos":""}],"HEAVY SPAR":[{"def":"Native barium sulphate or barite, -- so called because of its high specific gravity as compared with other non-metallic minerals.","pos":""}],"HEAVY-ARMED":[{"def":"Wearing heavy or complete armor; carrying heavy arms.","pos":""}],"HEAVY-HADED":[{"def":"Clumsy; awkward.","pos":""}]}