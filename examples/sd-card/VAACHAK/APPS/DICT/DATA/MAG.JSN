{"MAGAZINE":[{"def":"A receptacle in which anything is stored, especially military stores, as ammunition, arms, provisions, etc.","pos":""},{"def":"The building or room in which the supply of powder is kept in a fortification or a ship.","pos":""}],"MAGAZINE CAMERA":[{"def":"A camera in which a number of plates can be exposed without reloading.","pos":""}],"MAGAZINER":[{"def":"One who edits or writes for a magazine.","pos":""}],"MAGAZINING":[{"def":"The act of editing, or writing for, a magazine.","pos":""}],"MAGAZINIST":[{"def":"One who edits or writes for a magazine.","pos":""}],"MAGDALA":[{"def":"Designating an orange-red dyestuff obtained from naphthylamine, and called magdala red, naphthalene red, etc.","pos":""}],"MAGDALEN":[{"def":"A reformed prostitute.","pos":""}],"MAGDALEON":[{"def":"A medicine in the form of a roll, a esp.","pos":""}],"MAGDEBURG":[{"def":"A city of Saxony.","pos":""}],"MAGELLANIC":[{"def":"Of or pertaining to, or named from, Magellan, the navigator.","pos":""}],"MAGENTA":[{"def":"An aniline dye obtained as an amorphous substance having a green bronze surface color, which dissolves to a shade of red; also, the color; -- so called from Magenta, in Italy, in allusion to the battle fought there about the time the dye was discovered.","pos":""}],"MAGGED":[{"def":"Worn; fretted; as, a magged brace.","pos":""}],"MAGGIORE":[{"def":"Greater, in respect to scales, intervals, etc.","pos":""}],"MAGGOT":[{"def":"The footless larva of any fly.","pos":""}],"MAGGOTINESS":[{"def":"State of being maggoty.","pos":""}],"MAGGOTISH":[{"def":"Full of whims or fancies; maggoty.","pos":""}],"MAGGOTY":[{"def":"Infested with maggots.","pos":""},{"def":"Full of whims; capricious.","pos":""}],"MAGHET":[{"def":"A name for daisies and camomiles of several kinds.","pos":""}],"MAGI":[{"def":"A caste of priests, philosophers, and magicians, among the ancient Persians; hence, any holy men or sages of the East.","pos":""}],"MAGIAN":[{"def":"Of or pertaining to the Magi.","pos":""}],"MAGIC":[{"def":"Pertaining to the hidden wisdom supposed to be possessed by the Magi; relating to the occult powers of nature, and the producing of effects by their agency.","pos":""},{"def":"Performed by, or proceeding from, occult and superhuman agencies; done by, or seemingly done by, enchantment or sorcery.","pos":""}],"MAGICALLY":[{"def":"In a magical manner; by magic, or as if by magic.","pos":""}],"MAGICIAN":[{"def":"One skilled in magic; one who practices the black art; an enchanter; a necromancer; a sorcerer or sorceress; a conjurer.","pos":""}],"MAGISTER":[{"def":"Master; sir; -- a title of the Middle Ages, given to a person in authority, or to one having a license from a university to teach philosophy and the liberal arts.","pos":""}],"MAGISTERIAL":[{"def":"Pertaining to, produced by, or of the nature of, magistery.","pos":""}],"MAGISTERIALITY":[{"def":"Magisterialness; authoritativeness.","pos":""}],"MAGISTERIALLY":[{"def":"In a magisterial manner.","pos":""}],"MAGISTERIALNESS":[{"def":"The quality or state of being magisterial.","pos":""}],"MAGISTERY":[{"def":"A precipitate; a fine substance deposited by precipitation; -- applied in old chemistry to certain white precipitates from metallic solutions; as, magistery of bismuth.","pos":""}],"MAGISTRACY":[{"def":"The office or dignity of a magistrate.","pos":""},{"def":"The collective body of magistrates.","pos":""}],"MAGISTRAL":[{"def":"Formulated extemporaneously, or for a special case; -- opposed to officinal, and said of prescriptions and medicines.","pos":""}],"MAGISTRALITY":[{"def":"Magisterialness; arbitrary dogmatism.","pos":""}],"MAGISTRALLY":[{"def":"In a magistral manner.","pos":""}],"MAGISTRATE":[{"def":"A person clothed with power as a public civil officer; a public civil officer invested with the executive government, or some branch of it.","pos":""},{"def":"Of, pertaining to, or proceeding from, a magistrate; having the authority of a magistrate.","pos":""}],"MAGMA":[{"def":"The amorphous or homogenous matrix or ground mass, as distinguished from well-defined crystals; as, the magma of porphyry.","pos":""}],"MAGNA CHARTA":[{"def":"The great Charter, so called, obtained by the English barons from King John, A.","pos":""},{"def":"Hence, a fundamental constitution which guaranties rights and privileges.","pos":""}],"MAGNALITY":[{"def":"A great act or event; a great attainment.","pos":""}],"MAGNANIMOUS":[{"def":"Great of mind; elevated in soul or in sentiment; raised above what is low, mean, or ungenerous; of lofty and courageous spirit; as, a magnanimous character; a magnanimous conqueror.","pos":""},{"def":"Dictated by or exhibiting nobleness of soul; honorable; noble; not selfish.","pos":""}],"MAGNANIMOUSLY":[{"def":"In a magnanimous manner; with greatness of mind.","pos":""}],"MAGNASE BLACK":[{"def":"A black pigment which dries rapidly when mixed with oil, and is of intense body.","pos":""}],"MAGNATE":[{"def":"A person of rank; a noble or grandee; a person of influence or distinction in any sphere.","pos":""},{"def":"One of the nobility, or certain high officers of state belonging to the noble estate in the national representation of Hungary, and formerly of Poland.","pos":""}],"MAGNESIA":[{"def":"A light earthy white substance, consisting of magnesium oxide, and obtained by heating magnesium hydrate or carbonate, or by burning magnesium.","pos":""}],"MAGNESIAN":[{"def":"Pertaining to, characterized by, or containing, magnesia or magnesium.","pos":""}],"MAGNESIC":[{"def":"Pertaining to, or containing, magnesium; as, magnesic oxide.","pos":""}],"MAGNESITE":[{"def":"Native magnesium carbonate occurring in white compact or granular masses, and also in rhombohedral crystals.","pos":""}],"MAGNESIUM":[{"def":"A light silver-white metallic element, malleable and ductile, quite permanent in dry air but tarnishing in moist air.","pos":""}],"MAGNET":[{"def":"A bar or mass of steel or iron to which the peculiar properties of the loadstone have been imparted; -- called, in distinction from the loadstone, an artificial magnet.","pos":""}],"MAGNETIC":[{"def":"Any metal, as iron, nickel, cobalt, etc.","pos":""}],"MAGNETICALLY":[{"def":"By or as by, magnetism.","pos":""}],"MAGNETICALNESS":[{"def":"Quality of being magnetic.","pos":""}],"MAGNETICIAN":[{"def":"One versed in the science of magnetism; a magnetist.","pos":""}],"MAGNETICS":[{"def":"The science of magnetism.","pos":""}],"MAGNETIFEROUS":[{"def":"Producing or conducting magnetism.","pos":""}],"MAGNETISM":[{"def":"The property, quality, or state, of being magnetic; the manifestation of the force in nature which is seen in a magnet.","pos":""}],"MAGNETIST":[{"def":"One versed in magnetism.","pos":""}],"MAGNETITE":[{"def":"An oxide of iron (Fe3O4) occurring in isometric crystals, also massive, of a black color and metallic luster.","pos":""}],"MAGNETIZABLE":[{"def":"Capable of magnetized.","pos":""}],"MAGNETIZATION":[{"def":"The act of magnetizing, or the state of being magnetized.","pos":""}],"MAGNETIZE":[{"def":"To communicate magnetic properties to; as, to magnetize a needle.","pos":""},{"def":"To attract as a magnet attracts, or like a magnet; to move; to influence.","pos":""}],"MAGNETIZEE":[{"def":"A person subjected to the influence of animal magnetism.","pos":""}],"MAGNETIZER":[{"def":"One who, or that which, imparts magnetism.","pos":""}],"MAGNETO-":[{"def":"A prefix meaning pertaining to, produced by, or in some way connected with, magnetism.","pos":""},{"def":"Pertaining to, or characterized by, electricity by the action of magnets; as, magneto-electric induction.","pos":""}],"MAGNETO-ELECTRICITY":[{"def":"That branch of science which treats of the development of electricity by the action of magnets; -- the counterpart of electro- magnetism.","pos":""}],"MAGNETOGRAPH":[{"def":"An automatic instrument for registering, by photography or otherwise, the states and variations of any of the terrestrial magnetic elements.","pos":""}],"MAGNETOMETER":[{"def":"An instrument for measuring the intensity of magnetic forces; also, less frequently, an instrument for determining any of the terrestrial magnetic elements, as the dip and declination.","pos":""}],"MAGNETOMETRIC":[{"def":"Pertaining to, or employed in, the measurement of magnetic forces; obtained by means of a magnetometer; as, magnetometric instruments; magnetometric measurements.","pos":""}],"MAGNETOMOTIVE":[{"def":"Pertaining to, or designating, a force producing magnetic flux, analogous to electromotive force, and equal to the magnetic flux multiplied by the magnetic reluctance.","pos":""}],"MAGNETOMOTOR":[{"def":"A voltaic series of two or more large plates, producing a great quantity of electricity of low tension, and hence adapted to the exhibition of electro-magnetic phenomena.","pos":""}],"MAGNETOTHERAPY":[{"def":"The treatment of disease by the application of magnets to the surface of the body.","pos":""}],"MAGNIFIABLE":[{"def":"Such as can be magnified, or extolled.","pos":""},{"def":"Grand; splendid; illustrious; magnificent.","pos":""}],"MAGNIFICAT":[{"def":"The song of the Virgin Mary, Luke i.","pos":""}],"MAGNIFICATE":[{"def":"To magnify or extol.","pos":""}],"MAGNIFICATION":[{"def":"The act of magnifying; enlargement; exaggeration.","pos":""}],"MAGNIFICENCE":[{"def":"The act of doing what magnificent; the state or quality of being magnificent.","pos":""}],"MAGNIFICENT":[{"def":"Doing grand things; admirable in action; displaying great power or opulence, especially in building, way of living, and munificence.","pos":""},{"def":"Grand in appearance; exhibiting grandeur or splendor; splendid' pompous.","pos":""}],"MAGNIFICENTLY":[{"def":"In a Magnificent manner.","pos":""}],"MAGNIFICO":[{"def":"A grandee or nobleman of Venice; -- so called in courtesy.","pos":""},{"def":"A rector of a German university.","pos":""}],"MAGNIFIER":[{"def":"One who, or that which, magnifies.","pos":""}],"MAGNIFY":[{"def":"To make great, or greater; to increase the dimensions of; to amplify; to enlarge, either in fact or in appearance; as, the microscope magnifies the object by a thousand diameters.","pos":""},{"def":"To increase the importance of; to augment the esteem or respect in which one is held.","pos":""}],"MAGNILOQUENCE":[{"def":"The quality of being magniloquent; pompous discourse; grandiloquence.","pos":""}],"MAGNILOQUENT":[{"def":"Speaking pompously; using swelling discourse; bombastic; tumid in style; grandiloquent.","pos":""}],"MAGNITUDE":[{"def":"That which has one or more of the three dimensions, length, breadth, and thickness.","pos":""}],"MAGNOLIA":[{"def":"A genus of American and Asiatic trees, with aromatic bark and large sweet-scented whitish or reddish flowers.","pos":""}],"MAGNOLIACEOUS":[{"def":"Pertaining to a natural order (Magnoliaceæ) of trees of which the magnolia, the tulip tree, and the star anise are examples.","pos":""}],"MAGNUM":[{"def":"A bone of the carpus at the base of the third metacarpal bone.","pos":""}],"MAGOT":[{"def":"The Barbary ape.","pos":""}],"MAGPIE":[{"def":"Any one of numerous species of the genus Pica and related genera, allied to the jays, but having a long graduated tail.","pos":""}],"MAGUARI":[{"def":"A South American stork (Euxenara maguari), having a forked tail.","pos":""}],"MAGUEY":[{"def":"The century plant, a species of Agave (A.","pos":""}],"MAGYAR":[{"def":"One of the dominant people of Hungary, allied to the Finns; a Hungarian.","pos":""}]}