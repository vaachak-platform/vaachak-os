{"PLAID":[{"def":"A rectangular garment or piece of cloth, usually made of the checkered material called tartan, but sometimes of plain gray, or gray with black stripes.","pos":""},{"def":"Goods of any quality or material of the pattern of a plaid or tartan; a checkered cloth or pattern.","pos":""}],"PLAIDED":[{"def":"Of the material of which plaids are made; tartan.","pos":""},{"def":"Wearing a plaid.","pos":""}],"PLAIN":[{"def":"To lament; to bewail; to complain.","pos":""}],"PLAIN-DEALING":[{"def":"Practicing plain dealing; artless.","pos":""}],"PLAIN-HEARTED":[{"def":"Frank; sincere; artless.","pos":""}],"PLAIN-LAID":[{"def":"Consisting of strands twisted together in the ordinary way; as, a plain-laid rope.","pos":""}],"PLAIN-SPOKEN":[{"def":"Speaking with plain, unreserved sincerity; also, spoken sincerely; as, plain-spoken words.","pos":""}],"PLAINANT":[{"def":"One who makes complaint; the plaintiff.","pos":""}],"PLAINLY":[{"def":"In a plain manner; clearly.","pos":""}],"PLAINNESS":[{"def":"The quality or state of being plain.","pos":""}],"PLAINSMAN":[{"def":"One who lives in the plains.","pos":""}],"PLAINT":[{"def":"A private memorial tendered to a court, in which a person sets forth his cause of action; the exhibiting of an action in writing.","pos":""}],"PLAINTFUL":[{"def":"Containing a plaint; complaining; expressing sorrow with an audible voice.","pos":""}],"PLAINTIFF":[{"def":"One who commences a personal action or suit to obtain a remedy for an injury to his rights; -- opposed to Ant: defendant.","pos":""}],"PLAINTIVE":[{"def":"Repining; complaining; lamenting.","pos":""},{"def":"Expressive of sorrow or melancholy; mournful; sad.","pos":""}],"PLAINTLESS":[{"def":"Without complaint; unrepining.","pos":""}],"PLAIT":[{"def":"A flat fold; a doubling, as of cloth; a pleat; as, a box plait.","pos":""},{"def":"A braid, as of hair or straw; a plat.","pos":""}],"PLAITED":[{"def":"Folded; doubled over; braided; figuratively, involved; intricate; artful.","pos":""}],"PLAITER":[{"def":"One who, or that which, plaits.","pos":""}]}