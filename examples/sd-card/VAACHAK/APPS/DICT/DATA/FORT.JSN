{"FORT":[{"def":"A strong or fortified place; usually, a small fortified place, occupied only by troops, surrounded with a ditch, rampart, and parapet, or with palisades, stockades, or other means of defense; a fortification.","pos":""}],"FORTALICE":[{"def":"A small outwork of a fortification; a fortilage; -- called also fortelace.","pos":""}],"FORTE":[{"def":"The strong point; that in which one excels.","pos":""},{"def":"The stronger part of the blade of a sword; the part of half nearest the hilt; -- opposed to foible.","pos":""}],"FORTED":[{"def":"Furnished with, or guarded by, forts; strengthened or defended, as by forts.","pos":""}],"FORTH":[{"def":"Forward; onward in time, place, or order; in advance from a given point; on to end; as, from that day forth; one, two, three, and so forth.","pos":"verb"},{"def":"Out, as from a state of concealment, retirement, confinement, nondevelopment, or the like; out into notice or view; as, the plants in spring put forth leaves.","pos":"verb"}],"FORTHCOMING":[{"def":"Ready or about to appear; making appearance.","pos":""}],"FORTHGOING":[{"def":"A going forth; an utterance.","pos":""}],"FORTHINK":[{"def":"To repent; to regret; to be sorry for; to cause regret.","pos":""}],"FORTHPUTING":[{"def":"Bold; forward; aggressive.","pos":""}],"FORTHRIGHT":[{"def":"Straight forward; in a straight direction.","pos":""}],"FORTHRIGHTNESS":[{"def":"Straightforwardness; explicitness; directness.","pos":""}],"FORTHWITH":[{"def":"As soon as the thing required may be done by reasonable exertion confined to that object.","pos":""}],"FORTIETH":[{"def":"Following the thirty-ninth, or preceded by thirty-nine units, things, or parts.","pos":""},{"def":"Constituting one of forty equal parts into which anything is divided.","pos":""}],"FORTIFIABLE":[{"def":"Capable of being fortified.","pos":""}],"FORTIFICATION":[{"def":"The act of fortifying; the art or science of fortifying places in order to defend them against an enemy.","pos":""},{"def":"That which fortifies; especially, a work or works erected to defend a place against attack; a fortified place; a fortress; a fort; a castle.","pos":""}],"FORTIFIER":[{"def":"One who, or that which, fortifies, strengthens, supports, or upholds.","pos":""}],"FORTIFY":[{"def":"To add strength to; to strengthen; to confirm; to furnish with power to resist attack.","pos":""},{"def":"To strengthen and secure by forts or batteries, or by surrounding with a wall or ditch or other military works; to render defensible against an attack by hostile forces.","pos":""}],"FORTILAGE":[{"def":"A little fort; a blockhouse.","pos":""}],"FORTIN":[{"def":"A little fort; a fortlet.","pos":""}],"FORTISSIMO":[{"def":"Very loud; with the utmost strength or loudness.","pos":""}],"FORTITION":[{"def":"Casual choice; fortuitous selection; hazard.","pos":""}],"FORTITUDE":[{"def":"Power to resist attack; strength; firmness.","pos":""},{"def":"That strength or firmness of mind which enables a person to encounter danger with coolness and courage, or to bear pain or adversity without murmuring, depression, or despondency; passive courage; resolute endurance; firmness in confronting or bearing up against danger or enduring trouble.","pos":""}],"FORTITUDINOUS":[{"def":"Having fortitude; courageous.","pos":""}],"FORTNIGHT":[{"def":"The space of fourteen days; two weeks.","pos":""}],"FORTNIGHTLY":[{"def":"Occurring or appearing once in a fortnight; as, a fortnightly meeting of a club; a fortnightly magazine, or other publication.","pos":""},{"def":"Once in a fortnight; at intervals of a fortnight.","pos":""}],"FORTREAD":[{"def":"To tread down; to trample upon.","pos":""}],"FORTRESS":[{"def":"A fortified place; a large and permanent fortification, sometimes including a town; a fort; a castle; a stronghold; a place of defense or security.","pos":""}],"FORTUITOUS":[{"def":"Happening independently of human will or means of foresight; resulting from unavoidable physical causes.","pos":""}],"FORTUITY":[{"def":"Accident; chance; casualty.","pos":""}],"FORTUNATE":[{"def":"Coming by good luck or favorable chance; bringing some good thing not foreseen as certain; presaging happiness; auspicious; as, a fortunate event; a fortunate concurrence of circumstances; a fortunate investment.","pos":""},{"def":"Receiving same unforeseen or unexpected good, or some good which was not dependent on one's own skill or efforts; favored with good forune; lucky.","pos":""}],"FORTUNATELY":[{"def":"In a fortunate manner; luckily; successfully; happily.","pos":""}],"FORTUNATENESS":[{"def":"The condition or quality of being fortunate; good luck; success; happiness.","pos":""}],"FORTUNE":[{"def":"The arrival of something in a sudden or unexpected manner; chance; accident; luck; hap; also, the personified or deified power regarded as determining human success, apportioning happiness and unhappiness, and distributing arbitrarily or fortuitously the lots of life.","pos":""},{"def":"That which befalls or is to befall one; lot in life, or event in any particular undertaking; fate; destiny; as, to tell one's fortune.","pos":""}],"FORTUNELESS":[{"def":"Luckless; also, destitute of a fortune or portion.","pos":""}],"FORTUNIZE":[{"def":"To regulate the fortune of; to make happy.","pos":""}],"FORTY":[{"def":"Four times ten; thirtynine and one more.","pos":""}],"FORTY-NINER":[{"def":"One of those who went to California in the rush for gold in 1849; an argonaut.","pos":""}],"FORTY-SPOT":[{"def":"The Tasmanian forty-spotted diamond bird (Pardalotus quadragintus).","pos":""}]}