{"SHAB":[{"def":"The itch in animals; also, a scab.","pos":""}],"SHABBILY":[{"def":"In a shabby manner.","pos":""}],"SHABBINESS":[{"def":"The quality or state of being sghabby.","pos":"noun"},{"def":"A kind of crooked sword or hanger.","pos":"noun"}],"SHABBY":[{"def":"Torn or worn to rage; poor; mean; ragged.","pos":""},{"def":"Clothed with ragged, much worn, or soiled garments.","pos":""}],"SHABRACK":[{"def":"The saddlecloth or housing of a cavalry horse.","pos":""}]}