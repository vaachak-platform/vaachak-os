{"HEP":[{"def":"See Hip, the fruit of the dog-rose.","pos":""}],"HEP TREE":[{"def":"The wild dog-rose.","pos":""}],"HEPAR":[{"def":"Liver of sulphur; a substance of a liver-brown color, sometimes used in medicine.","pos":""}],"HEPATIC":[{"def":"Pertaining to, or resembling, the plants called Hepaticæ, or scale mosses and liverworts.","pos":""}],"HEPATICA":[{"def":"A genus of pretty spring flowers closely related to Anemone; squirrel cup.","pos":""},{"def":"Any plant, usually procumbent and mosslike, of the cryptogamous class Hepaticæ; -- called also scale moss and liverwort.","pos":""}],"HEPATITE":[{"def":"A variety of barite emitting a fetid odor when rubbed or heated.","pos":""}],"HEPATITIS":[{"def":"Inflammation of the liver.","pos":""}],"HEPATIZATION":[{"def":"Impregnating with sulphureted hydrogen gas.","pos":""},{"def":"Conversion into a substance resembling the liver; a state of the lungs when gorged with effused matter, so that they are no longer pervious to the air.","pos":""}],"HEPATIZE":[{"def":"To impregnate with sulphureted hydrogen gas, formerly called hepatic gas.","pos":""},{"def":"To gorge with effused matter, as the lungs.","pos":""}],"HEPATO-PANCREAS":[{"def":"A digestive gland in Crustacea, Mollusca, etc.","pos":""}],"HEPATOCELE":[{"def":"Hernia of the liver.","pos":""}],"HEPATOCYSTIC":[{"def":"Of or pertaining to the liver and gall bladder; as, the hepatocystic ducts.","pos":""}],"HEPATOGASTRIC":[{"def":"See Gastrohepatic.","pos":""},{"def":"Arising from the liver; due to a condition of the liver; as, hepatogenic jaundice.","pos":""}],"HEPATOLOGY":[{"def":"The science which treats of the liver; a treatise on the liver.","pos":""}],"HEPATORENAL":[{"def":"Of or pertaining to the liver and kidneys; as, the hepatorenal ligament.","pos":""}],"HEPATOSCOPY":[{"def":"Divination by inspecting the liver of animals.","pos":""}],"HEPPELWHITE":[{"def":"Designating a light and elegant style developed in England under George III.","pos":""}],"HEPPEN":[{"def":"Neat; fit; comfortable.","pos":""}],"HEPPER":[{"def":"A young salmon; a parr.","pos":""}],"HEPTA":[{"def":"A combining form from Gr.","pos":""}],"HEPTACHORD":[{"def":"A composition sung to the sound of seven chords or tones.","pos":""}],"HEPTAD":[{"def":"An atom which has a valence of seven, and which can be theoretically combined with, substituted for, or replaced by, seven monad atoms or radicals; as, iodine is a heptad in iodic acid.","pos":""}],"HEPTADE":[{"def":"The sum or number of seven.","pos":""}],"HEPTAGLOT":[{"def":"A book in seven languages.","pos":""}],"HEPTAGON":[{"def":"A plane figure consisting of seven sides and having seven angles.","pos":""}],"HEPTAGONAL":[{"def":"Having seven angles or sides.","pos":""}],"HEPTAGYNIA":[{"def":"A Linnæan order of plants having seven pistils.","pos":""},{"def":"Having seven pistils.","pos":""}],"HEPTAHEDRON":[{"def":"A solid figure with seven sides.","pos":""}],"HEPTAMEROUS":[{"def":"Consisting of seven parts, or having the parts in sets of sevens.","pos":""}],"HEPTANDRIA":[{"def":"A Linnæan class of plants having seven stamens.","pos":""},{"def":"Having seven stamens.","pos":""}],"HEPTANE":[{"def":"Any one of several isometric hydrocarbons, C7H16, of the paraffin series (nine are possible, four are known); -- so called because the molecule has seven carbon atoms.","pos":""}],"HEPTANGULAR":[{"def":"Having seven angles.","pos":""}],"HEPTAPHYLLOUS":[{"def":"Having seven leaves.","pos":""}],"HEPTARCH":[{"def":"Same as Heptarchist.","pos":""}],"HEPTARCHIC":[{"def":"Of or pertaining to a heptarchy; constituting or consisting of a heptarchy.","pos":""}],"HEPTARCHIST":[{"def":"A ruler of one division of a heptarchy.","pos":""}],"HEPTARCHY":[{"def":"A government by seven persons; also, a country under seven rulers.","pos":""}],"HEPTASPERMOUS":[{"def":"Having seven seeds.","pos":""}],"HEPTASTICH":[{"def":"A composition consisting of seven lines or verses.","pos":""}],"HEPTATEUCH":[{"def":"The first seven books of the Testament.","pos":""}],"HEPTAVALENT":[{"def":"Having seven units of attractive force or affinity; -- said of heptad elements or radicals.","pos":""}],"HEPTENE":[{"def":"Same as Heptylene.","pos":""}],"HEPTINE":[{"def":"Any one of a series of unsaturated metameric hydrocarbons, C7H12, of the acetylene series.","pos":""}],"HEPTOIC":[{"def":"Pertaining to, or derived from, heptane; as, heptoic acid.","pos":""}],"HEPTONE":[{"def":"A liquid hydrocarbon, C7H10, of the valylene series.","pos":""}],"HEPTYL":[{"def":"A compound radical, C7H15, regarded as the essential radical of heptane and a related series of compounds.","pos":""}],"HEPTYLENE":[{"def":"A colorless liquid hydrocarbon, C7H14, of the ethylene series; also, any one of its isomers.","pos":""}],"HEPTYLIC":[{"def":"Pertaining to, or derived from, heptyl or heptane; as, heptylic alcohol.","pos":""}]}