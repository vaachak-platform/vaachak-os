{"NOCAKE":[{"def":"Indian corn parched, and beaten to powder, -- used for food by the Northern American Indians.","pos":""}],"NOCENT":[{"def":"Doing hurt, or having a tendency to hurt; hurtful; mischievous; noxious; as, nocent qualities.","pos":""},{"def":"Guilty; -- the opposite of innocent.","pos":""}],"NOCENTLY":[{"def":"Hurtfully; injuriosly.","pos":""}],"NOCIVE":[{"def":"Hurtful; injurious.","pos":""}],"NOCK":[{"def":"The upper fore corner of a boom sail or of a trysail.","pos":""}],"NOCTAMBULATION":[{"def":"Somnambulism; walking in sleep.","pos":""}],"NOCTIDIAL":[{"def":"Comprising a night and a day; a noctidial day.","pos":""}],"NOCTILIONID":[{"def":"A South American bat of the genus Noctilio, having cheek pouches and large incisor teeth.","pos":""}],"NOCTILUCA":[{"def":"That which shines at night; -- a fanciful name for phosphorus.","pos":""},{"def":"A genus of marine flagellate Infusoria, remarkable for their unusually large size and complex structure, as well as for their phosphorescence.","pos":""}],"NOCTILUCIN":[{"def":"A fatlike substance in certain marine animals, to which they owe their phosphorescent properties.","pos":""}],"NOCTILUCINE":[{"def":"Of or pertaining to Noctiluca.","pos":""}],"NOCTILUCOUS":[{"def":"Shining in the night.","pos":""}],"NOCTIVAGANT":[{"def":"Going about in the night; night-wandering.","pos":""}],"NOCTIVAGATION":[{"def":"A roving or going about in the night.","pos":""}],"NOCTOGRAPH":[{"def":"A kind of writing frame for the blind.","pos":""},{"def":"An instrument or register which records the presence of watchmen on their beats.","pos":""}],"NOCTUARY":[{"def":"A record of what passes in the night; a nightly journal; -- distinguished from diary.","pos":""}],"NOCTUID":[{"def":"Any one of numerous moths of the family Noctuidæ, or Noctuælitæ, as the cutworm moths, and armyworm moths; -- so called because they fly at night.","pos":""},{"def":"Of or pertaining to the noctuids, or family Noctuidæ.","pos":""}],"NOCTULE":[{"def":"A large European bat (Vespertilio, or Noctulina, altivolans).","pos":""}],"NOCTURN":[{"def":"An office of devotion, or act of religious service, by night.","pos":""},{"def":"One of the portions into which the Psalter was divided, each consisting of nine psalms, designed to be used at a night service.","pos":""}],"NOCTURNAL":[{"def":"Of, pertaining to, done or occuring in, the night; as, nocturnal darkness, cries, expedition, etc.","pos":""},{"def":"Having a habit of seeking food or moving about at night; as, nocturnal birds and insects.","pos":""}],"NOCTURNALLY":[{"def":"By night; nightly.","pos":""}],"NOCTURNE":[{"def":"A night piece, or serenade.","pos":""}],"NOCUMENT":[{"def":"Harm; injury; detriment.","pos":""}],"NOCUOUS":[{"def":"Hurtful; noxious.","pos":""}]}