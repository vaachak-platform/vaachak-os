{"PLAGA":[{"def":"A stripe of color.","pos":""}],"PLAGAL":[{"def":"Having a scale running from the dominant to its octave; -- said of certain old church modes or tunes, as opposed to those called authentic, which ran from the tonic to its octave.","pos":""}],"PLAGATE":[{"def":"Having plagæ, or irregular enlongated color spots.","pos":""}],"PLAGE":[{"def":"A region; country.","pos":""}],"PLAGIARISM":[{"def":"The act or practice of plagiarizing.","pos":""},{"def":"That which plagiarized.","pos":""}],"PLAGIARIST":[{"def":"One who plagiarizes; or purloins the words, writings, or ideas of another, and passes them off as his own; a literary thief; a plagiary.","pos":""}],"PLAGIARIZE":[{"def":"To steal or purloin from the writings of another; to appropriate without due acknowledgement (the ideas or expressions of another).","pos":""}],"PLAGIARY":[{"def":"To commit plagiarism.","pos":""}],"PLAGIHEDRAL":[{"def":"Having an oblique spiral arrangement of planes, as levogyrate and dextrogyrate crystals.","pos":""}],"PLAGIOCEPHALIC":[{"def":"Having an oblique lateral deformity of the skull.","pos":""}],"PLAGIOCEPHALY":[{"def":"Oblique lateral deformity of the skull.","pos":""}],"PLAGIOCLASE":[{"def":"A general term used of any triclinic feldspar.","pos":""}],"PLAGIONITE":[{"def":"A sulphide of lead and antimony, of a blackish lead-gray color and metallic luster.","pos":""}],"PLAGIOSTOMATOUS":[{"def":"Same as Plagiostomous.","pos":""}],"PLAGIOSTOME":[{"def":"One of the Plagiostomi.","pos":""}],"PLAGIOSTOMI":[{"def":"An order of fishes including the sharks and rays; -- called also Plagiostomata.","pos":""}],"PLAGIOSTOMOUS":[{"def":"Of or pertaining to the Plagiostomi.","pos":""}],"PLAGIOTREMATA":[{"def":"Same as Lepidosauria.","pos":""}],"PLAGIOTROPIC":[{"def":"Having the longer axis inclined away from the vertical line.","pos":""}],"PLAGIUM":[{"def":"Manstealing; kidnaping.","pos":""}],"PLAGOSE":[{"def":"Fond of flogging; as, a plagose master.","pos":""}],"PLAGUE":[{"def":"An acute malignant contagious fever, that often prevails in Egypt, Syria, and Turkey, and has at times visited the large cities of Europe with frightful mortality; hence, any pestilence; as, the great London plague.","pos":""}],"PLAGUEFUL":[{"def":"Abounding, or infecting, with plagues; pestilential; as, plagueful exhalations.","pos":""}],"PLAGUELESS":[{"def":"Free from plagues or the plague.","pos":""}],"PLAGUER":[{"def":"One who plagues or annoys.","pos":""}],"PLAGUILY":[{"def":"In a plaguing manner; vexatiously; extremely.","pos":""}],"PLAGUY":[{"def":"Vexatious; troublesome; tormenting; as, a plaguy horse.","pos":""}]}