{"CURB":[{"def":"To bend or curve [Obs.","pos":""},{"def":"To guide and manage, or restrain, as with a curb; to bend to one's will; to subject; to subdue; to restrain; to confine; to keep in check.","pos":""}],"CURB ROOF":[{"def":"A roof having a double slope, or composed, on each side, of two parts which have unequal inclination; a gambrel roof.","pos":""}],"CURBLESS":[{"def":"Having no curb or restraint.","pos":""}],"CURBSTONE":[{"def":"A stone Curbstone broker.","pos":""}]}