{"VITAL":[{"def":"Belonging or relating to life, either animal or vegetable; as, vital energies; vital functions; vital actions.","pos":""},{"def":"Contributing to life; necessary to, or supporting, life; as, vital blood.","pos":""}],"VITALIC":[{"def":"Pertaining to life; vital.","pos":""}],"VITALISM":[{"def":"The doctrine that all the functions of a living organism are due to an unknown vital principle distinct from all chemical and physical forces.","pos":""}],"VITALIST":[{"def":"A believer in the theory of vitalism; -- opposed to physicist.","pos":""}],"VITALISTIC":[{"def":"Pertaining to, or involving, vitalism, or the theory of a special vital principle.","pos":""}],"VITALITY":[{"def":"The quality or state of being vital; the principle of life; vital force; animation; as, the vitality of eggs or vegetable seeds; the vitality of an enterprise.","pos":""}],"VITALIZATION":[{"def":"The act or process of vitalizing, or infusing the vital principle.","pos":""}],"VITALIZE":[{"def":"To endow with life, or vitality; to give life to; to make alive; as, vitalized blood.","pos":""}],"VITALLY":[{"def":"In a vital manner.","pos":""}],"VITALS":[{"def":"Organs that are necessary for life; more especially, the heart, lungs, and brain.","pos":""}],"VITASCOPE":[{"def":"A form of machine for exhibiting animated pictures.","pos":""}],"VITELLIGENOUS":[{"def":"Producing yolk, or vitelline substance; -- applied to certain cells (also called nutritive, or yolk, cells) formed in the ovaries of many insects, and supposed to supply nutriment to the developing ova.","pos":""}],"VITELLIN":[{"def":"An albuminous body, belonging to the class of globulins, obtained from yolk of egg, of which it is the chief proteid constituent, and from the seeds of many plants.","pos":""}],"VITELLINE":[{"def":"Of or pertaining to the yolk of eggs; as, the vitelline membrane, a smooth, transparent membrane surrounding the vitellus.","pos":""}],"VITELLOGENE":[{"def":"A gland secreting the yolk of the eggs in trematodes, turbellarians, and some other helminths.","pos":""}],"VITELLUS":[{"def":"The contents or substance of the ovum; egg yolk.","pos":""},{"def":"Perisperm in an early condition.","pos":""}],"VITIATE":[{"def":"To make vicious, faulty, or imperfect; to render defective; to injure the substance or qualities of; to impair; to contaminate; to spoil; as, exaggeration vitiates a style of writing; sewer gas vitiates the air.","pos":""},{"def":"To cause to fail of effect, either wholly or in part; to make void; to destroy, as the validity or binding force of an instrument or transaction; to annul; as, any undue influence exerted on a jury vitiates their verdict; fraud vitiates a contract.","pos":""}],"VITIATION":[{"def":"The act of vitiating, or the state of being vitiated; depravation; corruption; invalidation; as, the vitiation of the blood; the vitiation of a contract.","pos":""}],"VITICULOSE":[{"def":"Having long and slender trailing stems.","pos":""}],"VITICULTURAL":[{"def":"Of or pertaining to viticulture.","pos":""}],"VITICULTURE":[{"def":"The cultivation of the vine; grape growing.","pos":""}],"VITICULTURIST":[{"def":"One engaged in viticulture.","pos":""}],"VITILIGO":[{"def":"A rare skin disease consisting in the development of smooth, milk-white spots upon various parts of the body.","pos":""}],"VITILITIGATE":[{"def":"To contend in law litigiously or cavilously.","pos":""}],"VITILITIGATION":[{"def":"Cavilous litigation; cavillation.","pos":""}],"VITIOSITY":[{"def":"Viciousness; depravity.","pos":""},{"def":"See Vicious, Viciously, Viciousness.","pos":""}],"VITIS":[{"def":"A genus of plants including all true grapevines.","pos":""}],"VITRAGE":[{"def":"A curtain of light and translucent material intended to be secured directly to the woodwork of a French casement window or a glazed door.","pos":""}],"VITRELLA":[{"def":"One of the transparent lenslike cells in the ocelli of certain arthropods.","pos":""}],"VITREO-ELECTIC":[{"def":"Containing or exhibiting positive, or vitreous, electricity.","pos":""}],"VITREOUS":[{"def":"Consisting of, or resembling, glass; glassy; as, vitreous rocks.","pos":""},{"def":"Of or pertaining to glass; derived from glass; as, vitreous electricity.","pos":""}],"VITREOUSNESS":[{"def":"The quality or state of being vitreous.","pos":""}],"VITRESCENCE":[{"def":"The quality or state of being vitreous; glassiness, or the quality of being vitrescent; capability of conversion into glass; susceptibility of being formed into glass.","pos":""}],"VITRESCENT":[{"def":"Capable of being formed into glass; tending to become glass.","pos":""}],"VITRESCIBLE":[{"def":"That may be vitrified; vitrifiable.","pos":""}],"VITRIC":[{"def":"Having the nature and qualities of glass; glasslike; -- distinguished from ceramic.","pos":""}],"VITRICS":[{"def":"The art or study of the manufacture and decoration of glassware.","pos":""}],"VITRIFACTION":[{"def":"The act, art, or process of vitrifying; also, the state of being vitrified.","pos":""}],"VITRIFACTURE":[{"def":"The manufacture of glass and glassware.","pos":""}],"VITRIFIABLE":[{"def":"Capable of being vitrified, or converted into glass by heat and fusion; as, flint and alkalies are vitrifiable.","pos":""}],"VITRIFICATE":[{"def":"To convert into glass; to vitrify.","pos":""}],"VITRIFICATION":[{"def":"Same as Vitrifaction.","pos":""}],"VITRIFIED":[{"def":"Converted into glass.","pos":""}],"VITRIFORM":[{"def":"Having the form or appearance of glass; resembling glass; glasslike.","pos":""}],"VITRIFY":[{"def":"To convert into, or cause to resemble, glass or a glassy substance, by heat and fusion.","pos":""}],"VITRINA":[{"def":"A genus of terrestrial gastropods, having transparent, very thin, and delicate shells, -- whence the name.","pos":""}],"VITRINE":[{"def":"A glass show case for displaying fine wares, specimens, etc.","pos":""}],"VITRIOL":[{"def":"Formerly called also vitriol of zinc.","pos":""}],"VITRIOLATED":[{"def":"Changed into a vitriol or a sulphate, or subjected to the action of sulphuric acid or of a sulphate; as, vitriolated potash, i.","pos":""}],"VITRIOLATION":[{"def":"The act, process, or result of vitriolating.","pos":""}],"VITRIOLIC":[{"def":"Of or pertaining to vitriol; derived from, or resembling, vitriol; vitriolous; as, a vitriolic taste.","pos":""}],"VITRIOLIZABLE":[{"def":"Capable of being converted into a vitriol.","pos":""}],"VITRIOLIZATION":[{"def":"The act of vitriolizing, or the state of being vitriolized; vitriolation.","pos":""}],"VITRIOLIZE":[{"def":"To convert into a vitriol; to vitriolate.","pos":""}],"VITRITE":[{"def":"A kind of glass which is very hard and difficult to fuse, used as an insulator in electrical lamps and other apparatus.","pos":""}],"VITRO-DI-TRINA":[{"def":"A kind of Venetian glass or glassware in which white threads are embedded in transparent glass with a lacelike or netlike effect.","pos":""}],"VITRUVIAN":[{"def":"Of or pertaining to Vitruvius, an ancient Roman architect.","pos":""}],"VITTA":[{"def":"One of the oil tubes in the fruit of umbelliferous plants.","pos":""},{"def":"A band, or stripe, of color.","pos":""}],"VITTATE":[{"def":"Bearing or containing vittæ.","pos":""}],"VITULINE":[{"def":"Of or pertaining to a calf or veal.","pos":""}],"VITUPERABLE":[{"def":"Liable to, or deserving, vituperation, or severe censure.","pos":""}],"VITUPERATE":[{"def":"To find fault with; to scold; to overwhelm with wordy abuse; to censure severely or abusively; to rate.","pos":""}],"VITUPERATION":[{"def":"The act of vituperating; abuse; severe censure; blame.","pos":""}],"VITUPERATIVE":[{"def":"Uttering or writing censure; containing, or characterized by, abuse; scolding; abusive.","pos":""}],"VITUPERATOR":[{"def":"One who vituperates, or censures abusively.","pos":""}],"VITUPERRIOUS":[{"def":"Worthy of vituperation; shameful; disgraceful.","pos":""}]}