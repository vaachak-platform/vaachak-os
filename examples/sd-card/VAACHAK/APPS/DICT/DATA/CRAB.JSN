{"CRAB":[{"def":"One of the brachyuran Crustacea.","pos":""},{"def":"A crab apple; -- so named from its harsh taste.","pos":""}],"CRAB-YAWS":[{"def":"A disease in the West Indies.","pos":""}],"CRABBED":[{"def":"Characterized by or manifesting, sourness, peevishness, or moroseness; harsh; cross; cynical; -- applied to feelings, disposition, or manners.","pos":""},{"def":"Characterized by harshness or roughness; unpleasant; -- applied to things; as, a crabbed taste.","pos":""}],"CRABBER":[{"def":"One who catches crabs.","pos":""}],"CRABBING":[{"def":"The foghting of hawks with each other.","pos":""}],"CRABBISH":[{"def":"Somewhat sour or cross.","pos":""}],"CRABBY":[{"def":"Crabbed; difficult, or perplexing.","pos":""}],"CRABEATER":[{"def":"Crab\"eat`er (krb\"t`r), n.","pos":""}],"CRABFACED":[{"def":"Having a sour, disagreeable countenance.","pos":""}],"CRABSIDLE":[{"def":"To move sidewise, as a crab.","pos":""}],"CRABSTICK":[{"def":"A stick, cane, or cudgel, made of the wood of the carb tree.","pos":""}]}