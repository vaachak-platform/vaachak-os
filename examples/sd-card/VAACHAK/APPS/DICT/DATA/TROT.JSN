{"TROT":[{"def":"To proceed by a certain gait peculiar to quadrupeds; to ride or drive at a trot.","pos":""}],"TROTH":[{"def":"Belief; faith; fidelity.","pos":""},{"def":"Truth; verity; veracity; as, by my troth.","pos":""}],"TROTHLESS":[{"def":"Faitless; false; treacherous.","pos":""}],"TROTHPLIGHT":[{"def":"Betrothed; espoused; affianced.","pos":""}],"TROTHPLIGHTED":[{"def":"Having fidelity pledged.","pos":""}],"TROTTER":[{"def":"One that trots; especially, a horse trained to be driven in trotting matches.","pos":""},{"def":"The foot of an animal, especially that of a sheep; also, humorously, the human foot.","pos":""}],"TROTTOIR":[{"def":"Footpath; pavement; sidewalk.","pos":""}]}