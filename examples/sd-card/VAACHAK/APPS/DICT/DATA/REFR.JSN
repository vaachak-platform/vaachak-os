{"REFRACT":[{"def":"To bend sharply and abruptly back; to break off.","pos":""},{"def":"To break the natural course of, as rays of light orr heat, when passing from one transparent medium to another of different density; to cause to deviate from a direct course by an action distinct from reflection; as, a dense medium refrcts the rays of light as they pass into it from a rare medium.","pos":""}],"REFRACTABLE":[{"def":"Capable of being refracted.","pos":""}],"REFRACTED":[{"def":"Bent backward angularly, as if half-broken; as, a refracted stem or leaf.","pos":""}],"REFRACTING":[{"def":"Serving or tending to refract; as, a refracting medium.","pos":""}],"REFRACTION":[{"def":"The act of refracting, or the state of being refracted.","pos":""},{"def":"The change in the direction of ray of light, heat, or the like, when it enters obliquely a medium of a different density from that through which it has previously moved.","pos":""}],"REFRACTIVE":[{"def":"Serving or having power to refract, or turn from a direct course; pertaining to refraction; as, refractive surfaces; refractive powers.","pos":""}],"REFRACTIVENESS":[{"def":"The quality or condition of being refractive.","pos":""}],"REFRACTOMETER":[{"def":"A contrivance for exhibiting and measuring the refraction of light.","pos":""}],"REFRACTOR":[{"def":"Anything that refracts; specifically: (Opt.","pos":""},{"def":"A refracting telescope, in which the image to be viewed is formed by the refraction of light in passing through a convex lens.","pos":""}],"REFRACTORILY":[{"def":"In a refractory manner; perversely; obstinately.","pos":""}],"REFRACTORINESS":[{"def":"The quality or condition of being refractory.","pos":""}],"REFRACTORY":[{"def":"Obstinate in disobedience; contumacious; stubborn; unmanageable; as, a refractory child; a refractory beast.","pos":""},{"def":"Resisting ordinary treatment; difficult of fusion, reduction, or the like; -- said especially of metals and the like, which do not readily yield to heat, or to the hammer; as, a refractory ore.","pos":""}],"REFRACTURE":[{"def":"A second breaking (as of a badly set bone) by the surgeon.","pos":""}],"REFRAGABLE":[{"def":"Capable of being refuted; refutable.","pos":""}],"REFRAIN":[{"def":"To hold back; to restrain; to keep within prescribed bounds; to curb; to govern.","pos":""},{"def":"To abstain from [Obs.","pos":""}],"REFRAINER":[{"def":"One who refrains.","pos":""}],"REFRAINMENT":[{"def":"Act of refraining.","pos":""}],"REFRAME":[{"def":"To frame again or anew.","pos":""}],"REFRANGIBILITY":[{"def":"The quality of being refrangible.","pos":""}],"REFRANGIBLE":[{"def":"Capable of being refracted, or turned out of a direct course, in passing from one medium to another, as rays of light.","pos":""}],"REFRENATION":[{"def":"The act of refraining.","pos":""}],"REFRESH":[{"def":"To make fresh again; to restore strength, spirit, animation, or the like, to; to relieve from fatigue or depression; to reinvigorate; to enliven anew; to reanimate; as, sleep refreshes the body and the mind.","pos":""},{"def":"To make as if new; to repair; to restore.","pos":""}],"REFRESHER":[{"def":"An extra fee paid to counsel in a case that has been adjourned from one term to another, or that is unusually protracted.","pos":""}],"REFRESHFUL":[{"def":"Full of power to refresh; refreshing.","pos":""}],"REFRESHING":[{"def":"Reviving; reanimating.","pos":""}],"REFRESHMENT":[{"def":"The act of refreshing, or the state of being refreshed; restoration of strength, spirit, vigor, or liveliness; relief after suffering; new life or animation after depression.","pos":""},{"def":"That which refreshes; means of restoration or reanimation; especially, an article of food or drink.","pos":""}],"REFREYD":[{"def":"To chill; to cool.","pos":""}],"REFRICATION":[{"def":"A rubbing up afresh; a brightening.","pos":""}],"REFRIGERANT":[{"def":"Cooling; allaying heat or fever.","pos":""}],"REFRIGERATE":[{"def":"To cause to become cool; to make or keep cold or cool.","pos":""}],"REFRIGERATION":[{"def":"The act or process of refrigerating or cooling, or the state of being cooled.","pos":""}],"REFRIGERATIVE":[{"def":"Cooling; allaying heat.","pos":""}],"REFRIGERATOR":[{"def":"That which refrigerates or makes cold; that which keeps cool.","pos":""}],"REFRIGERATORY":[{"def":"Mitigating heat; cooling.","pos":""}],"REFRIGERIUM":[{"def":"Cooling refreshment; refrigeration.","pos":""}],"REFRINGENCY":[{"def":"The power possessed by a substance to refract a ray; as, different substances have different refringencies.","pos":""}],"REFRINGENT":[{"def":"Pertaining to, or possessing, refringency; refractive; refracting; as, a refringent prism of spar.","pos":""}]}