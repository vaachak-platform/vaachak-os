{"INK":[{"def":"The step, or socket, in which the lower end of a millstone spindle runs.","pos":""}],"INKER":[{"def":"One who, or that which, inks; especially, in printing, the pad or roller which inks the type.","pos":""}],"INKHORN":[{"def":"A small bottle of horn or other material formerly used for holding ink; an inkstand; a portable case for writing materials.","pos":""}],"INKINESS":[{"def":"The state or quality of being inky; blackness.","pos":""}],"INKING":[{"def":"Supplying or covering with ink.","pos":""}],"INKLE":[{"def":"A kind of tape or braid.","pos":""}],"INKLING":[{"def":"A hint; an intimation.","pos":""}],"INKNEE":[{"def":"Same as Knock-knee.","pos":""}],"INKNEED":[{"def":"See Knock-kneed.","pos":""}],"INKNOT":[{"def":"To fasten or bind, as with a knot; to knot together.","pos":""}],"INKSTAND":[{"def":"A small vessel for holding ink, to dip the pen into; also, a device for holding ink and writing materials.","pos":""}],"INKSTONE":[{"def":"A kind of stone containing native vitriol or subphate of iron, used in making ink.","pos":""}],"INKY":[{"def":"Consisting of, or resembling, ink; soiled with ink; black.","pos":""}]}