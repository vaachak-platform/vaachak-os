{"PABULAR":[{"def":"Of, pertaining to, or fit for, pabulum or food; affording food.","pos":""}],"PABULATION":[{"def":"The act of feeding, or providing food.","pos":""},{"def":"Food; fodder; pabulum.","pos":""}],"PABULOUS":[{"def":"Affording pabulum, or food; alimental.","pos":""}],"PABULUM":[{"def":"The means of nutriment to animals or plants; food; nourishment; hence, that which feeds or sustains, as fuel for a fire; that upon which the mind or soul is nourished; as, intellectual pabulum.","pos":""}]}