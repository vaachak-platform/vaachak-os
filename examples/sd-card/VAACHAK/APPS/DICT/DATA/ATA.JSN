{"ATABAL":[{"def":"A kettledrum; a kind of tabor, used by the Moors.","pos":""}],"ATACAMITE":[{"def":"An oxychloride of copper, usually in emerald-green prismatic crystals.","pos":""}],"ATAMAN":[{"def":"A hetman, or chief of the Cossacks.","pos":""}],"ATAMASCO LILY":[{"def":"Perfect peace of mind, or calmness.","pos":""}],"ATAVIC":[{"def":"Pertaining to a remote ancestor, or to atavism.","pos":""}],"ATAVISM":[{"def":"Disorder; irregularity.","pos":""}],"ATAXIC":[{"def":"Characterized by ataxy, that is, (a) by great irregularity of functions or symptoms, or (b) by a want of coordinating power in movements.","pos":""}],"ATAZIR":[{"def":"The influence of a star upon other stars or upon men.","pos":""}]}