{"DECIARE":[{"def":"A measure of area, the tenth part of an are; ten square meters.","pos":""}],"DECIDABLE":[{"def":"Capable of being decided; determinable.","pos":""}],"DECIDE":[{"def":"To cut off; to separate.","pos":""},{"def":"To bring to a termination, as a question, controversy, struggle, by giving the victory to one side or party; to render judgment concerning; to determine; to settle.","pos":""}],"DECIDED":[{"def":"Free from ambiguity; unequivocal; unmistakable; unquestionable; clear; evident; as, a decided advantage.","pos":""},{"def":"Free from doubt or wavering; determined; of fixed purpose; fully settled; positive; resolute; as, a decided opinion or purpose.","pos":""}],"DECIDEDLY":[{"def":"In a decided manner; indisputably; clearly; thoroughly.","pos":""}],"DECIDEMENT":[{"def":"Means of forming a decision.","pos":""}],"DECIDER":[{"def":"One who decides.","pos":""}],"DECIDUA":[{"def":"The inner layer of the wall of the uterus, which envelops the embryo, forms a part of the placenta, and is discharged with it.","pos":""}],"DECIDUATA":[{"def":"A group of Mammalia in which a decidua is thrown off with, or after, the fetus, as in the human species.","pos":""}],"DECIDUATE":[{"def":"Possessed of, or characterized by, a decidua.","pos":""}],"DECIDUOUS":[{"def":"Falling off, or subject to fall or be shed, at a certain season, or a certain stage or interval of growth, as leaves (except of evergreens) in autumn, or as parts of animals, such as hair, teeth, antlers, etc.","pos":""}],"DECIDUOUSNESS":[{"def":"The quality or state of being deciduous.","pos":""},{"def":"A weight in the metric system; one tenth of a gram, equal to 1.","pos":""}],"DECILLION":[{"def":"According to the English notation, a million involved to the tenth power, or a unit with sixty ciphers annexed; according to the French and American notation, a thousand involved to the eleventh power, or a unit with thirty-three ciphers annexed.","pos":""}],"DECILLIONTH":[{"def":"Pertaining to a decillion, or to the quotient of unity divided by a decillion.","pos":""}],"DECIMAL":[{"def":"Of or pertaining to decimals; numbered or proceeding by tens; having a tenfold increase or decrease, each unit being ten times the unit next smaller; as, decimal notation; a decimal coinage.","pos":""}],"DECIMALISM":[{"def":"The system of a decimal currency, decimal weights, measures, etc.","pos":""}],"DECIMALIZE":[{"def":"To reduce to a decimal system; as, to decimalize the currency.","pos":""}],"DECIMALLY":[{"def":"By tens; by means of decimals.","pos":""}],"DECIMATE":[{"def":"To take the tenth part of; to tithe.","pos":""},{"def":"To select by lot and punish with death every tenth man of; as, to decimate a regiment as a punishment for mutiny.","pos":""}],"DECIMATION":[{"def":"A selection of every tenth person by lot, as for punishment.","pos":""}],"DECIMATOR":[{"def":"One who decimates.","pos":""}],"DECIME":[{"def":"A French coin, the tenth part of a franc, equal to about two cents.","pos":""},{"def":"A measure of length in the metric system; one tenth of a meter, equal to 3.","pos":""}],"DECIMOSEXTO":[{"def":"A book consisting of sheets, each of which is folded into sixteen leaves; hence, indicating, more or less definitely, a size of book; -- usually written 16mo or 16º.","pos":""}],"DECINE":[{"def":"One of the higher hydrocarbons, C10H15, of the acetylene series; -- called also decenylene.","pos":""}],"DECIPHER":[{"def":"To translate from secret characters or ciphers into intelligible terms; as, to decipher a letter written in secret characters.","pos":""},{"def":"To find out, so as to be able to make known the meaning of; to make out or read, as words badly written or partly obliterated; to detect; to reveal; to unfold.","pos":""}],"DECIPHERABLE":[{"def":"Capable of being deciphered; as, old writings not decipherable.","pos":""}],"DECIPHERER":[{"def":"One who deciphers.","pos":""}],"DECIPHERESS":[{"def":"A woman who deciphers.","pos":""}],"DECIPHERMENT":[{"def":"The act of deciphering.","pos":""}],"DECIPIENCY":[{"def":"State of being deceived; hallucination.","pos":""}],"DECIPIUM":[{"def":"A supposed rare element, said to be associated with cerium, yttrium, etc.","pos":""}],"DECISION":[{"def":"Cutting off; division; detachment of a part.","pos":""},{"def":"The act of deciding; act of settling or terminating, as a controversy, by giving judgment on the matter at issue; determination, as of a question or doubt; settlement; conclusion.","pos":""}],"DECISIVE":[{"def":"Having the power or quality of deciding a question or controversy; putting an end to contest or controversy; final; conclusive.","pos":""},{"def":"Marked by promptness and decision.","pos":""}],"DECISORY":[{"def":"Able to decide or determine; having a tendency to decide.","pos":""}],"DECISTERE":[{"def":"The tenth part of the stere or cubic meter, equal to 3.","pos":""}],"DECITIZENIZE":[{"def":"To deprive of the rights of citizenship.","pos":""}],"DECIVILIZE":[{"def":"To reduce from civilization to a savage state.","pos":""}]}