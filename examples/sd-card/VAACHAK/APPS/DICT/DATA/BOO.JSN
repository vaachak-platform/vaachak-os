{"BOOBY":[{"def":"A dunce; a stupid fellow.","pos":""}],"BOODHISM":[{"def":"Same as Buddhism.","pos":""}],"BOODHIST":[{"def":"Same as Buddhist.","pos":""}],"BOODLE":[{"def":"The whole collection or lot; caboodle.","pos":""},{"def":"Money given in payment for votes or political influence; bribe money; swag.","pos":""}],"BOOHOE":[{"def":"To bawl; to cry loudly.","pos":""}],"BOOHOO":[{"def":"The sailfish; -- called also woohoo.","pos":""}],"BOOK":[{"def":"A collection of sheets of paper, or similar material, blank, written, or printed, bound together; commonly, many folded and bound sheets containing continuous printing or writing.","pos":""},{"def":"A composition, written or printed; a treatise.","pos":""}],"BOOK MUSLIN":[{"def":"A kind of muslin used for the covers of books.","pos":""},{"def":"A kind of thin white muslin for ladies' dresses.","pos":""}],"BOOK-LEARNED":[{"def":"Versed in books; having knowledge derived from books.","pos":""}],"BOOKBINDER":[{"def":"One whose occupation is to bind books.","pos":""}],"BOOKBINDERY":[{"def":"A bookbinder's shop; a place or establishment for binding books.","pos":""}],"BOOKBINDING":[{"def":"The art, process, or business of binding books.","pos":""}],"BOOKCASE":[{"def":"A case with shelves for holding books, esp.","pos":""}],"BOOKCRAFT":[{"def":"Authorship; literary skill.","pos":""}],"BOOKED":[{"def":"On the way; destined.","pos":""}],"BOOKER":[{"def":"One who enters accounts or names, etc.","pos":""}],"BOOKFUL":[{"def":"As much as will fill a book; a book full.","pos":""},{"def":"Filled with book learning.","pos":""}],"BOOKHOLDER":[{"def":"A prompter at a theater.","pos":""},{"def":"A support for a book, holding it open, while one reads or copies from it.","pos":""}],"BOOKING CLERK":[{"def":"A clerk who registers passengers, baggage, etc.","pos":""}],"BOOKING OFFICE":[{"def":"An office where passengers, baggage, etc.","pos":""},{"def":"An office where passage tickets are sold.","pos":""}],"BOOKISH":[{"def":"Given to reading; fond of study; better acquainted with books than with men; learned from books.","pos":""},{"def":"Characterized by a method of expression generally found in books; formal; labored; pedantic; as, a bookish way of talking; bookish sentences.","pos":""}],"BOOKKEEPER":[{"def":"One who keeps accounts; one who has the charge of keeping the books and accounts in an office.","pos":""}],"BOOKKEEPING":[{"def":"The art of recording pecuniary or business transactions in a regular and systematic manner, so as to show their relation to each other, and the state of the business in which they occur; the art of keeping accounts.","pos":""},{"def":"Charter land held by deed under certain rents and free services, which differed in nothing from free socage lands.","pos":""}],"BOOKLESS":[{"def":"Without books; unlearned.","pos":""}],"BOOKMAKER":[{"def":"A betting man who \"makes a book.","pos":""}],"BOOKMAN":[{"def":"A studious man; a scholar.","pos":""}],"BOOKMARK":[{"def":"Something placed in a book to guide in finding a particular page or passage; also, a label in a book to designate the owner; a bookplate.","pos":""}],"BOOKMATE":[{"def":"A schoolfellow; an associate in study.","pos":""}],"BOOKMONGER":[{"def":"A dealer in books.","pos":""}],"BOOKPLATE":[{"def":"A label, placed upon or in a book, showing its ownership or its position in a library.","pos":""}],"BOOKSELLER":[{"def":"One who sells books.","pos":""}],"BOOKSELLING":[{"def":"The employment of selling books.","pos":""}],"BOOKSHELF":[{"def":"A shelf to hold books.","pos":""}],"BOOKSHOP":[{"def":"A bookseller's shop.","pos":""}],"BOOKSTALL":[{"def":"A stall or stand where books are sold.","pos":""}],"BOOKSTAND":[{"def":"A place or stand for the sale of books in the streets; a bookstall.","pos":""},{"def":"A stand to hold books for reading or reference.","pos":""}],"BOOKSTORE":[{"def":"A store where books are kept for sale; -- called in England a bookseller's shop.","pos":""}],"BOOKWORK":[{"def":"Work done upon a book or books (as in a printing office), in distinction from newspaper or job work.","pos":""},{"def":"Study; application to books.","pos":""}],"BOOKWORM":[{"def":"Any larva of a beetle or moth, which is injurious to books.","pos":""}],"BOOLY":[{"def":"A company of Irish herdsmen, or a single herdsman, wandering from place to place with flocks and herds, and living on their milk, like the Tartars; also, a place in the mountain pastures inclosed for the shelter of cattle or their keepers.","pos":""}],"BOOM":[{"def":"A long pole or spar, run out for the purpose of extending the bottom of a particular sail; as, the jib boom, the studding-sail boom, etc.","pos":""},{"def":"A long spar or beam, projecting from the mast of a derrick, from the outer end of which the body to be lifted is suspended.","pos":""}],"BOOMDAS":[{"def":"A small African hyracoid mammal (Dendrohyrax arboreus) resembling the daman.","pos":""}],"BOOMER":[{"def":"A North American rodent, so named because it is said to make a booming noise.","pos":""},{"def":"A large male kangaroo.","pos":""}],"BOOMERANG":[{"def":"A very singular missile weapon used by the natives of Australia and in some parts of India.","pos":""}],"BOOMING":[{"def":"Rushing with violence; swelling with a hollow sound; making a hollow sound or note; roaring; resounding.","pos":""},{"def":"Advancing or increasing amid noisy excitement; as, booming prices; booming popularity.","pos":""}],"BOOMORAH":[{"def":"A small West African chevrotain (Hyæmoschus aquaticus), resembling the musk deer.","pos":""}],"BOOMSLANGE":[{"def":"A large South African tree snake (Bucephalus Capensis).","pos":""}],"BOON":[{"def":"A prayer or petition.","pos":""},{"def":"That which is asked or granted as a benefit or favor; a gift; a benefaction; a grant; a present.","pos":""}],"BOOR":[{"def":"A husbandman; a peasant; a rustic; esp.","pos":""},{"def":"A Dutch, German, or Russian peasant; esp.","pos":""}],"BOORISH":[{"def":"Like a boor; clownish; uncultured; unmannerly.","pos":""}],"BOOSE":[{"def":"A stall or a crib for an ox, cow, or other animal.","pos":""}],"BOOSER":[{"def":"A toper; a guzzler.","pos":""}],"BOOST":[{"def":"To lift or push from behind (one who is endeavoring to climb); to push up; hence, to assist in overcoming obstacles, or in making advancement.","pos":""}],"BOOSTER":[{"def":"An instrument for regulating the electro-motive force in an alternating-current circuit; -- so called because used to \"boost\", or raise, the pressure in the circuit.","pos":""}],"BOOT":[{"def":"Remedy; relief; amends; reparation; hence, one who brings relief.","pos":""},{"def":"That which is given to make an exchange equal, or to make up for the deficiency of value in one of the things exchanged.","pos":""}],"BOOTBLACK":[{"def":"One who blacks boots.","pos":""}],"BOOTED":[{"def":"Having an undivided, horny, bootlike covering; -- said of the tarsus of some birds.","pos":""}],"BOOTEE":[{"def":"A half boot or short boot.","pos":""},{"def":"A northern constellation, containing the bright star Arcturus.","pos":""}],"BOOTH":[{"def":"A house or shed built of boards, boughs, or other slight materials, for temporary occupation.","pos":""},{"def":"A covered stall or temporary structure in a fair or market, or at a polling place.","pos":""}],"BOOTHALE":[{"def":"To forage for booty; to plunder.","pos":""}],"BOOTHOSE":[{"def":"Stocking hose, or spatterdashes, in lieu of boots.","pos":""},{"def":"Hose made to be worn with boots, as by travelers on horseback.","pos":""}],"BOOTIKIN":[{"def":"A little boot, legging, or gaiter.","pos":""},{"def":"A covering for the foot or hand, worn as a cure for the gout.","pos":""}],"BOOTING":[{"def":"Advantage; gain; gain by plunder; booty.","pos":""}],"BOOTJACK":[{"def":"A device for pulling off boots.","pos":""}],"BOOTLESS":[{"def":"Unavailing; unprofitable; useless; without advantage or success.","pos":""}],"BOOTMAKER":[{"def":"One who makes boots.","pos":""}],"BOOTS":[{"def":"A servant at a hotel or elsewhere, who cleans and blacks the boots and shoes.","pos":""}],"BOOTTOPPING":[{"def":"The act or process of daubing a vessel's bottom near the surface of the water with a mixture of tallow, sulphur, and resin, as a temporary protection against worms, after the slime, shells, etc.","pos":""},{"def":"Sheathing a vessel with planking over felt.","pos":""}],"BOOTTREE":[{"def":"An instrument to stretch and widen the leg of a boot, consisting of two pieces, together shaped like a leg, between which, when put into the boot, a wedge is driven.","pos":""}],"BOOTY":[{"def":"That which is seized by violence or obtained by robbery, especially collective spoil taken in war; plunder; pillage.","pos":""}],"BOOZE":[{"def":"To drink greedily or immoderately, esp.","pos":""}],"BOOZER":[{"def":"One who boozes; a toper; a guzzler of alcoholic liquors; a bouser.","pos":""}],"BOOZY":[{"def":"A little intoxicated; fuddled; stupid with liquor; bousy.","pos":""}]}