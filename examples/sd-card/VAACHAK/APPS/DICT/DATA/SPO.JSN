{"SPODOMANCY":[{"def":"Divination by means of ashes.","pos":""}],"SPODOMANTIC":[{"def":"Relating to spodomancy, or divination by means of ashes.","pos":""}],"SPODUMENE":[{"def":"A mineral of a white to yellowish, purplish, or emerald-green color, occuring in prismatic crystals, often of great size.","pos":""}],"SPOFFISH":[{"def":"Earnest and active in matters of no moment; bustling.","pos":""}],"SPOIL":[{"def":"To plunder; to strip by violence; to pillage; to rob; -- with of before the name of the thing taken; as, to spoil one of his goods or possession.","pos":""},{"def":"To seize by violence;; to take by force; to plunder.","pos":""}],"SPOILABLE":[{"def":"Capable of being spoiled.","pos":""}],"SPOILER":[{"def":"One who spoils; a plunderer; a pillager; a robber; a despoiler.","pos":""},{"def":"One who corrupts, mars, or renders useless.","pos":""}],"SPOILFIVE":[{"def":"A certain game at cards in which, if no player wins three of the five tricks possible on any deal, the game is said to be spoiled.","pos":""}],"SPOILFUL":[{"def":"Wasteful; rapacious.","pos":""}],"SPOILSMAN":[{"def":"One who serves a cause or a party for a share of the spoils; in United States politics, one who makes or recognizes a demand for public office on the ground of partisan service; also, one who sanctions such a policy in appointments to the public service.","pos":""}],"SPOILSMONGER":[{"def":"One who promises or distributes public offices and their emoluments as the price of services to a party or its leaders.","pos":""}],"SPOKE":[{"def":"A projecting handle of a steering wheel.","pos":""}],"SPOKEN":[{"def":"Uttered in speech; delivered by word of mouth; oral; as, a spoken narrative; the spoken word.","pos":""},{"def":"Characterized by a certain manner or style in speaking; -- often in composition; as, a pleasant-spoken man.","pos":""}],"SPOKESHAVE":[{"def":"A kind of drawing knife or planing tool for dressing the spokes of wheels, the shells of blocks, and other curved work.","pos":""}],"SPOKESMAN":[{"def":"One who speaks for another.","pos":""}],"SPOLIATE":[{"def":"To plunder; to pillage; to despoil; to rob.","pos":""}],"SPOLIATION":[{"def":"Injury done to a document.","pos":""}],"SPOLIATIVE":[{"def":"Serving to take away, diminish, or rob; esp.","pos":""}],"SPOLIATOR":[{"def":"One who spoliates; a spoiler.","pos":""}],"SPOLIATORY":[{"def":"Tending to spoil; destructive; spoliative.","pos":""}],"SPONDEE":[{"def":"A poetic foot of two long syllables, as in the Latin word leges.","pos":""}],"SPONDULICS":[{"def":"A joint of the backbone; a vertebra.","pos":""}],"SPONG":[{"def":"An irregular, narrow, projecting part of a field.","pos":""}],"SPONGE":[{"def":"Any one of numerous species of Spongiæ, or Porifera.","pos":""},{"def":"A mop for cleaning the bore of a cannon after a discharge.","pos":""}],"SPONGEOUS":[{"def":"Resembling sponge; having the nature or qualities of sponge.","pos":""}],"SPONGER":[{"def":"One who sponges, or uses a sponge.","pos":""},{"def":"One employed in gathering sponges.","pos":""}],"SPONGIAE":[{"def":"The grand division of the animal kingdom which includes the sponges; -- called also Spongida, Spongiaria, Spongiozoa, and Porifera.","pos":""}],"SPONGIFORM":[{"def":"Resembling a sponge; soft and porous; porous.","pos":""}],"SPONGILLA":[{"def":"A genus of siliceous spongea found in fresh water.","pos":""}],"SPONGIN":[{"def":"The chemical basis of sponge tissue, a nitrogenous, hornlike substance which on decomposition with sulphuric acid yields leucin and glycocoll.","pos":""}],"SPONGINESS":[{"def":"The quality or state of being spongy.","pos":""}],"SPONGING":[{"def":"Spon\"ging, Defn: a.","pos":""}],"SPONGIOLE":[{"def":"A supposed spongelike expansion of the tip of a rootlet for absorbing water; -- called also spongelet.","pos":""}],"SPONGIOLITE":[{"def":"One of the microsporic siliceous spicules which occur abundantly in the texture of sponges, and are sometimes found fossil, as in flints.","pos":""}],"SPONGIOPILIN":[{"def":"A kind of cloth interwoven with small pieces of sponge and rendered waterproof on one side by a covering of rubber.","pos":""},{"def":"Somewhat spongy; spongelike; full of small cavities like sponge; as, spongious bones.","pos":""}],"SPONGOBLAST":[{"def":"One of the cells which, in sponges, secrete the spongin, or the material of the horny fibers.","pos":""}],"SPONGOID":[{"def":"Resembling sponge; like sponge.","pos":""}],"SPONGY":[{"def":"Soft, and full of cavities; of an open, loose, pliable texture; as, a spongy excrescence; spongy earth; spongy cake; spongy bones.","pos":""},{"def":"Wet; drenched; soaked and soft, like sponge; rainy.","pos":""}],"SPONSAL":[{"def":"Relating to marriage, or to a spouse; spousal.","pos":""}],"SPONSIBLE":[{"def":"responsible; worthy of credit.","pos":""}],"SPONSION":[{"def":"An act or engagement on behalf of a state, by an agent not specially authorized for the purpose, or by one who exceeds the limits of authority.","pos":""}],"SPONSIONAL":[{"def":"Of or pertaining to a pledge or agreement; responsible.","pos":""}],"SPONSOR":[{"def":"One who binds himself to answer for another, and is responsible for his default; a surety.","pos":""},{"def":"One who at the baptism of an infant professore the christian faith in its name, and guarantees its religious education; a godfather or godmother.","pos":""}],"SPONSORIAL":[{"def":"Pertaining to a sponsor.","pos":""}],"SPONSORSHIP":[{"def":"State of being a sponsor.","pos":""}],"SPONTANEITY":[{"def":"The quality or state of being spontaneous, or acting from native feeling, proneness, or temperament, without constraint or external force.","pos":""}],"SPONTANEOUS":[{"def":"Proceding from natural feeling, temperament, or disposition, or from a native internal proneness, readiness, or tendency, without constraint; as, a spontaneous gift or proportion.","pos":""},{"def":"Proceeding from, or acting by, internal impulse, energy, or natural law, without external force; as, spontaneous motion; spontaneous growth.","pos":""}],"SPONTOON":[{"def":"A kind of half-pike, or halberd, formerly borne by inferior officers of the British infantry, and used in giving signals to the soldiers.","pos":""}],"SPOOK":[{"def":"A spirit; a ghost; an apparition; a hobgoblin.","pos":""}],"SPOOL":[{"def":"A piece of cane or red with a knot at each end, or a hollow cylinder of wood with a ridge at each end, used to wind thread or yarn upon.","pos":""}],"SPOOLER":[{"def":"One who, or that which, spools.","pos":""}],"SPOOM":[{"def":"To be driven steadily and swiftly, as before a strong wind; to be driven before the wind without any sail, or with only a part of the sails spread; to scud under bare poles.","pos":""}],"SPOON":[{"def":"We might have spooned before the wind as well as they.","pos":""}],"SPOON-BILLED":[{"def":"Having the bill expanded and spatulate at the end.","pos":""}],"SPOON-MEAT":[{"def":"Food that is, or must be, taken with a spoon; liquid food.","pos":""}],"SPOONBILL":[{"def":"Note: The roseate spoonbill of America (Ajaja ajaja), and the European spoonbill (Platalea leucorodia) are the best known.","pos":""}],"SPOONDRIFT":[{"def":"Spray blown from the tops waves during a gale at sea; also, snow driven in the wind at sea; -- written also spindrift.","pos":""}],"SPOONEY":[{"def":"Weak-minded; demonstratively fond; as, spooney lovers.","pos":""}],"SPOONFUL":[{"def":"The quantity which a spoon contains, or is able to contain; as, a teaspoonful; a tablespoonful.","pos":""},{"def":"Hence, a small quantity.","pos":""}],"SPOONILY":[{"def":"In a spoony manner.","pos":""}],"SPOONWOOD":[{"def":"The mountain laurel (Kalmia latifolia).","pos":""}],"SPOONWORM":[{"def":"A gephyrean worm of the genus Thalassema, having a spoonlike probiscis.","pos":""}],"SPOONY":[{"def":"Same as Spooney.","pos":""}],"SPOOR":[{"def":"The track or trail of any wild animal; as, the spoor of an elephant; -- used originally by travelers in South Africa.","pos":""}],"SPORADES":[{"def":"Stars not included in any constellation; -- called also informed, or unformed, stars.","pos":""}],"SPORADIC":[{"def":"Occuring singly, or apart from other things of the same kind, or in scattered instances; separate; single; as, a sporadic fireball; a sporadic case of disease; a sporadic example of a flower.","pos":""}],"SPORADICALLY":[{"def":"In a sporadic manner.","pos":""}],"SPORANGIOPHORE":[{"def":"The axis or receptacle in certain ferns (as Trichomanes), which bears the sporangia.","pos":""}],"SPORANGIUM":[{"def":"A spore case in the cryptogamous plants, as in ferns, etc.","pos":""}],"SPORE":[{"def":"Note: Spores are produced differently in the different classes of cryptogamous plants, and as regards their nature are often so unlike that they have only their minuteness in common.","pos":""}],"SPORIDIFEROUS":[{"def":"Bearing sporidia.","pos":""}],"SPORIFEROUS":[{"def":"Bearing or producing spores.","pos":""}],"SPORIFICATION":[{"def":"Spore formation.","pos":""}],"SPOROCYST":[{"def":"An asexual zooid, usually forming one of a series of larval forms in the agamic reproduction of various trematodes and other parasitic worms.","pos":""},{"def":"Any protozoan when it becomes encysted produces germs by sporulation.","pos":""}],"SPOROGENESIS":[{"def":"reproduction by spores.","pos":""}],"SPOROGONY":[{"def":"The growth or development of an animal or a zooid from a nonsexual germ.","pos":""}],"SPOROPHORIC":[{"def":"Having the nature of a sporophore.","pos":""}],"SPOROPHYTE":[{"def":"In plants exhibiting alternation of generations, the generation which bears asexual spores; -- opposed to gametophyte.","pos":""}],"SPOROZOA":[{"def":"An extensive division of parasitic Protozoa, which increase by sporulation.","pos":""}],"SPOROZOID":[{"def":"Same as Zoöspore.","pos":""}],"SPOROZOITE":[{"def":"In certain Sporozoa, a small active, usually elongate, sickle- shaped or somewhat amoboid spore, esp.","pos":""}],"SPORRAN":[{"def":"A large purse or pouch made of skin with the hair or fur on, worn in front of the kilt by Highlanders when in full dress.","pos":""}],"SPORT":[{"def":"A plant or an animal, or part of a plant or animal, which has some peculiarity not usually seen in the species; an abnormal variety or growth.","pos":""}],"SPORTAL":[{"def":"Of or pertaining to sports; used in sports.","pos":""}],"SPORTER":[{"def":"One who sports; a sportsman.","pos":""}],"SPORTFUL":[{"def":"Full of sport; merry; frolicsome; full of jesting; indulging in mirth or play; playful; wanton; as, a sportful companion.","pos":""},{"def":"Done in jest, or for mere play; sportive.","pos":""}],"SPORTING":[{"def":"Of pertaining to, or engaging in, sport or sporrts; exhibiting the character or conduct of one who, or that which, sports.","pos":""}],"SPORTINGLY":[{"def":"In sport; sportively.","pos":""}],"SPORTIVE":[{"def":"Tending to, engaged in, or provocate of, sport; gay; froliscome; playful; merry.","pos":""}],"SPORTLESS":[{"def":"Without sport or mirth; joyless.","pos":""}],"SPORTLING":[{"def":"A little person or creature engaged in sports or in play.","pos":""}],"SPORTSMAN":[{"def":"One who pursues the sports of the field; one who hunts, fishes, etc.","pos":""}],"SPORTSMANSHIP":[{"def":"The practice of sportsmen; skill in field sports.","pos":""}],"SPORTULA":[{"def":"A gift; a present; a prize; hence, an alms; a largess.","pos":""}],"SPORTULARY":[{"def":"Subsisting on alms or charitable contributions.","pos":""}],"SPORTULE":[{"def":"A charitable gift or contribution; a gift; an alms; a dole; a largess; a sportula.","pos":""}],"SPORULATION":[{"def":"The act or process of forming spores; spore formation.","pos":""}],"SPORULE":[{"def":"A small spore; a spore.","pos":""}],"SPORULIFEROUS":[{"def":"Producing sporules.","pos":""}],"SPOT":[{"def":"A variety of the common domestic pigeon, so called from a spot on its head just above its beak.","pos":""},{"def":"Commodities, as merchandise and cotton, sold for immediate delivery.","pos":""}],"SPOT CASH":[{"def":"Cash paid or ready for payment at once upon delivery of property purchased.","pos":""}],"SPOT STROKE":[{"def":"The pocketing of the red ball in a top corner pocket from off its own spot so as to leave the cue ball in position for an easy winning hazard in either top corner pocket.","pos":""}],"SPOTLESS":[{"def":"Without a spot; especially, free from reproach or impurity; pure; untained; innocent; as, a spotless mind; spotless behavior.","pos":""}],"SPOTLIGHT":[{"def":"The projected spot or circle of light used to illuminate brilliantly a single person or object or group on the stage; leaving the rest of the stage more or less unilluminated; hence, conspicuous public notice.","pos":""}],"SPOTTED":[{"def":"Marked with spots; as, a spotted garment or character.","pos":""}],"SPOTTEDNESS":[{"def":"State or quality of being spotted.","pos":""}],"SPOTTINESS":[{"def":"The state or quality of being spotty.","pos":""}],"SPOTTY":[{"def":"Full of spots; marked with spots.","pos":""}],"SPOUSAL":[{"def":"Of or pertaining to a spouse or marriage; nuptial; matrimonial; conjugal; bridal; as, spousal rites; spousal ornaments.","pos":""}],"SPOUSE":[{"def":"A man or woman engaged or joined in wedlock; a married person, husband or wife.","pos":""},{"def":"A married man, in distinct from a spousess or married woman; a bridegroom or husband.","pos":""}],"SPOUSELESS":[{"def":"Destitute of a spouse; unmarried.","pos":""}],"SPOUSESS":[{"def":"A wife or bride.","pos":""}],"SPOUT":[{"def":"To throw out forcibly and abudantly, as liquids through an office or a pipe; to eject in a jet; as, an elephant spouts water from his trunk.","pos":""},{"def":"To utter magniloquently; to recite in an oratorical or pompous manner.","pos":""}],"SPOUTER":[{"def":"One who, or that which, spouts.","pos":""}],"SPOUTFISH":[{"def":"A marine animal that spouts water; -- applied especially to certain bivalve mollusks, like the long clams (Mya), which spout, or squirt out, water when retiring into their holes.","pos":""}],"SPOUTLESS":[{"def":"Having no spout.","pos":""}],"SPOUTSHELL":[{"def":"Any marine gastropod shell of the genus Apporhais having an elongated siphon.","pos":""}]}