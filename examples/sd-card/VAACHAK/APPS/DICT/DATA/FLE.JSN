{"FLEA":[{"def":"He will be fleaced first And horse collars made of's skin.","pos":""}],"FLEA-BEETLE":[{"def":"A small beetle of the family Halticidæ, of many species.","pos":""}],"FLEA-BITE":[{"def":"The bite of a flea, or the red spot caused by the bite.","pos":""},{"def":"A trifling wound or pain, like that of the bite of a flea.","pos":""}],"FLEA-BITTEN":[{"def":"Bitten by a flea; as, a flea-bitten face.","pos":""},{"def":"White, flecked with minute dots of bay or sorrel; -- said of the color of a horse.","pos":""}],"FLEA-LOUSE":[{"def":"A jumping plant louse of the family Psyllidæ, of many species.","pos":""}],"FLEABANE":[{"def":"One of various plants, supposed to have efficacy in driving away fleas.","pos":""}],"FLEAK":[{"def":"A flake; a thread or twist.","pos":""}],"FLEAKING":[{"def":"A light covering of reeds, over which the main covering is laid, in thatching houses.","pos":""}],"FLEAM":[{"def":"A sharp instrument used for opening veins, lancing gums, etc.","pos":""}],"FLEAMY":[{"def":"Bloody; clotted.","pos":""}],"FLEAWORT":[{"def":"An herb used in medicine (Plantago Psyllium), named from the shape of its seeds.","pos":""}],"FLECHE":[{"def":"A simple fieldwork, consisting of two faces forming a salient angle pointing outward and open at the gorge.","pos":""}],"FLECK":[{"def":"A flake; also, a lock, as of wool.","pos":""}],"FLECKLESS":[{"def":"Without spot or blame.","pos":""}],"FLECTION":[{"def":"The act of bending, or state of being bent.","pos":""},{"def":"The variation of words by declension, comparison, or conjugation; inflection.","pos":""}],"FLECTIONAL":[{"def":"Capable of, or pertaining to, flection or inflection.","pos":""}],"FLEDGE":[{"def":"Feathered; furnished with feathers or wings; able to fly.","pos":""}],"FLEDGELING":[{"def":"A young bird just fledged.","pos":""}],"FLEE":[{"def":"To run away, as from danger or evil; to avoid in an alarmed or cowardly manner; to hasten off; -- usually with from.","pos":""}],"FLEECE":[{"def":"The fine web of cotton or wool removed by the doffing knife from the cylinder of a carding machine.","pos":""}],"FLEECED":[{"def":"Furnished with a fleece; as, a sheep is well fleeced.","pos":""},{"def":"Stripped of a fleece; plundered; robbed.","pos":""}],"FLEECELESS":[{"def":"Without a fleece.","pos":""}],"FLEECER":[{"def":"One who fleeces or strips unjustly, especially by trickery or fraund.","pos":""}],"FLEECY":[{"def":"Covered with, made of, or resembling, a fleece.","pos":""}],"FLEER":[{"def":"To make a wry face in contempt, or to grin in scorn; to deride; to sneer; to mock; to gibe; as, to fleer and flout.","pos":""},{"def":"To grin with an air of civility; to leer.","pos":""}],"FLEERINGLY":[{"def":"In a fleering manner.","pos":""}],"FLEET":[{"def":"To slip on the whelps or the barrel of a capstan or windlass; - - said of a cable or hawser.","pos":""}],"FLEETEN":[{"def":"Fleeted or skimmed milk.","pos":""}],"FLEETING":[{"def":"Passing swiftly away; not durable; transient; transitory; as, the fleeting hours or moments.","pos":""}],"FLEETINGLY":[{"def":"In a fleeting manner; swiftly.","pos":""}],"FLEETINGS":[{"def":"A mixture of buttermilk and boiling whey; curds.","pos":""}],"FLEETLY":[{"def":"In a fleet manner; rapidly.","pos":""}],"FLEETNESS":[{"def":"Swiftness; rapidity; velocity; celerity; speed; as, the fleetness of a horse or of time.","pos":""}],"FLEME":[{"def":"To banish; to drive out; to expel.","pos":""}],"FLEMER":[{"def":"One who, or that which, banishes or expels.","pos":""}],"FLEMING":[{"def":"A native or inhabitant of Flanders.","pos":""}],"FLEMISH":[{"def":"Pertaining to Flanders, or the Flemings.","pos":""},{"def":"The language or dialect spoken by the Flemings; also, collectively, the people of Flanders.","pos":""}],"FLENSE":[{"def":"To strip the blubber or skin from, as from a whale, seal, etc.","pos":""}],"FLESH":[{"def":"The aggregate of the muscles, fat, and other tissues which cover the framework of bones in man and other animals; especially, the muscles.","pos":""},{"def":"Animal food, in distinction from vegetable; meat; especially, the body of beasts and birds used as food, as distinguished from fish.","pos":""}],"FLESHED":[{"def":"Corpulent; fat; having flesh.","pos":""},{"def":"Glutted; satiated; initiated.","pos":""}],"FLESHER":[{"def":"A two-handled, convex, blunt-edged knife, for scraping hides; a fleshing knife.","pos":""}],"FLESHHOOD":[{"def":"The state or condition of having a form of flesh; incarnation.","pos":""}],"FLESHINESS":[{"def":"The state of being fleshy; plumpness; corpulence; grossness.","pos":""}],"FLESHINGS":[{"def":"Flesh-colored tights, worn by actors dancers.","pos":""}],"FLESHLESS":[{"def":"Destitute of flesh; lean.","pos":""}],"FLESHLINESS":[{"def":"The state of being fleshly; carnal passions and appetites.","pos":""}],"FLESHLING":[{"def":"A person devoted to fleshly things.","pos":""}],"FLESHLY":[{"def":"Of or pertaining to the flesh; corporeal.","pos":""},{"def":"Animal; not Dryden.","pos":""}],"FLESHMENT":[{"def":"The act of fleshing, or the excitement attending a successful beginning.","pos":""}],"FLESHMONGER":[{"def":"One who deals in flesh; hence, a pimp; a procurer; a pander.","pos":""}],"FLESHPOT":[{"def":"A pot or vessel in which flesh is cooked; hence (pl.","pos":""},{"def":"plenty; high living.","pos":""}],"FLESHQUAKE":[{"def":"A quaking or trembling of the flesh; a quiver.","pos":""}],"FLESHY":[{"def":"Composed of firm pulp; succulent; as, the houseleek, cactus, and agave are fleshy plants.","pos":""}],"FLETCH":[{"def":"To feather, as an arrow.","pos":""}],"FLETCHER":[{"def":"One who fletches of feathers arrows; a manufacturer of bows and arrows.","pos":""}],"FLETE":[{"def":"To float; to swim.","pos":""}],"FLETIFEROUS":[{"def":"Producing tears.","pos":""}],"FLEUR-DE-LIS":[{"def":"A conventional flower suggested by the iris, and having a form which fits it for the terminal decoration of a scepter, the ornaments of a crown, etc.","pos":""}],"FLEURON":[{"def":"A flower-shaped ornament, esp.","pos":""}],"FLEURY":[{"def":"Finished at the ends with fleurs-de-lis; -- said esp.","pos":""}],"FLEWED":[{"def":"Having large flews.","pos":""}],"FLEWS":[{"def":"The pendulous or overhanging lateral parts of the upper lip of dogs, especially prominent in hounds; -- called also chaps.","pos":""}],"FLEX":[{"def":"To bend; as, to flex the arm.","pos":""}],"FLEXANIMOUS":[{"def":"Having power to change the mind.","pos":""}],"FLEXIBILITY":[{"def":"The state or quality of being flexible; flexibleness; pliancy; pliability; as, the flexibility of strips of hemlock, hickory, whalebone or metal, or of rays of light.","pos":""}],"FLEXIBLE":[{"def":"Capable of being flexed or bent; admitting of being turned, bowed, or twisted, without breaking; pliable; yielding to pressure; not stiff or brittle.","pos":""},{"def":"Willing or ready to yield to the influence of others; not invincibly rigid or obstinate; tractable; manageable; ductile; easy and compliant; wavering.","pos":""}],"FLEXICOSTATE":[{"def":"Having bent or curved ribs.","pos":""}],"FLEXILE":[{"def":"Flexible; pliant; pliable; easily bent; plastic; tractable.","pos":""}],"FLEXION":[{"def":"Syntactical change of form of words, as by declension or conjugation; inflection.","pos":""},{"def":"The bending of a limb or joint; that motion of a joint which gives the distal member a continually decreasing angle with the axis of the proximal part; -- distinguished from extension.","pos":""}],"FLEXOR":[{"def":"A muscle which bends or flexes any part; as, the flexors of the arm or the hand; -- opposed to extensor.","pos":""}],"FLEXUOUS":[{"def":"Having alternate curvatures in opposite directions; bent in a zigzag manner.","pos":""}],"FLEXURAL":[{"def":"Of, pertaining to, or resulting from, flexure; of the nature of, or characterized by, flexure; as, flexural elasticity.","pos":""}],"FLEXURE":[{"def":"The last joint, or bend, of the wing of a bird.","pos":""},{"def":"The small distortion of an astronomical instrument caused by the weight of its parts; the amount to be added or substracted from the observed readings of the instrument to correct them for this distortion.","pos":""}]}