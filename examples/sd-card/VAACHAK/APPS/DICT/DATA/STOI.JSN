{"STOIC":[{"def":"A disciple of the philosopher Zeno; one of a Greek sect which held that men should be free from passion, unmoved by joy or grief, and should submit without complaint to unavoidable necessity, by which all things are governed.","pos":""},{"def":"Hence, a person not easily excited; an apathetic person; one who is apparently or professedly indifferent to pleasure or pain.","pos":""}],"STOICHIOLOGICAL":[{"def":"Of or pertaining to stoichiology.","pos":""}],"STOICHIOLOGY":[{"def":"The doctrine of the elementary requisites of mere thought.","pos":""},{"def":"Of or pertaining to stoichiometry; employed in, or obtained by, stoichiometry.","pos":""}],"STOICHIOMETRY":[{"def":"The art or process of calculating the atomic proportions, combining weights, and other numerical relations of chemical elements and their compounds.","pos":""}],"STOICISM":[{"def":"The opinions and maxims of the Stoics.","pos":""},{"def":"A real or pretended indifference to pleasure or pain; insensibility; impassiveness.","pos":""}]}