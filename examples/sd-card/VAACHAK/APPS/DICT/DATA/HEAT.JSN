{"HEAT":[{"def":"A force in nature which is recognized in various effects, but especially in the phenomena of fusion and evaporation, and which, as manifested in fire, the sun's rays, mechanical action, chemical combination, etc.","pos":""},{"def":"The sensation caused by the force or influence of heat when excessive, or above that which is normal to the human body; the bodily feeling experienced on exposure to fire, the sun's rays, etc.","pos":""}],"HEATER":[{"def":"One who, or that which, heats.","pos":""},{"def":"Any contrivance or implement, as a furnace, stove, or other heated body or vessel, etc.","pos":""}],"HEATH":[{"def":"A place overgrown with heath; any cheerless tract of country overgrown with shrubs or coarse herbage.","pos":""}],"HEATHCLAD":[{"def":"Clad or crowned with heath.","pos":""}],"HEATHEN":[{"def":"An individual of the pagan or unbelieving nations, or those which worship idols and do not acknowledge the true God; a pagan; an idolater.","pos":""},{"def":"An irreligious person.","pos":""}],"HEATHENDOM":[{"def":"That part of the world where heathenism prevails; the heathen nations, considered collectively.","pos":""}],"HEATHENISH":[{"def":"Of or pertaining to the heathen; resembling or characteristic of heathens.","pos":""},{"def":"Rude; uncivilized; savage; cruel.","pos":""}],"HEATHENISHLY":[{"def":"In a heathenish manner.","pos":""}],"HEATHENISHNESS":[{"def":"The state or quality of being heathenish.","pos":""}],"HEATHENISM":[{"def":"The religious system or rites of a heathen nation; idolatry; paganism.","pos":""},{"def":"The manners or morals usually prevalent in a heathen country; ignorance; rudeness; barbarism.","pos":""}],"HEATHENIZE":[{"def":"To render heathen or heathenish.","pos":""}],"HEATHENNESS":[{"def":"State of being heathen or like the heathen.","pos":""}],"HEATHENRY":[{"def":"The state, quality, or character of the heathen.","pos":""},{"def":"Heathendom; heathen nations.","pos":""}],"HEATHER":[{"def":"Gorse and grass And heather, where his footsteps pass, The brighter seem.","pos":""}],"HEATHERY":[{"def":"Heathy; abounding in heather; of the nature of heath.","pos":""}],"HEATHY":[{"def":"Full of heath; abounding with heath; as, heathy land; heathy hills.","pos":""}],"HEATING":[{"def":"That heats or imparts heat; promoting warmth or heat; exciting action; stimulating; as, heating medicines or applications.","pos":""}],"HEATINGLY":[{"def":"In a heating manner; so as to make or become hot or heated.","pos":""}],"HEATLESS":[{"def":"Destitute of heat; cold.","pos":""}]}