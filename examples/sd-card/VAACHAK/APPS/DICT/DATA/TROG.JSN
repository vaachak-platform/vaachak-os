{"TROGLODYTE":[{"def":"One of any savage race that dwells in caves, instead of constructing dwellings; a cave dweller.","pos":""},{"def":"An anthropoid ape, as the chimpanzee.","pos":""}],"TROGLODYTES":[{"def":"A genus of apes including the chimpanzee.","pos":""},{"def":"A genus of singing birds including the common wrens.","pos":""}],"TROGON":[{"def":"Any one of numerous species of beautiful tropical birds belonging to the family Trogonidæ.","pos":""}],"TROGONOID":[{"def":"Like or pertaining to the trogons.","pos":""}],"TROGUE":[{"def":"A wooden trough, forming a drain.","pos":""}]}