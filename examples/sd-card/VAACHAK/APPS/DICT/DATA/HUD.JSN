{"HUD":[{"def":"A huck or hull, as of a nut.","pos":""}],"HUDDLE":[{"def":"To press together promiscuously, from confusion, apprehension, or the like; to crowd together confusedly; to press or hurry in disorder; to crowd.","pos":""}],"HUDDLER":[{"def":"One who huddles things together.","pos":""}],"HUDGE":[{"def":"An iron bucket for hoisting coal or ore.","pos":""}],"HUDIBRASTIC":[{"def":"Similar to, or in the style of, the poem \"Hudibras,\" by Samuel Butler; in the style of doggerel verse.","pos":""}],"HUDSONIAN":[{"def":"Of or pertaining to Hudson's Bay or to the Hudson River; as, the Hudsonian curlew.","pos":""}]}