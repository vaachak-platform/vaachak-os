{"LAP":[{"def":"The amount by which a slide valve at its half stroke overlaps a port in the seat, being equal to the distance the valve must move from its mid stroke position in order to begin to open the port.","pos":""},{"def":"A sheet, layer, or bat, of cotton fiber prepared for the carding machine.","pos":""}],"LAP-JOINTED":[{"def":"Having a lap joint, or lap joints, as many kinds of woodwork and metal work.","pos":""}],"LAP-WELDED":[{"def":"Having edges or ends united by a lap weld; as, a lap-welded pipe.","pos":""}],"LAPAROCELE":[{"def":"A rupture or hernia in the lumbar regions.","pos":""}],"LAPAROTOMY":[{"def":"A cutting through the walls of the abdomen, as in the Cæsarean section.","pos":""}],"LAPBOARD":[{"def":"A board used on the lap as a substitute for a table, as by tailors.","pos":""}],"LAPDOG":[{"def":"A small dog fondled in the lap.","pos":""}],"LAPEL":[{"def":"That part of a garment which is turned back; specifically, the lap, or fold, of the front of a coat in continuation of collar.","pos":""}],"LAPELLED":[{"def":"Furnished with lapels.","pos":""}],"LAPFUL":[{"def":"As much as the lap can contain.","pos":""}],"LAPIDARIAN":[{"def":"Of or pertaining to stone; inscribed on stone; as, a lapidarian record.","pos":""}],"LAPIDARIOUS":[{"def":"Consisting of stones.","pos":""}],"LAPIDARY":[{"def":"An artificer who cuts, polishes, and engraves precious stones; hence, a dealer in precious stones.","pos":""},{"def":"A virtuoso skilled in gems or precious stones; a connoisseur of lapidary work.","pos":""}],"LAPIDATION":[{"def":"The act of stoning.","pos":""}],"LAPIDEOUS":[{"def":"Of the nature of stone; [Obs.","pos":""}],"LAPIDESCENCE":[{"def":"The state or quality of being lapidescent.","pos":""},{"def":"A hardening into a stone substance.","pos":""}],"LAPIDESCENT":[{"def":"Undergoing the process of becoming stone; having the capacity of being converted into stone; having the quality of petrifying bodies.","pos":""}],"LAPIDIFICATION":[{"def":"The act or process of lapidifying; fossilization; petrifaction.","pos":""}],"LAPIDIFY":[{"def":"To convert into stone or stony material; to petrify.","pos":""}],"LAPILLATION":[{"def":"The state of being, or the act of making, stony.","pos":"noun"}],"LAPILLI":[{"def":"Volcanic ashes, consisting of small, angular, stony fragments or particles.","pos":""}],"LAPIS LAZULI":[{"def":"An albuminous mineral of a rich blue color.","pos":""}],"LAPLANDER":[{"def":"A native or inhabitant of Lapland; -- called also Lapp.","pos":""}],"LAPLANDISH":[{"def":"Of or pertaining to Lapland.","pos":""}],"LAPLING":[{"def":"One who has been fondled to excess; one fond of ease and sensual delights; -- a term of contempt.","pos":""}],"LAPP":[{"def":"Same as Laplander.","pos":""}],"LAPPACEOUS":[{"def":"Resembling the capitulum of burdock; covered with forked points.","pos":""}],"LAPPER":[{"def":"One who takes up food or liquid with his tongue.","pos":""}],"LAPPET":[{"def":"A small decorative fold or flap, esp, of lace or muslin, in a garment or headdress.","pos":""}],"LAPPIC":[{"def":"Of or pertaining to Lapland, or the Lapps.","pos":""},{"def":"The language of the Lapps.","pos":""}],"LAPPING":[{"def":"A kind of machine blanket or wrapping material used by calico printers.","pos":""}],"LAPPISH":[{"def":"Of or pertaining to the Lapps; Laplandish.","pos":""},{"def":"The language spoken by the Lapps in Lapland.","pos":""}],"LAPPS":[{"def":"A branch of the Mongolian race, now living in the northern parts of Norway, Sweden, and the adjacent parts of Russia.","pos":""}],"LAPSE":[{"def":"The termination of a right or privilege through neglect to exercise it within the limited time, or through failure of some contingency; hence, the devolution of a right or privilege.","pos":""},{"def":"A fall or apostasy.","pos":""}],"LAPSED":[{"def":"Having slipped downward, backward, or away; having lost position, privilege, etc.","pos":""},{"def":"Ineffectual, void, or forfeited; as, a lapsed policy of insurance; a lapsed legacy.","pos":""}],"LAPSIBLE":[{"def":"Liable to lapse.","pos":""}],"LAPSTONE":[{"def":"A stone for the lap, on which shoemakers beat leather.","pos":""},{"def":"Made with boards whose edges lap one over another; clinker- built; -- said of boats.","pos":""}],"LAPUTAN":[{"def":"Of or pertaining to Laputa, an imaginary flying island described in Gulliver's Travels as the home of chimerical philosophers.","pos":""}],"LAPWING":[{"def":"A small European bird of the Plover family (Vanellus cristatus, or V.","pos":""}],"LAPWORK":[{"def":"Work in which one part laps over another.","pos":""}]}