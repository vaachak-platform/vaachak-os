{"MAD":[{"def":"Disordered in intellect; crazy; insane.","pos":""},{"def":"Excited beyond self-control or the restraint of reason; inflamed by violent or uncontrollable desire, passion, or appetite; as, to be mad with terror, lust, or hatred; mad against political reform.","pos":""}],"MAD-HEADED":[{"def":"Wild; crack-brained.","pos":""}],"MADAM":[{"def":"A gentlewoman; -- an appellation or courteous form of address given to a lady, especially an elderly or a married lady; -- much used in the address, at the beginning of a letter, to a woman.","pos":""}],"MADAME":[{"def":"My lady; -- a French title formerly given to ladies of quality; now, in France, given to all married women.","pos":""}],"MADBRAIN":[{"def":"Hot-headed; rash.","pos":""},{"def":"A rash or hot-headed person.","pos":""}],"MADBRAINED":[{"def":"Disordered in mind; hot-headed.","pos":""}],"MADCAP":[{"def":"Inclined to wild sports; delighting in rash, absurd, or dangerous amusements.","pos":""}],"MADDEN":[{"def":"To make mad; to drive to madness; to craze; to excite violently with passion; to make very angry; to enrage.","pos":""}],"MADDER":[{"def":"A plant of the Rubia (R.","pos":""}],"MADDERWORT":[{"def":"A name proposed for any plant of the same natural order (Rubiaceæ) as the madder.","pos":""}],"MADDING":[{"def":"Affected with madness; raging; furious.","pos":""}],"MADE":[{"def":"Artificially produced; pieced together; formed by filling in; as, made ground; a made mast, in distinction from one consisting of a single spar.","pos":""},{"def":"A native or inhabitant of Madagascar, or Madecassee; the language of the natives of Madagascar.","pos":""}],"MADECASSEE":[{"def":"Of or pertaining to Madagascar or its inhabitants.","pos":""},{"def":"The act of madefying, or making wet; the state of that which is made wet.","pos":""}],"MADEFY":[{"def":"To make wet or moist.","pos":""}],"MADEIRA":[{"def":"A rich wine made on the Island of Madeira.","pos":""}],"MADEIRA VINE":[{"def":"A herbaceous climbing vine (Boussingaultia baselloides) very popular in cultivation, having shining entire leaves and racemes of small fragrant white flowers.","pos":""}],"MADEMOISELLE":[{"def":"A marine food fish (Sciæna chrysura), of the Southern United States; -- called also yellowtail, and silver perch.","pos":""}],"MADHOUSE":[{"def":"A house where insane persons are confined; an insane asylum; a bedlam.","pos":""}],"MADIA":[{"def":"A genus of composite plants, of which one species (Madia sativa) is cultivated for the oil yielded from its seeds by pressure.","pos":""}],"MADID":[{"def":"Wet; moist; as, a madid eye.","pos":""}],"MADISTERIUM":[{"def":"An instrument to extract hairs.","pos":""}],"MADJOUN":[{"def":"An intoxicating confection from the hemp plant; -- used by the Turks and Hindoos.","pos":""}],"MADLY":[{"def":"In a mad manner; without reason or understanding; wildly.","pos":""}],"MADMAN":[{"def":"A man who is mad; lunatic; a crazy person.","pos":""}],"MADNEP":[{"def":"The masterwort (Peucedanum Ostruthium).","pos":""}],"MADNESS":[{"def":"The condition of being mad; insanity; lunacy.","pos":""},{"def":"Frenzy; ungovernable rage; extreme folly.","pos":""}],"MADONNA":[{"def":"A picture of the Virgin Mary (usually with the babe).","pos":""}],"MADOQUA":[{"def":"A small Abyssinian antelope (Neotragus Saltiana), about the size of a hare.","pos":""}],"MADRAGUE":[{"def":"A large fish pound used for the capture of the tunny in the Mediterranean; also applied to the seines used for the same purpose.","pos":""}],"MADRAS":[{"def":"A large silk-and-cotton kerchief, usually of bright colors, such as those often used by negroes for turbans.","pos":""}],"MADREPERL":[{"def":"Mother-of-pearl.","pos":""}],"MADREPORA":[{"def":"A genus of reef corals abundant in tropical seas.","pos":""}],"MADREPORARIA":[{"def":"An extensive division of Anthozoa, including most of the species that produce stony corals.","pos":""}],"MADREPORE":[{"def":"Any coral of the genus Madrepora; formerly, often applied to any stony coral.","pos":""},{"def":"Resembling, or pertaining to, the genus Madrepora.","pos":""}],"MADREPORIFORM":[{"def":"Resembling a madreporian coral in form or structure.","pos":""}],"MADREPORITE":[{"def":"The madreporic plate of echinoderms.","pos":""}],"MADRIER":[{"def":"A thick plank, used for several mechanical purposes; especially: (a) A plank to receive the mouth of a petard, with which it is applied to anything intended to be broken down.","pos":""}],"MADRIGAL":[{"def":"An unaccompanied polyphonic song, in four, five, or more parts, set to secular words, but full of counterpoint and imitation, and adhering to the old church modes.","pos":""}],"MADRIGALIST":[{"def":"A composer of madrigals.","pos":""}],"MADRILENIAN":[{"def":"Of or pertaining to Madrid in Spain, or to its inhabitants.","pos":""},{"def":"A native or inhabitant of Madrid.","pos":""}],"MADRINA":[{"def":"An animal (usually an old mare), wearing a bell and acting as the leader of a troop of pack mules.","pos":""}],"MADRO":[{"def":"A small evergreen tree or shrub (Arbutus Menziesii), of California, having a smooth bark, thick shining leaves, and edible red berries, which are often called madroña apples.","pos":""},{"def":"A small evergreen tree or shrub (Arbutus Menziesii), of California, having a smooth bark, thick shining leaves, and edible red berries, which are often called madroña apples.","pos":""}],"MADWORT":[{"def":"A genus of cruciferous plants (Alyssum) with white or yellow flowers and rounded pods.","pos":""},{"def":"Compensation for the injury done by slaying a kinsman.","pos":""}]}