{"THRACIAN":[{"def":"Of or pertaining to Thrace, or its people.","pos":""},{"def":"A native or inhabitant of Thrace.","pos":""}],"THRACK":[{"def":"To load or burden; as, to thrack a man with property.","pos":""}],"THRACKSCAT":[{"def":"Metal still in the mine.","pos":""}],"THRALDOM":[{"def":"The condition of a thrall; slavery; bondage; state of servitude.","pos":""}],"THRALL":[{"def":"A slave; a bondman.","pos":""},{"def":"Slavery; bondage; servitude; thraldom.","pos":""}],"THRALL-LIKE":[{"def":"Resembling a thrall, or his condition, feelings, or the like; slavish.","pos":""}],"THRANITE":[{"def":"One of the rowers on the topmost of the three benches in a trireme.","pos":""}],"THRAPPLE":[{"def":"Windpipe; throttle.","pos":""}],"THRASHEL":[{"def":"An instrument to thrash with; a flail.","pos":""},{"def":"A large and voracious shark (Alopias vulpes), remarkable for the great length of the upper lobe of its tail, with which it beats, or thrashes, its prey.","pos":""}],"THRASHING":[{"def":"Thrash\"ing, Defn: a.","pos":""}],"THRASONICAL":[{"def":"Of or pertaining to Thraso; like, or becoming to, Thraso; bragging; boastful; vainglorious.","pos":""}],"THRAVE":[{"def":"Twenty-four (in some places, twelve) sheaves of wheat; a shock, or stook.","pos":""},{"def":"The number of two dozen; also, an indefinite number; a bunch; a company; a throng.","pos":""}]}