{"RYAL":[{"def":"See Rial, and old English coin.","pos":""}],"RYDER":[{"def":"A gold coin of Zealand [Netherlands] equal to 14 florins, about $ 5.","pos":""}],"RYE":[{"def":"A grain yielded by a hardy cereal grass (Secale cereale), closely allied to wheat; also, the plant itself.","pos":""}],"RYND":[{"def":"A piece of iron crossing the hole in the upper millstone by which the stone is supported on the spindle.","pos":""}],"RYOT":[{"def":"A peasant or cultivator of the soil.","pos":""}],"RYPOPHAGOUS":[{"def":"Eating, or subsisting on, filth.","pos":""}],"RYTINA":[{"def":"A genus of large edentulous sirenians, allied to the dugong and manatee, including but one species (R.","pos":""},{"def":"the nineteenth letter of the English alphabet, is a consonanat, and is often called a sibilant, in allusion to its hissing sound.","pos":""}]}