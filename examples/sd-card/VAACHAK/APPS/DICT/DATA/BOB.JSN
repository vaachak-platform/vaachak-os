{"BOB":[{"def":"Anything that hangs so as to play loosely, or with a short abrupt motion, as at the end of a string; a pendant; as, the bob at the end of a kite's tail.","pos":""},{"def":"A knot of worms, or of rags, on a string, used in angling, as for eels; formerly, a worm suitable for bait.","pos":""}],"BOB WIG":[{"def":"A short wig with bobs or short curls; -- called also bobtail wig.","pos":""}],"BOB-CHERRY":[{"def":"A play among children, in which a cherry, hung so as to bob against the mouth, is to be caught with the teeth.","pos":""}],"BOBAC":[{"def":"The Poland marmot (Arctomys bobac).","pos":""}],"BOBBER":[{"def":"One who, or that which, bobs.","pos":""}],"BOBBERY":[{"def":"A squabble; a tumult; a noisy disturbance; as, to raise a bobbery.","pos":""}],"BOBBIN":[{"def":"A fine cord or narrow braid.","pos":""},{"def":"A cylindrical or spool-shaped coil or insulated wire, usually containing a core of soft iron which becomes magnetic when the wire is traversed by an electrical current.","pos":""}],"BOBBINET":[{"def":"A kind of cotton lace which is wrought by machines, and not by hand.","pos":""}],"BOBBINWORK":[{"def":"Work woven with bobbins.","pos":""}],"BOBBISH":[{"def":"Hearty; in good spirits.","pos":""}],"BOBBY":[{"def":"A nickname for a policeman; -- from Sir Robert Peel, who remodeled the police force.","pos":""}],"BOBFLY":[{"def":"The fly at the end of the leader; an end fly.","pos":""}],"BOBOLINK":[{"def":"An American singing bird (Dolichonyx oryzivorus).","pos":""},{"def":"A short sled, mostly used as one of a pair connected by a reach or coupling; also, the compound sled so formed.","pos":""}],"BOBSTAY":[{"def":"A rope or chain to confine the bowsprit of a ship downward to the stem or cutwater; -- usually in the pl.","pos":""}],"BOBTAIL":[{"def":"An animal (as a horse or dog) with a short tail.","pos":""}],"BOBTAILED":[{"def":"Having the tail cut short, or naturally short; curtailed; as, a bobtailed horse or dog; a bobtailed coat.","pos":""}],"BOBWHITE":[{"def":"The common qua(Colinus, or Ortyx, Virginianus); -- so called from its note.","pos":""}]}