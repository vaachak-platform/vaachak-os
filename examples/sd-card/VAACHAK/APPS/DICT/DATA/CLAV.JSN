{"CLAVECIN":[{"def":"The harpsichord.","pos":""}],"CLAVELLATED":[{"def":"Said of potash, probably in reference to its having been obtained from billets of wood by burning.","pos":""}],"CLAVER":[{"def":"Frivolous or nonsensical talk; prattle; chattering.","pos":""}],"CLAVICHORD":[{"def":"A keyed stringed instrument, now superseded by the pianoforte.","pos":""}],"CLAVICLE":[{"def":"The collar bone, which is joined at one end to the scapula, or shoulder blade, and at the other to the sternum, or breastbone.","pos":""}],"CLAVICORN":[{"def":"Having club-shaped antennæ.","pos":""},{"def":"One of the Clavicornes.","pos":""}],"CLAVICORNES":[{"def":"A group of beetles having club-shaped antennæ.","pos":""}],"CLAVICULAR":[{"def":"Of or pertaining to the clavicle.","pos":""}],"CLAVIER":[{"def":"The keyboard of an organ, pianoforte, or harmonium.","pos":""}],"CLAVIFORM":[{"def":"Club-shaped; clavate.","pos":""}],"CLAVIGER":[{"def":"One who carries the keys of any place.","pos":""}],"CLAVIGEROUS":[{"def":"Bearing a club or a key.","pos":""}],"CLAVIS":[{"def":"A key; a glossary.","pos":""}],"CLAVUS":[{"def":"A callous growth, esp.","pos":""}]}