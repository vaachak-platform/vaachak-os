{"GOA":[{"def":"A species of antelope (Procapra picticauda), inhabiting Thibet.","pos":""}],"GOA POWDER":[{"def":"A bitter powder (also called araroba) found in the interspaces of the wood of a Brazilian tree (Andira araroba) and used as a medicine.","pos":""}],"GOAD":[{"def":"A pointed instrument used to urge on a beast; hence, any necessity that urges or stimulates.","pos":""}],"GOAF":[{"def":"That part of a mine from which the mineral has been partially or wholly removed; the waste left in old workings; -- called also gob .","pos":""}],"GOAL":[{"def":"The mark set to bound a race, and to or around which the constestants run, or from which they start to return to it again; the place at which a race or a journey is to end.","pos":""},{"def":"The final purpose or aim; the end to which a design tends, or which a person aims to reach or attain.","pos":""}],"GOAR":[{"def":"Same as lst Gore.","pos":""}],"GOAT":[{"def":"A hollow-horned ruminant of the genus Capra, of several species and varieties, esp.","pos":""}],"GOATEE":[{"def":"A part of a man's beard on the chin or lower lip which is allowed to grow, and trimmed so as to resemble the beard of a goat.","pos":""}],"GOATFISH":[{"def":"A fish of the genus Upeneus, inhabiting the Gulf of Mexico.","pos":""}],"GOATHERD":[{"def":"One who tends goats.","pos":""}],"GOATISH":[{"def":"Characteristic of a goat; goatlike.","pos":""}],"GOATLIKE":[{"def":"Like a goat; goatish.","pos":""}],"GOATSKIN":[{"def":"The skin of a goat, or leather made from it.","pos":""},{"def":"Made of the skin of a goat.","pos":""}],"GOATSUCKER":[{"def":"One of several species of insectivorous birds, belonging to Caprimulgus and allied genera, esp.","pos":""}]}