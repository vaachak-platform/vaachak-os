{"BUR FISH":[{"def":"A spinose, plectognath fish of the Allantic coast of the United States (esp.","pos":""}],"BUR MARIGOLD":[{"def":"See Beggar's ticks.","pos":""}],"BURBOT":[{"def":"A fresh-water fish of the genus Lota, having on the nose two very small barbels, and a larger one on the chin.","pos":""}],"BURDELAIS":[{"def":"A sort of grape.","pos":""}],"BURDEN":[{"def":"The tops or heads of stream-work which lie over the stream of tin.","pos":""},{"def":"The proportion of ore and flux to fuel, in the charge of a blast furnace.","pos":""}],"BURDENER":[{"def":"One who loads; a oppressor.","pos":""}],"BURDENSOME":[{"def":"Grievous to be borne; causing uneasiness or fatigue; oppressive.","pos":""}],"BURDOCK":[{"def":"A genus of coarse biennial herbs (Lappa), bearing small burs which adhere tenaciously to clothes, or to the fur or wool of animals.","pos":""}],"BURDON":[{"def":"A pilgrim's staff.","pos":""}],"BUREAU":[{"def":"Originally, a desk or writing table with drawers for papers.","pos":""},{"def":"The place where such a bureau is used; an office where business requiring writing is transacted.","pos":""}],"BUREAUCRACY":[{"def":"A system of carrying on the business of government by means of departments or bureaus, each under the control of a chief, in contradiction to a system in which the officers of government have an associated authority and responsibility; also, government conducted on this system.","pos":""},{"def":"Government officials, collectively.","pos":""}],"BUREAUCRAT":[{"def":"An official of a bureau; esp.","pos":""},{"def":"Of, relating to, or resembling, a bureaucracy.","pos":""}],"BUREAUCRATIST":[{"def":"An advocate for , or supporter of, bureaucracy.","pos":""}],"BURETTE":[{"def":"An apparatus for delivering measured quantities of liquid or for measuring the quantity of liquid or gas received or discharged.","pos":""}],"BURG":[{"def":"A fortified town.","pos":""}],"BURGAGE":[{"def":"A tenure by which houses or lands are held of the king or other lord of a borough or city; at a certain yearly rent, or by services relating to trade or handicraft.","pos":""}],"BURGALL":[{"def":"A small marine fish; -- also called cunner.","pos":""}],"BURGEE":[{"def":"A kind of small coat.","pos":""}],"BURGEOIS":[{"def":"See 1st Bourgeous.","pos":""}],"BURGESS":[{"def":"An inhabitant of a borough or walled town, or one who possesses a tenement therein; a citizen or freeman of a borough.","pos":""},{"def":"One who represents a borough in Parliament.","pos":""}],"BURGESS-SHIP":[{"def":"The state of privilege of a burgess.","pos":""}],"BURGGRAVE":[{"def":"Originally, one appointed to the command of a burg (fortress or castle); but the title afterward became hereditary, with a domain attached.","pos":""}],"BURGH":[{"def":"A borough or incorporated town, especially, one in Scotland.","pos":""}],"BURGHAL":[{"def":"Belonging of a burgh.","pos":""}],"BURGHBOTE":[{"def":"A contribution toward the building or repairing of castles or walls for the defense of a city or town.","pos":""}],"BURGHBRECH":[{"def":"The offense of violating the pledge given by every inhabitant of a tithing to keep the peace; breach of the peace.","pos":""}],"BURGHER":[{"def":"A member of that party, among the Scotch seceders, which asserted the lawfulness of the burgess oath (in which burgesses profess \"the true religion professed within the realm\"), the opposite party being called antiburghers.","pos":""}],"BURGHERMASTER":[{"def":"See Burgomaster.","pos":""}],"BURGHERSHIP":[{"def":"The state or privileges of a burgher.","pos":""}],"BURGHMASTER":[{"def":"An officer who directs and lays out the meres or boundaries for the workmen; -- called also bailiff, and barmaster.","pos":""}],"BURGHMOTE":[{"def":"A court or meeting of a burgh or borough; a borough court held three times yearly.","pos":""}],"BURGLAR":[{"def":"One guilty of the crime of burglary.","pos":""}],"BURGLARIOUS":[{"def":"Pertaining to burglary; constituting the crime of burglary.","pos":""}],"BURGLARIOUSLY":[{"def":"With an intent to commit burglary; in the manner of a burglar.","pos":""}],"BURGLARY":[{"def":"Breaking and entering the dwelling house of another, in the nighttime, with intent to commit a felony therein, whether the felonious purpose be accomplished or not.","pos":""}],"BURGOMASTER":[{"def":"An aquatic bird, the glaucous gull (Larus glaucus), common in arctic regions.","pos":""}],"BURGONET":[{"def":"A kind of helmet.","pos":""}],"BURGOO":[{"def":"A kind of oatmeal pudding, or thick gruel, used by seamen.","pos":""}],"BURGRASS":[{"def":"Grass of the genus Cenchrus, growing in sand, and having burs for fruit.","pos":""}],"BURGUNDY":[{"def":"An old province of France (in the eastern central part).","pos":""},{"def":"A richly flavored wine, mostly red, made in Burgundy, France.","pos":""}],"BURH":[{"def":"The wild Himalayan, or blue, sheep (Ovis burrhel).","pos":""}],"BURIAL":[{"def":"A grave; a tomb; a place of sepulture.","pos":""},{"def":"The act of burying; depositing a dead body in the earth, in a tomb or vault, or in the water, usually with attendant ceremonies; sepulture; interment.","pos":""}],"BURIER":[{"def":"One who, or that which, buries.","pos":""}],"BURIN":[{"def":"The cutting tool of an engraver on metal, used in line engraving.","pos":""},{"def":"The manner or style of execution of an engraver; as, a soft burin; a brilliant burin.","pos":""}],"BURINIST":[{"def":"One who works with the burin.","pos":""}],"BURION":[{"def":"The red-breasted house sparrow of California (Carpodacus frontalis); -- called also crimson-fronted bullfinch.","pos":""}],"BURKE":[{"def":"To murder by suffocation, or so as to produce few marks of violence, for the purpose of obtaining a body to be sold for dissection.","pos":""},{"def":"To dispose of quietly or indirectly; to suppress; to smother; to shelve; as, to burke a parliamentary question.","pos":""}],"BURKISM":[{"def":"The practice of killing persons for the purpose of selling their bodies for dissection.","pos":""}],"BURL":[{"def":"To dress or finish up (cloth); to pick knots, burs, loose threads, etc.","pos":""}],"BURLAP":[{"def":"A coarse fabric, made of jute or hemp, used for bagging; also, a finer variety of similar material, used for curtains, etc.","pos":""}],"BURLER":[{"def":"One who burls or dresses cloth.","pos":""}],"BURLESQUE":[{"def":"Tending to excite laughter or contempt by extravagant images, or by a contrast between the subject and the manner of treating it, as when a trifling subject is treated with mock gravity; jocular; ironical.","pos":""}],"BURLESQUER":[{"def":"One who burlesques.","pos":""}],"BURLETTA":[{"def":"A comic operetta; a music farce.","pos":""}],"BURLINESS":[{"def":"Quality of being burly.","pos":""}],"BURLY":[{"def":"Having a large, strong, or gross body; stout; lusty; -- now used chiefly of human beings, but formerly of animals, in the sense of stately or beautiful, and of inanimate things that were huge and bulky.","pos":""},{"def":"Coarse and rough; boisterous.","pos":""}],"BURMAN":[{"def":"A member of the Burman family, one of the four great families Burmah; also, sometimes, any inhabitant of Burmah; a Burmese.","pos":""},{"def":"Of or pertaining to the Burmans or to Burmah.","pos":""}],"BURMESE":[{"def":"Of or pertaining to Burmah, or its inhabitants.","pos":""},{"def":"A native or the natives of Burmah.","pos":""}],"BURN":[{"def":"To apply a cautery to; to cauterize.","pos":"verb"},{"def":"To cause to combine with oxygen or other active agent, with evolution of heat; to consume; to oxidize; as, a man burns a certain amount of carbon at each respiration; to burn iron in oxygen.","pos":"verb"}],"BURNER":[{"def":"One who, or that which, burns or sets fire to anything.","pos":""},{"def":"The part of a lamp, gas fixture, etc.","pos":""}],"BURNET":[{"def":"A genus of perennial herbs (Poterium); especially, P.","pos":""}],"BURNETTIZE":[{"def":"To subject (wood, fabrics, etc.","pos":""}],"BURNING":[{"def":"That burns; being on fire; excessively hot; fiery.","pos":""},{"def":"Consuming; intense; inflaming; exciting; vehement; powerful; as, burning zeal.","pos":""}],"BURNISH":[{"def":"To cause to shine; to make smooth and bright; to polish; specifically, to polish by rubbing with something hard and smooth; as, to burnish brass or paper.","pos":""}],"BURNISHER":[{"def":"One who burnishes.","pos":""},{"def":"A tool with a hard, smooth, rounded end or surface, as of steel, ivory, or agate, used in smoothing or polishing by rubbing.","pos":""}],"BURNSTICKLE":[{"def":"A stickleback (Gasterosteus aculeatus).","pos":""}],"BURNT":[{"def":"Consumed with, or as with, fire; scorched or dried, as with fire or heat; baked or hardened in the fire or the sun.","pos":""}],"BURR":[{"def":"A guttural pronounciation of the letter r, produced by trilling the extremity of the soft palate against the back part of the tongue; rotacism; -- often called the Newcastle, Northumberland, or Tweedside, burr.","pos":""}],"BURREL":[{"def":"A sort of pear, called also the red butter pear, from its smooth, delicious, soft pulp.","pos":""}],"BURREL FLY":[{"def":"The botfly or gadfly of cattle (Hypoderma bovis).","pos":""}],"BURREL SHOT":[{"def":"A mixture of shot, nails, stones, pieces of old iron, etc.","pos":""}],"BURRING MACHINE":[{"def":"A machine for cleansing wool of burs, seeds, and other substances.","pos":""}],"BURROCK":[{"def":"A small weir or dam in a river to direct the stream to gaps where fish traps are placed.","pos":""}],"BURROW":[{"def":"A heap or heaps of rubbish or refuse.","pos":""}],"BURROWER":[{"def":"One who, or that which, burrows; an animal that makes a hole under ground and lives in it.","pos":""}],"BURRY":[{"def":"Abounding in burs, or containing burs; resembling burs; as, burry wool.","pos":""}],"BURSA":[{"def":"Any sac or saclike cavity; especially, one of the synovial sacs, or small spaces, often lined with synovial membrane, interposed between tendons and bony prominences.","pos":""}],"BURSAL":[{"def":"Of or pertaining to a bursa or to bursæ.","pos":""}],"BURSAR":[{"def":"A treasurer, or cash keeper; a purser; as, the bursar of a college, or of a monastery.","pos":""},{"def":"A student to whom a stipend or bursary is paid for his complete or partial support.","pos":""}],"BURSARSHIP":[{"def":"The office of a bursar.","pos":""}],"BURSARY":[{"def":"The treasury of a college or monastery.","pos":""},{"def":"A scholarship or charitable foundation in a university, as in scotland; a sum given to enable a student to pursue his studies.","pos":""}],"BURSCH":[{"def":"A youth; especially, a student in a german university.","pos":""}],"BURSCHENSCHAFT":[{"def":"In Germany, any of various associations of university students formed (the original one at Jena in 1815) to support liberal ideas, or the organization formed by the affiliation of the local bodies.","pos":""}],"BURSE":[{"def":"An ornamental case of hold the corporal when not in use.","pos":""}],"BURSIFORM":[{"def":"Shaped like a purse.","pos":""}],"BURSITIS":[{"def":"Inflammation of a bursa.","pos":""}],"BURST":[{"def":"To fly apart or in pieces; of break open; to yield to force or pressure, especially to a sudden and violent exertion of force, or to pressure from within; to explode; as, the boiler had burst; the buds will burst in spring.","pos":""}],"BURSTER":[{"def":"One that bursts.","pos":""}],"BURSTWORT":[{"def":"A plant (Herniaria glabra) supposed to be valuable for the cure of hernia or rupture.","pos":""}],"BURTON":[{"def":"A peculiar tackle, formed of two or more blocks, or pulleys, the weight being suspended of a hook block in the bight of the running part.","pos":""}],"BURY":[{"def":"A borough; a manor; as, the Bury of St.","pos":""},{"def":"A manor house; a castle.","pos":""}]}