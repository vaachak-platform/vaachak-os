{"MONOSEPALOUS":[{"def":"Having only one sepal, or the calyx in one piece or composed of the sepals united into one piece; gamosepalous.","pos":""}],"MONOSPERM":[{"def":"A monospermous plant.","pos":""},{"def":"Having only one seed.","pos":""}],"MONOSPHERICAL":[{"def":"Consisting of one sphere only.","pos":""}],"MONOSTICH":[{"def":"A composition consisting of one verse only.","pos":""}],"MONOSTICHOUS":[{"def":"Arranged in a single row on one side of an axis, as the flowers in grasses of the tribe Chloridæ.","pos":""}],"MONOSTROPHE":[{"def":"A metrical composition consisting of a single strophe.","pos":""}],"MONOSTROPHIC":[{"def":"Having one strophe only; not varied in measure; written in unvaried measure.","pos":""}],"MONOSULPHIDE":[{"def":"A sulphide containing one atom of sulphur, and analogous to a monoxide; -- contrasted with a Ant: polysulphide; as, galena is a monosulphide.","pos":""}],"MONOSULPHURET":[{"def":"See Monosulphide.","pos":""}],"MONOSYLLABIC":[{"def":"Being a monosyllable, or composed of monosyllables; as, a monosyllabic word; a monosyllabic language.","pos":""}],"MONOSYLLABISM":[{"def":"The state of consisting of monosyllables, or having a monosyllabic form; frequent occurrence of monosyllables.","pos":""}],"MONOSYLLABLE":[{"def":"A word of one syllable.","pos":""}],"MONOSYLLABLED":[{"def":"Formed into, or consisting of, monosyllables.","pos":""},{"def":"Same as Monoclinic.","pos":""}]}