{"THRIBBLE":[{"def":"Triple; treble; threefold.","pos":""}],"THRICE":[{"def":"In a threefold manner or degree; repeatedly; very.","pos":""}],"THRICECOCK":[{"def":"The missel thrush.","pos":""}],"THRID":[{"def":"To pass through in the manner of a thread or a needle; to make or find a course through; to thread.","pos":""},{"def":"To make or effect (a way or course) through something; as, to thrid one's way through a wood.","pos":""}],"THRIFALLOW":[{"def":"See Thryfallow, and Trifallow.","pos":""}],"THRIFT":[{"def":"One of several species of flowering plants of the genera Statice and Armeria.","pos":""}],"THRIFTILY":[{"def":"In a thrifty manner.","pos":""},{"def":"Carefully; properly; becomingly.","pos":""}],"THRIFTINESS":[{"def":"The quality or state of being thrifty; thrift.","pos":""}],"THRIFTLESS":[{"def":"Without thrift; not prudent or prosperous in money affairs.","pos":""}],"THRIFTY":[{"def":"Given to, or evincing, thrift; characterized by economy and good menegement of property; sparing; frugal.","pos":""},{"def":"Thriving by industry and frugality; prosperous in the acquisition of worldly goods; increasing in wealth; as, a thrifty farmer or mechanic.","pos":""}],"THRILL":[{"def":"A warbling; a trill.","pos":""}],"THRILLANT":[{"def":"Piercing; sharp; thrilling.","pos":""}],"THRILLING":[{"def":"Causing a thrill; causing tremulous excitement; deeply moving; as, a thrilling romance.","pos":""}],"THRING":[{"def":"To press, crowd, or throng.","pos":""}],"THRIPS":[{"def":"Any one of numerous small species of Thysanoptera, especially those which attack useful plants, as the grain thrips (Thrips cerealium).","pos":""}],"THRIVE":[{"def":"To posper by industry, economy, and good management of property; to increase in goods and estate; as, a farmer thrives by good husbandry.","pos":""},{"def":"To prosper in any business; to have increase or success.","pos":""}],"THRIVER":[{"def":"One who thrives, or prospers.","pos":""}],"THRIVINGLY":[{"def":"In a thriving manner.","pos":""}],"THRIVINGNESS":[{"def":"The quality or condition of one who thrives; prosperity; growth; increase.","pos":""}]}