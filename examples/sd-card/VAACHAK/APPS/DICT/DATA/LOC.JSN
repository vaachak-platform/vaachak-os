{"LOCAL":[{"def":"Of or pertaining to a particular place, or to a definite region or portion of space; restricted to one place or region; as, a local custom.","pos":""}],"LOCALE":[{"def":"A place, spot, or location.","pos":""},{"def":"A principle, practice, form of speech, or other thing of local use, or limited to a locality.","pos":""}],"LOCALISM":[{"def":"The state or quality of being local; affection for a particular place.","pos":""},{"def":"A method of speaking or acting peculiar to a certain district; a local idiom or phrase.","pos":""}],"LOCALITY":[{"def":"The perceptive faculty concerned with the ability to remember the relative positions of places.","pos":""}],"LOCALIZATION":[{"def":"Act of localizing, or state of being localized.","pos":""}],"LOCALIZE":[{"def":"To make local; to fix in, or assign to, a definite place.","pos":""}],"LOCALLY":[{"def":"With respect to place; in place; as, to be locally separated or distant.","pos":""}],"LOCATE":[{"def":"To place; to set in a particular spot or position.","pos":""},{"def":"To designate the site or place of; to define the limits of; as, to locate a public building; to locate a mining claim; to locate (the land granted by) a land warrant.","pos":""}],"LOCATION":[{"def":"The marking out of the boundaries, or identifying the place or site of, a piece of land, according to the description given in an entry, plan, map, etc.","pos":""}],"LOCATIVE":[{"def":"Indicating place, or the place where, or wherein; as, a locative adjective; locative case of a noun.","pos":""},{"def":"The locative case.","pos":""}],"LOCATOR":[{"def":"One who locates, or is entitled to locate, land or a mining claim.","pos":""}],"LOCELLATE":[{"def":"Divided into secondary compartments or cells, as where one cavity is separated into several smaller ones.","pos":""}],"LOCH":[{"def":"A lake; a bay or arm of the sea.","pos":""}],"LOCHAGE":[{"def":"An officer who commanded a company; a captain.","pos":""}],"LOCHAN":[{"def":"A small lake; a pond.","pos":""}],"LOCHIA":[{"def":"The discharge from the womb and vagina which follows childbirth.","pos":""}],"LOCHIAL":[{"def":"Of or pertaining to the lochia.","pos":""}],"LOCK":[{"def":"A tuft of hair; a flock or small quantity of wool, hay, or other like substance; a tress or ringlet of hair.","pos":""}],"LOCK HOSPITAL":[{"def":"Lock\" hos\"pi*tal Defn: .","pos":""}],"LOCK STEP":[{"def":"Lock\" step` Defn: .","pos":""}],"LOCK STITCH":[{"def":"Lock\" stitch` Defn: .","pos":""}],"LOCK-DOWN":[{"def":"A contrivance to fasten logs together in rafting; -- used by lumbermen.","pos":""}],"LOCK-WEIR":[{"def":"A waste weir for a canal, discharging into a lock chamber.","pos":""}],"LOCKAGE":[{"def":"Materials for locks in a canal, or the works forming a lock or locks.","pos":""},{"def":"Toll paid for passing the locks of a canal.","pos":""}],"LOCKEN":[{"def":"The globeflower (Trollius).","pos":""}],"LOCKER":[{"def":"One who, or that which, locks.","pos":""},{"def":"A drawer, cupboard, compartment, or chest, esp.","pos":""}],"LOCKET":[{"def":"A small lock; a catch or spring to fasten a necklace or other ornament.","pos":""},{"def":"A little case for holding a miniature or lock of hair, usually suspended from a necklace or watch chain.","pos":""}],"LOCKJAW":[{"def":"A contraction of the muscles of the jaw by which its motion is suspended; a variety of tetanus.","pos":""}],"LOCKLESS":[{"def":"Destitute of a lock.","pos":""}],"LOCKMAN":[{"def":"A public executioner.","pos":""}],"LOCKOUT":[{"def":"The closing of a factory or workshop by an employer, usually in order to bring the workmen to satisfactory terms by a suspension of wages.","pos":""}],"LOCKRAM":[{"def":"A kind of linen cloth anciently used in England, originally imported from Brittany.","pos":""}],"LOCKSMITH":[{"def":"An artificer whose occupation is to make or mend locks.","pos":""}],"LOCKUP":[{"def":"A place where persons under arrest are temporarily locked up; a watchhouse.","pos":""}],"LOCKY":[{"def":"Having locks or tufts.","pos":""}],"LOCO":[{"def":"A direction in written or printed music to return to the proper pitch after having played an octave higher.","pos":""}],"LOCO DISEASE":[{"def":"A chronic nervous affection of cattle, horses, and sheep, caused by eating the loco weed and characterized by a slow, measured gait, high step, glassy eyes with defective vision, delirium, and gradual emaciation.","pos":""}],"LOCOFOCO":[{"def":"A friction match.","pos":""},{"def":"A nickname formerly given to a member of the Democratic party.","pos":""}],"LOCOMOTION":[{"def":"The act of moving from place to place.","pos":""},{"def":"The power of moving from place to place, characteristic of the higher animals and some of the lower forms of plant life.","pos":""}],"LOCOMOTIVE":[{"def":"Moving from place to place; changing place, or able to change place; as, a locomotive animal.","pos":""},{"def":"Used in producing motion; as, the locomotive organs of an animal.","pos":""}],"LOCOMOTOR":[{"def":"Of or pertaining to movement or locomotion.","pos":""}],"LOCULAMENT":[{"def":"The cell of a pericarp in which the seed is lodged.","pos":""}],"LOCULAR":[{"def":"Of or relating to the cell or compartment of an ovary, etc.","pos":""}],"LOCULATE":[{"def":"Divided into compartments.","pos":""}],"LOCULE":[{"def":"A little hollow; a loculus.","pos":""}],"LOCULICIDAL":[{"def":"Dehiscent through the middle of the back of each cell; -- said of capsules.","pos":""},{"def":"Divided by internal partitions into cells, as the pith of the pokeweed.","pos":""}],"LOCULUS":[{"def":"One of the spaces between the septa in the Anthozoa.","pos":""},{"def":"One of the compartments of a several-celled ovary; loculament.","pos":""}],"LOCUM TENENS":[{"def":"A substitute or deputy; one filling an office for a time.","pos":""}],"LOCUS":[{"def":"The line traced by a point which varies its position according to some determinate law; the surface described by a point or line that moves according to a given law.","pos":""}],"LOCUST":[{"def":"Any one of numerous species of long-winged, migratory, orthopterous insects, of the family Acrididæ, allied to the grasshoppers; esp.","pos":""},{"def":"The locust tree.","pos":""}],"LOCUST TREE":[{"def":"A large North American tree of the genus Robinia (R.","pos":""}],"LOCUSTA":[{"def":"The spikelet or flower cluster of grasses.","pos":""}],"LOCUSTELLA":[{"def":"The European cricket warbler.","pos":""}],"LOCUSTIC":[{"def":"Pertaining to, or derived from, the locust; -- formerly used to designate a supposed acid.","pos":""}],"LOCUSTING":[{"def":"Swarming and devastating like locusts.","pos":""}],"LOCUTION":[{"def":"Speech or discourse; a phrase; a form or mode of expression.","pos":""}],"LOCUTORY":[{"def":"A room for conversation; especially, a room in monasteries, where the monks were allowed to converse.","pos":""}]}