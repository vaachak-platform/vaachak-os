{"EPIPEDOMETRY":[{"def":"The mensuration of figures standing on the same base.","pos":""}],"EPIPERIPHERAL":[{"def":"Connected with, or having its origin upon, the external surface of the body; -- especially applied to the feelings which originate at the extremities of nerves distributed on the outer surface, as the sensation produced by touching an object with the finger; -- opposed to entoperipheral.","pos":""}],"EPIPETALOUS":[{"def":"Borne on the petals or corolla.","pos":""}],"EPIPHANY":[{"def":"An appearance, or a becoming manifest.","pos":""}],"EPIPHARYNGEAL":[{"def":"Pertaining to the segments above the epibranchial in the branchial arches of fishes.","pos":""},{"def":"An epipharyngeal bone or cartilage.","pos":""}],"EPIPHARYNX":[{"def":"A structure which overlaps the mouth of certain insects.","pos":""}],"EPIPHONEMA":[{"def":"An exclamatory sentence, or striking reflection, which sums up or concludes a discourse.","pos":""}],"EPIPHORA":[{"def":"The watery eye; a disease in which the tears accumulate in the eye, and trickle over the cheek.","pos":""},{"def":"The emphatic repetition of a word or phrase, at the end of several sentences or stanzas.","pos":""}],"EPIPHRAGM":[{"def":"A membranaceous or calcareous septum with which some mollusks close the aperture of the shell during the time of hibernation, or æstivation.","pos":""}],"EPIPHYLLOSPERMOUS":[{"def":"Bearing fruit on the back of the leaves, as ferns.","pos":""}],"EPIPHYLLOUS":[{"def":"Growing upon, or inserted into, the leaf.","pos":""}],"EPIPHYLLUM":[{"def":"A genus of cactaceous plants having flattened, jointed stems, and petals united in a tube.","pos":""},{"def":"Pertaining to, or having the nature of, an epiphysis.","pos":""}],"EPIPHYTAL":[{"def":"Pertaining to an epiphyte.","pos":""}],"EPIPHYTE":[{"def":"An air plant which grows on other plants, but does not derive its nourishment from them.","pos":""},{"def":"A vegetable parasite growing on the surface of the body.","pos":""}],"EPIPLASTRON":[{"def":"One of the first pair of lateral plates in the plastron of turtles.","pos":""}],"EPIPLEURAL":[{"def":"Arising from the pleurapophysis of a vertebra.","pos":""}],"EPIPLEXIS":[{"def":"A figure by which a person seeks to convince and move by an elegant kind of upbraiding.","pos":""}],"EPIPLOCE":[{"def":"A figure by which one striking circumstance is added, in due gradation, to another; climax; e.","pos":""}],"EPIPLOIC":[{"def":"Relating to the epiploön.","pos":""}],"EPIPODIAL":[{"def":"Pertaining to the epipodialia or the parts of the limbs to which they belong.","pos":""},{"def":"Pertaining to the epipodium of Mollusca.","pos":""}],"EPIPODIALE":[{"def":"One of the bones of either the forearm or shank, the epipodialia being the radius, ulna, tibia, and fibula.","pos":""}],"EPIPODITE":[{"def":"The outer branch of the legs in certain Crustacea.","pos":""}],"EPIPODIUM":[{"def":"One of the lateral lobes of the foot in certain gastropods.","pos":""}],"EPIPOLIC":[{"def":"Producing, or relating to, epipolism or fluorescence.","pos":""}],"EPIPOLISM":[{"def":"See Fluorescence.","pos":""}],"EPIPOLIZED":[{"def":"Changed to the epipolic condition, or that in which the phenomenon of fluorescence is presented; produced by fluorescence; as, epipolized light.","pos":""}],"EPIPTERIC":[{"def":"Pertaining to a small Wormian bone sometimes present in the human skull between the parietal and the great wing of the sphenoid.","pos":""},{"def":"The epipteric bone.","pos":""}],"EPIPTERYGOID":[{"def":"Situated upon or above the pterygoid bone.","pos":""},{"def":"An epipterygoid bone or cartilage; the columella in the skulls of many lizards.","pos":""}],"EPIPUBIC":[{"def":"Relating to the epipubis.","pos":""}],"EPIPUBIS":[{"def":"A cartilage or bone in front of the pubis in some amphibians and other animals.","pos":""}]}