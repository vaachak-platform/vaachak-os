{"NEF":[{"def":"The nave of a church.","pos":""},{"def":"Unfit to speak of; unmentionable; impious; execrable.","pos":""}],"NEFARIOUS":[{"def":"Wicked in the extreme; abominable; iniquitous; atrociously villainous; execrable; detestably vile.","pos":""}],"NEFASCH":[{"def":"Any fish of the genus Distichodus.","pos":""}]}