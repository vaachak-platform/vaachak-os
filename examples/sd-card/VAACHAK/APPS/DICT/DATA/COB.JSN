{"COB":[{"def":"A spider; perhaps from its shape; it being round like a head.","pos":""},{"def":"A young herring.","pos":""}],"COBAEA":[{"def":"A genus of climbing plants, native of Mexico and South America.","pos":""}],"COBALT":[{"def":"A tough, lustrous, reddish white metal of the iron group, not easily fusible, and somewhat magnetic.","pos":""}],"COBALTIC":[{"def":"Pertaining to, derived from, or containing, cobalt; -- said especially of those compounds in which cobalt has higher valence; as, cobaltic oxide.","pos":""}],"COBALTIFEROUS":[{"def":"Containing cobalt.","pos":""},{"def":"A mineral of a nearly silver-white color, composed of arsenic, sulphur, and cobalt.","pos":""}],"COBALTOUS":[{"def":"Pertaining to, derived from, or containing, cobalt; -- said esp.","pos":""}],"COBBING":[{"def":"Haughty; purse-proud.","pos":""}],"COBBLE":[{"def":"To make or mend coarsely; to patch; to botch; as, to cobble shoes.","pos":""},{"def":"To make clumsily.","pos":""}],"COBBLER":[{"def":"A mender of shoes.","pos":""},{"def":"A clumsy workman.","pos":""}],"COBBLESTONE":[{"def":"A large pebble; a rounded stone not too large to be handled; a small boulder; -- used for paving streets and for other purposes.","pos":""}],"COBBY":[{"def":"Headstrong; obstinate.","pos":""},{"def":"Stout; hearty; lively.","pos":""}],"COBELLIGERENT":[{"def":"Carryng on war in conjunction with another power.","pos":""}],"COBIA":[{"def":"An oceanic fish of large size (Elacate canada); the crabeater; -- called also bonito, cubbyyew, coalfish, and sergeant fish.","pos":""}],"COBIRON":[{"def":"An andiron with a knob at the top.","pos":""}],"COBISHOP":[{"def":"A joint or coadjutant bishop.","pos":""}],"COBLE":[{"def":"A flat-floored fishing boat with a lug sail, and a drop rudder extending from two to four feet below the keel.","pos":""}],"COBNUT":[{"def":"A large roundish variety of the cultivated hazelnut.","pos":""}],"COBOURG":[{"def":"A thin worsted fabric for women's dresses.","pos":""}],"COBRA":[{"def":"The cobra de capello.","pos":""}],"COBRA DE CAPELLO":[{"def":"The hooded snake (Naia tripudians), a highly venomous serpent inhabiting India.","pos":""}],"COBWALL":[{"def":"A wall made of clay mixed with straw.","pos":""}],"COBWEB":[{"def":"The European spotted flycatcher.","pos":""}],"COBWEBBED":[{"def":"Abounding in cobwebs.","pos":""}],"COBWEBBY":[{"def":"Abounding in cobwebs, or any fine web; resembling a cobweb.","pos":""}],"COBWORK":[{"def":"Built of logs, etc.","pos":""}]}