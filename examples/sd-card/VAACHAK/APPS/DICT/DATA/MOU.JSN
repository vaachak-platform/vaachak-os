{"MOUFLON":[{"def":"A wild sheep (Ovis musimon), inhabiting the mountains of Sardinia, Corsica, etc.","pos":""}],"MOUILLATION":[{"def":"The act of uttering the sound of a mouillé letter.","pos":""}],"MOUILLE":[{"def":"Applied to certain consonants having a \"liquid\" or softened sound; e.","pos":""},{"def":"See Mold, Molder, Moldy, etc.","pos":""}],"MOULE":[{"def":"To contract mold; to grow moldy; to mold.","pos":""}],"MOUND":[{"def":"A ball or globe forming part of the regalia of an emperor or other sovereign.","pos":""}],"MOUNT":[{"def":"A mass of earth, or earth and rock, rising considerably above the common surface of the surrounding land; a mountain; a high hill; -- used always instead of mountain, when put before a proper name; as, Mount Washington; otherwise, chiefly in poetry.","pos":""},{"def":"A bulwark for offense or defense; a mound.","pos":""}],"MOUNTABLE":[{"def":"Such as can be mounted.","pos":""}],"MOUNTAIN":[{"def":"A range, chain, or group of such elevations; as, the White Mountains.","pos":""}],"MOUNTAIN SPECTER":[{"def":"An optical phenomenon sometimes seen on the summit of mountains (as on the Brocken) when the observer is between the sun and a mass of cloud.","pos":""}],"MOUNTAIN STATE":[{"def":"Montana; -- a nickname.","pos":""}],"MOUNTAINEER":[{"def":"An inhabitant of a mountain; one who lives among mountains.","pos":""},{"def":"A rude, fierce person.","pos":""}],"MOUNTAINET":[{"def":"A small mountain.","pos":""}],"MOUNTAINOUS":[{"def":"Full of, or containing, mountains; as, the mountainous country of the Swiss.","pos":""},{"def":"Inhabiting mountains.","pos":""}],"MOUNTAINOUSNESS":[{"def":"The state or quality of being mountainous.","pos":""}],"MOUNTANCE":[{"def":"Amount; sum; quantity; extent.","pos":""}],"MOUNTEBANK":[{"def":"One who mounts a bench or stage in the market or other public place, boasts of his skill in curing diseases, and vends medicines which he pretends are infalliable remedies; a quack doctor.","pos":""},{"def":"Any boastful or false pretender; a charlatan; a quack.","pos":""}],"MOUNTEBANKERY":[{"def":"The practices of a mountebank; quackery; boastful and vain pretenses.","pos":""}],"MOUNTEBANKISH":[{"def":"Like a mountebank or his quackery.","pos":""}],"MOUNTEBANKISM":[{"def":"The practices of a mountebank; mountebankery.","pos":""}],"MOUNTED":[{"def":"Seated or serving on horseback or similarly; as, mounted police; mounted infantry.","pos":""},{"def":"Placed on a suitable support, or fixed in a setting; as, a mounted gun; a mounted map; a mounted gem.","pos":""}],"MOUNTER":[{"def":"An animal mounted; a monture.","pos":""}],"MOUNTING":[{"def":"The act of one that mounts.","pos":""},{"def":"That by which anything is prepared for use, or set off to advantage; equipment; embellishment; setting; as, the mounting of a sword or diamond.","pos":""}],"MOUNTINGLY":[{"def":"In an ascending manner.","pos":""}],"MOUNTLET":[{"def":"A small or low mountain.","pos":""}],"MOUNTY":[{"def":"The rise of a hawk after prey.","pos":""}],"MOURN":[{"def":"To express or to feel grief or sorrow; to grieve; to be sorrowful; to lament; to be in a state of grief or sadness.","pos":""},{"def":"To wear the customary garb of a mourner.","pos":""}],"MOURNE":[{"def":"The armed or feruled end of a staff; in a sheephook, the end of the staff to which the hook is attached.","pos":""}],"MOURNER":[{"def":"One who mourns or is grieved at any misfortune, as the death of a friend.","pos":""},{"def":"One who attends a funeral as a hired mourner.","pos":""}],"MOURNFUL":[{"def":"Full of sorrow; expressing, or intended to express, sorrow; mourning; grieving; sad; also, causing sorrow; saddening; grievous; as, a mournful person; mournful looks, tones, loss.","pos":""}],"MOURNING":[{"def":"The act of sorrowing or expressing grief; lamentation; sorrow.","pos":""},{"def":"Garb, drapery, or emblems indicative of grief, esp.","pos":""}],"MOURNINGLY":[{"def":"In a mourning manner.","pos":""}],"MOUSE":[{"def":"Any one of numerous species of small rodents belonging to the genus Mus and various related genera of the family Muridæ.","pos":""}],"MOUSE-EAR":[{"def":"All these are low herbs with soft, oval, or obovate leaves, whence the name.","pos":""}],"MOUSEHOLE":[{"def":"A hole made by a mouse, for passage or abode, as in a wall; hence, a very small hole like that gnawed by a mouse.","pos":""}],"MOUSER":[{"def":"A cat that catches mice.","pos":""},{"def":"One who pries about on the lookout for something.","pos":""}],"MOUSETAIL":[{"def":"A genus of ranunculaceous plants (Myosurus), in which the prolonged receptacle is covered with imbricating achenes, and so resembles the tail of a mouse.","pos":""}],"MOUSIE":[{"def":"Diminutive for Mouse.","pos":""}],"MOUSING":[{"def":"Impertinently inquisitive; prying; meddlesome.","pos":""}],"MOUSLE":[{"def":"To sport with roughly; to rumple.","pos":""}],"MOUSQUETAIRE":[{"def":"A musketeer, esp.","pos":""},{"def":"A mosquetaire cuff or glove, or other article of dress fancied to resemble those worn by the French mosquetaires.","pos":""}],"MOUSQUETAIRE CUFF":[{"def":"A deep flaring cuff.","pos":""}],"MOUSQUETAIRE GLOVE":[{"def":"A woman's glove with a long, loosely fitting wrist.","pos":""}],"MOUSSE":[{"def":"A frozen dessert of a frothy texture, made of sweetened and flavored whipped cream, sometimes with the addition of egg yolks and gelatin.","pos":""}],"MOUSSELINE DE SOIE":[{"def":"A soft thin silk fabric with a weave like that of muslin.","pos":""}],"MOUSY":[{"def":"Infested with mice; smelling of mice.","pos":""}],"MOUTAN":[{"def":"The Chinese tree peony (Pæonia Mountan), a shrub with large flowers of various colors.","pos":""}],"MOUTH":[{"def":"An opening affording entrance or exit; orifice; aperture; as: (a) The opening of a vessel by which it is filled or emptied, charged or discharged; as, the mouth of a jar or pitcher; the mouth of the lacteal vessels, etc.","pos":""},{"def":"The crosspiece of a bridle bit, which enters the mouth of an animal.","pos":""}],"MOUTH-FOOTED":[{"def":"Having the basal joints of the legs converted into jaws.","pos":""}],"MOUTH-MADE":[{"def":"Spoken without sincerity; not heartfelt.","pos":""}],"MOUTHED":[{"def":"Furnished with a mouth.","pos":""},{"def":"Having a mouth of a particular kind; using the mouth, speech, or voice in a particular way; -- used only in composition; as, wide- mouthed; hard-mouthed; foul-mouthed; mealy-mouthed.","pos":""}],"MOUTHER":[{"def":"One who mouths; an affected speaker.","pos":""}],"MOUTHFUL":[{"def":"As much as is usually put into the mouth at one time.","pos":""},{"def":"Hence, a small quantity.","pos":""}],"MOUTHLESS":[{"def":"Destitute of a mouth.","pos":""}],"MOUTHPIECE":[{"def":"The part of a musical or other instrument to which the mouth is applied in using it; as, the mouthpiece of a bugle, or of a tobacco pipe.","pos":""},{"def":"An appendage to an inlet or outlet opening of a pipe or vessel, to direct or facilitate the inflow or outflow of a fluid.","pos":""}]}