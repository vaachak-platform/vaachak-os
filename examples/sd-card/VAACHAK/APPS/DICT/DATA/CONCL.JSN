{"CONCLAMATION":[{"def":"An outcry or shout of many together.","pos":""}],"CONCLAVE":[{"def":"The set of apartments within which the cardinals of the Roman Catholic Church are continuously secluded while engaged in choosing a pope.","pos":""},{"def":"The body of cardinals shut up in the conclave for the election of a pope; hence, the body of cardinals.","pos":""}],"CONCLAVIST":[{"def":"One of the two ecclesiastics allowed to attend a cardinal in the conclave.","pos":""}],"CONCLUDE":[{"def":"To shut up; to inclose.","pos":""},{"def":"To include; to comprehend; to shut up together; to embrace.","pos":""}],"CONCLUDENCY":[{"def":"Deduction from premises; inference; conclusion.","pos":""}],"CONCLUDENT":[{"def":"Bringing to a close; decisive; conclusive.","pos":""}],"CONCLUDER":[{"def":"One who concludes.","pos":""}],"CONCLUSIBLE":[{"def":"Demonstrable; determinable.","pos":""}],"CONCLUSION":[{"def":"The inferred proposition of a syllogism; the necessary consequence of the conditions asserted in two related propositions called premises.","pos":""}],"CONCLUSIVE":[{"def":"Belonging to a close or termination; decisive; convincing; putting an end to debate or question; leading to, or involving, a conclusion or decision.","pos":""}],"CONCLUSIVELY":[{"def":"In the way of conclusion; decisively; positively.","pos":""}],"CONCLUSIVENESS":[{"def":"The quality of being conclusive; decisiveness.","pos":""}]}