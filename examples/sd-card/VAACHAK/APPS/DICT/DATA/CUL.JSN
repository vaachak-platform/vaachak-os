{"CUL-DE-SAC":[{"def":"a position in which an army finds itself with no way of exit but to the front.","pos":""},{"def":"Any bag-shaped or tubular cavity, vessel, or organ, open only at one end.","pos":""}],"CULASSE":[{"def":"The lower faceted portion of a brilliant-cut diamond.","pos":""}],"CULDEE":[{"def":"One of a class of anchorites who lived in various parts of Scotland, Ireland, and Wales.","pos":""}],"CULERAGE":[{"def":"Cul\"er*age (kl\"r-j), n.","pos":""}],"CULEX":[{"def":"A genus of dipterous insects, including the gnat and mosquito.","pos":""}],"CULICID":[{"def":"Like or pertaining to the Mosquito family (Culicidæ).","pos":""},{"def":"A culicid insect.","pos":""}],"CULICIFORM":[{"def":"Cu*lic\"i*form (k-ls\"i-frm).","pos":""}],"CULINARILY":[{"def":"In the manner of a kitchen; in connection with a kitchen or cooking.","pos":""}],"CULINARY":[{"def":"Relating to the kitchen, or to the art of cookery; used in kitchens; as, a culinary vessel; the culinary art.","pos":""}],"CULL":[{"def":"To separate, select, or pick out; to choose and gather or collect; as, to cuil flowers.","pos":""}],"CULLENDER":[{"def":"Cul\"len*der (kl\"ln-dr), n.","pos":""}],"CULLER":[{"def":"One who piks or chooses; esp.","pos":""}],"CULLET":[{"def":"Broken glass for remelting.","pos":""}],"CULLIBILITY":[{"def":"Cul`li*bil\"i*ty (-l-bl\"-ty), n.","pos":""}],"CULLIBLE":[{"def":"Easily deceived; gullible.","pos":""}],"CULLING":[{"def":"Anything separated or selected from a mass.","pos":""}],"CULLION":[{"def":"A mean wretch; a base fellow; a poltroon; a scullion.","pos":""}],"CULLIS":[{"def":"A strong broth of meat, strained and made clear for invalids; also, a savory jelly.","pos":""}],"CULLS":[{"def":"Refuse timber, from which the best part has been culled out.","pos":""},{"def":"Any refuse stuff, as rolls not properly baked.","pos":""}],"CULLY":[{"def":"A person easily deceived, tricked, or imposed on; a mean dupe; a gull.","pos":""}],"CULLYISM":[{"def":"The state of being a cully.","pos":""}],"CULM":[{"def":"The stalk or stem of grain and grasses (including the bamboo), jointed and usually hollow.","pos":""}],"CULMEN":[{"def":"The dorsal ridge of a bird's bill.","pos":""}],"CULMIFEROUS":[{"def":"Having jointed stems or culms.","pos":""}],"CULMINAL":[{"def":"Pertaining to a culmen.","pos":""}],"CULMINANT":[{"def":"Being vertical, or at the highest point of altitude; hence, predominant.","pos":""}],"CULMINATE":[{"def":"To reach its highest point of altitude; to come to the meridian; to be vertical or directly overhead.","pos":""},{"def":"To reach the highest point, as of rank, size, power, numbers, etc.","pos":""}],"CULMINATION":[{"def":"The attainment of the highest point of altitude reached by a heavently body; passage across the meridian; transit.","pos":""},{"def":"Attainment or arrival at the highest pitch of glory, power, etc.","pos":""}],"CULPA":[{"def":"Negligence or fault, as distinguishable from dolus (deceit, fraud), which implies intent, culpa being imputable to defect of intellect, dolus to defect of heart.","pos":""}],"CULPABILITY":[{"def":"The state of being culpable.","pos":""}],"CULPABLE":[{"def":"Deserving censure; worthy of blame; faulty; immoral; criminal.","pos":""},{"def":"Guilty; as, clpable of a crime.","pos":""}],"CULPATORY":[{"def":"Expressing blame; censuring; reprehensory; inculpating.","pos":""}],"CULPE":[{"def":"Blameworthiness.","pos":""}],"CULPON":[{"def":"A shered; a fragment; a strip of wood.","pos":""}],"CULPRIT":[{"def":"One accused of, or ar An author is in the condition of a culprit; the public are his judges.","pos":""},{"def":"One quilty of a fault; a criminal.","pos":""}],"CULRAGE":[{"def":"Smartweed (Polygonum Hydropiper).","pos":""}],"CULT":[{"def":"Attentive care; homage; worship.","pos":""},{"def":"A system of religious belief and worship.","pos":""}],"CULTCH":[{"def":"Empty oyster shells and other substances laid down on oyster grounds to furnish points for the attachment of the spawn of the oyster.","pos":""}],"CULTIROSTRAL":[{"def":"Having a bill shaped like the colter of a plow, or like a knife, as the heron, stork, etc.","pos":""}],"CULTIROSTRES":[{"def":"A tribe of wading birds including the stork, heron, crane, etc.","pos":""}],"CULTIVABLE":[{"def":"Capable of being cultivated or tilled.","pos":""}],"CULTIVATABLE":[{"def":"Cul\"ti*va`ta*ble (kl\"t-v`t-b'l), a.","pos":""}],"CULTIVATE":[{"def":"To bestow attention, care, and labor upon, with a view to valuable returns; to till; to fertilize; as, to cultivate soil.","pos":""},{"def":"To direct special attention to; to devote time and thought to; to foster; to cherish.","pos":""}],"CULTIVATION":[{"def":"The art or act of cultivating; improvement for agricultural purposes or by agricultural processes; tillage; production by tillage.","pos":""},{"def":"Bestowal of time or attention for self-improvement or for the benefit of others; fostering care.","pos":""}],"CULTIVATOR":[{"def":"Sharp-edged and pointed; shaped like a pruning knife, as the beak of certain birds.","pos":""}],"CULTRIFORM":[{"def":"Shaped like a pruning knife; cultrate.","pos":""}],"CULTRIVOROUS":[{"def":"Devouring knives; swallowing, or pretending to swallow, knives; -- applied to persons who have swallowed, or have seemed to swallow, knives with impunity.","pos":""}],"CULTURABLE":[{"def":"Capable of, or fit for, being cultivated; capable or becoming cultured.","pos":""}],"CULTURAL":[{"def":"Of or pertaining to culture.","pos":""}],"CULTURE":[{"def":"The act or practice of cultivating, or of preparing the earth for seed and raising crops by tillage; as, the culture of the soil.","pos":""},{"def":"The act of, or any labor or means employed for, training, disciplining, or refining the moral and intellectual nature of man; as.","pos":""}],"CULTURE FEATURES":[{"def":"The artificial features of a district as distinguished from the natural.","pos":""}],"CULTURE MYTH":[{"def":"A myth accounting for the discovery of arts and sciences or the advent of a higher civilization, as in the Prometheus myth.","pos":""}],"CULTURED":[{"def":"Under culture; cultivated.","pos":""},{"def":"Characterized by mental and moral training; disciplined; refined; well-educated.","pos":""}],"CULTURELESS":[{"def":"Having no culture.","pos":""}],"CULTURIST":[{"def":"One who is an advocate of culture.","pos":""}],"CULTUS":[{"def":"Established or accepted religious rites or usages of worship; state of religious development.","pos":""}],"CULTUS COD":[{"def":"See Cod, and Buffalo cod, under Buffalo.","pos":""}],"CULVER":[{"def":"Falcon and culver on each tower Stood prompt their deadly hail to shower.","pos":""}],"CULVERHOUSE":[{"def":"Cul\"ver*house` (-hous`), n.","pos":""}],"CULVERIN":[{"def":"A long cannon of the 16th century, usually an 18-pounder with serpent-shaped handles.","pos":"noun"}],"CULVERKEY":[{"def":"The root of a handsome erect herb (Leptandra, syn.","pos":""}],"CULVERT":[{"def":"A transverse drain or waterway of masonry under a road, railroad, canal, etc.","pos":""}],"CULVERTAIL":[{"def":"Cul\"ver*tail` (kl\"vr-tl`), n.","pos":""}],"CULVERTAILED":[{"def":"United or fastened by a dovetailed joint.","pos":""}]}