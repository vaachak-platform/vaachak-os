{"AMMA":[{"def":"An abbes or spiritual mother.","pos":""}],"AMMETER":[{"def":"A contraction of amperometer or ampèremeter.","pos":""}],"AMMIRAL":[{"def":"An obsolete form of admiral.","pos":""}],"AMMITE":[{"def":"Oölite or roestone; -- written also hammite.","pos":""}],"AMMONAL":[{"def":"An explosive consisting of a mixture of powdered aluminium and nitrate of ammonium.","pos":""}],"AMMONIA":[{"def":"A gaseous compound of hydrogen and nitrogen, NH3, with a pungent smell and taste: -- often called volatile alkali, and spirits of hartshorn.","pos":""},{"def":"Of or pertaining to ammonia, or possessing its properties; as, an ammoniac salt; ammoniacal gas.","pos":""}],"AMMONIACAL FERMENTATION":[{"def":"Any fermentation process by which ammonia is formed, as that by which urea is converted into ammonium carbonate when urine is exposed to the air.","pos":""}],"AMMONIATED":[{"def":"Combined or impregnated with ammonia.","pos":""}],"AMMONIC":[{"def":"Of or pertaining to ammonia.","pos":""}],"AMMONITE":[{"def":"A fossil cephalopod shell related to the nautilus.","pos":""}],"AMMONITIFEROUS":[{"def":"Containing fossil ammonites.","pos":""}],"AMMONITOIDEA":[{"def":"An extensive group of fossil cephalopods often very abundant in Mesozoic rocks.","pos":""}],"AMMONIUM":[{"def":"A compound radical, NH4, having the chemical relations of a strongly basic element like the alkali metals.","pos":""}],"AMMUNITION":[{"def":"Military stores, or provisions of all kinds for attack or defense.","pos":""},{"def":"Articles used in charging firearms and ordnance of all kinds; as powder, balls, shot, shells, percussion caps, rockets, etc.","pos":""}]}