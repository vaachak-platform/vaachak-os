{"GUT":[{"def":"A narrow passage of water; as, the Gut of Canso.","pos":""},{"def":"An intenstine; a bowel; the whole alimentary canal; the enteron; (pl.","pos":""}],"GUTTA":[{"def":"One of a series of ornaments, in the form of a frustum of a cone, attached to the lower part of the triglyphs, and also to the lower faces of the mutules, in the Doric order; -- called also campana, and drop.","pos":""}],"GUTTA-PERCHA":[{"def":"A concrete juice produced by various trees found in the Malayan archipelago, especially by the Isonandra, or Dichopsis, Gutta.","pos":""}],"GUTTATE":[{"def":"Spotted, as if discolored by drops.","pos":""}],"GUTTATED":[{"def":"Besprinkled with drops, or droplike spots.","pos":""}],"GUTTATRAP":[{"def":"The inspissated juice of a tree of the genus Artocarpus (A.","pos":""}],"GUTTER":[{"def":"A channel at the eaves of a roof for conveying away the rain; an eaves channel; an eaves trough.","pos":""},{"def":"A small channel at the roadside or elsewhere, to lead off surface water.","pos":""}],"GUTTIFER":[{"def":"A plant that exudes gum or resin.","pos":""}],"GUTTIFORM":[{"def":"Drop-shaped, as a spot of color.","pos":""}],"GUTTLE":[{"def":"To put into the gut; to swallow greedily; to gorge; to gormandize.","pos":""}],"GUTTLER":[{"def":"A greedy eater; a glutton.","pos":""}],"GUTTULOUS":[{"def":"In droplike form.","pos":""}],"GUTTURAL":[{"def":"Of or pertaining to the throat; formed in the throat; relating to, or characteristic of, a sound formed in the throat.","pos":""}],"GUTTURALISM":[{"def":"The quality of being guttural; as, the gutturalism of A [in the 16th cent.","pos":""}],"GUTTURALITY":[{"def":"The quality of being guttural.","pos":""}],"GUTTURALIZE":[{"def":"To speak gutturally; to give a guttural sound to.","pos":""}],"GUTTURALLY":[{"def":"In a guttural manner.","pos":""}],"GUTTURALNESS":[{"def":"The quality of being guttural.","pos":""}],"GUTTURINE":[{"def":"Pertaining to the throat.","pos":""}],"GUTTURIZE":[{"def":"To make in the throat; to gutturalize.","pos":""}],"GUTTURO-":[{"def":"A combining form denoting relation to the throat; as, gutturo- nasal, having both a guttural and a nasal character; gutturo-palatal.","pos":""}],"GUTTY":[{"def":"Charged or sprinkled with drops.","pos":""}],"GUTWORT":[{"def":"A plant, Globularia Alypum, a violent purgative, found in Africa.","pos":""}]}