{"EXUBERANCE":[{"def":"The state of being exuberant; an overflowing quantity; a copious or excessive production or supply; superabundance; richness; as, an exuberance of joy, of fancy, or of foliage.","pos":""}],"EXUBERANCY":[{"def":"Ex*u\"ber*an*cy Defn: , .","pos":""}],"EXUBERANT":[{"def":"Characterized by abundance or superabundance; plenteous; rich; overflowing; copious or excessive in production; as, exuberant goodness; an exuberant intellect; exuberant foliage.","pos":""}],"EXUBERATE":[{"def":"To abound; to be in great abundance.","pos":""}],"EXUDATION":[{"def":"The act of exuding; sweating; a discharge of humors, moisture, juice, or gum, as through pores or incisions; also, the substance exuded.","pos":""}],"EXUDE":[{"def":"To discharge through pores or incisions, as moisture or other liquid matter; to give out.","pos":""}],"EXULCERATE":[{"def":"To corrode; to fret; to chafe; to inflame.","pos":""}],"EXULCERATION":[{"def":"A fretting; a festering; soreness.","pos":""}],"EXULCERATIVE":[{"def":"Tending to cause ulcers; exulceratory.","pos":""}],"EXULCERATORY":[{"def":"Having a tendency to form ulcers; rendering ulcerous.","pos":""}],"EXULT":[{"def":"To be in high spirits; figuratively, to leap for joy; to rejoice in triumph or exceedingly; to triumph; as, an exulting heart.","pos":""}],"EXULTANT":[{"def":"Inclined to exult; characterized by, or expressing, exultation; rejoicing triumphantly.","pos":""}],"EXULTATION":[{"def":"The act of exulting; lively joy at success or victory, or at any advantage gained; rapturous delight; triumph.","pos":""}],"EXULTING":[{"def":"Rejoicing triumphantly or exceedingly; exultant.","pos":""}],"EXUNDATE":[{"def":"To overflow; to inundate.","pos":""}],"EXUNDATION":[{"def":"An overflow, or overflowing abundance.","pos":""}],"EXUNGULATE":[{"def":"To pare off, as nails, the hoof, etc.","pos":""}],"EXUPERABLE":[{"def":"Surmountable; superable.","pos":""}],"EXUPERANCE":[{"def":"Superiority; superfluity.","pos":""}],"EXUPERANT":[{"def":"Surpassing; exceeding; surmounting.","pos":""}],"EXUPERATE":[{"def":"To excel; to surmount.","pos":""}],"EXUPERATION":[{"def":"The act of rising or coming into view.","pos":""}],"EXURGENT":[{"def":"Arising; coming to light.","pos":""}],"EXUSCITATE":[{"def":"See Exsuscitate [Obs.","pos":""}],"EXUSTION":[{"def":"The act or operation of burning up.","pos":""}],"EXUVIA":[{"def":"Ex*u\"vi*a, Defn: n.","pos":""}],"EXUVIABILITY":[{"def":"Capability of shedding the skin periodically.","pos":""}],"EXUVIABLE":[{"def":"Capable of being cast off in the form of exuviæ.","pos":""}],"EXUVIAE":[{"def":"Cast skins, shells, or coverings of animals; any parts of animals which are shed or cast off, as the skins of snakes, the shells of lobsters, etc.","pos":""},{"def":"The fossil shells and other remains which animals have left in the strata of the earth.","pos":""}],"EXUVIAL":[{"def":"Of or pertaining to exuviæ.","pos":""}],"EXUVIATE":[{"def":"To shed an old covering or condition preliminary to taking on a new one; to molt.","pos":""}],"EXUVIATION":[{"def":"The rejecting or casting off of some part, more particularly, the outer cuticular layer, as the shells of crustaceans, skins of snakes, etc.","pos":""}]}