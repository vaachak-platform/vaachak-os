{"STRABISMOMETER":[{"def":"An instrument for measuring the amount of strabismus.","pos":""}],"STRABISMUS":[{"def":"An affection of one or both eyes, in which the optic axes can not be directed to the same object, -- a defect due either to undue contraction or to undue relaxation of one or more of the muscles which move the eyeball; squinting; cross-eye.","pos":""}],"STRABOTOMY":[{"def":"The operation for the removal of squinting by the division of such muscles as distort the eyeball.","pos":""}],"STRADDLE":[{"def":"To part the legs wide; to stand or to walk with the legs far apart.","pos":""},{"def":"To stand with the ends staggered; -- said of the spokes of a wagon wheel where they join the hub.","pos":""}],"STRADDLING":[{"def":"Applied to spokes when they are arranged alternately in two circles in the hub.","pos":""}],"STRADOMETRICAL":[{"def":"Of, or relating to, the measuring of streets or roads.","pos":""}],"STRAGGLE":[{"def":"To wander from the direct course or way; to rove; to stray; to wander from the line of march or desert the line of battle; as, when troops are on the march, the men should not straggle.","pos":""},{"def":"To wander at large; to roam idly about; to ramble.","pos":""}],"STRAGGLER":[{"def":"One who straggles, or departs from the direct or proper course, or from the company to which he belongs; one who falls behind the rest; one who rambles without any settled direction.","pos":""},{"def":"A roving vagabond.","pos":""}],"STRAGGLING":[{"def":"from Straggle, v.","pos":""}],"STRAGGLINGLY":[{"def":"In a straggling manner.","pos":""}],"STRAGULUM":[{"def":"The mantle, or pallium, of a bird.","pos":""}],"STRAIGHT":[{"def":"A variant of Strait, a.","pos":""}],"STRAIGHT-JOINT":[{"def":"Having straight joints.","pos":""}],"STRAIGHT-LINED":[{"def":"Having straight lines.","pos":""}],"STRAIGHT-OUT":[{"def":"Acting without concealment, obliquity, or compromise; hence, unqualified; thoroughgoing.","pos":""}],"STRAIGHT-PIGHT":[{"def":"Straight in form or upright in position; erect.","pos":""}],"STRAIGHT-SPOKEN":[{"def":"Speaking with directness; plain-spoken.","pos":""}],"STRAIGHTEDGE":[{"def":"A board, or piece of wood or metal, having one edge perfectly straight, -- used to ascertain whether a line is straight or a surface even, and for drawing straight lines.","pos":""}],"STRAIGHTEN":[{"def":"To make straight; to reduce from a crooked to a straight form.","pos":""},{"def":"To make right or correct; to reduce to order; as, to straighten one's affairs; to straighten an account.","pos":""}],"STRAIGHTENER":[{"def":"One who, or that which, straightens.","pos":""}],"STRAIGHTFORWARD":[{"def":"Proceeding in a straight course or manner; not deviating; honest; frank.","pos":""},{"def":"In a straightforward manner.","pos":""}],"STRAIGHTLY":[{"def":"In a right line; not crookedly.","pos":""}],"STRAIGHTNESS":[{"def":"The quality, condition, or state, of being straight; as, the straightness of a path.","pos":""}],"STRAIGHTWAY":[{"def":"Immediately; without loss of time; without delay.","pos":""}],"STRAIN":[{"def":"Race; stock; generation; descent; family.","pos":""},{"def":"Hereditary character, quality, or disposition.","pos":""}],"STRAINABLE":[{"def":"Capable of being strained.","pos":""},{"def":"Violent in action.","pos":""}],"STRAINED":[{"def":"Subjected to great or excessive tension; wrenched; weakened; as, strained relations between old friends.","pos":""},{"def":"Done or produced with straining or excessive effort; as, his wit was strained.","pos":""}],"STRAINER":[{"def":"One who strains.","pos":""}],"STRAINT":[{"def":"Overexertion; excessive tension; strain.","pos":""}],"STRAIT":[{"def":"A variant of Straight.","pos":""}],"STRAIT-HANDED":[{"def":"Parsimonious; sparing; niggardly.","pos":""}],"STRAIT-JACKET":[{"def":"A dress of strong materials for restraining maniacs or those who are violently delirious.","pos":""}],"STRAIT-LACED":[{"def":"Bound with stays.","pos":""},{"def":"Restricted; stiff; constrained.","pos":""}],"STRAIT-WAISTCOAT":[{"def":"Same as Strait-jacket.","pos":""}],"STRAITEN":[{"def":"To make strait; to make narrow; hence, to contract; to confine.","pos":""},{"def":"To make tense, or tight; to tighten.","pos":""}],"STRAITLY":[{"def":"In a strait manner; narrowly; strictly; rigorously.","pos":""},{"def":"Closely; intimately.","pos":""}],"STRAITNESS":[{"def":"The quality or condition of being strait; especially, a pinched condition or situation caused by poverty; as, the straitnessof their circumstances.","pos":""}],"STRAKE":[{"def":"One breadth of planks or plates forming a continuous range on the bottom or sides of a vessel, reaching from the stem to the stern; a streak.","pos":""},{"def":"A trough for washing broken ore, gravel, or sand; a launder.","pos":""}],"STRALE":[{"def":"Pupil of the eye.","pos":""}],"STRAM":[{"def":"To spring or recoil with violence.","pos":""}],"STRAMASH":[{"def":"To strike, beat, or bang; to break; to destroy.","pos":""}],"STRAMAZOUN":[{"def":"A direct descending blow with the edge of a sword.","pos":""}],"STRAMINEOUS":[{"def":"Strawy; consisting of straw.","pos":""},{"def":"Chaffy; like straw; straw-colored.","pos":""}],"STRAMONIUM":[{"def":"A poisonous plant (Datura Stramonium); stinkweed.","pos":""}],"STRAND":[{"def":"One of the twists, or strings, as of fibers, wires, etc.","pos":""}],"STRANGE":[{"def":"Belonging to another country; foreign.","pos":""},{"def":"Of or pertaining to others; not one's own; not pertaining to one's self; not domestic.","pos":""}],"STRANGELY":[{"def":"As something foreign, or not one's own; in a manner adapted to something foreign and strange.","pos":""},{"def":"In the manner of one who does not know another; distantly; reservedly; coldly.","pos":""}],"STRANGENESS":[{"def":"The state or quality of being strange (in any sense of the adjective).","pos":""}],"STRANGER":[{"def":"One not privy or party an act, contract, or title; a mere intruder or intermeddler; one who interferes without right; as, actual possession of land gives a good title against a stranger having no title; as to strangers, a mortgage is considered merely as a pledge; a mere stranger to the levy.","pos":""}],"STRANGLE":[{"def":"To compress the windpipe of (a person or animal) until death results from stoppage of respiration; to choke to death by compressing the throat, as with the hand or a rope.","pos":""},{"def":"To stifle, choke, or suffocate in any manner.","pos":""}],"STRANGLE HOLD":[{"def":"In wrestling, a hold by which one's opponent is choked.","pos":""}],"STRANGLEABLE":[{"def":"Capable of being strangled.","pos":""}],"STRANGLER":[{"def":"One who, or that which, strangles.","pos":""}],"STRANGLES":[{"def":"A disease in horses and swine, in which the upper part of the throat, or groups of lymphatic glands elsewhere, swells.","pos":""}],"STRANGULATED":[{"def":"Having the circulation stopped by compression; attended with arrest or obstruction of circulation, caused by constriction or compression; as, a strangulated hernia.","pos":""},{"def":"Contracted at irregular intervals, if tied with a ligature; constricted.","pos":""}],"STRANGULATION":[{"def":"Inordinate compression or constriction of a tube or part, as of the throat; especially, such as causes a suspension of breathing, of the passage of contents, or of the circulation, as in cases of hernia.","pos":""}],"STRANGURIOUS":[{"def":"Of or pertaining to strangury.","pos":""}],"STRANGURY":[{"def":"A painful discharge of urine, drop by drop, produced by spasmodic muscular contraction.","pos":""},{"def":"A swelling or other disease in a plant, occasioned by a ligature fastened tightly about it.","pos":""}],"STRAP":[{"def":"A band, plate, or loop of metal for clasping and holding timbers or parts of a machine.","pos":""},{"def":"A piece of rope or metal passing around a block and used for fastening it to anything.","pos":""}],"STRAP-SHAPED":[{"def":"Shaped like a strap; ligulate; as, a strap-shaped corolla.","pos":""}],"STRAPPADO":[{"def":"A military punishment formerly practiced, which consisted in drawing an offender to the top of a beam and letting him fall to the length of the rope, by which means a limb was often dislocated.","pos":""}],"STRAPPER":[{"def":"One who uses strap.","pos":""},{"def":"A person or thing of uncommon size.","pos":""}],"STRAPPING":[{"def":"Tall; strong; lusty; large; as, a strapping fellow.","pos":""}],"STRAPPLE":[{"def":"To hold or bind with, or as with, a strap; to entangle.","pos":""}],"STRAPWORK":[{"def":"A kind of ornament consisting of a narrow fillet or band folded, crossed, and interlaced.","pos":""}],"STRASS":[{"def":"A brilliant glass, used in the manufacture of artificial paste gems, which consists essentially of a complex borosilicate of lead and potassium.","pos":""}],"STRATAGEM":[{"def":"An artifice or trick in war for deceiving the enemy; hence, in general, artifice; deceptive device; secret plot; evil machination.","pos":""}],"STRATAGEMICAL":[{"def":"Containing stratagem; as, a stratagemical epistle.","pos":""}],"STRATARITHMETRY":[{"def":"The art of drawing up an army, or any given number of men, in any geometrical figure, or of estimating or expressing the number of men in such a figure.","pos":""}],"STRATEGETICS":[{"def":"Of or pertaining to strategy; effected by artifice.","pos":""}],"STRATEGIST":[{"def":"One skilled in strategy, or the science of directing great military movements.","pos":""}],"STRATEGUS":[{"def":"The leader or commander of an army; a general.","pos":""}],"STRATEGY":[{"def":"The science of military command, or the science of projecting campaigns and directing great military movements; generalship.","pos":""},{"def":"The use of stratagem or artifice.","pos":""}],"STRATH":[{"def":"A valley of considerable size, through which a river runs; a valley bottom; -- often used in composition with the name of the river; as, Strath Spey, Strathdon, Strathmore.","pos":""}],"STRATHSPEY":[{"def":"A lively Scottish dance, resembling the reel, but slower; also, the tune.","pos":""}],"STRATICULATE":[{"def":"Characterized by the presence of thin parallel strata, or layers, as in an agate.","pos":""}],"STRATIFICATION":[{"def":"The deposition of material in successive layers in the growth of a cell wall, thus giving rise to a stratified appearance.","pos":""}],"STRATIFIED":[{"def":"Having its substance arranged in strata, or layers; as, stratified rock.","pos":""}],"STRATIFORM":[{"def":"Having the form of strata.","pos":""}],"STRATIFY":[{"def":"To form or deposit in strata, or layers, as substances in the earth; to arrange in strata.","pos":""},{"def":"Pertaining to, or depended upon, the order or arrangement of strata; as, stratigraphical evidence.","pos":""}],"STRATIGRAPHY":[{"def":"That branch of geology which treats of the arrangement and succession of strata.","pos":""}],"STRATO-CIRRUS":[{"def":"An alto-stratus cloud.","pos":""}],"STRATO-CUMULUS":[{"def":"Large balls or rolls of dark cloud which frequently cover the whole sky, esp.","pos":""},{"def":"Of or pertaining to stratography.","pos":""}],"STRATOCRACY":[{"def":"A military government; government by military chiefs and an army.","pos":""}],"STRATOGRAPHY":[{"def":"A description of an army, or of what belongs to an army.","pos":""}],"STRATONIC":[{"def":"Of or pertaining to an army.","pos":""}],"STRATOTIC":[{"def":"Warlike; military.","pos":""}],"STRATUM":[{"def":"A bed of earth or rock of one kind, formed by natural causes, and consisting usually of a series of layers, which form a rock as it lies between beds of other kinds.","pos":""}],"STRATUS":[{"def":"A form of clouds in which they are arranged in a horizontal band or layer.","pos":""}],"STRAUGHT":[{"def":"To stretch; to make straight.","pos":""}],"STRAW":[{"def":"To spread or scatter.","pos":""}],"STRAW-COLORED":[{"def":"Being of a straw color.","pos":""}],"STRAW-CUTTER":[{"def":"An instrument to cut straw for fodder.","pos":""}],"STRAWBERRY":[{"def":"A fragrant edible berry, of a delicious taste and commonly of a red color, the fruit of a plant of the genus Fragaria, of which there are many varieties.","pos":""}],"STRAWBOARD":[{"def":"Pasteboard made of pulp of straw.","pos":""}],"STRAWED":[{"def":"Strawed, Defn: imp.","pos":""}],"STRAWY":[{"def":"Of or pertaining to straw; made of, or resembling, straw.","pos":""}],"STRAY":[{"def":"To wander, as from a direct course; to deviate, or go out of the way.","pos":""},{"def":"To wander from company, or from the proper limits; to rove at large; to roam; to go astray.","pos":""}],"STRAYER":[{"def":"One who strays; a wanderer.","pos":""}]}