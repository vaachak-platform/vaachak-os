{"ELL":[{"def":"A measure for cloth; -- now rarely used.","pos":""}],"ELLACHICK":[{"def":"A fresh-water tortoise (Chelopus marmoratus) of California; -- used as food.","pos":""}],"ELLAGIC":[{"def":"Pertaining to, or derived from, gallnuts or gallic acid; as, ellagic acid.","pos":""}],"ELLECK":[{"def":"The red gurnard or cuckoo fish.","pos":""},{"def":"See Elenge, Elengeness.","pos":""}],"ELLIPSE":[{"def":"An oval or oblong figure, bounded by a regular curve, which corresponds to an oblique projection of a circle, or an oblique section of a cone through its opposite sides.","pos":""}],"ELLIPSIS":[{"def":"Omission; a figure of syntax, by which one or more words, which are obviously understood, are omitted; as, the virtues I admire, for, the virtues which I admire.","pos":""}],"ELLIPSOGRAPH":[{"def":"An instrument for describing ellipses; -- called also trammel.","pos":""}],"ELLIPSOID":[{"def":"A solid, all plane sections of which are ellipses or circles.","pos":""},{"def":"Pertaining to, or shaped like, an ellipsoid; as, ellipsoid or ellipsoidal form.","pos":""}],"ELLIPTIC-LANCEOLATE":[{"def":"Having a form intermediate between elliptic and lanceolate.","pos":""}],"ELLIPTICALLY":[{"def":"In the form of an ellipse.","pos":""},{"def":"With a part omitted; as, elliptically expressed.","pos":""}],"ELLIPTICITY":[{"def":"Note: Some writers use ellipticity as the ratio of the difference of the two semiaxes to the minor axis, instead of the major.","pos":""}],"ELLIPTOGRAPH":[{"def":"Same as Ellipsograph.","pos":""}],"ELLWAND":[{"def":"Formerly, a measuring rod an ell long.","pos":""}]}