{"EXTOL":[{"def":"To place on high; to lift up; to elevate.","pos":""},{"def":"To elevate by praise; to eulogize; to praise; to magnify; as, to extol virtue; to extol an act or a person.","pos":""}],"EXTOLLER":[{"def":"One who extols; one who praises.","pos":""}],"EXTORSIVE":[{"def":"Serving or tending to extort.","pos":""}],"EXTORT":[{"def":"To get by the offense of extortion.","pos":""}],"EXTORTER":[{"def":"One who practices extortion.","pos":""}],"EXTORTION":[{"def":"The offense committed by an officer who corruptly claims and takes, as his fee, money, or other thing of value, that is not due, or more than is due, or before it is due.","pos":""}],"EXTORTIONATE":[{"def":"Characterized by extortion; oppressive; hard.","pos":""}],"EXTORTIONER":[{"def":", One who practices extortion.","pos":""}]}