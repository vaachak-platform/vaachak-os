{"ANNALIST":[{"def":"A writer of annals.","pos":""}],"ANNALISTIC":[{"def":"Pertaining to, or after the manner of, an annalist; as, the dry annalistic style.","pos":""}],"ANNALIZE":[{"def":"To record in annals.","pos":""}],"ANNALS":[{"def":"The record of a single event or item.","pos":""},{"def":"The first year's profits of a spiritual preferment, anciently paid by the clergy to the pope; first fruits.","pos":""}],"ANNEAL":[{"def":"To subject to great heat, and then cool slowly, as glass, cast iron, steel, or other metal, for the purpose of rendering it less brittle; to temper; to toughen.","pos":""},{"def":"To heat, as glass, tiles, or earthenware, in order to fix the colors laid on them.","pos":""}],"ANNEALER":[{"def":"One who, or that which, anneals.","pos":""}],"ANNEALING":[{"def":"The process used to render glass, iron, etc.","pos":""},{"def":"The burning of metallic colors into glass, earthenware, etc.","pos":""}],"ANNECTENT":[{"def":"Connecting; annexing.","pos":""},{"def":"Of or pertaining to the Annelida.","pos":""}],"ANNELIDA":[{"def":"A division of the Articulata, having the body formed of numerous rings or annular segments, and without jointed legs.","pos":""}],"ANNELIDOUS":[{"def":"Of the nature of an annelid.","pos":""}],"ANNELOID":[{"def":"An animal resembling an annelid.","pos":""}],"ANNEX":[{"def":"To join or attach; usually to subjoin; to affix; to append; -- followed by to.","pos":""},{"def":"To join or add, as a smaller thing to a greater.","pos":""}],"ANNEXATION":[{"def":"The act of annexing; process of attaching, adding, or appending; the act of connecting; union; as, the annexation of Texas to the United States, or of chattels to the freehold.","pos":""}],"ANNEXATIONIST":[{"def":"One who favors annexation.","pos":""}],"ANNEXER":[{"def":"One who annexes.","pos":""}],"ANNEXIONIST":[{"def":"An annexationist.","pos":""}],"ANNEXMENT":[{"def":"The act of annexing, or the thing annexed; appendage.","pos":""}],"ANNIHILABLE":[{"def":"Capable of being annihilated.","pos":""}],"ANNIHILATE":[{"def":"To reduce to nothing or nonexistence; to destroy the existence of; to cause to cease to be.","pos":""},{"def":"To destroy the form or peculiar distinctive properties of, so that the specific thing no longer exists; as, to annihilate a forest by cutting down the trees.","pos":""}],"ANNIHILATION":[{"def":"The act of reducing to nothing, or nonexistence; or the act of destroying the form or combination of parts under which a thing exists, so that the name can no longer be applied to it; as, the annihilation of a corporation.","pos":""},{"def":"The state of being annihilated.","pos":""}],"ANNIHILATIONIST":[{"def":"One who believes that eternal punishment consists in annihilation or extinction of being; a destructionist.","pos":""}],"ANNIHILATIVE":[{"def":"Serving to annihilate; destructive.","pos":""}],"ANNIHILATOR":[{"def":"One who, or that which, annihilates; as, a fire annihilator.","pos":""}],"ANNIVERSARILY":[{"def":"An`ni*ver\"sa*ri*ly, adv.","pos":""}],"ANNIVERSARY":[{"def":"Returning with the year, at a stated time; annual; yearly; as, an anniversary feast.","pos":""}],"ANNO DOMINI":[{"def":"In the year of the Christian era; as, a.","pos":""}],"ANNODATED":[{"def":"Curved somewhat in the form of the letter S.","pos":""}],"ANNOMINATION":[{"def":"Paronomasia; punning.","pos":""}],"ANNOTATE":[{"def":"To explain or criticize by notes; as, to annotate the works of Bacon.","pos":""}],"ANNOTATION":[{"def":"A note, added by way of comment, or explanation; -- usually in the plural; as, annotations on ancient authors, or on a word or a passage.","pos":""}],"ANNOTATIVE":[{"def":"Characterized by annotations; of the nature of annotation.","pos":""}],"ANNOTATOR":[{"def":"A writer of annotations; a commentator.","pos":""}],"ANNOTATORY":[{"def":"Pertaining to an annotator; containing annotations.","pos":""}],"ANNOTINE":[{"def":"A bird one year old, or that has once molted.","pos":""}],"ANNOTINOUS":[{"def":"A year old; in Yearly growths.","pos":""},{"def":"A red or yellowish-red dyeing material, prepared from the pulp surrounding the seeds of a tree (Bixa orellana) belonging to the tropical regions of America.","pos":""}],"ANNOUNCE":[{"def":"To give public notice, or first notice of; to make known; to publish; to proclaim.","pos":""},{"def":"To pronounce; to declare by judicial sentence.","pos":""}],"ANNOUNCEMENT":[{"def":"The act of announcing, or giving notice; that which announces; proclamation; publication.","pos":""}],"ANNOUNCER":[{"def":"One who announces.","pos":""}],"ANNOY":[{"def":"To molest, incommode, or harm; as, to annoy an army by impeding its march, or by a cannonade.","pos":""}],"ANNOYANCE":[{"def":"The act of annoying, or the state of being annoyed; molestation; vexation; annoy.","pos":""},{"def":"That which annoys.","pos":""}],"ANNOYER":[{"def":"One who, or that which, annoys.","pos":""}],"ANNOYING":[{"def":"That annoys; molesting; vexatious.","pos":""}],"ANNOYOUS":[{"def":"Troublesome; annoying.","pos":""}],"ANNUAL":[{"def":"Of or pertaining to a year; returning every year; coming or happening once in the year; yearly.","pos":""},{"def":"Performed or accomplished in a year; reckoned by the year; as, the annual motion of the earth.","pos":""}],"ANNUALIST":[{"def":"One who writes for, or who edits, an annual.","pos":""}],"ANNUALLY":[{"def":"Yearly; year by year.","pos":""}],"ANNUELER":[{"def":"A priest employed in saying annuals, or anniversary Masses.","pos":""}],"ANNUENT":[{"def":"Nodding; as, annuent muscles (used in nodding).","pos":""}],"ANNUITANT":[{"def":"One who receives, or its entitled to receive, an annuity.","pos":""}],"ANNUITY":[{"def":"A sum of money, payable yearly, to continue for a given number of years, for life, or forever; an annual allowance.","pos":""}],"ANNUL":[{"def":"To reduce to nothing; to obliterate.","pos":""},{"def":"To make void or of no effect; to nullify; to abolish; to do away with; -- used appropriately of laws, decrees, edicts, decisions of courts, or other established rules, permanent usages, and the like, which are made void by component authority.","pos":""}],"ANNULAR":[{"def":"Pertaining to, or having the form of, a ring; forming a ring; ringed; ring-shaped; as, annular fibers.","pos":""},{"def":"Banded or marked with circles.","pos":""}],"ANNULARITY":[{"def":"Annular condition or form; as, the annularity of a nebula.","pos":""}],"ANNULARRY":[{"def":"In an annular manner.","pos":""}],"ANNULARY":[{"def":"Having the form of a ring; annular.","pos":""}],"ANNULATA":[{"def":"A class of articulate animals, nearly equivalent to Annelida, including the marine annelids, earthworms, Gephyrea, Gymnotoma, leeches, etc.","pos":""}],"ANNULATE":[{"def":"One of the Annulata.","pos":""},{"def":"Of or pertaining to the Annulata.","pos":""}],"ANNULATION":[{"def":"A circular or ringlike formation; a ring or belt.","pos":""}],"ANNULET":[{"def":"A small, flat fillet, encircling a column, etc.","pos":""},{"def":"A little circle borne as a charge.","pos":""}],"ANNULLABLE":[{"def":"That may be Annulled.","pos":""}],"ANNULMENT":[{"def":"The act of annulling; abolition; invalidation.","pos":""}],"ANNULOID":[{"def":"Of or pertaining to the Annuloida.","pos":""}],"ANNULOIDA":[{"def":"A division of the Articulata, including the annelids and allied groups; sometimes made to include also the helminths and echinoderms.","pos":""}],"ANNULOSA":[{"def":"A division of the Invertebrata, nearly equivalent to the Articulata.","pos":""}],"ANNULOSAN":[{"def":"One of the Annulosa.","pos":""}],"ANNULOSE":[{"def":"Of or pertaining to the Annulosa.","pos":""}],"ANNULUS":[{"def":"Ring-shaped structures or markings, found in, or upon, various animals.","pos":""}],"ANNUMERATE":[{"def":"To add on; to count in.","pos":""}],"ANNUMERATION":[{"def":"Addition to a former number.","pos":""}],"ANNUNCIABLE":[{"def":"That may be announced or declared; declarable.","pos":""}],"ANNUNCIATE":[{"def":"Foretold; preannounced.","pos":""}],"ANNUNCIATION":[{"def":"The act of announcing; announcement; proclamation; as, the annunciation of peace.","pos":""}],"ANNUNCIATION LILY":[{"def":"The common white lily (Lilium candidum).","pos":""}],"ANNUNCIATIVE":[{"def":"Pertaining to annunciation; announcing.","pos":""}],"ANNUNCIATOR":[{"def":"One who announces.","pos":""},{"def":"An indicator (as in a hotel) which designates the room where attendance is wanted.","pos":""}],"ANNUNCIATORY":[{"def":"Pertaining to, or containing, announcement; making known.","pos":""}]}