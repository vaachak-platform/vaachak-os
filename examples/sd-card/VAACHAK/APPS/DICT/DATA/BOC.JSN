{"BOCAL":[{"def":"A cylindrical glass vessel, with a large and short neck.","pos":""}],"BOCARDO":[{"def":"A form of syllogism of which the first and third propositions are particular negatives, and the middle term a universal affirmative.","pos":""}],"BOCASINE":[{"def":"A sort of fine buckram.","pos":""}],"BOCCA":[{"def":"The round hole in the furnace of a glass manufactory through which the fused glass is taken out.","pos":""}],"BOCE":[{"def":"A European fish (Box vulgaris), having a compressed body and bright colors; -- called also box, and bogue.","pos":""}],"BOCK BEER":[{"def":"A strong beer, originally made in Bavaria.","pos":""}],"BOCKELET":[{"def":"A kind of long-winged hawk; -- called also bockerel, and bockeret.","pos":""}],"BOCKEY":[{"def":"A bowl or vessel made from a gourd.","pos":""}],"BOCKING":[{"def":"A coarse woolen fabric, used for floor cloths, to cover carpets, etc.","pos":""}]}