{"PED":[{"def":"A basket; a hammer; a pannier.","pos":""}],"PEDAGE":[{"def":"A toll or tax paid by passengers, entitling them to safe- conduct and protection.","pos":""}],"PEDAGOGIC":[{"def":"Of or pertaining to a pedagogue; suited to, or characteristic of, a pedagogue.","pos":""}],"PEDAGOGICS":[{"def":"The science or art of teaching; the principles and rules of teaching; pedagogy.","pos":""}],"PEDAGOGISM":[{"def":"The system, occupation, character, or manner of pedagogues.","pos":""}],"PEDAGOGUE":[{"def":"A slave who led his master's children to school, and had the charge of them generally.","pos":""}],"PEDAGOGY":[{"def":"Pedagogics; pedagogism.","pos":""}],"PEDAL":[{"def":"Of or pertaining to a pedal; having pedals.","pos":""}],"PEDALIAN":[{"def":"Relating to the foot, or to a metrical foot; pedal.","pos":""}],"PEDALITY":[{"def":"The act of measuring by paces.","pos":""}],"PEDANEOUS":[{"def":"Going on foot; pedestrian.","pos":""}],"PEDANT":[{"def":"Of or pertaining to a pedant; characteristic of, or resembling, a pedant; ostentatious of learning; as, a pedantic writer; a pedantic description; a pedantical affectation.","pos":""}],"PEDANTICALLY":[{"def":"In a pedantic manner.","pos":""}],"PEDANTISM":[{"def":"The office, disposition, or act of a pedant; pedantry.","pos":""}],"PEDANTIZE":[{"def":"To play the pedant; to use pedantic expressions.","pos":""}],"PEDANTOCRACY":[{"def":"The sway of pedants.","pos":""}],"PEDANTRY":[{"def":"The act, character, or manners of a pedant; vain ostentation of learning.","pos":""}],"PEDANTY":[{"def":"An assembly or clique of pedants.","pos":""}],"PEDARIAN":[{"def":"One of a class eligible to the office of senator, but not yet chosen, who could sit and speak in the senate, but could not vote; -- so called because he might indicate his opinion by walking over to the side of the party he favored when a vote was taken.","pos":""}],"PEDATA":[{"def":"An order of holothurians, including those that have ambulacral suckers, or feet, and an internal gill.","pos":""}],"PEDATE":[{"def":"Palmate, with the lateral lobes cleft into two or more segments; -- said of a leaf.","pos":""}],"PEDATIFID":[{"def":"Cleft in a pedate manner, but having the lobes distinctly connected at the base; -- said of a leaf.","pos":""}],"PEDDLE":[{"def":"To travel about with wares for sale; to go from place to place, or from house to house, for the purpose of retailing goods; as, to peddle without a license.","pos":""},{"def":"To do a small business; to be busy about trifles; to piddle.","pos":""}],"PEDDLER":[{"def":"One who peddles; a traveling trader; one who travels about, retailing small wares; a hawker.","pos":""}],"PEDDLERY":[{"def":"The trade, or the goods, of a peddler; hawking; small retail business, like that of a peddler.","pos":""},{"def":"Trifling; trickery.","pos":""}],"PEDDLING":[{"def":"Hawking; acting as a peddler.","pos":""},{"def":"Petty; insignificant.","pos":""}],"PEDERAST":[{"def":"One guilty of pederasty; a sodomite.","pos":""}],"PEDERASTIC":[{"def":"Of or pertaining to pederasty.","pos":""}],"PEDERASTY":[{"def":"The crime against nature; sodomy.","pos":""}],"PEDERERO":[{"def":"A term formerly applied to a short piece of chambered ordnance.","pos":""}],"PEDESIS":[{"def":"Same as Brownian movement, under Brownian.","pos":""}],"PEDESTAL":[{"def":"The base or foot of a column, statue, vase, lamp, or the like; the part on which an upright work stands.","pos":""}],"PEDESTALED":[{"def":"Placed on, or supported by, a pedestal; figuratively, exalted.","pos":""}],"PEDESTRIAL":[{"def":"Of or pertaining to the feet; employing the foot or feet.","pos":""}],"PEDESTRIALLY":[{"def":"In a pedestrial manner.","pos":""}],"PEDESTRIAN":[{"def":"Going on foot; performed on foot; as, a pedestrian journey.","pos":""}],"PEDESTRIANISM":[{"def":"The act, art, or practice of a pedestrian; walking or running; traveling or racing on foot.","pos":""}],"PEDESTRIANIZE":[{"def":"To practice walking; to travel on foot.","pos":""}],"PEDESTRIOUS":[{"def":"Going on foot; not winged.","pos":""}],"PEDETENTOUS":[{"def":"Proceeding step by step; advancing cautiously.","pos":""},{"def":"Combining forms from L.","pos":""}],"PEDIAL":[{"def":"Pertaining to the foot, or to any organ called a foot; pedal.","pos":""}],"PEDIATRIC":[{"def":"Pertaining to the care and medical treatment of children.","pos":""}],"PEDIATRICS":[{"def":"That branch of medical science which treats of the hygiene and diseases of children.","pos":""}],"PEDICEL":[{"def":"A slender stem by which certain of the lower animals or their eggs are attached.","pos":""}],"PEDICELLARIA":[{"def":"A peculiar forcepslike organ which occurs in large numbers upon starfishes and echini.","pos":""}],"PEDICELLATE":[{"def":"Having a pedicel; supported by a pedicel.","pos":""}],"PEDICELLINA":[{"def":"A genus of Bryozoa, of the order Entoprocta, having a bell- shaped body supported on a slender pedicel.","pos":""}],"PEDICLE":[{"def":"Same as Pedicel.","pos":""}],"PEDICULAR":[{"def":"Of or pertaining to lice; having the lousy distemper (phthiriasis); lousy.","pos":""}],"PEDICULATE":[{"def":"Of or pertaining to the Pediculati.","pos":""}],"PEDICULATI":[{"def":"An order of fishes including the anglers.","pos":""}],"PEDICULINA":[{"def":"A division of parasitic hemipterous insects, including the true lice.","pos":""}],"PEDICULUS":[{"def":"A genus of wingless parasitic Hemiptera, including the common lice of man.","pos":""}],"PEDICURE":[{"def":"The care of the feet and nails.","pos":""},{"def":"One who cares for the feet and nails; a chiropodist.","pos":""}],"PEDIFORM":[{"def":"Shaped like a foot.","pos":""}],"PEDIGEROUS":[{"def":"Bearing or having feet or legs.","pos":""}],"PEDIGREE":[{"def":"A record of the lineage or strain of an animal, as of a horse.","pos":""}],"PEDIGREE CLAUSE":[{"def":"A clause sometimes inserted in contracts or specifications, requiring that a material of construction, as cement, must be of a brand that has stood the test of a specified number of years' use in an important public work.","pos":""}],"PEDILUVY":[{"def":"The bathing of the feet, a bath for the feet.","pos":""}],"PEDIMANA":[{"def":"A division of marsupials, including the opossums.","pos":""}],"PEDIMANE":[{"def":"A pedimanous marsupial; an opossum.","pos":""}],"PEDIMANOUS":[{"def":"Having feet resembling hands, or with the first toe opposable, as the opossums and monkeys.","pos":""}],"PEDIMENT":[{"def":"Originally, in classical architecture, the triangular space forming the gable of a simple roof; hence, a similar form used as a decoration over porticoes, doors, windows, etc.","pos":""}],"PEDIMENTAL":[{"def":"Of or pertaining to a pediment.","pos":""}],"PEDIPALP":[{"def":"One of the Pedipalpi.","pos":""}],"PEDIPALPI":[{"def":"A division of Arachnida, including the whip scorpions (Thelyphonus) and allied forms.","pos":""}],"PEDIPALPOUS":[{"def":"Pertaining to, or resembling, the pedipalps.","pos":""}],"PEDIPALPUS":[{"def":"One of the second pair of mouth organs of arachnids.","pos":""}],"PEDIREME":[{"def":"A crustacean, some of whose feet serve as oars.","pos":""}],"PEDOBAPTISM":[{"def":"The baptism of infants or of small children.","pos":""}],"PEDOBAPTIST":[{"def":"One who advocates or practices infant baptism.","pos":""}],"PEDOGRAPH":[{"def":"An instrument carried by a pedestrian for automatically making a topographical record of the ground covered during a journey.","pos":""}],"PEDOMANCY":[{"def":"Divination by examining the soles of the feet.","pos":""}],"PEDOMETER":[{"def":"An instrument for including the number of steps in walking, and so ascertaining the distance passed over.","pos":""},{"def":"Pertaining to, or measured by, a pedometer.","pos":""}],"PEDOMOTIVE":[{"def":"Moved or worked by the action of the foot or feet on a pedal or treadle.","pos":""}],"PEDOTROPHY":[{"def":"The art of nourishing children properly.","pos":""}],"PEDUNCLE":[{"def":"The stem or stalk that supports the flower or fruit of a plant, or a cluster of flowers or fruits.","pos":""},{"def":"A sort of stem by which certain shells and barnacles are attached to other objects.","pos":""}],"PEDUNCLED":[{"def":"Having a peduncle; supported on a peduncle; pedunculate.","pos":""}],"PEDUNCULAR":[{"def":"Of or pertaining to a peduncle; growing from a peduncle; as, a peduncular tendril.","pos":""}],"PEDUNCULATA":[{"def":"A division of Cirripedia, including the stalked or goose barnacles.","pos":""},{"def":"Having a peduncle; growing on a peduncle; as, a pedunculate flower; a pedunculate eye, as in a lobster.","pos":""}]}