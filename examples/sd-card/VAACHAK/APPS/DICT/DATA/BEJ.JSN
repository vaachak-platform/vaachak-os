{"BEJADE":[{"def":"To jade or tire.","pos":""}],"BEJAPE":[{"def":"To jape; to laugh at; to deceive.","pos":""}],"BEJAUNDICE":[{"def":"To infect with jaundice.","pos":""}],"BEJEWEL":[{"def":"To ornament with a jewel or with jewels; to spangle.","pos":""}],"BEJUCO":[{"def":"Any climbing woody vine of the tropics with the habit of a liane; in the Philippines, esp.","pos":""}],"BEJUMBLE":[{"def":"To jumble together.","pos":""}]}