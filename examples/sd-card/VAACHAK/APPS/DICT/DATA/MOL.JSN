{"MOLAR":[{"def":"Of or pertaining to a mass of matter; -- said of the properties or motions of masses, as distinguished from those of molecules or atoms.","pos":""}],"MOLARY":[{"def":"Same as 2d Molar.","pos":""}],"MOLASSE":[{"def":"A soft Tertiary sandstone; -- applied to a rock occurring in Switzerland.","pos":""}],"MOLASSES":[{"def":"The thick, brown or dark colored, viscid, uncrystallizable sirup which drains from sugar, in the process of manufacture; any thick, viscid, sweet sirup made from vegetable juice or sap, as of the sorghum or maple.","pos":""}],"MOLD":[{"def":"A spot; a blemish; a mole.","pos":""},{"def":"To cover with mold or soil.","pos":""}],"MOLE":[{"def":"A spot; a stain; a mark which discolors or disfigures.","pos":""},{"def":"A spot, mark, or small permanent protuberance on the human body; esp.","pos":""}],"MOLE-EYED":[{"def":"Having eyes like those of the mole; having imperfect sight.","pos":""}],"MOLEBUT":[{"def":"The sunfish (Orthagoriscus, or Mola).","pos":""}],"MOLECAST":[{"def":"A little elevation of earth made by a mole; a molehill.","pos":""}],"MOLECH":[{"def":"The fire god of the Ammonites, to whom human sacrifices were offered; Moloch.","pos":""}],"MOLECULAR":[{"def":"Pertaining to, connected with, produced by, or consisting of, molecules; as, molecular forces; molecular groups of atoms, etc.","pos":""}],"MOLECULARITY":[{"def":"The state of consisting of molecules; the state or quality of being molecular.","pos":""}],"MOLECULARLY":[{"def":"With molecules; in the manner of molecules.","pos":""}],"MOLECULE":[{"def":"The smallest part of any substance which possesses the characteristic properties and qualities of that substance, and which can exist alone in a free state.","pos":""},{"def":"A group of atoms so united and combined by chemical affinity that they form a complete, integrated whole, being the smallest portion of any particular compound that can exist in a free state; as, a molecule of water consists of two atoms of hydrogen and one of oxygen.","pos":""}],"MOLEHILL":[{"def":"A little hillock of earth thrown up by moles working under ground; hence, a very small hill, or an insignificant obstacle or difficulty.","pos":""},{"def":"Resembling the sails of a windmill.","pos":""}],"MOLESKIN":[{"def":"Any fabric having a thick soft shag, like the fur of a mole; esp.","pos":""}],"MOLEST":[{"def":"To trouble; to disturb; to render uneasy; to interfere with; to vex.","pos":""}],"MOLESTATION":[{"def":"The act of molesting, or the state of being molested; disturbance; annoyance.","pos":""}],"MOLESTER":[{"def":"One who molests.","pos":""}],"MOLESTFUL":[{"def":"Troublesome; vexatious.","pos":""}],"MOLIMINOUS":[{"def":"Of great bulk or consequence; very important.","pos":""}],"MOLINE":[{"def":"The crossed iron that supports the upper millstone by resting on the spindle; a millrind.","pos":""}],"MOLINISM":[{"def":"The doctrines of the Molinists, somewhat resembling the tenets of the Arminians.","pos":""}],"MOLINIST":[{"def":"A follower of the opinions of Molina, a Spanish Jesuit (in respect to grace); an opposer of the Jansenists.","pos":""}],"MOLL":[{"def":"Minor; in the minor mode; as, A moll, that is, A minor.","pos":""}],"MOLLAH":[{"def":"One of the higher order of Turkish judges; also, a Turkish title of respect for a religious and learned man.","pos":""}],"MOLLE":[{"def":"Lower by a semitone; flat; as, E molle, that is, E flat.","pos":""}],"MOLLEBART":[{"def":"An agricultural implement used in Flanders, consisting of a kind of large shovel drawn by a horse and guided by a man.","pos":""}],"MOLLEMOKE":[{"def":"Any one of several species of large pelagic petrels and fulmars, as Fulmarus glacialis, of the North Atlantic, and several species of Æstrelata, of the Southern Ocean.","pos":""}],"MOLLIENT":[{"def":"Serving to soften; assuaging; emollient.","pos":""}],"MOLLIFIABLE":[{"def":"Capable of being mollified.","pos":""}],"MOLLIFICATION":[{"def":"The act of mollifying, or the state of being mollified; a softening.","pos":""}],"MOLLIFIER":[{"def":"One who, or that which, mollifies.","pos":""}],"MOLLIFY":[{"def":"To soften; to make tender; to reduce the hardness, harshness, or asperity of; to qualify; as, to mollify the ground.","pos":""},{"def":"To assuage, as pain or irritation, to appease, as excited feeling or passion; to pacify; to calm.","pos":""}],"MOLLIPILOSE":[{"def":"Having soft hairs; downy.","pos":""}],"MOLLITIES":[{"def":"Unnatural softness of any organ or part.","pos":""}],"MOLLITUDE":[{"def":"Softness; effeminacy; weakness.","pos":""}],"MOLLUSC":[{"def":"Same as Mollusk.","pos":""}],"MOLLUSCA":[{"def":"One of the grand divisions of the animal kingdom, including the classes Cephalopoda, Gastropoda, PteropodaScaphopoda, and Lamellibranchiata, or Conchifera.","pos":""}],"MOLLUSCAN":[{"def":"Of or pertaining to mollusks.","pos":""},{"def":"A mollusk; one of the Mollusca.","pos":""}],"MOLLUSCOID":[{"def":"Resembling the true mollusks; belonging to the Molluscoidea.","pos":""},{"def":"One of the Molluscoidea.","pos":""}],"MOLLUSCOIDEA":[{"def":"A division of Invertebrata which includes the classes Brachiopoda and Bryozoa; -- called also Anthoid Mollusca.","pos":""}],"MOLLUSCUM":[{"def":"A cutaneous disease characterized by numerous tumors, of various forms, filled with a thick matter; -- so called from the resemblance of the tumors to some molluscous animals.","pos":""}],"MOLLUSK":[{"def":"One of the Mollusca.","pos":""}],"MOLLY":[{"def":"Same as Mollemoke.","pos":""}],"MOLOCH":[{"def":"The fire god of the Ammonites in Canaan, to whom human sacrifices were offered; Molech.","pos":""},{"def":"A spiny Australian lizard (Moloch horridus).","pos":""}],"MOLOSSINE":[{"def":"A bat of the genus Molossus, as the monk bat.","pos":""}],"MOLOSSUS":[{"def":"A foot of three long syllables.","pos":""}],"MOLT":[{"def":"To shed or cast the hair, feathers, skin, horns, or the like, as an animal or a bird.","pos":""}],"MOLTABLE":[{"def":"Capable of assuming a molten state; meltable; fusible.","pos":""}],"MOLTEN":[{"def":"Melted; being in a state of fusion, esp.","pos":""},{"def":"Made by melting and casting the substance or metal of which the thing is formed; as, a molten image.","pos":""}],"MOLTO":[{"def":"Much; very; as, molto adagio, very slow.","pos":""}],"MOLY":[{"def":"A kind of garlic (Allium Moly) with large yellow flowers; -- called also golden garlic.","pos":""}],"MOLYBDATE":[{"def":"A salt of molybdic acid.","pos":""}],"MOLYBDENA":[{"def":"See Molybdenite.","pos":""}],"MOLYBDENITE":[{"def":"A mineral occurring in soft, lead-gray, foliated masses or scales, resembling graphite; sulphide of molybdenum.","pos":""}],"MOLYBDENUM":[{"def":"A rare element of the chromium group, occurring in nature in the minerals molybdenite and wulfenite, and when reduced obtained as a hard, silver-white, difficulty fusible metal.","pos":""}],"MOLYBDIC":[{"def":"Of, pertaining to, or containing, molybdenum; specif.","pos":""}],"MOLYBDOUS":[{"def":"Of, pertaining to, or containing, molybdenum; specif.","pos":""}]}