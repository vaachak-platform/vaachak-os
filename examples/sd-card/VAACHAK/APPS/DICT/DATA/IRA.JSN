{"IRACUND":[{"def":"Irascible; choleric.","pos":""}],"IRADE":[{"def":"A decree of the Sultan.","pos":""}],"IRAN":[{"def":"The native name of Persia.","pos":""}],"IRANIAN":[{"def":"Of or pertaining to Iran.","pos":""},{"def":"A native of Iran; also, the Iranian or Persian language, a division of the Aryan family of languages.","pos":""}],"IRASCIBILITY":[{"def":"The quality or state of being irascible; irritability of temper; irascibleness.","pos":""}],"IRASCIBLE":[{"def":"Prone to anger; easily provoked or inflamed to anger; choleric; irritable; as, an irascible man; an irascible temper or mood.","pos":""}],"IRATE":[{"def":"Angry; incensed; enraged.","pos":""}]}