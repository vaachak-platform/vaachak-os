{"DEFIANCE":[{"def":"The act of defying, putting in opposition, or provoking to combat; a challenge; a provocation; a summons to combat.","pos":""},{"def":"A state of opposition; willingness to flight; disposition to resist; contempt of opposition.","pos":""}],"DEFIANT":[{"def":"Full of defiance; bold; insolent; as, a defiant spirit or act.","pos":""}],"DEFIATORY":[{"def":"Bidding or manifesting defiance.","pos":""}],"DEFIBRINATE":[{"def":"To deprive of fibrin, as fresh blood or lymph by stirring with twigs.","pos":""}],"DEFIBRINATION":[{"def":"The act or process of depriving of fibrin.","pos":""}],"DEFICIENCE":[{"def":"Same as Deficiency.","pos":""}],"DEFICIENCY":[{"def":"The state of being deficient; inadequacy; want; failure; imperfection; shortcoming; defect.","pos":""}],"DEFICIENT":[{"def":"Wanting, to make up completeness; wanting, as regards a requirement; not sufficient; inadequate; defective; imperfect; incomplete; lacking; as, deficient parts; deficient estate; deficient strength; deficient in judgment.","pos":""}],"DEFICIT":[{"def":"Deficiency in amount or quality; a falling short; lack; as, a deficit in taxes, revenue, etc.","pos":""}],"DEFIER":[{"def":"One who dares and defies; a contemner; as, a defier of the laws.","pos":""}],"DEFIGURATION":[{"def":"Disfiguration; mutilation.","pos":""}],"DEFIGURE":[{"def":"These two stones as they are here defigured.","pos":""}],"DEFILADE":[{"def":"To raise, as a rampart, so as to shelter interior works commanded from some higher point.","pos":""}],"DEFILADING":[{"def":"The art or act of determining the directions and heights of the lines of rampart with reference to the protection of the interior from exposure to an enemy's fire from any point within range, or from any works which may be erected.","pos":""}],"DEFILE":[{"def":"To march off in a line, file by file; to file off.","pos":""}],"DEFILEMENT":[{"def":"The protection of the interior walls of a fortification from an enfilading fire, as by covering them, or by a high parapet on the exposed side.","pos":""}],"DEFILER":[{"def":"One who defiles; one who corrupts or violates; that which pollutes.","pos":""}],"DEFILIATION":[{"def":"Abstraction of a child from its parents.","pos":""}],"DEFINABLE":[{"def":"Capable of being defined, limited, or explained; determinable; describable by definition; ascertainable; as, definable limits; definable distinctions or regulations; definable words.","pos":""}],"DEFINE":[{"def":"To fix the bounds of; to bring to a termination; to end.","pos":""},{"def":"To determine or clearly exhibit the boundaries of; to mark the limits of; as, to define the extent of a kingdom or country.","pos":""}],"DEFINEMENT":[{"def":"The act of defining; definition; description.","pos":""}],"DEFINER":[{"def":"One who defines or explains.","pos":""}],"DEFINITE":[{"def":"Having certain or distinct; determinate in extent or greatness; limited; fixed; as, definite dimensions; a definite measure; a definite period or interval.","pos":""},{"def":"Having certain limits in signification; determinate; certain; precise; fixed; exact; clear; as, a definite word, term, or expression.","pos":""}],"DEFINITELY":[{"def":"In a definite manner; with precision; precisely; determinately.","pos":""}],"DEFINITENESS":[{"def":"The state of being definite; determinateness; precision; certainty.","pos":""}],"DEFINITION":[{"def":"An exact enunciation of the constituents which make up the logical essence.","pos":""},{"def":"Distinctness or clearness, as of an image formed by an optical instrument; precision in detail.","pos":""}],"DEFINITIONAL":[{"def":"Relating to definition; of the nature of a definition; employed in defining.","pos":""}],"DEFINITIVE":[{"def":"Determinate; positive; final; conclusive; unconditional; express.","pos":""},{"def":"Limiting; determining; as, a definitive word.","pos":""}],"DEFINITIVELY":[{"def":"In a definitive manner.","pos":""}],"DEFINITIVENESS":[{"def":"The quality of being definitive.","pos":""}],"DEFIX":[{"def":"To fix; to fasten; to establish.","pos":""}]}