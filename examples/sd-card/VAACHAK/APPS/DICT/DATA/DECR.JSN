{"DECREASE":[{"def":"To grow less, -- opposed to increase; to be diminished gradually, in size, degree, number, duration, etc.","pos":""}],"DECREASELESS":[{"def":"Suffering no decrease.","pos":""}],"DECREASING":[{"def":"Becoming less and less; diminishing.","pos":""}],"DECREATION":[{"def":"Destruction; -- opposed to creation.","pos":""}],"DECREE":[{"def":"An edict or law made by a council for regulating any business within their jurisdiction; as, the decrees of ecclesiastical councils.","pos":""}],"DECREEABLE":[{"def":"Capable of being decreed.","pos":""}],"DECREER":[{"def":"One who decrees.","pos":""}],"DECREET":[{"def":"The final judgment of the Court of Session, or of an inferior court, by which the question at issue is decided.","pos":""}],"DECREMENT":[{"def":"A name given by Haüy to the successive diminution of the layers of molecules, applied to the faces of the primitive form, by which he supposed the secondary forms to be produced.","pos":""},{"def":"The quantity by which a variable is diminished.","pos":""}],"DECREPIT":[{"def":"Broken down with age; wasted and enfeebled by the infirmities of old age; feeble; worn out.","pos":""}],"DECREPITATE":[{"def":"To roast or calcine so as to cause a crackling noise; as, to decrepitate salt.","pos":""}],"DECREPITATION":[{"def":"The act of decrepitating; a crackling noise, such as salt makes when roasting.","pos":""}],"DECREPITUDE":[{"def":"The broken state produced by decay and the infirmities of age; infirm old age.","pos":""}],"DECRESCENDO":[{"def":"With decreasing volume of sound; -- a direction to performers, either written upon the staff (abbreviated Dec.","pos":""}],"DECRESCENT":[{"def":"Becoming less by gradual diminution; decreasing; as, a decrescent moon.","pos":""}],"DECRETAL":[{"def":"Appertaining to a decree; containing a decree; as, a decretal epistle.","pos":""}],"DECRETIST":[{"def":"One who studies, or professes the knowledge of, the decretals.","pos":""}],"DECRETIVE":[{"def":"Having the force of a decree; determining.","pos":""}],"DECRETORIAL":[{"def":"Decretory; authoritative.","pos":""}],"DECRETORILY":[{"def":"In a decretory or definitive manner; by decree.","pos":""}],"DECRETORY":[{"def":"Established by a decree; definitive; settled.","pos":""},{"def":"Serving to determine; critical.","pos":""}],"DECRIAL":[{"def":"A crying down; a clamorous censure; condemnation by censure.","pos":""}],"DECRIER":[{"def":"One who decries.","pos":""}],"DECROWN":[{"def":"To deprive of a crown; to discrown.","pos":""}],"DECRUSTATION":[{"def":"The removal of a crust.","pos":""}],"DECRY":[{"def":"To cry down; to censure as faulty, mean, or worthless; to clamor against; to blame clamorously; to discredit; to disparage.","pos":""}]}