{"STOP":[{"def":"To regulate the sounds of, as musical strings, by pressing them against the finger board with the finger, or by shortening in any way the vibrating part.","pos":""},{"def":"To make fast; to stopper.","pos":""}],"STOP ORDER":[{"def":"An order that aims to limit losses by fixing a figure at which purchases shall be sold or sales bought in, as where stock is bought at 100 and the broker is directed to sell if the market price drops to 98.","pos":""}],"STOP-GAP":[{"def":"That which closes or fills up an opening or gap; hence, a temporary expedient.","pos":""}],"STOP-OVER":[{"def":"Permitting one to stop over; as, a stop-over check or ticket.","pos":""}],"STOPCOCK":[{"def":"A bib, faucet, or short pipe, fitted with a turning stopper or plug for permitting or restraining the flow of a liquid or gas; a cock or valve for checking or regulating the flow of water, gas, etc.","pos":""},{"def":"The turning plug, stopper, or spigot of a faucet.","pos":""}],"STOPE":[{"def":"A horizontal working forming one of a series, the working faces of which present the appearance of a flight of steps.","pos":""}],"STOPING":[{"def":"The act of excavating in the form of stopes.","pos":""}],"STOPLESS":[{"def":"Not to be stopped.","pos":""}],"STOPPAGE":[{"def":"The act of stopping, or arresting progress, motion, or action; also, the state of being stopped; as, the stoppage of the circulation of the blood; the stoppage of commerce.","pos":""}],"STOPPED":[{"def":"Made by complete closure of the mouth organs; shut; -- said of certain consonants (p, b, t, d, etc.","pos":""}],"STOPPER":[{"def":"A short piece of rope having a knot at one or both ends, with a lanyard under the knot, -- used to secure something.","pos":""},{"def":"A name to several trees of the genus Eugenia, found in Florida and the West Indies; as, the red stopper.","pos":""}],"STOPPING":[{"def":"A partition or door to direct or prevent a current of air.","pos":""},{"def":"A pad or poultice of dung or other material applied to a horse's hoof to keep it moist.","pos":""}],"STOPPING-OUT":[{"def":"A method adopted in etching, to keep the acid from those parts which are already sufficiently corroded, by applying varnish or other covering matter with a brush, but allowing the acid to act on the other parts.","pos":""}],"STOPPLE":[{"def":"That which stops or closes the mouth of a vessel; a stopper; as, a glass stopple; a cork stopple.","pos":""}]}