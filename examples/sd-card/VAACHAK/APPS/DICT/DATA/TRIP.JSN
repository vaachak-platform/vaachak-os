{"TRIP":[{"def":"To move with light, quick steps; to walk or move lightly; to skip; to move the feet nimbly; -- sometimes followed by it.","pos":""},{"def":"To make a brief journey or pleasure excursion; as, to trip to Europe.","pos":""}],"TRIPALMITATE":[{"def":"A palmitate derived from three molecules of palmitic acid.","pos":""}],"TRIPARTED":[{"def":"Parted into three piece; having three parts or pieces; -- said of the field or of a bearing; as, a cross triparted.","pos":""},{"def":"Divided nearly to the base into three segments or lobes.","pos":""}],"TRIPARTIBLE":[{"def":"Divisible into three parts.","pos":""}],"TRIPARTIENT":[{"def":"Dividing into three parts; -- said of a number which exactly divides another into three parts.","pos":""}],"TRIPARTITE":[{"def":"Divided into three parts; triparted; as, a tripartite leaf.","pos":""},{"def":"Having three corresponding parts or copies; as, to make indentures tripartite.","pos":""}],"TRIPARTITELY":[{"def":"In a tripartite manner.","pos":""}],"TRIPARTITION":[{"def":"A division by threes, or into three parts; the taking of a third part of any number or quantity.","pos":""}],"TRIPASCHAL":[{"def":"Including three passovers.","pos":""}],"TRIPE":[{"def":"The large stomach of ruminating animals, when prepared for food.","pos":""},{"def":"The entrails; hence, humorously or in contempt, the belly; -- generally used in the plural.","pos":""}],"TRIPE-DE-ROCHE":[{"def":"Same as Rock tripe, under Rock.","pos":""}],"TRIPEDAL":[{"def":"Having three feet.","pos":""}],"TRIPEL":[{"def":"Same as Tripoli.","pos":""}],"TRIPEMAN":[{"def":"A man who prepares or sells tripe.","pos":""}],"TRIPENNATE":[{"def":"Same as Tripinnate.","pos":""}],"TRIPERSONAL":[{"def":"Consisting of three persons.","pos":""}],"TRIPERSONALIST":[{"def":"Tri*per\"son*al*ist, n.","pos":""}],"TRIPERSONALITY":[{"def":"The state of existing as three persons in one Godhead; trinity.","pos":""}],"TRIPERY":[{"def":"A place where tripe is prepared or sold.","pos":""}],"TRIPESTONE":[{"def":"A variety of anhydrite composed of contorted plates fancied to resemble pieces of tripe.","pos":""}],"TRIPETALOID":[{"def":"Having the form or appearance of three petals; appearing as if furnished with three petals.","pos":""}],"TRIPETALOUS":[{"def":"Having three petals, or flower leaves; three-petaled.","pos":""}],"TRIPHTHONG":[{"def":"A combination of three vowel sounds in a single syllable, forming a simple or compound sound; also, a union of three vowel characters, representing together a single sound; a trigraph; as, eye, -ieu in adieu, -eau in beau, are examples of triphthongs.","pos":""}],"TRIPHTHONGAL":[{"def":"Of or pertaining to a triphthong; consisting of three vowel sounds pronounced together in a single syllable.","pos":""}],"TRIPHYLITE":[{"def":"A mineral of a grayish-green or bluish color, consisting of the phosphates of iron, manganese, and lithia.","pos":""}],"TRIPHYLLOUS":[{"def":"Having three leaves; three-leaved.","pos":""}],"TRIPINNATE":[{"def":"Having bipinnate leaflets arranged on each side of a rhachis.","pos":""}],"TRIPINNATIFID":[{"def":"Thrice pinnately cleft; -- said of a pinnatifid leaf when its segments are pinnatifid, and the subdivisions of these also are pinnatifid.","pos":""}],"TRIPITAKA":[{"def":"The three divisions, or \"baskets\" (pitakas), of buddhist scriptures, -- the Vinayapitaka [Skr.","pos":""}],"TRIPLASIAN":[{"def":"Three-fold; triple; treble.","pos":""}],"TRIPLE":[{"def":"Consisting of three united; multiplied by three; threefold; as, a triple knot; a triple tie.","pos":""},{"def":"Three times repeated; treble.","pos":""}],"TRIPLE-CROWNED":[{"def":"Having three crowns; wearing the triple crown, as the pope.","pos":""}],"TRIPLE-HEADED":[{"def":"Having three heads; three-headed; as, the triple-headed dog Cerberus.","pos":""}],"TRIPLE-TAIL":[{"def":"An edible fish (Lobotes Surinamensis) found in the warmer parts of all the oceans, and common on the southern and middle coasts of the United States.","pos":""}],"TRIPLET":[{"def":"Three verses rhyming together.","pos":""},{"def":"A group of three notes sung or played in the tree of two.","pos":""}],"TRIPLEX":[{"def":"Havingthree principal operative parts or motions, so as to produce a three-fold effect.","pos":""}],"TRIPLICATE":[{"def":"Made thrice as much; threefold; tripled.","pos":""}],"TRIPLICATE-TERNATE":[{"def":"Trip\"li*cate-ter`nate, a.","pos":""}],"TRIPLICATION":[{"def":"Same as Surrejoinder.","pos":""}],"TRIPLICITY":[{"def":"The quality or state of being triple, or threefold; trebleness.","pos":""}],"TRIPLITE":[{"def":"A mineral of a dark brown color, generally with a fibrous, massive structure.","pos":""}],"TRIPLOBLASTIC":[{"def":"Of, pertaining to, or designating, that condition of the ovum in which there are three primary germinal layers, or in which the blastoderm splits into three layers.","pos":""}],"TRIPLOIDITE":[{"def":"A manganese phosphate near triplite, but containing hydroxyl instead of fluorine.","pos":""}],"TRIPLY":[{"def":"In a triple manner.","pos":""}],"TRIPMADAM":[{"def":"Same as Prickmadam.","pos":""}],"TRIPOD":[{"def":"Any utensil or vessel, as a stool, table, altar, caldron, etc.","pos":""},{"def":"A three-legged frame or stand, usually jointed at top, for supporting a theodolite, compass, telescope, camera, or other instrument.","pos":""}],"TRIPODIAN":[{"def":"An ancient stringed instrument; -- so called because, in form, it resembled the Delphic tripod.","pos":""}],"TRIPODY":[{"def":"Three metrical feet taken together, or included in one measure.","pos":""}],"TRIPOLI":[{"def":"An earthy substance originally brought from Tripoli, used in polishing stones and metals.","pos":""}],"TRIPOLINE":[{"def":"Of or pertaining to Tripoli or its inhabitants; Tripolitan.","pos":""},{"def":"Of or pertaining to tripoli, the mineral.","pos":""}],"TRIPOLITAN":[{"def":"Of or pertaining to Tripoli or its inhabitants; Tripoline.","pos":""},{"def":"A native or inhabitant of Tripoli.","pos":""}],"TRIPOS":[{"def":"A university examination of questionists, for honors; also, a tripos paper; one who prepares a tripos paper.","pos":""}],"TRIPPANT":[{"def":"See Tripping, a.","pos":""}],"TRIPPER":[{"def":"One who trips or supplants; also, one who walks or trips nimbly; a dancer.","pos":""},{"def":"An excursionist.","pos":""}],"TRIPPET":[{"def":"A cam, wiper, or projecting piece which strikes another piece repeatedly.","pos":""}],"TRIPPING":[{"def":"Having the right forefoot lifted, the others remaining on the ground, as if he were trotting; trippant; -- said of an animal, as a hart, buck, and the like, used as a bearing.","pos":""}],"TRIPPINGLY":[{"def":"In a tripping manner; with a light, nimble, quick step; with agility; nimbly.","pos":""}],"TRIPTOTE":[{"def":"A noun having three cases only.","pos":""}],"TRIPTYCH":[{"def":"Anything in three parts or leaves.","pos":""}],"TRIPUDIARY":[{"def":"Of or pertaining to dancing; performed by dancing.","pos":""}],"TRIPUDIATION":[{"def":"The act of dancing.","pos":""}]}