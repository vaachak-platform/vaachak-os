{"RAVAGE":[{"def":"Desolation by violence; violent ruin or destruction; devastation; havoc; waste; as, the ravage of a lion; the ravages of fire or tempest; the ravages of an army, or of time.","pos":""}],"RAVAGER":[{"def":"One who, or that which, ravages or lays waste; spoiler.","pos":""}],"RAVE":[{"def":"One of the upper side pieces of the frame of a wagon body or a sleigh.","pos":""}],"RAVEHOOK":[{"def":"A tool, hooked at the end, for enlarging or clearing seams for the reception of oakum.","pos":""}],"RAVEL":[{"def":"To separate or undo the texture of; to take apart; to untwist; to unweave or unknit; -- often followed by out; as, to ravel a twist; to ravel out a sticking.","pos":""},{"def":"To undo the intricacies of; to disentangle.","pos":""}],"RAVELIN":[{"def":"A detached work with two embankments with make a salient angle.","pos":""}],"RAVELING":[{"def":"The act of untwisting, or of disentangling.","pos":""},{"def":"That which is raveled out; esp.","pos":""}],"RAVEN":[{"def":"A large black passerine bird (Corvus corax), similar to the crow, but larger.","pos":""}],"RAVEN'S-DUCK":[{"def":"A fine quality of sailcloth.","pos":""}],"RAVENALA":[{"def":"A genus of plants related to the banana.","pos":""}],"RAVENER":[{"def":"One who, or that which, ravens or plunders.","pos":""},{"def":"A bird of prey, as the owl or vulture.","pos":""}],"RAVENING":[{"def":"Eagerness for plunder; rapacity; extortion.","pos":""}],"RAVENOUS":[{"def":"Devouring with rapacious eagerness; furiously voracious; hungry even to rage; as, a ravenous wolf or vulture.","pos":""},{"def":"Eager for prey or gratification; as, a ravenous appetite or desire.","pos":""}],"RAVIN":[{"def":"Food obtained by violence; plunder; prey; raven.","pos":""}],"RAVINE":[{"def":"A torrent of water.","pos":""},{"def":"A deep and narrow hollow, usually worn by a stream or torrent of water; a gorge; a mountain cleft.","pos":""}],"RAVING":[{"def":"Talking irrationally and wildly; as, a raving lunatic.","pos":""}],"RAVISH":[{"def":"To seize and carry away by violence; to snatch by force.","pos":""},{"def":"To transport with joy or delight; to delight to ecstasy.","pos":""}],"RAVISHER":[{"def":"One who ravishes (in any sense).","pos":""}],"RAVISHING":[{"def":"Rapturous; transporting.","pos":""}],"RAVISHINGLY":[{"def":"In a ravishing manner.","pos":""}],"RAVISHMENT":[{"def":"The act of carrying away by force or against consent; abduction; as, the ravishment of children from their parents, or a ward from his guardian, or of a wife from her husband.","pos":""},{"def":"The state of being ravished; rapture; transport of delight; ecstasy.","pos":""}],"RAVISSANT":[{"def":"In a half-raised position, as if about to spring on prey.","pos":""}]}