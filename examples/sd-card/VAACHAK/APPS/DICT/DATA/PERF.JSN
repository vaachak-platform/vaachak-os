{"PERFECT":[{"def":"Hermaphrodite; having both stamens and pistils; -- said of flower.","pos":""}],"PERFECTER":[{"def":"One who, or that which, makes perfect.","pos":""}],"PERFECTIBILIAN":[{"def":"A perfectionist.","pos":""}],"PERFECTIBILIST":[{"def":"A perfectionist.","pos":""}],"PERFECTIBILITY":[{"def":"The quality or state of being perfectible.","pos":""}],"PERFECTIBLE":[{"def":"Capable of becoming, or being made, perfect.","pos":""}],"PERFECTION":[{"def":"A quality, endowment, or acquirement completely excellent; an ideal faultlessness; especially, the divine attribute of complete excellence.","pos":""}],"PERFECTIONAL":[{"def":"Of or pertaining to perfection; characterized by perfection.","pos":""}],"PERFECTIONISM":[{"def":"The doctrine of the Perfectionists.","pos":""}],"PERFECTIONIST":[{"def":"One pretending to perfection; esp.","pos":""}],"PERFECTIONMENT":[{"def":"The act of bringing to perfection, or the state of having attained to perfection.","pos":""}],"PERFECTIVE":[{"def":"Tending or conducing to make perfect, or to bring to perfection; -- usually followed by of.","pos":""}],"PERFECTIVELY":[{"def":"In a perfective manner.","pos":""}],"PERFECTLY":[{"def":"In a perfect manner or degree; in or to perfection; completely; wholly; throughly; faultlessly.","pos":""}],"PERFECTNESS":[{"def":"The quality or state of being perfect; perfection.","pos":""}],"PERFERVID":[{"def":"Very fervid; too fervid; glowing; ardent.","pos":""}],"PERFICIENT":[{"def":"Making or doing throughly; efficient; effectual.","pos":""}],"PERFIDIOUS":[{"def":"Guilty of perfidy; violating good faith or vows; false to trust or confidence reposed; teacherous; faithless; as, a perfidious friend.","pos":""},{"def":"Involving, or characterized by, perfidy.","pos":""}],"PERFIDIOUSLY":[{"def":"In a perfidious manner.","pos":""}],"PERFIDIOUSNESS":[{"def":"The quality of being perfidious; perfidy.","pos":""}],"PERFIDY":[{"def":"The act of violating faith or allegiance; violation of a promise or vow, or of trust reposed; faithlessness; teachery.","pos":""}],"PERFIX":[{"def":"To fix surely; to appoint.","pos":""}],"PERFLABLE":[{"def":"Capable of being blown through.","pos":""}],"PERFLATE":[{"def":"To blow through.","pos":""}],"PERFLATION":[{"def":"The act of perflating.","pos":""}],"PERFOLIATE":[{"def":"Having the basal part produced around the stem; -- said of leaves which the stem apparently passes directory through.","pos":""},{"def":"Surrounded by a circle of hairs, or projections of any kind.","pos":""}],"PERFORATE":[{"def":"To bore through; to pierce through with a pointed instrument; to make a hole or holes through by boring or piercing; to pierce or penetrate the surface of.","pos":""},{"def":"Pierced with a hole or holes, or with pores; having transparent dots resembling holes.","pos":""}],"PERFORATION":[{"def":"The act of perforating, or of boring or piercing through.","pos":""},{"def":"A hole made by boring or piercing; an aperture.","pos":""}],"PERFORATIVE":[{"def":"Having power to perforate or pierce.","pos":""}],"PERFORATOR":[{"def":"One who, or that which, perforates; esp.","pos":""}],"PERFORCE":[{"def":"By force; of necessary; at any rate.","pos":""}],"PERFORM":[{"def":"To carry through; to bring to completion; to achieve; to accomplish; to execute; to do.","pos":""},{"def":"To discharge; to fulfill; to act up to; as, to perform a duty; to perform a promise or a vow.","pos":""}],"PERFORMABLE":[{"def":"Admitting of being performed, done, or executed; practicable.","pos":""}],"PERFORMANCE":[{"def":"The act of performing; the carrying into execution or action; execution; achievement; accomplishment; representation by action; as, the performance of an undertaking of a duty.","pos":""}],"PERFORMER":[{"def":"One who performs, accomplishes, or fulfills; as, a good promiser, but a bad performer; especially, one who shows skill and training in any art; as, a performer of the drama; a performer on the harp.","pos":""}],"PERFUMATORY":[{"def":"Emitting perfume; perfuming.","pos":""}],"PERFUME":[{"def":"To fill or impregnate with a perfume; to scent.","pos":""}],"PERFUMER":[{"def":"One who, oe that which, perfumes.","pos":""},{"def":"One whose trade is to make or sell perfumes.","pos":""}],"PERFUMERY":[{"def":"The art of preparing perfumes.","pos":""}],"PERFUNCTORILY":[{"def":"In a perfunctory manner; formally; carelessly.","pos":""}],"PERFUNCTORINESS":[{"def":"The quality or state of being perfunctory.","pos":""}],"PERFUNCTORY":[{"def":"Done merely to get rid of a duty; performed mechanically and as a thing of rote; done in a careless and superficial manner; characterized by indifference; as, perfunctory admonitions.","pos":""},{"def":"Hence: Mechanical; indifferent; listless; careless.","pos":""}],"PERFUNCTURATE":[{"def":"To perform in a perfunctory manner; to do negligently.","pos":""}],"PERFUSE":[{"def":"To suffuse; to fill full or to excess.","pos":""}],"PERFUSION":[{"def":"The act of perfusing.","pos":""}],"PERFUSIVE":[{"def":"Of a nature to flow over, or to spread through.","pos":""}]}