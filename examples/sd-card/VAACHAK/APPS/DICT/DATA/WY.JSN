{"WYCH-ELM":[{"def":"A species of elm (Ulmus montana) found in Northern and Western Europe; Scotch elm.","pos":""}],"WYCH-HAZEL":[{"def":"The wych-elm; -- so called because its leaves are like those of the hazel.","pos":""},{"def":"A follower of Wyclif, the English reformer; a Lollard.","pos":""}],"WYE":[{"def":"A kind of crotch.","pos":""}],"WYLA":[{"def":"A helmeted Australian cockatoo (Calyptorhynchus funereus); -- called also funeral cockatoo.","pos":""},{"def":"One of the runes adopted into the Anglo-Saxon, or Old English, alphabet.","pos":""}],"WYND":[{"def":"A narrow lane or alley.","pos":""}],"WYNKERNEL":[{"def":"The European moor hen.","pos":""}],"WYNN":[{"def":"A kind of timber truck, or carriage.","pos":""}],"WYPE":[{"def":"The wipe, or lapwing.","pos":""}],"WYS":[{"def":"WYTE; WYTEN Wyte, Wy\"ten, obs.","pos":""}],"WYTHE":[{"def":"Same as Withe, n.","pos":""}],"WYVERN":[{"def":"X, the twenty-fourth letter of the English alphabet, has three sounds; a compound nonvocal sound (that of ks), as in wax; a compound vocal sound (that of gz), as in example; and, at the beginning of a word, a simple vocal sound (that of z), as in xanthic.","pos":""}]}