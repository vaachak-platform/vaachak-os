{"CIS-":[{"def":"A Latin preposition, sometimes used as a prefix in English words, and signifying on this side.","pos":""}],"CISALPINE":[{"def":"On the hither side of the Alps with reference to Rome, that is, on the south side of the Alps; -- opposed to transalpine.","pos":""}],"CISATLANTIC":[{"def":"On this side of the Atlantic Ocean; -- used of the eastern or the western side, according to the standpoint of the writer.","pos":""}],"CISCO":[{"def":"The Lake herring (Coregonus Artedi), valuable food fish of the Great Lakes of North America.","pos":""}],"CISELURE":[{"def":"The process of chasing on metals; also, the work thus chased.","pos":""}],"CISLEITHAN":[{"def":"On the Austrian side of the river Leitha; Austrian.","pos":""}],"CISMONTANE":[{"def":"On this side of the mountains.","pos":""}],"CISPADANE":[{"def":"On the hither side of the river Po with reference to Rome; that is, on the south side.","pos":""}],"CISSOID":[{"def":"A curve invented by Diocles, for the purpose of solving two celebrated problems of the higher geometry; viz.","pos":""}],"CISTED":[{"def":"Inclosed in a cyst.","pos":""}],"CISTERCIAN":[{"def":"A monk of the prolific branch of the Benedictine Order, established in 1098 at Cîteaux, in France, by Robert, abbot of Molesme.","pos":""},{"def":"Of or pertaining to the Cistercians.","pos":""}],"CISTERN":[{"def":"An artificial reservoir or tank for holding water, beer, or other liquids.","pos":""},{"def":"A natural reservoir; a hollow place containing water.","pos":""}]}