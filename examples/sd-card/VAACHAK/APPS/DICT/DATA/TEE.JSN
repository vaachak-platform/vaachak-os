{"TEE":[{"def":"A short piece of pipe having a lateral outlet, used to connect a line of pipe with a pipe at a right angle with the line; -- so called because it resembles the letter T in shape.","pos":""}],"TEE IRON":[{"def":"See T iron, under T.","pos":""}],"TEE-TO-TUM":[{"def":"A workingmen's resort conducted under religious influences as a counteractant to the drinking saloon.","pos":""}],"TEEING GROUND":[{"def":"The space from within which the ball must be struck in beginning the play for each hole.","pos":""}],"TEELSEED":[{"def":"The seed of sesame.","pos":""}],"TEEM":[{"def":"To pour, as steel, from a melting pot; to fill, as a mold, with molten metal.","pos":""}],"TEEMER":[{"def":"One who teems, or brings forth.","pos":""}],"TEEMFUL":[{"def":"Pregnant; prolific.","pos":""}],"TEEMING":[{"def":"Prolific; productive.","pos":""}],"TEEMLESS":[{"def":"Not fruitful or prolific; barren; as, a teemless earth.","pos":""}],"TEEN":[{"def":"Grief; sorrow; affiction; pain.","pos":""}],"TEENAGE":[{"def":"The longer wood for making or mending fences.","pos":""}],"TEEND":[{"def":"To kindle; to burn.","pos":""}],"TEENFUL":[{"def":"Full of teen; harmful; grievous; grieving; afflicted.","pos":""}],"TEENS":[{"def":"The years of one's age having the termination -teen, beginning with thirteen and ending with nineteen; as, a girl in her teens.","pos":""}],"TEENY":[{"def":"Very small; tiny.","pos":""}],"TEEST":[{"def":"A tinsmith's stake, or small anvil.","pos":""}],"TEESWATER":[{"def":"A breed of cattle formerly bred in England, but supposed to have originated in Holland and to have been the principal stock from which the shorthorns were derived.","pos":""},{"def":"An old English breed of sheep allied to the Leicester.","pos":""}],"TEETEE":[{"def":"Any one of several species of small, soft-furred South American monkeys belonging to Callithrix, Chrysothrix, and allied genera; as, the collared teetee (Callithrix torquatus), and the squirrel teetee (Chrysothrix sciurea).","pos":""},{"def":"A diving petrel of Australia (Halodroma wrinatrix).","pos":""}],"TEETER":[{"def":"To move up and down on the ends of a balanced plank, or the like, as children do for sport; to seesaw; to titter; to titter- totter.","pos":""}],"TEETER-TAIL":[{"def":"The spotted sandpiper.","pos":""}],"TEETH":[{"def":"To breed, or grow, teeth.","pos":""}],"TEETHING":[{"def":"The process of the first growth of teeth, or the phenomena attending their issue through the gums; dentition.","pos":""}],"TEETOTALER":[{"def":"One pledged to entire abstinence from all intoxicating drinks.","pos":""}],"TEETOTALISM":[{"def":"The principle or practice of entire abstinence, esp.","pos":""}],"TEETOTALLY":[{"def":"Entirely; totally.","pos":""}],"TEETOTUM":[{"def":"A child's toy, somewhat resembling a top, and twirled by the fingers.","pos":""}]}