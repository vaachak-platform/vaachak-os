{"DISJECTION":[{"def":"Destruction; dispersion.","pos":""}],"DISJOIN":[{"def":"To part; to disunite; to separate; to sunder.","pos":""}],"DISJOINT":[{"def":"Disjointed; unconnected; -- opposed to conjoint.","pos":""}],"DISJOINTED":[{"def":"Separated at the joints; disconnected; incoherent.","pos":""}],"DISJOINTLY":[{"def":"In a disjointed state.","pos":""}],"DISJUDICATION":[{"def":"Judgment; discrimination.","pos":""}],"DISJUNCT":[{"def":"Having the head, thorax, and abdomen separated by a deep constriction.","pos":""}],"DISJUNCTION":[{"def":"The act of disjoining; disunion; separation; a parting; as, the disjunction of soul and body.","pos":""},{"def":"A disjunctive proposition.","pos":""}],"DISJUNCTIVE":[{"def":"Pertaining to disjunct tetrachords.","pos":""}],"DISJUNCTIVELY":[{"def":"In a disjunctive manner; separately.","pos":""}],"DISJUNCTURE":[{"def":"The act of disjoining, or state of being disjoined; separation.","pos":""}]}