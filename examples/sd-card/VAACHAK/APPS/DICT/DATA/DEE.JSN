{"DEED":[{"def":"A sealed instrument in writing, on paper or parchment, duly executed and delivered, containing some transfer, bargain, or contract.","pos":""}],"DEED POLL":[{"def":"A deed of one part, or executed by only one party, and distinguished from an indenture by having the edge of the parchment or paper cut even, or polled as it was anciently termed, instead of being indented.","pos":""}],"DEEDFUL":[{"def":"Full of deeds or exploits; active; stirring.","pos":""}],"DEEDLESS":[{"def":"Not performing, or not having performed, deeds or exploits; inactive.","pos":""}],"DEEDY":[{"def":"Industrious; active.","pos":""}],"DEEM":[{"def":"To decide; to judge; to sentence; to condemn.","pos":""},{"def":"To account; to esteem; to think; to judge; to hold in opinion; to regard.","pos":""}],"DEEMSTER":[{"def":"A judge in the Isle of Man who decides controversies without process.","pos":""}],"DEEP":[{"def":"Extending far below the surface; of great perpendicular dimension (measured from the surface downward, and distinguished from high, which is measured upward); far to the bottom; having a certain depth; as, a deep sea.","pos":""},{"def":"Extending far back from the front or outer part; of great horizontal dimension (measured backward from the front or nearer part, mouth, etc.","pos":""}],"DEEP-FET":[{"def":"Deeply fetched or drawn.","pos":""}],"DEEP-LAID":[{"def":"Laid deeply; formed with cunning and sagacity; as, deep-laid plans.","pos":""}],"DEEP-MOUTHED":[{"def":"Having a loud and sonorous voice.","pos":""}],"DEEP-READ":[{"def":"Profoundly book-learned.","pos":""}],"DEEP-SEA":[{"def":"Of or pertaining to the deeper parts of the sea; as, a deep-sea line (i.","pos":""}],"DEEP-WAISTED":[{"def":"Having a deep waist, as when, in a ship, the poop and forecastle are much elevated above the deck.","pos":""}],"DEEPEN":[{"def":"To make deep or deeper; to increase the depth of; to sink lower; as, to deepen a well or a channel.","pos":""},{"def":"To make darker or more intense; to darken; as, the event deepened the prevailing gloom.","pos":""}],"DEEPLY":[{"def":"At or to a great depth; far below the surface; as, to sink deeply.","pos":""},{"def":"Profoundly; thoroughly; not superficially; in a high degree; intensely; as, deeply skilled in ethics.","pos":""}],"DEEPNESS":[{"def":"The state or quality of being deep, profound, mysterious, secretive, etc.","pos":""},{"def":"Craft; insidiousness.","pos":""}],"DEER":[{"def":"A ruminant of the genus Cervus, of many species, and of related genera of the family Cervidæ.","pos":""}],"DEER'S-TONGUE":[{"def":"A plant (Liatris odoratissima) whose fleshy leaves give out a fragrance compared to vanilla.","pos":""}],"DEER-NECK":[{"def":"A deerlike, or thin, ill-formed neck, as of a horse.","pos":""}],"DEERBERRY":[{"def":"A shrub of the blueberry group (Vaccinium stamineum); also, its bitter, greenish white berry; -- called also squaw huckleberry.","pos":""}],"DEERGRASS":[{"def":"An American genus (Rhexia) of perennial herbs, with opposite leaves, and showy flowers (usually bright purple), with four petals and eight stamens, -- the only genus of the order Melastomaceæ inhabiting a temperate clime.","pos":""}],"DEERHOUND":[{"def":"One of a large and fleet breed of hounds used in hunting deer; a staghound.","pos":""}],"DEERSKIN":[{"def":"The skin of a deer, or the leather which is made from it.","pos":""}],"DEERSTALKER":[{"def":"One who practices deerstalking.","pos":""}],"DEERSTALKING":[{"def":"The hunting of deer on foot, by stealing upon them unawares.","pos":""}],"DEESIS":[{"def":"An invocation of, or address to, the Supreme Being.","pos":""}]}