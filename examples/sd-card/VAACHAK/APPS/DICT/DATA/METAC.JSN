{"METACARPAL":[{"def":"Of or pertaining to the metacarpus.","pos":""},{"def":"A metacarpal bone.","pos":""}],"METACARPUS":[{"def":"That part of the skeleton of the hand or forefoot between the carpus and phalanges.","pos":""},{"def":"The point of intersection of a vertical line through the center of gravity of the fluid displaced by a floating body which is tipped through a small angle from its position of equilibrium, and the inclined line which was vertical through the center of gravity of the body when in equilibrium.","pos":""}],"METACETONE":[{"def":"A colorless liquid of an agreeable odor, C6H10O, obtained by distilling a mixture of sugar and lime; -- so called because formerly regarded as a polymeric modification of acetone.","pos":""}],"METACHLORAL":[{"def":"A white, amorphous, insoluble substance regarded as a polymeric variety of chloral.","pos":""}],"METACHRONISM":[{"def":"An error committed in chronology by placing an event after its real time.","pos":""}],"METACHROSIS":[{"def":"The power og changing color at will by the expansion of special pigment cells, under nerve influence, as seen in many reptiles, fishes, etc.","pos":""}],"METACINNABARITE":[{"def":"Sulphide of mercury in isometric form and black in color.","pos":""}],"METACISM":[{"def":"A defect in pronouncing the letter m, or a too frequent use of it.","pos":""}],"METACROLEIN":[{"def":"A polymeric modification of acrolein obtained by heating it with caustic potash.","pos":""}],"METACROMION":[{"def":"A process projecting backward and downward from the acromion of the scapula of some mammals.","pos":""}]}