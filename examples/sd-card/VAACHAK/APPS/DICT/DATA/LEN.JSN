{"LENARD RAYS":[{"def":"Rays emanating from the outer surface of a plate composed of any material permeable by cathode rays, as aluminium, which forms a portion of a wall of a vacuum tube, or which is mounted within the tube and exposed to radiation from the cathode.","pos":""}],"LENARD TUBE":[{"def":"A tube for producing Lenard rays.","pos":""}],"LEND":[{"def":"To allow the custody and use of, on condition of the return of the same; to grant the temporary use of; as, to lend a book; -- opposed to borrow.","pos":""},{"def":"To allow the possession and use of, on condition of the return of an equivalent in kind; as, to lend money or some article of food.","pos":""}],"LENDABLE":[{"def":"Such as can be lent.","pos":""}],"LENDER":[{"def":"The borrower is servant to the lender.","pos":""}],"LENDING":[{"def":"The act of one who lends.","pos":""},{"def":"That which is lent or furnished.","pos":""}],"LENE":[{"def":"To lend; to grant; to permit.","pos":""}],"LENGTH":[{"def":"The longest, or longer, dimension of any object, in distinction from breadth or width; extent of anything from end to end; the longest line which can be drawn through a body, parallel to its sides; as, the length of a church, or of a ship; the length of a rope or line.","pos":""},{"def":"A portion of space or of time considered as measured by its length; -- often in the plural.","pos":""}],"LENGTHEN":[{"def":"To extent in length; to make longer in extent or duration; as, to lengthen a line or a road; to lengthen life; -- sometimes followed by out.","pos":""}],"LENGTHILY":[{"def":"In a lengthy manner; at great length or extent.","pos":""}],"LENGTHINESS":[{"def":"The state or quality of being lengthy; prolixity.","pos":""},{"def":"In the direction of the length; in a longitudinal direction.","pos":""}],"LENGTHY":[{"def":"Having length; rather long or too long; prolix; not brief; -- said chiefly of discourses, writings, and the like.","pos":""},{"def":"The quality or state of being lenient; lenity; clemency.","pos":""}],"LENIENT":[{"def":"Relaxing; emollient; softening; assuasive; -- some \"Lenient of grief.","pos":""},{"def":"Mild; clement; merciful; not rigorous or severe; as, a lenient disposition; a lenient judge or sentence.","pos":""}],"LENIENTLY":[{"def":"In a lenient manner.","pos":""}],"LENIFY":[{"def":"To assuage; to soften; to Bacon.","pos":""}],"LENITIVE":[{"def":"Having the quality of softening or mitigating, as pain or acrimony; assuasive; emollient.","pos":""}],"LENITIVENESS":[{"def":"The quality of being lenitive.","pos":""}],"LENITUDE":[{"def":"The quality or habit of being lenient; lenity.","pos":""}],"LENITY":[{"def":"The state or quality of being lenient; mildness of temper or disposition; gentleness of treatment; softness; tenderness; clemency; -- opposed to severity and rigor.","pos":""}],"LENNI-LENAPE":[{"def":"A general name for a group of Algonquin tribes which formerly occupied the coast region of North America from Connecticut to Virginia.","pos":""}],"LENO":[{"def":"A light open cotton fabric used for window curtains.","pos":""}],"LENOCINANT":[{"def":"Given to lewdness.","pos":""}],"LENS":[{"def":"Note: Of spherical lenses, there are six varieties, as shown in section in the figures herewith given: viz.","pos":""}],"LENT":[{"def":"A fast of forty days, beginning with Ash Wednesday and continuing till Easter, observed by some Christian churches as commemorative of the fast of our Savior.","pos":""}],"LENT LILY":[{"def":"the daffodil; -- so named from its blossoming in spring.","pos":""}],"LENTAMENTE":[{"def":"Slowly; in slow time.","pos":""}],"LENTANDO":[{"def":"Slackening; retarding.","pos":""}],"LENTEN":[{"def":"Of or pertaining to the fast called Lent; used in, or suitable to, Lent; as, the Lenten season.","pos":""},{"def":"Spare, meager; plain; somber; unostentatious; not abundant or showy.","pos":""}],"LENTENTIDE":[{"def":"The season of Lenten or Lent.","pos":""}],"LENTICELLATE":[{"def":"Producing lenticels; dotted with lenticels.","pos":""}],"LENTICULA":[{"def":"A kind of eruption upon the skin; lentigo; freckle.","pos":""},{"def":"A lens of small size.","pos":""}],"LENTICULAR":[{"def":"Resembling a lentil in size or form; having the form of a double-convex lens.","pos":""}],"LENTICULARLY":[{"def":"In the manner of a lens; with a curve.","pos":""}],"LENTIGINOSE":[{"def":"Bearing numerous dots resembling freckles.","pos":""}],"LENTIGINOUS":[{"def":"Of or pertaining to lentigo; freckly; scurfy; furfuraceous.","pos":""}],"LENTIGO":[{"def":"A freckly eruption on the skin; freckles.","pos":""}],"LENTIL":[{"def":"A leguminous plant of the genus Ervum (Ervum Lens), of small size, common in the fields in Europe.","pos":""},{"def":"A tree; the mastic.","pos":""}],"LENTITUDE":[{"def":"Slowness; sluggishness.","pos":""}],"LENTO":[{"def":"Slow; in slow time; slowly; -- rarely written lente.","pos":""}],"LENTOID":[{"def":"Having the form of a lens; lens-shaped.","pos":""}],"LENTOR":[{"def":"Tenacity; viscidity; viscidity, as of fluids.","pos":""},{"def":"Slowness; delay; sluggishness.","pos":""}],"LENTOUS":[{"def":"Viscid; viscous; tenacious.","pos":""}]}