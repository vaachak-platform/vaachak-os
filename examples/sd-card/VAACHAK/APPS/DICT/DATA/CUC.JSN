{"CUCKOLD":[{"def":"A man whose wife is unfaithful; the husband of an adulteress.","pos":""}],"CUCKOLD'S KNOT":[{"def":"A hitch or knot, by which a rope is secured to a spar, the two parts of the rope being crossed and seized together; -- called also cuckold's neck.","pos":""}],"CUCKOLDLY":[{"def":"Having the qualities of a cuckold; mean-spirited; sneaking.","pos":""}],"CUCKOLDOM":[{"def":"The state of a cuckold; cuckolds, collectively.","pos":""}],"CUCKOLDRY":[{"def":"The state of being a cuckold; the practice of making cuckolds.","pos":""}],"CUCKOO":[{"def":"A bird belonging to Cuculus, Coccyzus, and several allied genera, of many species.","pos":""}],"CUCKOOBUD":[{"def":"A species of Ranunculus (R.","pos":""}],"CUCKOOFLOWER":[{"def":"A species of Cardamine (C.","pos":""}],"CUCKOOPINT":[{"def":"A plant of the genus Arum (A.","pos":""}],"CUCQUEAN":[{"def":"A woman whose husband is unfaithful to her.","pos":""}],"CUCUJO":[{"def":"The fire beetle of Mexico and the West Indies.","pos":""},{"def":"Having the edges toward the base rolled inward, as the leaf of the commonest American blue violet.","pos":""}],"CUCULLUS":[{"def":"A hood-shaped organ, resembling a cowl or monk's hood, as certain concave and arched sepals or petals.","pos":""}],"CUCULOID":[{"def":"Like or belonging to the cuckoos (Cuculidæ).","pos":""}],"CUCUMBER":[{"def":"A creeping plant, and its fruit, of several species of the genus Cucumis, esp.","pos":"noun"}],"CUCUMIFORM":[{"def":"Having the form of a cucumber; having the form of a cylinder tapered and rounded at the ends, and either straight or curved.","pos":""}],"CUCUMIS":[{"def":"A genus of plants including the cucumber, melon, and same kinds of gourds.","pos":""},{"def":"A vessel of flask for distillation, used with, or forming part of, an alembic; a matrass; -- originally in the shape of a gourd, with a wide mouth.","pos":""}],"CUCURBITACEOUS":[{"def":"Of, pertaining to, or resembling, a family of plants of which the cucumber, melon, and gourd are common examples.","pos":""}],"CUCURBITIVE":[{"def":"Having the shape of a gourd seed; -- said of certain small worms.","pos":""}]}