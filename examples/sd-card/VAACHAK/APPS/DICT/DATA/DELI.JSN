{"DELIBATE":[{"def":"To taste; to take a sip of; to dabble in.","pos":""}],"DELIBATION":[{"def":"Act of tasting; a slight trial.","pos":""}],"DELIBERATE":[{"def":"Weighing facts and arguments with a view a choice or decision; carefully considering the probable consequences of a step; circumspect; slow in determining; -- applied to persons; as, a deliberate judge or counselor.","pos":""},{"def":"Formed with deliberation; well-advised; carefully considered; not sudden or rash; as, a deliberate opinion; a deliberate measure or result.","pos":""}],"DELIBERATELY":[{"def":"With careful consideration, or deliberation; circumspectly; warily; not hastily or rashly; slowly; as, a purpose deliberately formed.","pos":""}],"DELIBERATENESS":[{"def":"The quality of being deliberate; calm consideration; circumspection.","pos":""}],"DELIBERATION":[{"def":"The act of deliberating, or of weighing and examining the reasons for and against a choice or measure; careful consideration; mature reflection.","pos":""},{"def":"Careful discussion and examination of the reasons for and against a measure; as, the deliberations of a legislative body or council.","pos":""}],"DELIBERATIVE":[{"def":"Pertaining to deliberation; proceeding or acting by deliberation, or by discussion and examination; deliberating; as, a deliberative body.","pos":""}],"DELIBERATIVELY":[{"def":"In a deliberative manner; circumspectly; considerately.","pos":""}],"DELIBERATOR":[{"def":"One who deliberates.","pos":""}],"DELIBRATE":[{"def":"To strip off the bark; to peel.","pos":""}],"DELIBRATION":[{"def":"The act of stripping off the bark.","pos":""}],"DELICACY":[{"def":"The state or condition of being delicate; agreeableness to the senses; delightfulness; as, delicacy of flavor, of odor, and the like.","pos":""},{"def":"Nicety or fineness of form, texture, or constitution; softness; elegance; smoothness; tenderness; and hence, frailty or weakness; as, the delicacy of a fiber or a thread; delicacy of a hand or of the human form; delicacy of the skin; delicacy of frame.","pos":""}],"DELICATE":[{"def":"Addicted to pleasure; luxurious; voluptuous; alluring.","pos":""},{"def":"Pleasing to the senses; refinedly; hence, adapted to please a nice or cultivated taste; nice; fine; elegant; as, a delicate dish; delicate flavor.","pos":""}],"DELICATELY":[{"def":"In a delicate manner.","pos":""}],"DELICATENESS":[{"def":"The quality of being delicate.","pos":""}],"DELICATESSEN":[{"def":"Relishes for the table; dainties; delicacies.","pos":""}],"DELICES":[{"def":"Delicacies; delights.","pos":""}],"DELICIATE":[{"def":"To delight one's self; to indulge in feasting; to revel.","pos":""}],"DELICIOUS":[{"def":"Affording exquisite pleasure; delightful; most sweet or grateful to the senses, especially to the taste; charming.","pos":""},{"def":"Addicted to pleasure; seeking enjoyment; luxurious; effeminate.","pos":""}],"DELICIOUSLY":[{"def":"Delightfully; as, to feed deliciously; to be deliciously entertained.","pos":""}],"DELICIOUSNESS":[{"def":"The quality of being delicious; as, the deliciousness of a repast.","pos":""}],"DELICT":[{"def":"An offense or transgression against law; (Scots Law) an offense of a lesser degree; a misdemeanor.","pos":""}],"DELIGATE":[{"def":"To bind up; to bandage.","pos":""}],"DELIGATION":[{"def":"A binding up; a bandaging.","pos":""}],"DELIGHT":[{"def":"A high degree of gratification of mind; a high-wrought state of pleasurable feeling; lively pleasure; extreme satisfaction; joy.","pos":""},{"def":"That which gives great pleasure or delight.","pos":""}],"DELIGHTABLE":[{"def":"Capable of delighting; delightful.","pos":""}],"DELIGHTED":[{"def":"Endowed with delight.","pos":""}],"DELIGHTEDLY":[{"def":"With delight; gladly.","pos":""}],"DELIGHTER":[{"def":"One who gives or takes delight.","pos":""}],"DELIGHTFUL":[{"def":"Highly pleasing; affording great pleasure and satisfaction.","pos":""}],"DELIGHTING":[{"def":"Giving delight; gladdening.","pos":""}],"DELIGHTLESS":[{"def":"Void of delight.","pos":""}],"DELIGHTSOME":[{"def":"Very pleasing; delightful.","pos":""}],"DELIGNATE":[{"def":"To clear or strip of wood (by cutting down trees).","pos":""}],"DELILAH":[{"def":"The mistress of Samson, who betrayed him (Judges xvi.","pos":""}],"DELIMIT":[{"def":"To fix the limits of; to demarcate; to bound.","pos":""}],"DELIMITATION":[{"def":"The act or process of fixing limits or boundaries; limitation.","pos":""}],"DELINEABLE":[{"def":"Capable of being, or liable to be, delineated.","pos":""}],"DELINEAMENT":[{"def":"Delineation; sketch.","pos":""}],"DELINEATE":[{"def":"Delineated; portrayed.","pos":""}],"DELINEATION":[{"def":"The act of representing, portraying, or describing, as by lines, diagrams, sketches, etc.","pos":""},{"def":"A delineated picture; representation; sketch; description in words.","pos":""}],"DELINEATOR":[{"def":"A perambulator which records distances and delineates a profile, as of a road.","pos":""}],"DELINEATORY":[{"def":"That delineates; descriptive; drawing the outline; delineating.","pos":""}],"DELINQUENCY":[{"def":"Failure or omission of duty; a fault; a misdeed; an offense; a misdemeanor; a crime.","pos":""}],"DELINQUENT":[{"def":"Failing in duty; offending by neglect of duty.","pos":""}],"DELINQUENTLY":[{"def":"So as to fail in duty.","pos":""}],"DELIQUATE":[{"def":"To melt or be dissolved; to deliquesce.","pos":""}],"DELIQUESCE":[{"def":"To dissolve gradually and become liquid by attracting and absorbing moisture from the air, as certain salts, acids, and alkalies.","pos":""}],"DELIQUESCENCE":[{"def":"The act of deliquescing or liquefying; process by which anything deliquesces; tendency to melt.","pos":""}],"DELIQUESCENT":[{"def":"Branching so that the stem is lost in branches, as in most deciduous trees.","pos":""}],"DELIQUIATE":[{"def":"To melt and become liquid by absorbing water from the air; to deliquesce.","pos":""}],"DELIQUIATION":[{"def":"The act of deliquating.","pos":""}],"DELIQUIUM":[{"def":"A melting or dissolution in the air, or in a moist place; a liquid condition; as, a salt falls into a deliquium.","pos":""}],"DELIRAMENT":[{"def":"A wandering of the mind; a crazy fancy.","pos":""}],"DELIRATE":[{"def":"To madden; to rave.","pos":""}],"DELIRATION":[{"def":"Aberration of mind; delirium.","pos":""}],"DELIRIANT":[{"def":"A poison which occasions a persistent delirium, or mental aberration (as belladonna).","pos":""}],"DELIRIFACIENT":[{"def":"Producing, or tending to produce, delirium.","pos":""},{"def":"Any substance which tends to cause delirium.","pos":""}],"DELIRIOUS":[{"def":"Having a delirium; wandering in mind; light-headed; insane; raving; wild; as, a delirious patient; delirious fancies.","pos":""}],"DELIRIUM":[{"def":"A state in which the thoughts, expressions, and actions are wild, irregular, and incoherent; mental aberration; a roving or wandering of the mind, -- usually dependent on a fever or some other disease, and so distinguished from mania, or madness.","pos":""}],"DELITABLE":[{"def":"Delightful; delectable.","pos":""}],"DELITESCENCE":[{"def":"The sudden disappearance of inflammation.","pos":""}],"DELITESCENCY":[{"def":"Concealment; seclusion.","pos":""}],"DELITESCENT":[{"def":"Lying hid; concealed.","pos":""}],"DELITIGATE":[{"def":"To chide; to rail heartily.","pos":""}],"DELIVER":[{"def":"To set free from restraint; to set at liberty; to release; to liberate, as from control; to give up; to free; to save; to rescue from evil actual or feared; -- often with from or out of; as, to deliver one from captivity, or from fear of death.","pos":""},{"def":"To give or transfer; to yield possession or control of; to part with (to); to make over; to commit; to surrender; to resign; -- often with up or over, to or into.","pos":""}],"DELIVERABLE":[{"def":"Capable of being, or about to be, delivered; necessary to be delivered.","pos":""}],"DELIVERANCE":[{"def":"Any fact or truth which is decisively attested or intuitively known as a psychological or philosophical datum; as, the deliverance of consciousness.","pos":""}],"DELIVERER":[{"def":"One who delivers or rescues; a preserver.","pos":""},{"def":"One who relates or communicates.","pos":""}],"DELIVERLY":[{"def":"Actively; quickly; nimbly.","pos":""}],"DELIVERNESS":[{"def":"Nimbleness; agility.","pos":""}],"DELIVERY":[{"def":"The act of delivering from restraint; rescue; release; liberation; as, the delivery of a captive from his dungeon.","pos":""},{"def":"The act of delivering up or over; surrender; transfer of the body or substance of a thing; distribution; as, the delivery of a fort, of hostages, of a criminal, of goods, of letters.","pos":""}]}