{"BIT":[{"def":"The part of a bridle, usually of iron, which is inserted in the mouth of a horse, and having appendages to which the reins are fastened.","pos":""}],"BITAKE":[{"def":"To commend; to commit.","pos":""}],"BITANGENT":[{"def":"Possessing the property of touching at two points.","pos":""},{"def":"A line that touches a curve in two points.","pos":""}],"BITARTRATE":[{"def":"A salt of tartaric acid in which the base replaces but half the acid hydrogen; an acid tartrate, as cream of tartar.","pos":""}],"BITCH":[{"def":"The female of the canine kind, as of the dog, wolf, and fox.","pos":""},{"def":"An opprobrious name for a woman, especially a lewd woman.","pos":""}],"BITE":[{"def":"To seize with the teeth, so that they enter or nip the thing seized; to lacerate, crush, or wound with the teeth; as, to bite an apple; to bite a crust; the dog bit a man.","pos":""},{"def":"To puncture, abrade, or sting with an organ (of some insects) used in taking food.","pos":""}],"BITER":[{"def":"One who, or that which, bites; that which bites often, or is inclined to bite, as a dog or fish.","pos":""},{"def":"One who cheats; a sharper.","pos":""}],"BITERNATE":[{"def":"Doubly ternate, as when a petiole has three ternate leaflets.","pos":""}],"BITHEISM":[{"def":"Belief in the existence of two gods; dualism.","pos":""}],"BITING":[{"def":"That bites; sharp; cutting; sarcastic; caustic.","pos":""}],"BITING IN":[{"def":"The process of corroding or eating into metallic plates, by means of an acid.","pos":""}],"BITINGLY":[{"def":"In a biting manner.","pos":""}],"BITLESS":[{"def":"Not having a bit or bridle.","pos":""},{"def":"A small scrubby tree (Balanites Ægyptiaca) growing in dry regions of tropical Africa and Asia.","pos":""}],"BITSTOCK":[{"def":"A stock or handle for holding and rotating a bit; a brace.","pos":""}],"BITT":[{"def":"To put round the bitts; as, to bitt the cable, in order to fasten it or to slacken it gradually, which is called veering away.","pos":""}],"BITTEN":[{"def":"Terminating abruptly, as if bitten off; premorse.","pos":""}],"BITTER":[{"def":"AA turn of the cable which is round the bitts.","pos":""}],"BITTER SPAR":[{"def":"A common name of dolomite; -- so called because it contains magnesia, the soluble salts of which are bitter.","pos":""}],"BITTERBUMP":[{"def":"the butterbump or bittern.","pos":""}],"BITTERFUL":[{"def":"Full of bitterness.","pos":""}],"BITTERING":[{"def":"A bitter compound used in adulterating beer; bittern.","pos":""}],"BITTERISH":[{"def":"Somewhat bitter.","pos":""}],"BITTERLING":[{"def":"A roachlike European fish (Rhodima amarus).","pos":""}],"BITTERLY":[{"def":"In a bitter manner.","pos":""}],"BITTERN":[{"def":"A wading bird of the genus Botaurus, allied to the herons, of various species.","pos":""}],"BITTERNESS":[{"def":"The quality or state of being bitter, sharp, or acrid, in either a literal or figurative sense; implacableness; resentfulness; severity; keenness of reproach or sarcasm; deep distress, grief, or vexation of mind.","pos":""},{"def":"A state of extreme impiety or enmity to God.","pos":""}],"BITTERNUT":[{"def":"The swamp hickory (Carya amara).","pos":""}],"BITTERROOT":[{"def":"A plant (Lewisia rediviva) allied to the purslane, but with fleshy, farinaceous roots, growing in the mountains of Idaho, Montana, etc.","pos":""}],"BITTERS":[{"def":"A liquor, generally spirituous in which a bitter herb, leaf, or root is steeped.","pos":""}],"BITTERSWEET":[{"def":"Sweet and then bitter or bitter and then sweet; esp.","pos":""}],"BITTERWEED":[{"def":"A species of Ambrosia (A.","pos":""}],"BITTERWOOD":[{"def":"A West Indian tree (Picræna excelsa) from the wood of which the bitter drug Jamaica quassia is obtained.","pos":""}],"BITTERWORT":[{"def":"The yellow gentian (Gentiana lutea), which has a very bitter taste.","pos":""}],"BITTOCK":[{"def":"A small bit of anything, of indefinite size or quantity; a short distance.","pos":""}],"BITTS":[{"def":"A frame of two strong timbers fixed perpendicularly in the fore part of a ship, on which to fasten the cables as the ship rides at anchor, or in warping.","pos":""}],"BITUMED":[{"def":"Smeared with bitumen.","pos":""}],"BITUMEN":[{"def":"Mineral pitch; a black, tarry substance, burning with a bright flame; Jew's pitch.","pos":""},{"def":"By extension, any one of the natural hydrocarbons, including the hard, solid, brittle varieties called asphalt, the semisolid maltha and mineral tars, the oily petroleums, and even the light, volatile naphthas.","pos":""}],"BITUMEN PROCESS":[{"def":"Any process in which advantage is taken of the fact that prepared bitumen is rendered insoluble by exposure to light, as in photolithography.","pos":""}],"BITUMINATE":[{"def":"To treat or impregnate with bitumen; to cement with bitumen.","pos":""}],"BITUMINIFEROUS":[{"def":"Producing bitumen.","pos":""}],"BITUMINIZATION":[{"def":"The process of bituminizing.","pos":""}],"BITUMINIZE":[{"def":"To prepare, treat, impregnate, or coat with bitumen.","pos":""}],"BITUMINOUS":[{"def":"Having the qualities of bitumen; compounded with bitumen; containing bitumen.","pos":""}]}