{"BIN":[{"def":"A box, frame, crib, or inclosed place, used as a receptacle for any commodity; as, a corn bin; a wine bin; a coal bin.","pos":""}],"BINAL":[{"def":"Twofold; double.","pos":""}],"BINARSENIATE":[{"def":"A salt having two equivalents of arsenic acid to one of the base.","pos":""}],"BINARY":[{"def":"Compounded or consisting of two things or parts; characterized by two (things).","pos":""}],"BINATE":[{"def":"Double; growing in pairs or couples.","pos":""}],"BINAURAL":[{"def":"Of or pertaining to, or used by, both ears.","pos":""}],"BINBASHI":[{"def":"A major in the Turkish army.","pos":""}],"BIND":[{"def":"To tie, or confine with a cord, band, ligature, chain, etc.","pos":""},{"def":"To confine, restrain, or hold by physical force or influence of any kind; as, attraction binds the planets to the sun; frost binds the earth, or the streams.","pos":""}],"BINDER":[{"def":"One who binds; as, a binder of sheaves; one whose trade is to bind; as, a binder of books.","pos":""},{"def":"Anything that binds, as a fillet, cord, rope, or band; a bandage; -- esp.","pos":""}],"BINDERY":[{"def":"A place where books, or other articles, are bound; a bookbinder's establishment.","pos":""}],"BINDHEIMITE":[{"def":"An amorphous antimonate of lead, produced from the alteration of other ores, as from jamesonite.","pos":""}],"BINDING":[{"def":"That binds; obligatory.","pos":""}],"BINDING POST":[{"def":"A metallic post attached to electrical apparatus for convenience in making connections.","pos":""}],"BINDING SCREW":[{"def":"A set screw used to bind parts together, esp.","pos":""}],"BINDINGNESS":[{"def":"The condition or property of being binding; obligatory quality.","pos":""}],"BINDWEED":[{"def":"A plant of the genus Convolvulus; as, greater bindweed (C.","pos":""}],"BINE":[{"def":"The winding or twining stem of a hop vine or other climbing plant.","pos":""}],"BINERVATE":[{"def":"Two-nerved; -- applied to leaves which have two longitudinal ribs or nerves.","pos":""},{"def":"Having only two nerves, as the wings of some insects.","pos":""}],"BING":[{"def":"A heap or pile; as, a bing of wood.","pos":""}],"BINIODIDE":[{"def":"Same as Diiodide.","pos":""}],"BINNACLE":[{"def":"A case or box placed near the helmsman, containing the compass of a ship, and a light to show it at night.","pos":""}],"BINNY":[{"def":"A large species of barbel (Barbus bynni), found in the Nile, and much esteemed for food.","pos":""}],"BINOCLE":[{"def":"A dioptric telescope, fitted with two tubes joining, so as to enable a person to view an object with both eyes at once; a double- barreled field glass or an opera glass.","pos":""}],"BINOCULAR":[{"def":"Having two eyes.","pos":""},{"def":"Pertaining to both eyes; employing both eyes at once; as, binocular vision.","pos":""}],"BINOCULARLY":[{"def":"In a binocular manner.","pos":""}],"BINOCULATE":[{"def":"Having two eyes.","pos":""}],"BINOMIAL":[{"def":"An expression consisting of two terms connected by the sign plus (+) or minus (-); as, a+b, or 7-3.","pos":""}],"BINOMINAL":[{"def":"Of or pertaining to two names; binomial.","pos":""}],"BINOTONOUS":[{"def":"Consisting of two notes; as, a binotonous cry.","pos":""}],"BINOXALATE":[{"def":"A salt having two equivalents of oxalic acid to one of the base; an acid oxalate.","pos":""}],"BINOXIDE":[{"def":"Same as Dioxide.","pos":""}],"BINTURONG":[{"def":"A small Asiatic civet of the genus Arctilis.","pos":""},{"def":"Having two nuclei; as, binucleate cells.","pos":""}],"BINUCLEOLATE":[{"def":"Having two nucleoli.","pos":""}]}