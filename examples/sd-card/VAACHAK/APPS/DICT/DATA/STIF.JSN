{"STIFF":[{"def":"Bearing a press of canvas without careening much; as, a stiff vessel; -- opposed to crank.","pos":""}],"STIFF-HEARTED":[{"def":"Obstinate; stubborn; contumacious.","pos":""}],"STIFF-NECKED":[{"def":"Stubborn; inflexibly obstinate; contumacious; as, stiff-necked pride; a stiff-necked people.","pos":""}],"STIFF-NECKEDNESS":[{"def":"The quality or state of being stiff-necked; stubbornness.","pos":""}],"STIFF-TAILED":[{"def":"Having the quill feathers of the tail somewhat rigid.","pos":""}],"STIFFEN":[{"def":"To inspissate; to make more thick or viscous; as, to stiffen paste.","pos":""},{"def":"To make torpid; to benumb.","pos":""}],"STIFFENER":[{"def":"One who, or that which, stiffens anything, as a piece of stiff cloth in a cravat.","pos":""}],"STIFFENING":[{"def":"Act or process of making stiff.","pos":""},{"def":"Something used to make anything stiff.","pos":""}],"STIFFLY":[{"def":"In a stiff manner.","pos":""}],"STIFFNESS":[{"def":"The quality or state of being stiff; as, the stiffness of cloth or of paste; stiffness of manner; stiffness of character.","pos":""}],"STIFLE":[{"def":"The joint next above the hock, and near the flank, in the hind leg of the horse and allied animals; the joint corresponding to the knee in man; -- called also stifle joint.","pos":""}],"STIFLED":[{"def":"The close and stifled study.","pos":""}],"STIFLER":[{"def":"One who, or that which, stifles.","pos":""}]}