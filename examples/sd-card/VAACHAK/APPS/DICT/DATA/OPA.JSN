{"OPACATE":[{"def":"To darken; to cloud.","pos":""}],"OPACITY":[{"def":"The state of being opaque; the quality of a body which renders it impervious to the rays of light; want of transparency; opaqueness.","pos":""},{"def":"Obscurity; want of clearness.","pos":""}],"OPAH":[{"def":"A large oceanic fish (Lampris quttatus), inhabiting the Atlantic Ocean.","pos":""}],"OPAL":[{"def":"A mineral consisting, like quartz, of silica, but inferior to quartz in hardness and specific gravity.","pos":""}],"OPALESCE":[{"def":"To give forth a play of colors, like the opal.","pos":""}],"OPALESCENCE":[{"def":"A reflection of a milky or pearly light from the interior of a mineral, as in the moonstone; the state or quality of being opalescent.","pos":""}],"OPALESCENT":[{"def":"Reflecting a milky or pearly light from the interior; having an opaline play of colors.","pos":""}],"OPALINE":[{"def":"Of, pertaining to, or like, opal in appearance; having changeable colors like those of the opal.","pos":""}],"OPALIZE":[{"def":"To convert into opal, or a substance like opal.","pos":""}],"OPALOTYPE":[{"def":"A picture taken on \"milky\" glass.","pos":""}],"OPAQUE":[{"def":"Impervious to the rays of light; not transparent; as, an opaque substance.","pos":""},{"def":"Obscure; not clear; unintelligible.","pos":""}],"OPAQUENESS":[{"def":"The state or quality of being impervious to light; opacity.","pos":""}]}