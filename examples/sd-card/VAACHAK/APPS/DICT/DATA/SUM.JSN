{"SUM":[{"def":"A problem to be solved, or an example to be wrought out.","pos":""}],"SUMATRA LEAF":[{"def":"A thin, elastic, uniformly light-colored tobacco leaf, raised in Sumatra and extensively used for cigar wrappers.","pos":""}],"SUMATRAN":[{"def":"Of or pertaining to Sumatra or its inhabitants.","pos":""},{"def":"A native of Sumatra.","pos":""}],"SUMBUL":[{"def":"The musky root of an Asiatic umbelliferous plant, Ferula Sumbul.","pos":""}],"SUMERIAN":[{"def":"Of or pertaining to the region of lower Babylonia, which was anciently called Sumer, or its inhabitants or their language.","pos":""}],"SUMLESS":[{"def":"Not to be summed up or computed; so great that the amount can not be ascertained; incalculable; inestimable.","pos":""}],"SUMMARILY":[{"def":"In a summary manner.","pos":""}],"SUMMARIST":[{"def":"One who summarized.","pos":""}],"SUMMARIZE":[{"def":"To comprise in, or reduce to, a summary; to present briefly.","pos":""}],"SUMMARY":[{"def":"Formed into a sum; summed up; reduced into a narrow compass, or into few words; short; brief; concise; compendious; as, a summary statement of facts.","pos":""},{"def":"Hence, rapidly performed; quickly executed; as, a summary process; to take summary vengeance.","pos":""}],"SUMMATION":[{"def":"The act of summing, or forming a sum, or total amount; also, an aggregate.","pos":""}],"SUMMER":[{"def":"One who sums; one who casts up an account.","pos":""}],"SUMMER-FALLOW":[{"def":"To plow and work in summer, in order to prepare for wheat or other crop; to plow and let lie fallow.","pos":""}],"SUMMERHOUSE":[{"def":"A rustic house or apartment in a garden or park, to be used as a pleasure resort in summer.","pos":""}],"SUMMERLINESS":[{"def":"The quality or state of being like summer.","pos":""},{"def":"See Somersault, Somerset.","pos":""}],"SUMMERSTIR":[{"def":"To summer-fallow.","pos":""}],"SUMMERY":[{"def":"Of or pertaining to summer; like summer; as, a summery day.","pos":""}],"SUMMIST":[{"def":"One who sums up; one who forms an abridgment or summary.","pos":""}],"SUMMIT":[{"def":"The most elevated part of a bivalve shell, or the part in which the hinge is situated.","pos":""}],"SUMMITLESS":[{"def":"Having no summit.","pos":""}],"SUMMITY":[{"def":"The height or top of anything.","pos":""},{"def":"The utmost degree; perfection.","pos":""}],"SUMMON":[{"def":"To call upon to surrender, as a fort.","pos":""}],"SUMMONER":[{"def":"One who summons; one who cites by authority; specifically, a petty officer formerly employed to summon persons to appear in court; an apparitor.","pos":""}],"SUMMONS":[{"def":"A warning or citation to appear in court; a written notification signed by the proper officer, to be served on a person, warning him to appear in court at a day specified, to answer to the plaintiff, testify as a witness, or the like.","pos":""},{"def":"A demand to surrender.","pos":""}],"SUMMUM BONUM":[{"def":"The supreme or highest good, -- referring to the object of human life.","pos":""}],"SUMP":[{"def":"A round pit of stone, lined with clay, for receiving the metal on its first fusion.","pos":""}],"SUMPH":[{"def":"A dunce; a blockhead.","pos":""}],"SUMPITAN":[{"def":"A kind of blowgun for discharging arrows, -- used by the savages of Borneo and adjacent islands.","pos":""}],"SUMPTER":[{"def":"The driver of a pack horse.","pos":""},{"def":"A pack; a burden.","pos":""}],"SUMPTION":[{"def":"The major premise of a syllogism.","pos":""}],"SUMPTUARY":[{"def":"Relating to expense; regulating expense or expenditure.","pos":""}],"SUMPTUOSITY":[{"def":"Expensiveness; costliness; sumptuousness.","pos":""}],"SUMPTUOUS":[{"def":"Involving large outlay or expense; costly; expensive; hence, luxurious; splendid; magnificient; as, a sumptuous house or table; sumptuous apparel.","pos":""}]}