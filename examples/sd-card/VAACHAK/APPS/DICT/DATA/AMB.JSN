{"AMBAGES":[{"def":"A circuit; a winding.","pos":""}],"AMBAGIOUS":[{"def":"Circumlocutory; circuitous.","pos":""}],"AMBAGITORY":[{"def":"A valuable East Indian fiber plant (Hibiscus cannabinus), or its fiber, which is used throughout India for making ropes, cordage, and a coarse canvas and sackcloth; --called also brown Indian hemp.","pos":""}],"AMBASSADORIAL":[{"def":"Of or pertaining to an ambassador.","pos":""}],"AMBASSADORSHIP":[{"def":"The state, office, or functions of an ambassador.","pos":""}],"AMBASSADRESS":[{"def":"A female ambassador; also, the wife of an ambassador.","pos":""}],"AMBASSAGE":[{"def":"Same as Embassage.","pos":""}],"AMBASSY":[{"def":"See Embassy, the usual spelling.","pos":""}],"AMBER":[{"def":"A yellowish translucent resin resembling copal, found as a fossil in alluvial soils, with beds of lignite, or on the seashore in many places.","pos":""}],"AMBER FISH":[{"def":"A fish of the southern Atlantic coast (Seriola Carolinensis.","pos":""}],"AMBER ROOM":[{"def":"A room formerly in the Czar's Summer Palace in Russia, which was richly decorated with walls and fixtures made from amber.","pos":""}],"AMBER SEED":[{"def":"Seed of the Hibiscus abelmoschus, somewhat resembling millet, brought from Egypt and the West Indies, and having a flavor like that of musk; musk seed.","pos":""}],"AMBER TREE":[{"def":"A species of Anthospermum, a shrub with evergreen leaves, which, when bruised, emit a fragrant odor.","pos":""}],"AMBERGRIS":[{"def":"A substance of the consistence of wax, found floating in the Indian Ocean and other parts of the tropics, and also as a morbid secretion in the intestines of the sperm whale (Physeter macrocephalus), which is believed to be in all cases its true origin.","pos":""}],"AMBIDEXTER":[{"def":"Using both hands with equal ease.","pos":""}],"AMBIDEXTERITY":[{"def":"A juror's taking of money from the both parties for a verdict.","pos":""}],"AMBIDEXTRAL":[{"def":"Pertaining equally to the right-hand side and the left-hand side.","pos":""}],"AMBIDEXTROUS":[{"def":"Pertaining the faculty of using both hands with equal ease.","pos":""},{"def":"Practicing or siding with both parties.","pos":""}],"AMBIDEXTROUSLY":[{"def":"In an ambidextrous manner; cunningly.","pos":""}],"AMBIDEXTROUSNESS":[{"def":"The quality of being ambidextrous; ambidexterity.","pos":""}],"AMBIENT":[{"def":"Encompassing on all sides; circumfused; investing.","pos":""}],"AMBIGENOUS":[{"def":"Partaking of two natures, as the perianth of some endogenous plants, where the outer surface is calycine, and the inner petaloid.","pos":""}],"AMBIGU":[{"def":"An entertainment at which a medley of dishes is set on at the same time.","pos":""}],"AMBIGUITY":[{"def":"The quality or state of being ambiguous; doubtfulness or uncertainty, particularly as to the signification of language, arising from its admitting of more than one meaning; an equivocal word or expression.","pos":""}],"AMBIGUOUS":[{"def":"Doubtful or uncertain, particularly in respect to signification; capable of being understood in either of two or more possible senses; equivocal; as, an ambiguous course; an ambiguous expression.","pos":""}],"AMBIGUOUSLY":[{"def":"In an ambiguous manner; with doubtful meaning.","pos":""}],"AMBILEVOUS":[{"def":"Left-handed on both sides; clumsy; -- opposed to ambidexter.","pos":""}],"AMBILOQUY":[{"def":"Doubtful or ambiguous language.","pos":""}],"AMBIPAROUS":[{"def":"Characterized by containing the rudiments of both flowers and leaves; -- applied to a bud.","pos":""}],"AMBIT":[{"def":"Circuit or compass.","pos":""}],"AMBITION":[{"def":"The act of going about to solicit or obtain an office, or any other object of desire; canvassing.","pos":""},{"def":"An eager, and sometimes an inordinate, desire for preferment, honor, superiority, power, or the attainment of something.","pos":""}],"AMBITIONIST":[{"def":"One excessively ambitious.","pos":""}],"AMBITIONLESS":[{"def":"Devoid of ambition.","pos":""}],"AMBITIOUS":[{"def":"Possessing, or controlled by, ambition; greatly or inordinately desirous of power, honor, office, superiority, or distinction.","pos":""},{"def":"Strongly desirous; -- followed by of or the infinitive; as, ambitious to be or to do something.","pos":""}],"AMBITIOUSLY":[{"def":"In an ambitious manner.","pos":""}],"AMBITIOUSNESS":[{"def":"The quality of being ambitious; ambition; pretentiousness.","pos":""}],"AMBITUS":[{"def":"A canvassing for votes.","pos":""}],"AMBLE":[{"def":"To go at the easy gait called an amble; -- applied to the horse or to its rider.","pos":""},{"def":"To move somewhat like an ambling horse; to go easily or without hard shocks.","pos":""}],"AMBLER":[{"def":"A horse or a person that ambles.","pos":""}],"AMBLINGLY":[{"def":"With an ambling gait.","pos":""}],"AMBLOTIC":[{"def":"Tending to cause abortion.","pos":""}],"AMBLYGON":[{"def":"An obtuse-angled figure, esp.","pos":""}],"AMBLYGONAL":[{"def":"Weakness of sight, without and opacity of the cornea, or of the interior of the eye; the first degree of amaurosis.","pos":""}],"AMBLYOPIC":[{"def":"Of or pertaining to amblyopy.","pos":""}],"AMBLYPODA":[{"def":"A group of large, extinct, herbivorous mammals, common in the Tertiary formation of the United States.","pos":""}],"AMBO":[{"def":"A large pulpit or reading desk, in the early Christian churches.","pos":""}],"AMBOYNA BUTTON":[{"def":"A chronic contagious affection of the skin, prevalent in the tropics.","pos":""}],"AMBOYNA PINE":[{"def":"The resiniferous tree Agathis Dammara, of the Moluccas.","pos":""}],"AMBOYNA WOOD":[{"def":"A beautiful mottled and curled wood, used in cabinetwork.","pos":""}],"AMBREATE":[{"def":"A salt formed by the combination of ambreic acid with a base or positive radical.","pos":""}],"AMBREIC":[{"def":"Of or pertaining to ambrein; -- said of a certain acid produced by digesting ambrein in nitric acid.","pos":""}],"AMBREIN":[{"def":"A fragrant substance which is the chief constituent of ambergris.","pos":""}],"AMBRITE":[{"def":"A fossil resin occurring in large masses in New Zealand.","pos":""}],"AMBROSE":[{"def":"A sweet-scented herb; ambrosia.","pos":""}],"AMBROSIA":[{"def":"A perfumed unguent, salve, or draught; something very pleasing to the taste or smell.","pos":""},{"def":"Formerly, a kind of fragrant plant; now (Bot.","pos":""}],"AMBROSIA BEETLE":[{"def":"A bark beetle that feeds on ambrosia.","pos":""}],"AMBROSIAC":[{"def":"Having the qualities of ambrosia; delicious.","pos":""}],"AMBROSIAL":[{"def":"Consisting of, or partaking of the nature of, ambrosia; delighting the taste or smell; delicious.","pos":""},{"def":"Divinely excellent or beautiful.","pos":""}],"AMBROSIALLY":[{"def":"After the manner of ambrosia; delightfully.","pos":""}],"AMBROSIAN":[{"def":"Of or pertaining to St.","pos":""}],"AMBROSIN":[{"def":"An early coin struck by the dukes of Milan, and bearing the figure of St.","pos":""}],"AMBROTYPE":[{"def":"A picture taken on a place of prepared glass, in which the lights are represented in silver, and the shades are produced by a dark background visible through the unsilvered portions of the glass.","pos":""}],"AMBRY":[{"def":"In churches, a kind of closet, niche, cupboard, or locker for utensils, vestments, etc.","pos":""},{"def":"A store closet, as a pantry, cupboard, etc.","pos":""}],"AMBS-ACE":[{"def":"Double aces, the lowest throw of all at dice.","pos":""}],"AMBULACRAL":[{"def":"Of or pertaining to ambulacra; avenuelike; as, the ambulacral ossicles, plates, spines, and suckers of echinoderms.","pos":""}],"AMBULACRIFORM":[{"def":"Having the form of ambulacra.","pos":""}],"AMBULANCE":[{"def":"Often used adjectively; as, an ambulance wagon; ambulance stretcher; ambulance corps.","pos":""}],"AMBULANT":[{"def":"Walking; moving from place to place.","pos":""}],"AMBULATE":[{"def":"To walk; to move about.","pos":""}],"AMBULATION":[{"def":"The act of walking.","pos":""}],"AMBULATOR":[{"def":"One who walks about; a walker.","pos":""},{"def":"An instrument for measuring distances; -- called also perambulator.","pos":""}],"AMBULATORIAL":[{"def":"Ambulatory; fitted for walking.","pos":""}],"AMBULATORY":[{"def":"Not yet fixed legally, or settled past alteration; alterable; as, the dispositions of a will are ambulatory until the death of the testator.","pos":""}],"AMBUSCADE":[{"def":"The body of troops lying in ambush.","pos":""}],"AMBUSCADOED":[{"def":"Posted in ambush; ambuscaded.","pos":""}],"AMBUSH":[{"def":"A disposition or arrangement of troops for attacking an enemy unexpectedly from a concealed station.","pos":""},{"def":"A concealed station, where troops or enemies lie in wait to attack by surprise.","pos":""}],"AMBUSHER":[{"def":"One lying in ambush.","pos":""}],"AMBUSTION":[{"def":"A burn or scald.","pos":""}]}