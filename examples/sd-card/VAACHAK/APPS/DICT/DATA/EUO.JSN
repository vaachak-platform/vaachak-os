{"EUONYMIN":[{"def":"A principle or mixture of principles derived from Euonymus atropurpureus, or spindle tree.","pos":""}],"EUONYMUS":[{"def":"A genus of small European and American trees; the spindle tree.","pos":""}],"EUORNITHES":[{"def":"The division of Aves which includes all the typical birds, or all living birds except the penguins and birds of ostrichlike form.","pos":""}],"EUOSMITTE":[{"def":"A fossil resin, so called from its strong, peculiar, pleasant odor.","pos":""}]}