{"INERADICABLE":[{"def":"Incapable of being The bad seed thus sown was ineradicable.","pos":""}],"INERADICABLY":[{"def":"So as not to be eradicable.","pos":""},{"def":"Having no energy; sluggish.","pos":""}],"INERGETICALLY":[{"def":"Same as Inermis.","pos":""}],"INERMIS":[{"def":"Unarmed; destitute of prickles or thorns, as a leaf.","pos":""}],"INERRABILITY":[{"def":"Freedom or exemption from error; infallibility.","pos":""}],"INERRABLE":[{"def":"Incapable of erring; infallible; unerring.","pos":""}],"INERRABLENESS":[{"def":"Exemption from error; inerrability; infallibility.","pos":""}],"INERRABLY":[{"def":"With security from error; infallibly; unerringly.","pos":""}],"INERRANCY":[{"def":"Exemption from error.","pos":""}],"INERRATIC":[{"def":"Not erratic or wandering; fixed; settled; established.","pos":""}],"INERRINGLY":[{"def":"Without error, mistake, or deviation; unerringly.","pos":""}],"INERT":[{"def":"Destitute of the power of moving itself, or of active resistance to motion; as, matter is inert.","pos":""},{"def":"Indisposed to move or act; very slow to act; sluggish; dull; inactive; indolent; lifeless.","pos":""}],"INERTIA":[{"def":"That property of matter by which it tends when at rest to remain so, and when in motion to continue in motion, and in the same straight line or direction, unless acted on by some external force; - - sometimes called vis inertiæ.","pos":""},{"def":"Want of activity; sluggishness; -- said especially of the uterus, when, in labor, its contractions have nearly or wholly ceased.","pos":""}],"INERTION":[{"def":"Want of activity or exertion; inertness; quietude.","pos":""}],"INERTITUDE":[{"def":"Inertness; inertia.","pos":""}],"INERTLY":[{"def":"Without activity; sluggishly.","pos":""}],"INERTNESS":[{"def":"Want of activity or exertion; habitual indisposition to action or motion; sluggishness; apathy; insensibility.","pos":""},{"def":"Absence of the power of self-motion; inertia.","pos":""}],"INERUDITE":[{"def":"Not erudite; unlearned; ignorant.","pos":""}]}