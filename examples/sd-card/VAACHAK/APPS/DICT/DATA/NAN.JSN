{"NANDINE":[{"def":"An African carnivore (Nandinia binotata), allied to the civets.","pos":""},{"def":"Any one of three species of South American ostriches of the genera Rhea and Pterocnemia.","pos":""}],"NANISM":[{"def":"The condition of being abnormally small in stature; dwarfishness; -- opposed to gigantism.","pos":""}],"NANKEEN":[{"def":"Trousers made of nankeen.","pos":""}],"NANNY":[{"def":"A diminutive of Ann or Anne, the proper name.","pos":""}]}