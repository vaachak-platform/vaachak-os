{"CALM":[{"def":"Freodom from motion, agitation, or disturbance; a cessation or abeence of that which causes motion or disturbance, as of winds or waves; tranquility; stilness; quiet; serenity.","pos":""}],"CALMER":[{"def":"One who, or that which, makes calm.","pos":""}],"CALMLY":[{"def":"In a calm manner.","pos":""}],"CALMNESS":[{"def":"The state of quality of being calm; quietness; tranquillity; self-repose.","pos":""}],"CALMY":[{"def":"Tranquil; peaceful; calm.","pos":""}]}