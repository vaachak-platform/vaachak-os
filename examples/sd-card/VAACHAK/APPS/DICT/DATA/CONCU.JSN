{"CONCUBINACY":[{"def":"The practice of concubinage.","pos":""}],"CONCUBINAGE":[{"def":"A plea, in which it is alleged that the woman suing for dower was not lawfully married to the man in whose lands she seeks to be endowed, but that she was his concubine.","pos":""}],"CONCUBINAL":[{"def":"Of or pertaining to concubinage.","pos":""}],"CONCUBINARIAN":[{"def":"Con*cu`bi*na\"ri*an, a.","pos":""}],"CONCUBINARY":[{"def":"Relating to concubinage; living in concubinage.","pos":""}],"CONCUBINE":[{"def":"A woman who cohabits with a man without being his wife; a paramour.","pos":""},{"def":"A wife of inferior condition; a lawful wife, but not united to the man by the usual ceremonies, and of inferior condition.","pos":""}],"CONCULCATE":[{"def":"To tread or trample under foot.","pos":""}],"CONCUPISCENCE":[{"def":"Sexual lust; morbid carnal passion.","pos":""}],"CONCUPISCENT":[{"def":"Having sexual lust; libidinous; lustful; lecherous; salacious.","pos":""}],"CONCUPISCENTIAL":[{"def":"Relating to concupiscence.","pos":""}],"CONCUPISCENTIOUS":[{"def":"Con*cu`pis*cen\"tious, a.","pos":""}],"CONCUPISCIBLE":[{"def":"Exciting to, or liable to be affected by, concupiscence; provoking lustful desires.","pos":""},{"def":"Exciting desire, good or evil.","pos":""}],"CONCUPISCIBLENESS":[{"def":"The state of being concupiscible.","pos":""}],"CONCUPY":[{"def":"Note: [Used only in \"Troilus and Cressida\"] Shak.","pos":""}],"CONCUR":[{"def":"To run together; to meet.","pos":""},{"def":"To meet in the same point; to combine or conjoin; to contribute or help toward a common object or effect.","pos":""}],"CONCURRENCE":[{"def":"The act of concurring; a meeting or coming together; union; conjunction; combination.","pos":""},{"def":"A meeting of minds; agreement in opinion; union in design or act; -- implying joint approbation.","pos":""}],"CONCURRENT":[{"def":"Meeting in one point.","pos":""}],"CONCURRENTLY":[{"def":"With concurrence; unitedly.","pos":""}],"CONCURRENTNESS":[{"def":"The state or quality of being concurrent; concurrence.","pos":""}],"CONCUSS":[{"def":"To force (a person) to do something, or give up something, by intimidation; to coerce.","pos":""}],"CONCUSSATION":[{"def":"A violent shock or agitation.","pos":""}],"CONCUSSION":[{"def":"A condition of lowered functional activity, without visible structural change, produced in an organ by a shock, as by fall or blow; as, a concussion of the brain.","pos":""},{"def":"The unlawful forcing of another by threats of violence to yield up something of value.","pos":""}],"CONCUSSIVE":[{"def":"Having the power or quality of shaking or agitating.","pos":""}]}