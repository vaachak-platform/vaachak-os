{"MESA":[{"def":"A high tableland; a plateau on a hill.","pos":""}],"MESACONATE":[{"def":"A salt of mesaconic acid.","pos":""}],"MESACONIC":[{"def":"Pertaining to, or designating, one of several isomeric acids obtained from citric acid.","pos":""}],"MESALLIANCE":[{"def":"A marriage with a person of inferior social position; a misalliance.","pos":""}],"MESALLY":[{"def":"Same as Mesially.","pos":""},{"def":"One of a class of independent, isolated cells found in the mesoderm, while the germ layers are undergoing differentiation.","pos":""}],"MESATICEPHALIC":[{"def":"Having the ratio of the length to the breadth of the cranium a medium one; neither brachycephalic nor dolichocephalic.","pos":""}],"MESATICEPHALOUS":[{"def":"Mes`a*ti*ceph\"a*lous, a.","pos":""}],"MESCAL":[{"def":"A distilled liquor prepared in Mexico from a species of agave.","pos":""}],"MESEMBRYANTHEMUM":[{"def":"A genus of herbaceous or suffruticose plants, chiefly natives of South Africa.","pos":""}],"MESENCEPHALIC":[{"def":"Of or pertaining to the mesencephalon or midbrain.","pos":""}],"MESENCEPHALON":[{"def":"The middle segment of the brain; the midbrain.","pos":""}],"MESENCHYMA":[{"def":"The part of the mesoblast which gives rise to the connective tissues and blood.","pos":""}],"MESENTERIC":[{"def":"Pertaining to a mesentery; mesaraic.","pos":""}],"MESENTERON":[{"def":"All that part of the alimentary canal which is developed from the primitive enteron and is lined with hypoblast.","pos":""}],"MESENTERY":[{"def":"The membranes, or one of the membranes (consisting of a fold of the peritoneum and inclosed tissues), which connect the intestines and their appendages with the dorsal wall of the abdominal cavity.","pos":""},{"def":"One of the vertical muscular radiating partitions which divide the body cavity of Anthozoa into chambers.","pos":""}],"MESETHMOID":[{"def":"Of or pertaining to the middle of the ethmoid region or ethmoid bone.","pos":""},{"def":"The median vertical plate, or median element, of the ethmoid bone.","pos":""}],"MESH":[{"def":"The engagement of the teeth of wheels, or of a wheel and rack.","pos":""}],"MESHY":[{"def":"Formed with meshes; netted.","pos":""}],"MESIAD":[{"def":"Toward, or on the side toward, the mesial plane; mesially; -- opposed to laterad.","pos":""}],"MESIAL":[{"def":"Middle; median; in, or in the region of, the mesial plane; internal; -- opposed to lateral.","pos":""}],"MESIALLY":[{"def":"In, near, or toward, the mesial plane; mesiad.","pos":""}],"MESITYL":[{"def":"A hypothetical radical formerly supposed to exist in mesityl oxide.","pos":""}],"MESITYLENATE":[{"def":"A salt of mesitylenic acid.","pos":""}],"MESITYLENE":[{"def":"A colorless, fragrant liquid, C6H3(CH3)3, of the benzene series of hydrocarbons, obtained by distilling acetone with sulphuric acid.","pos":""}],"MESITYLOL":[{"def":"A crystalline substance obtained from mesitylene.","pos":""}],"MESMEREE":[{"def":"A person subjected to mesmeric influence; one who is mesmerized.","pos":""},{"def":"Of, pertaining to, or induced by, mesmerism; as, mesmeric sleep.","pos":""}],"MESMERISM":[{"def":"The art of inducing an extraordinary or abnormal state of the nervous system, in which the actor claims to control the actions, and communicate directly with the mind, of the recipient.","pos":""}],"MESMERIST":[{"def":"One who practices, or believes in, mesmerism.","pos":""}],"MESMERIZATION":[{"def":"The act of mesmerizing; the state of being mesmerized.","pos":""}],"MESMERIZE":[{"def":"To bring into a state of mesmeric sleep.","pos":""}],"MESMERIZER":[{"def":"One who mesmerizes.","pos":""}],"MESNE":[{"def":"Middle; intervening; as, a mesne lord, that is, a lord who holds land of a superior, but grants a part of it to another person, in which case he is a tenant to the superior, but lord or superior to the second grantee, and hence is called the mesne lord.","pos":""},{"def":"A combining form denoting in the middle, intermediate; specif.","pos":""}],"MESOARIUM":[{"def":"The fold of peritoneum which suspends the ovary from the dorsal wall of the body cavity.","pos":""}],"MESOBLASTIC":[{"def":"Relating to the mesoblast; as, the mesoblastic layer.","pos":""}],"MESOBRANCHIAL":[{"def":"Of or pertaining to a region of the carapace of a crab covering the middle branchial region.","pos":""}],"MESOBRONCHIUM":[{"def":"The main bronchus of each lung.","pos":""}],"MESOCAECUM":[{"def":"The fold of peritoneum attached to the cæcum.","pos":""}],"MESOCARP":[{"def":"The middle layer of a pericarp which consists of three distinct or dissimilar layers.","pos":""}],"MESOCEPHALON":[{"def":"The pons Varolii.","pos":""}],"MESOCEPHALOUS":[{"def":"The cavity of the mesencephalon; the iter.","pos":""}],"MESOCOLON":[{"def":"The fold of peritoneum, or mesentery, attached to the colon.","pos":""}],"MESOCORACOID":[{"def":"A process from the middle of the coracoid in some animals.","pos":""},{"def":"One of the bones of the tarsus.","pos":""}],"MESODERMAL":[{"def":"Pertaining to, or derived from, the mesoderm; as, mesodermal tissues.","pos":""}],"MESODERMIC":[{"def":"Same as Mesodermal.","pos":""}],"MESODONT":[{"def":"Having teeth of moderate size.","pos":""}],"MESOGASTER":[{"def":"The fold of peritoneum connecting the stomach with the dorsal wall of the abdominal cavity; the mesogastrium.","pos":""}],"MESOGASTRIC":[{"def":"Of or pertaining to the middle gastric lobe of the carapace of a crab.","pos":""}],"MESOGASTRIUM":[{"def":"A thin gelatinous tissue separating the ectoderm and endoderm in certain coelenterates.","pos":""}],"MESOGNATHOUS":[{"def":"Having the jaws slightly projecting; between prognathous and orthognathous.","pos":""}],"MESOHEPAR":[{"def":"A fold of the peritoneum connecting the liver with the dorsal wall of the abdominal cavity.","pos":""}],"MESOHIPPUS":[{"def":"An extinct mammal of the Horse family, but not larger than a sheep, and having three toes on each foot.","pos":""}],"MESOLABE":[{"def":"An instrument of the ancients for finding two mean proportionals between two given lines, required in solving the problem of the duplication of the cube.","pos":""}],"MESOLE":[{"def":"Same as Thomsonite.","pos":""}],"MESOLITE":[{"def":"A zeolitic mineral, grayish white or yellowish, occuring in delicate groups of crystals, also fibrous massive.","pos":""}],"MESOLOGARITHM":[{"def":"A logarithm of the cosine or cotangent.","pos":""}],"MESOMETRIUM":[{"def":"The fold of the peritoneum supporting the oviduct.","pos":""}],"MESOMYCETES":[{"def":"One of the three classes into which the fungi are divided in Brefeld's classification.","pos":""}],"MESOMYODIAN":[{"def":"A bird having a mesomyodous larynx.","pos":""}],"MESOMYODOUS":[{"def":"Having the intrinsic muscles of the larynx attached to the middle of the semirings.","pos":""}],"MESON":[{"def":"The mesial plane dividing the body of an animal into similar right and left halves.","pos":""}],"MESONASAL":[{"def":"Of or pertaining to the middle portion of the nasal region.","pos":""}],"MESONEPHRIC":[{"def":"Of or pertaining to the mesonephros; as, the mesonephric, or Wolffian, duct.","pos":""}],"MESONEPHROS":[{"def":"The middle one of the three pairs of embryonic renal organs developed in most vertebrates; the Wolffian body.","pos":""}],"MESONOTUM":[{"def":"The dorsal portion of the mesothorax of insects.","pos":""}],"MESOPHLOEUM":[{"def":"The middle bark of a tree; the green layer of bark, usually soon covered by the outer or corky layer, and obliterated.","pos":""}],"MESOPHYLLUM":[{"def":"The parenchyma of a leaf between the skin of the two surfaces.","pos":""}],"MESOPLAST":[{"def":"The nucleus of a cell; mesoblast.","pos":""}],"MESOPODIAL":[{"def":"Of or pertaining to the mesopodialia or to the parts of the limbs to which they belong.","pos":""}],"MESOPODIALE":[{"def":"One of the bones of either the carpus or tarsus.","pos":""}],"MESOPODIUM":[{"def":"The middle portion of the foot in the Gastropoda and Pteropoda.","pos":""}],"MESOPTERYGIUM":[{"def":"The middle one of the three principal basal cartilages in the fins of fishes.","pos":""}],"MESORCHIUM":[{"def":"The fold of peritoneum which attaches the testis to the dorsal wall of the body cavity or scrotal sac.","pos":""}],"MESORECTUM":[{"def":"The fold of peritoneum, or mesentery, attached to the rectum.","pos":""}],"MESORHINE":[{"def":"Having the nose of medium width; between leptorhine and platyrhine.","pos":""}],"MESOSAURIA":[{"def":"Same as Mosasauria.","pos":""}],"MESOSCAPULA":[{"def":"A process from the middle of the scapula in some animals; the spine of the scapula.","pos":""}],"MESOSCAPULAR":[{"def":"Of or pertaining to the mesoscapula.","pos":""}],"MESOSCUTUM":[{"def":"The scutum or dorsal plate of the middle thoracic segment of an insect.","pos":""}],"MESOSEME":[{"def":"Having a medium orbital index; having orbits neither broad nor narrow; between megaseme and microseme.","pos":""}],"MESOSIDERITE":[{"def":"See the Note under Meteorite.","pos":""}],"MESOSPERM":[{"def":"A membrane of a seed.","pos":""}],"MESOSTATE":[{"def":"A product of metabolic action.","pos":""}],"MESOSTERNAL":[{"def":"Of or pertaining to the mesosternum.","pos":""}],"MESOSTERNUM":[{"def":"The middle portion, or body, of the sternum.","pos":""},{"def":"The ventral piece of the middle segment of the thorax in insects.","pos":""}],"MESOTARTARIC":[{"def":"Pertaining to, or designating, an acid called also inactive tartaric acid.","pos":""}],"MESOTHECA":[{"def":"The middle layer of the gonophore in the Hydrozoa.","pos":""}],"MESOTHELIUM":[{"def":"Epithelial mesoderm; a layer of cuboidal epithelium cells, formed from a portion of the mesoderm during the differetiation of the germ layers.","pos":""}],"MESOTHORACIC":[{"def":"Of or pertaining to the mesothorax.","pos":""}],"MESOTHORAX":[{"def":"The middle segment of the thorax in insects.","pos":""}],"MESOTHORIUM":[{"def":"A radioactive product intermediate between thorium and radiothorium, with a period of 5.","pos":""}],"MESOTROCHAL":[{"def":"Having the middle of the body surrounded by bands of cilia; -- said of the larvæ of certain marine annelids.","pos":""}],"MESOTYPE":[{"def":"An old term covering natrolite or soda mesolite, scolecite or lime mesotype, and mesolite or lime-soda mesotype.","pos":""}],"MESOVARIUM":[{"def":"The fold of peritoneum connecting the ovary with the wall of the abdominal cavity.","pos":""}],"MESOXALATE":[{"def":"A salt of mesoxalic acid.","pos":""}],"MESOXALIC":[{"def":"Pertaining to, or designating, an acid, CH2O2(CO2H)2, obtained from amido malonic acid.","pos":""}],"MESOZOA":[{"def":"A group of very lowly organized, wormlike parasites, including the Dicyemata.","pos":""}],"MESOZOIC":[{"def":"Belonging, or relating, to the secondary or reptilian age, or the era between the Paleozoic and Cenozoic.","pos":""}],"MESPRISE":[{"def":"Misadventure; ill-success.","pos":""},{"def":"A name for two trees of the southwestern part of North America, the honey mesquite, and screw-pod mesquite.","pos":""}],"MESQUITE BEAN":[{"def":"The pod or seed of the mesquite.","pos":""}],"MESS":[{"def":"Mass; church service.","pos":""}],"MESS BEEF":[{"def":"Barreled salt beef, packed with about 80 pounds chuck and rump, two flanks, and the rest plates.","pos":""}],"MESSAGE":[{"def":"Any notice, word, or communication, written or verbal, sent from one person to another.","pos":""},{"def":"Hence, specifically, an official communication, not made in person, but delivered by a messenger; as, the President's message.","pos":""}],"MESSAGE STICK":[{"def":"A stick, carved with lines and dots, used, esp.","pos":""}],"MESSENGER":[{"def":"A hawser passed round the capstan, and having its two ends lashed together to form an endless rope or chain; -- formerly used for heaving in the cable.","pos":""},{"def":"A person appointed to perform certain ministerial duties under bankrupt and insolvent laws, such as to take charge og the estate of the bankrupt or insolvent.","pos":""}],"MESSIAD":[{"def":"A German epic poem on the Messiah, by Klopstock.","pos":""}],"MESSIAH":[{"def":"The expected king and deliverer of the Hebrews; the Savior; Christ.","pos":""}],"MESSIAHSHIP":[{"def":"The state or office of the Messiah.","pos":""}],"MESSIANIC":[{"def":"Of or relating to the Messiah; as, the Messianic office or character.","pos":""}],"MESSIAS":[{"def":"I know that Messias cometh, which is called Christ.","pos":""}],"MESSIDOR":[{"def":"The tenth month of the French republican calendar dating from September 22, 1792.","pos":""}],"MESSIEURS":[{"def":"Sirs; gentlemen; -- abbreviated to Messrs.","pos":""}],"MESSINESE":[{"def":"Of or pertaining to Messina, or its inhabitans.","pos":""}],"MESSMATE":[{"def":"An associate in a mess.","pos":""}],"MESSUAGE":[{"def":"A dwelling house, with the adjacent buildings and curtilage, and the adjoining lands appropriated to the use of the household.","pos":""}],"MESTEE":[{"def":"The offspring of a white person and a quadroon; -- so called in the West Indies.","pos":""}],"MESTER":[{"def":"See Mister, a trade.","pos":""}],"MESTIZO":[{"def":"The offspring of an Indian or a negro and a European or person of European stock.","pos":""}],"MESTLING":[{"def":"A kind of brass.","pos":""}],"MESYMNICUM":[{"def":"A repetition at the end of a stanza.","pos":""}]}