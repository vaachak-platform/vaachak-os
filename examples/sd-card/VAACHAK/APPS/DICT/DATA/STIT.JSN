{"STITCH":[{"def":"A space of work taken up, or gone over, in a single pass of the needle; hence, by extension, any space passed over; distance.","pos":""}],"STITCHEL":[{"def":"A kind of hairy wool.","pos":""}],"STITCHER":[{"def":"One who stitches; a seamstress.","pos":""}],"STITCHERY":[{"def":"Needlework; -- in comtempt.","pos":""}],"STITCHING":[{"def":"The act of one who stitches.","pos":""},{"def":"Work done by sewing, esp.","pos":""}],"STITH":[{"def":"Strong; stiff; rigid.","pos":""}],"STITHY":[{"def":"A smith's shop; a smithy; a smithery; a forge.","pos":""}]}