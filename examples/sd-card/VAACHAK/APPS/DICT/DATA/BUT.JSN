{"BUT":[{"def":"Except with; unless with; without.","pos":""},{"def":"Except; besides; save.","pos":""}],"BUT-THORN":[{"def":"The common European starfish (Asterias rubens).","pos":""}],"BUTANE":[{"def":"An inflammable gaseous hydrocarbon, C4H10, of the marsh gas, or paraffin, series.","pos":""}],"BUTCHER":[{"def":"One who slaughters animals, or dresses their flesh for market; one whose occupation it is to kill animals for food.","pos":""},{"def":"A slaughterer; one who kills in large numbers, or with unusual cruelty; one who causes needless loss of life, as in battle.","pos":""}],"BUTCHER'S BROOM":[{"def":"A genus of plants (Ruscus); esp.","pos":""}],"BUTCHERING":[{"def":"The business of a butcher.","pos":""},{"def":"The act of slaughtering; the act of killing cruelly and needlessly.","pos":""}],"BUTCHERLINESS":[{"def":"Butchery quality.","pos":""}],"BUTCHERLY":[{"def":"Like a butcher; without compunction; savage; bloody; inhuman; fell.","pos":""}],"BUTCHERY":[{"def":"The business of a butcher.","pos":""},{"def":"Murder or manslaughter, esp.","pos":""}],"BUTLER":[{"def":"An officer in a king's or a nobleman's household, whose principal business it is to take charge of the liquors, plate, etc.","pos":""}],"BUTLERAGE":[{"def":"A duty of two shillings on every tun of wine imported into England by merchant strangers; -- so called because paid to the king's butler for the king.","pos":""}],"BUTLERSHIP":[{"def":"The office of a butler.","pos":""}],"BUTMENT":[{"def":"A buttress of an arch; the supporter, or that part which joins it to the upright pier.","pos":""},{"def":"The mass of stone or solid work at the end of a bridge, by which the extreme arches are sustained, or by which the end of a bridge without arches is supported.","pos":""}],"BUTT":[{"def":"To join at the butt, end, or outward extremity; to terminate; to be bounded; to abut.","pos":""},{"def":"To thrust the head forward; to strike by thrusting the head forward, as an ox or a ram.","pos":""}],"BUTT HINGE":[{"def":"See 1st Butt, 10.","pos":""}],"BUTT JOINT":[{"def":"A joint in which the edges or ends of the pieces united come squarely together instead of overlapping.","pos":""}],"BUTT SHAFT":[{"def":"An arrow without a barb, for shooting at butts; an arrow.","pos":""}],"BUTT WELD":[{"def":"See Butt weld, under Butt.","pos":""}],"BUTTE":[{"def":"A detached low mountain, or high rising abruptly from the general level of the surrounding plain; -- applied to peculiar elevations in the Rocky Mountain region.","pos":""}],"BUTTER":[{"def":"An oily, unctuous substance obtained from cream or milk by churning.","pos":""}],"BUTTER-FINGERED":[{"def":"Apt to let things fall, or to let them slip away; slippery; careless.","pos":""}],"BUTTER-SCOTCH":[{"def":"A kind of candy, mainly composed of sugar and butter.","pos":""}],"BUTTERBALL":[{"def":"The buffel duck.","pos":""}],"BUTTERBIRD":[{"def":"The rice bunting or bobolink; -- so called in the island of Jamaica.","pos":""}],"BUTTERBUMP":[{"def":"The European bittern.","pos":""}],"BUTTERBUR":[{"def":"A broad-leaved plant (Petasites vulgaris) of the Composite family, said to have been used in England for wrapping up pats of butter.","pos":""}],"BUTTERCUP":[{"def":"A plant of the genus Ranunculus, or crowfoot, particularly R.","pos":""}],"BUTTERFISH":[{"def":"A name given to several different fishes, in allusion to their slippery coating of mucus, as the Stromateus triacanthus of the Atlantic coast, the Epinephelus punctatus of the southern coast, the rock eel, and the kelpfish of New Zealand.","pos":""}],"BUTTERFLY":[{"def":"A general name for the numerous species of diurnal Lepidoptera.","pos":""}],"BUTTERINE":[{"def":"A substance prepared from animal fat with some other ingredients intermixed, as an imitation of butter.","pos":""}],"BUTTERIS":[{"def":"A steel cutting instrument, with a long bent shank set in a handle which rests against the shoulder of the operator.","pos":""}],"BUTTERMAN":[{"def":"A man who makes or sells butter.","pos":""}],"BUTTERMILK":[{"def":"The milk that remains after the butter is separated from the cream.","pos":""}],"BUTTERNUT":[{"def":"An American tree (Juglans cinerea) of the Walnut family, and its edible fruit; -- so called from the oil contained in the latter.","pos":""},{"def":"The nut of the Caryocar butyrosum and C.","pos":""}],"BUTTERWEED":[{"def":"An annual composite plant of the Mississippi valley (Senecio lobatus).","pos":""}],"BUTTERWEIGHT":[{"def":"Note: Formerly it was a custom to give 18 ounces of butter for a pound.","pos":""}],"BUTTERWORT":[{"def":"A genus of low herbs (Pinguicula) having simple leaves which secrete from their glandular upper surface a viscid fluid, to which insects adhere, after which the margin infolds and the insects are digested by the plant.","pos":""}],"BUTTERY":[{"def":"Having the qualities, consistence, or appearance, of butter.","pos":""}],"BUTTING":[{"def":"An abuttal; a boundary.","pos":""}],"BUTTING JOINT":[{"def":"A joint between two pieces of timber or wood, at the end of one or both, and either at right angles or oblique to the grain, as the joints which the struts and braces form with the truss posts; -- sometimes called abutting joint.","pos":""}],"BUTTOCK":[{"def":"The convexity of a ship behind, under the stern.","pos":""}],"BUTTON":[{"def":"A knob; a small ball; a small, roundish mass.","pos":""},{"def":"A catch, of various forms and materials, used to fasten together the different parts of dress, by being attached to one part, and passing through a slit, called a buttonhole, in the other; -- used also for ornament.","pos":""}],"BUTTONBUSH":[{"def":"A shrub (Cephalanthus occidentalis) growing by the waterside; - - so called from its globular head of flowers.","pos":""}],"BUTTONHOLE":[{"def":"The hole or loop in which a button is caught.","pos":""}],"BUTTONMOLD":[{"def":"A disk of bone, wood, or other material, which is made into a button by covering it with cloth.","pos":""}],"BUTTONS":[{"def":"A boy servant, or page, -- in allusion to the buttons on his livry.","pos":""}],"BUTTONWEED":[{"def":"The name of several plants of the genera Spermacoce and Diodia, of the Madder family.","pos":""}],"BUTTONWOOD":[{"def":"The Platanus occidentalis, or American plane tree, a large tree, producing rough balls, from which it is named; -- called also buttonball tree, and, in some parts of the United States, sycamore.","pos":""}],"BUTTONY":[{"def":"Ornamented with a large number of buttons.","pos":""}],"BUTTRESS":[{"def":"A projecting mass of masonry, used for resisting the thrust of an arch, or for ornament and symmetry.","pos":""}],"BUTTWELD":[{"def":"To unite by a butt weld.","pos":""}],"BUTTY":[{"def":"One who mines by contract, at so much per ton of coal or ore.","pos":""}],"BUTYL":[{"def":"A compound radical, regarded as butane, less one atom of hydrogen.","pos":""}],"BUTYLAMINE":[{"def":"A colorless liquid base, C4H9NH2, of which there are four isomeric varieties.","pos":""}],"BUTYLENE":[{"def":"Any one of three metameric hydrocarbons, C4H8, of the ethylene series.","pos":""}],"BUTYRACEOUS":[{"def":"Having the qualities of butter; resembling butter.","pos":""}],"BUTYRATE":[{"def":"A salt of butyric acid.","pos":""}],"BUTYRIC":[{"def":"Pertaining to, or derived from, butter.","pos":""}],"BUTYRIN":[{"def":"A butyrate of glycerin; a fat contained in small quantity in milk, which helps to give to butter its peculiar flavor.","pos":""}],"BUTYROMETER":[{"def":"An instrument for determining the amount of fatty matter or butter contained in a sample of milk.","pos":""}],"BUTYRONE":[{"def":"A liquid ketone obtained by heating calcium butyrate.","pos":""}],"BUTYRYL":[{"def":"The radical (C4H7O) of butyric acid.","pos":""}]}