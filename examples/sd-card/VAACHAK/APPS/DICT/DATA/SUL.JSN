{"SULA":[{"def":"A genus of sea birds including the booby and the common gannet.","pos":""},{"def":"Scored with deep and regular furrows; furrowed or grooved; as, a sulcated stem.","pos":""}],"SULCATION":[{"def":"A channel or furrow.","pos":""}],"SULCIFORM":[{"def":"Having the form of a sulcus; as, sulciform markings.","pos":""}],"SULCUS":[{"def":"A furrow; a groove; a fissure.","pos":""}],"SULEAH FISH":[{"def":"A coarse fish of India, used in making a breakfast relish called burtah.","pos":""}],"SULK":[{"def":"To be silently sullen; to be morose or obstinate.","pos":""}],"SULKILY":[{"def":"In a sulky manner.","pos":""}],"SULKINESS":[{"def":"The quality or state of being sulky; sullenness; moroseness; as, sulkiness of disposition.","pos":""}],"SULKS":[{"def":"The condition of being sulky; a sulky mood or humor; as, to be in the sulks.","pos":""}],"SULKY":[{"def":"Moodly silent; sullen; sour; obstinate; morose; splenetic.","pos":""}],"SULLAGE":[{"def":"The scoria on the surface of molten metal in the ladle.","pos":""},{"def":"Silt; mud deposited by water.","pos":""}],"SULLEN":[{"def":"Lonely; solitary; desolate.","pos":""},{"def":"Gloomy; dismal; foreboding.","pos":""}],"SULLEVATE":[{"def":"To rouse; to excite.","pos":""}],"SULLIAGE":[{"def":"Foulness; filth.","pos":""}],"SULLY":[{"def":"To soil; to dirty; to spot; to tarnish; to stain; to darken; -- used literally and figuratively; as, to sully a sword; to sully a person's reputation.","pos":""}],"SULPHACID":[{"def":"An acid in which, to a greater or less extent, sulphur plays a part analogous to that of oxygen in an oxyacid; thus, thiosulphuric and sulpharsenic acids are sulphacids; -- called also sulphoacid.","pos":""}],"SULPHAMATE":[{"def":"A salt of sulphamic acid.","pos":""}],"SULPHAMIC":[{"def":"Of or pertaining to a sulphamide; derived from, or related to, a sulphamide; specifically, designating an amido acid derivative, NH2.","pos":""}],"SULPHAMIDE":[{"def":"Any one of a series of amido compounds obtained by treating sulphuryl chloride with various amines.","pos":""}],"SULPHANILIC":[{"def":"Of, pertaining to, or designating, an anilene sulphonic acid which is obtained as a white crystalline substance.","pos":""}],"SULPHANTIMONATE":[{"def":"A salt of sulphantimonic acid.","pos":""}],"SULPHANTIMONIC":[{"def":"Of, pertaining to, or designating, a hypothetical sulphacid of antimony (called also thioantimonic acid) analogous to sulpharsenic acid.","pos":""}],"SULPHANTIMONIOUS":[{"def":"Of, pertaining to, or designating, a hypothetical sulphacid of antimony (called also thioantimonious acid) analogous to sulpharsenious acid.","pos":""}],"SULPHANTIMONITE":[{"def":"A salt of sulphantimonious acid.","pos":""}],"SULPHARSENATE":[{"def":"A salt of sulpharsenic acid.","pos":""}],"SULPHARSENIC":[{"def":"Of, pertaining to, or designating, a hypothetical sulphacid (called also thioarsenic acid) analogous to arsenic acid, and known only in its salts.","pos":""}],"SULPHARSENIOUS":[{"def":"Of, pertaining to, or designating, a hypothetical sulphacid (called also thioarsenious acid) analogous to arsenious acid, and known only in its salts.","pos":""}],"SULPHARSENITE":[{"def":"A salt of sulpharsenious acid.","pos":""}],"SULPHATE":[{"def":"A salt of sulphuric acid.","pos":""}],"SULPHATIC":[{"def":"Of, pertaining to, resembling, or containing, a sulphate or sulphates.","pos":""}],"SULPHATO-":[{"def":"A combining form (also used adjectively) denoting a sulphate as an ingredient in certain double salts; as, sulphato-carbonate.","pos":""}],"SULPHAURATE":[{"def":"A salt of sulphauric acid.","pos":""}],"SULPHAURIC":[{"def":"Of, pertaining to, or designating, a hypothetical sulphacid of gold (aurum), known only in its salts.","pos":""}],"SULPHIDE":[{"def":"A binary compound of sulphur, or one so regarded; -- formerly called sulphuret.","pos":""}],"SULPHINATE":[{"def":"A salt of a sulphinic acid.","pos":""}],"SULPHINDIGOTIC":[{"def":"Of, pertaining to, or designating, a sulphonic acid obtained, as a blue solution, by dissolving indigo in sulphuric acid; -- formerly called also cerulic sulphuric acid, but properly called indigo-disulphonic acid.","pos":""}],"SULPHINE":[{"def":"Any one of a series of basic compounds which consist essentially of sulphur united with hydrocarbon radicals.","pos":""}],"SULPHINIC":[{"def":"Of, pertaining to, or designating, any one of a series of acids regarded as acid ethereal salts of hyposulphurous acid; as, methyl sulphinic acid, CH3.","pos":""}],"SULPHINIDE":[{"def":"A white or yellowish crystalline substance, C6H4.","pos":""}],"SULPHION":[{"def":"A hypothetical radical, SO4, regarded as forming the acid or negative constituent of sulphuric acid and the sulphates in electrolytic decomposition; -- so called in accordance with the binary theory of salts.","pos":""}],"SULPHIONIDE":[{"def":"A binary compound of sulphion, or one so regarded; thus, sulphuric acid, Hsulphionide.","pos":""}],"SULPHITE":[{"def":"A salt of sulphurous acid.","pos":""}],"SULPHO-":[{"def":"A prefix (also used adjectively) designating sulphur as an ingredient in certain compounds.","pos":""}],"SULPHOARSENIC":[{"def":"Of, pertaining to, or containing, sulphur and arsenic; -- said of an acid which is the same as arsenic acid with the substitution of sulphur for oxygen.","pos":""}],"SULPHOCARBONATE":[{"def":"A salt of sulphocarbonic acid; a thiocarbonate.","pos":""}],"SULPHOCARBONIC":[{"def":"Of, pertaining to, or designating, a sulphacid, H2CSO2 (called also thiocarbonic acid), or an acid, H2CS3, analogous to carbonic acid, obtained as a yellow oily liquid of a pungent odor, and forming salts.","pos":""}],"SULPHOCYANATE":[{"def":"A salt of sulphocyanic acid; -- also called thiocyanate, and formerly inaccurately sulphocyanide.","pos":""}],"SULPHOCYANIC":[{"def":"Of, pertaining to, derived from, or designating, a sulphacid, HSCN, analogous to cyanic acid, and obtained as a colorless deliquescent crystalline substance, having a bitter saline taste, and not poisonous.","pos":""}],"SULPHOCYANIDE":[{"def":"See Sulphocyanate.","pos":""}],"SULPHOCYANOGEN":[{"def":"See Persulphocyanogen.","pos":""}],"SULPHONAL":[{"def":"A substance employed as a hypnotic, produced by the union of mercaptan and acetone.","pos":""}],"SULPHONATE":[{"def":"A salt of sulphonic acid.","pos":""}],"SULPHONE":[{"def":"Any one of a series of compounds analogous to the ketones, and consisting of the sulphuryl group united with two hydrocarbon radicals; as, dimethyl sulphone, (CH.","pos":""}],"SULPHONIUM":[{"def":"A hypothetical radical, SH3, regarded as the type and nucleus of the sulphines.","pos":""}],"SULPHOPHOSPHATE":[{"def":"A salt of sulphophosphoric acid.","pos":""}],"SULPHOPHOSPHITE":[{"def":"A salt of sulphophosphorous acid.","pos":""}],"SULPHOPHOSPHORIC":[{"def":"Of, pertaining to, or designating, a hypothetical sulphacid of phosphorus, analogous to phosphoric acid, and known in its salts.","pos":""}],"SULPHOPHOSPHOROUS":[{"def":"Of, pertaining to, or designating, a hypothetical acid of phosphorus, analogous to phosphorous acid, and known in its salts.","pos":""}],"SULPHOSALT":[{"def":"A salt of a sulphacid.","pos":""}],"SULPHOSTANNATE":[{"def":"A salt of sulphostannic acid.","pos":""}],"SULPHOTUNGSTATE":[{"def":"A salt of sulphotungstic acid.","pos":""}],"SULPHOTUNGSTIC":[{"def":"Of, pertaining to, or designating, hypothetical sulphacid of tungsten (called also sulphowolframic acid), analogous to sulphuric acid, and known in its salts.","pos":""}],"SULPHOVINIC":[{"def":"Of, pertaining to, and formerly designating, ethylsulphuric acid.","pos":""}],"SULPHUR":[{"def":"A nonmetallic element occurring naturally in large quantities, either combined as in the sulphides (as pyrites) and sulphates (as gypsum), or native in volcanic regions, in vast beds mixed with gypsum and various earthy materials, from which it is melted out.","pos":""},{"def":"Any one of numerous species of yellow or orange butterflies of the subfamily Pierinæ; as, the clouded sulphur (Eurymus, or Colias, philodice), which is the common yellow butterfly of the Eastern United States.","pos":""}],"SULPHUR-BOTTOM":[{"def":"A very large whalebone whale of the genus Sibbaldius, having a yellowish belly; especially, S.","pos":""}],"SULPHURATION":[{"def":"The act or process of combining or impregnating with sulphur or its compounds; also, the state of being so combined or impregnated.","pos":""}],"SULPHURATOR":[{"def":"An apparatus for impregnating with, or exposing to the action of, sulphur; especially, an apparatus for fumigating or bleaching by means of the fumes of burning sulphur.","pos":""}],"SULPHUREITY":[{"def":"The quality or state of being sulphureous.","pos":""}],"SULPHUREOUS":[{"def":"Consisting of sulphur; having the qualities of sulphur, or brimstone; impregnated with sulphur.","pos":""}],"SULPHURET":[{"def":"A sulphide; as, a sulphuret of potassium.","pos":""}],"SULPHURETED":[{"def":"Combined or impregnated with sulphur; sulphurized.","pos":""}],"SULPHURIC":[{"def":"Derived from, or containing, sulphur; specifically, designating those compounds in which the element has a higher valence as contrasted with the sulphurous compounds; as, sulphuric acid.","pos":""}],"SULPHURING":[{"def":"Exposure to the fumes of burning sulphur, as in bleaching; the process of bleaching by exposure to the fumes of sulphur.","pos":""}],"SULPHURIZE":[{"def":"To combine or impregnate with sulphur or any of its compounds; as, to sulphurize caoutchouc in vulcanizing.","pos":""}],"SULPHUROUS":[{"def":"Of or pertaining to sulphur.","pos":""}],"SULPHURWORT":[{"def":"The hog's fennel.","pos":""}],"SULPHURY":[{"def":"Resembling, or partaking of the nature of, sulphur; having the qualities of sulphur.","pos":""}],"SULPHURYL":[{"def":"The hypothetical radical SO2; -- called also sulphon.","pos":""}],"SULPHYDRATE":[{"def":"A compound, analogous to a hydrate, regarded as a salt of sulphydric acid, or as a derivative of hydrogen sulphide in which one half of the hydrogen is replaced by a base (as potassium sulphydrate, KSH), or as a hydrate in which the oxygen has been wholly or partially replaced by sulphur.","pos":""}],"SULPHYDRIC":[{"def":"Of, pertaining to, or designating, hydrogen sulphide, which is regarded as an acid, especially when in solution.","pos":""}],"SULPICIAN":[{"def":"One of an order of priests established in France in 1642 to educate men for the ministry.","pos":""}],"SULTAN":[{"def":"A ruler, or sovereign, of a Mohammedan state; specifically, the ruler of the Turks; the Padishah, or Grand Seignior; -- officially so called.","pos":""}],"SULTAN-RED":[{"def":"Having a deep red color.","pos":""}],"SULTANA":[{"def":"A kind of seedless raisin produced near Smyrna in Asiatic Turkey.","pos":""}],"SULTANATE":[{"def":"The rule or dominion of a sultan; sultanship.","pos":""}],"SULTANIC":[{"def":"Pertaining to a sultan.","pos":""}],"SULTANRY":[{"def":"The dominions of a sultan.","pos":""}],"SULTANSHIP":[{"def":"The office or dignity of a sultan.","pos":""}],"SULTRILY":[{"def":"In a sultry manner.","pos":""}],"SULTRINESS":[{"def":"The quality or state of being sultry.","pos":""}],"SULTRY":[{"def":"Very hot, burning, and oppressive; as, Libya's sultry deserts.","pos":""},{"def":"Very hot and moist, or hot, close, stagnant, and oppressive, as air.","pos":""}],"SULU":[{"def":"A member of the most prominent tribe of the Moro tribes, occupying the Sulu Archipelago; also, their language.","pos":""}]}