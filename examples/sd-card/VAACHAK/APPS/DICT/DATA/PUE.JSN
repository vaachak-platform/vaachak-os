{"PUE":[{"def":"To make a low whistling sound; to chirp, as birds.","pos":""}],"PUEBLO":[{"def":"A communistic building erected by certain Indian tribes of Arizona and New Mexico.","pos":""}],"PUER":[{"def":"The dung of dogs, used as an alkaline steep in tanning.","pos":""}],"PUERCO":[{"def":"New Mexico, along the Rio Puerco, and are characterized by their mammalian remains.","pos":""}],"PUERILE":[{"def":"Boyish; childish; trifling; silly.","pos":""}],"PUERILELY":[{"def":"In a puerile manner; childishly.","pos":""}],"PUERILENESS":[{"def":"The quality of being puerile; puerility.","pos":""}],"PUERILITY":[{"def":"The quality of being puerile; childishness; puerileness.","pos":""},{"def":"That which is puerile or childish; especially, an expression which is flat, insipid, or silly.","pos":""}],"PUERPERAL":[{"def":"Of or pertaining to childbirth; as, a puerperal fever.","pos":""}],"PUERPEROUS":[{"def":"Bearing children.","pos":""}]}