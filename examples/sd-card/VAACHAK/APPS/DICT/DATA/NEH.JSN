{"NEHILOTH":[{"def":"A term supposed to mean, perforated wind instruments of music, as pipes or flutes.","pos":""}],"NEHUSHTAN":[{"def":"A thing of brass; -- the name under which the Israelites worshiped the brazen serpent made by Moses.","pos":""},{"def":"A woman born in the state of villeinage; a female serf.","pos":""}]}