{"RECK":[{"def":"To make account of; to care for; to heed; to regard.","pos":""},{"def":"To concern; -- used impersonally.","pos":""}],"RECKLESS":[{"def":"Inattentive to duty; careless; neglectful; indifferent.","pos":""},{"def":"Rashly negligent; utterly careless or heedless.","pos":""}],"RECKLING":[{"def":"Needing care; weak; feeble; as, a reckling child.","pos":""},{"def":"A weak child or animal.","pos":""}],"RECKON":[{"def":"To count; to enumerate; to number; also, to compute; to calculate.","pos":""},{"def":"To count as in a number, rank, or series; to estimate by rank or quality; to place by estimation; to account; to esteem; to repute.","pos":""}],"RECKONER":[{"def":"One who reckons or computes; also, a book of calculation, tables, etc.","pos":""}],"RECKONING":[{"def":"The act of one who reckons, counts, or computes; the result of reckoning or counting; calculation.","pos":""},{"def":"The charge or account made by a host at an inn.","pos":""}]}