{"FOREBEAM":[{"def":"The breast beam of a loom.","pos":""}],"FOREBODE":[{"def":"To be prescient of (some ill or misfortune); to have an inward conviction of, as of a calamity which is about to happen; to augur despondingly.","pos":""}],"FOREBODEMENT":[{"def":"The act of foreboding; the thing foreboded.","pos":""}],"FOREBODER":[{"def":"One who forebodes.","pos":""}],"FOREBODING":[{"def":"Presage of coming ill; expectation of misfortune.","pos":""}],"FOREBODINGLY":[{"def":"In a foreboding manner.","pos":""}],"FOREBRACE":[{"def":"A rope applied to the fore yardarm, to change the position of the foresail.","pos":""}],"FOREBRAIN":[{"def":"The anterior of the three principal divisions of the brain, including the prosencephalon and thalamencephalon.","pos":""}],"FOREBY":[{"def":"Near; hard by; along; past.","pos":""}]}