{"BIB":[{"def":"An arctic fish (Gadus luscus), allied to the cod; -- called also pout and whiting pout.","pos":""},{"def":"To drink; to tipple.","pos":""}],"BIBACIOUS":[{"def":"Addicted to drinking.","pos":""}],"BIBACITY":[{"def":"The practice or habit of drinking too much; tippling.","pos":""}],"BIBASIC":[{"def":"Having to hydrogen atoms which can be replaced by positive or basic atoms or radicals to form salts; -- said of acids.","pos":""}],"BIBBER":[{"def":"One given to drinking alcoholic beverages too freely; a tippler; -- chiefly used in composition; as, winebibber.","pos":""}],"BIBBLE-BABBLE":[{"def":"Idle talk; babble.","pos":""}],"BIBBS":[{"def":"Pieces of timber bolted to certain parts of a mast tp support the trestletrees.","pos":""}],"BIBCOCK":[{"def":"A cock or faucet having a bent down nozzle.","pos":""}],"BIBELOT":[{"def":"A small decorative object without practical utility.","pos":""}],"BIBITORY":[{"def":"Of or pertaining to drinking or tippling.","pos":""}],"BIBLE":[{"def":"A book with an authoritative exposition of some topic, respected by many experts on the field.","pos":""}],"BIBLER":[{"def":"A great drinker; a tippler.","pos":""}],"BIBLICAL":[{"def":"Pertaining to, or derived from, the Bible; as, biblical learning; biblical authority.","pos":""}],"BIBLICALITY":[{"def":"The quality of being biblical; a biblical subject.","pos":""}],"BIBLICALLY":[{"def":"According to the Bible.","pos":""}],"BIBLICISM":[{"def":"Learning or literature relating to the Bible.","pos":""}],"BIBLICIST":[{"def":"One skilled in the knowledge of the Bible; a demonstrator of religious truth by the Scriptures.","pos":""}],"BIBLIOGRAPHER":[{"def":"One who writes, or is versed in, bibliography.","pos":""},{"def":"Pertaining to bibliography, or the history of books.","pos":""}],"BIBLIOGRAPHY":[{"def":"A history or description of books and manuscripts, with notices of the different editions, the times when they were printed, etc.","pos":""},{"def":"A worshiper of books; especially, a worshiper of the Bible; a believer in its verbal inspiration.","pos":""}],"BIBLIOLATRY":[{"def":"Book worship, esp.","pos":""}],"BIBLIOLOGICAL":[{"def":"Relating to bibliology.","pos":""}],"BIBLIOLOGY":[{"def":"An account of books; book lore; bibliography.","pos":""},{"def":"The literature or doctrine of the Bible.","pos":""}],"BIBLIOMANCY":[{"def":"A kind of divination, performed by selecting passages of Scripture at hazard, and drawing from them indications concerning future events.","pos":""}],"BIBLIOMANIA":[{"def":"A mania for acquiring books.","pos":""}],"BIBLIOMANIAC":[{"def":"One who has a mania for books.","pos":""},{"def":"Relating to a bibliomaniac.","pos":""}],"BIBLIOMANIACAL":[{"def":"Pertaining to a passion for books; relating to a bibliomaniac.","pos":""}],"BIBLIOPEGIC":[{"def":"Relating to the binding of books.","pos":""}],"BIBLIOPEGISTIC":[{"def":"Pertaining to the art of binding books.","pos":""}],"BIBLIOPEGY":[{"def":"The art of binding books.","pos":""}],"BIBLIOPHILE":[{"def":"A lover of books.","pos":""}],"BIBLIOPHILIST":[{"def":"A lover of books.","pos":""}],"BIBLIOPHOBIA":[{"def":"A dread of books.","pos":""}],"BIBLIOPOLE":[{"def":"One who sells books.","pos":""},{"def":"Of or pertaining to the sale of books.","pos":""}],"BIBLIOPOLISM":[{"def":"The trade or business of selling books.","pos":""}],"BIBLIOPOLIST":[{"def":"Same as Bibliopole.","pos":""}],"BIBLIOPOLISTIC":[{"def":"Of or pertaining to bibliopolism.","pos":""},{"def":"One who hides away books, as in a tomb.","pos":""}],"BIBLIOTHECAL":[{"def":"Belonging to a library.","pos":""}],"BIBLIOTHECARY":[{"def":"Bib`li*oth\"e*ca*ry, n.","pos":""}],"BIBLIST":[{"def":"One who makes the Bible the sole rule of faith.","pos":""},{"def":"A biblical scholar; a biblicist.","pos":""}],"BIBRACTEATE":[{"def":"Furnished with, or having, two bracts.","pos":""}],"BIBULOUS":[{"def":"Readily imbibing fluids or moisture; spongy; as, bibulous blotting paper.","pos":""},{"def":"Inclined to drink; addicted to tippling.","pos":""}],"BIBULOUSLY":[{"def":"In a bibulous manner; with profuse imbibition or absorption.","pos":""}]}