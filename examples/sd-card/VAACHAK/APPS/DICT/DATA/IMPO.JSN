{"IMPOISON":[{"def":"To poison; to imbitter; to impair.","pos":""}],"IMPOISONMENT":[{"def":"The act of poisoning or impoisoning.","pos":""},{"def":"Not according to or in, the direction of the poles.","pos":""}],"IMPOLICY":[{"def":"The quality of being impolitic; inexpedience; unsuitableness to the end proposed; bads policy; as, the impolicy of fraud.","pos":""}],"IMPOLITE":[{"def":"Not polite; not of polished manners; wanting in good manners; discourteous; uncivil; rude.","pos":""}],"IMPOLITIC":[{"def":"Not politic; contrary to, or wanting in, policy; unwise; imprudent; indiscreet; inexpedient; as, an impolitic ruler, law, or measure.","pos":""}],"IMPOLITICLY":[{"def":"In an impolitic manner.","pos":""}],"IMPOLITICNESS":[{"def":"The quality of being impolitic.","pos":""}],"IMPONDERABILITY":[{"def":"The quality or state of being imponderable; imponderableness.","pos":""}],"IMPONDERABLE":[{"def":"Not ponderable; without sensible or appreciable weight; incapable of being weighed.","pos":""}],"IMPONDERABLENESS":[{"def":"The quality or state of being imponderable.","pos":""}],"IMPONE":[{"def":"To stake; to wager; to pledge.","pos":""}],"IMPOROSITY":[{"def":"The state or quality of being imporous; want of porosity; compactness.","pos":""}],"IMPOROUS":[{"def":"Destitute of pores; very close or compact in texture; solid.","pos":""}],"IMPORT":[{"def":"To bring in from abroad; to introduce from without; especially, to bring (wares or merchandise) into a place or country from a foreign country, in the transactions of commerce; -- opposed to export.","pos":""},{"def":"To carry or include, as meaning or intention; to imply; to signify.","pos":""}],"IMPORTABLE":[{"def":"Capable of being imported.","pos":""}],"IMPORTANCE":[{"def":"The quality or state of being important; consequence; weight; moment; significance.","pos":""},{"def":"Subject; matter.","pos":""}],"IMPORTANCY":[{"def":"Importance; significance; consequence; that which is important.","pos":""}],"IMPORTANT":[{"def":"Full of, or burdened by, import; charged with great interests; restless; anxious.","pos":""},{"def":"Carrying or possessing weight or consequence; of valuable content or bearing; significant; weighty.","pos":""}],"IMPORTANTLY":[{"def":"In an important manner.","pos":""}],"IMPORTATION":[{"def":"The act of carrying, conveying, or delivering.","pos":""},{"def":"The act or practice of importing, or bringing into a country or state; -- opposed to exportation.","pos":""}],"IMPORTER":[{"def":"One who imports; the merchant who brings goods into a country or state; -- opposed to exporter.","pos":""}],"IMPORTING":[{"def":"Full of meaning.","pos":""}],"IMPORTLESS":[{"def":"Void of meaning.","pos":""}],"IMPORTUNABLE":[{"def":"Heavy; insupportable.","pos":""}],"IMPORTUNACY":[{"def":"The quality of being importunate; importunateness.","pos":""}],"IMPORTUNATE":[{"def":"Troublesomely urgent; unreasonably solicitous; overpressing in request or demand; urgent; teasing; as, an impotunate petitioner, curiosity.","pos":""},{"def":"Hard to be borne; unendurable.","pos":""}],"IMPORTUNATOR":[{"def":"One who importunes; an importuner.","pos":""}],"IMPORTUNE":[{"def":"Inopportune; unseasonable.","pos":""},{"def":"Troublesome; vexatious; persistent; urgent; hence, vexatious on account of untimely urgency or perinacious solicitation.","pos":""}],"IMPORTUNELY":[{"def":"In an importune manner.","pos":""}],"IMPORTUNER":[{"def":"One who importunes.","pos":""}],"IMPORTUNITY":[{"def":"The quality of being importunate; pressing or pertinacious solicitation; urgent request; incessant or frequent application; troublesome pertinacity.","pos":""}],"IMPORTUOUS":[{"def":"Without a port or harbor.","pos":""}],"IMPOSABLE":[{"def":"Capable of being imposed or laid on.","pos":""}],"IMPOSABLENESS":[{"def":"Quality of being imposable.","pos":""}],"IMPOSE":[{"def":"To lay on, as the hands, in the religious rites of confirmation and ordination.","pos":""},{"def":"To arrange in proper order on a table of stone or metal and lock up in a chase for printing; -- said of columns or pages of type, forms, etc.","pos":""}],"IMPOSER":[{"def":"One who imposes.","pos":""}],"IMPOSING":[{"def":"Laying as a duty; enjoining.","pos":""},{"def":"Adapted to impress forcibly; impressive; commanding; as, an imposing air; an imposing spectacle.","pos":""}],"IMPOSINGLY":[{"def":"In an imposing manner.","pos":""}],"IMPOSINGNESS":[{"def":"The quality of being imposing.","pos":""}],"IMPOSITION":[{"def":"An extra exercise enjoined on students as a punishment.","pos":""},{"def":"The act of laying on the hands as a religious ceremoy, in ordination, confirmation, etc.","pos":""}],"IMPOSSIBILITY":[{"def":"The quality of being impossible; impracticability.","pos":""},{"def":"An impossible thing; that which can not be thought, done, or endured.","pos":""}],"IMPOSSIBLE":[{"def":"Not possible; incapable of being done, of existing, etc.","pos":""}],"IMPOST":[{"def":"The top member of a pillar, pier, wall, etc.","pos":""}],"IMPOSTHUMATE":[{"def":"To apostemate; to form an imposthume or abscess.","pos":""}],"IMPOSTHUMATION":[{"def":"The act of forming an abscess; state of being inflamed; suppuration.","pos":""},{"def":"An abscess; an imposthume.","pos":""}],"IMPOSTHUME":[{"def":"A collection of pus or purulent matter in any part of an animal body; an abscess.","pos":""}],"IMPOSTOR":[{"def":"One who imposes upon others; a person who assumes a character or title not his own, for the purpose of deception; a pretender.","pos":""}],"IMPOSTORSHIP":[{"def":"The condition, character, or practice of an impostor.","pos":""},{"def":"A woman who imposes upon or deceives others.","pos":""}],"IMPOSTROUS":[{"def":"Characterized by imposture; deceitful.","pos":""}],"IMPOSTURAGE":[{"def":"Imposture; cheating.","pos":""}],"IMPOSTURE":[{"def":"The act or conduct of an impostor; deception practiced under a false or assumed character; fraud or imposition; cheating.","pos":""}],"IMPOSTURED":[{"def":"Done by imposture.","pos":""}],"IMPOSTUROUS":[{"def":"Impostrous; deceitful.","pos":""}],"IMPOSTURY":[{"def":"Want of procreative power; inability to copulate, or beget children; also, sometimes, sterility; barrenness.","pos":""}],"IMPOTENT":[{"def":"Wanting the power of procreation; unable to copulate; also, sometimes, sterile; barren.","pos":""}],"IMPOTENTLY":[{"def":"In an impotent manner.","pos":""}],"IMPOUND":[{"def":"To shut up or place in an inclosure called a pound; hence, to hold in the custody of a court; as, to impound stray cattle; to impound a document for safe keeping.","pos":""}],"IMPOUNDAGE":[{"def":"The act of impounding, or the state of being impounded.","pos":""},{"def":"The fee or fine for impounding.","pos":""}],"IMPOUNDER":[{"def":"One who impounds.","pos":""}],"IMPOVERISH":[{"def":"To make poor; to reduce to poverty or indigence; as, misfortune and disease impoverish families.","pos":""},{"def":"To exhaust the strength, richness, or fertility of; to make sterile; as, to impoverish land.","pos":""}],"IMPOVERISHER":[{"def":"One who, or that which, impoverishes.","pos":""}],"IMPOVERISHMENT":[{"def":"The act of impoverishing, or the state of being impoverished; reduction to poverty.","pos":""}]}