{"CHASABLE":[{"def":"Capable of being chased; fit for hunting.","pos":""}],"CHASE":[{"def":"To pursue for the purpose of killing or taking, as an enemy, or game; to hunt.","pos":""},{"def":"To follow as if to catch; to pursue; to compel to move on; to drive by following; to cause to fly; -- often with away or off; as, to chase the hens away.","pos":""}],"CHASER":[{"def":"Same as Chase gun, esp.","pos":""}],"CHASING":[{"def":"The art of ornamenting metal by means of chasing tools; also, a piece of ornamental work produced in this way.","pos":""}],"CHASM":[{"def":"A deep opening made by disruption, as a breach in the earth or a rock; a yawning abyss; a cleft; a fissure.","pos":""},{"def":"A void space; a gap or break, as in ranks of men.","pos":""}],"CHASMED":[{"def":"Having gaps or a chasm.","pos":""}],"CHASMY":[{"def":"Of or pertaining to a chasm; abounding in chasms.","pos":""}],"CHASSE":[{"def":"A movement in dancing, as across or to the right or left.","pos":""}],"CHASSE-MAREE":[{"def":"A French coasting lugger.","pos":""}],"CHASSELAS":[{"def":"A white grape, esteemed for the table.","pos":""}],"CHASSEPOT":[{"def":"A kind of breechloading, center-fire rifle, or improved needle gun.","pos":""}],"CHASSEUR":[{"def":"One of a body of light troops, cavalry or infantry, trained for rapid movements.","pos":""}],"CHASSIS":[{"def":"A traversing base frame, or movable railway, along which the carriage of a barbette or casemate gum moves backward and forward.","pos":""}],"CHASTE":[{"def":"Pure from unlawful sexual intercourse; virtuous; continent.","pos":""},{"def":"Pure in thought and act; innocent; free from lewdness and obscenity, or indecency in act or speech; modest; as, a chaste mind; chaste eyes.","pos":""}],"CHASTELY":[{"def":"In a chaste manner; with purity.","pos":""}],"CHASTEN":[{"def":"To correct by punishment; to inflict pain upon the purpose of reclaiming; to discipline; as, to chasten a son with a rod.","pos":""},{"def":"To purify from errors or faults; to refine.","pos":""}],"CHASTENED":[{"def":"Corrected; disciplined; refined; purified; toned down.","pos":""}],"CHASTENER":[{"def":"One who chastens.","pos":""}],"CHASTENESS":[{"def":"Freedom from all that is meretricious, gaundy, or affected; as, chasteness of design.","pos":""}],"CHASTISABLE":[{"def":"Capable or deserving of chastisement; punishable.","pos":""}],"CHASTISE":[{"def":"To inflict pain upon, by means of stripes, or in any other manner, for the purpose of punishment or reformation; to punish, as with stripes.","pos":""},{"def":"To reduce to order or obedience; to correct or purify; to free from faults or excesses.","pos":""}],"CHASTISEMENT":[{"def":"The act of chastising; pain inflicted for punishment and correction; discipline; punishment.","pos":""}],"CHASTISER":[{"def":"One who chastises; a punisher; a corrector.","pos":""}],"CHASTITY":[{"def":"The state of being chaste; purity of body; freedom from unlawful sexual intercourse.","pos":""}],"CHASUBLE":[{"def":"The outer vestment worn by the priest in saying Mass, consisting, in the Roman Catholic Church, of a broad, flat, back piece, and a narrower front piece, the two connected over the shoulders only.","pos":""}]}