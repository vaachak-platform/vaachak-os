{"CONFIDE":[{"def":"To put faith (in); to repose confidence; to trust; -- usually followed by in; as, the prince confides in his ministers.","pos":""}],"CONFIDENCE":[{"def":"The act of confiding, trusting, or putting faith in; trust; reliance; belief; -- formerly followed by of, now commonly by in.","pos":""},{"def":"That in which faith is put or reliance had.","pos":""}],"CONFIDENTIAL":[{"def":"Enjoying, or treated with, confidence; trusted in; trustworthy; as, a confidential servant or clerk.","pos":""},{"def":"Communicated in confidence; secret.","pos":""}],"CONFIDENTIALLY":[{"def":"In confidence; in reliance on secrecy.","pos":""}],"CONFIDENTLY":[{"def":"With confidence; with strong assurance; positively.","pos":""}],"CONFIDENTNESS":[{"def":"The quality of being confident.","pos":""}],"CONFIDER":[{"def":"One who confides.","pos":""}],"CONFIDING":[{"def":"That confides; trustful; unsuspicious.","pos":""}],"CONFIGURATE":[{"def":"To take form or position, as the parts of a complex structure; to agree with a pattern.","pos":""}],"CONFIGURATION":[{"def":"Relative position or aspect of the planets; the face of the horoscope, according to the relative positions of the planets at any time.","pos":""}],"CONFIGURE":[{"def":"To arrange or dispose in a certain form, figure, or shape.","pos":""}],"CONFINABLE":[{"def":"Capable of being confined, restricted, or limited.","pos":""}],"CONFINE":[{"def":"To restrain within limits; to restrict; to limit; to bound; to shut up; to inclose; to keep close.","pos":""}],"CONFINELESS":[{"def":"Without limitation or end; boundless.","pos":""}],"CONFINEMENT":[{"def":"Restraint within limits; imprisonment; any restraint of liberty; seclusion.","pos":""},{"def":"Restraint within doors by sickness, esp.","pos":""}],"CONFINER":[{"def":"One who, or that which, limits or restrains.","pos":""}],"CONFINITY":[{"def":"Community of limits; contiguity.","pos":""}],"CONFIRM":[{"def":"To administer the rite of confirmation to.","pos":""}],"CONFIRMABLE":[{"def":"That may be confirmed.","pos":""}],"CONFIRMATION":[{"def":"A rite supplemental to baptism, by which a person is admitted, through the laying on of the hands of a bishop, to the full privileges of the church, as in the Roman Catholic, the Episcopal Church, etc.","pos":""},{"def":"A conveyance by which a voidable estate is made sure and not voliable, or by which a particular estate is increased; a contract, express or implied, by which a person makes that firm and binding which was before voidable.","pos":""}],"CONFIRMATIVE":[{"def":"Tending confirm or establish.","pos":""}],"CONFIRMATOR":[{"def":"One who, or that which, confirms; a confirmer.","pos":""}],"CONFIRMATORY":[{"def":"Serving to confirm; corroborative.","pos":""}],"CONFIRMEDLY":[{"def":"With confirmation.","pos":""}],"CONFIRMEE":[{"def":"One to whom anuthing is confirmed.","pos":""}],"CONFIRMER":[{"def":"One who, or that which, confirms, establishes, or ratifies; one who corroborates.","pos":""}],"CONFIRMINGLY":[{"def":"In a confirming manner.","pos":""}],"CONFISCABLE":[{"def":"Capable of being confiscated; liable to forfeiture.","pos":""}],"CONFISCATE":[{"def":"Seized and appropriated by the government to the public use; forfeited.","pos":""}],"CONFISCATION":[{"def":"The act or process of taking property or condemning it to be taken, as forfeited to the public use.","pos":""}],"CONFISCATOR":[{"def":"One who confiscates.","pos":""}],"CONFISCATORY":[{"def":"Effecting confiscation; characterized by confiscations.","pos":""}],"CONFITENT":[{"def":"One who confesses his sins and faults.","pos":""}],"CONFITEOR":[{"def":"A form of prayer in which public confession of sins is made.","pos":""}],"CONFITURE":[{"def":"The state or quality of being congenial; natural affinity; adaptation; suitableness.","pos":""}],"CONFIX":[{"def":"To fix; to fasten.","pos":""}],"CONFIXURE":[{"def":"Act of fastening.","pos":""}]}