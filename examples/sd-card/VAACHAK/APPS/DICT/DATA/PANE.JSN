{"PANE":[{"def":"The narrow edge of a hammer head.","pos":""}],"PANED":[{"def":"Having flat sides or surfaces; as, a sixpaned nut.","pos":""}],"PANEGYRIC":[{"def":"An oration or eulogy in praise of some person or achievement; a formal or elaborate encomium; a laudatory discourse; laudation.","pos":""},{"def":"Containing praise or eulogy; encomiastic; laudatory.","pos":""}],"PANEGYRIS":[{"def":"A festival; a public assembly.","pos":""}],"PANEGYRIST":[{"def":"One who delivers a panegyric; a eulogist; one who extols or praises, either by writing or speaking.","pos":""}],"PANEGYRIZE":[{"def":"To praise highly; to extol in a public speech; to write or deliver a panegyric upon; to eulogize.","pos":""}],"PANEL":[{"def":"A sunken compartment with raised margins, molded or otherwise, as in ceilings, wainscotings, etc.","pos":""},{"def":"A board having its edges inserted in the groove of a surrounding frame; as, the panel of a door.","pos":""}],"PANELATION":[{"def":"The act of impaneling a jury.","pos":""}],"PANELESS":[{"def":"To patch his paneless window.","pos":""}],"PANELING":[{"def":"A forming in panels; panelwork.","pos":""}],"PANEULOGISM":[{"def":"Eulogy of everything; indiscriminate praise.","pos":""}]}