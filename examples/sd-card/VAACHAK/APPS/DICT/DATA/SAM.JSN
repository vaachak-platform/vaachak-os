{"SAMARA":[{"def":"A dry, indehiscent, usually one-seeded, winged fruit, as that of the ash, maple, and elm; a key or key fruit.","pos":""}],"SAMARITAN":[{"def":"Of or pertaining to Samaria, in Palestine.","pos":""},{"def":"A native or inhabitant of Samaria; also, the language of Samaria.","pos":""}],"SAMARIUM":[{"def":"A rare metallic element of doubtful identity.","pos":""}],"SAMAROID":[{"def":"Resembling a samara, or winged seed vessel.","pos":""}],"SAMARSKITE":[{"def":"A rare mineral having a velvet-black color and submetallic luster.","pos":""}],"SAMBO":[{"def":"A colloquial or humorous appelation for a negro; sometimes, the offspring of a black person and a mulatto; a zambo.","pos":""}],"SAMBUCUS":[{"def":"A genus of shrubs and trees; the elder.","pos":""}],"SAMBUKE":[{"def":"An ancient stringed instrument used by the Greeks, the particular construction of which is unknown.","pos":""}],"SAMBUR":[{"def":"An East Indian deer (Rusa Aristotelis) having a mane on its neck.","pos":""}],"SAME":[{"def":"Not different or other; not another or others; identical; unchanged.","pos":""},{"def":"Of like kind, species, sort, dimensions, or the like; not differing in character or in the quality or qualities compared; corresponding; not discordant; similar; like.","pos":""}],"SAMENESS":[{"def":"The state of being the same, identity; abscence of difference; near resemblance; correspondence; similarity; as, a sameness of person, of manner, of sound, of appearance, and the like.","pos":""},{"def":"Hence, want of variety; tedious monotony.","pos":""}],"SAMIAN":[{"def":"Of or pertaining to the island of Samos.","pos":""}],"SAMIEL":[{"def":"A hot and destructive wind that sometimes blows, in Turkey, from the desert.","pos":""}],"SAMISEN":[{"def":"A Japanese musical instrument with three strings, resembling a guitar or banjo.","pos":""}],"SAMITE":[{"def":"A species of silk stuff, or taffeta, generally interwoven with gold.","pos":""}],"SAMMIER":[{"def":"A machine for pressing the water from skins in tanning.","pos":""}],"SAMOAN":[{"def":"Of or pertaining to the Samoan Islands (formerly called Navigators' Islands) in the South Pacific Ocean, or their inhabitants.","pos":""},{"def":"An inhabitant of the Samoan Islands.","pos":""}],"SAMOVAR":[{"def":"A metal urn used in Russia for making tea.","pos":""}],"SAMOYEDES":[{"def":"An ignorant and degraded Turanian tribe which occupies a portion of Northern Russia and a part of Siberia.","pos":""}],"SAMP":[{"def":"An article of food consisting of maize broken or bruised, which is cooked by by boiling, and usually eaten with milk; coarse hominy.","pos":""}],"SAMPAN":[{"def":"A Chinese boat from twelve to fifteen feet long, covered with a house, and sometimes used as a permanent habitation on the inland waters.","pos":""}],"SAMPHIRE":[{"def":"Sam\"phire ( or ; 277), n.","pos":""}],"SAMPLE":[{"def":"Example; pattern.","pos":""},{"def":"A part of anything presented for inspection, or shown as evidence of the quality of the whole; a specimen; as, goods are often purchased by samples.","pos":""}],"SAMPLER":[{"def":"A spirituous liquor distilled by the Chinese from the yeasty liquor in which boiled rice has fermented under pressure.","pos":""}],"SAMSON":[{"def":"An Israelite of Bible record (see Judges xiii.","pos":""}],"SAMURAI":[{"def":"In the former feudal system of Japan, the class or a member of the class, of military retainers of the daimios, constituting the gentry or lesser nobility.","pos":""}]}