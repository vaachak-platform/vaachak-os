{"TOW":[{"def":"The coarse and broken part of flax or hemp, separated from the finer part by the hatchel or swingle.","pos":"verb"}],"TOW-HEAD":[{"def":"The hooded merganser.","pos":""}],"TOWAGE":[{"def":"The act of towing.","pos":""},{"def":"The price paid for towing.","pos":""}],"TOWALL":[{"def":"Near; at hand; in state of preparation.","pos":""}],"TOWARD":[{"def":"Approaching; coming near.","pos":""},{"def":"Readly to do or learn; compliant with duty; not froward; apt; docile; tractable; as, a toward youth.","pos":""}],"TOWARDLINESS":[{"def":"The quality or state of being towardly; docility; tractableness.","pos":""}],"TOWARDLY":[{"def":"Same as Toward, a.","pos":""}],"TOWARDNESS":[{"def":"Quality or state of being toward.","pos":""}],"TOWBOAT":[{"def":"A vessel constructed for being towed, as a canal boat.","pos":""},{"def":"A steamer used for towing other vessels; a tug.","pos":""}],"TOWEL":[{"def":"A cloth used for wiping, especially one used for drying anything wet, as the person after a bath.","pos":""}],"TOWELING":[{"def":"Cloth for towels, especially such as is woven in long pieces to be cut at will, as distinguished from that woven in towel lengths with borders, etc.","pos":""}],"TOWER":[{"def":"A citadel; a fortress; hence, a defense.","pos":""},{"def":"A headdress of a high or towerlike form, fashionable about the end of the seventeenth century and until 1715; also, any high headdress.","pos":""}],"TOWERED":[{"def":"Adorned or defended by towers.","pos":""}],"TOWERING":[{"def":"Very high; elevated; rising aloft; as, a towering height.","pos":""},{"def":"Hence, extreme; violent; surpassing.","pos":""}],"TOWERY":[{"def":"Having towers; adorned or defended by towers.","pos":""}],"TOWILLY":[{"def":"The sanderling; -- so called from its cry.","pos":""}],"TOWLINE":[{"def":"A line used to tow vessels; a towrope.","pos":""}],"TOWN":[{"def":"Formerly: (a) An inclosure which surrounded the mere homestead or dwelling of the lord of the manor.","pos":""},{"def":"Any number or collection of houses to which belongs a regular market, and which is not a city or the see of a bishop.","pos":""}],"TOWN-CRIER":[{"def":"A town officer who makes proclamations to the people; the public crier of a town.","pos":""}],"TOWNED":[{"def":"Having towns; containing many towns.","pos":""}],"TOWNHALL":[{"def":"A public hall or building, belonging to a town, where the public offices are established, the town council meets, the people assemble in town meeting, etc.","pos":""}],"TOWNHOUSE":[{"def":"A building devoted to the public used of a town; a townhall.","pos":""}],"TOWNISH":[{"def":"Of or pertaining to the inhabitants of a town; like the town.","pos":""}],"TOWNSFOLK":[{"def":"The people of a town; especially, the inhabitants of a city, in distinction from country people; townspeople.","pos":""}],"TOWNSHIP":[{"def":"The district or territory of a town.","pos":""},{"def":"In surveys of the public land of the United States, a division of territory six miles square, containing 36 sections.","pos":""}],"TOWNSMAN":[{"def":"An inhabitant of a town; one of the same town with another.","pos":""},{"def":"A selectman, in New England.","pos":""}],"TOWNSPEOPLE":[{"def":"The inhabitants of a town or city, especially in distinction from country people; townsfolk.","pos":""}],"TOWPATH":[{"def":"A path traveled by men or animals in towing boats; -- called also towing path.","pos":""}],"TOWROPE":[{"def":"A rope used in towing vessels.","pos":""}],"TOWSER":[{"def":"A familiar name for a dog.","pos":""}],"TOWY":[{"def":"Composed of, or like, tow.","pos":""},{"def":"Blood poisoning.","pos":""}]}