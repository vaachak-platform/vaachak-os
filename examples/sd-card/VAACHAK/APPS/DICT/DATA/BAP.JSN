{"BAPHOMET":[{"def":"An idol or symbolical figure which the Templars were accused of using in their mysterious rites.","pos":"noun"}],"BAPTISM":[{"def":"The act of baptizing; the application of water to a person, as a sacrament or religious ceremony, by which he is initiated into the visible church of Christ.","pos":""}],"BAPTISMAL":[{"def":"Pertaining to baptism; as, baptismal vows.","pos":""}],"BAPTISMALLY":[{"def":"In a baptismal manner.","pos":""}],"BAPTIST":[{"def":"One who administers baptism; -- specifically applied to John, the forerunner of Christ.","pos":""},{"def":"One of a denomination of Christians who deny the validity of infant baptism and of sprinkling, and maintain that baptism should be administered to believers alone, and should be by immersion.","pos":""}],"BAPTISTIC":[{"def":"Of or for baptism; baptismal.","pos":""}],"BAPTIZABLE":[{"def":"Capable of being baptized; fit to be baptized.","pos":""}],"BAPTIZATION":[{"def":"Their baptizations were null.","pos":""}],"BAPTIZE":[{"def":"To administer the sacrament of baptism to.","pos":""},{"def":"To christen ( because a name is given to infants at their baptism); to give a name to; to name.","pos":""}],"BAPTIZEMENT":[{"def":"The act of baptizing.","pos":""}],"BAPTIZER":[{"def":"One who baptizes.","pos":""}]}