{"PELA":[{"def":"See Wax insect, under Wax.","pos":""}],"PELAGE":[{"def":"The covering, or coat, of a mammal, whether of wool, fur, or hair.","pos":""}],"PELAGIAN":[{"def":"Of or pertaining to the sea; marine; pelagic; as, pelagian shells.","pos":""}],"PELAGIANISM":[{"def":"The doctrines of Pelagius.","pos":""}],"PELAGIC":[{"def":"Of or pertaining to the ocean; -- applied especially to animals that live at the surface of the ocean, away from the coast.","pos":""}],"PELARGONIC":[{"def":"Pertaining to, or designating, an organic acid (called also nonoic acid) found in the leaves of the geranium (Pelargonium) and allied plants.","pos":""}],"PELARGONIUM":[{"def":"A large genus of plants of the order Geraniaceæ, differing from Geranium in having a spurred calyx and an irregular corolla.","pos":""}],"PELE'S HAIR":[{"def":"Glass threads or fibers formed by the wind from bits blown from frothy lava or from the tips of lava jets or from bits of liquid lava thrown into the air.","pos":""}],"PELECANIFORMES":[{"def":"Those birds that are related to the pelican; the Totipalmi.","pos":""}],"PELECOID":[{"def":"A figure, somewhat hatched-shaped, bounded by a semicircle and two inverted quadrants, and equal in area to the square ABCD inclosed by the chords of the four quadrants.","pos":""}],"PELECYPODA":[{"def":"Same as Lamellibranchia.","pos":""}],"PELERINE":[{"def":"A woman's cape; especially, a fur cape that is longer in front than behind.","pos":""}],"PELF":[{"def":"Money; riches; lucre; gain; -- generally conveying the idea of something ill-gotten or worthless.","pos":""}],"PELFISH":[{"def":"Of or pertaining to pelf.","pos":""},{"def":"Pelf; also, figuratively, rubbish; trash.","pos":""}],"PELICAN":[{"def":"Any large webfooted bird of the genus of Pelecanus, of which about a dozen species are known.","pos":""},{"def":"A retort or still having a curved tube or tubes leading back from the head to the body for continuous condensation and redistillation.","pos":""}],"PELICAN STATE":[{"def":"Louisiana; -- a nickname alluding to the device on its seal.","pos":""}],"PELICK":[{"def":"The American coot (Fulica).","pos":""}],"PELICOSAURIA":[{"def":"A suborder of Theromorpha, including terrestrial reptiles from the Permian formation.","pos":""}],"PELIOM":[{"def":"A variety of iolite, of a smoky blue color; pelioma.","pos":""}],"PELIOMA":[{"def":"A livid ecchymosis.","pos":""}],"PELISSE":[{"def":"An outer garment for men or women, originally of fur, or lined with fur; a lady's outer garment, made of silk or other fabric.","pos":""}],"PELL":[{"def":"To pelt; to knock about.","pos":""}],"PELLAGE":[{"def":"A customs duty on skins of leather.","pos":""}],"PELLAGRA":[{"def":"An erythematous affection of the skin, with severe constitutional and nervous symptoms, endemic in Northern Italy.","pos":""}],"PELLAGRIN":[{"def":"One who is afficted with pellagra.","pos":""}],"PELLAGROUS":[{"def":"Pertaining to, or affected with, or attendant on, pellagra; as, pellagrous insanity.","pos":""}],"PELLET":[{"def":"A little ball; as, a pellet of wax .","pos":""},{"def":"A bullet; a ball for firearms.","pos":""}],"PELLETED":[{"def":"Made of, or like, pellets; furnished with pellets.","pos":""}],"PELLIBRANCHIATA":[{"def":"A division of Nudibranchiata, in which the mantle itself serves as a gill.","pos":""}],"PELLICLE":[{"def":"A thin film formed on the surface of an evaporating solution.","pos":""}],"PELLICULAR":[{"def":"Of or pertaining to a pellicle.","pos":""}],"PELLILE":[{"def":"The redshank; -- so called from its note.","pos":""}],"PELLITORY":[{"def":"The common name of the several species of the genus Parietaria, low, harmless weeds of the Nettle family; -- also called wall pellitory, and lichwort.","pos":""}],"PELLMELL":[{"def":"In utter confusion; with confused violence.","pos":""}],"PELLUCID":[{"def":"Transparent; clear; limpid; translucent; not opaque.","pos":""},{"def":"The quality or state of being pellucid; transparency; translucency; clearness; as, the pellucidity of the air.","pos":""}],"PELLUCIDLY":[{"def":"In a pellucid manner.","pos":""}],"PELMA":[{"def":"The under surface of the foot.","pos":""}],"PELOPIUM":[{"def":"A supposed new metal found in columbite, afterwards shown to be identical with columbium, or niobium.","pos":""}],"PELOPONNESIAN":[{"def":"Of or pertaining to the Peloponnesus, or southern peninsula of Greece.","pos":""},{"def":"A native or an inhabitant of the Peloponnesus.","pos":""}],"PELORIA":[{"def":"Abnormal regularity; the state of certain flowers, which, being naturally irregular, have become regular through a symmetrical repetition of the special irregularity.","pos":""}],"PELORIC":[{"def":"Abnormally regular or symmetrical.","pos":""}],"PELORUS":[{"def":"An instrument similar to a mariner's compass, but without magnetic needles, and having two sight vanes by which bearings are taken, esp.","pos":""}],"PELOTA":[{"def":"A Basque, Spanish, and Spanish-American game played in a court, in which a ball is struck with a wickerwork racket.","pos":""}],"PELOTAGE":[{"def":"Packs or bales of Spanish wool.","pos":""}],"PELT":[{"def":"The body of any quarry killed by the hawk.","pos":""}],"PELTA":[{"def":"A small shield, especially one of an approximately elliptic form, or crescent-shaped.","pos":""},{"def":"A flat apothecium having no rim.","pos":""}],"PELTER":[{"def":"A pinchpenny; a mean, sordid person; a miser; a skinflint.","pos":""}],"PELTIER EFFECT":[{"def":"The production or absorption of heat at the junction of two metals on the passage of a current.","pos":""}],"PELTIER'S CROSS":[{"def":"A cross formed of two strips of different metals, to illustrate the Peltier effect.","pos":""}],"PELTIFORM":[{"def":"Shieldlike, with the outline nearly circular; peltate.","pos":""}],"PELTON WHEEL":[{"def":"A form of impulse turbine or water wheel, consisting of a row of double cup-shaped buckets arranged round the rim of a wheel and actuated by one or more jets of water playing into the cups at high velocity.","pos":""}],"PELTRY":[{"def":"Pelts or skins, collectively; skins with the fur on them; furs.","pos":""}],"PELUDO":[{"def":"The South American hairy armadillo (Dasypus villosus).","pos":""}],"PELURE":[{"def":"A crisp, hard, thin paper, sometimes used for postage stamps.","pos":""}],"PELUSIAC":[{"def":"Of or pertaining to Pelusium, an ancient city of Egypt; as, the Pelusiac (or former eastern) outlet of the Nile.","pos":""}],"PELVIC":[{"def":"Of, pertaining to, or in the region of, the pelvis; as, pelvic cellulitis.","pos":""}],"PELVIMETER":[{"def":"An instrument for measuring the dimensions of the pelvis.","pos":""}],"PELVIMETRY":[{"def":"The measurement of the pelvis.","pos":""}],"PELVIS":[{"def":"The pelvic arch, or the pelvic arch together with the sacrum.","pos":""},{"def":"The calyx of a crinoid.","pos":""}]}