{"PHONAL":[{"def":"Of or relating to the voice; as, phonal structure.","pos":""}],"PHONASCETICS":[{"def":"Treatment for restoring or improving the voice.","pos":""}],"PHONATION":[{"def":"The act or process by which articulate sounds are uttered; the utterance of articulate sounds; articulate speech.","pos":""}],"PHONAUTOGRAPH":[{"def":"An instrument by means of which a sound can be made to produce a visible trace or record of itself.","pos":""}],"PHONEIDOSCOPE":[{"def":"An instrument for studying the motions of sounding bodies by optical means.","pos":""}],"PHONETIC":[{"def":"Of or pertaining to the voice, or its use.","pos":""},{"def":"Representing sounds; as, phonetic characters; -- opposed to ideographic; as, a phonetic notation.","pos":""}],"PHONETICALLY":[{"def":"In a phonetic manner.","pos":""}],"PHONETICIAN":[{"def":"One versed in phonetics; a phonetist.","pos":""}],"PHONETICS":[{"def":"The doctrine or science of sounds; especially those of the human voice; phonology.","pos":""},{"def":"The art of representing vocal sounds by signs and written characters.","pos":""}],"PHONETISM":[{"def":"The science which treats of vocal sounds.","pos":""}],"PHONETIST":[{"def":"One versed in phonetics; a phonologist.","pos":""},{"def":"One who advocates a phonetic spelling.","pos":""}],"PHONETIZATION":[{"def":"The act, art, or process of representing sounds by phonetic signs.","pos":""}],"PHONETIZE":[{"def":"To represent by phonetic signs.","pos":""}],"PHONIC":[{"def":"Of or pertaining to sound; of the nature of sound; acoustic.","pos":""}],"PHONO":[{"def":"A South American butterfly (Ithonia phono) having nearly transparent wings.","pos":""}],"PHONO-":[{"def":"A combining form from Gr.","pos":""}],"PHONOCAMPTIC":[{"def":"Reflecting sound.","pos":""}],"PHONOGRAM":[{"def":"A letter, character, or mark used to represent a particular sound.","pos":""},{"def":"A record of sounds made by a phonograph.","pos":""}],"PHONOGRAPH":[{"def":"An instrument for the mechanical registration and reproduction of audible sounds, as articulate speech, etc.","pos":""}],"PHONOGRAPHER":[{"def":"One versed or skilled in phonography.","pos":""},{"def":"One who uses, or is skilled in the use of, the phonograph.","pos":""}],"PHONOGRAPHICALLY":[{"def":"In a phonographic manner; by means of phonograph.","pos":""}],"PHONOGRAPHY":[{"def":"A description of the laws of the human voice, or sounds uttered by the organs of speech.","pos":""},{"def":"A representation of sounds by distinctive characters; commonly, a system of shorthand writing invented by Isaac Pitman, or a modification of his system, much used by reporters.","pos":""}],"PHONOLITE":[{"def":"A compact, feldspathic, igneous rock containing nephelite, haüynite, etc.","pos":""}],"PHONOLOGER":[{"def":"Of or pertaining to phonology.","pos":""}],"PHONOLOGIST":[{"def":"One versed in phonology.","pos":""}],"PHONOLOGY":[{"def":"The science or doctrine of the elementary sounds uttered by the human voice in speech, including the various distinctions, modifications, and combinations of tones; phonetics.","pos":""}],"PHONOMETER":[{"def":"An instrument for measuring sounds, as to their intensity, or the frequency of the vibrations.","pos":""}],"PHONOMOTOR":[{"def":"An instrument in which motion is produced by the vibrations of a sounding body.","pos":""}],"PHONORGANON":[{"def":"A speaking machine.","pos":""}],"PHONOSCOPE":[{"def":"König for testing the quality of musical strings.","pos":""}],"PHONOTYPE":[{"def":"A type or character used in phonotypy.","pos":""},{"def":"Of or pertaining to phonotypy; as, a phonotypic alphabet.","pos":""}],"PHONOTYPIST":[{"def":"One versed in phonotypy.","pos":""}],"PHONOTYPY":[{"def":"A method of phonetic printing of the English language, as devised by Mr.","pos":""}]}