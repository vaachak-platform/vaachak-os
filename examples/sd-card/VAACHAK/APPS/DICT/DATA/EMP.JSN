{"EMPAISTIC":[{"def":"Having to do with inlaid work; -- especially used with reference to work of the ancient Greeks.","pos":""}],"EMPALE":[{"def":"No bloodless malady empales their face.","pos":""}],"EMPALEMENT":[{"def":"Same as Impalement.","pos":""}],"EMPANEL":[{"def":"A list of jurors; a panel.","pos":""}],"EMPANOPLIED":[{"def":"Completely armed; panoplied.","pos":""}],"EMPARADISE":[{"def":"Same as Imparadise.","pos":""}],"EMPARK":[{"def":"To make a park of; to inclose, as with a fence; to impark.","pos":""}],"EMPARLANCE":[{"def":"Parley; imparlance.","pos":""}],"EMPASM":[{"def":"A perfumed powder sprinkled upon the body to mask the odor of sweat.","pos":""}],"EMPASSION":[{"def":"To move with passion; to affect strongly.","pos":""}],"EMPASSIONATE":[{"def":"Strongly affected.","pos":""}],"EMPAWN":[{"def":"To put in pawn; to pledge; to impawn.","pos":""}],"EMPEARL":[{"def":"To form like pearls; to decorate with, or as with, pearls; to impearl.","pos":""}],"EMPEOPLE":[{"def":"To form into a people or community; to inhabit; to people.","pos":""}],"EMPERIL":[{"def":"To put in peril.","pos":""}],"EMPERISHED":[{"def":"Perished; decayed.","pos":""}],"EMPEROR":[{"def":"The sovereign or supreme monarch of an empire; -- a title of dignity superior to that of king; as, the emperor of Germany or of Austria; the emperor or Czar of Russia.","pos":""}],"EMPERORSHIP":[{"def":"The rank or office of an emperor.","pos":""}],"EMPERY":[{"def":"Empire; sovereignty; dominion.","pos":""}],"EMPHASIS":[{"def":"A particular stress of utterance, or force of voice, given in reading and speaking to one or more words whose signification the speaker intends to impress specially upon his audience.","pos":""}],"EMPHASIZE":[{"def":"To utter or pronounce with a particular stress of voice; to make emphatic; as, to emphasize a word or a phrase.","pos":""}],"EMPHATICALLY":[{"def":"With emphasis; forcibly; in a striking manner or degree; preëminently.","pos":""},{"def":"Not really, but apparently.","pos":""}],"EMPHATICALNESS":[{"def":"The quality of being emphatic; emphasis.","pos":""}],"EMPHRACTIC":[{"def":"Having the quality of closing the pores of the skin.","pos":""}],"EMPHYSEMA":[{"def":"A swelling produced by gas or air diffused in the cellular tissue.","pos":""}],"EMPHYSEMATOUS":[{"def":"Pertaining to, or of the nature of, emphysema; swelled; bloated.","pos":""}],"EMPHYTEUSIS":[{"def":"A real right, susceptible of assignment and of descent, charged on productive real estate, the right being coupled with the enjoyment of the property on condition of taking care of the estate and paying taxes, and sometimes a small rent.","pos":""}],"EMPHYTEUTIC":[{"def":"Of or pertaining to an emphyteusis; as, emphyteutic lands.","pos":""}],"EMPHYTEUTICARY":[{"def":"One who holds lands by emphyteusis.","pos":""}],"EMPIERCE":[{"def":"To pierce; to impierce.","pos":""}],"EMPIGHT":[{"def":"Fixed; settled; fastened.","pos":""}],"EMPIRE":[{"def":"Supreme power; sovereignty; sway; dominion.","pos":""}],"EMPIRE STATE":[{"def":"New York; -- a nickname alluding to its size and wealth.","pos":""}],"EMPIRE STATE OF THE SOUTH":[{"def":"Georgia; -- a nickname.","pos":""}],"EMPIRE STATE OF THE WEST":[{"def":"Missouri; -- a nickname.","pos":""}],"EMPIRIC":[{"def":"One who follows an empirical method; one who relies upon practical experience.","pos":""},{"def":"One who confines himself to applying the results of mere experience or his own observation; especially, in medicine, one who deviates from the rules of science and regular practice; an ignorant and unlicensed pretender; a quack; a charlatan.","pos":""}],"EMPIRICALLY":[{"def":"By experiment or experience; without science; in the manner of quacks.","pos":""}],"EMPIRICISM":[{"def":"The philosophical theory which attributes the origin of all our knowledge to experience.","pos":""}],"EMPIRISTIC":[{"def":"Relating to, or resulting from, experience, or experiment; following from empirical methods or data; -- opposed to nativistic.","pos":""}],"EMPLACE":[{"def":"To put into place or position; to fix on an emplacement.","pos":""}],"EMPLACEMENT":[{"def":"A putting in, or assigning to, a definite place; localization; as, the emplacement of a structure.","pos":""}],"EMPLASTER":[{"def":"To plaster over; to cover over so as to present a good appearance.","pos":""}],"EMPLASTIC":[{"def":"Fit to be applied as a plaster; glutinous; adhesive; as, emplastic applications.","pos":""}],"EMPLASTRATION":[{"def":"The application of a plaster or salve.","pos":""}],"EMPLEAD":[{"def":"To accuse; to indict.","pos":""}],"EMPLECTON":[{"def":"A kind of masonry in which the outer faces of the wall are ashlar, the space between being filled with broken stone and mortar.","pos":""}],"EMPLOY":[{"def":"To inclose; to infold.","pos":""},{"def":"To use; to have in service; to cause to be engaged in doing something; -- often followed by in, about, on, or upon, and sometimes by to; as: (a) To make use of, as an instrument, a means, a material, etc.","pos":""}],"EMPLOYABLE":[{"def":"Capable of being employed; capable of being used; fit or proper for use.","pos":""}],"EMPLOYE":[{"def":"One employed by another; a clerk or workman in the service of an employer.","pos":""}],"EMPLOYEE":[{"def":"One employed by another.","pos":""}],"EMPLOYER":[{"def":"One who employs another; as, an employer of workmen.","pos":""}],"EMPLOYMENT":[{"def":"The act of employing or using; also, the state of being employed.","pos":""},{"def":"That which engages or occupies; that which consumes time or attention; office or post of business; service; as, agricultural employments; mechanical employments; public employments; in the employment of government.","pos":""}],"EMPLUNGE":[{"def":"To plunge; to implunge.","pos":""}],"EMPOISON":[{"def":"To poison; to impoison.","pos":""}],"EMPOISONMENT":[{"def":"The act of poisoning.","pos":""},{"def":"Pertaining to an emporium; relating to merchandise.","pos":""}],"EMPORIUM":[{"def":"A place of trade; a market place; a mart; esp.","pos":""}],"EMPOWER":[{"def":"To give authority to; to delegate power to; to commission; to authorize (having commonly a legal force); as, the Supreme Court is empowered to try and decide cases, civil or criminal; the attorney is empowered to sign an acquittance, and discharge the debtor.","pos":""},{"def":"To give moral or physical power, faculties, or abilities to.","pos":""}],"EMPRESS":[{"def":"The consort of an emperor.","pos":""},{"def":"A female sovereign.","pos":""}],"EMPRESSEMENT":[{"def":"Demonstrative warmth or cordiality of manner; display of enthusiasm.","pos":""}],"EMPRISE":[{"def":"An enterprise; endeavor; adventure.","pos":""},{"def":"The qualifies which prompt one to undertake difficult and dangerous exploits.","pos":""}],"EMPRISING":[{"def":"Full of daring; adventurous.","pos":""}],"EMPROSTHOTONOS":[{"def":"A drawing of the body forward, in consequence of the spasmodic action of some of the muscles.","pos":""}],"EMPTIER":[{"def":"One who, or that which, empties.","pos":""}],"EMPTINESS":[{"def":"The state of being empty; absence of contents; void space; vacuum; as, the emptiness of a vessel; emptiness of the stomach.","pos":""},{"def":"Want of solidity or substance; unsatisfactoriness; inability to satisfy desire; vacuity; hollowness; the emptiness of earthly glory.","pos":""}],"EMPTION":[{"def":"The act of buying.","pos":""}],"EMPTIONAL":[{"def":"Capable of being purchased.","pos":""}],"EMPTY":[{"def":"Containing nothing; not holding or having anything within; void of contents or appropriate contents; not filled; -- said of an inclosure, as a box, room, house, etc.","pos":""},{"def":"Free; clear; devoid; -- often with of.","pos":""}],"EMPTYING":[{"def":"The lees of beer, cider, etc.","pos":""}],"EMPURPLE":[{"def":"To tinge or dye of a purple color; to color with purple; to impurple.","pos":""}],"EMPUSE":[{"def":"A phantom or specter.","pos":""}],"EMPYEMA":[{"def":"A collection of blood, pus, or other fluid, in some cavity of the body, especially that of the pleura.","pos":""}],"EMPYESIS":[{"def":"An eruption of pustules.","pos":""}],"EMPYREAL":[{"def":"Formed of pure fire or light; refined beyond aërial substance; pertaining to the highest and purest region of heaven.","pos":""}],"EMPYREAN":[{"def":"The highest heaven, where the pure element of fire was supposed by the ancients to subsist.","pos":""}],"EMPYREUMA":[{"def":"The peculiar smell and taste arising from products of decomposition of animal or vegetable substances when burnt in close vessels.","pos":""},{"def":"Of or pertaining to empyreuma; as, an empyreumatic odor.","pos":""}],"EMPYREUMATIZE":[{"def":"To render empyreumatic.","pos":""}],"EMPYRICAL":[{"def":"Containing the combustible principle of coal.","pos":""}],"EMPYROSIS":[{"def":"A general fire; a conflagration.","pos":""}]}