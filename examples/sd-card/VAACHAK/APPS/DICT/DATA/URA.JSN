{"URACHUS":[{"def":"A cord or band of fibrous tissue extending from the bladder to the umbilicus.","pos":""}],"URAEMIA":[{"def":"Accumulation in the blood of the principles of the urine, producing dangerous disease.","pos":""}],"URAEMIC":[{"def":"Of or pertaining to uræmia; as, uræmic convulsions.","pos":""}],"URAEUM":[{"def":"The posterior half of an animal.","pos":""}],"URAEUS":[{"def":"A serpent, or serpent's head and neck, represented on the front of the headdresses of divinities and sovereigns as an emblem of supreme power.","pos":""}],"URAL":[{"def":"Pertaining to, or designating, the Urals, a mountain range between Europe and Asia.","pos":""}],"URAL-ALTAIC":[{"def":"Of or pertaining to the Urals and the Altai; as the Ural- Altaic, or Turanian, languages.","pos":""}],"URALI":[{"def":"Of or relating to the Ural Mountains.","pos":""}],"URALITE":[{"def":"Amphibole resulting from the alternation of pyroxene by paramorphism.","pos":""}],"URALITIZATION":[{"def":"The change of pyroxene to amphibole by paramorphism.","pos":""}],"URANATE":[{"def":"A salt of uranic acid.","pos":""}],"URANIA":[{"def":"One of the nine Muses, daughter of Zeus by Mnemosyne, and patron of astronomy.","pos":""},{"def":"A genus of large, brilliantly colored moths native of the West Indies and South America.","pos":""}],"URANIAN":[{"def":"Of or pertaining to the planet Uranus; as, the Uranian year.","pos":""}],"URANIC":[{"def":"Pertaining to, resembling, or containing uranium; specifically, designating those compounds in which uranium has a valence relatively higher than in uranous compounds.","pos":""}],"URANIN":[{"def":"An alkaline salt of fluorescein, obtained as a brownish red substance, which is used as a dye; -- so called from the peculiar yellowish green fluorescence (resembling that of uranium glass) of its solutions.","pos":""}],"URANINITE":[{"def":"A mineral consisting chiefly of uranium oxide with some lead, thorium, etc.","pos":""}],"URANISCOPLASTY":[{"def":"The process of forming an artificial palate.","pos":""},{"def":"Suture of the palate.","pos":""}],"URANITE":[{"def":"A general term for the uranium phosphates, autunite, or lime uranite, and torbernite, or copper uranite.","pos":""}],"URANITIC":[{"def":"Of or pertaining to uranium; containing uranium.","pos":""}],"URANIUM":[{"def":"An element of the chromium group, found in certain rare minerals, as pitchblende, uranite, etc.","pos":""},{"def":"Of or pertaining to uranography; as, an uranographic treatise.","pos":""}],"URANOGRAPHIST":[{"def":"One practiced in uranography.","pos":""}],"URANOGRAPHY":[{"def":"A description or plan of the heavens and the heavenly bodies; the construction of celestial maps, globes, etc.","pos":""}],"URANOLITE":[{"def":"A meteorite or aërolite.","pos":""}],"URANOLOGY":[{"def":"A discourse or treatise on the heavens and the heavenly bodies; the study of the heavens; uranography.","pos":""}],"URANOMETRY":[{"def":"A chart or catalogue of fixed stars, especially of stars visible to the naked eye.","pos":""}],"URANOPLASTY":[{"def":"The plastic operation for closing a fissure in the hard palate.","pos":""}],"URANOSCOPY":[{"def":"Observation of the heavens or heavenly bodies.","pos":""}],"URANOSO-":[{"def":"A combining form (also used adjectively) from uranium; -- used in naming certain complex compounds; as in uranoso-uranic oxide, uranoso-uranic sulphate.","pos":""}],"URANOUS":[{"def":"Pertaining to, or containing, uranium; designating those compounds in which uranium has a lower valence as contrasted with the uranic compounds.","pos":""}],"URANUS":[{"def":"The son or husband of Gaia (Earth), and father of Chronos (Time) and the Titans.","pos":""},{"def":"One of the primary planets.","pos":""}],"URANYL":[{"def":"The radical UO2, conveniently regarded as a residue of many uranium compounds.","pos":""}],"URAO":[{"def":"URARE; URARI U*ra\"re, U*ra\"ri, n.","pos":""}],"URATE":[{"def":"A salt of uric acid; as, sodium urate; ammonium urate.","pos":""}],"URATIC":[{"def":"Of or containing urates; as, uratic calculi.","pos":""}]}