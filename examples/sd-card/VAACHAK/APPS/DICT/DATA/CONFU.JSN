{"CONFUCIAN":[{"def":"Of, or relating to, Confucius, the great Chinese philosopher and teacher.","pos":""}],"CONFUCIANISM":[{"def":"The political morality taught by Confucius and his disciples, which forms the basis of the Chinese jurisprudence and education.","pos":""}],"CONFUCIANIST":[{"def":"A follower of Confucius; a Confucian.","pos":""}],"CONFUS":[{"def":"Confused, disturbed.","pos":""}],"CONFUSABILITY":[{"def":"Capability of being confused.","pos":""}],"CONFUSABLE":[{"def":"Capable of being confused.","pos":""}],"CONFUSE":[{"def":"Mixed; confounded.","pos":""}],"CONFUSEDLY":[{"def":"In a confused manner.","pos":""}],"CONFUSEDNESS":[{"def":"A state of confusion.","pos":""}],"CONFUSELY":[{"def":"Confusedly; obscurely.","pos":""}],"CONFUSION":[{"def":"The state of being mixed or blended so as to produce indistinctness or error; indistinct combination; disorder; tumult.","pos":""},{"def":"The state of being abashed or disconcerted; loss self-possession; perturbation; shame.","pos":""}],"CONFUSIVE":[{"def":"Confusing; having a tendency to confusion.","pos":""}],"CONFUTABLE":[{"def":"That may be confuted.","pos":""}],"CONFUTANT":[{"def":"One who undertakes to confute.","pos":""}],"CONFUTATION":[{"def":"The act or process of confuting; refutation.","pos":""}],"CONFUTATIVE":[{"def":"Adapted or designed to confute.","pos":""}],"CONFUTE":[{"def":"To overwhelm by argument; to refute conclusively; to prove or show to be false or defective; to overcome; to silence.","pos":""}],"CONFUTER":[{"def":"One who confutes or disproves.","pos":""}]}