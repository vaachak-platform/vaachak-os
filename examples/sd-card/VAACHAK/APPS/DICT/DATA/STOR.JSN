{"STORAGE":[{"def":"The act of depositing in a store or warehouse for safe keeping; also, the safe keeping of goods in a warehouse.","pos":""},{"def":"Space for the safe keeping of goods.","pos":""}],"STORAX":[{"def":"Any one of a number of similar complex resins obtained from the bark of several trees and shrubs of the Styrax family.","pos":""}],"STORE":[{"def":"Articles, especially of food, accumulated for some specific object; supplies, as of provisions, arms, ammunition, and the like; as, the stores of an army, of a ship, of a family.","pos":""}],"STORED":[{"def":"Collected or accumulated as a reserve supply; as, stored electricity.","pos":""}],"STOREHOUSE":[{"def":"A building for keeping goods of any kind, especially provisions; a magazine; a repository; a warehouse.","pos":""},{"def":"The Scripture of God is a storehouse abounding with estimable treasures of wisdom and knowledge.","pos":""}],"STOREKEEPER":[{"def":"A man in charge of stores or goods of any kind; as, a naval storekeeper.","pos":""},{"def":"One who keeps a \"store;\" a shopkeeper.","pos":""}],"STORER":[{"def":"One who lays up or forms a store.","pos":""}],"STOREROOM":[{"def":"Room in a storehouse or repository; a room in which articles are stored.","pos":""}],"STORESHIP":[{"def":"A vessel used to carry naval stores for a fleet, garrison, or the like.","pos":""}],"STORGE":[{"def":"Parental affection; the instinctive affection which animals have for their young.","pos":""}],"STORIED":[{"def":"Told in a story.","pos":""},{"def":"Having a history; interesting from the stories which pertain to it; venerable from the associations of the past.","pos":""}],"STORIER":[{"def":"A relater of stories; an historian.","pos":""}],"STORIFY":[{"def":"To form or tell stories of; to narrate or describe in a story.","pos":""}],"STORK":[{"def":"Any one of several species of large wading birds of the family Ciconidæ, having long legs and a long, pointed bill.","pos":""}],"STORK-BILLED":[{"def":"Having a bill like that of the stork.","pos":""}],"STORM":[{"def":"A violent assault on a fortified place; a furious attempt of troops to enter and take a fortified place by scaling the walls, forcing the gates, or the like.","pos":""}],"STORM-BEAT":[{"def":"Beaten, injured, or impaired by storms.","pos":""}],"STORMFINCH":[{"def":"The storm petrel.","pos":""}],"STORMFUL":[{"def":"Abounding with storms.","pos":""}],"STORMGLASS":[{"def":"A glass vessel, usually cylindrical, filled with a solution which is sensitive to atmospheric changes, indicating by a clouded appearance, rain, snow, etc.","pos":""}],"STORMILY":[{"def":"In a stormy manner.","pos":""}],"STORMINESS":[{"def":"The state of being stormy; tempestuousness; biosteruousness; impetuousness.","pos":""}],"STORMWIND":[{"def":"A heavy wind; a wind that brings a storm; the blast of a storm.","pos":""}],"STORMY":[{"def":"Characterized by, or proceeding from, a storm; subject to storms; agitated with furious winds; biosterous; tempestous; as, a stormy season; a stormy day or week.","pos":""},{"def":"Proceeding from violent agitation or fury; as, a stormy sound; stormy shocks.","pos":""}],"STORTHING":[{"def":"The Parliament of Norway, chosen by indirect election once in three years, but holding annual sessions.","pos":""}],"STORY":[{"def":"A set of rooms on the same floor or level; a floor, or the space between two floors.","pos":""}],"STORY-TELLER":[{"def":"One who tells stories; a narrator of anecdotes,incidents, or fictitious tales; as, an amusing story-teller.","pos":""},{"def":"An historian; -- in contempt.","pos":""}],"STORY-TELLING":[{"def":"Being accustomed to tell stories.","pos":""},{"def":"The act or practice of telling stories.","pos":""}],"STORY-WRITER":[{"def":"One who writes short stories, as for magazines.","pos":""},{"def":"An historian; a chronicler.","pos":""}],"STORYBOOK":[{"def":"A book containing stories, or short narratives, either true or false.","pos":""}]}