{"IXIA":[{"def":"A South African bulbous plant of the Iris family, remarkable for the brilliancy of its flowers.","pos":""}],"IXODES":[{"def":"A genus of parasitic Acarina, which includes various species of ticks.","pos":""}],"IXODIAN":[{"def":"A tick of the genus Ixodes, or the family Ixodidæ.","pos":""},{"def":"A Mexican name for a variety of Agave rigida, which furnishes a strong coarse fiber; also, the fiber itself, which is called also pita, and Tampico fiber.","pos":""}]}