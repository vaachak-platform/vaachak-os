{"UXORIAL":[{"def":"Dotingly fond of, or servilely submissive to, a wife; uxorious; also, becoming a wife; pertaining to a wife.","pos":""}],"UXORICIDAL":[{"def":"Of or pertaining to uxoricide; tending to uxoricide.","pos":""}],"UXORICIDE":[{"def":"The murder of a wife by her husband.","pos":""},{"def":"One who murders his wife.","pos":""}],"UXORIOUS":[{"def":"Excessively fond of, or submissive to, a wife; being a dependent husband.","pos":""}]}