{"ALGA":[{"def":"A kind of seaweed; pl.","pos":""}],"ALGAL":[{"def":"Pertaining to, or like, algæ.","pos":""}],"ALGAROBA":[{"def":"A term used for the Powder of Algaroth, a white powder which is a compound of trichloride and trioxide of antimony.","pos":""}],"ALGAROVILLA":[{"def":"The agglutinated seeds and husks of the legumes of a South American tree (Inga Marthæ).","pos":""}],"ALGAZEL":[{"def":"The true gazelle.","pos":""}],"ALGEBRA":[{"def":"That branch of mathematics which treats of the relations and properties of quantity by means of letters and other symbols.","pos":""},{"def":"Of or pertaining to algebra; containing an operation of algebra, or deduced from such operation; as, algebraic characters; algebraical writings.","pos":""}],"ALGEBRAICALLY":[{"def":"By algebraic process.","pos":""}],"ALGEBRAIST":[{"def":"One versed in algebra.","pos":""}],"ALGEBRAIZE":[{"def":"To perform by algebra; to reduce to algebraic form.","pos":""}],"ALGERIAN":[{"def":"Of or pertaining to Algeria.","pos":""},{"def":"A native of Algeria.","pos":""}],"ALGERINE":[{"def":"Of or pertaining to Algiers or Algeria.","pos":""}],"ALGIDITY":[{"def":"Chilliness; coldness; especially (Med.","pos":""},{"def":"coldness and collapse.","pos":""}],"ALGIN":[{"def":"A nitrogenous substance resembling gelatin, obtained from certain algæ.","pos":""}],"ALGOID":[{"def":"Of the nature of, or resembling, an alga.","pos":""}],"ALGOL":[{"def":"A fixed star, in Medusa's head, in the constellation Perseus, remarkable for its periodic variation in brightness.","pos":""}],"ALGOLOGICAL":[{"def":"Of or pertaining to algology; as, algological specimens.","pos":""}],"ALGOLOGIST":[{"def":"One learned about algæ; a student of algology.","pos":""}],"ALGOLOGY":[{"def":"The study or science of algæ or seaweeds.","pos":""}],"ALGOMETER":[{"def":"An instrument for measuring sensations of pain due to pressure.","pos":""}],"ALGONKIAN":[{"def":"The Algonkian period or era, or system or group of systems.","pos":""}],"ALGONQUIAN":[{"def":"An Algonquian Indian.","pos":""}],"ALGOR":[{"def":"Cold; chilliness.","pos":""}],"ALGOUS":[{"def":"Of or pertaining to the algæ, or seaweeds; abounding with, or like, seaweed.","pos":""}],"ALGUAZIL":[{"def":"An inferior officer of justice in Spain; a warrant officer; a constable.","pos":""}],"ALGUM":[{"def":"Same as Almug (and etymologically preferable).","pos":""}]}