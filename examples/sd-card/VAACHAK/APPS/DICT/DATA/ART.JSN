{"ART":[{"def":"The second person singular, indicative mode, present tense, of the substantive verb Be; but formed after the analogy of the plural are, with the ending -t, as in thou shalt, wilt, orig.","pos":""}],"ART UNION":[{"def":"An association for promoting art (esp.","pos":""}],"ARTEMIA":[{"def":"A genus of phyllopod Crustacea found in salt lakes and brines; the brine shrimp.","pos":""}],"ARTEMISIA":[{"def":"A genus of plants including the plants called mugwort, southernwood, and wormwood.","pos":""}],"ARTERIAC":[{"def":"Of or pertaining to the windpipe.","pos":""}],"ARTERIAL":[{"def":"Of or pertaining to an artery, or the arteries; as, arterial action; the arterial system.","pos":""},{"def":"Of or pertaining to a main channel (resembling an artery), as a river, canal, or railroad.","pos":""}],"ARTERIALIZATION":[{"def":"The process of converting venous blood into arterial blood during its passage through the lungs, oxygen being absorbed and carbonic acid evolved; -- called also aëration and hematosis.","pos":""}],"ARTERIALIZE":[{"def":"To transform, as the venous blood, into arterial blood by exposure to oxygen in the lungs; to make arterial.","pos":""}],"ARTERIOGRAPHY":[{"def":"A systematic description of the arteries.","pos":""}],"ARTERIOLOGY":[{"def":"That part of anatomy which treats of arteries.","pos":""}],"ARTERIOSCLEROSIS":[{"def":"Abnormal thickening and hardening of the walls of the arteries, esp.","pos":""}],"ARTERIOTOMY":[{"def":"The opening of an artery, esp.","pos":""}],"ARTERITIS":[{"def":"Inflammation of an artery or arteries.","pos":""}],"ARTERY":[{"def":"One of the vessels or tubes which carry either venous or arterial blood from the heart.","pos":""}],"ARTESIAN":[{"def":"Of or pertaining to Artois (anciently called Artesium), in France.","pos":""}],"ARTFUL":[{"def":"Performed with, or characterized by, art or skill.","pos":""},{"def":"Artificial; imitative.","pos":""}],"ARTFULLY":[{"def":"In an artful manner; with art or cunning; skillfully; dexterously; craftily.","pos":""}],"ARTFULNESS":[{"def":"The quality of being artful; art; cunning; craft.","pos":""}],"ARTHEN":[{"def":"Same as Earthen.","pos":""}],"ARTHRITIS":[{"def":"Any inflammation of the joints, particularly the gout.","pos":""}],"ARTHROCHONDRITIS":[{"def":"Chondritis of a joint.","pos":""}],"ARTHRODERM":[{"def":"The external covering of an Arthropod.","pos":""}],"ARTHRODESIS":[{"def":"Surgical fixation of joints.","pos":""}],"ARTHRODIA":[{"def":"A form of diarthrodial articulation in which the articular surfaces are nearly flat, so that they form only an imperfect ball and socket.","pos":""},{"def":"Of or pertaining to arthrodia.","pos":""}],"ARTHRODYNIA":[{"def":"An affection characterized by pain in or about a joint, not dependent upon structural disease.","pos":""}],"ARTHRODYNIC":[{"def":"Pertaining to arthrodynia, or pain in the joints; rheumatic.","pos":""}],"ARTHROGASTRA":[{"def":"A division of the Arachnida, having the abdomen annulated, including the scorpions, harvestmen, etc.","pos":""}],"ARTHROGRAPHY":[{"def":"The description of joints.","pos":""}],"ARTHROLOGY":[{"def":"That part of anatomy which treats of joints.","pos":""}],"ARTHROMERE":[{"def":"One of the body segments of Arthropods.","pos":""}],"ARTHROPATHY":[{"def":"Any disease of the joints.","pos":""}],"ARTHROPLEURA":[{"def":"The side or limb-bearing portion of an arthromere.","pos":""}],"ARTHROPOD":[{"def":"One of the Arthropoda.","pos":""}],"ARTHROPODA":[{"def":"A large division of Articulata, embracing all those that have jointed legs.","pos":""}],"ARTHROPOMATA":[{"def":"One of the orders of Branchiopoda.","pos":""}],"ARTHROSPORE":[{"def":"A bacterial resting cell, -- formerly considered a spore, but now known to occur even in endosporous bacteria.","pos":""}],"ARTHROSTRACA":[{"def":"One of the larger divisions of Crustacea, so called because the thorax and abdomen are both segmented; Tetradecapoda.","pos":""}],"ARTHROTOME":[{"def":"A strong scalpel used in the dissection of joints.","pos":""}],"ARTHROZOIC":[{"def":"Of or pertaining to the Articulata; articulate.","pos":""}],"ARTHURIAN":[{"def":"Of or pertaining to King Arthur or his knights.","pos":""}],"ARTIAD":[{"def":"Even; not odd; -- said of elementary substances and of radicals the valence of which is divisible by two without a remainder.","pos":""}],"ARTICHOKE":[{"def":"The Cynara scolymus, a plant somewhat resembling a thistle, with a dilated, imbricated, and prickly involucre.","pos":""},{"def":"See Jerusalem artichoke.","pos":""}],"ARTICLE":[{"def":"One of the three words, a, an, the, used before nouns to limit or define their application.","pos":""},{"def":"One of the segments of an articulated appendage.","pos":""}],"ARTICLED":[{"def":"Bound by articles; apprenticed; as, an articled clerk.","pos":""}],"ARTICULAR":[{"def":"Of or pertaining to the joints; as, an articular disease; an articular process.","pos":""},{"def":"A bone in the base of the lower jaw of many birds, reptiles, amphibians, and fishes.","pos":""}],"ARTICULARLY":[{"def":"In an articular or an articulate manner.","pos":""}],"ARTICULATA":[{"def":"One of the four subkingdoms in the classification of Cuvier.","pos":""},{"def":"One of the subdivisions of the Brachiopoda, including those that have the shells united by a hinge.","pos":""}],"ARTICULATE":[{"def":"Expressed in articles or in separate items or particulars.","pos":""},{"def":"Jointed; formed with joints; consisting of segments united by joints; as, articulate animals or plants.","pos":""}],"ARTICULATED":[{"def":"United by, or provided with, articulations; jointed; as, an articulated skeleton.","pos":""},{"def":"Produced, as a letter, syllable, or word, by the organs of speech; pronounced.","pos":""}],"ARTICULATELY":[{"def":"After the manner, or in the form, of a joint.","pos":""},{"def":"Article by article; in distinct particulars; in detail; definitely.","pos":""}],"ARTICULATENESS":[{"def":"Quality of being articulate.","pos":""}],"ARTICULATION":[{"def":"A joint or juncture between bones in the skeleton.","pos":""}],"ARTICULATIVE":[{"def":"Of or pertaining to articulation.","pos":""}],"ARTICULATOR":[{"def":"One who, or that which, articulates; as: (a) One who enunciates distinctly.","pos":""}],"ARTICULUS":[{"def":"A joint of the cirri of the Crinoidea; a joint or segment of an arthropod appendage.","pos":""}],"ARTIFACT":[{"def":"A product of human workmanship; -- applied esp.","pos":""}],"ARTIFICE":[{"def":"A handicraft; a trade; art of making.","pos":""},{"def":"Workmanship; a skillfully contrived work.","pos":""}],"ARTIFICER":[{"def":"A military mechanic, as a blacksmith, carpenter, etc.","pos":""}],"ARTIFICIAL":[{"def":"Made or contrived by art; produced or modified by human skill and labor, in opposition to natural; as, artificial heat or light, gems, salts, minerals, fountains, flowers.","pos":""},{"def":"Feigned; fictitious; assumed; affected; not genuine.","pos":""}],"ARTIFICIALITY":[{"def":"The quality or appearance of being artificial; that which is artificial.","pos":""}],"ARTIFICIALIZE":[{"def":"To render artificial.","pos":""}],"ARTIFICIALLY":[{"def":"In an artificial manner; by art, or skill and contrivance, not by nature.","pos":""},{"def":"Ingeniously; skillfully.","pos":""}],"ARTIFICIALNESS":[{"def":"The quality of being artificial.","pos":""}],"ARTILIZE":[{"def":"To make resemble.","pos":""}],"ARTILLERIST":[{"def":"A person skilled in artillery or gunnery; a gunner; an artilleryman.","pos":""}],"ARTILLERY":[{"def":"Munitions of war; implements for warfare, as slings, bows, and arrows.","pos":""},{"def":"Cannon; great guns; ordnance, including guns, mortars, howitzers, etc.","pos":""}],"ARTILLERY WHEEL":[{"def":"A kind of heavily built dished wheel with a long axle box, used on gun carriages, usually having 14 spokes and 7 felloes; hence, a wheel of similar construction for use on automobiles, etc.","pos":""}],"ARTILLERYMAN":[{"def":"A man who manages, or assists in managing, a large gun in firing.","pos":""}],"ARTIODACTYLA":[{"def":"One of the divisions of the ungulate animals.","pos":""}],"ARTIODACTYLE":[{"def":"One of the Artiodactyla.","pos":""}],"ARTIODACTYLOUS":[{"def":"Ar`ti*o*dac\"ty*lous, a.","pos":""}],"ARTISAN":[{"def":"One who professes and practices some liberal art; an artist.","pos":""},{"def":"One trained to manual dexterity in some mechanic art or trade; and handicraftsman; a mechanic.","pos":""}],"ARTIST":[{"def":"One who practices some mechanic art or craft; an artisan.","pos":""},{"def":"One who professes and practices an art in which science and taste preside over the manual execution.","pos":""}],"ARTISTE":[{"def":"One peculiarly dexterous and tasteful in almost any employment, as an opera dancer, a hairdresser, a cook.","pos":""},{"def":"Of or pertaining to art or to artists; made in the manner of an artist; conformable to art; characterized by art; showing taste or skill.","pos":""}],"ARTISTRY":[{"def":"Works of art collectively.","pos":""},{"def":"Artistic effect or quality.","pos":""}],"ARTLESS":[{"def":"Wanting art, knowledge, or skill; ignorant; unskillful.","pos":""},{"def":"Contrived without skill or art; inartistic.","pos":""}],"ARTLESSLY":[{"def":"In an artless manner; without art, skill, or guile; unaffectedly.","pos":""}],"ARTLESSNESS":[{"def":"The quality of being artless, or void of art or guile; simplicity; sincerity.","pos":""}],"ARTLY":[{"def":"With art or skill.","pos":""},{"def":"Of or pertaining to the breadfruit, or to the genus Artocarpus.","pos":""}],"ARTOTYPE":[{"def":"A kind of autotype.","pos":""}],"ARTOTYRITE":[{"def":"One of a sect in the primitive church, who celebrated the Lord's Supper with bread and cheese, alleging that the first oblations of men not only of the fruit of the earth, but of their flocks.","pos":""}],"ARTOW":[{"def":"A contraction of art thou.","pos":""}],"ARTSMAN":[{"def":"A man skilled in an art or in arts.","pos":""}]}