{"TID":[{"def":"Tender; soft; nice; -- now only used in tidbit.","pos":""}],"TIDAL":[{"def":"Of or pertaining to tides; caused by tides; having tides; periodically rising and falling, or following and ebbing; as, tidal waters.","pos":""}],"TIDBIT":[{"def":"A delicate or tender piece of anything eatable; a delicious morsel.","pos":""}],"TIDDE":[{"def":"To use with tenderness; to fondle.","pos":""}],"TIDDLEDYWINKS":[{"def":"A game in which the object is to snap small disks of bone, ivory, or the like, from a flat surface, as of a table, into a small cup or basket; --called also tiddlywinks.","pos":""}],"TIDDLYWINKS":[{"def":"Same as Tiddledywinks.","pos":""}],"TIDE":[{"def":"The period of twelve hours.","pos":""}],"TIDE-RODE":[{"def":"Swung by the tide when at anchor; -- opposed to wind-rode.","pos":""}],"TIDED":[{"def":"Affected by the tide; having a tide.","pos":""}],"TIDELAND":[{"def":"Land that is overflowed by tide water; hence, land near the sea.","pos":""}],"TIDESMAN":[{"def":"A customhouse officer who goes on board of a merchant ship to secure payment of the duties; a tidewaiter.","pos":""}],"TIDEWAITER":[{"def":"A customhouse officer who watches the landing of goods from merchant vessels, in order to secure payment of duties.","pos":""}],"TIDEWAY":[{"def":"Channel in which the tide sets.","pos":""}],"TIDIFE":[{"def":"The blue titmouse.","pos":""}],"TIDILY":[{"def":"In a tidy manner.","pos":""}],"TIDINESS":[{"def":"The quality or state of being tidy.","pos":""}],"TIDINGS":[{"def":"Account of what has taken place, and was not before known; news.","pos":""}],"TIDOLOGY":[{"def":"A discourse or treatise upon the tides; that part of science which treats of tides.","pos":""}],"TIDY":[{"def":"The wren; -- called also tiddy.","pos":""}],"TIDYTIPS":[{"def":"A California composite plant (Layia platyglossa), the flower of which has yellow rays tipped with white.","pos":""}]}