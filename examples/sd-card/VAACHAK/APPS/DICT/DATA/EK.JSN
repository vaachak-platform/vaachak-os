{"EKALUMINIUM":[{"def":"The name given to a hypothetical element, -- later discovered and called gallium.","pos":""}],"EKASILICON":[{"def":"The name of a hypothetical element predicted and afterwards discovered and named germanium; -- so called because it was a missing analogue of the silicon group.","pos":""}],"EKE":[{"def":"To increase; to add to; to augment; -- now commonly used with out, the notion conveyed being to add to, or piece out by a laborious, inferior, or scanty addition; as, to eke out a scanty supply of one kind with some other.","pos":""}],"EKEBERGITE":[{"def":"A variety of scapolite.","pos":""}],"EKENAME":[{"def":"An additional or epithet name; a nickname.","pos":""}]}