{"SIN":[{"def":"Old form of Since.","pos":""}],"SINALBIN":[{"def":"A glucoside found in the seeds of white mustard (Brassica alba, formerly Sinapis alba), and extracted as a white crystalline substance.","pos":""}],"SINAMINE":[{"def":"A bitter white crystalline nitrogenous substance, obtained indirectly from oil of mustard and ammonia; -- called also allyl melamine.","pos":""}],"SINAPATE":[{"def":"A salt of sinapic acid.","pos":""}],"SINAPIC":[{"def":"Of or pertaining to sinapine; specifically, designating an acid (C11H12O5) related to gallic acid, and obtained by the decomposition of sinapine, as a white crystalline substance.","pos":""}],"SINAPINE":[{"def":"An alkaloid occuring in the seeds of mustard.","pos":""}],"SINAPIS":[{"def":"A disused generic name for mustard; -- now called Brassica.","pos":""}],"SINAPISIN":[{"def":"A substance extracted from mustard seed and probably identical with sinalbin.","pos":""}],"SINAPISM":[{"def":"A plaster or poultice composed principally of powdered mustard seed, or containing the volatile oil of mustard seed.","pos":""}],"SINAPOLEIC":[{"def":"Of or pertaining to mustard oil; specifically, designating an acid of the oleic acid series said to occur in mistard oil.","pos":""}],"SINAPOLINE":[{"def":"A nitrogenous base, CO.","pos":""}],"SINCE":[{"def":"From a definite past time until now; as, he went a month ago, and I have not seen him since.","pos":""},{"def":"In the time past, counting backward from the present; before this or now; ago.","pos":""}],"SINCERE":[{"def":"Pure; unmixed; unadulterated.","pos":""},{"def":"Whole; perfect; unhurt; uninjured.","pos":""}],"SINCERELY":[{"def":"In a sincere manner.","pos":""}],"SINCERENESS":[{"def":"Same as Sincerity.","pos":""}],"SINCERITY":[{"def":"The quality or state of being sincere; honesty of mind or intention; freedom from simulation, hypocrisy, disguise, or false pretense; sincereness.","pos":""}],"SINCH":[{"def":"A saddle girth made of leather, canvas, woven horsehair, or woven grass.","pos":""}],"SINCIPITAL":[{"def":"Of or pertaining to the sinciput; being in the region of the sinciput.","pos":""}],"SINCIPUT":[{"def":"The fore part of the head.","pos":""},{"def":"The part of the head of a bird between the base of the bill and the vertex.","pos":""}],"SINDI":[{"def":"A native of Sind, India, esp.","pos":""}],"SINDON":[{"def":"A small rag or pledget introduced into the hole in the cranium made by a trephine.","pos":""}],"SINE":[{"def":"Trigonometrical function, under Function.","pos":""}],"SINECURAL":[{"def":"Of or pertaining to a sinecure; being in the nature of a sinecure.","pos":""}],"SINECURE":[{"def":"An ecclesiastical benefice without the care of souls.","pos":""},{"def":"Any office or position which requires or involves little or no responsibility, labor, or active service.","pos":""}],"SINECURISM":[{"def":"The state of having a sinecure.","pos":""}],"SINECURIST":[{"def":"One who has a sinecure.","pos":""}],"SINEW":[{"def":"A tendon or tendonous tissue.","pos":""}],"SINEW-SHRUNK":[{"def":"Having the sinews under the belly shrunk by excessive fatigue.","pos":""}],"SINEWED":[{"def":"Furnished with sinews; as, a strong-sinewed youth.","pos":""}],"SINEWINESS":[{"def":"Quality of being sinewy.","pos":""}],"SINEWLESS":[{"def":"Having no sinews; hence, having no strength or vigor.","pos":""}],"SINEWY":[{"def":"Pertaining to, consisting of, or resembling, a sinew or sinews.","pos":""},{"def":"Well braced with, or as if with, sinews; nervous; vigorous; strong; firm; tough; as, the sinewy Ajax.","pos":""}],"SINFUL":[{"def":"Tainted with, or full of, sin; wicked; iniquitous; criminal; unholy; as, sinful men; sinful thoughts.","pos":""}],"SING":[{"def":"To utter sounds with musical inflections or melodious modulations of voice, as fancy may dictate, or according to the notes of a song or tune, or of a given part (as alto, tenor, etc.","pos":""},{"def":"To utter sweet melodious sounds, as birds do.","pos":""}],"SINGE":[{"def":"To burn slightly or superficially; to burn the surface of; to burn the ends or outside of; as, to singe the hair or the skin.","pos":""}],"SINGER":[{"def":"One who, or that which, singes.","pos":""}],"SINGHALESE":[{"def":"Same as Cingalese.","pos":""}],"SINGINGLY":[{"def":"With sounds like singing; with a kind of tune; in a singing tone.","pos":""}],"SINGLE":[{"def":"One only, as distinguished from more than one; consisting of one alone; individual; separate; as, a single star.","pos":""},{"def":"Alone; having no companion.","pos":""}],"SINGLE TAX":[{"def":"A tax levied upon land alone, irrespective of improvements, -- advocated by certain economists as the sole source of public revenue.","pos":""}],"SINGLE-ACTING":[{"def":"Having simplicity of action; especially (Mach.","pos":""}],"SINGLE-BREASTED":[{"def":"Lapping over the breast only far enough to permit of buttoning, and having buttons on one edge only; as, a single-breasted coast.","pos":""}],"SINGLE-FOOT":[{"def":"An irregular gait of a horse; -- called also single-footed pace.","pos":""}],"SINGLE-HANDED":[{"def":"Having but one hand, or one workman; also, alone; unassisted.","pos":""}],"SINGLE-HEARTED":[{"def":"Having an honest heart; free from duplicity.","pos":""}],"SINGLE-MINDED":[{"def":"Having a single purpose; hence, artless; guileless; single- hearted.","pos":""}],"SINGLE-SURFACED":[{"def":"Having one surface; -- said specif.","pos":""}],"SINGLENESS":[{"def":"The quality or state of being single, or separate from all others; the opposite of doubleness, complication, or multiplicity.","pos":""},{"def":"Freedom from duplicity, or secondary and selfish ends; purity of mind or purpose; simplicity; sincerity; as, singleness of purpose; singleness of heart.","pos":""}],"SINGLET":[{"def":"An unlined or undyed waistcoat; a single garment; -- opposed to doublet.","pos":""}],"SINGLETON":[{"def":"In certain games at cards, as whist, a single card of any suit held at the deal by a player; as, to lead a singleton.","pos":""}],"SINGLETREE":[{"def":"The pivoted or swinging bar to which the traces of a harnessed horse are fixed; a whiffletree.","pos":""}],"SINGLY":[{"def":"Individually; particularly; severally; as, to make men singly and personally good.","pos":""},{"def":"Only; by one's self; alone.","pos":""}],"SINGSONG":[{"def":"Bad singing or poetry.","pos":""},{"def":"A drawling or monotonous tone, as of a badly executed song.","pos":""}],"SINGSPIEL":[{"def":"A dramatic work, partly in dialogue and partly in song, of a kind popular in Germany in the latter part of the 18th century.","pos":""}],"SINGULAR":[{"def":"Existing by itself; single; individual.","pos":""},{"def":"Each; individual; as, to convey several parcels of land, all and singular.","pos":""}],"SINGULARIST":[{"def":"One who affects singularity.","pos":""}],"SINGULARITY":[{"def":"The quality or state of being singular; some character or quality of a thing by which it is distinguished from all, or from most, others; peculiarity.","pos":""},{"def":"Anything singular, rare, or curious.","pos":""}],"SINGULARIZE":[{"def":"To make singular or single; to distinguish.","pos":""}],"SINGULARLY":[{"def":"In a singular manner; in a manner, or to a degree, not common to others; extraordinarily; as, to be singularly exact in one's statements; singularly considerate of others.","pos":""},{"def":"Strangely; oddly; as, to behave singularly.","pos":""}],"SINGULT":[{"def":"A sigh or sobbing; also, a hiccough.","pos":"noun"}],"SINGULTOUS":[{"def":"Relating to, or affected with, hiccough.","pos":""}],"SINIC":[{"def":"Of or pertaining to the Chinese and allied races; Chinese.","pos":""}],"SINICAL":[{"def":"Of or pertaining to a sine; employing, or founded upon, sines; as, a sinical quadrant.","pos":""}],"SINICISM":[{"def":"Anything peculiar to the Chinese; esp.","pos":""}],"SINIGRIN":[{"def":"A glucoside found in the seeds of black mustard (Brassica nigra, formerly Sinapis nigra) It resembles sinalbin, and consists of a potassium salt of myronic acid.","pos":""}],"SINISTER":[{"def":"On the left hand, or the side of the left hand; left; -- opposed to dexter, or right.","pos":""},{"def":"Unlucky; inauspicious; disastrous; injurious; evil; -- the left being usually regarded as the unlucky side; as, sinister influences.","pos":""}],"SINISTER-HANDED":[{"def":"Left-handed; hence, unlucky.","pos":""}],"SINISTERLY":[{"def":"In a sinister manner.","pos":""}],"SINISTRAD":[{"def":"Toward the left side; sinistrally.","pos":""}],"SINISTRAL":[{"def":"Having the whorls of the spire revolving or rising to the left; reversed; -- said of certain spiral shells.","pos":""}],"SINISTRALITY":[{"def":"The quality or state of being sinistral.","pos":""}],"SINISTRALLY":[{"def":"Toward the left; in a sinistral manner.","pos":""}],"SINISTRIN":[{"def":"A mucilaginous carbohydrate, resembling achroödextrin, extracted from squill as a colorless amorphous substance; -- so called because it is levorotatory.","pos":""}],"SINISTRORSAL":[{"def":"Rising spirally from right to left (of the spectator); sinistrorse.","pos":""}],"SINISTRORSE":[{"def":"Turning to the left (of the spectator) in the ascending line; - - the opposite of dextrorse.","pos":""}],"SINISTROUS":[{"def":"Being on the left side; inclined to the left; sinistral.","pos":""},{"def":"Wrong; absurd; perverse.","pos":""}],"SINISTROUSLY":[{"def":"In a sinistrous manner; perversely; wrongly; unluckily.","pos":""},{"def":"With a tendency to use the left hand.","pos":""}],"SINK":[{"def":"To fall by, or as by, the force of gravity; to descend lower and lower; to decline gradually; to subside; as, a stone sinks in water; waves rise and sink; the sun sinks in the west.","pos":""},{"def":"To enter deeply; to fall or retire beneath or below the surface; to penetrate.","pos":""}],"SINKER":[{"def":"One who, or that which, sinks.","pos":""}],"SINNER":[{"def":"One who has sinned; especially, one who has sinned without repenting; hence, a persistent and incorrigible transgressor; one condemned by the law of God.","pos":""}],"SINNERESS":[{"def":"A woman who sins.","pos":""}],"SINOLOGICAL":[{"def":"Relating to the Chinese language or literature.","pos":""}],"SINOLOGUE":[{"def":"A student of Chinese; one versed in the Chinese language, literature, and history.","pos":""}],"SINOLOGY":[{"def":"That branch of systemized knowledge which treats of the Chinese, their language, literature, etc.","pos":""}],"SINOPER":[{"def":"A red pigment made from sinopite.","pos":""}],"SINOPITE":[{"def":"A brickred ferruginous clay used by the ancients for red paint.","pos":""}],"SINOPLE":[{"def":"Ferruginous quartz, of a blood-red or brownish red color, sometimes with a tinge of yellow.","pos":""}],"SINSRING":[{"def":"Same as Banxring.","pos":""}],"SINTER":[{"def":"Dross, as of iron; the scale which files from iron when hammered; -- applied as a name to various minerals.","pos":""},{"def":"See Shinto, etc.","pos":""}],"SINTOC":[{"def":"A kind of spice used in the East Indies, consisting of the bark of a species of Cinnamomum.","pos":""}],"SINUATE":[{"def":"Having the margin alternately curved inward and outward; having rounded lobes separated by rounded sinuses; sinuous; wavy.","pos":""}],"SINUATED":[{"def":"Same as Sinuate.","pos":""}],"SINUATION":[{"def":"A winding or bending in and out.","pos":""}],"SINUOSITY":[{"def":"Quality or state of being sinuous.","pos":""},{"def":"A bend, or a series of bends and turns; a winding, or a series of windings; a wave line; a curve.","pos":""}],"SINUOUS":[{"def":"Bending in and out; of a serpentine or undulating form; winding; crooked.","pos":""}],"SINUPALLIATE":[{"def":"Having a pallial sinus.","pos":""}],"SINUS":[{"def":"A cavity; a depression.","pos":""},{"def":"A narrow, elongated cavity, in which pus is collected; an elongated abscess with only a small orifice.","pos":""}],"SINUSOID":[{"def":"The curve whose ordinates are proportional to the sines of the abscissas, the equation of the curve being y = a sin x.","pos":""}],"SINUSOIDAL":[{"def":"Of or pertaining to a sinusoid; like a sinusoid.","pos":""}]}