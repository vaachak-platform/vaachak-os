{"BUNCH":[{"def":"A small isolated mass of ore, as distinguished from a continuous vein.","pos":""}],"BUNCH GRASS":[{"def":"A grass growing in bunches and affording pasture.","pos":""}],"BUNCH-BACKED":[{"def":"Having a bunch on the back; crooked.","pos":""}],"BUNCHBERRY":[{"def":"The dwarf cornel (Cornus Canadensis), which bears a dense cluster of bright red, edible berries.","pos":""}],"BUNCHINESS":[{"def":"The quality or condition of being bunchy; knobbiness.","pos":""}],"BUNCHY":[{"def":"Yielding irregularly; sometimes rich, sometimes poor; as, a bunchy mine.","pos":""},{"def":"Speech-making for the gratification of constituents, or to gain public applause; flattering talk for a selfish purpose; anything said for mere show.","pos":""}],"BUND":[{"def":"League; confederacy; esp.","pos":""}],"BUNDER":[{"def":"A boat or raft used in the East Indies in the landing of passengers and goods.","pos":""}],"BUNDES-VERSAMMLUNG":[{"def":"See Legislature, Switzerland.","pos":""}],"BUNDESRATH":[{"def":"The federal council of the German Empire.","pos":""}],"BUNDLE":[{"def":"A number of things bound together, as by a cord or envelope, into a mass or package convenient for handling or conveyance; a loose package; a roll; as, a bundle of straw or of paper; a bundle of old clothes.","pos":""}],"BUNDOBUST":[{"def":"System; discipline.","pos":""}],"BUNG":[{"def":"The large stopper of the orifice in the bilge of a cask.","pos":""},{"def":"The orifice in the bilge of a cask through which it is filled; bunghole.","pos":""}],"BUNGALOW":[{"def":"A thatched or tiled house or cottage, of a single story, usually surrounded by a veranda.","pos":""}],"BUNGARUM":[{"def":"A venomous snake of India, of the genus Bungarus, allied to the cobras, but without a hood.","pos":""}],"BUNGLE":[{"def":"To act or work in a clumsy, awkward manner.","pos":""}],"BUNGLER":[{"def":"A clumsy, awkward workman; one who bungles.","pos":""}],"BUNGLING":[{"def":"Unskillful; awkward; clumsy; as, a bungling workman.","pos":""}],"BUNGLINGLY":[{"def":"Clumsily; awkwardly.","pos":""}],"BUNGO":[{"def":"A kind of canoe used in Central and South America; also, a kind of boat used in the Southern United States.","pos":""}],"BUNK":[{"def":"A wooden case or box, which serves for a seat in the daytime and for a bed at night.","pos":""},{"def":"One of a series of berths or bed places in tiers.","pos":""}],"BUNKER":[{"def":"A sort of chest or box, as in a window, the lid of which serves for a seat.","pos":""},{"def":"A large bin or similar receptacle; as, a coal bunker.","pos":""}],"BUNKO":[{"def":"A kind of swindling game or scheme, by means of cards or by a sham lottery.","pos":""}],"BUNNY":[{"def":"A great collection of ore without any vein coming into it or going out from it.","pos":""}],"BUNSEN CELL":[{"def":"A zinc-carbon cell in which the zinc (amalgamated) is surrounded by dilute sulphuric acid, and the carbon by nitric acid or a chromic acid mixture, the two plates being separated by a porous cup.","pos":""},{"def":"See under Battery, and Burner.","pos":""}],"BUNT":[{"def":"A fungus (Ustilago foetida) which affects the ear of cereals, filling the grains with a fetid dust; -- also called pepperbrand.","pos":""}],"BUNTER":[{"def":"A woman who picks up rags in the streets; hence, a low, vulgar woman.","pos":""}],"BUNTING":[{"def":"A bird of the genus Emberiza, or of an allied genus, related to the finches and sparrows (family Fringillidæ).","pos":""},{"def":"A thin woolen stuff, used chiefly for flags, colors, and ships' signals.","pos":""}],"BUNTLINE":[{"def":"One of the ropes toggled to the footrope of a sail, used to haul up to the yard the body of the sail when taking it in.","pos":""},{"def":"An enlargement and inflammation of a small membranous sac (one of the bursæ muscosæ), usually occurring on the first joint of the great toe.","pos":""}]}