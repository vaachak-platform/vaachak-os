{"LEO":[{"def":"The Lion, the fifth sign of the zodiac, marked thus 2.","pos":""}],"LEOD":[{"def":"People; a nation; a man.","pos":""}],"LEONESE":[{"def":"Of or pertaining to Leon, in Spain.","pos":""},{"def":"A native or natives of Leon.","pos":""}],"LEONID":[{"def":"One of the shooting stars which constitute the star shower that recurs near the fourteenth of November at intervals of about thirty- three years; so called because shooting stars appear on the heavens to move in lines directed from the constellation Leo.","pos":""}],"LEONINE":[{"def":"Pertaining to, or characteristic of, the lion; as, a leonine look; leonine repacity.","pos":""}],"LEONTODON":[{"def":"A genus of liguliflorous composite plants, including the fall dandelion (L.","pos":""}],"LEOPARD":[{"def":"A large, savage, carnivorous mammal (Felis leopardus).","pos":""}],"LEOPARD'S BANE":[{"def":"A name of several harmless plants, as Arnica montana, Senecio Doronicum, and Paris quadrifolia.","pos":""}]}