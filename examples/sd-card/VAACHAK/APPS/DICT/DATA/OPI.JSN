{"OPIANIC":[{"def":"Of, pertaining to, or designating, an organic acid obtained by the oxidation of narcotine.","pos":""}],"OPIANINE":[{"def":"An alkaloid found in small quantity in opium.","pos":""}],"OPIANYL":[{"def":"Same as Meconin.","pos":""}],"OPIATE":[{"def":"Originally, a medicine of a thicker consistence than sirup, prepared with opium.","pos":""},{"def":"Any medicine that contains opium, and has the quality of inducing sleep or repose; a narcotic.","pos":""}],"OPIATED":[{"def":"Mixed with opiates.","pos":""},{"def":"Under the influence of opiates.","pos":""}],"OPIFICER":[{"def":"An artificer; a workman.","pos":""}],"OPINABLE":[{"def":"Capable of being opined or thought.","pos":""}],"OPINATION":[{"def":"The act of thinking; a supposition.","pos":""}],"OPINATIVE":[{"def":"Obstinate in holding opinions; opinionated.","pos":""}],"OPINATOR":[{"def":"One fond of his own opinious; one who holds an opinion.","pos":""}],"OPINE":[{"def":"To have an opinion; to judge; to think; to suppose.","pos":""}],"OPINER":[{"def":"OPINIASTER; OPINIATRE O`pin*ias\"ter, O`pin*ia\"tre, a.","pos":""}],"OPINIATE":[{"def":"To hold or maintain persistently.","pos":""}],"OPINIATIVE":[{"def":"One who is opinionated.","pos":""}],"OPINIATRETY":[{"def":"Obstinacy in opinious.","pos":""}],"OPINICUS":[{"def":"An imaginary animal borne as a charge, having wings, an eagle's head, and a short tail; -- sometimes represented without wings.","pos":""}],"OPINION":[{"def":"The formal decision, or expression of views, of a judge, an umpire, a counselor, or other party officially called upon to consider and decide upon a matter or point submitted.","pos":""}],"OPINIONABLE":[{"def":"Being, or capable of being, a matter of opinion; that can be thought; not positively settled; as, an opinionable doctrine.","pos":""}],"OPINIONATED":[{"def":"Stiff in opinion; firmly or unduly adhering to one's own opinion or to preconceived notions; obstinate in opinion.","pos":""}],"OPINIONATELY":[{"def":"O*pin\"ion*ate*ly, adv.","pos":""}],"OPINIONATIVE":[{"def":"Unduly attached to one's own opinions; opinionated.","pos":""},{"def":"Of the nature of an opinion; conjectured.","pos":""}],"OPINIONATOR":[{"def":"An opinionated person; one given to conjecture.","pos":""}],"OPINIONED":[{"def":"Opinionated; conceited.","pos":""}],"OPINIONIST":[{"def":"One fond of his own notions, or unduly attached to his own opinions.","pos":""}],"OPISOMETER":[{"def":"An instrument with a revolving wheel for measuring a curved line, as on a map.","pos":""}],"OPISTHION":[{"def":"The middle of the posterior, or dorsal, margin of the great foramen of the skull.","pos":""},{"def":"A division of gastropod Mollusca, in which the breathing organs are usually situated behind the heart.","pos":""}],"OPISTHOBRANCHIATE":[{"def":"Of or pertaining to the Opisthobranchiata.","pos":""},{"def":"One of the Opisthobranchiata.","pos":""}],"OPISTHODOME":[{"def":"A back chamber; especially, that part of the naos, or cella, farthest from the main entrance, sometimes having an entrance of its own, and often used as a treasury.","pos":""}],"OPISTHOGLYPHA":[{"def":"A division of serpents which have some of the posterior maxillary teeth grooved for fangs.","pos":""}],"OPISTHOGRAPHY":[{"def":"A writing upon the back of anything, as upon the back of a leaf or sheet already written upon on one side.","pos":""}],"OPISTHOMI":[{"def":"An order of eellike fishes having the scapular arch attached to the vertebræ, but not connected with the skull.","pos":""}],"OPISTHOPULMONATE":[{"def":"Having the pulmonary sac situated posteriorly; -- said of certain air-breathing Mollusca.","pos":""}],"OPISTHOTIC":[{"def":"The inferior and posterior of the three elements forming the periotic bone.","pos":""}],"OPISTHOTONOS":[{"def":"A tetanic spasm in which the body is bent backwards and stiffened.","pos":""}],"OPITULATION":[{"def":"The act of helping or aiding; help.","pos":""}],"OPIUM":[{"def":"The inspissated juice of the Papaver somniferum, or white poppy.","pos":""}]}