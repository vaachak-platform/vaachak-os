{"DOCENT":[{"def":"Serving to instruct; teaching.","pos":""}],"DOCETAE":[{"def":"Ancient heretics who held that Christ's body was merely a phantom or appearance.","pos":""}],"DOCETIC":[{"def":"Pertaining to, held by, or like, the Docetæ.","pos":""}],"DOCETISM":[{"def":"The doctrine of the Docetæ.","pos":""}],"DOCHMIAC":[{"def":"Pertaining to, or containing, the dochmius.","pos":""}],"DOCHMIUS":[{"def":"A foot of five syllables (usually DOCIBILITY; DOCIBLENESS Doc`i*bil\"i*ty, Doc\"i*ble*ness, n.","pos":""},{"def":"Aptness for being taught; teachableness; docility.","pos":""}],"DOCIBLE":[{"def":"Easily taught or managed; teachable.","pos":""}],"DOCILE":[{"def":"Teachable; easy to teach; docible.","pos":""},{"def":"Disposed to be taught; tractable; easily managed; as, a docile child.","pos":""}],"DOCILITY":[{"def":"Willingness to be taught; tractableness.","pos":""}],"DOCIMACY":[{"def":"The art or practice of applying tests to ascertain the nature, quality, etc.","pos":""}],"DOCIMASTIC":[{"def":"Proving by experiments or tests.","pos":""}],"DOCIMOLOGY":[{"def":"A treatise on the art of testing, as in assaying metals, etc.","pos":""}],"DOCK":[{"def":"A genus of plants (Rumex), some species of which are well-known weeds which have a long taproot and are difficult of extermination.","pos":""}],"DOCKAGE":[{"def":"A charge for the use of a dock.","pos":""}],"DOCKET":[{"def":"A small piece of paper or parchment, containing the heads of a writing; a summary or digest.","pos":""},{"def":"A bill tied to goods, containing some direction, as the name of the owner, or the place to which they are to be sent; a label.","pos":""}],"DOCKYARD":[{"def":"A yard or storage place for all sorts of naval stores and timber for shipbuilding.","pos":""}],"DOCOGLOSSA":[{"def":"An order of gastropods, including the true limpets, and having the teeth on the odontophore or lingual ribbon.","pos":""}],"DOCTOR":[{"def":"The friar skate.","pos":""}],"DOCTORAL":[{"def":"Of or relating to a doctor, or to the degree of doctor.","pos":""}],"DOCTORALLY":[{"def":"In the manner of a doctor.","pos":""}],"DOCTORATE":[{"def":"The degree, title, or rank, of a doctor.","pos":""}],"DOCTORESS":[{"def":"A female doctor.","pos":""}],"DOCTORLY":[{"def":"Like a doctor or learned man.","pos":""}],"DOCTRESS":[{"def":"A female doctor.","pos":""}],"DOCTRINABLE":[{"def":"Of the nature of, or constituting, doctrine.","pos":""}],"DOCTRINAIRE":[{"def":"One who would apply to political or other practical concerns the abstract doctrines or the theories of his own philosophical system; a propounder of a new set of opinions; a dogmatic theorist.","pos":""}],"DOCTRINAL":[{"def":"Pertaining to, or containing, doctrine or something taught and to be believed; as, a doctrinal observation.","pos":""},{"def":"Pertaining to, or having to do with, teaching.","pos":""}],"DOCTRINALLY":[{"def":"In a doctrinal manner or for; by way of teaching or positive direction.","pos":""}],"DOCTRINARIANISM":[{"def":"The principles or practices of the Doctrinaires.","pos":""}],"DOCTRINE":[{"def":"Teaching; instruction.","pos":""},{"def":"That which is taught; what is held, put forth as true, and supported by a teacher, a school, or a sect; a principle or position, or the body of principles, in any branch of knowledge; any tenet or dogma; a principle of faith; as, the doctrine of atoms; the doctrine of chances.","pos":""}],"DOCUMENT":[{"def":"That which is taught or authoritatively set forth; precept; instruction; dogma.","pos":""},{"def":"An example for instruction or warning.","pos":""}],"DOCUMENTAL":[{"def":"Of or pertaining to instruction.","pos":""},{"def":"Of or pertaining to written evidence; documentary; as, documental testimony.","pos":""}],"DOCUMENTARY":[{"def":"Pertaining to written evidence; contained or certified in writing.","pos":""},{"def":"To cut off, as wool from sheep's tails; to lop or clip off.","pos":""}]}