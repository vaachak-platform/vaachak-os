{"HIN":[{"def":"A Hebrew measure of liquids, containing three quarts, one pint, one gill, English measure.","pos":""}],"HIND":[{"def":"The female of the red deer, of which the male is the stag.","pos":""},{"def":"A spotted food fish of the genus Epinephelus, as E.","pos":""}],"HINDBRAIN":[{"def":"The posterior of the three principal divisions of the brain, including the epencephalon and metencephalon.","pos":""}],"HINDER":[{"def":"Of or belonging to that part or end which is in the rear, or which follows; as, the hinder part of a wagon; the hinder parts of a horse.","pos":""}],"HINDERANCE":[{"def":"Same as Hindrance.","pos":""}],"HINDERER":[{"def":"One who, or that which, hinders.","pos":""}],"HINDEREST":[{"def":"Hindermost; -- superl.","pos":""}],"HINDERLING":[{"def":"A worthless, base, degenerate person or animal.","pos":""},{"def":"Furthest in or toward the rear; last.","pos":""}],"HINDGUT":[{"def":"The posterior part of the alimentary canal, including the rectum, and sometimes the large intestine also.","pos":""}],"HINDI":[{"def":"The name given by Europeans to that form of the Hindustani language which is chiefly spoken by native Hindoos.","pos":""}],"HINDLEYS SCREW":[{"def":"A screw cut on a solid whose sides are arcs of the periphery of a wheel into the teeth of which the screw is intended to work.","pos":""},{"def":"A native inhabitant of Hindostan.","pos":""}],"HINDRANCE":[{"def":"The act of hindering, or the state of being hindered.","pos":""},{"def":"That which hinders; an impediment.","pos":""}],"HINE":[{"def":"A servant; a farm laborer; a peasant; a hind.","pos":""}],"HINGE":[{"def":"The hook with its eye, or the joint, on which a door, gate, lid, etc.","pos":""},{"def":"That on which anything turns or depends; a governing principle; a cardinal point or rule; as, this argument was the hinge on which the question turned.","pos":""}],"HINGED":[{"def":"Furnished with hinges.","pos":""}],"HINGELESS":[{"def":"Without a hinge or joint.","pos":""}],"HINK":[{"def":"To neigh; to whinny.","pos":""}],"HINNY":[{"def":"A hybrid between a stallion and an ass.","pos":""}],"HINT":[{"def":"To bring to mind by a slight mention or remote allusion; to suggest in an indirect manner; as, to hint a suspicion.","pos":""}],"HINTERLAND":[{"def":"The land or region lying behind the coast district.","pos":""}],"HINTINGLY":[{"def":"In a hinting manner.","pos":""}]}