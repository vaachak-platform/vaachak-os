{"SERVABLE":[{"def":"Capable of being preserved.","pos":""}],"SERVAGE":[{"def":"Serfage; slavery; servitude.","pos":""}],"SERVAL":[{"def":"An African wild cat (Felis serval) of moderate size.","pos":""}],"SERVALINE":[{"def":"Related to, or resembling, the serval.","pos":""}],"SERVANT":[{"def":"One who serves, or does services, voluntarily or on compulsion; a person who is employed by another for menial offices, or for other labor, and is subject to his command; a person who labors or exerts himself for the benefit of another, his master or employer; a subordinate helper.","pos":""},{"def":"One in a state of subjection or bondage.","pos":""}],"SERVANTRY":[{"def":"A body of servants; servants, collectively.","pos":""}],"SERVE":[{"def":"To lead off in delivering (the ball).","pos":""},{"def":"To wind spun yarn, or the like, tightly around (a rope or cable, etc.","pos":""}],"SERVER":[{"def":"A tray for dishes; a salver.","pos":""}],"SERVIAN":[{"def":"Of or pertaining to Servia, a kingdom of Southern Europe.","pos":""},{"def":"A native or inhabitant of Servia.","pos":""}],"SERVICE":[{"def":"The act of bringing to notice, either actually or constructively, in such manner as is prescribed by law; as, the service of a subpoena or an attachment.","pos":""},{"def":"The materials used for serving a rope, etc.","pos":""}],"SERVICE UNIFORM":[{"def":"The uniform prescribed in regulations for active or routine service, in distinction from dress, full dress, etc.","pos":""}],"SERVICEABLE":[{"def":"Doing service; promoting happiness, interest, advantage, or any good; useful to any end; adapted to any good end use; beneficial; advantageous.","pos":""},{"def":"Prepared for rendering service; capable of, or fit for, the performance of duty; hence, active; diligent.","pos":""}],"SERVICEAGE":[{"def":"A cap or hat worn by officers or enlisted men when full-dress uniform, or dress uniform, is not worn.","pos":""}],"SERVILE":[{"def":"Of or pertaining to a servant or slave; befitting a servant or a slave; proceeding from dependence; hence, meanly submissive; slavish; mean; cringing; fawning; as, servile flattery; servile fear; servile obedience.","pos":""},{"def":"Held in subjection; dependent; enslaved.","pos":""}],"SERVILELY":[{"def":"In a servile manner; slavishly.","pos":""}],"SERVILENESS":[{"def":"Quality of being servile; servility.","pos":""}],"SERVILITY":[{"def":"The quality or state of being servile; servileness.","pos":""}],"SERVING":[{"def":"Serv\"ing, Defn: a & n.","pos":""}],"SERVITE":[{"def":"One of the order of the Religious Servants of the Holy Virgin, founded in Florence in 1223.","pos":""}],"SERVITOR":[{"def":"An undergraduate, partly supported by the college funds, whose duty it formerly was to wait at table.","pos":""}],"SERVITORSHIP":[{"def":"The office, rank, or condition of a servitor.","pos":""}],"SERVITUDE":[{"def":"A right whereby one thing is subject to another thing or person for use or convenience, contrary to the common right.","pos":""}],"SERVITURE":[{"def":"Servants, collectively.","pos":""}],"SERVO-MOTOR":[{"def":"A relay apparatus; specif.","pos":""}]}