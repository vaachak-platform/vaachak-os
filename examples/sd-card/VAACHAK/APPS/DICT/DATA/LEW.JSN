{"LEW":[{"def":"Lukewarm; tepid.","pos":""}],"LEWD":[{"def":"Not clerical; laic; laical; hence, unlearned; simple.","pos":""},{"def":"Belonging to the lower classes, or the rabble; idle and lawless; bad; vicious.","pos":""}],"LEWDSTER":[{"def":"An iron dovetailed tenon, made in sections, which can be fitted into a dovetail mortise; -- used in hoisting large stones, etc.","pos":""},{"def":"A kind of shears used in cropping woolen cloth.","pos":""}]}