{"CRONE":[{"def":"An old woman; -- usually in contempt.","pos":""}],"CRONEL":[{"def":"The iron head of a tilting spear.","pos":""}],"CRONET":[{"def":"The coronet of a horse.","pos":""}],"CRONIAN":[{"def":"Saturnian; -- applied to the North Polar Sea.","pos":""}],"CRONSTEDTITE":[{"def":"A mineral consisting principally of silicate of iron, and crystallizing in hexagonal prisms with perfect basal cleavage; -- so named from the Swedish mineralogist Cronstedt.","pos":""}],"CRONY":[{"def":"An intimate companion; a familiar frend.","pos":""}]}