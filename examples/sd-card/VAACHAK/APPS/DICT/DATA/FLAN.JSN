{"FLANCH":[{"def":"A bearing consisting of a segment of a circle encroaching on the field from the side.","pos":""}],"FLANCHED":[{"def":"Having flanches; -- said of an escutcheon with those bearings.","pos":""}],"FLANCONADE":[{"def":"A thrust in the side.","pos":""}],"FLANEUR":[{"def":"One who strolls about aimlessly; a lounger; a loafer.","pos":""}],"FLANG":[{"def":"A miner's two-pointed pick.","pos":""}],"FLANGE":[{"def":"An external or internal rib, or rim, for strength, as the flange of an iron beam; or for a guide, as the flange of a car wheel (see Car wheel.","pos":""},{"def":"A plate or ring to form a rim at the end of a pipe when fastened to the pipe.","pos":""}],"FLANGED":[{"def":"Having a flange or flanges; as, a flanged wheel.","pos":""}],"FLANK":[{"def":"That part of a bastion which reaches from the curtain to the face, and defends the curtain, the flank and face of the opposite bastion; any part of a work defending another by a fire along the outside of its parapet.","pos":""},{"def":"The side of any building.","pos":""}],"FLANKER":[{"def":"One who, or that which, flanks, as a skirmisher or a body of troops sent out upon the flanks of an army toguard a line of march, or a fort projecting so as to command the side of an assailing body.","pos":""}],"FLANNEL":[{"def":"A soft, nappy, woolen cloth, of loose texture.","pos":""}],"FLANNELED":[{"def":"Covered or wrapped in flannel.","pos":""}],"FLANNEN":[{"def":"Made or consisting of flannel.","pos":""}]}