{"SALIAN":[{"def":"Denoting a tribe of Franks who established themselves early in the fourth century on the river Sala [now Yssel]; Salic.","pos":""}],"SALIANT":[{"def":"Same as Salient.","pos":""}],"SALIAUNCE":[{"def":"Salience; onslaught.","pos":""}],"SALIC":[{"def":"Of or pertaining to the Salian Franks, or to the Salic law so called.","pos":""}],"SALICACEOUS":[{"def":"Belonging or relating to the willow.","pos":""}],"SALICIN":[{"def":"A glucoside found in the leaves of several species of willow (Salix) and poplar, and extracted as a bitter white crystalline substance.","pos":""}],"SALICYL":[{"def":"The hypothetical radical of salicylic acid and of certain related compounds.","pos":""}],"SALICYLAL":[{"def":"A thin, fragrant, colorless oil, HO.","pos":""}],"SALICYLATE":[{"def":"A salt of salicylic acid.","pos":""}],"SALICYLIC":[{"def":"Pertaining to, derived from, or designating, an acid formerly obtained by fusing salicin with potassium hydroxide, and now made in large quantities from phenol (carbolic acid) by the action of carbon dioxide on heated sodium phenolate.","pos":""}],"SALICYLIDE":[{"def":"A white crystalline substance obtained by dehydration of salicylic acid.","pos":""}],"SALICYLITE":[{"def":"A compound of salicylal; -- named after the analogy of a salt.","pos":""}],"SALICYLOL":[{"def":"Same as Salicylal.","pos":""}],"SALICYLOUS":[{"def":"Pertaining to, or designating, a substance called salicylous acid, and now salicylal.","pos":""}],"SALIENCE":[{"def":"That quality or condition of being salient; a leaping; a springing forward; an assaulting.","pos":""},{"def":"The quality or state of projecting, or being projected; projection; protrusion.","pos":""}],"SALIENCY":[{"def":"Quality of being salient; hence, vigor.","pos":""}],"SALIENT":[{"def":"Projectiong outwardly; as, a salient angle; -- opposed to reëntering.","pos":""},{"def":"Represented in a leaping position; as, a lion salient.","pos":""}],"SALIENTLY":[{"def":"In a salient manner.","pos":""}],"SALIFEROUS":[{"def":"Producing, or impregnated with, salt.","pos":""}],"SALIFIABLE":[{"def":"Capable of neutralizing an acid to form a salt; -- said of bases; thus, ammonia is salifiable.","pos":""}],"SALIFICATION":[{"def":"The act, process, or result of salifying; the state of being salified.","pos":""}],"SALIGENIN":[{"def":"A phenol alcohol obtained, by the decomposition of salicin, as a white crystalline substance; -- called also hydroxy-benzyl alcohol.","pos":""}],"SALIGOT":[{"def":"The water chestnut (Trapa natans).","pos":""}],"SALIMETER":[{"def":"An instrument for measuring the amount of salt present in any given solution.","pos":""}],"SALIMETRY":[{"def":"The art or process of measuring the amount of salt in a substance.","pos":""}],"SALINA":[{"def":"A salt marsh, or salt pond, inclosed from the sea.","pos":""}],"SALINA PERIOD":[{"def":"The period in which the American Upper Silurian system, containing the brine-producing rocks of central New York, was formed.","pos":""}],"SALINATION":[{"def":"The act of washing with salt water.","pos":""}],"SALINE":[{"def":"Consisting of salt, or containing salt; as, saline particles; saline substances; a saline cathartic.","pos":""},{"def":"Of the quality of salt; salty; as, a saline taste.","pos":""}],"SALINENESS":[{"def":"The quality or state of being salt; saltness.","pos":""}],"SALINIFEROUS":[{"def":"Same as Saliferous.","pos":""}],"SALINIFORM":[{"def":"Having the form or the qualities of a salt, especially of common salt.","pos":""}],"SALIQUE":[{"def":"She fulmined out her scorn of laws salique.","pos":""}],"SALIRETIN":[{"def":"A yellow amorphous resinoid substance obtained by the action of dilute acids on saligenin.","pos":""}],"SALISBURIA":[{"def":"The ginkgo tree (Ginkgo biloba, or Salisburia adiantifolia).","pos":""}],"SALITE":[{"def":"To season with salt; to salt.","pos":""}],"SALIVA":[{"def":"The secretion from the salivary glands.","pos":""}],"SALIVANT":[{"def":"Producing salivation.","pos":""}],"SALIVARY":[{"def":"Of or pertaining to saliva; producing or carrying saliva; as, the salivary ferment; the salivary glands; the salivary ducts, etc.","pos":""}],"SALIVATE":[{"def":"To produce an abnormal flow of saliva in; to produce salivation or ptyalism in, as by the use of mercury.","pos":""}],"SALIVATION":[{"def":"The act or process of salivating; an excessive secretion of saliva, often accompained with soreness of the mouth and gums; ptyalism.","pos":""}],"SALIVOUS":[{"def":"Pertaining to saliva; of the nature of saliva.","pos":""}]}