{"COACERVATE":[{"def":"Raised into a pile; collected into a crowd; heaped.","pos":""}],"COACERVATION":[{"def":"A heaping together.","pos":""}],"COACH":[{"def":"A cabin on the after part of the quarterdeck, usually occupied by the captain.","pos":""},{"def":"A first-class passenger car, as distinguished from a drawing- room car, sleeping car, etc.","pos":""}],"COACHBOX":[{"def":"The seat of a coachman.","pos":""}],"COACHDOG":[{"def":"One of a breed of dogs trained to accompany carriages; the Dalmatian dog.","pos":""}],"COACHER":[{"def":"one of the side at the bat posted near first or third base to direct a base runner.","pos":""}],"COACHFELLOW":[{"def":"One of a pair of horses employed to draw a coach; hence (Fig.","pos":""}],"COACHMAN":[{"def":"A tropical fish of the Atlantic ocean (Dutes auriga); -- called also charioteer.","pos":""}],"COACHMANSHIP":[{"def":"Skill in driving a coach.","pos":""}],"COACHWHIP SNAKE":[{"def":"A large, slender, harmless snake of the southern United States (Masticophis flagelliformis).","pos":""}],"COACT":[{"def":"To force; to compel; to drive.","pos":""}],"COACTION":[{"def":"Force; compulsion, either in restraining or impelling.","pos":""}],"COACTIVE":[{"def":"Serving to compel or constrain; compulsory; restrictive.","pos":""},{"def":"Acting in concurrence; united in action.","pos":""}],"COACTIVELY":[{"def":"In a coactive manner.","pos":""}],"COACTIVITY":[{"def":"Unity of action.","pos":""}],"COADAPTATION":[{"def":"Mutual adaption.","pos":""}],"COADAPTED":[{"def":"Adapted one to another; as, coadapted pulp and tooth.","pos":""}],"COADJUMENT":[{"def":"Mutual help; coöperation.","pos":""}],"COADJUST":[{"def":"To adjust by mutual adaptations.","pos":""}],"COADJUSTMENT":[{"def":"Mutual adjustment.","pos":""}],"COADJUTANT":[{"def":"Mutually assisting or operating; helping.","pos":""}],"COADJUTING":[{"def":"Mutually assisting.","pos":""}],"COADJUTIVE":[{"def":"Rendering mutual aid; coadjutant.","pos":""}],"COADJUTOR":[{"def":"The assistant of a bishop or of a priest holding a benefice.","pos":""}],"COADJUTORSHIP":[{"def":"The state or office of a coadjutor; joint assistance.","pos":""},{"def":"A female coadjutor or assistant.","pos":""}],"COADJUVANCY":[{"def":"Joint help; coöperation.","pos":""}],"COADUNATE":[{"def":"United at the base, as contiguous lobes of a leaf.","pos":""}],"COADUNATION":[{"def":"Union, as in one body or mass; unity.","pos":""}],"COADVENTURE":[{"def":"An adventure in which two or more persons are partakers.","pos":""}],"COADVENTURER":[{"def":"A fellow adventurer.","pos":""}],"COAFFOREST":[{"def":"To convert into, or add to, a forest.","pos":""}],"COAG":[{"def":"See Coak, a kind of tenon.","pos":""}],"COAGENCY":[{"def":"Agency in common; joint agency or agent.","pos":""}],"COAGENT":[{"def":"An associate in an act; a coworker.","pos":""}],"COAGMENT":[{"def":"To join together.","pos":""}],"COAGMENTATION":[{"def":"The act of joining, or the state of being joined, together; union.","pos":""}],"COAGULABILITY":[{"def":"The quality of being coagulable; capacity of being coagulated.","pos":""}],"COAGULABLE":[{"def":"Capable of being coagulated.","pos":""}],"COAGULANT":[{"def":"That which produces coagulation.","pos":""}],"COAGULATE":[{"def":"To cause (a liquid) to change into a curdlike or semisolid state, not by evaporation but by some kind of chemical reaction; to curdle; as, rennet coagulates milk; heat coagulates the white of an egg.","pos":""}],"COAGULATED":[{"def":"Changed into, or contained in, a coagulum or a curdlike mass; curdled.","pos":""}],"COAGULATION":[{"def":"The change from a liquid to a thickened, curdlike, insoluble state, not by evaporation, but by some kind of chemical reaction; as, the spontaneous coagulation of freshly drawn blood; the coagulation of milk by rennet, or acid, and the coagulation of egg albumin by heat.","pos":""},{"def":"The substance or body formed by coagulation.","pos":""}],"COAGULATIVE":[{"def":"Having the power to cause coagulation; as, a coagulative agent.","pos":""}],"COAGULATOR":[{"def":"That which causes coagulation.","pos":""}],"COAGULATORY":[{"def":"Serving to coagulate; produced by coagulation; as, coagulatory effects.","pos":""}],"COAGULUM":[{"def":"The thick, curdy precipitate formed by the coagulation of albuminous matter; any mass of coagulated matter, as a clot of bloot.","pos":""}],"COAITA":[{"def":"The native name of certain South American monkeys of the genus Ateles, esp.","pos":""}],"COAK":[{"def":"A kind of tenon connecting the face of a scarfed timber with the face of another timber, or a dowel or pin of hard wood or iron uniting timbers.","pos":""}],"COAL":[{"def":"A black, or brownish black, solid, combustible substance, dug from beds or veins in the earth to be used for fuel, and consisting, like charcoal, mainly of carbon, but more compact, and often affording, when heated, a large amount of volatile matter.","pos":""}],"COAL TAR":[{"def":"A thick, black, tarry liquid, obtained by the distillation of bituminous coal in the manufacture of illuminating gas; used for making printer's ink, black varnish, etc.","pos":""}],"COAL WORKS":[{"def":"A place where coal is dug, including the machinery for raising the coal.","pos":""}],"COAL-BLACK":[{"def":"As black as coal; jet black; very black.","pos":""}],"COAL-METER":[{"def":"A licensed or official coal measurer in London.","pos":""}],"COAL-WHIPPER":[{"def":"One who raises coal out of the hold of a ship.","pos":""}],"COALESCE":[{"def":"To grow together; to unite by growth into one body; as, the parts separated by a wound coalesce.","pos":""},{"def":"To unite in one body or product; to combine into one body or community; as, vapors coalesce.","pos":""}],"COALESCENCE":[{"def":"The act or state of growing together, as similar parts; the act of uniting by natural affinity or attraction; the state of being united; union; concretion.","pos":""}],"COALESCENT":[{"def":"Growing together; cohering, as in the organic cohesion of similar parts; uniting.","pos":""}],"COALGOOSE":[{"def":"The cormorant; -- so called from its black color.","pos":""}],"COALITE":[{"def":"To unite or coalesce.","pos":""}],"COALITION":[{"def":"The act of coalescing; union into a body or mass, as of separate bodies or parts; as, a coalition of atoms.","pos":""},{"def":"A combination, for temporary purposes, of persons, parties, or states, having different interests.","pos":""}],"COALITIONIST":[{"def":"One who joins or promotes a coalition; one who advocates coalition.","pos":""}],"COALMOUSE":[{"def":"A small species of titmouse, with a black head; the coletit.","pos":""}],"COALPIT":[{"def":"A pit where coal is dug.","pos":""},{"def":"A place where charcoal is made.","pos":""}],"COALSACK":[{"def":"Any one of the spaces in the Milky Way which are very black, owing to the nearly complete absence of stars; esp.","pos":""}],"COALY":[{"def":"Pertaining to, or resembling, coal; containing coal; of the nature of coal.","pos":""}],"COAMINGS":[{"def":"Raised pieces of wood of iron around a hatchway, skylight, or other opening in the deck, to prevent water from running bellow; esp.","pos":""}],"COANNEX":[{"def":"To annex with something else.","pos":""}],"COAPTATION":[{"def":"The adaptation or adjustment of parts to each other, as of a broken bone or dislocated joint.","pos":""}],"COARCTATE":[{"def":"Pressed together; closely connected; -- applied to insects having the abdomen separated from the thorax only by a constriction.","pos":""}],"COARCTATION":[{"def":"A stricture or narrowing, as of a canal, cavity, or orifice.","pos":""}],"COARSE":[{"def":"Large in bulk, or composed of large parts or particles; of inferior quality or appearance; not fine in material or close in texture; gross; thick; rough; -- opposed to fine; as, coarse sand; coarse thread; coarse cloth; coarse bread.","pos":""},{"def":"Not refined; rough; rude; unpolished; gross; indelicate; as, coarse manners; coarse language.","pos":""}],"COARSE-GRAINED":[{"def":"Having a coarse grain or texture, as wood; hence, wanting in refinement.","pos":""}],"COARSELY":[{"def":"In a coarse manner; roughly; rudely; inelegantly; uncivilly; meanly.","pos":""}],"COARSEN":[{"def":"To make coarse or vulgar; as, to coarsen one's character.","pos":""}],"COARSENESS":[{"def":"The quality or state of being coarse; roughness; melegance; vulgarity; grossness; as, coarseness of food, texture, manners, or language.","pos":""}],"COARTICULATION":[{"def":"The unoin or articulation of bones to form a joint.","pos":""}],"COAST":[{"def":"The side of a thing.","pos":""},{"def":"The exterior line, limit, or border of a country; frontier border.","pos":""}],"COAST AND GEODETIC SURVEY":[{"def":"A bureau of the United States government charged with the topographic and hydrographic survey of the coast and the execution of belts of primary triangulation and lines of precise leveling in the interior.","pos":""}],"COASTAL":[{"def":"Of or pertaining to a cast.","pos":""}],"COASTER":[{"def":"A vessel employed in sailing along a coast, or engaged in the coasting trade.","pos":""},{"def":"One who sails near the shore.","pos":""}],"COASTING":[{"def":"Sailing along or near a coast, or running between ports along a coast.","pos":""}],"COAT":[{"def":"An outer garment fitting the upper part of the body; especially, such a garment worn by men.","pos":""}],"COATEE":[{"def":"A coat with short flaps.","pos":""}],"COATI":[{"def":"A mammal of tropical America of the genus Nasua, allied to the raccoon, but with a longer body, tail, and nose.","pos":""}],"COATING":[{"def":"A coat or covering; a layer of any substance, as a cover or protection; as, the coating of a retort or vial.","pos":""},{"def":"Cloth for coats; as, an assortment of coatings.","pos":""}],"COATLESS":[{"def":"Not wearing a coat; also, not possessing a coat.","pos":""}],"COAX":[{"def":"To persuade by gentle, insinuating courtesy, flattering, or fondling; to wheedle; to soothe.","pos":""}],"COAXATION":[{"def":"The act of croaking.","pos":""}],"COAXINGLY":[{"def":"In a coaxing manner; by coaxing.","pos":""}]}