{"HOG":[{"def":"A quadruped of the genus Sus, and allied genera of Suidæ; esp.","pos":""},{"def":"A rough, flat scrubbing broom for scrubbing a ship's bottom under water.","pos":""}],"HOGBACK":[{"def":"An upward curve or very obtuse angle in the upper surface of any member, as of a timber laid horizontally; -- the opposite of camber.","pos":""}],"HOGCHAIN":[{"def":"A chain or tie rod, in a boat or barge, to prevent the vessel from hogging.","pos":""}],"HOGCHOKER":[{"def":"An American sole (Achirus lineatus, or A.","pos":""}],"HOGCOTE":[{"def":"A shed for swine; a sty.","pos":""}],"HOGFRAME":[{"def":"A trussed frame extending fore and aft, usually above deck, and intended to increase the longitudinal strength and stiffness.","pos":""}],"HOGGED":[{"def":"Broken or strained so as to have an upward curve between the ends.","pos":""}],"HOGGER":[{"def":"A stocking without a foot, worn by coal miners at work.","pos":""}],"HOGGER-PUMP":[{"def":"The for pump in the pit.","pos":""}],"HOGGEREL":[{"def":"A sheep of the second year.","pos":""},{"def":"The upper terminal pipe of a mining pump.","pos":""}],"HOGGERY":[{"def":"Hoggish character or manners; selfishness; greed; beastliness.","pos":""}],"HOGGET":[{"def":"A young boar of the second year.","pos":""},{"def":"A sheep or colt alter it has passed its first year.","pos":""}],"HOGGING":[{"def":"Drooping at the ends; arching;-in distinction from sagging.","pos":""}],"HOGGISH":[{"def":"Swinish; gluttonous; filthy; selfish.","pos":""}],"HOGH":[{"def":"A hill; a cliff.","pos":""}],"HOGMANAY":[{"def":"The old name, in Scotland, for the last day of the year, on which children go about singing, and receive a dole of bread or cakes; also, the entertainment given on that day to a visitor, or the gift given to an applicant.","pos":""}],"HOGNOSESNAKE":[{"def":"A harmless North American snake of the genus Heterodon, esp.","pos":""}],"HOGO":[{"def":"High flavor; strong scent.","pos":""}],"HOGPEN":[{"def":"A pen or sty for hogs.","pos":""}],"HOGREEVE":[{"def":"A civil officer charged with the duty of impounding hogs running at large.","pos":""}],"HOGRINGER":[{"def":"One who puts rings into the snouts of hogs.","pos":""}],"HOGSCORE":[{"def":"A distance lime brawn across the rink or course between the middle line and the tee.","pos":""}],"HOGSHEAD":[{"def":"An English measure of capacity, containing 63 wine gallons, or about 52 Note: The London hogshead of beer was 54 beer gallons, the London hogshead of ale was 48 ale gallons.","pos":""},{"def":"A large cask or barrel, of indefinite contents; esp.","pos":""}],"HOGSKIN":[{"def":"Leather tanned from a hog's skin.","pos":""}],"HOGSTY":[{"def":"A pen, house, or inclosure, for hogs.","pos":""}]}