{"BERAIN":[{"def":"To rain upon; to wet with rain.","pos":""}],"BERATE":[{"def":"To rate or chide vehemently; to scold.","pos":""}],"BERATTLE":[{"def":"To make rattle; to scold vociferously; to cry down.","pos":""}],"BERAY":[{"def":"TO make foul; to soil; to defile.","pos":"verb"}],"BERBE":[{"def":"An African genet (Genetta pardina).","pos":""}],"BERBER":[{"def":"A member of a race somewhat resembling the Arabs, but often classed as Hamitic, who were formerly the inhabitants of the whole of North Africa from the Mediterranean southward into the Sahara, and who still occupy a large part of that region; -- called also Kabyles.","pos":""}],"BERBERINE":[{"def":"An alkaloid obtained, as a bitter, yellow substance, from the root of the barberry, gold thread, and other plants.","pos":""}],"BERCEUSE":[{"def":"A vocal or instrumental composition of a soft tranquil character, having a lulling effect; a cradle song.","pos":""}],"BERDASH":[{"def":"A treatise against the cravat and berdash.","pos":"noun"}],"BEREAVE":[{"def":"To make destitute; to deprive; to strip; -- with of before the person or thing taken away.","pos":""},{"def":"To take away from.","pos":""}],"BEREAVEMENT":[{"def":"The state of being bereaved; deprivation; esp.","pos":""}],"BEREAVER":[{"def":"One who bereaves.","pos":""}],"BERENICE'S HAIR":[{"def":"See Coma Berenices, under Coma.","pos":""}],"BERETTA":[{"def":"Same as Berretta.","pos":""}],"BERG":[{"def":"A large mass or hill, as of ice.","pos":""}],"BERGAMOT":[{"def":"The essence or perfume made from the fruit.","pos":""},{"def":"A variety of pear.","pos":""}],"BERGANDER":[{"def":"A European duck (Anas tadorna).","pos":""}],"BERGERET":[{"def":"A pastoral song.","pos":""}],"BERGOMASK":[{"def":"A rustic dance, so called in ridicule of the people of Bergamo, in Italy, once noted for their clownishness.","pos":""}],"BERGSCHRUND":[{"def":"The crevasse or series of crevasses, usually deep and often broad, frequently occurring near the head of a mountain glacier, about where the névé field joins the valley portion of the glacier.","pos":""}],"BERGSTOCK":[{"def":"A long pole with a spike at the end, used in climbing mountains; an alpenstock.","pos":""}],"BERGYLT":[{"def":"The Norway haddock.","pos":""}],"BERHYME":[{"def":"To mention in rhyme or verse; to rhyme about.","pos":""}],"BERIBERI":[{"def":"An acute disease occurring in India, characterized by multiple inflammatory changes in the nerves, producing great muscular debility, a painful rigidity of the limbs, and cachexy.","pos":""}],"BERIME":[{"def":"Note: [The earlier and etymologically preferable spelling.","pos":""}],"BERING SEA CONTROVERSY":[{"def":"A controversy (1886 --93) between Great Britain and the United States as to the right of Canadians not licensed by the United States to carry on seal fishing in the Bering Sea, over which the United States claimed jurisdiction as a mare clausum.","pos":""}],"BERKELEIAN":[{"def":"Berke*le\"ian Defn: ,a.","pos":""}],"BERLIN":[{"def":"A narrow shelf or path between the bottom of a parapet and the ditch.","pos":""},{"def":"A ledge at the bottom of a bank or cutting, to catch earth that may roll down the slope, or to strengthen the bank.","pos":""}],"BERMUDA GRASS":[{"def":"A kind of grass (Cynodon Dactylon) esteemed for pasture in the Southern United States.","pos":""}],"BERMUDA LILY":[{"def":"The large white lily (Lilium longiflorum eximium, syn.","pos":""}],"BERNA FLY":[{"def":"A Brazilian dipterous insect of the genus Trypeta, which lays its eggs in the nostrils or in wounds of man and beast, where the larvæ do great injury.","pos":""}],"BERNARDINE":[{"def":"Of or pertaining to St.","pos":""},{"def":"A Cistercian monk.","pos":""}],"BERNESE":[{"def":"Pertaining to the city o -- n.","pos":""},{"def":"A native or natives of Bern.","pos":""}],"BERNICLE":[{"def":"A bernicle goose.","pos":""}],"BERNOUSE":[{"def":"Some as Burnoose.","pos":""}],"BEROB":[{"def":"To rob; to plunder.","pos":""}],"BEROE":[{"def":"A small, oval, transparent jellyfish, belonging to the Ctenophora.","pos":""}],"BERRETTA":[{"def":"A square cap worn by ecclesiastics of the Roman Catholic Church.","pos":""}],"BERRIED":[{"def":"Furnished with berries; consisting of a berry; baccate; as, a berried shrub.","pos":""}],"BERRY":[{"def":"A small fruit that is pulpy or succulent throughout, having seeds loosely imbedded in the pulp, as the currant, grape, blueberry.","pos":""}],"BERRYING":[{"def":"A seeking for or gathering of berries, esp.","pos":""}],"BERSEEM":[{"def":"An Egyptian clover (Trifolium alexandrinum) extensively cultivated as a forage plant and soil-renewing crop in the alkaline soils of the Nile valley, and now introduced into the southwestern United States.","pos":""},{"def":"One of a class of legendary heroes, who fought frenzied by intoxicating liquors, and naked, regardless of wounds.","pos":""}],"BERTH":[{"def":"An allotted place; an appointment; situation or employment.","pos":""},{"def":"A place in a ship to sleep in; a long box or shelf on the side of a cabin or stateroom, or of a railway car, for sleeping in.","pos":""}],"BERTHA":[{"def":"A kind of collar or cape worn by ladies.","pos":""}],"BERTHAGE":[{"def":"A place for mooring vessels in a dock or harbor.","pos":""}],"BERTHIERITE":[{"def":"A double sulphide of antimony and iron, of a dark steel-gray color.","pos":""}],"BERTHING":[{"def":"The planking outside of a vessel, above the sheer strake.","pos":""}],"BERTILLON SYSTEM":[{"def":"A system for the identification of persons by a physical description based upon anthropometric measurements, notes of markings, deformities, color, impression of thumb lines, etc.","pos":""}],"BERTRAM":[{"def":"Pellitory of Spain (Anacyclus pyrethrum).","pos":""}],"BERYCOID":[{"def":"Of or pertaining to the Berycidæ, a family of marine fishes.","pos":""}],"BERYL":[{"def":"A mineral of great hardness, and, when transparent, of much beauty.","pos":""}],"BERYLLINE":[{"def":"Like a beryl; of a light or bluish green color.","pos":""}],"BERYLLIUM":[{"def":"A metallic element found in the beryl.","pos":""}],"BERYLLOID":[{"def":"A solid consisting of a double twelve-sided pyramid; -- so called because the planes of this form occur on crystals of beryl.","pos":""},{"def":"A kind of writ which formerly lay where a great-grandfather died seized of lands in fee simple, and on the day of his death a stranger abated or entered and kept the heir out.","pos":""}]}