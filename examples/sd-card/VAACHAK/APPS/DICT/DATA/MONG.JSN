{"MONGER":[{"def":"A trader; a dealer; -- now used chiefly in composition; as, fishmonger, ironmonger, newsmonger.","pos":""},{"def":"A small merchant vessel.","pos":""}],"MONGOL":[{"def":"One of the Mongols.","pos":""},{"def":"Of or pertaining to Mongolia or the Mongols.","pos":""}],"MONGOLIAN":[{"def":"Of or pertaining to Mongolia or the Mongols.","pos":""},{"def":"One of the Mongols.","pos":""}],"MONGOLOID":[{"def":"Resembling a Mongol or the Mongols; having race characteristics, such as color, hair, and features, like those of the Mongols.","pos":""},{"def":"One of the great races of man, including the greater part of the inhabitants of China, Japan, and the interior of Asia, with branches in Northern Europe and other parts of the world.","pos":""}],"MONGREL":[{"def":"The progeny resulting from a cross between two breeds, as of domestic animals; anything of mixed breed.","pos":""}],"MONGRELIZE":[{"def":"To cause to be mongrel; to cross breeds, so as to produce mongrels.","pos":""}]}