{"PAD":[{"def":"A footpath; a road.","pos":""},{"def":"An easy-paced horse; a padnag.","pos":""}],"PAD ELEPHANT":[{"def":"An elephant that is furnished with a pad for carrying burdens instead of with a howdah for carrying passengers.","pos":""}],"PADAR":[{"def":"Groats; coarse flour or meal.","pos":""}],"PADDER":[{"def":"One who, or that which, pads.","pos":""},{"def":"A highwayman; a footpad.","pos":""}],"PADDING":[{"def":"The uniform impregnation of cloth with a mordant.","pos":""}],"PADDLE":[{"def":"To use the hands or fingers in toying; to make caressing strokes.","pos":""},{"def":"To dabble in water with hands or feet; to use a paddle, or something which serves as a paddle, in swimming, in paddling a boat, etc.","pos":""}],"PADDLEFISH":[{"def":"A large ganoid fish (Polyodon spathula) found in the rivers of the Mississippi Valley.","pos":""}],"PADDLER":[{"def":"One who, or that which, paddles.","pos":""}],"PADDLEWOOD":[{"def":"The light elastic wood of the Aspidosperma excelsum, a tree of Guiana having a fluted trunk readily split into planks.","pos":""}],"PADDOCK":[{"def":"A small inclosure or park for sporting.","pos":""},{"def":"A small inclosure for pasture; esp.","pos":""}],"PADDY":[{"def":"Low; mean; boorish; vagabond.","pos":""}],"PADELION":[{"def":"A plant with pedately lobed leaves; the lady's mantle.","pos":""}],"PADELLA":[{"def":"A large cup or deep saucer, containing fatty matter in which a wick is placed, -- used for public illuminations, as at St.","pos":""}],"PADGE":[{"def":"The barn owl; -- called also pudge, and pudge owl.","pos":""}],"PADISHAH":[{"def":"Chief ruler; monarch; sovereign; -- a title of the Sultan of Turkey, and of the Shah of Persia.","pos":""}],"PADLOCK":[{"def":"A portable lock with a bow which is usually jointed or pivoted at one end so that it can be opened, the other end being fastened by the bolt, -- used for fastening by passing the bow through a staple over a hasp or through the links of a chain, etc.","pos":""}],"PADOW":[{"def":"A paddock, or toad.","pos":""}],"PADRE":[{"def":"A Christian priest or monk; -- used in Italy, Spain, Portugal, and Spanish America.","pos":""},{"def":"In India (from the Portuguese), any Christian minister; also, a priest of the native region.","pos":""}],"PADRONE":[{"def":"A patron; a protector.","pos":""},{"def":"The master of a small coaster in the Mediterranean.","pos":""}],"PADUASOY":[{"def":"A rich and heavy silk stuff.","pos":""}]}