{"NEREID":[{"def":"A sea nymph, one of the daughters of Nereus, who were attendants upon Neptune, and were represented as riding on sea horses, sometimes with the human form entire, and sometimes with the tail of a fish.","pos":""},{"def":"Any species of Nereis.","pos":""}],"NEREIDIAN":[{"def":"Any annelid resembling Nereis, or of the family Lycoridæ or allied families.","pos":""}],"NEREIS":[{"def":"A genus, including numerous species, of marine chætopod annelids, having a well-formed head, with two pairs of eyes, antennæ, four pairs of tentacles, and a protrusile pharynx, armed with a pair of hooked jaws.","pos":""}],"NEREITES":[{"def":"Fossil tracks of annelids.","pos":""}],"NEREOCYSTIS":[{"def":"A genus of gigantic seaweeds.","pos":""}],"NERITA":[{"def":"A genus of marine gastropods, mostly natives of warm climates.","pos":""}],"NERITE":[{"def":"Any mollusk of the genus Nerita.","pos":""}],"NERITINA":[{"def":"A genus including numerous species of shells resembling Nerita in form.","pos":""}],"NERKA":[{"def":"The most important salmon of Alaska (Oncorhinchus nerka), ascending in spring most rivers and lakes from Alaska to Oregon, Washington, and Idaho; --called also red salmon, redfish, blueback, and sawqui.","pos":""}],"NERO":[{"def":"A Roman emperor notorius for debauchery and barbarous cruelty; hence, any profligate and cruel ruler or merciless tyrant.","pos":""}],"NERO-ANTICO":[{"def":"A beautiful black marble found in fragments among Roman ruins, and usually thought to have come from ancient Laconia.","pos":""}],"NEROLI":[{"def":"An essential oil obtained by distillation from the flowers of the orange.","pos":""}],"NERVATION":[{"def":"The arrangement of nerves and veins, especially those of leaves; neuration.","pos":""}],"NERVE":[{"def":"One of the whitish and elastic bundles of fibers, with the accompanying tissues, which transmit nervous impulses between nerve centers and various parts of the animal body.","pos":""},{"def":"One of the principal fibrovascular bundles or ribs of a leaf, especially when these extend straight from the base or the midrib of the leaf.","pos":""}],"NERVE-SHAKEN":[{"def":"Affected by a tremor, or by a nervous disease; weakened; overcome by some violent influence or sensation; shoked.","pos":""}],"NERVED":[{"def":"Having nerves, or simple and parallel ribs or veins.","pos":""}],"NERVELESS":[{"def":"Destitute of nerves.","pos":""},{"def":"Destitute of strength or of courage; wanting vigor; weak; powerless.","pos":""}],"NERVELESSNESS":[{"def":"The state of being nerveless.","pos":""}],"NERVIMOTION":[{"def":"The movement caused in the sensory organs by external agents and transmitted to the muscles by the nerves.","pos":""}],"NERVIMOTOR":[{"def":"Any agent capable of causing nervimotion.","pos":""}],"NERVINE":[{"def":"Having the quality of acting upon or affecting the nerves; quieting nervous excitement.","pos":""},{"def":"A nervine agent.","pos":""}],"NERVOMUSCULAR":[{"def":"Of or pertaining to both nerves and muscles; of the nature of nerves and muscles; as, nervomuscular energy.","pos":""}],"NERVOUS":[{"def":"Possessing or manifesting vigor of mind; characterized by strength in sentiment or style; forcible; spirited; as, a nervous writer.","pos":""},{"def":"Of or pertaining to the nerves; seated in the nerves; as, nervous excitement; a nervous fever.","pos":""}],"NERVOUSLY":[{"def":"In a nervous manner.","pos":""}],"NERVOUSNESS":[{"def":"State or quality of being nervous.","pos":""}],"NERVURE":[{"def":"One of the nerves of leaves.","pos":""},{"def":"One of the chitinous supports, or veins, in the wings of incests.","pos":""}]}