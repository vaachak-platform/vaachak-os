{"NEB":[{"def":"The nose; the snout; the mouth; the beak of a bird; a nib, as of a pen.","pos":""}],"NEBALIA":[{"def":"A genus of small marine Crustacea, considered the type of a distinct order (Nebaloidea, or Phyllocarida.","pos":""}],"NEBULA":[{"def":"A faint, cloudlike, self-luminous mass of matter situated beyond the solar system among the stars.","pos":""}],"NEBULAR":[{"def":"Of or pertaining to nebulæ; of the nature of, or resembling, a nebula.","pos":""}],"NEBULATED":[{"def":"Clouded with indistinct color markings, as an animal.","pos":""}],"NEBULATION":[{"def":"The condition of being nebulated; also, a clouded, or ill- defined, color mark.","pos":""}],"NEBULE":[{"def":"A little cloud; a cloud.","pos":""},{"def":"Composed of successive short curves supposed to resemble a cloud; -- said of a heraldic line by which an ordinary or subordinary may be bounded.","pos":""}],"NEBULIZATION":[{"def":"The act or process of nebulizing; atomization.","pos":""}],"NEBULIZE":[{"def":"To reduce (as a liquid) to a fine spray or vapor; to atomize.","pos":""}],"NEBULOSE":[{"def":"Nebulous; cloudy.","pos":""}],"NEBULOSITY":[{"def":"The state or quality of being nebulous; cloudiness; hazeness; mistiness; nebulousness.","pos":""}],"NEBULOUS":[{"def":"Of, pertaining to, or having the appearance of, a nebula; nebular; cloudlike.","pos":""}],"NEBULY":[{"def":"A line or a direction composed of successive short curves or waves supposed to resembe a cloud.","pos":""}]}