{"FEIGN":[{"def":"To give a mental existence to, as to something not real or actual; to imagine; to invent; hence, to pretend; to form and relate as if true.","pos":""},{"def":"To represent by a false appearance of; to pretend; to counterfeit; as, to feign a sickness.","pos":""}],"FEIGNED":[{"def":"Not real or genuine; pretended; counterfeit; insincere; false.","pos":""}],"FEIGNER":[{"def":"One who feigns or pretends.","pos":""}],"FEIGNING":[{"def":"That feigns; insincere; not genuine; false.","pos":""}],"FEINT":[{"def":"Feigned; counterfeit.","pos":""}],"FEITSUI":[{"def":"The Chinese name for a highly prized variety of pale green jade.","pos":""}]}