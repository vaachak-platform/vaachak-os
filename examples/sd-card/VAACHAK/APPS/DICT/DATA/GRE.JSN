{"GRE":[{"def":"See Gree, a step.","pos":""}],"GREASE":[{"def":"An inflammation of a horse's heels, suspending the ordinary greasy secretion of the part, and producing dryness and scurfiness, followed by cracks, ulceration, and fungous excrescences.","pos":""}],"GREASER":[{"def":"One who, or that which, greases; specifically, a person employed to lubricate the working parts of machinery, engines, carriages, etc.","pos":""},{"def":"A nickname sometimes applied in contempt to a Mexican of the lowest type.","pos":""}],"GREASILY":[{"def":"In a greasy manner.","pos":""},{"def":"In a gross or indelicate manner.","pos":""}],"GREASINESS":[{"def":"The quality or state of being greasy, oiliness; unctuousness; grossness.","pos":""}],"GREASY":[{"def":"Affected with the disease called grease; as, the heels of a horse.","pos":""}],"GREAT":[{"def":"Large in space; of much size; big; immense; enormous; expanded; -- opposed to small and little; as, a great house, ship, farm, plain, distance, length.","pos":""},{"def":"Large in number; numerous; as, a great company, multitude, series, etc.","pos":""}],"GREAT WHITE WAY":[{"def":"Broadway, in New York City, in the neighborhood chiefly occupied by theaters, as from about 30th Street about 50th Street; -- so called from its brilliant illumination at night.","pos":""}],"GREAT-BELLIED":[{"def":"Having a great belly, bigbellied; pregnant; teeming.","pos":""}],"GREAT-GRANDCHILD":[{"def":"The child of one's grandson or granddaughter.","pos":""}],"GREAT-GRANDDAUGHTER":[{"def":"A daughter of one's grandson or granddaughter.","pos":""}],"GREAT-GRANDFATHER":[{"def":"The father of one's grandfather or grandmother.","pos":""}],"GREAT-GRANDMOTHER":[{"def":"The mother of one's grandfather or grandmother.","pos":""}],"GREAT-GRANDSON":[{"def":"A son of one's grandson or granddaughter.","pos":""}],"GREAT-HEARTED":[{"def":"High-spirited; fearless.","pos":""},{"def":"Generous; magnanimous; noble.","pos":""}],"GREAT-HEARTEDNESS":[{"def":"The quality of being greathearted; high-mindedness; magnanimity.","pos":""}],"GREATEN":[{"def":"To make great; to aggrandize; to cause to increase in size; to expand.","pos":""}],"GREATLY":[{"def":"In a great degree; much.","pos":""},{"def":"Nobly; illustriously; magnanimously.","pos":""}],"GREATNESS":[{"def":"The state, condition, or quality of being great; as, greatness of size, greatness of mind, power, etc.","pos":""},{"def":"Pride; haughtiness.","pos":""}],"GREAVE":[{"def":"Armor for the leg below the knee; -- usually in the plural.","pos":""}],"GREAVES":[{"def":"The sediment of melted tallow.","pos":""}],"GREBE":[{"def":"One of several swimming birds or divers, of the genus Colymbus (formerly Podiceps), aud allied genera, found in the northern parts of America, Europe, and Asia.","pos":""}],"GRECIAN":[{"def":"Of or pertaining to Greece; Greek.","pos":""}],"GRECISM":[{"def":"An idiom of the Greek language; a Hellenism.","pos":""}],"GRECIZE":[{"def":"To conform to the Greek custom, especially in speech.","pos":""}],"GRECO-ROMAN":[{"def":"Having characteristics that are partly Greek and partly Roman; as, Greco-Roman architecture.","pos":""}],"GRECQUE":[{"def":"An ornament supposed to be of Greek origin, esp.","pos":""}],"GREE":[{"def":"Good will; favor; pleasure; satisfaction; -- used esp.","pos":""},{"def":"Rank; degree; position.","pos":""}],"GREECE":[{"def":"See Gree a step.","pos":""}],"GREED":[{"def":"An eager desire or longing; greediness; as, a greed of gain.","pos":""}],"GREEDILY":[{"def":"Greed\"i*ly Defn: , adv.","pos":""}],"GREEDINESS":[{"def":"The quality of being greedy; vehement and selfish desire.","pos":""}],"GREEDY":[{"def":"Having a keen appetite for food or drink; ravenous; voracious; very hungry; -- followed by of; as, a lion that is greedy of his prey.","pos":""},{"def":"Having a keen desire for anything; vehemently desirous; eager to obtain; avaricious; as, greedy of gain.","pos":""}],"GREEDY-GUT":[{"def":"An African talisman or Gri'gri' charm.","pos":""}],"GREEK":[{"def":"Of or pertaining to Greece or the Greeks; Grecian.","pos":""}],"GREEK CALENDAR":[{"def":"A time that will never come, as the Greeks had no calends.","pos":""}],"GREEKISH":[{"def":"Peculiar to Greece.","pos":""}],"GREEKLING":[{"def":"A little Greek, or one of small esteem or pretensions.","pos":""}],"GREEN":[{"def":"Having the color of grass when fresh and growing; resembling that color of the solar spectrum which is between the yellow and the blue; verdant; emerald.","pos":""},{"def":"Having a sickly color; wan.","pos":""}],"GREEN-BROOM":[{"def":"A plant of the genus Genista (G.","pos":""}],"GREEN-EYED":[{"def":"Having green eyes.","pos":""},{"def":"Seeing everything through a medium which discolors or distorts.","pos":""}],"GREEN-LEEK":[{"def":"An Australian parrakeet (Polytelis Barrabandi); -- called also the scarlet-breasted parrot.","pos":""}],"GREEN-STALL":[{"def":"A stall at which greens and fresh vegetables are exposed for sale.","pos":""}],"GREENBACK":[{"def":"One of the legal tender notes of the United States; -- first issued in 1862, and having the devices on the back printed with green ink, to prevent alterations and counterfeits.","pos":""}],"GREENBACKER":[{"def":"One of those who supported greenback or paper money, and opposed the resumption of specie payments.","pos":""}],"GREENCLOTH":[{"def":"Green\"cloth` (-klôth`; 115), n.","pos":""}],"GREENERY":[{"def":"Green plants; verdure.","pos":""}],"GREENFINCH":[{"def":"A European finch (Ligurinus chloris); -- called also green bird, green linnet, green grosbeak, green olf, greeny, and peasweep.","pos":""},{"def":"The Texas sparrow (Embernagra rufivirgata), in which the general color is olive green, with four rufous stripes on the head.","pos":""}],"GREENFISH":[{"def":"See Bluefish, and Pollock.","pos":""}],"GREENGAGE":[{"def":"A kind of plum of medium size, roundish shape, greenish flesh, and delicious flavor.","pos":""}],"GREENGILL":[{"def":"An oyster which has the gills tinged with a green pigment, said to be due to an abnormal condition of the blood.","pos":""}],"GREENGROCER":[{"def":"A retailer of vegetables or fruits in their fresh or green state.","pos":""}],"GREENHEAD":[{"def":"A state of greenness; verdancy.","pos":""}],"GREENHORN":[{"def":"A raw, inexperienced person; one easily imposed upon.","pos":""}],"GREENHOUSE":[{"def":"A house in which tender plants are cultivated and sheltered from the weather.","pos":""}],"GREENING":[{"def":"A greenish apple, of several varieties, among which the Rhode Island greening is the best known for its fine-grained acid flesh and its excellent keeping quality.","pos":""}],"GREENISH":[{"def":"Somewhat green; having a tinge of green; as, a greenish yellow.","pos":""}],"GREENLANDER":[{"def":"A native of Greenland.","pos":""}],"GREENLY":[{"def":"With a green color; newly; freshly, immaturely.","pos":""},{"def":"Of a green color.","pos":""}],"GREENNESS":[{"def":"The quality of being green; viridity; verdancy; as, the greenness of grass, or of a meadow.","pos":""},{"def":"Freshness; vigor; newness.","pos":""}],"GREENOCKITE":[{"def":"Native cadmium sulphide, a mineral occurring in yellow hexagonal crystals, also as an earthy incrustation.","pos":""}],"GREENROOM":[{"def":"The retiring room of actors and actresses in a theater.","pos":""}],"GREENSAND":[{"def":"A variety of sandstone, usually imperfectly consolidated, consisting largely of glauconite, a silicate of iron and potash of a green color, mixed with sand and a trace of phosphate of lime.","pos":""}],"GREENSHANK":[{"def":"A European sandpiper or snipe (Totanus canescens); -- called also greater plover.","pos":""}],"GREENSTONE":[{"def":"A name formerly applied rather loosely to certain dark-colored igneous rocks, including diorite, diabase, etc.","pos":""}],"GREENSWARD":[{"def":"Turf green with grass.","pos":""}],"GREENTH":[{"def":"The state or quality of being green; verdure.","pos":""}],"GREENWOOD":[{"def":"A forest as it appears is spring and summer.","pos":""}],"GREET":[{"def":"To weep; to cry; to lament.","pos":""}],"GREETER":[{"def":"One who greets or salutes another.","pos":""}],"GREETING":[{"def":"Expression of kindness or joy; salutation at meeting; a compliment from one absent.","pos":""}],"GREEVE":[{"def":"See Grieve, an overseer.","pos":""}],"GREEZE":[{"def":"The top of the ladder, or first greeze, is this.","pos":""}],"GREFFIER":[{"def":"A registrar or recorder; a notary.","pos":""}],"GREGAL":[{"def":"Pertaining to, or like, a flock.","pos":""}],"GREGARIAN":[{"def":"Gregarious; belonging to the herd or common sort; common.","pos":""},{"def":"An order of Protozoa, allied to the Rhizopoda, and parasitic in other animals, as in the earthworm, lobster, etc.","pos":""}],"GREGARINE":[{"def":"Of or pertaining to the Gregarinæ.","pos":""},{"def":"One of the Gregarinæ.","pos":""}],"GREGARINIDA":[{"def":"Greg`a*rin\"i*da Defn: Gregarinæ.","pos":""}],"GREGARIOUS":[{"def":"Habitually living or moving in flocks or herds; tending to flock or herd together; not habitually solitary or living alone.","pos":""},{"def":"To make heavy; to increase.","pos":""}],"GREGORIAN":[{"def":"Pertaining to, or originated by, some person named Gregory, especially one of the popes of that name.","pos":""}],"GREILLADE":[{"def":"Iron ore in coarse powder, prepared for reduction by the Catalan process.","pos":""}],"GREISEN":[{"def":"A crystalline rock consisting of quarts and mica, common in the tin regions of Cornwall and Saxony.","pos":""}],"GREIT":[{"def":"See Greet, to weep.","pos":""}],"GREITH":[{"def":"To make ready; -- often used reflexively.","pos":""}],"GREMIAL":[{"def":"Of or pertaining to the lap or bosom.","pos":""}],"GRENADE":[{"def":"A hollow ball or shell of iron filled with powder of other explosive, ignited by means of a fuse, and thrown from the hand among enemies.","pos":""}],"GRENADIER":[{"def":"Originaly, a soldier who carried and threw grenades; afterward, one of a company attached to each regiment or battalion, taking post on the right of the line, and wearing a peculiar uniform.","pos":""},{"def":"Any marine fish of the genus Macrurus, in which the body and tail taper to a point; they mostly inhabit the deep sea; -- called also onion fish, and rat-tail fish.","pos":""}],"GRENADILLO":[{"def":"A handsome tropical American wood, much used for making flutes and other wind instruments; -- called also Grenada cocos, or cocus, and red ebony.","pos":""}],"GRENADINE":[{"def":"A thin gauzelike fabric of silk or wool, for women's wear.","pos":""},{"def":"A trade name for a dyestuff, consisting essentially of impure fuchsine.","pos":""}],"GRENADO":[{"def":"Same as Grenade.","pos":""}],"GRES":[{"def":"Adapted for walking; anisodactylous; as the feet of certain birds and insects.","pos":""}],"GREW":[{"def":"GREWSOME; GRUESOME Grew\"some Defn: , Grue\"some, a.","pos":""}],"GREY":[{"def":"See Gray (the correct orthography).","pos":""}],"GREYHOUND":[{"def":"A slender, graceful breed of dogs, remarkable for keen sight and swiftness.","pos":""}]}