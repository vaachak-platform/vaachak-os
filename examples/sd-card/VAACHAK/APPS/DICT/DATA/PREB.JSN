{"PREBEND":[{"def":"A payment or stipend; esp.","pos":""}],"PREBENDAL":[{"def":"Of or pertaining to a prebend; holding a prebend; as, a prebendal priest or stall.","pos":""}],"PREBENDARY":[{"def":"A clergyman attached to a collegiate or cathedral church who enjoys a prebend in consideration of his officiating at stated times in the church.","pos":""},{"def":"A prebendaryship.","pos":""}],"PREBENDARYSHIP":[{"def":"The office of a prebendary.","pos":""}],"PREBENDATE":[{"def":"To invest with the office of prebendary; to present to a prebend.","pos":""}],"PREBENDSHIP":[{"def":"A prebendaryship.","pos":""}],"PREBRONCHIAL":[{"def":"Situated in front of the bronchus; -- applied especially to an air sac on either side of the esophagus of birds.","pos":""}]}