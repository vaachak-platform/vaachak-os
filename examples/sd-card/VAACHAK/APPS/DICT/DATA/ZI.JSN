{"ZIEGA":[{"def":"Curd produced from milk by adding acetic acid, after rennet has ceased to cause coagulation.","pos":""}],"ZIETRISIKITE":[{"def":"A mineral wax, vert similar to ozocerite.","pos":""}],"ZIF":[{"def":"The second month of the Jewish ecclesiastical year, corresponding to our May.","pos":""}],"ZIGZAG":[{"def":"A molding running in a zigzag line; a chevron, or series of chevrons.","pos":""}],"ZIGZAGGERY":[{"def":"The quality or state of being zigzag; crookedness.","pos":""}],"ZIGZAGGY":[{"def":"Having sharp turns.","pos":""}],"ZIKKURAT":[{"def":"A temple tower of the Babylonians or Assyrians, consisting of a lofty pyramidal structure, built in successive stages, with outside staircases, and a shrine at the top.","pos":""}],"ZILLA":[{"def":"A low, thorny, suffrutescent, crucifeous plant (Zilla myagroides) found in the deserts of Egypt.","pos":""}],"ZILLAH":[{"def":"A district or local division, as of a province.","pos":""}],"ZIMB":[{"def":"A large, venomous, two-winged fly, native of Abyssinia.","pos":""}],"ZIMENT-WATER":[{"def":"A kind of water found in copper mines; water impregnated with copper.","pos":""}],"ZIMOCCA":[{"def":"A sponge (Euspongia zimocca) of flat form and fine quality, from the Adriatic, about the Greek islands, and the coast of Barbary.","pos":""}],"ZINC":[{"def":"An abundant element of the magnesium-cadmium group, extracted principally from the minerals zinc blende, smithsonite, calamine, and franklinite, as an easily fusible bluish white metal, which is malleable, especially when heated.","pos":""}],"ZINCIC":[{"def":"Pertaining to, containing, or resembling, zinc; zincous.","pos":""}],"ZINCIDE":[{"def":"A binary compound of zinc.","pos":""}],"ZINCIFEROUS":[{"def":"Containing or affording zinc.","pos":""}],"ZINCIFICATION":[{"def":"The act or process of applying zinc; the condition of being zincified, or covered with zinc; galvanization.","pos":""}],"ZINCIFY":[{"def":"To coat or impregnate with zinc.","pos":""}],"ZINCITE":[{"def":"Native zinc oxide; a brittle, translucent mineral, of an orange-red color; -- called also red zinc ore, and red oxide of zinc.","pos":""},{"def":"The act or process of applying zinc; galvanization.","pos":""}],"ZINCKY":[{"def":", Pertaining to zinc, or having its appearance.","pos":""}],"ZINCO-":[{"def":"A combining form from zinc; in chemistry, designating zinc as an element of certain double compounds.","pos":""}],"ZINCO-POLAR":[{"def":"Electrically polarized like the surface of the zinc presented to the acid in a battery, which has zincous affinity.","pos":""}],"ZINCODE":[{"def":"The positive electrode of an electrolytic cell; anode.","pos":""}],"ZINCOGRAPH":[{"def":"A zinc plate prepared for printing by zincography; also, a print from such a plate.","pos":""}],"ZINCOGRAPHER":[{"def":"Am engraver on zinc.","pos":""},{"def":"Of or pertaining to zincography; as, zincographic processes.","pos":""}],"ZINCOGRAPHY":[{"def":"The art or process of engraving or etching on zinc, in which the design is left in relief in the style of a wood cut, the rest of the ground being eaten away by acid.","pos":""}],"ZINCOID":[{"def":"Pertaining to, or resembling, zinc; -- said of the electricity of the zincous plate in connection with a copper plate in a voltaic circle; also, designating the positive pole.","pos":""}],"ZINCOUS":[{"def":"Of or pertaining to the positive pole of a galvanic battery; electro-positive.","pos":""}],"ZINGEL":[{"def":"A small, edible, freshwater European perch (Aspro zingel), having a round, elongated body and prominent snout.","pos":""}],"ZINGIBERACEOUS":[{"def":"Of or pertaining to ginger, or to a tribe (Zingibereæ) of endogenous plants of the order Scitamineæ.","pos":""}],"ZINKENITE":[{"def":"A steel-gray metallic mineral, a sulphide of antimony and lead.","pos":""}],"ZINNIA":[{"def":"Any plant of the composite genus Zinnia, Mexican herbs with opposite leaves and large gay-colored blossoms.","pos":""}],"ZINNWALDITE":[{"def":"A kind of mica containing lithium, often associated with tin ore.","pos":""}],"ZINZIBERACEOUS":[{"def":"Same as Zingiberaceous.","pos":""}],"ZION":[{"def":"A hill in Jerusalem, which, after the capture of that city by the Israelites, became the royal residence of David and his successors.","pos":""}],"ZIONISM":[{"def":"Among the Jews, a theory, plan, or movement for colonizing their own race in Palestine, the land of Zion, or, if that is impracticable, elsewhere, either for religious or nationalizing purposes; -- called also Zion movement.","pos":""}],"ZIP":[{"def":"A hissing or sibilant sound such as that made by a flying bullet.","pos":""}],"ZIRCO-":[{"def":"A combining form (also used adjectively) designating zirconium as an element of certain double compounds; zircono-; as in zircofluoric acid, sodium zircofluoride.","pos":""}],"ZIRCOFLUORIDE":[{"def":"A double fluoride of zirconium and hydrogen, or some other positive element or radical; as, zircofluoride of sodium.","pos":""}],"ZIRCON":[{"def":"A mineral occurring in tetragonal crystals, usually of a brown or gray color.","pos":""}],"ZIRCON LIGHT":[{"def":"A light, similar to the calcium light, produced by incandescent zirconia.","pos":""}],"ZIRCONATE":[{"def":"A salt of zirconic acid.","pos":""}],"ZIRCONIA":[{"def":"The oxide of zirconium, obtained as a white powder, and possessing both acid and basic properties.","pos":""}],"ZIRCONIC":[{"def":"Pertaining to, containing, or resembling, zirconium; as, zirconic oxide; zirconic compounds.","pos":""}],"ZIRCONIUM":[{"def":"A rare element of the carbon-silicon group, intermediate between the metals and nonmetals, obtained from the mineral zircon as a dark sooty powder, or as a gray metallic crystalline substance.","pos":""}],"ZIRCONOID":[{"def":"A double eight-sided pyramid, a form common with tetragonal crystals; -- so called because this form often occurs in crystals of zircon.","pos":""}],"ZITHER":[{"def":"An instrument of music used in Austria and Germany.","pos":""}],"ZIZANIA":[{"def":"A genus of grasses including Indian rice.","pos":""}],"ZIZITH":[{"def":"The tassels of twisted cords or threads on the corners of the upper garment worn by strict Jews.","pos":""}]}