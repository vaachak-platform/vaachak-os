{"NOSE":[{"def":"The prominent part of the face or anterior extremity of the head containing the nostrils and olfactory cavities; the olfactory organ.","pos":""}],"NOSEBAG":[{"def":"A bag in which feed for a horse, ox, or the like, may be fastened under the nose by a string passing over the head.","pos":""}],"NOSEBAND":[{"def":"That part of the headstall of a bridle which passes over a horse's nose.","pos":""}],"NOSEBLEED":[{"def":"A bleeding at the nose.","pos":""}],"NOSED":[{"def":"Having a nose, or such a nose; -- chieflay used in composition; as, pug-nosed.","pos":""}],"NOSEGAY":[{"def":"A bunch of odorous and showy flowers; a bouquet; a posy.","pos":""}],"NOSEL":[{"def":"To nurse; to lead or teach; to foster; to nuzzle.","pos":""}],"NOSELESS":[{"def":"Destitute of a nose.","pos":""}],"NOSESMART":[{"def":"A kind of cress, a pungent cruciferous plant, including several species of the genus Nasturtium.","pos":""}],"NOSING":[{"def":"That part of the treadboard of a stair which projects over the riser; hence, any like projection, as the projecting edge of a molding.","pos":""}],"NOSOCOMIAL":[{"def":"Of or pertaining to a hospital; as, nosocomial atmosphere.","pos":""}],"NOSOGRAPHY":[{"def":"A description or classification of diseases.","pos":""}],"NOSOLOGICAL":[{"def":"Of or pertaining to nosology.","pos":""}],"NOSOLOGIST":[{"def":"One versed in nosology.","pos":""}],"NOSOLOGY":[{"def":"A systematic arrangement, or classification, of diseases.","pos":""},{"def":"That branch of medical science which treats of diseases, or of the classification of diseases.","pos":""}],"NOSOPHEN":[{"def":"An iodine compound obtained as a yellowish gray, odorless, tasteless powder by the action of iodine on phenolphthalein.","pos":""}],"NOSOPHOBIA":[{"def":"Morbid dread of disease.","pos":""}],"NOSOPOETIC":[{"def":"Producing diseases.","pos":""}],"NOST":[{"def":"Wottest not; knowest not.","pos":""}],"NOSTALGIA":[{"def":"Homesickness; esp.","pos":""}],"NOSTALGIC":[{"def":"Of or pertaining to nostalgia; affected with nostalgia.","pos":""}],"NOSTALGY":[{"def":"Same as Nostalgia.","pos":""}],"NOSTOC":[{"def":"A genus of algæ.","pos":""}],"NOSTRIL":[{"def":"One of the external openings of the nose, which give passage to the air breathed and to secretions from the nose and eyes; one of the anterior nares.","pos":""}],"NOSTRUM":[{"def":"A medicine, the ingredients of which are kept secret for the purpose of restricting the profits of sale to the inventor or proprietor; a quack medicine.","pos":""},{"def":"Any scheme or device proposed by a quack.","pos":""}]}