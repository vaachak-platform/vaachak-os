{"GOOD":[{"def":"Possessing desirable qualities; adapted to answer the end designed; promoting success, welfare, or happiness; serviceable; useful; fit; excellent; admirable; commendable; not bad, corrupt, evil, noxious, offensive, or troublesome, etc.","pos":""},{"def":"Possessing moral excellence or virtue; virtuous; pious; religious; -- said of persons or actions.","pos":""}],"GOOD NOW":[{"def":"An exclamation of wonder, surprise, or entreaty.","pos":""}],"GOOD-DEN":[{"def":"A form of salutation.","pos":""}],"GOOD-FELLOWSHIP":[{"def":"Agreeable companionship; companionableness.","pos":""}],"GOOD-HUMORED":[{"def":"Having a cheerful spirit and demeanor; good-tempered.","pos":""}],"GOOD-HUMOREDLY":[{"def":"With a cheerful spirit; in a cheerful or good-tempered manner.","pos":""}],"GOOD-NATURED":[{"def":"Naturally mild in temper; not easily provoked.","pos":""}],"GOOD-NATUREDLY":[{"def":"With maldness of temper.","pos":""}],"GOOD-TEMPERED":[{"def":"Having a good temper; not easily vexed.","pos":""}],"GOODGEON":[{"def":"Same as Gudgeon, 5.","pos":""}],"GOODISH":[{"def":"Rather good than the contrary; not actually bad; tolerable.","pos":""}],"GOODLESS":[{"def":"Having no goods.","pos":""}],"GOODLINESS":[{"def":"Beauty of form; grace; elegance; comeliness.","pos":""}],"GOODLY":[{"def":"Goodness; grace; goodliness.","pos":""}],"GOODMAN":[{"def":"A familiar appellation of civility, equivalent to \"My friend\", \"Good sir\", \"Mister;\" -- sometimes used ironically.","pos":""},{"def":"A husband; the master of a house or family; -- often used in speaking familiarly.","pos":""}],"GOODNESS":[{"def":"The quality of being good in any of its various senses; excellence; virtue; kindness; benevolence; as, the goodness of timber, of a soil, of food; goodness of character, of disposition, of conduct, etc.","pos":""}],"GOODWIFE":[{"def":"The mistress of a house.","pos":""}],"GOODY":[{"def":"An American fish; the lafayette or spot.","pos":""}],"GOODY-GOODY":[{"def":"Mawkishly or weakly good; exhibiting goodness with silliness.","pos":""}],"GOODYSHIP":[{"def":"The state or quality of a goody or goodwife [Jocose] Hudibraus.","pos":""},{"def":"A spiritual teacher, guide, or confessor amoung the Hindoos.","pos":""}],"GOOSANDER":[{"def":"A species of merganser (M.","pos":""}],"GOOSE":[{"def":"Any large web-footen bird of the subfamily Anserinæ, and belonging to Anser, Branta, Chen, and several allied genera.","pos":""},{"def":"Any large bird of other related families, resembling the common goose.","pos":""}],"GOOSE EGG":[{"def":"In games, a zero; a score or record of naught; -- so named in allusion to the egglike outline of the zero sign 0.","pos":""}],"GOOSE-RUMPED":[{"def":"Having the tail set low and buttocks that fall away sharply from the croup; -- said of certain horses.","pos":""}],"GOOSEBERRY":[{"def":"Any thorny shrub of the genus Ribes; also, the edible berries of such shrub.","pos":""}],"GOOSEFOOT":[{"def":"A genus of herbs (Chenopodium) mostly annual weeds; pigweed.","pos":""}],"GOOSERY":[{"def":"A place for keeping geese.","pos":""},{"def":"The characteristics or actions of a goose; silliness.","pos":""}],"GOOSEWING":[{"def":"One of the clews or lower corners of a course or a topsail when the middle part or the rest of the sail is furled.","pos":""}],"GOOSISH":[{"def":"Like a goose; foolish.","pos":""}]}