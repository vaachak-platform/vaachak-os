{"WON":[{"def":"To dwell or abide.","pos":""}],"WON'T":[{"def":"A colloquial contraction of woll not.","pos":""}],"WONDER":[{"def":"That emotion which is excited by novelty, or the presentation to the sight or mind of something new, unusual, strange, great, extraordinary, or not well understood; surprise; astonishment; admiration; amazement.","pos":""},{"def":"A cause of wonder; that which excites surprise; a strange thing; a prodigy; a miracle.","pos":""}],"WONDER-WORKER":[{"def":"One who performs wonders, or miracles.","pos":""}],"WONDER-WORKING":[{"def":"Doing wonders or surprising things.","pos":""}],"WONDERED":[{"def":"Having performed wonders; able to perform wonderful things.","pos":""}],"WONDERER":[{"def":"One who wonders.","pos":""}],"WONDERFUL":[{"def":"Adapted to excite wonder or admiration; surprising; strange; astonishing.","pos":""}],"WONDERINGLY":[{"def":"In a wondering manner.","pos":""}],"WONDERLAND":[{"def":"A land full of wonders, or marvels.","pos":""}],"WONDERLY":[{"def":"Wonderfully; wondrously.","pos":""}],"WONDERMENT":[{"def":"Surprise; astonishment; a wonderful appearance; a wonder.","pos":""}],"WONDEROUS":[{"def":"Same as Wondrous.","pos":""}],"WONDERS":[{"def":"They be wonders glad thereof.","pos":""}],"WONDERSTRUCK":[{"def":"Struck with wonder, admiration, or surprise.","pos":""}],"WONDERWORK":[{"def":"A wonderful work or act; a prodigy; a miracle.","pos":""}],"WONDROUS":[{"def":"In a wonderful or surprising manner or degree; wonderfully.","pos":""}],"WONE":[{"def":"To dwell; to abide.","pos":""}],"WONT":[{"def":"Using or doing customarily; accustomed; habituated; used.","pos":""}],"WONTED":[{"def":"Accustomed; customary; usual.","pos":""}],"WONTEDNESS":[{"def":"The quality or state of being accustomed.","pos":""}]}