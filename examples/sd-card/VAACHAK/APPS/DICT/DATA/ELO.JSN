{"ELOCATION":[{"def":"A removal from the usual place of residence.","pos":""},{"def":"Departure from the usual state; an ecstasy.","pos":""}],"ELOCULAR":[{"def":"Having but one cell, or cavity; not divided by a septum or partition.","pos":""}],"ELOCUTION":[{"def":"Utterance by speech.","pos":""},{"def":"Oratorical or expressive delivery, including the graces of intonation, gesture, etc.","pos":""}],"ELOCUTIONARY":[{"def":"Pertaining to elocution.","pos":""}],"ELOCUTIONIST":[{"def":"One who is versed in elocution; a teacher of elocution.","pos":""}],"ELOCUTIVE":[{"def":"Pertaining to oratorical expression.","pos":""}],"ELODIAN":[{"def":"One of a tribe of tortoises, including the terrapins, etc.","pos":""}],"ELOGE":[{"def":"A panegyrical funeral oration.","pos":""}],"ELOGIST":[{"def":"One who pronounces an éloge.","pos":""},{"def":"The praise bestowed on a person or thing; panegyric; eulogy.","pos":""}],"ELOHIM":[{"def":"One of the principal names by which God is designated in the Hebrew Scriptures.","pos":""}],"ELOHIST":[{"def":"The writer, or one of the writers, of the passages of the Old Testament, notably those of Elohim instead of Jehovah, as the name of the Supreme Being; -- distinguished from Jehovist.","pos":""}],"ELOHISTIC":[{"def":"Relating to Elohim as a name of God; -- said of passages in the Old Testament.","pos":""}],"ELOIGN":[{"def":"To convey to a distance, or beyond the jurisdiction, or to conceal, as goods liable to distress.","pos":""}],"ELOIGNMENT":[{"def":"Removal to a distance; withdrawal.","pos":""}],"ELONG":[{"def":"To lengthen out; to prolong.","pos":""},{"def":"To put away; to separate; to keep off.","pos":""}],"ELONGATE":[{"def":"To lengthen; to extend; to stretch; as, to elongate a line.","pos":""},{"def":"To remove further off.","pos":""}],"ELONGATION":[{"def":"The angular distance of a planet from the sun; as, the elongation of Venus or Mercury.","pos":""}],"ELOPE":[{"def":"To run away, or escape privately, from the place or station to which one is bound by duty; -- said especially of a woman or a man, either married or unmarried, who runs away with a paramour or a sweetheart.","pos":""}],"ELOPEMENT":[{"def":"The act of eloping; secret departure; -- said of a woman and a man, one or both, who run away from their homes for marriage or for cohabitation.","pos":""}],"ELOPS":[{"def":"A genus of fishes.","pos":""}],"ELOQUENCE":[{"def":"Fluent, forcible, elegant, and persuasive speech in public; the power of expressing strong emotions in striking and appropriate language either spoken or written, thereby producing conviction or persuasion.","pos":""}],"ELOQUENT":[{"def":"Having the power of expressing strong emotions or forcible arguments in an elevated, impassioned, and effective manner; as, an eloquent orator or preacher.","pos":""},{"def":"Adapted to express strong emotion or to state facts arguments with fluency and power; as, an eloquent address or statement; an eloquent appeal to a jury.","pos":""}],"ELOQUENTLY":[{"def":"In an eloquent manner.","pos":""},{"def":"Ghastly; preternatural.","pos":""}]}