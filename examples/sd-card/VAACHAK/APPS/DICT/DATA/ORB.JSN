{"ORB":[{"def":"A blank window or panel.","pos":""}],"ORBATE":[{"def":"Bereaved; fatherless; childless.","pos":""}],"ORBATION":[{"def":"The state of being orbate, or deprived of parents or children; privation, in general; bereavement.","pos":""}],"ORBED":[{"def":"Having the form of an orb; round.","pos":""},{"def":"Spherical; orbicular; orblike; circular.","pos":""}],"ORBICLE":[{"def":"A small orb, or sphere.","pos":""}],"ORBICULA":[{"def":"Same as Discina.","pos":""}],"ORBICULAR":[{"def":"Resembling or having the form of an orb; spherical; circular; orbiculate.","pos":""}],"ORBICULATE":[{"def":"That which is orbiculate; especially, a solid the vertical section of which is oval, and the horizontal section circular.","pos":""},{"def":"Made, or being, in the form of an orb; having a circular, or nearly circular, or a spheroidal, outline.","pos":""}],"ORBICULATION":[{"def":"The state or quality of being orbiculate; orbicularness.","pos":""}],"ORBIT":[{"def":"The path described by a heavenly body in its periodical revolution around another body; as, the orbit of Jupiter, of the earth, of the moon.","pos":""},{"def":"The cavity or socket of the skull in which the eye and its appendages are situated.","pos":""}],"ORBITAL":[{"def":"Of or pertaining to an orbit.","pos":""}],"ORBITARY":[{"def":"Situated around the orbit; as, the orbitary feathers of a bird.","pos":""}],"ORBITELAE":[{"def":"A division of spiders, including those that make geometrical webs, as the garden spider, or Epeira.","pos":""}],"ORBITOLITES":[{"def":"A genus of living Foraminifera, forming broad, thin, circular disks, containing numerous small chambers.","pos":""}],"ORBITONASAL":[{"def":"Of or pertaining to the orbit and the nose; as, the orbitonasal, or ophthalmic, nerve.","pos":""}],"ORBITOSPHENOID":[{"def":"Of or pertaining to the sphenoid bone and the orbit, or to the orbitosphenoid bone.","pos":""},{"def":"The orbitosphenoid bone, which is situated in the orbit on either side of the presphenoid.","pos":""}],"ORBITOSPHENOIDAL":[{"def":"Of or pertaining to the orbitosphenoid bone; orbitosphenoid.","pos":""}],"ORBITUARY":[{"def":"ORBITUDE; ORBITY Or\"bi*tude, Or\"bi*ty, n.","pos":""}],"ORBULINA":[{"def":"A genus of minute living Foraminifera having a globular shell.","pos":""}],"ORBY":[{"def":"Orblike; having the course of an orb; revolving.","pos":""}]}