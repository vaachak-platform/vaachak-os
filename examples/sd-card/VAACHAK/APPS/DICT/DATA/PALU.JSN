{"PALUDAL":[{"def":"Of or pertaining to marshes or fens; marshy.","pos":""}],"PALUDAMENT":[{"def":"See Paludamentum.","pos":""}],"PALUDICOLAE":[{"def":"A division of birds, including the cranes, rails, etc.","pos":""}],"PALUDINA":[{"def":"Any one of numerous species of freshwater pectinibranchiate mollusks, belonging to Paludina, Melantho, and allied genera.","pos":""}],"PALUDINAL":[{"def":"Inhabiting ponds or swamps.","pos":""}],"PALUDINE":[{"def":"Of or pertaining to a marsh.","pos":""}],"PALUDINOUS":[{"def":"Of or pertaining to a marsh or fen.","pos":""}],"PALUDISM":[{"def":"The morbid phenomena produced by dwelling among marshes; malarial disease or disposition.","pos":""}],"PALUDOSE":[{"def":"Growing or living in marshy places; marshy.","pos":""}],"PALULE":[{"def":"See Palulus or Palus.","pos":""}],"PALUS":[{"def":"One of several upright slender calcareous processes which surround the central part of the calicle of certain corals.","pos":""}],"PALUSTRAL":[{"def":"Of or pertaining to a bog or marsh; boggy.","pos":""}],"PALUSTRINE":[{"def":"Of, pertaining to, or living in, a marsh or swamp; marshy.","pos":""}]}