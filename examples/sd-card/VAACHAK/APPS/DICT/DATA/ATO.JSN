{"ATOKOUS":[{"def":"Producing only asexual individuals, as the eggs of certain annelids.","pos":""}],"ATOLE":[{"def":"A porridge or gruel of maize meal and water, milk, or the like.","pos":""}],"ATOLL":[{"def":"A coral island or islands, consisting of a belt of coral reef, partly submerged, surrounding a central lagoon or depression; a lagoon island.","pos":""}],"ATOM":[{"def":"The smallest particle of matter that can enter into combination; one of the elementary constituents of a molecule.","pos":""}],"ATOMICALLY":[{"def":"In an atomic manner; in accordance with the atomic philosophy.","pos":""}],"ATOMICITY":[{"def":"Degree of atomic attraction; equivalence; valence; also (a later use) the number of atoms in an elementary molecule.","pos":""}],"ATOMISM":[{"def":"The doctrine of atoms.","pos":""}],"ATOMIST":[{"def":"One who holds to the atomic philosophy or theory.","pos":""}],"ATOMISTIC":[{"def":"Of or pertaining to atoms; relating to atomism.","pos":""}],"ATOMIZATION":[{"def":"The reduction of fluids into fine spray.","pos":""}],"ATOMIZE":[{"def":"To reduce to atoms, or to fine spray.","pos":""}],"ATOMIZER":[{"def":"One who, or that which, atomizes; esp.","pos":""}],"ATOMOLOGY":[{"def":"The doctrine of atoms.","pos":""}],"ATOMY":[{"def":"An atom; a mite; a pigmy.","pos":""}],"ATONABLE":[{"def":"Admitting an atonement; capable of being atoned for; expiable.","pos":""}],"ATONE":[{"def":"To set at one; to reduce to concord; to reconcile, as parties at variance; to appease.","pos":""},{"def":"To unite in making.","pos":""}],"ATONEMENT":[{"def":"Satisfaction or reparation made by giving an equivalent for an injury, or by doing of suffering that which will be received in satisfaction for an offense or injury; expiation; amends; -- with for.","pos":""}],"ATONER":[{"def":"One who makes atonement.","pos":""}],"ATONES":[{"def":"Etym: [See At one.","pos":""}],"ATONIC":[{"def":"Characterized by atony, or want of vital energy; as, an atonic disease.","pos":""},{"def":"Unaccented; as, an atonic syllable.","pos":""}],"ATONY":[{"def":"Want of tone; weakness of the system, or of any organ, especially of such as are contractile.","pos":""}],"ATOP":[{"def":"On or at the top.","pos":""},{"def":"Affected with melancholy; atrabilious.","pos":""}]}