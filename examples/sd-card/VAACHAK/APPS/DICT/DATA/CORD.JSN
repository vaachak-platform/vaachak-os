{"CORD":[{"def":"Any structure having the appearance of a cord, esp.","pos":""}],"CORDAGE":[{"def":"Ropes or cords, collectively; hence, anything made of rope or cord, as those parts of the rigging of a ship which consist of ropes.","pos":""}],"CORDAL":[{"def":"Same as Cordelle.","pos":""}],"CORDATE":[{"def":"Heart-shaped; as, a cordate leaf.","pos":""}],"CORDATELY":[{"def":"In a cordate form.","pos":""}],"CORDED":[{"def":"Bound about, or wound, with cords.","pos":""}],"CORDELIER":[{"def":"A Franciscan; -- so called in France from the girdle of knotted cord worn by all Franciscans.","pos":""},{"def":"A member of a French political club of the time of the first Revolution, of which Danton and Marat were members, and which met in an old Cordelier convent in Paris.","pos":""}],"CORDELING":[{"def":"Cor\"del*ing (kr\"dlng), a.","pos":""}],"CORDELLE":[{"def":"A twisted cord; a tassel.","pos":""}],"CORDIAL":[{"def":"Proceeding from the heart.","pos":""},{"def":"Hearty; sincere; warm; affectionate.","pos":""}],"CORDIALITY":[{"def":"Relation to the heart.","pos":""},{"def":"Sincere affection and kindness; warmth of regard; heartiness.","pos":""}],"CORDIALIZE":[{"def":"To make into a cordial.","pos":""},{"def":"To render cordial; to reconcile.","pos":""}],"CORDIALLY":[{"def":"In a cordial manner.","pos":""}],"CORDIFORM":[{"def":"Cor\"di*form (kr\"d-frm), a.","pos":""}],"CORDILLERA":[{"def":"A mountain ridge or chain.","pos":""}],"CORDINER":[{"def":"Cor\"di*ner (kr\"d-nr), n.","pos":""}],"CORDITE":[{"def":"A smokeless powder composed of nitroglycerin, guncotton, and mineral jelly, and used by the British army and in other services.","pos":""}],"CORDON":[{"def":"The coping of the scarp wall, which projects beyong the face of the wall a few inches.","pos":""},{"def":"A line or series of sentinels, or of military posts, inclosing or guarding any place or thing.","pos":""}],"CORDONNET":[{"def":"Doubled and twisted thread, made of coarse silk, and used for tassels, fringes, etc.","pos":""}],"CORDOVAN":[{"def":"Same as Cordwain.","pos":""}],"CORDUROY":[{"def":"Trousers or breeches of corduroy.","pos":""}],"CORDWAIN":[{"def":"A term used in the Middle Ages for Spanish leather (goatskin tanned and dressed), and hence, any leather handsomely finished, colored, gilded, or the like.","pos":""}],"CORDWAINER":[{"def":"A worker in cordwain, or cordovan leather; a shoemaker.","pos":""}],"CORDY":[{"def":"Of, or like, cord; having cords or cordlike parts.","pos":""}]}