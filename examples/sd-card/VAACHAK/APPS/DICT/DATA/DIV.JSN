{"DIVAGATION":[{"def":"A wandering about or going astray; digression.","pos":""}],"DIVALENT":[{"def":"Having two units of combining power; bivalent.","pos":""}],"DIVAN":[{"def":"In Turkey and other Oriental countries: A council of state; a royal court.","pos":""}],"DIVARICATE":[{"def":"To part into two branches; to become bifid; to fork.","pos":""},{"def":"To diverge; to be divaricate.","pos":""}],"DIVARICATELY":[{"def":"With divarication.","pos":""}],"DIVARICATION":[{"def":"A divergence of lines of color sculpture, or of fibers at different angles.","pos":""}],"DIVARICATOR":[{"def":"One of the muscles which open the shell of brachiopods; a cardinal muscle.","pos":""}],"DIVAST":[{"def":"Devastated; laid waste.","pos":""}],"DIVE":[{"def":"To plunge into water head foremost; to thrust the body under, or deeply into, water or other fluid.","pos":""}],"DIVEDAPPER":[{"def":"A water fowl; the didapper.","pos":""}],"DIVELLENT":[{"def":"Drawing asunder.","pos":""}],"DIVELLICATE":[{"def":"To pull in pieces.","pos":""}],"DIVER":[{"def":"Any bird of certain genera, as Urinator (formerly Colymbus), or the allied genus Colymbus, or Podiceps, remarkable for their agility in diving.","pos":""}],"DIVERB":[{"def":"A saying in which two members of the sentence are contrasted; an antithetical proverb.","pos":""}],"DIVERBERATE":[{"def":"To strike or sound through.","pos":""}],"DIVERBERATION":[{"def":"A sounding through.","pos":""}],"DIVERGE":[{"def":"To extend from a common point in different directions; to tend from one point and recede from each other; to tend to spread apart; to turn aside or deviate (as from a given direction); -- opposed to converge; as, rays of light diverge as they proceed from the sun.","pos":""},{"def":"To differ from a typical form; to vary from a normal condition; to dissent from a creed or position generally held or taken.","pos":""}],"DIVERGEMENT":[{"def":"A receding from each other in moving from a common center; the state of being divergent; as, an angle is made by the divergence of straight lines.","pos":""},{"def":"Disagreement; difference.","pos":""}],"DIVERGENT":[{"def":"Causing divergence of rays; as, a divergent lens.","pos":""}],"DIVERGING":[{"def":"Tending in different directions from a common center; spreading apart; divergent.","pos":""}],"DIVERGINGLY":[{"def":"In a diverging manner.","pos":""}],"DIVERS":[{"def":"Different in kind or species; diverse.","pos":""},{"def":"Several; sundry; various; more than one, but not a great number; as, divers philosophers.","pos":""}],"DIVERSE":[{"def":"Different; unlike; dissimilar; distinct; separate.","pos":""},{"def":"Capable of various forms; multiform.","pos":""}],"DIVERSELY":[{"def":"In different ways; differently; variously.","pos":""},{"def":"In different directions; to different points.","pos":""}],"DIVERSENESS":[{"def":"The quality of being diverse.","pos":""}],"DIVERSIFIABILITY":[{"def":"The quality or capacity of being diversifiable.","pos":""}],"DIVERSIFIABLE":[{"def":"Capable of being diversified or varied.","pos":""}],"DIVERSIFICATION":[{"def":"The act of making various, or of changing form or quality.","pos":""},{"def":"State of diversity or variation; variegation; modification; change; alternation.","pos":""}],"DIVERSIFIED":[{"def":"Distinguished by various forms, or by a variety of aspects or objects; variegated; as, diversified scenery or landscape.","pos":""}],"DIVERSIFIER":[{"def":"One who, or that which, diversifies.","pos":""}],"DIVERSIFORM":[{"def":"Of a different form; of varied forms.","pos":""}],"DIVERSIFY":[{"def":"To make diverse or various in form or quality; to give variety to; to variegate; to distinguish by numerous differences or aspects.","pos":""}],"DIVERSILOQUENT":[{"def":"Speaking in different ways.","pos":""}],"DIVERSION":[{"def":"The act of drawing the attention and force of an enemy from the point where the principal attack is to be made; the attack, alarm, or feint which diverts.","pos":""}],"DIVERSITY":[{"def":"A state of difference; dissimilitude; unlikeness.","pos":""},{"def":"Multiplicity of difference; multiformity; variety.","pos":""}],"DIVERSIVOLENT":[{"def":"Desiring different things.","pos":""}],"DIVERSORY":[{"def":"Serving or tending to divert; also, distinguishing.","pos":""}],"DIVERT":[{"def":"To turn aside; to turn off from any course or intended application; to deflect; as, to divert a river from its channel; to divert commerce from its usual course.","pos":""},{"def":"To turn away from any occupation, business, or study; to cause to have lively and agreeable sensations; to amuse; to entertain; as, children are diverted with sports; men are diverted with works of wit and humor.","pos":""}],"DIVERTER":[{"def":"One who, or that which, diverts, turns off, or pleases.","pos":""}],"DIVERTIBLE":[{"def":"Capable of being diverted.","pos":""}],"DIVERTICLE":[{"def":"A turning; a byway; a bypath.","pos":""}],"DIVERTICULAR":[{"def":"Pertaining to a diverticulum.","pos":""}],"DIVERTICULUM":[{"def":"A blind tube branching out of a longer one.","pos":""}],"DIVERTIMENTO":[{"def":") A light and pleasing composition.","pos":""}],"DIVERTING":[{"def":"Amusing; entertaining.","pos":""}],"DIVERTISE":[{"def":"To divert; to entertain.","pos":""}],"DIVERTISEMENT":[{"def":"Diversion; amusement; recreation.","pos":""}],"DIVERTISSEMENT":[{"def":"A short ballet, or other entertainment, between the acts of a play.","pos":""}],"DIVERTIVE":[{"def":"Tending to divert; diverting; amusing; interesting.","pos":""}],"DIVES":[{"def":"The name popularly given to the rich man in our Lord's parable of the \"Rich Man and Lazarus\" (Luke xvi.","pos":""}],"DIVEST":[{"def":"To unclothe; to strip, as of clothes, arms, or equipage; -- opposed to invest.","pos":""}],"DIVESTIBLE":[{"def":"Capable of being divested.","pos":""}],"DIVESTITURE":[{"def":"The act of stripping, or depriving; the state of being divested; the deprivation, or surrender, of possession of property, rights, etc.","pos":""}],"DIVESTMENT":[{"def":"The act of divesting.","pos":""}],"DIVI-DIVI":[{"def":"A small tree of tropical America (Cæsalpinia coriaria), whose legumes contain a large proportion of tannic and gallic acid, and are used by tanners and dyers.","pos":""}],"DIVIDABLE":[{"def":"Capable of being divided; divisible.","pos":""},{"def":"Divided; separated; parted.","pos":""}],"DIVIDANT":[{"def":"Different; distinct.","pos":""}],"DIVIDE":[{"def":"To subject to arithmetical division.","pos":""},{"def":"To separate into species; -- said of a genus or generic term.","pos":""}],"DIVIDED":[{"def":"Cut into distinct parts, by incisions which reach the midrib; - - said of a leaf.","pos":""}],"DIVIDEDLY":[{"def":"Separately; in a divided manner.","pos":""}],"DIVIDEND":[{"def":"A number or quantity which is to be divided.","pos":""}],"DIVIDENT":[{"def":"Dividend; share.","pos":""}],"DIVIDER":[{"def":"An instrument for dividing lines, describing circles, etc.","pos":""}],"DIVIDING":[{"def":"That divides; separating; marking divisions; graduating.","pos":""}],"DIVIDUAL":[{"def":"Divided, shared, or participated in, in common with others.","pos":""}],"DIVIDUOUS":[{"def":"Divided; dividual.","pos":""}],"DIVINATION":[{"def":"The act of divining; a foreseeing or foretelling of future events; the pretended art discovering secret or future by preternatural means.","pos":""},{"def":"Note: Among the ancient heathen philosophers natural divination was supposed to be effected by a divine afflatus; artificial divination by certain rites, omens, or appearances, as the flight of birds, entrails of animals, etc.","pos":""}],"DIVINATOR":[{"def":"One who practices or pretends to divination; a diviner.","pos":""}],"DIVINATORY":[{"def":"Professing, or relating to, divination.","pos":""}],"DIVINE":[{"def":"Of or belonging to God; as, divine perfections; the divine will.","pos":""},{"def":"Proceeding from God; as, divine judgments.","pos":""}],"DIVINELY":[{"def":"In a divine or godlike manner; holily; admirably or excellently in a supreme degree.","pos":""},{"def":"By the agency or influence of God.","pos":""}],"DIVINENESS":[{"def":"The quality of being divine; superhuman or supreme excellence.","pos":""}],"DIVINER":[{"def":"One who professes divination; one who pretends to predict events, or to reveal occult things, by supernatural means.","pos":""},{"def":"A conjecture; a guesser; one who makes out occult things.","pos":""}],"DIVINERESS":[{"def":"A woman who divines.","pos":""}],"DIVING":[{"def":"That dives or is used or diving.","pos":""}],"DIVINIFY":[{"def":"To render divine; to deify.","pos":""}],"DIVINING":[{"def":"That divines; for divining.","pos":""}],"DIVININGLY":[{"def":"In a divining manner.","pos":""}],"DIVINITY":[{"def":"The state of being divine; the nature or essence of God; deity; godhead.","pos":""},{"def":"The Deity; the Supreme Being; God.","pos":""}],"DIVINITY CALF":[{"def":"Calf stained dark brown and worked without gilding, often used for theological books.","pos":""}],"DIVINIZATION":[{"def":"A making divine.","pos":""}],"DIVINIZE":[{"def":"To invest with a divine character; to deify.","pos":""}],"DIVISIBILITY":[{"def":"The quality of being divisible; the property of bodies by which their parts are capable of separation.","pos":""}],"DIVISIBLE":[{"def":"Capable of being divided or separated.","pos":""}],"DIVISION":[{"def":"The process of finding how many times one number or quantity is contained in another; the reverse of multiplication; also, the rule by which the operation is performed.","pos":""},{"def":"The separation of a genus into its constituent species.","pos":""}],"DIVISIONAL":[{"def":"That divides; pas, a divisional line; a divisional general; a divisional surgeon of police.","pos":""}],"DIVISIONALLY":[{"def":"So as to be divisional.","pos":""}],"DIVISIONOR":[{"def":"One who divides or makes division.","pos":""}],"DIVISIVE":[{"def":"Indicating division or distribution.","pos":""},{"def":"Creating, or tending to create, division, separation, or difference.","pos":""}],"DIVISOR":[{"def":"The number by which the dividend is divided.","pos":""}],"DIVORCE":[{"def":"The decree or writing by which marriage is dissolved.","pos":""},{"def":"Separation; disunion of things closely united.","pos":""}],"DIVORCEABLE":[{"def":"Capable of being divorced.","pos":""}],"DIVORCEE":[{"def":"A person divorced.","pos":""}],"DIVORCELESS":[{"def":"Incapable of being divorced or separated; free from divorce.","pos":""}],"DIVORCEMENT":[{"def":"Dissolution of the marriage tie; divorce; separation.","pos":""}],"DIVORCER":[{"def":"The person or cause that produces or effects a divorce.","pos":""}],"DIVORCIVE":[{"def":"Having power to divorce; tending to divorce.","pos":""}],"DIVOT":[{"def":"A thin, oblong turf used for covering cottages, and also for fuel.","pos":""}],"DIVULGATION":[{"def":"The act of divulging or publishing.","pos":""}],"DIVULGE":[{"def":"To make public; to several or communicate to the public; to tell (a secret) so that it may become generally known; to disclose; -- said of that which had been confided as a secret, or had been before unknown; as, to divulge a secret.","pos":""},{"def":"To indicate publicly; to proclaim.","pos":""}],"DIVULSIVE":[{"def":"Tending to pull asunder, tear, or rend; distracting.","pos":""}]}