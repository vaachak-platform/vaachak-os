{"NUL":[{"def":"No; not any; as, nul disseizin; nul tort.","pos":""}],"NULL":[{"def":"Of no legal or binding force or validity; of no efficacy; invalid; void; nugatory; useless.","pos":""}],"NULLAH":[{"def":"A water course, esp.","pos":""}],"NULLED":[{"def":"Turned so as to resemble nulls.","pos":""}],"NULLIBIETY":[{"def":"The state or condition of being nowhere.","pos":""}],"NULLIFICATION":[{"def":"The act of nullifying; a rendering void and of no effect, or of no legal effect.","pos":""}],"NULLIFIDIAN":[{"def":"Of no faith; also, not trusting to faith for salvation; -- opposed to Ant: solifidian.","pos":""}],"NULLIFIER":[{"def":"One who nullifies or makes void; one who maintains the right to nullify a contract by one of the parties.","pos":""}],"NULLIFY":[{"def":"To make void; to render invalid; to deprive of legal force or efficacy.","pos":""}],"NULLIPORE":[{"def":"A name for certain crustaceous marine algæ which secrete carbonate of lime on their surface, and were formerly thought to be of animal nature.","pos":""}],"NULLITY":[{"def":"Nonexistence; as, a decree of nullity of marriage is a decree that no legal marriage exists.","pos":""}]}