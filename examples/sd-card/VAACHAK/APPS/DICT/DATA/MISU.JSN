{"MISUNDERSTAND":[{"def":"To misconceive; to mistake; to miscomprehend; to take in a wrong sense.","pos":""}],"MISUNDERSTANDER":[{"def":"One who misunderstands.","pos":""}],"MISUNDERSTANDING":[{"def":"Mistake of the meaning; error; misconception.","pos":""},{"def":"Disagreement; difference of opinion; dissension; quarrel.","pos":""}],"MISURATO":[{"def":"Measured; -- a direction to perform a passage in strict or measured time.","pos":""}],"MISUSAGE":[{"def":"Bad treatment; abuse.","pos":""}],"MISUSE":[{"def":"To treat or use improperly; to use to a bad purpose; to misapply; as, to misuse one's talents.","pos":""},{"def":"To abuse; to treat ill.","pos":""}],"MISUSER":[{"def":"Unlawful use of a right; use in excess of, or varying from, one's right.","pos":""}]}