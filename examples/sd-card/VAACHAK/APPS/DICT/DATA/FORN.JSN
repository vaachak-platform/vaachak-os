{"FORNICAL":[{"def":"Relating to a fornix.","pos":""},{"def":"Arching over; overarched.","pos":""}],"FORNICATE":[{"def":"To commit fornication; to have unlawful sexual intercourse.","pos":""}],"FORNICATION":[{"def":"Unlawful sexual intercourse on the part of an unmarried person; the act of such illicit sexual intercourse between a man and a woman as does not by law amount to adultery.","pos":""}],"FORNICATOR":[{"def":"An unmarried person, male or female, who has criminal intercourse with the other sex; one guilty of fornication.","pos":""}],"FORNICATRESS":[{"def":"A woman guilty of fornication.","pos":""}]}