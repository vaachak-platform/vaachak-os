{"PYOCYANIN":[{"def":"A blue coloring matter found in the pus from old sores, supposed to be formed through the agency of a species of bacterium (Bacillus pyocyaneus).","pos":""}],"PYOGENIC":[{"def":"Producing or generating pus.","pos":""}],"PYOID":[{"def":"Of or pertaining to pus; of the nature of, or like, pus.","pos":""}],"PYOPNEUMOTHORAX":[{"def":"Accumulation of air, or other gas, and of pus, in the pleural cavity.","pos":""}],"PYOXANTHOSE":[{"def":"A greenish yellow crystalline coloring matter found with pyocyanin in pus.","pos":""}]}