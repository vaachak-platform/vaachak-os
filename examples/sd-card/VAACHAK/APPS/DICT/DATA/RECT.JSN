{"RECTAL":[{"def":"Of or pertaining to the rectum; in the region of the rectum.","pos":""}],"RECTANGLE":[{"def":"A four-sided figure having only right angles; a right-angled parallelogram.","pos":""}],"RECTANGLED":[{"def":"Rec\"tan`gled (-g'ld), a.","pos":""}],"RECTANGULAR":[{"def":"Right-angled; having one or more angles of ninety degrees.","pos":""}],"RECTANGULARITY":[{"def":"The quality or condition of being rectangular, or right-angled.","pos":""}],"RECTI-":[{"def":"A combining form signifying straight; as, rectilineal, having straight lines; rectinerved.","pos":""}],"RECTIFIABLE":[{"def":"Capable of being rectified; as, a rectifiable mistake.","pos":""}],"RECTIFICATION":[{"def":"The determination of a straight line whose length is equal a portion of a curve.","pos":""}],"RECTIFICATOR":[{"def":"That which rectifies or refines; esp.","pos":""}],"RECTIFIER":[{"def":"One who, or that which, rectifies.","pos":""},{"def":"Specifically: (a) (Naut.","pos":""}],"RECTIFY":[{"def":"To refine or purify by repeated distillation or sublimation, by which the fine parts of a substance are separated from the grosser; as, to rectify spirit of wine.","pos":""},{"def":"To produce ( as factitious gin or brandy) by redistilling low wines or ardent spirits (whisky, rum, etc.","pos":""}],"RECTILINEARITY":[{"def":"The quality or state of being rectilinear.","pos":""}],"RECTILINEOUS":[{"def":"Rec`ti*lin\"e*ous (-s), a.","pos":""}],"RECTINERVED":[{"def":"Having the veins or nerves straight; -- said of leaves.","pos":""}],"RECTION":[{"def":"See Government, n.","pos":""}],"RECTIROSTRAL":[{"def":"Having a straight beak.","pos":""}],"RECTISERIAL":[{"def":"Arranged in exactly vertical ranks, as the leaves on stems of many kinds; -- opposed to curviserial.","pos":""}],"RECTITIS":[{"def":"Rec*ti\"tis (rk*t\"ts), n.","pos":""}],"RECTITUDE":[{"def":"Rightness of principle or practice; exact conformity to truth, or to the rules prescribed for moral conduct, either by divine or human laws; uprightness of mind; uprightness; integrity; honesty; justice.","pos":""}],"RECTO":[{"def":"A writ of right.","pos":""}],"RECTO-":[{"def":"A combining form indicating connection with, or relation to, the rectum; as, recto-vesical.","pos":""}],"RECTO-UTERINE":[{"def":"Of or pertaining to both the rectum and the uterus.","pos":""}],"RECTO-VESICAL":[{"def":"Of or pertaining to both the rectum and the bladder.","pos":""}],"RECTOR":[{"def":"A clergyman in charge of a parish.","pos":""},{"def":"The superior officer or chief of a convent or religious house; and among the Jesuits the superior of a house that is a seminary or college.","pos":""}],"RECTORAL":[{"def":"Pertaining to a rector or governor.","pos":""}],"RECTORATE":[{"def":"The office, rank, or station of a rector; rectorship.","pos":""}],"RECTORESS":[{"def":"A governess; a rectrix.","pos":""},{"def":"The wife of a rector.","pos":""}],"RECTORIAL":[{"def":"Pertaining to a rector or a rectory; rectoral.","pos":""}],"RECTORSHIP":[{"def":"Government; guidance.","pos":""},{"def":"The office or rank of a rector; rectorate.","pos":""}],"RECTORY":[{"def":"The province of a rector; a parish church, parsonage, or spiritual living, with all its rights, tithes, and glebes.","pos":""},{"def":"A rector's mansion; a parsonage house.","pos":""}],"RECTOVAGINAL":[{"def":"Of or pertaining to both the rectum and the vagina.","pos":""}],"RECTRESS":[{"def":"Rec\"tress (rk\"trs), n.","pos":""}],"RECTRIX":[{"def":"One of the quill feathers of the tail of a bird.","pos":""}],"RECTUM":[{"def":"The terminal part of the large intestine; -- so named because supposed by the old anatomists to be straight.","pos":""}],"RECTUS":[{"def":"A straight muscle; as, the recti of the eye.","pos":""}]}