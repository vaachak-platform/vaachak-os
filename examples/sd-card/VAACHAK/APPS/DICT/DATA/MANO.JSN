{"MANO":[{"def":"The muller, or crushing and grinding stone, used in grinding corn on a metate.","pos":""}],"MANOGRAPH":[{"def":"An optical device for making an indicator diagram for high- speed engines.","pos":""}],"MANOMETER":[{"def":"An instrument for measuring the tension or elastic force of gases, steam, etc.","pos":""},{"def":"Of or pertaining to the manometer; made by the manometer.","pos":""}],"MANOR":[{"def":"The land belonging to a lord or nobleman, or so much land as a lord or great personage kept in his own hands, for the use and subsistence of his family.","pos":""},{"def":"A tract of land occupied by tenants who pay a free-farm rent to the proprietor, sometimes in kind, and sometimes by performing certain stipulated services.","pos":""}],"MANORIAL":[{"def":"Of or pertaining to a manor.","pos":""}],"MANOSCOPE":[{"def":"Same as Manometer.","pos":""}],"MANOSCOPY":[{"def":"The science of the determination of the density of vapors and gases.","pos":""}],"MANOVERY":[{"def":"A contrivance or maneuvering to catch game illegally.","pos":""}]}