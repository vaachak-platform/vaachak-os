{"CYNANCHE":[{"def":"Any disease of the tonsils, throat, or windpipe, attended with inflammation, swelling, and difficulty of breathing and swallowing.","pos":""}],"CYNANTHROPY":[{"def":"A kind of madness in which men fancy themselves changed into dogs, and imitate the voice and habits of that animal.","pos":""}],"CYNARCTOMACHY":[{"def":"Bear baiting with a dog.","pos":""}],"CYNARRHODIUM":[{"def":"A fruit like that of the rose, consisting of a cup formed of the calyx tube and receptacle, and containing achenes.","pos":""}],"CYNEGETICS":[{"def":"The art of hunting with dogs.","pos":""}],"CYNIC":[{"def":"One of a sect or school of philosophers founded by Antisthenes, and of whom Diogenes was a disciple.","pos":""},{"def":"One who holds views resembling those of the Cynics; a snarler; a misanthrope; particularly, a person who believes that human conduct is directed, either consciously or unconsciously, wholly by self- interest or self-indulgence, and that appearances to the contrary are superficial and untrustworthy.","pos":""}],"CYNICALLY":[{"def":"In a cynical manner.","pos":""}],"CYNICALNESS":[{"def":"The quality of being cynical.","pos":""}],"CYNICISM":[{"def":"The doctrine of the Cynics; the quality of being cynical; the mental state, opnions, or conduct, of a cynic; morose and contemptuous views and opinions.","pos":""}],"CYNOIDEA":[{"def":"A division of Carnivora, including the dogs, wolves, and foxes.","pos":""}],"CYNOREXIA":[{"def":"A voracious appetite, like that of a starved dog.","pos":""}],"CYNOSURAL":[{"def":"Of or pertaining to a cynosure.","pos":""}],"CYNOSURE":[{"def":"The constellation of the Lesser Bear, to which, as containing the polar star, the eyes of mariners and travelers were often directed.","pos":""},{"def":"That which serves to direct.","pos":""}]}