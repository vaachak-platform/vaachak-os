{"COURAGE":[{"def":"The heart; spirit; temper; disposition.","pos":""},{"def":"Heart; inclination; desire; will.","pos":""}],"COURAGEOUS":[{"def":"Possessing, or characterized by, courage; brave; bold.","pos":""}],"COURAGEOUSLY":[{"def":"In a courageous manner.","pos":""}],"COURAGEOUSNESS":[{"def":"The quality of being courageous; courage.","pos":""}],"COURANT":[{"def":"Represented as running; -- said of a beast borne in a coat of arms.","pos":""}],"COURANTO":[{"def":"A sprightly dance; a coranto; a courant.","pos":""}],"COURAP":[{"def":"A skin disease, common in India, in which there is perpetual itching and eruption, esp.","pos":""}],"COURB":[{"def":"Curved; rounded.","pos":""}],"COURBARIL":[{"def":"Cour\"ba*ril (kr\"b-rl), n.","pos":""}],"COURCHE":[{"def":"A square piece of linen used formerly by women instead of a cap; a kerchief.","pos":""}],"COURIER":[{"def":"A messenger sent with haste to convey letters or dispatches, usually on public busuness.","pos":""},{"def":"An attendant on travelers, whose business it is to make arrangements for their convenience at hotels and on the way.","pos":""}],"COURLAN":[{"def":"A South American bird, of the genus Aramus, allied to the rails.","pos":""}],"COURSE":[{"def":"A continuous level range of brick or stones of the same height throughout the face or faces of a building.","pos":""},{"def":"The lowest sail on any mast of a square-rigged vessel; as, the fore course, main course, etc.","pos":""}],"COURSED":[{"def":"Hunted; as, a coursed hare.","pos":""},{"def":"Arranged in courses; as, coursed masonry.","pos":""}],"COURSER":[{"def":"A grallatorial bird of Europe (Cursorius cursor), remarkable for its speed in running.","pos":""}],"COURSEY":[{"def":"A space in the galley; a part of the hatches.","pos":""}],"COURSING":[{"def":"The pursuit or running game with dogs that follow by sight instead of by scent.","pos":""}],"COURT":[{"def":"An inclosed space; a courtyard; an uncovered area shut in by the walls of a building, or by different building; also, a space opening from a street and nearly surrounded by houses; a blind alley.","pos":""},{"def":"The residence of a sovereign, prince, nobleman, or ether dignitary; a palace.","pos":""}],"COURT TENNIS":[{"def":"See under Tennis.","pos":""}],"COURT-BARON":[{"def":"An inferior court of civil jurisdiction, attached to a manor, and held by the steward; a baron's court; -- now fallen into disuse.","pos":""}],"COURT-CRAFT":[{"def":"The artifices, intrigues, and plottings, at courts.","pos":""}],"COURT-CUPBOARD":[{"def":"A movable sideboard or buffet, on which plate and other articles of luxury were displayed on special ocasions.","pos":""}],"COURT-LEET":[{"def":"A court of record held once a year, in a particular hundred, lordship, or manor, before the steward of the leet.","pos":""}],"COURT-MARTIAL":[{"def":"A court consisting of military or naval officers, for the trial of one belonging to the army or navy, or of offenses against military or naval law.","pos":""}],"COURT-PLASTER":[{"def":"Sticking plaster made by coating taffeta or silk on one side with some adhesive substance, commonly a mixture of isinglass and glycerin.","pos":""}],"COURTBRED":[{"def":"Bred, or educated, at court; polished; courtly.","pos":""}],"COURTELLE":[{"def":"a wool-like fabric.","pos":""}],"COURTEOUS":[{"def":"Of courtlike manners; pertaining to, or exxpressive of, courtesy; characterized by courtesy; civil; obliging; well bred; polite; affable; complaisant.","pos":""}],"COURTEOUSLY":[{"def":"In a courteous manner.","pos":""}],"COURTEOUSNESS":[{"def":"The quality of being courteous; politeness; courtesy.","pos":""}],"COURTEPY":[{"def":"A short coat of coarse cloth.","pos":""}],"COURTER":[{"def":"One who courts; one who plays the lover, or who solicits in marriage; one who flatters and cajoles.","pos":""}],"COURTESAN":[{"def":"A woman who prostitutes herself for hire; a prostitute; a harlot.","pos":""}],"COURTESY":[{"def":"Politeness; civility; urbanity; courtliness.","pos":""},{"def":"An act of civility or respect; an act of kindness or favor performed with politeness.","pos":""}],"COURTHOUSE":[{"def":"A house in which established courts are held, or a house appropriated to courts and public meetings.","pos":""},{"def":"A county town; -- so called in Virginia and some others of the Southern States.","pos":""}],"COURTIER":[{"def":"One who is in attendance at the court of a prince; one who has an appointment at court.","pos":""},{"def":"One who courts or solicits favor; one who flatters.","pos":""}],"COURTIERY":[{"def":"The manners of a courtier; courtliness.","pos":""}],"COURTLIKE":[{"def":"After the manner of a court; elegant; polite; courtly.","pos":""}],"COURTLINESS":[{"def":"The quality of being courtly; elegance or dignity of manners.","pos":""}],"COURTLING":[{"def":"A sycophantic courtier.","pos":""}],"COURTLY":[{"def":"Relating or belonging to a court.","pos":""},{"def":"Elegant; polite; courtlike; flattering.","pos":""}],"COURTSHIP":[{"def":"The act of paying court, with the intent to solicit a favor.","pos":""},{"def":"The act of wooing in love; solicitation of woman to marriage.","pos":""}],"COURTYARD":[{"def":"A court or inclosure attached to a house.","pos":""}]}