{"COX":[{"def":"A coxcomb; a simpleton; a gull.","pos":""}],"COXA":[{"def":"The first joint of the leg of an insect or crustacean.","pos":""},{"def":"Pain in the hip.","pos":""}],"COXCOMB":[{"def":"A name given to several plants of different genera, but particularly to Celosia cristata, or garden cockscomb.","pos":""}],"COXCOMBICAL":[{"def":"Befitting or indicating a coxcomb; like a coxcomb; foppish; conceited.","pos":""}],"COXCOMBLY":[{"def":"Cox\"comb\"ly (kks\"km`l), a.","pos":""}],"COXCOMBRY":[{"def":"The manners of a coxcomb; foppishness.","pos":""}],"COXCOMICAL":[{"def":"Cox*com\"ic*al (kks-km\"-kal), a.","pos":""}],"COXCOMICALLY":[{"def":"Cox*com\"ic*al*ly, adv.","pos":""}],"COXSWAIN":[{"def":"Cox\"swain` (kk\"swn, Colloq.","pos":""}]}