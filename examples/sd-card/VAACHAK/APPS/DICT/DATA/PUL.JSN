{"PULAS":[{"def":"The East Indian leguminous tree Butea frondosa.","pos":""}],"PULCHRITUDE":[{"def":"That quality of appearance which pleases the eye; beauty; comeliness; grace; loveliness.","pos":""},{"def":"Attractive moral excellence; moral beauty.","pos":""}],"PULE":[{"def":"To cry like a chicken.","pos":""},{"def":"To whimper; to whine, as a complaining child.","pos":""}],"PULER":[{"def":"One who pules; one who whines or complains; a weak person.","pos":""}],"PULEX":[{"def":"A genus of parasitic insects including the fleas.","pos":""}],"PULICENE":[{"def":"Pertaining to, or abounding in, fleas; pulicose.","pos":""},{"def":"Abounding with fleas.","pos":""}],"PULING":[{"def":"A cry, as of a chicken,; a whining or whimpering.","pos":""}],"PULINGLY":[{"def":"With whining or complaint.","pos":""}],"PULKHA":[{"def":"A Laplander's traveling sledge.","pos":""}],"PULL":[{"def":"To hold back, and so prevent from winning; as, the favorite was pulled.","pos":""},{"def":"To take or make, as a proof or impression; -- hand presses being worked by pulling a lever.","pos":""}],"PULLBACK":[{"def":"The iron hook fixed to a casement to pull it shut, or to hold it party open at a fixed point.","pos":""}],"PULLDEVIL":[{"def":"A number of fishhooks rigidly fastened back to be pulled through the water to catch fish.","pos":""}],"PULLED":[{"def":"Plucked; pilled; moulting.","pos":""}],"PULLER":[{"def":"One who, or that which, pulls.","pos":""}],"PULLET":[{"def":"A young hen, or female of the domestic fowl.","pos":""}],"PULLEY":[{"def":"A wheel with a broad rim, or grooved rim, for transmitting power from, or imparting power to, the different parts of machinery, or for changing the direction of motion, by means of a belt, cord, rope, or chain.","pos":""}],"PULLICATE":[{"def":"A kind of checked cotton or silk handkerchief.","pos":""}],"PULLMAN CAR":[{"def":"A kind of sleeping car; also, a palace car; -- often shortened to Pullman.","pos":""}],"PULLULATE":[{"def":"To germinate; to bud; to multiply abundantly.","pos":""}],"PULLULATION":[{"def":"A germinating, or budding.","pos":""}],"PULLUS":[{"def":"A chick; a young bird in the downy stage.","pos":""},{"def":"Same as Pulmonibranchiata, -ate.","pos":""}],"PULMOCUTANEOUS":[{"def":"Of or pertaining to the lungs and the akin; as, the pulmocutaneous arteries of the frog.","pos":""}],"PULMOGASTEROPODA":[{"def":"Same as Pulmonata.","pos":""}],"PULMOGRADE":[{"def":"Swimming by the expansion and contraction, or lunglike movement, of the body, or of the disk, as do the medusæ.","pos":""}],"PULMOMETRY":[{"def":"The determination of the capacity of the lungs.","pos":""}],"PULMONARIAN":[{"def":"Any arachnid that breathes by lunglike organs, as the spiders and scorpions.","pos":""}],"PULMONARY":[{"def":"Of or pertaining to the lungs; affecting the lungs; pulmonic.","pos":""}],"PULMONATA":[{"def":"An extensive division, or sub-class, of hermaphrodite gastropods, in which the mantle cavity is modified into an air- breathing organ, as in Helix, or land snails, Limax, or garden slugs, and many pond snails, as Limnæa and Planorbis.","pos":""}],"PULMONATE":[{"def":"One of the Pulmonata.","pos":""}],"PULMONATED":[{"def":"same as Pulmonate (a).","pos":""}],"PULMONIBRANCHIATA":[{"def":"Same as Pulmonata.","pos":""}],"PULMONIBRANCHIATE":[{"def":"Same as Pulmonate.","pos":""}],"PULMONIC":[{"def":"Relating to, or affecting the lungs; pulmonary.","pos":""},{"def":"A pulmonic medicine.","pos":""}],"PULMONIFERA":[{"def":"Same as Pulmonata.","pos":""}],"PULMONIFEROUS":[{"def":"Having lungs; pulmonate.","pos":""}],"PULMOTOR":[{"def":"An apparatus for producing artificial respiration by pumping oxygen or air or a mixture of the two into and out of the lungs, as of a person who has been asphyxiated by drowning, breathing poisonous gases, or the like, or of one who has been stunned by an electrical shock.","pos":""}],"PULP":[{"def":"A moist, slightly cohering mass, consisting of soft, undissolved animal or vegetable matter.","pos":""}],"PULPATOON":[{"def":"A kind of delicate confectionery or cake, perhaps made from the pulp of fruit.","pos":""}],"PULPINESS":[{"def":"the quality or state of being pulpy.","pos":""}],"PULPIT":[{"def":"An elevated place, or inclosed stage, in a church, in which the clergyman stands while preaching.","pos":""},{"def":"The whole body of the clergy; preachers as a class; also, preaching.","pos":""}],"PULPITED":[{"def":"Placed in a pulpit.","pos":""}],"PULPITEER":[{"def":"One who speaks in a pulpit; a preacher; -- so called in contempt.","pos":""}],"PULPITICAL":[{"def":"Of or pertaining to the pulpit; suited to the pulpit.","pos":""}],"PULPITISH":[{"def":"Of or pertaining to the pulpit; like preaching.","pos":""}],"PULPITRY":[{"def":"The teaching of the pulpit; preaching.","pos":""}],"PULPOUS":[{"def":"Containing pulp; pulpy.","pos":""}],"PULPY":[{"def":"Like pulp; consisting of pulp; soft; fleshy; succulent; as, the pulpy covering of a nut; the pulpy substance of a peach or a cherry.","pos":""}],"PULQUE":[{"def":"An intoxicating Mexican drink.","pos":""}],"PULSATE":[{"def":"To throb, as a pulse; to beat, as the heart.","pos":""}],"PULSATILE":[{"def":"Capable of being struck or beaten; played by beating or by percussion; as, a tambourine is a pulsatile musical instrument.","pos":""},{"def":"Pulsating; throbbing, as a tumor.","pos":""}],"PULSATILLA":[{"def":"A genus of ranunculaceous herbs including the pasque flower.","pos":""}],"PULSATION":[{"def":"A beating or throbbing, especially of the heart or of an artery, or in an inflamed part; a beat of the pulse.","pos":""},{"def":"Any touching of another's body willfully or in anger.","pos":""}],"PULSATIVE":[{"def":"Beating; throbbing.","pos":""}],"PULSATOR":[{"def":"That which beats or throbs in working.","pos":""}],"PULSATORY":[{"def":"Capable of pulsating; throbbing.","pos":""}],"PULSE":[{"def":"Leguminous plants, or their seeds, as beans, pease, etc.","pos":""}],"PULSELESS":[{"def":"Having no pulsation; lifeless.","pos":""}],"PULSELESSNESS":[{"def":"The state of being pulseless.","pos":""}],"PULSIFIC":[{"def":"Exciting the pulse; causing pulsation.","pos":""}],"PULSION":[{"def":"The act of driving forward; propulsion; -- opposed to Ant: suction or Ant: traction.","pos":""}],"PULSIVE":[{"def":"Tending to compel; compulsory.","pos":""}],"PULSOMETER":[{"def":"A device, with valves, for raising water by steam, partly by atmospheric pressure, and partly by the direct action of the steam on the water, without the intervention of a piston; -- also called vacuum pump.","pos":""}],"PULTACEOUS":[{"def":"Macerated; softened; nearly fluid.","pos":""}],"PULU":[{"def":"A vegetable substance consisting of soft, elastic, yellowish brown chaff, gathered in the Hawaiian Islands from the young fronds of free ferns of the genus Cibotium, chiefly C.","pos":""}],"PULVERABLE":[{"def":"Capable of being reduced to fine powder.","pos":""}],"PULVERACEOUS":[{"def":"Having a finely powdered surface; pulverulent.","pos":""}],"PULVERATE":[{"def":"To beat or reduce to powder or dust; to pulverize.","pos":""}],"PULVERINE":[{"def":"Ashes of barilla.","pos":""}],"PULVERIZABLE":[{"def":"Admitting of being pulverized; pulverable.","pos":""}],"PULVERIZATION":[{"def":"The action of reducing to dust or powder.","pos":""}],"PULVERIZE":[{"def":"To reduce of fine powder or dust, as by beating, grinding, or the like; as, friable substances may be pulverized by grinding or beating, but to pulverize malleable bodies other methods must be pursued.","pos":""}],"PULVERIZER":[{"def":"One who, or that which, pulverizes.","pos":""}],"PULVEROUS":[{"def":"Consisting of dust or powder; like powder.","pos":""}],"PULVERULENCE":[{"def":"The state of being pulverulent; abundance of dust or powder; dustiness.","pos":""}],"PULVERULENT":[{"def":"Consisting of, or reducible to, fine powder; covered with dust or powder; powdery; dusty.","pos":""}],"PULVIL":[{"def":"A sweet-scented powder; pulvillio.","pos":""}],"PULVILLUS":[{"def":"One of the minute cushions on the feet of certain insects.","pos":""}],"PULVINAR":[{"def":"A prominence on the posterior part of the thalamus of the human brain.","pos":""},{"def":"Curved convexly or swelled; as, a pulvinated frieze.","pos":""}],"PULVINIC":[{"def":"Pertaining to, or designating, an acid obtained by the decomposition of vulpinic acid, as a white crystalline substance.","pos":""}],"PULVINULUS":[{"def":"Same as Pulvillus.","pos":""}]}