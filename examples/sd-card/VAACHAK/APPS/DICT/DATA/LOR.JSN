{"LORAL":[{"def":"Of or pertaining to the lores.","pos":""}],"LORATE":[{"def":"Having the form of a thong or strap; ligulate.","pos":""}],"LORCHA":[{"def":"A kind of light vessel used on the coast of China, having the hull built on a European model, and the rigging like that of a Chinese junk.","pos":""}],"LORD":[{"def":"A hump-backed person; -- so called sportively.","pos":""}],"LORDING":[{"def":"The son of a lord; a person of noble lineage.","pos":""},{"def":"A little lord; a lordling; a lord, in contempt or ridicule.","pos":""}],"LORDLIKE":[{"def":"Befitting or like a lord; lordly.","pos":""},{"def":"Haughty; proud; insolent; arrogant.","pos":""}],"LORDLINESS":[{"def":"The state or quality of being lordly.","pos":""}],"LORDLING":[{"def":"A little or insignificant lord.","pos":""}],"LORDLY":[{"def":"Suitable for a lord; of or pertaining to a lord; resembling a lord; hence, grand; noble; dignified; honorable.","pos":""},{"def":"Proud; haughty; imperious; insolent.","pos":""}],"LORDOLATRY":[{"def":"Worship of, or reverence for, a lord as such.","pos":""}],"LORDS AND LADIES":[{"def":"The European wake-robin (Arum maculatum), -- those with purplish spadix the lords, and those with pale spadix the ladies.","pos":""}],"LORDSHIP":[{"def":"The state or condition of being a lord; hence (with his or your), a title applied to a lord (except an archbishop or duke, who is called Grace) or a judge (in Great Britain), etc.","pos":""},{"def":"Seigniory; domain; the territory over which a lord holds jurisdiction; a manor.","pos":""}],"LORE":[{"def":"Neither of them she found where she them lore.","pos":""}],"LOREL":[{"def":"A good for nothing fellow; a vagabond.","pos":""}],"LORESMAN":[{"def":"Members of a congregation of nuns founded by Mrs.","pos":""}],"LORETTE":[{"def":"In France, a name for a woman who is supported by her lovers, and devotes herself to idleness, show, and pleasure; -- so called from the church of Notre Dame de Lorette, in Paris, near which many of them resided.","pos":""}],"LORETTINE":[{"def":"One of a order of nuns founded in 1812 at Loretto, in Kentucky.","pos":""}],"LORGNETTE":[{"def":"An opera glass; pl.","pos":""},{"def":"elaborate double eyeglasses.","pos":""}],"LORICA":[{"def":"A cuirass, originally of leather, afterward of plates of metal or horn sewed on linen or the like.","pos":""},{"def":"Lute for protecting vessels from the fire.","pos":""}],"LORICATE":[{"def":"To cover with some protecting substance, as with lute, a crust, coating, or plates.","pos":""}],"LORICATION":[{"def":"The act of loricating; the protecting substance put on; a covering of scales or plates.","pos":""}],"LORIKEET":[{"def":"Any one numerous species of small brush-tongued parrots or lories, found mostly in Australia, New Guinea and the adjacent islands, with some forms in the East Indies.","pos":""},{"def":"A maker of bits, spurs, and metal mounting for bridles and saddles; hence, a saddler.","pos":""}],"LORING":[{"def":"Instructive discourse.","pos":""}],"LORIOT":[{"def":"The golden oriole of Europe.","pos":""}],"LORIS":[{"def":"Any one of several species of small lemurs of the genus Stenops.","pos":""}],"LORN":[{"def":"A small cart or wagon, as those used on the tramways in mines to carry coal or rubbish; also, a barrow or truck for shifting baggage, as at railway stations.","pos":""}],"LORY":[{"def":"Any one of many species of small parrots of the family Trichoglossidæ, generally having the tongue papillose at the tip, and the mandibles straighter and less toothed than in common parrots.","pos":""}]}