{"SAI":[{"def":"See Capuchin, 3 (a).","pos":""}],"SAIBLING":[{"def":"A European mountain trout (Salvelinus alpinus); -- called also Bavarian charr.","pos":""}],"SAIC":[{"def":"A kind of ketch very common in the Levant, which has neither topgallant sail nor mizzen topsail.","pos":""}],"SAID":[{"def":"before-mentioned; already spoken of or specified; aforesaid; -- used chiefly in legal style.","pos":""}],"SAIGA":[{"def":"An antelope (Saiga Tartarica) native of the plains of Siberia and Eastern Russia.","pos":""}],"SAIL":[{"def":"An extent of canvas or other fabric by means of which the wind is made serviceable as a power for propelling vessels through the water.","pos":""},{"def":"Anything resembling a sail, or regarded as a sail.","pos":""}],"SAILABLE":[{"def":"Capable of being sailed over; navigable; as, a sailable river.","pos":""}],"SAILBOAT":[{"def":"A boat propelled by a sail or sails.","pos":""}],"SAILCLOTH":[{"def":"Duck or canvas used in making sails.","pos":""}],"SAILER":[{"def":"A ship or other vessel; -- with qualifying words descriptive of speed or manner of sailing; as, a heavy sailer; a fast sailer.","pos":""}],"SAILING":[{"def":"The art of managing a vessel; seamanship; navigation; as, globular sailing; oblique sailing.","pos":""}],"SAILLESS":[{"def":"Destitute of sails.","pos":""}],"SAILMAKER":[{"def":"One whose occupation is to make or repair sails.","pos":""}],"SAILOR":[{"def":"One who follows the business of navigating ships or other vessels; one who understands the practical management of ships; one of the crew of a vessel; a mariner; a common seaman.","pos":""}],"SAIMIR":[{"def":"The squirrel monkey.","pos":""}],"SAIN":[{"def":"To sanctify; to bless so as to protect from evil influence.","pos":""}],"SAINT":[{"def":"One canonized by the church.","pos":""}],"SAINT-SIMONIAN":[{"def":"A follower of the Count de St.","pos":""}],"SAINT-SIMONIANISM":[{"def":"The principles, doctrines, or practice of the Saint-Simonians; -- called also Saint-Simonism.","pos":""}],"SAINT-SIMONISM":[{"def":"A system of socialism in which the state owns all the property and the laborer is entitled to share according to the quality and amount of his work, founded by Saint Simon (1760-1825).","pos":""}],"SAINTDOM":[{"def":"The state or character of a saint.","pos":""}],"SAINTED":[{"def":"Consecrated; sacred; holy; pious.","pos":""},{"def":"Entered into heaven; -- a euphemism for dead.","pos":""}],"SAINTHOOD":[{"def":"The state of being a saint; the condition of a saint.","pos":""},{"def":"The order, or united body, of saints; saints, considered collectively.","pos":""}],"SAINTISH":[{"def":"Somewhat saintlike; -- used ironically.","pos":""}],"SAINTISM":[{"def":"The character or quality of saints; also, hypocritical pretense of holiness.","pos":""}],"SAINTLIKE":[{"def":"Resembling a saint; suiting a saint; becoming a saint; saintly.","pos":""}],"SAINTLINESS":[{"def":"Quality of being saintly.","pos":""}],"SAINTLY":[{"def":"Like a saint; becoming a holy person.","pos":""}],"SAINTOLOGIST":[{"def":"One who writes the lives of saints.","pos":""}],"SAINTSHIP":[{"def":"The character or qualities of a saint.","pos":""}],"SAITH":[{"def":"Saith, Defn: 3d pers.","pos":""}],"SAITHE":[{"def":"The pollock, or coalfish; -- called also sillock.","pos":""}],"SAIVA":[{"def":"One of an important religious sect in India which regards Siva with peculiar veneration.","pos":""}],"SAIVISM":[{"def":"The worship of Siva.","pos":""}]}