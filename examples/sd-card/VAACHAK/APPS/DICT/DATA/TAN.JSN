{"TAN":[{"def":"The bark of the oak, and some other trees, bruised and broken by a mill, for tanning hides; -- so called both before and after it has been used.","pos":""},{"def":"A yellowish-brown color, like that of tan.","pos":""}],"TANA":[{"def":"Same as Banxring.","pos":""}],"TANAGER":[{"def":"Any one of numerous species of bright-colored singing birds belonging to Tanagra, Piranga, and allied genera.","pos":""}],"TANAGRINE":[{"def":"Of or pertaining to the tanagers.","pos":""}],"TANATE":[{"def":"An Asiatic wild dog (Canis procyonoides), native of Japan and adjacent countries.","pos":""}],"TANDEM":[{"def":"One after another; -- said especially of horses harnessed and driven one before another, instead of abreast.","pos":""}],"TANDEM CART":[{"def":"A kind of two-wheeled vehicle with seats back to back, the front one somewhat elevated.","pos":""}],"TANDEM ENGINE":[{"def":"A steam engine having two or more steam cylinders in line, with a common piston rod.","pos":""}],"TANDEM SYSTEM":[{"def":"= Cascade system.","pos":""}],"TANG":[{"def":"A coarse blackish seaweed (Fuscus nodosus).","pos":""}],"TANGALUNG":[{"def":"An East Indian civet (Viverra tangalunga).","pos":""}],"TANGELO":[{"def":"A hybrid between the tangerine orange and the grapefruit, or pomelo; also, the fruit.","pos":""}],"TANGENCY":[{"def":"The quality or state of being tangent; a contact or touching.","pos":""}],"TANGENT":[{"def":"A tangent line curve, or surface; specifically, that portion of the straight line tangent to a curve that is between the point of tangency and a given line, the given line being, for example, the axis of abscissas, or a radius of a circle produced.","pos":""}],"TANGENT SPOKE":[{"def":"A tension spoke of a bicycle or similar wheel, secured tangentially to the hub.","pos":""}],"TANGENTIAL":[{"def":"Of or pertaining to a tangent; in the direction of a tangent.","pos":""}],"TANGENTIALLY":[{"def":"In the direction of a tangent.","pos":""}],"TANGERINE":[{"def":"A kind of orange, much like the mandarin, but of deeper color and higher flavor.","pos":""}],"TANGFISH":[{"def":"The common harbor seal.","pos":""}],"TANGHINIA":[{"def":"The ordeal tree.","pos":""}],"TANGIBILITY":[{"def":"The quality or state of being tangible.","pos":""}],"TANGIBLE":[{"def":"Perceptible to the touch; tactile; palpable.","pos":""},{"def":"Capable of being possessed or realized; readily apprehensible by the mind; real; substantial; evident.","pos":""}],"TANGLE":[{"def":"To unite or knit together confusedly; to interweave or interlock, as threads, so as to make it difficult to unravel the knot; to entangle; to ravel.","pos":""},{"def":"To involve; to insnare; to entrap; as, to be tangled in lies.","pos":""}],"TANGLEFISH":[{"def":"The sea adder, or great pipefish of Europe.","pos":""}],"TANGLINGLY":[{"def":"In a tangling manner.","pos":""}],"TANGLY":[{"def":"Entangled; intricate.","pos":""},{"def":"Covered with tangle, or seaweed.","pos":""}],"TANGRAM":[{"def":"A Chinese toy made by cutting a square of thin wood, or other suitable material, into seven pieces, as shown in the cut, these pieces being capable of combination in various ways, so as to form a great number of different figures.","pos":""}],"TANGUN":[{"def":"A piebald variety of the horse, native of Thibet.","pos":""}],"TANIER":[{"def":"An aroid plant (Caladium sagittæfolium), the leaves of which are boiled and eaten in the West Indies.","pos":""}],"TANIST":[{"def":"In Ireland, a lord or proprietor of a tract of land or of a castle, elected by a family, under the system of tanistry.","pos":""}],"TANISTRY":[{"def":"In Ireland, a tenure of family lands by which the proprietor had only a life estate, to which he was admitted by election.","pos":""}],"TANITE":[{"def":"A firm composition of emery and a certain kind of cement, used for making grinding wheels, slabs, etc.","pos":""}],"TANK":[{"def":"A small Indian dry measure, averaging 240 grains in weight; also, a Bombay weight of 72 grains, for pearls.","pos":""}],"TANKA":[{"def":"A kind of boat used in Canton.","pos":""}],"TANKAGE":[{"def":"The act or process of putting or storing in tanks.","pos":""},{"def":"Fees charged for storage in tanks.","pos":""}],"TANKARD":[{"def":"A large drinking vessel, especially one with a cover.","pos":""}],"TANKLING":[{"def":"A vessel fitted with tanks for the carrying of oil or other liquid in bulk.","pos":""}],"TANLING":[{"def":"One tanned by the sun.","pos":""}],"TANNABLE":[{"def":"That may be tanned.","pos":""}],"TANNAGE":[{"def":"A tanning; the act, operation, or result of tanning.","pos":""}],"TANNATE":[{"def":"A salt of tannic acid.","pos":""}],"TANNER":[{"def":"One whose occupation is to tan hides, or convert them into leather by the use of tan.","pos":""}],"TANNERY":[{"def":"A place where the work of tanning is carried on.","pos":""},{"def":"The art or process of tanning.","pos":""}],"TANNIC":[{"def":"Of or pertaining to tan; derived from, or resembling, tan; as, tannic acid.","pos":""}],"TANNIGEN":[{"def":"A compound obtained as a yellowish gray powder by the action of acetyl chloride or acetic anhydride or ordinary tannic acid.","pos":""}],"TANNIN":[{"def":"Same as Tannic acid, under Tannic.","pos":""}],"TANNING":[{"def":"The art or process of converting skins into leather.","pos":""}],"TANSY":[{"def":"Any plant of the composite genus Tanacetum.","pos":""}],"TANT":[{"def":"A small scarlet arachnid.","pos":""}],"TANTALATE":[{"def":"A salt of tantalic acid.","pos":""}],"TANTALIC":[{"def":"Of or pertaining to tantalum; derived from, or containing, tantalum; specifically, designating any one of a series of acids analogous to nitric acid and the polyacid compounds of phosphorus.","pos":""}],"TANTALISM":[{"def":"A punishment like that of Tantalus; a teasing or tormenting by the hope or near approach of good which is not attainable; tantalization.","pos":""}],"TANTALITE":[{"def":"A heavy mineral of an iron-black color and submetallic luster.","pos":""}],"TANTALIZATION":[{"def":"The act of tantalizing, or state of being tantalized.","pos":""}],"TANTALIZE":[{"def":"To tease or torment by presenting some good to the view and exciting desire, but continually frustrating the expectations by keeping that good out of reach; to tease; to torment.","pos":""}],"TANTALIZER":[{"def":"One who tantalizes.","pos":""}],"TANTALIZINGLY":[{"def":"In a tantalizing or teasing manner.","pos":""}],"TANTALUM":[{"def":"A rare nonmetallic element found in certain minerals, as tantalite, samarskite, and fergusonite, and isolated as a dark powder which becomes steel-gray by burnishing.","pos":""}],"TANTALUS":[{"def":"A genus of wading birds comprising the wood ibises.","pos":""}],"TANTAMOUNT":[{"def":"Equivalent in value, signification, or effect.","pos":""}],"TANTIVY":[{"def":"Swiftly; speedily; rapidly; -- a fox-hunting term; as, to ride tantivy.","pos":""}],"TANTRA":[{"def":"A ceremonial treatise related to Puranic and magic literature; esp.","pos":""}],"TANTRISM":[{"def":"The system of doctrines and rites taught in the tantras.","pos":""}],"TANTRUM":[{"def":"A whim, or burst of ill-humor; an affected air.","pos":""}],"TANYARD":[{"def":"An inclosure where the tanning of leather is carried on; a tannery.","pos":""}],"TANYSTOMATA":[{"def":"A division of dipterous insects in which the proboscis is large and contains lancelike mandibles and maxillæ.","pos":""}]}