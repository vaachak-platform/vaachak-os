{"UNOBSERVANCE":[{"def":"Want or neglect of observance; inobservance.","pos":""}],"UNOBTRUSIVE":[{"def":"Not obtrusive; not presuming; modest.","pos":""}],"UNOIL":[{"def":"To remove the oil from.","pos":""}],"UNOPERATIVE":[{"def":"Producing no effect; inoperative.","pos":""}],"UNOPERCULATED":[{"def":"Destitute of an operculum, or cover.","pos":""}],"UNORDER":[{"def":"To countermand an order for.","pos":""}],"UNORDINATE":[{"def":"Disorderly; irregular; inordinate.","pos":""}],"UNORGANIZED":[{"def":"Not organized; being without organic structure; specifically (Biol.","pos":""}],"UNORIGINATED":[{"def":"Not originated; existing from all eternity.","pos":""},{"def":"Not yet caused to be, or to be made; as, possible inventions still unoriginated.","pos":""}],"UNORIGINATELY":[{"def":"Un`o*rig\"i*nate*ly, adv.","pos":""}],"UNOSSIFIED":[{"def":"Destitute of a bony structure.","pos":""}],"UNOWED":[{"def":"Not owed; as, to pay money unowed.","pos":""}],"UNOWNED":[{"def":"Not owned; having no owner.","pos":""},{"def":"Not acknowledged; not avowed.","pos":""}]}