{"KEA":[{"def":"A large New Zealand parrot (Nestor notabilis), notorious for having acquired the habit of killing sheep; -- called also mountain parrot.","pos":""}],"KECK":[{"def":"To heave or to retch, as in an effort to vomit.","pos":""}],"KECKLE":[{"def":"To wind old rope around, as a cable, to preserve its surface from being fretted, or to wind iron chains around, to defend from the friction of a rocky bottom, or from the ice.","pos":""}],"KECKLING":[{"def":"Old rope or iron chains wound around a cable.","pos":""}],"KECKLISH":[{"def":"Inclined to vomit; squeamish.","pos":""}],"KECKSY":[{"def":"The hollow stalk of an umbelliferous plant, such as the cow parsnip or the hemlock.","pos":""}],"KECKY":[{"def":"Resembling a kecksy.","pos":""}],"KEDDAH":[{"def":"An inclosure constructed to entrap wild elephants; an elephant trap.","pos":""}],"KEDGE":[{"def":"To move (a vessel) by carrying out a kedge in a boat, dropping it overboard, and hauling the vessel up to it.","pos":""}],"KEDGER":[{"def":"A small anchor; a kedge.","pos":""}],"KEE":[{"def":"See Kie, Ky, and Kine.","pos":""}],"KEECH":[{"def":"A mass or lump of fat rolled up by the butcher.","pos":""}],"KEEL":[{"def":"To cool; to akin or stir [Obs.","pos":""}],"KEELAGE":[{"def":"The right of demanding a duty or toll for a ship entering a port; also, the duty or toll.","pos":""}],"KEELED":[{"def":"Keel-shaped; having a longitudinal prominence on the back; as, a keeled leaf.","pos":""},{"def":"Having a median ridge; carinate; as, a keeled scale.","pos":""}],"KEELER":[{"def":"One employed in managing a Newcastle keel; -- called also keelman.","pos":""},{"def":"A small or shallow tub; esp.","pos":""}],"KEELFAT":[{"def":"A cooler; a vat for cooling wort, etc.","pos":""}],"KEELHAUL":[{"def":"To haul under the keel of a ship, by ropes attached to the yardarms on each side.","pos":""}],"KEELIVINE":[{"def":"A pencil of black or red lead; -- called also keelyvine pen.","pos":""}],"KEELMAN":[{"def":"Defn: See Keeler, 1.","pos":""}],"KEELRAKE":[{"def":"Same as Keelhaul.","pos":""}],"KEELSON":[{"def":"A piece of timber in a ship laid on the middle of the floor timbers over the keel, and binding the floor timbers to the keel; in iron vessels, a structure of plates, situated like the keelson of a timber ship.","pos":""}],"KEEN":[{"def":"Sharp; having a fine edge or point; as, a keen razor, or a razor with a keen edge.","pos":""},{"def":"Acute of mind; sharp; penetrating; having or expressing mental acuteness; as, a man of keen understanding; a keen look; keen features.","pos":""}],"KEENER":[{"def":"A professional mourner who wails at a funeral.","pos":""}],"KEENLY":[{"def":"In a keen manner.","pos":""}],"KEENNESS":[{"def":"The quality or state of being keen.","pos":""}],"KEEP":[{"def":"To care; to desire.","pos":""},{"def":"To hold; to restrain from departure or removal; not to let go of; to retain in one's power or possession; not to lose; to retain; to detain.","pos":""}],"KEEPER":[{"def":"One who, or that which, keeps; one who, or that which, holds or has possession of anything.","pos":""},{"def":"One who retains in custody; one who has the care of a prison and the charge of prisoners.","pos":""}],"KEEPERSHIP":[{"def":"The office or position of a keeper.","pos":""}],"KEEPING":[{"def":"Harmony or correspondence between the different parts of a work of art; as, the foreground of this painting is not in keeping.","pos":""}],"KEEPSAKE":[{"def":"Anything kept, or given to be kept, for the sake of the giver; a token of friendship.","pos":""}],"KEEVE":[{"def":"A vat or tub in which the mash is made; a mash tub.","pos":""},{"def":"A bleaching vat; a kier.","pos":""}],"KEFIR":[{"def":"An effervescent liquor like kumiss, made from fermented milk, used as a food and as a medicine in the northern Caucasus.","pos":""}],"KEFIR GRAINS":[{"def":"Small hard yellowish aggregations found in the Caucasus region, and containing various yeasts and bacteria.","pos":""}],"KEG":[{"def":"A small cask or barrel.","pos":""}],"KEILHAUITE":[{"def":"A mineral of a brownish black color, related to titanite in form.","pos":""}],"KEITLOA":[{"def":"A black, two-horned, African rhinoceros (Atelodus keitloa).","pos":""}],"KELD":[{"def":"Having a kell or covering; webbed.","pos":""}],"KELL":[{"def":"A sort of pottage; kale.","pos":""}],"KELOID":[{"def":"Applied to a variety of tumor forming hard, flat, irregular excrescences upon the skin.","pos":""}],"KELP":[{"def":"Any large blackish seaweed.","pos":""}],"KELPFISH":[{"def":"A small California food fish (Heterostichus rostratus), living among kelp.","pos":""},{"def":"An imaginary spirit of the waters, horselike in form, vulgarly believed to warn, by preternatural noises and lights, those who are to be drowned.","pos":""}],"KELPWARE":[{"def":"Same as Kelp, 2.","pos":""}],"KELT":[{"def":"Cloth with the nap, generally of native black wool.","pos":""}],"KELTER":[{"def":"Regular order or proper condition.","pos":""}],"KELTIC":[{"def":"Same as Celtic, a.","pos":""}],"KEMB":[{"def":"His longe hair was kembed behind his back.","pos":""}],"KEMELIN":[{"def":"A tub; a brewer's vessel.","pos":""},{"def":"Coarse, rough hair wool or fur, injuring its quality.","pos":""}],"KEMPS":[{"def":"The long flower stems of the ribwort plantain (Plantago Lanceolata).","pos":""}],"KEN":[{"def":"To know; to understand; to take cognizance of.","pos":""},{"def":"To recognize; to descry; to discern.","pos":""}],"KENNEL":[{"def":"The water course of a street; a little canal or channel; a gutter; also, a puddle.","pos":""}],"KENNEL COAL":[{"def":"Ken\"nel coal` Defn: .","pos":""}],"KENNING":[{"def":"The limit of vision at sea, being a distance of about twenty miles.","pos":""}],"KENO":[{"def":"A gambling game, a variety of the game of lotto, played with balls or knobs, numbered, and cards also numbered.","pos":""}],"KENOGENESIS":[{"def":"Modified evolution, in which nonprimitive characters make their appearance in consequence of a secondary adaptation of the embryo to the peculiar conditions of its environment; -- distinguished from palingenesis.","pos":""}],"KENOGENETIC":[{"def":"Of or pertaining to kenogenesis; as, kenogenetic processes.","pos":""}],"KENSPECKLE":[{"def":"Having so marked an appearance as easily to be recognized.","pos":""}],"KENT BUGLE":[{"def":"A curved bugle, having six finger keys or stops, by means of which the performer can play upon every key in the musical scale; -- called also keyed bugle, and key bugle.","pos":""}],"KENTLE":[{"def":"A hundred weight; a quintal.","pos":""}],"KENTLEDGE":[{"def":"Pigs of iron used for ballast.","pos":""}],"KENTUCKY":[{"def":"One of the United States.","pos":""}],"KEPHALIN":[{"def":"One of a group of nitrogenous phosphorized principles, supposed by Thudichum to exist in brain tissue.","pos":""}],"KEPI":[{"def":"A military cap having a close-fitting band, a round flat top sloping toward the front, and a visor.","pos":""}],"KEPVISELOHAZ":[{"def":"See Legislature.","pos":""}],"KERAMIC":[{"def":"Same as Ceramic.","pos":""}],"KERAMICS":[{"def":"Same as Ceramics.","pos":""}],"KERAMOGRAPHIC":[{"def":"Suitable to be written upon; capable of being written upon, as a slate; -- said especially of a certain kind of globe.","pos":""}],"KERANA":[{"def":"A kind of long trumpet, used among the Persians.","pos":""}],"KERARGYRITE":[{"def":"See Cerargyrite.","pos":""}],"KERASIN":[{"def":"A nitrogenous substance free from phosphorus, supposed to be present in the brain; a body closely related to cerebrin.","pos":""}],"KERASINE":[{"def":"Resembling horn; horny; corneous.","pos":""}],"KERATIN":[{"def":"A nitrogenous substance, or mixture of substances, containing sulphur in a loose state of combination, and forming the chemical basis of epidermal tissues, such as horn, hair, feathers, and the like.","pos":""}],"KERATITIS":[{"def":"Inflammation of the cornea.","pos":""}],"KERATOGENOUS":[{"def":"Producing horn; as, the keratogenous membrane within the horny hoof of the horse.","pos":""}],"KERATOIDEA":[{"def":"Same as Keratosa.","pos":""}],"KERATOME":[{"def":"An instrument for dividing the cornea in operations for cataract.","pos":""}],"KERATONYXIS":[{"def":"The operation of removing a cataract by thrusting a needle through the cornea of the eye, and breaking up the opaque mass.","pos":""}],"KERATOPHYTE":[{"def":"A gorgonian coral having a horny axis.","pos":""}],"KERATOSA":[{"def":"An order of sponges having a skeleton composed of hornlike fibers.","pos":""}],"KERATOSE":[{"def":"A tough, horny animal substance entering into the composition of the skeleton of sponges, and other invertebrates; -- called also keratode.","pos":""}],"KERAUNOGRAPH":[{"def":"A figure or picture impressed by lightning upon the human body or elsewhere.","pos":""}],"KERCHERED":[{"def":"Covered, or bound round, with a kercher.","pos":""}],"KERCHIEF":[{"def":"Dressed; hooded; covered; wearing a kerchief.","pos":""}],"KERF":[{"def":"A notch, channel, or slit made in any material by cutting or sawing.","pos":""}],"KERITE":[{"def":"A compound in which tar or asphaltum combined with animal or vegetable oils is vulcanized by sulphur, the product closely resembling rubber; -- used principally as an insulating material in telegraphy.","pos":""}],"KERMES":[{"def":"The dried bodies of the females of a scale insect (Coccus ilicis), allied to the cochineal insect, and found on several species of oak near the Mediterranean.","pos":""},{"def":"A small European evergreen oak (Quercus coccifera) on which the kermes insect (Coccus ilicis) feeds.","pos":""}],"KERN":[{"def":"An idler; a vagabond.","pos":""}],"KERN BABY":[{"def":"A doll or image decorated with corn (grain) flowers, etc.","pos":""}],"KERNED":[{"def":"Having part of the face projecting beyond the body or shank; -- said of type.","pos":""}],"KERNEL":[{"def":"The essential part of a seed; all that is within the seed walls; the edible substance contained in the shell of a nut; hence, anything included in a shell, husk, or integument; as, the kernel of a nut.","pos":""},{"def":"A single seed or grain; as, a kernel of corn.","pos":""}],"KERNELLY":[{"def":"Full of kernels; resembling kernels; of the nature of kernels.","pos":""}],"KERNISH":[{"def":"Clownish; booorish.","pos":""}],"KEROLITE":[{"def":"Same as Cerolite.","pos":""}],"KEROSENE":[{"def":"An oil used for illuminating purposes, formerly obtained from the distillation of mineral wax, bituminous shale, etc.","pos":""}],"KERSEY":[{"def":"A kind of coarse, woolen cloth, usually ribbed, woven from wool of long staple.","pos":""}],"KERSEYS":[{"def":"Varieties of kersey; also, trousers made of kersey.","pos":""}],"KESAR":[{"def":"See Kaiser [Obs.","pos":""}],"KESLOP":[{"def":"The stomach of a calf, prepared for rennet.","pos":""}],"KESTREL":[{"def":"A small, slender European hawk (Falco alaudarius), allied to the sparrow hawk.","pos":""}],"KET":[{"def":"Carrion; any filth.","pos":""}],"KETA":[{"def":"A small salmon (Oncorhynchus keta) of inferior value, which in the autumn runs up all the larger rivers between San Francisco and Kamchatka.","pos":""}],"KETCH":[{"def":"An almost obsolete form of vessel, with a mainmast and a mizzenmast, -- usually from one hundred to two hundred and fifty tons burden.","pos":""}],"KETINE":[{"def":"One of a series of organic bases obtained by the reduction of certain isonitroso compounds of the ketones.","pos":""}],"KETMIE":[{"def":"The name of certain African species of Hibiscus, cultivated for the acid of their mucilage.","pos":""}],"KETOL":[{"def":"One of a series of series of complex nitrogenous substances, represented by methyl ketol and related to indol.","pos":""}],"KETONE":[{"def":"One of a large class of organic substances resembling the aldehydes, obtained by the distillation of certain salts of organic acids and consisting of carbonyl (CO) united with two hydrocarbon radicals.","pos":""}],"KETONIC":[{"def":"Pertaining to, or derived from, a ketone; as, a ketonic acid.","pos":""}],"KETTLE":[{"def":"A metallic vessel, with a wide mouth, often without a cover, used for heating and boiling water or other liguids.","pos":""}],"KETTLEDRUM":[{"def":"A drum made of thin copper in the form of a hemispherical kettle, with parchment stretched over the mouth of it.","pos":""}],"KETTLEDRUMMER":[{"def":"One who plays on a kettledrum.","pos":""}],"KEUPER":[{"def":"The upper division of the European Triassic.","pos":""}],"KEVEL":[{"def":"A strong cleat to which large ropes are belayed.","pos":""}],"KEX":[{"def":"A weed; a kecksy.","pos":""}],"KEY":[{"def":"An indehiscent, one-seeded fruit furnished with a wing, as the fruit of the ash and maple; a samara; -- called also key fruit.","pos":""}],"KEY-COLD":[{"def":"Cold as a metallic key; lifeless.","pos":""}],"KEYAGE":[{"def":"Wharfage; quayage.","pos":""}],"KEYBOARD":[{"def":"The whole arrangement, or one range, of the keys of an organ, typewriter, etc.","pos":""}],"KEYED":[{"def":"Furnished with keys; as, a keyed instrument; also, set to a key, as a tune.","pos":""}],"KEYHOLE":[{"def":"A hole or apertupe in a door or lock, for receiving a key.","pos":""}],"KEYNOTE":[{"def":"The tonic or first tone of the scale in which a piece or passage is written; the fundamental tone of the chord, to which all the modulations of the piece are referred; -- called also key tone.","pos":""}],"KEYSEAT":[{"def":"To form a key seat, as by cutting.","pos":""}],"KEYSTONE":[{"def":"The central or topmost stone of an arch.","pos":""}],"KEYSTONE STATE":[{"def":"Pennsylvania; -- a nickname alluding to its having been the central one of the 13 original United States.","pos":""}],"KEYWAY":[{"def":"See Key way, under Key.","pos":""}]}