{"CHIN":[{"def":"The exterior or under surface embraced between the branches of the lower jaw bone, in birds.","pos":""}],"CHINA":[{"def":"A country in Eastern Asia.","pos":""},{"def":"China ware, which is the modern popular term for porcelain.","pos":""}],"CHINAMAN":[{"def":"A native of China; a Chinese.","pos":""}],"CHINCH":[{"def":"The bedbug (Cimex lectularius).","pos":""},{"def":"A bug (Blissus leucopterus), which, in the United States, is very destructive to grass, wheat, and other grains; -- also called chiniz, chinch bug, chink bug.","pos":""}],"CHINCHA":[{"def":"A south American rodent of the genus Lagotis.","pos":""}],"CHINCHE":[{"def":"Parsimonious; niggardly.","pos":""}],"CHINCHERIE":[{"def":"By cause of his skarsete and chincherie.","pos":""}],"CHINCHILLA":[{"def":"A small rodent (Chinchilla lanigera), of the size of a large squirrel, remarkable for its fine fur, which is very soft and of a pearly gray color.","pos":""}],"CHINE":[{"def":"A chink or cleft; a narrow and deep ravine; as, Shanklin Chine in the Isle of Wight, a quarter of a mile long and 230 feet deep.","pos":""}],"CHINED":[{"def":"Pertaining to, or having, a chine, or backbone; -- used in composition.","pos":""},{"def":"Broken in the back.","pos":""}],"CHINESE":[{"def":"Of or pertaining to China; peculiar to China.","pos":""}],"CHINESE EXCLUSION ACT":[{"def":"Any of several acts forbidding the immigration of Chinese laborers into the United States, originally from 1882 to 1892 by act of May 6, 1882, then from 1892 to 1902 by act May 5, 1892.","pos":""}],"CHINK":[{"def":"A small cleft, rent, or fissure, of greater length than breadth; a gap or crack; as, the chinks of wall.","pos":""}],"CHINKY":[{"def":"Full of chinks or fissures; gaping; opening in narrow clefts.","pos":""}],"CHINNED":[{"def":"Having a chin; -- used chiefly in compounds; as, short-chinned.","pos":""}],"CHINOIDINE":[{"def":"Peruvian bark) + --oil + -ine.","pos":""}],"CHINOISERIE":[{"def":"Chinese conduct, art, decoration, or the like; also, a specimen of Chinese manners, art, decoration, etc.","pos":""}],"CHINOOK":[{"def":"One of a tribe of North American Indians now living in the state of Washington, noted for the custom of flattening their skulls.","pos":""}],"CHINOOK STATE":[{"def":"Washington -- a nickname.","pos":""}],"CHINQUAPIN":[{"def":"A branching, nut-bearing tree or shrub (Castanea pumila) of North America, from six to twenty feet high, allied to the chestnut.","pos":""}],"CHINSE":[{"def":"To thrust oakum into (seams or chinks) with a chisel , the point of a knife, or a chinsing iron; to calk slightly.","pos":""}],"CHINTZ":[{"def":"Cotton cloth, printed with flowers and other devices, in a number of different colors, and often glazed.","pos":""}]}