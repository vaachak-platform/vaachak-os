{"OVERBALANCE":[{"def":"To exceed equality with; to outweigh.","pos":""},{"def":"To cause to lose balance or equilibrium.","pos":""}],"OVERBARREN":[{"def":"Excessively barren.","pos":""}],"OVERBATTLE":[{"def":"Excessively fertile; bearing rank or noxious growths.","pos":""}],"OVERBEAR":[{"def":"To bear down or carry down, as by excess of weight, power, force, etc.","pos":""},{"def":"To domineer over; to overcome by insolence.","pos":""}],"OVERBEARING":[{"def":"Overpowering; subduing; repressing.","pos":""},{"def":"Aggressively haughty; arrogant; domineering; tyrannical; dictatorial; insolent.","pos":""}],"OVERBEND":[{"def":"To bend to excess.","pos":""}],"OVERBID":[{"def":"To bid or offer beyond, or in excess of.","pos":""}],"OVERBLOW":[{"def":"To force so much wind into a pipe that it produces an overtone, or a note higher than the natural note; thus, the upper octaves of a flute are produced by overblowing.","pos":""}],"OVERBOARD":[{"def":"Over the side of a ship; hence, from on board of a ship, into the water; as, to fall overboard.","pos":""}],"OVERBOIL":[{"def":"To boil over or unduly.","pos":""}],"OVERBOLD":[{"def":"Excessively or presumptuously bold; impudent.","pos":""}],"OVERBOOKISH":[{"def":"Excessively bookish.","pos":""}],"OVERBOUNTEOUS":[{"def":"Bounteous to excess.","pos":""}],"OVERBOW":[{"def":"To bend or bow over; to bend in a contrary direction.","pos":""}],"OVERBREED":[{"def":"To breed to excess.","pos":""}],"OVERBRIM":[{"def":"To flow over the brim; to be so full as to overflow.","pos":""}],"OVERBROW":[{"def":"To hang over like a brow; to impend over.","pos":""}],"OVERBUILD":[{"def":"To build too much; to build beyond the demand.","pos":""}],"OVERBUILT":[{"def":"Having too many buildings; as, an overbuilt part of a town.","pos":""}],"OVERBULK":[{"def":"To oppress by bulk; to overtower.","pos":""}],"OVERBURDEN":[{"def":"To load with too great weight or too much care, etc.","pos":""}],"OVERBURDENSOME":[{"def":"O\"ver*bur\"den*some, a.","pos":""}],"OVERBURN":[{"def":"To burn too much; to be overzealous.","pos":""}],"OVERBUY":[{"def":"To buy too much.","pos":""},{"def":"To buy at too dear a rate.","pos":""}]}