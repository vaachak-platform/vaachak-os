{"RAW":[{"def":"Not altered from its natural state; not prepared by the action of heat; as, raw sienna; specifically, not cooked; not changed by heat to a state suitable for eating; not done; as, raw meat.","pos":""},{"def":"Hence: Unprepared for use or enjoyment; immature; unripe; unseasoned; inexperienced; unpracticed; untried; as, raw soldiers; a raw recruit.","pos":""}],"RAWBONED":[{"def":"Having little flesh on the bones; gaunt.","pos":""}],"RAWHEAD":[{"def":"A specter mentioned to frighten children; as, rawhead and bloodybones.","pos":""}],"RAWHIDE":[{"def":"A cowhide, or coarse riding whip, made of untanned (or raw) hide twisted.","pos":""}],"RAWLY":[{"def":"In a raw manner; unskillfully; without experience.","pos":""},{"def":"Without proper preparation or provision.","pos":""}],"RAWNESS":[{"def":"The quality or state of being raw.","pos":""}]}