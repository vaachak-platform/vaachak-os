{"SWOBBER":[{"def":"Four privileged cards, formerly used in betting at the game of whist.","pos":""}],"SWOLLEN":[{"def":"Enlarged by swelling; immoderately increased; as, swollen eyes; swollen streams.","pos":""}],"SWOLN":[{"def":"Contraction of Swollen, p.","pos":""}],"SWOON":[{"def":"To sink into a fainting fit, in which there is an apparent suspension of the vital functions and mental powers; to faint; -- often with away.","pos":""}],"SWOOP":[{"def":"To fall on at once and seize; to catch while on the wing; as, a hawk swoops a chicken.","pos":""},{"def":"To seize; to catch up; to take with a sweep.","pos":""}],"SWOOPSTAKE":[{"def":"Altogether; indiscriminately.","pos":""}],"SWORD":[{"def":"One of the end bars by which the lay of a hand loom is suspended.","pos":""}],"SWORD-SHAPED":[{"def":"Shaped like a sword; ensiform, as the long, flat leaves of the Iris, cattail, and the like.","pos":""}],"SWORDBILL":[{"def":"A humming bird (Docimastes ensiferus) having a very long, slender bill, exceeding the length of the body of the bird.","pos":""}],"SWORDED":[{"def":"Girded with a sword.","pos":""}],"SWORDER":[{"def":"One who uses, or fights with, a sword; a swordsman; a soldier; a cutthroat.","pos":""}],"SWORDFISH":[{"def":"A southern constellation.","pos":""}],"SWORDICK":[{"def":"The spotted gunnel (Murænoides gunnellus).","pos":""}],"SWORDING":[{"def":"Slashing with a sword.","pos":""}],"SWORDLESS":[{"def":"Destitute of a sword.","pos":""}],"SWORDPLAY":[{"def":"Fencing; a sword fight.","pos":""}],"SWORDPLAYER":[{"def":"A fencer; a gladiator; one who exhibits his skill in the use of the sword.","pos":""}],"SWORDSMAN":[{"def":"A soldier; a fighting man.","pos":""},{"def":"One skilled of a use of the sword; a professor of the science of fencing; a fencer.","pos":""}],"SWORDSMANSHIP":[{"def":"The state of being a swordsman; skill in the use of the sword.","pos":""}],"SWOUGH":[{"def":"A sound; a groan; a moan; a sough.","pos":""}],"SWOUND":[{"def":"An exclamation contracted from God's wounds; -- used as an oath.","pos":""}]}