{"PARGASITE":[{"def":"A dark green aluminous variety of amphibole, or hornblende.","pos":""}],"PARGET":[{"def":"To coat with parget; to plaster, as walls, or the interior of flues; as, to parget the outside of their houses.","pos":""},{"def":"To paint; to cover over.","pos":""}],"PARGETING":[{"def":"Plasterwork; esp.","pos":""}],"PARGETORY":[{"def":"Something made of, or covered with, parget, or plaster.","pos":""}]}