{"COUNCIL":[{"def":"An assembly of men summoned or convened for consultation, deliberation, or advice; as, a council of physicians for consultation in a critical case.","pos":""},{"def":"A body of man elected or appointed to constitute an advisory or a legislative assembly; as, a governor's council; a city council.","pos":""}],"COUNCILIST":[{"def":"One who belong to a council; one who gives an opinion.","pos":""}],"COUNCILMAN":[{"def":"A member of a council, especially of the common council of a city; a councilor.","pos":""}],"COUNCILOR":[{"def":"A member of a council.","pos":""}]}