{"SIEGE":[{"def":"A seat; especially, a royal seat; a throne.","pos":""},{"def":"Hence, place or situation; seat.","pos":""}],"SIEGEWORK":[{"def":"A temporary fort or parallel where siege guns are mounted.","pos":""}],"SIEMENS-MARTIN PROCESS":[{"def":"See Open-hearth process, etc.","pos":""}],"SIEMENS-MARTIN STEEL":[{"def":"See Open-hearth steel, under Open.","pos":""}],"SIENNA":[{"def":"Clay that is colored red or brown by the oxides of iron or manganese, and used as a pigment.","pos":""}],"SIENNESE":[{"def":"Of or pertaining to Sienna, a city of Italy.","pos":""}],"SIERRA":[{"def":"A ridge of mountain and craggy rocks, with a serrated or irregular outline; as, the Sierra Nevada.","pos":""}],"SIESTA":[{"def":"A short sleep taken about the middle of the day, or after dinner; a midday nap.","pos":""}],"SIEUR":[{"def":"Sir; -- a title of respect used by the French.","pos":""}],"SIEVA":[{"def":"A small variety of the Lima bean (Phaseolus lunatus).","pos":""}],"SIEVE":[{"def":"A utensil for separating the finer and coarser parts of a pulverized or granulated substance from each other.","pos":""},{"def":"A kind of coarse basket.","pos":""}]}