{"CANOE":[{"def":"A boat used by rude nations, formed of trunk of a tree, excavated, by cutting of burning, into a suitable shape.","pos":""},{"def":"A boat made of bark or skins, used by savages.","pos":""}],"CANOEING":[{"def":"The act or art of using a canoe.","pos":""}],"CANOEMAN":[{"def":"One who uses a canoe; one who travels in a canoe.","pos":""}],"CANON":[{"def":"A law, or rule of doctrine or discipline, enacted by a council and confirmed by the pope or the sovereign; a decision, regulation, code, or constitution made by ecclesiastical authority.","pos":""},{"def":"A musical composition in which the voice begin one after another, at regular intervals, succesively taking up the same subject.","pos":""}],"CANON BIT":[{"def":"That part of a bit which is put in a horse's mouth.","pos":""}],"CANON BONE":[{"def":"The shank bone, or great bone above the fetlock, in the fore and hind legs of the horse and allied animals, corresponding to the middle metacarpal or metatarsal bone of most mammals.","pos":""}],"CANONESS":[{"def":"A woman who holds a canonry in a conventual chapter.","pos":""},{"def":"Of or pertaining to a canon; established by, or according to a , canon or canons.","pos":""}],"CANONICALLY":[{"def":"; according to the canons.","pos":""}],"CANONICALNESS":[{"def":"The quality of being canonical; canonicity.","pos":""}],"CANONICALS":[{"def":"The dress prescribed by canon to be worn by a clergyman when oficiating.","pos":""}],"CANONICATE":[{"def":"The office of a canon; a canonry.","pos":""}],"CANONICITY":[{"def":"The state or quality of being canonical; agreement with the canon.","pos":""}],"CANONIST":[{"def":"A professor of canon law; one skilled in the knowledge and practice of ecclesiastical law.","pos":""}],"CANONISTIC":[{"def":"Of or pertaining to a canonist.","pos":""}],"CANONIZATION":[{"def":"The final process or decree (following beatifacation) by which the name of a deceased person is placed in the catalogue (canon) of saints and commended to perpetual veneration and invocation.","pos":""}],"CANONIZE":[{"def":"To declare (a deceased person) a saint; to put in the catalogue of saints; as, Thomas a Becket was canonized.","pos":""}],"CANONRY":[{"def":"A benefice or prebend in a cathedral or collegiate church; a right to a place in chapter and to a portion of its revenues; the dignity or emoluments of a canon.","pos":""}],"CANONSHIP":[{"def":"Of pertaining to Canopus in egypt; as, the Canopic vases, used in embalming.","pos":""}],"CANOPUS":[{"def":"A star of the first magnitude in the southern constellation Argo.","pos":""}],"CANOPY":[{"def":"A covering fixed over a bed, dais, or the like, or carried on poles over an exalted personage or a sacred object, etc.","pos":""}],"CANOROUS":[{"def":"Melodious; musical.","pos":""}],"CANOROUSNESS":[{"def":"The quality of being musical.","pos":""}]}