{"PHRAGMOCONE":[{"def":"The thin chambered shell attached to the anterior end of a belemnite.","pos":""}],"PHRAGMOSIPHON":[{"def":"The siphon of a phragmocone.","pos":""}],"PHRASAL":[{"def":"Of the nature of a phrase; consisting of a phrase; as, a phrasal adverb.","pos":""}],"PHRASE":[{"def":"A short clause or portion of a period.","pos":""}],"PHRASEOGRAM":[{"def":"A symbol for a phrase.","pos":""},{"def":"Of or pertaining to phraseology; consisting of a peculiar form of words.","pos":""}],"PHRASEOLOGIST":[{"def":"A collector or coiner of phrases.","pos":""}],"PHRASEOLOGY":[{"def":"Manner of expression; peculiarity of diction; style.","pos":""},{"def":"A collection of phrases; a phrase book.","pos":""}],"PHRASING":[{"def":"The act or method of grouping the notes so as to form distinct musical phrases.","pos":""}],"PHRATRY":[{"def":"A subdivision of a phyle, or tribe, in Athens.","pos":""}],"PHREATIC":[{"def":"Subterranean; -- applied to sources supplying wells.","pos":""},{"def":"Relating to phrenitis; suffering from frenzy; delirious; mad; frantic; frenetic.","pos":""}],"PHRENETIC":[{"def":"One who is phrenetic.","pos":""}],"PHRENIC":[{"def":"Of or pertaining to the diaphragm; diaphragmatic; as, the phrenic nerve.","pos":""}],"PHRENICS":[{"def":"That branch of science which relates to the mind; mental philosophy.","pos":""}],"PHRENISM":[{"def":"See Vital force, under Vital.","pos":""}],"PHRENITIS":[{"def":"Inflammation of the brain, or of the meninges of the brain, attended with acute fever and delirium; -- called also cephalitis.","pos":""}],"PHRENOGRAPH":[{"def":"An instrument for registering the movements of the diaphragm, or midriff, in respiration.","pos":""}],"PHRENOLOGICAL":[{"def":"Of or pertaining to phrenology.","pos":""}],"PHRENOLOGIST":[{"def":"One versed in phrenology; a craniologist.","pos":""}],"PHRENOLOGY":[{"def":"The science of the special functions of the several parts of the brain, or of the supposed connection between the various faculties of the mind and particular organs in the brain.","pos":""},{"def":"In popular usage, the physiological hypothesis of Gall, that the mental faculties, and traits of character, are shown on the surface of the head or skull; craniology.","pos":""}],"PHRENOMAGNETISM":[{"def":"The power of exciting the organs of the brain by magnetic or mesmeric influence.","pos":""}],"PHRENOSIN":[{"def":"A nitrogenous body, related to cerebrin, supposed to exist in the brain.","pos":""}],"PHRENSY":[{"def":"Violent and irrational excitement; delirium.","pos":""}],"PHRYGANEID":[{"def":"Any insect belonging to the Phryganeides.","pos":""}],"PHRYGANEIDES":[{"def":"A tribe of neuropterous insects which includes the caddice flies; -- called also Trichoptera.","pos":""}],"PHRYGIAN":[{"def":"Of or pertaining to Phrygia, or to its inhabitants.","pos":""}],"PHRYGIAN CAP":[{"def":"A close-fitting cap represented in Greek art as worn by Orientals, assumed to have been conical in shape.","pos":""}]}