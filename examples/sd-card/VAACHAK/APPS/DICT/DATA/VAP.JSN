{"VAP":[{"def":"That which is vapid, insipid, or lifeless; especially, the lifeless part of liquor or wine.","pos":""}],"VAPID":[{"def":"Having lost its life and spirit; dead; spiritless; insipid; flat; dull; unanimated; as, vapid beer; a vapid speech; a vapid state of the blood.","pos":""}],"VAPIDITY":[{"def":"The quality or state of being vapid; vapidness.","pos":""}],"VAPOR":[{"def":"Any substance in the gaseous, or aëriform, state, the condition of which is ordinarily that of a liquid or solid.","pos":""},{"def":"An old name for hypochondria, or melancholy; the blues.","pos":""}],"VAPOR GALVANIZING":[{"def":"A process for coating metal (usually iron or steel) surfaces with zinc by exposing them to the vapor of zinc instead of, as in ordinary galvanizing, to molten zinc; -- called also Sherardizing.","pos":""}],"VAPORABILITY":[{"def":"The quality or state of being vaporable.","pos":""}],"VAPORABLE":[{"def":"Capable of being converted into vapor by the agency of heat; vaporizable.","pos":""}],"VAPORATE":[{"def":"To emit vapor; to evaporate.","pos":""}],"VAPORATION":[{"def":"The act or process of converting into vapor, or of passing off in vapor; evaporation.","pos":""}],"VAPORED":[{"def":"Wet with vapors; moist.","pos":""},{"def":"Affected with the vapors.","pos":""}],"VAPORER":[{"def":"One who vapors; a braggart.","pos":""}],"VAPORIFEROUS":[{"def":"Conveying or producing vapor.","pos":""}],"VAPORIFIC":[{"def":"Producing vapor; tending to pass, or to cause to pass, into vapor; thus, volatile fluids are vaporific; heat is a vaporific agent.","pos":""}],"VAPORIFORM":[{"def":"Existing in a vaporous form or state; as, steam is a vaporiform substance.","pos":""}],"VAPORIMETER":[{"def":"An instrument for measuring the volume or the tension of any vapor; specifically, an instrument of this sort used as an alcoholometer in testing spirituous liquors.","pos":""}],"VAPORING":[{"def":"Talking idly; boasting; vaunting.","pos":""}],"VAPORISH":[{"def":"Full of vapors; vaporous.","pos":""},{"def":"Hypochondriacal; affected by hysterics; splenetic; peevish; humorsome.","pos":""}],"VAPORIZABLE":[{"def":"Capable of being vaporized into vapor.","pos":""}],"VAPORIZATION":[{"def":"The act or process of vaporizing, or the state of being converted into vapor; the artificial formation of vapor; specifically, the conversion of water into steam, as in a steam boiler.","pos":""}],"VAPORIZE":[{"def":"To convert into vapor, as by the application of heat, whether naturally or artificially.","pos":""}],"VAPORIZER":[{"def":"One who, or that which, vaporizes, or converts into vapor.","pos":""}],"VAPOROSE":[{"def":"Full of vapor; vaporous.","pos":""}],"VAPOROUS":[{"def":"Having the form or nature of vapor.","pos":""},{"def":"Full of vapors or exhalations.","pos":""}],"VAPOROUSNESS":[{"def":"The quality of being vaporous.","pos":""},{"def":"The pressure or tension of a confined body of vapor.","pos":""}],"VAPORY":[{"def":"Full of vapors; vaporous.","pos":""},{"def":"Hypochondriacal; splenetic; peevish.","pos":""}],"VAPULATION":[{"def":"The act of beating or whipping.","pos":""}]}