{"LOG":[{"def":"A Hebrew measure of liquids, containing 2.","pos":""}],"LOG-CHIP":[{"def":"A thin, flat piece of board in the form of a quadrant of a circle attached to the log line; -- called also log-ship.","pos":""}],"LOG-SHIP":[{"def":"A part of the log.","pos":""}],"LOGAN":[{"def":"A rocking or balanced stone.","pos":""}],"LOGAOEDIC":[{"def":"Composed of dactyls and trochees so arranged as to produce a movement like that of ordinary speech.","pos":""}],"LOGARITHM":[{"def":"One of a class of auxiliary numbers, devised by John Napier, of Merchiston, Scotland (1550-1617), to abridge arithmetical calculations, by the use of addition and subtraction in place of multiplication and division.","pos":""},{"def":"See Logarithmic.","pos":""}],"LOGARITHMETICALLY":[{"def":"Logarithmically.","pos":""},{"def":"Of or pertaining to logarithms; consisting of logarithms.","pos":""}],"LOGARITHMICALLY":[{"def":"By the use of logarithms.","pos":""}],"LOGCOCK":[{"def":"The pileated woodpecker.","pos":""}],"LOGE":[{"def":"A lodge; a habitation.","pos":""}],"LOGGAT":[{"def":"An old game in England, played by throwing pieces of wood at a stake set in the ground.","pos":""}],"LOGGED":[{"def":"Made slow and heavy in movement; water-logged.","pos":""}],"LOGGER":[{"def":"One engaged in logging.","pos":""}],"LOGGERHEAD":[{"def":"An upright piece of round timber, in a whaleboat, over which a turn of the line is taken when it is running out too fast.","pos":""},{"def":"A very large marine turtle (Thalassochelys caretta, or caouana), common in the warmer parts of the Atlantic Ocean, from Brazil to Cape Cod; -- called also logger-headed turtle.","pos":""}],"LOGGERHEADED":[{"def":"A rabble of loggerheaded physicians.","pos":""}],"LOGGIA":[{"def":"A roofed open gallery.","pos":""}],"LOGGING":[{"def":"The business of felling trees, cutting them into logs, and transporting the logs to sawmills or to market.","pos":""}],"LOGIC":[{"def":"A treatise on logic; as, Mill's Logic.","pos":""}],"LOGICAL":[{"def":"Of or pertaining to logic; used in logic; as, logical subtilties.","pos":""},{"def":"According to the rules of logic; as, a logical argument or inference; the reasoning is logical.","pos":""}],"LOGICALLY":[{"def":"In a logical manner; as, to argue logically.","pos":""}],"LOGICALNESS":[{"def":"The quality of being logical.","pos":""}],"LOGICIAN":[{"def":"A person skilled in logic.","pos":""}],"LOGICS":[{"def":"Sexagesimal, or made on the scale of 60; as, logistic, or sexagesimal, arithmetic.","pos":""}],"LOGISTICS":[{"def":"That branch of the military art which embraces the details of moving and supplying armies.","pos":""},{"def":"A system of arithmetic, in which numbers are expressed in a scale of 60; logistic arithmetic.","pos":""}],"LOGMAN":[{"def":"A man who carries logs.","pos":""}],"LOGODAEDALY":[{"def":"Verbal legerdemain; a playing with words.","pos":""}],"LOGOGRAM":[{"def":"A word letter; a phonogram, that, for the sake of brevity, represents a word; as, |, i.","pos":""}],"LOGOGRAPHER":[{"def":"Of or pertaining to logography.","pos":""}],"LOGOGRAPHY":[{"def":"A method of printing in which whole words or syllables, cast as single types, are used.","pos":""},{"def":"A mode of reporting speeches without using shorthand, -- a number of reporters, each in succession, taking down three or four words.","pos":""}],"LOGOGRIPH":[{"def":"A sort of riddle in which it is required to discover a chosen word from various combinations of its letters, or of some of its letters, which form other words; -- thus, to discover the chosen word chatter form cat, hat, rat, hate, rate, etc.","pos":""}],"LOGOMACHIST":[{"def":"One who contends about words.","pos":""}],"LOGOMACHY":[{"def":"Contention in words merely, or a contention about words; a war of words.","pos":""},{"def":"A game of word making.","pos":""}],"LOGOMETRIC":[{"def":"Serving to measure or ascertain chemical equivalents; stoichiometric.","pos":""}],"LOGOS":[{"def":"A word; reason; speech.","pos":""},{"def":"The divine Word; Christ.","pos":""}],"LOGOTHETE":[{"def":"An accountant; under Constantine, an officer of the empire; a receiver of revenue; an administrator of a department.","pos":""}],"LOGOTYPE":[{"def":"A single type, containing two or more letters; as, æ, Æ, fi, fl, ffl, etc.","pos":""}],"LOGROLL":[{"def":"To engage in logrolling; to accomplish by logrolling.","pos":""}],"LOGROLLER":[{"def":"One who engages in logrolling.","pos":""}],"LOGROLLING":[{"def":"The act or process of rolling logs from the place where they were felled to the stream which floats them to the sawmill or to market.","pos":""}],"LOGWOOD":[{"def":"The heartwood of a tree (Hæmatoxylon Campechianum), a native of South America, It is a red, heavy wood, containing a crystalline substance called hæmatoxylin, and is used largely in dyeing.","pos":""},{"def":"A combining form denoting a discourse, treatise, doctrine, theory, science; as, theology, geology, biology, mineralogy.","pos":""}],"LOGY":[{"def":"Heavy or dull in respect to motion or thought; as, a logy horse.","pos":""}]}