{"GALL":[{"def":"The bitter, alkaline, viscid fluid found in the gall bladder, beneath the liver.","pos":"noun"}],"GALLANT":[{"def":"Showy; splendid; magnificent; gay; well-dressed.","pos":""},{"def":"Noble in bearing or spirit; brave; high-spirited; courageous; heroic; magnanimous; as, a gallant youth; a gallant officer.","pos":""}],"GALLANTLY":[{"def":"In a polite or courtly manner; like a gallant or wooer.","pos":""}],"GALLANTNESS":[{"def":"The quality of being gallant.","pos":""}],"GALLANTRY":[{"def":"Splendor of appearance; ostentatious finery.","pos":""},{"def":"Bravery; intrepidity; as, the troops behaved with great gallantry.","pos":""}],"GALLATE":[{"def":"A salt of gallic acid.","pos":""}],"GALLATURE":[{"def":"The tread, treadle, or chalasa of an egg.","pos":""}],"GALLEASS":[{"def":"A large galley, having some features of the galleon, as broadside guns; esp.","pos":""},{"def":"A native or inhabitant of Galicia, in Spain; a Galician.","pos":""}],"GALLEIN":[{"def":"A red crystalline dyestuff, obtained by heating together pyrogallic and phthalic acids.","pos":""}],"GALLEON":[{"def":"A sailing vessel of the 15th and following centuries, often having three or four decks, and used for war or commerce.","pos":""}],"GALLERY":[{"def":"A frame, like a balcony, projecting from the stern or quarter of a ship, and hence called stern galery or quarter gallry, -- seldom found in vessels built since 1850.","pos":""},{"def":"Any communication which is covered overhead as well as at the sides.","pos":""}],"GALLETYLE":[{"def":"A little tile of glazed earthenware.","pos":""}],"GALLEY":[{"def":"A vessel propelled by oars, whether having masts and sails or not; as: (a) A large vessel for war and national purposes; -- common in the Middle Ages, and down to the 17th century.","pos":""},{"def":"An oblong oven or muffle with a battery of retorts; a gallery furnace.","pos":""}],"GALLEY-BIRD":[{"def":"The European green woodpecker; also, the spotted woodpecker.","pos":""}],"GALLEY-WORM":[{"def":"A chilognath myriapod of the genus Iulus, and allied genera, having numerous short legs along the sides; a milliped or \"thousand legs.","pos":""}],"GALLFLY":[{"def":"An insect that deposits its eggs in plants, and occasions galls, esp.","pos":""}],"GALLIAMBIC":[{"def":"Consisting of two iambic dimeters catalectic, the last of which lacks the final syllable; -- said of a kind of verse.","pos":""}],"GALLIARD":[{"def":"Gay; brisk; active.","pos":""}],"GALLIARDISE":[{"def":"Excessive gayety; merriment.","pos":""}],"GALLIASS":[{"def":"Same as Galleass.","pos":""}],"GALLIC":[{"def":"Pertaining to, or containing, gallium.","pos":""}],"GALLICAN":[{"def":"Of or pertaining to Gaul or France; Gallic; French; as, the Gallican church or clergy.","pos":""}],"GALLICANISM":[{"def":"The principles, tendencies, or action of those, within the Roman Catholic Church in France, who (esp.","pos":""}],"GALLICISM":[{"def":"A mode of speech peculiar to the French; a French idiom; also, in general, a French mode or custom.","pos":""}],"GALLICIZE":[{"def":"To conform to the French mode or idiom.","pos":""}],"GALLIED":[{"def":"Worried; flurried; frightened.","pos":""}],"GALLIFORM":[{"def":"Like the Gallinae (or Galliformes) in structure.","pos":""}],"GALLIGASKINS":[{"def":"Loose hose or breeches; leather leg quards.","pos":""}],"GALLIMATIA":[{"def":"Gal`li*ma\"ti*a ( or ), n.","pos":""}],"GALLIMAUFRY":[{"def":"A hash of various kinds of meats, a ragout.","pos":""},{"def":"Any absurd medley; a hotchpotch.","pos":""}],"GALLIN":[{"def":"A substance obtained by the reduction of galleïn.","pos":""}],"GALLINACEAE":[{"def":"Same as Gallinae.","pos":""}],"GALLINACEAN":[{"def":"One of the Gallinae or gallinaceous birds.","pos":""}],"GALLINACEOUS":[{"def":"Resembling the domestic fowls and pheasants; of or pertaining to the Gallinae.","pos":""}],"GALLINAE":[{"def":"An order of birds, including the common domestic fowls, pheasants, grouse, quails, and allied forms; -- sometimes called Rasores.","pos":""}],"GALLING":[{"def":"Fitted to gall or chafe; vexing; harassing; irritating.","pos":""}],"GALLINIPPER":[{"def":"A large mosquito.","pos":""}],"GALLINULE":[{"def":"One of several wading birds, having long, webless toes, and a frontal shield, belonging to the family Rallidae.","pos":""}],"GALLIPOLI OIL":[{"def":"An inferior kind of olive oil, brought from Gallipoli, in Italy.","pos":""}],"GALLIPOT":[{"def":"A glazed earthen pot or vessel, used by druggists and apothecaries for containing medicines, etc.","pos":""}],"GALLIUM":[{"def":"A rare metallic element, found in certain zinc ores.","pos":""}],"GALLIVANT":[{"def":"To play the beau; to wait upon the ladies; also, to roam about for pleasure without any definite plan.","pos":""}],"GALLIVAT":[{"def":"A small armed vessel, with sails and oars, -- used on the Malabar coast.","pos":"noun"}],"GALLIWASP":[{"def":"A West Indian lizard (Celestus occiduus), about a foot long, imagined by the natives to be venomous.","pos":""}],"GALLIZE":[{"def":"In wine making, to add water and sugar to (unfermented grape juice) so as to increase the quantity of wine produced.","pos":""}],"GALLNUT":[{"def":"A round gall produced on the leaves and shoots of various species of the oak tree.","pos":""}],"GALLOMANIA":[{"def":"An excessive admiration of what is French.","pos":""}],"GALLON":[{"def":"A measure of capacity, containing four quarts; -- used, for the most part, in liquid measure, but sometimes in dry measure.","pos":""}],"GALLOON":[{"def":"A narrow tapelike fabric used for binding hats, shoes, etc.","pos":""},{"def":"A similar bordering or binding of rich material, such as gold lace.","pos":""}],"GALLOONED":[{"def":"Furnished or adorned with galloon.","pos":""}],"GALLOP":[{"def":"To move or run in the mode called a gallop; as a horse; to go at a gallop; to run or move with speed.","pos":""},{"def":"To ride a horse at a gallop.","pos":""}],"GALLOPADE":[{"def":"I horsemanship, a sidelong or curveting kind of gallop.","pos":""},{"def":"A kind of dance; also, music to the dance; a galop.","pos":""}],"GALLOPER":[{"def":"A carriage on which very small guns were formerly mounted, the gun resting on the shafts, without a limber.","pos":""}],"GALLOPIN":[{"def":"An under servant for the kitchen; a scullion; a cook's errand boy.","pos":"noun"}],"GALLOPING":[{"def":"Going at a gallop; progressing rapidly; as, a galloping horse.","pos":""}],"GALLOTANNIC":[{"def":"Pertaining to the tannin or nutgalls.","pos":""}],"GALLOW":[{"def":"To fright or terrify.","pos":""}],"GALLOWAY":[{"def":"A small horse of a breed raised at Galloway, Scotland; -- called also garran, and garron.","pos":""}],"GALLOWGLASS":[{"def":"A heavy-armed foot soldier from Ireland and the Western Isles in the time of Edward Shak.","pos":""}],"GALLOWS":[{"def":"The rest for the tympan when raised.","pos":""},{"def":"A pair of suspenders or braces.","pos":""}],"GALLSTONE":[{"def":"A concretion, or calculus, formed in the gall bladder or biliary passages.","pos":""}],"GALLY":[{"def":"To frighten; to worry.","pos":""}],"GALLYGASKINS":[{"def":"See Galligaskins.","pos":""}]}