{"NOG":[{"def":"A kind of strong ale.","pos":""}],"NOGGEN":[{"def":"Made of hemp; hence, hard; rough; harsh.","pos":""}],"NOGGIN":[{"def":"A small mug or cup.","pos":""},{"def":"A measure equivalent to a gill.","pos":""}],"NOGGING":[{"def":"Rough brick masonry used to fill in the interstices of a wooden frame, in building.","pos":""}]}