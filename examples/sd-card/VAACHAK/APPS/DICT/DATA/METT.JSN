{"METTE":[{"def":"of Mete, to dream.","pos":""}],"METTLE":[{"def":"Substance or quality of temperament; spirit, esp.","pos":""}],"METTLED":[{"def":"Having mettle; high-spirited; ardent; full of fire.","pos":""}],"METTLESOME":[{"def":"Full of spirit; possessing constitutional ardor; fiery; as, a mettlesome horse.","pos":""}]}