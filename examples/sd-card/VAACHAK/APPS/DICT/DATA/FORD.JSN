{"FORD":[{"def":"A place in a river, or other water, where it may passed by man or beast on foot, by wading.","pos":""},{"def":"A stream; a current.","pos":""}],"FORDABLE":[{"def":"Capable of being forded.","pos":""}],"FORDLESS":[{"def":"A deep and fordless river.","pos":""}],"FORDO":[{"def":"To destroy; to undo; to ruin.","pos":""},{"def":"To overcome with fatigue; to exhaust.","pos":""}],"FORDRIVE":[{"def":"To drive about; to drive here and there.","pos":""}],"FORDRUNKEN":[{"def":"Utterly drunk; very drunk.","pos":""}],"FORDRY":[{"def":"Entirely dry; withered.","pos":""}],"FORDWINE":[{"def":"To dwindle away; to disappear.","pos":""}]}