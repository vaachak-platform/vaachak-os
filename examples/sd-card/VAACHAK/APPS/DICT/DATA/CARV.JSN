{"CARVACROL":[{"def":"A thick oily liquid, C10H13.","pos":""}],"CARVE":[{"def":"To cut, as wood, stone, or other material, in an artistic or decorative manner; to sculpture; to engrave.","pos":""}],"CARVEL":[{"def":"Same as Caravel.","pos":""},{"def":"A species of jellyfish; sea blubber.","pos":""}],"CARVELBUILT":[{"def":"Having the planks meet flush at the seams, instead of lapping as in a clinker-built vessel.","pos":""}],"CARVEN":[{"def":"Wrought by carving; ornamented by carvings; carved.","pos":""}],"CARVENE":[{"def":"An oily substance, C10H16, extracted from oil caraway.","pos":""}],"CARVER":[{"def":"One who carves; one who shapes or fashions by carving, or as by carving; esp.","pos":""},{"def":"One who carves or divides meat at table.","pos":""}],"CARVING":[{"def":"The act or art of one who carves.","pos":""},{"def":"A piece of decorative work cut in stone, wood, or other material.","pos":""}],"CARVIST":[{"def":"A hawk which is of proper age and training to be carried on the hand; a hawk in its first year.","pos":""}],"CARVOL":[{"def":"One of a species of aromatic oils, resembling carvacrol.","pos":""}]}