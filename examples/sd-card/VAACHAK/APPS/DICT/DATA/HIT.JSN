{"HIT":[{"def":"Hit, Defn: 3d pers.","pos":""}],"HITCH":[{"def":"To become entangled or caught; to be linked or yoked; to unite; to cling.","pos":""},{"def":"To move interruptedly or with halts, jerks, or steps; -- said of something obstructed or impeded.","pos":""}],"HITHE":[{"def":"A port or small haven; -- used in composition; as, Lambhithe, now Lambeth.","pos":""}],"HITHER":[{"def":"To this place; -- used with verbs signifying motion, and implying motion toward the speaker; correlate of hence and thither; as, to come or bring hither.","pos":""},{"def":"To this point, source, conclusion, design, etc.","pos":""}],"HITHERMOST":[{"def":"Nearest on this side.","pos":""}],"HITHERTO":[{"def":"To this place; to a prescribed limit.","pos":""},{"def":"Up to this time; as yet; until now.","pos":""}],"HITHERWARD":[{"def":"Toward this place; hither.","pos":""}],"HITTER":[{"def":"One who hits or strikes; as, a hard hitter.","pos":""}],"HITTITE":[{"def":"A member of an ancient people (or perhaps group of peoples) whose settlements extended from Armenia westward into Asia Minor and southward into Palestine.","pos":""}],"HITTORF RAYS":[{"def":"Rays (chiefly cathode rays) developed by the electric discharge in Hittorf tubes.","pos":""}]}