{"NUDATION":[{"def":"The act of stripping, or making bare or naked.","pos":""}],"NUDDLE":[{"def":"To walk quickly with the head bent forward; -- often with along.","pos":""}],"NUDE":[{"def":"Naked; without consideration; void; as, a nude contract.","pos":""}],"NUDGE":[{"def":"To touch gently, as with the elbow, in order to call attention or convey intimation.","pos":""}],"NUDIBRACHIATE":[{"def":"Having tentacles without vibratile cilia.","pos":""}],"NUDIBRANCH":[{"def":"Of or pertaining to the Nudibranchiata.","pos":""},{"def":"One of the Nudibranchiata.","pos":""}],"NUDIBRANCHIATA":[{"def":"A division of opisthobranchiate mollusks, having no shell except while very young.","pos":""}],"NUDIBRANCHIATE":[{"def":"Same as Nudibranch.","pos":""}],"NUDICAUL":[{"def":"Having the stems leafless.","pos":""}],"NUDIFICATION":[{"def":"The act of making nude.","pos":""}],"NUDITY":[{"def":"The quality or state of being nude; nakedness.","pos":""},{"def":"That which is nude or naked; naked part; undraped or unclothed portion; esp.","pos":""}],"NUDUM PACTUM":[{"def":"A bare, naked contract, without any consideration.","pos":""}]}