{"BROOCH":[{"def":"A painting all of one color, as a sepia painting, or an India painting.","pos":""}],"BROOD":[{"def":"Heavy waste in tin and copper ores.","pos":""}],"BROODY":[{"def":"Inclined to brood.","pos":""}],"BROOK":[{"def":"A natural stream of water smaller than a river or creek.","pos":""}],"BROOKITE":[{"def":"A mineral consisting of titanic oxide, and hence identical with rutile and octahedrite in composition, but crystallizing in the orthorhombic system.","pos":""}],"BROOKLIME":[{"def":"A plant (Veronica Beccabunga), with flowers, usually blue, in axillary racemes.","pos":""}],"BROOKSIDE":[{"def":"The bank of a brook.","pos":""}],"BROOKWEED":[{"def":"A small white-flowered herb (Samolus Valerandi) found usually in wet places; water pimpernel.","pos":""}],"BROOM":[{"def":"A plant having twigs suitable for making brooms to sweep with when bound together; esp.","pos":""}],"BROOM CORN":[{"def":"A variety of Sorghum vulgare, having a joined stem, like maize, rising to the height of eight or ten feet, and bearing its seeds on a panicle with long branches, of which brooms are made.","pos":""}],"BROOM RAPE":[{"def":"A genus (Orobanche) of parasitic plants of Europe and Asia.","pos":""}],"BROOMSTICK":[{"def":"A stick used as a handle of a broom.","pos":""}],"BROOMY":[{"def":"Of or pertaining to broom; overgrowing with broom; resembling broom or a broom.","pos":""}]}