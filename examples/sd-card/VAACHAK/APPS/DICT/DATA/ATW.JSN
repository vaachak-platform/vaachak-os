{"ATWAIN":[{"def":"In twain; asunder.","pos":""}],"ATWIRL":[{"def":"Twisted; distorted; awry.","pos":""}],"ATWITE":[{"def":"To speak reproachfully of; to twit; to upbraid.","pos":""}],"ATWO":[{"def":"In two; in twain; asunder.","pos":""},{"def":"That has no type; devoid of typical character; irregular; unlike the type.","pos":""}]}