{"UNSIGHT":[{"def":"Doing or done without sight; not seeing or examining.","pos":""}],"UNSIGHTED":[{"def":"Not aimed by means of a sight; also, not furnished with a sight, or with a properly adjusted sight; as, to shoot and unsighted rife or cannon.","pos":""}],"UNSIMPLICITY":[{"def":"Absence of simplicity; artfulness.","pos":""}],"UNSIN":[{"def":"To deprive of sinfulness, as a sin; to make sinless.","pos":""}],"UNSINCERE":[{"def":"Not sincere or pure; insincere.","pos":""}],"UNSINCERITY":[{"def":"The quality or state of being unsincere or impure; insincerity.","pos":""}],"UNSINEW":[{"def":"To deprive of sinews or of strength.","pos":""}],"UNSISTER":[{"def":"To separate, as sisters; to disjoin.","pos":""}],"UNSITTING":[{"def":"Not sitting well; unbecoming.","pos":""}]}