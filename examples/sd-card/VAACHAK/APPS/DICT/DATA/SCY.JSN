{"SCYBALA":[{"def":"Hardened masses of feces.","pos":""}],"SCYE":[{"def":"Arm scye, a cutter's term for the armhole or part of the armhole of the waist of a garnment.","pos":""}],"SCYLE":[{"def":"To hide; to secrete; to conceal.","pos":""}],"SCYLLA":[{"def":"A dangerous rock on the Italian coast opposite the whirpool Charybdis on the coast of Sicily, -- both personified in classical literature as ravenous monsters.","pos":""}],"SCYLLAEA":[{"def":"A genus of oceanic nudibranchiate mollusks having the small branched gills situated on the upper side of four fleshy lateral lobes, and on the median caudal crest.","pos":""}],"SCYLLARIAN":[{"def":"One of a family (Scyllaridæ) of macruran Crustacea, remarkable for the depressed form of the body, and the broad, flat antennæ.","pos":""}],"SCYLLITE":[{"def":"A white crystalline substance of a sweetish taste, resembling inosite and metameric with dextrose.","pos":""}],"SCYPHA":[{"def":"See Scyphus, 2 (b).","pos":""}],"SCYPHISTOMA":[{"def":"The young attached larva of Discophora in the stage when it resembles a hydroid, or actinian.","pos":""}],"SCYPHOBRANCHII":[{"def":"An order of fishes including the blennioid and gobioid fishes, and other related families.","pos":""},{"def":"Same as Acraspeda, or Discophora.","pos":""}],"SCYPHOPHORI":[{"def":"An order of fresh-water fishes inhabiting tropical Africa.","pos":""}],"SCYPHUS":[{"def":"A kind of large drinking cup, -- used by Greeks and Romans, esp.","pos":""}],"SCYTHE":[{"def":"A scythe-shaped blade attached to ancient war chariots.","pos":""}],"SCYTHED":[{"def":"Armed scythes, as a chariot.","pos":""}],"SCYTHEMAN":[{"def":"One who uses a scythe; a mower.","pos":""}],"SCYTHESTONE":[{"def":"A stone for sharpening scythes; a whetstone.","pos":""}],"SCYTHEWHET":[{"def":"Wilson's thrush; -- so called from its note.","pos":""}],"SCYTHIAN":[{"def":"Of or pertaining to Scythia (a name given to the northern part of Asia, and Europe adjoining to Asia), or its language or inhabitants.","pos":""}],"SCYTODERMATA":[{"def":"Same as Holothurioidea.","pos":""}]}