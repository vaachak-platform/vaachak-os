{"HOME":[{"def":"The home base; he started for home.","pos":""}],"HOME-BRED":[{"def":"Bred at home; domestic; not foreign.","pos":""},{"def":"Not polished; rude; uncultivated.","pos":""}],"HOME-COMING":[{"def":"Kepeth this child, al be it foul or fayr, And eek my wyf, unto myn hoom-cominge.","pos":""}],"HOME-DRIVEN":[{"def":"Driven to the end, as a nail; driven close.","pos":""}],"HOME-DWELLING":[{"def":"Keeping at home.","pos":""}],"HOME-FELT":[{"def":"Felt in one's own breast; inward; private.","pos":""}],"HOME-KEEPING":[{"def":"Staying at home; not gadding.","pos":""}],"HOME-SPEAKING":[{"def":"Direct, forcible, and effective speaking.","pos":""}],"HOMEBORN":[{"def":"Native; indigenous; not foreign.","pos":""},{"def":"Of or pertaining to the home or family.","pos":""}],"HOMEFIELD":[{"def":"Afield adjacent to its owner's home.","pos":""}],"HOMELESS":[{"def":"Destitute of a home.","pos":""}],"HOMELIKE":[{"def":"Like a home; comfortable; cheerful; cozy; friendly.","pos":""}],"HOMELILY":[{"def":"Plainly; inelegantly.","pos":""}],"HOMELINESS":[{"def":"Domesticity; care of home.","pos":""},{"def":"Familiarity; intimacy.","pos":""}],"HOMELING":[{"def":"A person or thing belonging to a home or to a particular country; a native; as, a word which is a homeling.","pos":""}],"HOMELY":[{"def":"Belonging to, or having the characteristics of, home; domestic; familiar; intimate.","pos":""},{"def":"Plain; unpretending; rude in appearance; unpolished; as, a homely garment; a homely house; homely fare; homely manners.","pos":""}],"HOMELYN":[{"def":"The European sand ray (Raia maculata); -- called also home, mirror ray, and rough ray.","pos":""}],"HOMEMADE":[{"def":"Made at home; of domestic manufacture; made either in a private family or in one's own country.","pos":""}],"HOMEOPATH":[{"def":"A practitioner of homeopathy.","pos":""}],"HOMEOPATHIC":[{"def":"Of or pertaining to homeopathy; according to the principles of homeopathy.","pos":""}],"HOMEOPATHICALLY":[{"def":"According to the practice of homeopathy.","pos":""}],"HOMEOPATHIST":[{"def":"A believer in, or practitioner of, homeopathy.","pos":""}],"HOMEOPATHY":[{"def":"Samuel Hahnemann, and is opposed to allopathy, or heteropathy.","pos":""}],"HOMER":[{"def":"A carrier pigeon remarkable for its ability to return home from a distance.","pos":""}],"HOMERIC":[{"def":"Of or pertaining to Homer, the most famous of Greek poets; resembling the poetry of Homer.","pos":""}],"HOMESICK":[{"def":"Pining for home; in a nostalgic condition.","pos":""}],"HOMESPUN":[{"def":"Spun or wrought at home; of domestic manufacture; coarse; plain.","pos":""},{"def":"Plain in manner or style; not elegant; rude; coarse.","pos":""}],"HOMESTALL":[{"def":"Place of a home; homestead.","pos":""}],"HOMESTEAD":[{"def":"The home and appurtenant land and buildings owned by the head of a family, and occupied by him and his family.","pos":""}],"HOMESTEADER":[{"def":"One who has entered upon a portion of the public land with the purpose of acquiring ownership of it under provisions of the homestead law, so called; one who has acquired a homestead in this manner.","pos":""}],"HOMEWARD":[{"def":"Being in the direction of home; as, the homeward way.","pos":""},{"def":"Toward home; in the direction of one's house, town, or country.","pos":""}]}