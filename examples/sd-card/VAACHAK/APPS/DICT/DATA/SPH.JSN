{"SPHACELATE":[{"def":"To die, decay, or become gangrenous, as flesh or bone; to mortify.","pos":""}],"SPHACELATION":[{"def":"The process of becoming or making gangrenous; mortification.","pos":""}],"SPHACELUS":[{"def":"Gangrenous part; gangrene; slough.","pos":""}],"SPHAERENCHYMA":[{"def":"Vegetable tissue composed of thin-walled rounded cells, -- a modification of parenchyma.","pos":""}],"SPHAERIDIUM":[{"def":"A peculiar sense organ found upon the exterior of most kinds of sea urchins, and consisting of an oval or sherical head surmounting a short pedicel.","pos":""}],"SPHAEROSPORE":[{"def":"One of the nonsexual spores found in red algæ; a tetraspore.","pos":""}],"SPHAERULITE":[{"def":"Same as Spherulite.","pos":""}],"SPHAGNICOLOUS":[{"def":"Growing in moss of the genus Sphagnum.","pos":""}],"SPHAGNOUS":[{"def":"Pertaining to moss of the genus Sphagnum, or bog moss; abounding in peat or bog moss.","pos":""}],"SPHAGNUM":[{"def":"A genus of mosses having white leaves slightly tinged with red or green and found growing in marshy places; bog moss; peat moss.","pos":""}],"SPHALERITE":[{"def":"Zinc sulphide; -- called also blende, black-jack, false galena, etc.","pos":""}],"SPHENE":[{"def":"A mineral found usually in thin, wedge-shaped crystals of a yellow or green to black color.","pos":""}],"SPHENETHMOID":[{"def":"Of or pertaining to both the sphenoidal and the ethmoidal regions of the skull, or the sphenethmoid bone; sphenethmoidal.","pos":""}],"SPHENETHMOIDAL":[{"def":"Relating to the sphenoethmoid bone; sphenoethmoid.","pos":""}],"SPHENISCAN":[{"def":"Any species of penguin.","pos":""}],"SPHENO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the sphenoid bone; as in sphenomaxillary, sphenopalatine.","pos":""}],"SPHENODON":[{"def":"Same as Hatteria.","pos":""}],"SPHENOETHMOIDAL":[{"def":"Sphe\"no*eth*moid`al, a.","pos":""}],"SPHENOGRAM":[{"def":"A cuneiform, or arrow-headed, character.","pos":""}],"SPHENOGRAPHER":[{"def":"One skilled in sphenography; a sphenographist.","pos":""}],"SPHENOGRAPHIC":[{"def":"Of or pertaining to sphenography.","pos":""}],"SPHENOGRAPHIST":[{"def":"A sphenographer.","pos":""}],"SPHENOGRAPHY":[{"def":"The art of writing in cuneiform characters, or of deciphering inscriptions made in such characters.","pos":""}],"SPHENOID":[{"def":"Of or pertaining to the sphenoid bone.","pos":""}],"SPHENOIDAL":[{"def":"Pertaining to, or resembling, a sphenoid.","pos":""}],"SPHENOTIC":[{"def":"Of, pertaining to, or designating, the sphenotic bone.","pos":""}],"SPHERAL":[{"def":"Of or pertaining to a sphere or the spheres.","pos":""},{"def":"Rounded like a sphere; sphere-shaped; hence, symmetrical; complete; perfect.","pos":""}],"SPHERE":[{"def":"A body or space contained under a single surface, which in every part is equally distant from a point within called its center.","pos":""},{"def":"The extension of a general conception, or the totality of the individuals or species to which it may be applied.","pos":""}],"SPHERICITY":[{"def":"The quality or state of being spherial; roundness; as, the sphericity of the planets, or of a drop of water.","pos":""}],"SPHERICS":[{"def":"The doctrine of the sphere; the science of the properties and relations of the circles, figures, and other magnitudes of a sphere, produced by planes intersecting it; spherical geometry and trigonometry.","pos":""}],"SPHEROBACTERIA":[{"def":"See the Note under Microbacteria.","pos":""}],"SPHEROCONIC":[{"def":"A nonplane curve formed by the intersection of the surface of an oblique cone with the surface of a sphere whose center is at the vertex of the cone.","pos":""}],"SPHEROID":[{"def":"A body or figure approaching to a sphere, but not perfectly spherical; esp.","pos":""}],"SPHEROIDAL":[{"def":"Having the form of a spheroid.","pos":""}],"SPHEROMERE":[{"def":"Any one of the several symmetrical segments arranged around the central axis and composing the body of a radiate anmal.","pos":""}],"SPHEROMETER":[{"def":"An instrument for measuring the curvature of spherical surface, as of lenses for telescope, etc.","pos":""}],"SPHEROSIDERITE":[{"def":"Siderite occuring in spheroidal masses.","pos":""}],"SPHEROSOME":[{"def":"The body wall of any radiate animal.","pos":""}],"SPHERULATE":[{"def":"Covered or set with spherules; having one or more rows of spherules, or minute tubercles.","pos":""}],"SPHERULE":[{"def":"A little sphere or spherical body; as, quicksilver, when poured upon a plane, divides itself into a great number of minute spherules.","pos":""}],"SPHERULITE":[{"def":"A minute spherical crystalline body having a radiated structure, observed in some vitreous volcanic rocks, as obsidian and pearlstone.","pos":""}],"SPHERULITIC":[{"def":"Of or pertaining to a spherulite; characterized by the presence of spherulites.","pos":""}],"SPHERY":[{"def":"Round; spherical; starlike.","pos":""},{"def":"Of or pertaining to the spheres.","pos":""}],"SPHEX":[{"def":"Any one of numerous species of sand wasps of the genus Sphex and allied genera.","pos":"noun"}],"SPHIGMOMETER":[{"def":"See Sphygmometer.","pos":""}],"SPHINCTER":[{"def":"A muscle which surrounds, and by its contraction tends to close, a natural opening; as, the sphincter of the bladder.","pos":""}],"SPHINGID":[{"def":"Of or pertaining to a sphinx, or the family Sphingidæ.","pos":""}],"SPHINX":[{"def":"Any one of numerous species of large moths of the family Sphingidæ; -- called also hawk moth.","pos":""},{"def":"The Guinea, or sphinx, baboon (Cynocephalus sphinx).","pos":""}],"SPHRAGISTICS":[{"def":"The science of seals, their history, age, distinctions, etc.","pos":""}],"SPHRIGOSIS":[{"def":"A condition of vegetation in which there is too abundant growth of the stem and leaves, accompanied by deficiency of flowers and fruit.","pos":""}],"SPHYGMIC":[{"def":"Of or pertaining to the pulse.","pos":""}],"SPHYGMOGRAM":[{"def":"A tracing, called a pulse tracing, consisting of a series of curves corresponding with the beats of the heart, obtained by the application of the sphygmograph.","pos":""}],"SPHYGMOGRAPH":[{"def":"An instrument which, when applied over an artery, indicates graphically the movements or character of the pulse.","pos":""}],"SPHYGMOGRAPHIC":[{"def":"Relating to, or produced by, a sphygmograph; as, a sphygmographic tracing.","pos":""}],"SPHYGMOMETER":[{"def":"An instrument for measuring the strength of the pulse beat; a sphygmograph.","pos":""}],"SPHYGMOPHONE":[{"def":"An electrical instrument for determining by the ear the rhythm of the pulse of a person at a distance.","pos":""}],"SPHYGMOSCOPE":[{"def":"Same as Sphygmograph.","pos":""}],"SPHYRAENOID":[{"def":"Of or pertaining to the Sphyrænidæ, a family of marine fishes including the barracudas.","pos":""}]}