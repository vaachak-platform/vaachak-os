{"JAM":[{"def":"A kind of frock for children.","pos":""}],"JAMADAR":[{"def":"Same as Jemidar.","pos":""}],"JAMAICA":[{"def":"One of the West India is islands.","pos":""}],"JAMAICAN":[{"def":"Of or pertaining to Jamaica.","pos":""},{"def":"A native or inhabitant of Jamaica.","pos":""}],"JAMAICINE":[{"def":"An alkaloid said to be contained in the bark of Geoffroya inermis, a leguminous tree growing in Jamaica and Surinam; -- called also jamacina.","pos":""}],"JAMB":[{"def":"The vertical side of any opening, as a door or fireplace; hence, less properly, any narrow vertical surface of wall, as the of a chimney-breast or of a pier, as distinguished from its face.","pos":""},{"def":"Any thick mass of rock which prevents miners from following the lode or vein.","pos":""}],"JAMBEE":[{"def":"A fashionable cane.","pos":""},{"def":"In the Middle Ages, armor for the legs below the knees.","pos":""}],"JAMBOLANA":[{"def":"A myrtaceous tree of the West Indies and tropical America (Calyptranthes Jambolana), with astringent bark, used for dyeing.","pos":""},{"def":"The Java plum; also, a drug obtained from its bark and seeds, used as a remedy for diabetes.","pos":""}],"JAMBOOREE":[{"def":"A noisy or unrestrained carousal or frolic; a spree.","pos":""}],"JAMDANI":[{"def":"A silk fabric, with a woven pattern of sprigs of flowers.","pos":""}],"JAMES'S POWDER":[{"def":"Antimonial powder, first prepared by Dr.","pos":""}],"JAMESONITE":[{"def":"A steel-gray mineral, of metallic luster, commonly fibrous massive.","pos":""}],"JAMESTOWN WEED":[{"def":"The poisonous thorn apple or stramonium (Datura stramonium), a rank weed early noticed at Jamestown, Virginia.","pos":""}]}