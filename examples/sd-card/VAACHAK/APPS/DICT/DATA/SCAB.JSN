{"SCAB":[{"def":"A slight iregular protuberance which defaces the surface of a casting, caused by the breaking away of a part of the mold.","pos":""}],"SCABBARD":[{"def":"The case in which the blade of a sword, dagger, etc.","pos":""}],"SCABBARD PLANE":[{"def":"See Scaleboard plane, under Scaleboard.","pos":""}],"SCABBED":[{"def":"Abounding with scabs; diseased with scabs.","pos":""}],"SCABBILY":[{"def":"In a scabby manner.","pos":""}],"SCABBINESS":[{"def":"The quality or state of being scabby.","pos":""}],"SCABBY":[{"def":"Affected with scabs; full of scabs.","pos":""},{"def":"Diseased with the scab, or mange; mangy.","pos":""}],"SCABIOUS":[{"def":"Consisting of scabs; rough; itchy; leprous; as, scabious eruptions.","pos":""}],"SCABLING":[{"def":"A fragment or chip of stone.","pos":""}],"SCABREDITY":[{"def":"Roughness; ruggedness.","pos":""}],"SCABROUS":[{"def":"Rough to the touch, like a file; having small raised dots, scales, or points; scabby; scurfy; scaly.","pos":""}],"SCABROUSNESS":[{"def":"The quality of being scabrous.","pos":""}]}