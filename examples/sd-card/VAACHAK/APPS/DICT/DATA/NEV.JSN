{"NEVADITE":[{"def":"A grantitoid variety of rhyolite, common in Nevada.","pos":""}],"NEVE":[{"def":"The upper part of a glacier, above the limit or perpetual snow.","pos":""}],"NEVEN":[{"def":"To name; to mention; to utter.","pos":""}],"NEVER":[{"def":"Not ever; not at any time; at no time, whether past, present, or future.","pos":""},{"def":"In no degree; not in the least; not.","pos":""}],"NEVERMORE":[{"def":"Never again; at no time hereafter.","pos":""}],"NEVERTHELATER":[{"def":"Nev`er*the*lat\"er, adv.","pos":""}],"NEVERTHELESS":[{"def":"Not the less; notwithstanding; in spite of that; yet.","pos":""}]}