{"PERPEND":[{"def":"To weight carefully in the mind.","pos":""}],"PERPENDER":[{"def":"A large stone reaching through a wall so as to appear on both sides of it, and acting as a binder; -- called also perbend, perpend stone, and perpent stone.","pos":""}],"PERPENDICLE":[{"def":"Something hanging straight down; a plumb line.","pos":""}],"PERPENDICULAR":[{"def":"At right angles to a given line or surface; as, the line ad is perpendicular to the line bc.","pos":""}],"PERPENDICULARITY":[{"def":"The quality or state of being perpendicular.","pos":""}],"PERPENDICULARLY":[{"def":"In a perpendicular manner; vertically.","pos":""}],"PERPENSION":[{"def":"Careful consideration; pondering.","pos":""}],"PERPESSION":[{"def":"Suffering; endurance.","pos":""}],"PERPETRABLE":[{"def":"Capable of being perpetrated.","pos":""}],"PERPETRATE":[{"def":"To do or perform; to carry through; to execute, commonly in a bad sense; to commit (as a crime, an offense); to be guilty of; as, to perpetrate a foul deed.","pos":""}],"PERPETRATION":[{"def":"The act of perpetrating; a doing; -- commonly used of doing something wrong, as a crime.","pos":""},{"def":"The thing perpetrated; an evil action.","pos":""}],"PERPETRATOR":[{"def":"One who perpetrates; esp.","pos":""}],"PERPETUABLE":[{"def":"Capable of being perpetuated or continued.","pos":""}],"PERPETUAL":[{"def":"Neverceasing; continuing forever or for an unlimited time; unfailing; everlasting; continuous.","pos":""}],"PERPETUAL CALENDAR":[{"def":"A calendar that can be used perpetually or over a wide range of years.","pos":""}],"PERPETUALLY":[{"def":"In a perpetual manner; constantly; continually.","pos":""}],"PERPETUALTY":[{"def":"The state or condition of being perpetual.","pos":""}],"PERPETUATE":[{"def":"To make perpetual; to cause to endure, or to be continued, indefinitely; to preserve from extinction or oblivion; to eternize.","pos":""}],"PERPETUATION":[{"def":"The act of making perpetual, or of preserving from extinction through an endless existence, or for an indefinite period of time; continuance.","pos":""}],"PERPETUITY":[{"def":"The quality or state of being perpetual; as, the perpetuity of laws.","pos":""},{"def":"Something that is perpetual.","pos":""}],"PERPLEX":[{"def":"To involve; to entangle; to make intricate or complicated, and difficult to be unraveled or understood; as, to perplex one with doubts.","pos":""},{"def":"To embarrass; to puzzle; to distract; to bewilder; to confuse; to trouble with ambiguity, suspense, or anxiety.","pos":""}],"PERPLEXED":[{"def":"Entangled, involved, or confused; hence, embarrassd; puzzled; doubtful; anxious.","pos":""}],"PERPLEXING":[{"def":"Embarrassing; puzzling; troublesome.","pos":""}],"PERPLEXITY":[{"def":"The quality or state of being perplexed or puzzled; complication; intricacy; entanglement; distraction of mind through doubt or difficulty; embarrassment; bewilderment; doubt.","pos":""}],"PERPLEXIVENESS":[{"def":"The quality of being perplexing; tendency to perplex.","pos":""}],"PERPOTATION":[{"def":"The act of drinking excessively; a drinking bout.","pos":""}]}