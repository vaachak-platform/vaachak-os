{"GRY":[{"def":"A measure equal to one tenth of a line.","pos":""},{"def":"Anything very small, or of little value.","pos":""}],"GRYLLUS":[{"def":"A genus of insects including the common crickets.","pos":""}],"GRYPE":[{"def":"A vulture; the griffin.","pos":""}],"GRYPHAEA":[{"def":"A genus of cretaceous fossil shells allied to the oyster.","pos":""}],"GRYPHITE":[{"def":"A shell of the genus Gryphea.","pos":""}],"GRYPHON":[{"def":"The griffin vulture.","pos":""}],"GRYSBOK":[{"def":"A small South African antelope (Neotragus melanotis).","pos":""}]}