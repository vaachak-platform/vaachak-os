{"PRELACY":[{"def":"The office or dignity of a prelate; church government by prelates.","pos":""},{"def":"The order of prelates, taken collectively; the body of ecclesiastical dignitaries.","pos":""}],"PRELAL":[{"def":"Of or pertaining to printing; typographical.","pos":""}],"PRELATE":[{"def":"A clergyman of a superior order, as an archbishop or a bishop, having authority over the lower clergy; a dignitary of the church.","pos":""}],"PRELATESHIP":[{"def":"The office of a prelate.","pos":""}],"PRELATESS":[{"def":"A woman who is a prelate; the wife of a prelate.","pos":""}],"PRELATIAL":[{"def":"Of or pertaining to prelates or prelacy; as, prelatical authority.","pos":""}],"PRELATICALLY":[{"def":"In a prelatical manner; with reference to prelates.","pos":""}],"PRELATION":[{"def":"The setting of one above another; preference.","pos":""}],"PRELATISM":[{"def":"Prelacy; episcopacy.","pos":""}],"PRELATIST":[{"def":"One who supports of advocates prelacy, or the government of the church by prelates; hence, a high-churchman.","pos":""}],"PRELATIZE":[{"def":"To bring under the influence of prelacy.","pos":""}],"PRELATRY":[{"def":"Prelaty; prelacy.","pos":""},{"def":"The state or dignity of a prelate; prelacy.","pos":""}],"PRELECT":[{"def":"To read publicly, as a lecture or discourse.","pos":""}],"PRELECTION":[{"def":"A lecture or discourse read in public or to a select company.","pos":""}],"PRELECTOR":[{"def":"A reader of lectures or discourses; a lecturer.","pos":""}],"PRELIBATION":[{"def":"A pouring out, or libation, before tasting.","pos":""}],"PRELIMINARILY":[{"def":"In a preliminary manner.","pos":""}],"PRELIMINARY":[{"def":"Introductory; previous; preceding the main discourse or business; prefatory; as, preliminary observations to a discourse or book; preliminary articles to a treaty; preliminary measures; preliminary examinations.","pos":""}],"PRELIMIT":[{"def":"To limit previously.","pos":""}],"PRELOOK":[{"def":"To look forward.","pos":""}],"PRELUDE":[{"def":"An introductory performance, preceding and preparing for the principal matter; a preliminary part, movement, strain, etc.","pos":""}],"PRELUDER":[{"def":"One who, or that which, preludes; one who plays a prelude.","pos":""}],"PRELUDIAL":[{"def":"Of or pertaining to a prelude; of the nature of a prelude; introductory.","pos":""}],"PRELUMBAR":[{"def":"Situated immediately in front of the loins;- applied to the dorsal part of the abdomen.","pos":""}],"PRELUSIVE":[{"def":"Of the nature of a prelude; introductory; indicating that something of a like kind is to follow.","pos":""}],"PRELUSORILY":[{"def":"In a prelusory way.","pos":""}],"PRELUSORY":[{"def":"Introductory; prelusive.","pos":""}]}