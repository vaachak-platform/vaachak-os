{"FLY":[{"def":"To move in or pass thorugh the air with wings, as a bird.","pos":""},{"def":"To move through the air or before the wind; esp.","pos":""}],"FLY-BITTEN":[{"def":"Marked by, or as if by, the bite of flies.","pos":""}],"FLY-CASE":[{"def":"The covering of an insect, esp.","pos":""}],"FLY-CATCHING":[{"def":"Having the habit of catching insects on the wing.","pos":""}],"FLY-FISH":[{"def":"To angle, using flies for bait.","pos":""}],"FLYAWAY":[{"def":"Disposed to fly away; flighty; unrestrained; light and free; -- used of both persons and things.","pos":""},{"def":"A flyaway person or thing.","pos":""}],"FLYAWAY GRASS":[{"def":"The hair grass (Agrostis scabra).","pos":""}],"FLYBANE":[{"def":"A kind of catchfly of the genus Silene; also, a poisonous mushroom (Agaricus muscarius); fly agaric.","pos":""}],"FLYBLOW":[{"def":"To deposit eggs upon, as a flesh fly does on meat; to cause to be maggoty; hence, to taint or contaminate, as if with flyblows.","pos":""}],"FLYBLOWN":[{"def":"Tainted or contaminated with flyblows; damaged; foul.","pos":""}],"FLYBOAT":[{"def":"A large Dutch coasting vessel.","pos":""}],"FLYCATCHER":[{"def":"One of numerous species of birds that feed upon insects, which they take on the wing.","pos":""}],"FLYER":[{"def":"One in a flight of steps which are parallel to each other(as in ordinary stairs), as distinguished from a winder.","pos":""},{"def":"A small operation not involving considerable part of one's capital, or not in the line of one's ordinary business; a venture.","pos":""}],"FLYFISH":[{"def":"A California scorpænoid fish (Sebastichthys rhodochloris), having brilliant colors.","pos":""}],"FLYING":[{"def":"Moving in the air with, or as with, wings; moving lightly or rapidly; intended for rapid movement.","pos":""}],"FLYING BOAT":[{"def":"A compact form of hydro-aëroplane having one central body, or hull.","pos":""}],"FLYING FISH":[{"def":"A fish which is able to leap from the water, and fly a considerable distance by means of its large and long pectoral fins.","pos":""}],"FLYING SQUIRREL":[{"def":"One of a group of squirrels, of the genera Pteromus and Sciuropterus, having parachute-like folds of skin extending from the fore to the hind legs, which enable them to make very long leaps.","pos":""}],"FLYMAN":[{"def":"The driver of a fly, or light public carriage.","pos":""}],"FLYSCH":[{"def":"A name given to the series of sandstones and schists overlying the true nummulitic formation in the Alps, and included in the Eocene Tertiary.","pos":""}],"FLYSPECK":[{"def":"A speck or stain made by the excrement of a fly; hence, any insignificant dot.","pos":""}],"FLYTRAP":[{"def":"A plant (Dionæa muscipula), called also Venus's flytrap, the leaves of which are fringed with stiff bristles, and fold together when certain hairs on their upper surface are touched, thus seizing insects that light on them.","pos":""}]}