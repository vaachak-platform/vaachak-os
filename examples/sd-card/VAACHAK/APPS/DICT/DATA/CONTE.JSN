{"CONTE":[{"def":"A short narrative or tale, esp.","pos":""}],"CONTEK":[{"def":"Contumely; reproach.","pos":""}],"CONTEMN":[{"def":"To view or treat with contempt, as mean and despicable; to reject with disdain; to despise; to scorn.","pos":""}],"CONTEMNER":[{"def":"One who contemns; a despiser; a scorner.","pos":""}],"CONTEMPER":[{"def":"To modify or temper; to allay; to qualify; to moderate; to soften.","pos":""}],"CONTEMPERATE":[{"def":"To temper; to moderate.","pos":""}],"CONTEMPERATION":[{"def":"The act of tempering or moderating.","pos":""},{"def":"Proportionate mixture or combination.","pos":""}],"CONTEMPERATURE":[{"def":"The condition of being tempered; proportionate mixture; temperature.","pos":""}],"CONTEMPLANT":[{"def":"Given to contemplation; meditative.","pos":""}],"CONTEMPLATE":[{"def":"To look at on all sides or in all its bearings; to view or consider with continued attention; to regard with deliberate care; to meditate on; to study.","pos":""},{"def":"To consider or have in view, as contingent or probable; to look forward to; to purpose; to intend.","pos":""}],"CONTEMPLATION":[{"def":"The act of the mind in considering with attention; continued attention of the mind to a particular subject; meditation; musing; study.","pos":""},{"def":"Holy meditation.","pos":""}],"CONTEMPLATIVE":[{"def":"Pertaining to contemplation; addicted to, or employed in, contemplation; meditative.","pos":""},{"def":"Having the power of contemplation; as, contemplative faculties.","pos":""}],"CONTEMPLATIVELY":[{"def":"With contemplation; in a contemplative manner.","pos":""}],"CONTEMPLATIVENESS":[{"def":"The state of being contemplative; thoughtfulness.","pos":""}],"CONTEMPLATOR":[{"def":"One who contemplates.","pos":""}],"CONTEMPORANEITY":[{"def":"The state of being contemporaneous.","pos":""}],"CONTEMPORANEOUS":[{"def":"Living, existing, or occurring at the same time; contemporary.","pos":""}],"CONTEMPORANEOUSLY":[{"def":"At the same time with some other event.","pos":""}],"CONTEMPORARINESS":[{"def":"Existence at the same time; contemporaneousness.","pos":""}],"CONTEMPORARY":[{"def":"Living, occuring, or existing, at the same time; done in, or belonging to, the same times; contemporaneous.","pos":""},{"def":"Of the same age; coeval.","pos":""}],"CONTEMPT":[{"def":"Disobedience of the rules, orders, or process of a court of justice, or of rules or orders of a legislative body; disorderly, contemptuous, or insolent language or behavior in presence of a court, tending to disturb its proceedings, or impair the respect due to its authority.","pos":""}],"CONTEMPTIBILITY":[{"def":"The quality of being contemptible; contemptibleness.","pos":""}],"CONTEMPTIBLE":[{"def":"Worthy of contempt; deserving of scorn or disdain; mean; vile; despicable.","pos":""},{"def":"Despised; scorned; neglected; abject.","pos":""}],"CONTEMPTIBLENESS":[{"def":"The state or quality of being contemptible, or of being despised.","pos":""}],"CONTEMPTIBLY":[{"def":"In a contemptible manner.","pos":""}],"CONTEMPTUOUS":[{"def":"Manifecting or expressing contempt or disdain; scornful; haughty; insolent; disdainful.","pos":""}],"CONTEMPTUOUSLY":[{"def":"In a contemptuous manner; with scorn or disdain; despitefully.","pos":""}],"CONTEMPTUOUSNESS":[{"def":"Disposition to or manifestion of contempt; insolence; haughtiness.","pos":""}],"CONTEND":[{"def":"To strive in opposition; to contest; to dispute; to vie; to quarrel; to fight.","pos":""},{"def":"To struggle or exert one's self to obtain or retain possession of, or to defend.","pos":""}],"CONTENDENT":[{"def":"n antagonist; a contestant.","pos":""}],"CONTENDER":[{"def":"One who contends; a contestant.","pos":""}],"CONTENDRESS":[{"def":"A female contestant.","pos":""}],"CONTENEMENT":[{"def":"That which is held together with another thing; that which is connected with a tenetment, or thing holden, as a certin quantity of land a Burrill.","pos":""}],"CONTENT":[{"def":"Contained within limits; hence, having the desires limited by that which one has; not disposed to repine or grumble; satisfied; contented; at rest.","pos":""}],"CONTENTATION":[{"def":"Content; satisfaction.","pos":""}],"CONTENTED":[{"def":"Content; easy in mind; satisfied; quiet; willing.","pos":""}],"CONTENTFUL":[{"def":"Full of content.","pos":""}],"CONTENTION":[{"def":"A violent effort or struggle to obtain, or to resist, something; contest; strife.","pos":""},{"def":"Strife in words; controversy; altercation quarrel; dispute; as, a bone of contention.","pos":""}],"CONTENTIOUS":[{"def":"Contested; litigated; litigious; having power to decide controversy.","pos":""}],"CONTENTLESS":[{"def":"Discontented; dissatisfied.","pos":""}],"CONTENTLY":[{"def":"In a contented manner.","pos":""}],"CONTENTMENT":[{"def":"The state of being contented or satisfied; content.","pos":""},{"def":"The act or process of contenting or satisfying; as, the contentment of avarice is impossible.","pos":""}],"CONTENTS":[{"def":"Con*tents ( or ; 277), n.","pos":""}],"CONTERMINABLE":[{"def":"Having the same bounds; terminating at the same time or place; conterminous.","pos":""}],"CONTERMINANT":[{"def":"Having the same limits; ending at the same time; conterminous.","pos":""}],"CONTERMINATE":[{"def":"Having the same bounds; conterminous.","pos":""}],"CONTERMINOUS":[{"def":"Having the same bounds, or limits; bordering upon; contiguous.","pos":""},{"def":"Of or belonging to the same country.","pos":""}],"CONTESSERATION":[{"def":"An assemblage; a collection; harmonious union.","pos":""}],"CONTEST":[{"def":"To make a subject of litigation; to defend, as a suit; to dispute or resist; as a claim, by course of law; to controvert.","pos":""}],"CONTESTABLE":[{"def":"Capable of being contested; debatable.","pos":""}],"CONTESTANT":[{"def":"One who contests; an opponent; a litigant; a disputant; one who claims that which has been awarded to another.","pos":""}],"CONTESTATION":[{"def":"The act of contesting; emulation; rivalry; strife; dispute.","pos":""},{"def":"Proof by witness; attestation; testimony.","pos":""}],"CONTESTINGLY":[{"def":"In a contending manner.","pos":""}],"CONTEXT":[{"def":"Knit or woven together; close; firm.","pos":""}],"CONTEXTURAL":[{"def":"Pertaining to contexture or arrangement of parts; producing contexture; interwoven.","pos":""}],"CONTEXTURE":[{"def":"The arrangement and union of the constituent parts of a thing; a weaving together of parts; structural character of a thing; system; constitution; texture.","pos":""}],"CONTEXTURED":[{"def":"Formed into texture; woven together; arranged; composed.","pos":""}]}