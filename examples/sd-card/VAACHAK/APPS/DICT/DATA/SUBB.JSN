{"SUBBEADLE":[{"def":"An under beadle.","pos":""}],"SUBBRACHIAL":[{"def":"Of or pertaining to the subbrachians.","pos":""}],"SUBBRACHIALES":[{"def":"A division of soft-finned fishes in which the ventral fins are situated beneath the pectorial fins, or nearly so.","pos":""}],"SUBBRACHIAN":[{"def":"One of the Subbrachiales.","pos":""}],"SUBBREED":[{"def":"A race or strain differing in certain characters from the parent breed; an incipient breed.","pos":""}],"SUBBRONCHIAL":[{"def":"Situated under, or on the ventral side of, the bronchi; as, the subbronchial air sacs of birds.","pos":""}]}