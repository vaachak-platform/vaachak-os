{"CHAR":[{"def":"A car; a chariot.","pos":""}],"CHAR-A-BANC":[{"def":"A long, light, open vehicle, with benches or seats running lengthwise.","pos":""}],"CHARA":[{"def":"A genus of flowerless plants, having articulated stems and whorled branches.","pos":""}],"CHARACT":[{"def":"A distinctive mark; a character; a letter or sign.","pos":""}],"CHARACTER":[{"def":"A distinctive mark; a letter, figure, or symbol.","pos":""},{"def":"Style of writing or printing; handwriting; the peculiar form of letters used by a particular person or people; as, an inscription in the Runic character.","pos":""}],"CHARACTERISM":[{"def":"A distinction of character; a characteristic.","pos":""}],"CHARACTERISTIC":[{"def":"Pertaining to, or serving to constitute, the character; showing the character, or distinctive qualities or traits, of a person or thing; peculiar; distinctive.","pos":""}],"CHARACTERISTICAL":[{"def":"Char`ac*ter*is\"tic*al, a.","pos":""}],"CHARACTERISTICALLY":[{"def":"In a characteristic manner; in a way that characterizes.","pos":""}],"CHARACTERIZATION":[{"def":"The act or process of characterizing.","pos":""}],"CHARACTERIZE":[{"def":"To make distinct and recognizable by peculiar marks or traits; to make with distinctive features.","pos":""},{"def":"To engrave or imprint.","pos":""}],"CHARACTERLESS":[{"def":"Destitute of any distinguishing quality; without character or force.","pos":""}],"CHARACTERY":[{"def":"The art or means of characterizing; a system of signs or characters; symbolism; distinctive mark.","pos":""},{"def":"That which is charactered; the meaning.","pos":""}],"CHARADE":[{"def":"A verbal or acted enigma based upon a word which has two or more significant syllables or parts, each of which, as well as the word itself, is to be guessed from the descriptions or representations.","pos":""}],"CHARBON":[{"def":"A small black spot or mark remaining in the cavity of the corner tooth of a horse after the large spot or mark has become obliterated.","pos":""}],"CHARCOAL":[{"def":"Finely prepared charcoal in small sticks, used as a drawing implement.","pos":""}],"CHARD":[{"def":"The tender leaves or leafstalks of the artichoke, white beet, etc.","pos":""},{"def":"A variety of the white beet, which produces large, succulent leaves and leafstalks.","pos":""}],"CHARE":[{"def":"A narrow street.","pos":""}],"CHARGE":[{"def":"To assume as a bearing; as, he charges three roses or; to add to or represent on; as, he charges his shield with three roses or.","pos":""}],"CHARGE D'AFFAIRES":[{"def":"A diplomatic representative, or minister of an inferior grade, accredited by the government of one state to the minister of foreign affairs of another; also, a substitute, ad interim, for an ambassador or minister plenipotentiary.","pos":""}],"CHARGEABLE":[{"def":"That may be charged, laid, imposed, or imputes; as, a duty chargeable on iron; a fault chargeable on a man.","pos":""},{"def":"Subject to be charge or accused; liable or responsible; as, revenues chargeable with a claim; a man chargeable with murder.","pos":""}],"CHARGEABLENESS":[{"def":"The quality of being chargeable or expensive.","pos":""}],"CHARGEABLY":[{"def":"At great cost; expensively.","pos":""}],"CHARGEANT":[{"def":"Burdensome; troublesome.","pos":""}],"CHARGEFUL":[{"def":"Costly; expensive.","pos":""}],"CHARGELESS":[{"def":"Free from, or with little, charge.","pos":""}],"CHARGEOUS":[{"def":"I was chargeous to no man.","pos":""}],"CHARGER":[{"def":"One who, or that which charges.","pos":""},{"def":"An instrument for measuring or inserting a charge.","pos":""}],"CHARGESHIP":[{"def":"The office of a chargé d'affaires.","pos":""}],"CHARILY":[{"def":"In a chary manner; carefully; cautiously; frugally.","pos":""}],"CHARINESS":[{"def":"The quality of being chary.","pos":""}],"CHARIOT":[{"def":"A two-wheeled car or vehicle for war, racing, state processions, etc.","pos":""}],"CHARIOTEE":[{"def":"A light, covered, four-wheeled pleasure carriage with two seats.","pos":""}],"CHARIOTEER":[{"def":"A constellation.","pos":""}],"CHARISM":[{"def":"A miraculously given power, as of healing, speaking foreign languages without instruction, etc.","pos":""}],"CHARISMATIC":[{"def":"Of or pertaining to a charism.","pos":""}],"CHARITABLE":[{"def":"Full of love and good will; benevolent; kind.","pos":""},{"def":"Liberal in judging of others; disposed to look on the best side, and to avoid harsh judgment.","pos":""}],"CHARITABLENESS":[{"def":"The quality of being charitable; the exercise of charity.","pos":""}],"CHARITABLY":[{"def":"In a charitable manner.","pos":""}],"CHARITY":[{"def":"Now abideth faith, hope, charity, three; but the greatest of these is charity.","pos":""},{"def":"Eleemosynary appointments [grants or devises] including relief of the poor or friendless, education, religious culture, and public institutions.","pos":""}],"CHARIVARI":[{"def":"A mock serenade of discordant noises, made with kettles, tin horns, etc.","pos":""}],"CHARK":[{"def":"Charcoal; a cinder.","pos":""}],"CHARLATAN":[{"def":"One who prates much in his own favor, and makes unwarrantable pretensions; a quack; an impostor; an empiric; a mountebank.","pos":""},{"def":"Of or like a charlatan; making undue pretension; empirical; pretentious; quackish.","pos":""}],"CHARLATANRY":[{"def":"Undue pretensions to skill; quackery; wheedling; empiricism.","pos":""}],"CHARLES'S WAIN":[{"def":"The group of seven stars, commonly called the Dipper, in the constellation Ursa Major, or Great Bear.","pos":""}],"CHARLIE":[{"def":"A familiar nickname or substitute for Charles.","pos":""},{"def":"A night watchman; -- an old name.","pos":""}],"CHARLOCK":[{"def":"A cruciferous plant (Brassica sinapistrum) with yellow flowers; wild mustard.","pos":""}],"CHARLOTTE":[{"def":"A kind of pie or pudding made by lining a dish with slices of bread, and filling it with bread soaked in milk, and baked.","pos":""}],"CHARM":[{"def":"A melody; a song.","pos":""},{"def":"A word or combination of words sung or spoken in the practice of magic; a magical combination of words, characters, etc.","pos":""}],"CHARMEL":[{"def":"A fruitful field.","pos":""}],"CHARMER":[{"def":"One who charms, or has power to charm; one who uses the power of enchantment; a magician.","pos":""},{"def":"One who delights and attracts the affections.","pos":""}],"CHARMFUL":[{"def":"Abounding with charms.","pos":""}],"CHARMING":[{"def":"Pleasing the mind or senses in a high degree; delighting; fascinating; attractive.","pos":""}],"CHARMLESS":[{"def":"Destitute of charms.","pos":""},{"def":"A sort of sweet wine.","pos":""}],"CHARNEL":[{"def":"Containing the bodies of the dead.","pos":""}],"CHARON":[{"def":"The son of Erebus and Nox, whose office it was to ferry the souls of the dead over the Styx, a river of the infernal regions.","pos":""}],"CHARPIE":[{"def":"Straight threads obtained by unraveling old linen cloth; -- used for surgical dressings.","pos":""}],"CHARQUI":[{"def":"Jerked beef; beef cut into long strips and dried in the wind and sun.","pos":""}],"CHARRAS":[{"def":"The gum resin of the hemp plant (Cannabis sativa).","pos":""}],"CHARRY":[{"def":"Pertaining to charcoal, or partaking of its qualities.","pos":""}],"CHART":[{"def":"A sheet of paper, pasteboard, or the like, on which information is exhibited, esp.","pos":""}],"CHARTACEOUS":[{"def":"Resembling paper or parchment; of paper-like texture; papery.","pos":""}],"CHARTE":[{"def":"The constitution, or fundamental law, of the French monarchy, as established on the restoration of Louis XVIII.","pos":""}],"CHARTER":[{"def":"The letting or hiring a vessel by special contract, or the contract or instrument whereby a vessel is hired or let; as, a ship is offered for sale or charter.","pos":""}],"CHARTERED":[{"def":"Granted or established by charter; having, or existing under, a charter; having a privilege by charter.","pos":""},{"def":"Hired or let by charter, as a ship.","pos":""}],"CHARTERER":[{"def":"One who charters; esp.","pos":""}],"CHARTERHOUSE":[{"def":"A well known public school and charitable foundation in the building once used as a Carthusian monastery (Chartreuse) in London.","pos":""}],"CHARTERIST":[{"def":"Same as Chartist.","pos":""}],"CHARTISM":[{"def":"The principles of a political party in England (1838-48), which contended for universal suffrage, the vote by ballot, annual parliaments, equal electoral districts, and other radical reforms, as set forth in a document called the People's Charter.","pos":""}],"CHARTIST":[{"def":"A supporter or partisan of chartism.","pos":""}],"CHARTLESS":[{"def":"Same as Cartographer, Cartographic, Cartography, etc.","pos":""}],"CHARTOMANCY":[{"def":"Divination by written paper or by cards.","pos":""}],"CHARTOMETER":[{"def":"An instrument for measuring charts or maps.","pos":""}],"CHARTREUSE":[{"def":"A Carthusian monastery; esp.","pos":""},{"def":"An alcoholic cordial, distilled from aromatic herbs; -- made at La Grande Chartreuse.","pos":""}],"CHARWOMAN":[{"def":"A woman hired for odd work or for single days.","pos":""}],"CHARY":[{"def":"Careful; wary; cautious; not rash, reckless, or spendthrift; saving; frugal.","pos":""}],"CHARYBDIS":[{"def":"A dangerous whirlpool on the coast of Sicily opposite Scylla on the Italian coast.","pos":""}]}