{"BUM":[{"def":"To make murmuring or humming sound.","pos":""}],"BUMBAILIFF":[{"def":"See Bound bailiff, under Bound, a.","pos":""}],"BUMBELO":[{"def":"A glass used in subliming camphor.","pos":""}],"BUMBLE":[{"def":"To make a hollow or humming noise, like that of a bumblebee; to cry as a bittern.","pos":""}],"BUMBLEBEE":[{"def":"A large bee of the genus Bombus, sometimes called humblebee; -- so named from its sound.","pos":"verb"}],"BUMBLEPUPPY":[{"def":"The old game of nineholes.","pos":""}],"BUMBOAT":[{"def":"A clumsy boat, used for conveying provisions, fruit, etc.","pos":""}],"BUMKIN":[{"def":"A projecting beam or boom; as: (a) One projecting from each bow of a vessel, to haul the fore tack to, called a tack bumpkin.","pos":""}],"BUMMALO":[{"def":"A small marine Asiatic fish (Saurus ophidon) used in India as a relish; -- called also Bombay duck.","pos":""}],"BUMMER":[{"def":"An idle, worthless fellow, who is without any visible means of support; a dissipated sponger.","pos":""}],"BUMMERY":[{"def":"There was a scivener of Wapping brought to hearing for relief against a bummery bond.","pos":""}],"BUMP":[{"def":"To strike, as with or against anything large or solid; to thump; as, to bump the head against a wall.","pos":"verb"}],"BUMPER":[{"def":"A cup or glass filled to the brim, or till the liquor runs over, particularly in drinking a health or toast.","pos":""},{"def":"A covered house at a theater, etc.","pos":""}],"BUMPKIN":[{"def":"An awkward, heavy country fellow; a clown; a country lout.","pos":""}],"BUMPTIOUS":[{"def":"Self-conceited; forward; pushing.","pos":""}],"BUMPTIOUSNESS":[{"def":"A slightly sweetened raised cake or bisquit with a glazing of sugar and milk on the top crust.","pos":""}]}