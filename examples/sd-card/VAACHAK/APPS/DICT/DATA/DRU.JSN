{"DRUB":[{"def":"To beat with a stick; to thrash; to cudgel.","pos":""}],"DRUDGE":[{"def":"To perform menial work; to labor in mean or unpleasant offices with toil and fatigue.","pos":""}],"DRUDGER":[{"def":"One who drudges; a drudge.","pos":""}],"DRUDGERY":[{"def":"The act of drudging; disagreeable and wearisome labor; ignoble or slavish toil.","pos":""}],"DRUDGING BOX":[{"def":"See Dredging box.","pos":""}],"DRUDGINGLY":[{"def":"In a drudging manner; laboriously.","pos":""}],"DRUERY":[{"def":"Courtship; gallantry; love; an object of love.","pos":""}],"DRUG":[{"def":"To drudge; to toil laboriously.","pos":""}],"DRUGGIST":[{"def":"One who deals in drugs; especially, one who buys and sells drugs without compounding them; also, a pharmaceutist or apothecary.","pos":""}],"DRUID":[{"def":"One of an order of priests which in ancient times existed among certain branches of the Celtic race, especially among the Gauls and Britons.","pos":""},{"def":"A member of a social and benevolent order, founded in London in 1781, and professedly based on the traditions of the ancient Druids.","pos":""}],"DRUIDESS":[{"def":"A female Druid; a prophetess.","pos":""},{"def":"Pertaining to, or resembling, the Druids.","pos":""}],"DRUIDISM":[{"def":"The system of religion, philosophy, and instruction, received and taught by the Druids; the rites and ceremonies of the Druids.","pos":""}],"DRUM":[{"def":"One of the cylindrical, or nearly cylindrical, blocks, of which the shaft of a column is composed; also, a vertical wall, whether circular or polygonal in plan, carrying a cupola or dome.","pos":""}],"DRUM MAJOR":[{"def":"The chief or first drummer of a regiment; an instructor of drummers.","pos":""},{"def":"The marching leader of a military band.","pos":""}],"DRUM WINDING":[{"def":"A method of armature winding in which the wire is wound upon the outer surface of a cylinder or drum from end to end of the cylinder; -- distinguished from ring winding, etc.","pos":""}],"DRUMBEAT":[{"def":"The sound of a beaten drum; drum music.","pos":""}],"DRUMBLE":[{"def":"To be sluggish or lazy; to be confused.","pos":""},{"def":"To mumble in speaking.","pos":""}],"DRUMFISH":[{"def":"any fish of the family Sciænidæ, which makes a loud noise by means of its air bladder; -- called also drum.","pos":""}],"DRUMHEAD":[{"def":"The parchment or skin stretched over one end of a drum.","pos":""},{"def":"The top of a capstan which is pierced with sockets for levers used in turning it.","pos":""}],"DRUMLIN":[{"def":"A hill of compact, unstratified, glacial drift or till, usually elongate or oval, with the larger axis parallel to the former local glacial motion.","pos":""}],"DRUMMER":[{"def":"A fish that makes a sound when caught; as: (a) The squeteague.","pos":""},{"def":"A large West Indian cockroach (Blatta gigantea) which drums on woodwork, as a sexual call.","pos":""}],"DRUMMING":[{"def":"The act of beating upon, or as if upon, a drum; also, the noise which the male of the ruffed grouse makes in spring, by beating his wings upon his sides.","pos":""}],"DRUMMOND LIGHT":[{"def":"A very intense light, produced by turning two streams of gas, one oxygen and the other hydrogen, or coal gas, in a state of ignition, upon a ball of lime; or a stream of oxygen gas through a flame of alcohol upon a ball or disk of lime; -- called also oxycalcium light, or lime light.","pos":""}],"DRUMSTICK":[{"def":"A stick with which a drum is beaten.","pos":""},{"def":"Anything resembling a drumstick in form, as the tibiotarsus, or second joint, of the leg of a fowl.","pos":""}],"DRUNK":[{"def":"Intoxicated with, or as with, strong drink; inebriated; drunken; - - never used attributively, but always predicatively; as, the man is drunk (not, a drunk man).","pos":""},{"def":"Drenched or saturated with moisture or liquid.","pos":""}],"DRUNKARD":[{"def":"One who habitually drinks strong liquors immoderately; one whose habit it is to get drunk; a toper; a sot.","pos":""}],"DRUNKEN":[{"def":"Overcome by strong drink; intoxicated by, or as by, spirituous liquor; inebriated.","pos":""},{"def":"Saturated with liquid or moisture; drenched.","pos":""}],"DRUNKENLY":[{"def":"In a drunken manner.","pos":""}],"DRUNKENNESS":[{"def":"The state of being drunk; drunkenness.","pos":""}],"DRUPACEOUS":[{"def":"Producing, or pertaining to, drupes; having the form of drupes; as, drupaceous trees or fruits.","pos":""}],"DRUPE":[{"def":"A fruit consisting of pulpy, coriaceous, or fibrous exocarp, without valves, containing a nut or stone with a kernel.","pos":""},{"def":"A small drupe, as one of the pulpy grains of the blackberry.","pos":""}],"DRUSE":[{"def":"A cavity in a rock, having its interior surface studded with crystals and sometimes filled with water; a geode.","pos":""}]}