{"HOUGH":[{"def":"Same as Hock, a joint.","pos":""}],"HOULT":[{"def":"A piece of woodland; a small wood.","pos":""}],"HOUND":[{"def":"A variety of the domestic dog, usually having large, drooping ears, esp.","pos":""}],"HOUND'S-TONGUE":[{"def":"A biennial weed (Cynoglossum officinale), with soft tongue- shaped leaves, and an offensive odor.","pos":""}],"HOUNDFISH":[{"def":"Any small shark of the genus Galeus or Mustelus, of which there are several species, as the smooth houndfish (G.","pos":""}],"HOUNDING":[{"def":"The part of a mast below the hounds and above the deck.","pos":""}],"HOUR":[{"def":"Certain prayers to be repeated at stated times of the day, as matins and vespers.","pos":""}],"HOURGLASS":[{"def":"An instrument for measuring time, especially the interval of an hour.","pos":""}],"HOURI":[{"def":"A nymph of paradise; -- so called by the Mohammedans.","pos":""}],"HOURLY":[{"def":"Happening or done every hour; occurring hour by hour; frequent; often repeated; renewed hour by hour; continual.","pos":""}],"HOURS":[{"def":"Goddess of the seasons, or of the hours of the day.","pos":""}],"HOUSAGE":[{"def":"A fee for keeping goods in a house.","pos":""}],"HOUSE":[{"def":"A firm, or commercial establishment.","pos":""},{"def":"A twelfth part of the heavens, as divided by six circles intersecting at the north and south points of the horizon, used by astrologers in noting the positions of the heavenly bodies, and casting horoscopes or nativities.","pos":""}],"HOUSEBOTE":[{"def":"Wood allowed to a tenant for repairing the house and for fuel.","pos":""}],"HOUSEBREAKER":[{"def":"One who is guilty of the crime of housebreaking.","pos":""}],"HOUSEBREAKING":[{"def":"The act of breaking open and entering, with a felonious purpose, the dwelling house of another, whether done by day or night.","pos":""}],"HOUSEBUILDER":[{"def":"One whose business is to build houses; a housewright.","pos":""}],"HOUSECARL":[{"def":"A household servant; also, one of the bodyguard of King Canute.","pos":""}],"HOUSEHOLD":[{"def":"Those who dwell under the same roof and compose a family.","pos":""},{"def":"A line of ancestory; a race or house.","pos":""}],"HOUSEHOLDER":[{"def":"The master or head of a family; one who occupies a house with his family.","pos":""}],"HOUSEKEEPER":[{"def":"One who occupies a house with his family; a householder; the master or mistress of a family.","pos":""},{"def":"One who does, or oversees, the work of keeping house; as, his wife is a good housekeeper; often, a woman hired to superintend the servants of a household and manage the ordinary domestic affairs.","pos":""}],"HOUSEKEEPING":[{"def":"The state of being occupying a dwelling house as a householder.","pos":""},{"def":"Care of domestic concerns; management of a house and home affairs.","pos":""}],"HOUSEL":[{"def":"To administer the eucharist to.","pos":""}],"HOUSELEEK":[{"def":"A succulent plant of the genus Sempervivum (S.","pos":""}],"HOUSELESS":[{"def":"Destitute of the shelter of a house; shelterless; homeless; as, a houseless wanderer.","pos":""}],"HOUSELESSNESS":[{"def":"The state of being houseless.","pos":""}],"HOUSELINE":[{"def":"A small line of three strands used for seizing; -- called also housing.","pos":""}],"HOUSELING":[{"def":"Same as Housling.","pos":""}],"HOUSEMAID":[{"def":"A female servant employed to do housework, esp.","pos":""}],"HOUSEMATE":[{"def":"One who dwells in the same house with another.","pos":""}],"HOUSEROOM":[{"def":"Room or place in a house; as, to give any one houseroom.","pos":""}],"HOUSEWARMING":[{"def":"A feast or merry-making made by or for a family or business firm on taking possession of a new house or premises.","pos":""}],"HOUSEWIFE":[{"def":"A little case or bag for materials used in sewing, and for other articles of female work; -- called also hussy.","pos":""},{"def":"To manage with skill and economy, as a housewife or other female manager; to economize.","pos":""}],"HOUSEWIFELY":[{"def":"Pertaining or appropriate to a housewife; domestic; economical; prudent.","pos":""}],"HOUSEWIFERY":[{"def":"The business of the mistress of a family; female management of domestic concerns.","pos":""}],"HOUSEWORK":[{"def":"The work belonging to housekeeping; especially, kitchen work, sweeping, scrubbing, bed making, and the like.","pos":""}],"HOUSEWRIGHT":[{"def":"A builder of houses.","pos":""}],"HOUSING":[{"def":"A frame or support for holding something in place, as journal boxes, etc.","pos":""}],"HOUSLING":[{"def":"Sacramental; as, housling fire.","pos":""}],"HOUSS":[{"def":"A saddlecloth; a housing.","pos":""}],"HOUSTONIA":[{"def":"A genus of small rubiaceous herbs, having tetramerous salveform blue or white flower.","pos":""}],"HOUTOU":[{"def":"A beautiful South American motmot.","pos":""}],"HOUVE":[{"def":"A head covering of various kinds; a hood; a coif; a cap.","pos":""}],"HOUYHNHNM":[{"def":"One of the race of horses described by Swift in his imaginary travels of Lemuel Gulliver.","pos":""}]}