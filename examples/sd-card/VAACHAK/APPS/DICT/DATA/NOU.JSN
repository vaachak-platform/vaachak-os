{"NOUCH":[{"def":"An ouch; a jewel.","pos":""}],"NOUGAT":[{"def":"A cake, sweetmeat, or confectión made with almonds or other nuts.","pos":""}],"NOULE":[{"def":"The top of the head; the head or noll.","pos":""}],"NOUMENAL":[{"def":"Of or pertaining to the noumenon; real; -- opposed to phenomenal.","pos":""}],"NOUMENON":[{"def":"The of itself unknown and unknowable rational object, or thing in itself, which is distinguished from the Ant: phenomenon through which it is apprehended by the senses, and by which it is interpreted and understood; -- so used in the philosophy of Kant and his followers.","pos":""}],"NOUN":[{"def":"A word used as the designation or appellation of a creature or thing, existing in fact or in thought; a substantive.","pos":""}],"NOUNAL":[{"def":"Of or pertaining to a noun.","pos":""}],"NOUNIZE":[{"def":"To change (an adjective, verb, etc.","pos":""}],"NOURISH":[{"def":"To feed and cause to grow; to supply with matter which increases bulk or supplies waste, and promotes health; to furnish with nutriment.","pos":""},{"def":"To support; to maintain.","pos":""}],"NOURISHABLE":[{"def":"Capable of being nourished; as, the nourishable parts of the body.","pos":""},{"def":"Capable of giving nourishment.","pos":""}],"NOURISHER":[{"def":"One who, or that which, nourishes.","pos":""}],"NOURISHINGLY":[{"def":"Nutritively; cherishingly.","pos":""}],"NOURISHMENT":[{"def":"The act of nourishing, or the state of being nourished; nutrition.","pos":""},{"def":"That which serves to nourish; nutriment; food.","pos":""}],"NOURSLE":[{"def":"To nurse; to rear; to bring up.","pos":""}],"NOUS":[{"def":"Intellect; understanding; talent; -- used humorously.","pos":""},{"def":"To insnare; to entrap.","pos":""}]}