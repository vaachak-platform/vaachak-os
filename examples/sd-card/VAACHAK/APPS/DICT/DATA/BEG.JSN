{"BEG":[{"def":"A title of honor in Turkey and in some other parts of the East; a bey.","pos":""}],"BEGEM":[{"def":"To adorn with gems, or as with gems.","pos":""}],"BEGET":[{"def":"To procreate, as a father or sire; to generate; -- commonly said of the father.","pos":""},{"def":"To get (with child.","pos":""}],"BEGETTER":[{"def":"One who begets; a father.","pos":""}],"BEGGABLE":[{"def":"Capable of being begged.","pos":""}],"BEGGAR":[{"def":"One who begs; one who asks or entreats earnestly, or with humility; a petitioner.","pos":""},{"def":"One who makes it his business to ask alms.","pos":""}],"BEGGAR'S LICE":[{"def":"The prickly fruit or seed of certain plants (as some species of Echinospermum and Cynoglossum) which cling to the clothing of those who brush by them.","pos":""}],"BEGGAR'S TICKS":[{"def":"The bur marigold (Bidens) and its achenes, which are armed with barbed awns, and adhere to clothing and fleeces with unpleasant tenacity.","pos":""}],"BEGGARHOOD":[{"def":"The condition of being a beggar; also, the class of beggars.","pos":""}],"BEGGARLINESS":[{"def":"The quality or state of being beggarly; meanness.","pos":""}],"BEGGARLY":[{"def":"In the condition of, or like, a beggar; suitable for a beggar; extremely indigent; poverty-stricken; mean; poor; contemptible.","pos":""},{"def":"Produced or occasioned by beggary.","pos":""}],"BEGGARY":[{"def":"The act of begging; the state of being a beggar; mendicancy; extreme poverty.","pos":""},{"def":"Beggarly appearance.","pos":""}],"BEGGESTERE":[{"def":"One of an association of religious laymen living in imitation of the Beguines.","pos":""}],"BEGIN":[{"def":"To have or commence an independent or first existence; to take rise; to commence.","pos":""},{"def":"To do the first act or the first part of an action; to enter upon or commence something new, as a new form or state of being, or course of action; to take the first step; to start.","pos":""}],"BEGINNER":[{"def":"One who begins or originates anything.","pos":""}],"BEGINNING":[{"def":"The act of doing that which begins anything; commencement of an action, state, or space of time; entrance into being or upon a course; the first act, effort, or state of a succession of acts or states.","pos":""},{"def":"That which begins or originates something; the first cause; origin; source.","pos":""}],"BEGIRD":[{"def":"To bind with a band or girdle; to gird.","pos":""},{"def":"To surround as with a band; to encompass.","pos":""}],"BEGIRDLE":[{"def":"To surround as with a girdle.","pos":""}],"BEGIRT":[{"def":"To encompass; to begird.","pos":""}],"BEGLERBEG":[{"def":"The governor of a province of the Ottoman empire, next in dignity to the grand vizier.","pos":""}],"BEGNAW":[{"def":"To gnaw; to eat away; to corrode.","pos":""}],"BEGOD":[{"def":"To exalt to the dignity of a god; to deify.","pos":""}],"BEGOHM":[{"def":"A unit of resistance equal to one billion ohms, or one thousand megohms.","pos":""}],"BEGONE":[{"def":"Go away; depart; get you gone.","pos":""}],"BEGONIA":[{"def":"A genus of plants, mostly of tropical America, many species of which are grown as ornamental plants.","pos":""}],"BEGORE":[{"def":"To besmear with gore.","pos":""}],"BEGOT":[{"def":"Be*got\", Defn: imp.","pos":""}],"BEGOTTEN":[{"def":"Be*got\"ten, Defn: p.","pos":""}],"BEGRAVE":[{"def":"To bury; also, to engrave.","pos":""}],"BEGREASE":[{"def":"To soil or daub with grease or other oily matter.","pos":""}],"BEGRIME":[{"def":"To soil with grime or dirt deeply impressed or rubbed in.","pos":""}],"BEGRIMER":[{"def":"One who, or that which, begrimes.","pos":""}],"BEGRUDGE":[{"def":"To grudge; to envy the possession of.","pos":""}],"BEGUILE":[{"def":"To delude by guile, artifice, or craft; to deceive or impose on, as by a false statement; to lure.","pos":""},{"def":"To elude, or evade by craft; to foil.","pos":""}],"BEGUILEMENT":[{"def":"The act of beguiling, or the state of being beguiled.","pos":""}],"BEGUILER":[{"def":"One who, or that which, beguiles.","pos":""}],"BEGUILING":[{"def":"Alluring by guile; deluding; misleading; diverting.","pos":""}],"BEGUINAGE":[{"def":"A collection of small houses surrounded by a wall and occupied by a community of Beguines.","pos":""}],"BEGUINE":[{"def":"A woman belonging to one of the religious and charitable associations or communities in the Netherlands, and elsewhere, whose members live in beguinages and are not bound by perpetual vows.","pos":""}],"BEGUM":[{"def":"In the East Indies, a princess or lady of high rank.","pos":""}]}