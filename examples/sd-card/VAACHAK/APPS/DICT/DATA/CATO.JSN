{"CATO-CATHARTIC":[{"def":"A remedy that purges by alvine discharges.","pos":""}],"CATONIAN":[{"def":"Of, pertaining to, or resembling, the stern old Roman, Cato the Censor; severe; inflexible.","pos":""}],"CATOPRON":[{"def":"A reflecting optical glass or instrument; a mirror.","pos":""}],"CATOPTRICS":[{"def":"That part of optics which explants the properties and phenomena of reflected light, and particularly that which is reflected from mirrors or polished bodies; --- formerly caled anacamptics.","pos":""}],"CATOPTROMANCY":[{"def":"A species of divination, which was perforned by letting down a mirror into water, for a sick person to look at his face in it.","pos":""}]}