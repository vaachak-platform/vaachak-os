{"VOUCH":[{"def":"To call into court to warrant and defend, or to make good a warranty of title.","pos":""}],"VOUCHEE":[{"def":"The person who is vouched, or called into court to support or make good his warranty of title in the process of common recovery.","pos":""}],"VOUCHER":[{"def":"One who vouches, or gives witness or full attestation, to anything.","pos":""}],"VOUCHMENT":[{"def":"A solemn assertion.","pos":""}],"VOUCHOR":[{"def":"Same as Voucher, 3 (b).","pos":""}],"VOUCHSAFE":[{"def":"To condescend to grant; to concede; to bestow.","pos":""},{"def":"To receive or accept in condescension.","pos":""}],"VOUCHSAFEMENT":[{"def":"The act of vouchsafing, or that which is vouchsafed; a gift or grant in condescension.","pos":""}],"VOUSSOIR":[{"def":"One of the wedgelike stones of which an arch is composed.","pos":""}]}