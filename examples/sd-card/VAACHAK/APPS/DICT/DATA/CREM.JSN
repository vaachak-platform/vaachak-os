{"CREMAILLERE":[{"def":"An indented or zigzaged line of intrenchment.","pos":""}],"CREMASTER":[{"def":"A thin muscle which serves to draw up the testicle.","pos":""},{"def":"The apex of the last abdominal segment of an insect.","pos":""}],"CREMASTERIC":[{"def":"Of or pertaining to the cremaster; as, the cremasteric artery.","pos":""}],"CREMATE":[{"def":"To burn; to reduce to ashes by the action of fire, either directly or in an oven or retort; to incremate or incinerate; as, to cremate a corpse, instead of burying it.","pos":""}],"CREMATION":[{"def":"Cre*ma\"tion (kr-m\"shn), n.","pos":""}],"CREMATIONIST":[{"def":"One who advocates the practice of cremation.","pos":""}],"CREMATOR":[{"def":"One who, or that which, cremmates or consumes to ashes.","pos":""},{"def":"A furnace for cremating corpses; a building containing such a furnace.","pos":""}],"CREMATORY":[{"def":"Pertaining to, or employed in, cremation.","pos":""}],"CREME":[{"def":"Cream; -- a term used esp.","pos":""}],"CREMOCARP":[{"def":"The peculiar fruit of fennel, carrott, parsnip, and the like, consisting of a pair of carpels pendent from a supporting axis.","pos":""}],"CREMONA":[{"def":"A superior kind of violin, formerly made at Cremona, in Italy.","pos":""}],"CREMOR":[{"def":"Cream; a substance resembling cream; yeast; scum.","pos":""}],"CREMOSIN":[{"def":"Crem\"o*sin (krm\"-sn), n.","pos":""}],"CREMS":[{"def":"Having the margin cut into rounded teeth notches, or scallops.","pos":""}]}