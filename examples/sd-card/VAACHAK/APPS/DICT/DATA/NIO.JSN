{"NIOBATE":[{"def":"Same as Columbate.","pos":""}],"NIOBE":[{"def":"The daughter of Tantalus, and wife of Amphion, king of Thebes.","pos":""}],"NIOBIC":[{"def":"Same as Columbic.","pos":""}],"NIOBITE":[{"def":"Same as Columbite.","pos":""}],"NIOBIUM":[{"def":"A later name of columbium.","pos":""}],"NIOPO":[{"def":"A kind of snuff prepared by the natives of Venezuela from the roasted seeds of a leguminous tree (Piptadenia peregrina), thence called niopo tree.","pos":""}]}