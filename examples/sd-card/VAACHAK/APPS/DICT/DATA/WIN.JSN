{"WIN":[{"def":"To extract, as ore or coal.","pos":""}],"WINCE":[{"def":"To shrink, as from a blow, or from pain; to flinch; to start back.","pos":""},{"def":"To kick or flounce when unsteady, or impatient at a rider; as, a horse winces.","pos":""}],"WINCER":[{"def":"One who, or that which, winces, shrinks, or kicks.","pos":""}],"WINCH":[{"def":"To wince; to shrink; to kick with impatience or uneasiness.","pos":""}],"WINCING":[{"def":"The act of washing cloth, dipping it in dye, etc.","pos":""}],"WINCOPIPE":[{"def":"A little red flower, no doubt the pimpernel, which, when it opens in the morning, is supposed to bode a fair day.","pos":""}],"WIND":[{"def":"To turn completely, or with repeated turns; especially, to turn about something fixed; to cause to form convolutions about anything; to coil; to twine; to twist; to wreathe; as, to wind thread on a spool or into a ball.","pos":""},{"def":"To entwist; to infold; to encircle.","pos":""}],"WIND SIGNAL":[{"def":"In general, any signal announcing information concerning winds, and esp.","pos":""}],"WIND-BREAK":[{"def":"To break the wind of; to cause to lose breath; to exhaust.","pos":""}],"WIND-BROKEN":[{"def":"Having the power of breathing impaired by the rupture, dilatation, or running together of air cells of the lungs, so that while the inspiration is by one effort, the expiration is by two; affected with pulmonary emphysema or with heaves; -- said of a horse.","pos":""}],"WIND-FERTILIZED":[{"def":"Anemophilous; fertilized by pollen borne by the wind.","pos":""}],"WIND-RODE":[{"def":"Caused to ride or drive by the wind in opposition to the course of the tide; -- said of a vessel lying at anchor, with wind and tide opposed to each other.","pos":""}],"WIND-SHAKEN":[{"def":"Shaken by the wind; specif.","pos":""},{"def":"affected by wind shake, or anemosis (which see, above).","pos":""}],"WIND-SUCKING":[{"def":"A vicious habit of a horse, consisting in the swallowing of air; -- usually associated with crib-biting, or cribbing.","pos":""}],"WIND-UP":[{"def":"Act of winding up, or closing; a concluding act or part; the end.","pos":""}],"WINDAGE":[{"def":"The difference between the diameter of the bore of a gun and that of the shot fired from it.","pos":""}],"WINDAS":[{"def":"See 3d Windlass.","pos":""}],"WINDBORE":[{"def":"The lower, or bottom, pipe in a lift of pumps in a mine.","pos":""}],"WINDBOUND":[{"def":"prevented from sailing, by a contrary wind.","pos":""}],"WINDER":[{"def":"One in a flight of steps which are curved in plan, so that each tread is broader at one end than at the other; -- distinguished from flyer.","pos":""}],"WINDFALL":[{"def":"Anything blown down or off by the wind, as fruit from a tree, or the tree itself, or a portion of a forest prostrated by a violent wind, etc.","pos":""},{"def":"An unexpected legacy, or other gain.","pos":""}],"WINDFALLEN":[{"def":"Blown down by the wind.","pos":""}],"WINDFLOWER":[{"def":"The anemone; -- so called because formerly supposed to open only when the wind was blowing.","pos":""}],"WINDGALL":[{"def":"A soft tumor or synovial swelling on the fetlock joint of a horse; -- so called from having formerly been supposed to contain air.","pos":""}],"WINDHOVER":[{"def":"The kestrel; -- called also windbibber, windcuffer, windfanner.","pos":""}],"WINDINESS":[{"def":"The quality or state of being windy or tempestuous; as, the windiness of the weather or the season.","pos":""},{"def":"Fullness of wind; flatulence.","pos":""}],"WINDING":[{"def":"A call by the boatswain's whistle.","pos":""}],"WINDINGLY":[{"def":"In a winding manner.","pos":""}],"WINDJAMMER":[{"def":"An army bugler or trumpeter; any performer on a wind instrument.","pos":""}],"WINDLASS":[{"def":"A winding and circuitous way; a roundabout course; a shift.","pos":"noun"}],"WINDLE":[{"def":"A spindle; a kind of reel; a winch.","pos":""}],"WINDLESS":[{"def":"A grass used for making ropes or for plaiting, esp.","pos":""}],"WINDMILL":[{"def":"A mill operated by the power of the wind, usually by the action of the wind upon oblique vanes or sails which radiate from a horizontal shaft.","pos":""}],"WINDOW":[{"def":"The shutter, casement, sash with its fittings, or other framework, which closes a window opening.","pos":""}],"WINDOWED":[{"def":"Having windows or openings.","pos":""}],"WINDOWLESS":[{"def":"Destitute of a window.","pos":""}],"WINDOWPANE":[{"def":"A thin, spotted American turbot (Pleuronectes maculatus) remarkable for its translucency.","pos":""}],"WINDOWY":[{"def":"Having little crossings or openings like the sashes of a window.","pos":""}],"WINDPIPE":[{"def":"The passage for the breath from the larynx to the lungs; the trachea; the weasand.","pos":""}],"WINDROW":[{"def":"A row or line of hay raked together for the purpose of being rolled into cocks or heaps.","pos":""},{"def":"Sheaves of grain set up in a row, one against another, that the wind may blow between them.","pos":""}],"WINDSOR":[{"def":"A town in Berkshire, England.","pos":""}],"WINDSTORM":[{"def":"A storm characterized by high wind with little or no rain.","pos":""}],"WINDTIGHT":[{"def":"So tight as to prevent the passing through of wind.","pos":""}],"WINDWARD":[{"def":"The point or side from which the wind blows; as, to ply to the windward; -- opposed to Ant: leeward.","pos":""}],"WINDY":[{"def":"Consisting of wind; accompanied or characterized by wind; exposed to wind.","pos":""},{"def":"Next the wind; windward.","pos":""}],"WINE":[{"def":"The expressed juice of grapes, esp.","pos":""},{"def":"A liquor or beverage prepared from the juice of any fruit or plant by a process similar to that for grape wine; as, currant wine; gooseberry wine; palm wine.","pos":""}],"WINEBIBBER":[{"def":"One who drinks much wine.","pos":""}],"WINEGLASS":[{"def":"A small glass from to drink wine.","pos":""}],"WINEGLASSFUL":[{"def":"As much as a wineglass will hold; enough to fill a wineglass.","pos":""}],"WINELESS":[{"def":"destitute of wine; as, wineless life.","pos":""}],"WINERY":[{"def":"A place where grapes are converted into wine.","pos":""}],"WINESAP":[{"def":"A variety of winter apple of medium size, deep red color, and yellowish flesh of a rich, rather subacid flavor.","pos":""}],"WING":[{"def":"One of the broad, thin, anterior lobes of the foot of a pteropod, used as an organ in swimming.","pos":""},{"def":"The right or left division of an army, regiment, etc.","pos":""}],"WING-FOOTED":[{"def":"Having wings attached to the feet; as, wing-footed Mercury; hence, swift; moving with rapidity; fleet.","pos":""}],"WING-HANDED":[{"def":"Having the anterior limbs or hands adapted for flight, as the bats and pterodactyls.","pos":""}],"WING-LEAVED":[{"def":"Having pinnate or pinnately divided leaves.","pos":""}],"WINGED":[{"def":"Furnished with a leaflike appendage, as the fruit of the elm and the ash, or the stem in certain plants; alate.","pos":""},{"def":"Represented with wings, or having wings, of a different tincture from the body.","pos":""}],"WINGER":[{"def":"One of the casks stowed in the wings of a vessel's hold, being smaller than such as are stowed more amidships.","pos":""}],"WINGFISH":[{"def":"A sea robin having large, winglike pectoral fins.","pos":""}],"WINGLESS":[{"def":"Having no wings; not able to ascend or fly.","pos":""}],"WINGLET":[{"def":"A bastard wing, or alula.","pos":""}],"WINGMANSHIP":[{"def":"Power or skill in flying.","pos":""}],"WINGY":[{"def":"Having wings; rapid.","pos":""},{"def":"Soaring with wings, or as if with wings; volatile airy.","pos":""}],"WINK":[{"def":"To nod; to sleep; to nap.","pos":""},{"def":"To shut the eyes quickly; to close the eyelids with a quick motion.","pos":""}],"WINKER":[{"def":"A horse's blinder; a blinker.","pos":""}],"WINKINGLY":[{"def":"In a winking manner; with the eye almost closed.","pos":""}],"WINKLE":[{"def":"States, either of two species of Fulgar (F.","pos":""}],"WINKLE-HAWK":[{"def":"A rectangular rent made in cloth; -- called also winkle-hole.","pos":""}],"WINNEBAGOES":[{"def":"A tribe of North American Indians who originally occupied the region about Green Bay, Lake Michigan, but were driven back from the lake and nearly exterminated in 1640 by the IIlinnois.","pos":""}],"WINNER":[{"def":"One who wins, or gains by success in competition, contest, or gaming.","pos":""}],"WINNING":[{"def":"Attracting; adapted to gain favor; charming; as, a winning address.","pos":""}],"WINNINGLY":[{"def":"In a winning manner.","pos":""}],"WINNINGNESS":[{"def":"The quality or state of being winning.","pos":""}],"WINNINISH":[{"def":"The land-locked variety of the common salmon.","pos":""}],"WINNOW":[{"def":"To separate, and drive off, the chaff from by means of wind; to fan; as, to winnow grain.","pos":""},{"def":"To sift, as for the purpose of separating falsehood from truth; to separate, as had from good.","pos":""}],"WINNOWER":[{"def":"One who, or that which, winnows; specifically, a winnowing machine.","pos":""}],"WINNOWING":[{"def":"The act of one who, or that which, winnows.","pos":""}],"WINSOME":[{"def":"Cheerful; merry; gay; light-hearted.","pos":""},{"def":"Causing joy or pleasure; gladsome; pleasant.","pos":""}],"WINSOMENESS":[{"def":"The characteristic of being winsome; attractiveness of manner.","pos":""}],"WINTER":[{"def":"The season of the year in which the sun shines most obliquely upon any region; the coldest season of the year.","pos":""},{"def":"The period of decay, old age, death, or the like.","pos":""}],"WINTER'S BARK":[{"def":"The aromatic bark of tree (Drimys, or Drymis, Winteri) of the Magnolia family, which is found in Southern Chili.","pos":""}],"WINTER-BEATEN":[{"def":"Beaten or harassed by the severe weather of winter.","pos":""}],"WINTER-GROUND":[{"def":"To coved over in the season of winter, as for protection or shelter; as, to winter-ground the roods of a plant.","pos":""}],"WINTER-PROUD":[{"def":"Having too rank or forward a growth for winter.","pos":""}],"WINTER-RIG":[{"def":"To fallow or till in winter.","pos":""}],"WINTERGREEN":[{"def":"A plant which keeps its leaves green through the winter.","pos":""}],"WINTERKILL":[{"def":"To kill by the cold, or exposure to the inclemency of winter; as, the wheat was winterkilled.","pos":""}],"WINTERLY":[{"def":"Like winter; wintry; cold; hence, disagreeable, cheerless; as, winterly news.","pos":""}],"WINTERWEED":[{"def":"A kind of speedwell (Veronica hederifolia) which spreads chiefly in winter.","pos":""}],"WINTRY":[{"def":"Suitable to winter; resembling winter, or what belongs to winter; brumal; hyemal; cold; stormy; wintery.","pos":""}],"WINY":[{"def":"Having the taste or qualities of wine; vinous; as, grapes of a winy taste.","pos":""}],"WINZE":[{"def":"A small shaft sunk from one level to another, as for the purpose of ventilation.","pos":""}]}