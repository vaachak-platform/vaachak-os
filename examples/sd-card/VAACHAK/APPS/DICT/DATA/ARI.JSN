{"ARIA":[{"def":"An air or song; a melody; a tune.","pos":""}],"ARIAN":[{"def":"Pertaining to Arius, a presbyter of the church of Alexandria, in the fourth century, or to the doctrines of Arius, who held Christ to be inferior to God the Father in nature and dignity, though the first and noblest of all created beings.","pos":""},{"def":"One who adheres to or believes the doctrines of Arius.","pos":""}],"ARIANISM":[{"def":"The doctrines of the Arians.","pos":""}],"ARIANIZE":[{"def":"To admit or accept the tenets of the Arians; to become an Arian.","pos":""}],"ARICINE":[{"def":"An alkaloid, first found in white cinchona bark.","pos":""}],"ARID":[{"def":"Exhausted of moisture; parched with heat; dry; barren.","pos":""}],"ARIDITY":[{"def":"The state or quality of being arid or without moisture; dryness.","pos":""}],"ARIDNESS":[{"def":"Aridity; dryness.","pos":""},{"def":"A variety of the gazelle (Antilope, or Gazella, dorcas), found in Arabia and adjacent countries.","pos":""}],"ARIES":[{"def":"A battering-ram.","pos":""}],"ARIETATE":[{"def":"To butt, as a ram.","pos":""}],"ARIETATION":[{"def":"A short aria, or air.","pos":""}],"ARIGHT":[{"def":"Rightly; correctly; in a right way or form; without mistake or crime; as, to worship God aright.","pos":""},{"def":"A exterior covering, forming a false coat or appendage to a seed, as the loose, transparent bag inclosing the seed or the white water lily.","pos":""}],"ARILLODE":[{"def":"A false aril; an aril originating from the micropyle instead of from the funicle or chalaza of the ovule.","pos":""}],"ARIOLATION":[{"def":"A soothsaying; a foretelling.","pos":""}],"ARIOSE":[{"def":"Characterized by melody, as distinguished from harmony.","pos":""}],"ARIOSO":[{"def":"In the smooth and melodious style of an air; ariose.","pos":""}],"ARISE":[{"def":"To come up from a lower to a higher position; to come above the horizon; to come up from one's bed or place of repose; to mount; to ascend; to rise; as, to arise from a kneeling posture; a cloud arose; the sun ariseth; he arose early in the morning.","pos":""},{"def":"To spring up; to come into action, being, or notice; to become operative, sensible, or visible; to begin to act a part; to present itself; as, the waves of the sea arose; a persecution arose; the wrath of the king shall arise.","pos":""}],"ARIST":[{"def":"of Arise, for ariseth.","pos":""}],"ARISTARCH":[{"def":"A severe critic.","pos":""}],"ARISTARCHIAN":[{"def":"Severely critical.","pos":""}],"ARISTARCHY":[{"def":"Severely criticism.","pos":""}],"ARISTATE":[{"def":"Having a pointed, beardlike process, as the glumes of wheat; awned.","pos":""},{"def":"Having a slender, sharp, or spinelike tip.","pos":""}],"ARISTOCRACY":[{"def":"Government by the best citizens.","pos":""},{"def":"A ruling body composed of the best citizens.","pos":""}],"ARISTOCRAT":[{"def":"One of the aristocracy or people of rank in a community; one of a ruling class; a noble.","pos":""},{"def":"One who is overbearing in his temper or habits; a proud or haughty person.","pos":""}],"ARISTOCRATISM":[{"def":"The principles of aristocrats.","pos":""},{"def":"Aristocrats, collectively.","pos":""}],"ARISTOLOGY":[{"def":"The science of dining.","pos":""}],"ARISTOPHANIC":[{"def":"Of or pertaining to Aristophanes, the Athenian comic poet.","pos":""}],"ARISTOTELIAN":[{"def":"Of or pertaining to Aristotle, the famous Greek philosopher (384-322 b.","pos":""},{"def":"A follower of Aristotle; a Peripatetic.","pos":""}],"ARISTOTELIANISM":[{"def":"The philosophy of Aristotle, otherwise called the Peripatetic philosophy.","pos":""}],"ARISTOTELIC":[{"def":"Pertaining to Aristotle or to his philosophy.","pos":""}],"ARISTOTLE'S LANTERN":[{"def":"The five united jaws and accessory ossicles of certain sea urchins.","pos":""}],"ARISTULATE":[{"def":"Pertaining a short beard or awn.","pos":""}],"ARITHMANCY":[{"def":"Divination by means of numbers.","pos":""}],"ARITHMETIC":[{"def":"The science of numbers; the art of computation by figures.","pos":""},{"def":"A book containing the principles of this science.","pos":""}],"ARITHMETICAL":[{"def":"Of or pertaining to arithmetic; according to the rules or method of arithmetic.","pos":""}],"ARITHMETICALLY":[{"def":"Conformably to the principles or methods of arithmetic.","pos":""}],"ARITHMETICIAN":[{"def":"One skilled in arithmetic.","pos":""}],"ARITHMOMETER":[{"def":"A calculating machine.","pos":""}]}