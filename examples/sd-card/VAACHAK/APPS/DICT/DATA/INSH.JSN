{"INSHADED":[{"def":"Marked with different shades.","pos":""}],"INSHAVE":[{"def":"A plane for shaving or dressing the concave or inside faces of barrel staves.","pos":""}],"INSHEATHE":[{"def":"To insert as in a sheath; to sheathe.","pos":""}],"INSHELL":[{"def":"To hide in a shell.","pos":""}],"INSHORE":[{"def":"Being near or moving towards the shore; as, inshore fisheries; inshore currents.","pos":""},{"def":"Towards the shore; as, the boat was headed inshore.","pos":""}]}