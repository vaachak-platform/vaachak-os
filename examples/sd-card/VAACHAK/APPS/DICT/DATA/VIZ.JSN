{"VIZ":[{"def":"To wit; that is; namely.","pos":""}],"VIZARD":[{"def":"A mask; a visor.","pos":""}],"VIZARDED":[{"def":"Wearing a vizard.","pos":""}],"VIZCACHA":[{"def":"Same as Viscacha.","pos":""}],"VIZIER":[{"def":"A councilor of state; a high executive officer in Turkey and other Oriental countries.","pos":""}],"VIZIERATE":[{"def":"The office, dignity, or authority of a vizier.","pos":""}],"VIZIERIAL":[{"def":"Of, pertaining to, or issued by, a vizier.","pos":""}]}