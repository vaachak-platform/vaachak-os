{"DELACERATION":[{"def":"A tearing in pieces.","pos":""}],"DELACRYMATION":[{"def":"An involuntary discharge of watery humors from the eyes; wateriness of the eyes.","pos":""}],"DELACTATION":[{"def":"The act of weaning.","pos":""}],"DELAINE":[{"def":"A kind of fabric for women's dresses.","pos":""}],"DELAMINATION":[{"def":"Formation and separation of laminæ or layers; one of the methods by which the various blastodermic layers of the ovum are differentiated.","pos":""}],"DELAPSE":[{"def":"To pass down by inheritance; to lapse.","pos":""}],"DELAPSION":[{"def":"A falling down, or out of place; prolapsion.","pos":""}],"DELASSATION":[{"def":"Able to continue without delassation.","pos":""}],"DELATE":[{"def":"To carry; to convey.","pos":""},{"def":"To carry abroad; to spread; to make public.","pos":""}],"DELATION":[{"def":"Accusation by an informer.","pos":""}],"DELATOR":[{"def":"An accuser; an informer.","pos":""}],"DELAWARE":[{"def":"An American grape, with compact bunches of small, amber-colored berries, sweet and of a good flavor.","pos":""}],"DELAWARES":[{"def":"A tribe of Indians formerly inhabiting the valley of the Delaware River, but now mostly located in the Indian Territory.","pos":""}],"DELAY":[{"def":"A putting off or deferring; procrastination; lingering inactivity; stop; detention; hindrance.","pos":""}],"DELAYER":[{"def":"One who delays; one who lingers.","pos":""}]}