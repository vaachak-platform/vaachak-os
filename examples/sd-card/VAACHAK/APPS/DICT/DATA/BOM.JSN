{"BOM":[{"def":"A large American serpent, so called from the sound it makes.","pos":""}],"BOMB":[{"def":"A great noise; a hollow sound.","pos":""}],"BOMBACE":[{"def":"Cotton; padding.","pos":""}],"BOMBARD":[{"def":"A piece of heavy ordnance formerly used for throwing stones and other ponderous missiles.","pos":""},{"def":"Padded breeches.","pos":""}],"BOMBARDMAN":[{"def":"One who carried liquor or beer in a can or bombard.","pos":""}],"BOMBARDMENT":[{"def":"An attack upon a fortress or fortified town, with shells, hot shot, rockets, etc.","pos":""},{"def":"Originally, a deep-toned instrument of the oboe or bassoon family; thence, a bass reed stop on the organ.","pos":""}],"BOMBASINE":[{"def":"Same as Bombazine.","pos":""}],"BOMBAST":[{"def":"Originally, cotton, or cotton wool.","pos":""},{"def":"Cotton, or any soft, fibrous material, used as stuffing for garments; stuffing; padding.","pos":""}],"BOMBASTRY":[{"def":"Swelling words without much meaning; bombastic language; fustian.","pos":""}],"BOMBAX":[{"def":"A genus of trees, called also the silkcotton tree; also, a tree of the genus Bombax.","pos":""},{"def":"A sort of thin woolen cloth.","pos":""}],"BOMBAZINE":[{"def":"A twilled fabric for dresses, of which the warp is silk, and the weft worsted.","pos":""}],"BOMBIC":[{"def":"Pertaining to, or obtained from, the silkworm; as, bombic acid.","pos":""}],"BOMBILATE":[{"def":"To hum; to buzz.","pos":""}],"BOMBILATION":[{"def":"A humming sound; a booming.","pos":""}],"BOMBINATE":[{"def":"To hum; to boom.","pos":""}],"BOMBINATION":[{"def":"A humming or buzzing.","pos":""}],"BOMBOLO":[{"def":"A thin spheroidal glass retort or flask, used in the sublimation of camphor.","pos":""}],"BOMBPROOF":[{"def":"Secure against the explosive force of bombs.","pos":""},{"def":"A structure which heavy shot and shell will not penetrate.","pos":""}],"BOMBYCID":[{"def":"Like or pertaining to the genus Bombyx, or the family Bombycidæ.","pos":""}],"BOMBYCINOUS":[{"def":"Silken; made of silk.","pos":""},{"def":"Being of the color of the silkworm; transparent with a yellow tint.","pos":""}],"BOMBYLIOUS":[{"def":"Buzzing, like a bumblebee; as, the bombylious noise of the horse fly.","pos":""}],"BOMBYX":[{"def":"A genus of moths, which includes the silkworm moth.","pos":""}]}