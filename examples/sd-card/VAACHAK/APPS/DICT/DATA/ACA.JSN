{"ACACIA":[{"def":"A roll or bag, filled with dust, borne by Byzantine emperors, as a memento of mortality.","pos":""}],"ACADEMIAN":[{"def":"A member of an academy, university, or college.","pos":""}],"ACADEMIC":[{"def":"One holding the philosophy of Socrates and Plato; a Platonist.","pos":""},{"def":"A member of an academy, college, or university; an academician.","pos":""}],"ACADEMICALLY":[{"def":"In an academical manner.","pos":""}],"ACADEMICALS":[{"def":"The articles of dress prescribed and worn at some colleges and universities.","pos":""}],"ACADEMICIAN":[{"def":"A member of an academy, or society for promoting science, art, or literature, as of the French Academy, or the Royal Academy of arts.","pos":""}],"ACADEMICISM":[{"def":"A tenet of the Academic philosophy.","pos":""},{"def":"A mannerism or mode peculiar to an academy.","pos":""}],"ACADEMISM":[{"def":"The doctrines of the Academic philosophy.","pos":""}],"ACADEMIST":[{"def":"An Academic philosopher.","pos":""}],"ACADEMY":[{"def":"A garden or grove near Athens (so named from the hero Academus), where Plato and his followers held their philosophical conferences; hence, the school of philosophy of which Plato was head.","pos":""},{"def":"An institution for the study of higher learning; a college or a university.","pos":""}],"ACADIAN":[{"def":"Of or pertaining to Acadie, or Nova Scotia.","pos":""},{"def":"A native of Acadie.","pos":""}],"ACAJOU":[{"def":"One of the Acalephæ.","pos":""}],"ACALEPHAE":[{"def":"A group of Coelenterata, including the Medusæ or jellyfishes, and hydroids; -- so called from the stinging power they possess.","pos":""}],"ACALEPHOID":[{"def":"Belonging to or resembling the Acalephæ or jellyfishes.","pos":""},{"def":"Without a calyx, or outer floral envelope.","pos":""}],"ACANTH":[{"def":"Same as Acanthus.","pos":""}],"ACANTHA":[{"def":"A spine or prickly fin.","pos":""}],"ACANTHACEOUS":[{"def":"Of, pertaining to, or resembling, the family of plants of which the acanthus is the type.","pos":""}],"ACANTHINE":[{"def":"Of, pertaining to, or resembling, the plant acanthus.","pos":""}],"ACANTHOCARPOUS":[{"def":"Having the fruit covered with spines.","pos":""}],"ACANTHOCEPHALA":[{"def":"A group of intestinal worms, having the proboscis armed with recurved spines.","pos":""}],"ACANTHOCEPHALOUS":[{"def":"Having a spiny head, as one of the Acanthocephala.","pos":""}],"ACANTHOPHOROUS":[{"def":"Ac`an*thoph\"o*rous, a.","pos":""}],"ACANTHOPODIOUS":[{"def":"Having spinous petioles.","pos":""}],"ACANTHOPTERI":[{"def":"A group of teleostean fishes having spiny fins.","pos":""}],"ACANTHOPTEROUS":[{"def":"Acanthopterygious.","pos":""}],"ACANTHOPTERYGIAN":[{"def":"Belonging to the order of fishes having spinose fins, as the perch.","pos":""},{"def":"A spiny-finned fish.","pos":""}],"ACANTHOPTERYGII":[{"def":"An order of fishes having some of the rays of the dorsal, ventral, and anal fins unarticulated and spinelike, as the perch.","pos":""}],"ACANTHOPTERYGIOUS":[{"def":"Having fins in which the rays are hard and spinelike; spiny- finned.","pos":""}],"ACANTHUS":[{"def":"A genus of herbaceous prickly plants, found in the south of Europe, Asia Minor, and India; bear's-breech.","pos":""},{"def":"An ornament resembling the foliage or leaves of the acanthus (Acanthus spinosus); -- used in the capitals of the Corinthian and Composite orders.","pos":""}],"ACAPSULAR":[{"def":"Having no capsule.","pos":""}],"ACARDIAC":[{"def":"Without a heart; as, an acardiac fetus.","pos":""}],"ACARIDAN":[{"def":"One of a group of arachnids, including the mites and ticks.","pos":""}],"ACARINA":[{"def":"The group of Arachnida which includes the mites and ticks.","pos":""}],"ACARINE":[{"def":"Of or caused by acari or mites; as, acarine diseases.","pos":""}],"ACAROID":[{"def":"Shaped like or resembling a mite.","pos":""}],"ACARPELLOUS":[{"def":"Having no carpels.","pos":""}],"ACARPOUS":[{"def":"Not producing fruit; unfruitful.","pos":""}],"ACARUS":[{"def":"A genus including many species of small mites.","pos":""}],"ACATALECTIC":[{"def":"Not defective; complete; as, an acatalectic verse.","pos":""},{"def":"A verse which has the complete number of feet and syllables.","pos":""}],"ACATALEPSY":[{"def":"Incomprehensibility of things; the doctrine held by the ancient Skeptic philosophers, that human knowledge never amounts to certainty, but only to probability.","pos":""}],"ACATALEPTIC":[{"def":"Incapable of being comprehended; incomprehensible.","pos":""}],"ACAULESCENT":[{"def":"Having no stem or caulis, or only a very short one concealed in the ground.","pos":""}],"ACAULINE":[{"def":"Same as Acaulescent.","pos":""},{"def":"Same as Acaulescent.","pos":""}]}