{"GOD":[{"def":"A being conceived of as possessing supernatural power, and to be propitiated by sacrifice, worship, etc.","pos":""},{"def":"The Supreme Being; the eternal and infinite Spirit, the Creator, and the Sovereign of the universe; Jehovah.","pos":""}],"GOD-FEARING":[{"def":"Having a reverential and loving feeling towards God; religious.","pos":""}],"GODCHILD":[{"def":"One for whom a person becomes sponsor at baptism, and whom he promises to see educated as a Christian; a godson or goddaughter.","pos":""}],"GODDAUGHTER":[{"def":"A female for whom one becomes sponsor at baptism.","pos":""}],"GODDESS":[{"def":"A female god; a divinity, or deity, of the female sex.","pos":""},{"def":"A woman of superior charms or excellence.","pos":""}],"GODE-YEAR":[{"def":"The venereal disease; -- often used as a mild oath.","pos":""}],"GODFATHER":[{"def":"A man who becomes sponsor for a child at baptism, and makes himself a surety for its Christian training and instruction.","pos":""}],"GODHEAD":[{"def":"Godship; deity; divinity; divine nature or essence; godhood.","pos":""},{"def":"The Deity; God; the Supreme Being.","pos":""}],"GODHOOD":[{"def":"Divine nature or essence; deity; godhead.","pos":""}],"GODILD":[{"def":"A corruption of God yield, i.","pos":""}],"GODLESS":[{"def":"Having, or acknowledging, no God; without reverence for God; impious; wicked.","pos":""}],"GODLIKE":[{"def":"Resembling or befitting a god or God; divine; hence, preeminently good; as, godlike virtue.","pos":""}],"GODLINESS":[{"def":"Careful observance of, or conformity to, the laws of God; the state or quality of being godly; piety.","pos":""}],"GODLING":[{"def":"A diminutive god.","pos":""}],"GODLY":[{"def":"Pious; reverencing God, and his character and laws; obedient to the commands of God from love for, and reverence of, his character; conformed to God's law; devout; righteous; as, a godly life.","pos":""}],"GODMOTHER":[{"def":"A woman who becomes sponsor for a child in baptism.","pos":""}],"GODROON":[{"def":"An ornament produced by notching or carving a rounded molding.","pos":""}],"GODSEND":[{"def":"Something sent by God; an unexpected acquisiton or piece of good fortune.","pos":""}],"GODSHIP":[{"def":"The rank or character of a god; deity; divinity; a god or goddess.","pos":""}],"GODSON":[{"def":"A male for whom one has stood sponsor in baptism.","pos":""}],"GODSPEED":[{"def":"Success; prosperous journeying; -- a contraction of the phrase, \"God speed you.","pos":""}],"GODWIT":[{"def":"One of several species of long-billed, wading birds of the genus Limosa, and family Tringidæ.","pos":""}]}