{"HIRCIC":[{"def":"Of, pertaining to, or derived from, mutton suet; -- applied by Chevreul to an oily acid which was obtained from mutton suet, and to which he attributed the peculiar taste and smell of that substance.","pos":""}],"HIRCIN":[{"def":"Goatlike; of or pertaining to a goat or the goats.","pos":""},{"def":"Of a strong goatish smell.","pos":""}],"HIRE":[{"def":"A bailment by which the use of a thing, or the services and labor of a person, are contracted for at a certain price or reward.","pos":""}],"HIRELING":[{"def":"One who is hired, or who serves for wages; esp.","pos":""}],"HIRER":[{"def":"HIRES; HIRS Hires, Hirs, pron.","pos":""}],"HIRSUTE":[{"def":"Pubescent with coarse or stiff hairs.","pos":""},{"def":"Covered with hairlike feathers, as the feet of certain birds.","pos":""}],"HIRTELLOUS":[{"def":"Pubescent with minute and somewhat rigid hairs.","pos":""}],"HIRUDINE":[{"def":"Of or pertaining to the leeches.","pos":""}],"HIRUDINEA":[{"def":"An order of Annelida, including the leeches; -- called also Hirudinei.","pos":""}],"HIRUDO":[{"def":"A genus of leeches, including the common medicinal leech.","pos":""}],"HIRUNDINE":[{"def":"Like or pertaining to the swallows.","pos":""}],"HIRUNDO":[{"def":"A genus of birds including the swallows and martins.","pos":""}]}