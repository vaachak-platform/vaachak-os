{"MILAGE":[{"def":"Same as Mileage.","pos":""}],"MILANESE":[{"def":"Of or pertaining to Milan in Italy, or to its inhabitants.","pos":""},{"def":"A native or inhabitant of Milan; people of Milan.","pos":""}],"MILCH":[{"def":"Giving milk; -- now applied only to beasts.","pos":""},{"def":"Tender; pitiful; weeping.","pos":""}],"MILD":[{"def":"Gentle; pleasant; kind; soft; bland; clement; hence, moderate in degree or quality; -- the opposite of harsh, severe, irritating, violent, disagreeable, etc.","pos":""}],"MILDEN":[{"def":"To make mild, or milder.","pos":""}],"MILDEW":[{"def":"A growth of minute powdery or webby fungi, whitish or of different colors, found on various diseased or decaying substances.","pos":""}],"MILDLY":[{"def":"In a mild manner.","pos":""}],"MILDNESS":[{"def":"The quality or state of being mild; as, mildness of temper; the mildness of the winter.","pos":""}],"MILE":[{"def":"A certain measure of distance, being equivalent in England and the United States to 320 poles or rods, or 5,280 feet.","pos":""}],"MILEAGE":[{"def":"An allowance for traveling expenses at a certain rate per mile.","pos":""},{"def":"Aggregate length or distance in miles; esp.","pos":""}],"MILEPOST":[{"def":"A post, or one of a series of posts, set up to indicate spaces of a mile each or the distance in miles from a given place.","pos":""}],"MILESIAN":[{"def":"Of or pertaining to Miletus, a city of Asia Minor, or to its inhabitants.","pos":""},{"def":"Descended from King Milesius of Spain, whose two sons are said to have conquered Ireland about 1300 b.","pos":""}],"MILESTONE":[{"def":"A stone serving the same purpose as a milepost.","pos":""}],"MILFOIL":[{"def":"A common composite herb (Achillea Millefolium) with white flowers and finely dissected leaves; yarrow.","pos":""}],"MILIARIA":[{"def":"A fever accompanied by an eruption of small, isolated, red pimples, resembling a millet seed in form or size; miliary fever.","pos":""}],"MILIARY":[{"def":"Accompanied with an eruption like millet seeds; as, a miliary fever.","pos":""},{"def":"Small and numerous; as, the miliary tubercles of Echini.","pos":""}],"MILIEU":[{"def":"The intellectual and moral milieu created by multitudes of self- centered, cultivated personalities.","pos":""}],"MILIOLA":[{"def":"A genus of Foraminifera, having a porcelanous shell with several longitudinal chambers.","pos":""}],"MILIOLITE":[{"def":"A fossil shell of, or similar to, the genus Miliola.","pos":""}],"MILIOLITIC":[{"def":"Of or pertaining to the genus Miliola; containing miliolites.","pos":""}],"MILITANCY":[{"def":"The state of being militant; warfare.","pos":""},{"def":"A military spirit or system; militarism.","pos":""}],"MILITANT":[{"def":"Engaged in warfare; fighting; combating; serving as a soldier.","pos":""}],"MILITARILY":[{"def":"In a military manner.","pos":""}],"MILITARISM":[{"def":"A military state or condition; reliance on military force in administering government; a military system.","pos":""},{"def":"The spirit and traditions of military life.","pos":""}],"MILITARY":[{"def":"Of or pertaining to soldiers, to arms, or to war; belonging to, engaged in, or appropriate to, the affairs of war; as, a military parade; military discipline; military bravery; military conduct; military renown.","pos":""},{"def":"Performed or made by soldiers; as, a military election; a military expedition.","pos":""}],"MILITATE":[{"def":"To make war; to fight; to contend; -- usually followed by against and with.","pos":""}],"MILITIA":[{"def":"Military service; warfare.","pos":""}],"MILITIAMAN":[{"def":"One who belongs to the militia.","pos":""}],"MILITIATE":[{"def":"To carry on, or prepare for, war.","pos":""}],"MILK":[{"def":"A white fluid secreted by the mammary glands of female mammals for the nourishment of their young, consisting of minute globules of fat suspended in a solution of casein, albumin, milk sugar, and inorganic salts.","pos":""},{"def":"A kind of juice or sap, usually white in color, found in certain plants; latex.","pos":""}],"MILK SICKNESS":[{"def":"A peculiar malignant disease, occurring in parts of the western United States, and affecting certain kinds of farm stock (esp.","pos":""}],"MILK VETCH":[{"def":"A leguminous herb (Astragalus glycyphyllos) of Europe and Asia, supposed to increase the secretion of milk in goats.","pos":""}],"MILK-LIVERED":[{"def":"White-livered; cowardly; timorous.","pos":""}],"MILKEN":[{"def":"Consisting of milk.","pos":""}],"MILKER":[{"def":"One who milks; also, a mechanical apparatus for milking cows.","pos":""},{"def":"A cow or other animal that gives milk.","pos":""}],"MILKFUL":[{"def":"Full of milk; abounding with food.","pos":""}],"MILKILY":[{"def":"In a milky manner.","pos":""}],"MILKINESS":[{"def":"State or quality of being milky.","pos":""}],"MILKMAID":[{"def":"A woman who milks cows or is employed in the dairy.","pos":""}],"MILKMAN":[{"def":"A man who sells milk or delivers is to customers.","pos":""}],"MILKSOP":[{"def":"A piece of bread sopped in milk; figuratively, an effeminate or weak-minded person.","pos":""}],"MILKWEED":[{"def":"Any plant of the genera Asclepias and Acerates, abounding in a milky juice, and having its seed attached to a long silky down; silkweed.","pos":""}],"MILKWORT":[{"def":"A genus of plants (Polygala) of many species.","pos":""}],"MILKY":[{"def":"Consisting of, or containing, milk.","pos":""},{"def":"Like, or somewhat like, milk; whitish and turbid; as, the water is milky.","pos":""}],"MILL":[{"def":"A money of account of the United States, having the value of the tenth of a cent, or the thousandth of a dollar.","pos":""}],"MILL-CAKE":[{"def":"The incorporated materials for gunpowder, in the form of a dense mass or cake, ready to be subjected to the process of granulation.","pos":""}],"MILL-SIXPENCE":[{"def":"A milled sixpence; -- the sixpence being one of the first English coins milled (1561).","pos":""}],"MILLBOARD":[{"def":"A kind of stout pasteboard.","pos":""}],"MILLDAM":[{"def":"A dam or mound to obstruct a water course, and raise the water to a height sufficient to turn a mill wheel.","pos":""}],"MILLED":[{"def":"Having been subjected to some process of milling.","pos":""}],"MILLEFIORE GLASS":[{"def":"Slender rods or tubes of colored glass fused together and embedded in clear glass; -- used for paperweights and other small articles.","pos":""}],"MILLENARIAN":[{"def":"Consisting of a thousand years; of or pertaining to the millennium, or to the Millenarians.","pos":""}],"MILLENARY":[{"def":"Consisting of a thousand; millennial.","pos":""}],"MILLENNIAL":[{"def":"Of or pertaining to the millennium, or to a thousand years; as, a millennial period; millennial happiness.","pos":""},{"def":"Belief in, or expectation of, the millennium; millenarianism.","pos":""}],"MILLENNIALIST":[{"def":"One who believes that Christ will reign personally on earth a thousand years; a Chiliast; also, a believer in the universal prevalence of Christianity for a long period.","pos":""}],"MILLENNIST":[{"def":"One who believes in the millennium.","pos":""}],"MILLENNIUM":[{"def":"A thousand years; especially, thousand years mentioned in the twentieth chapter in the twentieth chapter of Revelation, during which holiness is to be triumphant throughout the world.","pos":""}],"MILLEPED":[{"def":"A myriapod with many legs, esp.","pos":""}],"MILLEPORA":[{"def":"A genus of Hydrocorallia, which includes the millipores.","pos":""}],"MILLEPORE":[{"def":"Any coral of the genus Millepora, having the surface nearly smooth, and perforated with very minute unequal pores, or cells.","pos":""}],"MILLEPORITE":[{"def":"A fossil millepore.","pos":""}],"MILLER":[{"def":"One who keeps or attends a flour mill or gristmill.","pos":""},{"def":"A milling machine.","pos":""}],"MILLERITE":[{"def":"A believer in the doctrine of William Miller (d.","pos":""}],"MILLESIMAL":[{"def":"Thousandth; consisting of thousandth parts; as, millesimal fractions.","pos":""}],"MILLET":[{"def":"The name of several cereal and forage grasses which bear an abundance of small roundish grains.","pos":""}],"MILLI-":[{"def":"A prefix denoting a thousandth part of; as, millimeter, milligram, milliampère.","pos":""}],"MILLIAMPERE":[{"def":"The thousandth part of one ampère.","pos":""}],"MILLIARD":[{"def":"A thousand millions; -- called also billion.","pos":""}],"MILLIARY":[{"def":"Of or pertaining to a mile, or to distance by miles; denoting a mile or miles.","pos":""}],"MILLIER":[{"def":"A weight of the metric system, being one million grams; a metric ton.","pos":""}],"MILLIFOLD":[{"def":"A measure of weight, in the metric system, being the thousandth part of a gram, equal to the weight of a cubic millimeter of water, or .","pos":""}],"MILLIMICRON":[{"def":"The thousandish part of a micron or the millionth part of a millimeter; -- a unit of length used in measuring light waves, etc.","pos":""}],"MILLINER":[{"def":"Formerly, a man who imported and dealt in small articles of a miscellaneous kind, especially such as please the fancy of women.","pos":""},{"def":"A person, usually a woman, who makes, trims, or deals in hats, bonnets, headdresses, etc.","pos":""}],"MILLINERY":[{"def":"The articles made or sold by milliners, as headdresses, hats or bonnets, laces, ribbons, and the like.","pos":""},{"def":"The business of work of a milliner.","pos":""}],"MILLINET":[{"def":"A stiff cotton fabric used by milliners for lining bonnets.","pos":""}],"MILLING":[{"def":"The act or employment of grinding or passing through a mill; the process of fulling; the process of making a raised or intented edge upon coin, etc.","pos":""}],"MILLION":[{"def":"The number of ten hundred thousand, or a thousand thousand, -- written 1,000, 000.","pos":""},{"def":"A very great number; an indefinitely large number.","pos":""}],"MILLIONAIRE":[{"def":"One whose wealth is counted by millions of francs, dollars, or pounds; a very rich person; a person worth a million or more.","pos":""}],"MILLIONAIRESS":[{"def":"A woman who is a millionaire, or the wife of a millionaire.","pos":""}],"MILLIONARY":[{"def":"Of or pertaining to millions; consisting of millions; as, the millionary chronology of the pundits.","pos":""}],"MILLIONED":[{"def":"Multiplied by millions; innumerable.","pos":""}],"MILLIONTH":[{"def":"Being the last one of a million of units or objects counted in regular order from the first of a series or succession; being one of a million.","pos":""}],"MILLIPED":[{"def":"The same Milleped.","pos":""}],"MILLISTERE":[{"def":"A liter, or cubic decimeter.","pos":""}],"MILLIWEBER":[{"def":"The thousandth part of one weber.","pos":""}],"MILLSTONE":[{"def":"One of two circular stones used for grinding grain or other substance.","pos":""}],"MILLWORK":[{"def":"The shafting, gearing, and other driving machinery of mils.","pos":""},{"def":"The business of setting up or of operating mill machinery.","pos":""}],"MILLWRIGHT":[{"def":"A mechanic whose occupation is to build mills, or to set up their machinery.","pos":""}],"MILREIS":[{"def":"A Portuguese money of account rated in the treasury department of the United States at one dollar and eight cents; also, a Brazilian money of account rated at fifty-four cents and six mills.","pos":""}],"MILT":[{"def":"To impregnate (the roe of a fish) with milt.","pos":""}],"MILTONIC":[{"def":"Of, pertaining to, or resembling, Milton, or his writings; as, Miltonic prose.","pos":""}],"MILTWASTE":[{"def":"A small European fern (Asplenium Ceterach) formerly used in medicine.","pos":""}],"MILVINE":[{"def":"Of or resembling birds of the kite kind.","pos":""}],"MILVUS":[{"def":"A genus of raptorial birds, including the European kite.","pos":""}]}