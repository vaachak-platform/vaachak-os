{"BARACA":[{"def":"An international, interdenominational organization of Bible classes of young men; -- so named in allusion to the Hebrew word Berachah (Meaning blessing) occurring in 2 Chron.","pos":""}],"BARAD":[{"def":"The pressure of one dyne per square centimeter; -- used as a unit of pressure.","pos":""},{"def":"An instrument for determining the delicacy of the sense of pressure.","pos":""}],"BARATHEA":[{"def":"A soft fabric with a kind of basket weave and a diapered pattern.","pos":""}]}