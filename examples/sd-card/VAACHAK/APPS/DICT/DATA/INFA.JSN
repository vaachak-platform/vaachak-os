{"INFABRICATED":[{"def":"Not fabricated; unwrought; not artificial; natural.","pos":""}],"INFALLIBILIST":[{"def":"One who accepts or maintains the dogma of papal infallibility.","pos":""}],"INFALLIBILITY":[{"def":"The quality or state of being infallible, or exempt from error; inerrability.","pos":""}],"INFALLIBLE":[{"def":"Incapable of error in defining doctrines touching faith or morals.","pos":""}],"INFALLIBLENESS":[{"def":"The state or quality of being infallible; infallibility.","pos":""}],"INFALLIBLY":[{"def":"In an infallible manner; certainly; unfailingly; unerringly.","pos":""}],"INFAME":[{"def":"To defame; to make infamous.","pos":""}],"INFAMIZE":[{"def":"To make infamous; to defame.","pos":""}],"INFAMOUS":[{"def":"Branded with infamy by conviction of a crime; as, at common law, an infamous person can not be a witness.","pos":""}],"INFAMOUSLY":[{"def":"In an infamous manner or degree; scandalously; disgracefully; shamefully.","pos":""}],"INFAMOUSNESS":[{"def":"The state or quality of being infamous; infamy.","pos":""}],"INFAMY":[{"def":"That loss of character, or public disgrace, which a convict incurs, and by which he is at common law rendered incompetent as a witness.","pos":""}],"INFANCY":[{"def":"The state or condition of one under age, or under the age of twenty-one years; nonage; minority.","pos":""}],"INFANDOUS":[{"def":"Too odious to be expressed or mentioned.","pos":""}],"INFANGTHEF":[{"def":"The privilege granted to lords of certain manors to judge thieves taken within the seigniory of such lords.","pos":""}],"INFANT":[{"def":"A person who is not of full age, or who has not attained the age of legal capacity; a person under the age of twenty-one years; a minor.","pos":""}],"INFANTA":[{"def":"A title borne by every one of the daughters of the kings of Spain and Portugal, except the eldest.","pos":""}],"INFANTE":[{"def":"A title given to every one of sons of the kings of Spain and Portugal, except the eldest or heir apparent.","pos":""}],"INFANTICIDAL":[{"def":"Of or pertaining to infanticide; engaged in, or guilty of, child murder.","pos":""}],"INFANTICIDE":[{"def":"The murder of an infant born alive; the murder or killing of a newly born or young child; child murder.","pos":""}],"INFANTILE":[{"def":"Of or pertaining to infancy, or to an infant; similar to, or characteristic of, an infant; childish; as, infantile behavior.","pos":""}],"INFANTILE PARALYSIS":[{"def":"An acute disease, almost exclusively infantile, characterized by inflammation of the anterior horns of the gray substance of the spinal cord.","pos":""}],"INFANTINE":[{"def":"Infantile; childish.","pos":""}],"INFANTRY":[{"def":"A body of soldiers serving on foot; foot soldiers, in distinction from cavalry.","pos":""}],"INFARCE":[{"def":"To stuff; to swell.","pos":""}],"INFARCTION":[{"def":"The act of stuffing or filling; an overloading and obstruction of any organ or vessel of the body; constipation.","pos":""}],"INFARE":[{"def":"A house-warming; especially, a reception, party, or entertainment given by a newly married couple, or by the husband upon receiving the wife to his house.","pos":""}],"INFATUATE":[{"def":"To make foolish; to affect with folly; to weaken the intellectual powers of, or to deprive of sound judgment.","pos":""},{"def":"To inspire with a foolish and extravagant passion; as, to be infatuated with gaming.","pos":""}],"INFATUATED":[{"def":"Overcome by some foolish passion or desire; affected by infatuation.","pos":""}],"INFATUATION":[{"def":"The act of infatuating; the state of being infatuated; folly; that which infatuates.","pos":""}],"INFAUST":[{"def":"Not favorable; unlucky; unpropitious; sinister.","pos":""}],"INFAUSTING":[{"def":"The act of making unlucky; misfortune; bad luck.","pos":""}]}