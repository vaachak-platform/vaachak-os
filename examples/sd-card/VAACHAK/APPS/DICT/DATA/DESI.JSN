{"DESICCANT":[{"def":"Drying; desiccative.","pos":""}],"DESICCATE":[{"def":"To dry up; to deprive or exhaust of moisture; to preserve by drying; as, to desiccate fish or fruit.","pos":""}],"DESICCATION":[{"def":"The act of desiccating, or the state of being desiccated.","pos":""}],"DESICCATIVE":[{"def":"Drying; tending to dry.","pos":""},{"def":"An application for drying up secretions.","pos":""}],"DESICCATOR":[{"def":"A short glass jar fitted with an air-tight cover, and containing some desiccating agent, as sulphuric acid or calcium chloride, above which is suspended the material to be dried, or preserved from moisture.","pos":""}],"DESIDERATA":[{"def":"See Desideratum.","pos":""}],"DESIDERATE":[{"def":"To desire; to feel the want of; to lack; to miss; to want.","pos":""}],"DESIDERATION":[{"def":"Act of desiderating; also, the thing desired.","pos":""}],"DESIDERATIVE":[{"def":"Denoting desire; as, desiderative verbs.","pos":""}],"DESIDERATUM":[{"def":"Anything desired; that of which the lack is felt; a want generally felt and acknowledge.","pos":""}],"DESIDIOUSNESS":[{"def":"The state or quality of being desidiose, or indolent.","pos":""}],"DESIGHT":[{"def":"An unsightly object.","pos":""}],"DESIGHTMENT":[{"def":"The act of making unsightly; disfigurement.","pos":""}],"DESIGN":[{"def":"To draw preliminary outline or main features of; to sketch for a pattern or model; to delineate; to trace out; to draw.","pos":""},{"def":"To mark out and exhibit; to designate; to indicate; to show; to point out; to appoint.","pos":""}],"DESIGNABLE":[{"def":"Capable of being designated or distinctly marked out; distinguishable.","pos":""}],"DESIGNATE":[{"def":"Designated; appointed; chosen.","pos":""}],"DESIGNATION":[{"def":"The act of designating; a pointing out or showing; indication.","pos":""},{"def":"Selection and appointment for a purpose; allotment; direction.","pos":""}],"DESIGNATIVE":[{"def":"Serving to designate or indicate; pointing out.","pos":""}],"DESIGNATOR":[{"def":"An officer who assigned to each his rank and place in public shows and ceremonies.","pos":""}],"DESIGNATORY":[{"def":"Serving to designate; designative; indicating.","pos":""}],"DESIGNEDLY":[{"def":"By design; purposely; intentionally; -- opposed to accidentally, ignorantly, or inadvertently.","pos":""}],"DESIGNER":[{"def":"One who produces or creates original works of art or decoration.","pos":""}],"DESIGNFUL":[{"def":"Full of design; scheming.","pos":""}],"DESIGNING":[{"def":"Intriguing; artful; scheming; as, a designing man.","pos":""}],"DESIGNMENT":[{"def":"Delineation; sketch; design; ideal; invention.","pos":""},{"def":"Design; purpose; scheme.","pos":""}],"DESILVER":[{"def":"To deprive of silver; as, to desilver lead.","pos":""}],"DESILVERIZATION":[{"def":"The act or the process of freeing from silver; also, the condition resulting from the removal of silver.","pos":""}],"DESILVERIZE":[{"def":"To deprive, or free from, silver; to remove silver from.","pos":""}],"DESINENCE":[{"def":"Termination; ending.","pos":""}],"DESINENT":[{"def":"Ending; forming an end; lowermost.","pos":""}],"DESINENTIAL":[{"def":"Furthermore, b, as a desinential element, has a dynamic function.","pos":""}],"DESIPIENT":[{"def":"Foolish; silly; trifling.","pos":""}],"DESIRABILITY":[{"def":"The state or quality of being desirable; desirableness.","pos":""}],"DESIRABLE":[{"def":"Worthy of desire or longing; fitted to excite desire or a wish to possess; pleasing; agreeable.","pos":""}],"DESIRABLENESS":[{"def":"The quality of being desirable.","pos":""}],"DESIRABLY":[{"def":"In a desirable manner.","pos":""}],"DESIRE":[{"def":"To long for; to wish for earnestly; to covet.","pos":""},{"def":"To express a wish for; to entreat; to request.","pos":""}],"DESIREFUL":[{"def":"Filled with desire; eager.","pos":""}],"DESIREFULNESS":[{"def":"The state of being desireful; eagerness to obtain and possess.","pos":""}],"DESIRELESS":[{"def":"Free from desire.","pos":""}],"DESIRER":[{"def":"One who desires, asks, or wishes.","pos":""}],"DESIROUS":[{"def":"Feeling desire; eagerly wishing; solicitous; eager to obtain; covetous.","pos":""}],"DESIROUSLY":[{"def":"With desire; eagerly.","pos":""}],"DESIROUSNESS":[{"def":"The state of being desirous.","pos":""}],"DESIST":[{"def":"To cease to proceed or act; to stop; to forbear; -- often with from.","pos":""}],"DESISTANCE":[{"def":"The act or state of desisting; cessation.","pos":""}],"DESISTIVE":[{"def":"Final; conclusive; ending.","pos":""}],"DESITION":[{"def":"An end or ending.","pos":""}],"DESITIVE":[{"def":"Final; serving to complete; conclusive.","pos":""}]}