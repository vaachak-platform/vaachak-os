{"COMMEASURABLE":[{"def":"Having the same measure; commensurate; proportional.","pos":""}],"COMMEASURE":[{"def":"To be commensurate with; to equal.","pos":""}],"COMMEMORABLE":[{"def":"Worthy to be commemorated.","pos":""}],"COMMEMORATE":[{"def":"We are called upon to commemorate a revolution.","pos":""}],"COMMEMORATION":[{"def":"The act of commemorating; an observance or celebration designed to honor the memory of some person or event.","pos":""},{"def":"Whatever serves the purpose of commemorating; a memorial.","pos":""}],"COMMEMORATIVE":[{"def":"Tending or intended to commemorate.","pos":""}],"COMMEMORATOR":[{"def":"One who commemorates.","pos":""}],"COMMEMORATORY":[{"def":"Serving to commemorate; commomerative.","pos":""}],"COMMENCE":[{"def":"To have a beginning or origin; to originate; to start; to begin.","pos":""},{"def":"To begin to be, or to act as.","pos":""}],"COMMENCEMENT":[{"def":"The first existence of anything; act or fact of commencing; rise; origin; beginnig; start.","pos":""},{"def":"The day when degrees are conferred by colleges and universities upon students and others.","pos":""}],"COMMEND":[{"def":"To commit, intrust, or give in charge for care or preservation.","pos":""},{"def":"To recommend as worthy of confidence or regard; to present as worthy of notice or favorable attention.","pos":""}],"COMMENDABLE":[{"def":"Worthy of being commended or praised; laudable; praiseworthy.","pos":""}],"COMMENDAM":[{"def":"A vacant living or benefice commended to a cleric (usually a bishop) who enjoyed the revenue until a pastor was provided.","pos":""}],"COMMENDATARY":[{"def":"One who holds a living in commendam.","pos":""}],"COMMENDATION":[{"def":"A message of affection or respect; compliments; greeting.","pos":""}],"COMMENDATOR":[{"def":"One who holds a benefice in commendam; a commendatary.","pos":""}],"COMMENDATORY":[{"def":"Serving to commend; containing praise or commendation; commending; praising.","pos":""},{"def":"Holding a benefice in commendam; as, a commendatory bishop.","pos":""}],"COMMENDER":[{"def":"One who commends or praises.","pos":""}],"COMMENSAL":[{"def":"An animal, not truly parasitic, which lives in with, or on, another, partaking usually of the same food.","pos":""}],"COMMENSALISM":[{"def":"The act of eating together; table fellowship.","pos":""}],"COMMENSALITY":[{"def":"Fellowship at table; the act or practice of eating at the same table.","pos":""}],"COMMENSURABILITY":[{"def":"The quality of being commersurable.","pos":""}],"COMMENSURABLE":[{"def":"Having a common measure; capable of being exactly measured by the same number, quantity, or measure.","pos":""}],"COMMENSURABLY":[{"def":"In a commensurable manner; so as to be commensurable.","pos":""}],"COMMENSURATE":[{"def":"To reduce to a common measure.","pos":""},{"def":"To proportionate; to adjust.","pos":""}],"COMMENSURATELY":[{"def":"In a commensurate manner; so as to be equal or proportionate; adequately.","pos":""},{"def":"With equal measure or extent.","pos":""}],"COMMENSURATENESS":[{"def":"The state or quality of being commensurate.","pos":""}],"COMMENSURATION":[{"def":"The act of commensurating; the state of being commensurate.","pos":""}],"COMMENT":[{"def":"To make remarks, observations, or criticism; especially, to write notes on the works of an author, with a view to illustrate his meaning, or to explain particular passages; to write annotations; -- often followed by on or upon.","pos":""}],"COMMENTARY":[{"def":"A series of comments or annotations; esp.","pos":""},{"def":"A brief account of transactions or events written hastily, as if for a memorandum; -- usually in the plural; as, Caesar's Commentaries on the Gallic War.","pos":""}],"COMMENTATE":[{"def":"To write comments or notes upon; to make comments.","pos":""}],"COMMENTATION":[{"def":"The act or process of commenting or criticising; exposition.","pos":""},{"def":"The result of the labors of a commentator.","pos":""}],"COMMENTATOR":[{"def":"One who writes a commentary or comments; an expositor; an annotator.","pos":""}],"COMMENTATORIAL":[{"def":"Pertaining to the making of commentaries.","pos":""}],"COMMENTATORSHIP":[{"def":"The office or occupation of a commentator.","pos":""}],"COMMENTER":[{"def":"One who makes or writes comments; a commentator; an annotator.","pos":""}],"COMMENTITIOUS":[{"def":"Fictitious or imaginary; unreal; as, a commentitious system of religion.","pos":""}],"COMMERCE":[{"def":"The exchange or buying and selling of commodities; esp.","pos":""},{"def":"Social intercourse; the dealings of one person or class in society with another; familiarity.","pos":""}],"COMMERCE DESTROYER":[{"def":"A very fast, unarmored, lightly armed vessel designed to capture or destroy merchant vessels of an enemy.","pos":""}],"COMMERCIAL":[{"def":"Of or pertaining to commerce; carrying on or occupied with commerce or trade; mercantile; as, commercial advantages; commercial relations.","pos":""}],"COMMERCIALISM":[{"def":"The commercial spirit or method.","pos":""}],"COMMERCIALLY":[{"def":"In a commercial manner.","pos":""}]}