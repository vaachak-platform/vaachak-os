{"POLYNEME":[{"def":"Any one of numerous species of tropical food fishes of the family Polynemidæ.","pos":""}],"POLYNEMOID":[{"def":"Of or pertaining to the polynemes, or the family Polynemidæ.","pos":""}],"POLYNESIAN":[{"def":"Of or pertaining to Polynesia (the islands of the eastern and central Pacific), or to the Polynesians.","pos":""}],"POLYNESIANS":[{"def":"The race of men native in Polynesia.","pos":""}],"POLYNIA":[{"def":"The open sea supposed to surround the north pole.","pos":""}],"POLYNOMIAL":[{"def":"An expression composed of two or more terms, connected by the signs plus or minus; as, a2 - 2ab + b2.","pos":""}],"POLYNUCLEAR":[{"def":"Containing many nuclei.","pos":""}],"POLYNUCLEOLAR":[{"def":"Having more than one nucleolus.","pos":""}]}