{"ANTIOCHIAN":[{"def":"Pertaining to Antiochus, a contemporary with Cicero, and the founder of a sect of philosophers.","pos":""},{"def":"Of or pertaining to the city of Antioch, in Syria.","pos":""}],"ANTIODONTALGIC":[{"def":"Efficacious in curing toothache.","pos":""},{"def":"A remedy for toothache.","pos":""}],"ANTIORGASTIC":[{"def":"Tending to allay venereal excitement or desire; sedative.","pos":""}]}