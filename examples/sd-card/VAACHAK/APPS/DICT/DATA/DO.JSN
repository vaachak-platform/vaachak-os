{"DO":[{"def":"A syllable attached to the first tone of the major diatonic scale for the purpose of solmization, or solfeggio.","pos":""}],"DO-ALL":[{"def":"General manager; factotum.","pos":""}],"DO-LITTLE":[{"def":"One who performs little though professing much.","pos":""}],"DO-NAUGHT":[{"def":"A lazy, good-for-nothing fellow.","pos":""}],"DO-NOTHING":[{"def":"Doing nothing; inactive; idle; lazy; as, a do-nothing policy.","pos":""},{"def":"Inactivity; habitual sloth; idleness.","pos":""}]}