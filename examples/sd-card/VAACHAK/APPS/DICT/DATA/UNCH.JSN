{"UNCHAIN":[{"def":"To free from chains or slavery; to let loose.","pos":""}],"UNCHANCY":[{"def":"Happening at a bad time; unseasonable; inconvenient.","pos":""},{"def":"Ill-fated; unlucky.","pos":""}],"UNCHAPLAIN":[{"def":"To remove from a chaplaincy.","pos":""}],"UNCHARGE":[{"def":"To free from a charge or load; to unload.","pos":""},{"def":"To free from an accusation; to make no charge against; to acquit.","pos":""}],"UNCHARIOT":[{"def":"To throw out of a chariot.","pos":""}],"UNCHARITABLE":[{"def":"Not charitable; contrary to charity; severe in judging; harsh; censorious; as, uncharitable opinions or zeal.","pos":""}],"UNCHARITY":[{"def":"Uncharitableness.","pos":""}],"UNCHARM":[{"def":"To release from a charm, fascination, or secret power; to disenchant.","pos":""}],"UNCHARNEL":[{"def":"To remove from a charnel house; to raise from the grave; to exhume.","pos":""}],"UNCHASTE":[{"def":"Not chaste; not continent; lewd.","pos":""}],"UNCHASTITY":[{"def":"The quality or state of being unchaste; lewdness; incontinence.","pos":""}],"UNCHECKABLE":[{"def":"Not capable of being checked or stopped.","pos":""}],"UNCHILD":[{"def":"To bereave of children; to make childless.","pos":""},{"def":"To make unlike a child; to divest of the characteristics of a child.","pos":""}],"UNCHRISTEN":[{"def":"To render unchristian.","pos":""}],"UNCHRISTENED":[{"def":"Not christened; as, an unchristened child.","pos":""}],"UNCHRISTIAN":[{"def":"Not Christian; not converted to the Christian faith; infidel.","pos":""},{"def":"Contrary to Christianity; not like or becoming a Christian; as, unchristian conduct.","pos":""}],"UNCHRISTIANIZE":[{"def":"To turn from the Christian faith; to cause to abandon the belief and profession of Christianity.","pos":""}],"UNCHRISTIANLY":[{"def":"In an unchristian manner.","pos":""}],"UNCHRISTIANNESS":[{"def":"The quality or state of being unchristian.","pos":""}],"UNCHURCH":[{"def":"To expel, or cause to separate, from a church; to excommunicate.","pos":""},{"def":"To deprive of the character, privileges, and authority of a church.","pos":""}]}