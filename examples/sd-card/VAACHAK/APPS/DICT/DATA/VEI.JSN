{"VEIL":[{"def":"A covering for a person or thing; as, a nun's veil; a paten veil; an altar veil.","pos":""},{"def":"Same as Velum, 3.","pos":""}],"VEILED":[{"def":"Covered by, or as by, a veil; hidden.","pos":""}],"VEILING":[{"def":"A veil; a thin covering; also, material for making veils.","pos":""}],"VEIN":[{"def":"One of the vessels which carry blood, either venous or arterial, to the heart.","pos":""},{"def":"One of the similar branches of the framework of a leaf.","pos":""}],"VEIN QUARTZ":[{"def":"Quartz occurring as gangue in a vein.","pos":""}],"VEINAL":[{"def":"Pertaining to veins; venous.","pos":""}],"VEINED":[{"def":"Having fibrovascular threads extending throughout the lamina; as, a veined leaf.","pos":""}],"VEINLESS":[{"def":"Having no veins; as, a veinless leaf.","pos":""}],"VEINOUS":[{"def":"Marked with veins; veined; veiny.","pos":""}],"VEINSTONE":[{"def":"The nonmetalliferous mineral or rock material which accompanies the ores in a vein, as quartz, calcite, barite, fluor spar, etc.","pos":""}],"VEINY":[{"def":"Full of veins; veinous; veined; as, veiny marble.","pos":""}]}