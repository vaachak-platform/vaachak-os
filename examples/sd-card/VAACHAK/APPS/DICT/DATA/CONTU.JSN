{"CONTUMACIOUS":[{"def":"Willfully disobedient to the summous or prders of a court.","pos":""}],"CONTUMACY":[{"def":"A willful contempt of, and disobedience to, any lawful summons, or to the rules and orders of court, as a refusal to appear in court when legally summoned.","pos":""}],"CONTUMELIOUS":[{"def":"Exhibiting contumely; rudely contemptuous; insolent; disdainful.","pos":""},{"def":"Shameful; disgraceful.","pos":""}],"CONTUMELY":[{"def":"Rudeness compounded of haughtiness and contempt; scornful insolence; despiteful treatment; disdain; contemptuousness in act or speech; disgrace.","pos":""}],"CONTUSE":[{"def":"To beat, pound, or together.","pos":""},{"def":"To bruise; to injure or disorganize a part without breaking the skin.","pos":""}],"CONTUSION":[{"def":"A bruise; an injury attended with more or less disorganization of the subcutaneous tissue and effusion of blood beneath the skin, but without apparent wound.","pos":""}]}