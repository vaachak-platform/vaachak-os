{"PNEOMETER":[{"def":"Fitted to contain air; Having cavities filled with air; as, pneumatic cells; pneumatic bones.","pos":""}],"PNEUMATICITY":[{"def":"The state of being pneumatic, or of having a cavity or cavities filled with air; as, the pneumaticity of the bones of birds.","pos":""}],"PNEUMATICS":[{"def":"The scientific study or knowledge of spiritual beings and their relations to God, angels, and men.","pos":""}],"PNEUMATO-":[{"def":"A combining form from Gr.","pos":""}],"PNEUMATOCELE":[{"def":"A distention of the scrotum by air; also, hernia of the lungs.","pos":""}],"PNEUMATOCYST":[{"def":"A cyst or sac of a siphonophore, containing air, and serving as a float, as in Physalia.","pos":""}],"PNEUMATOGARM":[{"def":"A tracing of the respiratory movements, obtained by a pneumatograph or stethograph.","pos":""}],"PNEUMATOGRAPH":[{"def":"An instrument for recording the movements of the thorax or chest wall during respiration; -- also called stethograph.","pos":""}],"PNEUMATOLOGICAL":[{"def":"Of or pertaining to pneumatology.","pos":""}],"PNEUMATOLOGIST":[{"def":"One versed in pneumatology.","pos":""}],"PNEUMATOLOGY":[{"def":"The science of spiritual being or phenomena of any description.","pos":""}],"PNEUMATOMETER":[{"def":"An instrument for measuring the amount of force exerted by the lungs in respiration.","pos":""}],"PNEUMATOPHORE":[{"def":"One of the Pneumonophora.","pos":""}],"PNEUMATOTHORAX":[{"def":"See Pneumothorax.","pos":""}],"PNEUMO-":[{"def":"A combining form from Gr.","pos":""}],"PNEUMOCOCCUS":[{"def":"A form of micrococcus found in the sputum (and elsewhere) of persons suffering with pneumonia, and thought to be the cause of this disease.","pos":""}],"PNEUMOGASTRIC":[{"def":"Of or pertaining to the lungs and the stomach.","pos":""},{"def":"The pneumogastric nerve.","pos":""}],"PNEUMOGRAPH":[{"def":"Same as Pneumatograph.","pos":""}],"PNEUMOGRAPHY":[{"def":"A description of the lungs.","pos":""}],"PNEUMOLOGY":[{"def":"The science which treats of the lungs.","pos":""}],"PNEUMOMETRY":[{"def":"Measurement of the capacity of the lungs for air.","pos":""}],"PNEUMONIA":[{"def":"Inflammation of the lungs.","pos":""}],"PNEUMONIC":[{"def":"A medicine for affections of the lungs.","pos":""}],"PNEUMONITIC":[{"def":"Of or pertaining to pneumonitis.","pos":""}],"PNEUMONITIS":[{"def":"Inflammation of the lungs; pneumonia.","pos":""}],"PNEUMONOMETER":[{"def":"A spirometer; a pneumometer.","pos":""}],"PNEUMONOPHORA":[{"def":"The division of Siphonophora which includes the Physalia and allied genera; -- called also Pneumatophoræ.","pos":""}],"PNEUMONY":[{"def":"Same as Sauropsida.","pos":""}],"PNEUMOPHORA":[{"def":"A division of holothurians having an internal gill, or respiratory tree.","pos":""}],"PNEUMOSKELETON":[{"def":"A chitinous structure which supports the gill in some invertebrates.","pos":""}],"PNEUMOTHERAPY":[{"def":"The treatment of disease by inhalations of compressed or rarefied air.","pos":""}],"PNEUMOTHORAX":[{"def":"A condition in which air or other gas is present in the cavity of the chest; -- called also pneumatothorax.","pos":""}],"PNYX":[{"def":"The place at Athens where the meetings of the people were held for making decrees, etc.","pos":""}]}