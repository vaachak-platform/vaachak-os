{"BAUBLE":[{"def":"A trifling piece of finery; a gewgaw; that which is gay and showy without real value; a cheap, showy plaything.","pos":""},{"def":"The fool's club.","pos":""}],"BAUBLING":[{"def":"Bau\"bling Defn: , a.","pos":""}],"BAUDEKIN":[{"def":"The richest kind of stuff used in garments in the Middle Ages, the web being gold, and the woof silk, with embroidery : -- made originally at Bagdad.","pos":""}],"BAUDRICK":[{"def":"BAUK; BAULK Bauk, Baulk, n.","pos":""}],"BAUME":[{"def":"Designating or conforming to either of the scales used by the French chemist Antoine Baumé in the graduation of his hydrometers; of or relating to Baumé's scales or hydrometers.","pos":""}],"BAUNSCHEIDTISM":[{"def":"A form of acupuncture, followed by the rubbing of the part with a stimulating fluid.","pos":""},{"def":"A ferruginous hydrate of alumina.","pos":""}]}