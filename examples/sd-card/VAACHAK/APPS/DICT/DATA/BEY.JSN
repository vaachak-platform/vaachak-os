{"BEY":[{"def":"A governor of a province or district in the Turkish dominions; also, in some places, a prince or nobleman; a beg; as, the bey of Tunis.","pos":""}],"BEYLIC":[{"def":"The territory ruled by a bey.","pos":""}],"BEYOND":[{"def":"On the further side of; in the same direction as, and further on or away than.","pos":""},{"def":"At a place or time not yet reached; before.","pos":""}]}