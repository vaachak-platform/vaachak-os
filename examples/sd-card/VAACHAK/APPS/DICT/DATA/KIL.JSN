{"KILDERKIN":[{"def":"A small barrel; an old liquid measure containing eighteen English beer gallons, or nearly twenty-two gallons, United States measure.","pos":""}],"KILERG":[{"def":"A unit of work equal to one thousand ergs.","pos":""}],"KILKENNY CATS":[{"def":"Two cats fabled, in an Irish story, to have fought till nothing was left but their tails.","pos":""}],"KILL":[{"def":"A channel or arm of the sea; a river; a stream; as, the channel between Staten Island and Bergen Neck is the Kill van Kull, or the Kills; -- used also in composition; as, Schuylkill, Catskill, etc.","pos":""}],"KILL-JOY":[{"def":"One who causes gloom or grief; a dispiriting person.","pos":""}],"KILLER":[{"def":"A voracious, toothed whale of the genus Orca, of which several species are known.","pos":""}],"KILLIFISH":[{"def":"Any one of several small American cyprinodont fishes of the genus Fundulus and allied genera.","pos":""}],"KILLIGREW":[{"def":"The Cornish chough.","pos":""}],"KILLING":[{"def":"Literally, that kills; having power to kill; fatal; in a colloquial sense, conquering; captivating; irresistible.","pos":""}],"KILLOCK":[{"def":"A small anchor; also, a kind of anchor formed by a stone inclosed by pieces of wood fastened together.","pos":""}],"KILLOW":[{"def":"An earth of a blackish or deep blue color.","pos":""}],"KILN":[{"def":"A large stove or oven; a furnace of brick or stone, or a heated chamber, for the purpose of hardening, burning, or drying anything; as, a kiln for baking or hardening earthen vessels; a kiln for drying grain, meal, lumber, etc.","pos":""},{"def":"A furnace for burning bricks; a brickkiln.","pos":""}],"KILN-DRY":[{"def":"To dry in a kiln; as, to kiln-dry meal or grain.","pos":""}],"KILNHOLE":[{"def":"The mouth or opening of an oven or kiln.","pos":""}],"KILO":[{"def":"An abbreviation of Kilogram.","pos":""}],"KILO-":[{"def":"A combining form used to signify thousand in forming the names of units of measurement; as, kilogram, kilometer, kilowatt, etc.","pos":""},{"def":"A measure of weight, being a thousand grams, equal to 2.","pos":""}],"KILOSTERE":[{"def":"A cubic measure containing 1000 cubic meters, and equivalent to 35,315 cubic feet.","pos":""}],"KILOVOLT":[{"def":"A unit of electromotive force equal to one thousand volts.","pos":""}],"KILOWATT":[{"def":"One thousand watts.","pos":""}],"KILOWATT HOUR":[{"def":"A unit of work or energy equal to that done by one kilowatt acting for one hour; --approx.","pos":""}],"KILT":[{"def":"A kind of short petticoat, reaching from the waist to the knees, worn in the Highlands of Scotland by men, and in the Lowlands by young boys; a filibeg.","pos":""}],"KILTED":[{"def":"Having on a kilt.","pos":""},{"def":"Plaited after the manner of kilting.","pos":""}],"KILTING":[{"def":"A perpendicular arrangement of flat, single plaits, each plait being folded so as to cover half the breadth of the preceding one.","pos":""}]}