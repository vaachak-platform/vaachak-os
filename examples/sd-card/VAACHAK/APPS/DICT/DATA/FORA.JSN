{"FORAGE":[{"def":"The act of foraging; search for provisions, etc.","pos":""},{"def":"Food of any kind for animals, especially for horses and cattle, as grass, pasture, hay, corn, oats.","pos":""}],"FORAGER":[{"def":"One who forages.","pos":""}],"FORALITE":[{"def":"A tubelike marking, occuring in sandstone and other strata.","pos":""}],"FORAMEN":[{"def":"A small opening, perforation, or orifice; a fenestra.","pos":""}],"FORAMINATED":[{"def":"Having small opening, or foramina.","pos":""}],"FORAMINIFER":[{"def":"One of the foraminifera.","pos":""}],"FORAMINIFERA":[{"def":"An extensive order of rhizopods which generally have a chambered calcareous shell formed by several united zooids.","pos":""}],"FORAMINIFEROUS":[{"def":"Having small openings, or foramina.","pos":""},{"def":"Pertaining to, or composed of, Foraminifera; as, foraminiferous mud.","pos":""}],"FORAMINOUS":[{"def":"Having foramina; full of holes; porous.","pos":""}],"FORASMUCH":[{"def":"In consideration that; seeing that; since; because that; -- followed by as.","pos":""}],"FORAY":[{"def":"A sudden or irregular incursion in border warfare; hence, any irregular incursion for war or spoils; a raid.","pos":""}],"FORAYER":[{"def":"One who makes or joins in a foray.","pos":""}]}