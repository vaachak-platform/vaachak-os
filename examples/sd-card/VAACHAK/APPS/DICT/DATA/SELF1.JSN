{"SELF":[{"def":"Same; particular; very; identical.","pos":""}],"SELF-ABASED":[{"def":"Humbled by consciousness of inferiority, unworthiness, guilt, or shame.","pos":""}],"SELF-ABASEMENT":[{"def":"Degradation of one's self by one's own act.","pos":""},{"def":"Humiliation or abasement proceeding from consciousness of inferiority, guilt, or shame.","pos":""}],"SELF-ABASING":[{"def":"Lowering or humbling one's self.","pos":""}],"SELF-ABHORRENCE":[{"def":"Abhorrence of one's self.","pos":""}],"SELF-ABNEGATION":[{"def":"Self-denial; self-renunciation; self-sacrifice.","pos":""}],"SELF-ABUSE":[{"def":"The abuse of one's own self, powers, or faculties.","pos":""},{"def":"Self-deception; delusion.","pos":""}],"SELF-ACCUSED":[{"def":"Accused by one's self or by one's conscience.","pos":""}],"SELF-ACTING":[{"def":"Acting of or by one's self or by itself; -- said especially of a machine or mechanism which is made to perform of or for itself what is usually done by human agency; automatic; as, a self-acting feed apparatus; a self-acting mule; a self-acting press.","pos":""}],"SELF-ACTION":[{"def":"Action by, or originating in, one's self or itself.","pos":""}],"SELF-ACTIVE":[{"def":"Acting of one's self or of itself; acting without depending on other agents.","pos":""}],"SELF-ACTIVITY":[{"def":"The quality or state of being self-active; self-action.","pos":""}],"SELF-ADJUSTING":[{"def":"Capable of assuming a desired position or condition with relation to other parts, under varying circumstances, without requiring to be adjusted by hand; -- said of a piece in machinery.","pos":""}],"SELF-ADMIRATION":[{"def":"Admiration of one's self.","pos":""}],"SELF-AFFAIRS":[{"def":"One's own affairs; one's private business.","pos":""}],"SELF-AFFRIGHTED":[{"def":"Frightened at or by one's self.","pos":""}],"SELF-AGGRANDIZEMENT":[{"def":"The aggrandizement of one's self.","pos":""}],"SELF-ANNIHILATED":[{"def":"Annihilated by one's self.","pos":""}],"SELF-ANNIHILATION":[{"def":"Annihilation by one's own acts; annihilation of one's desires.","pos":""}],"SELF-APPLAUSE":[{"def":"Applause of one's self.","pos":""}],"SELF-APPLYING":[{"def":"Applying to or by one's self.","pos":""}],"SELF-APPROVING":[{"def":"Approving one's own action or character by one's own judgment.","pos":""}],"SELF-ASSERTING":[{"def":"asserting one's self, or one's own rights or claims; hence, putting one's self forward in a confident or assuming manner.","pos":""}],"SELF-ASSERTION":[{"def":"The act of asserting one's self, or one's own rights or claims; the quality of being self-asserting.","pos":""}],"SELF-ASSERTIVE":[{"def":"Disposed to self-assertion; self-asserting.","pos":""}],"SELF-ASSUMED":[{"def":"Assumed by one's own act, or without authority.","pos":""}],"SELF-ASSURED":[{"def":"Assured by or of one's self; self-reliant; complacent.","pos":""}],"SELF-BANISHED":[{"def":"Exiled voluntarily.","pos":""}],"SELF-BEGOTTEN":[{"def":"Begotten by one's self, or one's own powers.","pos":""}],"SELF-BINDER":[{"def":"A reaping machine containing mechanism for binding the grain into sheaves.","pos":""}],"SELF-BORN":[{"def":"Born or produced by one's self.","pos":""},{"def":"Centered in itself, or in one's self.","pos":""}],"SELF-CENTRATION":[{"def":"The quality or state of being self-centered.","pos":""}],"SELF-COLOR":[{"def":"A color not mixed or variegated.","pos":""}],"SELF-COLORED":[{"def":"Being of a single color; -- applied to flowers, animals, and textile fabrics.","pos":""}],"SELF-COMMAND":[{"def":"Control over one's own feelings, temper, etc.","pos":""}],"SELF-COMMUNICATIVE":[{"def":"Imparting or communicating by its own powers.","pos":""}],"SELF-COMMUNION":[{"def":"Communion with one's self; thoughts about one's self.","pos":""}],"SELF-COMPLACENCY":[{"def":"The quality of being self-complacent.","pos":""}],"SELF-COMPLACENT":[{"def":"Satisfied with one's own character, capacity, and doings; self- satisfied.","pos":""}],"SELF-CONCEIT":[{"def":"Conceit of one's self; an overweening opinion of one's powers or endowments.","pos":""}],"SELF-CONCEITED":[{"def":"Having an overweening opinion of one's own powers, attainments; vain; conceited.","pos":""}],"SELF-CONCERN":[{"def":"Concern for one's self.","pos":""}],"SELF-CONDEMNATION":[{"def":"Condemnation of one's self by one's own judgment.","pos":""}],"SELF-CONFIDENCE":[{"def":"The quality or state of being self-confident; self-reliance.","pos":""}],"SELF-CONFIDENT":[{"def":"Confident of one's own strength or powers; relying on one's judgment or ability; self-reliant.","pos":""}],"SELF-CONJUGATE":[{"def":"Having the two things that are conjugate parts of the same figure; as, self-conjugate triangles.","pos":""}],"SELF-CONSCIOUS":[{"def":"Conscious of one's acts or state as belonging to, or originating in, one's self.","pos":""},{"def":"Conscious of one's self as an object of the observation of others; as, the speaker was too self-conscious.","pos":""}],"SELF-CONSCIOUSNESS":[{"def":"The quality or state of being self-conscious.","pos":""}],"SELF-CONSIDERING":[{"def":"Considering in one's own mind; deliberating.","pos":""}],"SELF-CONSISTENCY":[{"def":"The quality or state of being self-consistent.","pos":""}],"SELF-CONSISTENT":[{"def":"Consistent with one's self or with itself; not deviation from the ordinary standard by which the conduct is guided; logically consistent throughout; having each part consistent with the rest.","pos":""}],"SELF-CONSUMING":[{"def":"Consuming one's self or itself.","pos":""}],"SELF-CONTAINED":[{"def":"Having all the essential working parts connected by a bedplate or framework, or contained in a case, etc.","pos":""}],"SELF-CONTRADICTION":[{"def":"The act of contradicting one's self or itself; repugnancy in conceptions or in terms; a proposition consisting of two members, one of which contradicts the other; as, to be and not to be at the same time is a self-contradiction.","pos":""}],"SELF-CONTRADICTORY":[{"def":"Contradicting one's self or itself.","pos":""}],"SELF-CONTROL":[{"def":"Control of one's self; restraint exercised over one's self; self-command.","pos":""}],"SELF-CONVICTED":[{"def":"Convicted by one's own consciousness, knowledge, avowal, or acts.","pos":""}],"SELF-CONVICTION":[{"def":"The act of convicting one's self, or the state of being self- convicted.","pos":""}],"SELF-CREATED":[{"def":"Created by one's self; not formed or constituted by another.","pos":""}],"SELF-CULTURE":[{"def":"Culture, training, or education of one's self by one's own efforts.","pos":""}],"SELF-DECEIT":[{"def":"The act of deceiving one's self, or the state of being self- deceived; self-deception.","pos":""}],"SELF-DECEIVED":[{"def":"Deceived or misled respecting one's self by one's own mistake or error.","pos":""}],"SELF-DEFENCE":[{"def":"See Self-defense.","pos":""}],"SELF-DEFENSE":[{"def":"The act of defending one's own person, property, or reputation.","pos":""}],"SELF-DEFENSIVE":[{"def":"Defending, or tending to defend, one's own person, property, or reputation.","pos":""}],"SELF-DEGRADATION":[{"def":"The act of degrading one's self, or the state of being so degraded.","pos":""}],"SELF-DELATION":[{"def":"Accusation of one's self.","pos":""}],"SELF-DELUSION":[{"def":"The act of deluding one's self, or the state of being thus deluded.","pos":""}],"SELF-DENIAL":[{"def":"The denial of one's self; forbearing to gratify one's own desires; self-sacrifice.","pos":""}],"SELF-DENYING":[{"def":"Refusing to gratify one's self; self-sacrificing.","pos":""}],"SELF-DEPENDENT":[{"def":"Dependent on one's self; self-depending; self-reliant.","pos":""}],"SELF-DEPENDING":[{"def":"Depending on one's self.","pos":""}],"SELF-DEPRAVED":[{"def":"Corrupted or depraved by one's self.","pos":""}],"SELF-DESTROYER":[{"def":"One who destroys himself; a suicide.","pos":""}],"SELF-DESTRUCTION":[{"def":"The destruction of one's self; self-murder; suicide.","pos":""}],"SELF-DESTRUCTIVE":[{"def":"Destroying, or tending to destroy, one's self or itself; rucidal.","pos":""}],"SELF-DETERMINATION":[{"def":"Determination by one's self; or, determination of one's acts or states without the necessitating force of motives; -- applied to the voluntary or activity.","pos":""}],"SELF-DETERMINING":[{"def":"Capable of self-determination; as, the self-determining power of will.","pos":""}],"SELF-DEVISED":[{"def":"Devised by one's self.","pos":""}],"SELF-DEVOTED":[{"def":"Devoted in person, or by one's own will.","pos":""}],"SELF-DEVOTEMENT":[{"def":"Self`-de*vote\"ment, n.","pos":""}],"SELF-DEVOTION":[{"def":"The act of devoting one's self, or the state of being self- devoted; willingness to sacrifice one's own advantage or happiness for the sake of others; self-sacrifice.","pos":""}],"SELF-DEVOURING":[{"def":"Devouring one's self or itself.","pos":""}],"SELF-DIFFUSIVE":[{"def":"Having power to diffuse itself; diffusing itself.","pos":""}],"SELF-DISCIPLINE":[{"def":"Correction or government of one's self for the sake of improvement.","pos":""}],"SELF-DISTRUST":[{"def":"Want of confidence in one' self; diffidence.","pos":""}],"SELF-EDUCATED":[{"def":"Educated by one's own efforts, without instruction, or without pecuniary assistance from others.","pos":""}],"SELF-ELECTIVE":[{"def":"Having the right of electing one's self, or, as a body, of electing its own members.","pos":""}],"SELF-ENJOYMENT":[{"def":"Enjoyment of one's self; self-satisfaction.","pos":""}],"SELF-ESTEEM":[{"def":"The holding a good opinion of one's self; self-complacency.","pos":""}],"SELF-ESTIMATION":[{"def":"The act of estimating one's self; self-esteem.","pos":""}],"SELF-EVIDENCE":[{"def":"The quality or state of being self-evident.","pos":""}],"SELF-EVIDENT":[{"def":"Evident without proof or reasoning; producing certainty or conviction upon a bare presentation to the mind; as, a self-evident proposition or truth.","pos":""}],"SELF-EVOLUTION":[{"def":"Evolution of one's self; development by inherent quality or power.","pos":""}],"SELF-EXALTATION":[{"def":"The act of exalting one's self, or the state of being so exalted.","pos":""}],"SELF-EXAMINANT":[{"def":"One who examines himself; one given to self-examination.","pos":""}],"SELF-EXAMINATION":[{"def":"An examination into one's own state, conduct, and motives, particularly in regard to religious feelings and duties.","pos":""}],"SELF-EXCITE":[{"def":"To energize or excite (the field magnets of a dynamo) by induction from the residual magnetism of its cores, leading all or a part of the current thus produced through the field-magnet coils.","pos":""}],"SELF-EXISTENCE":[{"def":"Inherent existence; existence possessed by virtue of a being's own nature, and independent of any other being or cause; -- an attribute peculiar to God.","pos":""}],"SELF-EXISTENT":[{"def":"Existing of or by himself,independent of any other being or cause; -- as, God is the only self-existent being.","pos":""}],"SELF-EXPLAINING":[{"def":"Explaining itself; capable of being understood without explanation.","pos":""}],"SELF-EXPOSURE":[{"def":"The act of exposing one's self; the state of being so exposed.","pos":""}],"SELF-FERTILIZATION":[{"def":"The fertilization of a flower by pollen from the same flower and without outer aid; autogamy.","pos":""}],"SELF-FERTILIZED":[{"def":"Fertilized by pollen from the same flower.","pos":""}],"SELF-GLORIOUS":[{"def":"Springing from vainglory or vanity; vain; boastful.","pos":""}],"SELF-GOVERNMENT":[{"def":"The act of governing one's self, or the state of being governed by one's self; self-control; self-command.","pos":""},{"def":"Hence, government of a community, state, or nation by the joint action of the mass of people constituting such a civil body; also, the state of being so governed; democratic government; democracy.","pos":""}],"SELF-GRATULATION":[{"def":"Gratulation of one's self.","pos":""}],"SELF-HARDENING":[{"def":"Designating, or pert.","pos":""}],"SELF-HEAL":[{"def":"A blue-flowered labiate plant (Brunella vulgaris); the healall.","pos":""}],"SELF-HEALING":[{"def":"Having the power or property of healing itself.","pos":""}],"SELF-HELP":[{"def":"The act of aiding one's self, without depending on the aid of others.","pos":""}],"SELF-HOMICIDE":[{"def":"The act of killing one's self; suicide.","pos":""}],"SELF-IGNORANCE":[{"def":"Ignorance of one's own character, powers, and limitations.","pos":""}],"SELF-IGNORANT":[{"def":"Ignorant of one's self.","pos":""}],"SELF-IMPARTING":[{"def":"Imparting by one's own, or by its own, powers and will.","pos":""}],"SELF-IMPORTANCE":[{"def":"An exaggerated estimate of one's own importance or merit, esp.","pos":""}],"SELF-IMPORTANT":[{"def":"Having or manifesting an exaggerated idea of one's own importance or merit.","pos":""}],"SELF-IMPOSED":[{"def":"Voluntarily taken on one's self; as, self-imposed tasks.","pos":""}],"SELF-IMPOSTURE":[{"def":"Imposture practiced on one's self; self-deceit.","pos":""}],"SELF-INDIGNATION":[{"def":"Indignation at one's own character or actions.","pos":""}],"SELF-INDUCTION":[{"def":"Induction in a circuit due to the action of one portion of a current upon an adjacent portion during periods of varying current strength.","pos":""}],"SELF-INDULGENCE":[{"def":"Indulgence of one's appetites, desires, or inclinations; -- the opposite of self-restraint, and self-denial.","pos":""}],"SELF-INDULGENT":[{"def":"Indulging one's appetites, desires, etc.","pos":""}],"SELF-INTEREST":[{"def":"Private interest; the interest or advantage of one's self.","pos":""}],"SELF-INTERESTED":[{"def":"Particularly concerned for one's own interest or happiness.","pos":""}],"SELF-INVOLUTION":[{"def":"Involution in one's self; hence, abstraction of thought; reverie.","pos":""}],"SELF-JUSTIFIER":[{"def":"One who excuses or justifies himself.","pos":""}],"SELF-KINDLED":[{"def":"Kindled of itself, or without extraneous aid or power.","pos":""}],"SELF-KNOWING":[{"def":"Knowing one's self, or one's own character, powers, and limitations.","pos":""},{"def":"Knowing of itself, without help from another.","pos":""}],"SELF-KNOWLEDGE":[{"def":"Knowledge of one's self, or of one's own character, powers, limitations, etc.","pos":""}],"SELF-LIFE":[{"def":"Life for one's self; living solely or chiefly for one's own pleasure or good.","pos":""}]}