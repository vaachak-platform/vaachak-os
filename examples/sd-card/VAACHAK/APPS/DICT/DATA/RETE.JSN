{"RETE":[{"def":"A net or network; a plexus; particularly, a network of blood vessels or nerves, or a part resembling a network.","pos":""}],"RETECIOUS":[{"def":"Resembling network; retiform.","pos":""}],"RETECTION":[{"def":"Act of disclosing or uncovering something concealed.","pos":""}],"RETENE":[{"def":"A white crystalline hydrocarbon, polymeric with benzene.","pos":""}],"RETENT":[{"def":"That which is retained.","pos":""}],"RETENTION":[{"def":"The right of withholding a debt, or of retaining property until a debt due to the person claiming the right be duly paid; a lien.","pos":""}],"RETENTIVE":[{"def":"Having power to retain; as, a retentive memory.","pos":""}],"RETENTIVELY":[{"def":"In a retentive manner.","pos":""}],"RETENTIVENESS":[{"def":"The quality of being retentive.","pos":""}],"RETENTIVITY":[{"def":"The power of retaining; retentive force; as, the retentivity of a magnet.","pos":""}],"RETENTOR":[{"def":"A muscle which serves to retain an organ or part in place, esp.","pos":""}],"RETEPORE":[{"def":"Any one of several species of bryozoans of the genus Retepora.","pos":""}],"RETEX":[{"def":"To annual, as orders.","pos":""}],"RETEXTURE":[{"def":"The act of weaving or forming again.","pos":""}]}