{"TRAM":[{"def":"A four-wheeled truck running on rails, and used in a mine, as for carrying coal or ore.","pos":""},{"def":"The shaft of a cart.","pos":""}],"TRAMA":[{"def":"The loosely woven substance which lines the chambers within the gleba in certain Gasteromycetes.","pos":""}],"TRAMBLE":[{"def":"To wash, as tin ore, with a shovel in a frame fitted for the purpose.","pos":""}],"TRAMMEL":[{"def":"A kind of net for catching birds, fishes, or other prey.","pos":""},{"def":"A net for confining a woman's hair.","pos":""}],"TRAMMEL WHEEL":[{"def":"A circular plate or a cross, with two or more cross grooves intersecting at the center, used on the end of a shaft to transmit motion to another shaft not in line with the first.","pos":""}],"TRAMMELED":[{"def":"Having blazes, or white marks, on the fore and hind foot of one side, as if marked by trammels; -- said of a horse.","pos":""}],"TRAMMELER":[{"def":"One who uses a trammel net.","pos":""},{"def":"One who, or that which, trammels or restrains.","pos":""}],"TRAMMING":[{"def":"The act or process of forming trams.","pos":""}],"TRAMONTANA":[{"def":"A dry, cold, violent, northerly wind of the Adriatic.","pos":""}],"TRAMONTANE":[{"def":"Lying or being beyond the mountains; coming from the other side of the mountains; hence, foreign; barbarous.","pos":""}],"TRAMP":[{"def":"To tread upon forcibly and repeatedly; to trample.","pos":""},{"def":"To travel or wander through; as, to tramp the country.","pos":""}],"TRAMPER":[{"def":"One who tramps; a stroller; a vagrant or vagabond; a tramp.","pos":""}],"TRAMPLE":[{"def":"To tread under foot; to tread down; to prostrate by treading; as, to trample grass or flowers.","pos":""}],"TRAMPLER":[{"def":"One who tramples; one who treads down; as, a trampler on nature's law.","pos":""}],"TRAMPOOSE":[{"def":"To walk with labor, or heavily; to tramp.","pos":""}],"TRAMRAIL":[{"def":"An overhead rail forming a track on which a trolley runs to convey a load, as in a shop.","pos":""}],"TRAMROAD":[{"def":"A road prepared for easy transit of trams or wagons, by forming the wheel tracks of smooth beams of wood, blocks of stone, or plates of iron.","pos":""}],"TRAMWAY":[{"def":"Same as Tramroad.","pos":""},{"def":"A railway laid in the streets of a town or city, on which cars for passengers or for freight are drawn by horses; a horse railroad.","pos":""}]}