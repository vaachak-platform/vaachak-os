{"TURACIN":[{"def":"A red or crimson pigment obtained from certain feathers of several species of turacou; whence the name.","pos":""}],"TURACOU":[{"def":"Any one of several species of plantain eaters of the genus Turacus, native of Africa.","pos":""}],"TURACOVERDIN":[{"def":"A green pigment found in the feathers of the turacou.","pos":""}],"TURANIAN":[{"def":"Of, pertaining to, or designating, an extensive family of languages of simple structure and low grade (called also Altaic, Ural-Altaic, and Scythian), spoken in the northern parts of Europe and Asia and Central Asia; of pertaining to, or designating, the people who speak these languages.","pos":""}],"TURATT":[{"def":"The hare kangaroo.","pos":""}]}