{"EXCREABLE":[{"def":"Capable of being discharged by spitting.","pos":""}],"EXCREATE":[{"def":"To spit out; to discharge from the throat by hawking and spitting.","pos":""}],"EXCREATION":[{"def":"Act of spitting out.","pos":""}],"EXCREMENT":[{"def":"Matter excreted and ejected; that which is excreted or cast out of the animal body by any of the natural emunctories; especially, alvine, discharges; dung; ordure.","pos":""}],"EXCREMENTAL":[{"def":"Of or pertaining to excrement.","pos":""},{"def":"Pertaining to, or consisting of, excrement; of the nature of excrement.","pos":""}],"EXCREMENTIVE":[{"def":"Serving to excrete; connected with excretion or excrement.","pos":""}],"EXCREMENTIZE":[{"def":"To void excrement.","pos":""}],"EXCRESCENCE":[{"def":"An excrescent appendage, as, a wart or tumor; anything growing out unnaturally from anything else; a preternatural or morbid development; hence, a troublesome superfluity; an incumbrance; as, an excrescence on the body, or on a plant.","pos":""}],"EXCRESCENT":[{"def":"Growing out in an abnormal or morbid manner or as a superfluity.","pos":""}],"EXCRESCENTIAL":[{"def":"Pertaining to, or resembling, an excrescence.","pos":""}],"EXCRETA":[{"def":"Matters to be excreted.","pos":""}],"EXCRETE":[{"def":"To separate and throw off; to excrete urine.","pos":""}],"EXCRETIN":[{"def":"A nonnitrogenous, crystalline body, present in small quantity in human fæces.","pos":""}],"EXCRETION":[{"def":"The act of excreting.","pos":""},{"def":"That which is excreted; excrement.","pos":""}],"EXCRETIVE":[{"def":"Having the power of excreting, or promoting excretion.","pos":""}],"EXCRETORY":[{"def":"Having the quality of excreting, or throwing off excrementitious matter.","pos":""}],"EXCRUCIABLE":[{"def":"Liable to torment.","pos":""}],"EXCRUCIATE":[{"def":"Excruciated; tortured.","pos":""}],"EXCRUCIATING":[{"def":"Ex*cru\"ci*a`ting Defn: .","pos":""}],"EXCRUCIATION":[{"def":"The act of inflicting agonizing pain, or the state of being thus afflicted; that which excruciates; torture.","pos":""}]}