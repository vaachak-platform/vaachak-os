{"NOMAD":[{"def":"One of a race or tribe that has no fixed location, but wanders from place to place in search of pasture or game.","pos":""}],"NOMADIC":[{"def":"Of or pertaining to nomads, or their way of life; wandering; moving from place to place for subsistence; as, a nomadic tribe.","pos":""}],"NOMADISM":[{"def":"The state of being a nomad.","pos":""}],"NOMADIZE":[{"def":"To lead the life of a nomad; to wander with flocks and herds for the sake of finding pasturage.","pos":""}],"NOMANCY":[{"def":"The art or practice of divining the destiny of persons by the letters which form their names.","pos":""}],"NOMARCH":[{"def":"The chief magistrate of a nome or nomarchy.","pos":""}],"NOMARCHY":[{"def":"A province or territorial division of a kingdom, under the rule of a nomarch, as in modern Greece; a nome.","pos":""}],"NOMBLES":[{"def":"The entrails of a deer; the umbles.","pos":""}],"NOMBRIL":[{"def":"A point halfway between the fess point and the middle base point of an escutcheon; -- called also navel point.","pos":""}],"NOME":[{"def":"A province or political division, as of modern Greece or ancient Egypt; a nomarchy.","pos":""},{"def":"Any melody determined by inviolable rules.","pos":""}],"NOMENCLATOR":[{"def":"One who calls persons or things by their names.","pos":""},{"def":"One who gives names to things, or who settles and adjusts the nomenclature of any art or science; also, a list or vocabulary of technical names.","pos":""}],"NOMENCLATRESS":[{"def":"A female nomenclator.","pos":""}],"NOMENCLATURAL":[{"def":"Pertaining or according to a nomenclature.","pos":""}],"NOMENCLATURE":[{"def":"A vocabulary, dictionary, or glossary.","pos":""}],"NOMIC":[{"def":"Customary; ordinary; -- applied to the usual English spelling, in distinction from strictly phonetic methods.","pos":""}],"NOMINAL":[{"def":"Of or pertaining to a name or names; having to do with the literal meaning of a word; verbal; as, a nominal definition.","pos":""},{"def":"Existing in name only; not real; as, a nominal difference.","pos":""}],"NOMINALISM":[{"def":"The principles or philosophy of the Nominalists.","pos":""}],"NOMINALIST":[{"def":"One of a sect of philosophers in the Middle Ages, who adopted the opinion of Roscelin, that general conceptions, or universals, exist in name only.","pos":""}],"NOMINALISTIC":[{"def":"Of or pertaining to the Nominalists.","pos":""}],"NOMINALIZE":[{"def":"To convert into a noun.","pos":""}],"NOMINALLY":[{"def":"In a nominal manner; by name; in name only; not in reality.","pos":""}],"NOMINATE":[{"def":"To mention by name; to name.","pos":""},{"def":"To call; to entitle; to denominate.","pos":""}],"NOMINATELY":[{"def":"By name; particularly; namely.","pos":""}],"NOMINATION":[{"def":"The act of naming or nominating; designation of a person as a candidate for office; the power of nominating; the state of being nominated.","pos":""},{"def":"The denomination, or name.","pos":""}],"NOMINATIVAL":[{"def":"Of or pertaining to the nominative case.","pos":""}],"NOMINATIVE":[{"def":"Giving a name; naming; designating; -- said of that case or form of a noun which stands as the subject of a finite verb.","pos":""},{"def":"The nominative case.","pos":""}],"NOMINATIVELY":[{"def":"In the manner of a nominative; as a nominative.","pos":""}],"NOMINATOR":[{"def":"One who nominates.","pos":""}],"NOMINEE":[{"def":"A person named, or designated, by another, to any office, duty, or position; one nominated, or proposed, by others for office or for election to office.","pos":""}],"NOMOCRACY":[{"def":"Government in accordance with a system of law.","pos":""}],"NOMOGRAPHY":[{"def":"A treatise on laws; an exposition of the form proper for laws.","pos":""}],"NOMOLOGY":[{"def":"The science of law; legislation.","pos":""},{"def":"The science of the laws of the mind; rational psychology.","pos":""}],"NOMOPELMOUS":[{"def":"Having a separate and simple tendon to flex the first toe, or hallux, as do passerine birds.","pos":""}],"NOMOTHETE":[{"def":"Legislative; enacting laws; as, a nomothetical power.","pos":""}]}