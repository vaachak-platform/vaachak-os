{"MINA":[{"def":"An ancient weight or denomination of money, of varying value.","pos":""}],"MINABLE":[{"def":"Such as can be mined; as, minable earth.","pos":""}],"MINACIOUS":[{"def":"Threatening; menacing.","pos":""}],"MINACITY":[{"def":"Disposition to threaten.","pos":""}],"MINARET":[{"def":"A slender, lofty tower attached to a mosque and surrounded by one or more projecting balconies, from which the summon to prayer is cried by the muezzin.","pos":""}],"MINARGENT":[{"def":"An alloy consisting of copper, nickel, tungsten, and aluminium; -- used by jewelers.","pos":""},{"def":"In a minatory manner; with threats.","pos":""}],"MINATORY":[{"def":"Threatening; menacing.","pos":""}],"MINCE":[{"def":"To cut into very small pieces; to chop fine; to hash; as, to mince meat.","pos":""},{"def":"To suppress or weaken the force of; to extenuate; to palliate; to tell by degrees, instead of directly and frankly; to clip, as words or expressions; to utter half and keep back half of.","pos":""}],"MINCE PIE":[{"def":"A pie made of mince-meat.","pos":""}],"MINCE-MEAT":[{"def":"Minced meat; meat chopped very fine; a mixture of boiled meat, suet, apples, etc.","pos":""}],"MINCING":[{"def":"That minces; characterized by primness or affected nicety.","pos":""}],"MINCINGLY":[{"def":"In a mincing manner; not fully; with affected nicety.","pos":""}],"MIND":[{"def":"The intellectual or rational faculty in man; the understanding; the intellect; the power that conceives, judges, or reasons; also, the entire spiritual nature; the soul; -- often in distinction from the body.","pos":""},{"def":"The state, at any given time, of the faculties of thinking, willing, choosing, and the like; psychical activity or state; as: (a) Opinion; judgment; belief.","pos":""}],"MINDED":[{"def":"Disposed; inclined; having a mind.","pos":""}],"MINDER":[{"def":"One who minds, tends, or watches something, as a child, a machine, or cattle; as, a minder of a loom.","pos":""},{"def":"One to be attended; specif.","pos":""}],"MINDFUL":[{"def":"Bearing in mind; regardful; attentive; heedful; observant.","pos":""}],"MINDING":[{"def":"Regard; mindfulness.","pos":""}],"MINDLESS":[{"def":"Not indued with mind or intellectual powers; stupid; unthinking.","pos":""},{"def":"Unmindful; inattentive; heedless; careless.","pos":""}],"MINE":[{"def":"Belonging to me; my.","pos":""}],"MINER":[{"def":"One who mines; a digger for metals, etc.","pos":""}],"MINERAL":[{"def":"An inorganic species or substance occurring in nature, having a definite chemical composition and usually a distinct crystalline form.","pos":""}],"MINERALIST":[{"def":"One versed in minerals; mineralogist.","pos":""}],"MINERALIZATION":[{"def":"The conversion of a cell wall into a material of a stony nature.","pos":""}],"MINERALIZE":[{"def":"To transform into a mineral.","pos":""},{"def":"To impregnate with a mineral; as, mineralized water.","pos":""}],"MINERALIZER":[{"def":"An element which is combined with a metal, thus forming an ore.","pos":""}],"MINERALOGICAL":[{"def":"Of or pertaining to mineralogy; as, a mineralogical table.","pos":""}],"MINERALOGICALLY":[{"def":"According to the principles of, or with reference to, mineralogy.","pos":""}],"MINERALOGIST":[{"def":"A carrier shell (Phorus).","pos":""}],"MINERALOGIZE":[{"def":"To study mineralogy by collecting and examining minerals.","pos":""}],"MINERALOGY":[{"def":"The science which treats of minerals, and teaches how to describe, distinguish, and classify them.","pos":""},{"def":"A treatise or book on this science.","pos":""}],"MINERVA":[{"def":"The goddess of wisdom, of war, of the arts and sciences, of poetry, and of spinning and weaving; -- identified with the Grecian Pallas Athene.","pos":""}],"MINETTE":[{"def":"The smallest of regular sizes of portrait photographs.","pos":""}],"MINEVER":[{"def":"Same as Miniver.","pos":""}],"MINGE":[{"def":"To mingle; to mix.","pos":""}],"MINGLE":[{"def":"To mix; intermix; to combine or join, as an individual or part, with other parts, but commonly so as to be distinguishable in the product; to confuse; to confound.","pos":""},{"def":"To associate or unite in society or by ties of relationship; to cause or allow to intermarry; to intermarry.","pos":""}],"MINGLE-MANGLE":[{"def":"To mix in a disorderly way; to make a mess of.","pos":""}],"MINGLEABLE":[{"def":"That can be mingled.","pos":""}],"MINGLEMENT":[{"def":"The act of mingling, or the state of being mixed.","pos":""}],"MINGLER":[{"def":"One who mingles.","pos":""}],"MINGLINGLY":[{"def":"In a mingling manner.","pos":""},{"def":"Of the color of minium or red lead; miniate.","pos":""}],"MINIARDIZE":[{"def":"To render delicate or dainty.","pos":""}],"MINIATE":[{"def":"To paint or tinge with red lead or vermilion; also, to decorate with letters, or the like, painted red, as the page of a manuscript.","pos":""}],"MINIATURE":[{"def":"Originally, a painting in colors such as those in mediæval manuscripts; in modern times, any very small painting, especially a portrait.","pos":""},{"def":"Greatly diminished size or form; reduced scale.","pos":""}],"MINIATURIST":[{"def":"A painter of miniatures.","pos":""}],"MINIBUS":[{"def":"A kind of light passenger vehicle, carrying four persons.","pos":""}],"MINIE BALL":[{"def":"A conical rifle bullet, with a cavity in its base plugged with a piece of iron, which, by the explosion of the charge, is driven farther in, expanding the sides to fit closely the grooves of the barrel.","pos":""}],"MINIE RIFLE":[{"def":"A rifle adapted to minie balls.","pos":""}],"MINIFY":[{"def":"To make small, or smaller; to diminish the apparent dimensions of; to lessen.","pos":""},{"def":"To degrade by speech or action.","pos":""}],"MINIKIN":[{"def":"A little darling; a favorite; a minion.","pos":""}],"MINIM":[{"def":"A small fish; a minnow.","pos":""},{"def":"One of an austere order of mendicant hermits of friars founded in the 15th century by St.","pos":""}],"MINIMAL":[{"def":"Of, pertaining to, or having a character of, a minim or minimum; least; smallest; as, a minimal amount or value.","pos":""}],"MINIMENT":[{"def":"A trifle; a trinket; a token.","pos":""}],"MINIMIZATION":[{"def":"The act or process of minimizing.","pos":""}],"MINIMIZE":[{"def":"To reduce to the smallest part or proportion possible; to reduce to a minimum.","pos":""}],"MINIMUM":[{"def":"The least quantity assignable, admissible, or possible, in a given case; hence, a thing of small consequence; -- opposed to Ant: maximum.","pos":""}],"MINIMUM THERMOMETER":[{"def":", a thermometer for recording the lowest temperature since its last adjustment.","pos":""}],"MINIMUS":[{"def":"The little finger; the fifth digit, or that corresponding to it, in either the manus or pes.","pos":""}],"MINING":[{"def":"The act or business of making mines or of working them.","pos":""}],"MINION":[{"def":"A small kind of type, in size between brevier and nonpareil.","pos":""}],"MINIONETTE":[{"def":"Small; delicate.","pos":""}],"MINIONIZE":[{"def":"Like a minion; daintily.","pos":""}],"MINIONSHIP":[{"def":"State of being a minion.","pos":""}],"MINIOUS":[{"def":"Of the color of red or vermilion.","pos":""}],"MINISH":[{"def":"To diminish; to lessen.","pos":""}],"MINISHMENT":[{"def":"The act of diminishing, or the state of being diminished; diminution.","pos":""}],"MINISTER":[{"def":"A servant; a subordinate; an officer or assistant of inferior rank; hence, an agent, an instrument.","pos":""},{"def":"An officer of justice.","pos":""}],"MINISTERIAL":[{"def":"Of or pertaining to ministry or service; serving; attendant.","pos":""},{"def":"Of or pertaining to the office of a minister or to the ministry as a body, whether civil or sacerdotal.","pos":""}],"MINISTERIALIST":[{"def":"A supporter of the ministers, or the party in power.","pos":""}],"MINISTERIALLY":[{"def":"In a ministerial manner; in the character or capacity of a minister.","pos":""}],"MINISTRANT":[{"def":"Performing service as a minister; attendant on service; acting under command; subordinate.","pos":""},{"def":"One who ministers.","pos":""}],"MINISTRATION":[{"def":"The act of ministering; service; ministry.","pos":""}],"MINISTRATIVE":[{"def":"Serving to aid; ministering.","pos":""}],"MINISTRESS":[{"def":"A woman who ministers.","pos":""}],"MINISTRY":[{"def":"The act of ministering; ministration; service.","pos":""},{"def":"Hence: Agency; instrumentality.","pos":""}],"MINISTRYSHIP":[{"def":"The office of a minister.","pos":""}],"MINIUM":[{"def":"A heavy, brilliant red pigment, consisting of an oxide of lead, Pb3O4, obtained by exposing lead or massicot to a gentle and continued heat in the air.","pos":""}],"MINIVER":[{"def":"A fur esteemed in the Middle Ages as a part of costume.","pos":""}],"MINIVET":[{"def":"A singing bird of India of the family Campephagidæ.","pos":""}],"MINK":[{"def":"A carnivorous mammal of the genus Putorius, allied to the weasel.","pos":""}],"MINNESINGER":[{"def":"A love-singer; specifically, one of a class of German poets and musicians who flourished from about the middle of the twelfth to the middle of the fourteenth century.","pos":""}],"MINNOW":[{"def":"A small European fresh-water cyprinoid fish (Phoxinus lævis, formerly Leuciscus phoxinus); sometimes applied also to the young of larger kinds; -- called also minim and minny.","pos":""},{"def":"Any of numerous small American cyprinodont fishes of the genus Fundulus, and related genera.","pos":""}],"MINO BIRD":[{"def":"An Asiatic bird (Gracula musica), allied to the starlings.","pos":""}],"MINOR":[{"def":"Less by a semitone in interval or difference of pitch; as, a minor third.","pos":""}],"MINORAT":[{"def":"A custom or right, analogous to borough-English in England, formerly existing in various parts of Europe, and surviving in parts of Germany and Austria, by which certain entailed estates, as a homestead and adjacent land, descend to the youngest male heir.","pos":""}],"MINORESS":[{"def":"See Franciscan Nuns, under Franciscan, a.","pos":""}],"MINORITE":[{"def":"A Franciscan friar.","pos":""}],"MINORITY":[{"def":"The state of being a minor, or under age.","pos":""},{"def":"State of being less or small.","pos":""}],"MINOS":[{"def":"A king and lawgiver of Crete, fabled to be the son of Jupiter and Europa.","pos":""}],"MINOTAUR":[{"def":"A fabled monster, half man and half bull, confined in the labyrinth constructed by Dædalus in Crete.","pos":""}],"MINSTER":[{"def":"A church of a monastery.","pos":""}],"MINSTREL":[{"def":"In the Middle Ages, one of an order of men who subsisted by the arts of poetry and music, and sang verses to the accompaniment of a harp or other instrument; in modern times, a poet; a bard; a singer and harper; a musician.","pos":""}],"MINSTRELSY":[{"def":"The arts and occupation of minstrels; the singing and playing of a minstrel.","pos":""},{"def":"Musical instruments.","pos":""}],"MINT":[{"def":"The name of several aromatic labiate plants, mostly of the genus Mentha, yielding odoriferous essential oils by distillation.","pos":""}],"MINT SAUCE":[{"def":"A sauce of vinegar and sugar flavored with spearmint leaves.","pos":""}],"MINT-MASTER":[{"def":"The master or superintendent of a mint.","pos":""}],"MINTAGE":[{"def":"The coin, or other production, made in a mint.","pos":""},{"def":"The duty paid to the mint for coining.","pos":""}],"MINTMAN":[{"def":"One skilled in coining, or in coins; a coiner.","pos":""}],"MINUEND":[{"def":"The number from which another number is to be subtracted.","pos":""}],"MINUET":[{"def":"A tune or air to regulate the movements of the dance so called; a movement in suites, sonatas, symphonies, etc.","pos":""}],"MINUM":[{"def":"A small kind of printing type; minion.","pos":""}],"MINUS":[{"def":"Less; requiring to be subtracted; negative; as, a minus quantity.","pos":""}],"MINUSCULE":[{"def":"Of the size and style of minuscules; written in minuscules.","pos":""}],"MINUTARY":[{"def":"Pertaining to, or consisting of, minutes.","pos":""}],"MINUTE":[{"def":"A fixed part of a module.","pos":""}],"MINUTE-JACK":[{"def":"A figure which strikes the hour on the bell of some fanciful clocks; -- called also jack of the clock house.","pos":""},{"def":"A timeserver; an inconstant person.","pos":""}],"MINUTELY":[{"def":"In a minute manner; with minuteness; exactly; nicely.","pos":""}],"MINUTEMAN":[{"def":"A militiaman who was to be ready to march at a moment's notice; -- a term used in the American Revolution.","pos":""}],"MINUTENESS":[{"def":"The quality of being minute.","pos":""}],"MINUTIA":[{"def":"A minute particular; a small or minor detail; -- used chiefly in the plural.","pos":""}],"MINX":[{"def":"A pert or a wanton girl.","pos":""},{"def":"A she puppy; a pet dog.","pos":""}],"MINY":[{"def":"Abounding with mines; like a mine.","pos":""}],"MINYAN":[{"def":"A quorum, or number necessary, for conducting public worship.","pos":""}]}