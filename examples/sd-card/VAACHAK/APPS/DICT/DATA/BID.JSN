{"BID":[{"def":"To make an offer of; to propose.","pos":""},{"def":"To offer in words; to declare, as a wish, a greeting, a threat, or defiance, etc.","pos":""}],"BIDALE":[{"def":"An invitation of friends to drink ale at some poor man's house, and there to contribute in charity for his relief.","pos":""},{"def":"A portable boat made of skins stretched on a frame.","pos":""}],"BIDDABLE":[{"def":"Obedient; docile.","pos":""}],"BIDDER":[{"def":"One who bids or offers a price.","pos":""}],"BIDDERY WARE":[{"def":"A kind of metallic ware made in India.","pos":""}],"BIDDING":[{"def":"Command; order; a proclamation or notifying.","pos":""},{"def":"The act or process of making bids; an offer; a proposal of a price, as at an auction.","pos":""}],"BIDDING PRAYER":[{"def":"The prayer for the souls of benefactors, said before the sermon.","pos":""},{"def":"The prayer before the sermon, with petitions for various specified classes of persons.","pos":""}],"BIDDY":[{"def":"A name used in calling a hen or chicken.","pos":""}],"BIDE":[{"def":"To dwell; to inhabit; to abide; to stay.","pos":""},{"def":"To remain; to continue or be permanent in a place or state; to continue to be.","pos":""}],"BIDENT":[{"def":"An instrument or weapon with two prongs.","pos":""}],"BIDENTAL":[{"def":"Having two teeth.","pos":""}],"BIDENTATE":[{"def":"Having two teeth or two toothlike processes; two-toothed.","pos":""}],"BIDET":[{"def":"A small horse formerly allowed to each trooper or dragoon for carrying his baggage.","pos":""},{"def":"A kind of bath tub for sitting baths; a sitz bath.","pos":""}],"BIDIGITATE":[{"def":"Having two fingers or fingerlike projections.","pos":""}],"BIDING":[{"def":"Residence; habitation.","pos":""}]}