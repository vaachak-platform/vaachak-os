{"REFUGE":[{"def":"Shelter or protection from danger or distress.","pos":""},{"def":"That which shelters or protects from danger, or from distress or calamity; a stronghold which protects by its strength, or a sanctuary which secures safety by its sacredness; a place inaccessible to an enemy.","pos":""}],"REFUGEE":[{"def":"The quality of being refulgent; brilliancy; splender; radiance.","pos":""}],"REFULGENT":[{"def":"Casting a bright light; radiant; brilliant; resplendent; shining; splendid; as, refulgent beams.","pos":""}],"REFUND":[{"def":"To fund again or anew; to replace (a fund or loan) by a new fund; as, to refund a railroad loan.","pos":""}],"REFUNDER":[{"def":"One who refunds.","pos":""}],"REFUNDMENT":[{"def":"The act of refunding; also, that which is refunded.","pos":""}],"REFURBISH":[{"def":"To furbish anew.","pos":""}],"REFURNISH":[{"def":"To furnish again.","pos":""}],"REFURNISHMENT":[{"def":"The act of refurnishing, or state of being refurnished.","pos":""}],"REFUSABLE":[{"def":"Capable of being refused; admitting of refusal.","pos":""}],"REFUSAL":[{"def":"The act of refusing; denial of anything demanded, solicited, or offered for acceptance.","pos":""},{"def":"The right of taking in preference to others; the choice of taking or refusing; option; as, to give one the refusal of a farm; to have the refusal of an employment.","pos":""}],"REFUSE":[{"def":"To throw back, or cause to keep back (as the center, a wing, or a flank), out of the regular aligment when troops aras, to refuse the right wing while the left wing attacks.","pos":""}],"REFUSER":[{"def":"One who refuses or rejects.","pos":""}],"REFUSION":[{"def":"New or repeated melting, as of metals.","pos":""}],"REFUTABILITY":[{"def":"The quality of being refutable.","pos":""}],"REFUTABLE":[{"def":"Admitting of being refuted or disproved; capable of being proved false or erroneous.","pos":""}],"REFUTAL":[{"def":"Act of refuting; refutation.","pos":""}],"REFUTATION":[{"def":"The act or process of refuting or disproving, or the state of being refuted; proof of falsehood or error; the overthrowing of an argument, opinion, testimony, doctrine, or theory, by argument or countervailing proof.","pos":""}],"REFUTATORY":[{"def":"Tending tu refute; refuting.","pos":""}],"REFUTE":[{"def":"To disprove and overthrow by argument, evidence, or countervailing proof; to prove to be false or erroneous; to confute; as, to refute arguments; to refute testimony; to refute opinions or theories; to refute a disputant.","pos":""}],"REFUTER":[{"def":"One who, or that which, refutes.","pos":""}]}