{"HAZARD":[{"def":"Holing a ball, whether the object ball (winning hazard) or the player's ball (losing hazard).","pos":""}],"HAZARDABLE":[{"def":"Liable to hazard or chance; uncertain; risky.","pos":""},{"def":"Such as can be hazarded or risked.","pos":""}],"HAZARDER":[{"def":"A player at the game of hazard; a gamester.","pos":""},{"def":"One who hazards or ventures.","pos":""}],"HAZARDIZE":[{"def":"A hazardous attempt or situation; hazard.","pos":""}],"HAZARDOUS":[{"def":"Exposed to hazard; dangerous; risky.","pos":""}],"HAZARDRY":[{"def":"Playing at hazard; gaming; gambling.","pos":""},{"def":"Rashness; temerity.","pos":""}],"HAZE":[{"def":"Light vapor or smoke in the air which more or less impedes vision, with little or no dampness; a lack of transparency in the air; hence, figuratively, obscurity; dimness.","pos":""}],"HAZEL":[{"def":"A shrub or small tree of the genus Corylus, as the C.","pos":""}],"HAZELESS":[{"def":"Destitute of haze.","pos":""}],"HAZELLY":[{"def":"Of the color of the hazelnut; of a light brown.","pos":""}],"HAZELNUT":[{"def":"The nut of the hazel.","pos":""}],"HAZILY":[{"def":"In a hazy manner; mistily; obscurely; confusedly.","pos":""}],"HAZINESS":[{"def":"The quality or state of being hazy.","pos":""}],"HAZLE":[{"def":"To make dry; to dry.","pos":""}],"HAZY":[{"def":"Thick with haze; somewhat obscured with haze; not clear or transparent.","pos":""},{"def":"Obscure; confused; not clear; as, a hazy argument; a hazy intellect.","pos":""}]}