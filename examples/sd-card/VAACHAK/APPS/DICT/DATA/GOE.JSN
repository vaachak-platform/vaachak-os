{"GOELAND":[{"def":"A white tropical tern (Cygis candida).","pos":""}],"GOEMIN":[{"def":"A complex mixture of several substances extracted from Irish moss.","pos":""}],"GOER":[{"def":"One who, or that which, goes; a runner or walker; as: (a) A foot.","pos":""}],"GOETY":[{"def":"Invocation of evil spirits; witchcraft.","pos":""}]}