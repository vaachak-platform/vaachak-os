{"HOMACANTH":[{"def":"Having the dorsal fin spines symmetrical, and in the same line; -- said of certain fishes.","pos":""}],"HOMAGE":[{"def":"A symbolical acknowledgment made by a feudal tenant to, and in the presence of, his lord, on receiving investiture of fee, or coming to it by succession, that he was his man, or vassal; profession of fealty to a sovereign.","pos":""}],"HOMAGEABLE":[{"def":"Subject to homage.","pos":""}],"HOMAGER":[{"def":"One who does homage, or holds land of another by homage; a vassal.","pos":""}],"HOMALOGRAPHIC":[{"def":"Same as Homolographic.","pos":""},{"def":"Flat; even; -- a term applied to surfaces and to spaces, whether real or imagined, in which the definitions, axioms, and postulates of Euclid respecting parallel straight lines are assumed to hold true.","pos":""}],"HOMARUS":[{"def":"A genus of decapod Crustacea, including the common lobsters.","pos":""}],"HOMATROPINE":[{"def":"An alkaloid, prepared from atropine, and from other sources.","pos":""}],"HOMAXONIAL":[{"def":"Relating to that kind of homology or symmetry, the mathematical conception of organic form, in which all axes are equal.","pos":""}]}