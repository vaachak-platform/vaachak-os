{"SUN":[{"def":"The luminous orb, the light of which constitutes day, and its absence night; the central body round which the earth and planets revolve, by which they are held in their orbits, and from which they receive light and heat.","pos":""},{"def":"Any heavenly body which forms the center of a system of orbs.","pos":""}],"SUN STAR":[{"def":"See Sun star, under Sun.","pos":""}],"SUN-BURNER":[{"def":"A circle or cluster of gas-burners for lighting and ventilating public buildings.","pos":""}],"SUN-DRIED":[{"def":"Dried by the heat of the sun.","pos":""}],"SUN-STRUCK":[{"def":"Overcome by, or affected with, sunstroke; as, sun-struck soldiers.","pos":""}],"SUNBEAM":[{"def":"A beam or ray of the sun.","pos":""}],"SUNBIRD":[{"def":"Indies, and Australia.","pos":""}],"SUNBLINK":[{"def":"A glimpse or flash of the sun.","pos":""}],"SUNBONNET":[{"def":"A bonnet, generally made of some thin or light fabric, projecting beyond the face, and commonly having a cape, -- worn by women as a protection against the sun.","pos":""}],"SUNBOW":[{"def":"A rainbow; an iris.","pos":""}],"SUNBURN":[{"def":"To burn or discolor by the sun; to tan.","pos":""}],"SUNBURST":[{"def":"A burst of sunlight.","pos":""}],"SUNCUP":[{"def":"A yellow flowered evening primrose (Taraxia, syn.","pos":""}],"SUNDAY":[{"def":"The first day of the week, -- consecrated among Christians to rest from secular employments, and to religious worship; the Christian Sabbath; the Lord's Day.","pos":""}],"SUNDER":[{"def":"To disunite in almost any manner, either by rending, cutting, or breaking; to part; to put or keep apart; to separate; to divide; to sever; as, to sunder a rope; to sunder a limb; to sunder friends.","pos":""}],"SUNDEW":[{"def":"Any plant of the genus Drosera, low bog plants whose leaves are beset with pediceled glands which secrete a viscid fluid that glitters like dewdrops and attracts and detains insects.","pos":""}],"SUNDIAL":[{"def":"An instrument to show the time of day by means of the shadow of a gnomon, or style, on a plate.","pos":""}],"SUNDOG":[{"def":"A luminous spot occasionally seen a few degrees from the sun, supposed to be formed by the intersection of two or more halos, or in a manner similar to that of halos.","pos":""}],"SUNDOWN":[{"def":"The setting of the sun; sunset.","pos":""},{"def":"A kind of broad-brimmed sun hat worn by women.","pos":""}],"SUNDOWNER":[{"def":"A tramp or vagabond in the Australian bush; -- so called from his coming to sheep stations at sunset of ask for supper and a bed, when it is too late to work; -- called also traveler and swagman (but not all swagmen are sundowners).","pos":""}],"SUNDRIES":[{"def":"Many different or small things; sundry things.","pos":""}],"SUNDRILY":[{"def":"In sundry ways; variously.","pos":""}],"SUNDROPS":[{"def":"Any one of the several species of Kneiffia, esp.","pos":""}],"SUNDRY":[{"def":"Several; divers; more than one or two; various.","pos":""},{"def":"Separate; diverse.","pos":""}],"SUNDRYMAN":[{"def":"One who deals in sundries, or a variety of articles.","pos":""}],"SUNFISH":[{"def":"Eastern United States are Lepomis gibbosus (called also bream, pondfish, pumpkin seed, and sunny), the blue sunfish, or dollardee (L.","pos":""}],"SUNFLOWER":[{"def":"Any plant of the genus Helianthus; -- so called probably from the form and color of its flower, which is large disk with yellow rays.","pos":""}],"SUNFLOWER STATE":[{"def":"Kansas; a nickname.","pos":""}],"SUNGLASS":[{"def":"A convex lens of glass for producing heat by converging the sun's rays into a focus.","pos":""}],"SUNGLOW":[{"def":"A rosy flush in the sky seen after sunset.","pos":""}],"SUNKEN":[{"def":"Lying on the bottom of a river or other water; sunk.","pos":""}],"SUNLESS":[{"def":"Destitute or deprived of the sun or its rays; shaded; shadowed.","pos":""}],"SUNLIGHT":[{"def":"The light of the sun.","pos":""}],"SUNLIKE":[{"def":"Like or resembling the sun.","pos":""}],"SUNLIT":[{"def":"Lighted by the sun.","pos":""}],"SUNN":[{"def":"An East Indian leguminous plant (Crotalaria juncea) and its fiber, which is also called sunn hemp.","pos":""}],"SUNNA":[{"def":"A collection of traditions received by the orthodox Mohammedans as of equal authority with the Koran.","pos":""}],"SUNNIAH":[{"def":"One of the sect of Sunnites.","pos":""}],"SUNNINESS":[{"def":"The quality or state of being sunny.","pos":""}],"SUNNITE":[{"def":"One of the orthodox Mohammedans who receive the Sunna as of equal importance with the Koran.","pos":""}],"SUNNUD":[{"def":"A charter or warrant; also, a deed of gift.","pos":""}],"SUNNY":[{"def":"Of or pertaining to the sun; proceeding from, or resembling the sun; hence, shining; bright; brilliant; radiant.","pos":""},{"def":"Exposed to the rays of the sun; brightened or warmed by the direct rays of the sun; as, a sunny room; the sunny side of a hill.","pos":""}],"SUNPROOF":[{"def":"Impervious to the rays of the sun.","pos":""}],"SUNSHADE":[{"def":"Anything used as a protection from the sun's rays.","pos":""}],"SUNSHINE":[{"def":"The light of the sun, or the place where it shines; the direct rays of the sun, the place where they fall, or the warmth and light which they give.","pos":""},{"def":"Anything which has a warming and cheering influence like that of the rays of the sun; warmth; illumination; brightness.","pos":""}],"SUNSHINY":[{"def":"Bright with the rays of the sun; clear, warm, or pleasant; as, a sunshiny day.","pos":""},{"def":"Bright like the sun; resplendent.","pos":""}],"SUNSQUALL":[{"def":"Any large jellyfish.","pos":""}],"SUNSTONE":[{"def":"Aventurine feldspar.","pos":""}],"SUNSTROKE":[{"def":"Any affection produced by the action of the sun on some part of the body; especially, a sudden prostration of the physical powers, with symptoms resembling those of apoplexy, occasioned by exposure to excessive heat, and often terminating fatally; coup de soleil.","pos":""}],"SUNUP":[{"def":"Such a horse as that might get over a good deal of ground atwixt sunup and sundown.","pos":""}],"SUNWISE":[{"def":"In the direction of the sun's apparent motion, or from the east southward and westward, and so around the circle; also, in the same direction as the movement of the hands of a watch lying face upward.","pos":""}]}