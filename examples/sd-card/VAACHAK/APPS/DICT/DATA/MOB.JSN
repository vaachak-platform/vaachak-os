{"MOB":[{"def":"To wrap up in, or cover with, a cowl.","pos":""}],"MOBBISH":[{"def":"Like a mob; tumultuous; lawless; as, a mobbish act.","pos":""}],"MOBCAP":[{"def":"A plain cap or headdress for women or girls; especially, one tying under the chin by a very broad band, generally of the same material as the cap itself.","pos":""}],"MOBILE":[{"def":"Capable of being moved, aroused, or excited; capable of spontaneous movement.","pos":""}],"MOBILITY":[{"def":"The quality or state of being mobile; as, the mobility of a liquid, of an army, of the populace, of features, of a muscle.","pos":""},{"def":"The mob; the lower classes.","pos":""}],"MOBILIZATION":[{"def":"The act of mobilizing.","pos":""}],"MOBILIZE":[{"def":"To put in a state of readiness for active service in war, as an army corps.","pos":""}],"MOBLE":[{"def":"To wrap the head of in a hood.","pos":""}],"MOBOCRACY":[{"def":"A condition in which the lower classes of a nation control public affairs without respect to law, precedents, or vested rights.","pos":""}],"MOBOCRAT":[{"def":"One who favors a form of government in which the unintelligent populace rules without restraint.","pos":""}],"MOBOCRATIC":[{"def":"Of, or relating to, a mobocracy.","pos":""}]}