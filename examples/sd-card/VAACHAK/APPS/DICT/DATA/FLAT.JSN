{"FLAT":[{"def":"Wanting relief; destitute of variety; without points of prominence and striking interest.","pos":""},{"def":"Sonant; vocal; -- applied to any one of the sonant or vocal consonants, as distinguished from a nonsonant (or sharp) consonant.","pos":""}],"FLAT FOOT":[{"def":"A foot in which the arch of the instep is flattened so that the entire sole of the foot rests upon the ground; also, the deformity, usually congential, exhibited by such a foot; splayfoot.","pos":""}],"FLAT-BOTTOMED":[{"def":"Having an even lower surface or bottom; as, a flat-bottomed boat.","pos":""}],"FLAT-CAP":[{"def":"A kind of low-crowned cap formerly worn by all classes in England, and continued in London after disuse elsewhere; -- hence, a citizen of London.","pos":""}],"FLAT-FOOTED":[{"def":"Having a flat foot, with little or no arch of the instep.","pos":""},{"def":"Firm-footed; determined.","pos":""}],"FLAT-HEADED":[{"def":"Having a head with a flattened top; as, a flat-headed nail.","pos":""}],"FLATBILL":[{"def":"Any bird of the genus Flatyrynchus.","pos":""}],"FLATBOAT":[{"def":"A boat with a flat bottom and square ends; -- used for the transportation of bulky freight, especially in shallow waters.","pos":""}],"FLATFISH":[{"def":"Any fish of the family Pleuronectidæ; esp.","pos":""}],"FLATHEAD":[{"def":"Characterized by flatness of head, especially that produced by artificial means, as a certain tribe of American Indians.","pos":""}],"FLATIRON":[{"def":"An iron with a flat, smooth surface for ironing clothes.","pos":""}],"FLATIVE":[{"def":"Producing wind; flatulent.","pos":""}],"FLATLING":[{"def":"With the flat side, as of a sword; flatlong; in a prostrate position.","pos":""}],"FLATLONG":[{"def":"Flat\"long Defn: ; 115), adv.","pos":""}],"FLATLY":[{"def":"In a flat manner; evenly; horizontally; without spirit; dully; frigidly; peremptori;y; positively, plainly.","pos":""}],"FLATNESS":[{"def":"The quality or state of being flat.","pos":""},{"def":"Eveness of surface; want of relief or prominence; the state of being plane or level.","pos":""}],"FLATTEN":[{"def":"To lower the pitch of; to cause to sound less sharp; to let fall from the pitch.","pos":""}],"FLATTER":[{"def":"One who, or that which, makes flat or flattens.","pos":""}],"FLATTERER":[{"def":"One who flatters.","pos":""}],"FLATTERING":[{"def":"That flatters (in the various senses of the verb); as, a flattering speech.","pos":""}],"FLATTERY":[{"def":"The act or practice of flattering; the act of pleasing by artiful commendation or compliments; adulation; false, insincere, or excessive praise.","pos":""}],"FLATTING":[{"def":"The process or operation of making flat, as a cylinder of glass by opening it out.","pos":""},{"def":"A mode of painting,in which the paint, being mixed with turpentine, leaves the work without gloss.","pos":""}],"FLATTISH":[{"def":"The state or quality of being flatulent.","pos":""}],"FLATULENT":[{"def":"Affected with flatus or gases generated in the alimentary canal; windy.","pos":""},{"def":"Generating, or tending to generate, wind in the stomach.","pos":""}],"FLATULENTLY":[{"def":"In a flatulent manner; with flatulence.","pos":""}],"FLATUOUS":[{"def":"Windy; generating wind.","pos":""}],"FLATUS":[{"def":"A breath; a puff of wind.","pos":""},{"def":"Wind or gas generated in the stomach or other cavities of the body.","pos":""}],"FLATWARE":[{"def":"Articles for the table, as china or silverware, that are more or less flat, as distinguished from hollow ware.","pos":""}],"FLATWISE":[{"def":"With the flat side downward, or next to another object; not edgewise.","pos":""}],"FLATWORM":[{"def":"Any worm belonging to the Plathelminthes; also, sometimes applied to the planarians.","pos":""}]}