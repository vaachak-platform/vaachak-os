{"GOTE":[{"def":"A channel for water.","pos":""}],"GOTH":[{"def":"One of an ancient Teutonic race, who dwelt between the Elbe and the Vistula in the early part of the Christian era, and who overran and took an important part in subverting the Roman empire.","pos":""}],"GOTHAMIST":[{"def":"A wiseacre; a person deficient in wisdom; -- so called from Gotham, in Nottinghamshire, England, noted for some pleasant blunders.","pos":""}],"GOTHAMITE":[{"def":"An inhabitant of New York city.","pos":""}],"GOTHIC":[{"def":"Of or pertaining to a style of architecture with pointed arches, steep roofs, windows large in proportion to the wall spaces, and, generally, great height in proportion to the other dimensions -- prevalent in Western Europe from about 1200 to 1475 a.","pos":""}],"GOTHICISM":[{"def":"Conformity to the Gothic style of architecture.","pos":""}],"GOTHICIZE":[{"def":"To make Gothic; to bring back to barbarism.","pos":""},{"def":"A hydrous oxide of iron, occurring in prismatic crystals, also massive, with a fibrous, reniform, or stalactitic structure.","pos":""}]}