{"TURK":[{"def":"The plum weevil.","pos":""}],"TURK'S-HEAD":[{"def":"A long-handled, round-headed broom for sweeping ceilings, etc.","pos":""}],"TURKEY":[{"def":"An empire in the southeast of Europe and southwest of Asia.","pos":""}],"TURKEY-TROT":[{"def":"An eccentric ragtime dance, danced with the feet well apart and with a characteristic rise on the ball of the foot, followed by a drop upon the heel.","pos":""}],"TURKISH":[{"def":"Of or pertaining to Turkey or the Turks.","pos":""},{"def":"The language spoken by Turks, esp.","pos":""}],"TURKISM":[{"def":"Same as Turcism.","pos":""}],"TURKO":[{"def":"One of a body of native Algerian tirailleurs in the French army, dressed as a Turk.","pos":""}],"TURKO-IRANIAN":[{"def":"Designating, or pert.","pos":""}],"TURKOMAN":[{"def":"Same as Turcoman.","pos":""}]}