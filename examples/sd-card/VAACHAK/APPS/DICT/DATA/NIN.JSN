{"NINCOMPOOP":[{"def":"A fool; a silly or stupid person.","pos":""}],"NINE":[{"def":"Eight and one more; one less than ten; as, nine miles.","pos":""}],"NINE-BARK":[{"def":"A white-flowered rosaceous shrub (Neillia, or Spiræa, opulifolia), common in the Northern United States.","pos":""}],"NINE-KILLER":[{"def":"The northern butcher bird.","pos":""}],"NINEFOLD":[{"def":"Nine times repeated.","pos":""}],"NINEHOLES":[{"def":"A game in which nine holes are made in the ground, into which a ball is bowled.","pos":""}],"NINEPENCE":[{"def":"An old English silver coin, worth nine pence.","pos":""},{"def":"A New England name for the Spanish real, a coin formerly current in the United States, as valued at twelve and a half cents.","pos":""}],"NINEPINS":[{"def":"A game played with nine pins, or pieces of wood, set on end, at which a wooden ball is bowled to knock them down; bowling.","pos":""}],"NINESCORE":[{"def":"Nine times twenty, or one hundred and eighty.","pos":""},{"def":"The product of nine times twenty; ninescore units or objects.","pos":""}],"NINETEEN":[{"def":"Nine and ten; eighteen and one more; one less than twenty; as, nineteen months.","pos":""}],"NINETEENTH":[{"def":"Following the eighteenth and preceding the twentieth; coming after eighteen others.","pos":""},{"def":"Constituting or being one of nineteen equal parts into which anything is divided.","pos":""}],"NINETIETH":[{"def":"Next in order after the eighty-ninth.","pos":""},{"def":"Constituting or being one of ninety equal parts.","pos":""}],"NINETY":[{"def":"Nine times ten; eighty-nine and one more; as, ninety men.","pos":""}],"NINNY":[{"def":"A fool; a simpleton.","pos":""}],"NINNYHAMMER":[{"def":"A simpleton; a silly person.","pos":""}],"NINTH":[{"def":"Following the eight and preceding the tenth; coming after eight others.","pos":""},{"def":"Constituting or being one of nine equal parts into which anything is divided.","pos":""}],"NINTHLY":[{"def":"In the ninth place.","pos":""}]}