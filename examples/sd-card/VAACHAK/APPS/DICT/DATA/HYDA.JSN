{"HYDANTOIC":[{"def":"Pertaining to, or derived from, hydantoin.","pos":""}],"HYDANTOIN":[{"def":"A derivative of urea, C3H4N2O2, obtained from allantion, as a white, crystalline substance, with a sweetish taste; -- called also glycolyl urea.","pos":""}],"HYDATID":[{"def":"A membranous sac or bladder filled with a pellucid fluid, found in various parts of the bodies of animals, but unconnected with the tissues.","pos":""}],"HYDATIFORM":[{"def":"Resembling a hydatid.","pos":""}],"HYDATOID":[{"def":"Resembling water; watery; aqueous; hyaloid.","pos":""}]}