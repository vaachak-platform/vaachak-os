{"PIN":[{"def":"To inclose; to confine; to pen; to pound.","pos":""}],"PIN-EYED":[{"def":"Having the stigma visible at the throad of a gamopetalous corolla, while the stamens are concealed in the tube; -- said of dimorphous flowers.","pos":""}],"PIN-FIRE":[{"def":"Having a firing pin to explode the cartridge; as, a pin-fire rifle.","pos":""}],"PIN-TAILED":[{"def":"Having a tapered tail, with the middle feathers longest; -- said of birds.","pos":""}],"PINACATE BUG":[{"def":"Any of several clumsy, wingless beetles of the genus Eleodes, found in the Pacific States.","pos":""},{"def":"A fine material for ladies' shawls, scarfs, handkerchiefs, etc.","pos":""}],"PINACOID":[{"def":"A plane parallel to two of the crystalline axes.","pos":""}],"PINACOLIN":[{"def":"A colorless oily liquid related to the ketones, and obtained by the decomposition of pinacone; hence, by extension, any one of the series of which pinacolin proper is the type.","pos":""}],"PINACONE":[{"def":"A white crystalline substance related to the glycols, and made from acetone; hence, by extension, any one of a series of substances of which pinacone proper is the type.","pos":""}],"PINACOTHECA":[{"def":"A picture gallery.","pos":""}],"PINAFORE":[{"def":"An apron for a child to protect the front part of dress; a tier.","pos":""}],"PINASTER":[{"def":"A species of pine (Pinus Pinaster) growing in Southern Europe.","pos":""}],"PINAX":[{"def":"A tablet; a register; hence, a list or scheme inscribed on a tablet.","pos":""}],"PINCE-NEZ":[{"def":"Eyeglasses kept on the nose by a spring.","pos":""}],"PINCH":[{"def":"To press hard or squeeze between the ends of the fingers, between teeth or claws, or between the jaws of an instrument; to squeeze or compress, as between any two hard bodies.","pos":""}],"PINCHBECK":[{"def":"An alloy of copper and zinc, resembling gold; a yellow metal, composed of about three ounces of zinc to a pound of copper.","pos":""}],"PINCHCOCK":[{"def":"A clamp on a flexible pipe to regulate the flow of a fluid through the pipe.","pos":""}],"PINCHEM":[{"def":"The European blue titmouse.","pos":""}],"PINCHER":[{"def":"One who, or that which, pinches.","pos":""}],"PINCHERS":[{"def":"An instrument having two handles and two grasping jaws working on a pivot; -- used for griping things to be held fast, drawing nails, etc.","pos":""}],"PINCHFIST":[{"def":"A closefisted person; a miser.","pos":""}],"PINCHING":[{"def":"Compressing; nipping; griping; niggardly; as, pinching cold; a pinching parsimony.","pos":""}],"PINCHINGLY":[{"def":"In a pinching way.","pos":""}],"PINCHPENNY":[{"def":"A miserly person.","pos":""}],"PINCOFFIN":[{"def":"A commercial preparation of garancin, yielding fine violet tints.","pos":""}],"PINCPINC":[{"def":"An African wren warbler.","pos":""}],"PINCUSHION":[{"def":"A small cushion, in which pins may be stuck for use.","pos":""},{"def":"The peanut (Arachis hypogæa); -- so called in the West Indies.","pos":""}],"PINDARIC":[{"def":"Of or pertaining to Pindar, the Greek lyric poet; after the style and manner of Pindar; as, Pindaric odes.","pos":""}],"PINDARICAL":[{"def":"Too extravagant and Pindarical for prose.","pos":""}],"PINDARISM":[{"def":"Imitation of Pindar.","pos":""}],"PINDARIST":[{"def":"One who imitates Pindar.","pos":""}],"PINDER":[{"def":"One who impounds; a poundkeeper.","pos":""}],"PINE":[{"def":"Woe; torment; pain.","pos":""}],"PINE-TREE STATE":[{"def":"Maine; -- a nickname alluding to the pine tree in its coat of arms.","pos":""}],"PINEAL":[{"def":"Of or pertaining to a pine cone; resembling a pine cone.","pos":""}],"PINEAPPLE":[{"def":"A tropical plant (Ananassa sativa); also, its fruit; -- so called from the resemblance of the latter, in shape and external appearance, to the cone of the pine tree.","pos":""}],"PINEASTER":[{"def":"Clad or crowned with pine trees; as, pine-clad hills.","pos":""}],"PINEDROPS":[{"def":"A reddish herb (Pterospora andromedea) of the United States, found parasitic on the roots of pine trees.","pos":""}],"PINENCHYMA":[{"def":"Tabular parenchyma, a form of cellular tissue in which the cells are broad and flat, as in some kinds of epidermis.","pos":""}],"PINERY":[{"def":"A pine forest; a grove of pines.","pos":""},{"def":"A hothouse in which pineapples are grown.","pos":""}],"PINESAP":[{"def":"A reddish fleshy herb of the genus Monotropa (M.","pos":""}],"PINETUM":[{"def":"A plantation of pine trees; esp.","pos":""}],"PINEWEED":[{"def":"A low, bushy, nearly leafless herb (Hypericum Sarothra), common in sandy soil in the Eastern United States.","pos":""}],"PINEY":[{"def":"A term used in designating an East Indian tree (the Vateria Indica or piney tree, of the order Dipterocarpeæ, which grows in Malabar, etc.","pos":""}],"PINFEATHER":[{"def":"A feather not fully developed; esp.","pos":""}],"PINFEATHERED":[{"def":"Having part, or all, of the feathers imperfectly developed.","pos":""}],"PINFISH":[{"def":"Note: Both are excellent food fishes, common on the coast of the United States south of Cape Hatteras.","pos":""}],"PINFOLD":[{"def":"A place in which stray cattle or domestic animals are confined; a pound; a penfold.","pos":""}],"PING":[{"def":"The sound made by a bullet in striking a solid object or in passing through the air.","pos":""}],"PING-PONG":[{"def":"An indoor modification of lawn tennis played with small bats, or battledores, and a very light, hollow, celluloid ball, on a large table divided across the middle by a net.","pos":""},{"def":"A size of photograph a little larger than a postage stamp.","pos":""}],"PINGLE":[{"def":"A small piece of inclosed ground.","pos":""}],"PINGUEFACTION":[{"def":"A making of, or turning into, fat.","pos":""}],"PINGUID":[{"def":"Fat; unctuous; greasy.","pos":""}],"PINGUIDINOUS":[{"def":"Containing fat; fatty.","pos":""}],"PINGUITUDE":[{"def":"Fatness; a growing fat; obesity.","pos":""}],"PINHOLD":[{"def":"A place where a pin is fixed.","pos":""}],"PINIC":[{"def":"Of or pertaining to the pine; obtained from the pine; formerly, designating an acid which is the chief constituent of common resin, - - now called abietic, or sylvic, acid.","pos":""}],"PINING":[{"def":"Languishing; drooping; wasting away, as with longing.","pos":""},{"def":"Wasting; consuming.","pos":""}],"PININGLY":[{"def":"In a pining manner; droopingly.","pos":""}],"PINION":[{"def":"A moth of the genus Lithophane, as L.","pos":""}],"PINIONED":[{"def":"Having wings or pinions.","pos":""}],"PINIONIST":[{"def":"Any winged creature.","pos":""}],"PINITE":[{"def":"A compact granular cryptocrystalline mineral of a dull grayish or greenish white color.","pos":""}],"PINK":[{"def":"A vessel with a very narrow stern; -- called also pinky.","pos":""}],"PINK STERN":[{"def":"See Chebacco, and 1st Pink.","pos":""}],"PINK-EYED":[{"def":"Having small eyes.","pos":""}],"PINK-STERNED":[{"def":"Having a very narrow stern; -- said of a vessel.","pos":""}],"PINKED":[{"def":"Pierced with small holes; worked in eyelets; scalloped on the edge.","pos":""}],"PINKING":[{"def":"The act of piercing or stabbing.","pos":""},{"def":"The act or method of decorating fabrics or garments with a pinking iron; also, the style of decoration; scallops made with a pinking iron.","pos":""}],"PINKNESS":[{"def":"Quality or state of being pink.","pos":""}],"PINKROOT":[{"def":"The root of Spigelia Marilandica, used as a powerful vermifuge; also, that of S.","pos":""}],"PINNA":[{"def":"One of the divisions of a pinnate part or organ.","pos":""},{"def":"Any species of Pinna, a genus of large bivalve mollusks found in all warm seas.","pos":""}],"PINNACE":[{"def":"A procuress; a pimp.","pos":""}],"PINNACLE":[{"def":"An architectural member, upright, and generally ending in a small spire, -- used to finish a buttress, to constitute a part in a proportion, as where pinnacles flank a gable or spire, and the like.","pos":""}],"PINNAGE":[{"def":"Poundage of cattle.","pos":""},{"def":"Consisting of several leaflets, or separate portions, arranged on each side of a common petiole, as the leaves of a rosebush, a hickory, or an ash.","pos":""}],"PINNATELY":[{"def":"In a pinnate manner.","pos":""}],"PINNATIFID":[{"def":"Divided in a pinnate manner, with the divisions not reaching to the midrib.","pos":""}],"PINNATILOBATE":[{"def":"Having lobes arranged in a pinnate manner.","pos":""}],"PINNATIPED":[{"def":"Having the toes bordered by membranes; fin-footed, as certain birds.","pos":""}],"PINNER":[{"def":"One who, or that which, pins or fastens, as with pins.","pos":""}],"PINNIFORM":[{"def":"Shaped like a fin or feather.","pos":""}],"PINNIGRADA":[{"def":"Same as Pinnipedia.","pos":""}],"PINNIGRADE":[{"def":"An animal of the seal tribe, moving by short feet that serve as paddles.","pos":""}],"PINNIPEDES":[{"def":"Same as Steganopodes.","pos":""}],"PINNIPEDIA":[{"def":"A suborder of aquatic carnivorous mammals including the seals and walruses; -- opposed to Fissipedia.","pos":""}],"PINNOTHERE":[{"def":"A crab of the genus pinnotheres.","pos":""}],"PINNULA":[{"def":"Same as Pinnule.","pos":""}],"PINNULATE":[{"def":"Having each pinna subdivided; -- said of a leaf, or of its pinnæ.","pos":""}],"PINNULATED":[{"def":"Having pinnules.","pos":""}],"PINNULE":[{"def":"One of the small divisions of a decompound frond or leaf.","pos":""},{"def":"Any one of a series of small, slender organs, or parts, when arranged in rows so as to have a plumelike appearance; as, a pinnule of a gorgonia; the pinnules of a crinoid.","pos":""}],"PINNYWINKLES":[{"def":"An instrument of torture, consisting of a board with holes into which the fingers were pressed, and fastened with pegs.","pos":""}],"PINOLE":[{"def":"An aromatic powder used in Italy in the manufacture of chocolate.","pos":""},{"def":"Parched maize, ground, and mixed with sugar, etc.","pos":""}],"PINPATCH":[{"def":"The common English periwinkle.","pos":""}],"PINT":[{"def":"A measure of capacity, equal to half a quart, or four gills, -- used in liquid and dry measures.","pos":""}],"PINTADO":[{"def":"Any bird of the genus Numida.","pos":""}],"PINTAIL":[{"def":"A northern duck (Dafila acuta), native of both continents.","pos":""},{"def":"The sharp-tailed grouse of the great plains and Rocky Mountains (Pediocætes phasianellus); -- called also pintailed grouse, pintailed chicken, springtail, and sharptail.","pos":""}],"PINTLE":[{"def":"An upright pivot pin; as: (a) The pivot pin of a hinge.","pos":""}],"PINTO":[{"def":"Any pied animal; esp.","pos":""}],"PINTOS":[{"def":"A mountain tribe of Mexican Indians living near Acapulco.","pos":""}],"PINTSCH GAS":[{"def":"A kind of oil gas extensively used for lighting railroad cars, which carry it in compressed form.","pos":""}],"PINULE":[{"def":"One of the sights of an astrolabe.","pos":""}],"PINUS":[{"def":"A large genus of evergreen coniferous trees, mostly found in the northern hemisphere.","pos":""}],"PINWEED":[{"def":"Any plant of the genus Lechea, low North American herbs with branching stems, and very small and abundant leaves and flowers.","pos":""}],"PINWORM":[{"def":"A small nematoid worm (Oxyurus vermicularis), which is parasitic chiefly in the rectum of man.","pos":""}],"PINXIT":[{"def":"A word appended to the artist's name or initials on a painting, or engraved copy of a painting; as, Rubens pinxit, Rubens painted (this).","pos":""}],"PINY":[{"def":"Abounding with pines.","pos":""}]}