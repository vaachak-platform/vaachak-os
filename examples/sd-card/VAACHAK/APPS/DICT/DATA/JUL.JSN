{"JULACEOUS":[{"def":"Like an ament, or bearing aments; amentaceous.","pos":""}],"JULEP":[{"def":"a sweet, demulcent, acidulous, or mucilaginous mixture, used as a vehicle.","pos":""}],"JULIAN":[{"def":"Relating to, or derived from, Julius Cæsar.","pos":""}],"JULIENNE":[{"def":"A kind of soup containing thin slices or shreds of carrots, onions, etc.","pos":""}],"JULIFORM":[{"def":"Having the shape or appearance of a julus or catkin.","pos":""}],"JULUS":[{"def":"A catkin or ament.","pos":""}],"JULY":[{"def":"The seventh month of the year, containing thirty-one days.","pos":""}],"JULY-FLOWER":[{"def":"See Gillyflower.","pos":""}]}