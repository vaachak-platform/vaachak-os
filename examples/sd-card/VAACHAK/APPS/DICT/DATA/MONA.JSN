{"MONA":[{"def":"A small, handsome, long-tailed West American monkey (Cercopithecus mona).","pos":""}],"MONACHAL":[{"def":"Of or pertaining to monks or a monastic life; monastic.","pos":""}],"MONACHISM":[{"def":"The system and influences of a monastic life; monasticism.","pos":""}],"MONACID":[{"def":"Having one hydrogen atom replaceable by a negative or acid atom or radical; capable of neutralizing a monobasic acid; -- said of bases, and of certain metals.","pos":""}],"MONAD":[{"def":"The elementary and indestructible units which were conceived of as endowed with the power to produce all the changes they undergo, and thus determine all physical and spiritual phenomena.","pos":""},{"def":"One of the smallest flangellate Infusoria; esp.","pos":""}],"MONADELPHIA":[{"def":"A Linnæan class of plants having the stamens united into a tube, or ring, by the filaments, as in the Mallow family.","pos":""},{"def":"Of or pertaining to the Monadelphia; having the stamens united in one body by the filaments.","pos":""}],"MONADIFORM":[{"def":"Having the form of a monad; resembling a monad in having one or more filaments of vibratile protoplasm; as, monadiform young.","pos":""}],"MONADOLOGY":[{"def":"The doctrine or theory of monads.","pos":""}],"MONAL":[{"def":"Any Asiatic pheasant of the genus Lophophorus, as the Impeyan pheasant.","pos":""}],"MONAMIDE":[{"def":"An amido compound with only one amido group.","pos":""}],"MONAMINE":[{"def":"A basic compound containing one amido group; as, methyl amine is a monamine.","pos":""}],"MONANDER":[{"def":"One of the Monandria.","pos":""}],"MONANDRIA":[{"def":"A Linnæan class of plants embracing those having but a single stamen.","pos":""}],"MONANDRIAN":[{"def":"Same as Monandrous.","pos":""}],"MONANDRIC":[{"def":"Of or pertaining to monandry; practicing monandry as a system of marriage.","pos":""}],"MONANDROUS":[{"def":"Of or pertaining to the monandria; having but one stamen.","pos":""}],"MONANDRY":[{"def":"The possession by a woman of only one husband at the same time; -- contrasted with polyandry.","pos":""}],"MONANTHOUS":[{"def":"Having but one flower; one-flowered.","pos":""}],"MONARCH":[{"def":"A very large red and black butterfly (Danais Plexippus); -- called also milkweed butterfly.","pos":""}],"MONARCHAL":[{"def":"Pertaining to a monarch; suiting a monarch; sovoreign; regal; imperial.","pos":""}],"MONARCHESS":[{"def":"A female monarch.","pos":""}],"MONARCHIAN":[{"def":"One of a sect in the early Christian church which rejected the doctrine of the Trinity; -- called also patripassian.","pos":""},{"def":"Of or pertaining to a monarch, or to monarchy.","pos":""}],"MONARCHISM":[{"def":"The principles of, or preference for, monarchy.","pos":""}],"MONARCHIST":[{"def":"An advocate of, or believer in, monarchy.","pos":""}],"MONARCHIZE":[{"def":"To play the sovereign; to act the monarch.","pos":""}],"MONARCHIZER":[{"def":"One who monarchizes; also, a monarchist.","pos":""}],"MONARCHO":[{"def":"The nickname of a crackbrained Italian who fancied himself an emperor.","pos":""}],"MONARCHY":[{"def":"A state or government in which the supreme power is lodged in the hands of a monarch.","pos":""},{"def":"A system of government in which the chief ruler is a monarch.","pos":""}],"MONAS":[{"def":"A genus of minute flagellate Infusoria of which there are many species, both free and attached.","pos":""}],"MONASTERIAL":[{"def":"Of or pertaining to monastery, or to monastic life.","pos":""}],"MONASTERY":[{"def":"A house of religious retirement, or of secusion from ordinary temporal concerns, especially for monks; -- more rarely applied to such a house for females.","pos":""}],"MONASTIC":[{"def":"Of or pertaining to monasteries, or to their occupants, rules, etc.","pos":""},{"def":"Secluded from temporal concerns and devoted to religion; recluse.","pos":""}],"MONASTICALLY":[{"def":"In a monastic manner.","pos":""}],"MONASTICISM":[{"def":"The monastic life, system, or condition.","pos":""}],"MONASTICON":[{"def":"A book giving an account of monasteries.","pos":""}],"MONAXIAL":[{"def":"Having only one axis; developing along a single line or plane; as, monaxial development.","pos":""}],"MONAZITE":[{"def":"A mineral occurring usually in small isolated crystals, -- phosphate of the cerium metals.","pos":""}]}