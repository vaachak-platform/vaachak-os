{"SIGAULTIAN":[{"def":"Pertaining to Sigault, a French physician.","pos":""}],"SIGH":[{"def":"To inhale a larger quantity of air than usual, and immediately expel it; to make a deep single audible respiration, especially as the result or involuntary expression of fatigue, exhaustion, grief, sorrow, or the like.","pos":""},{"def":"Hence, to lament; to grieve.","pos":""}],"SIGH-BORN":[{"def":"Sorrowful; mournful.","pos":""}],"SIGHING":[{"def":"Uttering sighs; grieving; lamenting.","pos":""}],"SIGHT":[{"def":"The act of seeing; perception of objects by the eye; view; as, to gain sight of land.","pos":""},{"def":"The power of seeing; the faculty of vision, or of perceiving objects by the instrumentality of the eyes.","pos":""}],"SIGHT-HOLE":[{"def":"A hole for looking through; a peephole.","pos":""}],"SIGHT-SEEING":[{"def":"Engaged in, or given to, seeing sights; eager for novelties or curiosities.","pos":""}],"SIGHT-SEER":[{"def":"One given to seeing sights or noted things, or eager for novelties or curiosities.","pos":""}],"SIGHT-SHOT":[{"def":"Distance to which the sight can reach or be thrown.","pos":""}],"SIGHTED":[{"def":"Having sight, or seeing, in a particular manner; -- used in composition; as, long-sighted, short-sighted, quick-sighted, sharp- sighted, and the like.","pos":""}],"SIGHTFUL":[{"def":"Easily or clearly seen; distinctly visible; perspicuous.","pos":""}],"SIGHTFULNESS":[{"def":"The state of being sightful; perspicuity.","pos":""}],"SIGHTLESS":[{"def":"Wanting sight; without sight; blind.","pos":""},{"def":"That can not be seen; invisible.","pos":""}],"SIGHTLINESS":[{"def":"The state of being sightly; comeliness; conspicuousness.","pos":""}],"SIGHTLY":[{"def":"Pleasing to the sight; comely.","pos":""},{"def":"Open to sight; conspicuous; as, a house stands in a sightly place.","pos":""}],"SIGHTPROOF":[{"def":"Undiscoverable to sight.","pos":""}],"SIGHTSMAN":[{"def":"One who reads or performs music readily at first sight.","pos":""}],"SIGIL":[{"def":"A seal; a signature.","pos":""}],"SIGILLARIA":[{"def":"Little images or figures of earthenware exposed for sale, or given as presents, on the last two days of the Saturnalia; hence, the last two, or the sixth and seventh, days of the Saturnalia.","pos":""}],"SIGILLARID":[{"def":"One of an extinct family of cryptagamous trees, including the genus Sigillaria and its allies.","pos":""}],"SIGILLATED":[{"def":"Decorated by means of stamps; -- said of pottery.","pos":""}],"SIGILLATIVE":[{"def":"Fit to seal; belonging to a seal; composed of wax.","pos":""}],"SIGLA":[{"def":"The signs, abbreviations, letters, or characters standing for words, shorthand, etc.","pos":""}],"SIGMA":[{"def":"The Greek letter S, or s).","pos":""}],"SIGMODONT":[{"def":"Any one of a tribe (Sigmodontes) of rodents which includes all the indigenous rats and mice of America.","pos":""},{"def":"Curved in two directions, like the letter S, or the Greek s.","pos":""}],"SIGMOIDALLY":[{"def":"In a sigmoidal manner.","pos":""}],"SIGN":[{"def":"That by which anything is made known or represented; that which furnishes evidence; a mark; a token; an indication; a proof.","pos":""},{"def":"The twelfth part of the ecliptic or zodiac.","pos":""}],"SIGNABLE":[{"def":"Suitable to be signed; requiring signature; as, a legal document signable by a particular person.","pos":""}],"SIGNAL":[{"def":"A sign made for the purpose of giving notice to a person of some occurence, command, or danger; also, a sign, event, or watchword, which has been agreed upon as the occasion of concerted action.","pos":""},{"def":"A token; an indication; a foreshadowing; a sign.","pos":""}],"SIGNALIST":[{"def":"One who makes signals; one who communicates intelligence by means of signals.","pos":""}],"SIGNALITY":[{"def":"The quality or state of being signal or remarkable.","pos":""}],"SIGNALIZE":[{"def":"To make signal or eminent; to render distinguished from what is common; to distinguish.","pos":""},{"def":"To communicate with by means of a signal; as, a ship signalizes its consort.","pos":""}],"SIGNALLY":[{"def":"In a signal manner; eminently.","pos":""}],"SIGNALMAN":[{"def":"A man whose business is to manage or display signals; especially, one employed in setting the signals by which railroad trains are run or warned.","pos":""}],"SIGNALMENT":[{"def":"The act of signaling, or of signalizing; hence, description by peculiar, appropriate, or characteristic marks.","pos":""}],"SIGNATE":[{"def":"Having definite color markings.","pos":""}],"SIGNATION":[{"def":"Sign given; marking.","pos":""}],"SIGNATORY":[{"def":"Relating to a seal; used in sealing.","pos":""},{"def":"Signing; joining or sharing in a signature; as, signatory powers.","pos":""}],"SIGNATURE":[{"def":"An outward mark by which internal characteristics were supposed to be indicated.","pos":""},{"def":"A resemblance between the external characters of a disease and those of some physical agent, for instance, that existing between the red skin of scarlet fever and a red cloth; -- supposed to indicate this agent in the treatment of the disease.","pos":""}],"SIGNATURIST":[{"def":"One who holds to the doctrine of signatures impressed upon objects, indicative of character or qualities.","pos":""}],"SIGNBOARD":[{"def":"A board, placed on or before a shop, office, etc.","pos":""}],"SIGNER":[{"def":"One who signs or subscribes his name; as, a memorial with a hundred signers.","pos":""}],"SIGNET":[{"def":"A seal; especially, in England, the seal used by the sovereign in sealing private letters and grants that pass by bill under the sign manual; -- called also privy signet.","pos":""}],"SIGNETED":[{"def":"Stamped or marked with a signet.","pos":""}],"SIGNIFER":[{"def":"The quality or state of being significant.","pos":""},{"def":"That which is signified; meaning; import; as, the significance of a nod, of a motion of the hand, or of a word or expression.","pos":""}],"SIGNIFICANT":[{"def":"Fitted or designed to signify or make known somethingl having a meaning; standing as a sign or token; expressive or suggestive; as, a significant word or sound; a significant look.","pos":""},{"def":"Deserving to be considered; important; momentous; as, a significant event.","pos":""}],"SIGNIFICANTLY":[{"def":"In a significant manner.","pos":""}],"SIGNIFICATE":[{"def":"One of several things signified by a common term.","pos":""}],"SIGNIFICATION":[{"def":"The act of signifying; a making known by signs or other means.","pos":""},{"def":"That which is signified or made known; that meaning which a sign, character, or token is intended to convey; as, the signification of words.","pos":""}],"SIGNIFICATIVE":[{"def":"Betokening or representing by an external sign.","pos":""},{"def":"Having signification or meaning; expressive of a meaning or purpose; significant.","pos":""}],"SIGNIFICATOR":[{"def":"One who, or that which, signifies.","pos":""}],"SIGNIFICATORY":[{"def":"That which is significatory.","pos":""}],"SIGNIFICAVIT":[{"def":"Formerly, a writ issuing out of chancery, upon certificate given by the ordinary, of a man's standing excommunicate by the space of forty days, for the laying him up in prison till he submit himself to the authority of the church.","pos":""}],"SIGNIFY":[{"def":"To show by a sign; to communicate by any conventional token, as words, gestures, signals, or the like; to announce; to make known; to declare; to express; as, a signified his desire to be present.","pos":""},{"def":"To mean; to import; to denote; to betoken.","pos":""}],"SIGNIOR":[{"def":"Signor and the Spanish Señor.","pos":""}],"SIGNIORIZE":[{"def":"To exercise dominion over; to lord it over.","pos":""}],"SIGNIORSHIP":[{"def":"State or position of a signior.","pos":""}],"SIGNIORY":[{"def":"Same as Seigniory.","pos":""},{"def":"Sir; Mr; -- a title of address or respect among the Italians.","pos":""}],"SIGNORA":[{"def":"Madam; Mrs; -- a title of address or respect among the Italians.","pos":""}],"SIGNORINA":[{"def":"Miss; -- a title of address among the Italians.","pos":""}],"SIGNPOST":[{"def":"A post on which a sign hangs, or on which papers are placed to give public notice of anything.","pos":""}]}