{"FAC":[{"def":"A large ornamental letter used, esp.","pos":""}],"FACADE":[{"def":"The front of a building; esp.","pos":""}],"FACE":[{"def":"Ten degrees in extent of a sign of the zodiac.","pos":""},{"def":"The end or wall of the tunnel, drift, or excavation, at which work is progressing or was last done.","pos":""}],"FACED":[{"def":"Having (such) a face, or (so many) faces; as, smooth-faced, two-faced.","pos":""}],"FACER":[{"def":"One who faces; one who puts on a false show; a bold-faced person.","pos":""},{"def":"A blow in the face, as in boxing; hence, any severe or stunning check or defeat, as in controversy.","pos":""}],"FACET":[{"def":"A smooth circumscribed surface; as, the articular facet of a bone.","pos":""},{"def":"The narrow plane surface between flutings of a column.","pos":""}],"FACETE":[{"def":"Facetious; witty; humorous.","pos":""}],"FACETIAE":[{"def":"Witty or humorous writings or saying; witticisms; merry conceits.","pos":""}],"FACETIOUS":[{"def":"Given to wit and good humor; merry; sportive; jocular; as, a facetious companion.","pos":""},{"def":"Characterized by wit and pleasantry; exciting laughter; as, a facetious story or reply.","pos":""}],"FACEWORK":[{"def":"The material of the outside or front side, as of a wall or building; facing.","pos":""}],"FACIAL":[{"def":"Of or pertaining to the face; as, the facial artery, vein, or nerve.","pos":""}],"FACIEND":[{"def":"The multiplicand.","pos":""}],"FACIENT":[{"def":"One who does anything, good or bad; a doer; an agent.","pos":""}],"FACIES":[{"def":"The general aspect or habit of a species, or group of species, esp.","pos":""},{"def":"The face of a bird, or the front of the head, excluding the bill.","pos":""}],"FACILE":[{"def":"Easy to be done or performed: not difficult; performable or attainable with little labor.","pos":""},{"def":"Easy to be surmounted or removed; easily conquerable; readily mastered.","pos":""}],"FACILITATE":[{"def":"To make easy or less difficult; to free from difficulty or impediment; to lessen the labor of; as, to facilitate the execution of a task.","pos":""}],"FACILITATION":[{"def":"The act of facilitating or making easy.","pos":""}],"FACILITY":[{"def":"The quality of being easily performed; freedom from difficulty; ease; as, the facility of an operation.","pos":""},{"def":"Ease in performance; readiness proceeding from skill or use; dexterity; as, practice gives a wonderful facility in executing works of art.","pos":""}],"FACING":[{"def":"The finishing of any face of a wall with material different from that of which it is chiefly composed, or the coating or material so used.","pos":""},{"def":"A powdered substance, as charcoal, bituminous coal, ect.","pos":""}],"FACINGLY":[{"def":"In a facing manner or position.","pos":""}],"FACINOROUS":[{"def":"Atrociously wicked.","pos":""}],"FACOUND":[{"def":"Speech; eloquence.","pos":""}],"FACSIMILE":[{"def":"A copy of anything made, either so as to be deceptive or so as to give every part and detail of the original; an exact copy or likeness.","pos":""}],"FACT":[{"def":"A doing, making, or preparing.","pos":""},{"def":"An effect produced or achieved; anything done or that comes to pass; an act; an event; a circumstance.","pos":""}],"FACTION":[{"def":"One of the divisions or parties of charioteers (distinguished by their colors) in the games of the circus.","pos":""}],"FACTIONARY":[{"def":"Belonging to a faction; being a partisan; taking sides.","pos":""}],"FACTIONER":[{"def":"One of a faction.","pos":""}],"FACTIONIST":[{"def":"One who promotes faction.","pos":""}],"FACTIOUS":[{"def":"Given to faction; addicted to form parties and raise dissensions, in opposition to government or the common good; turbulent; seditious; prone to clamor against public measures or men; -- said of persons.","pos":""},{"def":"Pertaining to faction; proceeding from faction; indicating, or characterized by, faction; -- said of acts or expressions; as, factious quarrels.","pos":""}],"FACTITIOUS":[{"def":"Made by art, in distinction from what is produced by nature; artificial; sham; formed by, or adapted to, an artificial or conventional, in distinction from a natural, standard or rule; not natural; as, factitious cinnabar or jewels; a factitious taste.","pos":""}],"FACTITIVE":[{"def":"Pertaining to that relation which is proper when the act, as of a transitive verb, is not merely received by an object, but produces some change in the object, as when we say, He made the water wine.","pos":""}],"FACTIVE":[{"def":"Making; having power to make.","pos":""}],"FACTO":[{"def":"In fact; by the act or fact.","pos":""}],"FACTOR":[{"def":"One who transacts business for another; an agent; a substitute; especially, a mercantile agent who buys and sells goods and transacts business for others in commission; a commission merchant or consignee.","pos":""},{"def":"One of the elements or quantities which, when multiplied together, from a product.","pos":""}],"FACTORAGE":[{"def":"The allowance given to a factor, as a compensation for his services; -- called also a commission.","pos":""}],"FACTORESS":[{"def":"A factor who is a woman.","pos":""}],"FACTORIAL":[{"def":"Related to factorials.","pos":""}],"FACTORING":[{"def":"The act of resolving into factors.","pos":""}],"FACTORSHIP":[{"def":"The business of a factor.","pos":""}],"FACTORY":[{"def":"A house or place where factors, or commercial agents, reside, to transact business for their employers.","pos":""},{"def":"The body of factors in any place; as, a chaplain to a British factory.","pos":""}],"FACTOTUM":[{"def":"A person employed to do all kinds of work or business.","pos":""}],"FACTUAL":[{"def":"Relating to, or containing, facts.","pos":""}],"FACTUM":[{"def":"A man's own act and deed; particularly: (a) (Civil Law) Anything stated and made certain.","pos":""}],"FACTURE":[{"def":"An invoice or bill of parcels.","pos":""}],"FACULAE":[{"def":"Groups of small shining spots on the surface of the sun which are brighter than the other parts of the photosphere.","pos":""}],"FACULAR":[{"def":"Of or pertaining to the faculæ.","pos":""}],"FACULTATIVE":[{"def":"Having the power to live under different conditions; as, a facultative parasite, a plant which is normally saprophytic, but which may exist wholly or in part as a parasite; -- opposed to obligate.","pos":""}],"FACULTY":[{"def":"The body of person to whom are intrusted the government and instruction of a college or university, or of one of its departments; the president, professors, and tutors in a college.","pos":""}],"FACUNDIOUS":[{"def":"Eloquement; full of words.","pos":""}],"FACUNDITY":[{"def":"Eloquence; readiness of speech.","pos":""}]}