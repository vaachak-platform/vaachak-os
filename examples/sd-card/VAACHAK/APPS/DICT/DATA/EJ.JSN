{"EJACULATE":[{"def":"To throw out suddenly and swiftly, as if a dart; to dart; to eject.","pos":""},{"def":"To throw out, as an exclamation; to utter by a brief and sudden impulse; as, to ejaculate a prayer.","pos":""}],"EJACULATION":[{"def":"The act of ejecting or suddenly throwing, as a fluid from a duct.","pos":""}],"EJACULATOR":[{"def":"A muscle which helps ejaculation.","pos":""}],"EJACULATORY":[{"def":"Casting or throwing out; fitted to eject; as, ejaculatory vessels.","pos":""},{"def":"Suddenly darted out; uttered in short sentences; as, an ejaculatory prayer or petition.","pos":""}],"EJECT":[{"def":"To cast out; to evict; to dispossess; as, to eject tenants from an estate.","pos":""}],"EJECTA":[{"def":"Matter ejected; material thrown out; as, the ejecta of a volcano; the ejecta, or excreta, of the body.","pos":""}],"EJECTION":[{"def":"The act or process of discharging anything from the body, particularly the excretions.","pos":""}],"EJECTMENT":[{"def":"A species of mixed action, which lies for the recovery of possession of real property, and damages and costs for the wrongful withholding of it.","pos":""}],"EJECTOR":[{"def":"A jet jump for lifting water or withdrawing air from a space.","pos":""}],"EJULATION":[{"def":"A wailing; lamentation.","pos":""},{"def":"The name given by Mendelejeff in accordance with the periodic law, and by prediction, to a hypothetical element then unknown, but since discovered and named scandium; -- so called because it was a missing analogue of the boron group.","pos":""}]}