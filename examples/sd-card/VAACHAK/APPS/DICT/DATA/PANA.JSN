{"PANABASE":[{"def":"Same as Tetrahedrite.","pos":""}],"PANACEA":[{"def":"The herb allheal.","pos":""}],"PANACEAN":[{"def":"Having the properties of a panacea.","pos":""}],"PANACHE":[{"def":"A plume or bunch of feathers, esp.","pos":""},{"def":"Bread boiled in water to the consistence of pulp, and sweetened or flavored.","pos":""}],"PANAMA HAT":[{"def":"A fine plaited hat, made in Central America of the young leaves of a plant (Carludovica palmata).","pos":""}],"PANAMANIAN":[{"def":"A native or citizen of Panama.","pos":""}],"PANARY":[{"def":"Of or pertaining to bread or to breadmaking.","pos":""}],"PANATHENAEA":[{"def":"The most ancient and important festival of Athens, celebrated in honor of Athena, the tutelary goddess of the city.","pos":""}]}