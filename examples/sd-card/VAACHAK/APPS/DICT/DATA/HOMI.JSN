{"HOMICIDAL":[{"def":"Pertaining to homicide; tending to homicide; murderous.","pos":""}],"HOMICIDE":[{"def":"The killing of one human being by another.","pos":""},{"def":"One who kills another; a manslayer.","pos":""}],"HOMILETE":[{"def":"Of or pertaining to familiar intercourse; social; affable; conversable; companionable.","pos":""},{"def":"Of or pertaining to homiletics; hortatory.","pos":""}],"HOMILETICS":[{"def":"The art of preaching; that branch of theology which treats of homilies or sermons, and the best method of preparing and delivering them.","pos":""}],"HOMILIST":[{"def":"One who prepares homilies; one who preaches to a congregation.","pos":""}],"HOMILITE":[{"def":"A borosilicate of iron and lime, near datolite in form and composition.","pos":""}],"HOMILY":[{"def":"A discourse or sermon read or pronounced to an audience; a serious discourse.","pos":""},{"def":"A serious or tedious exhortation in private on some moral point, or on the conduct of life.","pos":""}],"HOMING":[{"def":"Home-returning; -- used specifically of carrier pigeons.","pos":""}],"HOMINY":[{"def":"Maize hulled and broken, and prepared for food by being boiled in water.","pos":""}],"HOMISH":[{"def":"Like a home or a home circle.","pos":""}]}