{"BOW":[{"def":"To cause to deviate from straightness; to bend; to inflect; to make crooked or curved.","pos":"verb"},{"def":"To exercise powerful or controlling influence over; to bend, figuratively; to turn; to incline.","pos":"verb"}],"BOW HAND":[{"def":"The hand that holds the bow, i.","pos":""},{"def":"The hand that draws the bow, i.","pos":""}],"BOW NET":[{"def":"A trap for lobsters, being a wickerwork cylinder with a funnel- shaped entrance at one end.","pos":""},{"def":"A net for catching birds.","pos":""}],"BOW OAR":[{"def":"The oar used by the bowman.","pos":""},{"def":"One who rows at the bow of a boat.","pos":""}],"BOW-BELLS":[{"def":"The bells of Bow Church in London; cockneydom.","pos":""}],"BOW-COMPASS":[{"def":"A small pair of compasses, one leg of which carries a pencil, or a pen, for drawing circles.","pos":""}],"BOW-LEGGED":[{"def":"Having crooked legs, esp.","pos":""}],"BOW-PEN":[{"def":"Bow-compasses carrying a drawing pen.","pos":""}],"BOW-PENCIL":[{"def":"Bow-compasses, one leg of which carries a pencil.","pos":""}],"BOW-SAW":[{"def":"A saw with a thin or narrow blade set in a strong frame.","pos":""}],"BOWABLE":[{"def":"Capable of being bowed or bent; flexible; easily influenced; yielding.","pos":""}],"BOWBELL":[{"def":"One born within hearing distance of Bow-bells; a cockney.","pos":""}],"BOWBENT":[{"def":"Bent, like a bow.","pos":""}],"BOWDLERIZE":[{"def":"To expurgate, as a book, by omitting or modifying the parts considered offensive.","pos":""}],"BOWEL":[{"def":"Hence, figuratively: The interior part of anything; as, the bowels of the earth.","pos":""},{"def":"The seat of pity or kindness.","pos":""}],"BOWELED":[{"def":"Having bowels; hollow.","pos":""}],"BOWENITE":[{"def":"A hard, compact variety of serpentine found in Rhode Island.","pos":""}],"BOWER":[{"def":"An anchor carried at the bow of a ship.","pos":""}],"BOWER BIRD":[{"def":"An Australian bird (Ptilonorhynchus violaceus or holosericeus), allied to the starling, which constructs singular bowers or playhouses of twigs and decorates them with brightcolored objects; the satin bird.","pos":""}],"BOWER-BARFF PROCESS":[{"def":"A certain process for producing upon articles of iron or steel an adherent coating of the magnetic oxide of iron (which is not liable to corrosion by air, moisture, or ordinary acids).","pos":""}],"BOWERY":[{"def":"Shading, like a bower; full of bowers.","pos":""}],"BOWFIN":[{"def":"A voracious ganoid fish (Amia calva) found in the fresh waters of the United States; the mudfish; -- called also Johnny Grindle, and dogfish.","pos":""}],"BOWGE":[{"def":"To cause to leak.","pos":""}],"BOWGRACE":[{"def":"A frame or fender of rope or junk, laid out at the sides or bows of a vessel to secure it from injury by floating ice.","pos":""}],"BOWHEAD":[{"def":"The great Arctic or Greenland whale.","pos":""}],"BOWIE KNIFE":[{"def":"A knife with a strong blade from ten to fifteen inches long, and double-edged near the point; -- used as a hunting knife, and formerly as a weapon in the southwestern part of the United States.","pos":""}],"BOWING":[{"def":"The act or art of managing the bow in playing on stringed instruments.","pos":""},{"def":"In hatmaking, the act or process of separating and distributing the fur or hair by means of a bow, to prepare it for felting.","pos":""}],"BOWINGLY":[{"def":"In a bending manner.","pos":""}],"BOWKNOT":[{"def":"A knot in which a portion of the string is drawn through in the form of a loop or bow, so as to be readily untied.","pos":""}],"BOWL":[{"def":"A concave vessel of various forms (often approximately hemisherical), to hold liquids, etc.","pos":""},{"def":"Specifically, a drinking vessel for wine or other spirituous liquors; hence, convival drinking.","pos":""}],"BOWLDERY":[{"def":"Characterized by bowlders.","pos":""}],"BOWLER":[{"def":"One who plays at bowls, or who rolls the ball in cricket or any other game.","pos":""}],"BOWLESS":[{"def":"Destitute of a bow.","pos":""}],"BOWLINE":[{"def":"A rope fastened near the middle of the leech or perpendicular edge of the square sails, by subordinate ropes, called bridles, and used to keep the weather edge of the sail tight forward, when the ship is closehauled.","pos":""}],"BOWLING":[{"def":"The act of playing at or rolling bowls, or of rolling the ball at cricket; the game of bowls or of tenpins.","pos":""}],"BOWLS":[{"def":"See Bowl, a ball, a game.","pos":""}],"BOWMAN":[{"def":"A man who uses a bow; an archer.","pos":""}],"BOWNE":[{"def":"To make ready; to prepare; to dress.","pos":""}],"BOWSE":[{"def":"To pull or haul; as, to bowse upon a tack; to bowse away, i.","pos":""}],"BOWSHOT":[{"def":"The distance traversed by an arrow shot from a bow.","pos":""}],"BOWSPRIT":[{"def":"A large boom or spar, which projects over the stem of a ship or other vessel, to carry sail forward.","pos":""}],"BOWSSEN":[{"def":"To drench; to soak; especially, to immerse (in water believed to have curative properties).","pos":""}],"BOWSTRING":[{"def":"The string of a bow.","pos":""},{"def":"A string used by the Turks for strangling offenders.","pos":""}],"BOWSTRINGED":[{"def":"Furnished with bowstring.","pos":""},{"def":"Put to death with a bowstring; strangled.","pos":""}],"BOWWOW":[{"def":"An onomatopoetic name for a dog or its bark.","pos":""},{"def":"Onomatopoetic; as, the bowwow theory of language; a bowwow word.","pos":""}],"BOWYER":[{"def":"An archer; one who uses bow.","pos":""},{"def":"One who makes or sells bows.","pos":""}]}