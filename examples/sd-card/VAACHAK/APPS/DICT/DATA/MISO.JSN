{"MISOBEDIENCE":[{"def":"Mistaken obedience; disobedience.","pos":""}],"MISOBSERVE":[{"def":"To observe inaccurately; to mistake in observing.","pos":""}],"MISOBSERVER":[{"def":"One who misobserves; one who fails to observe properly.","pos":""}],"MISOGAMIST":[{"def":"A hater of marriage.","pos":""}],"MISOGYNY":[{"def":"Hatred of women.","pos":""}],"MISOLOGY":[{"def":"Hatred of argument or discussion; hatred of enlightenment.","pos":""}],"MISORDER":[{"def":"To order ill; to manage erroneously; to conduct badly.","pos":""}],"MISORDERLY":[{"def":"Irregular; disorderly.","pos":""}],"MISORDINATION":[{"def":"Wrong ordination.","pos":""}]}