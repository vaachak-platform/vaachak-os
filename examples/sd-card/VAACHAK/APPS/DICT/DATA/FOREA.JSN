{"FOREADMONISH":[{"def":"To admonish beforehand, or before the act or event.","pos":""}],"FOREADVISE":[{"def":"To advise or counsel before the time of action, or before the event.","pos":""}],"FOREALLEGE":[{"def":"To allege or cite before.","pos":""}],"FOREAPPOINT":[{"def":"To set, order, or appoint, beforehand.","pos":""}],"FOREAPPOINTMENT":[{"def":"Previous appointment; preordinantion.","pos":""}],"FOREARM":[{"def":"To arm or prepare for attack or resistance before the time of need.","pos":""}]}