{"CAN":[{"def":"With gentle words he can faile gree.","pos":""}],"CAN BUOY":[{"def":"See under Buoy, n.","pos":""}],"CAN HOOK":[{"def":"A device consisting of a short rope with flat hooks at each end, for hoisting casks or barrels by the ends of the staves.","pos":""},{"def":"The Dog Star; Sirius.","pos":""}],"CAN'T":[{"def":"A colloquial contraction for can not.","pos":""}]}