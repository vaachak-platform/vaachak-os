{"METE":[{"def":"To dream; also impersonally; as, me mette, I dreamed.","pos":""}],"METECORN":[{"def":"A quantity of corn formerly given by the lord to his customary tenants, as an encouragement to, or reward for, labor and faithful service.","pos":""}],"METELY":[{"def":"According to measure or proportion; proportionable; proportionate.","pos":""},{"def":"Related, or belonging, to the objects of knowledge within the province of metempirics.","pos":""}],"METEMPIRICISM":[{"def":"The science that is concerned with metempirics.","pos":""}],"METEMPIRICS":[{"def":"The concepts and relations which are conceived as beyond, and yet as related to, the knowledge gained by experience.","pos":""}],"METEMPSYCHOSE":[{"def":"To translate or transfer, as the soul, from one body to another.","pos":""}],"METEMPSYCHOSIS":[{"def":"The passage of the soul, as an immortal essence, at the death of the animal body it had inhabited, into another living body, whether of a brute or a human being; transmigration of souls.","pos":""}],"METEMPTOSIS":[{"def":"The suppression of a day in the calendar to prevent the date of the new moon being set a day too late, or the suppression of the bissextile day once in 134 years.","pos":""}],"METENCEPHALON":[{"def":"The posterior part of the brain, including the medulla; the afterbrain.","pos":""}],"METENSOMATOSIS":[{"def":"The assimilation by one body or organism of the elements of another.","pos":""}],"METEOR":[{"def":"Any phenomenon or appearance in the atmosphere, as clouds, rain, hail, snow, etc.","pos":""}],"METEORIC":[{"def":"Of or pertaining to a meteor, or to meteors; atmospheric, as, meteoric phenomena; meteoric stones.","pos":""},{"def":"Influenced by the weather; as, meteoric conditions.","pos":""}],"METEORISM":[{"def":"Flatulent distention of the abdomen; tympanites.","pos":""}],"METEORITE":[{"def":"A mass of stone or iron which has fallen to the earth from space; an aërolite.","pos":""}],"METEORIZE":[{"def":"To ascend in vapors; to take the form of a meteor.","pos":""}],"METEOROGRAPH":[{"def":"An instrument which registers meteorologic phases or conditions.","pos":""}],"METEOROGRAPHIC":[{"def":"Of or pertaining to meteorography.","pos":""}],"METEOROGRAPHY":[{"def":"The registration of meteorological phenomena.","pos":""}],"METEOROID":[{"def":"A small body moving through space, or revolving about the sun, which on entering the earth's atmosphere would be deflagrated and appear as a meteor.","pos":""}],"METEOROIDAL":[{"def":"Of or pertaining to a meteoroid or to meteoroids.","pos":""}],"METEOROLITE":[{"def":"A meteoric stone; an aërolite; a meteorite.","pos":""},{"def":"Of or pertaining to the atmosphere and its phenomena, or to meteorology.","pos":""}],"METEOROLOGIST":[{"def":"A person skilled in meteorology.","pos":""}],"METEOROLOGY":[{"def":"The science which treats of the atmosphere and its phenomena, particularly of its variations of heat and moisture, of its winds, storms, etc.","pos":""}],"METEOROMANCY":[{"def":"A species of divination by meteors, chiefly by thunder and lightning, which was held in high estimation by the Romans.","pos":""}],"METEOROMETER":[{"def":"An apparatus which transmits automatically to a central station atmospheric changes as marked by the anemometer, barometer, thermometer, etc.","pos":""}],"METEOROUS":[{"def":"Of the nature or appearance of a meteor.","pos":""},{"def":"A suffix denoting that by which anything is measured; as, barometer, chronometer, dynamometer.","pos":""}],"METER":[{"def":"One who, or that which, metes or measures.","pos":""},{"def":"An instrument for measuring, and usually for recording automatically, the quantity measured.","pos":""}],"METERAGE":[{"def":"The act of measuring, or the cost of measuring.","pos":""}],"METERGRAM":[{"def":"A measure of energy or work done; the power exerted in raising one gram through the distance of one meter against gravitation.","pos":""}],"METEWAND":[{"def":"A measuring rod.","pos":""}],"METEYARD":[{"def":"A yard, staff, or rod, used as a measure.","pos":""}]}