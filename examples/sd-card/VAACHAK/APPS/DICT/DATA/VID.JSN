{"VIDA FINCH":[{"def":"The whidah bird.","pos":""}],"VIDAME":[{"def":"One of a class of temporal officers who originally represented the bishops, but later erected their offices into fiefs, and became feudal nobles.","pos":""}],"VIDE":[{"def":"imperative sing.","pos":""}],"VIDELICET":[{"def":"To wit; namely; -- often abbreviated to viz.","pos":""}],"VIDONIA":[{"def":"A dry white wine, of a tart flavor, produced in Teneriffe; -- called also Teneriffe.","pos":""}],"VIDUAGE":[{"def":"The state of widows or of widowhood; also, widows, collectively.","pos":""}],"VIDUAL":[{"def":"Of or pertaining to the state of a widow; widowed.","pos":""}],"VIDUATION":[{"def":"The state of being widowed or bereaved; loss; bereavement.","pos":""}]}