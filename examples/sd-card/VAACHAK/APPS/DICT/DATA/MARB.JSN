{"MARBLE":[{"def":"A massive, compact limestone; a variety of calcite, capable of being polished and used for architectural and ornamental purposes.","pos":""},{"def":"A thing made of, or resembling, marble, as a work of art, or record, in marble; or, in the plural, a collection of such works; as, the Arundel or Arundelian marbles; the Elgin marbles.","pos":""}],"MARBLE-EDGED":[{"def":"Having the edge veined or spotted with different colors like marble, as a book.","pos":""}],"MARBLED":[{"def":"Varied with irregular markings, or witch a confused blending of irregular spots and streaks.","pos":""}],"MARBLEIZE":[{"def":"To stain or grain in imitation of marble; to cover with a surface resembling marble; as, to marbleize slate, wood, or iron.","pos":""}],"MARBLER":[{"def":"One who works upon marble or other stone.","pos":""},{"def":"One who colors or stains in imitation of marble.","pos":""}],"MARBLING":[{"def":"Distinct markings resembling the variegations of marble, as on birds and insects.","pos":""}],"MARBLY":[{"def":"Containing, or resembling, marble.","pos":""}],"MARBRINUS":[{"def":"A cloth woven so as to imitate the appearance of marble; -- much used in the 15th and 16th centuries.","pos":""}]}