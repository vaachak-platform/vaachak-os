{"MURAENA":[{"def":"A genus of large eels of the family Mirænidæ.","pos":""},{"def":"Like or pertaining to the genus Muræna, or family Murænidæ.","pos":""}],"MURAGE":[{"def":"A tax or toll paid for building or repairing the walls of a fortified town.","pos":""}],"MURAL":[{"def":"Of or pertaining to a wall; being on, or in, a wall; growing on, or against, a wall; as, a mural quadrant.","pos":""},{"def":"Resembling a wall; perpendicular or steep; as, a mural precipice.","pos":""}],"MURDER":[{"def":"The offense of killing a human being with malice prepense or aforethought, express or implied; intentional and unlawful homicide.","pos":""}],"MURDERER":[{"def":"One guilty of murder; a person who, in possession of his reason, unlawfully kills a human being with premeditated malice.","pos":""},{"def":"A small cannon, formerly used for clearing a ship's decks of boarders; -- called also murdering piece.","pos":""}],"MURDERESS":[{"def":"A woman who commits murder.","pos":""}],"MURDEROUS":[{"def":"Of or pertaining to murder; characterized by, or causing, murder or bloodshed; having the purpose or quality of murder; bloody; sanguinary; as, the murderous king; murderous rapine; murderous intent; a murderous assault.","pos":""}],"MURDRESS":[{"def":"A battlement in ancient fortifications with interstices for firing through.","pos":""}],"MURE":[{"def":"To inclose in walls; to wall; to immure; to shut up.","pos":""}],"MURENGER":[{"def":"One who had charge of the wall of a town, or its repairs.","pos":""}],"MUREX":[{"def":"A genus of marine gastropods, having rough, and frequently spinose, shells, which are often highly colored inside; the rock shells.","pos":""}],"MUREXAN":[{"def":"A complex nitrogenous substance obtained from murexide, alloxantin, and other ureids, as a white, or yellowish, crystalline which turns red on exposure to the air; -- called also uramil, dialuramide, and formerly purpuric acid.","pos":""}],"MUREXIDE":[{"def":"A crystalline nitrogenous substance having a splendid dichroism, being green by reflected light and garnet-red by transmitted light.","pos":""}],"MUREXOIN":[{"def":"A complex nitrogenous compound obtained as a scarlet crystalline substance, and regarded as related to murexide.","pos":""}],"MURIATE":[{"def":"A salt of muriatic hydrochloric acid; a chloride; as, muriate of ammonia.","pos":""}],"MURIATED":[{"def":"Combined or impregnated with muriatic or hydrochloric acid.","pos":""},{"def":"Prepared with chloride of silver through the agency of common salt.","pos":""}],"MURIATIC":[{"def":"Of, pertaining to, or obtained from, sea salt, or from chlorine, one of the constituents of sea salt; hydrochloric.","pos":""}],"MURIATIFEROUS":[{"def":"Producing muriatic substances or salt.","pos":""},{"def":"Formed with sharp points; full of sharp points or of pickles; covered, or roughened, as a surface, with sharp points or excrescences.","pos":""}],"MURICOID":[{"def":"Like, or pertaining to, the genus Murex, or family Muricidæ.","pos":""}],"MURICULATE":[{"def":"Minutely muricate.","pos":""}],"MURIDE":[{"def":"Bromine; -- formerly so called from its being obtained from sea water.","pos":""}],"MURIFORM":[{"def":"Resembling courses of bricks or stones in squareness and regular arrangement; as, a muriform variety of cellular tissue.","pos":""}],"MURINE":[{"def":"Pertaining to a family of rodents (Muridæ), of which the mouse is the type.","pos":""}],"MURK":[{"def":"He can not see through the mantle murk.","pos":""}],"MURKILY":[{"def":"Darkly; gloomily.","pos":""}],"MURKINESS":[{"def":"The state of being murky.","pos":""}],"MURKY":[{"def":"Dark; obscure; gloomy.","pos":""}],"MURMUR":[{"def":"A low, confused, and indistinct sound, like that of running water.","pos":""},{"def":"A complaint half suppressed, or uttered in a low, muttering voice.","pos":""}],"MURMURATION":[{"def":"The act of murmuring; a murmur.","pos":""}],"MURMURER":[{"def":"One who murmurs.","pos":""}],"MURMURING":[{"def":"Uttering murmurs; making low sounds; complaining.","pos":""}],"MURMUROUS":[{"def":"Attended with murmurs; exciting murmurs or complaint; murmuring.","pos":""}],"MURNIVAL":[{"def":"In the game of gleek, four cards of the same value, as four aces or four kings; hence, four of anything.","pos":""}],"MURRAIN":[{"def":"An infectious and fatal disease among cattle.","pos":""}],"MURRAYIN":[{"def":"A glucoside found in the flowers of a plant (Murraya exotica) of South Asia, and extracted as a white amorphous slightly bitter substance.","pos":""}],"MURRE":[{"def":"Any one of several species of sea birds of the genus Uria, or Catarractes; a guillemot.","pos":""}],"MURRELET":[{"def":"One of several species of sea birds of the genera Synthliboramphus and Brachyramphus, inhabiting the North Pacific.","pos":""}],"MURREY":[{"def":"A dark red color.","pos":""},{"def":"Of a dark red color.","pos":""}],"MURRHINE":[{"def":"Made of the stone or material called by the Romans murrha; -- applied to certain costly vases of great beauty and delicacy used by the luxurious in Rome as wine cups; as, murrhine vases, cups, vessels.","pos":""}],"MURRION":[{"def":"Infected with or killed by murrain.","pos":""}],"MURTH":[{"def":"Plenty; abundance.","pos":""}],"MURZA":[{"def":"One of the hereditary nobility among the Tatars, esp.","pos":""}]}