{"WHIP":[{"def":"To strike with a lash, a cord, a rod, or anything slender and lithe; to lash; to beat; as, to whip a horse, or a carpet.","pos":""},{"def":"To drive with lashes or strokes of a whip; to cause to rotate by lashing with a cord; as, to whip a top.","pos":""}],"WHIP-POOR-WILL":[{"def":"An American bird (Antrostomus vociferus) allied to the nighthawk and goatsucker; -- so called in imitation of the peculiar notes which it utters in the evening.","pos":""}],"WHIP-SHAPED":[{"def":"Shaped like the lash of a whip; long, slender, round, and tapering; as, a whip-shaped root or stem.","pos":""}],"WHIP-TOM-KELLY":[{"def":"A vireo (Vireo altiloquus) native of the West Indies and Florida; -- called also black-whiskered vireo.","pos":""}],"WHIPCORD":[{"def":"A kind of hard-twisted or braided cord, sometimes used for making whiplashes.","pos":""}],"WHIPGRAFT":[{"def":"To graft by cutting the scion and stock in a certain manner.","pos":""}],"WHIPLASH":[{"def":"The lash of a whip, -- usually made of thongs of leather, or of cords, braided or twisted.","pos":""}],"WHIPPAREE":[{"def":"Southern United States.","pos":""}],"WHIPPER":[{"def":"A kind of simple willow.","pos":""}],"WHIPPERIN":[{"def":"A huntsman who keeps the hounds from wandering, and whips them in, if necessary, to the of chase.","pos":""},{"def":"Hence, one who enforces the discipline of a party, and urges the attendance and support of the members on all necessary occasions.","pos":""}],"WHIPPERSNAPPER":[{"def":"A diminutive, insignificant, or presumptuous person.","pos":""}],"WHIPPING":[{"def":"Whip\"ping, Defn: a & n.","pos":""}],"WHIPPLETREE":[{"def":"The cornel tree.","pos":""}],"WHIPSAW":[{"def":"A saw for dividing timber lengthwise, usually set in a frame, and worked by two persons; also, a fret saw.","pos":""}],"WHIPSTAFF":[{"def":"A bar attached to the tiller, for convenience in steering.","pos":""}],"WHIPSTER":[{"def":"A nimble little fellow; a whippersnapper.","pos":""}],"WHIPSTICK":[{"def":"Whip handle; whipstock.","pos":""}],"WHIPSTITCH":[{"def":"The act or process of whipstitching.","pos":""}],"WHIPSTOCK":[{"def":"The rod or handle to which the lash of a whip is fastened.","pos":""}],"WHIPWORM":[{"def":"A nematode worm (Trichocephalus dispar) often found parasitic in the human intestine.","pos":""}]}