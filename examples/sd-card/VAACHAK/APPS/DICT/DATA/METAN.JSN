{"METANAUPLIUS":[{"def":"A larval crustacean in a stage following the nauplius, and having about seven pairs of appendages.","pos":""}],"METANEPHRITIC":[{"def":"Of or pertaining to the metanephros.","pos":""}],"METANEPHROS":[{"def":"The most posterior of the three pairs of embryonic renal organs developed in many vertebrates.","pos":""}],"METANOTUM":[{"def":"The dorsal portion of the metaphorax of insects.","pos":""}],"METANTIMONATE":[{"def":"A salt of metantimonic acid.","pos":""}]}