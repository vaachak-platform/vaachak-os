{"BRACCATE":[{"def":"Furnished with feathers which conceal the feet.","pos":""}],"BRACE":[{"def":"A piece of material used to transmit, or change the direction of, weight or pressure; any one of the pieces, in a frame or truss, which divide the structure into triangular parts.","pos":""},{"def":"A vertical curved line connecting two or more words or lines, which are to be taken together; thus, boll, bowl; or, in music, used to connect staves.","pos":""}],"BRACELET":[{"def":"An ornamental band or ring, for the wrist or the arm; in modern times, an ornament encircling the wrist, worn by women or girls.","pos":""},{"def":"A piece of defensive armor for the arm.","pos":""}],"BRACER":[{"def":"That which braces, binds, or makes firm; a band or bandage.","pos":""},{"def":"A covering to protect the arm of the bowman from the vibration of the string; also, a brassart.","pos":""}],"BRACH":[{"def":"A bitch of the hound kind.","pos":""}],"BRACHELYTRA":[{"def":"A group of beetles having short elytra, as the rove beetles.","pos":""}],"BRACHIAL":[{"def":"Pertaining or belonging to the arm; as, the brachial artery; the brachial nerve.","pos":""}],"BRACHIATA":[{"def":"A division of the Crinoidea, including those furnished with long jointed arms.","pos":""}],"BRACHIATE":[{"def":"Having branches in pairs, decussated, all nearly horizontal, and each pair at right angles with the next, as in the maple and lilac.","pos":""}],"BRACHIOGANOID":[{"def":"One of the Brachioganoidei.","pos":""}],"BRACHIOGANOIDEI":[{"def":"An order of ganoid fishes of which the bichir of Africa is a living example.","pos":""}],"BRACHIOPOD":[{"def":"One of the Brachiopoda, or its shell.","pos":""}],"BRACHIOPODA":[{"def":"A class of Molluscoidea having a symmetrical bivalve shell, often attached by a fleshy peduncle.","pos":""}],"BRACHIUM":[{"def":"The upper arm; the segment of the fore limb between the shoulder and the elbow.","pos":""}],"BRACHYCATALECTIC":[{"def":"A verse wanting two syllables at its termination.","pos":""},{"def":"Having the skull short in proportion to its breadth; shortheaded; -- in distinction from dolichocephalic.","pos":""}],"BRACHYCERAL":[{"def":"Having short antennæ, as certain insects.","pos":""}],"BRACHYDIAGONAL":[{"def":"Pertaining to the shorter diagonal, as of a rhombic prism.","pos":""}],"BRACHYDOME":[{"def":"A dome parallel to the shorter lateral axis.","pos":""}],"BRACHYGRAPHER":[{"def":"A writer in short hand; a stenographer.","pos":""}],"BRACHYLOGY":[{"def":"Conciseness of expression; brevity.","pos":""}],"BRACHYPINACOID":[{"def":"A plane of an orthorhombic crystal which is parallel both to the vertical axis and to the shorter lateral (brachydiagonal) axis.","pos":""}],"BRACHYPTERA":[{"def":"A group of Coleoptera having short wings; the rove beetles.","pos":""}],"BRACHYPTERES":[{"def":"A group of birds, including auks, divers, and penguins.","pos":"noun"}],"BRACHYPTEROUS":[{"def":"Having short wings.","pos":""}],"BRACHYSTOCHRONE":[{"def":"A curve, in which a body, starting from a given point, and descending solely by the force of gravity, will reach another given point in a shorter time than it could by any other path.","pos":""}],"BRACHYTYPOUS":[{"def":"Of a short form.","pos":""}],"BRACHYURA":[{"def":"A group of decapod Crustacea, including the common crabs, characterized by a small and short abdomen, which is bent up beneath the large cephalo-thorax.","pos":""},{"def":"Of or pertaining to the Brachyura.","pos":""}],"BRACHYURAN":[{"def":"One of the Brachyura.","pos":""}],"BRACING":[{"def":"Imparting strength or tone; strengthening; invigorating; as, a bracing north wind.","pos":""}],"BRACK":[{"def":"An opening caused by the parting of any solid body; a crack or breach; a flaw.","pos":""}],"BRACKEN":[{"def":"A brake or fern.","pos":""}],"BRACKET":[{"def":"An architectural member, plain or ornamental, projecting from a wall or pier, to support weight falling outside of the same; also, a decorative feature seeming to discharge such an office.","pos":""},{"def":"A piece or combination of pieces, usually triangular in general shape, projecting from, or fastened to, a wall, or other surface, to support heavy bodies or to strengthen angles.","pos":""}],"BRACKETING":[{"def":"A series or group of brackets; brackets, collectively.","pos":""}],"BRACKISH":[{"def":"Saltish, or salt in a moderate degree, as water in saline soil.","pos":""}],"BRACKISHNESS":[{"def":"The quality or state of being brackish, or somewhat salt.","pos":""}],"BRACT":[{"def":"Note: Bracts are often inconspicuous, but sometimes large and showy, or highly colored, as in many cactaceous plants.","pos":""}],"BRACTEAL":[{"def":"Having the nature or appearance of a bract.","pos":""}],"BRACTEATE":[{"def":"Having a bract or bracts.","pos":""}],"BRACTED":[{"def":"Furnished with bracts.","pos":""}],"BRACTEOLATE":[{"def":"Furnished with bracteoles or bractlets.","pos":""}],"BRACTEOLE":[{"def":"Same as Bractlet.","pos":""}],"BRACTLESS":[{"def":"Destitute of bracts.","pos":""}],"BRACTLET":[{"def":"A bract on the stalk of a single flower, which is itself on a main stalk that support several flowers.","pos":""}]}