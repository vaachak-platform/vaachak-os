{"ELECTROTYPIC":[{"def":"Pertaining to, or effected by means of, electrotypy.","pos":""}],"ELECTROTYPING":[{"def":"The act or the process of making electrotypes.","pos":""}],"ELECTROTYPY":[{"def":"The process of producing electrotype plates.","pos":""}],"ELECTRUM":[{"def":"An alloy of gold and silver, of an amber color, used by the ancients.","pos":""}],"ELECTUARY":[{"def":"A medicine composed of powders, or other ingredients, incorporated with some convserve, honey, or sirup; a confection.","pos":""}]}