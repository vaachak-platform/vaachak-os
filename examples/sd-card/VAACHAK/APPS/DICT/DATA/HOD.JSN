{"HOD":[{"def":"A kind of wooden tray with a handle, borne on the shoulder, for carrying mortar, brick, etc.","pos":""},{"def":"A utensil for holding coal; a coal scuttle.","pos":""}],"HODDENGRAY":[{"def":"Applied to coarse cloth made of undyed wool, formerly worn by Scotch peasants.","pos":""}],"HODDY":[{"def":"See Dun crow, under Dun, a.","pos":""}],"HODDYDODDY":[{"def":"An awkward or foolish person.","pos":""}],"HODGEPODGE":[{"def":"A mixed mass; a medley.","pos":""}],"HODGKIN'S DISEASE":[{"def":"A morbid condition characterized by progressive anæmia and enlargement of the lymphatic glands; -- first described by Dr.","pos":""},{"def":"Of this day; belonging to the present day.","pos":""}],"HODMAN":[{"def":"A man who carries a hod; a mason's tender.","pos":""}],"HODOGRAPH":[{"def":"A curve described by the moving extremity of a line the other end of which is fixed, this line being constantly parallel to the direction of motion of, and having its length constantly proportional to the velocity of, a point moving in any path; -used in investigations respecting central forces.","pos":""}]}