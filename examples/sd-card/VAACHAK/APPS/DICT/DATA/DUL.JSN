{"DULCAMARA":[{"def":"A plant (Solanum Dulcamara).","pos":""}],"DULCAMARIN":[{"def":"A glucoside extracted from the bittersweet (Solanum Dulcamara), as a yellow amorphous substance.","pos":""}],"DULCE":[{"def":"To make sweet; to soothe.","pos":""}],"DULCET":[{"def":"Sweet to the taste; luscious.","pos":""},{"def":"Sweet to the ear; melodious; harmonious.","pos":""}],"DULCIANA":[{"def":"A sweet-toned stop of an organ.","pos":""}],"DULCIFICATION":[{"def":"The act of dulcifying or sweetening.","pos":""}],"DULCIFIED":[{"def":"Sweetened; mollified.","pos":""}],"DULCIFLUOUS":[{"def":"Flowing sweetly.","pos":""}],"DULCIFY":[{"def":"To sweeten; to free from acidity, saltness, or acrimony.","pos":""}],"DULCILOQUY":[{"def":"A soft manner of speaking.","pos":""}],"DULCIMER":[{"def":"It is supposed to be the same with the psaltery.","pos":""}],"DULCINEA":[{"def":"A mistress; a sweetheart.","pos":""}],"DULCITE":[{"def":"A white, sugarlike substance, C6H8.","pos":""}],"DULCORATE":[{"def":"To sweeten; to make less acrimonious.","pos":""}],"DULCORATION":[{"def":"The act of sweetening.","pos":""}],"DULEDGE":[{"def":"One of the dowels joining the ends of the fellies which form the circle of the wheel of a gun carriage.","pos":""}],"DULIA":[{"def":"An inferior kind of veneration or worship, given to the angels and saints as the servants of God.","pos":""}],"DULL":[{"def":"Slow of understanding; wanting readiness of apprehension; stupid; doltish; blockish.","pos":""},{"def":"Slow in action; sluggish; unready; awkward.","pos":""}],"DULL-BRAINED":[{"def":"Stupid; doltish.","pos":""}],"DULL-BROWED":[{"def":"Having a gloomy look.","pos":""}],"DULL-EYED":[{"def":"Having eyes wanting brightness, liveliness, or vivacity.","pos":""}],"DULL-SIGHTED":[{"def":"Having poor eyesight.","pos":""}],"DULLARD":[{"def":"A stupid person; a dunce.","pos":""}],"DULLER":[{"def":"One who, or that which, dulls.","pos":""}],"DULLHEAD":[{"def":"A blockhead; a dolt.","pos":""}],"DULLISH":[{"def":"Somewhat dull; uninteresting; tiresome.","pos":""}],"DULLNESS":[{"def":"The state of being dull; slowness; stupidity; heaviness; drowsiness; bluntness; obtuseness; dimness; want of luster; want of vividness, or of brightness.","pos":""}],"DULLY":[{"def":"In a dull manner; stupidly; slowly; sluggishly; without life or spirit.","pos":""}],"DULSE":[{"def":"A seaweed of a reddish brown color, which is sometimes eaten, as in Scotland.","pos":""}],"DULWILLY":[{"def":"The ring plover.","pos":""}],"DULY":[{"def":"In a due, fit, or becoming manner; as it (anything) ought to be; properly; regularly.","pos":""}]}