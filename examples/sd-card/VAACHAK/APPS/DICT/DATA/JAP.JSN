{"JAPAN":[{"def":"Work varnished and figured in the Japanese manner; also, the varnish or lacquer used in japanning.","pos":""}],"JAPAN CURRENT":[{"def":"A branch of the equatorial current of the Pacific, washing the eastern coast of Formosa and thence flowing northeastward past Japan and merging into the easterly drift of the North Pacific; -- called also Kuro-Siwo, or Black Stream, in allusion to the deep blue of its water.","pos":""}],"JAPANESE":[{"def":"Of or pertaining to Japan, or its inhabitants.","pos":""}],"JAPANNED":[{"def":"Treated, or coated, with varnish in the Japanese manner.","pos":""}],"JAPANNER":[{"def":"One who varnishes in the manner of the Japanese, or one skilled in the art.","pos":""}],"JAPANNING":[{"def":"The art or act of varnishing in the Japanese manner.","pos":""}],"JAPANNISH":[{"def":"After the manner of the Japanese; resembling japanned articles.","pos":""}],"JAPE":[{"def":"To jest; to play tricks; to jeer.","pos":""}],"JAPER":[{"def":"A jester; a buffoon.","pos":""}],"JAPERY":[{"def":"Jesting; buffoonery.","pos":""}],"JAPHETIC":[{"def":"Pertaining to, or derived from, Japheth, one of the sons of Noah; as, Japhetic nations, the nations of Europe and Northern Asia; Japhetic languages.","pos":""}],"JAPHETITE":[{"def":"A descendant of Japheth.","pos":""}],"JAPONICA":[{"def":"A species of Camellia (Camellia Japonica), a native of Japan, bearing beautiful red or white flowers.","pos":""}],"JAPONISM":[{"def":"A quality, idiom, or peculiarity characteristic of the Japanese or their products, esp.","pos":""}]}