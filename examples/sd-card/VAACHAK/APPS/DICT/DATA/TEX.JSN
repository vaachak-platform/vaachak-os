{"TEXAS":[{"def":"A structure on the hurricane deck of a steamer, containing the pilot house, officers' cabins, etc.","pos":""}],"TEXAS LEAGUER":[{"def":"A short fly that falls too far out to be handled by an infielder and too close in to be caught by an outfielder.","pos":""}],"TEXT":[{"def":"The four Gospels, by way of distinction or eminence.","pos":""}],"TEXT HAND":[{"def":"A large hand in writing; -- so called because it was the practice to write the text of a book in a large hand and the notes in a smaller hand.","pos":""}],"TEXT-BOOK":[{"def":"A book with wide spaces between the lines, to give room for notes.","pos":""},{"def":"A volume, as of some classical author, on which a teacher lectures or comments; hence, any manual of instruction; a schoolbook.","pos":""}],"TEXT-HAND":[{"def":"A large hand in writing; -- so called because it was the practice to write the text of a book in a large hand and the notes in a smaller hand.","pos":""}],"TEXTILE":[{"def":"Pertaining to weaving or to woven fabrics; as, textile arts; woven, capable of being woven; formed by weaving; as, textile fabrics.","pos":""}],"TEXTMAN":[{"def":"One ready in quoting texts.","pos":""}],"TEXTORIAL":[{"def":"Of or pertaining to weaving.","pos":""}],"TEXTRINE":[{"def":"Of or pertaining to weaving, textorial; as, the textrine art.","pos":""}],"TEXTUAL":[{"def":"Of, pertaining to, or contained in, the text; as, textual criticism; a textual reading.","pos":""},{"def":"Serving for, or depending on, texts.","pos":""}],"TEXTUALIST":[{"def":"A textman; a textuary.","pos":""}],"TEXTUALLY":[{"def":"In a textual manner; in the text or body of a work; in accordance with the text.","pos":""}],"TEXTUARY":[{"def":"Contained in the text; textual.","pos":""},{"def":"Serving as a text; authoritative.","pos":""}],"TEXTUIST":[{"def":"A textualist; a textman.","pos":""}],"TEXTURAL":[{"def":"Of or pertaining to texture.","pos":""}],"TEXTURE":[{"def":"The act or art of weaving.","pos":""},{"def":"That which woven; a woven fabric; a web.","pos":""}],"TEXTURY":[{"def":"The art or process of weaving; texture.","pos":""}]}