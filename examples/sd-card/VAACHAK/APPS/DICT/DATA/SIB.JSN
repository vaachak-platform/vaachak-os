{"SIB":[{"def":"A blood relation.","pos":""}],"SIBBENS":[{"def":"A contagious disease, endemic in Scotland, resembling the yaws.","pos":""}],"SIBERIAN":[{"def":"Of or pertaining to Siberia, a region comprising all northern Asia and belonging to Russia; as, a Siberian winter.","pos":""},{"def":"A native or inhabitant of Siberia.","pos":""}],"SIBILANT":[{"def":"Making a hissing sound; uttered with a hissing sound; hissing; as, s, z, sh, and zh, are sibilant elementary sounds.","pos":""},{"def":"A sibiliant letter.","pos":""}],"SIBILATE":[{"def":"To pronounce with a hissing sound, like that of the letter s; to mark with a character indicating such pronunciation.","pos":""}],"SIBILATION":[{"def":"Utterance with a hissing sound; also, the sound itself; a hiss.","pos":""}],"SIBILATORY":[{"def":"Hissing; sibilant.","pos":""}],"SIBILOUS":[{"def":"Having a hissing sound; hissing; sibilant.","pos":""}],"SIBYL":[{"def":"A woman supposed to be endowed with a spirit of prophecy.","pos":""}],"SIBYLIST":[{"def":"One who believes in a sibyl or the sibylline prophecies.","pos":""}],"SIBYLLINE":[{"def":"Pertaining to the sibyls; uttered, written, or composed by sibyls; like the productions of sibyls.","pos":""}]}