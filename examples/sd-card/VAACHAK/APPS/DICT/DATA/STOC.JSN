{"STOCAH":[{"def":"A menial attendant.","pos":""}],"STOCCADO":[{"def":"A stab; a thrust with a rapier.","pos":""}],"STOCHASTIC":[{"def":"Conjectural; able to conjecture.","pos":""}],"STOCK":[{"def":"Same as Stock account, below.","pos":""},{"def":"Domestic animals or beasts collectively, used or raised on a farm; as, a stock of cattle or of sheep, etc.","pos":""}],"STOCK-BLIND":[{"def":"Blind as a stock; wholly blind.","pos":""}],"STOCK-STILL":[{"def":"Still as a stock, or fixed post; perfectly still.","pos":""}],"STOCKADE":[{"def":"A line of stout posts or timbers set firmly in the earth in contact with each other (and usually with loopholes) to form a barrier, or defensive fortification.","pos":""}],"STOCKBROKER":[{"def":"A broker who deals in stocks.","pos":""}],"STOCKDOVE":[{"def":"A common European wild pigeon (Columba ænas), so called because at one time believed to be the stock of the domestic pigeon, or, according to some, from its breeding in the stocks, or trunks, of trees.","pos":""}],"STOCKER":[{"def":"One who makes or fits stocks, as of guns or gun carriages, etc.","pos":""}],"STOCKFISH":[{"def":"Young fresh cod.","pos":""}],"STOCKHOLDER":[{"def":"One who is a holder or proprietor of stock in the public funds, or in the funds of a bank or other stock company.","pos":""}],"STOCKINET":[{"def":"An elastic textile fabric imitating knitting, of which stockings, under-garments, etc.","pos":""}],"STOCKING":[{"def":"A close-fitting covering for the foot and leg, usually knit or woven.","pos":""}],"STOCKINGER":[{"def":"A stocking weaver.","pos":""}],"STOCKISH":[{"def":"Like a stock; stupid; blockish.","pos":""}],"STOCKJOBBER":[{"def":"One who speculates in stocks for gain; one whose occupation is to buy and sell stocks.","pos":""}],"STOCKJOBBING":[{"def":"The act or art of dealing in stocks; the business of a stockjobber.","pos":""}],"STOCKMAN":[{"def":"A herdsman; a ranchman; one owning, or having charge of, herds of live stock.","pos":""}],"STOCKWORK":[{"def":"A system of working in ore, etc.","pos":""},{"def":"A metalliferous deposit characterized by the impregnation of the mass of rock with many small veins or nests irregularly grouped.","pos":""}],"STOCKY":[{"def":"Short and thick; thick rather than tall or corpulent.","pos":""}]}