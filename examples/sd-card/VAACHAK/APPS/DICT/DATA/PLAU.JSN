{"PLAUDIT":[{"def":"A mark or expression of applause; praise bestowed.","pos":""}],"PLAUDITORY":[{"def":"Applauding; commending.","pos":""}],"PLAUSIBILITY":[{"def":"Something worthy of praise.","pos":""},{"def":"The quality of being plausible; speciousness.","pos":""}],"PLAUSIBLE":[{"def":"Worthy of being applauded; praiseworthy; commendable; ready.","pos":""},{"def":"Obtaining approbation; specifically pleasing; apparently right; specious; as, a plausible pretext; plausible manners; a plausible delusion.","pos":""}],"PLAUSIBLEIZE":[{"def":"To render plausible.","pos":""}],"PLAUSIBLENESS":[{"def":"Quality of being plausible.","pos":""}],"PLAUSIBLY":[{"def":"In a plausible manner.","pos":""},{"def":"Contentedly, readily.","pos":""}],"PLAUSIVE":[{"def":"Applauding; manifesting praise.","pos":""},{"def":"Plausible, specious.","pos":""}]}