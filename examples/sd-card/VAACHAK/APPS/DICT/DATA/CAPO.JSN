{"CAPO TASTO":[{"def":"A sort of bar or movable nut, attached to the finger board of a guitar or other fretted instrument for the purpose of raising uniformly the pitch of all the strings.","pos":""}],"CAPOC":[{"def":"A sort of cotton so short and fine thet it can not be spun, used in the East Indies to line palanquins, to make mattresses, etc.","pos":""}],"CAPOCH":[{"def":"A hood; especialy, the hood attached to the gown of a monk.","pos":""}],"CAPON":[{"def":"A castrated cock, esp.","pos":""}],"CAPONIERE":[{"def":"A work made across or in the ditch, to protect it from the enemy, or to serve as a covered passageway.","pos":""}],"CAPONIZE":[{"def":"To castrate, as a fowl.","pos":""}],"CAPORAL":[{"def":"One who directs work; an overseer.","pos":""}],"CAPOT":[{"def":"A winning of all the tricks at the game of piquet.","pos":""}],"CAPOTE":[{"def":"A long cloak or overcoat, especially one with a hood.","pos":""}]}