{"RAP":[{"def":"A lay or skein containing 120 yards of yarn.","pos":""}],"RAPACES":[{"def":"Same as Accipitres.","pos":""}],"RAPACIOUS":[{"def":"Given to plunder; disposed or accustomed to seize by violence; seizing by force.","pos":""},{"def":"Accustomed to seize food; subsisting on prey, or animals seized by violence,; as, a tiger is a rapacious animal; a rapacious bird.","pos":""}],"RAPACITY":[{"def":"The quality of being rapacious; rapaciousness; ravenousness; as, the rapacity of pirates; the rapacity of wolves.","pos":""},{"def":"The act or practice of extorting or exacting by oppressive injustice; exorbitant greediness of gain.","pos":""}],"RAPE":[{"def":"Fruit, as grapes, plucked from the cluster.","pos":""},{"def":"The refuse stems and skins of grapes or raisins from which the must has been expressed in wine making.","pos":""}],"RAPEFUL":[{"def":"Given to the commission of rape.","pos":""}],"RAPHAELESQUE":[{"def":"Like Raphael's works; in Raphael's manner of painting.","pos":""}],"RAPHAELISM":[{"def":"The principles of painting introduced by Raphael, the Italian painter.","pos":""}],"RAPHAELITE":[{"def":"One who advocates or adopts the principles of Raphaelism.","pos":""}],"RAPHANY":[{"def":"A convulsive disease, attended with ravenous hunger, not uncommon in Sweden and Germany.","pos":""}],"RAPHE":[{"def":"A line, ridge, furrow, or band of fibers, especially in the median line; as, the raphe of the tongue.","pos":""}],"RAPID":[{"def":"Very swift or quick; moving with celerity; fast; as, a rapid stream; a rapid flight; a rapid motion.","pos":""},{"def":"Advancing with haste or speed; speedy in progression; in quick sequence; as, rapid growth; rapid improvement; rapid recurrence; rapid succession.","pos":""}],"RAPID-FIRE MOUNT":[{"def":"A mount permitting easy and quick elevation or depression and training of the gun, and fitting with a device for taking up the recoil.","pos":""}],"RAPIDITY":[{"def":"The quality or state of being rapid; swiftness; celerity; velocity; as, the rapidity of growth or improvement.","pos":""}],"RAPIDLY":[{"def":"In a rapid manner.","pos":""}],"RAPIDNESS":[{"def":"Quality of being rapid; rapidity.","pos":""}],"RAPIER":[{"def":"A straight sword, with a narrow and finely pointed blade, used only for thrusting.","pos":""}],"RAPIERED":[{"def":"Wearing a rapier.","pos":""}],"RAPINE":[{"def":"The act of plundering; the seizing and carrying away of things by force; spoliation; pillage; plunder.","pos":""},{"def":"Ravishment; rape.","pos":""}],"RAPINOUS":[{"def":"Given to rapine.","pos":""}],"RAPPAGE":[{"def":"The enlargement of a molt caused by rapping the pattern.","pos":""}],"RAPPAREE":[{"def":"A wild Irish plunderer, esp.","pos":""}],"RAPPED":[{"def":"Rapped (râpt), Defn: imp.","pos":""}],"RAPPEE":[{"def":"A pungent kind of snuff made from the darker and ranker kinds of tobacco leaves.","pos":""}],"RAPPEL":[{"def":"The beat of the drum to call soldiers to arms.","pos":""}],"RAPPER":[{"def":"One who, or that which, raps or knocks; specifically, the knocker of a door.","pos":""},{"def":"A forcible oath or lie.","pos":""}],"RAPPORT":[{"def":"Relation; proportion; conformity; correspondence; accord.","pos":""}],"RAPPROCHEMENT":[{"def":"Act or fact of coming or being drawn near or together; establishment or state of cordial relations.","pos":""}],"RAPSCALLION":[{"def":"A rascal; a good-for-nothing fellow.","pos":""}],"RAPT":[{"def":"Snatched away; hurried away or along.","pos":""},{"def":"Transported with love, admiration, delight, etc.","pos":""}],"RAPTOR":[{"def":"A ravisher; a plunderer.","pos":""}],"RAPTORES":[{"def":"Same as Accipitres.","pos":""}],"RAPTURE":[{"def":"A seizing by violence; a hurrying along; rapidity with violence.","pos":""},{"def":"The state or condition of being rapt, or carried away from one's self by agreeable excitement; violence of a pleasing passion; extreme joy or pleasure; ecstasy.","pos":""}],"RAPTURIZE":[{"def":"To put, or be put, in a state of rapture.","pos":""}],"RAPTUROUS":[{"def":"Ecstatic; transporting; ravishing; feeling, expressing, or manifesting rapture; as, rapturous joy, pleasure, or delight; rapturous applause.","pos":""}],"RAPTUROUSLY":[{"def":"In a rapturous manner.","pos":""}]}