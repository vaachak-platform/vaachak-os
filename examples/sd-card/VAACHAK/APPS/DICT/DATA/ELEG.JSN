{"ELEGANT":[{"def":"Exercising a nice choice; discriminating beauty or sensitive to beauty; as, elegant taste.","pos":""}],"ELEGANTLY":[{"def":"In a manner to please nice taste; with elegance; with due symmetry; richly.","pos":""}],"ELEGIAC":[{"def":"Belonging to elegy, or written in elegiacs; plaintive; expressing sorrow or lamentation; as, an elegiac lay; elegiac strains.","pos":""},{"def":"Used in elegies; as, elegiac verse; the elegiac distich or couplet, consisting of a dactylic hexameter and pentameter.","pos":""}],"ELEGIAST":[{"def":"One who composes elegies.","pos":""}],"ELEGIOGRAPHER":[{"def":"El`e*gi*og\"ra*pher, n.","pos":""}],"ELEGIST":[{"def":"A write of elegies.","pos":""}],"ELEGIT":[{"def":"A judicial writ of execution, by which a defendant's goods are appraised and delivered to the plaintiff, and, if no sufficient to satisfy the debt, all of his lands are delivered, to be held till the debt is paid by the rents and profits, or until the defendant's interest has expired.","pos":""}],"ELEGIZE":[{"def":"To lament in an elegy; to celebrate in elegiac verse; to bewail.","pos":""}],"ELEGY":[{"def":"A mournful or plaintive poem; a funereal song; a poem of lamentation.","pos":""}]}