{"PRORATABLE":[{"def":"Capable of being prorated, or divided proportionately.","pos":""}],"PRORATE":[{"def":"To divide or distribute proportionally; to assess pro rata.","pos":""}],"PRORE":[{"def":"The prow or fore part of a ship.","pos":""}],"PRORECTOR":[{"def":"An officer who presides over the academic senate of a German university.","pos":""}],"PRORECTORATE":[{"def":"The office of prorector.","pos":""}],"PRORHINAL":[{"def":"Situated in front of the nasal chambers.","pos":""}],"PROROGATION":[{"def":"The act of counting in duration; prolongation.","pos":""},{"def":"The act of proroguing; the ending of the session of Parliament, and postponing of its business, by the command of the sovereign.","pos":""}],"PROROGUE":[{"def":"To protract; to prolong; to extend.","pos":""},{"def":"To defer; to delay; to postpone; as, to proroguedeath; to prorogue a marriage.","pos":""}],"PRORUPTION":[{"def":"The act or state of bursting forth; a bursting out.","pos":""}]}