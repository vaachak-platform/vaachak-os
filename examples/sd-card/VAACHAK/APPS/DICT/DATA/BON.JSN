{"BON":[{"def":"Good; valid as security for something.","pos":""}],"BON SILENE":[{"def":"A very fragrant tea rose with petals of various shades of pink.","pos":""}],"BON TON":[{"def":"The height of the fashion; fashionable society.","pos":""}],"BON VIVANT":[{"def":"A good fellow; a jovial companion; a free liver.","pos":""}],"BON-ACCORD":[{"def":"Good will; good fellowship; agreement.","pos":""}],"BONA FIDE":[{"def":"In or with good faith; without fraud or deceit; real or really; actual or actually; genuine or genuinely; as, you must proceed bona fide; a bona fide purchaser or transaction.","pos":""}],"BONA FIDES":[{"def":"Good faith; honesty; freedom from fraud or deception.","pos":""}],"BONA PERITURA":[{"def":"Perishable goods.","pos":""}],"BONA ROBA":[{"def":"A showy wanton; a courtesan.","pos":""},{"def":"The aurochs or European bison.","pos":""}],"BONACI":[{"def":"Indies, valuable as a food fish; -- called also aguaji and, in Florida, black grouper.","pos":""}],"BONAIR":[{"def":"Gentle; courteous; complaisant; yielding.","pos":""}],"BONANZA":[{"def":"In mining, a rich mine or vein of silver or gold; hence, anything which is a mine of wealth or yields a large income.","pos":""}],"BONAPARTEAN":[{"def":"Of or pertaining to Napoleon Bonaparte or his family.","pos":""}],"BONAPARTISM":[{"def":"The policy of Bonaparte or of the Bonapartes.","pos":""}],"BONAPARTIST":[{"def":"One attached to the policy or family of Bonaparte, or of the Bonapartes.","pos":""}],"BONBON":[{"def":"Sugar confectionery; a sugarplum; hence, any dainty.","pos":""}],"BONBONNIERE":[{"def":"A small fancy box or dish for bonbons.","pos":""}],"BONCE":[{"def":"A boy's game played with large marbles.","pos":""}],"BONCHRETIEN":[{"def":"A name given to several kinds of pears.","pos":""}],"BONCILATE":[{"def":"A substance composed of ground bone, mineral matters, etc.","pos":""}],"BOND":[{"def":"The state of being bound; imprisonment; captivity, restraint.","pos":""},{"def":"A writing under seal, by which a person binds himself, his heirs, executors, and administrators, to pay a certain sum on or before a future day appointed.","pos":""}],"BOND SERVANT":[{"def":"A slave; one who is bound to service without wages.","pos":""}],"BOND SERVICE":[{"def":"The condition of a bond servant; sevice without wages; slavery.","pos":""}],"BONDAGE":[{"def":"Villenage; tenure of land on condition of doing the meanest services for the owner.","pos":""}],"BONDAGER":[{"def":"A field worker, esp.","pos":""}],"BONDAR":[{"def":"A small quadruped of Bengal (Paradoxurus bondar), allied to the genet; -- called also musk cat.","pos":""}],"BONDED":[{"def":"Placed under, or covered by, a bond, as for the payment of duties, or for conformity to coertain regulations.","pos":""}],"BONDER":[{"def":"A bonding stone or brick; a bondstone.","pos":""}],"BONDHOLDER":[{"def":"A person who holds the bonds of a public or private corporation for the payment of money at a certain time.","pos":""}],"BONDMAID":[{"def":"A female slave, or one bound to service without wages, as distinguished from a hired servant.","pos":""}],"BONDMAN":[{"def":"A villain, or tenant in villenage.","pos":""}],"BONDSLAVE":[{"def":"A person in a state of slavery; one whose person and liberty are subjected to the authority of a master.","pos":""}],"BONDSMAN":[{"def":"A surety; one who is bound, or who gives security, for another.","pos":""}],"BONDSTONE":[{"def":"A stone running through a wall from one face to another, to bind it together; a binding stone.","pos":""}],"BONDUC":[{"def":"See Nicker tree.","pos":""}],"BONDWOMAN":[{"def":"A woman who is a slave, or in bondage.","pos":""}],"BONE":[{"def":"The hard, calcified tissue of the skeleton of vertebrate animals, consisting very largely of calcic carbonate, calcic phosphate, and gelatine; as, blood and bone.","pos":""},{"def":"Two or four pieces of bone held between the fingers and struck together to make a kind of music.","pos":""}],"BONEACHE":[{"def":"Pain in the bones.","pos":""}],"BONEBLACK":[{"def":"See Bone black, under Bone, n.","pos":""}],"BONED":[{"def":"Having (such) bones; -- used in composition; as, big-boned; strong-boned.","pos":""},{"def":"Deprived of bones; as, boned turkey or codfish.","pos":""}],"BONEDOG":[{"def":"The spiny dogfish.","pos":""}],"BONESET":[{"def":"A medicinal plant, the thoroughwort (Eupatorium perfoliatum).","pos":""}],"BONESETTER":[{"def":"One who sets broken or dislocated bones; -- commonly applied to one, not a regular surgeon, who makes an occupation of setting bones.","pos":""}],"BONFIRE":[{"def":"A large fire built in the open air, as an expression of public joy and exultation, or for amusement.","pos":""}],"BONGO":[{"def":"Either of two large antelopes (Boöcercus eurycercus of West Africa, and B.","pos":""}],"BONGRACE":[{"def":"A projecting bonnet or shade to protect the complexion; also, a wide-brimmed hat.","pos":""},{"def":"good nature; pleasant and easy manner.","pos":""}],"BONIFORM":[{"def":"Sensitive or responsive to moral excellence.","pos":""}],"BONIFY":[{"def":"To convert into, or make, good.","pos":""}],"BONINESS":[{"def":"The condition or quality of being bony.","pos":""}],"BONING":[{"def":"The clearing of bones from fish or meat.","pos":""},{"def":"The manuring of land with bones.","pos":""}],"BONITARY":[{"def":"Beneficial, as opposed to statutory or civil; as, bonitary dominion of land.","pos":""}],"BONITO":[{"def":"A large tropical fish (Orcynus pelamys) allied to the tunny.","pos":""},{"def":"The skipjack (Sarda Mediterranea) of the Atlantic, an important and abundant food fish on the coast of the United States, and (S.","pos":""}],"BONMOT":[{"def":"A witty repartee; a jest.","pos":""}],"BONNAZ":[{"def":"A kind of embroidery made with a complicated sewing machine, said to have been originally invented by a Frenchman of the name of Bonnaz.","pos":""}],"BONNE BOUCHE":[{"def":"A delicious morsel or mouthful; a tidbit.","pos":""}],"BONNET":[{"def":"An additional piece of canvas laced to the foot of a jib or foresail in moderate winds.","pos":""}],"BONNET ROUGE":[{"def":"The red cap adopted by the extremists in the French Revolution, which became a sign of patriotism at that epoch; hence, a revolutionist; a Red Republican.","pos":""}],"BONNETED":[{"def":"Protected by a bonnet.","pos":""}],"BONNETLESS":[{"def":"Without a bonnet.","pos":""}],"BONNIBEL":[{"def":"A handsome girl.","pos":""}],"BONNILASS":[{"def":"A \"bonny lass\"; a beautiful girl.","pos":""}],"BONNILY":[{"def":"Gayly; handsomely.","pos":""}],"BONNINESS":[{"def":"The quality of being bonny; gayety [R.","pos":""}],"BONNY":[{"def":"Handsome; beautiful; pretty; attractively lively and graceful.","pos":""},{"def":"Gay; merry; frolicsome; cheerful; blithe.","pos":""}],"BONNYCLABBER":[{"def":"Coagulated sour milk; loppered milk; curdled milk; -- sometimes called simply clabber.","pos":""}],"BONTEBOK":[{"def":"The pied antelope of South Africa (Alcelaphus pygarga).","pos":""}],"BONUS":[{"def":"A premium given for a loan, or for a charter or other privilege granted to a company; as the bank paid a bonus for its charter.","pos":""}],"BONY":[{"def":"Consisting of bone, or of bones; full of bones; pertaining to bones.","pos":""},{"def":"Having large or prominent bones.","pos":""}],"BONZE":[{"def":"A Buddhist or Fohist priest, monk, or nun.","pos":""}]}