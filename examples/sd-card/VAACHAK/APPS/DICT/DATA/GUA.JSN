{"GUACHARO":[{"def":"A nocturnal bird of South America and Trinidad (Steatornis Caripensis, or S.","pos":""}],"GUACHO":[{"def":"One of the mixed-blood (Spanish-Indian) inhabitants of the pampas of South America; a mestizo.","pos":""},{"def":"An Indian who serves as a messenger.","pos":""}],"GUAIAC":[{"def":"Pertaining to, or resembling, guaiacum.","pos":""}],"GUAIACOL":[{"def":"A colorless liquid, C7H8O2, with a peculiar odor.","pos":""}],"GUAIACUM":[{"def":"A genus of small, crooked trees, growing in tropical America.","pos":""}],"GUAN":[{"def":"Any one of many species of large gallinaceous birds of Certal and South America, belonging to Penelope, Pipile, Ortalis, and allied genera.","pos":""}],"GUANACO":[{"def":"A South American mammal (Auchenia huanaco), allied to the llama, but of larger size and more graceful form, inhabiting the southern Andes and Patagonia.","pos":""}],"GUANIDINE":[{"def":"A strongly alkaline base, CN3H5, formed by the oxidation of guanin, and also obtained combined with methyl in the decomposition of creatin.","pos":""}],"GUANIN":[{"def":"A crystalline substance (C5H5N5O) contained in guano.","pos":""}],"GUANO":[{"def":"A substance found in great abundance on some coasts or islands frequented by sea fowls, and composed chiefly of their excrement.","pos":""}],"GUARANA":[{"def":"A preparation from the seeds of Paullinia sorbilis, a woody climber of Brazil, used in making an astringent drink, and also in the cure of headache.","pos":""}],"GUARANINE":[{"def":"An alkaloid extracted from guarana.","pos":""}],"GUARANTEE":[{"def":"The person to whom a guaranty is made; -- the correlative of guarantor.","pos":""}],"GUARANTY":[{"def":"In law and common usage: An undertaking to answer for the payment of some debt, or the performance of some contract or duty, of another, in case of the failure of such other to pay or perform; a guarantee; a warranty; a security.","pos":""}],"GUARD":[{"def":"To protect from danger; to secure against surprise, attack, or injury; to keep in safety; to defend; to shelter; to shield from surprise or attack; to protect by attendance; toaccompany for protection; to vare for.","pos":""},{"def":"To keep watch over, in order to prevent escape or restrain from acts of violence, or the like.","pos":""}],"GUARDABLE":[{"def":"Capable of being guarded or protected.","pos":""}],"GUARDANT":[{"def":"Same as Gardant.","pos":""}],"GUARDED":[{"def":"Cautious; wary; circumspect; as, he was guarded in his expressions; framed or uttered with caution; as, his expressions were guarded.","pos":""}],"GUARDFUL":[{"def":"Cautions; wary; watchful.","pos":""}],"GUARDHOUSE":[{"def":"A building which is occupied by the guard, and in which soldiers are confined for misconduct; hence, a lock-up.","pos":""}],"GUARDIAN":[{"def":"One who has, or is entitled to, the custody of the person or property of an infant, a minor without living parents, or a person incapable of managing his own affairs.","pos":""}],"GUARDIANESS":[{"def":"A female guardian.","pos":""}],"GUARDIANLESS":[{"def":"Without a guardian.","pos":""}],"GUARDIANSHIP":[{"def":"The office, duty, or care, of a guardian; protection; care; watch.","pos":""}],"GUARDLESS":[{"def":"Without a guard or defense; unguarded.","pos":""}],"GUARDROOM":[{"def":"The room occupied by the guard during its term of duty; also, a room where prisoners are confined.","pos":""}],"GUARDS":[{"def":"A body of picked troops; as, \"The Household Guards.","pos":""}],"GUARDSHIP":[{"def":"Care; protection.","pos":""}],"GUARDSMAN":[{"def":"One who guards; a guard.","pos":""},{"def":"A member, either officer or private, of any military body called Guards.","pos":""}],"GUAVA":[{"def":"A tropical tree, or its fruit, of the genus Psidium.","pos":""}]}