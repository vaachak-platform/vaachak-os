{"SEPAL":[{"def":"A leaf or division of the calyx.","pos":""}],"SEPALED":[{"def":"Having one or more sepals.","pos":""}],"SEPALINE":[{"def":"Relating to, or having the nature of, sepals.","pos":""}],"SEPALODY":[{"def":"The metamorphosis of other floral organs into sepals or sepaloid bodies.","pos":""}],"SEPALOID":[{"def":"Like a sepal, or a division of a calyx.","pos":""}],"SEPALOUS":[{"def":"Having, or relating to, sepals; -- used mostly in composition.","pos":""}],"SEPARABILITY":[{"def":"Quality of being separable or divisible; divisibility; separableness.","pos":""}],"SEPARABLE":[{"def":"Capable of being separated, disjoined, disunited, or divided; as, the separable parts of plants; qualities not separable from the substance in which they exist.","pos":""}],"SEPARATE":[{"def":"To disunite; to divide; to disconnect; to sever; to part in any manner.","pos":""},{"def":"To come between; to keep apart by occupying the space between; to lie between; as, the Mediterranean Sea separates Europe and Africa.","pos":""}],"SEPARATICAL":[{"def":"Of or pertaining to separatism in religion; schismatical.","pos":""}],"SEPARATING":[{"def":"Designed or employed to separate.","pos":""}],"SEPARATION":[{"def":"The act of separating, or the state of being separated, or separate.","pos":""}],"SEPARATISM":[{"def":"The character or act of a separatist; disposition to withdraw from a church; the practice of so withdrawing.","pos":""}],"SEPARATIST":[{"def":"One who withdraws or separates himself; especially, one who withdraws from a church to which he has belonged; a seceder from an established church; a dissenter; a nonconformist; a schismatic; a sectary.","pos":""}],"SEPARATISTIC":[{"def":"Of or pertaining to separatists; characterizing separatists; schismatical.","pos":""}],"SEPARATIVE":[{"def":"Causing, or being to cause, separation.","pos":""}],"SEPARATOR":[{"def":"One who, or that which, separates.","pos":""},{"def":"An instrument used for spreading apart the threads of the warp in the loom, etc.","pos":""}],"SEPARATORY":[{"def":"An apparatus used in separating, as a separating funnel.","pos":""},{"def":"A surgical instrument for separating the pericranium from the cranium.","pos":""}],"SEPARATRIX":[{"def":"The decimal point; the dot placed at the left of a decimal fraction, to separate it from the whole number which it follows.","pos":""}],"SEPELIBLE":[{"def":"Admitting of burial.","pos":""}],"SEPHARDIC":[{"def":"Of, pertaining to, or designating, the Jews (the Sephardim, also called Spanish or Portuguese Jews) descended from Jewish families driven from Spain by the Inquisition.","pos":""}],"SEPHARDIM":[{"def":"Jews who are descendants of the former Jews of Spain and Portugal.","pos":""}],"SEPHEN":[{"def":"A large sting ray of the genus Trygon, especially T.","pos":""}],"SEPIA":[{"def":"A pigment prepared from the ink, or black secretion, of the sepia, or cuttlefish.","pos":""}],"SEPIC":[{"def":"Of or pertaining to sepia; done in sepia; as, a sepic drawing.","pos":""}],"SEPIDACEOUS":[{"def":"Like or pertaining to the cuttlefishes of the genus Sepia.","pos":""}],"SEPIMENT":[{"def":"Something that separates; a hedge; a fence.","pos":""}],"SEPIOSTARE":[{"def":"The bone or shell of cuttlefish.","pos":""}],"SEPOSIT":[{"def":"To set aside; to give up.","pos":""}],"SEPOSITION":[{"def":"The act of setting aside, or of giving up.","pos":""}],"SEPOY":[{"def":"A native of India employed as a soldier in the service of a European power, esp.","pos":""}],"SEPPUKU":[{"def":"Same as Hara-kiri.","pos":""}],"SEPSIN":[{"def":"A soluble poison (ptomaine) present in putrid blood.","pos":""}],"SEPSIS":[{"def":"The poisoning of the system by the introduction of putrescent material into the blood.","pos":""}],"SEPT":[{"def":"A clan, tribe, or family, proceeding from a common progenitor; -- used especially of the ancient clans in Ireland.","pos":""}],"SEPTAL":[{"def":"Of or pertaining to a septum or septa, as of a coral or a shell.","pos":""}],"SEPTANGLE":[{"def":"A figure which has seven angles; a heptagon.","pos":""}],"SEPTARIUM":[{"def":"A flattened concretionary nodule, usually of limestone, intersected within by cracks which are often filled with calcite, barite, or other minerals.","pos":""}],"SEPTATE":[{"def":"Divided by partition or partitions; having septa; as, a septate pod or shell.","pos":""}],"SEPTEMBER":[{"def":"The ninth month of the year, containing thurty days.","pos":""}],"SEPTEMBRIST":[{"def":"An agent in the massacres in Paris, committed in patriotic frenzy, on the 22d of September, 1792.","pos":""}],"SEPTEMFLUOUS":[{"def":"Flowing sevenfold; divided into seven streams or currents.","pos":""}],"SEPTEMPARTITE":[{"def":"Divided nearly to the base into seven parts; as, a septempartite leaf.","pos":""}],"SEPTEMVIR":[{"def":"One of a board of seven men associated in some office.","pos":""}],"SEPTEMVIRATE":[{"def":"The office of septemvir; a government by septimvirs.","pos":"noun"}],"SEPTENARY":[{"def":"Consisting of, or relating to, seven; as, a septenary number.","pos":""},{"def":"Lasting seven years; continuing seven years.","pos":""}],"SEPTENATE":[{"def":"Having parts in sevens; heptamerous.","pos":""}],"SEPTENNATE":[{"def":"A period of seven years; as, the septennate during which the President of the French Republic holds office.","pos":""}],"SEPTENNIAL":[{"def":"Lasting or continuing seven years; as, septennial parliaments.","pos":""},{"def":"Happening or returning once in every seven years; as, septennial elections in England.","pos":""}],"SEPTENNIALLY":[{"def":"Once in seven years.","pos":""}],"SEPTENTRIO":[{"def":"The constellation Ursa Major.","pos":""}],"SEPTENTRION":[{"def":"The north or northern regions.","pos":""},{"def":"Of or pertaining to the north; northern.","pos":""}],"SEPTENTRIONALITY":[{"def":"Sep*ten`tri*on*al\"i*ty, n.","pos":""}],"SEPTENTRIONALLY":[{"def":"Sep*ten\"tri*on*al*ly, adv.","pos":""}],"SEPTENTRIONATE":[{"def":"To tend or point toward the north; to north.","pos":""},{"def":"A musical composition for seven instruments or seven voices; -- called also septuor.","pos":""}],"SEPTFOIL":[{"def":"A European herb, the tormentil.","pos":""},{"def":"An ornamental foliation having seven lobes.","pos":""}],"SEPTI-":[{"def":"A combining form meaning seven; as, septifolious, seven-leaved; septi-lateral, seven-sided.","pos":""}],"SEPTIC":[{"def":"Of the seventh degree or order.","pos":""},{"def":"A quantic of the seventh degree.","pos":""}],"SEPTICAEMIA":[{"def":"A poisoned condition of the blood produced by the absorption into it of septic or putrescent material; blood poisoning.","pos":""}],"SEPTICALLY":[{"def":"In a septic manner; in a manner tending to promote putrefaction.","pos":""}],"SEPTICIDAL":[{"def":"Dividing the partitions; -- said of a method of dehiscence in which a pod splits through the partitions and is divided into its component carpels.","pos":""}],"SEPTICITY":[{"def":"Tendency to putrefaction; septic quality.","pos":""}],"SEPTIFARIOUS":[{"def":"Turned in seven different ways.","pos":""}],"SEPTIFEROUS":[{"def":"Bearing a partition; -- said of the valves of a capsule.","pos":""}],"SEPTIFLUOUS":[{"def":"Flowing in seven streams; septemfluous.","pos":""}],"SEPTIFOLIOUS":[{"def":"Having seven leaves.","pos":""}],"SEPTIFORM":[{"def":"Having the form of a septum.","pos":""}],"SEPTIFRAGAL":[{"def":"Breaking from the partitions; -- said of a method of dehiscence in which the valves of a pod break away from the partitions, and these remain attached to the common axis.","pos":""}],"SEPTILATERAL":[{"def":"Having seven sides; as, a septilateral figure.","pos":""}],"SEPTILLION":[{"def":"According to the French method of numeration (which is followed also in the United States), the number expressed by a unit with twenty-four ciphers annexed.","pos":""}],"SEPTIMOLE":[{"def":"A group of seven notes to be played in the time of four or six.","pos":""}],"SEPTINSULAR":[{"def":"Consisting of seven islands; as, the septinsular republic of the Ionian Isles.","pos":""}],"SEPTISYLLABLE":[{"def":"A word of seven syllables.","pos":""}],"SEPTOMAXILLARY":[{"def":"Of or pertaining to the nasal septum and the maxilla; situated in the region of these parts.","pos":""},{"def":"A small bone between the nasal septum and the maxilla in many reptiles and amphibians.","pos":""}],"SEPTUAGENARIAN":[{"def":"A person who is seventy years of age; a septuagenary.","pos":""}],"SEPTUAGENARY":[{"def":"Consisting of seventy; also, seventy years old.","pos":""},{"def":"A septuagenarian.","pos":""}],"SEPTUAGESIMA":[{"def":"The third Sunday before Lent; -- so called because it is about seventy days before Easter.","pos":""}],"SEPTUAGESIMAL":[{"def":"Consisting of seventy days, years, etc.","pos":""}],"SEPTUAGINT":[{"def":"A Greek version of the Old Testament; -- so called because it was believed to be the work of seventy (or rather of seventy-two) translators.","pos":""}],"SEPTUARY":[{"def":"Something composed of seven; a week.","pos":""}],"SEPTULATE":[{"def":"Having imperfect or spurious septa.","pos":""}],"SEPTULUM":[{"def":"A little septum; a division between small cavities or parts.","pos":""}],"SEPTUM":[{"def":"A partition that separates the cells of a fruit.","pos":""}],"SEPTUPLE":[{"def":"Seven times as much; multiplied by seven; sevenfold.","pos":""}],"SEPULCHRAL":[{"def":"Of or pertaining to burial, to the grave, or to monuments erected to the memory of the dead; as, a sepulchral stone; a sepulchral inscription.","pos":""},{"def":"Unnaturally low and grave; hollow in tone; -- said of sound, especially of the voice.","pos":""}],"SEPULTURE":[{"def":"The act of depositing the dead body of a human being in the grave; burial; interment.","pos":""},{"def":"A sepulcher; a grave; a place of burial.","pos":""}]}