{"ACRANIA":[{"def":"Partial or total absence of the skull.","pos":""},{"def":"The lowest group of Vertebrata, including the amphioxus, in which no skull exists.","pos":""}],"ACRANIAL":[{"def":"Wanting a skull.","pos":""},{"def":"Excess; intemperance.","pos":""}],"ACRASPEDA":[{"def":"A group of acalephs, including most of the larger jellyfishes; the Discophora.","pos":""}],"ACRE":[{"def":"Any field of arable or pasture land.","pos":""},{"def":"A piece of land, containing 160 square rods, or 4,840 square yards, or 43,560 square feet.","pos":""}],"ACREABLE":[{"def":"Of an acre; per acre; as, the acreable produce.","pos":""}],"ACREAGE":[{"def":"Acres collectively; as, the acreage of a farm or a country.","pos":""}],"ACRED":[{"def":"Possessing acres or landed property; -- used in composition; as, large-acred men.","pos":""}],"ACRID":[{"def":"The quality of being acrid or pungent; irritant bitterness; acrimony; as, the acridity of a plant, of a speech.","pos":""}],"ACRIDLY":[{"def":"In an acid manner.","pos":""}],"ACRIMONIOUS":[{"def":"Acrid; corrosive; as, acrimonious gall.","pos":""},{"def":"Caustic; bitter-tempered' sarcastic; as, acrimonious dispute, language, temper.","pos":""}],"ACRIMONIOUSLY":[{"def":"In an acrimonious manner.","pos":""}],"ACRIMONIOUSNESS":[{"def":"The quality of being acrimonious; asperity; acrimony.","pos":""}],"ACRIMONY":[{"def":"Undecided character of a disease.","pos":""}],"ACRITA":[{"def":"The lowest groups of animals, in which no nervous system has been observed.","pos":""}],"ACRITAN":[{"def":"Of or pertaining to the Acrita.","pos":""}],"ACRITICAL":[{"def":"Having no crisis; giving no indications of a crisis; as, acritical symptoms, an acritical abscess.","pos":""}],"ACRITOCHROMACY":[{"def":"Color blindness; achromatopsy.","pos":""}],"ACRITUDE":[{"def":"Acridity; pungency joined with heat.","pos":""}],"ACRITY":[{"def":"Sharpness; keenness.","pos":""},{"def":"Communicated orally; oral; -- applied to the esoteric teachings of Aristotle, those intended for his genuine disciples, in distinction from his exoteric doctrines, which were adapted to outsiders or the public generally.","pos":""}],"ACROATIC":[{"def":"Same as Acroamatic.","pos":""}],"ACROBAT":[{"def":"One who practices rope dancing, high vaulting, or other daring gymnastic feats.","pos":""}],"ACROBATIC":[{"def":"Pertaining to an acrobat.","pos":""}],"ACROBATISM":[{"def":"Feats of the acrobat; daring gymnastic feats; high vaulting.","pos":""}],"ACROCEPHALIC":[{"def":"Characterized by a high skull.","pos":""}],"ACROCEPHALY":[{"def":"Loftiness of skull.","pos":""}],"ACROCERAUNIAN":[{"def":"Of or pertaining to the high mountain range of \"thunder- smitten\" peaks (now Kimara), between Epirus and Macedonia.","pos":""}],"ACRODACTYLUM":[{"def":"The upper surface of the toes, individually.","pos":""}],"ACRODONT":[{"def":"One of a group of lizards having the teeth immovably united to the top of the alveolar ridge.","pos":""}],"ACROGEN":[{"def":"A plant of the highest class of cryptograms, including the ferns, etc.","pos":""}],"ACROGENOUS":[{"def":"Increasing by growth from the extremity; as, an acrogenous plant.","pos":""}],"ACROLEIN":[{"def":"A limpid, colorless, highly volatile liquid, obtained by the dehydration of glycerin, or the destructive distillation of neutral fats containing glycerin.","pos":""}],"ACROLITH":[{"def":"A statue whose extremities are of stone, the trunk being generally of wood.","pos":""},{"def":"Pertaining to, or like, an acrolith.","pos":""}],"ACROMEGALY":[{"def":"Chronic enlargement of the extremities and face.","pos":""}],"ACROMIAL":[{"def":"Of or pertaining to the acromion.","pos":""}],"ACROMION":[{"def":"The outer extremity of the shoulder blade.","pos":""}],"ACROMONOGRAMMATIC":[{"def":"Having each verse begin with the same letter as that with which the preceding verse ends.","pos":""},{"def":"Rising at sunset and setting at sunrise, as a star; -- opposed to cosmical.","pos":""}],"ACRONYCALLY":[{"def":"In an acronycal manner as rising at the setting of the sun, and vise versâ.","pos":""}],"ACROPETAL":[{"def":"Developing from below towards the apex, or from the circumference towards the center; centripetal; -- said of certain inflorescence.","pos":""},{"def":"The use of a picture symbol of an object to represent phonetically the initial sound of the name of the object.","pos":""}],"ACROPHONY":[{"def":"The use of a picture symbol of an object to represent phonetically the initial sound of the name of the object.","pos":""}],"ACROPODIUM":[{"def":"The entire upper surface of the foot.","pos":""}],"ACROPOLIS":[{"def":"The upper part, or the citadel, of a Grecian city; especially, the citadel of Athens.","pos":""}],"ACROPOLITAN":[{"def":"Pertaining to an acropolis.","pos":""}],"ACROSPIRE":[{"def":"The sprout at the end of a seed when it begins to germinate; the plumule in germination; -- so called from its spiral form.","pos":""}],"ACROSPORE":[{"def":"A spore borne at the extremity of the cells of fructification in fungi.","pos":""}],"ACROSPOROUS":[{"def":"Having acrospores.","pos":""}],"ACROSS":[{"def":"From side to side; athwart; crosswise, or in a direction opposed to the length; quite over; as, a bridge laid across a river.","pos":""}],"ACROSTIC":[{"def":"Pertaining to, or characterized by, acrostics.","pos":""}],"ACROSTICALLY":[{"def":"After the manner of an acrostic.","pos":""}],"ACROTARSIUM":[{"def":"The instep or front of the tarsus.","pos":""}],"ACROTELEUTIC":[{"def":"The end of a verse or psalm, or something added thereto, to be sung by the people, by way of a response.","pos":""}],"ACROTER":[{"def":"Same as Acroterium.","pos":""}],"ACROTERIAL":[{"def":"Pertaining to an acroterium; as, ornaments.","pos":""}],"ACROTIC":[{"def":"Pertaining to or affecting the surface.","pos":""}],"ACROTISM":[{"def":"Lack or defect of pulsation.","pos":""}],"ACROTOMOUS":[{"def":"Having a cleavage parallel with the base.","pos":""}],"ACRYLIC":[{"def":"Of or containing acryl, the hypothetical radical of which acrolein is the hydride; as, acrylic acid.","pos":""}]}