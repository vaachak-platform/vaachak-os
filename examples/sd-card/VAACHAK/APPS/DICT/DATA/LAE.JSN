{"LAELAPS":[{"def":"A genus of huge, carnivorous, dinosaurian reptiles from the Cretaceous formation of the United States.","pos":""}],"LAEMODIPOD":[{"def":"One of the Læmodipoda.","pos":""}],"LAEMODIPODA":[{"def":"A division of amphipod Crustacea, in which the abdomen is small or rudimentary and the legs are often reduced to five pairs.","pos":""}],"LAEMODIPODOUS":[{"def":"Of or pertaining to the Læmodipoda.","pos":""}],"LAETERE SUNDAY":[{"def":"Læ*te\"re Sun\"day Defn: .","pos":""}],"LAEVIGATE":[{"def":"Having a smooth surface, as if polished.","pos":""}],"LAEVOROTATORY":[{"def":"Same as Levorotatory.","pos":""}]}