{"PET":[{"def":"A slight fit of peevishness or fretfulness.","pos":""}],"PETAL":[{"def":"One of the leaves of the corolla, or the colored leaves of a flower.","pos":""},{"def":"One of the expanded ambulacra which form a rosette on the black of certain Echini.","pos":""}],"PETALED":[{"def":"Having petals; as, a petaled flower; -- opposed to Ant: apetalous, and much used in compounds; as, one-petaled, three- petaled, etc.","pos":""}],"PETALIFORM":[{"def":"Having the form of a petal; petaloid; petal-shaped.","pos":""}],"PETALINE":[{"def":"Pertaining to a petal; attached to, or resembling, a petal.","pos":""}],"PETALISM":[{"def":"A form of sentence among the ancient Syracusans by which they banished for five years a citizen suspected of having dangerous influence or ambition.","pos":""}],"PETALITE":[{"def":"A rare mineral, occurring crystallized and in cleavable masses, usually white, or nearly so, in color.","pos":""}],"PETALODY":[{"def":"The metamorphosis of various floral organs, usually stamens, into petals.","pos":""}],"PETALOIDEOUS":[{"def":"Having the whole or part of the perianth petaline.","pos":""}],"PETALOSTICHA":[{"def":"An order of Echini, including the irregular sea urchins, as the spatangoids.","pos":""}],"PETALOUS":[{"def":"Having petals; petaled; -- opposed to Ant: apetalous.","pos":""}],"PETARD":[{"def":"A case containing powder to be exploded, esp.","pos":""},{"def":"One who managed a petard.","pos":""}],"PETASUS":[{"def":"The winged cap of Mercury; also, a broad-brimmed, low-crowned hat worn by Greeks and Romans.","pos":""}],"PETAURIST":[{"def":"Any flying marsupial of the genera Petaurus, Phalangista, Acrobata, and allied genera.","pos":""}],"PETECHIAE":[{"def":"Small crimson, purple, or livid spots, like flea-bites, due to extravasation of blood, which appear on the skin in malignant fevers, etc.","pos":""}],"PETECHIAL":[{"def":"Characterized by, or pertaining to, petechiæ; spotted.","pos":""}],"PETER":[{"def":"A common baptismal name for a man.","pos":""}],"PETERMAN":[{"def":"A fisherman; -- so called after the apostle Peter.","pos":""}],"PETERSHAM":[{"def":"A rough, knotted woolen cloth, used chiefly for men's overcoats; also, a coat of that material.","pos":""}],"PETERWORT":[{"def":"See Saint Peter's-wort, under Saint.","pos":""},{"def":"Of or pertaining to petiole, or proceeding from it; as, a petiolar tendril; growing or supported upon a petiole; as, a petiolar gland; a petiolar bud.","pos":""}],"PETIOLE":[{"def":"A leafstalk; the footstalk of a leaf, connecting the blade with the stem.","pos":""},{"def":"A stalk or peduncle.","pos":""}],"PETIOLULATE":[{"def":"Supported by its own petiolule.","pos":""}],"PETIOLULE":[{"def":"A small petiole, or the petiole of a leaflet.","pos":""}],"PETIT":[{"def":"Small; little; insignificant; mean; -- Same as Petty.","pos":""}],"PETIT MAL":[{"def":"The mildest form of epilepsy, with momentary faintness or unconsciousness, but without convulsions; -- opposed to grand mal.","pos":""}],"PETITE":[{"def":"Small, little; of a woman or girl, of small size and trim figure.","pos":""}],"PETITION":[{"def":"A prayer; a supplication; an imploration; an entreaty; especially, a request of a solemn or formal kind; a prayer to the Supreme Being, or to a person of superior power, rank, or authority; also, a single clause in such a prayer.","pos":""}],"PETITIONARILY":[{"def":"By way of begging the question; by an assumption.","pos":""}],"PETITIONARY":[{"def":"Supplicatory; making a petition.","pos":""},{"def":"Containing a petition; of the nature of a petition; as, a petitionary epistle.","pos":""}],"PETITIONEE":[{"def":"A person cited to answer, or defend against, a petition.","pos":""}],"PETITIONER":[{"def":"One who presents a petition.","pos":""}],"PETITIONING":[{"def":"The act of presenting apetition; a supplication.","pos":""}],"PETITOR":[{"def":"One who seeks or asks; a seeker; an applicant.","pos":""}],"PETITORY":[{"def":"Petitioning; soliciting; supplicating.","pos":""}],"PETRARY":[{"def":"An ancient war engine for hurling stones.","pos":""}],"PETREAN":[{"def":"Of or pertaining to to rock.","pos":""}],"PETREL":[{"def":"Any one of numerous species of longwinged sea birds belonging to the family Procellaridæ.","pos":""}],"PETRESCENCE":[{"def":"The process of changing into stone; petrification.","pos":""}],"PETRESCENT":[{"def":"Petrifying; converting into stone; as, petrescent water.","pos":""}],"PETRIFACTION":[{"def":"The process of petrifying, or changing into stone; conversion of any organic matter (animal or vegetable) into stone, or a substance of stony hardness.","pos":""},{"def":"The state or condition of being petrified.","pos":""}],"PETRIFACTIVE":[{"def":"Having the quality of converting organic matter into stone; petrifying.","pos":""},{"def":"Pertaining to, or characterized by, petrifaction.","pos":""}],"PETRIFIC":[{"def":"Petrifying; petrifactive.","pos":""}],"PETRIFICATE":[{"def":"Our hearts petrificated were.","pos":""}],"PETRIFICATION":[{"def":"See Petrifaction.","pos":""}],"PETRIFY":[{"def":"To convert, as any animal or vegetable matter, into stone or stony substance.","pos":""},{"def":"To make callous or obdurate; to stupefy; to paralyze; to transform; as by petrifaction; as, to petrify the heart.","pos":""}],"PETRINE":[{"def":"Of or pertaining to St.","pos":""}],"PETRO-":[{"def":"A combining form from Gr.","pos":""}],"PETROGALE":[{"def":"Any Australian kangaroo of the genus Petrogale, as the rock wallaby (P.","pos":""}],"PETROGLYPHIC":[{"def":"Of or pertaining to petroglyphy.","pos":""}],"PETROGLYPHY":[{"def":"The art or operation of carving figures or inscriptions on rock or stone.","pos":""},{"def":"Pertaining to petrography.","pos":""}],"PETROGRAPHY":[{"def":"The art of writing on stone.","pos":""},{"def":"The scientific description of rocks; that department of science which investigates the constitution of rocks; petrology.","pos":""}],"PETROHYOID":[{"def":"Pertaining to petrous, oe periotic, portion of the skull and the hyoid arch; as, the petrohyoid muscles of the frog.","pos":""}],"PETROLATUM":[{"def":"A semisolid unctuous substance, neutral, and without taste or odor, derived from petroleum by distilling off the lighter portions and purifying the residue.","pos":""}],"PETROLEUM":[{"def":"Rock oil, mineral oil, or natural oil, a dark brown or greenish inflammable liquid, which, at certain points, exists in the upper strata of the earth, from whence it is pumped, or forced by pressure of the gas attending it.","pos":""},{"def":"One who makes use of petroleum for incendiary purposes.","pos":""}],"PETROLINE":[{"def":"A paraffin obtained from petroleum from Rangoon in India, and practically identical with ordinary paraffin.","pos":""},{"def":"Of or pertaining to petrology.","pos":""}],"PETROLOGICALLY":[{"def":"According to petrology.","pos":""}],"PETROLOGIST":[{"def":"One who is versed in petrology.","pos":""}],"PETROLOGY":[{"def":"The department of science which is concerned with the mineralogical and chemical composition of rocks, and with their classification: lithology.","pos":""},{"def":"A treatise on petrology.","pos":""}],"PETROMASTOID":[{"def":"Of or pertaining to the petrous and mastoid parts of the temporal bone, periotic.","pos":""}],"PETRONEL":[{"def":"A sort of hand cannon, or portable firearm, used in France in the 15th century.","pos":""}],"PETROSILICIOUS":[{"def":"Containing, or consisting of, petrosilex.","pos":""}],"PETROSTEARINE":[{"def":"A solid unctuous material, of which candles are made.","pos":""}],"PETROUS":[{"def":"Same as Petrosal.","pos":""}],"PETTICOAT":[{"def":"A loose under-garment worn by women, and covering the body below the waist.","pos":""}],"PETTIFOG":[{"def":"To do a petty business as a lawyer; also, to do law business in a petty or tricky way.","pos":""}],"PETTIFOGGER":[{"def":"A lawyer who deals in petty cases; an attorney whose methods are mean and tricky; an inferior lawyer.","pos":""}],"PETTIFOGGERY":[{"def":"The practice or arts of a pettifogger; disreputable tricks; quibbles.","pos":""}],"PETTIFOGGING":[{"def":"Paltry; quibbling; mean.","pos":""}],"PETTIFOGULIZE":[{"def":"To act as a pettifogger; to use contemptible tricks.","pos":""}],"PETTILY":[{"def":"In a petty manner; frivolously.","pos":""}],"PETTINESS":[{"def":"The quality or state of being petty or paltry; littleness; meanness.","pos":""}],"PETTISH":[{"def":"Fretful; peevish; moody; capricious; inclined to ill temper.","pos":""}],"PETTITOES":[{"def":"The toes or feet of a pig, -- often used as food; sometimes, in contempt, the human feet.","pos":""}],"PETTY":[{"def":"Little; trifling; inconsiderable; also, inferior; subordinate; as, a petty fault; a petty prince.","pos":""}],"PETTYCHAPS":[{"def":"Any one of several species of small European singing birds of the subfamily Sylviinæ, as the willow warbler, the chiff-chaff, and the golden warbler (Sylvia hortensis).","pos":""}],"PETTYWHIN":[{"def":"The needle furze.","pos":""},{"def":"The quality or state of being petulant; temporary peevishness; pettishness; capricious ill humor.","pos":""}],"PETULANT":[{"def":"Forward; pert; insolent; wanton.","pos":""},{"def":"Capriciously fretful; characterized by ill-natured freakishness; irritable.","pos":""}],"PETULANTLY":[{"def":"In a petulant manner.","pos":""}],"PETULCITY":[{"def":"Wantonness; friskiness.","pos":""}],"PETULCOUS":[{"def":"Wanton; frisky; lustful.","pos":""}],"PETUNE":[{"def":"To spray (tobacco) with a liquid intended to produce flavor or aroma.","pos":""}],"PETUNIA":[{"def":"A genus of solanaceous herbs with funnelform or salver-shaped corollas.","pos":""},{"def":"Powdered fledspar, kaolin, or quartz, used in the manufacture of porcelain.","pos":""}],"PETWORTH MARBLE":[{"def":"A kind of shell marble occurring in the Wealden clay at Petworth, in Sussex, England; -- called also Sussex marble.","pos":""}],"PETZITE":[{"def":"A telluride of silver and gold, related to hessite.","pos":""}]}