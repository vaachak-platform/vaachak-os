{"STREAK":[{"def":"To stretch; to extend; hence, to lay out, as a dead body.","pos":""}],"STREAKED":[{"def":"Marked or variegated with stripes.","pos":""},{"def":"Uncomfortable; out of sorts.","pos":""}],"STREAKY":[{"def":"Same as Streaked, 1.","pos":""}],"STREAM":[{"def":"A current water or other fluid; a liquid flowing continuously in a line or course, either on the earth, as a river, brook, etc.","pos":""},{"def":"A beam or ray of light.","pos":""}],"STREAM CLOCK":[{"def":"An instrument for ascertaining the velocity of the blood in a vessel.","pos":""}],"STREAM GOLD":[{"def":"Gold in alluvial deposits; placer gold.","pos":""}],"STREAM LINE":[{"def":"The path of a constituent particle of a flowing fluid undisturbed by eddies or the like.","pos":""}],"STREAM WHEEL":[{"def":"A wheel used for measuring, by its motion when submerged, the velocity of flowing water; a current wheel.","pos":""}],"STREAMER":[{"def":"A searcher for stream tin.","pos":""}],"STREAMFUL":[{"def":"Abounding in streams, or in water.","pos":""}],"STREAMINESS":[{"def":"The state of being streamy; a trailing.","pos":""}],"STREAMING":[{"def":"Sending forth streams.","pos":""}],"STREAMLESS":[{"def":"Destitute of streams, or of a stream, as a region of country, or a dry channel.","pos":""}],"STREAMLET":[{"def":"A small stream; a rivulet; a rill.","pos":""}],"STREAMY":[{"def":"Abounding with streams, or with running water; streamful.","pos":""},{"def":"Resembling a stream; issuing in a stream.","pos":""}],"STREEK":[{"def":"To stretch; also, to lay out, as a dead body.","pos":""}],"STREEL":[{"def":"To trail along; to saunter or be drawn along, carelessly, swaying in a kind of zigzag motion.","pos":""}],"STREET":[{"def":"Originally, a paved way or road; a public highway; now commonly, a thoroughfare in a city or village, bordered by dwellings or business houses.","pos":""}],"STREETWALKER":[{"def":"A common prostitute who walks the streets to find customers.","pos":""}],"STREETWARD":[{"def":"An officer, or ward, having the care of the streets.","pos":""}],"STREIT":[{"def":"Pyrrhus with his streite sword.","pos":""}],"STREITE":[{"def":"Narrowly; strictly; straitly.","pos":""}],"STRELITZ":[{"def":"A soldier of the ancient Muscovite guard or Russian standing army; also, the guard itself.","pos":"noun"}],"STRELITZIA":[{"def":"A genus of plants related to the banana, found at the Cape of Good Hope.","pos":""}],"STRENE":[{"def":"Race; offspring; stock; breed; strain.","pos":""},{"def":", the original compar.","pos":""}],"STRENGTH":[{"def":"The quality or state of being strong; ability to do or to bear; capacity for exertion or endurance, whether physical, intellectual, or moral; force; vigor; power; as, strength of body or of the arm; strength of mind, of memory, or of judgment.","pos":""},{"def":"Power to resist force; solidity or toughness; the quality of bodies by which they endure the application of force without breaking or yielding; -- in this sense opposed to frangibility; as, the strength of a bone, of a beam, of a wall, a rope, and the like.","pos":""}],"STRENGTHEN":[{"def":"To make strong or stronger; to add strength to; as, to strengthen a limb, a bridge, an army; to strengthen an obligation; to strengthen authority.","pos":""},{"def":"To animate; to encourage; to fix in resolution.","pos":""}],"STRENGTHENER":[{"def":"One who, or that which, gives or adds strength.","pos":""}],"STRENGTHENING":[{"def":"That strengthens; giving or increasing strength.","pos":""}],"STRENGTHFUL":[{"def":"Abounding in strength; full of strength; strong.","pos":""}],"STRENGTHLESS":[{"def":"Destitute of strength.","pos":""}],"STRENGTHNER":[{"def":"See Strengthener.","pos":""}],"STRENGTHY":[{"def":"Having strength; strong.","pos":""}],"STRENUITY":[{"def":"Strenuousness; activity.","pos":""}],"STRENUOUS":[{"def":"Eagerly pressing or urgent; zealous; ardent; earnest; bold; valiant; intrepid; as, a strenuous advocate for national rights; a strenuous reformer; a strenuous defender of his country.","pos":""}],"STREPEROUS":[{"def":"Loud; boisterous.","pos":""}],"STREPITORES":[{"def":"A division of birds, including the clamatorial and picarian birds, which do not have well developed singing organs.","pos":""},{"def":"One of the Strepsiptera.","pos":""}],"STREPSIPTERA":[{"def":"A group of small insects having the anterior wings rudimentary, and in the form of short and slender twisted appendages, while the posterior ones are large and membranous.","pos":""}],"STREPSIPTEROUS":[{"def":"Of or pertaining to Strepsiptera.","pos":""}],"STREPSORHINA":[{"def":"Same as Lemuroidea.","pos":""}],"STREPSORHINE":[{"def":"Having twisted nostrils; -- said of the lemurs.","pos":""},{"def":"One of the Strepsorhina; a lemur.","pos":""}],"STREPTOBACTERIA":[{"def":"A so-called variety of bacterium, consisting in reality of several bacteria linked together in the form of a chain.","pos":""}],"STREPTOCOCCUS":[{"def":"A long or short chain of micrococci, more or less curved.","pos":""}],"STREPTONEURA":[{"def":"An extensive division of gastropod Mollusca in which the loop or visceral nerves is twisted, and the sexes separate.","pos":""}],"STREPTOTHRIX":[{"def":"A genus of bacilli occurring of the form of long, smooth and apparently branched threads, either straight or twisted.","pos":""}],"STRESS":[{"def":"The force, or combination of forces, which produces a strain; force exerted in any direction or manner between contiguous bodies, or parts of bodies, and taking specific names according to its direction, or mode of action, as thrust or pressure, pull or tension, shear or tangential stress.","pos":""},{"def":"Force of utterance expended upon words or syllables.","pos":""}],"STRESSFUL":[{"def":"Having much stress.","pos":""}],"STRETCH":[{"def":"To reach out; to extend; to put forth.","pos":""},{"def":"To draw out to the full length; to cause to extend in a straight line; as, to stretch a cord or rope.","pos":""}],"STRETCHER":[{"def":"A brick or stone laid with its longer dimension in the line of direction of the wall.","pos":""},{"def":"A piece of timber used in building.","pos":""}],"STRETCHING":[{"def":"from Stretch, v.","pos":""}],"STREW":[{"def":"To scatter; to spread by scattering; to cast or to throw loosely apart; -- used of solids, separated or separable into parts or particles; as, to strew seed in beds; to strew sand on or over a floor; to strew flowers over a grave.","pos":""},{"def":"To cover more or less thickly by scattering something over or upon; to cover, or lie upon, by having been scattered; as, they strewed the ground with leaves; leaves strewed the ground.","pos":""}],"STREWING":[{"def":"The act of scattering or spreading.","pos":""},{"def":"Anything that is, or may be, strewed; -- used chiefly in the plural.","pos":""}],"STREWMENT":[{"def":"Anything scattered, as flowers for decoration.","pos":""}]}