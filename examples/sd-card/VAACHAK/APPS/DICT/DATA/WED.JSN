{"WED":[{"def":"A pledge; a pawn.","pos":""}],"WEDDED":[{"def":"Joined in wedlock; married.","pos":""},{"def":"Of or pertaining to wedlock, or marriage.","pos":""}],"WEDDING":[{"def":"Nuptial ceremony; nuptial festivities; marriage; nuptials.","pos":""}],"WEDGE":[{"def":"A solid of five sides, having a rectangular base, two rectangular or trapezoidal sides meeting in an edge, and two triangular ends.","pos":""}],"WEDGE GEAR":[{"def":"A friction gear wheel with wedge-shaped circumferential grooves.","pos":""}],"WEDGE-FORMED":[{"def":"Having the form of a wedge; cuneiform.","pos":""},{"def":"A wedge with a graduated edge, to measure the width of a space into which it is thrust.","pos":""}],"WEDGE-SHAPED":[{"def":"Broad and truncate at the summit, and tapering down to the base; as, a wedge-shaped leaf.","pos":""}],"WEDGE-SHELL":[{"def":"Any one of numerous species of small marine bivalves belonging to Donax and allied genera in which the shell is wedge-shaped.","pos":""}],"WEDGE-TAILED":[{"def":"Having a tail which has the middle pair of feathers longest, the rest successively and decidedly shorter, and all more or less attenuate; -- said of certain birds.","pos":""}],"WEDGEBILL":[{"def":"An Australian crested insessorial bird (Sphenostoma cristatum) having a wedge-shaped bill.","pos":""}],"WEDGEWISE":[{"def":"In the manner of a wedge.","pos":""}],"WEDGWOOD WARE":[{"def":"A kind of fine pottery, the most remarkable being what is called jasper, either white, or colored throughout the body, and capable of being molded into the most delicate forms, so that fine and minute bas-reliefs like cameos were made of it, fit even for being set as jewels.","pos":""}],"WEDGY":[{"def":"Like a wedge; wedge-shaped.","pos":""}],"WEDLOCK":[{"def":"The ceremony, or the state, of marriage; matrimony.","pos":""},{"def":"A wife; a married woman.","pos":""}],"WEDNESDAY":[{"def":"The fourth day of the week; the next day after Tuesday.","pos":""}]}