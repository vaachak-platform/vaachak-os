{"PENNA":[{"def":"A perfect, or normal, feather.","pos":""}],"PENNACEOUS":[{"def":"Like or pertaining to a normal feather.","pos":""}],"PENNACH":[{"def":"A bunch of feathers; a plume.","pos":""}],"PENNACHED":[{"def":"Variegated; striped.","pos":""}],"PENNAGE":[{"def":"Feathery covering; plumage.","pos":""}],"PENNANT":[{"def":"Same as Pinnate.","pos":""}],"PENNATULA":[{"def":"Any one of numerous species of Pennatula, Pteroides, and allied genera of Alcyonaria, having a featherlike form; a sea-pen.","pos":""}],"PENNATULACEA":[{"def":"A division of alcyonoid corals, including the seapens and related kinds.","pos":""}],"PENNED":[{"def":"Winged; having plumes.","pos":""},{"def":"Written with a pen; composed.","pos":""}],"PENNER":[{"def":"One who pens; a writer.","pos":""},{"def":"A case for holding pens.","pos":""}],"PENNIFORM":[{"def":"Having the form of a feather or plume.","pos":""}],"PENNIGEROUS":[{"def":"Bearing feathers or quills.","pos":""}],"PENNILESS":[{"def":"Destitute of money; impecunious; poor.","pos":""}],"PENNINERVED":[{"def":"Pinnately veined or nerved.","pos":""}],"PENNIPOTENT":[{"def":"Strong of wing; strong on the wing.","pos":""}],"PENNON":[{"def":"A wing; a pinion.","pos":""}],"PENNY":[{"def":"Denoting pound weight for one thousand; -- used in combination, with respect to nails; as, tenpenny nails, nails of which one thousand weight ten pounds.","pos":""}],"PENNY-A-LINER":[{"def":"One who furnishes matter to public journals at so much a line; a poor writer for hire; a hack writer.","pos":""}],"PENNYROYAL":[{"def":"An aromatic herb (Mentha Pulegium) of Europe; also, a North American plant (Hedeoma pulegioides) resembling it in flavor.","pos":""}],"PENNYWEIGHT":[{"def":"A troy weight containing twenty-four grains, or the twentieth part of an ounce; as, a pennyweight of gold or of arsenic.","pos":""}],"PENNYWORT":[{"def":"A European trailing herb (Linaria Cymbalaria) with roundish, reniform leaves.","pos":""}],"PENNYWORTH":[{"def":"A penny's worth; as much as may be bought for a penny.","pos":""},{"def":"Hence: The full value of one's penny expended; due return for money laid out; a good bargain; a bargain.","pos":""}]}