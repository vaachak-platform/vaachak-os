{"UNCIA":[{"def":"A twelfth part, as of the Roman as; an ounce.","pos":""},{"def":"A numerical coefficient in any particular case of the binomial theorem.","pos":""}],"UNCIAL":[{"def":"Of, pertaining to, or designating, a certain style of letters used in ancient manuscripts, esp.","pos":""}],"UNCIFORM":[{"def":"Having the shape of a hook; being of a curved or hooked from; hooklike.","pos":""}],"UNCINATA":[{"def":"A division of marine chætopod annelids which are furnished with uncini, as the serpulas and sabellas.","pos":""}],"UNCINATE":[{"def":"Hooked; bent at the tip in the form of a hook; as, an uncinate process.","pos":""}],"UNCINATUM":[{"def":"The unciform bone.","pos":""}],"UNCINUS":[{"def":"One of the peculiar minute chitinous hooks found in large numbers in the tori of tubicolous annelids belonging to the Uncinata.","pos":""}],"UNCIPHER":[{"def":"To decipher; as, to uncipher a letter.","pos":""}],"UNCIRCUMCISED":[{"def":"Not circumcised; hence, not of the Israelites.","pos":""}],"UNCIRCUMCISION":[{"def":"People not circumcised; the Gentiles.","pos":""}],"UNCIRCUMSTANDTIAL":[{"def":"Not circumstantial; not entering into minute particulars.","pos":""},{"def":"Not important; not pertinent; trivial.","pos":""}],"UNCITY":[{"def":"To deprive of the rank or rights of a city.","pos":""}],"UNCIVIL":[{"def":"Not civilized; savage; barbarous; uncivilized.","pos":""},{"def":"Not civil; not complaisant; discourteous; impolite; rude; unpolished; as, uncivil behavior.","pos":""}],"UNCIVILIZATION":[{"def":"The state of being uncivilized; savagery or barbarism.","pos":""}],"UNCIVILIZED":[{"def":"Not civilized; not reclaimed from savage life; rude; barbarous; savage; as, the uncivilized inhabitants of Central Africa.","pos":""},{"def":"Not civil; coarse; clownish.","pos":""}],"UNCIVILTY":[{"def":"In an uncivil manner.","pos":""}]}