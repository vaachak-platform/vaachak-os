{"ELVAN":[{"def":"Of or pertaining to certain veins of feldspathic or porphyritic rock crossing metalliferous veins in the mining districts of Cornwall; as, an elvan course.","pos":""},{"def":"The rock of an elvan vein, or the elvan vein itself; an elvan course.","pos":""}],"ELVE":[{"def":"An old form of Elf.","pos":""}],"ELVER":[{"def":"A young eel; a young conger or sea eel; -- called also elvene.","pos":""}],"ELVISH":[{"def":"Pertaining to elves; implike; mischievous; weird; also, vacant; absent in demeanor.","pos":""},{"def":"Mysterious; also, foolish.","pos":""}],"ELVISHLY":[{"def":"In an elvish manner.","pos":""}]}