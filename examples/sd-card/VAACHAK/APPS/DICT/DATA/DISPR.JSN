{"DISPRAISE":[{"def":"To withdraw praise from; to notice with disapprobation or some degree of censure; to disparage; to blame.","pos":""}],"DISPRAISER":[{"def":"One who blames or dispraises.","pos":""}],"DISPRAISINGLY":[{"def":"By way of dispraise.","pos":""}],"DISPREAD":[{"def":"To spread abroad, or different ways; to spread apart; to open; as, the sun dispreads his beams.","pos":""}],"DISPREADER":[{"def":"One who spreads abroad.","pos":""}],"DISPREJUDICE":[{"def":"To free from prejudice.","pos":""}],"DISPREPARE":[{"def":"To render unprepared.","pos":""}],"DISPRINCE":[{"def":"To make unlike a prince.","pos":""}],"DISPRISON":[{"def":"To let loose from prison, to set all liberty.","pos":""}],"DISPRIVILEGE":[{"def":"To deprive of a privilege or privileges.","pos":""}],"DISPROFESS":[{"def":"To renounce the profession or pursuit of.","pos":""}],"DISPROFIT":[{"def":"To be, or to cause to be, without profit or benefit.","pos":""}],"DISPROOF":[{"def":"A proving to be false or erroneous; confutation; refutation; as, to offer evidence in disproof of a statement.","pos":""}],"DISPROPERTY":[{"def":"To cause to be no longer property; to dispossess of.","pos":""}],"DISPROPORTION":[{"def":"Want of proportion in form or quantity; lack of symmetry; as, the arm may be in disproportion to the body; the disproportion of the length of a building to its height.","pos":""},{"def":"Want of suitableness, adequacy, or due proportion to an end or use; unsuitableness; disparity; as, the disproportion of strength or means to an object.","pos":""}],"DISPROPORTIONABLE":[{"def":"Disproportional; unsuitable in form, size, quantity, or adaptation; disproportionate; inadequate.","pos":""}],"DISPROPORTIONAL":[{"def":"Not having due proportion to something else; not having proportion or symmetry of parts; unsuitable in form, quantity or value; inadequate; unequal; as, a disproportional limb constitutes deformity in the body; the studies of youth should not be disproportional to their understanding.","pos":""}],"DISPROPORTIONALITY":[{"def":"The state of being disproportional.","pos":""}],"DISPROPORTIONALLY":[{"def":"In a disproportional manner; unsuitably in form, quantity, or value; unequally.","pos":""}],"DISPROPORTIONATE":[{"def":"Not proportioned; unsymmetrical; unsuitable to something else in bulk, form, value, or extent; out of proportion; inadequate; as, in a perfect body none of the limbs are disproportionate; it is wisdom not to undertake a work disproportionate means.","pos":""}],"DISPROPRIATE":[{"def":"To cancel the appropriation of; to disappropriate.","pos":""}],"DISPROVABLE":[{"def":"Capable of being disproved or refuted.","pos":""}],"DISPROVAL":[{"def":"Act of disproving; disproof.","pos":""}],"DISPROVE":[{"def":"To prove to be false or erroneous; to confute; to refute.","pos":""},{"def":"To disallow; to disapprove of.","pos":""}],"DISPROVER":[{"def":"One who disproves or confutes.","pos":""}],"DISPROVIDE":[{"def":"Not to provide; to fail to provide.","pos":""}]}