{"MISJOIN":[{"def":"To join unfitly or improperly.","pos":""}],"MISJOINDER":[{"def":"An incorrect union of parties or of causes of action in a procedure, criminal or civil.","pos":""}],"MISJUDGE":[{"def":"To judge erroneously or unjustly; to err in judgment; to misconstrue.","pos":""}],"MISJUDGMENT":[{"def":"A wrong or unjust judgment.","pos":""}]}