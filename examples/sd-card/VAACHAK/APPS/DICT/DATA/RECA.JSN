{"RECADENCY":[{"def":"A falling back or descending a second time; a relapse.","pos":""}],"RECALCITRANT":[{"def":"Kicking back; recalcitrating; hence, showing repugnance or opposition; refractory.","pos":""}],"RECALCITRATE":[{"def":"To kick against; to show repugnance to; to rebuff.","pos":""}],"RECALCITRATION":[{"def":"A kicking back again; opposition; repugnance; refractoriness.","pos":""}],"RECALL":[{"def":"To call back; to summon to return; as, to recall troops; to recall an ambassador.","pos":""},{"def":"To revoke; to annul by a subsequent act; to take back; to withdraw; as, to recall words, or a decree.","pos":""}],"RECALLABLE":[{"def":"Capable of being recalled.","pos":""}],"RECANT":[{"def":"To withdraw or repudiate formally and publicly (opinions formerly expressed); to contradict, as a former declaration; to take back openly; to retract; to recall.","pos":""}],"RECANTATION":[{"def":"The act of recanting; a declaration that contradicts a former one; that which is thus asserted in contradiction; retraction.","pos":""}],"RECANTER":[{"def":"One who recants.","pos":""}],"RECAPACITATE":[{"def":"To qualify again; to confer capacity on again.","pos":""}],"RECAPITULATE":[{"def":"To repeat, as the principal points in a discourse, argument, or essay; to give a summary of the principal facts, points, or arguments of; to relate in brief; to summarize.","pos":""}],"RECAPITULATION":[{"def":"The act of recapitulating; a summary, or concise statement or enumeration, of the principal points, facts, or statements, in a preceding discourse, argument, or essay.","pos":""}],"RECAPITULATOR":[{"def":"One who recapitulates.","pos":""}],"RECAPITULATORY":[{"def":"Of the nature of a recapitulation; containing recapitulation.","pos":""}],"RECAPPER":[{"def":"A tool used for applying a fresh percussion cap or primer to a cartridge shell in reloading it.","pos":""}],"RECAPTION":[{"def":"The act of retaking, as of one who has escaped after arrest; reprisal; the retaking of one's own goods, chattels, wife, or children, without force or violence, from one who has taken them and who wrongfully detains them.","pos":""}],"RECAPTOR":[{"def":"One who recaptures; one who takes a prize which had been previously taken.","pos":""}],"RECAPTURE":[{"def":"The act of retaking or recovering by capture; especially, the retaking of a prize or goods from a captor.","pos":""},{"def":"That which is captured back; a prize retaken.","pos":""}],"RECARBONIZE":[{"def":"To restore carbon to; as, to recarbonize iron in converting it into steel.","pos":""}],"RECARNIFY":[{"def":"To convert again into flesh.","pos":""}],"RECARRIAGE":[{"def":"Act of carrying back.","pos":""}],"RECAST":[{"def":"To mold anew; to cast anew; to throw into a new from a shape; to reconstruct; as, to recast cannon; to recast an argument or a play.","pos":""}]}