{"INDICAN":[{"def":"A glucoside obtained from woad (indigo plant) and other plants, as a yellow or light brown sirup.","pos":""},{"def":"An indigo-forming substance, found in urine, and other animal fluids, and convertible into red and blue indigo (urrhodin and uroglaucin).","pos":""}],"INDICANT":[{"def":"Serving to point out, as a remedy; indicating.","pos":""}],"INDICATE":[{"def":"To show or manifest by symptoms; to point to as the proper remedies; as, great prostration of strength indicates the use of stimulants.","pos":""},{"def":"To investigate the condition or power of, as of steam engine, by means of an indicator.","pos":""}],"INDICATED":[{"def":"Shown; denoted; registered; measured.","pos":""}],"INDICATION":[{"def":"Any symptom or occurrence in a disease, which serves to direct to suitable remedies.","pos":""}],"INDICATIVE":[{"def":"Suggestive; representing the whole by a part, as a fleet by a ship, a forest by a tree, etc.","pos":""}],"INDICATIVELY":[{"def":"In an indicative manner; in a way to show or signify.","pos":""}],"INDICATOR":[{"def":"A pressure gauge; a water gauge, as for a steam boiler; an apparatus or instrument for showing the working of a machine or moving part; as: (a) (Steam Engine) An instrument which draws a diagram showing the varying pressure in the cylinder of an engine or pump at every point of the stroke.","pos":""},{"def":"The part of an instrument by which an effect is indicated, as an index or pointer.","pos":""}],"INDICATORY":[{"def":"Serving to show or make known; showing; indicative; signifying; implying.","pos":""}],"INDICATRIX":[{"def":"A certain conic section supposed to be drawn in the tangent plane to any surface, and used to determine the accidents of curvature of the surface at the point of contact.","pos":""}],"INDICAVIT":[{"def":"A writ of prohibition against proceeding in the spiritual court in certain cases, when the suit belongs to the common-law courts.","pos":""}],"INDICE":[{"def":"Index; indication.","pos":""}],"INDICIA":[{"def":"Discriminating marks; signs; tokens; indications; appearances.","pos":""}],"INDICOLITE":[{"def":"A variety of tourmaline of an indigo-blue color.","pos":""}],"INDICT":[{"def":"To charge with a crime, in due form of law, by the finding or presentment of a grand jury; to find an indictment against; as, to indict a man for arson.","pos":""}],"INDICTABLE":[{"def":"Capable of being, or liable to be, indicted; subject to indictment; as, an indictable offender or offense.","pos":""}],"INDICTEE":[{"def":"A person indicted.","pos":""}],"INDICTER":[{"def":"One who indicts.","pos":""}],"INDICTION":[{"def":"Declaration; proclamation; public notice or appointment.","pos":""},{"def":"A cycle of fifteen years.","pos":""}],"INDICTIVE":[{"def":"Proclaimed; declared; public.","pos":""}],"INDICTMENT":[{"def":"The formal statement of an offense, as framed by the prosecuting authority of the State, and found by the grand jury.","pos":""}],"INDICTOR":[{"def":"One who indicts.","pos":""}]}