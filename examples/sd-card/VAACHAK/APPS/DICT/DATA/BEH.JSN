{"BEHALF":[{"def":"Advantage; favor; stead; benefit; interest; profit; support; defense; vindication.","pos":""}],"BEHAVE":[{"def":"To manage or govern in point of behavior; to discipline; to handle; to restrain.","pos":""},{"def":"To carry; to conduct; to comport; to manage; to bear; -- used reflexively.","pos":""}],"BEHAVIOR":[{"def":"Manner of behaving, whether good or bad; mode of conducting one's self; conduct; deportment; carriage; -- used also of inanimate objects; as, the behavior of a ship in a storm; the behavior of the magnetic needle.","pos":""}],"BEHEAD":[{"def":"To sever the head from; to take off the head of.","pos":""}],"BEHEADAL":[{"def":"Be*head\"al Defn: ,n.","pos":"noun"}],"BEHELD":[{"def":"Be*held\", Defn: imp.","pos":""}],"BEHEMOTH":[{"def":"An animal, probably the hippopotamus, described in Job xl.","pos":""}],"BEHEST":[{"def":"That which is willed or ordered; a command; a mandate; an injunction.","pos":""},{"def":"A vow; a promise.","pos":""}],"BEHIGHT":[{"def":"To promise; to vow.","pos":""},{"def":"To give in trust; to commit; to intrust.","pos":""}],"BEHIND":[{"def":"On the side opposite the front or nearest part; on the back side of; at the back of; on the other side of; as, behind a door; behind a hill.","pos":""},{"def":"Left after the departure of, whether this be by removing to a distance or by death.","pos":""}],"BEHINDHAND":[{"def":"In arrears financially; in a state where expenditures have exceeded the receipt of funds.","pos":""},{"def":"In a state of backwardness, in respect to what is seasonable or appropriate, or as to what should have been accomplished; not equally forward with some other person or thing; dilatory; backward; late; tardy; as, behindhand in studies or in work.","pos":""}],"BEHITHER":[{"def":"On this side of.","pos":""}],"BEHOLD":[{"def":"To have in sight; to see clearly; to look at; to regard with the eyes.","pos":""}],"BEHOLDEN":[{"def":"Obliged; bound in gratitude; indebted.","pos":""}],"BEHOLDER":[{"def":"One who beholds; a spectator.","pos":""}],"BEHOLDING":[{"def":"Obliged; beholden.","pos":""}],"BEHOLDINGNESS":[{"def":", The state of being obliged or beholden.","pos":""}],"BEHOOF":[{"def":"Advantage; profit; benefit; interest; use.","pos":""}],"BEHOOVABLE":[{"def":"Supplying need; profitable; advantageous.","pos":""}],"BEHOOVE":[{"def":"To be necessary for; to be fit for; to be meet for, with respect to necessity, duty, or convenience; -- mostly used impersonally.","pos":""}],"BEHOOVEFUL":[{"def":"Advantageous; useful; profitable.","pos":""}],"BEHOVE":[{"def":", and derivatives.","pos":""}],"BEHOVELY":[{"def":"Useful, or usefully.","pos":""}],"BEHOWL":[{"def":"The wolf behowls the moon.","pos":""}]}