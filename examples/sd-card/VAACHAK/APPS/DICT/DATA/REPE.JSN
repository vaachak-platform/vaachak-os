{"REPEAL":[{"def":"To recall; to summon again, as persons.","pos":""},{"def":"To recall, as a deed, will, law, or statute; to revoke; to rescind or abrogate by authority, as by act of the legislature; as, to repeal a law.","pos":""}],"REPEALABILITY":[{"def":"The quality or state of being repealable.","pos":""}],"REPEALABLE":[{"def":"Capable of being repealed.","pos":""}],"REPEALER":[{"def":"One who repeals; one who seeks a repeal; specifically, an advocate for the repeal of the Articles of Union between Great Britain and Ireland.","pos":""}],"REPEALMENT":[{"def":"Recall, as from banishment.","pos":""}],"REPEAT":[{"def":"To repay or refund (an excess received).","pos":""}],"REPEATEDLY":[{"def":"More than once; again and again; indefinitely.","pos":""}],"REPEATER":[{"def":"One who, or that which, repeats.","pos":""}],"REPEATING":[{"def":"Doing the same thing over again; accomplishing a given result many times in succession; as, a repeating firearm; a repeating watch.","pos":""}],"REPEDATION":[{"def":"A stepping or going back.","pos":""}],"REPEL":[{"def":"To drive back; to force to return; to check the advance of; to repulse as, to repel an enemy or an assailant.","pos":""},{"def":"To resist or oppose effectually; as, to repel an assault, an encroachment, or an argument.","pos":""}],"REPELLENT":[{"def":"Driving back; able or tending to repel.","pos":""}],"REPELLER":[{"def":"One who, or that which, repels.","pos":""}],"REPENT":[{"def":"Prostrate and rooting; -- said of stems.","pos":""},{"def":"Same as Reptant.","pos":""}],"REPENTANCE":[{"def":"The act of repenting, or the state of being penitent; sorrow for what one has done or omitted to do; especially, contrition for sin.","pos":""}],"REPENTANT":[{"def":"Penitent; sorry for sin.","pos":""},{"def":"Expressing or showing sorrow for sin; as, repentant tears; repentant ashes.","pos":""}],"REPENTANTLY":[{"def":"In a repentant manner.","pos":""}],"REPENTER":[{"def":"One who repents.","pos":""}],"REPENTINGLY":[{"def":"With repentance; penitently.","pos":""}],"REPEOPLE":[{"def":"Re*peo\"ple (r-p\"p'l), v.","pos":""}],"REPERCEPTION":[{"def":"The act of perceiving again; a repeated perception of the same object.","pos":""}],"REPERCUSS":[{"def":"To drive or beat back; hence, to reflect; to reverberate.","pos":""}],"REPERCUSSION":[{"def":"Rapid reiteration of the same sound.","pos":""},{"def":"The subsidence of a tumor or eruption by the action of a repellent.","pos":""}],"REPERCUSSIVE":[{"def":"Tending or able to repercuss; having the power of sending back; causing to reverberate.","pos":""}],"REPERTITIOUS":[{"def":"Found; gained by finding.","pos":""}],"REPERTOIRE":[{"def":"A list of drams, operas, pieces, parts, etc.","pos":""}],"REPERTORY":[{"def":"A place in which things are disposed in an orderly manner, so that they can be easily found, as the index of a book, a commonplace book, or the like.","pos":""},{"def":"A treasury; a magazine; a storehouse.","pos":""}],"REPERUSAL":[{"def":"A second or repeated perusal.","pos":""}],"REPERUSE":[{"def":"To peruse again.","pos":""}],"REPETEND":[{"def":"That part of a circulating decimal which recurs continually, ad infinitum: -- sometimes indicated by a dot over the first and last repetend is 283.","pos":""}],"REPETITION":[{"def":"The act of repeating, singing, 4.","pos":""},{"def":"Reiteration, or repeating the same word, or the same sense in different words, for the purpose of making a deeper impression on the audience.","pos":""}],"REPETITIONER":[{"def":"One who repeats.","pos":""}],"REPETITIOUS":[{"def":"Repeating; containing repetition.","pos":""}],"REPETITIVE":[{"def":"Containing repetition; repeating.","pos":""}],"REPETITOR":[{"def":"A private instructor.","pos":""}]}