{"WAD":[{"def":"A little mass, tuft, or bundle, as of hay or tow.","pos":""},{"def":"Specifically: A little mass of some soft or flexible material, such as hay, straw, tow, paper, or old rope yarn, used for retaining a charge of powder in a gun, or for keeping the powder and shot close; also, to diminish or avoid the effects of windage.","pos":""}],"WADDING":[{"def":"A wad, or the materials for wads; any pliable substance of which wads may be made.","pos":""},{"def":"Any soft stuff of loose texture, used for stuffing or padding garments; esp.","pos":""}],"WADDLE":[{"def":"To walk with short steps, swaying the body from one side to the other, like a duck or very fat person; to move clumsily and totteringly along; to toddle; to stumble; as, a child waddles when he begins to walk; a goose waddles.","pos":""}],"WADDLER":[{"def":"One who, or that which, waddles.","pos":""}],"WADDLINGLY":[{"def":"In a waddling manner.","pos":""}],"WADDY":[{"def":"An aboriginal war club.","pos":""},{"def":"A piece of wood; stick; peg; also, a walking stick.","pos":""}],"WADDYWOOD":[{"def":"An Australian tree (Pittosporum bicolor); also, its wood, used in making waddies.","pos":""}],"WADE":[{"def":"To go; to move forward.","pos":""},{"def":"To walk in a substance that yields to the feet; to move, sinking at each step, as in water, mud, sand, etc.","pos":""}],"WADER":[{"def":"Any long-legged bird that wades in the water in search of food, especially any species of limicoline or grallatorial birds; -- called also wading bird.","pos":""}],"WADMOL":[{"def":"A coarse, hairy, woolen cloth, formerly used for garments by the poor, and for various other purposes.","pos":""}],"WADSET":[{"def":"A kind of pledge or mortgage.","pos":""}],"WADSETTER":[{"def":"One who holds by a wadset.","pos":""}],"WADY":[{"def":"A ravine through which a brook flows; the channel of a water course, which is dry except in the rainy season.","pos":""}]}