{"LUNA":[{"def":"American moth (Actias luna).","pos":""}],"LUNACY":[{"def":"Insanity or madness; properly, the kind of insanity which is broken by intervals of reason, -- formerly supposed to be influenced by the changes of the moon; any form of unsoundness of mind, except idiocy; mental derangement or alienation.","pos":""},{"def":"A morbid suspension of good sense or judgment, as through fanaticism.","pos":""}],"LUNAR":[{"def":"Of or pertaining to the moon; as, lunar observations.","pos":""},{"def":"Resembling the moon; orbed.","pos":""}],"LUNARIAN":[{"def":"An inhabitant of the moon.","pos":""}],"LUNARY":[{"def":"Crescent-shaped; as, a lunate leaf; a lunate beak; a lunated cross.","pos":""}],"LUNATIC":[{"def":"Affected by lunacy; insane; mad.","pos":""},{"def":"Of or pertaining to, or suitable for, an insane person; evincing lunacy; as, lunatic gibberish; a lunatic asylum.","pos":""}],"LUNCH":[{"def":"A luncheon; specifically, a light repast between breakfast and dinner.","pos":""}],"LUNCHEON":[{"def":"A portion of food taken at any time except at a regular meal; an informal or light repast, as between breakfast and dinner.","pos":""}],"LUNE":[{"def":"A figure in the form of a crescent, bounded by two intersecting arcs of circles.","pos":""}],"LUNET":[{"def":"A little moon or satellite.","pos":""}],"LUNETTE":[{"def":"A fieldwork consisting of two faces, forming a salient angle, and two parallel flanks.","pos":""},{"def":"A half horseshoe, which wants the sponge.","pos":""}],"LUNG":[{"def":"An organ for aërial respiration; -- commonly in the plural.","pos":""}],"LUNG-GROWN":[{"def":"Having lungs that adhere to the pleura.","pos":""}],"LUNGE":[{"def":"A sudden thrust or pass, as with a sword.","pos":""}],"LUNGED":[{"def":"Having lungs, or breathing organs similar to lungs.","pos":""}],"LUNGFISH":[{"def":"Any fish belonging to the Dipnoi; -- so called because they have both lungs and gills.","pos":""}],"LUNGIS":[{"def":"A lingerer; a dull, drowsy fellow.","pos":""}],"LUNGLESS":[{"def":"Being without lungs.","pos":""}],"LUNGOOR":[{"def":"A long-tailed monkey (Semnopithecus schislaceus), from the mountainous districts of India.","pos":""}],"LUNGWORM":[{"def":"Any one of several species of parasitic nematoid worms which infest the lungs and air passages of cattle, sheep, and other animals, often proving fatal.","pos":""}],"LUNGWORT":[{"def":"Sibirica) plants nearly related to Pulmonaria.","pos":""}],"LUNICURRENT":[{"def":"Having relation to changes in currents that depend on the moon's phases.","pos":""}],"LUNIFORM":[{"def":"Resembling the moon in shape.","pos":""}],"LUNISOLAR":[{"def":"Resulting from the united action, or pertaining to the mutual relations, of the sun and moon.","pos":""}],"LUNISTICE":[{"def":"The farthest point of the moon's northing and southing, in its monthly revolution.","pos":""}],"LUNITIDAL":[{"def":"Pertaining to tidal movements dependent on the moon.","pos":""}],"LUNT":[{"def":"The match cord formerly used in firing cannon.","pos":""},{"def":"A puff of smoke.","pos":""}],"LUNULAR":[{"def":"Having a form like that of the new moon; shaped like a crescent.","pos":""},{"def":"Resembling a small crescent.","pos":""}],"LUNULE":[{"def":"Anything crescent-shaped; a crescent-shaped part or mark; a lunula, a lune.","pos":""}],"LUNULET":[{"def":"A small spot, shaped like a half-moon or crescent; as, the lunulet on the wings of many insects.","pos":""}],"LUNULITE":[{"def":"Any bryozoan of the genus Lunulites, having a more or less circular form.","pos":""}],"LUNY":[{"def":"Crazy; mentally unsound.","pos":""}]}