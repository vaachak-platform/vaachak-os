{"INDISCERNIBLE":[{"def":"Not to be discerned; imperceptible; not discoverable or visible.","pos":""},{"def":"The state or quality of being indiscerpible.","pos":""}],"INDISCIPLINABLE":[{"def":"Not disciplinable; undisciplinable.","pos":""}],"INDISCIPLINE":[{"def":"Want of discipline or instruction.","pos":""}],"INDISCOVERABLE":[{"def":"Not discoverable; undiscoverable.","pos":""}],"INDISCOVERY":[{"def":"Want of discovery.","pos":""}],"INDISCREET":[{"def":"Not discreet; wanting in discretion.","pos":""}],"INDISCRETE":[{"def":"Not discrete or separated; compact; homogenous.","pos":""}],"INDISCRETION":[{"def":"The quality or state of being indiscreet; want of discretion; imprudence.","pos":""},{"def":"An indiscreet act; indiscreet behavior.","pos":""}],"INDISCRIMINATE":[{"def":"Not discriminate; wanting discrimination; undistinguishing; not making any distinction; confused; promiscuous.","pos":""}],"INDISCRIMINATING":[{"def":"Not discriminating.","pos":""}],"INDISCRIMINATION":[{"def":"Want of discrimination or distinction; impartiality.","pos":""}],"INDISCRIMINATIVE":[{"def":"Making no distinction; not discriminating.","pos":""}],"INDISPENSABILITY":[{"def":"Indispensableness.","pos":""}],"INDISPENSABLE":[{"def":"Not admitting dispensation; not subject to release or exemption.","pos":""}],"INDISPENSABLENESS":[{"def":"The state or quality of being indispensable, or absolutely necessary.","pos":""}],"INDISPENSABLY":[{"def":"In an indispensable manner.","pos":""}],"INDISPOSE":[{"def":"To render unfit or unsuited; to disqualify.","pos":""},{"def":"To disorder slightly as regards health; to make somewhat.","pos":""}],"INDISPOSEDNESS":[{"def":"The condition or quality of being indisposed.","pos":""}],"INDISPOSITION":[{"def":"The state of being indisposed; disinclination; as, the indisposition of two substances to combine.","pos":""},{"def":"A slight disorder or illness.","pos":""}],"INDISPUTABILITY":[{"def":"Indisputableness.","pos":""}],"INDISPUTABLE":[{"def":"Not disputable; incontrovertible; too evident to admit of dispute.","pos":""}],"INDISSOLUBILITY":[{"def":"The quality or state of being indissoluble.","pos":""}],"INDISSOLUBLE":[{"def":"Not dissoluble; not capable of being dissolved, melted, or liquefied; insoluble; as few substances are indissoluble by heat, but many are indissoluble in water.","pos":""},{"def":"Incapable of being rightfully broken or dissolved; perpetually binding or obligatory; firm; stable, as, an indissoluble league or covenant.","pos":""}],"INDISSOLUBLENESS":[{"def":"Indissolubility.","pos":""}],"INDISSOLUBLY":[{"def":"In an indissoluble manner.","pos":""}],"INDISSOLVABLE":[{"def":"Not dissolvable; incapable of being dissolved or separated; incapable oas, an indissolvable bond of union.","pos":""}],"INDISSOLVABLENESS":[{"def":"Indissolubleness.","pos":""}],"INDISTANCY":[{"def":"Want of distance o [Obs.","pos":""}],"INDISTINCT":[{"def":"Not distinct or distinguishable; not separate in such a manner as to be perceptible by itself; as, the indistinct parts of a substance.","pos":""},{"def":"Obscure to the mind or senses; not clear; not definite; confused; imperfect; faint; as, indistinct vision; an indistinct sound; an indistinct idea or recollection.","pos":""}],"INDISTINCTIBLE":[{"def":"Indistinguishable.","pos":""}],"INDISTINCTION":[{"def":"Want of distinction or distinguishableness; confusion; uncertainty; indiscrimination.","pos":""}],"INDISTINCTIVE":[{"def":"Having nothing distinctive; common.","pos":""}],"INDISTINCTLY":[{"def":"In an indistinct manner; not clearly; confusedly; dimly; as, certain ideas are indistinctly comprehended.","pos":""}],"INDISTINCTNESS":[{"def":"The quality or condition of being indistinct; want of definiteness; dimness; confusion; as, the indistinctness of a picture, or of comprehension; indistinctness of vision.","pos":""}],"INDISTINGUISHABLE":[{"def":"In`dis*tin\"guish*a*ble, a.","pos":""}],"INDISTINGUISHABLY":[{"def":"In a indistinguishable manner.","pos":""}],"INDISTINGUISHED":[{"def":"In`dis*tin\"guished, a.","pos":""}],"INDISTINGUISHING":[{"def":"Making no difference; indiscriminative; impartial; as, indistinguishing liberalities.","pos":""}],"INDISTURBANCE":[{"def":"Freedom from disturbance; calmness; repose; apathy; indifference.","pos":""}]}