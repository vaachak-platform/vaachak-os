{"CLICHE":[{"def":"A stereotype plate or any similar reproduction of ornament, or lettering, in relief.","pos":""}],"CLICK":[{"def":"To make a slight, sharp noise (or a succession of such noises), as by gentle striking; to tick.","pos":""}],"CLICKER":[{"def":"One who as has charge of the work of a companionship.","pos":""}],"CLICKET":[{"def":"The knocker of a door.","pos":""}],"CLICKY":[{"def":"Resembling a click; abounding in clicks.","pos":""}],"CLIDASTES":[{"def":"A genus of exinct marine reptiles, allied to the Mosasaurus.","pos":""}],"CLIENCY":[{"def":"State of being a client.","pos":""}],"CLIENT":[{"def":"A citizen who put himself under the protection of a man of distinction and influence, who was called his patron.","pos":""},{"def":"One who consults a legal adviser, or submits his cause to his management.","pos":""}],"CLIENTAGE":[{"def":"State of being client.","pos":""},{"def":"A body of clients.","pos":""}],"CLIENTAL":[{"def":"Of or pertaining to a client.","pos":""}],"CLIENTED":[{"def":"Supplied with clients.","pos":""}],"CLIENTELAGE":[{"def":"See Clientele, n.","pos":""}],"CLIENTELE":[{"def":"The condition or position of a client; clientship.","pos":""},{"def":"The clients or dependents of a nobleman of patron.","pos":""}],"CLIENTSHIP":[{"def":"Condition of a client; state of being under the protection of a patron.","pos":""}],"CLIFF":[{"def":"A high, steep rock; a precipice.","pos":""}],"CLIFF LIMESTONE":[{"def":"A series of limestone strata found in Ohio and farther west, presenting bluffs along the rivers and valleys, formerly supposed to be of one formation, but now known to be partly Silurian and partly Devonian.","pos":""}],"CLIFFY":[{"def":"Having cliffs; broken; craggy.","pos":""}],"CLIFT":[{"def":"That gainst the craggy clifts did loudly roar.","pos":""}],"CLIFTED":[{"def":"Broken; fissured.","pos":""}],"CLIMACTER":[{"def":"See Climacteric, n.","pos":""}],"CLIMACTERIC":[{"def":"Relating to a climacteric; critical.","pos":""}],"CLIMACTERICAL":[{"def":"See Climacteric.","pos":""}],"CLIMACTIC":[{"def":"Of or pertaining to a climax; forming, or of the nature of, a climax, or ascending series.","pos":""}],"CLIMATARCHIC":[{"def":"Presiding over, or regulating, climates.","pos":""}],"CLIMATE":[{"def":"One of thirty regions or zones, parallel to the equator, into which the surface of the earth from the equator to the pole was divided, according to the successive increase of the length of the midsummer day.","pos":""}],"CLIMATIC":[{"def":"Of or pertaining to a climate; depending on, or limited by, a climate.","pos":""}],"CLIMATIZE":[{"def":"To acclimate or become acclimated.","pos":""}],"CLIMATOGRAPHY":[{"def":"A description of climates.","pos":""}],"CLIMATOLOGICAL":[{"def":"Of or pertaining to climatology.","pos":""}],"CLIMATOLOGIST":[{"def":"One versed in, or who studies, climatology.","pos":""}],"CLIMATOLOGY":[{"def":"The science which treats of climates and investigates their phenomena and causes.","pos":""}],"CLIMAX":[{"def":"A figure of which the parts of a sentence or paragraph are so arranged that each sicceeding one rise \"Tribulation worketh patience, patience experience, and experience hope\" -- a happy climax.","pos":""}],"CLIMB":[{"def":"To ascend or creep upward by twining about a support, or by attaching itself by tendrills, rootlets, etc.","pos":""}],"CLIMBABLE":[{"def":"Capable of being climbed.","pos":""}],"CLIMBER":[{"def":"One who, or that which, climbs: (a) (Bot.","pos":""}],"CLIMBING":[{"def":"Climb\"ing, Defn: p.","pos":""}],"CLIME":[{"def":"A climate; a tract or region of the earth.","pos":""}],"CLINANTHIUM":[{"def":"The receptacle of the flowers in a composite plant; -- also called clinium.","pos":""}],"CLINCH":[{"def":"To hold firmly; to hold fast by grasping or embracing tightly.","pos":""},{"def":"To set closely together; to close tightly; as, to clinch the teeth or the first.","pos":""}],"CLINCHER":[{"def":"One who, or that which, clinches; that which holds fast.","pos":""},{"def":"That which ends a dispute or controversy; a decisive argument.","pos":""}],"CLINCHER-BUILT":[{"def":"See Clinker-built.","pos":""}],"CLING":[{"def":"To adhere closely; to stick; to hold fast, especially by twining round or embracing; as, the tendril of a vine clings to its support; -- usually followed by to or together.","pos":""}],"CLINGSTONE":[{"def":"Having the flesh attached closely to the stone, as in some kinds of peaches.","pos":""},{"def":"A fruit, as a peach, whose flesh adheres to the stone.","pos":""}],"CLINGY":[{"def":"Apt to cling; adhesive.","pos":""}],"CLINIC":[{"def":"One who receives baptism on a sick bed.","pos":""},{"def":"A school, or a session of a school or class, in which medicine or surgery is taught by the examination and treatment of patients in the presence of the pupils.","pos":""}],"CLINICALLY":[{"def":"In a clinical manner.","pos":""}],"CLINIUM":[{"def":"See Clinanthium.","pos":""}],"CLINK":[{"def":"To cause to give out a slight, sharp, tinkling, sound, as by striking metallic or other sonorous bodies together.","pos":""}],"CLINKER":[{"def":"A mass composed of several bricks run together by the action of the fire in the kiln.","pos":""},{"def":"Scoria or vitrified incombustible matter, formed in a grate or furnace where anthracite coal in used; vitrified or burnt matter ejected from a volcano; slag.","pos":""}],"CLINKER-BUILT":[{"def":"Having the side planks (af a boat) so arranged that the lower edge of each overlaps the upper edge of the plank next below it like clapboards on a house.","pos":""}],"CLINKSTONE":[{"def":"An igneous rock of feldspathic composition, lamellar in structure, and clinking under the hammer.","pos":""}],"CLINODIAGONAL":[{"def":"That diagonal or lateral axis in a monoclinic crystal which makes an oblique angle witch the vertical axis.","pos":""},{"def":"Pertaining to, or the direction of, the clinidiagonal.","pos":""}],"CLINOGRAPHIC":[{"def":"Pertaining to that mode of projection in drawing in which the rays of light are supposed to fall obliquely on the plane of projection.","pos":""}],"CLINOID":[{"def":"Like a bed; -- applied to several processes on the inner side of the sphenoid bone.","pos":""}],"CLINOMETER":[{"def":"An instrument for determining the dip of beds or strata, pr the slope of an embankment or cutting; a kind of plumb level.","pos":""}],"CLINOMETRIC":[{"def":"Pertaining to, or ascertained by, the clinometer.","pos":""},{"def":"Pertaining to the oblique crystalline forms, or to solids which have oblique angles between the axes; as, the clinometric systems.","pos":""}],"CLINOMETRY":[{"def":"That art or operation of measuring the inclination of strata.","pos":""}],"CLINOPINACOID":[{"def":"The plane in crystals of the monoclinic system which is parallel to the vertical and the inclined lateral (clinidiagonal) axes.","pos":""}],"CLINORHOMBIC":[{"def":"Possessing the qualities of a prism, obliquely inclined to a rhombic base; monoclinic.","pos":""}],"CLINOSTAT":[{"def":"An apparatus consisting of a slowly revolving disk, usually regulated by clockwork, by means of wich the action of external agents, as light and gravity, on growing plants may be regulated or eliminated.","pos":""}],"CLINQUANT":[{"def":"Glittering; dressed in, or overlaid with, tinsel finery.","pos":""}],"CLIO":[{"def":"The Muse who presided over history.","pos":""}],"CLIONE":[{"def":"A genus of naked pteropods.","pos":""}],"CLIP":[{"def":"To embrace, hence; to encompass.","pos":""},{"def":"To cut off; as with shears or scissors; as, to clip the hair; to clip coin.","pos":""}],"CLIPPER":[{"def":"A vessel with a sharp bow, built and rigged for fast sailing.","pos":""}],"CLIPPING":[{"def":"The act of embracing.","pos":""},{"def":"The act of cutting off, curtailing, or diminishing; the practice of clipping the edges of coins.","pos":""}],"CLIQUE":[{"def":"A narrow circle of persons associated by common interests or for the accomplishment of a common purpose; -- generally used in a bad sense.","pos":""}],"CLIQUISH":[{"def":"Of or pertaining to a clique; disposed to from cliques; exclusive in spirit.","pos":""}],"CLIQUISM":[{"def":"The tendency to associate in cliques; the spirit of cliques.","pos":""}],"CLITELLUS":[{"def":"A thickened glandular portion of the body of the adult earthworm, consisting of several united segments modified for reproductive purposes.","pos":""}],"CLITORIS":[{"def":"A small organ at the upper part of the vulva, homologous to the penis in the male.","pos":""}],"CLIVITY":[{"def":"Inclination; ascent or descent; a gradient.","pos":""}]}