{"STAVE":[{"def":"The five horizontal and parallel lines on and between which musical notes are written or pointed; the staff.","pos":""}],"STAVESACRE":[{"def":"A kind of larkspur (Delphinium Staphysagria), and its seeds, which are violently purgative and emetic.","pos":""}],"STAVEWOOD":[{"def":"A tall tree (Simaruba amara) growing in tropical America.","pos":""}],"STAVING":[{"def":"A cassing or lining of staves; especially, one encircling a water wheel.","pos":""}]}