{"SEA-BORDERING":[{"def":"Bordering on the sea; situated beside the sea.","pos":""}],"SEA-BORN":[{"def":"Born of the sea; produced by the sea.","pos":""}],"SEA-BUILT":[{"def":"Built at, in, or by the sea.","pos":""}],"SEA-EAR":[{"def":"Any species of ear-shaped shells of the genus Haliotis.","pos":""}],"SEA-GREEN":[{"def":"Of a beautiful bluish green color, like sea water on soundings.","pos":""}],"SEA-ISLAND":[{"def":"Of or pertaining to certain islands along the coast of South Carolina and Georgia; as, sea-island cotton, a superior cotton of long fiber produced on those islands.","pos":""}],"SEA-MAIL":[{"def":"A gull; the mew.","pos":""}],"SEA-ROVING":[{"def":"Sea\"-rov\"ing Defn: , a.","pos":""}],"SEA-WALLED":[{"def":"Surrounded, bounded, or protected by the sea, as if by a wall.","pos":""},{"def":"The name used by the Algonquin Indians for the shell beads which passed among the Indians as money.","pos":""}]}