{"LONDON":[{"def":"The capital city of England.","pos":""}],"LONDON SMOKE":[{"def":"A neutral tint given to spectacles, shade glasses for optical instruments, etc.","pos":""}],"LONDON TUFT":[{"def":"The Sweet William (Dianthus barbatus).","pos":""}],"LONDONER":[{"def":"A native or inhabitant of London.","pos":""}],"LONDONISM":[{"def":"A characteristic of Londoners; a mode of speaking peculiar to London.","pos":""}],"LONDONIZE":[{"def":"To impart to (one) a manner or character like that which distinguishes Londoners.","pos":""}],"LONE":[{"def":"Being without a companion; being by one's self; also, sad from lack of companionship; lonely; as, a lone traveler or watcher.","pos":""},{"def":"Single; unmarried, or in widowhood.","pos":""}],"LONE-STAR STATE":[{"def":"Texas; -- a nickname alluding to the single star on its coat of arms, being the device used on its flag and seal when it was a republic.","pos":""}],"LONELINESS":[{"def":"The condition of being lonely; solitude; seclusion.","pos":""},{"def":"The state of being unfrequented by human beings; as, the loneliness of a road.","pos":""}],"LONELY":[{"def":"Sequestered from company or neighbors; solitary; retired; as, a lonely situation; a lonely cell.","pos":""},{"def":"Alone, or in want of company; forsaken.","pos":""}],"LONENESS":[{"def":"Solitude; seclusion.","pos":""}],"LONESOME":[{"def":"Secluded from society; not frequented by human beings; solitary.","pos":""},{"def":"Conscious of, and somewhat depressed by, solitude; as, to feel lonesome.","pos":""}],"LONG":[{"def":"Prolonged, or relatively more prolonged, in utterance; -- said of vowels and syllables.","pos":""}],"LONG PRIMER":[{"def":"A kind of type, in size between small pica and bourgeois.","pos":""}],"LONG-ARMED":[{"def":"Having long arms; as, the long-armed ape or gibbon.","pos":""}],"LONG-BREATHED":[{"def":"Having the power of retaining the breath for a long time; long- winded.","pos":""}],"LONG-DRAWN":[{"def":"Extended to a great length.","pos":""}],"LONG-HORNED":[{"def":"Having a long horn or horns; as, a long-horned goat, or cow; having long antennæ, as certain beetles (Longicornia).","pos":""}],"LONG-LIVED":[{"def":"Having a long life; having constitutional peculiarities which make long life probable; lasting long; as, a long-lived tree; they are a longlived family; long-lived prejudices.","pos":""}],"LONG-SIGHT":[{"def":"Long-sightedness Good.","pos":""}],"LONG-SIGHTED":[{"def":"Able to see objects at a great distance; hence, having great foresight; sagacious; farseeing.","pos":""},{"def":"Able to see objects distinctly at a distance, but not close at hand; hypermetropic.","pos":""}],"LONG-SIGHTEDNESS":[{"def":"See Hypermetropia.","pos":""}],"LONG-STOP":[{"def":"One who is set to stop balls which pass the wicket keeper.","pos":""}],"LONG-SUFFERANCE":[{"def":"Forbearance to punish or resent.","pos":""}],"LONG-SUFFERING":[{"def":"Bearing injuries or provocation for a long time; patient; not easily provoked.","pos":""}],"LONG-TONGUED":[{"def":"Having a long tongue.","pos":""},{"def":"Talkative; babbling; loquacious.","pos":""}],"LONG-WAISTED":[{"def":"Having a long waist; long from the armpits to the armpits to the bottom of the waist; -- said of persons.","pos":""},{"def":"Long from the part about the neck or shoulder, or from the armpits, to the bottom of the weist, or to the skirt; -- said of garments; as, a long-waisted coat.","pos":""}],"LONG-WINDED":[{"def":"Long-breathed; hence, tediously long in speaking; consuming much time; as, a long-winded talker.","pos":""}],"LONGAN":[{"def":"A pulpy fruit related to the litchi, and produced by an evergreen East Indian tree (Nephelium Longan).","pos":""}],"LONGANIMITY":[{"def":"Disposition to bear injuries patiently; forbearance; patience.","pos":""}],"LONGBEAK":[{"def":"The American redbellied snipe (Macrorhamphus scolopaceus); -- called also long-billed dowitcher.","pos":""}],"LONGBOAT":[{"def":"Formerly, the largest boat carried by a merchant vessel, corresponding to the launch of a naval vessel.","pos":""}],"LONGBOW":[{"def":"The ordinary bow, not mounted on a stock; -- so called in distinction from the crossbow when both were used as weapons of war.","pos":""}],"LONGE":[{"def":"The training ground for a horse.","pos":""}],"LONGER":[{"def":"One who longs for anything.","pos":""}],"LONGEVAL":[{"def":"Long-loved; longevous.","pos":""}],"LONGEVITY":[{"def":"Long duration of life; length of life.","pos":""}],"LONGEVOUS":[{"def":"Living a long time; of great age.","pos":""}],"LONGHAND":[{"def":"The written characters used in the common method of writing; -- opposed to shorthand.","pos":""}],"LONGHEADED":[{"def":"Having unusual foresight or sagacity.","pos":""}],"LONGHORN":[{"def":"A long-horned animal, as a cow, goat, or beetle.","pos":""}],"LONGICORN":[{"def":"Long-horned; pertaining to the Longicornia.","pos":""},{"def":"One of the Longicornia.","pos":""}],"LONGICORNIA":[{"def":"A division of beetles, including a large number of species, in which the antennæ are very long.","pos":""}],"LONGILATERAL":[{"def":"Having long sides especially, having the form of a long parallelogram.","pos":""}],"LONGILOQUENCE":[{"def":"Long-windedness.","pos":""}],"LONGIMANOUS":[{"def":"Having long hands.","pos":""}],"LONGIMETRY":[{"def":"The art or practice of measuring distances or lengths.","pos":""}],"LONGING":[{"def":"An eager desire; a craving; a morbid appetite; an earnest wish; an aspiration.","pos":""}],"LONGINQUITY":[{"def":"Greatness of distance; remoteness.","pos":""}],"LONGIPALP":[{"def":"One of a tribe of beetles, having long maxillary palpi.","pos":""}],"LONGIPENNATE":[{"def":"Having long wings, or quills.","pos":""}],"LONGIPENNES":[{"def":"A group of longwinged sea birds, including the gulls, petrels, etc.","pos":""}],"LONGIPENNINE":[{"def":"Of or pertaining to the Longipennes; longipennate.","pos":""}],"LONGIROSTER":[{"def":"One of the Longirostres.","pos":""}],"LONGIROSTRAL":[{"def":"Having a long bill; of or pertaining to the Longirostres.","pos":""}],"LONGIROSTRES":[{"def":"A group of birds characterized by having long slender bills, as the sandpipers, curlews, and ibises.","pos":""}],"LONGISH":[{"def":"Somewhat long; moderately long.","pos":""}],"LONGITUDE":[{"def":"The arc or portion of the equator intersected between the meridian of a given place and the meridian of some other place from which longitude is reckoned, as from Greenwich, England, or sometimes from the capital of a country, as from Washington or Paris.","pos":""},{"def":"The distance in degrees, reckoned from the vernal equinox, on the ecliptic, to a circle at right angles to the ecliptic passing through the heavenly body whose longitude is designated; as, the longitude of Capella is 79º.","pos":""}],"LONGITUDINAL":[{"def":"Of or pertaining to longitude or length; as, longitudinal distance.","pos":""},{"def":"Extending in length; in the direction of the length; running lengthwise, as distinguished from transverse; as, the longitudinal diameter of a body.","pos":""}],"LONGITUDINALLY":[{"def":"In the direction of length.","pos":""}],"LONGLEGS":[{"def":"A daddy longlegs.","pos":""}],"LONGLY":[{"def":"With longing desire.","pos":""},{"def":"For a long time; hence, wearisomely.","pos":""}],"LONGMYND ROCKS":[{"def":"The sparingly fossiliferous conglomerates, grits, schists, and states of Great Britain, which lie at the base of the Cambrian system; -- so called, because typically developed in the Longmynd Hills, Shropshire.","pos":""}],"LONGNOSE":[{"def":"The European garfish.","pos":""}],"LONGSHORE":[{"def":"Belonging to the seashore or a seaport; along and on the shore.","pos":""}],"LONGSHOREMAN":[{"def":"One of a class of laborers employed about the wharves of a seaport, especially in loading and unloading vessels.","pos":""}],"LONGSOME":[{"def":"Extended in length; tiresome.","pos":""}],"LONGSPUN":[{"def":"Spun out, or extended, to great length; hence, long-winded; tedious.","pos":""}],"LONGSPUR":[{"def":"Any one of several species of fringilline birds of the genus Calcarius (or Plectrophanes), and allied genera.","pos":""}],"LONGTAIL":[{"def":"An animal, particularly a log, having an uncut tail.","pos":""}],"LONGULITE":[{"def":"A kind of crystallite having a (slender) acicular form.","pos":""}]}