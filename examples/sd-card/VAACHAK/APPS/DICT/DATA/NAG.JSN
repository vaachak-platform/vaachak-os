{"NAG":[{"def":"A small horse; a pony; hence, any horse.","pos":""},{"def":"A paramour; -- in contempt.","pos":""}],"NAGANA":[{"def":"The disease caused by the tsetse fly.","pos":""}],"NAGGING":[{"def":"Fault-finding; teasing; persistently annoying; as, a nagging toothache.","pos":""}],"NAGGY":[{"def":"Irritable; touchy.","pos":""}],"NAGOR":[{"def":"A West African gazelle (Gazella redunca).","pos":""}],"NAGYAGITE":[{"def":"A mineral of blackish lead-gray color and metallic luster, generally of a foliated massive structure; foliated tellurium.","pos":""}]}