{"NOT":[{"def":"Wot not; know not; knows not.","pos":""}],"NOTABILIA":[{"def":"Things worthy of notice.","pos":""}],"NOTABILITY":[{"def":"Quality of being notable.","pos":""},{"def":"A notable, or remarkable, person or thing; a person of note.","pos":""}],"NOTABLE":[{"def":"Capable of being noted; noticeable; plan; evident.","pos":""},{"def":"Worthy of notice; remarkable; memorable; noted or distinguished; as, a notable event, person.","pos":""}],"NOTABLENESS":[{"def":"The quality of being notable.","pos":""}],"NOTABLY":[{"def":"In a notable manner.","pos":""}],"NOTAEUM":[{"def":"The back or upper surface, as of a bird.","pos":""}],"NOTAL":[{"def":"Of or pertaining to the back; dorsal.","pos":""}],"NOTANDUM":[{"def":"A thing to be noted or observed; a notable fact; -- chiefly used in the plural.","pos":""}],"NOTARIAL":[{"def":"Of or pertaining to a notary; done or taken by a notary; as, a notarial seal; notarial evidence or attestation.","pos":""}],"NOTARIALLY":[{"def":"In a notarial manner.","pos":""}],"NOTARY":[{"def":"A public officer who attests or certifies deeds and other writings, or copies of them, usually under his official seal, to make them authentic, especially in foreign countries.","pos":""}],"NOTATE":[{"def":"Marked with spots or lines, which are often colored.","pos":""}],"NOTATION":[{"def":"The act or practice of recording anything by marks, figures, or characters.","pos":""},{"def":"Any particular system of characters, symbols, or abbreviated expressions used in art or science, to express briefly technical facts, quantities, etc.","pos":""}],"NOTCH":[{"def":"A hollow cut in anything; a nick; an indentation.","pos":""},{"def":"A narrow passage between two elevation; a deep, close pass; a defile; as, the notch of a mountain.","pos":""}],"NOTCHBOARD":[{"def":"The board which receives the ends of the steps in a staircase.","pos":""}],"NOTCHING":[{"def":"A method of joining timbers, scantling, etc.","pos":""},{"def":"A method of excavating, as in a bank, by a series of cuttings side by side.","pos":""}],"NOTCHWEED":[{"def":"A foul-smelling weed, the stinking goosefoot (Chenopodium Vulvaria).","pos":""}],"NOTE":[{"def":"To butt; to push with the horns.","pos":""}],"NOTE PAPER":[{"def":"Writing paper, not exceeding in size, when folded once, five by eight inches.","pos":""}],"NOTEBOOK":[{"def":"A book in which notes or memorandums are written.","pos":""},{"def":"A book in which notes of hand are registered.","pos":""}],"NOTED":[{"def":"Well known by reputation or report; eminent; celebrated; as, a noted author, or traveler.","pos":""}],"NOTELESS":[{"def":"Not attracting notice; not conspicuous.","pos":""}],"NOTELESSNESS":[{"def":"A state of being noteless.","pos":""}],"NOTELET":[{"def":"A little or short note; a billet.","pos":""}],"NOTER":[{"def":"One who takes notice.","pos":""}],"NOTEWORTHY":[{"def":"Worthy of observation or notice; remarkable.","pos":""}],"NOTHING":[{"def":"A cipher; naught.","pos":""}],"NOTHINGARIAN":[{"def":"One of no certain belief; one belonging to no particular sect.","pos":""}],"NOTHINGISM":[{"def":"Nihility; nothingness.","pos":""}],"NOTHINGNESS":[{"def":"Nihility; nonexistence.","pos":""},{"def":"The state of being of no value; a thing of no value.","pos":""}],"NOTICE":[{"def":"The act of noting, remarking, or observing; observation by the senses or intellect; cognizance; note.","pos":""},{"def":"Intelligence, by whatever means communicated; knowledge given or received; means of knowledge; express notification; announcement; warning.","pos":""}],"NOTICEABLE":[{"def":"Capable of being observed; worthy of notice; likely to attract observation; conspicous.","pos":""}],"NOTICEABLY":[{"def":"In a noticeable manner.","pos":""}],"NOTICER":[{"def":"One who notices.","pos":""}],"NOTIDANIAN":[{"def":"Any one of several species of sharks of the family Notidanidæ, or Hexanchidæ.","pos":""}],"NOTIFICATION":[{"def":"The act of notifying, or giving notice; the act of making known; especially, the act of giving official notice or information to the public or to individuals, corporations, companies, or societies, by words, by writing, or by other means.","pos":""},{"def":"Notice given in words or writing, or by signs.","pos":""}],"NOTIFY":[{"def":"To make known; to declare; to publish; as, to notify a fact to a person.","pos":""},{"def":"To give notice to; to inform by notice; to apprise; as, the constable has notified the citizens to meet at the city hall; the bell notifies us of the time of meeting.","pos":""}],"NOTION":[{"def":"Mental apprehension of whatever may be known or imagined; an idea; a conception; more properly, a general or universal conception, as distinguishable or definable by marks or notæ.","pos":""},{"def":"A sentiment; an opinion.","pos":""}],"NOTIONAL":[{"def":"Consisting of, or conveying, notions or ideas; expressing abstract conceptions.","pos":""},{"def":"Existing in idea only; visionary; whimsical.","pos":""}],"NOTIONALITY":[{"def":"A notional or groundless opinion.","pos":""}],"NOTIONALLY":[{"def":"In mental apprehension; in conception; not in reality.","pos":""}],"NOTIONIST":[{"def":"One whose opinions are ungrounded notions.","pos":""}],"NOTOBRANCHIATA":[{"def":"No`to*bran`chi*a*ta, n.","pos":""}],"NOTOBRANCHIATE":[{"def":"Of or pertaining to the Notobranchiata.","pos":""}],"NOTOCHORD":[{"def":"An elastic cartilagelike rod which is developed beneath the medullary groove in the vertebrate embryo, and constitutes the primitive axial skeleton around which the centra of the vertebræ and the posterior part of the base of the skull are developed; the chorda dorsalis.","pos":""}],"NOTOCHORDAL":[{"def":"Of or pertaining to the notochord; having a notochord.","pos":""}],"NOTODONTIAN":[{"def":"Any one of several species of bombycid moths belonging to Notodonta, Nerice, and allied genera.","pos":""}],"NOTOPODIUM":[{"def":"The dorsal lobe or branch of a parapodium.","pos":""}],"NOTORHIZAL":[{"def":"Having the radicle of the embryo lying against the back of one of the cotyledons; incumbent.","pos":""}],"NOTORIETY":[{"def":"The quality or condition of being notorious; the state of being generally or publicly known; -- commonly used in an unfavorable sense; as, the notoriety of a crime.","pos":""}],"NOTORIOUS":[{"def":"Generally known and talked of by the public; universally believed to be true; manifest to the world; evident; -- usually in an unfavorable sense; as, a notorious thief; a notorious crime or vice.","pos":""}],"NOTORNIS":[{"def":"A genus of birds allied to the gallinules, but having rudimentary wings and incapable of flight.","pos":""}],"NOTOTHERIUM":[{"def":"An extinct genus of gigantic herbivorous marsupials, found in the Pliocene formation of Australia.","pos":""}],"NOTOTREMA":[{"def":"The pouched, or marsupial, frog of South America.","pos":""},{"def":"Same as Nott-headed.","pos":""}],"NOTSELF":[{"def":"The negative of self.","pos":""}],"NOTT-HEADED":[{"def":"Having the hair cut close.","pos":""}],"NOTTURNO":[{"def":"Same as Nocturne.","pos":""}],"NOTWHEAT":[{"def":"Wheat not bearded.","pos":""}],"NOTWITHSTANDING":[{"def":"Without prevention, or obstruction from or by; in spite of.","pos":""}]}