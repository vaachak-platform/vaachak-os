{"DARBIES":[{"def":"Manacles; handcuffs.","pos":""}],"DARBY":[{"def":"A plasterer's float, having two handles; -- used in smoothing ceilings, etc.","pos":""}],"DARBYITE":[{"def":"One of the Plymouth Brethren, or of a sect among them; -- so called from John N.","pos":""}],"DARE":[{"def":"To have adequate or sufficient courage for any purpose; to be bold or venturesome; not to be afraid; to venture.","pos":""}],"DARE-DEVIL":[{"def":"A reckless fellow.","pos":""}],"DARE-DEVILTRY":[{"def":"Reckless mischief; the action of a dare-devil.","pos":""}],"DAREFUL":[{"def":"Full af daring or of defiance; adveturous.","pos":""}],"DARER":[{"def":"One who dares or defies.","pos":""},{"def":"A day's work; also, a fixed amount of work, whether more or less than that of a day.","pos":""}],"DARIC":[{"def":"Any very pure gold coin.","pos":""}],"DARING":[{"def":"Boldness; fearlessness; adventurousness; also, a daring act.","pos":""}],"DARIOLE":[{"def":"A shell or cup of pastry filled with custard, whipped cream, crushed macaroons, etc.","pos":""}],"DARK":[{"def":"Destitute, or partially destitute, of light; not receiving, reflecting, or radiating light; wholly or partially black, or of some deep shade of color; not light-colored; as, a dark room; a dark day; dark cloth; dark paint; a dark complexion.","pos":""},{"def":"Not clear to the understanding; not easily The dark problems of existence.","pos":""}],"DARKEN":[{"def":"To make dark or black; to deprite of light; to obscure; as, a darkened room.","pos":""},{"def":"To render dim; to deprive of vision.","pos":""}],"DARKENER":[{"def":"One who, or that which, darkens.","pos":""}],"DARKENING":[{"def":"Twilight; gloaming.","pos":""}],"DARKFUL":[{"def":"Full of darkness.","pos":""}],"DARKISH":[{"def":"Somewhat dark; dusky.","pos":""}],"DARKLE":[{"def":"To grow dark; to show indistinctly.","pos":""}],"DARKLING":[{"def":"So, out went the candle, and we were left darkling.","pos":""}],"DARKLY":[{"def":"With imperfect light, clearness, or knowledge; obscurely; dimly; blindly; uncertainly.","pos":""},{"def":"With a dark, gloomy, cruel, or menacing look.","pos":""}],"DARKNESS":[{"def":"The absence of light; blackness; obscurity; gloom.","pos":""},{"def":"A state of privacy; secrecy.","pos":""}],"DARKSOME":[{"def":"Dark; gloomy; obscure; shaded; cheerless.","pos":""}],"DARLING":[{"def":"One dearly beloved; a favorite.","pos":""}],"DARLINGTONIA":[{"def":"A genus of California pitcher plants consisting of a single species.","pos":""}],"DARN":[{"def":"To mend as a rent or hole, with interlacing stitches of yarn or thread by means of a needle; to sew together with yarn or thread.","pos":""}],"DARNEL":[{"def":"Any grass of the genus Lolium, esp.","pos":""}],"DARNER":[{"def":"One who mends by darning.","pos":""},{"def":"Same as Dornick.","pos":""}],"DAROO":[{"def":"The Egyptian sycamore (Ficus Sycamorus).","pos":""}],"DARR":[{"def":"The European black tern.","pos":""}],"DARREIN":[{"def":"Last; as, darrein continuance, the last continuance.","pos":""}],"DART":[{"def":"A fish; the dace.","pos":""}],"DARTARS":[{"def":"A kind of scab or ulceration on the skin of lambs.","pos":""}],"DARTER":[{"def":"The snakebird, a water bird of the genus Plotus; -- so called because it darts out its long, snakelike neck at its prey.","pos":""},{"def":"A small fresh-water etheostomoid fish.","pos":""}],"DARTINGLY":[{"def":"Like a dart; rapidly.","pos":""}],"DARTLE":[{"def":"To pierce or shoot through; to dart repeatedly: -- frequentative of dart.","pos":""}],"DARTOIC":[{"def":"Of or pertaining to the dartos.","pos":""}],"DARTOID":[{"def":"Like the dartos; dartoic; as, dartoid tissue.","pos":""}],"DARTOS":[{"def":"A thin layer of peculiar contractile tissue directly beneath the skin of the scrotum.","pos":""}],"DARTROUS":[{"def":"Relating to, or partaking of the nature of, the disease called tetter; herpetic.","pos":""}],"DARWINIAN":[{"def":"Pertaining to Darwin; as, the Darwinian theory, a theory of the manner and cause of the supposed development of living things from certain original forms or elements.","pos":""}],"DARWINISM":[{"def":"The theory or doctrines put forth by Darwin.","pos":""}]}