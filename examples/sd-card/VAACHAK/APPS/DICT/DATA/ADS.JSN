{"ADSCITITIOUS":[{"def":"Supplemental; additional; adventitious; ascititious.","pos":""}],"ADSCRIPT":[{"def":"Held to service as attached to the soil; -- said of feudal serfs.","pos":""}],"ADSCRIPTIVE":[{"def":"Attached or annexed to the glebe or estate and transferable with it.","pos":""}],"ADSIGNIFICATION":[{"def":"Additional signification.","pos":""}],"ADSIGNIFY":[{"def":"To denote additionally.","pos":""}],"ADSTRICT":[{"def":"See Astrict, and Astriction.","pos":""}],"ADSUKI BEAN":[{"def":"A cultivated variety of the Asiatic gram, now introduced into the United States.","pos":""}]}