{"CELADON":[{"def":"A pale sea-green color; also, porcelain or fine pottery of this tint.","pos":""},{"def":"A perennial herbaceous plant (Chelidonium majus) of the poppy family, with yellow flowers.","pos":""}],"CELATURE":[{"def":"The act or art of engraving or embossing.","pos":""},{"def":"That which is engraved.","pos":""}],"CELEBRANT":[{"def":"One who performs a public religious rite; -- applied particularly to an officiating priest in the Roman Catholic Church, as distinguished from his assistants.","pos":""}],"CELEBRATE":[{"def":"To extol or honor in a solemn manner; as, to celebrate the name of the Most High.","pos":""},{"def":"To honor by solemn rites, by ceremonies of joy and respect, or by refraining from ordinary business; to observe duly; to keep; as, to celebrate a birthday.","pos":""}],"CELEBRATED":[{"def":"Having celebrity; distinguished; renowned.","pos":""}],"CELEBRATION":[{"def":"The act, process, or time of celebrating.","pos":""}],"CELEBRATOR":[{"def":"One who celebrates; a praiser.","pos":""}],"CELEBRITY":[{"def":"Celebration; solemnization.","pos":""},{"def":"The state or condition of being celebrated; fame; renown; as, the celebrity of Washington.","pos":""}],"CELERIAC":[{"def":"Turnip-rooted celery, a from of celery with a large globular root, which is used for food.","pos":""}],"CELERITY":[{"def":"Rapidity of motion; quickness; swiftness.","pos":""}],"CELERY":[{"def":"A plant of the Parsley family (Apium graveolens), of which the blanched leafstalks are used as a salad.","pos":""}],"CELESTIAL":[{"def":"Belonging to the aërial regions, or visible heavens.","pos":""},{"def":"Of or pertaining to the spiritual heaven; heavenly; divine.","pos":""}],"CELESTIALIZE":[{"def":"To make celestial.","pos":""}],"CELESTIALLY":[{"def":"In a celestial manner.","pos":""}],"CELESTIFY":[{"def":"To make like heaven.","pos":""},{"def":"Native strontium sulphate, a mineral so named from its occasional delicate blue color.","pos":""}],"CELIBACY":[{"def":"The state of being unmarried; single life, esp.","pos":""}],"CELIBATE":[{"def":"Celibate state; celibacy.","pos":""},{"def":"One who is unmarried, esp.","pos":""}],"CELIBATIST":[{"def":"One who lives unmarried.","pos":""}],"CELIDOGRAPHY":[{"def":"A description of apparent spots on the disk of the sun, or on planets.","pos":""}],"CELL":[{"def":"A jar of vessel, or a division of a compound vessel, for holding the exciting fluid of a battery.","pos":""},{"def":"One of the minute elementary structures, of which the greater part of the various tissues and organs of animals and plants are composed.","pos":""}],"CELLA":[{"def":"The part inclosed within the walls of an ancient temple, as distinguished from the open porticoes.","pos":""}],"CELLAR":[{"def":"A room or rooms under a building, and usually below the surface of the ground, where provisions and other stores are kept.","pos":""}],"CELLARAGE":[{"def":"The space or storerooms of a cellar; a cellar.","pos":""},{"def":"Chare for storage in a cellar.","pos":""}],"CELLARER":[{"def":"A steward or butler of a monastery or chapter; one who has charge of procuring and keeping the provisions.","pos":""}],"CELLARET":[{"def":"A receptacle, as in a dining room, for a few bottles of wine or liquor, made in the form of a chest or coffer, or a deep drawer in a sideboard, and usually lined with metal.","pos":""}],"CELLARIST":[{"def":"Same as Cellarer.","pos":""}],"CELLED":[{"def":"Containing a cell or cells.","pos":""}],"CELLEPORE":[{"def":"A genus of delicate branching corals, made up of minute cells, belonging to the Bryozoa.","pos":""}],"CELLIFEROUS":[{"def":"Bearing or producing cells.","pos":""}],"CELLO":[{"def":"A contraction for Violoncello.","pos":""}],"CELLULAR":[{"def":"Consisting of, or containing, cells; of or pertaining to a cell or cells.","pos":""}],"CELLULIFEROUS":[{"def":"Bearing or producing little cells.","pos":""}],"CELLULITIS":[{"def":"An inflammantion of the cellular or areolar tissue, esp.","pos":""}],"CELLULOID":[{"def":"A substance composed essentially of gun cotton and camphor, and when pure resembling ivory in texture and color, but variously colored to imitate coral, tortoise shell, amber, malachite, etc.","pos":""}],"CELLULOSE":[{"def":"Consisting of, or containing, cells.","pos":""}],"CELOTOMY":[{"def":"The act or operation of cutting, to relieve the structure in strangulated hernia.","pos":""}],"CELSITURE":[{"def":"Height; altitude.","pos":""}],"CELSIUS":[{"def":"The Celsius thermometer or scale, so called from Anders Celsius, a Swedish astronomer, who invented it.","pos":""}],"CELT":[{"def":"One of an ancient race of people, who formerly inhabited a great part of Central and Western Europe, and whose descendants at the present day occupy Ireland, Wales, the Highlands of Scotland, and the northern shores of France.","pos":""}],"CELTIBERIAN":[{"def":"Of or pertaining to the ancient Celtiberia (a district in Spain lying between the Ebro and the Tagus) or its inhabitants the Celtiberi (Celts of the river Iberus).","pos":""},{"def":"An inhabitant of Celtiberia.","pos":""}],"CELTIC":[{"def":"Of or pertaining to the Celts; as, Celtic people, tribes, literature, tongue.","pos":""}],"CELTICISM":[{"def":"A custom of the Celts, or an idiom of their language.","pos":""}],"CELTICIZE":[{"def":"To render Celtic; to assimilate to the Celts.","pos":""}],"CELTIUM":[{"def":"A supposed new element of the rare-earth group, accompanying lutecium and scandium in the gadolinite earths.","pos":""}]}