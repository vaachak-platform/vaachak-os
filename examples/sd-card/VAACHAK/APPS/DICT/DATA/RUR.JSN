{"RURAL":[{"def":"Of or pertaining to the country, as distinguished from a city or town; living in the country; suitable for, or resembling, the country; rustic; as, rural scenes; a rural prospect.","pos":""},{"def":"Of or pertaining to agriculture; as, rural economy.","pos":""}],"RURALES":[{"def":"The gossamer-winged butterflies; a family of small butterflies, including the hairstreaks, violets, and theclas.","pos":""}],"RURALISM":[{"def":"The quality or state of being rural; ruralness.","pos":""},{"def":"A rural idiom or expression.","pos":""}],"RURALIST":[{"def":"One who leads a rural life.","pos":""}],"RURALITY":[{"def":"The quality or state of being rural.","pos":""}],"RURALIZE":[{"def":"To render rural; to give a rural appearance to.","pos":""}],"RURALLY":[{"def":"In a rural manner; as in the country.","pos":""}],"RURALNESS":[{"def":"The quality or state of being rural.","pos":""}],"RURICOLIST":[{"def":"An inhabitant of the country.","pos":""}],"RURIDECANAL":[{"def":"Of or pertaining to a rural dean; as, a ruridecanal district; the ruridecanal intellect.","pos":""}],"RURIGENOUS":[{"def":"Born in the country.","pos":""}]}