{"INEPT":[{"def":"Not apt or fit; unfit; unsuitable; improper; unbecoming.","pos":""},{"def":"Silly; useless; nonsensical; absurd; foolish.","pos":""}],"INEPTITUDE":[{"def":"The quality of being inept; unfitness; inaptitude; unsuitableness.","pos":""},{"def":"Absurdity; nonsense; foolishness.","pos":""}],"INEPTLY":[{"def":"Unfitly; unsuitably; awkwardly.","pos":""}],"INEPTNESS":[{"def":"Unfitness; ineptitude.","pos":""}]}