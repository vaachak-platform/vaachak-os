{"REFLAME":[{"def":"To kindle again into flame.","pos":""}],"REFLECT":[{"def":"To bend back; to give a backwaas, a mirror reflects rays of light; polished metals reflect heat.","pos":""},{"def":"To give back an image or likeness of; to mirror.","pos":""}],"REFLECTED":[{"def":"Thrown back after striking a surface; as, reflected light, heat, sound, etc.","pos":""},{"def":"Hence: Not one's own; received from another; as, his glory was reflected glory.","pos":""}],"REFLECTENT":[{"def":"Bending or flying back; reflected.","pos":""},{"def":"Reflecting; as, a reflectent body.","pos":""}],"REFLECTIBLE":[{"def":"Capable of being reflected, or thrown back; reflexible.","pos":""}],"REFLECTING":[{"def":"Throwing back light, heat, etc.","pos":""},{"def":"Given to reflection or serious consideration; reflective; contemplative; as, a reflecting mind.","pos":""}],"REFLECTINGLY":[{"def":"With reflection; also, with censure; reproachfully.","pos":""}],"REFLECTION":[{"def":"The transference of an excitement from one nerve fiber to another by means of the nerve cells, as in reflex action.","pos":""}],"REFLECTIVE":[{"def":"Reflexive; reciprocal.","pos":""}],"REFLECTOR":[{"def":"One who, or that which, reflects.","pos":""}],"REFLET":[{"def":"Luster; special brilliancy of surface; -- used esp.","pos":""}],"REFLEX":[{"def":"Of, pertaining to, or produced by, stimulus or excitation without the necessary intervention of consciousness.","pos":""}],"REFLEXED":[{"def":"Bent backward or outward.","pos":""}],"REFLEXIBILITY":[{"def":"The quality or capability of being reflexible; as, the reflexibility of the rays of light.","pos":""}],"REFLEXIBLE":[{"def":"Capable of being reflected, or thrown back.","pos":""}],"REFLEXION":[{"def":"Re*flex\"ion (-flk\"shn), n.","pos":""}],"REFLEXITY":[{"def":"The state or condition of being reflected.","pos":""}],"REFLEXIVE":[{"def":"Bending or turned backward; reflective; having respect to something past.","pos":""},{"def":"Having for its direct object a pronoun which refers to the agent or subject as its antecedent; -- said of certain verbs; as, the witness perjured himself; I bethought myself.","pos":""}],"REFLEXLY":[{"def":"In a reflex manner; reflectively.","pos":""}],"REFLORESCENCE":[{"def":"A blossoming anew of a plant after it has apparently ceased blossoming for the season.","pos":""}],"REFLOURISH":[{"def":"To flourish again.","pos":""}],"REFLOW":[{"def":"To flow back; to ebb.","pos":""}],"REFLOWER":[{"def":"To flower, or cause to flower, again.","pos":""}],"REFLUCTUATION":[{"def":"A flowing back; refluence.","pos":""},{"def":"The quality of being refluent; a flowing back.","pos":""}],"REFLUENT":[{"def":"Flowing back; returning; ebbing.","pos":""}],"REFLUX":[{"def":"Returning, or flowing back; reflex; as, reflux action.","pos":""}]}