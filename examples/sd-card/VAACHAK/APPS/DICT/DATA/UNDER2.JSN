{"UNDERPOSSESSOR":[{"def":"One who possesses or holds anything subject to the superior of another.","pos":""}],"UNDERPRAISE":[{"def":"To praise below desert.","pos":""}],"UNDERPRIZE":[{"def":"To undervalue; to underestimate.","pos":""}],"UNDERPRODUCTION":[{"def":"The production of less than is demanded or of less than the usual supply.","pos":""}],"UNDERPROOF":[{"def":"Containing less alcohol than proof spirit.","pos":""}],"UNDERPROP":[{"def":"To prop from beneath; to put a prop under; to support; to uphold.","pos":""}],"UNDERPROPORTIONED":[{"def":"Of inadequate or inferior proportions; small; poor.","pos":""}],"UNDERPROPPER":[{"def":"One who, or that which, underprops or supports.","pos":""}],"UNDERPULL":[{"def":"To exert one's influence secretly.","pos":""}],"UNDERPULLER":[{"def":"One who underpulls.","pos":""}],"UNDERPUT":[{"def":"To put or send under.","pos":""}],"UNDERRATE":[{"def":"To rate too low; to rate below the value; to undervalue.","pos":""}],"UNDERRECKON":[{"def":"To reckon below what is right or proper; to underrate.","pos":""}],"UNDERRUN":[{"def":"To run or pass under; especially (Naut.","pos":""}],"UNDERSAIL":[{"def":"To sail alongshore.","pos":""}],"UNDERSAILED":[{"def":"Inadequately equipped with sails.","pos":""}],"UNDERSATURATED":[{"def":"Not fully saturated; imperfectly saturated.","pos":""}],"UNDERSAY":[{"def":"To say by way of derogation or contradiction.","pos":""}],"UNDERSCORE":[{"def":"To draw a mark or line under; to underline.","pos":""}],"UNDERSECRETARY":[{"def":"A secretary who is subordinate to the chief secretary; an assistant secretary; as, an undersecretary of the Treasury.","pos":""}],"UNDERSELL":[{"def":"To sell the same articles at a lower price than; to sell cheaper than.","pos":""}],"UNDERSERVANT":[{"def":"An inferior servant.","pos":""}],"UNDERSET":[{"def":"To prop or support.","pos":""}],"UNDERSETTER":[{"def":"One who, or that which, undersets or supports; a prop; a support; a pedestal.","pos":""}],"UNDERSETTING":[{"def":"Something set or built under as a support; a pedestal.","pos":""}],"UNDERSHAPEN":[{"def":"Under the usual shape or size; small; dwarfish.","pos":""}],"UNDERSHERIFF":[{"def":"A sheriff's deputy.","pos":""}],"UNDERSHERIFFRY":[{"def":"Undershrievalty.","pos":""}],"UNDERSHIRT":[{"def":"A shirt worn next the skin, under another shirt; -- called also undervest.","pos":""}],"UNDERSHOOT":[{"def":"To shoot short of (a mark).","pos":""}],"UNDERSHOT":[{"def":"Having the lower incisor teeth projecting beyond the upper ones, as in the bulldog.","pos":""}],"UNDERSHRIEVALTY":[{"def":"The office or position of an undersheriff.","pos":""}],"UNDERSHRIEVE":[{"def":"A low shrub; a woody plant of low stature.","pos":""}],"UNDERSHRUB":[{"def":"Partly shrublike.","pos":""}],"UNDERSHUT":[{"def":"Closed from beneath.","pos":""}],"UNDERSIDE":[{"def":"The lower or lowest side of anything.","pos":""}],"UNDERSIGN":[{"def":"To write one's name at the foot or end of, as a letter or any legal instrument.","pos":""}],"UNDERSIZED":[{"def":"Of a size less than is common.","pos":""}],"UNDERSKIRT":[{"def":"A petticoat; the foundation skirt of a draped dress.","pos":""}],"UNDERSKY":[{"def":"The lower region of the sky.","pos":""}],"UNDERSLEEVE":[{"def":"A sleeve of an under-garment; a sleeve worn under another, UNDERSLUNG; UNDERHUNG Un\"der*slung`, Un\"der*hung\", a.","pos":""},{"def":"Of an automobile body, suspended from the springs in such a manner that the frame of the chassis is below the axles, the object being to lower the center of gravity of the car.","pos":""}],"UNDERSOIL":[{"def":"The soil beneath the surface; understratum; subsoil.","pos":""}],"UNDERSOLD":[{"def":"Un`der*sold\" Defn: p.","pos":""}],"UNDERSONG":[{"def":"The burden of a song; the chorus; the refrain.","pos":""},{"def":"Accompanying strain; subordinate and underlying meaning; accompaniment; undertone.","pos":""}],"UNDERSPARRED":[{"def":"Having spars smaller than the usual dimension; -- said of vessels.","pos":""}],"UNDERSPEND":[{"def":"To spend less than.","pos":""}],"UNDERSPHERE":[{"def":"A sphere which is smaller than, and in its movements subject to, another; a satellite.","pos":""},{"def":"An inferior sphere, or field of action.","pos":""}],"UNDERSPORE":[{"def":"To raise with a spar, or piece of wood, used as a lever.","pos":""}],"UNDERSTAIR":[{"def":"Of or pertaining to the kitchen, or the servants' quarters; hence, subordinate; menial.","pos":""}],"UNDERSTAIRS":[{"def":"The basement or cellar.","pos":""}],"UNDERSTAND":[{"def":"To be apprised, or have information, of; to learn; to be informed of; to hear; as, I understand that Congress has passed the bill.","pos":""}],"UNDERSTANDABLE":[{"def":"Capable of being understood; intelligible.","pos":""}],"UNDERSTANDER":[{"def":"One who understands, or knows by experience.","pos":""}],"UNDERSTANDING":[{"def":"Knowing; intelligent; skillful; as, he is an understanding man.","pos":""}],"UNDERSTANDINGLY":[{"def":"In an understanding manner; intelligibly; with full knowledge or comprehension; intelligently; as, to vote upon a question understandingly; to act or judge understandingly.","pos":""}],"UNDERSTATE":[{"def":"To state or represent less strongly than may be done truthfully.","pos":""}],"UNDERSTATEMENT":[{"def":"The act of understating, or the condition of being understated; that which is understated; a statement below the truth.","pos":""}],"UNDERSTOCK":[{"def":"To supply insufficiently with stock.","pos":""}],"UNDERSTOOD":[{"def":"Un`der*stood\", Defn: imp.","pos":""}],"UNDERSTRAPPER":[{"def":"A petty fellow; an inferior agent; an underling.","pos":""}],"UNDERSTRAPPING":[{"def":"Becoming an understrapper; subservient.","pos":""}],"UNDERSTRATUM":[{"def":"The layer, or stratum, of earth on which the mold, or soil, rests; subsoil.","pos":""}],"UNDERSTROKE":[{"def":"To underline or underscore.","pos":""}],"UNDERSTUDY":[{"def":"To study, as another actor's part, in order to be his substitute in an emergency; to study another actor's part.","pos":""}],"UNDERSUIT":[{"def":"A suit worn under another suit; a suit of underclothes.","pos":""}],"UNDERTAKABLE":[{"def":"Capable of being undertaken; practicable.","pos":""}],"UNDERTAKE":[{"def":"To take upon one's self; to engage in; to enter upon; to take in hand; to begin to perform; to set about; to attempt.","pos":""},{"def":"Specifically, to take upon one's self solemnly or expressly; to lay one's self under obligation, or to enter into stipulations, to perform or to execute; to covenant; to contract.","pos":""}],"UNDERTAKER":[{"def":"One who undertakes; one who engages in any project or business.","pos":""},{"def":"One who stipulates or covenants to perform any work for another; a contractor.","pos":""}],"UNDERTAKING":[{"def":"The act of one who undertakes, or engages in, any project or business.","pos":""},{"def":"That which is undertaken; any business, work, or project which a person engages in, or attempts to perform; an enterprise.","pos":""}],"UNDERTAPSTER":[{"def":"Assistant to a tapster.","pos":""}],"UNDERTAXED":[{"def":"Taxed too little, or at a lower rate than others.","pos":""}],"UNDERTENANCY":[{"def":"Tenancy or tenure under a tenant or lessee; the tenure of an undertenant.","pos":""}],"UNDERTENANT":[{"def":"The tenant of a tenant; one who holds lands or tenements of a tenant or lessee.","pos":""}],"UNDERTHING":[{"def":"Something that is inferior and of little worth.","pos":""},{"def":"The under or after part of the day; undermeal; evening.","pos":""}],"UNDERTONE":[{"def":"A low or subdued tone or utterance; a tone less loud than usual.","pos":""}],"UNDERTOOK":[{"def":"Un`der*took\", Defn: imp.","pos":""}],"UNDERTOW":[{"def":"The current that sets seaward near the bottom when waves are breaking upon the shore.","pos":""}],"UNDERTREASURER":[{"def":"An assistant treasurer.","pos":""}],"UNDERTURN":[{"def":"To turn upside down; to subvert; to upset.","pos":""}],"UNDERVALUATION":[{"def":"The act of undervaluing; a rate or value not equal to the real worth.","pos":""}],"UNDERVALUE":[{"def":"To value, rate, or estimate below the real worth; to depreciate.","pos":""},{"def":"To esteem lightly; to treat as of little worth; to hold in mean estimation; to despise.","pos":""}],"UNDERVALUER":[{"def":"One who undervalues.","pos":""}],"UNDERVERSE":[{"def":"The lower or second verse.","pos":""}],"UNDERVIEWER":[{"def":"See Underlooker.","pos":""}],"UNDERWEAR":[{"def":"That which is worn under the outside clothing; underclothes.","pos":""}],"UNDERWENT":[{"def":"Un`der*went\", Defn: imp.","pos":""}],"UNDERWING":[{"def":"One of the posterior wings of an insect.","pos":""},{"def":"Any one of numerous species of noctuid moths belonging to Catocala and allied genera, in which the hind wings are banded with red and black or other conspicuous colors.","pos":""}],"UNDERWITTED":[{"def":"Weak in intellect; half-witted; silly.","pos":""}],"UNDERWOOD":[{"def":"Small trees and bushes that grow among large trees; coppice; underbrush; -- formerly used in the plural.","pos":""}],"UNDERWORK":[{"def":"To injure by working secretly; to destroy or overthrow by clandestine measure; to undermine.","pos":""},{"def":"To expend too little work upon; as, to underwork a painting.","pos":""}],"UNDERWORKER":[{"def":"One who underworks.","pos":""},{"def":"An inferior or subordinate workman.","pos":""}],"UNDERWORLD":[{"def":"The lower of inferior world; the world which is under the heavens; the earth.","pos":""},{"def":"The mythological place of departed souls; Hades.","pos":""}],"UNDERWRITE":[{"def":"To write under something else; to subscribe.","pos":""}],"UNDERWRITER":[{"def":"One who underwrites his name to the conditions of an insurance policy, especially of a marine policy; an insurer.","pos":""}],"UNDERYOKE":[{"def":"To subject to the yoke; to make subject.","pos":""}]}