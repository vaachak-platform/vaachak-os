{"SHAM":[{"def":"That which deceives expectation; any trick, fraud, or device that deludes and disappoint; a make-believe; delusion; imposture, humbug.","pos":""},{"def":"A false front, or removable ornamental covering.","pos":""}],"SHAMA":[{"def":"A saxicoline singing bird (Kittacincla macroura) of India, noted for the sweetness and power of its song.","pos":""}],"SHAMAN":[{"def":"A priest of Shamanism; a wizard among the Shamanists.","pos":""}],"SHAMANIC":[{"def":"Of or pertaining to Shamanism.","pos":""}],"SHAMANISM":[{"def":"The type of religion which once prevalied among all the Ural- Altaic peoples (Tungusic, Mongol, and Turkish), and which still survives in various parts of Northern Asia.","pos":""}],"SHAMANIST":[{"def":"An adherent of Shamanism.","pos":""}],"SHAMBLE":[{"def":"One of a succession of niches or platforms, one above another, to hold ore which is thrown successively from platform to platform, and thus raised to a higher level.","pos":""},{"def":"A place where butcher's meat is sold.","pos":""}],"SHAMBLING":[{"def":"Characterized by an awkward, irregular pace; as, a shambling trot; shambling legs.","pos":""}],"SHAME":[{"def":"A painful sensation excited by a consciousness of guilt or impropriety, or of having done something which injures reputation, or of the exposure of that which nature or modesty prompts us to conceal.","pos":""},{"def":"Reproach incurred or suffered; dishonor; ignominy; derision; contempt.","pos":""}],"SHAMEFACED":[{"def":"Easily confused or put out of countenance; diffident; bashful; modest.","pos":""}],"SHAMEFAST":[{"def":"Modest; shamefaced.","pos":""}],"SHAMEFUL":[{"def":"Bringing shame or disgrace; injurious to reputation; disgraceful.","pos":""},{"def":"Exciting the feeling of shame in others; indecent; as, a shameful picture; a shameful sight.","pos":""}],"SHAMELESS":[{"def":"Destitute of shame; wanting modesty; brazen-faced; insensible to disgrace.","pos":""},{"def":"Indicating want of modesty, or sensibility to disgrace; indecent; as, a shameless picture or poem.","pos":""}],"SHAMER":[{"def":"One who, or that which, disgraces, or makes ashamed.","pos":""}],"SHAMMER":[{"def":"One who shams; an impostor.","pos":""}],"SHAMMY":[{"def":"A soft, pliant leather, prepared originally from the skin of the chamois, but now made also from the skin of the sheep, goat, kid, deer, and calf.","pos":""}],"SHAMOYING":[{"def":"A process used in preparing certain kinds of leather, which consists in frizzing the skin, and working oil into it to supply the place of the astringent (tannin, alum, or the like) ordinarily used in tanning.","pos":""}],"SHAMPOO":[{"def":"To press or knead the whole surface of the body of (a person), and at the same time to stretch the limbs and joints, in connection with the hot bath.","pos":""},{"def":"To wash throughly and rub the head of (a person), with the fingers, using either soap, or a soapy preparation, for the more thorough cleansing.","pos":""}],"SHAMPOOER":[{"def":"One who shampoos.","pos":""}],"SHAMROCK":[{"def":"A trifoliate plant used as a national emblem by the Irish.","pos":""}]}