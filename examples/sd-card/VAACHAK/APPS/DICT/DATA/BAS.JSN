{"BAS-RELIEF":[{"def":"Low relief; sculpture, the figures of which project less than half of their true proportions; -- called also bassrelief and basso- rilievo.","pos":""}],"BASAL":[{"def":"Relating to, or forming, the base.","pos":""}],"BASAL-NERVED":[{"def":"Having the nerves radiating from the base; -- said of leaves.","pos":""}],"BASALT":[{"def":"A rock of igneous origin, consisting of augite and triclinic feldspar, with grains of magnetic or titanic iron, and also bottle- green particles of olivine frequently disseminated.","pos":""}],"BASALTIC":[{"def":"Pertaining to basalt; formed of, or containing, basalt; as basaltic lava.","pos":""}],"BASALTIFORM":[{"def":"In the form of basalt; columnar.","pos":""}],"BASALTOID":[{"def":"Formed like basalt; basaltiform.","pos":""}],"BASAN":[{"def":"Same as Basil, a sheepskin.","pos":""}],"BASANITE":[{"def":"Lydian stone, or black jasper, a variety of siliceous or flinty slate, of a grayish or bluish black color.","pos":""}],"BASBLEU":[{"def":"A bluestocking; a literary woman.","pos":""}],"BASCINET":[{"def":"A light helmet, at first open, but later made with a visor.","pos":""}],"BASCULE":[{"def":"In mechanics an apparatus on the principle of the seesaw, in which one end rises as the other falls.","pos":""}],"BASE":[{"def":"Not held by honorable service; as, a base estate, one held by services not honorable; held by villenage.","pos":""}],"BASE-BURNER":[{"def":"A furnace or stove in which the fuel is contained in a hopper or chamber, and is fed to the fire as the lower stratum is consumed.","pos":""}],"BASE-COURT":[{"def":"An inferior court of law, not of record.","pos":""}],"BASEBALL":[{"def":"A game of ball, so called from the bases or bounds ( four in number) which designate the circuit which each player must endeavor to make after striking the ball.","pos":""},{"def":"The ball used in this game.","pos":""}],"BASEBOARD":[{"def":"A board, or other woodwork, carried round the walls of a room and touching the floor, to form a base and protect the plastering; -- also called washboard (in England), mopboard, and scrubboard.","pos":""}],"BASEBORN":[{"def":"Born out of wedlock.","pos":""},{"def":"Born of low parentage.","pos":""}],"BASED":[{"def":"Wearing, or protected by, bases.","pos":""}],"BASEDOW'S DISEASE":[{"def":"A disease characterized by enlargement of the thyroid gland, prominence of the eyeballs, and inordinate action of the heart; -- called also exophthalmic goiter.","pos":""}],"BASELARD":[{"def":"A short sword or dagger, worn in the fifteenth century.","pos":""}],"BASELESS":[{"def":"Without a base; having no foundation or support.","pos":""}],"BASELY":[{"def":"In a base manner; with despicable meanness; dishonorably; shamefully.","pos":""},{"def":"Illegitimately; in bastardy.","pos":""}],"BASEMENT":[{"def":"The outer wall of the ground story of a building, or of a part of that story, when treated as a distinct substructure.","pos":""}],"BASENESS":[{"def":"The quality or condition of being base; degradation; vileness.","pos":""}],"BASH":[{"def":"To abash; to disconcert or be disconcerted or put out of countenance.","pos":""}],"BASHAW":[{"def":"A very large siluroid fish (Leptops olivaris) of the Mississippi valley; -- also called goujon, mud cat, and yellow cat.","pos":""}],"BASHFUL":[{"def":"Abashed; daunted; dismayed.","pos":""},{"def":"Very modest, or modest excess; constitutionally disposed to shrink from public notice; indicating extreme or excessive modesty; shy; as, a bashful person, action, expression.","pos":""}],"BASHFULLY":[{"def":"In a bashful manner.","pos":""}],"BASHFULNESS":[{"def":"The quality of being bashful.","pos":""}],"BASHI-BAZOUK":[{"def":"A soldier belonging to the irregular troops of the Turkish army.","pos":""}],"BASHLESS":[{"def":"Shameless; unblushing.","pos":""}],"BASIC":[{"def":"Said of crystalline rocks which contain a relatively low percentage of silica, as basalt.","pos":""}],"BASIC PROCESS":[{"def":"A Bessemer or open-hearth steel-making process in which a lining that is basic, or not siliceous, is used, and additions of basic material are made to the molten charge during treatment.","pos":""}],"BASIC SLAG":[{"def":"A by-product from the manufacture of steel by the basic process, used as a fertilizer.","pos":""}],"BASIC STEEL":[{"def":"Steel produced by the basic process.","pos":""}],"BASICERITE":[{"def":"The second joint of the antennæ of crustaceans.","pos":""}],"BASIDIOMYCETES":[{"def":"A large subdivision of fungi coördinate with the Ascomycetes, characterized by having the spores borne on a basidium.","pos":""}],"BASIDIOSPORE":[{"def":"A spore borne by a basidium.","pos":""}],"BASIDIUM":[{"def":"A special oblong or pyriform cell, with slender branches, which bears the spores in that division of fungi called Basidiomycetes, of which the common mushroom is an example.","pos":""}],"BASIFIER":[{"def":"That which converts into a salifiable base.","pos":""}],"BASIFUGAL":[{"def":"Tending or proceeding away from the base; as, a basifugal growth.","pos":""}],"BASIFY":[{"def":"To convert into a salifiable base.","pos":""}],"BASIGYNIUM":[{"def":"The pedicel on which the ovary of certain flowers, as the passion flower, is seated; a carpophore or thecaphore.","pos":""}],"BASIHYAL":[{"def":"Noting two small bones, forming the body of the inverted hyoid arch.","pos":""}],"BASIHYOID":[{"def":"The central tongue bone.","pos":""}],"BASIL":[{"def":"The slope or angle to which the cutting edge of a tool, as a plane, is ground.","pos":""}],"BASILIC":[{"def":"Pertaining to certain parts, anciently supposed to have a specially important function in the animal economy, as the middle vein of the right arm.","pos":""}],"BASILICA":[{"def":"Originally, the place of a king; but afterward, an apartment provided in the houses of persons of importance, where assemblies were held for dispensing justice; and hence, any large hall used for this purpose.","pos":""}],"BASILICAN":[{"def":"Of, relating to, or resembling, a basilica; basilical.","pos":""}],"BASILICON":[{"def":"An ointment composed of wax, pitch, resin, and olive oil, lard, or other fatty substance.","pos":""}],"BASILISK":[{"def":"A lizard of the genus Basiliscus, belonging to the family Iguanidæ.","pos":""},{"def":"A large piece of ordnance, so called from its supposed resemblance to the serpent of that name, or from its size.","pos":""}],"BASIN":[{"def":"An isolated or circumscribed formation, particularly where the strata dip inward, on all sides, toward a center; -- especially applied to the coal formations, called coal basins or coal fields.","pos":""}],"BASINED":[{"def":"Inclosed in a basin.","pos":""}],"BASINET":[{"def":"Same as Bascinet.","pos":""}],"BASIOCCIPITAL":[{"def":"Of or pertaining to the bone in the base of the cranium, frequently forming a part of the occipital in the adult, but usually distinct in the young.","pos":""},{"def":"The basioccipital bone.","pos":""}],"BASION":[{"def":"The middle of the anterior margin of the great foramen of the skull.","pos":""}],"BASIPODITE":[{"def":"The basal joint of the legs of Crustacea.","pos":""}],"BASIPTERYGIUM":[{"def":"A bar of cartilage at the base of the embryonic fins of some fishes.","pos":""}],"BASIPTERYGOID":[{"def":"Applied to a protuberance of the base of the sphenoid bone.","pos":""}],"BASIS":[{"def":"The foundation of anything; that on which a thing rests.","pos":""},{"def":"The pedestal of a column, pillar, or statue.","pos":""}],"BASISOLUTE":[{"def":"Prolonged at the base, as certain leaves.","pos":""},{"def":"Of or pertaining to that part of the base of the cranium between the basioccipital and the presphenoid, which usually ossifies separately in the embryo or in the young, and becomes a part of the sphenoid in the adult.","pos":""}],"BASISPHENOID":[{"def":"The basisphenoid bone.","pos":""}],"BASK":[{"def":"To lie in warmth; to be exposed to genial heat.","pos":""}],"BASKET":[{"def":"The bell or vase of the Corinthian capital.","pos":""}],"BASKET BALL":[{"def":"A game, usually played indoors, in which two parties of players contest with each other to toss a large inflated ball into opposite goals resembling baskets.","pos":""}],"BASKETFUL":[{"def":"As much as a basket will contain.","pos":""}],"BASKETRY":[{"def":"The art of making baskets; also, baskets, taken collectively.","pos":""}],"BASKING SHARK":[{"def":"One of the largest species of sharks (Cetorhinus maximus), so called from its habit of basking in the sun; the liver shark, or bone shark.","pos":""}],"BASNET":[{"def":"Same as Bascinet.","pos":""}],"BASOMMATOPHORA":[{"def":"A group of Pulmonifera having the eyes at the base of the tentacles, including the common pond snails.","pos":""}],"BASQUE":[{"def":"Pertaining to Biscay, its people, or their language.","pos":""}],"BASQUISH":[{"def":"Pertaining to the country, people, or language of Biscay; Basque [Obs.","pos":""}],"BASS":[{"def":"An edible, spiny-finned fish, esp.","pos":""},{"def":"The two American fresh-water species of black bass (genus Micropterus).","pos":""}],"BASS DRUM":[{"def":"The largest of the different kinds of drums, having two heads, and emitting a deep, grave sound.","pos":""}],"BASS HORN":[{"def":"A modification of the bassoon, much deeper in tone.","pos":""}],"BASS VIOL":[{"def":"A stringed instrument of the viol family, used for playing bass.","pos":""}],"BASS-RELIEF":[{"def":"Some as Bas-relief.","pos":""}],"BASSET":[{"def":"A game at cards, resembling the modern faro, said to have been invented at Venice.","pos":""}],"BASSET HORN":[{"def":"An instrument blown with a reed, and resembling a clarinet, but of much greater compass, embracing nearly four octaves.","pos":""}],"BASSET HOUND":[{"def":"A small kind of hound with a long body and short legs, used as an earth dog.","pos":""}],"BASSETING":[{"def":"The upward direction of a vein in a mine; the emergence of a stratum at the surface.","pos":""}],"BASSETTO":[{"def":"A tenor or small bass viol.","pos":""}],"BASSINET":[{"def":"A wicker basket, with a covering or hood over one end, in which young children are placed as in a cradle.","pos":""}],"BASSOON":[{"def":"A wind instrument of the double reed kind, furnished with holes, which are stopped by the fingers, and by keys, as in flutes.","pos":""}],"BASSOONIST":[{"def":"A performer on the bassoon.","pos":""},{"def":"Same as Bas-relief.","pos":""}],"BASSORIN":[{"def":"A constituent part of a species of gum from Bassora, as also of gum tragacanth and some gum resins.","pos":""}],"BASSWOOD":[{"def":"The bass (Tilia) or its wood; especially, T.","pos":""}],"BAST":[{"def":"The inner fibrous bark of various plants; esp.","pos":""},{"def":"A thick mat or hassock.","pos":""}],"BASTARD":[{"def":"A \"natural\" child; a child begotten and born out of wedlock; an illegitimate child; one born of an illicit union.","pos":""},{"def":"A sweet Spanish wine like muscadel in flavor.","pos":""}],"BASTARDISM":[{"def":"The state of being a bastard; bastardy.","pos":""}],"BASTARDIZE":[{"def":"To make or prove to be a bastard; to stigmatize as a bastard; to declare or decide legally to be illegitimate.","pos":""},{"def":"To beget out of wedlock.","pos":""}],"BASTARDLY":[{"def":"Bastardlike; baseborn; spuripous; corrupt.","pos":""},{"def":"In the manner of a bastard; spuriously.","pos":""}],"BASTARDY":[{"def":"The state of being a bastard; illegitimacy.","pos":""},{"def":"The procreation of a bastard child.","pos":""}],"BASTE":[{"def":"To sprinkle flour and salt and drip butter or fat on, as on meat in roasting.","pos":""}],"BASTINADE":[{"def":"See Bastinado, n.","pos":""}],"BASTINADO":[{"def":"A blow with a stick or cudgel.","pos":""},{"def":"A sound beating with a stick or cudgel.","pos":""}],"BASTION":[{"def":"A work projecting outward from the main inclosure of a fortification, consisting of two faces and two flanks, and so constructed that it is able to defend by a flanking fire the adjacent curtain, or wall which extends from one bastion to another.","pos":""}],"BASTIONED":[{"def":"Furnished with a bastion; having bastions.","pos":""}],"BASTO":[{"def":"The ace of clubs in qua Pope.","pos":""}],"BASTON":[{"def":"A staff or cudgel.","pos":""},{"def":"An officer bearing a painted staff, who formerly was in attendance upon the king's court to take into custody persons committed by the court.","pos":""}],"BASUTOS":[{"def":"A warlike South African people of the Bantu stock, divided into many tribes, subject to the English.","pos":""}],"BASYLE":[{"def":"A positive or nonacid constituent of compound, either elementary, or, if compound, performing the functions of an element.","pos":""}],"BASYLOUS":[{"def":"Pertaining to, or having the nature of, a basyle; electro- positive; basic; -- opposed to chlorous.","pos":""}]}