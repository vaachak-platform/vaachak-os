{"SORA":[{"def":"A North American rail (Porzana Carolina) common in the Eastern United States.","pos":""}],"SORBATE":[{"def":"A salt of sorbic acid.","pos":""}],"SORBEFACIENT":[{"def":"Producing absorption.","pos":""},{"def":"A medicine or substance which produces absorption.","pos":""}],"SORBET":[{"def":"A kind of beverage; sherbet.","pos":""}],"SORBILE":[{"def":"Fit to be drunk or sipped.","pos":""}],"SORBIN":[{"def":"An unfermentable sugar, isomeric with glucose, found in the ripe berries of the rowan tree, or sorb, and extracted as a sweet white crystalline substance; -- called also mountain-ash sugar.","pos":""}],"SORBITE":[{"def":"A sugarlike substance, isomeric with mannite and dulcite, found with sorbin in the ripe berries of the sorb, and extracted as a sirup or a white crystalline substance.","pos":""}],"SORBITION":[{"def":"The act of drinking or sipping.","pos":""}],"SORBONICAL":[{"def":"Belonging to the Sorbonne or to a Sorbonist.","pos":""}],"SORBONIST":[{"def":"A doctor of the Sorbonne, or theological college, in the University of Paris, founded by Robert de Sorbon, a.","pos":""}],"SORCERER":[{"def":"A conjurer; an enchanter; a magician.","pos":""}],"SORCERESS":[{"def":"A female sorcerer.","pos":""}],"SORCERING":[{"def":"Act or practice of using sorcery.","pos":""}],"SORCEROUS":[{"def":"Of or pertaining to sorcery.","pos":""}],"SORCERY":[{"def":"Divination by the assistance, or supposed assistance, of evil spirits, or the power of commanding evil spirits; magic; necromancy; witchcraft; enchantment.","pos":""}],"SORDES":[{"def":"Foul matter; excretion; dregs; filthy, useless, or rejected matter of any kind; specifically (Med.","pos":""}],"SORDID":[{"def":"Filthy; foul; dirty.","pos":""},{"def":"Vile; base; gross; mean; as, vulgar, sordid mortals.","pos":""}],"SORDIDLY":[{"def":"In a sordid manner.","pos":""}],"SORDIDNESS":[{"def":"The quality or state of being sordid.","pos":""}],"SORDINE":[{"def":"See Damper, and 5th Mute.","pos":""}],"SORE":[{"def":"Reddish brown; sorrel.","pos":""}],"SOREDIATE":[{"def":"Bearing soredia; sorediate.","pos":""}],"SOREDIUM":[{"def":"A patch of granular bodies on the surface of the thallus of lichens.","pos":""}],"SOREHEAD":[{"def":"One who is disgruntled by a failure in politics, or the like.","pos":""}],"SOREHON":[{"def":"Formerly, in Ireland, a kind of servile tenure which subjected the tenant to maintain his chieftain gratuitously whenever he wished to indulge in a revel.","pos":""}],"SOREL":[{"def":"A young buck in the third year.","pos":""}],"SORELY":[{"def":"In a sore manner; grievously; painfully; as, to be sorely afflicted.","pos":""}],"SOREMA":[{"def":"A heap of carpels belonging to one flower.","pos":""}],"SORENESS":[{"def":"The quality or state of being sore; tenderness; painfull; as, the soreness of a wound; the soreness of an affliction.","pos":""}],"SOREX":[{"def":"A genus of small Insectivora, including the common shrews.","pos":""}],"SORGHE":[{"def":"The three-beared rocking, or whistlefish.","pos":""}],"SORGHUM":[{"def":"Halepense, the Arabian millet, or Johnson grass (see Johnson grass), and S.","pos":""}],"SORGO":[{"def":"Indian millet and its varieties.","pos":""}],"SORICINE":[{"def":"Of or pertaining to the Shrew family (Soricidæ); like a shrew in form or habits; as, the soricine bat (Glossophaga soricina).","pos":""}],"SORITES":[{"def":"The soul is a thinking agent; A thinking agent can not be severed into parts; That which can not be severed can not be destroyed; Therefore the soul can not be destroyed.","pos":""}],"SORITICAL":[{"def":"Of or pertaining to a sorites; resembling a sorites.","pos":""}],"SORN":[{"def":"To obtrude one's self on another for bed and board.","pos":""}],"SORNER":[{"def":"One who obtrudes himself on another for bed and board.","pos":""}],"SORORAL":[{"def":"Relating to a sister; sisterly.","pos":""}],"SORORICIDE":[{"def":"The murder of one's sister; also, one who murders or kills one's own sister.","pos":""}],"SORORIZE":[{"def":"To associate, or hold fellowship, as sisters; to have sisterly feelings; -- analogous to fraternize.","pos":""}],"SOROSIS":[{"def":"A woman's club; an association of women.","pos":""}],"SORRAGE":[{"def":"The blades of green or barley.","pos":""}],"SORRANCE":[{"def":"Same as Sorance.","pos":""}],"SORREL":[{"def":"Of a yellowish or redish brown color; as, a sorrel horse.","pos":""}],"SORRENTO WORK":[{"def":"Ornamental work, mostly carved in olivewood, decorated with inlay, made at or near Sorrento, Italy.","pos":""}],"SORRILY":[{"def":"In a sorry manner; poorly.","pos":""}],"SORRINESS":[{"def":"The quality or state of being sorry.","pos":""}],"SORROW":[{"def":"The uneasiness or pain of mind which is produced by the loss of any good, real or supposed, or by diseappointment in the expectation of good; grief at having suffered or occasioned evil; regret; unhappiness; sadness.","pos":""}],"SORROWED":[{"def":"Accompanied with sorrow; sorrowful.","pos":""}],"SORROWFUL":[{"def":"Full of sorrow; exhibiting sorrow; sad; dejected; distressed.","pos":""},{"def":"Producing sorrow; exciting grief; mournful; lamentable; grievous; as, a sorrowful accident.","pos":""}],"SORROWLESS":[{"def":"Free from sorrow.","pos":""}],"SORRY":[{"def":"Grieved for the loss of some good; pained for some evil; feeling regret; -- now generally used to express light grief or affliction, but formerly often used to express deeper feeling.","pos":""},{"def":"Melancholy; dismal; gloomy; mournful.","pos":""}],"SORS":[{"def":"A lot; also, a kind of divination by means of lots.","pos":""}],"SORT":[{"def":"Chance; lot; destiny.","pos":""}],"SORTABLE":[{"def":"Capable of being sorted.","pos":""},{"def":"Suitable; befitting; proper.","pos":""}],"SORTAL":[{"def":"Pertaining to a sort.","pos":""}],"SORTANCE":[{"def":"Suitableness; agreement.","pos":""}],"SORTER":[{"def":"One who, or that which, sorts.","pos":""}],"SORTIE":[{"def":"The sudden issuing of a body of troops, usually small, from a besieged place to attack or harass the besiegers; a sally.","pos":""}],"SORTILEGE":[{"def":"The act or practice of drawing lots; divination by drawing lots.","pos":""}],"SORTILEGIOUS":[{"def":"Pertaining to sortilege.","pos":""}],"SORTITA":[{"def":"The air sung by any of the principal characters in an opera on entering.","pos":""},{"def":"A closing voluntary; a postlude.","pos":""}],"SORTITION":[{"def":"Selection or appointment by lot.","pos":""}],"SORUS":[{"def":"One of the fruit dots, or small clusters of sporangia, on the back of the fronds of ferns.","pos":""}],"SORY":[{"def":"Green vitriol, or some earth imregnated with it.","pos":""}]}