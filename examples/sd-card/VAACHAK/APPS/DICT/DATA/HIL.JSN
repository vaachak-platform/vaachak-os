{"HILAL":[{"def":"Of or pertaining to a hilum.","pos":""}],"HILAR":[{"def":"Belonging to the hilum.","pos":""}],"HILARIOUS":[{"def":"Mirthful; noisy; merry.","pos":""}],"HILARITY":[{"def":"Boisterous mirth; merriment; jollity.","pos":""}],"HILARY TERM":[{"def":"Formerly, one of the four terms of the courts of common law in England, beginning on the eleventh of January and ending on the thirty-first of the same month, in each year; -- so called from the festival of St.","pos":""}],"HILDING":[{"def":"A base, menial wretch.","pos":""},{"def":"Base; spiritless.","pos":""}],"HILL":[{"def":"A natural elevation of land, or a mass of earth rising above the common level of the surrounding land; an eminence less than a mountain.","pos":""},{"def":"The earth raised about the roots of a plant or cluster of plants.","pos":""}],"HILLINESS":[{"def":"The state of being hilly.","pos":""}],"HILLING":[{"def":"The act or process of heaping or drawing earth around plants.","pos":""}],"HILLSIDE":[{"def":"The side or declivity of a hill.","pos":""}],"HILLTOP":[{"def":"The top of a hill.","pos":""}],"HILLY":[{"def":"Abounding with hills; uneven in surface; as, a hilly country.","pos":""},{"def":"Lofty; as, hilly empire.","pos":""}],"HILT":[{"def":"A handle; especially, the handle of a sword, dagger, or the like.","pos":""}],"HILTED":[{"def":"Having a hilt; -- used in composition; as, basket-hilted, cross-hilted.","pos":""}],"HILUM":[{"def":"The eye of a bean or other seed; the mark or scar at the point of attachment of an ovule or seed to its base or support; -- called also hile.","pos":""},{"def":"The part of a gland, or similar organ, where the blood vessels and nerves enter; the hilus; as, the hilum of the kidney.","pos":""}],"HILUS":[{"def":"Same as Hilum, 2.","pos":""}]}