{"FREAK":[{"def":"To variegate; to checker; to streak.","pos":""}],"FREAKISH":[{"def":"Apt to change the mind suddenly; whimsical; capricious.","pos":""}],"FRECK":[{"def":"To checker; to diversify.","pos":""}],"FRECKLE":[{"def":"A small yellowish or brownish spot in the skin, particularly on the face, neck, or hands.","pos":""},{"def":"Any small spot or discoloration.","pos":""}],"FRECKLED":[{"def":"Marked with freckles; spotted.","pos":""}],"FRECKLEDNESS":[{"def":"The state of being freckled.","pos":""}],"FRECKLY":[{"def":"Full of or marked with freckles; sprinkled with spots; freckled.","pos":""}],"FRED":[{"def":"Peace; -- a word used in composition, especially in proper names; as, Alfred; Frederic.","pos":""}],"FREE":[{"def":"Certain or honorable; the opposite of base; as, free service; free socage.","pos":""},{"def":"Privileged or individual; the opposite of common; as, a free fishery; a free warren.","pos":""}],"FREE COINAGE":[{"def":"In the fullest sense, the conversion of bullion (of any specified metal) into legal-tender coins for any person who chooses to bring it to the mint; in a modified sense, such coinage when done at a fixed charge proportionate to the cost of the operation.","pos":""}],"FREE SILVER":[{"def":"The free coinage of silver; often, specif.","pos":""}],"FREE WILL":[{"def":"A will free from improper coercion or restraint.","pos":""},{"def":"The power asserted of moral beings of willing or choosing without the restraints of physical or absolute necessity.","pos":""}],"FREE-HAND":[{"def":"Done by the hand, without support, or the guidance of instruments; as, free-hand drawing.","pos":""}],"FREE-HANDED":[{"def":"Open-handed; liberal.","pos":""}],"FREE-HEARTED":[{"def":"Open; frank; unreserved; liberal; generous; as, free-hearted mirth.","pos":""}],"FREE-LIVER":[{"def":"One who gratifies his appetites without stint; one given to indulgence in eating and drinking.","pos":""}],"FREE-LIVING":[{"def":"Unrestrained indulgence of the appetites.","pos":""}],"FREE-LOVE":[{"def":"The doctrine or practice of consorting with the opposite sex, at pleasure, without marriage.","pos":""}],"FREE-LOVER":[{"def":"One who believes in or practices free-love.","pos":""}],"FREE-MARTIN":[{"def":"An imperfect female calf, twinborn with a male.","pos":""}],"FREE-MILLING":[{"def":"Yielding free gold or silver; -- said of certain ores which can be reduced by crushing and amalgamation, without roasting or other chemical treatment.","pos":""}],"FREE-MINDED":[{"def":"Not perplexed; having a mind free from care.","pos":""}],"FREE-SOIL":[{"def":"Pertaining to, or advocating, the non-extension of slavery; -- esp.","pos":""}],"FREE-SPOKEN":[{"def":"Accustomed to speak without reserve.","pos":""}],"FREE-SWIMMING":[{"def":"Swimming in the open sea; -- said of certain marine animals.","pos":""}],"FREE-TONGUED":[{"def":"Speaking without reserve.","pos":""}],"FREEBOOTER":[{"def":"One who plunders or pillages without the authority of national warfare; a member of a predatory band; a pillager; a buccaneer; a sea robber.","pos":""}],"FREEBOOTERY":[{"def":"The act, practice, or gains of a freebooter; freebooting.","pos":""}],"FREEBOOTING":[{"def":"Robbery; plunder; a pillaging.","pos":""}],"FREEBORN":[{"def":"Born free; not born in vasssalage; inheriting freedom.","pos":""}],"FREEDMAN":[{"def":"A man who has been a slave, and has been set free.","pos":""}],"FREEDOM":[{"def":"The state of being free; exemption from the power and control of another; liberty; independence.","pos":""},{"def":"Privileges; franchises; immunities.","pos":""}],"FREEHOLD":[{"def":"An estate in real property, of inheritance (in fee simple or fee tail) or for life; or the tenure by which such estate is held.","pos":""}],"FREEHOLDER":[{"def":"The possessor of a freehold.","pos":""}],"FREELY":[{"def":"In a free manner; without restraint or compulsion; abundantly; gratuitously.","pos":""}],"FREEMAN":[{"def":"One who enjoys liberty, or who is not subject to the will of another; one not a slave or vassal.","pos":""},{"def":"A member of a corporation, company, or city, possessing certain privileges; a member of a borough, town, or State, who has the right to vote at elections.","pos":""}],"FREEMASON":[{"def":"One of an ancient and secret association or fraternity, said to have been at first composed of masons or builders in stone, but now consisting of persons who are united for social enjoyment and mutual assistance.","pos":""}],"FREEMASONIC":[{"def":"Pertaining to, or resembling, the institutions or the practices of freemasons; as, a freemasonic signal.","pos":""}],"FREEMASONRY":[{"def":"The institutions or the practices of freemasons.","pos":""}],"FREENESS":[{"def":"The state or quality of being free; freedom; liberty; openness; liberality; gratuitousness.","pos":""}],"FREER":[{"def":"One who frees, or sets free.","pos":""}],"FREESTONE":[{"def":"A stone composed of sand or grit; -- so called because it is easily cut or wrought.","pos":""}],"FREETHINKER":[{"def":"One who speculates or forms opinions independently of the authority of others; esp.","pos":""}],"FREETHINKING":[{"def":"Undue boldness of speculation; unbelief.","pos":""},{"def":"Exhibiting undue boldness of speculation; skeptical.","pos":""}],"FREEWHEEL":[{"def":"A clutch fitted in the rear hub of a cycle, which engages the rear sprocket with the rear wheel when the pedals are rotated forwards, but permits the rear wheel to run on free from the rear sprocket when the pedals are stopped or rotated backwards.","pos":""}],"FREEWILL":[{"def":"Of or pertaining to free will; voluntary; spontaneous; as, a freewill offering.","pos":""}],"FREEZABLE":[{"def":"Capable of being frozen.","pos":""}],"FREEZE":[{"def":"To become congealed by cold; to be changed from a liquid to a solid state by the abstraction of heat; to be hardened into ice or a like solid body.","pos":""},{"def":"To become chilled with cold, or as with cold; to suffer loss of animation or life by lack of heat; as, the blood freezes in the veins.","pos":""}],"FREEZER":[{"def":"One who, or that which, cools or freezes, as a refrigerator, or the tub and can used in the process of freezing ice cream.","pos":""}],"FREEZING":[{"def":"Tending to freeze; for freezing; hence, cold or distant in manner.","pos":""}],"FREIESLEBENITE":[{"def":"A sulphide of antimony, lead, and silver, occuring in monoclinic crystals.","pos":""}],"FREIGHT":[{"def":"That with which anything in fraught or laden for transportation; lading; cargo, especially of a ship, or a car on a railroad, etc.","pos":""},{"def":"Freight transportation, or freight line.","pos":""}],"FREIGHTAGE":[{"def":"Charge for transportation; expense of carriage.","pos":""},{"def":"The transportation of freight.","pos":""}],"FREIGHTER":[{"def":"One who loads a ship, or one who charters and loads a ship.","pos":""},{"def":"One employed in receiving and forwarding freight.","pos":""}],"FREIGHTLESS":[{"def":"Destitute of freight.","pos":""}],"FREIHERR":[{"def":"In Germany and Austria, a baron.","pos":""}],"FRELTE":[{"def":"Strange; foreign.","pos":""}],"FREMESCENT":[{"def":"Becoming murmurous, roaring.","pos":""}],"FREMITUS":[{"def":"Palpable vibration or thrill; as, the rhonchial fremitus.","pos":""}],"FRENCH":[{"def":"Of or pertaining to France or its inhabitants.","pos":""}],"FRENCHIFY":[{"def":"To make French; to infect or imbue with the manners or tastes of the French; to Gallicize.","pos":""}],"FRENCHISM":[{"def":"A French mode or characteristic; an idiom peculiar to the French language.","pos":""}],"FRENCHMAN":[{"def":"A native or one of the people of France.","pos":""}],"FRENETIC":[{"def":"Distracted; mad; frantic; phrenetic.","pos":""}],"FRENETICAL":[{"def":"Frenetic; frantic; frenzied.","pos":""}],"FRENUM":[{"def":"A cheek stripe of color.","pos":""}],"FRENZIED":[{"def":"Affected with frenzy; frantic; maddened.","pos":""}],"FRENZY":[{"def":"Any violent agitation of the mind approaching to distraction; violent and temporary derangement of the mental faculties; madness; rage.","pos":""}],"FREQUENCE":[{"def":"A crowd; a throng; a concourse.","pos":""},{"def":"Frequency; abundance.","pos":""}],"FREQUENCY":[{"def":"The condition of returning frequently; occurrence often repeated; common occurence; as, the frequency of crimes; the frequency of miracles.","pos":""},{"def":"A crowd; a throng.","pos":""}],"FREQUENT":[{"def":"Often to be met with; happening at short intervals; often repeated or occurring; as, frequent visits.","pos":""},{"def":"Addicted to any course of conduct; inclined to indulge in any practice; habitual; persistent.","pos":""}],"FREQUENTAGE":[{"def":"The practice or habit of frequenting.","pos":""}],"FREQUENTATION":[{"def":"The act or habit of frequenting or visiting often; resort.","pos":""}],"FREQUENTATIVE":[{"def":"Serving to express the frequent repetition of an action; as, a frequentative verb.","pos":""},{"def":"A frequentative verb.","pos":""}],"FREQUENTER":[{"def":"One who frequents; one who often visits, or resorts to customarily.","pos":""}],"FREQUENTLY":[{"def":"At frequent or short intervals; many times; often; repeatedly; commonly.","pos":""}],"FREQUENTNESS":[{"def":"The quality of being frequent.","pos":""}],"FRESCADE":[{"def":"A cool walk; shady place.","pos":""}],"FRESCO":[{"def":"A cool, refreshing state of the air; duskiness; coolness; shade.","pos":""}],"FRESH":[{"def":"Possessed of original life and vigor; new and strong; unimpaired; sound.","pos":""},{"def":"New; original; additional.","pos":""}],"FRESH-WATER":[{"def":"A lantern having a lamp surrounded by a hollow cylindrical Fresnel lens.","pos":""}],"FRESHEN":[{"def":"To relieve, as a rope, by change of place where friction wears it; or to renew, as the material used to prevent chafing; as, to freshen a hawse.","pos":""}],"FRESHET":[{"def":"A stream of fresh water.","pos":""},{"def":"A flood or overflowing of a stream caused by heavy rains or melted snow; a sudden inundation.","pos":""}],"FRESHLY":[{"def":"In a fresh manner; vigorously; newly, recently; brightly; briskly; coolly; as, freshly gathered; freshly painted; the wind blows freshly.","pos":""}],"FRESHMAN":[{"def":"novice; one in the rudiments of knowledge; especially, a student during his fist year in a college or university.","pos":""}],"FRESHMANSHIP":[{"def":"The state of being a freshman.","pos":""}],"FRESHNESS":[{"def":"The state of being fresh.","pos":""}],"FRET":[{"def":"To rub; to wear away by friction; to chafe; to gall; hence, to eat away; to gnaw; as, to fret cloth; to fret a piece of gold or other metal; a worm frets the plants of a ship.","pos":""}],"FRETFUL":[{"def":"Disposed to fret; ill-humored; peevish; angry; in a state of vexation; as, a fretful temper.","pos":""}],"FRETT":[{"def":"The worn side of the bank of a river.","pos":""}],"FRETTED":[{"def":"Rubbed or worn away; chafed.","pos":""},{"def":"Agitated; vexed; worried.","pos":""}],"FRETTEN":[{"def":"Rubbed; marked; as, pock-fretten, marked with the smallpox.","pos":""}],"FRETTER":[{"def":"One who, or that which, frets.","pos":""}],"FRETTY":[{"def":"Adorned with fretwork.","pos":""}],"FRETUM":[{"def":"A strait, or arm of the sea.","pos":""}],"FRETWORK":[{"def":"Work adorned with frets; ornamental openwork or work in relief, esp.","pos":""}],"FREYA":[{"def":"The daughter of Njörd, aud goddess of love and beauty; the Scandinavian Venus; -- in Teutonic myths confounded with Frigga, but in Scandinavian, distinct.","pos":""}]}