{"BRAW":[{"def":"Well-dressed; handsome; smart; brave; -- used of persons or their clothing, etc.","pos":""}],"BRAWL":[{"def":"To quarrel noisily and outrageously.","pos":""},{"def":"To complain loudly; to scold.","pos":""}],"BRAWLER":[{"def":"One that brawls; wrangler.","pos":""}],"BRAWLING":[{"def":"Quarreling; quarrelsome; noisy.","pos":""},{"def":"Making a loud confused noise.","pos":""}],"BRAWLINGLY":[{"def":"In a brawling manner.","pos":""}],"BRAWN":[{"def":"A muscle; flesh.","pos":""},{"def":"Full, strong muscles, esp.","pos":""}],"BRAWNED":[{"def":"Brawny; strong; muscular.","pos":""}],"BRAWNER":[{"def":"A boor killed for the table.","pos":""}],"BRAWNINESS":[{"def":"The quality or state of being brawny.","pos":""}],"BRAWNY":[{"def":"Having large, strong muscles; muscular; fleshy; strong.","pos":""}]}