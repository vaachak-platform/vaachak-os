{"NONABILITY":[{"def":"An exception taken against a plaintiff in a cause, when he is unable legally to commence a suit.","pos":""}],"NONACCEPTANCE":[{"def":"A neglect or refusal to accept.","pos":""}],"NONACID":[{"def":"Destitute of acid properties; hence, basic; metallic; positive; -- said of certain atoms and radicals.","pos":""}],"NONACQUAINTANCE":[{"def":"Want of acquaintance; the state of being unacquainted.","pos":""}],"NONACQUIESCENCE":[{"def":"Refusal of acquiescence; failure to yield or comply.","pos":""}],"NONADMISSION":[{"def":"Failure to be admitted.","pos":""}],"NONADULT":[{"def":"Not adult; immature.","pos":""}],"NONAEROBIOTIC":[{"def":"Capable of living without atmospheric oxygen; anaërobiotic.","pos":""}],"NONAGE":[{"def":"The ninth part of movable goods, formerly payable to the clergy on the death of persons in their parishes.","pos":""}],"NONAGED":[{"def":"Having the quality of nonage; being a minor; immature.","pos":""}],"NONAGENARIAN":[{"def":"A person ninety years old.","pos":""}],"NONAGESIMAL":[{"def":"Of or pertaining to the ninetieth degree or to a nonagesimal.","pos":""}],"NONAGON":[{"def":"A figure or polygon having nine sides and nine angles.","pos":""}],"NONAGRIAN":[{"def":"Any moth of the genus Nonagria and allied genera, as the spindleworm and stalk borer.","pos":""}],"NONALIENATION":[{"def":"Failure to alienate; also, the state of not being alienated.","pos":""}],"NONANE":[{"def":"One of a group of metameric hydrocarbons C9H20 of the paraffin series; -- so called because of the nine carbon atoms in the molecule.","pos":""}],"NONAPPEARANCE":[{"def":"Default of apperance, as in court, to prosecute or defend; failure to appear.","pos":""}],"NONAPPOINTMENT":[{"def":"Neglect of making appointment; failure to receive an appointment.","pos":""}],"NONARRIVAL":[{"def":"Failure to arrive.","pos":""}],"NONATTENDANCE":[{"def":"A failure to attend; omission of attendance; nonappearance.","pos":""}]}