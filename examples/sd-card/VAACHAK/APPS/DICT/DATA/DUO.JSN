{"DUO":[{"def":"A composition for two performers; a duet.","pos":""},{"def":"See Dodecahedral, and Dodecahedron.","pos":""}],"DUODECENNIAL":[{"def":"Consisting of twelve years.","pos":""}],"DUODECIMAL":[{"def":"Proceeding in computation by twelves; expressed in the scale of twelves.","pos":""}],"DUODECIMFID":[{"def":"Divided into twelve parts.","pos":""}],"DUODECIMO":[{"def":"Having twelve leaves to a sheet; as, a duodecimo from, book, leaf, size, etc.","pos":""}],"DUODECUPLE":[{"def":"Consisting of twelves.","pos":""}],"DUODENAL":[{"def":"Of or pertaining to the duodenum; as, duodenal digestion.","pos":""}],"DUODENARY":[{"def":"Containing twelve; twelvefold; increasing by twelves; duodecimal.","pos":""}],"DUODENUM":[{"def":"The part of the small intestines between the stomach and the jejunum.","pos":""}],"DUOGRAPH":[{"def":"A picture printed from two half-tone plates made with the screen set at different angles, and usually printed in two shades of the same color or in black and one tint.","pos":""}],"DUOLITERAL":[{"def":"Consisting of two letters only; biliteral.","pos":""}],"DUOMO":[{"def":"Of tower or duomo, sunny sweet.","pos":""}],"DUOTONE":[{"def":"Any picture printed in two shades of the same color, as duotypes and duographs are usually printed.","pos":""}],"DUOTYPE":[{"def":"A print made from two half-tone plates made from the same negative, but etched differently.","pos":""}]}