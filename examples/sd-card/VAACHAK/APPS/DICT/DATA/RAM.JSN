{"RAM":[{"def":"The male of the sheep and allied animals.","pos":""},{"def":"An engine of war used for butting or battering.","pos":""}],"RAMADAN":[{"def":"The ninth Mohammedan month.","pos":""},{"def":"The great annual fast of the Mohammedans, kept during daylight through the ninth month.","pos":""}],"RAMAGE":[{"def":"Boughs or branches.","pos":""},{"def":"Warbling of birds in trees.","pos":""}],"RAMAGIOUS":[{"def":"Now is he tame that was so ramagious.","pos":""}],"RAMAL":[{"def":"Of or pertaining to a ramus, or branch; rameal.","pos":""}],"RAMAYANA":[{"def":"The more ancient of the two great epic poems in Sanskrit.","pos":""}],"RAMBERGE":[{"def":"Formerly, a kind of large war galley.","pos":""}],"RAMBLE":[{"def":"To walk, ride, or sail, from place to place, without any determinate object in view; to roam carelessly or irregularly; to rove; to wander; as, to ramble about the city; to ramble over the world.","pos":""},{"def":"To talk or write in a discursive, aimless way.","pos":""}],"RAMBLER":[{"def":"One who rambles; a rover; a wanderer.","pos":""}],"RAMBLING":[{"def":"Roving; wandering; discursive; as, a rambling fellow, talk, or building.","pos":""}],"RAMBLINGLY":[{"def":"In a rambling manner.","pos":""}],"RAMBOOZE":[{"def":"A beverage made of wine, ale (or milk), sugar, etc.","pos":""}],"RAMBUTAN":[{"def":"A Malayan fruit produced by the tree Nephelium lappaceum, and closely related to the litchi nut.","pos":""}],"RAMED":[{"def":"Having the frames, stem, and sternpost adjusted; -- said of a ship on the stocks.","pos":""}],"RAMENT":[{"def":"A scraping; a shaving.","pos":""}],"RAMENTA":[{"def":"Thin brownish chaffy scales upon the leaves or young shoots of some plants, especially upon the petioles and leaves of ferns.","pos":""}],"RAMENTACEOUS":[{"def":"Covered with ramenta.","pos":""}],"RAMEOUS":[{"def":"Ra\"me*ous, a Etym: [L.","pos":""}],"RAMEQUIN":[{"def":"A mixture of cheese, eggs, etc.","pos":""}],"RAMIE":[{"def":"The grasscloth plant (Boehmeria nivea); also, its fiber, which is very fine and exceedingly strong; -- called also China grass, and rhea.","pos":""}],"RAMIFICATION":[{"def":"The process of branching, or the development or offshoots from a stem; also, the mode of their arrangement.","pos":""},{"def":"A small branch or offshoot proceeding from a main stock or channel; as, the ramifications of an artery, vein, or nerve.","pos":""}],"RAMIFLOROUS":[{"def":"Flowering on the branches.","pos":""}],"RAMIFORM":[{"def":"Having the form of a branch.","pos":""}],"RAMIFY":[{"def":"To divide into branches or subdivisions; as, to ramify an art, subject, scheme.","pos":""}],"RAMIGEROUS":[{"def":"Bearing branches; branched.","pos":""}],"RAMIPAROUS":[{"def":"Producing branches; ramigerous.","pos":""}],"RAMIST":[{"def":"A follower of Pierre Ramé, better known as Ramus, a celebrated French scholar, who was professor of rhetoric and philosophy at Paris in the reign of Henry II.","pos":""}],"RAMLINE":[{"def":"A line used to get a straight middle line, as on a spar, or from stem to stern in building a vessel.","pos":""}],"RAMMEL":[{"def":"Filled with any rubbish, rammel and broken stones.","pos":""}],"RAMMER":[{"def":"One who, or that which, rams or drives.","pos":""}],"RAMMISH":[{"def":"Like a ram; hence, rank; lascivious.","pos":""}],"RAMMISHNESS":[{"def":"The quality of being rammish.","pos":""}],"RAMMY":[{"def":"Like a ram; rammish.","pos":""}],"RAMOLLESCENCE":[{"def":"A softening or mollifying.","pos":""}],"RAMOON":[{"def":"A small West Indian tree (Trophis Americana) of the Mulberry family, whose leaves and twigs are used as fodder for cattle.","pos":""}],"RAMOSE":[{"def":"Branched, as the stem or root of a plant; having lateral divisions; consisting of, or having, branches; full of branches; ramifying; branching; branchy.","pos":""}],"RAMP":[{"def":"To spring; to leap; to bound; to rear; to prance; to become rampant; hence, to frolic; to romp.","pos":""},{"def":"To move by leaps, or by leaps; hence, to move swiftly or with violence.","pos":""}],"RAMPACIOUS":[{"def":"High-spirited; rampageous.","pos":""}],"RAMPAGE":[{"def":"Violent or riotous behavior; a state of excitement, passion, or debauchery; as, to be on the rampage.","pos":""}],"RAMPAGEOUS":[{"def":"Characterized by violence and passion; unruly; rampant.","pos":""}],"RAMPANCY":[{"def":"The quality or state of being rampant; excessive action or development; exuberance; extravagance.","pos":""}],"RAMPANT":[{"def":"Rising with fore paws in the air as if attacking; -- said of a beast of prey, especially a lion.","pos":""}],"RAMPANTLY":[{"def":"In a rampant manner.","pos":""}],"RAMPART":[{"def":"A broad embankment of earth round a place, upon which the parapet is raised.","pos":""}],"RAMPION":[{"def":"A plant (Campanula Rapunculus) of the Bellflower family, with a tuberous esculent root; -- also called ramps.","pos":""}],"RAMPIRE":[{"def":"The Trojans round the place a rampire cast.","pos":""}],"RAMPLER":[{"def":"Roving; rambling.","pos":""}],"RAMROD":[{"def":"The rod used in ramming home the charge in a muzzle-loading firearm.","pos":""}],"RAMSHACKLE":[{"def":"Loose; disjointed; falling to pieces; out of repair.","pos":""}],"RAMSON":[{"def":"A broad-leaved species of garlic (Allium ursinum), common in European gardens; -- called also buckram.","pos":""}],"RAMSTED":[{"def":"A yellow-flowered weed; -- so named from a Mr.","pos":""}],"RAMTIL":[{"def":"A tropical African asteraceous shrub (Guizotia abyssinica) cultivated for its seeds (called ramtil, or niger, seeds) which yield a valuable oil used for food and as an illuminant.","pos":""}],"RAMULOSE":[{"def":"Having many small branches, or ramuli.","pos":""}],"RAMULUS":[{"def":"A small branch, or branchlet, of corals, hydroids, and similar organisms.","pos":""}],"RAMUS":[{"def":"A branch; a projecting part or prominent process; a ramification.","pos":""}],"RAMUSCULE":[{"def":"A small ramus, or branch.","pos":""}]}