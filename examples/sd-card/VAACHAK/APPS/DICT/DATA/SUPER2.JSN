{"SUPEROCCIPITAL":[{"def":"Su`per*oc*cip\"i*tal, a.","pos":""}],"SUPERORDER":[{"def":"A group intermediate in importance between an order and a subclass.","pos":""}],"SUPERORDINATION":[{"def":"The ordination of a person to fill a station already occupied; especially, the ordination by an ecclesiastical official, during his lifetime, of his successor.","pos":""}],"SUPERPARTICULAR":[{"def":"Of or pertaining to a ratio when the excess of the greater term over the less is a unit, as the ratio of 1 to 2, or of 3 to 4.","pos":""}],"SUPERPARTIENT":[{"def":"Of or pertaining to a ratio when the excess of the greater term over the less is more than a unit, as that of 3 to 5, or 7 to 10.","pos":""}],"SUPERPHOSPHATE":[{"def":"An acid phosphate.","pos":""}],"SUPERPHYSICAL":[{"def":"Above or beyond physics; not explainable by physical laws.","pos":""}],"SUPERPLANT":[{"def":"A plant growing on another, as the mistletoe; an epiphyte.","pos":""}],"SUPERPLEASE":[{"def":"To please exceedingly.","pos":""}],"SUPERPOLITIC":[{"def":"More than politic; above or exceeding policy.","pos":""}],"SUPERPONDERATE":[{"def":"To wiegh over and above.","pos":""}],"SUPERPOSABLE":[{"def":"Capable of being superposed, as one figure upon another.","pos":""}],"SUPERPOSE":[{"def":"To lay (a figure) upon another in such a manner that all the parts of the one coincide with the parts of the other; as, to superpose one plane figure on another.","pos":""}],"SUPERPOSITION":[{"def":"The act of superposing, or the state of being superposed; as, the superposition of rocks; the superposition of one plane figure on another, in geometry.","pos":""}],"SUPERPRAISE":[{"def":"To praise to excess.","pos":""}],"SUPERPROPORTION":[{"def":"Overplus or excess of proportion.","pos":""}],"SUPERPURGATION":[{"def":"Excessive purgation.","pos":""}],"SUPERREFLECTION":[{"def":"The reflection of a reflected image or sound.","pos":""}],"SUPERREGAL":[{"def":"More than regal; worthy of one greater than a king.","pos":""}],"SUPERREWARD":[{"def":"To reward to an excessive degree.","pos":""}],"SUPERROYAL":[{"def":"Larger than royal; -- said of a particular size of printing and writing paper.","pos":""}],"SUPERSACRAL":[{"def":"Situated over, or on the dorsal side of, the sacrum.","pos":""}],"SUPERSALIENCY":[{"def":"The act of leaping on anything.","pos":""}],"SUPERSATURATE":[{"def":"To add to beyond saturation; as, to supersaturate a solution.","pos":""}],"SUPERSATURATION":[{"def":"The operation of supersaturating, or the state of being supersaturated.","pos":""}],"SUPERSCRIBE":[{"def":"To write or engrave (a name, address, inscription, or the like) on the top or surface; to write a name, address, or the like, on the outside or cover of (anything); as, to superscribe a letter.","pos":""}],"SUPERSCRIPTION":[{"def":"The act of superscribing.","pos":""},{"def":"That which is written or engraved on the surface, outside, or above something else; specifically, an address on a letter, envelope, or the like.","pos":""}],"SUPERSECULAR":[{"def":"Being above the world, or secular things.","pos":""}],"SUPERSEDE":[{"def":"To omit; to forbear.","pos":""}],"SUPERSEDEAS":[{"def":"A writ of command to suspend the powers of an officer in certain cases, or to stay proceedings under another writ.","pos":""}],"SUPERSEDURE":[{"def":"The act of superseding, or setting aside; supersession; as, the supersedure of trial by jury.","pos":""}],"SUPERSEMINATE":[{"def":"To sow, as seed, over something previously sown.","pos":""}],"SUPERSEMINATION":[{"def":"The sowing of seed over seed previously sown.","pos":""}],"SUPERSENSIBLE":[{"def":"Beyond the reach of the senses; above the natural powers of perception.","pos":""}],"SUPERSENSITIVE":[{"def":"Excessively sensitive; morbidly sensitive.","pos":""}],"SUPERSENSUOUS":[{"def":"Excessively sensuous.","pos":""}],"SUPERSERVICEABLE":[{"def":"Overofficious; doing more than is required or desired.","pos":""}],"SUPERSESSION":[{"def":"The act of superseding, or the state of being superseded; supersedure.","pos":""}],"SUPERSPHENOIDAL":[{"def":"Situated above, or on the dorsal side of, the body of the sphenoid bone.","pos":""}],"SUPERSTITION":[{"def":"An excessive reverence for, or fear of, that which is unknown or mysterious.","pos":""}],"SUPERSTITIONIST":[{"def":"One addicted to superstition.","pos":""}],"SUPERSTITIOUS":[{"def":"Of or pertaining to superstition; proceeding from, or manifesting, superstition; as, superstitious rites; superstitious observances.","pos":""},{"def":"Evincing superstition; overscrupulous and rigid in religious observances; addicted to superstition; full of idle fancies and scruples in regard to religion.","pos":""}],"SUPERSTRATUM":[{"def":"A stratum, or layer, above another.","pos":""}],"SUPERSTRUCT":[{"def":"To build over or upon another structure; to erect upon a foundation.","pos":""}],"SUPERSTRUCTION":[{"def":"The act of superstructing, or building upon.","pos":""},{"def":"That which id superstructed, or built upon some foundation; an edifice; a superstructure.","pos":""}],"SUPERSTRUCTIVE":[{"def":"Built or erected on something else.","pos":""}],"SUPERSTRUCTOR":[{"def":"One who builds a superstructure.","pos":""}],"SUPERSTRUCTURE":[{"def":"all that part of a building above the basement.","pos":""},{"def":"The sleepers, and fastenings, in distinction from the roadbed.","pos":""}],"SUPERSUBSTANTIAL":[{"def":"More than substantial; spiritual.","pos":""}],"SUPERSULPHATE":[{"def":"An acid sulphate.","pos":""}],"SUPERSULPHURETED":[{"def":"Supersulphurized.","pos":""}],"SUPERSULPHURIZE":[{"def":"To impregnate or combine with an excess of sulphur.","pos":""}],"SUPERTAX":[{"def":"A tax in addition to the usual or normal tax; specif.","pos":""}],"SUPERTEMPORAL":[{"def":"That which is more than temporal; that which is eternal.","pos":""}],"SUPERTERRANEAN":[{"def":"Being above ground.","pos":""}],"SUPERTERRENE":[{"def":"Being above ground, or above the earth.","pos":""}],"SUPERTERRESTRIAL":[{"def":"Being above the earth, or above what belongs to the earth.","pos":""}],"SUPERTONIC":[{"def":"The note next above the keynote; the second of the scale.","pos":""}],"SUPERTRAGICAL":[{"def":"Tragical to excess.","pos":""}],"SUPERTUBERATION":[{"def":"The production of young tubers, as potatoes, from the old while still growing.","pos":""}],"SUPERVACANEOUS":[{"def":"Serving no purpose; superfluous; needless.","pos":""}],"SUPERVENE":[{"def":"To come as something additional or extraneous; to occur with reference or relation to something else; to happen upon or after something else; to be added; to take place; to happen.","pos":""}],"SUPERVENIENT":[{"def":"Coming as something additional or extraneous; coming afterwards.","pos":""}],"SUPERVENTION":[{"def":"The act of supervening.","pos":""}],"SUPERVISE":[{"def":"To oversee for direction; to superintend; to inspect with authority; as, to supervise the construction of a steam engine, or the printing of a book.","pos":""},{"def":"To look over so as to read; to peruse.","pos":""}],"SUPERVISION":[{"def":"The act of overseeing; inspection; superintendence; oversight.","pos":""}],"SUPERVISOR":[{"def":"One who supervises; an overseer; an inspector; a superintendent; as, a supervisor of schools.","pos":""},{"def":"A spectator; a looker-on.","pos":""}],"SUPERVISORY":[{"def":"Of or pertaining to supervision; as, supervisory powers.","pos":""}],"SUPERVIVE":[{"def":"To survive; to outlive.","pos":""}],"SUPERVOLUTE":[{"def":"Having a plainted and convolute arrangement in the bud, as in the morning-glory.","pos":""}]}