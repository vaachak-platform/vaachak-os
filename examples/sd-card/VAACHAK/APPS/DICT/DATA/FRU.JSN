{"FRUBISH":[{"def":"To rub up: to furbish.","pos":""}],"FRUCTED":[{"def":"Bearing fruit; -- said of a tree or plant so represented upon an escutcheon.","pos":""}],"FRUCTESCENCE":[{"def":"The maturing or ripening of fruit.","pos":""}],"FRUCTICULOSE":[{"def":"Fruitful; full of fruit.","pos":""}],"FRUCTIDOR":[{"def":"The twelfth month of the French republican calendar; -- commencing August 18, and ending September 16.","pos":""}],"FRUCTIFERUOS":[{"def":"Bearing or producing fruit.","pos":""}],"FRUCTIFICATION":[{"def":"The act of forming or producing fruit; the act of fructifying, or rendering productive of fruit; fecundation.","pos":""}],"FRUCTIFY":[{"def":"To make fruitful; to render productive; to fertilize; as, to fructify the earth.","pos":""}],"FRUCTOSE":[{"def":"Fruit sugar; levulose.","pos":""}],"FRUCTUARY":[{"def":"One who enjoys the profits, income, or increase of anything.","pos":""}],"FRUCTUATION":[{"def":"Produce; fruit, [R.","pos":""}],"FRUCTUOUS":[{"def":"Fruitful; productive; profitable.","pos":""}],"FRUCTURE":[{"def":"Use; fruition; enjoyment.","pos":""}],"FRUE VANNER":[{"def":"A moving, inclined, endless apron on which ore is concentrated by a current of water; a kind of buddle.","pos":""}],"FRUGAL":[{"def":"Economical in the use or appropriation of resources; not wasteful or lavish; wise in the expenditure or application of force, materials, time, etc.","pos":""},{"def":"Obtained by, or appropriate to, economy; as, a frugal fortune.","pos":""}],"FRUGALITY":[{"def":"The quality of being frugal; prudent economy; that careful management of anything valuable which expends nothing unnecessarily, and applies what is used to a profitable purpose; thrift; --- opposed to extravagance.","pos":""},{"def":"A sparing use; sparingness; as, frugality of praise.","pos":""}],"FRUGALLY":[{"def":"Thriftily; prudently.","pos":""}],"FRUGALNESS":[{"def":"Fru\"gal*ness Defn: , n.","pos":""}],"FRUGIFEROUS":[{"def":"Producing fruit; fruitful; fructiferous.","pos":""}],"FRUGIVORA":[{"def":"The fruit bate; a group of the Cheiroptera, comprising the bats which live on fruits.","pos":""}],"FRUGIVOROUS":[{"def":"Feeding on fruit, as birds and other animals.","pos":""}],"FRUIT":[{"def":"The pulpy, edible seed vessels of certain plants, especially those grown on branches above ground, as apples, oranges, grapes, melons, berries, etc.","pos":""},{"def":"The ripened ovary of a flowering plant, with its contents and whatever parts are consolidated with it.","pos":""}],"FRUITAGE":[{"def":"Fruit, collectively; fruit, in general; fruitery.","pos":""},{"def":"Product or result of any action; effect, good or ill.","pos":""}],"FRUITER":[{"def":"A ship for carrying fruit.","pos":""}],"FRUITERER":[{"def":"One who deals in fruit; a seller of fruits.","pos":""}],"FRUITERESS":[{"def":"A woman who sells fruit.","pos":""}],"FRUITERY":[{"def":"Fruit, taken collectively; fruitage.","pos":""},{"def":"A repository for fruit.","pos":""}],"FRUITFUL":[{"def":"Full of fruit; producing fruit abundantly; bearing results; prolific; fertile; liberal; bountiful; as, a fruitful tree, or season, or soil; a fruitful wife.","pos":""}],"FRUITING":[{"def":"Pertaining to, or producing, fruit.","pos":""}],"FRUITION":[{"def":"Use or possession of anything, especially such as is accompanied with pleasure or satisfaction; pleasure derived from possession or use.","pos":""}],"FRUITIVE":[{"def":"Eujoying; possessing.","pos":""}],"FRUITLESS":[{"def":"Lacking, or not bearing, fruit; barren; destitute of offspring; as, a fruitless tree or shrub; a fruitless marriage.","pos":""},{"def":"Productive of no advantage or good effect; vain; idle; useless; unprofitable; as, a fruitless attempt; a fruitless controversy.","pos":""}],"FRUITY":[{"def":"Having the odor, taste, or appearance of fruit; also, fruitful.","pos":""}],"FRUMENTACEOUS":[{"def":"Made of, or resembling, wheat or other grain.","pos":""}],"FRUMENTARIOUS":[{"def":"Of or pertaining to wheat or grain.","pos":""}],"FRUMENTATION":[{"def":"A largess of grain bestowed upon the people, to quiet them when uneasy.","pos":""}],"FRUMENTY":[{"def":"Food made of hulled wheat boiled in milk, with sugar, plums, etc.","pos":""}],"FRUMP":[{"def":"To insult; to flout; to mock; to snub.","pos":""}],"FRUMPISH":[{"def":"Cross-tempered; scornful.","pos":""},{"def":"Old-fashioned, as a woman's dress.","pos":""}],"FRUSH":[{"def":"To batter; to break in pieces.","pos":""}],"FRUSTRABLE":[{"def":"Capable of beeing frustrated or defeated.","pos":""}],"FRUSTRANEOUS":[{"def":"Vain; useless; unprofitable.","pos":""}],"FRUSTRATE":[{"def":"Vain; ineffectual; useless; unprofitable; null; voil; nugatory; of no effect.","pos":""}],"FRUSTRATIVE":[{"def":"Tending to defeat; fallacious.","pos":""}],"FRUSTRATORY":[{"def":"Making void; rendering null; as, a frustratory appeal.","pos":""}],"FRUSTULE":[{"def":"The siliceous shell of a diatom.","pos":""}],"FRUSTULENT":[{"def":"Abounding in fragments.","pos":""}],"FRUSTUM":[{"def":"The part of a solid next the base, formed by cutting off the, top; or the part of any solid, as of a cone, pyramid, etc.","pos":""},{"def":"One of the drums of the shaft of a column.","pos":""}],"FRUTAGE":[{"def":"A picture of fruit; decoration by representation of fruit.","pos":""},{"def":"A confection of fruit.","pos":""}],"FRUTESCENT":[{"def":"Somewhat shrubby in character; imperfectly shrubby, as the American species of Wistaria.","pos":""}],"FRUTEX":[{"def":"A plant having a woody, durable stem, but less than a tree; a shrub.","pos":""}],"FRUTICOSE":[{"def":"Pertaining to a shrub or shrubs; branching like a shrub; shrubby; shrublike; as, a fruticose stem.","pos":""}],"FRUTICULOSE":[{"def":"Like, or pertaining to, a small shrub.","pos":""}]}