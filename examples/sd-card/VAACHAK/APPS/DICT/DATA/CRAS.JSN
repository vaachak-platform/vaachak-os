{"CRASE":[{"def":"To break in pieces; to crack.","pos":""}],"CRASH":[{"def":"To break in pieces violently; to dash together with noise and violence.","pos":""}],"CRASHING":[{"def":"The noise of many things falling and breaking at once.","pos":""}],"CRASIS":[{"def":"A mixture of constituents, as of the blood; constitution; temperament.","pos":""},{"def":"A contraction of two vowels (as the final and initial vowels of united words) into one long vowel, or into a dipthong; synæresis; as, cogo for coago.","pos":""}],"CRASPEDOTA":[{"def":"The hydroid or naked-eyed medusæ.","pos":""}],"CRASPEDOTE":[{"def":"Of or pertaining to the Craspedota.","pos":""}],"CRASS":[{"def":"Cross; thick; dense; coarse; not elaborated or refined.","pos":""},{"def":"A semisolid mass or clot, especially that formed in coagulation of the blood.","pos":""}],"CRASSIMENT":[{"def":"Cras\"si*ment (krs\"s-ment), n.","pos":""}],"CRASSITUDE":[{"def":"Crossness; coarseness; thickness; density.","pos":""}],"CRASSNESS":[{"def":"Crass\"ness (krs\"ns), n.","pos":""}],"CRASTINATION":[{"def":"Procrastination; a putting off till to-morrow.","pos":""}]}