{"MAUCACO":[{"def":"A lemur; -- applied to several species, as the White-fronted, the ruffed, and the ring-tailed lemurs.","pos":""}],"MAUD":[{"def":"A gray plaid; -- used by shepherds in Scotland.","pos":""}],"MAUDLE":[{"def":"To throw onto confusion or disorder; to render maudlin.","pos":""}],"MAUDLIN":[{"def":"An aromatic composite herb, the costmary; also, the South European Achillea Ageratum, a kind of yarrow.","pos":""}],"MAUDLINISM":[{"def":"A maudlin state.","pos":""}],"MAUDLINWORT":[{"def":"The oxeye daisy.","pos":""},{"def":"In spite of; in opposition to; notwithstanding.","pos":""}],"MAUL":[{"def":"A heavy wooden hammer or beetle.","pos":""}],"MAUL-STICK":[{"def":"A stick used by painters as a rest for the hand while working.","pos":""}],"MAULE":[{"def":"The common mallow.","pos":""}],"MAULING":[{"def":"A severe beating with a stick, cudgel, or the fist.","pos":""}],"MAUND":[{"def":"An East Indian weight, varying in different localities from 25 to about 82 pounds avoirdupois.","pos":""}],"MAUNDER":[{"def":"To utter in a grumbling manner; to mutter.","pos":""}],"MAUNDERER":[{"def":"One who maunders.","pos":""}],"MAUNDRIL":[{"def":"A pick with two prongs, to pry with.","pos":""},{"def":"Silver coins or money of the nominal value of 1d.","pos":""}],"MAUNDY THURSDAY":[{"def":"The Thursday in Passion week, or next before Good Friday.","pos":""}],"MAURIST":[{"def":"A member of the Congregation of Saint Maur, an offshoot of the Benedictines, originating in France in the early part of the seventeenth century.","pos":""}],"MAUSOLEAN":[{"def":"Pertaining to a mausoleum; monumental.","pos":""}],"MAUSOLEUM":[{"def":"A magnificent tomb, or stately sepulchral monument.","pos":""}],"MAUVANILINE":[{"def":"See Mauve aniline, under Mauve.","pos":""}],"MAUVE":[{"def":"A color of a delicate purple, violet, or lilac.","pos":""}],"MAUVEINE":[{"def":"An artificial organic base, obtained by oxidizing a mixture of aniline and toluidine, and valuable for the dyestuffs it forms.","pos":""}]}