{"CHOU":[{"def":"A kind of light pastry, usually in the form of a small round cake, and with a filling, as of jelly or cream.","pos":""}],"CHOUAN":[{"def":"One of the royalist insurgents in western France (Brittany, etc.","pos":""}],"CHOUGH":[{"def":"A bird of the Crow family (Fregilus graculus) of Europe.","pos":""}],"CHOUICHA":[{"def":"The salmon of the Columbia River or California.","pos":""}],"CHOUKA":[{"def":"The Indian four-horned antelope; the chikara.","pos":""}],"CHOUSE":[{"def":"To cheat, trick, defraud; -- followed by of, or out of; as, to chouse one out of his money.","pos":""}],"CHOUT":[{"def":"An assessment equal to a fourth part of the revenue.","pos":""}]}