{"DIABASE":[{"def":"A basic, dark-colored, holocrystalline, igneous rock, consisting essentially of a triclinic feldspar and pyroxene with magnetic iron; -- often limited to rocks pretertiary in age.","pos":""}],"DIABATERIAL":[{"def":"Passing over the borders.","pos":""}],"DIABETES":[{"def":"A disease which is attended with a persistent, excessive discharge of urine.","pos":""},{"def":"Pertaining to diabetes; as, diabetic or diabetical treatment.","pos":""}],"DIABOLIFY":[{"def":"To ascribed diabolical qualities to; to change into, or to represent as, a devil.","pos":""}],"DIABOLISM":[{"def":"Character, action, or principles appropriate to the devil.","pos":""},{"def":"Possession by the devil.","pos":""}],"DIABOLIZE":[{"def":"To render diabolical.","pos":""}],"DIABOLO":[{"def":"An old game or sport (revived under this name) consisting in whirling on a string, fastened to two sticks, a small somewhat spool- shaped object (called the diabolo) so as to balance it on a string, toss it in the air and catch it, etc.","pos":""}]}