{"METABASIS":[{"def":"A transition from one subject to another.","pos":""},{"def":"Same as Metabola.","pos":""}],"METABOLIAN":[{"def":"An insect which undergoes a metamorphosis.","pos":""}],"METABOLIC":[{"def":"Of or pertaining to metamorphosis; pertaining to, or involving, change.","pos":""},{"def":"Of or pertaining to metabolism; as, metabolic activity; metabolic force.","pos":""}],"METABOLITE":[{"def":"A product of metabolism; a substance produced by metabolic action, as urea.","pos":""}],"METABOLIZE":[{"def":"To change by a metabolic process.","pos":""}],"METABRANCHIAL":[{"def":"Of or pertaining to the lobe of the carapace of crabs covering the posterior branchiæ.","pos":""}]}