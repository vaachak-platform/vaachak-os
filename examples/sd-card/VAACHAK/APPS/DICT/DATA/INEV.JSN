{"INEVIDENCE":[{"def":"Want of evidence; obscurity.","pos":""}],"INEVIDENT":[{"def":"Not evident; not clear or obvious; obscure.","pos":""}],"INEVITABILITY":[{"def":"Impossibility to be avoided or shunned; inevitableness.","pos":""}],"INEVITABLE":[{"def":"Not evitable; incapable of being shunned; unavoidable; certain.","pos":""}],"INEVITABLENESS":[{"def":"The state of being unavoidable; certainty to happen.","pos":""}],"INEVITABLY":[{"def":"Without possibility of escape or evasion; unavoidably; certainly.","pos":""}]}