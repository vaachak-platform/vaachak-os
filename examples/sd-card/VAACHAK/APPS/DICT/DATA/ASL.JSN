{"ASLAKE":[{"def":"To mitigate; to moderate; to appease; to abate; to diminish.","pos":""}],"ASLANT":[{"def":"Toward one side; in a slanting direction; obliquely.","pos":""}],"ASLEEP":[{"def":"In a state of sleep; in sleep; dormant.","pos":""},{"def":"In the sleep of the grave; dead.","pos":""}],"ASLOPE":[{"def":"Slopingly; aslant; declining from an upright direction; sloping.","pos":""}]}