{"TRIM":[{"def":"To dress, as timber; to make smooth.","pos":""}],"TRIMACULATED":[{"def":"Marked with three spots, or maculæ.","pos":""}],"TRIMELLIC":[{"def":"Of, pertaining to, or designating, a certain tribasic acid (called also trimellitic acid) metameric with trimesitic acid.","pos":""}],"TRIMEMBRAL":[{"def":"Having, or consisting of, three members.","pos":""}],"TRIMERA":[{"def":"A division of Coleoptera including those which have but three joints in the tarsi.","pos":""}],"TRIMERAN":[{"def":"One of the Trimera.","pos":""}],"TRIMEROUS":[{"def":"Having the parts in threes.","pos":""}],"TRIMESITIC":[{"def":"Of, pertaining to, or designating, a tribasic acid, C6H3.","pos":""}],"TRIMESTER":[{"def":"A term or period of three months.","pos":""}],"TRIMESTRIAL":[{"def":"Of or pertaining to a trimester, or period of three months; occurring once in every three months; quarterly.","pos":""}],"TRIMETER":[{"def":"Consisting of three poetical measures.","pos":""},{"def":"A poetical division of verse, consisting of three measures.","pos":""}],"TRIMETHYLAMINE":[{"def":"A colorless volatile alkaline liquid, N.","pos":""}],"TRIMETHYLENE":[{"def":"A gaseous hydrocarbon, C3H6, isomeric with propylene and obtained from it indirectly.","pos":""}],"TRIMETRIC":[{"def":"Same as Orthorhombic.","pos":""}],"TRIMETRICAL":[{"def":"Same as Trimeter.","pos":""}],"TRIMLY":[{"def":"In a trim manner; nicely.","pos":""}],"TRIMMER":[{"def":"A beam, into which are framed the ends of headers in floor framing, as when a hole is to be left for stairs, or to avoid bringing joists near chimneys, and the like.","pos":""}],"TRIMMING":[{"def":"Trim\"ming, Defn: a.","pos":""}],"TRIMMINGLY":[{"def":"In a trimming manner.","pos":""}],"TRIMNESS":[{"def":"The quality or state of being trim; orderliness; compactness; snugness; neatness.","pos":""}],"TRIMORPH":[{"def":"A substance which crystallizes in three distinct forms, or which has three distinct physical states; also, any one of these distinct forms.","pos":""},{"def":"Of, pertaining to, or characterized by, trimorphism; -- contrasted with monomorphic, dimorphic, and polymorphic.","pos":""}],"TRIMORPHISM":[{"def":"The property of crystallizing in three forms fundamentally distinct, as is the case with titanium dioxide, which crystallizes in the forms of rutile, octahedrite, and brookite.","pos":""}],"TRIMURTI":[{"def":"The triad, or trinity, of Hindoo gods, consisting of Brahma, the Creator, Vishnu, the Preserver, and Siva, the Destroyer.","pos":""}],"TRIMYARIAN":[{"def":"A lamellibranch which has three muscular scars on each valve.","pos":""}]}