{"ELABORATE":[{"def":"Wrought with labor; finished with great care; studied; executed with exactness or painstaking; as, an elaborate discourse; an elaborate performance; elaborate research.","pos":""}],"ELABORATED":[{"def":"developed or executed with care and in minute detail; as, the carefully elaborated theme.","pos":""}],"ELABORATION":[{"def":"The natural process of formation or assimilation, performed by the living organs in animals and vegetables, by which a crude substance is changed into something of a higher order; as, the elaboration of food into chyme; the elaboration of chyle, or sap, or tissues.","pos":""}],"ELABORATIVE":[{"def":"Serving or tending to elaborate; constructing with labor and minute attention to details.","pos":""}],"ELABORATOR":[{"def":"One who, or that which, elaborates.","pos":""}],"ELABORATORY":[{"def":"Tending to elaborate.","pos":""}],"ELAEAGNUS":[{"def":"A genus of shrubs or small trees, having the foliage covered with small silvery scales; oleaster.","pos":""}],"ELAEIS":[{"def":"A genus of palms.","pos":""}],"ELAEOLITE":[{"def":"A variety of hephelite, usually massive, of greasy luster, and gray to reddish color.","pos":""}],"ELAEOPTENE":[{"def":"The more liquid or volatile portion of certain oily substance, as distinguished from stearoptene, the more solid parts.","pos":""}],"ELAIDATE":[{"def":"A salt of elaidic acid.","pos":""}],"ELAIDIC":[{"def":"Relating to oleic acid, or elaine.","pos":""}],"ELAIDIN":[{"def":"A solid isomeric modification of olein.","pos":""}],"ELAIODIC":[{"def":"Derived from castor oil; ricinoleic; as, elaiodic acid.","pos":""}],"ELAIOMETER":[{"def":"An apparatus for determining the amount of oil contained in any substance, or for ascertaining the degree of purity of oil.","pos":""}],"ELAMITE":[{"def":"A dweller in Flam (or Susiana), an ancient kingdom of Southwestern Asia, afterwards a province of Persia.","pos":""}],"ELAN":[{"def":"Ardor inspired by passion or enthusiasm.","pos":""}],"ELANCE":[{"def":"To throw as a lance; to hurl; to dart.","pos":""}],"ELAND":[{"def":"A species of large South African antelope (Oreas canna).","pos":""},{"def":"The elk or moose.","pos":""}],"ELANET":[{"def":"A kite of the genus Elanus.","pos":""}],"ELAPHINE":[{"def":"Pertaining to, resembling, or characteristic of, the stag, or Cervus elaphus.","pos":""}],"ELAPHURE":[{"def":"A species of deer (Elaphurus Davidianus) found in china.","pos":""}],"ELAPIDATION":[{"def":"A clearing away of stones.","pos":""}],"ELAPINE":[{"def":"Like or pertaining to the Elapidæ, a family of poisonous serpents, including the cobras.","pos":""}],"ELAPS":[{"def":"A genus of venomous snakes found both in America and the Old World.","pos":""}],"ELAPSE":[{"def":"To slip or glide away; to pass away silently, as time; -- used chiefly in reference to time.","pos":""}],"ELAPSION":[{"def":"The act of elapsing.","pos":""}],"ELASIPODA":[{"def":"An order of holothurians mostly found in the deep sea.","pos":""}],"ELASMOBRANCH":[{"def":"Of or pertaining to the Elasmobranchii.","pos":""},{"def":"One of the Elasmobranchii.","pos":""}],"ELASMOBRANCHIATE":[{"def":"Of or pertaining to Elasmobranchii.","pos":""},{"def":"One of the Elasmobranchii.","pos":""}],"ELASMOBRANCHII":[{"def":"A subclass of fishes, comprising the sharks, the rays, and the Chimæra.","pos":""}],"ELASMOSAURUS":[{"def":"An extinct, long-necked, marine, cretaceous reptile from Kansas, allied to Plesiosaurus.","pos":""}],"ELASTIC":[{"def":"Springing back; having a power or inherent property of returning to the form from which a substance is bent, drawn, pressed, or twisted; springy; having the power of rebounding; as, a bow is elastic; the air is elastic; India rubber is elastic.","pos":""},{"def":"Able to return quickly to a former state or condition, after being depressed or overtaxed; having power to recover easily from shocks and trials; as, elastic spirits; an elastic constitution.","pos":""}],"ELASTICALLY":[{"def":"In an elastic manner; by an elastic power; with a spring.","pos":""}],"ELASTICITY":[{"def":"The quality of being elastic; the inherent property in bodies by which they recover their former figure or dimensions, after the removal of external pressure or altering force; springiness; tendency to rebound; as, the elasticity of caoutchouc; the elasticity of the air.","pos":""},{"def":"Power of resistance to, or recovery from, depression or overwork.","pos":""}],"ELASTICNESS":[{"def":"The quality of being elastic; elasticity.","pos":""}],"ELASTIN":[{"def":"A nitrogenous substance, somewhat resembling albumin, which forms the chemical basis of elastic tissue.","pos":""}],"ELATE":[{"def":"Lifted up; raised; elevated.","pos":""},{"def":"Having the spirits raised by success, or by hope; flushed or exalted with confidence; elated; exultant.","pos":""}],"ELATEDNESS":[{"def":"The state of being elated.","pos":""}],"ELATER":[{"def":"One who, or that which, elates.","pos":""}],"ELATERITE":[{"def":"A mineral resin, of a blackish brown color, occurring in soft, flexible masses; -- called also mineral caoutchouc, and elastic bitumen.","pos":""}],"ELATERIUM":[{"def":"A cathartic substance obtained, in the form of yellowish or greenish cakes, as the dried residue of the juice of the wild or squirting cucumber (Ecballium agreste, formerly called Momordica Elaterium).","pos":""}],"ELATEROMETER":[{"def":"Same as Elatrometer.","pos":""}],"ELATERY":[{"def":"Acting force; elasticity.","pos":""}],"ELATION":[{"def":"A lifting up by success; exaltation; inriation with pride of prosperity.","pos":""}],"ELATIVE":[{"def":"Raised; lifted up; -- a term applied to what is also called the absolute superlative, denoting a high or intense degree of a quality, but not excluding the idea that an equal degree may exist in other cases.","pos":""}],"ELATROMETER":[{"def":"An instrument for measuring the degree of rarefaction of air contained in the receiver of an air pump.","pos":""}],"ELAYL":[{"def":"Olefiant gas or ethylene; -- so called by Berzelius from its forming an oil combining with chlorine.","pos":""}]}