{"TROOP":[{"def":"Specifically, a small body of cavalry, light horse, or dragoons, consisting usually of about sixty men, commanded by a captain; the unit of formation of cavalry, corresponding to the company in infantry.","pos":""},{"def":"A particular roll of the drum; a quick march.","pos":""}],"TROOPER":[{"def":"A soldier in a body of cavalry; a cavalryman; also, the horse of a cavalryman.","pos":""}],"TROOPFOWL":[{"def":"The American scaup duck.","pos":""}],"TROOPIAL":[{"def":"Same as Troupial.","pos":""}],"TROOPMEAL":[{"def":"By troops; in crowds.","pos":""}],"TROOPSHIP":[{"def":"A vessel built or fitted for the conveyance of troops; a transport.","pos":""}]}