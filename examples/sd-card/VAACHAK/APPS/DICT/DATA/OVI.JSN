{"OVICAPSULE":[{"def":"The outer layer of a Graafian follicle.","pos":""},{"def":"Same as Oötheca.","pos":""}],"OVICELL":[{"def":"One of the dilatations of the body wall of Bryozoa in which the ova sometimes undegro the first stages of their development.","pos":""}],"OVICULAR":[{"def":"Of or pertaining to an egg.","pos":""}],"OVICYST":[{"def":"The pouch in which incubation takes place in some Tunicata.","pos":""}],"OVIDIAN":[{"def":"Of or pertaining to the Latin poet Ovid; resembling the style of Ovid.","pos":""}],"OVIDUCAL":[{"def":"Of or pertaining to oviducts; as, oviducal glands.","pos":""}],"OVIDUCT":[{"def":"A tube, or duct, for the passage of ova from the ovary to the exterior of the animal or to the part where further development takes place.","pos":""}],"OVIFEROUS":[{"def":"Egg-bearing; -- applied particularly to certain receptacles, as in Crustacea, that retain the eggs after they have been excluded from the formative organs, until they are hatched.","pos":""}],"OVIFORM":[{"def":"Having the form or figure of an egg; egg-shaped; as, an oviform leaf.","pos":""}],"OVIGERONS":[{"def":"Bearing eggs; oviferous.","pos":""}],"OVINE":[{"def":"Of or pertaining to sheep; consisting of sheep.","pos":""}],"OVIPARA":[{"def":"An artifical division of vertebrates, including those that lay eggs; -opposed to Vivipara.","pos":""}],"OVIPARITY":[{"def":"Generatuon by means of ova.","pos":""}],"OVIPAROUS":[{"def":"Producing young from rggs; as, an oviparous animal, in which the egg is generally separated from the animal, and hatched after exclusion; -- opposed to viviparous.","pos":""}],"OVIPOSIT":[{"def":"To lay or deposit eggs; -- said esp.","pos":""}],"OVIPOSITOR":[{"def":"The organ with which many insects and some other animals deposit their eggs.","pos":""}],"OVISM":[{"def":"The old theory that the egg contains the whole embryo of the future organism and the germs of all subsequent offsprings and is merely awakened to activity by the spermatozoön; -- opposed to spermism or animalculism.","pos":""}],"OVIST":[{"def":"Same as Ovulist.","pos":""}]}