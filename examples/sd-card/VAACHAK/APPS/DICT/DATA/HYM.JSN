{"HYMAR":[{"def":"The wild ass of Persia.","pos":""}],"HYMEN":[{"def":"A fold of muscous membrane often found at the orifice of the vagina; the vaginal membrane.","pos":""}],"HYMENIUM":[{"def":"The spore-bearing surface of certain fungi, as that on the gills of a mushroom.","pos":""}],"HYMENOGENY":[{"def":"The production of artificial membranes by contact of two fluids, as albumin and fat, by which the globules of the latter are surrounded by a thin film of the former.","pos":""}],"HYMENOMYCETES":[{"def":"One of the great divisions of fungi, containing those species in which the hymenium is completely exposed.","pos":""}],"HYMENOPHORE":[{"def":"That part of a fungus which is covered with the hymenium.","pos":""}],"HYMENOPTER":[{"def":"One of the Hymenoptera.","pos":""}],"HYMENOPTERA":[{"def":"An extensive order of insects, including the bees, ants, ichneumons, sawflies, etc.","pos":""},{"def":"Like, or characteristic of, the Hymenoptera; pertaining to the Hymenoptera.","pos":""}],"HYMENOPTERAN":[{"def":"One of the Hymenoptera.","pos":""}],"HYMN":[{"def":"An ode or song of praise or adoration; especially, a religious ode, a sacred lyric; a song of praise or thankgiving intended to be used in religious service; as, the Homeric hymns; Watts' hymns.","pos":""}],"HYMNAL":[{"def":"A collection of hymns; a hymn book.","pos":""}],"HYMNIC":[{"def":"Relating to hymns, or sacred lyrics.","pos":""}],"HYMNING":[{"def":"Praising with hymns; singing.","pos":""}],"HYMNIST":[{"def":"A writer of hymns.","pos":""}],"HYMNODY":[{"def":"Hymns, considered collectively; hymnology.","pos":""}],"HYMNOGRAPHER":[{"def":"One who writes on the subject of hymns.","pos":""},{"def":"A writer or composed of hymns.","pos":""}],"HYMNOGRAPHY":[{"def":"The art or act of composing hymns.","pos":""}],"HYMNOLOGIST":[{"def":"A composer or compiler of hymns; one versed in hymnology.","pos":""}],"HYMNOLOGY":[{"def":"The hymns or sacred lyrics composed by authors of a particular country or period; as, the hymnology of the eighteenth century; also, the collective body of hymns used by any particular church or religious body; as, the Anglican hymnology.","pos":""},{"def":"A knowledge of hymns; a treatise on hymns.","pos":""}]}