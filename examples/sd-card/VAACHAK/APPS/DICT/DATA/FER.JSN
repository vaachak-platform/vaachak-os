{"FER-DE-LANCE":[{"def":"A large, venomous serpent (Trigonocephalus lanceolatus) of Brazil and the West Indies.","pos":""}],"FERACIOUS":[{"def":"Fruitful; producing abudantly.","pos":""}],"FERACITY":[{"def":"The state of being feracious or fruitful.","pos":""}],"FERAE":[{"def":"A group of mammals which formerly included the Carnivora, Insectivora, Marsupialia, and lemurs, but is now often restricted to the Carnivora.","pos":""}],"FERAE NATURAE":[{"def":"Of a wild nature; -- applied to animals, as foxes, wild ducks, etc.","pos":""}],"FERAL":[{"def":"Wild; untamed; ferine; not domesticated; -- said of beasts, birds, and plants.","pos":""}],"FERDING":[{"def":"A measure of land mentioned in Domesday Book.","pos":""}],"FERE":[{"def":"A mate or companion; -- often used of a wife.","pos":""}],"FERETORY":[{"def":"A portable bier or shrine, variously adorned, used for containing relics of saints.","pos":""}],"FERGUSONITE":[{"def":"A mineral of a brownish black color, essentially a tantalo- niobate of yttrium, erbium, and cerium; -- so called after Robert Ferguson.","pos":""}],"FERIA":[{"def":"A week day, esp.","pos":""}],"FERIAL":[{"def":"Of or pertaining to holidays.","pos":""},{"def":"Belonging to any week day, esp.","pos":""}],"FERIATION":[{"def":"The act of keeping holiday; cessation from work.","pos":""}],"FERIER":[{"def":"Rhenus ferier than the cataract.","pos":""}],"FERINE":[{"def":"Wild; untamed; savage; as, lions, tigers, wolves, and bears are ferine beasts.","pos":""},{"def":"A wild beast; a beast of prey.","pos":""}],"FERINGEE":[{"def":"The name given to Europeans by the Hindos.","pos":""}],"FERITY":[{"def":"Wildness; savageness; fierceness.","pos":""}],"FERLY":[{"def":"Singular; wonderful; extraordinary.","pos":""},{"def":"A wonder; a marvel.","pos":""}],"FERMACY":[{"def":"Medicine; pharmacy.","pos":""}],"FERMENT":[{"def":"That which causes fermentation, as yeast, barm, or fermenting beer.","pos":""},{"def":"Intestine motion; heat; tumult; agitation.","pos":""}],"FERMENTABILITY":[{"def":"Capability of fermentation.","pos":""}],"FERMENTABLE":[{"def":"Capable of fermentation; as, cider and other vegetable liquors are fermentable.","pos":""}],"FERMENTATION":[{"def":"The process of undergoing an effervescent change, as by the action of yeast; in a wider sense (Physiol.","pos":""},{"def":"A state of agitation or excitement, as of the intellect or the feelings.","pos":""}],"FERMENTATION THEORY":[{"def":"The theory which likens the course of certain diseases (esp.","pos":""}],"FERMENTATIVE":[{"def":"Causing, or having power to cause, fermentation; produced by fermentation; fermenting; as, a fermentative process.","pos":""}],"FERMERERE":[{"def":"The officer in a religious house who had the care of the infirmary.","pos":""}],"FERMETURE":[{"def":"The mechanism for closing the breech of a breech-loading firearm, in artillery consisting principally of the breechblock, obturator, and carrier ring.","pos":""}],"FERMILLET":[{"def":"A buckle or clasp.","pos":""}],"FERN":[{"def":"An order of cryptogamous plants, the Filices, which have their fructification on the back of the fronds or leaves.","pos":""}],"FERNERY":[{"def":"A place for rearing ferns.","pos":""}],"FERNTICLE":[{"def":"A freckle on the skin, resembling the seed of fern.","pos":""}],"FERNY":[{"def":"Abounding in ferns.","pos":""}],"FEROCIOUS":[{"def":"Fierce; savage; wild; indicating cruelty; ravenous; rapacious; as, ferocious look or features; a ferocious lion.","pos":""}],"FEROCITY":[{"def":"Savage wildness or fierceness; fury; cruelty; as, ferocity of countenance.","pos":""}],"FEROHER":[{"def":"A symbol of the solar deity, found on monuments exhumed in Babylon, Nineveh, etc.","pos":""}],"FEROUS":[{"def":"A suffix signifying bearing, producing, yielding; as, auriferous, yielding gold; chyliferous, producing chyle.","pos":""}],"FERRANDINE":[{"def":"A stuff made of silk and wool.","pos":""},{"def":"A form of conductor, designed by Ferranti, for currents of high potential, and consisting of concentric tubes of copper separated by an insulating material composed of paper saturated with black mineral wax.","pos":""}],"FERRANTI PHENOMENON":[{"def":"Fer*ran\"ti phe*nom\"e*non.","pos":""}],"FERRARA":[{"def":"A sword bearing the mark of one of the Ferrara family of Italy.","pos":""}],"FERRARESE":[{"def":"Pertaining to Ferrara, in Italy.","pos":""},{"def":"A citizen of Ferrara; collectively, the inhabitants of Ferrara.","pos":""}],"FERRARY":[{"def":"The art of working in iron.","pos":""}],"FERRATE":[{"def":"A salt of ferric acid.","pos":""}],"FERREOUS":[{"def":"Partaking of, made of, or pertaining to, iron; like iron.","pos":""}],"FERRET":[{"def":"An animal of the Weasel family (Mustela or Putorius furo), about fourteen inches in length, of a pale yellow or white color, with red eyes.","pos":""}],"FERRET-EYE":[{"def":"The spur-winged goose; -- so called from the red circle around the eyes.","pos":""}],"FERRETER":[{"def":"One who ferrets.","pos":""}],"FERRETTO":[{"def":"Copper sulphide, used to color glass.","pos":""}],"FERRI-":[{"def":"A combining form indicating ferric iron as an ingredient; as, ferricyanide.","pos":""}],"FERRIAGE":[{"def":"The price or fare to be paid for passage at a ferry.","pos":""}],"FERRIC":[{"def":"Pertaining to, derived from, or containing iron.","pos":""}],"FERRICYANATE":[{"def":"A salt of ferricyanic acid; a ferricyanide.","pos":""}],"FERRICYANIC":[{"def":"Pertaining to, or derived from, a ferricyanide.","pos":""}],"FERRICYANIDE":[{"def":"One of a complex series of double cyanides of ferric iron and some other base.","pos":""}],"FERRIFEROUS":[{"def":"Producing or yielding iron.","pos":""}],"FERRIPRUSSIATE":[{"def":"A ferricyanate; a ferricyanide.","pos":""}],"FERRIPRUSSIC":[{"def":"Fer`ri*prus\"sic ( or ; see Prussik, 277), a.","pos":""}],"FERRIS WHEEL":[{"def":"An amusement device consisting of a giant power-driven steel wheel, revolvable on its stationary axle, and carrying a number of balanced passenger cars around its rim; -- so called after G.","pos":""}],"FERRO-":[{"def":"A prefix, or combining form, indicating ferrous iron as an ingredient; as, ferrocyanide.","pos":""}],"FERRO-CONCRETE":[{"def":"Concrete strengthened by a core or foundation skeleton of iron or steel bars, strips, etc.","pos":""}],"FERROCALCITE":[{"def":"Limestone containing a large percentage of iron carbonate, and hence turning brown on exposure.","pos":""}],"FERROCYANATE":[{"def":"A salt of ferrocyanic acid; a ferrocyanide.","pos":""}],"FERROCYANIC":[{"def":"Pertaining to, derived from, or designating, a ferrocyanide.","pos":""}],"FERROCYANIDE":[{"def":"One of a series of complex double cyanides of ferrous iron and some other base.","pos":""}],"FERROPRUSSIATE":[{"def":"A ferrocyanate; a ferocyanide.","pos":""}],"FERROPRUSSIC":[{"def":"Fer`ro*prus\"sic ( or ; see Prussic, 277), a.","pos":""}],"FERROTYPE":[{"def":"A photographic picture taken on an iron plate by a collodion process; -- familiarly called tintype.","pos":""}],"FERROUS":[{"def":"Pertaining to, or derived from, iron; -- especially used of compounds of iron in which the iron has its lower valence; as, ferrous sulphate.","pos":""}],"FERRUGINATED":[{"def":"Having the color or properties of the rust of iron.","pos":""}],"FERRUGINOUS":[{"def":"Partaking of iron; containing particles of iron.","pos":""},{"def":"Resembling iron rust in appearance or color; brownish red, or yellowish red.","pos":""}],"FERRUGO":[{"def":"A disease of plants caused by fungi, commonly called the rust, from its resemblance to iron rust in color.","pos":""}],"FERRULE":[{"def":"A bushing for expanding the end of a flue to fasten it tightly in the tube plate, or for partly filling up its mouth.","pos":""}],"FERRUMINATE":[{"def":"To solder or unite, as metals.","pos":""}],"FERRUMINATION":[{"def":"The soldering ir uniting of me [R.","pos":""}],"FERRY":[{"def":"To carry or transport over a river, strait, or other narrow water, in a boat.","pos":""}],"FERRYBOAT":[{"def":"A vessel for conveying passengers, merchandise, etc.","pos":""}],"FERRYMAN":[{"def":"One who maintains or attends a ferry.","pos":""}],"FERTILE":[{"def":"Producing fruit or vegetation in abundance; fruitful; able to produce abundantly; prolific; fecund; productive; rich; inventive; as, fertile land or fields; a fertile mind or imagination.","pos":""}],"FERTILELY":[{"def":"In a fertile or fruitful manner.","pos":""}],"FERTILITATE":[{"def":"To fertilize; to fecundate.","pos":""}],"FERTILITY":[{"def":"The state or quality of being fertile or fruitful; fruitfulness; productiveness; fecundity; richness; abundance of resources; fertile invention; quickness; readiness; as, the fertility of soil, or of imagination.","pos":""}],"FERTILIZATION":[{"def":"The act of fecundating or impregnating animal or vegetable germs; esp.","pos":""}],"FERTILIZE":[{"def":"To make fertile or enrich; to supply with nourishment for plants; to make fruitful or productive; as, to fertilize land, soil, ground, and meadows.","pos":""},{"def":"To fecundate; as, to fertilize flower.","pos":""}],"FERTILIZER":[{"def":"One who fertilizes; the agent that carries the fertilizing principle, as a moth to an orchid.","pos":""},{"def":"That which renders fertile; a general name for commercial manures, as guano, phosphate of lime, etc.","pos":""}],"FERULA":[{"def":"The imperial scepter in the Byzantine or Eastern Empire.","pos":""}],"FERULACEOUS":[{"def":"Pertaining to reeds and canes; having a stalk like a reed; as, ferulaceous plants.","pos":""}],"FERULE":[{"def":"A flat piece of wood, used for striking, children, esp.","pos":""}],"FERULIC":[{"def":"Pertaining to, or derived from, asafetida (Ferula asafoetida); as, ferulic acid.","pos":""}],"FERVENCY":[{"def":"The state of being fervent or warm; ardor; warmth of feeling or devotion; eagerness.","pos":""}],"FERVENT":[{"def":"Hot; glowing; boiling; burning; as, a fervent summer.","pos":""},{"def":"Warm in feeling; ardent in temperament; earnest; full of fervor; zealous; glowing.","pos":""}],"FERVID":[{"def":"Very hot; burning; boiling.","pos":""},{"def":"Ardent; vehement; zealous.","pos":""}],"FERVOR":[{"def":"Heat; excessive warmth.","pos":""},{"def":"Intensity of feeling or expression; glowing ardor; passion; holy zeal; earnestness.","pos":""}]}