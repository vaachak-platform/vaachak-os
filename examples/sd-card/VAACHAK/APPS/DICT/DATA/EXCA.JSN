{"EXCALCEATE":[{"def":"To deprive of shoes.","pos":""}],"EXCALCEATION":[{"def":"The act of depriving or divesting of shoes.","pos":""}],"EXCALFACTION":[{"def":"A heating or warming; calefaction.","pos":""}],"EXCALFACTIVE":[{"def":"Serving to heat; warming.","pos":""}],"EXCALFACTORY":[{"def":"Heating; warming.","pos":""}],"EXCALIBUR":[{"def":"The name of King Arthur's mythical sword.","pos":""},{"def":"To exchange; -- used with reference to transfers of land.","pos":""}],"EXCANDESCENCE":[{"def":"A growing hot; a white or glowing heat; incandescence.","pos":""},{"def":"Violent anger; a growing angry.","pos":""}],"EXCANDESCENT":[{"def":"White or glowing with heat.","pos":""}],"EXCANTATION":[{"def":"Disenchantment by a countercharm.","pos":""}],"EXCARNATE":[{"def":"To deprive or clear of flesh.","pos":""}],"EXCARNATION":[{"def":"The act of depriving or divesting of flesh; excarnification; -- opposed to incarnation.","pos":""}],"EXCARNIFICATE":[{"def":"To clear of flesh; to excarnate.","pos":""}],"EXCARNIFICATION":[{"def":"The act of excarnificating or of depriving of flesh; excarnation.","pos":""}],"EXCAVATE":[{"def":"To dig out and remove, as earth.","pos":""}],"EXCAVATION":[{"def":"The act of excavating, or of making hollow, by cutting, scooping, or digging out a part of a solid mass.","pos":""},{"def":"A cavity formed by cutting, digging, or scooping.","pos":""}],"EXCAVATOR":[{"def":"One who, or that which, excavates or hollows out; a machine, as a dredging machine, or a tool, for excavating.","pos":""}]}