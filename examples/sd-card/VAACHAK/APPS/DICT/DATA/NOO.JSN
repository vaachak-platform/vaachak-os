{"NOODLE":[{"def":"A simpleton; a blockhead; a stupid person; a ninny.","pos":""}],"NOOK":[{"def":"A narrow place formed by an angle in bodies or between bodies; a corner; a recess; a secluded retreat.","pos":""}],"NOOK-SHOTTEN":[{"def":"Full of nooks, angles, or corners.","pos":""},{"def":"Of or pertaining to noölogy.","pos":""}],"NOON":[{"def":"The middle of the day; midday; the time when the sun is in the meridian; twelve o'clock in the daytime.","pos":""},{"def":"Hence, the highest point; culmination.","pos":""}],"NOON-FLOWER":[{"def":"The goat's beard, whose flowers close at midday.","pos":""}],"NOONDAY":[{"def":"Midday; twelve o'clock in the day; noon.","pos":""}],"NOONING":[{"def":"A rest at noon; a repast at noon.","pos":""}],"NOONSTEAD":[{"def":"The position of the sun at noon.","pos":""}],"NOONTIDE":[{"def":"The time of noon; midday.","pos":""}],"NOOSE":[{"def":"A running knot, or loop, which binds the closer the more it is drawn.","pos":""}]}