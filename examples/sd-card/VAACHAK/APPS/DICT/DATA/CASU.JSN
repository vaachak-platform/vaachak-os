{"CASUAL":[{"def":"Happening or coming to pass without design, and without being foreseen or expected; accidental; fortuitous; coming by chance.","pos":""},{"def":"Coming without regularity; occasional; incidental; as, casual expenses.","pos":""}],"CASUALISM":[{"def":"The doctrine that all things exist or are controlled by chance.","pos":""}],"CASUALIST":[{"def":"One who believes in casualism.","pos":""}],"CASUALLY":[{"def":"Without design; accidentally; fortuitously; by chance; occasionally.","pos":""}],"CASUALNESS":[{"def":"The quality of being casual.","pos":""}],"CASUALTY":[{"def":"Numerical loss caused by death, wounds, discharge, or desertion.","pos":""}],"CASUARINA":[{"def":"A genus of leafles trees or shrubs, with drooping branchlets of a rushlike appearance, mostly natives of Australia.","pos":""}],"CASUIST":[{"def":"One who is skilled in, or given to, casuistry.","pos":""}],"CASUISTRY":[{"def":"Sophistical, equivocal, or false reasoning or teaching in regard to duties, obligations, and morals.","pos":""}],"CASUS":[{"def":"An event; an occurrence; an occasion; a combination of circumstances; a case; an act of God.","pos":""}]}