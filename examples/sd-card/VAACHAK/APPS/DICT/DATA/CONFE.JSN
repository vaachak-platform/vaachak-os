{"CONFECT":[{"def":"To prepare, as sweetmeats; to make a confection of.","pos":""},{"def":"To construct; to form; to mingle or mix.","pos":""}],"CONFECTION":[{"def":"A soft solid made by incorporating a medicinal substance or substances with sugar, sirup, or honey.","pos":""}],"CONFECTIONARY":[{"def":"He will take your daughters to be confectionaries, and to be cooks.","pos":""}],"CONFECTIONER":[{"def":"One whose occupation it is to make or sell confections, candies, etc.","pos":""}],"CONFECTIONERS' SUGAR":[{"def":"A highly refined sugar in impalpable powder, esp.","pos":""}],"CONFECTIONERY":[{"def":"Sweetmeats, in general; things prepared and sold by a confectioner; confections; candies.","pos":""},{"def":"A place where candies, sweetmeats, and similar things are made or sold.","pos":""}],"CONFECTORY":[{"def":"Pertaining to the art of making sweetmeats.","pos":""}],"CONFECTURE":[{"def":"Same as Confiture.","pos":""}],"CONFEDERACY":[{"def":"A combination of two or more persons to commit an unlawful act, or to do a lawful act by unlawful means.","pos":""}],"CONFEDERATE":[{"def":"Of or pertaining to the government of the eleven Southern States of the United States which (1860-1865) attempted to establish an independent nation styled the Confederate States of America; as, the Confederate congress; Confederate money.","pos":""}],"CONFEDERATION":[{"def":"The act of confederating; a league; a compact for mutual support; alliance, particulary of princes, nations, or states.","pos":""},{"def":"The parties that are confederated, considered as a unit; a confederacy.","pos":""}],"CONFEDERATIVE":[{"def":"Of or pertaining to a confederation.","pos":""}],"CONFER":[{"def":"To bring together for comparison; to compare.","pos":"verb"},{"def":"To grant as a possession; to bestow.","pos":"verb"}],"CONFEREE":[{"def":"One who is conferred with, or who takes part in a conference; as, the conferees on the part of the Senate.","pos":""},{"def":"One upon whom something is conferred.","pos":""}],"CONFERENCE":[{"def":"A stated meeting of preachers and others, invested with authority to take cognizance of ecclesiastical matters.","pos":""}],"CONFERENTIAL":[{"def":"Relating to conference.","pos":""}],"CONFERRABLE":[{"def":"Capable of being conferred.","pos":""}],"CONFERREE":[{"def":"Same as Conferee.","pos":""}],"CONFERRER":[{"def":"Closely united by the coalescence, or sticking together, of contiguous faces, as in the case of the cotyledons of the live-oak acorn.","pos":""}],"CONFERVA":[{"def":"Any unbranched, slender, green plant of the fresh-water algae.","pos":""}],"CONFERVACEOUS":[{"def":"Belonging to the confervae.","pos":""}],"CONFERVOID":[{"def":"Like, or related to, the confervae.","pos":""}],"CONFERVOUS":[{"def":"Pertaining to confervae; consisting of, or resembling, the confervae.","pos":""}],"CONFESS":[{"def":"To make acknowledgment or avowal in a matter pertaining to one's self; to acknowledge, own, or admit, as a crime, a fault, a debt.","pos":""},{"def":"To acknowledge faith in; to profess belief in.","pos":""}],"CONFESSANT":[{"def":"One who confesses to a priest.","pos":""}],"CONFESSARY":[{"def":"One who makes a confession.","pos":""}],"CONFESSEDLY":[{"def":"By confession; without denial.","pos":""}],"CONFESSER":[{"def":"One who makes a confession.","pos":""}],"CONFESSION":[{"def":"The act of disclosing sins or faults to a priest in order to obtain sacramental absolution.","pos":""},{"def":"An admission by a party to whom an act is imputed, in relation to such act.","pos":""}],"CONFESSIONAL":[{"def":"The recess, seat, or inclosed place, where a priest sits to hear confessions; often a small structure furnished with a seat for the priest and with a window or aperture so that the penitent who is outside may whisper into the priest's ear without being seen by him or heard by others.","pos":""}],"CONFESSIONALISM":[{"def":"An exaggerated estimate of the importance of giving full assent to any particular formula of the Christian faith.","pos":""}],"CONFESSIONALIST":[{"def":"A priest hearing, or sitting to hear, confession.","pos":""}],"CONFESSIONARY":[{"def":"Pertaining to auricular confession; as, a confessionary litany.","pos":""}],"CONFESSIONIST":[{"def":"One professing a certain faith.","pos":""}],"CONFESSOR":[{"def":"One who confesses; one who acknowledges a fault, or the truth of a charge, at the risk of suffering; specifically, one who confesses himself a follower of Christ and endures persecution for his faith.","pos":""},{"def":"A priest who hears the confessions of others and is authorized to grant them absolution.","pos":""}],"CONFESSORSHIP":[{"def":"The act or state of suffering persecution for religious faith.","pos":""}],"CONFETTI":[{"def":"Bonbons; sweetmeats; confections; also, plaster or paper imitations of, or substitutes for, bonbons, often used by carnival revelers, at weddings, etc.","pos":""},{"def":"One to whom secrets, especially those relating to affairs of love, are confided or intrusted; a confidential or bosom friend.","pos":""}]}