{"JUDAHITE":[{"def":"One of the tribe of Judah; a member of the kingdom of Judah; a Jew.","pos":""},{"def":"Of or pertaining to the Jews.","pos":""}],"JUDAICALLY":[{"def":"After the Jewish manner.","pos":""}],"JUDAISM":[{"def":"The religious doctrines and rites of the Jews as enjoined in the laws of Moses.","pos":""},{"def":"Conformity to the Jewish rites and ceremonies.","pos":""}],"JUDAIST":[{"def":"One who believes and practices Judaism.","pos":""}],"JUDAISTIC":[{"def":"Of or pertaining to Judaism.","pos":""}],"JUDAIZATION":[{"def":"The act of Judaizing; a conforming to the Jewish religion or ritual.","pos":""}],"JUDAIZE":[{"def":"To conform to the doctrines, observances, or methods of the Jews; to inculcate or impose Judaism.","pos":""}],"JUDAIZER":[{"def":"One who conforms to or inculcates Judaism; specifically, pl.","pos":""}],"JUDAIZERS":[{"def":"Ju\"da*iz`ers (ju\"day*iz`erz), n.","pos":""}],"JUDAS":[{"def":"The disciple who betrayed Christ.","pos":""},{"def":"Treacherous; betraying.","pos":""}],"JUDAS-COLORED":[{"def":"Red; -- from a tradition that Judas Iscariot had red hair and beard.","pos":""}],"JUDEAN":[{"def":"Of or pertaining to Judea.","pos":""},{"def":"A native of Judea; a Jew.","pos":""}],"JUDGE":[{"def":"A public officer who is invested with authority to hear and determine litigated causes, and to administer justice between parties in courts held for that purpose.","pos":""},{"def":"One of supreme magistrates, with both civil and military powers, who governed Israel for more than four hundred years.","pos":""}],"JUDGE-MADE":[{"def":"Created by judges or judicial decision; -- applied esp.","pos":""}],"JUDGESHIP":[{"def":"The office of a judge.","pos":""}],"JUDGMENT":[{"def":"The final award; the last sentence.","pos":""}],"JUDICABLE":[{"def":"Capable of being judged; capable of being tried or decided upon.","pos":""}],"JUDICATIVE":[{"def":"Having power to judge; judicial; as, the judicative faculty.","pos":""}],"JUDICATORY":[{"def":"Pertaining to the administration of justice; dispensing justice; judicial; as, judicatory tribunals.","pos":""}],"JUDICATURE":[{"def":"The state or profession of those employed in the administration of justice; also, the dispensing or administration of justice.","pos":""},{"def":"A court of justice; a judicatory.","pos":""}],"JUDICIAL":[{"def":"Pertaining or appropriate to courts of justice, or to a judge; practiced or conformed to in the administration of justice; sanctioned or ordered by a court; as, judicial power; judicial proceedings; a judicial sale.","pos":""},{"def":"Fitted or apt for judging or deciding; as, a judicial mind.","pos":""}],"JUDICIALLY":[{"def":"In a judicial capacity or judicial manner.","pos":""}],"JUDICIARY":[{"def":"Of or pertaining to courts of judicature, or legal tribunals; judicial; as, a judiciary proceeding.","pos":""}],"JUDICIOUS":[{"def":"Of or relating to a court; judicial.","pos":""}],"JUDICIOUSLY":[{"def":"In a judicious manner; with good judgment; wisely.","pos":""}]}