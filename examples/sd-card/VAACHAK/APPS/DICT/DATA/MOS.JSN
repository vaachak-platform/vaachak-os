{"MOSAIC":[{"def":"A surface decoration made by inlaying in patterns small pieces of variously colored glass, stone, or other material; -- called also mosaic work.","pos":""}],"MOSAICAL":[{"def":"Mosaic (in either sense).","pos":""}],"MOSAICALLY":[{"def":"In the manner of a mosaic.","pos":""}],"MOSAISM":[{"def":"Attachment to the system or doctrines of Moses; that which is peculiar to the Mosaic system or doctrines.","pos":""},{"def":"One of an extinct order of reptiles, including Mosasaurus and allied genera.","pos":""}],"MOSASAURIA":[{"def":"An order of large, extinct, marine reptiles, found in the Cretaceous rocks, especially in America.","pos":""}],"MOSASAURUS":[{"def":"A genus of extinct marine reptiles allied to the lizards, but having the body much elongated, and the limbs in the form of paddles.","pos":""}],"MOSCHATEL":[{"def":"A plant of the genus Adoxa (A.","pos":""}],"MOSCHINE":[{"def":"Of or pertaining to Moschus, a genus including the musk deer.","pos":""}],"MOSELLE":[{"def":"A light wine, usually white, produced in the vicinity of the river Moselle.","pos":""}],"MOSES":[{"def":"A large flatboat, used in the West Indies for taking freight from shore to ship.","pos":""}],"MOSEY":[{"def":"To go, or move (in a certain manner); -- usually with out, off, along, etc.","pos":""}],"MOSLEM":[{"def":"A Mussulman; an orthodox Mohammedan.","pos":""}],"MOSLINGS":[{"def":"Thin shreds of leather shaved off in dressing skins.","pos":""}],"MOSOSAURUS":[{"def":"Same as Mosasaurus.","pos":""}],"MOSQUE":[{"def":"A Mohammedan church or place of religious worship.","pos":""}],"MOSQUITO":[{"def":"Any one of various species of gnats of the genus Culex and allied genera.","pos":""}],"MOSS":[{"def":"A cryptogamous plant of a cellular structure, with distinct stem and simple leaves.","pos":""}],"MOSS-GROWN":[{"def":"Overgrown with moss.","pos":""}],"MOSSBACK":[{"def":"A veteran partisan; one who is so conservative in opinion that he may be likened to a stone or old tree covered with moss.","pos":""}],"MOSSINESS":[{"def":"The state of being mossy.","pos":""}],"MOSSTROOPER":[{"def":"One of a class of marauders or bandits that formerly infested the border country between England and Scotland; -- so called in allusion to the mossy or boggy character of much of the border country.","pos":""}],"MOSSY":[{"def":"Overgrown with moss; abounding with or edged with moss; as, mossy trees; mossy streams.","pos":""},{"def":"Resembling moss; as, mossy green.","pos":""}],"MOST":[{"def":"Consisting of the greatest number or quantity; greater in number or quantity than all the rest; nearly all.","pos":""},{"def":"Greatest in degree; as, he has the most need of it.","pos":""}],"MOSTE":[{"def":"A painter's maul-stick.","pos":""}],"MOSTLY":[{"def":"For the greatest part; for the most part; chiefly; in the main.","pos":""}],"MOSTWHAT":[{"def":"For the most part.","pos":""}]}