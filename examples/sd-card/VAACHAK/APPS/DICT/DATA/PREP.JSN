{"PREPARABLE":[{"def":"Capable of being prepared.","pos":""}],"PREPARATION":[{"def":"The holding over of a note from one chord into the next chord, where it forms a temporary discord, until resolved in the chord that follows; the anticipation of a discordant note in the preceding concord, so that the ear is prepared for the shock.","pos":""}],"PREPARATIVE":[{"def":"Tending to prepare or make ready; having the power of preparing, qualifying, or fitting; preparatory.","pos":""}],"PREPARATIVELY":[{"def":"By way of preparation.","pos":""}],"PREPARATOR":[{"def":"One who prepares beforehand, as subjects for dissection, specimens for preservation in collections, etc.","pos":""}],"PREPARATORY":[{"def":"Preparing the way for anything by previous measures of adaptation; antecedent and adapted to what follows; introductory; preparative; as, a preparatory school; a preparatory condition.","pos":""}],"PREPARE":[{"def":"To fit, adapt, or qualify for a particular purpose or condition; to make ready; to put into a state for use or application; as, to prepare ground for seed; to prepare a lesson.","pos":""},{"def":"To procure as suitable or necessary; to get ready; to provide; as, to prepare ammunition and provisions for troops; to prepare ships for defence; to prepare an entertainment.","pos":""}],"PREPARED":[{"def":"Made fit or suitable; adapted; ready; as, prepared food; prepared questions.","pos":""}],"PREPARER":[{"def":"One who, or that which, prepares, fits, or makes ready.","pos":""}],"PREPAY":[{"def":"To pay in advance, or beforehand; as, to prepay postage.","pos":""}],"PREPAYMENT":[{"def":"Payment in advance.","pos":""}],"PREPENIAL":[{"def":"Situated in front of, or anterior to, the penis.","pos":""}],"PREPENSE":[{"def":"To weigh or consider beforehand; to premeditate.","pos":""}],"PREPENSELY":[{"def":"In a premeditated manner.","pos":""},{"def":"The quality or state of being prepollent; superiority of power; predominance; prevalence.","pos":""}],"PREPOLLENT":[{"def":"Having superior influence or power; prevailing; predominant.","pos":""}],"PREPONDER":[{"def":"To preponderate [Obs.","pos":""},{"def":"The excess of weight of that part of a canon behind the trunnions over that in front of them.","pos":""}],"PREPONDERANT":[{"def":"Preponderating; outweighing; overbalancing; -- used literally and figuratively; as, a preponderant weight; of preponderant importance.","pos":""}],"PREPONDERATE":[{"def":"To outweigh; to overpower by weight; to exceed in weight; to overbalance.","pos":""},{"def":"To overpower by stronger or moral power.","pos":""}],"PREPONDERATINGLY":[{"def":"In a preponderating manner; preponderantly.","pos":""}],"PREPONDERATION":[{"def":"The act or state of preponderating; preponderance; as, a preponderation of reasons.","pos":""}],"PREPOSE":[{"def":"To place or set before; to prefix.","pos":""}],"PREPOSITION":[{"def":"A proposition; an exposition; a discourse.","pos":""}],"PREPOSITIONAL":[{"def":"Of or pertaining to a preposition; of the nature of a preposition.","pos":""}],"PREPOSITIVE":[{"def":"Put before; prefixed; as, a prepositive particle.","pos":""},{"def":"A prepositive word.","pos":""}],"PREPOSITOR":[{"def":"A scholar appointed to inspect other scholars; a monitor.","pos":""}],"PREPOSITURE":[{"def":"The office or dignity of a provost; a provostship.","pos":""}],"PREPOSSESS":[{"def":"To preoccupy, as ground or land; to take previous possession of.","pos":""},{"def":"To preoccupy, as the mind or heart, so as to preclude other things; hence, to bias or prejudice; to give a previous inclination to, for or against anything; esp.","pos":""}],"PREPOSSESSING":[{"def":"Tending to invite favor; attracting confidence, favor, esteem, or love; attractive; as, a prepossessing manner.","pos":""}],"PREPOSSESSION":[{"def":"Preoccupation; prior possession.","pos":""},{"def":"Preoccupation of the mind by an opinion, or impression, already formed; preconceived opinion; previous impression; bias; -- generally, but not always, used in a favorable sense; as, the prepossessions of childhood.","pos":""}],"PREPOSSESSOR":[{"def":"One who possesses, or occupies, previously.","pos":""}],"PREPOSTEROUS":[{"def":"Having that first which ought to be last; inverted in order.","pos":""},{"def":"Contrary to nature or reason; not adapted to the end; utterly and glaringly foolish; unreasonably absurd; perverted.","pos":""}],"PREPOTENCY":[{"def":"The capacity, on the part of one of the parents, as compared with the other, to transmit more than his or her own share of characteristics to their offspring.","pos":""}],"PREPOTENT":[{"def":"Characterized by prepotency.","pos":""}],"PREPROVIDE":[{"def":"To provide beforehand.","pos":""}],"PREPUBIC":[{"def":"Situated in front of, or anterior to, the pubis; pertaining to the prepubis.","pos":""}],"PREPUBIS":[{"def":"A bone or cartilage, of some animals, situated in the middle line in front of the pubic bones.","pos":""}],"PREPUTIAL":[{"def":"Of or pertaining to the prepuce.","pos":""},{"def":"The doctrine or practice of a school of modern painters who profess to be followers of the painters before Raphael.","pos":""}]}