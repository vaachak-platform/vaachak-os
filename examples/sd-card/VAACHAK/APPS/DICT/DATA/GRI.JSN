{"GRIBBLE":[{"def":"A small marine isopod crustacean (Limnoria lignorum or L.","pos":""}],"GRICE":[{"def":"See Gree, a step.","pos":""}],"GRID":[{"def":"A grating of thin parallel bars, similar to a gridiron.","pos":""}],"GRIDDLE":[{"def":"An iron plate or pan used for cooking cakes.","pos":""},{"def":"A sieve with a wire bottom, used by miners.","pos":""}],"GRIDDLECAKE":[{"def":"A cake baked or fried on a griddle, esp.","pos":""}],"GRIDE":[{"def":"To cut with a grating sound; to cut; to penetrate or pierce harshly; as, the griding sword.","pos":""}],"GRIDELIN":[{"def":"A color mixed of white, and red, or a gray violet.","pos":""}],"GRIDIRON":[{"def":"An openwork frame on which vessels are placed for examination, cleaning, and repairs.","pos":""},{"def":"A football field.","pos":""}],"GRIEF":[{"def":"Pain of mind on account of something in the past; mental suffering arising from any cause, as misfortune, loss of friends, misconduct of one's self or others, etc.","pos":""},{"def":"Cause of sorrow or pain; that which afficts or distresses; trial; grievance.","pos":""}],"GRIEFFUL":[{"def":"Full of grief or sorrow.","pos":""}],"GRIEVANCE":[{"def":"A cause of uneasiness and complaint; a wrong done and suffered; that which gives ground for remonstrance or resistance, as arising from injustice, tyranny, etc.","pos":""},{"def":"Grieving; grief; affliction.","pos":""}],"GRIEVANCER":[{"def":"One who occasions a grievance; one who gives ground for complaint.","pos":""},{"def":"A manager of a farm, or overseer of any work; a reeve; a manorial bailiff.","pos":""}],"GRIEVE":[{"def":"To occasion grief to; to wound the sensibilities of; to make sorrowful; to cause to suffer; to affect; to hurt; to try.","pos":""},{"def":"To sorrow over; as, to grieve one's fate.","pos":""}],"GRIEVER":[{"def":"One who, or that which, grieves.","pos":""}],"GRIEVING":[{"def":"Sad; sorrowful; causing grief.","pos":""},{"def":"The act of causing grief; the state of being grieved.","pos":""}],"GRIEVOUS":[{"def":"Causing grief or sorrow; painful; afflictive; hard to bear; offensive; harmful.","pos":""},{"def":"Characterized by great atrocity; heinous; aggravated; flagitious; as, a grievous sin.","pos":""}],"GRIFF":[{"def":"An arrangement of parallel bars for lifting the hooked wires which raise the warp threads in a loom for weaving figured goods.","pos":""}],"GRIFFE":[{"def":"The offspring of a mulatto woman and a negro; also, a mulatto.","pos":""}],"GRIFFIN":[{"def":"An Anglo-Indian name for a person just arrived from Europe.","pos":""},{"def":"A fabulous monster, half lion and half eagle.","pos":""}],"GRIL":[{"def":"Harah; hard; severe; stern; rough.","pos":""}],"GRILL":[{"def":"That which is broiled on a gridiron, as meat, fish, etc.","pos":""}],"GRILLADE":[{"def":"The act of grilling; also, that which is grilled.","pos":""}],"GRILLAGE":[{"def":"A framework of sleepers and crossbeams forming a foundation in marshy or treacherous soil.","pos":""}],"GRILLE":[{"def":"A lattice or grating.","pos":""}],"GRILLROOM":[{"def":"A room specially fitted for broiling food, esp.","pos":""}],"GRILLY":[{"def":"To broil; to grill; hence, To harass.","pos":""}],"GRILSE":[{"def":"A young salmon after its first return from the sea.","pos":""}],"GRIM":[{"def":"Of forbidding or fear-inspiring aspect; fierce; stern; surly; cruel; frightful; horrible.","pos":""}],"GRIMACE":[{"def":"A distortion of the countenance, whether habitual, from affectation, or momentary aad occasional, to express some feeling, as contempt, disapprobation, complacency, etc.","pos":""}],"GRIMACED":[{"def":"Distorted; crabbed.","pos":""}],"GRIMALKIN":[{"def":"An old cat, esp.","pos":""}],"GRIME":[{"def":"Foul matter; dirt, rubbed in; sullying blackness, deeply ingrained.","pos":""}],"GRIMILY":[{"def":"In a grimy manner.","pos":""}],"GRIMINESS":[{"def":"The state of being grimy.","pos":""}],"GRIMLY":[{"def":"Grim; hideous; stern.","pos":""}],"GRIMME":[{"def":"A West African antelope (Cephalophus rufilotus) of a deep bay color, with a broad dorsal stripe of black; -- called also conquetoon.","pos":""}],"GRIMNESS":[{"def":"Fierceness of look; sternness; crabbedness; forbiddingness.","pos":""}],"GRIMY":[{"def":"Full of grime; begrimed; dirty; foul.","pos":""}],"GRIN":[{"def":"Like a bird that hasteth to his grin.","pos":""}],"GRIND":[{"def":"To reduce to powder by friction, as in a mill, or with the teeth; to crush into small fragments; to produce as by the action of millstones.","pos":""},{"def":"To wear down, polish, or sharpen, by friction; to make smooth, sharp, or pointed; to whet, as a knife or drill; to rub against one another, as teeth, etc.","pos":""}],"GRINDELIA":[{"def":"The dried stems and leaves of tarweed (Grindelia), used as a remedy in asthma and bronchitis.","pos":""}],"GRINDER":[{"def":"The restless flycatcher (Seisura inquieta) of Australia; -- called also restless thrush and volatile thrush.","pos":""}],"GRINDERY":[{"def":"Leather workers' materials.","pos":""}],"GRINDINGLY":[{"def":"In a grinding manner.","pos":""}],"GRINDLE":[{"def":"The bowfin; -- called also Johnny Grindle.","pos":""}],"GRINDSTONE":[{"def":"A flat, circular stone, revolving on an axle, for grinding or sharpening tools, or shaping or smoothing objects.","pos":""}],"GRINGO":[{"def":"Among Spanish Americans, a foreigner, esp.","pos":""}],"GRINNINGLY":[{"def":"In a grinning manner.","pos":""}],"GRINT":[{"def":"Grint, Defn: 3d pers.","pos":""}],"GRIP":[{"def":"A small ditch or furrow.","pos":""}],"GRIP CAR":[{"def":"A car with a grip to clutch a traction cable.","pos":""}],"GRIPE":[{"def":"A vulture; the griffin.","pos":""}],"GRIPEFUL":[{"def":"Disposed to gripe; extortionate.","pos":""}],"GRIPER":[{"def":"One who gripes; an oppressor; an extortioner.","pos":""}],"GRIPINGLY":[{"def":"In a griping or oppressive manner.","pos":""}],"GRIPMAN":[{"def":"The man who manipulates a grip.","pos":""}],"GRIPPE":[{"def":"The influenza or epidemic catarrh.","pos":""}],"GRIPPER":[{"def":"In printing presses, the fingers or nippers.","pos":""}],"GRIPPLE":[{"def":"A grasp; a gripe.","pos":""}],"GRIPPLENESS":[{"def":"The quality of being gripple.","pos":""}],"GRIPSACK":[{"def":"A traveler's handbag.","pos":""}],"GRIS":[{"def":"A costly kind of fur.","pos":""}],"GRISAILLE":[{"def":"Decorative painting in gray monochrome; -- used in English especially for painted glass.","pos":""}],"GRISE":[{"def":"See Grice, a pig.","pos":""}],"GRISEOUS":[{"def":"Of a light color, or white, mottled with black or brown; grizzled or grizzly.","pos":""}],"GRISETTE":[{"def":"A French girl or young married woman of the lower class; more frequently, a young working woman who is fond of gallantry.","pos":""}],"GRISKIN":[{"def":"The spine of a hog.","pos":""}],"GRISLINESS":[{"def":"The quality or state of being grisly; horrid.","pos":""}],"GRISLY":[{"def":"Frightful; horrible; dreadful; harsh; as, grisly locks; a grisly specter.","pos":""}],"GRISON":[{"def":"American monkey (Lagothrix infumatus), said to be gluttonous.","pos":""}],"GRISONS":[{"def":"The largest and most eastern of the Swiss cantons.","pos":""}],"GRIST":[{"def":"Ground corn; that which is ground at one time; as much grain as is carried to the mill at one time, or the meal it produces.","pos":""},{"def":"Supply; provision.","pos":""}],"GRISTLY":[{"def":"Consisting of, or containing, gristle; like gristle; cartilaginous.","pos":""}],"GRISTMILL":[{"def":"A mill for grinding grain; especially, a mill for grinding grists, or portions of grain brought by different customers; a custom mill.","pos":""}],"GRIT":[{"def":"A hard, coarse-grained siliceous sandstone; as, millstone grit; -- called also gritrock and gritstone.","pos":""}],"GRITH":[{"def":"Peace; security; agreement.","pos":""}],"GRITTINESS":[{"def":"The quality of being gritty.","pos":""}],"GRITTY":[{"def":"Containing sand or grit; consisting of grit; caused by grit; full of hard particles.","pos":""},{"def":"Spirited; resolute; unyielding.","pos":""}],"GRIVET":[{"def":"A monkey of the upper Nile and Abyssinia (Cercopithecus griseoviridis), having the upper parts dull green, the lower parts white, the hands, ears, and face black.","pos":""}],"GRIZE":[{"def":"Same as 2d Grise.","pos":""}],"GRIZZLE":[{"def":"Gray; a gray color; a mixture of white and black.","pos":""}],"GRIZZLED":[{"def":"Gray; grayish; sprinkled or mixed with gray; of a mixed white and black.","pos":""}],"GRIZZLY":[{"def":"Somewhat gray; grizzled.","pos":""}]}