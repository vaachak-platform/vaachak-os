{"REPTANT":[{"def":"Creeping; crawling; -- said of reptiles, worms, etc.","pos":""}],"REPTANTIA":[{"def":"A divisiom of gastropods; the Pectinibranchiata.","pos":"noun"}],"REPTATION":[{"def":"The act of creeping.","pos":""}],"REPTATORY":[{"def":"Rep\"ta*to*ry (rp\"t-t-r), a.","pos":""}],"REPTILE":[{"def":"Creeping; moving on the belly, or by means of small and short legs.","pos":""},{"def":"Hence: Groveling; low; vulgar; as, a reptile race or crew; reptile vices.","pos":""}],"REPTILIA":[{"def":"A class of air-breathing oviparous vertebrates, usually covered with scales or bony plates.","pos":"noun"}],"REPTILIAN":[{"def":"Belonging to the reptiles.","pos":""}]}