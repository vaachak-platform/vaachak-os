{"CONSCIENCE":[{"def":"Knowledge of one's own thoughts or actions; consciousness.","pos":""},{"def":"The faculty, power, or inward principle which decides as to the character of one's own actions, purposes, and affections, warning against and condemning that which is wrong, and approving and prompting to that which is right; the moral faculty passing judgment on one's self; the moral sense.","pos":""}],"CONSCIENCED":[{"def":"Having a conscience.","pos":""}],"CONSCIENCELESS":[{"def":"Without conscience; indifferent to conscience; unscrupulous.","pos":""}],"CONSCIENTIOUS":[{"def":"Influenced by conscience; governed by a strict regard to the dictates of conscience, or by the known or supposed rules of right and wrong; -- said of a person.","pos":""},{"def":"Characterized by a regard to conscience; conformed to the dictates of conscience; -- said of actions.","pos":""}],"CONSCIENTIOUSLY":[{"def":"In a conscientious manner; as a matter of conscience; hence; faithfully; accurately; completely.","pos":""}],"CONSCIENTIOUSNESS":[{"def":"The quality of being conscientious; a scrupulous regard to the dictates of conscience.","pos":""}],"CONSCIONABLE":[{"def":"Governed by, or according to, conscience; reasonable; just.","pos":""}],"CONSCIONABLENESS":[{"def":"The quality of being conscionable; reasonableness.","pos":""}],"CONSCIONABLY":[{"def":"Reasonably; justly.","pos":""}],"CONSCIOUS":[{"def":"Possessing the faculty of knowing one's own thoughts or mental operations.","pos":""},{"def":"Possessing knowledge, whether by internal, conscious experience or by external observation; cognizant; aware; sensible.","pos":""}],"CONSCIOUSLY":[{"def":"In a conscious manner; with knowledge of one's own mental operations or actions.","pos":""}],"CONSCIOUSNESS":[{"def":"The state of being conscious; knowledge of one's own existence, condition, sensations, mental operations, acts, etc.","pos":""},{"def":"Immediate knowledge or perception of the presence of any object, state, or sensation.","pos":""}],"CONSCRIBE":[{"def":"To enroll; to enlist.","pos":""}],"CONSCRIPT":[{"def":"Enrolled; written; registered.","pos":""}],"CONSCRIPTION":[{"def":"An enrolling or registering.","pos":""},{"def":"A compulsory enrollment of men for military or naval service; a draft.","pos":""}]}