{"CILIA":[{"def":"Small, generally microscopic, vibrating appendages lining certain organs, as the air passages of the higher animals, and in the lower animals often covering also the whole or a part of the exterior.","pos":""}],"CILIARY":[{"def":"Pertaining to the cilia, or eyelashes.","pos":""},{"def":"Pertaining to or connected with the cilia in animal or vegetable organisms; as, ciliary motion.","pos":""}],"CILIATA":[{"def":"One of the orders of Infusoria, characterized by having cilia.","pos":""},{"def":"Provided with, or surrounded by, cilia; as, a ciliate leaf; endowed with vibratory motion; as, the ciliated epithelium of the windpipe.","pos":""}],"CILICE":[{"def":"A kind of haircloth undergarment.","pos":""}],"CILICIAN":[{"def":"Of or pertaining to Cilicia in Asia Minor.","pos":""},{"def":"A native or inhabitant of Cilicia.","pos":""}],"CILICIOUS":[{"def":"Made, or consisting, of hair.","pos":""},{"def":"Having the form of cilia; very fine or slender.","pos":""}],"CILIOGRADE":[{"def":"Moving by means of cilia, or cilialike organs; as, the ciliograde Medusæ.","pos":""}],"CILLOSIS":[{"def":"A spasmodic trembling of the upper eyelid.","pos":""}]}