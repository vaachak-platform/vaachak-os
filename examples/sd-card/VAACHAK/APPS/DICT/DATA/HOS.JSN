{"HOSANNA":[{"def":"A Hebrew exclamation of praise to the Lord, or an invocation of blessings.","pos":""}],"HOSE":[{"def":"Close-fitting trousers or breeches, as formerly worn, reaching to the knee.","pos":""},{"def":"Covering for the feet and lower part of the legs; a stocking or stockings.","pos":""}],"HOSIER":[{"def":"One who deals in hose or stocking, or in goods knit or woven like hose.","pos":""}],"HOSIERY":[{"def":"The business of a hosier.","pos":""},{"def":"Stockings, in general; goods knit or woven like hose.","pos":""}],"HOSPICE":[{"def":"A convent or monastery which is also a place of refuge or entertainment for travelers on some difficult road or pass, as in the Alps; as, the Hospice of the Great St.","pos":""}],"HOSPITABLE":[{"def":"Receiving and entertaining strangers or guests with kindness and without reward; kind to strangers and guests; characterized by hospitality.","pos":""},{"def":"Proceeding from or indicating kindness and generosity to guests and strangers; as, hospitable rites.","pos":""}],"HOSPITABLENESS":[{"def":"The quality of being hospitable; hospitality.","pos":""}],"HOSPITABLY":[{"def":"In a hospitable manner.","pos":""}],"HOSPITAL":[{"def":"A place for shelter or entertainment; an inn.","pos":""}],"HOSPITALER":[{"def":"One residing in a hospital, for the purpose of receiving the poor, the sick, and strangers.","pos":""},{"def":"One of an order of knights who built a hospital at Jerusalem for pilgrims, A.","pos":""}],"HOSPITALISM":[{"def":"A vitiated condition of the body, due to long confinement in a hospital, or the morbid condition of the atmosphere of a hospital.","pos":""}],"HOSPITALITY":[{"def":"The act or practice of one who is hospitable; reception and entertainment of strangers or guests without reward, or with kind and generous liberality.","pos":""}],"HOSPITALIZE":[{"def":"To render (a building) unfit for habitation, by long continued use as a hospital.","pos":""}],"HOSPITATE":[{"def":"To receive hospitality; to be a guest.","pos":""}],"HOSPITIUM":[{"def":"An inn of court.","pos":""}],"HOSPODAR":[{"def":"A title borne by the princes or governors of Moldavia and Wallachia before those countries were united as Roumania.","pos":""}],"HOST":[{"def":"The consecrated wafer, believed to be the body of Christ, which in the Mass is offered as a sacrifice; also, the bread before consecration.","pos":""}],"HOST PLANT":[{"def":"A plant which aids, shelters, or protects another plant in its growth, as those which are used for nurse crops.","pos":""}],"HOSTAGE":[{"def":"A person given as a pledge or security for the performance of the conditions of a treaty or stipulations of any kind, on the performance of which the person is to be released.","pos":""}],"HOSTEL":[{"def":"A small, unendowed college in Oxford or Cambridge.","pos":""}],"HOSTELER":[{"def":"The keeper of a hostel or inn.","pos":""},{"def":"A student in a hostel, or small unendowed collede in Oxford or Cambridge.","pos":""}],"HOSTELRY":[{"def":"An inn; a lodging house.","pos":""}],"HOSTESS":[{"def":"A female host; a woman who hospitably entertains guests at her house.","pos":""},{"def":"A woman who entertains guests for compensation; a female innkeeper.","pos":""}],"HOSTESS-SHIP":[{"def":"The character, personality, or office of a hostess.","pos":""}],"HOSTIE":[{"def":"The consecrated wafer; the host.","pos":""}],"HOSTILE":[{"def":"Belonging or appropriate to an enemy; showing the disposition of an enemy; showing ill will and malevolence, or a desire to thwart and injure; occupied by an enemy or enemies; inimical; unfriendly; as, a hostile force; hostile intentions; a hostile country; hostile to a sudden change.","pos":""}],"HOSTILELY":[{"def":"In a hostile manner.","pos":""}],"HOSTILITY":[{"def":"State of being hostile; public or private enemy; unfriendliness; animosity.","pos":""},{"def":"An act of an open enemy; a hostile deed; especially in the plural, acts of warfare; attacks of an enemy.","pos":""}],"HOSTILIZE":[{"def":"To make hostile; to cause to become an enemy.","pos":""}],"HOSTING":[{"def":"An encounter; a battle.","pos":""},{"def":"A muster or review.","pos":""}],"HOSTLER":[{"def":"The person who takes charge of a locomotive when it is left by the engineer after a trip.","pos":""}],"HOSTRY":[{"def":"A hostelry; an inn or lodging house.","pos":""},{"def":"A stable for horses.","pos":""}]}