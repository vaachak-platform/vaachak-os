{"SUE":[{"def":"To clean, as the beak; -- said of a hawk.","pos":""},{"def":"To leave high and dry on shore; as, to sue a ship.","pos":""}],"SUEDE":[{"def":"Swedish glove leather, --usually made from lambskins tanned with willow bark.","pos":""}],"SUENT":[{"def":"Uniformly or evenly distributed or spread; even; smooth.","pos":""}],"SUENTLY":[{"def":"Evenly; smoothly.","pos":""}],"SUER":[{"def":"One who sues; a suitor.","pos":""}],"SUET":[{"def":"The fat and fatty tissues of an animal, especially the harder fat about the kidneys and loins in beef and mutton, which, when melted and freed from the membranes, forms tallow.","pos":""}],"SUETY":[{"def":"Consisting of, or resembling, suet; as, a suety substance.","pos":""}]}