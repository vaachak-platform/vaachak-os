{"TERRA":[{"def":"The earth; earth.","pos":""}],"TERRA INCOGNITA":[{"def":"An unknown land; unexplored country.","pos":""}],"TERRACE":[{"def":"A level plain, usually with a steep front, bordering a river, a lake, or sometimes the sea.","pos":""}],"TERRACULTURE":[{"def":"Cultivation on the earth; agriculture.","pos":""}],"TERRANE":[{"def":"A group of rocks having a common age or origin; -- nearly equivalent to formation, but used somewhat less comprehensively.","pos":""}],"TERRAPIN":[{"def":"Any one of numerous species of tortoises living in fresh and brackish waters.","pos":""}],"TERRAQUEOUS":[{"def":"Consisting of land and water; as, the earth is a terraqueous globe.","pos":""}],"TERRAR":[{"def":"See 2d Terrier, 2.","pos":""}],"TERRE-TENANT":[{"def":"One who has the actual possession of land; the occupant.","pos":""}],"TERRE-VERTE":[{"def":"An olive-green earth used as a pigment.","pos":""}],"TERREITY":[{"def":"Quality of being earthy; earthiness.","pos":""}],"TERREL":[{"def":"A spherical magnet so placed that its poles, equator, etc.","pos":""}],"TERRENE":[{"def":"Of or pertaining to the earth; earthy; as, terrene substance.","pos":""},{"def":"Earthy; terrestrial.","pos":""}],"TERRENITY":[{"def":"Earthiness; worldliness.","pos":""}],"TERREOUS":[{"def":"Consisting of earth; earthy; as, terreous substances; terreous particles.","pos":""}],"TERREPLEIN":[{"def":"The top, platform, or horizontal surface, of a rampart, on which the cannon are placed.","pos":""}],"TERRESTRE":[{"def":"Terrestrial; earthly.","pos":""}],"TERRESTRIAL":[{"def":"Of or pertaining to the earth; existing on the earth; earthly; as, terrestrial animals.","pos":""},{"def":"Representing, or consisting of, the earth; as, a terrestrial globe.","pos":""}],"TERRESTRIFY":[{"def":"To convert or reduce into a condition like that of the earth; to make earthy.","pos":""}],"TERRET":[{"def":"One of the rings on the top of the saddle of a harness, through which the reins pass.","pos":""}],"TERRIBLE":[{"def":"Adapted or likely to excite terror, awe, or dread; dreadful; formidable.","pos":""},{"def":"Excessive; extreme; severe.","pos":""}],"TERRICOLAE":[{"def":"A division of annelids including the common earthworms and allied species.","pos":""}],"TERRIER":[{"def":"An auger or borer.","pos":""}],"TERRIFIC":[{"def":"Causing terror; adapted to excite great fear or dread; terrible; as, a terrific form; a terrific sight.","pos":""}],"TERRIFICALLY":[{"def":"In a terrific manner.","pos":""}],"TERRIFY":[{"def":"To make terrible.","pos":""},{"def":"To alarm or shock with fear; to frighten.","pos":""}],"TERRIGENOUS":[{"def":"Earthborn; produced by the earth.","pos":""}],"TERRINE":[{"def":"A dish or pan, originally of earthenware, such as those in which various dishes are cooked and served; esp.","pos":""}],"TERRITORIAL":[{"def":"Of or pertaining to territory or land; as, territorial limits; territorial jurisdiction.","pos":""},{"def":"Limited to a certain district; as, right may be personal or territorial.","pos":""}],"TERRITORIAL WATERS":[{"def":"The waters under the territorial jurisdiction of a state; specif.","pos":""}],"TERRITORIALIZE":[{"def":"To enlarge by extension of territory.","pos":""},{"def":"To reduce to the condition of a territory.","pos":""}],"TERRITORIALLY":[{"def":"In regard to territory; by means of territory.","pos":""}],"TERRITORIED":[{"def":"Possessed of territory.","pos":""}],"TERRITORY":[{"def":"A large extent or tract of land; a region; a country; a district.","pos":""},{"def":"The extent of land belonging to, or under the dominion of, a prince, state, or other form of government; often, a tract of land lying at a distance from the parent country or from the seat of government; as, the territory of a State; the territories of the East India Company.","pos":""}],"TERROR":[{"def":"Extreme fear; fear that agitates body and mind; violent dread; fright.","pos":""},{"def":"That which excites dread; a cause of extreme fear.","pos":""}],"TERRORISM":[{"def":"The act of terrorizing, or state of being terrorized; a mode of government by terror or intimidation.","pos":""},{"def":"The practise of coercing governments to accede to political demands by committing violence on civilian targets; any similar use of violence to achieve goals.","pos":""}],"TERRORIST":[{"def":"One who governs by terrorism or intimidation; specifically, an agent or partisan of the revolutionary tribunal during the Reign of Terror in France.","pos":""}],"TERRORIZE":[{"def":"To impress with terror; to coerce by intimidation.","pos":""}],"TERRORLESS":[{"def":"Free from terror.","pos":""}],"TERRY":[{"def":"A kind of heavy colored fabric, either all silk, or silk and worsted, or silk and cotton, often called terry velvet, used for upholstery and trimmings.","pos":""}]}