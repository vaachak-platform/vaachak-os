{"ROGATION":[{"def":"The demand, by the consuls or tribunes, of a law to be passed by the people; a proposed law or decree.","pos":""},{"def":"Litany; supplication.","pos":""}],"ROGATORY":[{"def":"Seeking information; authorized to examine witnesses or ascertain facts; as, a rogatory commission.","pos":""}],"ROGER":[{"def":"A black flag with white skull and crossbones, formerly used by pirates; -- called also Jolly Roger.","pos":""}],"ROGUE":[{"def":"A vagrant; an idle, sturdy beggar; a vagabond; a tramp.","pos":""},{"def":"A worthless plant occuring among seedlings of some choice variety.","pos":""}],"ROGUERY":[{"def":"The life of a vargant.","pos":""},{"def":"The practices of a rogue; knavish tricks; cheating; fraud; dishonest practices.","pos":""}],"ROGUESHIP":[{"def":"The quality or state of being a rogue.","pos":""}],"ROGUISH":[{"def":"Resembling, or characteristic of, a rogue; knavish.","pos":""}]}