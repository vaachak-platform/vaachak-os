{"CARNAGE":[{"def":"Flesh of slain animals or men.","pos":""},{"def":"Great destruction of life, as in battle; bloodshed; slaughter; massacre; murder; havoc.","pos":""}],"CARNAL":[{"def":"Of or pertaining to the body or is appetites; animal; fleshly; sensual; given to sensual indulgence; lustful; human or worldly as opposed to spiritual.","pos":""},{"def":"Flesh-devouring; cruel; ravenous; bloody.","pos":""}],"CARNAL-MINDEDNESS":[{"def":"Grossness of mind.","pos":""}],"CARNALISM":[{"def":"The state of being carnal; carnality; sensualism.","pos":""}],"CARNALITY":[{"def":"The state of being carnal; fleshly lust, or the indulgence of lust; grossness of mind.","pos":""}],"CARNALIZE":[{"def":"To make carnal; to debase to carnality.","pos":""}],"CARNALLITE":[{"def":"A hydrous chloride of potassium and magnesium, sometimes found associated with deposits of rock salt.","pos":""}],"CARNALLY":[{"def":"According to the flesh, to the world, or to human nature; in a manner to gratify animal appetites and lusts; sensually.","pos":""}],"CARNARY":[{"def":"A vault or crypt in connection with a church, used as a repository for human bones disintered from their original burial places; a charnel house.","pos":""}],"CARNASSIAL":[{"def":"Adapted to eating flesh.","pos":""},{"def":"A carnassial tooth; especially, the last premolar in many carnivores.","pos":""}],"CARNATE":[{"def":"Invested with, or embodied in, flesh.","pos":""}],"CARNATION":[{"def":"Those parts of a picture in which the human body or any part of it is represented in full color; the flesh tints.","pos":""},{"def":"A species of Dianthus (D.","pos":""}],"CARNATIONED":[{"def":"Having a flesh color.","pos":""}],"CARNAUBA":[{"def":"The Brazilian wax palm.","pos":""}],"CARNELIAN":[{"def":"A variety of chalcedony, of a clear, deep red, flesh red, or reddish white color.","pos":""}],"CARNEOUS":[{"def":"Consisting of, or like, flesh; carnous; fleshy.","pos":""}],"CARNEY":[{"def":"A disease of horses, on which the mouth is so furred that the afflicted animal can not eat.","pos":""}],"CARNIC":[{"def":"Of or pertaining to flesh; specif.","pos":""},{"def":"pertaining to or designating a hydroscopic monobasic acid, C10H15O5N3, obtained as a cleavage product from an acid of muscle tissue.","pos":""}],"CARNIFEX":[{"def":"The public executioner at Rome, who executed persons of the lowest rank; hence, an executioner or hangman.","pos":""}],"CARNIFICATION":[{"def":"The act or process of turning to flesh, or to a substance resembling flesh.","pos":""}],"CARNIFY":[{"def":"To form flesh; to become like flesh.","pos":""}],"CARNIN":[{"def":"A white crystalline nitrogenous substance, found in extract of meat, and related to xanthin.","pos":""}],"CARNIVAL":[{"def":"A festival celebrated with merriment and revelry in Roman Gatholic countries during the week before Lent, esp.","pos":""},{"def":"Any merrymaking, feasting, or masquerading, especially when overstepping the bounds of decorum; a time of riotous excess.","pos":""}],"CARNIVORA":[{"def":"An order of Mammallia including the lion, tiger, wolf bear, seal, etc.","pos":""}],"CARNIVORACITY":[{"def":"Greediness of appetite for flesh.","pos":""}],"CARNIVORE":[{"def":"One of the Carnivora.","pos":""}],"CARNIVOROUS":[{"def":"Eating or feeding on flesh.","pos":""},{"def":"Of a fleshy consistence; -- applied to succulent leaves, stems, etc.","pos":""}],"CARNOSITY":[{"def":"A fleshy excrescence; esp.","pos":""}]}