{"UNHAIR":[{"def":"To deprive of hair, or of hairs; as, to unhair hides for leather.","pos":""}],"UNHALLOW":[{"def":"To profane; to desecrate.","pos":""}],"UNHALLOWED":[{"def":"Not consecrated; hence, profane; unholy; impious; wicked.","pos":""}],"UNHAND":[{"def":"To loose from the hand; to let go.","pos":""}],"UNHANDSOME":[{"def":"Not handsome; not beautiful; ungraceful; not comely or pleasing; plain; homely.","pos":""},{"def":"Wanting noble or amiable qualities; dishonorable; illiberal; low; disingenuous; mean; indecorous; as, unhandsome conduct, treatment, or imputations.","pos":""}],"UNHANDY":[{"def":"Clumsy; awkward; as, an Unhandy man.","pos":""}],"UNHANG":[{"def":"To divest or strip of hangings; to remove the hangings, as a room.","pos":""},{"def":"To remove (something hanging or swinging) from that which supports it; as, to unhang a gate.","pos":""}],"UNHAP":[{"def":"Ill luck; misfortune.","pos":""}],"UNHAPPY":[{"def":"Not happy or fortunate; unfortunate; unlucky; as, affairs have taken an unhappy turn.","pos":""},{"def":"In a degree miserable or wretched; not happy; sad; sorrowful; as, children render their parents unhappy by misconduct.","pos":""}],"UNHARBOR":[{"def":"To drive from harbor or shelter.","pos":""}],"UNHARBORED":[{"def":"Having no harbor or shelter; unprotected.","pos":""},{"def":"Affording no harbor or shelter.","pos":""}],"UNHARMONIOUS":[{"def":"Inharmonious; unsymmetrical; also, unmusical; discordant.","pos":""}],"UNHARNESS":[{"def":"To strip of harness; to loose from harness or gear; as, to unharness horses or oxen.","pos":""},{"def":"To disarm; to divest of armor.","pos":""}],"UNHASP":[{"def":"To unloose the hasp of; to unclose.","pos":""}],"UNHAT":[{"def":"To take off the hat of; to remove one's hat, especially as a mark of respect.","pos":""}],"UNHEAD":[{"def":"To take out the head of; as, to unhead a cask.","pos":""},{"def":"To decapitate; to behead.","pos":""}],"UNHEAL":[{"def":"Misfortune; calamity; sickness.","pos":""}],"UNHEALTH":[{"def":"Unsoundness; disease.","pos":""}],"UNHEARD":[{"def":"Not heard; not perceived by the ear; as, words unheard by those present.","pos":""},{"def":"Not granted an audience or a hearing; not allowed to speak; not having made a defense, or stated one's side of a question; disregarded; unheeded; as, to condemunheard.","pos":""}],"UNHEARD-OF":[{"def":"New; unprecedented; unparalleled.","pos":""}],"UNHEART":[{"def":"To cause to lose heart; to dishearten.","pos":""}],"UNHEEDY":[{"def":"Incautious; precipitate; heedless.","pos":""}],"UNHEIRED":[{"def":"Destitute of an heir.","pos":""}],"UNHELE":[{"def":"Same as Unheal, n.","pos":""}],"UNHELM":[{"def":"To deprive of the helm or helmet.","pos":""}],"UNHELMED":[{"def":"Divested or deprived of the helm or helmet.","pos":""},{"def":"Not wearing a helmet; without a helmet.","pos":""}],"UNHELMET":[{"def":"To deprive of the helmet.","pos":""}],"UNHIDE":[{"def":"To bring out from concealment; to discover.","pos":""}],"UNHINGE":[{"def":"To take from the hinges; as, to unhinge a door.","pos":""},{"def":"To displace; to unfix by violence.","pos":""}],"UNHINGEMENT":[{"def":"The act unhinging, or the state of being unhinged.","pos":""}],"UNHITCH":[{"def":"To free from being hitched, or as if from being hitched; to unfasten; to loose; as, to unhitch a horse, or a trace.","pos":""}],"UNHIVE":[{"def":"To drive or remove from a hive.","pos":""},{"def":"To deprive of habitation or shelter, as a crowd.","pos":""}],"UNHOARD":[{"def":"To take or steal from a hoard; to pilfer.","pos":""}],"UNHOLD":[{"def":"To cease to hold; to unhand; to release.","pos":""}],"UNHOLY":[{"def":"Not holy; unhallowed; not consecrated; hence, profane; wicked; impious.","pos":""}],"UNHONEST":[{"def":"Dishonest; dishonorable.","pos":""}],"UNHOOD":[{"def":"To remove a hood or disguise from.","pos":""}],"UNHOOK":[{"def":"To loose from a hook; to undo or open by loosening or unfastening the hooks of; as, to unhook a fish; to unhook a dress.","pos":""}],"UNHOOP":[{"def":"To strip or deprive of hoops; to take away the hoops of.","pos":""}],"UNHOPED":[{"def":"Not hoped or expected.","pos":""}],"UNHOPED-FOR":[{"def":"Unhoped; unexpected.","pos":""}],"UNHORSE":[{"def":"To throw from a horse; to cause to dismount; also, to take a horse or horses from; as, to unhorse a rider; to unhorse a carriage.","pos":""}],"UNHOUSE":[{"def":"To drive from a house or habitation; to dislodge; hence, to deprive of shelter.","pos":""}],"UNHOUSED":[{"def":"Driven from a house; deprived of shelter.","pos":""},{"def":"Not provided with a house or shelter; houseless; homeless.","pos":""}],"UNHOUSELED":[{"def":"Not having received the sacrament.","pos":""}],"UNHUMAN":[{"def":"Not human; inhuman.","pos":""}],"UNHUMANIZE":[{"def":"To render inhuman or barbarous.","pos":""}],"UNHUSKED":[{"def":"Not husked; having the husk on.","pos":""},{"def":"Having the husk removed; without husk.","pos":""}]}