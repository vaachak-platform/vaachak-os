{"CHERIMOYER":[{"def":"A small downy-leaved tree (Anona Cherimolia), with fragrant flowers.","pos":""},{"def":"Its delicious fruit, which is succulent, dark purple, and similar to the custard apple of the West Indies.","pos":""}],"CHERISH":[{"def":"To treat with tenderness and affection; to nurture with care; to protect and aid.","pos":""},{"def":"To hold dear; to embrace with interest; to indulge; to encourage; to foster; to promote; as, to cherish religious principle.","pos":""}],"CHERISHER":[{"def":"One who cherishes.","pos":""}],"CHERISHMENT":[{"def":"Encouragement; comfort.","pos":""}],"CHEROKEES":[{"def":"An Appalachian tribe of Indians, formerly inhabiting the region about the head waters of the Tennessee River.","pos":""}],"CHEROOT":[{"def":"A kind of cigar, originally brought from Mania, in the Philippine Islands; now often made of inferior or adulterated tabacco.","pos":""}],"CHERRY":[{"def":"The fruit of the cherry tree, a drupe of various colors and flavors.","pos":""},{"def":"The timber of the cherry tree, esp.","pos":""}],"CHERSONESE":[{"def":"A peninsula; a tract of land nearly surrounded by water, but united to a larger tract by a neck of land or isthmus; as, the Cimbric Chersonese, or Jutland; the Tauric Chersonese, or Crimea.","pos":""}],"CHERT":[{"def":"An impure, massive, flintlike quartz or hornstone, of a dull color.","pos":""}],"CHERTY":[{"def":"Like chert; containing chert; flinty.","pos":""}],"CHERUB":[{"def":"Of or pertaining to cherubs; angelic.","pos":""}],"CHERUBIM":[{"def":"The Hebrew plural of Cherub.","pos":""}],"CHERUBIN":[{"def":"Cherubic; angelic.","pos":""}],"CHERUP":[{"def":"To make a short, shrill, cheerful sound; to chirp.","pos":""}],"CHERVIL":[{"def":"A plant (Anthriscus cerefolium) with pinnately divided aromatic leaves, of which several curled varieties are used in soups and salads.","pos":""}]}