{"PERS":[{"def":"Light blue; grayish blue; -- a term applied to different shades at different periods.","pos":""},{"def":"A cloth of sky-blue color.","pos":""}],"PERSALT":[{"def":"A term formerly given to the salts supposed to be formed respectively by neutralizing acids with certain peroxides.","pos":""}],"PERSCRUTATION":[{"def":"A thorough searching; a minute inquiry or scrutiny.","pos":""}],"PERSECUTE":[{"def":"To pursue in a manner to injure, grieve, or afflict; to beset with cruelty or malignity; to harass; especially, to afflict, harass, punish, or put to death, for adherence to a particular religious creed or mode of worship.","pos":""},{"def":"To harass with importunity; to pursue with persistent solicitations; to annoy.","pos":""}],"PERSECUTION":[{"def":"The act or practice of persecuting; especially, the infliction of loss, pain, or death for adherence to a particular creed or mode of worship.","pos":""},{"def":"The state or condition of being persecuted.","pos":""}],"PERSECUTOR":[{"def":"One who persecutes, or harasses.","pos":""}],"PERSECUTRIX":[{"def":"A woman who persecutes.","pos":""}],"PERSEID":[{"def":"One of a group of shooting stars which appear yearly about the 10th of August, and cross the heavens in paths apparently radiating from the constellation Perseus.","pos":""}],"PERSEUS":[{"def":"A Grecian legendary hero, son of Jupiter and Danaë, who slew the Gorgon Medusa.","pos":""},{"def":"A consellation of the northern hemisphere, near Taurus and Cassiopea.","pos":""}],"PERSEVERANCE":[{"def":"Continuance in a state of grace until it is succeeded by a state of glory; sometimes called final perseverance, and the perseverance of the saints.","pos":""}],"PERSEVERE":[{"def":"To persist in any business or enterprise undertaken; to pursue steadily any project or course begun; to maintain a purpose in spite of counter influences, opposition, or discouragement; not to give or abandon what is undertaken.","pos":""}],"PERSEVERING":[{"def":"Characterized by perseverance; persistent.","pos":""}],"PERSIAN":[{"def":"Of or pertaining to Persia, to the Persians, or to their language.","pos":""}],"PERSIC":[{"def":"Of or relating to Persia.","pos":""},{"def":"The Persian language.","pos":""}],"PERSICARIA":[{"def":"See Lady's thumb.","pos":""}],"PERSICOT":[{"def":"A cordial made of the kernels of apricots, nectarines, etc.","pos":""}],"PERSIENNE":[{"def":"Properly, printed calico, whether Oriental or of fanciful design with flowers, etc.","pos":""}],"PERSIENNES":[{"def":"Window blinds having movable slats, similar to Venetian blinds.","pos":""}],"PERSIFLAGE":[{"def":"Frivolous or bantering talk; a frivolous manner of treating any subject, whether serious or otherwise; light raillery.","pos":""}],"PERSIFLEUR":[{"def":"One who indulges in persiflage; a banterer; a quiz.","pos":""}],"PERSIMMON":[{"def":"An American tree (Diospyros Virginiana) and its fruit, found from New York southward.","pos":""}],"PERSIS":[{"def":"A kind of coloring matter obtained from lichens.","pos":""}],"PERSISM":[{"def":"A Persian idiom.","pos":""}],"PERSIST":[{"def":"To stand firm; to be fixed and unmoved; to stay; to continue steadfastly; especially, to continue fixed in a course of conduct against opposing motives; to persevere; -- sometimes conveying an unfavorable notion, as of doggedness or obstinacy.","pos":""},{"def":"The persistence of motion.","pos":""}],"PERSISTENT":[{"def":"Remaining beyond the period when parts of the same kind sometimes fall off or are absorbed; permanent; as, persistent teeth or gills; a persistent calyx; -- opposed to deciduous, and caducous.","pos":""}],"PERSISTENTLY":[{"def":"In a persistent manner.","pos":""}],"PERSISTING":[{"def":"Inclined to persist; tenacious of purpose; persistent.","pos":""}],"PERSOLVE":[{"def":"To pay wholly, or fully.","pos":""}],"PERSON":[{"def":"Among Trinitarians, one of the three subdivisions of the Godhead (the Father, the Son, and the Holy Ghost); an hypostasis.","pos":""},{"def":"One of three relations or conditions (that of speaking, that of being spoken to, and that of being spoken of) pertaining to a noun or a pronoun, and thence also to the verb of which it may be the subject.","pos":""}],"PERSONA":[{"def":"Same as Person, n.","pos":""}],"PERSONABLE":[{"def":"Having a well-formed body, or person; graceful; comely; of good appearance; presentable; as, a personable man or woman.","pos":""}],"PERSONAGE":[{"def":"Form, appearance, or belongings of a person; the external appearance, stature, figure, air, and the like, of a person.","pos":""},{"def":"Character assumed or represented.","pos":""}],"PERSONAL":[{"def":"Denoting person; as, a personal pronoun.","pos":""}],"PERSONALISM":[{"def":"The quality or state of being personal; personality.","pos":""}],"PERSONALITY":[{"def":"That quality of a law which concerns the condition, state, and capacity of persons.","pos":""}],"PERSONALIZE":[{"def":"To make personal.","pos":""}],"PERSONALLY":[{"def":"In a personal manner; by bodily presence; in person; not by representative or substitute; as, to deliver a letter personally.","pos":""},{"def":"With respect to an individual; as regards the person; individually; particularly.","pos":""}],"PERSONALTY":[{"def":"Personal property, as distinguished from realty or real property.","pos":""}],"PERSONATE":[{"def":"To celebrate loudly; to extol; to praise.","pos":""}],"PERSONATION":[{"def":"The act of personating, or conterfeiting the person or character of another.","pos":""}],"PERSONATOR":[{"def":"One who personates.","pos":""}],"PERSONIFICATION":[{"def":"A figure of speech in which an inanimate object or abstract idea is represented as animated, or endowed with personality; prosopopas, the floods clap their hands.","pos":""}],"PERSONIFIER":[{"def":"One who personifies.","pos":""}],"PERSONIFY":[{"def":"To regard, treat, or represent as a person; to represent as a rational being.","pos":""},{"def":"To be the embodiment or personification of; to impersonate; as, he personifies the law.","pos":""}],"PERSONIZE":[{"def":"Milton has personized them.","pos":""}],"PERSONNEL":[{"def":"The body of persons employed in some public service, as the army, navy, etc.","pos":""}],"PERSPECTIVE":[{"def":"Of or pertaining to the science of vision; optical.","pos":""},{"def":"Pertaining to the art, or in accordance with the laws, of perspective.","pos":""}],"PERSPECTIVELY":[{"def":"Optically; as through a glass.","pos":""},{"def":"According to the rules of perspective.","pos":""}],"PERSPECTOGRAPH":[{"def":"An instrument for obtaining, and transferring to a picture, the points and outlines of objects, so as to represent them in their proper geometrical relations as viewed from some one point.","pos":""}],"PERSPECTOGRAPHY":[{"def":"The science or art of delineating objects according to the laws of perspective; the theory of perspective.","pos":""}],"PERSPICACIOUS":[{"def":"Having the power of seeing clearly; quick-sighted; sharp of sight.","pos":""}],"PERSPICACITY":[{"def":"The state of being perspicacious; acuteness of sight or of intelligence; acute discernment.","pos":""}],"PERSPICIENCE":[{"def":"The act of looking sharply.","pos":""}],"PERSPICIL":[{"def":"An optical glass; a telescope.","pos":""}],"PERSPICUITY":[{"def":"The quality or state of being transparent or translucent.","pos":""},{"def":"The quality of being perspicuous to the understanding; clearness of expression or thought.","pos":""}],"PERSPICUOUS":[{"def":"Capable of being through; transparent; translucent; not opaque.","pos":""},{"def":"Clear to the understanding; capable of being clearly understood; clear in thought or in expression; not obscure or ambiguous; as, a perspicuous writer; perspicuous statements.","pos":""}],"PERSPIRABILITY":[{"def":"The quality or state of being perspirable.","pos":""}],"PERSPIRABLE":[{"def":"Capable of being perspired.","pos":""},{"def":"Emitting perspiration; perspiring.","pos":""}],"PERSPIRATION":[{"def":"The act or process of perspiring.","pos":""},{"def":"That which is excreted through the skin; sweat.","pos":""}],"PERSPIRATIVE":[{"def":"Performing the act of perspiration; perspiratory.","pos":""}],"PERSPIRATORY":[{"def":"Of, pertaining to, or producing, perspiration; as, the perspiratory ducts.","pos":""}],"PERSPIRE":[{"def":"To excrete matter through the skin; esp.","pos":""}],"PERSTREPEROUS":[{"def":"Noisy; obstreperous.","pos":""}],"PERSTRINGE":[{"def":"To touch; to graze; to glance on.","pos":""},{"def":"To criticise; to touch upon.","pos":""}],"PERSUADABLE":[{"def":"That may be persuaded.","pos":""}],"PERSUADE":[{"def":"To influence or gain over by argument, advice, entreaty, expostulation, etc.","pos":""},{"def":"To try to influence.","pos":""}],"PERSUADED":[{"def":"Prevailed upon; influenced by argument or entreaty; convinced.","pos":""}],"PERSUADER":[{"def":"One who, or that which, persuades or influences.","pos":""}],"PERSUASIBILITY":[{"def":"Capability of being persuaded.","pos":""}],"PERSUASIBLE":[{"def":"Capable of being persuaded; persuadable.","pos":""}],"PERSUASION":[{"def":"The act of persuading; the act of influencing the mind by arguments or reasons offered, or by anything that moves the mind or passions, or inclines the will to a determination.","pos":""},{"def":"The state of being persuaded or convinced; settled opinion or conviction, which has been induced.","pos":""}],"PERSUASIVE":[{"def":"Tending to persuade; having the power of persuading; as, persuasive eloquence.","pos":""}],"PERSULPHATE":[{"def":"A sulphate of the peroxide of any base.","pos":""}],"PERSULPHIDE":[{"def":"A sulphide containing more sulphur than some other compound of the same elements; as, iron pyrites is a persulphide; -- formerly called persulphuret.","pos":""}],"PERSULPHOCYANATE":[{"def":"A salt of persulphocyanic acid.","pos":""}],"PERSULPHOCYANIC":[{"def":"Pertaining to, or designating, a yellow crystalline substance (called also perthiocyanic acid), analogous to sulphocyanic acid, but containing more sulphur.","pos":""}],"PERSULPHOCYANOGEN":[{"def":"An orange-yellow substance, produced by the action of chlorine or boiling dilute nitric acid and sulphocyanate of potassium; -- called also pseudosulphocyanogen, perthiocyanogen, and formerly sulphocyanogen.","pos":""}]}