{"PREHALLUX":[{"def":"An extra first toe, or rudiment of a toe, on the preaxial side of the hallux.","pos":""}],"PREHEND":[{"def":"To lay hold of; to seize.","pos":""}],"PREHENSI-BLE":[{"def":"Capable of being seized.","pos":""}],"PREHENSILE":[{"def":"Adapted to seize or grasp; seizing; grasping; as, the prehensile tail of a monkey.","pos":""}],"PREHENSION":[{"def":"The act of taking hold, seizing, or grasping, as with the hand or other member.","pos":""}],"PREHENSORY":[{"def":"Adapted to seize or grasp; prehensile.","pos":""}],"PREHISTORIC":[{"def":"Of or pertaining to a period before written history begins; as, the prehistoric ages; prehistoric man.","pos":""}],"PREHNITE":[{"def":"A pale green mineral occurring in crystalline aggregates having a botryoidal or mammillary structure, and rarely in distinct crystals.","pos":""}],"PREHNITIC":[{"def":"Pertaining to, or designating, a tetrabasic acid of benzene obtained as a white crystalline substance; -- probably so called from the resemblance of the wartlike crystals to the mammillæ on the surface of prehnite.","pos":""}]}