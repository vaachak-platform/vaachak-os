{"VIA":[{"def":"By the way of; as, to send a letter via Queenstown to London.","pos":""}],"VIABILITY":[{"def":"The quality or state of being viable.","pos":""},{"def":"The capacity of living after birth.","pos":""}],"VIABLE":[{"def":"Capable of living; born alive and with such form and development of organs as to be capable of living; -- said of a newborn, or a prematurely born, infant.","pos":""}],"VIADUCT":[{"def":"A structure of considerable magnitude, usually with arches or supported on trestles, for carrying a road, as a railroad, high above the ground or water; a bridge; especially, one for crossing a valley or a gorge.","pos":""}],"VIAGE":[{"def":"A voyage; a journey.","pos":""}],"VIAL":[{"def":"A small bottle, usually of glass; a little glass vessel with a narrow aperture intended to be closed with a stopper; as, a vial of medicine.","pos":""}],"VIAMETER":[{"def":"An odometer; -- called also viatometer.","pos":""}],"VIAND":[{"def":"An article of food; provisions; food; victuals; -- used chiefly in the plural.","pos":""}],"VIANDER":[{"def":"A feeder; an eater; also, one who provides viands, or food; a host.","pos":""}],"VIARY":[{"def":"Of or pertaining to roads; happening on roads.","pos":""}],"VIATECTURE":[{"def":"The art of making roads or ways for traveling, including the construction of bridges, canals, viaducts, etc.","pos":""}],"VIATIC":[{"def":"Of or pertaining to a journey or traveling.","pos":""}],"VIATICUM":[{"def":"An allowance for traveling expenses made to those who were sent into the provinces to exercise any office or perform any service.","pos":""},{"def":"The communion, or eucharist, when given to persons in danger of death.","pos":""}]}