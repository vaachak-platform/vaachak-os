{"ASSE":[{"def":"A small foxlike animal (Vulpes cama) of South Africa, valued for its fur.","pos":""}],"ASSECURATION":[{"def":"Assurance; certainty.","pos":""}],"ASSECURE":[{"def":"To make sure or safe; to assure.","pos":""}],"ASSECUTION":[{"def":"An obtaining or acquiring.","pos":""}],"ASSEGAI":[{"def":"Same as Assagai.","pos":""}],"ASSEMBLAGE":[{"def":"The act of assembling, or the state o In sweet assemblage every blooming grace.","pos":""},{"def":"A collection of individuals, or of individuals, or of particular things; as, a political assemblage; an assemblage of ideas.","pos":""}],"ASSEMBLANCE":[{"def":"Resemblance; likeness; appearance.","pos":""},{"def":"An assembling; assemblage.","pos":""}],"ASSEMBLE":[{"def":"To collect into one place or body; to bring or call together; to convene; to congregate.","pos":""}],"ASSEMBLER":[{"def":"One who assembles a number of individuals; also, one of a number assembled.","pos":""}],"ASSEMBLY":[{"def":"A beat of the drum or sound of the bugle as a signal to troops to assemble.","pos":""}],"ASSEMBLYMAN":[{"def":"A member of an assembly, especially of the lower branch of a state legislature.","pos":""}],"ASSENT":[{"def":"To admit a thing as true; to express one's agreement, acquiescence, concurrence, or concession.","pos":""}],"ASSENTATION":[{"def":"Insincere, flattering, or obsequious assent; hypocritical or pretended concurrence.","pos":""}],"ASSENTATOR":[{"def":"An obsequious; a flatterer.","pos":""}],"ASSENTATORY":[{"def":"Flattering; obsequious.","pos":""}],"ASSENTER":[{"def":"One who assents.","pos":""}],"ASSENTING":[{"def":"Giving or implying assent.","pos":""}],"ASSENTIVE":[{"def":"Giving assent; of the nature of assent; complying.","pos":""}],"ASSENTMENT":[{"def":"Assent; agreement.","pos":""}],"ASSERT":[{"def":"To affirm; to declare with assurance, or plainly and strongly; to state positively; to aver; to asseverate.","pos":""},{"def":"To maintain; to defend.","pos":""}],"ASSERTER":[{"def":"One who asserts; one who avers pr maintains; an assertor.","pos":""}],"ASSERTION":[{"def":"The act of asserting, or that which is asserted; positive declaration or averment; affirmation; statement asserted; position advanced.","pos":""},{"def":"Maintenance; vindication; as, the assertion of one's rights or prerogatives.","pos":""}],"ASSERTIVE":[{"def":"Positive; affirming confidently; affirmative; peremptory.","pos":""}],"ASSERTOR":[{"def":"One who asserts or avers; one who maintains or vindicates a claim or a right; an affirmer, supporter, or vindicator; a defender; an asserter.","pos":""}],"ASSERTORIAL":[{"def":"Asserting that a thing is; -- opposed to problematical and apodeictical.","pos":""}],"ASSERTORY":[{"def":"Affirming; maintaining.","pos":""}],"ASSESS":[{"def":"To value; to make a valuation or official estimate of for the purpose of taxation.","pos":""},{"def":"To apportion a sum to be paid by (a person, a community, or an estate), in the nature of a tax, fine, etc.","pos":""}],"ASSESSABLE":[{"def":"Liable to be assessed or taxed; as, assessable property.","pos":""}],"ASSESSEE":[{"def":"One who is assessed.","pos":""}],"ASSESSION":[{"def":"A sitting beside or near.","pos":""}],"ASSESSMENT":[{"def":"The act of assessing; the act of determining an amount to be paid; as, an assessment of damages, or of taxes; an assessment of the members of a club.","pos":""},{"def":"A valuation of property or profits of business, for the purpose of taxation; such valuation and an adjudging of the proper sum to be levied on the property; as, an assessment of property or an assessment on property.","pos":""}],"ASSESSOR":[{"def":"One appointed or elected to assist a judge or magistrate with his special knowledge of the subject to be decided; as legal assessors, nautical assessors.","pos":""},{"def":"One who sits by another, as next in dignity, or as an assistant and adviser; an associate in office.","pos":""}],"ASSESSORIAL":[{"def":"Of or pertaining to an assessor, or to a court of assessors.","pos":""}],"ASSESSORSHIP":[{"def":"The office or function of an assessor.","pos":""}],"ASSET":[{"def":"Any article or separable part of one's assets.","pos":""}],"ASSETS":[{"def":"The entire property of all sorts, belonging to a person, a corporation, or an estate; as, the assets of a merchant or a trading association; -- opposed to liabilities.","pos":""}],"ASSEVERATE":[{"def":"To affirm or aver positively, or with solemnity.","pos":""}],"ASSEVERATION":[{"def":"The act of asseverating, or that which is asseverated; positive affirmation or assertion; solemn declaration.","pos":""}],"ASSEVERATIVE":[{"def":"Characterized by asseveration; asserting positively.","pos":""}]}