{"NIL":[{"def":"Nothing; of no account; worthless; -- a term often used for canceling, in accounts or bookkeeping.","pos":""}],"NILE":[{"def":"The great river of Egypt.","pos":""}],"NILL":[{"def":"Not to will; to refuse; to reject.","pos":""}],"NILOMETER":[{"def":"An instrument for measuring the rise of water in the Nile during its periodical flood.","pos":""}],"NILOTIC":[{"def":"Of or pertaining to the river Nile; as, the Nilotic crocodile.","pos":""}]}