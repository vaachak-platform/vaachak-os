{"MOO":[{"def":"To make the noise of a cow; to low; -- child's word.","pos":""}],"MOOD":[{"def":"Manner of conceiving and expressing action or being, as positive, possible, hypothetical, etc.","pos":""}],"MOODILY":[{"def":"In a moody manner.","pos":""}],"MOODINESS":[{"def":"The quality or state of being moody; specifically, liability to strange or violent moods.","pos":""}],"MOODIR":[{"def":"The governor of a province in Egypt, etc.","pos":""}],"MOODY":[{"def":"Subject to varying moods, especially to states of mind which are unamiable or depressed.","pos":""},{"def":"Hence: Out of humor; peevish; angry; fretful; also, abstracted and pensive; sad; gloomy; melancholy.","pos":""}],"MOON":[{"def":"A crescentlike outwork.","pos":""}],"MOON-CULMINATING":[{"def":"Culminating, or coming to the meredian, at or about the same time with the moon; -- said of a star or stars, esp.","pos":""}],"MOON-EYE":[{"def":"A eye affected by the moon; also, a disease in the eye of a horse.","pos":""}],"MOON-EYED":[{"def":"Having eyes affected by the moon; moonblind; dim-eyed; purblind.","pos":""}],"MOON-FACED":[{"def":"Having a round, full face.","pos":""}],"MOONBEAM":[{"def":"A ray of light from the moon.","pos":""}],"MOONBLIND":[{"def":"Dim-sighted; purblind.","pos":""}],"MOONBLINK":[{"def":"A temporary blindness, or impairment of sight, said to be caused by sleeping in the moonlight; -- sometimes called nyctalopia.","pos":""}],"MOONCALF":[{"def":"A monster; a false conception; a mass of fleshy matter, generated in the uterus.","pos":""},{"def":"A dolt; a stupid fellow.","pos":""}],"MOONED":[{"def":"Of or resembling the moon; symbolized by the moon.","pos":""}],"MOONER":[{"def":"One who abstractedly wanders or gazes about, as if moonstruck.","pos":""}],"MOONERY":[{"def":"Conduct of one who moons.","pos":""}],"MOONGLADE":[{"def":"The bright reflection of the moon's light on an expanse of water.","pos":""}],"MOONIE":[{"def":"The European goldcrest.","pos":""}],"MOONISH":[{"def":"Like the moon; variable.","pos":""}],"MOONLESS":[{"def":"Being without a moon or moonlight.","pos":""}],"MOONLIGHT":[{"def":"The light of the moon.","pos":""},{"def":"Occurring during or by moonlight; characterized by moonlight.","pos":""}],"MOONLING":[{"def":"A simpleton; a lunatic.","pos":""}],"MOONLIT":[{"def":"Illumined by the moon.","pos":""}],"MOONRAKER":[{"def":"Same as Moonsail.","pos":""}],"MOONRISE":[{"def":"The rising of the moon above the horizon; also, the time of its rising.","pos":""}],"MOONSAIL":[{"def":"A sail sometimes carried in light winds, above a skysail.","pos":""}],"MOONSEED":[{"def":"A climbing plant of the genus Menispermum; -- so called from the crescentlike form of the seeds.","pos":""}],"MOONSET":[{"def":"The descent of the moon below the horizon; also, the time when the moon sets.","pos":""}],"MOONSHEE":[{"def":"A Mohammedan professor or teacher of language.","pos":""}],"MOONSHINE":[{"def":"The light of the moon.","pos":""},{"def":"Hence, show without substance or reality.","pos":""}],"MOONSHINER":[{"def":"A person engaged in illicit distilling; -- so called because the work is largely done at night.","pos":""}],"MOONSHINING":[{"def":"Illicit distilling.","pos":""}],"MOONSHINY":[{"def":"I went to see them in a moonshiny night.","pos":""}],"MOONSTONE":[{"def":"A nearly pellucid variety of feldspar, showing pearly or opaline reflections from within.","pos":""}],"MOONSTRUCK":[{"def":"Mentally affected or deranged by the supposed influence of the moon; lunatic.","pos":""},{"def":"Produced by the supposed influence of the moon.","pos":""}],"MOONY":[{"def":"Of or pertaining to the moon.","pos":""},{"def":"Furnished with a moon; bearing a crescent.","pos":""}],"MOOR":[{"def":"Any individual of the swarthy races of Africa or Asia which have adopted the Mohammedan religion.","pos":""}],"MOORAGE":[{"def":"A place for mooring.","pos":""}],"MOORBALL":[{"def":"A fresh-water alga (Cladophora Ægagropila) which forms a globular mass.","pos":""}],"MOORESS":[{"def":"A female Moor; a Moorish woman.","pos":""}],"MOORING":[{"def":"The place or condition of a ship thus confined.","pos":""}],"MOORISH":[{"def":"Having the characteristics of a moor or heath.","pos":""}],"MOORLAND":[{"def":"Land consisting of a moor or moors.","pos":""}],"MOORPAN":[{"def":"A clayey layer or pan underlying some moors, etc.","pos":""}],"MOORSTONE":[{"def":"A species of English granite, used as a building stone.","pos":""}],"MOORUK":[{"def":"A species of cassowary (Casuarius Bennetti) found in New Britain, and noted for its agility in running and leaping.","pos":""}],"MOORY":[{"def":"Of or pertaining to moors; marshy; fenny; boggy; moorish.","pos":""}],"MOOSE":[{"def":"A large cervine mammal (Alces machlis, or A.","pos":""}],"MOOT":[{"def":"A ring for gauging wooden pins.","pos":""}],"MOOT-HILL":[{"def":"A hill of meeting or council; an elevated place in the open air where public assemblies or courts were held by the Saxons; -- called, in Scotland, mute-hill.","pos":""}],"MOOTABLE":[{"def":"Capable of being mooted.","pos":""}],"MOOTER":[{"def":"A disputer of a mooted case.","pos":""},{"def":"A hall for public meetings; a hall of judgment.","pos":""}],"MOOTMAN":[{"def":"One who argued moot cases in the inns of court.","pos":""}]}