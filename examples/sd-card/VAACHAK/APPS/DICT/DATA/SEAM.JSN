{"SEAM":[{"def":"Grease; tallow; lard.","pos":""}],"SEAMAN":[{"def":"A merman; the male of the mermaid.","pos":""}],"SEAMANLIKE":[{"def":"Having or showing the skill of a practical seaman.","pos":""}],"SEAMANSHIP":[{"def":"The skill of a good seaman; the art, or skill in the art, of working a ship.","pos":""}],"SEAMARK":[{"def":"Any elevated object on land which serves as a guide to mariners; a beacon; a landmark visible from the sea, as a hill, a tree, a steeple, or the like.","pos":""}],"SEAMED":[{"def":"Out of condition; not in good condition; -- said of a hawk.","pos":""}],"SEAMING":[{"def":"The cord or rope at the margin of a seine, to which the meshes of the net are attached.","pos":""}],"SEAMLESS":[{"def":"Christ's seamless coat, all of a piece.","pos":""}],"SEAMSTER":[{"def":"One who sews well, or whose occupation is to sew.","pos":""}],"SEAMSTRESS":[{"def":"A woman whose occupation is sewing; a needlewoman.","pos":""}],"SEAMSTRESSY":[{"def":"The business of a seamstress.","pos":""}],"SEAMY":[{"def":"Having a seam; containing seams, or showing them.","pos":""}]}