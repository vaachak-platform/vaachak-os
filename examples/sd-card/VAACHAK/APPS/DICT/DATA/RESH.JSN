{"RESHAPE":[{"def":"Re*shape\" (r-shp\"), v.","pos":""}],"RESHIP":[{"def":"To ship again; to put on board of a vessel a second time; to send on a second voyage; as, to reship bonded merchandise.","pos":""}],"RESHIPMENT":[{"def":"The act of reshipping; also, that which is reshippped.","pos":""}],"RESHIPPER":[{"def":"One who reships.","pos":""}]}