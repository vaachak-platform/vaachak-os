{"COUCAL":[{"def":"A large, Old World, ground cuckoo of the genus Centropus, of several species.","pos":""}],"COUCH":[{"def":"To transfer (as sheets of partly dried pulp) from the wire clotch mold to a felt blanket, for further drying.","pos":""},{"def":"To treat by pushing down or displacing the opaque lens with a needle; as, to couch a cataract.","pos":""}],"COUCH GRASS":[{"def":"See Quitch grass.","pos":""}],"COUCHANCY":[{"def":"State of lying down for repose.","pos":""}],"COUCHANT":[{"def":"Lying down with the head raised, which distinguishes the posture of couchant from that of dormant, or sleeping; -- said of a lion or other beast.","pos":""}],"COUCHEE":[{"def":"A reception held at the time of going to bed, as by a sovereign or great prince.","pos":""}],"COUCHER":[{"def":"One who couches paper.","pos":""}],"COUCHING":[{"def":"The operation of putting down or displacing the opaque lens in cataract.","pos":""}],"COUCHLESS":[{"def":"Having no couch or bed.","pos":""}]}