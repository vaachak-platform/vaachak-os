{"CIRRATE":[{"def":"Having cirri along the margin of a part or organ.","pos":""}],"CIRRHIFEROUS":[{"def":"See Cirriferous.","pos":""}],"CIRRHOSE":[{"def":"Same as Cirrose.","pos":""}],"CIRRHOSIS":[{"def":"A disease of the liver in which it usually becomes smaller in size and more dense and fibrous in consistence; hence sometimes applied to similar changes in other organs, caused by increase in the fibrous framework and decrease in the proper substance of the organ.","pos":""}],"CIRRHOTIC":[{"def":"Pertaining to, caused by, or affected with, cirrhosis; as, cirrhotic degeneration; a cirrhotic liver.","pos":""}],"CIRRIFEROUS":[{"def":"Bearing cirri, as many plants and animals.","pos":""}],"CIRRIFORM":[{"def":"Formed like a cirrus or tendril; -- said of appendages of both animals and plants.","pos":""}],"CIRRIGEROUS":[{"def":"Having curled locks of hair; supporting cirri, or hairlike appendages.","pos":""}],"CIRRIGRADE":[{"def":"Moving or moved by cirri, or hairlike appendages.","pos":""}],"CIRRIPED":[{"def":"One of the Cirripedia.","pos":""}],"CIRRIPEDIA":[{"def":"An order of Crustacea including the barnacles.","pos":""}],"CIRRO-CUMULUS":[{"def":"See under Cloud.","pos":""}],"CIRRO-STRATUS":[{"def":"See under Cloud.","pos":""}],"CIRROBRANCHIATA":[{"def":"A division of Mollusca having slender, cirriform appendages near the mouth; the Scaphopoda.","pos":""}],"CIRROSTOMI":[{"def":"The lowest group of vertebrates; -- so called from the cirri around the mouth; the Leptocardia.","pos":""}],"CIRROUS":[{"def":"Tufted; -- said of certain feathers of birds.","pos":""}],"CIRRUS":[{"def":"A tendril or clasper.","pos":""},{"def":"The external male organ of trematodes and some other worms, and of certain Mollusca.","pos":""}]}