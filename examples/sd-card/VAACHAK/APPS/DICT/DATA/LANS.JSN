{"LANSEH":[{"def":"The small, whitish brown fruit of an East Indian tree (Lansium domesticum).","pos":""}],"LANSQUENET":[{"def":"A German foot soldier in foreign service in the 15th and 16th centuries; a soldier of fortune; -- a term used in France and Western Europe.","pos":""},{"def":"A game at cards, vulgarly called lambskinnet.","pos":""}]}