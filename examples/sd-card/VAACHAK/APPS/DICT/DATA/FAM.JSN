{"FAMBLE":[{"def":"A hand [Slang & Obs.","pos":""}],"FAME":[{"def":"Public report or rumor.","pos":""},{"def":"Report or opinion generally diffused; renown; public estimation; celebrity, either favorable or unfavorable; as, the fame of Washington.","pos":""}],"FAMELESS":[{"def":"Without fame or renown.","pos":""}],"FAMILIAR":[{"def":"Of or pertaining to a family; domestic.","pos":""},{"def":"Closely acquainted or intimate, as a friend or companion; well versed in, as any subject of study; as, familiar with the Scriptures.","pos":""}],"FAMILIARITY":[{"def":"The state of being familiar; intimate and frequent converse, or association; unconstrained intercourse; freedom from ceremony and constraint; intimacy; as, to live in remarkable familiarity.","pos":""},{"def":"Anything said or done by one person to another unceremoniously and without constraint; esp.","pos":""}],"FAMILIARIZATION":[{"def":"The act or process of making familiar; the result of becoming familiar; as, familiarization with scenes of blood.","pos":""}],"FAMILIARIZE":[{"def":"To make familiar or intimate; to habituate; to accustom; to make well known by practice or converse; as, to familiarize one's self with scenes of distress.","pos":""},{"def":"To make acquainted, or skilled, by practice or study; as, to familiarize one's self with a business, a book, or a science.","pos":""}],"FAMILIARLY":[{"def":"In a familiar manner.","pos":""}],"FAMILIARY":[{"def":"Of or pertaining to a family or household; domestic.","pos":""}],"FAMILISM":[{"def":"The tenets of the Familists.","pos":""}],"FAMILIST":[{"def":"One of afanatical Antinomian sect originating in Holland, and existing in England about 1580, called the Family of Love, who held that religion consists wholly in love.","pos":""}],"FAMILISTERY":[{"def":"A community in which many persons unite as in one family, and are regulated by certain communistic laws and customs.","pos":""},{"def":"Pertaining to Familists.","pos":""}],"FAMILY":[{"def":"A groupe of organisms, either animal or vegetable, related by certain points of resemblance in structure or development, more comprehensive than a genus, because it is usually based on fewer or less pronounced points of likeness.","pos":""}],"FAMINE":[{"def":"General scarcity of food; dearth; a want of provisions; destitution.","pos":""}],"FAMISH":[{"def":"To starve, kill, or destroy with hunger.","pos":""},{"def":"To exhaust the strength or endurance of, by hunger; to distress with hanger.","pos":""}],"FAMISHMENT":[{"def":"State of being famished.","pos":""}],"FAMOSITY":[{"def":"The state or quality of being famous.","pos":""}],"FAMOUS":[{"def":"Celebrated in fame or public report; renowned; mach talked of; distinguished in story; -- used in either a good or a bad sense, chiefly the former; often followed by for; as, famous for erudition, for eloquence, for military skill; a famous pirate.","pos":""}],"FAMOUSLY":[{"def":"In a famous manner; in a distinguished degree; greatly; splendidly.","pos":""}],"FAMOUSNESS":[{"def":"The state of being famous.","pos":""}],"FAMULAR":[{"def":"Domestic; familiar.","pos":""}],"FAMULIST":[{"def":"A collegian of inferior rank or position, corresponding to the sizar at Cambridge.","pos":""}]}