{"RELADE":[{"def":"To lade or load again.","pos":""}],"RELAID":[{"def":"Re*laid\" (r-ld), Defn: imp.","pos":""}],"RELAIS":[{"def":"A narrow space between the foot of the rampart and the scarp of the ditch, serving to receive the earth that may crumble off or be washed down, and prevent its falling into the ditch.","pos":""}],"RELAND":[{"def":"To land again; to put on land, as that which had been shipped or embarked.","pos":""}],"RELAPSE":[{"def":"To fall from Christian faith into paganism, heresy, or unbelief; to backslide.","pos":""}],"RELAPSER":[{"def":"One who relapses.","pos":""}],"RELAPSING":[{"def":"Marked by a relapse; falling back; tending to return to a former worse state.","pos":""}],"RELATE":[{"def":"To bring back; to restore.","pos":""},{"def":"To refer; to ascribe, as to a source.","pos":""}],"RELATED":[{"def":"Same as Relative, 4.","pos":""}],"RELATEDNESS":[{"def":"The state or condition of being related; relationship; affinity.","pos":""}],"RELATER":[{"def":"One who relates or narrates.","pos":""}],"RELATION":[{"def":"The act of relating or telling; also, that which is related; recital; account; narration; narrative; as, the relation of historical events.","pos":""}],"RELATIONAL":[{"def":"Having relation or kindred; related.","pos":""},{"def":"Indicating or specifying some relation.","pos":""}],"RELATIONIST":[{"def":"A relative; a relation.","pos":""}],"RELATIONSHIP":[{"def":"The state of being related by kindred, affinity, or other alliance.","pos":""}],"RELATIVE":[{"def":"Indicating or expressing relation; refering to an antecedent; as, a relative pronoun.","pos":""},{"def":"Characterizing or pertaining to chords and keys, which, by reason of the identify of some of their tones, admit of a natural transition from one to the other.","pos":""}],"RELATIVELY":[{"def":"In a relative manner; in relation or respect to something else; not absolutely.","pos":""}],"RELATIVENESS":[{"def":"The state of being relative, or having relation; relativity.","pos":""}],"RELATIVITY":[{"def":"The state of being relative; as, the relativity of a subject.","pos":""}],"RELATOR":[{"def":"A private person at whose relation, or in whose behalf, the attorney-general allows an information in the nature of a quo warranto to be filed.","pos":""}],"RELATRIX":[{"def":"A female relator.","pos":""}],"RELAX":[{"def":"To make lax or loose; to make less close, firm, rigid, tense, or the like; to slacken; to loosen; to open; as, to relax a rope or cord; to relax the muscles or sinews.","pos":""},{"def":"To make less severe or rogorous; to abate the stringency of; to remit in respect to strenuousness, esrnestness, or effort; as, to relax discipline; to relax one's attention or endeavors.","pos":""}],"RELAXABLE":[{"def":"Capable of being relaxed.","pos":""}],"RELAXANT":[{"def":"A medicine that relaxes; a laxative.","pos":""}],"RELAXATION":[{"def":"The act or process of relaxing, or the state of being relaxed; as, relaxation of the muscles; relaxation of a law.","pos":""},{"def":"Remission from attention and effort; indulgence in recreation, diversion, or amusement.","pos":""}],"RELAXATIVE":[{"def":"Having the quality of relaxing; laxative.","pos":""}],"RELAY":[{"def":"To lay again; to lay a second time; as, to relay a pavement.","pos":""}],"RELAY CYLINDER":[{"def":"In a variable expansion central-valve engine, a small auxiliary engine for automatically adjusting the steam distribution to the load on the main engine.","pos":""}],"RELAY GOVERNOR":[{"def":"A speed regulator, as a water-wheel governor, embodying the relay principle.","pos":""}],"RELBUN":[{"def":"The roots of the Chilian plant Calceolaria arachnoidea, -- used for dyeing crimson.","pos":""}],"RELEASABLE":[{"def":"That may be released.","pos":""}],"RELEASE":[{"def":"To lease again; to grant a new lease of; to let back.","pos":""}],"RELEASEE":[{"def":"One to whom a release is given.","pos":""}],"RELEASEMENT":[{"def":"The act of releasing, as from confinement or obligation.","pos":""}],"RELEASER":[{"def":"One who releases, or sets free.","pos":""}],"RELEASOR":[{"def":"One by whom a release is given.","pos":""}],"RELEGATE":[{"def":"To remove, usually to an inferior position; to consign; to transfer; specifically, to send into exile; to banish.","pos":""}],"RELEGATION":[{"def":"The act of relegating, or the state of being relegated; removal; banishment; exile.","pos":""}],"RELENT":[{"def":"To become less rigid or hard; to yield; to dissolve; to melt; to deliquesce.","pos":""},{"def":"To become less severe or intense; to become less hard, harsh, cruel, or the like; to soften in temper; to become more mild and tender; to feel compassion.","pos":""}],"RELENTLESS":[{"def":"Unmoved by appeals for sympathy or forgiveness; insensible to the distresses of others; destitute of tenderness; unrelenting; unyielding; unpitying; as, a prey to relentless despotism.","pos":""}],"RELENTMENT":[{"def":"The act or process of retenting; the state of having relented.","pos":""}],"RELESSEE":[{"def":"Re`les*see\" (r`ls-s\"), n.","pos":""}],"RELESSOR":[{"def":"Re`les*sor\" (-sr\"), n.","pos":""}],"RELEVANT":[{"def":"Sufficient to support the cause.","pos":""}],"RELEVANTLY":[{"def":"In a relevant manner.","pos":""}],"RELEVATION":[{"def":"A raising or lifting up.","pos":""}],"RELIABILITY":[{"def":"The state or quality of being reliable; reliableness.","pos":""}],"RELIABLE":[{"def":"Suitable or fit to be relied on; worthy of dependance or reliance; trustworthy.","pos":""}],"RELIANCE":[{"def":"The act of relying, or the condition or quality of being reliant; dependence; confidence; trust; repose of mind upon what is deemed sufficient support or authority.","pos":""},{"def":"Anything on which to rely; dependence; ground of trust; as, the boat was a poor reliance.","pos":""}],"RELIANT":[{"def":"Having, or characterized by, reliance; confident; trusting.","pos":""}],"RELIC":[{"def":"That which remains; that which is left after loss or decay; a remaining portion; a remnant.","pos":""},{"def":"The body from which the soul has departed; a corpse; especially, the body, or some part of the body, of a deceased saint or martyr; -- usually in the plural when referring to the whole body.","pos":""}],"RELICLY":[{"def":"In the manner of relics.","pos":""}],"RELICT":[{"def":"A woman whose husband is dead; a widow.","pos":""}],"RELICTED":[{"def":"Left uncovered, as land by recession of water.","pos":""}],"RELICTION":[{"def":"A leaving dry; a recession of the sea or other water, leaving dry land; land left uncovered by such recession.","pos":""}],"RELIEF":[{"def":"A fine or composition which the heir of a deceased tenant paid to the lord for the privilege of taking up the estate, which, on strict feudal principles, had lapsed or fallen to the lord on the death of the tenant.","pos":""},{"def":"The projection of a figure above the ground or plane on wwhich it is formed.","pos":""}],"RELIEFFUL":[{"def":"Re*lief\"ful (r-lf\"fl), a.","pos":""}],"RELIEFLESS":[{"def":"Destitute of relief; also, remediless.","pos":""}],"RELIEVABLE":[{"def":"Capable of being relieved; fitted to recieve relief.","pos":""}],"RELIEVE":[{"def":"To lift up; to raise again, as one who has fallen; to cause to rise.","pos":""},{"def":"To cause to seem to rise; to put in relief; to give prominence or conspicuousness to; to Her tall figure relieved against the blue sky; seemed almost of supernatural height.","pos":""}],"RELIEVEMENT":[{"def":"The act of relieving, or the state of being relieved; relief; release.","pos":""}],"RELIEVER":[{"def":"One who, or that which, relieves.","pos":""}],"RELIEVING":[{"def":"Serving or tending to relieve.","pos":""}],"RELIGHT":[{"def":"To light or kindle anew.","pos":""},{"def":"A person bound by monastic vows; a nun; a monk.","pos":""}],"RELIGION":[{"def":"A monastic or religious order subject to a regulated mode of life; the religious state; as, to enter religion.","pos":""}],"RELIGIONARY":[{"def":"Relating to religion; pious; as, religionary professions.","pos":""}],"RELIGIONISM":[{"def":"The practice of, or devotion to, religion.","pos":""},{"def":"Affectation or pretense of religion.","pos":""}],"RELIGIONIST":[{"def":"One earnestly devoted or attached to a religion; a religious zealot.","pos":""}],"RELIGIONIZE":[{"def":"To bring under the influence of religion.","pos":""}],"RELIGIONLESS":[{"def":"Destitute of religion.","pos":""}],"RELIGIOSITY":[{"def":"The quality of being religious; religious feeling or sentiment; religiousness.","pos":""}],"RELIGIOUS":[{"def":"Of or pertaining to religion; concerned with religion; teaching, or setting forth, religion; set apart to religion; as, a religious society; a religious sect; a religious place; religious subjects, books, teachers, houses, wars.","pos":""},{"def":"Possessing, or conforming to, religion; pious; godly; as, a religious man, life, behavior, etc.","pos":""}],"RELIGIOUSLY":[{"def":"In a religious manner.","pos":""}],"RELIGIOUSNESS":[{"def":"The quality of being religious.","pos":""}],"RELINQUENT":[{"def":"Re*lin\"quent (r-ln\"kwent), a.","pos":""}],"RELINQUISH":[{"def":"To withdraw from; to leave behind; to desist from; to abandon; to quit; as, to relinquish a pursuit.","pos":""},{"def":"To give up; to renounce a claim to; resign; as, to relinquish a debt.","pos":""}],"RELINQUISHER":[{"def":"One who relinquishes.","pos":""}],"RELINQUISHMENT":[{"def":"The act of relinquishing.","pos":""}],"RELIQUARY":[{"def":"A depositary, often a small box or casket, in which relics are kept.","pos":""}],"RELIQUIAE":[{"def":"Same as Induviæ.","pos":"noun"}],"RELIQUIAN":[{"def":"Of or pertaining to a relic or relics; of the nature of a relic.","pos":""}],"RELIQUIDATE":[{"def":"To liquidate anew; to adjust a second time.","pos":""}],"RELIQUIDATION":[{"def":"A second or renewed liquidation; a renewed adjustment.","pos":""}],"RELISH":[{"def":"To taste or eat with pleasure; to like the flavor of; to partake of with gratification; hence, to enjoy; to be pleased with or gratified by; to experience pleasure from; as, to relish food.","pos":""},{"def":"To give a relish to; to cause to taste agreeably.","pos":""}],"RELISHABLE":[{"def":"Capable of being relished; agreeable to the taste; gratifying.","pos":""}],"RELIVE":[{"def":"To live again; to revive.","pos":""}],"RELOAD":[{"def":"To load again, as a gun.","pos":""}],"RELOAN":[{"def":"A second lending of the same thing; a renewal of a loan.","pos":""}],"RELOCATE":[{"def":"To locate again.","pos":""}],"RELOCATION":[{"def":"Renewal of a lease.","pos":""}],"RELOVE":[{"def":"To love in return.","pos":""}],"RELUCENT":[{"def":"Reflecting light; shining; glittering; glistening; bright; luminous; splendid.","pos":""}],"RELUCT":[{"def":"To strive or struggle against anything; to make resistance; to draw back; to feel or show repugnance or reluctance.","pos":""},{"def":"The state or quality of being reluctant; repugnance; aversion of mind; unwillingness; -- often followed by an infinitive, or by to and a noun, formerly sometimes by against.","pos":""}],"RELUCTANT":[{"def":"Striving against; opposed in desire; unwilling; disinclined; loth.","pos":""},{"def":"Proceeding from an unwilling mind; granted with reluctance; as, reluctant obedience.","pos":""}],"RELUCTANTLY":[{"def":"In a reluctant manner.","pos":""}],"RELUCTATE":[{"def":"To struggle against anything; to resist; to oppose.","pos":""}],"RELUCTATION":[{"def":"Repugnance; resistance; reluctance.","pos":""}],"RELUCTIVITY":[{"def":"Specific reluctance.","pos":""}],"RELUME":[{"def":"To rekindle; to light again.","pos":""}],"RELUMINE":[{"def":"To light anew; to rekindle.","pos":""},{"def":"To illuminate again.","pos":""}],"RELY":[{"def":"To rest with confidence, as when fully satisfied of the veracity, integrity, or ability of persons, or of the certainty of facts or of evidence; to have confidence; to trust; to depend; -- with on, formerly also with in.","pos":""}]}