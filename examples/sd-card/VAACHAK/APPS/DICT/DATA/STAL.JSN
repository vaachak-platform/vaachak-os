{"STAL":[{"def":"STALACTIC; STALACTICAL Sta*lac\"tic, Sta*lac\"tic*al, a.","pos":""}],"STALACTIFORM":[{"def":"Like a stalactite; resembling a stalactite.","pos":""}],"STALACTITES":[{"def":"Of or pertaining to a stalactite; having the form or characters of a stalactite; stalactic.","pos":""}],"STALACTITIFORM":[{"def":"Having the form of a stalactite; stalactiform.","pos":""}],"STALAGMITE":[{"def":"A deposit more or less resembling an inverted stalactite, formed by calcareous water dropping on the floors of caverns; hence, a similar deposit of other material.","pos":""},{"def":"Having the form or structure of stalagmites.","pos":""}],"STALDER":[{"def":"A wooden frame to set casks on.","pos":""}],"STALE":[{"def":"The stock or handle of anything; as, the stale of a rake.","pos":""}],"STALELY":[{"def":"In a state stale manner.","pos":""},{"def":"Of old; long since.","pos":""}],"STALEMATE":[{"def":"The position of the king when he can not move without being placed on check and there is no other piece which can be moved.","pos":""}],"STALENESS":[{"def":"The quality or state of being stale.","pos":""}],"STALK":[{"def":"An ornament in the Corinthian capital resembling the stalk of a plant, from which the volutes and helices spring.","pos":""},{"def":"An iron bar with projections inserted in a core to strengthen it; a core arbor.","pos":""}],"STALK-EYED":[{"def":"Having the eyes raised on a stalk, or peduncle; -- opposed to sessile-eyed.","pos":""}],"STALKED":[{"def":"Having a stalk or stem; borne upon a stem.","pos":""}],"STALKER":[{"def":"A kind of fishing net.","pos":""}],"STALKING-HORSE":[{"def":"A horse, or a figure resembling a horse, behind which a hunter conceals himself from the game he is aiming to kill.","pos":""}],"STALKLESS":[{"def":"Having no stalk.","pos":""}],"STALKY":[{"def":"Hard as a stalk; resembling a stalk.","pos":""}],"STALL":[{"def":"The space left by excavation between pillars.","pos":""}],"STALL-FEED":[{"def":"To feed and fatten in a stall or on dry fodder; as, to stall- feed an ox.","pos":""}],"STALLAGE":[{"def":"The right of erecting a stalls in fairs; rent paid for a stall.","pos":""}],"STALLED":[{"def":"Put or kept in a stall; hence, fatted.","pos":""}],"STALLER":[{"def":"A standard bearer.","pos":""}],"STALLION":[{"def":"A male horse not castrated; a male horse kept for breeding.","pos":""}],"STALLMAN":[{"def":"One who keeps a stall for the sale of merchandise, especially books.","pos":""}],"STALLON":[{"def":"A slip from a plant; a scion; a cutting.","pos":""},{"def":"Brave; bold; strong; redoubted; daring; vehement; violent.","pos":""}],"STALWARTLY":[{"def":"In a stalwart manner.","pos":""}],"STALWARTNESS":[{"def":"The quality of being stalwart.","pos":""},{"def":"The quality or state of being stalworth; stalwartness; boldness; daring.","pos":""}]}