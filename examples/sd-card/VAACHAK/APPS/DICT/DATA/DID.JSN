{"DID":[{"def":"Fitted or intended to teach; conveying instruction; preceptive; instructive; teaching some moral lesson; as, didactic essays.","pos":""}],"DIDACTIC":[{"def":"A treatise on teaching or education.","pos":""}],"DIDACTICALLY":[{"def":"In a didactic manner.","pos":""}],"DIDACTICISM":[{"def":"The didactic method or system.","pos":""}],"DIDACTICITY":[{"def":"Aptitude for teaching.","pos":""}],"DIDACTICS":[{"def":"The art or science of teaching.","pos":""}],"DIDACTYL":[{"def":"An animal having only two digits.","pos":""}],"DIDACTYLOUS":[{"def":"Having only two digits; two-toed.","pos":""}],"DIDAL":[{"def":"A kind of triangular spade.","pos":""}],"DIDASCALIC":[{"def":"Didactic; preceptive.","pos":""}],"DIDDLE":[{"def":"To totter, as a child in walking.","pos":""}],"DIDDLER":[{"def":"James Kenney, entitled \"Raising the wind.","pos":""}],"DIDELPHIA":[{"def":"The subclass of Mammalia which includes the marsupials.","pos":""}],"DIDELPHIAN":[{"def":"Of or relating to the Didelphia.","pos":""},{"def":"One of the Didelphia.","pos":""}],"DIDELPHIC":[{"def":"Having the uterus double; of or pertaining to the Didelphia.","pos":""}],"DIDELPHID":[{"def":"Same as Didelphic.","pos":""}],"DIDELPHOUS":[{"def":"Formerly, any marsupial; but the term is now restricted to an American genus which includes the opossums, of which there are many species.","pos":""}],"DIDELPHYC":[{"def":"Same as Didelphic.","pos":""}],"DIDELPHYS":[{"def":"Formerly, any marsupial; but the term is now restricted to an American genus which includes the opossums, of which there are many species.","pos":""}],"DIDINE":[{"def":"Like or pertaining to the genus Didus, or the dodo.","pos":""}],"DIDO":[{"def":"A shrewd trick; an antic; a caper.","pos":""}],"DIDONIA":[{"def":"The curve which on a given surface and with a given perimeter contains the greatest area.","pos":""},{"def":"A two-drachma piece; an ancient Greek silver coin, worth nearly forty cents.","pos":""}],"DIDST":[{"def":"Didst Defn: , the 2d pers.","pos":""}],"DIDUCEMENT":[{"def":"Diduction; separation into distinct parts.","pos":""}],"DIDUCTION":[{"def":"The act of drawing apart; separation.","pos":""}],"DIDYMIUM":[{"def":"A rare metallic substance usually associated with the metal cerium; -- hence its name.","pos":""}],"DIDYMOUS":[{"def":"Growing in pairs or twins.","pos":""}],"DIDYNAMIA":[{"def":"A Linnæan class of plants having four stamens disposed in pairs of unequal length.","pos":""}],"DIDYNAMOUS":[{"def":"Of or pertaining to the Didynamia; containing four stamens disposed in pairs of unequal length.","pos":""}]}