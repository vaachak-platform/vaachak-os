{"EMU":[{"def":"A large Australian bird, of two species (Dromaius Novæ- Hollandiæ and D.","pos":""}],"EMU WREN":[{"def":"A small wrenlike Australian bird (Stipiturus malachurus), having the tail feathers long and loosely barbed, like emu feathers.","pos":""}],"EMULABLE":[{"def":"Capable of being emulated.","pos":""}],"EMULATE":[{"def":"Striving to excel; ambitious; emulous.","pos":""}],"EMULATION":[{"def":"The endeavor to equal or to excel another in qualities or actions; an assiduous striving to equal or excel another; rivalry.","pos":""},{"def":"Jea Such factious emulations shall arise.","pos":""}],"EMULATIVE":[{"def":"Inclined to emulation; aspiring to competition; rivaling; as, an emulative person or effort.","pos":""}],"EMULATIVELY":[{"def":"In an emulative manner; with emulation.","pos":""}],"EMULATOR":[{"def":"One who emulates, or strives to equal or surpass.","pos":""}],"EMULATORY":[{"def":"Pertaining to emulation; connected with rivalry.","pos":""}],"EMULATRESS":[{"def":"A female emulator.","pos":""}],"EMULGE":[{"def":"To milk out; to drain.","pos":""}],"EMULGENT":[{"def":"Pertaining to the kidneys; renal; as, emulgent arteries and veins.","pos":""},{"def":"An emulgent vessel, as a renal artery or vein.","pos":""}],"EMULOUS":[{"def":"Ambitiously desirous to equal or even to excel another; eager to emulate or vie with another; desirous of like excellence with another; -- with of; as, emulous of another's example or virtues.","pos":""},{"def":"Vying with; rivaling; hence, contentious, envious.","pos":""}],"EMULOUSLY":[{"def":"In an emulous manner.","pos":""}],"EMULOUSNESS":[{"def":"The quality of being emulous.","pos":""}],"EMULSIC":[{"def":"Pertaining to, or produced from, emulsin; as, emulsic acid.","pos":""}],"EMULSIFY":[{"def":"To convert into an emulsion; to form an emulsion; to reduce from an oily substance to a milky fluid in which the fat globules are in a very finely divided state, giving it the semblance of solution; as, the pancreatic juice emulsifies the oily part of food.","pos":""}],"EMULSION":[{"def":"Any liquid preparation of a color and consistency resembling milk; as: (a) In pharmacy, an extract of seeds, or a mixture of oil and water united by a mucilaginous substance.","pos":""}],"EMULSIVE":[{"def":"Softening; milklike.","pos":""},{"def":"Yielding oil by expression; as, emulsive seeds.","pos":""}],"EMUNCTORY":[{"def":"Any organ or part of the body (as the kidneys, skin, etc.","pos":""}],"EMUSCATION":[{"def":"A freeing from moss.","pos":""}]}