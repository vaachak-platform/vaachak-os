{"PROG":[{"def":"To wander about and beg; to seek food or other supplies by low arts; to seek for advantage by mean shift or tricks.","pos":""},{"def":"To steal; to rob; to filch.","pos":""}],"PROGENERATE":[{"def":"To beget; to generate; to produce; to procreate; as, to progenerate a race.","pos":""}],"PROGENERATION":[{"def":"The act of begetting; propagation.","pos":""}],"PROGENITOR":[{"def":"An ancestor in the direct line; a forefather.","pos":""}],"PROGENITORSHIP":[{"def":"The state of being a progenitor.","pos":""}],"PROGENITRESS":[{"def":"A female progenitor.","pos":""}],"PROGENITURE":[{"def":"A begetting, or birth.","pos":""}],"PROGENY":[{"def":"Descendants of the human kind, or offspring of other animals; children; offspring; race, lineage.","pos":""}],"PROGLOTTIS":[{"def":"One of the free, or nearly free, segments of a tapeworm.","pos":""}],"PROGNATHI":[{"def":"A comprehensive group of mankind, including those that have prognathous jaws.","pos":""}],"PROGNATHISM":[{"def":"Projection of the jaws.","pos":""}],"PROGNATHOUS":[{"def":"Having the jaws projecting beyond the upper part of the face; - - opposed to orthognathous.","pos":""}],"PROGNOSIS":[{"def":"The act or art of foretelling the course and termination of a disease; also, the outlook afforded by this act of judgment; as, the prognosis of hydrophobia is bad.","pos":""}],"PROGNOSTIC":[{"def":"Indicating something future by signs or symptoms; foreshowing; aiding in prognosis; as, the prognostic symptoms of a disease; prognostic signs.","pos":""}],"PROGNOSTICABLE":[{"def":"Capable of being prognosticated or foretold.","pos":""}],"PROGNOSTICATE":[{"def":"To indicate as future; to foretell from signs or symptoms; to prophesy; to foreshow; to predict; as, to prognosticate evil.","pos":""}],"PROGNOSTICATION":[{"def":"The act of foreshowing or foretelling something future by present signs; prediction.","pos":""},{"def":"That which foreshows; a foretoken.","pos":""}],"PROGNOSTICATOR":[{"def":"One who prognosticates; a foreknower or foreteller of a future course or event by present signs.","pos":""}],"PROGRAM":[{"def":"Same as Programme.","pos":""}],"PROGRAMMA":[{"def":"Any law, which, after it had passed the Athenian senate, was fixed on a tablet for public inspection previously to its being proposed to the general assembly of the people.","pos":""}],"PROGRAMME":[{"def":"That which is written or printed as a public notice or advertisement; a scheme; a prospectus; especially, a brief outline or explanation of the order to be pursued, or the subjects embraced, in any public exercise, performance, or entertainment; a preliminary sketch.","pos":""}],"PROGRESS":[{"def":"A moving or going forward; a proceeding onward; an advance; specifically: (a) In actual space, as the progress of a ship, carriage, etc.","pos":""},{"def":"A journey of state; a circuit; especially, one made by a sovereign through parts of his own dominions.","pos":""}],"PROGRESSION":[{"def":"Regular or proportional advance in increase or decrease of numbers; continued proportion, arithmetical, geometrical, or harmonic.","pos":""},{"def":"A regular succession of tones or chords; the movement of the parts in harmony; the order of the modulations in a piece from key to key.","pos":""}],"PROGRESSIONAL":[{"def":"Of or pertaining to progression; tending to, or capable of, progress.","pos":""}],"PROGRESSIONIST":[{"def":"One who holds to a belief in the progression of society toward perfection.","pos":""},{"def":"One who maintains the doctrine of progression in organic forms; -- opposed to uniformitarian.","pos":""}],"PROGRESSIST":[{"def":"One who makes, or holds to, progress; a progressionist.","pos":""}],"PROGRESSIVE":[{"def":"Moving forward; proceeding onward; advancing; evincing progress; increasing; as, progressive motion or course; -- opposed to retrograde.","pos":""},{"def":"Improving; as, art is in a progressive state.","pos":""}],"PROGRESSIVE PARTY":[{"def":"The political party formed, chiefly out of the Republican party, by the adherents of Theodore Roosevelt in the presidential campaign of 1912.","pos":""}],"PROGUE":[{"def":"A sharp point; a goad.","pos":""},{"def":"To prick; to goad.","pos":""}]}