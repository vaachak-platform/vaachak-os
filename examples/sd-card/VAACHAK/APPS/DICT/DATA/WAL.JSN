{"WALD":[{"def":"A forest; -- used as a termination of names.","pos":""}],"WALDENSES":[{"def":"A sect of dissenters from the ecclesiastical system of the Roman Catholic Church, who in the 13th century were driven by persecution to the valleys of Piedmont, where the sect survives.","pos":""}],"WALDENSIAN":[{"def":"Of or pertaining to the Waldenses.","pos":""},{"def":"One Holding the Waldensian doctrines.","pos":""}],"WALDGRAVE":[{"def":"In the old German empire, the head forest keeper.","pos":""}],"WALDHEIMIA":[{"def":"A genus of brachiopods of which many species are found in the fossil state.","pos":""}],"WALE":[{"def":"A timber bolted to a row of piles to secure them together and in position.","pos":""},{"def":"Certain sets or strakes of the outside planking of a vessel; as, the main wales, or the strakes of planking under the port sills of the gun deck; channel wales, or those along the spar deck, etc.","pos":""}],"WALER":[{"def":"A horse imported from New South Wales; also, any Australian horse.","pos":""}],"WALING":[{"def":"Same as Wale, n.","pos":""}],"WALK":[{"def":"To move along on foot; to advance by steps; to go on at a moderate pace; specifically, of two-legged creatures, to proceed at a slower or faster rate, but without running, or lifting one foot entirely before the other touches the ground.","pos":""},{"def":"To move or go on the feet for exercise or amusement; to take one's exercise; to ramble.","pos":""}],"WALK-OVER":[{"def":"In racing, the going over a course by a horse which has no competitor for the prize; hence, colloquially, a one-sided contest; an uncontested, or an easy, victory.","pos":""}],"WALKABLE":[{"def":"Fit to be walked on; capable of being walked on or over.","pos":""}],"WALKER":[{"def":"A forest officer appointed to walk over a certain space for inspection; a forester.","pos":""},{"def":"A fuller of cloth.","pos":""}],"WALL":[{"def":"A kind of knot often used at the end of a rope; a wall knot; a wale.","pos":""}],"WALL STREET":[{"def":"A street towards the southern end of the borough of Manhattan, New York City, extending from Broadway to the East River; -- so called from the old wall which extended along it when the city belonged to the Dutch.","pos":""}],"WALL-EYE":[{"def":"An eye in which the iris is of a very light gray or whitish color; -- said usually of horses.","pos":""}],"WALL-EYED":[{"def":"Having an eye of a very light gray or whitish color.","pos":""}],"WALL-PLAT":[{"def":"The spotted flycatcher.","pos":""}],"WALL-SIDED":[{"def":"Having sides nearly perpendicular; -- said of certain vessels to distinguish them from those having flaring sides, or sides tumbling home (see under Tumble, v.","pos":""}],"WALLABA":[{"def":"A leguminous tree (Eperua falcata) of Demerara, with pinnate leaves and clusters of red flowers.","pos":""}],"WALLABY":[{"def":"Any one of numerous species of kangaroos belonging to the genus Halmaturus, native of Australia and Tasmania, especially the smaller species, as the brush kangaroo (H.","pos":""}],"WALLACHIAN":[{"def":"Of or pertaining to Wallachia, a former principality, now part of the kingdom, of Roumania.","pos":""},{"def":"An inhabitant of Wallachia; also, the language of the Wallachians; Roumanian.","pos":""}],"WALLAH":[{"def":"A black variety of the jaguar; -- called also tapir tiger.","pos":""}],"WALLAROO":[{"def":"Any one of several species of kangaroos of the genus Macropus, especially M.","pos":""}],"WALLBIRD":[{"def":"The spotted flycatcher.","pos":""}],"WALLER":[{"def":"One who builds walls.","pos":""}],"WALLERIAN DEGENERATION":[{"def":"A form of degeneration occurring in nerve fibers as a result of their division; -- so called from Dr.","pos":""}],"WALLET":[{"def":"A bag or sack for carrying about the person, as a bag for carrying the necessaries for a journey; a knapsack; a beggar's receptacle for charity; a peddler's pack.","pos":""},{"def":"A pocketbook for keeping money about the person.","pos":""}],"WALLETEER":[{"def":"One who carries a wallet; a foot traveler; a tramping beggar.","pos":""}],"WALLFLOWER":[{"def":"A perennial, cruciferous plant (Cheiranthus Cheiri), with sweet-scented flowers varying in color from yellow to orange and deep red.","pos":""}],"WALLHICK":[{"def":"The lesser spotted woodpecker (Dryobates minor).","pos":""}],"WALLING":[{"def":"The act of making a wall or walls.","pos":""},{"def":"Walls, in general; material for walls.","pos":""}],"WALLOONS":[{"def":"A Romanic people inhabiting that part of Belgium which comprises the provinces of Hainaut, Namur, Liége, and Luxembourg, and about one third of Brabant; also, the language spoken by this people.","pos":""}],"WALLOP":[{"def":"To move quickly, but with great effort; to gallop.","pos":""}],"WALLOW":[{"def":"To roll one's self about, as in mire; to tumble and roll about; to move lazily or heavily in any medium; to flounder; as, swine wallow in the mire.","pos":""},{"def":"To live in filth or gross vice; to disport one's self in a beastly and unworthy manner.","pos":""}],"WALLOWER":[{"def":"A lantern wheel; a trundle.","pos":""}],"WALLWORT":[{"def":"The dwarf elder, or danewort (Sambucus Ebulus).","pos":""}],"WALM":[{"def":"To roll; to spout; to boil up.","pos":""}],"WALNUT":[{"def":"The fruit or nut of any tree of the genus Juglans; also, the tree, and its timber.","pos":""}],"WALRUS":[{"def":"A very large marine mammal (Trichecus rosmarus) of the Seal family, native of the Arctic Ocean.","pos":""}],"WALTER":[{"def":"To roll or wallow; to welter.","pos":""}],"WALTY":[{"def":"Liable to roll over; crank; as, a walty ship.","pos":""}],"WALTZ":[{"def":"A dance performed by two persons in circular figures with a whirling motion; also, a piece of music composed in triple measure for this kind of dance.","pos":""}],"WALTZER":[{"def":"A person who waltzes.","pos":""}],"WALY":[{"def":"An exclamation of grief.","pos":""}]}