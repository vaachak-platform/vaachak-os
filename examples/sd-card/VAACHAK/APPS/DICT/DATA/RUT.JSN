{"RUT":[{"def":"Sexual desire or oestrus of deer, cattle, and various other mammals; heat; also, the period during which the oestrus exists.","pos":""}],"RUTA-BAGA":[{"def":"A kind of turnip commonly with a large and long or ovoid yellowish root; a Swedish turnip.","pos":""}],"RUTACEOUS":[{"def":"Of or pertaining to plants of a natural order (Rutacæ) of which the rue is the type, and which includes also the orange, lemon, dittany, and buchu.","pos":""}],"RUTATE":[{"def":"A salt of rutic acid.","pos":""}],"RUTH":[{"def":"Sorrow for the misery of another; pity; tenderness.","pos":""},{"def":"That which causes pity or compassion; misery; distress; a pitiful.","pos":""}],"RUTHENIC":[{"def":"Pertaining to, or containing, ruthenium; specifically, designating those compounds in which it has a higher valence as contrasted with ruthenious compounds.","pos":""}],"RUTHENIOUS":[{"def":"Pertaining to, or containing, ruthenium; designating those compounds in which it has a lower valence as contrasted with ruthenic compounds.","pos":""}],"RUTHENIUM":[{"def":"A rare element of the light platinum group, found associated with platinum ores, and isolated as a hard, brittle steel-gray metal which is very infusible.","pos":""}],"RUTHFUL":[{"def":"Full of ruth; as: (a) Pitiful; tender.","pos":""}],"RUTHLESS":[{"def":"Having no ruth; cruel; pitiless.","pos":""}],"RUTIC":[{"def":"pertaining to, or obtained from, rue (Ruta); as, rutic acid, now commonly called capric acid.","pos":""}],"RUTILANT":[{"def":"Having a reddish glow; shining.","pos":""}],"RUTILATE":[{"def":"To shine; to emit rays of light.","pos":""}],"RUTILE":[{"def":"A mineral usually of a reddish brown color, and brilliant metallic adamantine luster, occurring in tetragonal crystals.","pos":""}],"RUTILIAN":[{"def":"Any species of lamellicorn beetles belonging to Rurila and allied genera, as the spotted grapevine beetle (Pelidnota punctata).","pos":""}],"RUTIN":[{"def":"A glucoside resembling, but distinct from, quercitrin.","pos":""}],"RUTINOSE":[{"def":"A disaccharide present in glycosides.","pos":""}],"RUTTER":[{"def":"A horseman or trooper.","pos":""}],"RUTTERKIN":[{"def":"An old crafty fox or beguiler -- a word of contempt.","pos":""}],"RUTTIER":[{"def":"A chart of a course, esp.","pos":""}],"RUTTISH":[{"def":"Inclined to rut; lustful; libidinous; salacious.","pos":""}],"RUTTLE":[{"def":"A rattling sound in the throat arising from difficulty of breathing; a rattle.","pos":""}],"RUTTY":[{"def":"Ruttish; lustful.","pos":""}],"RUTYLENE":[{"def":"A liquid hydrocarbon, C10H18, of the acetylene series.","pos":""}]}