{"CINCH":[{"def":"A strong saddle girth, as of canvas.","pos":""}],"CINCHONA":[{"def":"A genus of trees growing naturally on the Andes in Peru and adjacent countries, but now cultivated in the East Indies, producing a medicinal bark of great value.","pos":""},{"def":"The bark of any species of cinchona containing three per cent.","pos":""}],"CINCHONACEOUS":[{"def":"Allied or pertaining to cinchona, or to the plants that produce it.","pos":""}],"CINCHONIC":[{"def":"Belonging to, or obtained from, cinchona.","pos":""}],"CINCHONIDINE":[{"def":"One of the quinine group of alkaloids, found especially in red cinchona bark.","pos":""}],"CINCHONINE":[{"def":"One of the quinine group of alkaloids isomeric with and resembling cinchonidine; -- called also cinchonia.","pos":""}],"CINCHONISM":[{"def":"A condition produced by the excessive or long-continued use of quinine, and marked by deafness, roaring in the ears, vertigo, etc.","pos":""}],"CINCHONIZE":[{"def":"To produce cinchonism in; to poison with quinine or with cinchona.","pos":""}],"CINCINNATI EPOCH":[{"def":"An epoch at the close of the American lower Silurian system.","pos":""}],"CINCINNUS":[{"def":"A form of monochasium in which the lateral branches arise alternately on opposite sides of the false axis; -- called also scorpioid cyme.","pos":""}],"CINCTURE":[{"def":"The fillet, listel, or band next to the apophyge at the extremity of the shaft of a column.","pos":""}],"CINCTURED":[{"def":"Having or wearing a cincture or gridle.","pos":""}],"CINDER":[{"def":"Partly burned or vitrified coal, or other combustible, in which fire is extinct.","pos":""},{"def":"A hot coal without flame; an ember.","pos":""}],"CINDERY":[{"def":"Resembling, or composed of, cinders; full of cinders.","pos":""}],"CINEFACTION":[{"def":"Cineration; reduction to ashes.","pos":""}],"CINEMATOGRAPH":[{"def":"A camera for taking chronophotographs for exhibition by the instrument described above.","pos":""}],"CINEMATOGRAPHER":[{"def":"One who exhibits moving pictures or who takes chronophotographs by the cinematograph.","pos":""}],"CINEMOGRAPH":[{"def":"An integrating anemometer.","pos":""}],"CINERACEOUS":[{"def":"Like ashes; ash-colored; cinerous.","pos":""}],"CINERARIA":[{"def":"A Linnæan genus of free-flowering composite plants, mostly from South Africa.","pos":""}],"CINERARY":[{"def":"Pertaining to ashes; containing ashes.","pos":""}],"CINERATION":[{"def":"The reducing of anything to ashes by combustion; cinefaction.","pos":""}],"CINEREOUS":[{"def":"Like ashes; ash-colored; grayish.","pos":""}],"CINERESCENT":[{"def":"Somewhat cinereous; of a color somewhat resembling that of wood ashes.","pos":""}],"CINERITIOUS":[{"def":"Like ashes; having the color of ashes, -- as the cortical substance of the brain.","pos":""}],"CINGALESE":[{"def":"A native or natives of Ceylon descended from its primitive inhabitants; also (sing.","pos":""},{"def":"the language of the Cingalese.","pos":""}],"CINNABAR":[{"def":"Red sulphide of mercury, occurring in brilliant red crystals, and also in red or brown amorphous masses.","pos":""}],"CINNABARINE":[{"def":"Pertaining to, or resembling, cinnabar; consisting of cinnabar, or containing it; as, cinnabarine sand.","pos":""}],"CINNAMENE":[{"def":"Styrene (which was formerly called cinnamene because obtained from cinnamic acid).","pos":""}],"CINNAMIC":[{"def":"Pertaining to, or obtained from, cinnamon.","pos":""}],"CINNAMONE":[{"def":"A yellow crystalline substance, (C6H5.","pos":""}],"CINNAMYL":[{"def":"The hypothetical radical, (C6H5.","pos":""}],"CINNOLINE":[{"def":"A nitrogenous organic base, C8H6N2, analogous to quinoline, obtained from certain complex diazo compounds.","pos":""}],"CINQUE":[{"def":"Five; the number five in dice or cards.","pos":""}],"CINQUE PORTS":[{"def":"Five English ports, to which peculiar privileges were anciently accorded; -- viz.","pos":""}],"CINQUE-PACE":[{"def":"A lively dance (called also galliard), the steps of which were regulated by the number five.","pos":""}],"CINQUECENTIST":[{"def":"An Italian of the sixteenth century, esp.","pos":""},{"def":"A student or imitator of the art or literature of the Cinquecento.","pos":""}],"CINQUECENTO":[{"def":"The sixteenth century, when applied to Italian art or literature; as, the sculpture of the Cinquecento; Cinquecento style.","pos":""}],"CINQUEFOIL":[{"def":"The name of several different species of the genus Potentilla; -- also called five-finger, because of the resemblance of its leaves to the fingers of the hand.","pos":""},{"def":"An ornamental foliation having five points or cups, used in windows, panels, etc.","pos":""}],"CINURA":[{"def":"The group of Thysanura which includes Lepisma and allied forms; the bristletails.","pos":""}]}