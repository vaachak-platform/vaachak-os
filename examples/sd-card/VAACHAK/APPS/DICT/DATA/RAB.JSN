{"RAB":[{"def":"A rod or stick used by masons in mixing hair with mortar.","pos":""}],"RABAT":[{"def":"A polishing material made of potter's clay that has failed in baking.","pos":""}],"RABATE":[{"def":"To recover to the fist, as a hawk.","pos":""}],"RABATINE":[{"def":"A collar or cape.","pos":""}],"RABATO":[{"def":"A kind of ruff for the neck; a turned-down collar; a rebato.","pos":""}],"RABBATE":[{"def":"To abate or diminish.","pos":""}],"RABBET":[{"def":"To cut a rabbet in; to furnish with a rabbet.","pos":""},{"def":"To unite the edges of, as boards, etc.","pos":""}],"RABBI":[{"def":"Master; lord; teacher; -- a Jewish title of respect or honor for a teacher or doctor of the law.","pos":""}],"RABBIN":[{"def":"Of or pertaining to the rabbins or rabbis, or pertaining to the opinions, learning, or language of the rabbins.","pos":""}],"RABBINIC":[{"def":"The language or dialect of the rabbins; the later Hebrew.","pos":""}],"RABBINICALLY":[{"def":"In a rabbinical manner; after the manner of the rabbins.","pos":""}],"RABBINISM":[{"def":"A rabbinic expression or phraseology; a peculiarity of the language of the rabbins.","pos":""},{"def":"The teachings and traditions of the rabbins.","pos":""}],"RABBINIST":[{"def":"One among the Jews who adhered to the Talmud and the traditions of the rabbins, in opposition to the Karaites, who rejected the traditions.","pos":""}],"RABBINITE":[{"def":"Same as Rabbinist.","pos":""}],"RABBITING":[{"def":"The hunting of rabbits.","pos":""}],"RABBITRY":[{"def":"A place where rabbits are kept; especially, a collection of hutches for tame rabbits.","pos":""}],"RABBLE":[{"def":"An iron bar, with the end bent, used in stirring or skimming molten iron in the process of puddling.","pos":""}],"RABBLE-ROUT":[{"def":"A tumultuous crowd; a rabble; a noisy throng.","pos":""}],"RABBLEMENT":[{"def":"A tumultuous crowd of low people; a rabble.","pos":""}],"RABBLER":[{"def":"A scraping tool for smoothing metal.","pos":""}],"RABDOIDAL":[{"def":"Rab*doid\"al (rab*doid\"al), a.","pos":""}],"RABDOLOGY":[{"def":"The method or art of performing arithmetical operations by means of Napier's bones.","pos":""}],"RABDOMANCY":[{"def":"Divination by means of rods or wands.","pos":""}],"RABID":[{"def":"Furious; raging; extremely violent.","pos":""},{"def":"Extreme, unreasonable, or fanatical in opinion; excessively zealous; as, a rabid socialist.","pos":""}],"RABIDITY":[{"def":"Rabidness; furiousness.","pos":""}],"RABIDLY":[{"def":"In a rabid manner; with extreme violence.","pos":""}],"RABIDNESS":[{"def":"The quality or state of being rabid.","pos":""}],"RABIES":[{"def":"Same as Hydrophobia (b); canine madness.","pos":""}],"RABINET":[{"def":"A kind of small ordnance formerly in use.","pos":""}],"RABIOUS":[{"def":"Ra\"bi*ous (ra\"bi*us), a.","pos":""}],"RABOT":[{"def":"A rubber of hard wood used in smoothing marble to be polished.","pos":""}]}