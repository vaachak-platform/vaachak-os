{"RHABARBARATE":[{"def":"Impregnated or tinctured with rhubarb.","pos":""},{"def":"Chrysophanic acid.","pos":""}],"RHABDITE":[{"def":"A minute smooth rodlike or fusiform structure found in the tissues of many Turbellaria.","pos":""},{"def":"One of the hard parts forming the ovipositor of insects.","pos":""}],"RHABDOCOELA":[{"def":"A suborder of Turbellaria including those that have a simple cylindrical, or saclike, stomach, without an intestine.","pos":""}],"RHABDOCOELOUS":[{"def":"Of or pertaining to the Rhabdocoela.","pos":""}],"RHABDOLITH":[{"def":"A minute calcareous rodlike structure found both at the surface and the bottom of the ocean; -- supposed by some to be a calcareous alga.","pos":""}],"RHABDOLOGY":[{"def":"Same as Rabdology.","pos":""}],"RHABDOM":[{"def":"One of numerous minute rodlike structures formed of two or more cells situated behind the retinulæ in the compound eyes of insects, etc.","pos":""}],"RHABDOMANCY":[{"def":"Same as Rabdomancy.","pos":""}],"RHABDOMERE":[{"def":"One of the several parts composing a rhabdom.","pos":""}],"RHABDOPHORA":[{"def":"An extinct division of Hydrozoa which includes the graptolities.","pos":""}],"RHABDOPLEURA":[{"def":"A genus of marine Bryozoa in which the tubular cells have a centralchitinous axis and the tentacles are borne on a bilobed lophophore.","pos":""}],"RHABDOSPHERE":[{"def":"A minute sphere composed of rhabdoliths.","pos":""}],"RHACHIDIAN":[{"def":"Of or pertaining to the rhachis; as, the rhachidian teeth of a mollusk.","pos":""}],"RHACHIGLOSSA":[{"def":"A division of marine gastropods having a retractile proboscis and three longitudinal rows of teeth on the radula.","pos":"noun"}],"RHACHILLA":[{"def":"A branch of inflorescence; the zigzag axis on which the florets are arranged in the spikelets of grasses.","pos":""}],"RHACHIODONT":[{"def":"Having gular teeth formed by a peculiar modification of the inferior spines of some of the vertebræ, as certain South African snakes (Dasypelits) which swallow birds' eggs and use these gular teeth to crush them.","pos":""}],"RHADAMANTHINE":[{"def":"Of or pertaining to Rhadamanthus; rigorously just; as, a Rhadamanthine judgment.","pos":""},{"def":"One of the three judges of the internal regions; figuratively, a strictly just judge.","pos":""}],"RHAETIAN":[{"def":"Pertining to, or of the same horizon as, certain Mesozoic strata of the Rhetian Alps.","pos":""}],"RHAMNACEOUS":[{"def":"Of or pertaining to a natural order of shrubs and trees (Rhamnaceæ, or Rhamneæ) of which the buckthorn (Rhamnus) is the type.","pos":""}],"RHAMNUS":[{"def":"A genus of shrubs and small trees; buckthorn.","pos":""}],"RHAMPHORHYNCHUS":[{"def":"A genus of pterodactyls in which the elongated tail supported a leathery expansion at the tip.","pos":""}],"RHAMPHOTHECA":[{"def":"The horny covering of the bill of birds.","pos":""}],"RHAPHE":[{"def":"The continuation of the seed stalk along the side of an anatropous ovule or seed, forming a ridge or seam.","pos":""}],"RHAPHIDES":[{"def":"Minute transparent, often needlle-shaped, crystals found in the tissues of plants.","pos":""}],"RHAPONTICINE":[{"def":"Chrysophanic acid.","pos":""}],"RHAPSODER":[{"def":"Of or pertaining to rhapsody; consisting of rhapsody; hence, confused; unconnected.","pos":""}],"RHAPSODIST":[{"def":"Anciently, one who recited or composed a rhapsody; especially, one whose profession was to recite the verses of Hormer and other epic poets.","pos":""},{"def":"Hence, one who recites or sings poems for a livelihood; one who makes and repeats verses extempore.","pos":""}],"RHAPSODIZE":[{"def":"To utter as a rhapsody, or in the manner of a rhapsody Sterne.","pos":""}],"RHAPSODOMANCY":[{"def":"Divination by means of verses.","pos":""}],"RHAPSODY":[{"def":"A composition irregular in form, like an improvisation; as, Liszt's \"Hungarian Rhapsodies.","pos":""},{"def":"The powerfully astringent root of a half-shrubby Peruvian plant (Krameria triandra).","pos":""}]}