{"MEACH":[{"def":"To skulk; to cower.","pos":""}],"MEACOCK":[{"def":"An uxorious, effeminate, or spiritless man.","pos":""}],"MEAD":[{"def":"A fermented drink made of water and honey with malt, yeast, etc.","pos":""},{"def":"A drink composed of sirup of sarsaparilla or other flavoring extract, and water.","pos":""}],"MEADOW":[{"def":"A tract of low or level land producing grass which is mown for hay; any field on which grass is grown for hay.","pos":""},{"def":"Low land covered with coarse grass or rank herbage near rives and in marshy places by the sea; as, the salt meadows near Newark Bay.","pos":""}],"MEADOWY":[{"def":"Of or pertaining to meadows; resembling, or consisting of, meadow.","pos":""},{"def":"Dry and harsh to the touch, as chalk.","pos":""}],"MEAGRE":[{"def":"A large European sciænoid fish (Sciæna umbra or S.","pos":""}],"MEAK":[{"def":"A hook with a long handle.","pos":""}],"MEAKING":[{"def":"The process of picking out the oakum from the seams of a vessel which is to be recalked.","pos":""}],"MEAL":[{"def":"A part; a fragment; a portion.","pos":""}],"MEAL-MOUTHED":[{"def":"See Mealy-mouthed.","pos":""}],"MEALIES":[{"def":"Maize or Indian corn; -- the common name in South Africa.","pos":""}],"MEALINESS":[{"def":"The quality or state of being mealy.","pos":""}],"MEALTIME":[{"def":"The usual time of eating a meal.","pos":""}],"MEALY":[{"def":"Having the qualities of meal; resembling meal; soft, dry, and friable; easily reduced to a condition resembling meal; as, a mealy potato.","pos":""},{"def":"Overspread with something that resembles meal; as, the mealy wings of an insect.","pos":""}],"MEALY-MOUTHED":[{"def":"Using soft words; plausible; affectedly or timidly delicate of speech; unwilling to tell the truth in plain language.","pos":""}],"MEAN":[{"def":"To have in the mind, as a purpose, intention, etc.","pos":""},{"def":"To signify; to indicate; to import; to denote.","pos":""}],"MEAN-SPIRITED":[{"def":"Of a mean spirit; base; groveling.","pos":""}],"MEANDER":[{"def":"A winding, crooked, or involved course; as, the meanders of the veins and arteries.","pos":""},{"def":"A tortuous or intricate movement.","pos":""}],"MEANDRIAN":[{"def":"Winding; having many turns.","pos":""}],"MEANDRINA":[{"def":"A genus of corals with meandering grooves and ridges, including the brain corals.","pos":""},{"def":"Winding; flexuous.","pos":""}],"MEANING":[{"def":"That which is meant or intended; intent; purpose; aim; object; as, a mischievous meaning was apparent.","pos":""},{"def":"That which is signified, whether by act lanquage; signification; sence; import; as, the meaning of a hint.","pos":""}],"MEANLY":[{"def":"A man meanly learned himself, but not meanly affectioned to set forward learning in others.","pos":""}],"MEANNESS":[{"def":"The condition, or quality, of being mean; want of excellence; poorness; lowness; baseness; sordidness; stinginess.","pos":""},{"def":"A mean act; as, to be guilty of meanness.","pos":""}],"MEANT":[{"def":"The intervening time; as, in the meantime (or mean time).","pos":""}],"MEASE":[{"def":"Five hundred; as, a mease of herrings.","pos":""}],"MEASLE":[{"def":"A tapeworm larva.","pos":""}],"MEASLED":[{"def":"Infected or spotted with measles, as pork.","pos":""}],"MEASLES":[{"def":"Leprosy; also, a leper.","pos":""}],"MEASLY":[{"def":"Containing larval tapeworms; -- said of pork and beef.","pos":""}],"MEASURABLE":[{"def":"Capable of being measured; susceptible of mensuration or computation.","pos":""},{"def":"Moderate; temperate; not excessive.","pos":""}],"MEASURE":[{"def":"The space between two bars.","pos":""},{"def":"A number which is contained in a given number a number of times without a remainder; as in the phrases, the common measure, the greatest common measure, etc.","pos":""}],"MEASURED":[{"def":"Regulated or determined by a standard; hence, equal; uniform; graduated; limited; moderated; as, he walked with measured steps; he expressed himself in no measured terms.","pos":""}],"MEASURELESS":[{"def":"Without measure; unlimited; immeasurable.","pos":""}],"MEASUREMENT":[{"def":"The act or result of measuring; mensuration; as, measurement is required.","pos":""},{"def":"The extent, size, capacity, amount.","pos":""}],"MEASURER":[{"def":"One who measures; one whose occupation or duty is to measure commondities in market.","pos":""}],"MEASURING":[{"def":"Used in, or adapted for, ascertaining measurements, or dividing by measure.","pos":""}],"MEAT":[{"def":"Food, in general; anything eaten for nourishment, either by man or beast.","pos":""},{"def":"The flesh of animals used as food; esp.","pos":""}],"MEATAL":[{"def":"Of or pertaining to a meatus; resembling a meatus.","pos":""}],"MEATED":[{"def":"A sweet liquor; mead.","pos":""}],"MEATINESS":[{"def":"Quality of being meaty.","pos":""}],"MEATLESS":[{"def":"Having no meat; without food.","pos":""}],"MEATOSCOPE":[{"def":"A speculum for examining a natural passage, as the urethra.","pos":""}],"MEATOTOME":[{"def":"An instrument for cutting into the urethra so as to enlarge its orifice.","pos":""}],"MEATUS":[{"def":"A natural passage or canal; as, the external auditory meatus.","pos":""}],"MEATY":[{"def":"Abounding in meat.","pos":""}],"MEAW":[{"def":"See Mew, to cry as a cat.","pos":""}],"MEAWL":[{"def":"See Mewl, and Miaul.","pos":""}],"MEAZLING":[{"def":"Falling in small drops; mistling; mizzing.","pos":""}]}