{"MISE":[{"def":"The issue in a writ of right.","pos":""}],"MISEASE":[{"def":"Want of ease; discomfort; misery.","pos":""}],"MISEASED":[{"def":"Having discomfort or misery; troubled.","pos":""}],"MISEASY":[{"def":"Not easy; painful.","pos":""}],"MISEDITION":[{"def":"An incorrect or spurious edition.","pos":""}],"MISEDUCATE":[{"def":"To educate in a wrong manner.","pos":""}],"MISEMPLOY":[{"def":"To employ amiss; as, to misemploy time, advantages, talents, etc.","pos":""}],"MISEMPLOYMENT":[{"def":"Wrong or mistaken employment.","pos":""}],"MISENTER":[{"def":"To enter or insert wrongly, as a charge in an account.","pos":""}],"MISENTREAT":[{"def":"To treat wrongfully.","pos":""}],"MISENTRY":[{"def":"An erroneous entry or charge, as of an account.","pos":""}],"MISER":[{"def":"A wretched person; a person afflicted by any great misfortune.","pos":""},{"def":"A despicable person; a wretch.","pos":""}],"MISERABLE":[{"def":"Very unhappy; wretched.","pos":""},{"def":"Causing unhappiness or misery.","pos":""}],"MISERABLENESS":[{"def":"The state or quality of being miserable.","pos":""}],"MISERABLY":[{"def":"In a miserable; unhappily; calamitously; wretchedly; meanly.","pos":""}],"MISERERE":[{"def":"The psalm usually appointed for penitential acts, being the 50th psalm in the Latin version.","pos":""},{"def":"A small projecting boss or bracket, on the under side of the hinged seat of a church stall (see Stall).","pos":""}],"MISERICORDE":[{"def":"Same as Misericordia, 2.","pos":""}],"MISERICORDIA":[{"def":"A thin-bladed dagger; so called, in the Middle Ages, because used to give the death wound or \"mercy\" stroke to a fallen adversary.","pos":""}],"MISERLY":[{"def":"Like a miser; very covetous; sordid; niggardly.","pos":""}],"MISERY":[{"def":"Great unhappiness; extreme pain of body or mind; wretchedness; distress; woe.","pos":""},{"def":"Cause of misery; calamity; misfortune.","pos":""}],"MISESTEEM":[{"def":"Want of esteem; disrespect.","pos":""}],"MISESTIMATE":[{"def":"To estimate erroneously.","pos":""}],"MISEXPLANATION":[{"def":"An erroneous explanation.","pos":""}],"MISEXPLICATION":[{"def":"Wrong explication.","pos":""}],"MISEXPOSITION":[{"def":"Wrong exposition.","pos":""}],"MISEXPOUND":[{"def":"To expound erroneously.","pos":""}],"MISEXPRESSION":[{"def":"Wrong expression.","pos":""}]}