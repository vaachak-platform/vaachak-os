{"AI":[{"def":"The three-toed sloth (Bradypus tridactylus) of South America.","pos":""},{"def":"Perhaps; possibly.","pos":""}],"AICH'S METAL":[{"def":"A kind of gun metal, containing copper, zinc, and iron, but no tin.","pos":""}],"AID":[{"def":"To support, either by furnishing strength or means in coöperation to effect a purpose, or to prevent or to remove evil; to help; to assist.","pos":""}],"AID-DE-CAMP":[{"def":"An officer selected by a general to carry orders, also to assist or represent him in correspondence and in directing movements.","pos":""}],"AID-MAJOR":[{"def":"The adjutant of a regiment.","pos":""}],"AIDANCE":[{"def":"Aidance 'gainst the enemy.","pos":""}],"AIDANT":[{"def":"Helping; helpful; supplying aid.","pos":""}],"AIDER":[{"def":"One who, or that which, aids.","pos":""}],"AIDLESS":[{"def":"Helpless; without aid.","pos":""}],"AIGREMORE":[{"def":"Charcoal prepared for making powder.","pos":""},{"def":"The small white European heron.","pos":""}],"AIGUILLE":[{"def":"A needle-shaped peak.","pos":""},{"def":"An instrument for boring holes, used in blasting.","pos":""}],"AIGUILLETTE":[{"def":"A point or tag at the end of a fringe or lace; an aglet.","pos":""},{"def":"One of the ornamental tags, cords, or loops on some military and naval uniforms.","pos":""}],"AIL":[{"def":"To affect with pain or uneasiness, either physical or mental; to trouble; to be the matter with; -- used to express some uneasiness or affection, whose cause is unknown; as, what ails the man I know not what ails him.","pos":""}],"AILANTHUS":[{"def":"Same as Ailantus.","pos":""}],"AILANTUS":[{"def":"A genus of beautiful trees, natives of the East Indies.","pos":""}],"AILERON":[{"def":"A half gable, as at the end of a penthouse or of the aisle of a church.","pos":""}],"AILETTE":[{"def":"A small square shield, formerly worn on the shoulders of knights, -- being the prototype of the modern epaulet.","pos":""}],"AILMENT":[{"def":"Indisposition; morbid affection of the body; -- not applied ordinarily to acute diseases.","pos":""}],"AILUROIDEA":[{"def":"A group of the Carnivora, which includes the cats, civets, and hyenas.","pos":""}],"AIM":[{"def":"To point or direct a missile weapon, or a weapon which propels as missile, towards an object or spot with the intent of hitting it; as, to aim at a fox, or at a target.","pos":""},{"def":"To direct the indention or purpose; to attempt the accomplishment of a purpose; to try to gain; to endeavor; -- followed by at, or by an infinitive; as, to aim at distinction; to aim to do well.","pos":""}],"AIMER":[{"def":"One who aims, directs, or points.","pos":""}],"AIMLESS":[{"def":"Without aim or purpose; as, an aimless life.","pos":""}],"AIN'T":[{"def":"A contraction for are not and am not; also used for is not.","pos":""}],"AINO":[{"def":"One of a peculiar race inhabiting Yesso, the Kooril Islands etc.","pos":""}],"AIR":[{"def":"An artificial or affected manner; show of pride or vanity; haughtiness; as, it is said of a person, he puts on airs.","pos":""},{"def":"The artificial motion or carriage of a horse.","pos":""}],"AIR BED":[{"def":"A sack or matters inflated with air, and used as a bed.","pos":""}],"AIR BLADDER":[{"def":"An air sac, sometimes double or variously lobed, in the visceral cavity of many fishes.","pos":""}],"AIR BRAKE":[{"def":"A railway brake operated by condensed air.","pos":""}],"AIR BRUSH":[{"def":"A kind of atomizer for applying liquid coloring matter in a spray by compressed air.","pos":""}],"AIR CELL":[{"def":"A cavity in the cellular tissue of plants, containing air only.","pos":""},{"def":"A receptacle of air in various parts of the system; as, a cell or minute cavity in the walls of the air tubes of the lungs; the air sac of birds; a dilatation of the air vessels in insects.","pos":""}],"AIR CHAMBER":[{"def":"A chamber or cavity filled with air, in an animal or plant.","pos":""},{"def":"A cavity containing air to act as a spring for equalizing the flow of a liquid in a pump or other hydraulic machine.","pos":""}],"AIR COCK":[{"def":"A faucet to allow escape of air.","pos":""}],"AIR COOLING":[{"def":"In gasoline-engine motor vehicles, the cooling of the cylinder by increasing its radiating surface by means of ribs or radiators, and placing it so that it is exposed to a current of air.","pos":""}],"AIR DRILL":[{"def":"A drill driven by the elastic pressure of condensed air; a pneumatic drill.","pos":""}],"AIR ENGINE":[{"def":"An engine driven by heated or by compressed air.","pos":""}],"AIR GAP":[{"def":"An air-filled gap in a magnetic or electric circuit; specif.","pos":""}],"AIR GUN":[{"def":"A kind of gun in which the elastic force of condensed air is used to discharge the ball.","pos":""}],"AIR HOLE":[{"def":"A fault in a casting, produced by a bubble of air; a blowhole.","pos":""}],"AIR JACKET":[{"def":"A jacket having air-tight cells, or cavities which can be filled with air, to render persons buoyant in swimming.","pos":""}],"AIR LINE":[{"def":"A path through the air made easy for aërial navigation by steady winds.","pos":""}],"AIR PIPE":[{"def":"A pipe for the passage of air; esp.","pos":""}],"AIR PLANT":[{"def":"A plant deriving its sustenance from the air alone; an aërophyte.","pos":""}],"AIR PUMP":[{"def":"A kind of pump for exhausting air from a vessel or closed space; also, a pump to condense air of force in into a closed space.","pos":""},{"def":"A pump used to exhaust from a condenser the condensed steam, the water used for condensing, and any commingled air.","pos":""}],"AIR SAC":[{"def":"One of the spaces in different parts.","pos":""}],"AIR SHAFT":[{"def":"A passage, usually vertical, for admitting fresh air into a mine or a tunnel.","pos":""}],"AIR STOVE":[{"def":"A stove for heating a current of air which is directed against its surface by means of pipes, and then distributed through a building.","pos":""}],"AIR VESSEL":[{"def":"A vessel, cell, duct, or tube containing or conducting air; as the air vessels of insects, birds, plants, etc.","pos":""},{"def":"Toward the air; upward.","pos":""}],"AIR-BUILT":[{"def":"Erected in the air; having no solid foundation; chimerical; as, an air-built castle.","pos":""}],"AIR-DRAWN":[{"def":"Drawn in air; imaginary.","pos":""}],"AIR-SLACKED":[{"def":"Slacked, or pulverized, by exposure to the air; as, air-slacked lime.","pos":""}],"AIR-TIGHT":[{"def":"So tight as to be impermeable to air; as, an air-tight cylinder.","pos":""}],"AIRCRAFT":[{"def":"Any device, as a balloon, aëroplane, etc.","pos":""}],"AIRER":[{"def":"One who exposes to the air.","pos":""},{"def":"A frame on which clothes are aired or dried.","pos":""}],"AIRILY":[{"def":"In an airy manner; lightly; gaily; jauntily; fippantly.","pos":""}],"AIRINESS":[{"def":"The state or quality of being airy; openness or exposure to the air; as, the airiness of a country seat.","pos":""},{"def":"Lightness of spirits; gayety; levity; as, the airiness of young persons.","pos":""}],"AIRING":[{"def":"A walk or a ride in the open air; a short excursion for health's sake.","pos":""},{"def":"An exposure to air, or to a fire, for warming, drying, etc.","pos":""}],"AIRLESS":[{"def":"Not open to a free current of air; wanting fresh air, or communication with the open air.","pos":""}],"AIRLING":[{"def":"A thoughtless, gay person.","pos":""}],"AIRMAN":[{"def":"A man who ascends or flies in an aircraft; a flying machine pilot.","pos":""}],"AIRMANSHIP":[{"def":"Art, skill, or ability in the practice of aërial navigation.","pos":""}],"AIROL":[{"def":"A grayish green antiseptic powder, consisting of a basic iodide and gallate of bismuth, sometimes used in place of iodoform.","pos":""}],"AIROMETER":[{"def":"A hollow cylinder to contain air.","pos":""}],"AIRSICK":[{"def":"Affected with aërial sickness.","pos":""}],"AIRWOMAN":[{"def":"A woman who ascends or flies in an aircraft.","pos":""}],"AIRY":[{"def":"Having the light and aërial tints true to nature.","pos":""}],"AISLED":[{"def":"Furnished with an aisle or aisles.","pos":""}],"AISLESS":[{"def":"Without an aisle.","pos":""}],"AIT":[{"def":"An islet, or little isle, in a river or lake; an eyot.","pos":""}],"AITCH":[{"def":"The letter h or H.","pos":""}],"AITCHBONE":[{"def":"The bone of the rump; also, the cut of beef surrounding this bone.","pos":""}]}