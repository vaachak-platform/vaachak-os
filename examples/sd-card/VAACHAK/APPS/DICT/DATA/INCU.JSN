{"INCUBATE":[{"def":"To sit, as on eggs for hatching; to brood; to brood upon, or keep warm, as eggs, for the purpose of hatching.","pos":""}],"INCUBATION":[{"def":"The development of a disease from its causes, or its period of incubation.","pos":""}],"INCUBATIVE":[{"def":"Of or pertaining to incubation, or to the period of incubation.","pos":""}],"INCUBATOR":[{"def":"That which incubates, especially, an apparatus by means of which eggs are hatched by artificial heat.","pos":""}],"INCUBATORY":[{"def":"Serving for incubation.","pos":""}],"INCUBE":[{"def":"To fix firmly, as in cube; to secure or place firmly.","pos":""}],"INCUBOUS":[{"def":"Having the leaves so placed that the upper part of each one covers the base of the leaf next above it, as in hepatic mosses of the genus Frullania.","pos":""}],"INCUBUS":[{"def":"A demon; a fiend; a lascivious spirit, supposed to have sexual intercourse with women by night.","pos":""},{"def":"Any oppressive encumbrance or burden; anything that prevents the free use of the faculties.","pos":""}],"INCULCATE":[{"def":"To teach and impress by frequent repetitions or admonitions; to urge on the mind; as, Christ inculcates on his followers humility.","pos":""}],"INCULCATION":[{"def":"A teaching and impressing by frequent repetitions.","pos":""}],"INCULCATOR":[{"def":"One who inculcates.","pos":""}],"INCULPABLE":[{"def":"Faultless; blameless; innocent.","pos":""}],"INCULPABLENESS":[{"def":"Blamelessness; faultlessness.","pos":""}],"INCULPATE":[{"def":"To blame; to impute guilt to; to accuse; to involve or implicate in guilt.","pos":""}],"INCULPATION":[{"def":"Blame; censure; crimination.","pos":""}],"INCULPATORY":[{"def":"Imputing blame; criminatory; compromising; implicating.","pos":""}],"INCULT":[{"def":"Untilled; uncultivated; crude; rude; uncivilized.","pos":""}],"INCULTIVATION":[{"def":"Want of cultivation.","pos":""}],"INCULTURE":[{"def":"Want or neglect of cultivation or culture.","pos":""}],"INCUMBENCY":[{"def":"The state of being incumbent; a lying or resting on something.","pos":""},{"def":"That which is physically incumbent; that which lies as a burden; a weight.","pos":""}],"INCUMBENT":[{"def":"Leaning or resting; -- said of anthers when lying on the inner side of the filament, or of cotyledons when the radicle lies against the back of one of them.","pos":""},{"def":"Bent downwards so that the ends touch, or rest on, something else; as, the incumbent toe of a bird.","pos":""}],"INCUMBENTLY":[{"def":"In an incumbent manner; so as to be incumbent.","pos":""}],"INCUMBRANCE":[{"def":"A burden or charge upon property; a claim or lien upon an estate, which may diminish its value.","pos":""}],"INCUMBRANCER":[{"def":"One who holds Kent.","pos":""}],"INCUMBROUS":[{"def":"Cumbersome; troublesome.","pos":""}],"INCUNABULUM":[{"def":"A work of art or of human industry, of an early epoch; especially, a book printed before A.","pos":""}],"INCUR":[{"def":"To render liable or subject to; to occasion.","pos":""}],"INCURABILITY":[{"def":"The state of being uncurable; irremediableness.","pos":""}],"INCURABLE":[{"def":"Not capable of being cured; beyond the power of skill or medicine to remedy; as, an incurable disease.","pos":""},{"def":"Not admitting or capable of remedy or correction; irremediable; remediless; as, incurable evils.","pos":""}],"INCURABLENESS":[{"def":"The state of being incurable; incurability.","pos":""}],"INCURABLY":[{"def":"In a manner that renders cure impracticable or impossible; irremediably.","pos":""}],"INCURIOSITY":[{"def":"Want of curiosity or interest; inattentiveness; indifference.","pos":""}],"INCURIOUS":[{"def":"Not curious or inquisitive; without care for or interest in; inattentive; careless; negligent; heedless.","pos":""}],"INCURIOUSLY":[{"def":"In an curious manner.","pos":""}],"INCURIOUSNESS":[{"def":"Unconcernedness; incuriosity.","pos":""}],"INCURRENCE":[{"def":"The act of incurring, bringing on, or subjecting one's self to (something troublesome or burdensome); as, the incurrence of guilt, debt, responsibility, etc.","pos":""}],"INCURRENT":[{"def":"Characterized by a current which flows inward; as, the incurrent orifice of lamellibranch Mollusca.","pos":""}],"INCURSION":[{"def":"A running into; hence, an entering into a territory with hostile intention; a temporary invasion; a predatory or harassing inroad; a raid.","pos":""},{"def":"Attack; occurrence.","pos":""}],"INCURSIVE":[{"def":"Making an incursion; invasive; aggressive; hostile.","pos":""}],"INCURVATE":[{"def":"Curved; bent; crooked.","pos":""}],"INCURVATION":[{"def":"The act of bending, or curving.","pos":""},{"def":"The state of being bent or curved; curvature.","pos":""}],"INCURVE":[{"def":"To bend; to curve; to make crooked.","pos":""}],"INCURVED":[{"def":"Bending gradually toward the axis or center, as branches or petals.","pos":""}],"INCURVITY":[{"def":"A state of being bent or curved; incurvation; a bending inwards.","pos":""}],"INCUS":[{"def":"One of the small bones in the tympanum of the ear; the anvil bone.","pos":""},{"def":"The central portion of the armature of the pharynx in the Rotifera.","pos":""}],"INCUSE":[{"def":"Cut or stamped in, or hollowed out by engraving.","pos":""},{"def":"To form, or mold, by striking or stamping, as a coin or medal.","pos":""}],"INCUTE":[{"def":"To strike or stamp in.","pos":""}]}