{"DISPIRIT":[{"def":"To deprive of cheerful spirits; to depress the spirits of; to dishearten; to discourage.","pos":""},{"def":"To distill or infuse the spirit of.","pos":""}],"DISPIRITED":[{"def":"Depressed in spirits; disheartened; daunted.","pos":""}],"DISPIRITMENT":[{"def":"Depression of spirits; discouragement.","pos":""}],"DISPITEOUS":[{"def":"Full of despite; cruel; spiteful; pitiless.","pos":""}]}