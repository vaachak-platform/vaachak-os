{"VERACIOUS":[{"def":"Observant of truth; habitually speaking truth; truthful; as, veracious historian.","pos":""},{"def":"Characterized by truth; not false; as, a veracious account or narrative.","pos":""}],"VERACIOUSLY":[{"def":"In a veracious manner.","pos":""}],"VERACITY":[{"def":"The quality or state of being veracious; habitual observance of truth; truthfulness; truth; as, a man of veracity.","pos":""}],"VERANDA":[{"def":"An open, roofed gallery or portico, adjoining a dwelling house, forming an out-of-door sitting room.","pos":""}],"VERATRALBINE":[{"def":"A yellowish amorphous alkaloid extracted from the rootstock of Veratrum album.","pos":""}],"VERATRATE":[{"def":"A salt of veratric acid.","pos":""}],"VERATRIC":[{"def":"Pertaining to, or derived from, plants of the genus Veratrum.","pos":""}],"VERATRINA":[{"def":"Same as Veratrine.","pos":""}],"VERATRINE":[{"def":"A poisonous alkaloid obtained from the root hellebore (Veratrum) and from sabadilla seeds as a white crystalline powder, having an acrid, burning taste.","pos":""}],"VERATROL":[{"def":"A liquid hydrocarbon obtained by the decomposition of veratric acid, and constituting the dimethyl ether of pyrocatechin.","pos":""}],"VERATRUM":[{"def":"A genus of coarse liliaceous herbs having very poisonous qualities.","pos":""}]}