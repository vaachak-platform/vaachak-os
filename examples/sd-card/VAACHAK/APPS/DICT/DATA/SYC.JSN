{"SYCEE":[{"def":"Silver, pounded into ingots of the shape of a shoe, and used as currency.","pos":""}],"SYCHNOCARPOUS":[{"def":"Having the capacity of bearing several successive crops of fruit without perishing; as, sychnocarpous plants.","pos":""}],"SYCITE":[{"def":"A nodule of flint, or a pebble, which resembles a fig.","pos":""}],"SYCOCERIC":[{"def":"Of, pertaining to, or designating, an acid obtained by the oxidation of sycoceryl alcohol.","pos":""}],"SYCOCERYL":[{"def":"A radical, of the aromatic series, regarded as an essential ingredient of certain compounds found in the waxy resin of an Australian species of fig.","pos":""}],"SYCOCK":[{"def":"The missel thrush.","pos":""}],"SYCONES":[{"def":"A division of calcareous sponges.","pos":""},{"def":"A collective fleshy fruit, in which the ovaries are hidden within a hollow receptacle, as in the fig.","pos":""}],"SYCOPHANCY":[{"def":"The character or characteristic of a sycophant.","pos":""}],"SYCOPHANT":[{"def":"An informer; a talebearer.","pos":""},{"def":"A base parasite; a mean or servile flatterer; especially, a flatterer of princes and great men.","pos":""}],"SYCOPHANTCY":[{"def":"Of or pertaining to a sycophant; characteristic of a sycophant; meanly or obsequiously flattering; courting favor by mean adulation; parasitic.","pos":""}],"SYCOPHANTISH":[{"def":"Like a sycophant; obsequiously flattering.","pos":""}],"SYCOPHANTIZE":[{"def":"To play the sycophant.","pos":""}],"SYCOSIS":[{"def":"A pustular eruption upon the scalp, or the beared part of the face, whether due to ringworm, acne, or impetigo.","pos":""}]}