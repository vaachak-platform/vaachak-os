{"GAD":[{"def":"The point of a spear, or an arrowhead.","pos":""},{"def":"A pointed or wedge-shaped instrument of metal, as a steel wedge used in mining, etc.","pos":""}],"GADABOUT":[{"def":"A gadder [Colloq.","pos":""}],"GADDER":[{"def":"One who roves about idly, a rambling gossip.","pos":""}],"GADDING":[{"def":"Going about much, needlessly or without purpose.","pos":""}],"GADDINGLY":[{"def":"In a roving, idle manner.","pos":""}],"GADDISH":[{"def":"Disposed to gad.","pos":""}],"GADE":[{"def":"GADERE; GADRE Gad\"er*e, Gad\"re (, v.","pos":""}],"GADFLY":[{"def":"Any dipterous insect of the genus Oestrus, and allied genera of botflies.","pos":""}],"GADHELIC":[{"def":"Of or pertaining to that division of the Celtic languages, which includes the Irish, Gaelic, and Manx.","pos":""}],"GADIC":[{"def":"Pertaining to, or derived from, the cod (Gadus); -- applied to an acid obtained from cod-liver oil, viz.","pos":""}],"GADITANIAN":[{"def":"Of or relating to Cadiz, in Spain.","pos":""},{"def":"A native or inhabitant of Cadiz.","pos":""}],"GADLING":[{"def":"A roving vagabond.","pos":""}],"GADOID":[{"def":"Of or pertaining to the family of fishes (Gadidæ) which includes the cod, haddock, and hake.","pos":""},{"def":"One of the Gadidæ.","pos":""}],"GADOLINIA":[{"def":"A rare earth, regarded by some as an oxide of the supposed element gadolinium, by others as only a mixture of the oxides of yttrium, erbium, ytterbium, etc.","pos":""}],"GADOLINIC":[{"def":"Pertaining to or containing gadolinium.","pos":""}],"GADOLINITE":[{"def":"A mineral of a nearly black color and vitreous luster, and consisting principally of the silicates of yttrium, cerium, and iron.","pos":""}],"GADOLINIUM":[{"def":"A supposed rare metallic element, with a characteristic spectrum, found associated with yttrium and other rare metals.","pos":""}],"GADSMAN":[{"def":"One who uses a gad or goad in driving.","pos":""}],"GADUIN":[{"def":"A yellow or brown amorphous substance, of indifferent nature, found in cod-liver oil.","pos":"noun"}],"GADWALL":[{"def":"A large duck (Anas strepera), valued as a game bird, found in the northern parts of Europe and America; -- called also gray duck.","pos":""}]}