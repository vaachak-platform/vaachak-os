{"PERRADIAL":[{"def":"Situated around the radii, or radial tubes, of a radiate.","pos":""}],"PERRIE":[{"def":"Precious stones; jewels.","pos":""}],"PERRIER":[{"def":"A short mortar used formerly for throwing stone shot.","pos":""}],"PERRON":[{"def":"An out-of-door flight of steps, as in a garden, leading to a terrace or to an upper story; -- usually applied to mediævel or later structures of some architectural pretensions.","pos":""}],"PERROQUET":[{"def":"See Paroquet, Parakeet.","pos":""}],"PERRUQUIER":[{"def":"A marker of perukes or wigs.","pos":""}],"PERRY":[{"def":"A fermented liquor made from pears; pear cider.","pos":""}]}