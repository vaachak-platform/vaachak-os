{"AUTO-":[{"def":"A combining form, with the meaning of self, one's self, one's own, itself, its own.","pos":""}],"AUTO-DA-FE":[{"def":"A judgment of the Inquisition in Spain and Portugal condemning or acquitting persons accused of religious offenses.","pos":""},{"def":"An execution of such sentence, by the civil power, esp.","pos":""}],"AUTO-DE-FE":[{"def":"Same as Auto-da-fé.","pos":""}],"AUTO-INFECTION":[{"def":"Poisoning caused by a virus that originates and develops in the organism itself.","pos":""}],"AUTO-INOCULATION":[{"def":"Inoculation of a person with virus from his own body.","pos":""}],"AUTO-INTOXICATION":[{"def":"Poisoning, or the state of being poisoned, from toxic substances produced within the body; autotoxæmia.","pos":""}],"AUTOBIOGRAPHER":[{"def":"One who writers his own life or biography.","pos":""},{"def":"Pertaining to, or containing, autobiography; as, an autobiographical sketch.","pos":""}],"AUTOBIOGRAPHIST":[{"def":"One who writes his own life; an autobiographer.","pos":""}],"AUTOBIOGRAPHY":[{"def":"A biography written by the subject of it; memoirs of one's life written by one's self.","pos":""},{"def":"Consisting of the pericarp of the ripened pericarp with no other parts adnate to it, as a peach, a poppy capsule, or a grape.","pos":""}],"AUTOCATALYSIS":[{"def":"Self-catalysis; catalysis of a substance by one of its own products, as of silver oxide by the silver formed by reduction of a small portion of it.","pos":""}],"AUTOCEPHALOUS":[{"def":"Having its own head; independent of episcopal or patriarchal jurisdiction, as certain Greek churches.","pos":""}],"AUTOCHRONOGRAPH":[{"def":"An instrument for the instantaneous self-recording or printing of time.","pos":""}],"AUTOCHTHON":[{"def":"Aboriginal; indigenous; native.","pos":""}],"AUTOCHTHONISM":[{"def":"The state of being autochthonal.","pos":""}],"AUTOCHTHONY":[{"def":"An aboriginal or autochthonous condition.","pos":""}],"AUTOCLASTIC":[{"def":"Broken in place; -- said of rocks having a broken or brecciated structure due to crushing, in contrast to those of brecciated materials brought from a distance.","pos":""}],"AUTOCLAVE":[{"def":"A kind of French stewpan with a steamtight lid.","pos":""}],"AUTOCOHERER":[{"def":"A self-restoring coherer, as a microphonic detector.","pos":""}],"AUTOCRACY":[{"def":"The action of the vital principle, or of the instinctive powers, toward the preservation of the individual; also, the vital principle.","pos":""}],"AUTOCRAT":[{"def":"Of or pertaining to autocracy or to an autocrat; absolute; holding independent and arbitrary powers of government.","pos":""}],"AUTOCRATORICAL":[{"def":"Pertaining to an autocrator; absolute.","pos":""}],"AUTOCRATRIX":[{"def":"A female sovereign who is independent and absolute; -- a title given to the empresses of Russia.","pos":""}],"AUTOCRATSHIP":[{"def":"The office or dignity of an autocrat.","pos":""}],"AUTODIDACT":[{"def":"One who is self-taught; an automath.","pos":""}],"AUTODYNAMIC":[{"def":"Supplying its own power; -- applied to an instrument of the nature of a water-ram.","pos":""}],"AUTOECIOUS":[{"def":"Passing through all its stages on one host, as certain parasitic fungi; -- contrasted with heterocious.","pos":""}],"AUTOECISM":[{"def":"Quality of being autocious.","pos":""}],"AUTOFECUNDATION":[{"def":"Self-impregnation.","pos":""}],"AUTOGAMOUS":[{"def":"Characterized by autogamy; self-fertilized.","pos":""}],"AUTOGAMY":[{"def":"Self-fertilization, the fertilizing pollen being derived from the same blossom as the pistil acted upon.","pos":""}],"AUTOGENEAL":[{"def":"Self-produced; autogenous.","pos":""}],"AUTOGENESIS":[{"def":"Spontaneous generation.","pos":""}],"AUTOGENETIC":[{"def":"Relating to autogenesis; self-generated.","pos":""}],"AUTOGENETIC DRAINAGE":[{"def":"A system of natural drainage developed by the constituent streams through headwater erosion.","pos":""}],"AUTOGENETIC TOPOGRAPHY":[{"def":"A system of land forms produced by the free action of rain and streams on rocks of uniform texture.","pos":""}],"AUTOGENOUS":[{"def":"Self-generated; produced independently.","pos":""},{"def":"Developed from an independent center of ossification.","pos":""}],"AUTOGENOUSLY":[{"def":"In an autogenous manner; spontaneously.","pos":""}],"AUTOGRAPH":[{"def":"That which is written with one's own hand; an original manuscript; a person's own signature or handwriting.","pos":""}],"AUTOGRAPHAL":[{"def":"Pertaining to an autograph, or one's own handwriting; of the nature of an autograph.","pos":""},{"def":"Pertaining to, or used in, the process of autography; as, autographic ink, paper, or press.","pos":""}],"AUTOGRAPHY":[{"def":"The science of autographs; a person's own handwriting; an autograph.","pos":""},{"def":"A process in lithography by which a writing or drawing is transferred from paper to stone.","pos":""}],"AUTOHARP":[{"def":"A zitherlike musical instrument, provided with dampers which, when depressed, deaden some strings, leaving free others that form a chord.","pos":""}],"AUTOHYPNOTIC":[{"def":"An autohypnotic person.","pos":""}],"AUTOHYPNOTISM":[{"def":"Hypnotism of one's self by concentration of the attention on some object or idea.","pos":""}],"AUTOKINESIS":[{"def":"Spontaneous or voluntary movement; movement due to an internal cause.","pos":""}],"AUTOKINETIC":[{"def":"Self-moving; moving automatically.","pos":""}],"AUTOKINETIC SYSTEM":[{"def":"In fire-alarm telegraphy, a system so arranged that when one alarm is being transmitted, no other alarm, sent in from another point, will be transmitted until after the first alarm has been disposed of.","pos":""}],"AUTOMATH":[{"def":"One who is self-taught.","pos":""}],"AUTOMATICALLY":[{"def":"In an automatic manner.","pos":""}],"AUTOMATISM":[{"def":"The state or quality of being automatic; the power of self- moving; automatic, mechanical, or involuntary action.","pos":""}],"AUTOMATON":[{"def":"Any thing or being regarded as having the power of spontaneous motion or action.","pos":""},{"def":"A self-moving machine, or one which has its motive power within itself; -- applied chiefly to machines which appear to imitate spontaneously the motions of living beings, such as men, birds, etc.","pos":""}],"AUTOMIXTE SYSTEM":[{"def":"A system (devised by Henri Pieper, a Belgian) of driving automobiles employing a gasoline engine and an auxiliary reversible dynamo.","pos":""}],"AUTOMOBILE":[{"def":"An automobile vehicle or mechanism; esp.","pos":""}],"AUTOMOBILISM":[{"def":"The use of automobiles, or the practices, methods, or the like, of those who use them.","pos":""}],"AUTOMORPHIC":[{"def":"Patterned after one's self.","pos":""}],"AUTOMORPHISM":[{"def":"Automorphic characterization.","pos":""}],"AUTONOMASY":[{"def":"The use of a word of common or general signification for the name of a particular thing; as, \"He has gone to town,\" for, \"He has gone to London.","pos":""}],"AUTONOMIC":[{"def":"Having the power of self-government; autonomous.","pos":""}],"AUTONOMIST":[{"def":"One who advocates autonomy.","pos":""}],"AUTONOMOUS":[{"def":"Having independent existence or laws.","pos":""}],"AUTONOMY":[{"def":"The sovereignty of reason in the sphere of morals; or man's power, as possessed of reason, to give law to himself.","pos":""}],"AUTOPATHIC":[{"def":"Dependent upon, or due or relating to, the structure and characteristics of the diseased organism; endopathic; as, an autopathic disease; an autopathic theory of diseases.","pos":""}],"AUTOPHAGI":[{"def":"Birds which are able to run about and obtain their own food as soon as hatched.","pos":""}],"AUTOPHAGY":[{"def":"The feeding of the body upon itself, as in fasting; nutrition by consumption of one's own tissues.","pos":""}],"AUTOPHOBY":[{"def":"Fear of one's self; fear of being egotistical.","pos":""}],"AUTOPHONY":[{"def":"An auscultatory process, which consists in noting the tone of the observer's own voice, while he speaks, holding his head close to the patient's chest.","pos":""}],"AUTOPLASTIC":[{"def":"Of or pertaining to autoplasty.","pos":""}],"AUTOPLASTY":[{"def":"The process of artificially repairing lesions by taking a piece of healthy tissue, as from a neighboring part, to supply the deficiency caused by disease or wounds.","pos":""}],"AUTOPNEUMATIC":[{"def":"Acting or moving automatically by means of compressed air.","pos":""},{"def":"Pertaining to autopsy; autoptical.","pos":""}],"AUTOPSORIN":[{"def":"That which is given under the doctrine of administering a patient's own virus.","pos":""}],"AUTOPSY":[{"def":"Dissection of a dead body, for the purpose of ascertaining the cause, seat, or nature of a disease; a post-mortem examination.","pos":""},{"def":"Seen with one's own eyes; belonging to, or connected with, personal observation; as, autoptic testimony or experience.","pos":""}],"AUTOPTICALLY":[{"def":"By means of ocular view, or one's own observation.","pos":""},{"def":"Extemporary; offhand.","pos":""}],"AUTOSTABILITY":[{"def":"Automatic stability; also, inherent stability.","pos":""}],"AUTOSTYLIC":[{"def":"Having the mandibular arch articulated directly to the cranium, as in the skulls of the Amphibia.","pos":""}],"AUTOSUGGESTION":[{"def":"Self-suggestion as distinguished from suggestion coming from another, esp.","pos":""}],"AUTOTHEISM":[{"def":"The doctrine of God's self-existence.","pos":""},{"def":"Deification of one's self; self-worship.","pos":""}],"AUTOTHEIST":[{"def":"One given to self-worship.","pos":""},{"def":"Self-intoxication.","pos":""}],"AUTOTOXIC":[{"def":"Pertaining to, or causing, autotoxæmia.","pos":""}],"AUTOTOXICATION":[{"def":"Same as Auto-intoxication.","pos":""}],"AUTOTRANSFORMER":[{"def":"A transformer in which part of the primary winding is used as a secondary winding, or vice versa; -- called also a compensator or balancing coil.","pos":""}],"AUTOTROPHIC":[{"def":"Capable of self-nourishment; -- said of all plants in which photosynthetic activity takes place, as opposed to parasitism or saprophytism.","pos":""}],"AUTOTROPISM":[{"def":"The tendency of plant organs to grow in a straight line when uninfluenced by external stimuli.","pos":""}],"AUTOTYPE":[{"def":"A photographic picture produced in sensitized pigmented gelatin by exposure to light under a negative; and subsequent washing out of the soluble parts; a kind of picture in ink from a gelatin plate.","pos":""}],"AUTOTYPOGRAPHY":[{"def":"A process resembling \"nature printing,\" by which drawings executed on gelatin are impressed into a soft metal plate, from which the printing is done as from copperplate.","pos":""}],"AUTOTYPY":[{"def":"The art or process of making autotypes.","pos":""}]}