{"DEICIDE":[{"def":"The act of killing a being of a divine nature; particularly, the putting to death of Jesus Christ.","pos":""},{"def":"One concerned in putting Christ to death.","pos":""}],"DEICTIC":[{"def":"Direct; proving directly; -- applied to reasoning, and opposed to elenchtic or refutative.","pos":""}],"DEICTICALLY":[{"def":"In a manner to show or point out; directly; absolutely; definitely.","pos":""},{"def":"Making divine; producing a likeness to God; god-making.","pos":""}],"DEIFICATION":[{"def":"The act of deifying; exaltation to divine honors; apotheosis; excessive praise.","pos":""}],"DEIFIED":[{"def":"Honored or worshiped as a deity; treated with supreme regard; godlike.","pos":""}],"DEIFIER":[{"def":"One who deifies.","pos":""}],"DEIFORM":[{"def":"Godlike, or of a godlike form.","pos":""},{"def":"Conformable to the will of God.","pos":""}],"DEIFORMITY":[{"def":"Likeness to deity.","pos":""}],"DEIFY":[{"def":"To make a god of; to exalt to the rank of a deity; to enroll among the deities; to apotheosize; as, Julius Cæsar was deified.","pos":""},{"def":"To praise or revere as a deity; to treat as an object of supreme regard; as, to deify money.","pos":""}],"DEIGN":[{"def":"To esteem worthy; to consider worth notice; -- opposed to disdain.","pos":""},{"def":"To condescend to give or bestow; to stoop to furnish; to vouchsafe; to allow; to grant.","pos":""}],"DEIGNOUS":[{"def":"Haughty; disdainful.","pos":""}],"DEIL":[{"def":"Devil; -- spelt also deel.","pos":""}],"DEINOTHERIUM":[{"def":"See Dinotherium.","pos":""}],"DEINTEGRATE":[{"def":"To disintegrate.","pos":""},{"def":"Rare; excellent; costly.","pos":""}],"DEIPAROUS":[{"def":"Bearing or bringing forth a god; -- said of the Virgin Mary.","pos":""}],"DEIPNOSOPHIST":[{"def":"One of an ancient sect of philosophers, who cultivated learned conversation at meals.","pos":""}],"DEISM":[{"def":"The doctrine or creed of a deist; the belief or system of those who acknowledge the existence of one God, but deny revelation.","pos":""}],"DEIST":[{"def":"One who believes in the existence of a God, but denies revealed religion; a freethinker.","pos":""},{"def":"Pertaining to, savoring of, or consisting in, deism; as, a deistic writer; a deistical book.","pos":""}],"DEISTICALLY":[{"def":"After the manner of deists.","pos":""}],"DEISTICALNESS":[{"def":"State of being deistical.","pos":""}],"DEITY":[{"def":"The collection of attributes which make up the nature of a god; divinity; godhead; as, the deity of the Supreme Being is seen in his works.","pos":""},{"def":"A god or goddess; a heathen god.","pos":""}]}