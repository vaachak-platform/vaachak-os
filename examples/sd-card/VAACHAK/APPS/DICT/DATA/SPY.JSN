{"SPY":[{"def":"To gain sight of; to discover at a distance, or in a state of concealment; to espy; to see.","pos":"verb"}],"SPYBOAT":[{"def":"A boat sent to make discoveries and bring intelligence.","pos":""}],"SPYGLASS":[{"def":"A small telescope for viewing distant terrestrial objects.","pos":""}],"SPYISM":[{"def":"SPYNACE; SPYNE Spy\"nace, Spyne, n.","pos":""}]}