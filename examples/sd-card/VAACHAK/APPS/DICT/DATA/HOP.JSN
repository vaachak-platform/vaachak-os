{"HOP":[{"def":"To move by successive leaps, as toads do; to spring or jump on one foot; to skip, as birds do.","pos":""},{"def":"To walk lame; to limp; to halt.","pos":""}],"HOP-THUMB":[{"def":"See Hop-o'-my-thumb.","pos":""}],"HOPE":[{"def":"A sloping plain between mountain ridges.","pos":""},{"def":"A small bay; an inlet; a haven.","pos":""}],"HOPEFUL":[{"def":"Full of hope, or agreeable expectation; inclined to hope; expectant.","pos":""},{"def":"Having qualities which excite hope; affording promise of good or of success; as, a hopeful youth; a hopeful prospect.","pos":""}],"HOPEITE":[{"def":"A hydrous phosphate of zinc in transparent prismatic crystals.","pos":""}],"HOPELESS":[{"def":"Destitute of hope; having no expectation of good; despairing.","pos":""},{"def":"Giving no ground of hope; promising nothing desirable; desperate; as, a hopeless cause.","pos":""}],"HOPINGLY":[{"def":"In a hopeful manner.","pos":""}],"HOPLITE":[{"def":"A heavy-armed infantry soldier.","pos":""},{"def":"A very diminutive person.","pos":""}],"HOPPED":[{"def":"Impregnated with hops.","pos":""}],"HOPPER":[{"def":"See Grasshopper, 2.","pos":""}],"HOPPERDOZER":[{"def":"An appliance for the destruction of insects, consisting of a shallow iron box, containing kerosene or coated with tar or other sticky substance, which may be mounted on wheels.","pos":""}],"HOPPERINGS":[{"def":"Gravel retaining in the hopper of a cradle.","pos":""}],"HOPPESTERE":[{"def":"An unexplained epithet used by Chaucer in reference to ships.","pos":""}],"HOPPET":[{"def":"A hand basket; also, a dish used by miners for measuring ore.","pos":""},{"def":"An infant in arms.","pos":""}],"HOPPING":[{"def":"The act of one who, or that which, hops; a jumping, frisking, or dancing.","pos":""}],"HOPPLE":[{"def":"To impede by a hopple; to tie the feet of (a horse or a cow) loosely together; to hamper; to hobble; as, to hopple an unruly or straying horse.","pos":""}],"HOPPLEBUSH":[{"def":"Same as Hobblebush.","pos":""}],"HOPSCOTCH":[{"def":"A child's game, in which a player, hopping on one foot, drives a stone from one compartment to another of a figure traced or scotched on the ground; -- called also hoppers.","pos":""}],"HOPYARD":[{"def":"A field where hops are raised.","pos":""}]}