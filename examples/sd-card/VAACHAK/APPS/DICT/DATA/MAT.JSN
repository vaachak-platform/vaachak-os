{"MAT":[{"def":"A name given by coppersmiths to an alloy of copper, tin, iron, etc.","pos":""}],"MATACHIN":[{"def":"An old dance with swords and bucklers; a sword dance.","pos":""}],"MATACO":[{"def":"The three-banded armadillo (Tolypeutis tricinctus).","pos":""},{"def":"In the game of quadrille or omber, the three principal trumps, the ace of spades being the first, the ace of clubs the third, and the second being the deuce of a black trump or the seven of a red one.","pos":""}],"MATAGASSE":[{"def":"A shrike or butcher bird; -- called also mattages.","pos":""}],"MATAJUELO":[{"def":"A large squirrel fish (Holocentrus ascensionis) of Florida and the West Indies.","pos":""}],"MATAJUELO BLANCO":[{"def":"A West Indian food fish (Malacanthus plumieri) related to the tilefish.","pos":""}],"MATAMATA":[{"def":"The bearded tortoise (Chelys fimbriata) of South American rivers.","pos":""}],"MATANZA":[{"def":"A place where animals are slaughtered for their hides and tallow.","pos":""}],"MATCH":[{"def":"Anything used for catching and retaining or communicating fire, made of some substance which takes fire readily, or remains burning some time; esp.","pos":""}],"MATCH GAME":[{"def":"A game arranged as a test of superiority; also, one of a series of such games.","pos":""}],"MATCH PLAY":[{"def":"Play in which the score is reckoned by counting the holes won or lost by each side; -- disting.","pos":""}],"MATCH-COAT":[{"def":"A coat made of match-cloth.","pos":""}],"MATCHABLE":[{"def":"Capable of being matched; comparable on equal conditions; adapted to being joined together; correspondent.","pos":""}],"MATCHER":[{"def":"One who, or that which, matches; a matching machine.","pos":""}],"MATCHLESS":[{"def":"Having no equal; unequaled.","pos":""},{"def":"Unlike each other; unequal; unsuited.","pos":""}],"MATCHLOCK":[{"def":"An old form of gunlock containing a match for firing the priming; hence, a musket fired by means of a match.","pos":""}],"MATCHMAKER":[{"def":"One who makes matches for burning or kinding.","pos":""},{"def":"One who tries to bring about marriages.","pos":""}],"MATCHMAKING":[{"def":"The act or process of making matches for kindling or burning.","pos":""},{"def":"The act or process of trying to bring about a marriage for others.","pos":""}],"MATE":[{"def":"The Paraguay tea, being the dried leaf of the Brazilian holly (Ilex Paraguensis).","pos":""}],"MATELASSE":[{"def":"Ornamented by means of an imitation or suggestion of quilting, the surface being marked by depressed lines which form squares or lozenges in relief; as, matelassé silks.","pos":""}],"MATELOTE":[{"def":"A dish of food composed of many kings of fish.","pos":""}],"MATEOLOGY":[{"def":"A vain, unprofitable discourse or inquiry.","pos":""}],"MATEOTECHNY":[{"def":"Any unprofitable science.","pos":""}],"MATER":[{"def":"See Alma mater, Dura mater, and Pia mater.","pos":""}],"MATERIA MEDICA":[{"def":"Material or substance used in the composition of remedies; -- a general term for all substances used as curative agents in medicine.","pos":""},{"def":"That branch of medical science which treats of the nature and properties of all the substances that are employed for the cure of diseases.","pos":""}],"MATERIAL":[{"def":"Pertaining to the matter, as opposed to the form, of a thing.","pos":""}],"MATERIALISM":[{"def":"The doctrine of materialists; materialistic views and tenets.","pos":""},{"def":"The tendency to give undue importance to material interests; devotion to the material nature and its wants.","pos":""}],"MATERIALIST":[{"def":"Of or pertaining to materialism or materialists; of the nature of materialism.","pos":""}],"MATERIALITY":[{"def":"The quality or state of being material; material existence; corporeity.","pos":""},{"def":"Importance; as, the materiality of facts.","pos":""}],"MATERIALIZATION":[{"def":"The act of materializing, or the state of being materialized.","pos":""}],"MATERIALIZE":[{"def":"To make visable in, or as in, a material form; -- said of spirits.","pos":""}],"MATERIALLY":[{"def":"In the state of matter.","pos":""},{"def":"In its essence; substantially.","pos":""}],"MATERIALNESS":[{"def":"The state of being material.","pos":""}],"MATERIARIAN":[{"def":"See Materialist.","pos":""},{"def":"Consisting of matter.","pos":""}],"MATERIATION":[{"def":"Act of forming matter.","pos":""}],"MATERIEL":[{"def":"That in a complex system which constitutes the materials, or instruments employed, in distinction from the personnel, or men; as, the baggage, munitions, provisions, etc.","pos":""}],"MATERNAL":[{"def":"Of or pertaining to a mother; becoming to a mother; motherly; as, maternal love; maternal tenderness.","pos":""}],"MATERNALLY":[{"def":"In a motherly manner.","pos":""}],"MATERNITY":[{"def":"The state of being a mother; the character or relation of a mother.","pos":""}],"MATFELON":[{"def":"The knapweed (Centaurea nigra).","pos":""}],"MATH":[{"def":"A mowing, or that which is gathered by mowing; -- chiefly used in composition; as, an aftermath.","pos":""}],"MATHEMATIC":[{"def":"See Mathematical.","pos":""}],"MATHEMATICAL":[{"def":"Of or pertaining to mathematics; according to mathematics; hence, theoretically precise; accurate; as, mathematical geography; mathematical instruments; mathematical exactness.","pos":""}],"MATHEMATICIAN":[{"def":"One versed in mathematics.","pos":""}],"MATHEMATICS":[{"def":"Geometry, including Trigonometry and Conic Sections.","pos":""}],"MATHESIS":[{"def":"Learning; especially, mathematics.","pos":""}],"MATHURIN":[{"def":"See Trinitarian.","pos":""}],"MATICO":[{"def":"A Peruvian plant (Piper, or Artanthe, elongatum), allied to the pepper, the leaves of which are used as a styptic and astringent.","pos":""}],"MATIE":[{"def":"A fat herring with undeveloped roe.","pos":""}],"MATIN":[{"def":"A French mastiff.","pos":""}],"MATINAL":[{"def":"Relating to the morning, or to matins; matutinal.","pos":""}],"MATINEE":[{"def":"A reception, or a musical or dramatic entertainment, held in the daytime.","pos":""}],"MATRASS":[{"def":"A round-bottomed glass flask having a long neck; a bolthead.","pos":""}],"MATRIARCH":[{"def":"The mother and ruler of a family or of her descendants; a ruler by maternal right.","pos":""}],"MATRIARCHAL":[{"def":"Of or pertaining to a matriarch; governed by a matriarch.","pos":""}],"MATRIARCHATE":[{"def":"The office or jurisdiction of a matriarch; a matriarchal form of government.","pos":""}],"MATRICIDAL":[{"def":"Of or pertaining to matricide.","pos":""}],"MATRICIDE":[{"def":"One who murders one's own mother.","pos":""}],"MATRICULATE":[{"def":"To enroll; to enter in a register; specifically, to enter or admit to membership in a body or society, particularly in a college or university, by enrolling the name in a register.","pos":""}],"MATRICULATION":[{"def":"The act or process of matriculating; the state of being matriculated.","pos":""}],"MATRIMONIAL":[{"def":"Of or pertaining to marriage; derived from marriage; connubial; nuptial; hymeneal; as, matrimonial rights or duties.","pos":""}],"MATRIMONIALLY":[{"def":"In a matrimonial manner.","pos":""}],"MATRIMONY":[{"def":"The union of man and woman as husband and wife; the nuptial state; marriage; wedlock.","pos":""},{"def":"A kind of game at cards played by several persons.","pos":""}],"MATRIX":[{"def":"The five simple colors, black, white, blue, red, and yellow, of which all the rest are composed.","pos":""}],"MATRON":[{"def":"A wife or a widow, especially, one who has borne children; a woman of staid or motherly manners.","pos":""},{"def":"A housekeeper; esp.","pos":""}],"MATRONAGE":[{"def":"The state of a matron.","pos":""},{"def":"The collective body of matrons.","pos":""}],"MATRONAL":[{"def":"Of or pertaining to a matron; suitable to an elderly lady or to a married woman; grave; motherly.","pos":""}],"MATRONHOOD":[{"def":"The state of being a matron.","pos":""}],"MATRONIZE":[{"def":"To make a matron of; to make matronlike.","pos":""},{"def":"To act the part of a marton toward; to superintend; to chaperone; as, to matronize an assembly.","pos":""}],"MATRONLIKE":[{"def":"Like a matron; sedate; grave; matronly.","pos":""}],"MATRONLY":[{"def":"Advanced in years; elderly.","pos":""},{"def":"Like, or befitting, a matron; grave; sedate.","pos":""}],"MATROSS":[{"def":"Formerly, in the British service, a gunner or a gunner's mate; one of the soldiers in a train of artillery, who assisted the gunners in loading, firing, and sponging the guns.","pos":""}],"MATTAGES":[{"def":"A shrike or butcher bird; -- written also matagasse.","pos":""}],"MATTAMORE":[{"def":"A subterranean repository for wheat.","pos":""}],"MATTE":[{"def":"A partly reduced copper sulphide, obtained by alternately roasting and melting copper ore in separating the metal from associated iron ores, and called coarse metal, fine metal, etc.","pos":""}],"MATTED":[{"def":"Having a dull surface; unburnished; as, matted gold leaf or gilding.","pos":""}],"MATTER":[{"def":"That which is permanent, or is supposed to be given, and in or upon which changes are effected by psychological or physical processes and relations; -- opposed to form.","pos":""},{"def":"Written manuscript, or anything to be set in type; copy; also, type set up and ready to be used, or which has been used, in printing.","pos":""}],"MATTER-OF-FACT":[{"def":"Adhering to facts; not turning aside from absolute realities; not fanciful or imaginative; commonplace; dry.","pos":""}],"MATTERLESS":[{"def":"Not being, or having, matter; as, matterless spirits.","pos":""},{"def":"Unimportant; immaterial.","pos":""}],"MATTERY":[{"def":"Generating or containing pus; purulent.","pos":""},{"def":"Full of substance or matter; important.","pos":""}],"MATTING":[{"def":"The act of interweaving or tangling together so as to make a mat; the process of becoming matted.","pos":""},{"def":"Mats, in general, or collectively; mat work; a matlike fabric, for use in covering floors, packing articles, and the like; a kind of carpeting made of straw, etc.","pos":""}],"MATTOCK":[{"def":"An implement for digging and grubbing.","pos":""}],"MATTOID":[{"def":"A person of congenitally abnormal mind bordering on insanity or degeneracy.","pos":""}],"MATTOIR":[{"def":"A kind of coarse punch with a rasplike face, used for making a rough surface on etching ground, or on the naked copper, the effect after biting being very similar to stippled lines.","pos":""}],"MATTOWACCA":[{"def":"An American clupeoid fish (Clupea mediocris), similar to the shad in habits and appearance, but smaller and less esteemed for food; -- called also hickory shad, tailor shad, fall herring, and shad herring.","pos":""}],"MATTRESS":[{"def":"A mass of interwoven brush, poles, etc.","pos":""}],"MATURANT":[{"def":"A medicine, or application, which promotes suppuration.","pos":""}],"MATURATE":[{"def":"To bring to ripeness or maturity; to ripen.","pos":""},{"def":"To promote the perfect suppuration of (an abscess).","pos":""}],"MATURATION":[{"def":"The process of bringing, or of coming, to maturity; hence, specifically, the process of suppurating perfectly; the formation of pus or matter.","pos":""}],"MATURATIVE":[{"def":"Conducing to ripeness or maturity; hence, conducing to suppuration.","pos":""}],"MATURE":[{"def":"Brought by natural process to completeness of growth and development; fitted by growth and development for any function, action, or state, appropriate to its kind; full-grown; ripe.","pos":""},{"def":"Completely worked out; fully digested or prepared; ready for action; made ready for destined application or use; perfected; as, a mature plan.","pos":""}],"MATURELY":[{"def":"In a mature manner; with ripeness; completely.","pos":""},{"def":"With caution; deliberately.","pos":""}],"MATURENESS":[{"def":"The state or quality of being mature; maturity.","pos":""}],"MATURER":[{"def":"One who brings to maturity.","pos":""}],"MATURESCENT":[{"def":"Approaching maturity.","pos":""}],"MATURING":[{"def":"Approaching maturity; as, maturing fruits; maturing notes of hand.","pos":""}],"MATURITY":[{"def":"The state or quality of being mature; ripeness; full development; as, the maturity of corn or of grass; maturity of judgment; the maturity of a plan.","pos":""},{"def":"Arrival of the time fixed for payment; a becoming due; termination of the period a note, etc.","pos":""}],"MATUTINAL":[{"def":"Of or pertaining to the morning; early.","pos":""}],"MATWEED":[{"def":"A name of several maritime grasses, as the sea sand-reed (Ammophila arundinacea) which is used in Holland to bind the sand of the seacoast dikes (see Beach grass, under Beach); also, the Lygeum Spartum, a Mediterranean grass of similar habit.","pos":""}],"MATY":[{"def":"A native house servant in India.","pos":""}],"MATZOTH":[{"def":"A cake of unleavened bread eaten by the Jews at the feast of the Passover.","pos":""}]}