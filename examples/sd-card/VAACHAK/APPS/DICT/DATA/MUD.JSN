{"MUD":[{"def":"Earth and water mixed so as to be soft and adhesive.","pos":""}],"MUDAR":[{"def":"Either one of two asclepiadaceous shrubs (Calotropis gigantea, and C.","pos":""}],"MUDARIN":[{"def":"A brown, amorphous, bitter substance having a strong emetic action, extracted from the root of the mudar.","pos":""}],"MUDDILY":[{"def":", In a muddy manner; turbidly; without mixture; cloudily; obscurely; confusedly.","pos":""}],"MUDDINESS":[{"def":"The condition or quality of being muddy; turbidness; foulness casued by mud, dirt, or sediment; as, the muddiness of a stream.","pos":""},{"def":"Obscurity or confusion, as in treatment of a subject; intellectual dullness.","pos":""}],"MUDDLE":[{"def":"To make turbid, or muddy, as water.","pos":""},{"def":"To cloud or stupefy; to render stupid with liquor; to intoxicate partially.","pos":""}],"MUDDLEHEAD":[{"def":"A stupid person.","pos":""}],"MUDDLER":[{"def":"One who, or that which, muddles.","pos":""}],"MUDDY":[{"def":"Abounding in mud; besmeared or dashed with mud; as, a muddy road or path; muddy boots.","pos":""},{"def":"Turbid with mud; as, muddy water.","pos":""}],"MUDHOLE":[{"def":"A hole near the bottom, through which the sediment is withdrawn.","pos":""}],"MUDSILL":[{"def":"The lowest sill of a structure, usually embedded in the soil; the lowest timber of a house; also, that sill or timber of a bridge which is laid at the bottom of the water.","pos":""}],"MUDWALL":[{"def":"The European bee-eater.","pos":""}],"MUDWORT":[{"def":"A small herbaceous plant growing on muddy shores (Limosella aquatica).","pos":""}]}