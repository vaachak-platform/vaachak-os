{"DECLAIM":[{"def":"To speak rhetorically; to make a formal speech or oration; to harangue; specifically, to recite a speech, poem, etc.","pos":""},{"def":"To speak for rhetorical display; to speak pompously, noisily, or theatrically; to make an empty speech; to rehearse trite arguments in debate; to rant.","pos":""}],"DECLAIMER":[{"def":"One who declaims; an haranguer.","pos":""}],"DECLAMATION":[{"def":"The act or art of declaiming; rhetorical delivery; haranguing; loud speaking in public; especially, the public recitation of speeches as an exercise in schools and colleges; as, the practice declamation by students.","pos":""},{"def":"A set or harangue; declamatory discourse.","pos":""}],"DECLAMATORY":[{"def":"Pertaining to declamation; treated in the manner of a rhetorician; as, a declamatory theme.","pos":""},{"def":"Characterized by rhetorical display; pretentiously rhetorical; without solid sense or argument; bombastic; noisy; as, a declamatory way or style.","pos":""}],"DECLARABLE":[{"def":"Capable of being declared.","pos":""}],"DECLARANT":[{"def":"One who declares.","pos":""}],"DECLARATION":[{"def":"That part of the process in which the plaintiff sets forth in order and at large his cause of complaint; the narration of the plaintiff's case containing the count, or counts.","pos":""}],"DECLARATIVE":[{"def":"Making declaration, proclamation, or publication; explanatory; assertive; declaratory.","pos":""}],"DECLARATIVELY":[{"def":"By distinct assertion; not impliedly; in the form of a declaration.","pos":""}],"DECLARATOR":[{"def":"A form of action by which some right or interest is sought to be judicially declared.","pos":""}],"DECLARATORILY":[{"def":"In a declaratory manner.","pos":""}],"DECLARATORY":[{"def":"Making declaration, explanation, or exhibition; making clear or manifest; affirmative; expressive; as, a clause declaratory of the will of the legislature.","pos":""}],"DECLARE":[{"def":"To make full statement of, as goods, etc.","pos":""}],"DECLAREDLY":[{"def":"Avowedly; explicitly.","pos":""}],"DECLAREDNESS":[{"def":"The state of being declared.","pos":""}],"DECLARER":[{"def":"One who makes known or proclaims; that which exhibits.","pos":""}],"DECLASS":[{"def":"To remove from a class; to separate or degrade from one's class.","pos":""}],"DECLENSION":[{"def":"The act or the state of declining; declination; descent; slope.","pos":""},{"def":"A falling off towards a worse state; a downward tendency; deterioration; decay; as, the declension of virtue, of science, of a state, etc.","pos":""}],"DECLENSIONAL":[{"def":"Belonging to declension.","pos":""}],"DECLINABLE":[{"def":"Capable of being declined; admitting of declension or inflection; as, declinable parts of speech.","pos":""}],"DECLINAL":[{"def":"Declining; sloping.","pos":""}],"DECLINATE":[{"def":"Bent downward or aside; (Bot.","pos":""}],"DECLINATION":[{"def":"The angular distance of any object from the celestial equator, either northward or southward.","pos":""},{"def":"The arc of the horizon, contained between the vertical plane and the prime vertical circle, if reckoned from the east or west, or between the meridian and the plane, reckoned from the north or south.","pos":""}],"DECLINATOR":[{"def":"An instrument for taking the declination or angle which a plane makes with the horizontal plane.","pos":""}],"DECLINATORY":[{"def":"Containing or involving a declination or refusal, as of submission to a charge or sentence.","pos":""}],"DECLINATURE":[{"def":"The act of declining or refusing; as, the declinature of an office.","pos":""}],"DECLINE":[{"def":"To bend, or lean downward; to take a downward direction; to bend over or hang down, as from weakness, weariness, despondency, etc.","pos":""},{"def":"To tend or draw towards a close, decay, or extinction; to tend to a less perfect state; to become diminished or impaired; to fail; to sink; to diminish; to lessen; as, the day declines; virtue declines; religion declines; business declines.","pos":""}],"DECLINER":[{"def":"He who declines or rejects.","pos":""}],"DECLINOMETER":[{"def":"An instrument for measuring the declination of the magnetic needle.","pos":""}],"DECLINOUS":[{"def":"Descending gradually; moderately steep; sloping; downhill.","pos":""}],"DECLIVITY":[{"def":"Deviation from a horizontal line; gradual descent of surface; inclination downward; slope; -- opposed to acclivity, or ascent; the same slope, considered as descending, being a declivity, which, considered as ascending, is an acclivity.","pos":""},{"def":"A descending surface; a sloping place.","pos":""}]}