{"MIZMAZE":[{"def":"A maze or labyrinth.","pos":""}],"MIZZEN":[{"def":"Hindmost; nearest the stern; as, the mizzen shrouds, sails, etc.","pos":""}],"MIZZENMAST":[{"def":"The hindmost mast of a three-masted vessel, or of a yawl-rigged vessel.","pos":""}],"MIZZLE":[{"def":"To rain in very fine drops.","pos":""},{"def":"To take one's self off; to go.","pos":""}],"MIZZY":[{"def":"A bog or quagmire.","pos":""}]}