{"ABRA":[{"def":"A narrow pass or defile; a break in a mesa; the mouth of a cañon.","pos":""}],"ABRACADABRA":[{"def":"A mystical word or collocation of letters written as in the figure.","pos":""}],"ABRADANT":[{"def":"A material used for grinding, as emery, sand, powdered glass, etc.","pos":""}],"ABRADE":[{"def":"To rub or wear off; to waste or wear away by friction; as, to abrade rocks.","pos":""}],"ABRAHAMIC":[{"def":"Pertaining to Abraham, the patriarch; as, the Abrahamic covenant.","pos":""},{"def":"Relating to the patriarch Abraham.","pos":""}],"ABRAID":[{"def":"To awake; to arouse; to stir or start up; also, to shout out.","pos":""}],"ABRANCHIATA":[{"def":"A group of annelids, so called because the species composing it have no special organs of respiration.","pos":""}],"ABRASION":[{"def":"A superficial excoriation, with loss of substance under the form of small shreds.","pos":""}],"ABRASIVE":[{"def":"Producing abrasion.","pos":""},{"def":"A red ocher used to darken mahogany and for making chloride of potassium.","pos":""}],"ABRAXAS":[{"def":"A mystical word used as a charm and engraved on gems among the ancients; also, a gem stone thus engraved.","pos":""}],"ABREACTION":[{"def":"See Catharsis, below.","pos":""}],"ABREAST":[{"def":"Side by side; also, opposite; over against; on a line with the vessel's beam; -- with of.","pos":""}],"ABRENUNCIATION":[{"def":"Absolute renunciation or repudiation.","pos":""}],"ABREPTION":[{"def":"A snatching away.","pos":""}],"ABREUVOIR":[{"def":"The joint or interstice between stones, to be filled with mortar.","pos":""}],"ABRIDGE":[{"def":"To make shorter; to shorten in duration; to lessen; to diminish; to curtail; as, to abridge labor; to abridge power or rights.","pos":""},{"def":"To shorten or contract by using fewer words, yet retaining the sense; to epitomize; to condense; as, to abridge a history or dictionary.","pos":""}],"ABRIDGER":[{"def":"One who abridges.","pos":""}],"ABRIDGMENT":[{"def":"The act abridging, or the state of being abridged; diminution; lessening; reduction or deprivation; as, an abridgment of pleasures or of expenses.","pos":""},{"def":"An epitome or compend, as of a book; a shortened or abridged form; an abbreviation.","pos":""}],"ABROACH":[{"def":"To set abroach; to let out, as liquor; to broach; to tap.","pos":""}],"ABROAD":[{"def":"At large; widely; broadly; over a wide space; as, a tree spreads its branches abroad.","pos":""},{"def":"Without a certain confine; outside the house; away from one's abode; as, to walk abroad.","pos":""}],"ABROGABLE":[{"def":"Capable of being abrogated.","pos":""}],"ABROGATE":[{"def":"Abrogated; abolished.","pos":""}],"ABROGATION":[{"def":"The act of abrogating; repeal by authority.","pos":""}],"ABROGATIVE":[{"def":"Tending or designed to abrogate; as, an abrogative law.","pos":""}],"ABROGATOR":[{"def":"One who repeals by authority.","pos":""}],"ABROOD":[{"def":"In the act of brooding.","pos":""}],"ABROOK":[{"def":"To brook; to endure.","pos":""}],"ABRUPT":[{"def":"Suddenly terminating, as if cut off.","pos":""}],"ABRUPTION":[{"def":"A sudden breaking off; a violent separation of bodies.","pos":""}],"ABRUPTLY":[{"def":"In an abrupt manner; without giving notice, or without the usual forms; suddenly.","pos":""}],"ABRUPTNESS":[{"def":"The state of being abrupt or broken; craggedness; ruggedness; steepness.","pos":""},{"def":"Suddenness; unceremonious haste or vehemence; as, abruptness of style or manner.","pos":""}]}