{"EEL":[{"def":"An elongated fish of many genera and species.","pos":""}],"EELBUCK":[{"def":"An eelpot or eel basket.","pos":""}],"EELFARE":[{"def":"A brood of eels.","pos":""}],"EELGRASS":[{"def":"A plant (Zostera marina), with very long and narrow leaves, growing abundantly in shallow bays along the North Atlantic coast.","pos":""}],"EELPOT":[{"def":"A boxlike structure with funnel-shaped traps for catching eels; an eelbuck.","pos":""}],"EELSPEAR":[{"def":"A spear with barbed forks for spearing eels.","pos":""}],"EEN":[{"def":"The old plural of Eye.","pos":""}],"EERILY":[{"def":"In a strange, unearthly way.","pos":""}],"EERISOME":[{"def":"Causing fear; eerie.","pos":""}]}