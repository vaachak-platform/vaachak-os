{"AH":[{"def":"An exclamation, expressive of surprise, pity, complaint, entreaty, contempt, threatening, delight, triumph, etc.","pos":""}],"AHA":[{"def":"An exclamation expressing, by different intonations, triumph, mixed with derision or irony, or simple surprise.","pos":""}],"AHEAD":[{"def":"In or to the front; in advance; onward.","pos":""},{"def":"Headlong; without restraint.","pos":""}],"AHEAP":[{"def":"In a heap; huddled together.","pos":""}],"AHEM":[{"def":"An exclamation to call one's attention; hem.","pos":""}],"AHOLD":[{"def":"Near the wind; as, to lay a ship ahold.","pos":""}],"AHORSEBACK":[{"def":"Two suspicious fellows ahorseback.","pos":""}],"AHOY":[{"def":"A term used in hailing; as, \"Ship ahoy.","pos":""}],"AHRIMAN":[{"def":"The Evil Principle or Being of the ancient Persians; the Prince of Darkness as opposer to Ormuzd, the King of Light.","pos":""}],"AHU":[{"def":"The Asiatic gazelle.","pos":""}],"AHULL":[{"def":"With the sails furled, and the helm lashed alee; -- applied to ships in a storm.","pos":""}],"AHUNGERED":[{"def":"Pinched with hunger; very hungry.","pos":""}]}