{"PIDDLE":[{"def":"To deal in trifles; to concern one's self with trivial matters rather than with those that are important.","pos":""},{"def":"To be squeamishly nice about one's food.","pos":""}],"PIDDLER":[{"def":"One who piddles.","pos":""}],"PIDDLING":[{"def":"Trifling; trivial; frivolous; paltry; -- applied to persons and things.","pos":""}],"PIDDOCK":[{"def":"Any species of Pholas; a pholad.","pos":""}]}