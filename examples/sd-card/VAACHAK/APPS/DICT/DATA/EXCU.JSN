{"EXCUBATION":[{"def":"A keeping watch.","pos":""}],"EXCUBITORIUM":[{"def":"A gallery in a church, where persons watched all night.","pos":""}],"EXCULPABLE":[{"def":"Ex*cul\"pa*ble Defn: .","pos":""}],"EXCULPATE":[{"def":"To clear from alleged fault or guilt; to prove to be guiltless; to relieve of blame; to acquit.","pos":""}],"EXCULPATION":[{"def":"The act of exculpating from alleged fault or crime; that which exculpates; excuse.","pos":""}],"EXCULPATORY":[{"def":"Ex*cul\"pa*to*ry Defn: .","pos":""}],"EXCUR":[{"def":"To run out or forth; to extend.","pos":""}],"EXCURRENT":[{"def":"Running or extending out; as, an excurrent midrib, one which projects beyond the apex of a leaf; an excurrent steam or trunk, one which continues to the top.","pos":""},{"def":"Characterized by a current which flows outward; as, an excurrent orifice or tube.","pos":""}],"EXCURSE":[{"def":"To journey or pass thought.","pos":""}],"EXCURSION":[{"def":"Length of stroke, as of a piston; stroke.","pos":""}],"EXCURSIONIST":[{"def":"One who goes on an excursion, or pleasure trip.","pos":""}],"EXCURSIVE":[{"def":"Prone to make excursions; wandering; roving; exploring; as, an excursive fancy.","pos":""}],"EXCURSUS":[{"def":"A dissertation or digression appended to a work, and containing a more extended exposition of some important point or topic.","pos":""}],"EXCUSABLE":[{"def":"That may be excused, forgiven, justified, or acquitted of blame; pardonable; as, the man is excusable; an excusable action.","pos":""}],"EXCUSATION":[{"def":"Excuse; apology.","pos":""}],"EXCUSATOR":[{"def":"One who makes, or is authorized to make, an excuse; an apologist.","pos":""}],"EXCUSATORY":[{"def":"Making or containing excuse or apology; apologetical; as, an excusatory plea.","pos":""}],"EXCUSE":[{"def":"To free from accusation, or the imputation of fault or blame; to clear from guilt; to release from a charge; to justify by extenuating a fault; to exculpate; to absolve; to acquit.","pos":""},{"def":"To pardon, as a fault; to forgive entirely, or to admit to be little censurable, and to overlook; as, we excuse irregular conduct, when extraordinary circumstances appear to justify it.","pos":""}],"EXCUSELESS":[{"def":"Having no excuse; not admitting of excuse or apology.","pos":""}],"EXCUSER":[{"def":"One who offers excuses or pleads in extenuation of the fault of another.","pos":""},{"def":"One who excuses or forgives another.","pos":""}],"EXCUSS":[{"def":"To shake off; to discard.","pos":""},{"def":"To inspect; to investigate; to decipher.","pos":""}],"EXCUSSION":[{"def":"The act of excusing; seizure by law.","pos":""}]}