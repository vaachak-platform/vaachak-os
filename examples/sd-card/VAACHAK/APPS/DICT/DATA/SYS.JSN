{"SYSSARCOSIS":[{"def":"The junction of bones by intervening muscles.","pos":""}],"SYSTALTIC":[{"def":"Capable of, or taking place by, alternate contraction and dilatation; as, the systaltic action of the heart.","pos":""}],"SYSTASIS":[{"def":"A political union, confederation, or league.","pos":""}],"SYSTEM":[{"def":"The collection of staves which form a full score.","pos":""},{"def":"An assemblage of parts or organs, either in animal or plant, essential to the performance of some particular function or functions which as a rule are of greater complexity than those manifested by a single organ; as, the capillary system, the muscular system, the digestive system, etc.","pos":""}],"SYSTEMATICALLY":[{"def":"In a systematic manner; methodically.","pos":""}],"SYSTEMATISM":[{"def":"The reduction of facts or principles to a system.","pos":""}],"SYSTEMATIST":[{"def":"One who forms a system, or reduces to system.","pos":""},{"def":"One who adheres to a system.","pos":""}],"SYSTEMATIZATION":[{"def":"The act or operation of systematizing.","pos":""}],"SYSTEMATIZE":[{"def":"To reduce to system or regular method; to arrange methodically; to methodize; as, to systematize a collection of plants or minerals; to systematize one's work; to systematize one's ideas.","pos":""}],"SYSTEMATIZER":[{"def":"One who systematizes.","pos":""}],"SYSTEMATOLOGY":[{"def":"The doctrine of, or a treatise upon, systems.","pos":""}],"SYSTEMIC":[{"def":"Of or pertaining to the general system, or the body as a whole; as, systemic death, in distinction from local death; systemic circulation, in distinction from pulmonic circulation; systemic diseases.","pos":""}],"SYSTEMIZATION":[{"def":"The act or process of systematizing; systematization.","pos":""}],"SYSTEMIZE":[{"def":"To reduce to system; to systematize.","pos":""}],"SYSTEMIZER":[{"def":"One who systemizes, or reduces to system; a systematizer.","pos":""}],"SYSTEMLESS":[{"def":"Not agreeing with some artificial system of classification.","pos":""},{"def":"Not having any of the distinct systems or types of structure, as the radiate, articulate, etc.","pos":""}],"SYSTOLE":[{"def":"The shortening of the long syllable.","pos":""},{"def":"The contraction of the heart and arteries by which the blood is forced onward and the circulation kept up; -- correlative to diastole.","pos":""}],"SYSTOLIC":[{"def":"Of or pertaining to systole, or contraction; contracting; esp.","pos":""}],"SYSTYLE":[{"def":"Having a space equal to two diameters or four modules between two columns; -- said of a portico or building.","pos":""},{"def":"A systyle temple or other edifice.","pos":""}]}