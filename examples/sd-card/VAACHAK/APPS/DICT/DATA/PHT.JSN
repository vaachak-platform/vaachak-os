{"PHTHALATE":[{"def":"A salt of phthalic acid.","pos":""}],"PHTHALEIN":[{"def":"One of a series of artificial organic dyes made as condensation products of the phenols with phthalic acid, and well represented by phenol phthaleïn.","pos":""}],"PHTHALIC":[{"def":"Pertaining to, or designating, a dibasic acid obtained by the oxidation of naphthalene and allied substances.","pos":""}],"PHTHALIDE":[{"def":"A lactone obtained by reduction of phthalyl chloride, as a white crystalline substance; hence, by extension, any one of the series of which phthalide proper is the type.","pos":""}],"PHTHALIMIDE":[{"def":"An imido derivative of phthalic acid, obtained as a white crystalline substance, C6H4.","pos":""}],"PHTHALIN":[{"def":"A colorless crystalline substance obtained by reduction from phthaleïn, into which it is easily converted by oxidation; hence, any one of the series of which phthalin proper is the type.","pos":""}],"PHTHALYL":[{"def":"The hypothetical radical of phthalic acid.","pos":""}],"PHTHIRIASIS":[{"def":"A disease (morbus pediculous) consisting in the excessive multiplication of lice on the human body.","pos":""}],"PHTHISIC":[{"def":"Same as Phthisis.","pos":""}],"PHTHISICAL":[{"def":"Of or pertaining to phthisis; affected with phthisis; wasting; consumptive.","pos":""}],"PHTHISICKY":[{"def":"Having phthisis, or some symptom of it, as difficulty in breathing.","pos":""}],"PHTHISIOLOGY":[{"def":"A treatise on phthisis.","pos":""},{"def":"Pulmonary consumption.","pos":""}],"PHTHISIS":[{"def":"A wasting or consumption of the tissues.","pos":""}],"PHTHONGAL":[{"def":"Formed into, or characterized by, voice; vocalized; -- said of all the vowels and the semivowels, also of the vocal or sonant consonants g, d, b, l, r, v, z, etc.","pos":""}],"PHTHONGOMETER":[{"def":"An instrument for measuring vocal sounds.","pos":""}]}