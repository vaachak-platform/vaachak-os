{"REDUB":[{"def":"To refit; to repair, or make reparation for; hence, to repay or requite.","pos":""}],"REDUCE":[{"def":"To bring to the metallic state by separating from impurities; hence, in general, to remove oxygen from; to deoxidize; to combine with, or to subject to the action of, hydrogen; as, ferric iron is reduced to ferrous iron; or metals are reduced from their ores; -- opposed to Ant: oxidize.","pos":""},{"def":"To restore to its proper place or condition, as a displaced organ or part; as, to reduce a dislocation, a fracture, or a hernia.","pos":""}],"REDUCEMENT":[{"def":"Re*duce\"ment (r*ds\"ment), n.","pos":""}],"REDUCENT":[{"def":"Tending to reduce.","pos":""},{"def":"A reducent agent.","pos":""}],"REDUCER":[{"def":"One who, or that which, reduces.","pos":""}],"REDUCIBLE":[{"def":"Capable of being reduced.","pos":""}],"REDUCIBLENESS":[{"def":"Quality of being reducible.","pos":""}],"REDUCING":[{"def":"Re*du\"cing (r*d\"sng), Defn: a & n.","pos":""}],"REDUCTIBILITY":[{"def":"The quality of being reducible; reducibleness.","pos":""}],"REDUCTION":[{"def":"The act or process of reducing.","pos":""},{"def":"The bringing of a syllogism in one of the so-called imperfect modes into a mode in the first figure.","pos":""}],"REDUCTIVE":[{"def":"Tending to reduce; having the power or effect of reducing.","pos":""},{"def":"A reductive agent.","pos":""}],"REDUCTIVELY":[{"def":"By reduction; by consequence.","pos":""}],"REDUIT":[{"def":"A central or retired work within any other work.","pos":""},{"def":"Surplusage inserted in a pleading which may be rejected by the court without impairing the validity of what remains.","pos":""}],"REDUNDANT":[{"def":"Exceeding what is natural or necessary; superabundant; exuberant; as, a redundant quantity of bile or food.","pos":""},{"def":"Using more worrds or images than are necessary or useful; pleonastic.","pos":""}],"REDUNDANTLY":[{"def":"In a refundant manner.","pos":""}],"REDUPLICATE":[{"def":"Double; doubled; reduplicative; repeated.","pos":""}],"REDUPLICATION":[{"def":"The doubling of a stem or syllable (more or less modified), with the effect of changing the time expressed, intensifying the meaning, or making the word more imitative; also, the syllable thus added; as, L.","pos":""}],"REDUPLICATIVE":[{"def":"Double; formed by reduplication; reduplicate.","pos":""}],"REDUVID":[{"def":"Any hemipterous insect of the genus Redivius, or family Reduvidæ.","pos":""}]}