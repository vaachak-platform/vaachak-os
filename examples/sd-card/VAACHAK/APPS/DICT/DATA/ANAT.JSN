{"ANATHEMA":[{"def":"Pertaining to, or having the nature of, an anathema.","pos":""}],"ANATHEMATISM":[{"def":"Anathematization.","pos":""}],"ANATHEMATIZATION":[{"def":"The act of anathematizing, or denouncing as accursed; imprecation.","pos":""}],"ANATHEMATIZE":[{"def":"To pronounce an anathema against; to curse.","pos":""}],"ANATHEMATIZER":[{"def":"One who pronounces an anathema.","pos":""}],"ANATIFA":[{"def":"An animal of the barnacle tribe, of the genus Lepas, having a fleshy stem or peduncle; a goose barnacle.","pos":""}],"ANATIFER":[{"def":"Same as Anatifa.","pos":""}],"ANATIFEROUS":[{"def":"Producing ducks; -- applied to Anatifæ, under the absurd notion of their turning into ducks or geese.","pos":""}],"ANATINE":[{"def":"Of or pertaining to the ducks; ducklike.","pos":""}],"ANATOCISM":[{"def":"Compound interest.","pos":""},{"def":"Of or relating to anatomy or dissection; as, the anatomic art; anatomical observations.","pos":""}],"ANATOMICALLY":[{"def":"In an anatomical manner; by means of dissection.","pos":""}],"ANATOMISM":[{"def":"The application of the principles of anatomy, as in art.","pos":""},{"def":"The doctrine that the anatomical structure explains all the phenomena of the organism or of animal life.","pos":""}],"ANATOMIST":[{"def":"One who is skilled in the art of anatomy, or dissection.","pos":""}],"ANATOMIZATION":[{"def":"The act of anatomizing.","pos":""}],"ANATOMIZE":[{"def":"To dissect; to cut in pieces, as an animal vegetable body, for the purpose of displaying or examining the structure and use of the several parts.","pos":""},{"def":"To discriminate minutely or carefully; to analyze.","pos":""}],"ANATOMY":[{"def":"The art of dissecting, or artificially separating the different parts of any organized body, to discover their situation, structure, and economy; dissection.","pos":""},{"def":"The science which treats of the structure of organic bodies; anatomical structure or organization.","pos":""}],"ANATREPTIC":[{"def":"Overthrowing; defeating; -- applied to Plato's refutative dialogues.","pos":""}],"ANATRON":[{"def":"Having the ovule inverted at an early period in its development, so that the chalaza is as the apparent apex; -- opposed to orthotropous.","pos":""}],"ANATTO":[{"def":"Same as Annotto.","pos":""},{"def":"A soft tumor or bloody wart on horses or oxen.","pos":""}]}