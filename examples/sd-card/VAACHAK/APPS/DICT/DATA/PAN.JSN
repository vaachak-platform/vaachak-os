{"PAN":[{"def":"The distance comprised between the angle of the epaule and the flanked angle.","pos":""},{"def":"A leaf of gold or silver.","pos":""}],"PAN-AMERICAN":[{"def":"Of or pertaining to both North and South America.","pos":""}],"PAN-AMERICAN CONGRESS":[{"def":"Pan-American Congress.","pos":""}],"PAN-AMERICANISM":[{"def":"The principle or advocacy of a political alliance or union of all the states of America.","pos":""}],"PAN-ANGLICAN":[{"def":"Belonging to, or representing, the whole Church of England; used less strictly, to include the Protestant Episcopal Church of the United States; as, the Pan-Anglican Conference at Lambeth, in 1888.","pos":""}]}