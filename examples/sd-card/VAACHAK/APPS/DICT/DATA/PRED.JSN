{"PREDACEAN":[{"def":"A carnivorous animal.","pos":""}],"PREDACEOUS":[{"def":"Living by prey; predatory.","pos":""}],"PREDAL":[{"def":"Of or pertaining to prey; plundering; predatory.","pos":""}],"PREDATE":[{"def":"To date anticipation; to affix to (a document) an earlier than the actual date; to antedate; as, a predated deed or letter.","pos":""}],"PREDATION":[{"def":"The act of pillaging.","pos":""}],"PREDATORILY":[{"def":"In a predatory manner.","pos":""}],"PREDATORY":[{"def":"Living by preying upon other animals; carnivorous.","pos":""}],"PREDE":[{"def":"To prey; to plunder.","pos":""}],"PREDECAY":[{"def":"Premature decay.","pos":""}],"PREDECEASE":[{"def":"To die sooner than.","pos":""}],"PREDECESSIVE":[{"def":"Going before; preceding.","pos":""}],"PREDECESSOR":[{"def":"One who precedes; one who has preceded another in any state, position, office, etc.","pos":""}],"PREDECLARE":[{"def":"To declare or announce beforehand; to preannounce.","pos":""}],"PREDEDICATION":[{"def":"A dedication made previously or beforehand.","pos":""}],"PREDEFINE":[{"def":"To define beforehand.","pos":""}],"PREDELIBERATION":[{"def":"Previous deliberation.","pos":""}],"PREDELINEATION":[{"def":"Previous delineation.","pos":""}],"PREDELLA":[{"def":"The step, or raised secondary part, of an altar; a superaltar; hence, in Italian painting, a band or frieze of several pictures running along the front of a superaltar, or forming a border or frame at the foot of an altarpiece.","pos":""}],"PREDESIGN":[{"def":"To design or purpose beforehand; to predetermine.","pos":""}],"PREDESIGNATE":[{"def":"A term used by Sir William Hamilton to define propositions having their quantity indicated by a verbal sign; as, all, none, etc.","pos":""}],"PREDESTINARIAN":[{"def":"Of or pertaining to predestination; as, the predestinarian controversy.","pos":""}],"PREDESTINARIANISM":[{"def":"The system or doctrine of the predestinarians.","pos":""}],"PREDESTINATE":[{"def":"Predestinated; foreordained; fated.","pos":""}],"PREDESTINATION":[{"def":"The purpose of Good from eternity respecting all events; especially, the preordination of men to everlasting happiness or misery.","pos":""}],"PREDESTINATIVE":[{"def":"Determining beforehand; predestinating.","pos":""}],"PREDESTINATOR":[{"def":"One who predestinates, or foreordains.","pos":""},{"def":"One who holds to the doctrine of predestination; a predestinarian.","pos":""}],"PREDESTINE":[{"def":"To decree beforehand; to foreordain; to predestinate.","pos":""}],"PREDETERMINABLE":[{"def":"Capable of being determined beforehand.","pos":""}],"PREDETERMINATE":[{"def":"Determined beforehand; as, the predeterminate counsel of God.","pos":""}],"PREDETERMINATION":[{"def":"The act of previous determination; a purpose formed beforehand; as, the predetermination of God's will.","pos":""}],"PREDETERMINE":[{"def":"To determine (something) beforehand.","pos":""},{"def":"To doom by previous decree; to foredoom.","pos":""}],"PREDIAL":[{"def":"Consisting of land or farms; landed; as, predial estate; that is, real estate.","pos":""},{"def":"Attached to land or farms; as, predial slaves.","pos":""}],"PREDIASTOLIC":[{"def":"Preceding the diastole of the heart; as, a prediastolic friction sound.","pos":""}],"PREDICABILITY":[{"def":"The quality or state of being predicable, or affirmable of something, or attributed to something.","pos":""}],"PREDICABLE":[{"def":"Capable of being predicated or affirmed of something; affirmable; attributable.","pos":""}],"PREDICAMENT":[{"def":"A class or kind described by any definite marks; hence, condition; particular situation or state; especially, an unfortunate or trying position or condition.","pos":""}],"PREDICAMENTAL":[{"def":"Of or pertaining to a predicament.","pos":""}],"PREDICANT":[{"def":"Predicating; affirming; declaring; proclaiming; hence; preaching.","pos":""}],"PREDICATE":[{"def":"To assert to belong to something; to affirm (one thing of another); as, to predicate whiteness of snow.","pos":""},{"def":"To found; to base.","pos":""}],"PREDICATION":[{"def":"The act of predicating, or of affirming one thing of another; affirmation; assertion.","pos":""}],"PREDICATIVE":[{"def":"Expressing affirmation or predication; affirming; predicating, as, a predicative term.","pos":""}],"PREDICATORY":[{"def":"Affirmative; positive.","pos":""}],"PREDICROTIC":[{"def":"A term applied to the pulse wave sometimes seen in a pulse curve or sphygmogram, between the apex of the curve and the dicrotic wave.","pos":""}],"PREDICT":[{"def":"To tell or declare beforehand; to foretell; to prophesy; to presage; as, to predict misfortune; to predict the return of a comet.","pos":""}],"PREDICTABLE":[{"def":"That may be predicted.","pos":""}],"PREDICTION":[{"def":"The act of foretelling; also, that which is foretold; prophecy.","pos":""}],"PREDICTIONAL":[{"def":"Prophetic; prognostic.","pos":""}],"PREDICTIVE":[{"def":"Foretelling; prophetic; foreboding.","pos":""}],"PREDICTOR":[{"def":"One who predicts; a foreteller.","pos":""}],"PREDIGEST":[{"def":"To subject (food) to predigestion or artificial digestion.","pos":""}],"PREDIGESTION":[{"def":"Artificial digestion of food for use in illness or impaired digestion.","pos":""}],"PREDILECT":[{"def":"To elect or choose beforehand.","pos":""}],"PREDILECTION":[{"def":"A previous liking; a prepossession of mind in favor of something; predisposition to choose or like; partiality.","pos":""}],"PREDISCOVER":[{"def":"To discover beforehand.","pos":""}],"PREDISCOVERY":[{"def":"A previous discovery.","pos":""}],"PREDISPONENCY":[{"def":"The state of being predisposed; predisposition.","pos":""}],"PREDISPONENT":[{"def":"Disposing beforehand; predisposing.","pos":""},{"def":"That which predisposes.","pos":""}],"PREDISPOSE":[{"def":"To dispose or incline beforehand; to give a predisposition or bias to; as, to predispose the mind to friendship.","pos":""},{"def":"To make fit or susceptible beforehand; to give a tendency to; as, debility predisposes the body to disease.","pos":""}],"PREDISPOSITION":[{"def":"The act of predisposing, or the state of being predisposed; previous inclination, tendency, or propensity; predilection; -- applied to the mind; as, a predisposition to anger.","pos":"noun"},{"def":"Previous fitness or adaptation to any change, impression, or purpose; susceptibility; -- applied to material things; as, the predisposition of the body to disease.","pos":"noun"}],"PREDOMINANCE":[{"def":"The superior influence of a planet.","pos":""}],"PREDOMINANT":[{"def":"Having the ascendency over others; superior in strength, influence, or authority; prevailing; as, a predominant color; predominant excellence.","pos":""}],"PREDOMINANTLY":[{"def":"In a predominant manner.","pos":""}],"PREDOMINATE":[{"def":"To be superior in number, strength, influence, or authority; to have controlling power or influence; to prevail; to rule; to have the mastery; as, love predominated in her heart.","pos":""}],"PREDOMINATION":[{"def":"The act or state of predominating; ascendency; predominance.","pos":""}],"PREDORSAL":[{"def":"Situated in front of the back; immediately in front, or on the ventral side the dorsal part of the vertebral column.","pos":""}],"PREDY":[{"def":"Cleared and ready for engagement, as a ship.","pos":""}]}