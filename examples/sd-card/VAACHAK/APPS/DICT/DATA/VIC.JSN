{"VICAR":[{"def":"The incumbent of an appropriated benefice.","pos":""}],"VICARAGE":[{"def":"The benefice of a vicar.","pos":""},{"def":"The house or residence of a vicar.","pos":""}],"VICARIAL":[{"def":"Of or pertaining to a vicar; as, vicarial tithes.","pos":""},{"def":"Delegated; vicarious; as, vicarial power.","pos":""}],"VICARIATE":[{"def":"Having delegated power, as a vicar; vicarious.","pos":""}],"VICARIOUS":[{"def":"Acting as a substitute; -- said of abnormal action which replaces a suppressed normal function; as, vicarious hemorrhage replacing menstruation.","pos":""}],"VICARIOUSLY":[{"def":"In a vicarious manner.","pos":""}],"VICARSHIP":[{"def":"The office or dignity of a vicar.","pos":""}],"VICE":[{"def":"A defect; a fault; an error; a blemish; an imperfection; as, the vices of a political constitution; the vices of a horse.","pos":""}],"VICE-REGAL":[{"def":"Of or pertaining to a viceroy or viceroyalty.","pos":""}],"VICED":[{"def":"Vicious; corrupt.","pos":""}],"VICEGERENCY":[{"def":"The office of a vicegerent.","pos":""}],"VICEGERENT":[{"def":"Having or exercising delegated power; acting by substitution, or in the place of another.","pos":""}],"VICEMAN":[{"def":"A smith who works at the vice instead of at the anvil.","pos":""}],"VICENARY":[{"def":"Of or pertaining to twenty; consisting of twenty.","pos":""}],"VICENNIAL":[{"def":"Lasting or comprising twenty years.","pos":""},{"def":"Happening once in twenty years; as, a vicennial celebration.","pos":""}],"VICEROY":[{"def":"A large and handsome American butterfly (Basilarchia, or Limenitis, archippus).","pos":""}],"VICEROYALTY":[{"def":"The dignity, office, or jurisdiction of a viceroy.","pos":""}],"VICETY":[{"def":"Fault; defect; coarseness.","pos":""}],"VICHY WATER":[{"def":"A mineral water found at Vichy, France.","pos":""}],"VICINAGE":[{"def":"The place or places adjoining or near; neighborhood; vicinity; as, a jury must be of the vicinage.","pos":""}],"VICINE":[{"def":"Near; neighboring; vicinal.","pos":""}],"VICINITY":[{"def":"The quality or state of being near, or not remote; nearness; propinquity; proximity; as, the value of the estate was increased by the vicinity of two country seats.","pos":""},{"def":"That which is near, or not remote; that which is adjacent to anything; adjoining space or country; neighborhood.","pos":""}],"VICIOUS":[{"def":"Characterized by vice or defects; defective; faulty; imperfect.","pos":""},{"def":"Addicted to vice; corrupt in principles or conduct; depraved; wicked; as, vicious children; vicious examples; vicious conduct.","pos":""}],"VICISSITUDE":[{"def":"Regular change or succession from one thing to another; alternation; mutual succession; interchange.","pos":""},{"def":"Irregular change; revolution; mutation.","pos":""}],"VICISSITUDINARY":[{"def":"Subject to vicissitudes.","pos":""}],"VICISSITUDINOUS":[{"def":"Full of, or subject to, changes.","pos":""}],"VICISSY DUCK":[{"def":"A West Indian duck, sometimes domesticated.","pos":""}],"VICKERS' GUN":[{"def":"One of a system of guns manufactured by the firm of Vickers' Sons, at Sheffield, Eng.","pos":""}],"VICKERS-MAXIM GUN":[{"def":"One of a system of ordnance, including machine, quick-fire, coast, and field guns, of all calibers, manufactured by the combined firms of Vickers' Sons of Sheffield and Maxim of Birmingham and elsewhere, England.","pos":""}],"VICONTIEL":[{"def":"Of or pertaining to the viscount or sheriff of a country.","pos":""}],"VICONTIELS":[{"def":"Things belonging to the sheriff; especially, farms (called also vicontiel rents) for which the sheriff used to pay rent to the king.","pos":""}],"VICTIM":[{"def":"A living being sacrificed to some deity, or in the performance of a religious rite; a creature immolated, or made an offering of.","pos":""},{"def":"A person or thing destroyed or sacrificed in the pursuit of an object, or in gratification of a passion; as, a victim to jealousy, lust, or ambition.","pos":""}],"VICTIMATE":[{"def":"To make a victim of; to sacrifice; to immolate.","pos":""}],"VICTIMIZE":[{"def":"To make a victim of, esp.","pos":""}],"VICTOR":[{"def":"The winner in a contest; one who gets the better of another in any struggle; esp.","pos":""}],"VICTORIA":[{"def":"A genus of aquatic plants named in honor of Queen Victoria.","pos":""},{"def":"An asteroid discovered by Hind in 1850; -- called also Clio.","pos":""}],"VICTORIA CRAPE":[{"def":"A kind of cotton crape.","pos":""}],"VICTORIAN":[{"def":"Of or pertaining to the reign of Queen Victoria of England; as, the Victorian poets.","pos":""}],"VICTORINE":[{"def":"A woman's fur tippet.","pos":""}],"VICTORIOUS":[{"def":"Of or pertaining to victory, or a victor' being a victor; bringing or causing a victory; conquering; winning; triumphant; as, a victorious general; victorious troops; a victorious day.","pos":""}],"VICTORIUM":[{"def":"A probable chemical element discovered by Sir William Crookes in 1898.","pos":""}],"VICTORY":[{"def":"The defeat of an enemy in battle, or of an antagonist in any contest; a gaining of the superiority in any struggle or competition; conquest; triumph; -- the opposite of Ant: defeat.","pos":""}],"VICTRESS":[{"def":"A woman who wins a victory; a female victor.","pos":""}],"VICTUAL":[{"def":"Food; -- now used chiefly in the plural.","pos":""},{"def":"Grain of any kind.","pos":""}],"VICTUALAGE":[{"def":"Vict\"ual*age (; 48), n.","pos":""}],"VICTUALER":[{"def":"One who furnishes victuals.","pos":""},{"def":"One who keeps a house of entertainment; a tavern keeper; an innkeeper.","pos":""}],"VICTUALING":[{"def":"Of or pertaining to victuals, or provisions; supplying provisions; as, a victualing ship.","pos":""}],"VICTUALS":[{"def":"Food for human beings, esp.","pos":""}],"VICTUS":[{"def":"A South American mammal (Auchenia vicunna) native of the elevated plains of the Andes, allied to the llama but smaller.","pos":""}]}