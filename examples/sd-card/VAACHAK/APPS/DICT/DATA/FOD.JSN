{"FODDER":[{"def":"A weight by which lead and some other metals were formerly sold, in England, varying from 19 [Obs.","pos":""}],"FODDERER":[{"def":"One who fodders cattle.","pos":""}],"FODIENT":[{"def":"Fitted for, or pertaining to, digging.","pos":""}],"FODIENTIA":[{"def":"A group of African edentates including the aard-vark.","pos":"noun"}]}