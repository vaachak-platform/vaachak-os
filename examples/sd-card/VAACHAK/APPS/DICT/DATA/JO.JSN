{"JO":[{"def":"A sweetheart; a darling.","pos":""}],"JOB":[{"def":"A sudden thrust or stab; a jab.","pos":""},{"def":"A piece of chance or occasional work; any definite work undertaken in gross for a fixed price; as, he did the job for a thousand dollars.","pos":""}],"JOBATION":[{"def":"A scolding; a hand, tedious reproof.","pos":""}],"JOBBER":[{"def":"One who works by the job.","pos":""},{"def":"A dealer in the public stocks or funds; a stockjobber.","pos":""}],"JOBBERY":[{"def":"The act or practice of jobbing.","pos":""},{"def":"Underhand management; official corruption; as, municipal jobbery.","pos":""}],"JOBBING":[{"def":"Doing chance work or add jobs; as, a jobbing carpenter.","pos":""},{"def":"Using opportunities of public service for private gain; as, a jobbing politician.","pos":""}],"JOCANTRY":[{"def":"The act or practice of jesting.","pos":""}],"JOCKEY":[{"def":"A professional rider of horses in races.","pos":""},{"def":"A dealer in horses; a horse trader.","pos":""}],"JOCKEYING":[{"def":"The act or management of one who jockeys; trickery.","pos":""}],"JOCKEYISM":[{"def":"The practice of jockeys.","pos":""}],"JOCKEYSHIP":[{"def":"The art, character, or position, of a jockey; the personality of a jockey.","pos":""}],"JOCOSE":[{"def":"Given to jokes and jesting; containing a joke, or abounding in jokes; merry; sportive; humorous.","pos":""}],"JOCOSERIOUS":[{"def":"Mingling mirth and seriousness.","pos":""}],"JOCOSITY":[{"def":"A jocose act or saying; jocoseness.","pos":""}],"JOCULAR":[{"def":"Given to jesting; jocose; as, a jocular person.","pos":""},{"def":"Sportive; merry.","pos":""}],"JOCULARITY":[{"def":"Jesting; merriment.","pos":""}],"JOCULARLY":[{"def":"In jest; for sport or mirth; jocosely.","pos":""}],"JOCULARY":[{"def":"Jocular; jocose; sportive.","pos":""}],"JOCULATOR":[{"def":"A jester; a joker.","pos":""}],"JOCULATORY":[{"def":"Droll; sportive.","pos":""}],"JOCUND":[{"def":"Merry; cheerful; gay; airy; lively; sportive.","pos":""}],"JOCUNDITY":[{"def":"The state or quality of being jocund; gayety; sportiveness.","pos":""}],"JOE MILLER":[{"def":"A jest book; a stale jest; a worn-out joke.","pos":""}],"JOE-PYE WEED":[{"def":"A tall composite plant of the genus Eupatorium (E.","pos":""}],"JOG":[{"def":"To push or shake with the elbow or hand; to jostle; esp.","pos":""},{"def":"To suggest to; to notify; to remind; to call the attention of; as, to jog the memory.","pos":""}],"JOGGING":[{"def":"The act of giving a jog or jogs; traveling at a jog.","pos":""}],"JOGGLE":[{"def":"To join by means of joggles, so as to prevent sliding apart; sometimes, loosely, to dowel.","pos":""}],"JOHANNEAN":[{"def":"Of or pertaining to John, esp.","pos":""}],"JOHANNES":[{"def":"A Portuguese gold coin of the value of eight dollars, named from the figure of King John which it bears;- often contracted into joe; as, a joe, or a half joe.","pos":""}],"JOHANNISBERGER":[{"def":"A fine white wine produced on the estate of Schloss (or Castle) Johannisberg, on the Rhine.","pos":""}],"JOHN":[{"def":"A proper name of a man.","pos":""}],"JOHNADREAMS":[{"def":"A dreamy, idle fellow.","pos":""}],"JOHNNY":[{"def":"A familiar diminutive of John.","pos":""}],"JOHNNYCAKE":[{"def":"A kind of bread made of the meal of maize (Indian corn), mixed with water or milk, etc.","pos":""}],"JOHNSON GRASS":[{"def":"A tall perennial grass (Sorghum Halepense), valuable in the Southern and Western States for pasture and hay.","pos":""}],"JOHNSONESE":[{"def":"The literary style of Dr.","pos":""}],"JOHNSONIAN":[{"def":"Pertaining to or resembling Dr.","pos":""}],"JOHNSONIANISM":[{"def":"A manner of acting or of writing peculiar to, or characteristic of, Dr.","pos":""}],"JOIN":[{"def":"To bring together, literally or figuratively; to place in contact; to connect; to couple; to unite; to combine; to associate; to add; to append.","pos":""},{"def":"To associate one's self to; to be or become connected with; to league one's self with; to unite with; as, to join a party; to join the church.","pos":""}],"JOINDER":[{"def":"The act of joining; a putting together; conjunction.","pos":""}],"JOINER":[{"def":"One who, or that which, joins.","pos":""},{"def":"One whose occupation is to construct articles by joining pieces of wood; a mechanic who does the woodwork (as doors, stairs, etc.","pos":""}],"JOINERY":[{"def":"The art, or trade, of a joiner; the work of a joiner.","pos":""}],"JOINHAND":[{"def":"Writing in which letters are joined in words; -- distinguished from writing in single letters.","pos":""}],"JOINT":[{"def":"A plane of fracture, or divisional plane, of a rock transverse to the stratification.","pos":""},{"def":"The space between the adjacent surfaces of two bodies joined and held together, as by means of cement, mortar, etc.","pos":""}],"JOINT-FIR":[{"def":"A genus (Ephedra) of leafless shrubs, with the stems conspicuously jointed; -- called also shrubby horsetail.","pos":""}],"JOINTED":[{"def":"Having joints; articulated; full of nodes; knotty; as, a jointed doll; jointed structure.","pos":""}],"JOINTER":[{"def":"One who, or that which, joints.","pos":""},{"def":"A plane for smoothing the surfaces of pieces which are to be accurately joined; especially: (a) The longest plane used by a joiner.","pos":""}],"JOINTING":[{"def":"The act or process of making a joint; also, the joints thus produced.","pos":""}],"JOINTLESS":[{"def":"Without a joint; rigid; stiff.","pos":""}],"JOINTLY":[{"def":"In a joint manner; together; unitedly; in concert; not separately.","pos":""}],"JOINTRESS":[{"def":"A woman who has a jointure.","pos":""}],"JOINTURE":[{"def":"An estate settled on a wife, which she is to enjoy after husband's decease, for her own life at least, in satisfaction of dower.","pos":""}],"JOINTURELESS":[{"def":"Having no jointure.","pos":""}],"JOINTWEED":[{"def":"A slender, nearly leafless, American herb (Polygonum articulatum), with jointed spikes of small flowers.","pos":""}],"JOINTWORM":[{"def":"The larva of a small, hymenopterous fly (Eurytoma hordei), which is found in gall-like swellings on the stalks of wheat, usually at or just above the first joint.","pos":""}],"JOIST":[{"def":"A piece of timber laid horizontally, or nearly so, to which the planks of the floor, or the laths or furring strips of a ceiling, are nailed; -- called, according to its position or use, binding joist, bridging joist, ceiling joist, trimming joist, etc.","pos":""}],"JOKE":[{"def":"Something said for the sake of exciting a laugh; something witty or sportive (commonly indicating more of hilarity or humor than jest); a jest; a witticism; as, to crack good-natured jokes.","pos":""},{"def":"Something not said seriously, or not actually meant; something done in sport.","pos":""}],"JOKER":[{"def":"See Rest bower, under 2d Bower.","pos":""}],"JOKINGLY":[{"def":"In a joking way; sportively.","pos":""}],"JOLIF":[{"def":"Joyful; merry; pleasant; jolly.","pos":""}],"JOLLIFICATION":[{"def":"A merrymaking; noisy festivity.","pos":""}],"JOLLILY":[{"def":"In a jolly manner.","pos":""}],"JOLLINESS":[{"def":"Jollity; noisy mirth.","pos":""}],"JOLLITY":[{"def":"Noisy mirth; gayety; merriment; festivity; boisterous enjoyment.","pos":""}],"JOLLY":[{"def":"Full of life and mirth; jovial; joyous; merry; mirthful.","pos":""},{"def":"Expressing mirth, or inspiring it; exciting mirth and gayety.","pos":""}],"JOLLY-BOAT":[{"def":"A boat of medium size belonging to a ship.","pos":""}],"JOLT":[{"def":"To shake with short, abrupt risings and fallings, as a carriage moving on rough ground; as, the coach jolts.","pos":""}],"JOLTER":[{"def":"One who, or that which, jolts.","pos":""},{"def":"A dunce; a blockhead.","pos":""}],"JOLTINGLY":[{"def":"In a jolting manner.","pos":""}],"JOLTY":[{"def":"That jolts; as, a jolty coach.","pos":""}],"JONAH":[{"def":"The Hebrew prophet, who was cast overboard as one who endangered the ship; hence, any person whose presence is unpropitious.","pos":""}],"JONESIAN":[{"def":"Of or pertaining to Jones.","pos":""},{"def":"A bulbous plant of the genus Narcissus (N.","pos":""}],"JORAM":[{"def":"A pot or vessel with a large neck, formerly used by physicians and alchemists.","pos":""}],"JORUM":[{"def":"A large drinking vessel; also, its contents.","pos":""}],"JOSEPH":[{"def":"An outer garment worn in the 18th century; esp.","pos":""}],"JOSEPH'S FLOWER":[{"def":"A composite herb (Tragopogon pratensis), of the same genus as the salsify.","pos":""}],"JOSO":[{"def":"A small gudgeon.","pos":""}],"JOSS":[{"def":"A Chinese household divinity; a Chinese idol.","pos":""}],"JOSS PAPER":[{"def":"Gold and silver paper burned by the Chinese, in the form of coins or ingots, in worship and at funerals.","pos":""}],"JOSSA":[{"def":"A command to a horse, probably meaning \"stand still.","pos":""}],"JOSTLE":[{"def":"To run against and shake; to push out of the way; to elbow; to hustle; to disturb by crowding; to crowd against.","pos":""}],"JOSTLEMENT":[{"def":"Crowding; hustling.","pos":""}],"JOT":[{"def":"An iota; a point; a tittle; the smallest particle.","pos":""}],"JOTTER":[{"def":"One who jots down memoranda.","pos":""},{"def":"A memorandum book.","pos":""}],"JOUGS":[{"def":"An iron collar fastened to a wall or post, formerly used in Scotland as a kind of pillory.","pos":""}],"JOUISSANCE":[{"def":"Jollity; merriment.","pos":""}],"JOULE":[{"def":"A unit of work which is equal to 107 units of work in the C.","pos":""}],"JOULE'S CYCLE":[{"def":"The cycle for the air engine proposed by Joule.","pos":""}],"JOULE'S LAW":[{"def":"The law that the rate at which heat is produced in any part of an electric circuit is measured by the product of the square of the current into the resistance of that part of the circuit.","pos":""}],"JOULEMETER":[{"def":"An integrating wattmeter for measuring the energy in joules expended in an electric circuit or developed by a machine.","pos":""}],"JOUNCE":[{"def":"To jolt; to shake, especially by rough riding or by driving over obstructions.","pos":""}],"JOURNAL":[{"def":"Whiles from their journal labors they did rest.","pos":""}],"JOURNALISM":[{"def":"The keeping of a journal or diary.","pos":""},{"def":"The periodical collection and publication of current news; the business of managing, editing, or writing for, journals or newspapers; as, political journalism.","pos":""}],"JOURNALIST":[{"def":"One who keeps a journal or diary.","pos":""},{"def":"The conductor of a public journal, or one whose business it to write for a public journal; an editorial or other professional writer for a periodical.","pos":""}],"JOURNALISTIC":[{"def":"Pertaining to journals or to journalists; contained in, or characteristic of, the public journals; as journalistic literature or enterprise.","pos":""}],"JOURNALIZE":[{"def":"To enter or record in a journal or diary.","pos":""}],"JOURNEY":[{"def":"The travel or work of a day.","pos":""},{"def":"Travel or passage from one place to another; hence, figuratively, a passage through life.","pos":""}],"JOURNEY-BATED":[{"def":"Worn out with journeying.","pos":""}],"JOURNEYER":[{"def":"One who journeys.","pos":""}],"JOURNEYMAN":[{"def":"Formerly, a man hired to work by the day; now, commonly, one who has mastered a handicraft or trade; -- distinguished from apprentice and from master workman.","pos":""}],"JOURNEYWORK":[{"def":"Originally, work done by the day; work done by a journeyman at his trade.","pos":""}],"JOUST":[{"def":"To engage in mock combat on horseback, as two knights in the lists; to tilt.","pos":""}],"JOUSTER":[{"def":"One who jousts or tilts.","pos":""}],"JOVE":[{"def":"The planet Jupiter.","pos":""}],"JOVIAL":[{"def":"Of or pertaining to the god, or the planet, Jupiter.","pos":""}],"JOVIALIST":[{"def":"One who lives a jovial life.","pos":""}],"JOVIALITY":[{"def":"The quality or state of being jovial.","pos":""}],"JOVIALLY":[{"def":"In a jovial manner; merrily; gayly.","pos":""}],"JOVIALNESS":[{"def":"Noisy mirth; joviality.","pos":""}],"JOVIAN":[{"def":"Of or pertaining to Jove, or Jupiter (either the deity or the planet).","pos":""}],"JOVICENTRIC":[{"def":"Revolving around the planet Jupiter; appearing as viewed from Jupiter.","pos":""}],"JOVINIANIST":[{"def":"An adherent to the doctrines of Jovinian, a monk of the fourth century, who denied the virginity of Mary, and opposed the asceticism of his time.","pos":""}],"JOWL":[{"def":"The cheek; the jaw.","pos":""}],"JOWLER":[{"def":"A dog with large jowls, as the beagle.","pos":""}],"JOWTER":[{"def":"A mounted peddler of fish; -- called also jouster.","pos":""}],"JOY":[{"def":"The passion or emotion excited by the acquisition or expectation of good; pleasurable feelings or emotions caused by success, good fortune, and the like, or by a rational prospect of possessing what we love or desire; gladness; exhilaration of spirits; delight.","pos":""},{"def":"That which causes joy or happiness.","pos":""}],"JOYANCE":[{"def":"Enjoyment; gayety; festivity; joyfulness.","pos":""}],"JOYFUL":[{"def":"Full of joy; having or causing joy; very glad; as, a joyful heart.","pos":""}],"JOYLESS":[{"def":"Not having joy; not causing joy; unenjoyable.","pos":""}],"JOYOUS":[{"def":"Glad; gay; merry; joyful; also, affording or inspiring joy; with of before the word or words expressing the cause of joy.","pos":""}],"JOYSOME":[{"def":"Causing joyfulness.","pos":""}]}