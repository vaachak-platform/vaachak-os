{"PES":[{"def":"The distal segment of the hind limb of vertebrates, including the tarsus and foot.","pos":""}],"PESADE":[{"def":"The motion of a horse when, raising his fore quarters, he keeps his hind feet on the ground without advancing; rearing.","pos":""}],"PESAGE":[{"def":"A fee, or toll, paid for the weighing of merchandise.","pos":""}],"PESANTED":[{"def":"Made heavy or dull; debased.","pos":""}],"PESETA":[{"def":"A Spanish silver coin, and money of account, equal to about nineteen cents, and divided into 100 centesimos.","pos":""},{"def":"The earliest Syriac version of the Old Testament, translated from Hebrew; also, the incomplete Syriac version of the New Testament.","pos":""}],"PESKY":[{"def":"Pestering; vexatious; troublesome.","pos":""}],"PESO":[{"def":"A Spanish dollar; also, an Argentine, Chilian, Colombian, etc.","pos":""}],"PESSIMISM":[{"def":"The opinion or doctrine that everything in nature is ordered for or tends to the worst, or that the world is wholly evil; -- opposed to Ant: optimism.","pos":""}],"PESSIMIST":[{"def":"One who advocates the doctrine of pessimism; -- opposed to Ant: optimist.","pos":""},{"def":"Of or pertaining to pessimism; characterized by pessimism; gloomy; foreboding.","pos":""}],"PESSIMIZE":[{"def":"To hold or advocate the doctrine of pessimism.","pos":""}],"PESSULUS":[{"def":"A delicate bar of cartilage connecting the dorsal and ventral extremities of the first pair of bronchial cartilages in the syrinx of birds.","pos":""}],"PEST":[{"def":"A fatal epidemic disease; a pestilence; specif.","pos":""},{"def":"Anything which resembles a pest; one who, or that which, is troublesome, noxious, mischievous, or destructive; a nuisance.","pos":""}],"PESTALOZZIAN":[{"def":"Belonging to, or characteristic of, a system of elementary education which combined manual training with other instruction, advocated and practiced by Jean Henri Pestalozzi (1746-1827), a Swiss teacher.","pos":""},{"def":"An advocate or follower of the system of Pestalozzi.","pos":""}],"PESTALOZZIANISM":[{"def":"The system of education introduced by Pestalozzi.","pos":""}],"PESTER":[{"def":"To trouble; to disturb; to annoy; to harass with petty vexations.","pos":""},{"def":"To crowd together in an annoying way; to overcrowd; to infest.","pos":""}],"PESTERER":[{"def":"One who pesters or harasses.","pos":""}],"PESTERMENT":[{"def":"The act of pestering, or the state of being pestered; vexation; worry.","pos":""}],"PESTEROUS":[{"def":"Inclined to pester.","pos":""}],"PESTHOUSE":[{"def":"A house or hospital for persons who are infected with any pestilential disease.","pos":""}],"PESTIDUCT":[{"def":"That which conveys contagion or infection.","pos":""}],"PESTIFEROUS":[{"def":"Pest-bearing; pestilential; noxious to health; malignant; infectious; contagious; as, pestiferous bodies.","pos":""},{"def":"Noxious to peace, to morals, or to society; vicious; hurtful; destructive; as, a pestiferous demagogue.","pos":""}],"PESTIFEROUSLY":[{"def":"In a pestiferuos manner.","pos":""}],"PESTILENCE":[{"def":"Specifically, the disease known as the plague; hence, any contagious or infectious epidemic disease that is virulent and devastating.","pos":""}],"PESTILENT":[{"def":"Pestilential; noxious; pernicious; mischievous.","pos":""}],"PESTILENTIAL":[{"def":"Having the nature or qualities of a pestilence.","pos":""},{"def":"Hence: Mischievous; noxious; pernicious; morally destructive.","pos":""}],"PESTILENTIALLY":[{"def":"Pes`ti*len\"tial*ly, adv.","pos":""}],"PESTILENTLY":[{"def":"In a pestilent manner; mischievously; destructively.","pos":""}],"PESTILENTNESS":[{"def":"The quality of being pestilent.","pos":""}],"PESTILLATION":[{"def":"The act of pounding and bruising with a pestle in a mortar.","pos":""}],"PESTLE":[{"def":"An implement for pounding and breaking or braying substances in a mortar.","pos":""},{"def":"A constable's or bailiff's staff; -- so called from its shape.","pos":""}]}