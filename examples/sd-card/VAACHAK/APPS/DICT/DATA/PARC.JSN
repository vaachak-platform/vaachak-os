{"PARCASE":[{"def":"Perchance; by chance.","pos":""}],"PARCEL":[{"def":"A part; a portion; a piece; as, a certain piece of land is part and parcel of another piece.","pos":""}],"PARCEL POST":[{"def":"That branch of the post office having to do with the collection, transmission, and delivery of parcels.","pos":""}],"PARCEL-MELE":[{"def":"By parcels or parts.","pos":""}],"PARCELING":[{"def":"Long, narrow slips of canvas daubed with tar and wound about a rope like a bandage, before it is served; used, also, in mousing on the stayes, etc.","pos":""}],"PARCENARY":[{"def":"The holding or occupation of an inheritable estate which descends from the ancestor to two or more persons; coheirship.","pos":""}],"PARCENER":[{"def":"A coheir, or one of two or more persons to whom an estate of inheritance descends jointly, and by whom it is held as one estate.","pos":""}],"PARCH":[{"def":"To burn the surface of; to scorch; to roast over the fire, as dry grain; as, to parch the skin; to parch corn.","pos":""},{"def":"To dry to extremity; to shrivel with heat; as, the mouth is parched from fever.","pos":""}],"PARCHEDNESS":[{"def":"The state of being parched.","pos":""}],"PARCHING":[{"def":"Scorching; burning; drying.","pos":""}],"PARCHMENT":[{"def":"The skin of a lamb, sheep, goat, young calf, or other animal, prepared for writing on.","pos":""},{"def":"The envelope of the coffee grains, inside the pulp.","pos":""}],"PARCHMENTIZE":[{"def":"To convert to a parchmentlike substance, esp.","pos":""}],"PARCLOSE":[{"def":"A screen separating a chapel from the body of the church.","pos":""}]}