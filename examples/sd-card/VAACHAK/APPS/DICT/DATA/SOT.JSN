{"SOT":[{"def":"A stupid person; a blockhead; a dull fellow; a dolt.","pos":""},{"def":"A person stupefied by excessive drinking; an habitual drunkard.","pos":""}],"SOTADIC":[{"def":"Pertaining to, or resembling, the lascivious compositions of the Greek poet Sotades.","pos":""},{"def":"A Sotadic verse or poem.","pos":""}],"SOTE":[{"def":"SOTEL; SOTIL So\"tel, So\"til, a.","pos":""}],"SOTERIOLOGY":[{"def":"The doctrine of salvation by Jesus Christ.","pos":""}],"SOTHE":[{"def":"Of or pertaining to Sothis, the Egyptian name for the Dog Star; taking its name from the Dog Star; canicular.","pos":""}],"SOTTISH":[{"def":"Like a sot; doltish; very foolish; drunken.","pos":""}],"SOTTO VOCE":[{"def":"With a restrained voice or moderate force; in an undertone.","pos":""}]}