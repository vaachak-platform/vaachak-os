{"FORWAKED":[{"def":"Tired out with excessive waking or watching.","pos":""}],"FORWANDER":[{"def":"To wander away; to go astray; to wander far and to weariness.","pos":""}],"FORWARD":[{"def":"An agreement; a covenant; a promise.","pos":""},{"def":"Toward a part or place before or in front; onward; in advance; progressively; -- opposed to backward.","pos":""}],"FORWARDER":[{"def":"One employed in forwarding.","pos":""}],"FORWARDING":[{"def":"The process of putting a book into its cover, and making it ready for the finisher.","pos":""}],"FORWARDLY":[{"def":"Eagerly; hastily; obtrusively.","pos":""}],"FORWARDNESS":[{"def":"The quality of being forward; cheerful readiness; promtness; as, the forwardness of Christians in propagating the gospel.","pos":""}],"FORWARDS":[{"def":"Same as Forward.","pos":""}],"FORWASTE":[{"def":"To desolate or lay waste utterly.","pos":""}],"FORWEARY":[{"def":"To weary extremely; to dispirit.","pos":""}],"FORWHY":[{"def":"Wherefore; because.","pos":""}],"FORWORN":[{"def":"A silly man, in simple weeds forworn.","pos":""}],"FORWOT":[{"def":"For*wot\", Defn: pres.","pos":""}],"FORWRAP":[{"def":"To wrap up; to conceal.","pos":""}]}