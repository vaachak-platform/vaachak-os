{"PEW":[{"def":"One of the compartments in a church which are separated by low partitions, and have long seats upon which several persons may sit; - - sometimes called slip.","pos":""},{"def":"Any structure shaped like a church pew, as a stall, formerly used by money lenders, etc.","pos":""}],"PEWEE":[{"def":"A common American tyrant flycatcher (Sayornis phoebe, or S.","pos":""}],"PEWFELLOW":[{"def":"One who occupies the same pew with another.","pos":""},{"def":"An intimate associate; a companion.","pos":""}],"PEWTER":[{"def":"A hard, tough, but easily fusible, alloy, originally consisting of tin with a little lead, but afterwards modified by the addition of copper, antimony, or bismuth.","pos":""},{"def":"Utensils or vessels made of pewter, as dishes, porringers, drinking vessels, tankards, pots.","pos":""}],"PEWTERER":[{"def":"One whose occupation is to make utensils of pewter; a pewtersmith.","pos":""}],"PEWTERY":[{"def":"Belonging to, or resembling, pewter; as, a pewtery taste.","pos":""}]}