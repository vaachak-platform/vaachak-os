{"INFUCATE":[{"def":"To stain; to paint; to daub.","pos":""}],"INFUCATION":[{"def":"The act of painting or staining, especially of painting the face.","pos":""}],"INFULA":[{"def":"A sort of fillet worn by dignitaries, priests, and others among the ancient Romans.","pos":""}],"INFUMATE":[{"def":"To dry by exposing to smoke; to expose to smoke.","pos":""}],"INFUMATED":[{"def":"Clouded; having a cloudy appearance.","pos":""}],"INFUMATION":[{"def":"Act of drying in smoke.","pos":""}],"INFUMED":[{"def":"Dried in smoke; smoked.","pos":""},{"def":"Having the form of a funnel; pertaining to an infundibulum.","pos":""}],"INFUNDIBULIFORM":[{"def":"Same as Funnelform.","pos":""}],"INFUNDIBULUM":[{"def":"A funnel-shaped or dilated organ or part; as, the infundibulum of the brain, a hollow, conical process, connecting the floor of the third ventricle with the pituitary body; the infundibula of the lungs, the enlarged terminations of the bronchial tubes.","pos":""}],"INFUNERAL":[{"def":"To inter with funeral rites; to bury.","pos":""}],"INFURCATION":[{"def":"A forked exlpansion or divergence; a bifurcation; a branching.","pos":""}],"INFURIATE":[{"def":"Enraged; rading; furiously angry; infuriated.","pos":""}],"INFURIATED":[{"def":"Enraged; furious.","pos":""}],"INFUSCATE":[{"def":"To darken; to make black; to obscure.","pos":""}],"INFUSCATED":[{"def":"Darkened with a blackish tinge.","pos":""}],"INFUSCATION":[{"def":"The act of darkening, or state of being dark; darkness; obscurity.","pos":""}],"INFUSE":[{"def":"To pour in, as a liquid; to pour (into or upon); to shed.","pos":""},{"def":"To instill, as principles or qualities; to introduce.","pos":""}],"INFUSER":[{"def":"One who, or that which, infuses.","pos":""}],"INFUSIBILITY":[{"def":"Capability of being infused, pouredin, or instilled.","pos":""}],"INFUSIBLE":[{"def":"Capable of being infused.","pos":""}],"INFUSION":[{"def":"The act of infusing, pouring in, or instilling; instillation; as, the infusion of good principles into the mind; the infusion of ardor or zeal.","pos":""},{"def":"That which is infused; suggestion; inspiration.","pos":""}],"INFUSIONISM":[{"def":"The doctrine that the soul is preexistent to the body, and is infused into it at conception or birth; -- opposed to tradicianism and creationism.","pos":""}],"INFUSIVE":[{"def":"Having the power of infusion; inspiring; influencing.","pos":""}],"INFUSORIA":[{"def":"One of the classes of Protozoa, including a large number of species, all of minute size.","pos":""}],"INFUSORIAL":[{"def":"Belonging to the Infusoria; composed of, or containing, Infusoria; as, infusorial earth.","pos":""}],"INFUSORIAN":[{"def":"One of the Infusoria.","pos":""}],"INFUSORY":[{"def":"One of the Infusoria; -- usually in the pl.","pos":""},{"def":"A suffix used to from present participles; as, singing, playing.","pos":""}]}