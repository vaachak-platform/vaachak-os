{"PREELECT":[{"def":"To elect beforehand.","pos":""}],"PREELECTION":[{"def":"Election beforehand.","pos":""}],"PREEMINENCE":[{"def":"The quality or state of being preëminent; superiority in prominence or in excellence; distinction above others in quality, rank, etc.","pos":""}],"PREEMINENT":[{"def":"Eminent above others; prominent among those who are eminent; superior in excellence; surpassing, or taking precedence of, others; rarely, surpassing others in evil, or in bad qualities; as, preëminent in guilt.","pos":""}],"PREEMINENTLY":[{"def":"In a preëminent degree.","pos":""}],"PREEMPLOY":[{"def":"To employ beforehand.","pos":""}],"PREEMPT":[{"def":"To settle upon (public land) with a right of preemption, as under the laws of the United States; to take by preëmption.","pos":""}],"PREEMPTION":[{"def":"The act or right of purchasing before others.","pos":""}],"PREEMPTIONER":[{"def":"One who holds a prior to purchase certain public land.","pos":""}],"PREEMPTIVE":[{"def":"Of or pertaining to preëmption; having power to preëmpt; preëmpting.","pos":""}],"PREEMPTOR":[{"def":"One who preëmpts; esp.","pos":""}],"PREEMPTORY":[{"def":"Pertaining to preëmption.","pos":""}],"PREEN":[{"def":"A forked tool used by clothiers in dressing cloth.","pos":""}],"PREENGAGE":[{"def":"To engage by previous contract; to bind or attach previously; to preoccupy.","pos":""}],"PREENGAGEMENT":[{"def":"Prior engagement, obligation, or attachment, as by contract, promise, or affection.","pos":""}],"PREERECT":[{"def":"To erect beforehand.","pos":""}],"PREESTABLISH":[{"def":"To establish beforehand.","pos":""}],"PREESTABLISHMENT":[{"def":"Settlement beforehand.","pos":""}],"PREETERNITY":[{"def":"Infinite previous duration.","pos":""}],"PREEXAMINATION":[{"def":"Previous examination.","pos":""}],"PREEXAMINE":[{"def":"To examine beforehand.","pos":""}],"PREEXIST":[{"def":"To exist previously; to exist before something else.","pos":""}],"PREEXISTENCE":[{"def":"Existence in a former state, or previous to something else.","pos":""},{"def":"Existence of the soul before its union with the body; -- a doctrine held by certain philosophers.","pos":""}],"PREEXISTENT":[{"def":"Existing previously; preceding existence; as, a preëxistent state.","pos":""}],"PREEXISTENTISM":[{"def":"The theory of a preëxistence of souls before their association with human bodies.","pos":""}],"PREEXISTIMATION":[{"def":"Previous esteem or estimation.","pos":""}],"PREEXPECTATION":[{"def":"Previous expectation.","pos":""}]}