{"CORM":[{"def":"A solid bulb-shaped root, as of the crocus.","pos":""},{"def":"Same as Cormus, 2.","pos":""}],"CORMOGENY":[{"def":"The embryological history of groups or families of individuals.","pos":""}],"CORMOPHYLOGENY":[{"def":"The phylogeny of groups or families of individuals.","pos":""},{"def":"A term proposed by Endlicher to include all plants with an axis containing vascular tissue and with foliage.","pos":""}],"CORMORANT":[{"def":"Any species of Phalacrocorax, a genus of sea birds having a sac under the beak; the shag.","pos":""}],"CORMORAUT":[{"def":"Ravenous; voracious.","pos":""}],"CORMUS":[{"def":"A vegetable or animal made up of a number of individuals, such as, for example, would be formed by a process of budding from a parent stalk wherre the buds remain attached.","pos":""}]}