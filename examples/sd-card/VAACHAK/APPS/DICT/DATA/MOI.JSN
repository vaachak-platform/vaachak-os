{"MOIDORE":[{"def":"A gold coin of Portugal, valued at about 27s.","pos":""}],"MOIETY":[{"def":"One of two equal parts; a half; as, a moiety of an estate, of goods, or of profits; the moiety of a jury, or of a nation.","pos":""},{"def":"An indefinite part; a small part.","pos":""}],"MOIL":[{"def":"To daub; to make dirty; to soil; to defile.","pos":""}],"MOILE":[{"def":"A kind of high shoe anciently worn.","pos":""}],"MOINEAU":[{"def":"A small flat bastion, raised in the middle of an overlong curtain.","pos":""}],"MOIRA":[{"def":"The deity who assigns to every man his lot.","pos":""}],"MOIRE":[{"def":"Originally, a fine textile fabric made of the hair of an Asiatic goat; afterwards, any textile fabric to which a watered appearance is given in the process of calendering.","pos":""},{"def":"A watered, clouded, or frosted appearance produced upon either textile fabrics or metallic surfaces.","pos":""}],"MOIRE METALLIQUE":[{"def":"A crystalline or frosted appearance produced by some acids on tin plate; also, the tin plate thus treated.","pos":""}],"MOIST":[{"def":"Moderately wet; damp; humid; not dry; as, a moist atmosphere or air.","pos":""}],"MOISTEN":[{"def":"To make damp; to wet in a small degree.","pos":""},{"def":"To soften by making moist; to make tender.","pos":""}],"MOISTENER":[{"def":"One who, or that which, moistens.","pos":""}],"MOISTFUL":[{"def":"Full of moisture.","pos":""}],"MOISTLESS":[{"def":"Without moisture; dry.","pos":""}],"MOISTNESS":[{"def":"The quality or state of being moist.","pos":""}],"MOISTURE":[{"def":"A moderate degree of wetness.","pos":""},{"def":"That which moistens or makes damp or wet; exuding fluid; liquid in small quantity.","pos":""}],"MOISTURELESS":[{"def":"Without moisture.","pos":""}],"MOITHER":[{"def":"To perplex; to confuse.","pos":""}]}