{"DISK":[{"def":"The circular figure of a celestial body, as seen projected of the heavens.","pos":""},{"def":"A circular structure either in plants or animals; as, a blood disk; germinal disk, etc.","pos":""}],"DISK CLUTCH":[{"def":"A friction clutch in which the gripping surfaces are disks or more or less resemble disks.","pos":""}],"DISKINDNESS":[{"def":"Unkindness; disservice.","pos":""}],"DISKLESS":[{"def":"Having no disk; appearing as a point and not expanded into a disk, as the image of a faint star in a telescope.","pos":""}]}