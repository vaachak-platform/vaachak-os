{"PREIGNITION":[{"def":"Ignition in an internal-combustion engine while the inlet valve is open or before compression is completed.","pos":""}],"PREINDESIGNATE":[{"def":"Having no sign expressive of quantity; indefinite.","pos":""}],"PREINDISPOSE":[{"def":"To render indisposed beforehand.","pos":""}],"PREINSTRUCT":[{"def":"To instruct previously or beforehand.","pos":""}],"PREINTIMATION":[{"def":"Previous intimation; a suggestion beforehand.","pos":""}]}