{"ARNATTO":[{"def":"An inhabitant of Albania and neighboring mountainous regions, specif.","pos":""}],"ARNICA":[{"def":"A genus of plants; also, the most important species (Arnica montana), native of the mountains of Europe, used in medicine as a narcotic and stimulant.","pos":""}],"ARNICIN":[{"def":"An active principle of Arnica montana.","pos":""}],"ARNICINE":[{"def":"An alkaloid obtained from the arnica plant.","pos":""}],"ARNOTTO":[{"def":"Same as Annotto.","pos":""},{"def":"Belonging to, or resembling, the Arum family of plants.","pos":""}]}