{"SHAN'T":[{"def":"A contraction of shall not.","pos":""}],"SHANDRYDAN":[{"def":"A jocosely depreciative name for a vehicle.","pos":""}],"SHANDYGAFF":[{"def":"A mixture of strong beer and ginger beer.","pos":""}],"SHANGHAI":[{"def":"To intoxicate and ship (a person) as a sailor while in this condition.","pos":""}],"SHANK":[{"def":"The space between two channels of the Doric triglyph.","pos":""},{"def":"A large ladle for molten metal, fitted with long bars for handling it.","pos":""}],"SHANNY":[{"def":"The European smooth blenny (Blennius pholis).","pos":""}],"SHANTY":[{"def":"A small, mean dwelling; a rough, slight building for temporary use; a hut.","pos":""}]}