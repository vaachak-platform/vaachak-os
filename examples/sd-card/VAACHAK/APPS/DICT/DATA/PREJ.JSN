{"PREJUDGE":[{"def":"To judge before hearing, or before full and sufficient examination; to decide or sentence by anticipation; to condemn beforehand.","pos":""}],"PREJUDGMENT":[{"def":"The act of prejudging; decision before sufficient examination.","pos":""}],"PREJUDICACY":[{"def":"Prejudice; prepossession.","pos":""}],"PREJUDICAL":[{"def":"Of or pertaining to the determination of some matter not previously decided; as, a prejudical inquiry or action at law.","pos":""}],"PREJUDICANT":[{"def":"Influenced by prejudice; biased.","pos":""}],"PREJUDICATE":[{"def":"Formed before due examination.","pos":""},{"def":"Biased by opinions formed prematurely; prejudiced.","pos":""}],"PREJUDICATELY":[{"def":"Pre*ju\"di*cate*ly, adv.","pos":""}],"PREJUDICATION":[{"def":"The act of prejudicating, or of judging without due examination of facts and evidence; prejudgment.","pos":""}],"PREJUDICATIVE":[{"def":"Forming a judgment without due examination; prejudging.","pos":""}],"PREJUDICE":[{"def":"A bias on the part of judge, juror, or witness which interferes with fairness of judgment.","pos":""}],"PREJUDICIAL":[{"def":"Biased, possessed, or blinded by prejudices; as, to look with a prejudicial eye.","pos":""},{"def":"Tending to obstruct or impair; hurtful; injurious; disadvantageous; detrimental.","pos":""}]}