{"INTENABLE":[{"def":"Incapable of being held; untenable; not defensible; as, an intenable opinion; an intenable fortress.","pos":""}],"INTEND":[{"def":"To stretch' to extend; to distend.","pos":""},{"def":"To strain; to make tense.","pos":""}],"INTENDANCY":[{"def":"The office or employment of an intendant.","pos":""},{"def":"A territorial district committed to the charge of an intendant.","pos":""}],"INTENDANT":[{"def":"One who has the charge, direction, or management of some public business; a superintendent; as, an intendant of marine; an intendant of finance.","pos":""}],"INTENDED":[{"def":"Made tense; stretched out; extended; forcible; violent.","pos":""},{"def":"Purposed; designed; as, intended harm or help.","pos":""}],"INTENDENT":[{"def":"See Intendant, n.","pos":""}],"INTENDER":[{"def":"One who intends.","pos":""}],"INTENDIMENT":[{"def":"Attention; consideration; knowledge; understanding.","pos":""}],"INTENDMENT":[{"def":"The true meaning, understanding, or intention of a law, or of any legal instrument.","pos":""}],"INTENERATE":[{"def":"To make tender or sensitive; to soften.","pos":""}],"INTENERATION":[{"def":"The act or process of intenerating, or the state of being intenerated; softening.","pos":""}],"INTENIBLE":[{"def":"Incapable of holding or containing.","pos":""}],"INTENSATION":[{"def":"The act or process of intensifying; intensification; climax.","pos":""}],"INTENSATIVE":[{"def":"Adding intensity; intensifying.","pos":""}],"INTENSE":[{"def":"Strained; tightly drawn; kept on the stretch; strict; very close or earnest; as, intense study or application; intense thought.","pos":""},{"def":"Extreme in degree; excessive; immoderate; as: (a) Ardent; fervent; as, intense heat.","pos":""}],"INTENSELY":[{"def":"To an extreme degree; as, weather intensely cold.","pos":""}],"INTENSENESS":[{"def":"The state or quality of being intense; intensity; as, the intenseness of heat or cold; the intenseness of study or thought.","pos":""}],"INTENSIFICATION":[{"def":"The act or process of intensifying, or of making more intense.","pos":""}],"INTENSIFIER":[{"def":"One who or that which intensifies or strengthens; in photography, an agent used to intensify the lights or shadows of a picture.","pos":""}],"INTENSIFY":[{"def":"To render more intense; as, to intensify heat or cold; to intensify colors; to intensify a photographic negative; to intensify animosity.","pos":""}],"INTENSION":[{"def":"The collective attributes, qualities, or marks that make up a complex general notion; the comprehension, content, or connotation; - - opposed to extension, extent, or sphere.","pos":""}],"INTENSITIVE":[{"def":"Increasing the force or intensity of; intensive; as, the intensitive words of a sentence.","pos":""}],"INTENSITY":[{"def":"The amount or degree of energy with which a force operates or a cause acts; effectiveness, as estimated by results produced.","pos":""},{"def":"The magnitude of a distributed force, as pressure, stress, weight, etc.","pos":""}],"INTENSIVE":[{"def":"Serving to give force or emphasis; as, an intensive verb or preposition.","pos":""}],"INTENSIVELY":[{"def":"In an intensive manner; by increase of degree.","pos":""}],"INTENSIVENESS":[{"def":"The quality or state of being intensive; intensity.","pos":""}],"INTENT":[{"def":"Closely directed; strictly attentive; bent; -- said of the mind, thoughts, etc.","pos":""},{"def":"Having the mind closely directed to or bent on an object; sedulous; eager in pursuit of an object; -- formerly with to, but now with on; as, intent on business or pleasure.","pos":""}],"INTENTION":[{"def":"Any mental apprehension of an object.","pos":""}],"INTENTIONAL":[{"def":"Done by intention or design; intended; designed; as, the act was intentional, not accidental.","pos":""}],"INTENTIONALITY":[{"def":"The quality or state of being intentional; purpose; design.","pos":""}],"INTENTIONALLY":[{"def":"In an intentional manner; with intention; by design; of purpose.","pos":""}],"INTENTIONED":[{"def":"Having designs; -- chiefly used in composition; as, well- intentioned, having good designs; ill-intentioned, having ill designs.","pos":""}],"INTENTIVE":[{"def":"Attentive; intent.","pos":""}],"INTENTIVELY":[{"def":"Attentively; closely.","pos":""}],"INTENTIVENESS":[{"def":"Closeness of attention or application of mind; attentiveness.","pos":""}],"INTENTLY":[{"def":"In an intent manner; as, the eyes intently fixed.","pos":""}],"INTENTNESS":[{"def":"The state or quality of being intent; close application; attention.","pos":""}]}