{"CRAP":[{"def":"In the game of craps, a first throw of the dice in which the total is two, three, or twelve, in which case the caster loses.","pos":""}],"CRAP SHOOTING":[{"def":"Same as Crapulence.","pos":""}],"CRAPAUD":[{"def":"Crapaud, a nickname for a Frenchman.","pos":""}],"CRAPAUDINE":[{"def":"Turning on pivots at the top and bottom; -- said of a door.","pos":""}],"CRAPE":[{"def":"A thin, crimped stuff, made of raw silk gummed and twisted on the mill.","pos":""}],"CRAPEFISH":[{"def":"Salted codfish hardened by pressure.","pos":""}],"CRAPNEL":[{"def":"A hook or drag; a grapnel.","pos":""}],"CRAPPIE":[{"def":"A kind of fresh-water bass of the genus Pomoxys, found in the rivers of the Southern United States and Mississippi valley.","pos":""}],"CRAPPLE":[{"def":"Crap\"ple (krp\"p'l), n.","pos":""}],"CRAPS":[{"def":"A gambling game with dice.","pos":""}],"CRAPULENCE":[{"def":"The sickness occasioned by intemperance; surfeit.","pos":""},{"def":"Surcharged with liquor; sick from excessive indulgence in liquor; drunk; given to excesses.","pos":""}],"CRAPY":[{"def":"Resembling crape.","pos":""}]}