{"DELPH":[{"def":"Five nothings in five plates of delph.","pos":""}],"DELPHIC":[{"def":"Pertaining to the dauphin of France; as, the Delphin classics, an edition of the Latin classics, prepared in the reign of Louis XIV.","pos":""}],"DELPHIN":[{"def":"A fatty substance contained in the oil of the dolphin and the porpoise; -- called also phocenin.","pos":""}],"DELPHINE":[{"def":"Pertaining to the dolphin, a genus of fishes.","pos":""}],"DELPHINIC":[{"def":"Pertaining to, or derived from, the dolphin; phocenic.","pos":""}],"DELPHININE":[{"def":"A poisonous alkaloid extracted from the stavesacre (Delphinium staphisagria), as a colorless amorphous powder.","pos":""}],"DELPHINOID":[{"def":"Pertaining to, or resembling, the dolphin.","pos":""}],"DELPHINOIDEA":[{"def":"The division of Cetacea which comprises the dolphins, porpoises, and related forms.","pos":""}],"DELPHINUS":[{"def":"A genus of Cetacea, including the dolphin.","pos":""},{"def":"The Dolphin, a constellation near the equator and east of Aquila.","pos":""}]}