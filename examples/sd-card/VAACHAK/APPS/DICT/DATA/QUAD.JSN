{"QUAD":[{"def":"A quadrangle; hence, a prison.","pos":""}],"QUADRABLE":[{"def":"That may be sqyared, or reduced to an equivalent square; -- said of a surface when the area limited by a curve can be exactly found, and expressed in a finite number of algebraic terms.","pos":""}],"QUADRAGENARIOUS":[{"def":"Consisting of forty; forty years old.","pos":""}],"QUADRAGENE":[{"def":"An indulgence of forty days, corresponding to the forty days of ancient canonical penance.","pos":""}],"QUADRAGESIMA":[{"def":"The forty days of fast preceding Easter; Lent.","pos":""}],"QUADRAGESIMAL":[{"def":"Belonging to Lent; used in Lent; Lenten.","pos":""}],"QUADRAGESIMALS":[{"def":"Offerings formerly made to the mother church of a diocese on Mid-Lent Sunday.","pos":""}],"QUADRANGLE":[{"def":"A plane figure having four angles, and consequently four sides; any figure having four angles.","pos":""}],"QUADRANGULAR":[{"def":"Having four angles, and consequently four sides; tetragonal.","pos":""}],"QUADRANS":[{"def":"A fourth part of the coin called an as.","pos":""}],"QUADRANT":[{"def":"The quarter of a circle, or of the circumference of a circle, an arc of 90º, or one subtending a right angle at the center.","pos":""},{"def":"One of the four parts into which a plane is divided by the coördinate axes.","pos":""}],"QUADRANTAL":[{"def":"Of or pertaining to a quadrant; also, included in the fourth part of a circle; as, quadrantal space.","pos":""}],"QUADRAT":[{"def":"A block of type metal lower than the letters, -- used in spacing and in blank lines.","pos":""}],"QUADRATE":[{"def":"Having four equal sides, the opposite sides parallel, and four right angles; square.","pos":""},{"def":"Produced by multiplying a number by itself; square.","pos":""}],"QUADRATIC":[{"def":"Pertaining to terms of the second degree; as, a quadratic equation, in which the highest power of the unknown quantity is a square.","pos":""}],"QUADRATICS":[{"def":"That branch of algebra which treats of quadratic equations.","pos":""}],"QUADRATOJUGAL":[{"def":"The quadratojugal bone.","pos":""}],"QUADRATRIX":[{"def":"A curve made use of in the quadrature of other curves; as the quadratrix, of Dinostratus, or of Tschirnhausen.","pos":""}],"QUADRATURE":[{"def":"The act of squaring; the finding of a square having the same area as some given curvilinear figure; as, the quadrature of a circle; the operation of finding an expression for the area of a figure bounded wholly or in part by a curved line, as by a curve, two ordinates, and the axis of abscissas.","pos":""},{"def":"The integral used in obtaining the area bounded by a curve; hence, the definite integral of the product of any function of one variable into the differential of that variable.","pos":""}],"QUADREL":[{"def":"A square piece of turf or peat.","pos":""},{"def":"A square brick, tile, or the like.","pos":""}],"QUADRENNIAL":[{"def":"Comprising four years; as, a quadrennial period.","pos":""},{"def":"Occurring once in four years, or at the end of every four years; as, quadrennial games.","pos":""}],"QUADRENNIALLY":[{"def":"Once in four years.","pos":""}],"QUADRENNIUM":[{"def":"A space or period of four years.","pos":""}],"QUADRI-":[{"def":"A combining form meaning four, four times, fourfold; as, quadricapsular, having four capsules.","pos":""}],"QUADRIBASIC":[{"def":"Same as Tetrabasic.","pos":""}],"QUADRIC":[{"def":"Of or pertaining to the second degree.","pos":""}],"QUADRICAPSULAR":[{"def":"Having four capsules.","pos":""}],"QUADRICEPS":[{"def":"The great extensor muscle of the knee, divided above into four parts which unite in a single tendon at the knee.","pos":""}],"QUADRICIPITAL":[{"def":"Of or pertaining to the quadriceps.","pos":""}],"QUADRICORN":[{"def":"Any quadricornous animal.","pos":""}],"QUADRICORNOUS":[{"def":"Having four horns, or hornlike organs; as, a quadricornous beetle.","pos":""}],"QUADRICOSTATE":[{"def":"Having four ribs.","pos":""}],"QUADRIDENTATE":[{"def":"Having four teeth; as, a quadridentate leaf.","pos":""}],"QUADRIENNIAL":[{"def":"Same as Quadrennial.","pos":""}],"QUADRIFARIOUS":[{"def":"Arranged in four rows or ranks; as, quadrifarious leaves.","pos":""}],"QUADRIFID":[{"def":"Divided, or deeply cleft, into four parts; as, a quadrifid perianth; a quadrifid leaf.","pos":""},{"def":"Four-leaved; having the leaves in whorls of four.","pos":""}],"QUADRIFURCATED":[{"def":"Having four forks, or branches.","pos":""}],"QUADRIGA":[{"def":"A car or chariot drawn by four horses abreast.","pos":""},{"def":"Fourfold; having four similar parts, or two pairs of similar parts.","pos":""}],"QUADRIGENARIOUS":[{"def":"Consisting of four hundred.","pos":""}],"QUADRIJUGATE":[{"def":"Same as Quadrijugous.","pos":""}],"QUADRIJUGOUS":[{"def":"Pinnate, with four pairs of leaflets; as, a quadrijugous leaf.","pos":""}],"QUADRILATERAL":[{"def":"Having four sides, and consequently four angles; quadrangular.","pos":""}],"QUADRILATERALNESS":[{"def":"The property of being quadrilateral.","pos":""}],"QUADRILITERAL":[{"def":"Consisting of four letters.","pos":""}],"QUADRILLE":[{"def":"A dance having five figures, in common time, four couples of dancers being in each set.","pos":""},{"def":"The appropriate music for a quadrille.","pos":""}],"QUADRILLION":[{"def":"Having four lobes; as, a quadrilobate leaf.","pos":""}],"QUADRILOCULAR":[{"def":"Having four cells, or cavities; as, a quadrilocular heart.","pos":""}],"QUADRIN":[{"def":"A small piece of money, in value about a farthing, or a half cent.","pos":""}],"QUADRINODAL":[{"def":"Possessing four nodes; as, quadrinodal curves.","pos":""}],"QUADRINOMIAL":[{"def":"A polynomial of four terms connected by the signs plus or minus.","pos":""}],"QUADRIPARTITE":[{"def":"Divided into four parts.","pos":""}],"QUADRIPARTITELY":[{"def":"Quad*rip\"ar*tite*ly, adv.","pos":""}],"QUADRIPARTITION":[{"def":"A division or distribution by four, or into four parts; also, a taking the fourth part of any quantity or number.","pos":""}],"QUADRIPENNATE":[{"def":"Having four wings; -- said of insects.","pos":""}],"QUADRIPHYLLOUS":[{"def":"Having four leaves; quadrifoliate.","pos":""}],"QUADRIREME":[{"def":"A galley with four banks of oars or rowers.","pos":""}],"QUADRISECTION":[{"def":"A subdivision into four parts.","pos":""}],"QUADRISULCATE":[{"def":"Having four hoofs; as, a quadrisulcate foot; a quadrisulcate animal.","pos":""},{"def":"Having four syllables; of or pertaining to quadrisyllables; as, a quadrisyllabic word.","pos":""}],"QUADRISYLLABLE":[{"def":"A word consisting of four syllables.","pos":""}],"QUADRIVALENCE":[{"def":"The quality or state of being quadrivalent; tetravalence.","pos":""}],"QUADRIVALENT":[{"def":"Having a valence of four; capable of combining with, being replaced by, or compared with, four monad atoms; tetravalent; -- said of certain atoms and radicals; thus, carbon and silicon are quadrivalent elements.","pos":""}],"QUADRIVALVE":[{"def":"Dehiscent into four similar parts; four-valved; as, a quadrivalve pericarp.","pos":""}],"QUADRIVALVULAR":[{"def":"Having four valves; quadrivalve.","pos":""}],"QUADRIVIAL":[{"def":"Having four ways meeting in a point.","pos":""}],"QUADRIVIUM":[{"def":"The four \"liberal arts,\" arithmetic, music, geometry, and astronomy; -- so called by the schoolmen.","pos":""}],"QUADROON":[{"def":"The offspring of a mulatto and a white person; a person quarter-blooded.","pos":""}],"QUADRUMANA":[{"def":"A division of the Primates comprising the apes and monkeys; -- so called because the hind foot is usually prehensile, and the great toe opposable somewhat like a thumb.","pos":""}],"QUADRUMANE":[{"def":"One of the Quadrumana.","pos":""}],"QUADRUMANOUS":[{"def":"Having four hands; of or pertaining to the Quadrumana.","pos":""}],"QUADRUPED":[{"def":"Having four feet.","pos":""}],"QUADRUPEDAL":[{"def":"Having four feet; of or pertaining to a quadruped.","pos":""}],"QUADRUPLANE":[{"def":"An aëroplane with four superposed main supporting surfaces.","pos":""}],"QUADRUPLE":[{"def":"Fourfold; as, to make quadruple restitution; a quadruple alliance.","pos":""}],"QUADRUPLET":[{"def":"A collection or combination of four of a kind.","pos":""},{"def":"A cycle for carrying four riders, so arranged that all the reders can assist in the propulsion.","pos":""}],"QUADRUPLEX":[{"def":"Fourfold; folded or doubled twice.","pos":""}],"QUADRUPLICATE":[{"def":"To make fourfold; to double twice; to quadruple.","pos":""}],"QUADRUPLICATION":[{"def":"The act of making fourfold; a taking four times the simple sum or amount.","pos":""}],"QUADRUPLY":[{"def":"To a fourfold quantity; so as to be, or cause to be, quadruple; as, to be quadruply recompensed.","pos":""}]}