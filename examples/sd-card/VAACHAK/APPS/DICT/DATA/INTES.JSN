{"INTESTABLE":[{"def":"Not capable of making a will; not legally qualified or competent to make a testament.","pos":""}],"INTESTACY":[{"def":"The state of being intestate, or of dying without having made a valid will.","pos":""}],"INTESTATE":[{"def":"Without having made a valid will; without a will; as, to die intestate.","pos":""},{"def":"Not devised or bequeathed; not disposed of by will; as, an intestate estate.","pos":""}],"INTESTINAL":[{"def":"Of or pertaining to the intestines of an animal; as, the intestinal tube; intestinal digestion; intestinal ferments.","pos":""}],"INTESTINE":[{"def":"Internal; inward; -- opposed to external.","pos":""},{"def":"Internal with regard to a state or country; domestic; not foreign; -- applied usually to that which is evil; as, intestine disorders, calamities, etc.","pos":""}]}