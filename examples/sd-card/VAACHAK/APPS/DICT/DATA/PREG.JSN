{"PREGLACIAL":[{"def":"Prior to the glacial or drift period.","pos":""}],"PREGNABLE":[{"def":"Capable of being entered, taken, or captured; expugnable; as, a pregnable fort.","pos":""}],"PREGNANCY":[{"def":"The condition of being pregnant; the state of being with young.","pos":""},{"def":"Figuratively: The quality of being heavy with important contents, issue, significance, etc.","pos":""}],"PREGNANT":[{"def":"Being with young, as a female; having conceived; great with young; breeding; teeming; gravid; preparing to bring forth.","pos":""},{"def":"Heavy with important contents, significance, or issue; full of consequence or results; weighty; as, pregnant replies.","pos":""}],"PREGNANTLY":[{"def":"In a pregnant manner; fruitfully; significantly.","pos":""}],"PREGRAVATE":[{"def":"To bear down; to depress.","pos":""}],"PREGRAVITATE":[{"def":"To descend by gravity; to sink.","pos":""}],"PREGUSTANT":[{"def":"Tasting beforehand; having a foretaste.","pos":""}],"PREGUSTATION":[{"def":"The act of tasting beforehand; foretaste.","pos":""}]}