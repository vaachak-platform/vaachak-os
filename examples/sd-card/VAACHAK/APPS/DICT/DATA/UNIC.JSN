{"UNICAMERAL":[{"def":"Having, or consisting of, a single chamber; -- said of a legislative assembly.","pos":""}],"UNICAPSULAR":[{"def":"Having but one capsule to each flower.","pos":""}],"UNICARINATED":[{"def":"Having one ridge or keel.","pos":""}],"UNICELLULAR":[{"def":"Having, or consisting of, but a single cell; as, a unicellular organism.","pos":""}],"UNICENTRAL":[{"def":"Having a single center of growth.","pos":""}],"UNICITY":[{"def":"The condition of being united; quality of the unique; unification.","pos":""}],"UNICOLOROUS":[{"def":"Having the surface of a uniform color.","pos":""}],"UNICORN":[{"def":"The kamichi; -- called also unicorn bird.","pos":""}],"UNICORNOUS":[{"def":"Having but a single horn; -- said of certain insects.","pos":""}],"UNICOSTATE":[{"def":"Having a single rib or strong nerve running upward from the base; -- said of a leaf.","pos":""}],"UNICURSAL":[{"def":"That can be passed over in a single course; -- said of a curve when the coördinates of the point on the curve can be expressed as rational algebraic functions of a single parameter th.","pos":""}]}