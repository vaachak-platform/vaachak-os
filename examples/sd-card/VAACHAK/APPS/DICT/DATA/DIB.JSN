{"DIB":[{"def":"A child's game, played with dib bones.","pos":""}],"DIBASIC":[{"def":"Having two acid hydrogen atoms capable of replacement by basic atoms or radicals, in forming salts; bibasic; -- said of acids, as oxalic or sulphuric acids.","pos":""}],"DIBASICITY":[{"def":"The property or condition of being dibasic.","pos":""}],"DIBBLE":[{"def":"A pointed implement used to make holes in the ground in which no set out plants or to plant seeds.","pos":""}],"DIBBLER":[{"def":"One who, or that which, dibbles, or makes holes in the ground for seed.","pos":""}],"DIBRANCHIATA":[{"def":"An order of cephalopods which includes those with two gills, an apparatus for emitting an inky fluid, and either eight or ten cephalic arms bearing suckers or hooks, as the octopi and squids.","pos":""}],"DIBRANCHIATE":[{"def":"Having two gills.","pos":""},{"def":"One of the Dibranchiata.","pos":""}],"DIBS":[{"def":"A sweet preparation or treacle of grape juice, much used in the East.","pos":""}],"DIBSTONE":[{"def":"A pebble used in a child's game called dibstones.","pos":""}],"DIBUTYL":[{"def":"A liquid hydrocarbon, C8H18, of the marsh-gas series, being one of several octanes, and consisting of two butyl radicals.","pos":""}]}