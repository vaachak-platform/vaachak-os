{"DACAPO":[{"def":"From the beginning; a direction to return to, and end with, the first strain; -- indicated by the letters D.","pos":""}],"DACE":[{"def":"A small European cyprinoid fish (Squalius leuciscus or Leuciscus vulgaris); -- called also dare.","pos":""}],"DACHSHUND":[{"def":"One of a breed of small dogs with short crooked legs, and long body; -- called also badger dog.","pos":""}],"DACIAN":[{"def":"Of or pertaining to Dacia or the Dacians.","pos":""},{"def":"A native of ancient Dacia.","pos":""}],"DACOIT":[{"def":"One of a class of robbers, in India, who act in gangs.","pos":""}],"DACOITY":[{"def":"The practice of gang robbery in India; robbery committed by dacoits.","pos":""}],"DACOTAHS":[{"def":"Same as Dacotas.","pos":""}],"DACTYL":[{"def":"A poetical foot of three sylables (-- ~ ~), one long followed by two short, or one accented followed by two unaccented; as, L.","pos":""}],"DACTYLAR":[{"def":"Of or pertaining to a finger or toe, or to the claw of an insect crustacean.","pos":""}],"DACTYLIC":[{"def":"Pertaining to, consisting chiefly or wholly of, dactyls; as, dactylic verses.","pos":""}],"DACTYLIOGLYPHY":[{"def":"The art or process of gem engraving.","pos":""}],"DACTYLIOGRAPHY":[{"def":"Dac*tyl`i*og\"ra*phy, n.","pos":""}],"DACTYLIOLOGY":[{"def":"Dac*tyl`i* ol\"o*gy, n.","pos":""}],"DACTYLIOMANCY":[{"def":"Divination by means of finger rings.","pos":""}],"DACTYLIST":[{"def":"A writer of dactylic verse.","pos":""}],"DACTYLITIS":[{"def":"An inflammatory affection of the fingers.","pos":""}],"DACTYLOLOGY":[{"def":"The art of communicating ideas by certain movements and positions of the fingers; -- a method of conversing practiced by the deaf and dumb.","pos":""}],"DACTYLONOMY":[{"def":"The art of numbering or counting by the fingers.","pos":""}],"DACTYLOPTEROUS":[{"def":"Having the inferior rays of the pectoral fins partially or entirely free, as in the gurnards.","pos":""}],"DACTYLOTHECA":[{"def":"The scaly covering of the toes, as in birds.","pos":""}],"DACTYLOZOOID":[{"def":"A kind of zooid of Siphonophora which has an elongated or even vermiform body, with one tentacle, but no mouth.","pos":""}]}