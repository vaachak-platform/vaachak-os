{"SPERABLE":[{"def":"Within the range of hpe; proper to be hoped for.","pos":""}],"SPERATE":[{"def":"Hoped for, or to be hoped for.","pos":""}],"SPERE":[{"def":"To search; to pry; to ask; to inquire.","pos":""}],"SPERGE":[{"def":"A charge of wash for the still.","pos":""}],"SPERM":[{"def":"The male fecundating fluid; semen.","pos":"noun"}],"SPERM WHALE":[{"def":"A very large toothed whale (Physeter macrocephalus), having a head of enormous size.","pos":""}],"SPERMACETI":[{"def":"A white waxy substance obtained from cavities in the head of the sperm whale, and used making candles, oilments, cosmetics, etc.","pos":""}],"SPERMAPHORE":[{"def":"That part of the ovary from which the ovules arise; the placenta.","pos":""}],"SPERMARY":[{"def":"An organ in which spermatozoa are developed; a sperm gland; a testicle.","pos":""}],"SPERMATHECA":[{"def":"A small sac connected with the female reproductive organs of insects and many other invertebrates, serving to receive and retain the spermatozoa.","pos":""}],"SPERMATIC":[{"def":"Of or pertaining to semen; as, the spermatic fluid, the spermatic vessels, etc.","pos":""}],"SPERMATIN":[{"def":"A substance allied to alkali albumin and to mucin, present in semen, to which it is said to impart the mucilaginous character.","pos":""}],"SPERMATISM":[{"def":"The emission of sperm, or semen.","pos":""}],"SPERMATIUM":[{"def":"One of the motionless spermatozoids in the conceptacles of certain fungi.","pos":""}],"SPERMATIZE":[{"def":"To yield seed; to emit seed, or sperm.","pos":""},{"def":"Combining forms from Gr.","pos":""}],"SPERMATOBLAST":[{"def":"Same as Spermoblast.","pos":""}],"SPERMATOCYTE":[{"def":"Same as Spermoblast.","pos":""}],"SPERMATOGEMMA":[{"def":"Same as Spermosphere.","pos":""}],"SPERMATOGENESIS":[{"def":"The development of the spermatozoids.","pos":""}],"SPERMATOGENETIC":[{"def":"Relating to, or connected with, spermatogenesis; as, spermatogenetic function.","pos":""}],"SPERMATOGENOUS":[{"def":"Sperm-producing.","pos":""}],"SPERMATOGONIUM":[{"def":"A primitive seminal cell, occuring in masses in the seminal tubules.","pos":""}],"SPERMATOID":[{"def":"Spermlike; resembling sperm, or semen.","pos":""}],"SPERMATOPHORE":[{"def":"Same as Spermospore.","pos":""},{"def":"A capsule or pocket inclosing a number of spermatozoa.","pos":""}],"SPERMATOPHOROUS":[{"def":"Producing seed, or sperm; seminiferous; as, the so-called spermatophorous cells.","pos":""}],"SPERMATOPHYTA":[{"def":"A phylum embracing the highest plants, or those that produce seeds; the seed plants, or flowering plants.","pos":""}],"SPERMATOPHYTE":[{"def":"Any plant of the phylum Spermatophyta.","pos":""},{"def":"Abnormally frequent involuntary emission of the semen without copulation.","pos":""}],"SPERMATOSPORE":[{"def":"Same as Spermospore.","pos":""}],"SPERMATOZOID":[{"def":"The male germ cell in animals and plants, the essential element in fertilization; a microscopic animalcule-like particle, usually provided with one or more cilia by which it is capable of active motion.","pos":""}],"SPERMATOZOOID":[{"def":"Same as Spermatozoid.","pos":""}],"SPERMIC":[{"def":"Of or pertaining to sperm, or semen.","pos":""}],"SPERMISM":[{"def":"The theory, formerly held by many, that the sperm or spermatozoön contains the germ of the future embryo; animalculism.","pos":""}],"SPERMIST":[{"def":"A believer in the doctrine, formerly current, of encasement in the male (see Encasement), in which the seminal thread, or spermatozoid, was considered as the real animal germ, the head being the true animal head and the tail the body.","pos":""}],"SPERMOBLAST":[{"def":"One of the cells formed by the diivision of the spermospore, each of which is destined to become a spermatozoid; a spermatocyte; a spermatoblast.","pos":""}],"SPERMOCOCCUS":[{"def":"The nucleus of the sperm cell.","pos":""}],"SPERMODERM":[{"def":"The covering of a seed; -- sometimes limited to the outer coat or testa.","pos":""}],"SPERMOGONIUM":[{"def":"A conceptacle of certain lichens, which contains spermatia.","pos":""}],"SPERMOLOGIST":[{"def":"One who treats of, or collects, seeds.","pos":""}],"SPERMOPHILE":[{"def":"Any ground squirrel of the genus Spermophilus; gopher.","pos":""}],"SPERMOPHORE":[{"def":"A spermatophore.","pos":""}],"SPERMOPHYTA":[{"def":"Plants which produce seed; phænogamia.","pos":""}],"SPERMOPHYTE":[{"def":"Any plant which produces true seeds; -- a term recently proposed to replace phænogam.","pos":""}],"SPERMOPHYTIC":[{"def":"Capable of producing seeds; phænogamic.","pos":""}],"SPERMOPLASMA":[{"def":"The protoplasm of the sperm cell.","pos":""}],"SPERMOSPHERE":[{"def":"A mass or ball of cells formed by the repeated division of a male germinal cell (spermospore), each constituent cell (spermoblast) of which is converted into a spermatozoid; a spermatogemma.","pos":""}],"SPERMOSPORE":[{"def":"The male germinal or seminal cell, from the breaking up of which the spermoblasts are formed and ultimately the spermatozoids; a spermatospore.","pos":""}],"SPERRYLITE":[{"def":"An arsenide of platinum occuring in grains and minute isometric crystals of tin-white color.","pos":"noun"}]}