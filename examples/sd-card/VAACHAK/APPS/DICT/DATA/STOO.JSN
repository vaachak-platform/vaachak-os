{"STOOK":[{"def":"A small collection of sheaves set up in the field; a shock; in England, twelve sheaves.","pos":""}],"STOOL":[{"def":"A plant from which layers are propagated by bending its branches into the soil.","pos":""}],"STOOLBALL":[{"def":"A kind of game with balls, formerly common in England, esp.","pos":""}],"STOOP":[{"def":"Originally, a covered porch with seats, at a house door; the Dutch stoep as introduced by the Dutch into New York.","pos":""}],"STOOR":[{"def":"To rise in clouds, as dust.","pos":""},{"def":"Strong; powerful; hardy; bold; audacious.","pos":""}]}