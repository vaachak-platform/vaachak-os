{"AFFABILITY":[{"def":"The quality of being affable; readiness to converse; courteousness in receiving others and in conversation; complaisant behavior.","pos":""}],"AFFABLE":[{"def":"Easy to be spoken to or addressed; receiving others kindly and conversing with them in a free and friendly manner; courteous; sociable.","pos":""},{"def":"Gracious; mild; benign.","pos":""}],"AFFABLY":[{"def":"In an affable manner; courteously.","pos":""}],"AFFABROUS":[{"def":"Executed in a workmanlike manner; ingeniously made.","pos":""}],"AFFAIR":[{"def":"An action or engagement not of sufficient magnitude to be called a battle.","pos":""}],"AFFAMISH":[{"def":"To afflict with, or perish from, hunger.","pos":""}],"AFFECT":[{"def":"To act upon; to produce an effect or change upon.","pos":""},{"def":"To influence or move, as the feelings or passions; to touch.","pos":""}],"AFFECTATION":[{"def":"An attempt to assume or exhibit what is not natural or real; false display; artificial show.","pos":""},{"def":"A striving after.","pos":""}],"AFFECTATIONIST":[{"def":"One who exhibits affectation.","pos":""}],"AFFECTED":[{"def":"Made up of terms involving different powers of the unknown quantity; adfected; as, an affected equation.","pos":""}],"AFFECTEDLY":[{"def":"In an affected manner; hypocritically; with more show than reality.","pos":""},{"def":"Lovingly; with tender care.","pos":""}],"AFFECTER":[{"def":"One who affects, assumes, pretends, or strives after.","pos":""}],"AFFECTIBILITY":[{"def":"The quality or state of being affectible.","pos":""}],"AFFECTIBLE":[{"def":"That may be affected.","pos":""}],"AFFECTING":[{"def":"Moving the emotions; fitted to excite the emotions; pathetic; touching; as, an affecting address; an affecting sight.","pos":""},{"def":"Affected; given to false show.","pos":""}],"AFFECTINGLY":[{"def":"In an affecting manner; is a manner to excite emotions.","pos":""}],"AFFECTION":[{"def":"Disease; morbid symptom; malady; as, a pulmonary affection.","pos":""}],"AFFECTIONAL":[{"def":"Of or pertaining to the affections; as, affectional impulses; an affectional nature.","pos":""}],"AFFECTIONATE":[{"def":"Having affection or warm regard; loving; fond; as, an affectionate brother.","pos":""},{"def":"Kindly inclined; zealous.","pos":""}],"AFFECTIONATED":[{"def":"Disposed; inclined.","pos":""}],"AFFECTIONATELY":[{"def":"With affection; lovingly; fondly; tenderly; kindly.","pos":""}],"AFFECTIONATENESS":[{"def":"The quality of being affectionate; fondness; affection.","pos":""}],"AFFECTIONED":[{"def":"Affected; conceited.","pos":""}],"AFFECTIVE":[{"def":"Tending to affect; affecting.","pos":""},{"def":"Pertaining to or exciting emotion; affectional; emotional.","pos":""}],"AFFECTIVELY":[{"def":"In an affective manner; impressively; emotionally.","pos":""}],"AFFECTUOUS":[{"def":"Full of passion or emotion; earnest.","pos":""}],"AFFEER":[{"def":"To assess or reduce, as an arbitrary penalty or amercement, to a certain and reasonable sum.","pos":""},{"def":"One who affeers.","pos":""}],"AFFEERMENT":[{"def":"The act of affeering.","pos":""}],"AFFERENT":[{"def":"Bearing or conducting inwards to a part or organ; -- opposed to efferent; as, afferent vessels; afferent nerves, which convey sensations from the external organs to the brain.","pos":""}],"AFFIANCE":[{"def":"Plighted faith; marriage contract or promise.","pos":""},{"def":"Trust; reliance; faith; confidence.","pos":""}],"AFFIANCER":[{"def":"One who makes a contract of marriage between two persons.","pos":""}],"AFFIANT":[{"def":"One who makes an affidavit.","pos":""}],"AFFICHE":[{"def":"A written or printed notice to be posted, as on a wall; a poster; a placard.","pos":""}],"AFFIDAVIT":[{"def":"A sworn statement in writing; a declaration in writing, signed and made upon oath before an authorized magistrate.","pos":""}],"AFFILIABLE":[{"def":"Capable of being affiliated to or on, or connected with in origin.","pos":""}],"AFFILIATE":[{"def":"To adopt; to receive into a family as a son; hence, to bring or receive into close connection; to ally.","pos":""},{"def":"To fix the paternity of; -- said of an illegitimate child; as, to affiliate the child to (or on or upon) one man rather than another.","pos":""}],"AFFILIATION":[{"def":"The establishment or ascertaining of parentage; the assignment of a child, as a bastard, to its father; filiation.","pos":""}],"AFFINAL":[{"def":"Related by marriage; from the same source.","pos":""}],"AFFINED":[{"def":"Joined in affinity or by any tie.","pos":""}],"AFFINITATIVE":[{"def":"Of the nature of affinity.","pos":""}],"AFFINITIVE":[{"def":"Closely connected, as by affinity.","pos":""}],"AFFINITY":[{"def":"That attraction which takes place, at an insensible distance, between the heterogeneous particles of bodies, and unites them to form chemical compounds; chemism; chemical or elective affinity or attraction.","pos":""},{"def":"A relation between species or highe 6.","pos":""}],"AFFIRM":[{"def":"to assert or confirm, as a judgment, decree, or order, brought before an appelate court for review.","pos":""},{"def":"To declare, as a fact, solemnly, under judicial sanction.","pos":""}],"AFFIRMABLE":[{"def":"Capable of being affirmed, asserted, or declared; -- followed by of; as, an attribute affirmable of every just man.","pos":""}],"AFFIRMANCE":[{"def":"Confirmation; ratification; confirmation of a voidable act.","pos":""},{"def":"A strong declaration; affirmation.","pos":""}],"AFFIRMANT":[{"def":"One who affirms of taking an oath.","pos":""}],"AFFIRMATION":[{"def":"A solemn declaration made under the penalties of perjury, by persons who conscientiously decline taking an oath, which declaration is in law equivalent to an oath.","pos":""}],"AFFIRMATIVE":[{"def":"Expressing the agreement of the two terms of a proposition.","pos":""},{"def":"Positive; -- a term applied to quantities which are to be added, and opposed to negative, or such as are to be subtracted.","pos":""}],"AFFIRMATIVELY":[{"def":"In an affirmative manner; on the affirmative side of a question; in the affirmative; -- opposed to negatively.","pos":""}],"AFFIRMATORY":[{"def":"Giving affirmation; assertive; affirmative.","pos":""}],"AFFIRMER":[{"def":"One who affirms.","pos":""}],"AFFIX":[{"def":"To subjoin, annex, or add at the close or end; to append to; to fix to any part of; as, to affix a syllable to a word; to affix a seal to an instrument; to affix one's name to a writing.","pos":""},{"def":"To fix or fasten in any way; to attach physically.","pos":""}],"AFFIXTURE":[{"def":"The act of affixing, or the state of being affixed; attachment.","pos":""}],"AFFLATION":[{"def":"A blowing or breathing on; inspiration.","pos":""}],"AFFLATUS":[{"def":"A breath or blast of wind.","pos":""},{"def":"A divine impartation of knowledge; supernatural impulse; inspiration.","pos":""}],"AFFLICT":[{"def":"To strike or cast down; to overthrow.","pos":""},{"def":"To inflict some great injury or hurt upon, causing continued pain or mental distress; to trouble grievously; to torment.","pos":""}],"AFFLICTEDNESS":[{"def":"The state of being afflicted; affliction.","pos":""}],"AFFLICTER":[{"def":"One who afflicts.","pos":""}],"AFFLICTING":[{"def":"Grievously painful; distressing; afflictive; as, an afflicting event.","pos":""}],"AFFLICTION":[{"def":"The cause of continued pain of body or mind, as sickness, losses, etc.","pos":""},{"def":"The state of being afflicted; a state of pain, distress, or grief.","pos":""}],"AFFLICTIONLESS":[{"def":"Free from affliction.","pos":""}],"AFFLICTIVE":[{"def":"Giving pain; causing continued or repeated pain or grief; distressing.","pos":""}],"AFFLICTIVELY":[{"def":"In an afflictive manner.","pos":""}],"AFFLUENCE":[{"def":"A flowing to or towards; a concourse; an influx.","pos":""},{"def":"An abundant supply, as of thought, words, feelings, etc.","pos":""}],"AFFLUENT":[{"def":"Flowing to; flowing abundantly.","pos":""},{"def":"Abundant; copious; plenteous; hence, wealthy; abounding in goods or riches.","pos":""}],"AFFLUENTLY":[{"def":"Abundantly; copiously.","pos":""}],"AFFLUX":[{"def":"A flowing towards; that which flows to; as, an afflux of blood to the head.","pos":""}],"AFFLUXION":[{"def":"The act of flowing towards; afflux.","pos":""}],"AFFORCE":[{"def":"To reënforce; to strengthen.","pos":""}],"AFFORCEMENT":[{"def":"A fortress; a fortification for defense.","pos":""},{"def":"A reënforcement; a strengthening.","pos":""}],"AFFORCIAMENT":[{"def":"See Afforcement.","pos":""}],"AFFORD":[{"def":"To give forth; to supply, yield, or produce as the natural result, fruit, or issue; as, grapes afford wine; olives afford oil; the earth affords fruit; the sea affords an abundant supply of fish.","pos":""},{"def":"To give, grant, or confer, with a remoter reference to its being the natural result; to provide; to furnish; as, a good life affords consolation in old age.","pos":""}],"AFFORDABLE":[{"def":"That may be afforded.","pos":""}],"AFFORDMENT":[{"def":"Anything given as a help; bestowal.","pos":""}],"AFFOREST":[{"def":"To convert into a forest; as, to afforest a tract of country.","pos":""}],"AFFORESTATION":[{"def":"The act of converting into forest or woodland.","pos":""}],"AFFRANCHISE":[{"def":"To make free; to enfranchise.","pos":""}],"AFFRANCHISEMENT":[{"def":"The act of making free; enfranchisement.","pos":""}],"AFFRAP":[{"def":"To strike, or strike down.","pos":""}],"AFFRAY":[{"def":"To startle from quiet; to alarm.","pos":""},{"def":"To frighten; to scare; to frighten away.","pos":""}],"AFFRAYER":[{"def":"One engaged in an affray.","pos":""}],"AFFREIGHT":[{"def":"To hire, as a ship, for the transportation of goods or freight.","pos":""}],"AFFREIGHTER":[{"def":"One who hires or charters a ship to convey goods.","pos":""}],"AFFREIGHTMENT":[{"def":"The act of hiring, or the contract for the use of, a vessel, or some part of it, to convey cargo.","pos":""}],"AFFRET":[{"def":"A furious onset or attack.","pos":""}],"AFFRICATE":[{"def":"A combination of a stop, or explosive, with an immediately following fricative or spirant of corresponding organic position, as pf in german Pfeffer, pepper, z (= ts) in German Zeit, time.","pos":""}],"AFFRICTION":[{"def":"The act of rubbing against.","pos":""}],"AFFRIENDED":[{"def":"Made friends; reconciled.","pos":""}],"AFFRIGHT":[{"def":"To impress with sudden fear; to frighten; to alarm.","pos":""}],"AFFRIGHTER":[{"def":"One who frightens.","pos":""}],"AFFRIGHTFUL":[{"def":"Terrifying; frightful.","pos":""}],"AFFRIGHTMENT":[{"def":"Affright; the state of being frightened; sudden fear or alarm.","pos":""}],"AFFRONT":[{"def":"To front; to face in position; to meet or encounter face to face.","pos":""},{"def":"To face in defiance; to confront; as, to confront; as, to affront death; hence, to meet in hostile encounter.","pos":""}],"AFFRONTE":[{"def":"Face to face, or front to front; facing.","pos":""}],"AFFRONTEE":[{"def":"One who receives an affront.","pos":""}],"AFFRONTER":[{"def":"One who affronts, or insults to the face.","pos":""}],"AFFRONTINGLY":[{"def":"In an affronting manner.","pos":""}],"AFFRONTIVE":[{"def":"Tending to affront or offend; offensive; abusive.","pos":""}],"AFFRONTIVENESS":[{"def":"The quality that gives an affront or offense.","pos":""}],"AFFUSE":[{"def":"To pour out or upon.","pos":""}],"AFFUSION":[{"def":"The act of pouring upon, or sprinkling with a liquid, as water upon a child in baptism.","pos":""},{"def":"The act of pouring water or other fluid on the whole or a part of the body, as a remedy in disease.","pos":""}],"AFFY":[{"def":"To confide (one's self to, or in); to trust.","pos":""},{"def":"To betroth or espouse; to affiance.","pos":""}]}