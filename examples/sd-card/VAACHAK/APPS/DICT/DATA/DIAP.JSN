{"DIAPASE":[{"def":"Same as Diapason.","pos":""}],"DIAPASM":[{"def":"Powdered aromatic herbs, sometimes made into little balls and strung together.","pos":""}],"DIAPASON":[{"def":"The octave, or interval which includes all the tones of the diatonic scale.","pos":""}],"DIAPEDESIS":[{"def":"The passage of the corpuscular elements of the blood from the blood vessels into the surrounding tissues, without rupture of the walls of the blood vessels.","pos":""}],"DIAPENTE":[{"def":"The interval of the fifth.","pos":""},{"def":"A composition of five ingredients.","pos":""}],"DIAPER":[{"def":"Surface decoration of any sort which consists of the constant repetition of one or more simple figures or units of design evenly spaced.","pos":""}],"DIAPERING":[{"def":"Same as Diaper, n.","pos":""}],"DIAPHANE":[{"def":"A woven silk stuff with transparent and colored figures; diaper work.","pos":""}],"DIAPHANED":[{"def":"Transparent or translucent.","pos":""}],"DIAPHANEITY":[{"def":"The quality of being diaphanous; transparency; pellucidness.","pos":""}],"DIAPHANIC":[{"def":"Having power to transmit light; transparent; diaphanous.","pos":""}],"DIAPHANOMETER":[{"def":"An instrument for measuring the transparency of the air.","pos":""}],"DIAPHANOSCOPE":[{"def":"A dark box constructed for viewing transparent pictures, with or without a lens.","pos":""}],"DIAPHANOTYPE":[{"def":"A colored photograph produced by superimposing a translucent colored positive over a strong uncolored one.","pos":""}],"DIAPHANOUS":[{"def":"Allowing light to pass through, as porcelain; translucent or transparent; pellucid; clear.","pos":""}],"DIAPHANOUSLY":[{"def":"Di*aph\"a*nous*ly, adv.","pos":""}],"DIAPHEMETRIC":[{"def":"Relating to the measurement of the tactile sensibility of parts; as, diaphemetric compasses.","pos":""}],"DIAPHONICS":[{"def":"The doctrine of refracted sound; diacoustics.","pos":""}],"DIAPHORESIS":[{"def":"Perspiration, or an increase of perspiration.","pos":""},{"def":"Having the power to increase perspiration.","pos":""}],"DIAPHORETIC":[{"def":"A medicine or agent which promotes perspiration.","pos":""}],"DIAPHOTE":[{"def":"An instrument designed for transmitting pictures by telegraph.","pos":""}],"DIAPHRAGM":[{"def":"The muscular and tendinous partition separating the cavity of the chest from that of the abdomen; the midriff.","pos":""},{"def":"A calcareous plate which divides the cavity of certain shells into two parts.","pos":""}],"DIAPHRAGMATIC":[{"def":"Pertaining to a diaphragm; as, diaphragmatic respiration; the diaphragmatic arteries and nerves.","pos":""}],"DIAPHYSIS":[{"def":"An abnormal prolongation of the axis of inflorescence.","pos":""},{"def":"The shaft, or main part, of a bone, which is first ossified.","pos":""}],"DIAPNOIC":[{"def":"Slightly increasing an insensible perspiration; mildly diaphoretic.","pos":""},{"def":"A gentle diaphoretic.","pos":""}],"DIAPOPHYSICAL":[{"def":"Pertaining to a diapophysis.","pos":""}],"DIAPOPHYSIS":[{"def":"The dorsal transverse, or tubercular, process of a vertebra.","pos":""}]}