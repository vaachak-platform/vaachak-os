{"CONVECTION":[{"def":"A process of transfer or transmission, as of heat or electricity, by means of currents in liquids or gases, resulting from changes of temperature and other causes.","pos":""}],"CONVECTIVE":[{"def":"Caused or accomplished by convection; as, a convective discharge of electricity.","pos":""}],"CONVECTIVELY":[{"def":"In a convective manner.","pos":""}],"CONVELLENT":[{"def":"Tending to tear or pull up.","pos":""}],"CONVENABLE":[{"def":"Capable of being convened or assembled.","pos":""}],"CONVENANCE":[{"def":"That which is suitable, agreeable, or convenient.","pos":""}],"CONVENE":[{"def":"To come together; to meet; to unite.","pos":""},{"def":"To come together, as in one body or for a public purpose; to meet; to assemble.","pos":""}],"CONVENER":[{"def":"One who convenes or meets with others.","pos":""},{"def":"One who calls an assembly together or convenes a meeting; hence, the chairman of a committee or other organized body.","pos":""}],"CONVENIENT":[{"def":"Fit or adapted; suitable; proper; becoming; appropriate.","pos":""},{"def":"Affording accommodation or advantage; well adapted to use; handly; as, a convenient house; convenient implements or tools.","pos":""}],"CONVENIENTLY":[{"def":"In a convenient manner, form, or situation; without difficulty.","pos":""}],"CONVENT":[{"def":"A coming together; a meeting.","pos":""},{"def":"An association or community of recluses devoted to a religious life; a body of monks or nuns.","pos":""}],"CONVENTICAL":[{"def":"Of or from, or pertaining to, a convent.","pos":""}],"CONVENTICLE":[{"def":"A small assembly or gathering; esp.","pos":""},{"def":"An assembly for religious worship; esp.","pos":""}],"CONVENTICLER":[{"def":"One who supports or frequents conventicles.","pos":""}],"CONVENTICLING":[{"def":"Belonging or going to, or resembling, a conventicle.","pos":""}],"CONVENTION":[{"def":"An extraordinary assembly of the parkiament or estates of the realm, held without the king's writ, -- as the assembly which restored Charles II.","pos":""}],"CONVENTIONAL":[{"def":"Formed by agreement or compact; stipulated.","pos":""},{"def":"Growing out of, or depending on, custom or tacit agreement; sanctioned by general concurrence or usage; formal.","pos":""}],"CONVENTIONALISM":[{"def":"The principles or practice of conventionalizing.","pos":""}],"CONVENTIONALIST":[{"def":"One who adheres to a convention or treaty.","pos":""},{"def":"One who is governed by conventionalism.","pos":""}],"CONVENTIONALITY":[{"def":"The state of being conventional; adherence to social formalities or usages; that which is established by conventional use; one of the customary usages of social life.","pos":""}],"CONVENTIONALIZATION":[{"def":"Con*ven`tion*al*i*za\"tion, n.","pos":""}],"CONVENTIONALIZE":[{"def":"To make conventional; to bring under the influence of, or cause to conform to, conventional rules; to establish by usage.","pos":""}],"CONVENTIONALLY":[{"def":"In a conventional manner.","pos":""}],"CONVENTIONARY":[{"def":"Acting under contract; settled by express agreement; as, conventionary tenants.","pos":""}],"CONVENTIONER":[{"def":"One who belongs to a convention or assembly.","pos":""}],"CONVENTIONIST":[{"def":"One who enters into a convention, covenant, or contract.","pos":""}],"CONVENTUAL":[{"def":"Of or pertaining to a convent; monastic.","pos":""}],"CONVERGE":[{"def":"To tend to one point; to incline and approach nearer together; as, lines converge.","pos":""}],"CONVERGENT":[{"def":"tending to one point of focus; tending to approach each other; converging.","pos":""}],"CONVERGING":[{"def":"Tending to one point; approaching each other; convergent; as, converging lines.","pos":""}],"CONVERSABLE":[{"def":"Qualified for conversation; disposed to converse; sociable; free in discourse.","pos":""}],"CONVERSABLENESS":[{"def":"The quality of being conversable; disposition to converse; sociability.","pos":""}],"CONVERSABLY":[{"def":"In a conversable manner.","pos":""}],"CONVERSANCE":[{"def":"The state or quality of being conversant; habit of familiarity; familiar acquaintance; intimacy.","pos":""}],"CONVERSANT":[{"def":"Having frequent or customary intercourse; familiary associated; intimately acquainted.","pos":""},{"def":"Familiar or acquainted by use or study; well-informed; versed; -- generally used with with, sometimes with in.","pos":""}],"CONVERSANTLY":[{"def":"In a familiar manner.","pos":""}],"CONVERSATION":[{"def":"General course of conduct; behavior.","pos":""},{"def":"Familiar intercourse; intimate fellowship or association; close acquaintance.","pos":""}],"CONVERSATIONAL":[{"def":"Pertaining to conversation; in the manner of one conversing; as, a conversational style.","pos":""}],"CONVERSATIONALIST":[{"def":"A conversationist.","pos":""}],"CONVERSATIONED":[{"def":"Acquainted with manners and deportment; behaved.","pos":""}],"CONVERSATIONISM":[{"def":"A word or phrase used in conversation; a colloqualism.","pos":""}],"CONVERSATIONIST":[{"def":"One who converses much, or who excels in conversation.","pos":""}],"CONVERSATIVE":[{"def":"Relating to intercourse with men; social; -- opposed to contemplative.","pos":""}],"CONVERSAZIONE":[{"def":"A meeting or assembly for conversation, particularly on literary or scientific subjects.","pos":""}],"CONVERSE":[{"def":"To keep company; to hold intimate intercourse; to commune; -- followed by with.","pos":""},{"def":"To engage, in familiar colloqui; to interchange thoughts and opinions in a free, informal manner; to chat; -- followed by with before a person; by on, about, concerning, etc.","pos":""}],"CONVERSELY":[{"def":"In a converse manner; with change of order or relation; reciprocally.","pos":""}],"CONVERSER":[{"def":"One who engages in conversation.","pos":""}],"CONVERSIBLE":[{"def":"Capable of being converted or reversed.","pos":""}],"CONVERSION":[{"def":"An appropriation of, and dealing with the property of another as if it were one's own, without right; as, the conversion of a horse.","pos":""},{"def":"The act of interchanging the terms of a proposition, as by putting the subject in the place of the predicate, or the contrary.","pos":""}],"CONVERSIVE":[{"def":"Capable of being converted or changed.","pos":""},{"def":"Ready to converse; social.","pos":""}],"CONVERT":[{"def":"To change (one proposition) into another, so that what was the subject of the first becomes the predicate of the second.","pos":""}],"CONVERTEND":[{"def":"Any proposition which is subject to the process of conversion; -- so called in its relation to itself as converted, after which process it is termed the conversae.","pos":""}],"CONVERTER":[{"def":"A retort, used in the Bessemer process, in which molten cast iron is decarburized and converted into steel by a blast of air forced through the liquid metal.","pos":""}],"CONVERTIBILITY":[{"def":"The condition or quality of being convertible; capability of being exchanged; convertibleness.","pos":""}],"CONVERTIBLE":[{"def":"Capable of being converted; susceptible of change; transmutable; transformable.","pos":""},{"def":"Capable of being exchanged or interchanged; reciprocal; interchangeable.","pos":""}],"CONVERTIBLENESS":[{"def":"The state of being convertible; convertibility.","pos":""}],"CONVERTIBLY":[{"def":"In a convertible manner.","pos":""}],"CONVEX":[{"def":"Rising or swelling into a spherical or rounded form; regularly protuberant or bulging; -- said of a spherical surface or curved line when viewed from without, in opposition to concave.","pos":""}],"CONVEXED":[{"def":"Made convex; protuberant in a spherical form.","pos":""}],"CONVEXEDLY":[{"def":"In a convex form; convexly.","pos":""}],"CONVEXITY":[{"def":"The state of being convex; the exterior surface of a convex body; roundness.","pos":""}],"CONVEXLY":[{"def":"In a convex form; as, a body convexly shaped.","pos":""}],"CONVEXNESS":[{"def":"The state of being convex; convexity.","pos":""}],"CONVEXO-CONCAVE":[{"def":"Convex on one side, and concave on the other.","pos":""}],"CONVEXO-CONVEX":[{"def":"Convex on botConvex, a.","pos":""}],"CONVEXO-PLANE":[{"def":"Convex on one side, and flat on the other; plano-convex.","pos":""}],"CONVEY":[{"def":"To carry from one place to another; to bear or transport.","pos":""},{"def":"To cause to pass from one place or person to another; to serve as a medium in carrying (anything) from one place or person to another; to transmit; as, air conveys sound; words convey ideas.","pos":""}],"CONVEYABLE":[{"def":"Capable of being conveyed or transferred.","pos":""}],"CONVEYANCE":[{"def":"The act by which the title to property, esp.","pos":""}],"CONVEYANCER":[{"def":"One whose business is to draw up conveyances of property, as deeds, mortgages, leases, etc.","pos":""}],"CONVEYANCING":[{"def":"The business of a conveyancer; the act or business of drawing deeds, leases, or other writings, for transferring the title to property from one person to another.","pos":""}],"CONVEYER":[{"def":"One who, or that which, conveys or carries, transmits or transfers.","pos":""},{"def":"One given to artifices or secret practices; a juggler; a cheat; a thief.","pos":""}],"CONVEYOR":[{"def":"A contrivance for carrying objects from place to place; esp.","pos":""}]}