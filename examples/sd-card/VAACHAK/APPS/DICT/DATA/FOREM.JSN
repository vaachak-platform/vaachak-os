{"FOREMAN":[{"def":"The first or chief man; as: (a) The chief man of a jury, who acts as their speaker.","pos":""}],"FOREMAST":[{"def":"The mast nearest the bow.","pos":""}],"FOREMEANT":[{"def":"Intended beforehand; premeditated.","pos":""}],"FOREMENTIONED":[{"def":"Mentioned before; already cited; aforementioned.","pos":""}],"FOREMILK":[{"def":"The milk secreted just before, or directly after, the birth of a child or of the young of an animal; colostrum.","pos":""}],"FOREMOST":[{"def":"First in time or place; most advanced; chief in rank or dignity; as, the foremost troops of an army.","pos":""}],"FOREMOSTLY":[{"def":"In the foremost place or order; among the foremost.","pos":""}],"FOREMOTHER":[{"def":"A female ancestor.","pos":""}]}