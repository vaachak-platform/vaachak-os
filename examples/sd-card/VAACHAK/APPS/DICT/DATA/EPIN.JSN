{"EPINASTIC":[{"def":"A term applied to that phase of vegetable growth in which an organ grows more rapidly on its upper than on its under surface.","pos":""}],"EPINEURAL":[{"def":"Arising from the neurapophysis of a vertebra.","pos":""}],"EPINEURIUM":[{"def":"The connective tissue framework and sheath of a nerve which bind together the nerve bundles, each of which has its own special sheath, or perineurium.","pos":""}],"EPINGLETTE":[{"def":"An iron needle for piercing the cartridge of a cannon before priming.","pos":""}],"EPINICIAL":[{"def":"Relating to victory.","pos":""}],"EPINICION":[{"def":"A song of triumph.","pos":""}]}