{"FIR":[{"def":"A genus (Abies) of coniferous trees, often of large size and elegant shape, some of them valued for their timber and others for their resin.","pos":""}],"FIRE":[{"def":"The evolution of light and heat in the combustion of bodies; combustion; state of ignition.","pos":""},{"def":"Fuel in a state of combustion, as on a hearth, or in 3.","pos":""}],"FIRE BEETLE":[{"def":"A very brilliantly luminous beetle (Pyrophorus noctilucus), one of the elaters, found in Central and South America; -- called also cucujo.","pos":""}],"FIRE-FANGED":[{"def":"Injured as by fire; burned; -- said of manure which has lost its goodness and acquired an ashy hue in consequence of heat generated by decomposition.","pos":""}],"FIRE-NEW":[{"def":"Fresh from the forge; bright; quite new; brand-new.","pos":""}],"FIRE-SET":[{"def":"A set of fire irons, including, commonly, tongs, shovel, and poker.","pos":""}],"FIREARM":[{"def":"A gun, pistol, or any weapon from a shot is discharged by the force of an explosive substance, as gunpowder.","pos":""}],"FIREBACK":[{"def":"One of several species of pheasants of the genus Euplocamus, having the lower back a bright, fiery red.","pos":""}],"FIREBIRD":[{"def":"The Baltimore oriole.","pos":""}],"FIREBOARD":[{"def":"A chimney board or screen to close a fireplace when not in use.","pos":""}],"FIREBOTE":[{"def":"An allowance of fuel.","pos":""}],"FIREBRAND":[{"def":"A piece of burning wood.","pos":""},{"def":"One who inflames factions, or causes contention and mischief; an incendiary.","pos":""}],"FIRECREST":[{"def":"A small European kinglet (Regulus ignicapillus), having a bright red crest; -- called also fire-crested wren.","pos":""}],"FIREDOG":[{"def":"A support for wood in a fireplace; an andiron.","pos":""}],"FIREDRAKE":[{"def":"A fiery meteor; an ignis fatuus; a rocket.","pos":""}],"FIREFISH":[{"def":"A singular marine fish of the genus Pterois, family Scorpænidæ, of several species, inhabiting the Indo-Pacific region.","pos":""}],"FIREFLAIRE":[{"def":"A European sting ray of the genus Trygon (T.","pos":""}],"FIREFLAME":[{"def":"The European band fish (Cepola rubescens).","pos":""}],"FIREFLY":[{"def":"Any luminous winged insect, esp.","pos":""}],"FIRELESS":[{"def":"Destitute of fire.","pos":""}],"FIRELOCK":[{"def":"An old form of gunlock, as the flintlock, which ignites the priming by a spark; perhaps originally, a matchlock.","pos":""}],"FIREMAN":[{"def":"A man whose business is to extinguish fires in towns; a member of a fire company.","pos":""},{"def":"A man who tends the fires, as of a steam engine; a stocker.","pos":""}],"FIREPLACE":[{"def":"The part a chimney appropriated to the fire; a hearth; -- usually an open recess in a wall, in which a fire may be built.","pos":""}],"FIREPROOF":[{"def":"Proof against fire; incombustible.","pos":""}],"FIREPROOFING":[{"def":"The act or process of rendering anything incombustible; also, the materials used in the process.","pos":""}],"FIRER":[{"def":"One who fires or sets fire to anything; an incendiary.","pos":""}],"FIREROOM":[{"def":"Same as Stokehold, below.","pos":""}],"FIRESIDE":[{"def":"A place near the fire or hearth; home; domestic life or retirement.","pos":""}],"FIRESTONE":[{"def":"Iron pyrites, formerly used for striking fire; also, a flint.","pos":""},{"def":"A stone which will bear the heat of a furnace without injury; -- especially applied to the sandstone at the top of the upper greensand in the south of England, used for lining kilns and furnaces.","pos":""}],"FIRETAIL":[{"def":"The European redstart; -- called also fireflirt.","pos":""}],"FIREWARDEN":[{"def":"An officer who has authority to direct in the extinguishing of fires, or to order what precautions shall be taken against fires; -- called also fireward.","pos":""}],"FIREWORK":[{"def":"A pyrotechnic exhibition.","pos":""}],"FIREWORM":[{"def":"The larva of a small tortricid moth which eats the leaves of the cranberry, so that the vines look as if burned; -- called also cranberry worm.","pos":""}],"FIRING":[{"def":"The act of disharging firearms.","pos":""},{"def":"The mode of introducing fuel into the furnace and working it.","pos":""}],"FIRING PIN":[{"def":"In the breech mechanism of a firearm, the pin which strikes the head of the cartridge and explodes it.","pos":""}],"FIRK":[{"def":"To beat; to strike; to chastise.","pos":""}],"FIRKIN":[{"def":"A varying measure of capacity, usually being the fourth part of a barrel; specifically, a measure equal to nine imperial gallons.","pos":""},{"def":"A small wooden vessel or cask of indeterminate size, -- used for butter, lard, etc.","pos":""}],"FIRLOT":[{"def":"A dry measure formerly used in Scotland; the fourth part of a boll of grain or meal.","pos":""}],"FIRM":[{"def":"Fixed; hence, closely compressed; compact; substantial; hard; solid; -- applied to the matter of bodies; as, firm flesh; firm muscles, firm wood.","pos":""},{"def":"Not easily excited or disturbed; unchanging in purpose; fixed; steady; constant; stable; unshaken; not easily changed in feelings or will; strong; as, a firm believer; a firm friend; a firm adherent.","pos":""}],"FIRMAMENT":[{"def":"The orb of the fixed stars; the most rmote of the celestial spheres.","pos":""}],"FIRMAMENTAL":[{"def":"Pertaining to the firmament; celestial; being of the upper regions.","pos":""}],"FIRMAN":[{"def":"In Turkey and some other Oriental countries, a decree or mandate issued by the sovereign; a royal order or grant; -- generally given for special objects, as to a traveler to insure him protection and assistance.","pos":""}],"FIRMER-CHISEL":[{"def":"A chisel, thin in proportion to its width.","pos":""}],"FIRMITUDE":[{"def":"Strength; stability.","pos":""}],"FIRMITY":[{"def":"Strength; firmness; stability.","pos":""}],"FIRMLESS":[{"def":"Detached from substance.","pos":""},{"def":"Infirm; unstable.","pos":""}],"FIRMLY":[{"def":"In a firm manner.","pos":""}],"FIRMNESS":[{"def":"The state or quality of being firm.","pos":""}],"FIRMS":[{"def":"The principal rafters of a roof, especially a pair of rafters taken together.","pos":""}],"FIRRY":[{"def":"Made of fir; abounding in firs.","pos":""}],"FIRST":[{"def":"Preceding all others of a series or kind; the ordinal of one; earliest; as, the first day of a month; the first year of a reign.","pos":""},{"def":"Foremost; in front of, or in advance of, all others.","pos":""}],"FIRST-CLASS":[{"def":"Of the best class; of the highest rank; in the first division; of the best quality; first-rate; as, a first-class telescope.","pos":""}],"FIRST-HAND":[{"def":"Obtained directly from the first or original source; hence, without the intervention of an agent.","pos":""}],"FIRST-RATE":[{"def":"Of the highest excellence; preëminent in quality, size, or estimation.","pos":""}],"FIRSTBORN":[{"def":"First brought forth; first in the order of nativity; eldest; hence, most excellent; most distinguished or exalted.","pos":""}],"FIRSTLING":[{"def":"The first produce or offspring; -- said of animals, especially domestic animals; as, the firstlings of his flock.","pos":""},{"def":"The thing first thought or done.","pos":""}],"FIRSTLY":[{"def":"In the first place; before anything else; -- sometimes improperly used for first.","pos":""}],"FIRTH":[{"def":"An arm of the sea; a frith.","pos":""}]}