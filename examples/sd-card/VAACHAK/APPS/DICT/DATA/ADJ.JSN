{"ADJACENT":[{"def":"Lying near, close, or contiguous; neighboring; bordering on; as, a field adjacent to the highway.","pos":""}],"ADJACENTLY":[{"def":"So as to be adjacent.","pos":""}],"ADJECT":[{"def":"To add or annex; to join.","pos":""}],"ADJECTION":[{"def":"The act or mode of adding; also, the thing added.","pos":""}],"ADJECTIONAL":[{"def":"Pertaining to adjection; that is, or may be, annexed.","pos":""}],"ADJECTITIOUS":[{"def":"Added; additional.","pos":""}],"ADJECTIVAL":[{"def":"Of or relating to the relating to the adjective; of the nature of an adjective; adjective.","pos":""}],"ADJECTIVALLY":[{"def":"As, or in the manner of, an adjective; adjectively.","pos":""}],"ADJECTIVE":[{"def":"Added to a substantive as an attribute; of the nature of an adjunct; as, an word sentence.","pos":""},{"def":"Not standing by itself; dependent.","pos":""}],"ADJECTIVELY":[{"def":"In the manner of an adjective; as, a word used adjectively.","pos":""}],"ADJOIN":[{"def":"To join or unite to; to lie contiguous to; to be in contact with; to attach; to append.","pos":""}],"ADJOINING":[{"def":"Joining to; contiguous; adjacent; as, an adjoining room.","pos":""}],"ADJOINT":[{"def":"An adjunct; a helper.","pos":""}],"ADJOURN":[{"def":"To put off or defer to another day, or indefinitely; to postpone; to close or suspend for the day; -- commonly said of the meeting, or the action, of convened body; as, to adjourn the meeting; to adjourn a debate.","pos":""}],"ADJOURNAL":[{"def":"Adjournment; postponement.","pos":""}],"ADJOURNMENT":[{"def":"The act of adjourning; the putting off till another day or time specified, or without day.","pos":""},{"def":"The time or interval during which a public body adjourns its sittings or postpones business.","pos":""}],"ADJUDGE":[{"def":"To award judicially in the case of a controverted question; as, the prize was adjudged to the victor.","pos":""},{"def":"To determine in the exercise of judicial power; to decide or award judicially; to adjudicate; as, the case was adjudged in the November term.","pos":""}],"ADJUDGER":[{"def":"One who adjudges.","pos":""}],"ADJUDGMENT":[{"def":"The act of adjudging; judicial decision; adjudication.","pos":""}],"ADJUDICATE":[{"def":"To adjudge; to try and determine, as a court; to settle by judicial decree.","pos":""}],"ADJUDICATION":[{"def":"The decision upon the question whether the debtor is a bankrupt.","pos":""},{"def":"A process by which land is attached security or in satisfaction of a debt.","pos":""}],"ADJUDICATOR":[{"def":"One who adjudicates.","pos":""}],"ADJUMENT":[{"def":"Help; support; also, a helper.","pos":""}],"ADJUNCT":[{"def":"Conjoined; attending; consequent.","pos":""}],"ADJUNCTION":[{"def":"The act of joining; the thing joined or added.","pos":""}],"ADJUNCTIVE":[{"def":"Joining; having the quality of joining; forming an adjunct.","pos":""}],"ADJUNCTIVELY":[{"def":"In an adjunctive manner.","pos":""}],"ADJUNCTLY":[{"def":"By way of addition or adjunct; in connection with.","pos":""}],"ADJURATION":[{"def":"The act of adjuring; a solemn charging on oath, or under the penalty of a curse; an earnest appeal.","pos":""},{"def":"The form of oath or appeal.","pos":""}],"ADJURATORY":[{"def":"Containing an adjuration.","pos":""}],"ADJURE":[{"def":"To charge, bind, or command, solemnly, as if under oath, or under the penalty of a curse; to appeal to in the most solemn or impressive manner; to entreat earnestly.","pos":""}],"ADJURER":[{"def":"One who adjures.","pos":""}],"ADJUST":[{"def":"To make exact; to fit; to make correspondent or conformable; to bring into proper relations; as, to adjust a garment to the body, or things to a standard.","pos":""},{"def":"To put in order; to regulate, or reduce to system.","pos":""}],"ADJUSTABLE":[{"def":"Capable of being adjusted.","pos":""}],"ADJUSTER":[{"def":"One who, or that which, adjusts.","pos":""},{"def":"A small plane or surface, usually capable of adjustment but not of manipulation, for preserving lateral balance in an aëroplane or flying machine.","pos":""}],"ADJUSTIVE":[{"def":"Tending to adjust.","pos":""}],"ADJUSTMENT":[{"def":"Settlement of claims; an equitable arrangement of conflicting claims, as in set-off, contribution, exoneration, subrogation, and marshaling.","pos":""}],"ADJUTAGE":[{"def":"Same as Ajutage.","pos":""}],"ADJUTANCY":[{"def":"The office of an adjutant.","pos":""},{"def":"Skillful arrangement in aid; assistance.","pos":""}],"ADJUTANT":[{"def":"A regimental staff officer, who assists the colonel, or commanding officer of a garrison or regiment, in the details of regimental and garrison duty.","pos":""},{"def":"A species of very large stork (Ciconia argala), a native of India; -- called also the gigantic crane, and by the native name argala.","pos":""}],"ADJUTATOR":[{"def":"A corruption of Agitator.","pos":""}],"ADJUTOR":[{"def":"A helper or assistant.","pos":""}],"ADJUTORY":[{"def":"Serving to help or assist; helping.","pos":""}],"ADJUTRIX":[{"def":"A female helper or assistant.","pos":""}],"ADJUVANT":[{"def":"Helping; helpful; assisting.","pos":""}]}