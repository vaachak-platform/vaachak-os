{"FOOD":[{"def":"What is fed upon; that which goes to support life by being received within, and assimilated by, the organism of an animal or a plant; nutriment; aliment; especially, what is eaten by animals for nourishment.","pos":""},{"def":"Anything that instructs the intellect, excites the feelings, or molds habits of character; that which nourishes.","pos":""}],"FOODFUL":[{"def":"Full of food; supplying food; fruitful; fertile.","pos":""}],"FOODLESS":[{"def":"Without food; barren.","pos":""}],"FOODY":[{"def":"Eatable; fruitful.","pos":""}],"FOOL":[{"def":"A compound of gooseberries scalded and crushed, with cream; -- commonly called gooseberry fool.","pos":""}],"FOOL-BORN":[{"def":"Begotten by a fool.","pos":""}],"FOOL-HAPPY":[{"def":"Lucky, without judgment or contrivance.","pos":""}],"FOOL-HASTY":[{"def":"Foolishly hasty.","pos":""}],"FOOL-LARGE":[{"def":"Foolishly liberal.","pos":""}],"FOOL-LARGESSE":[{"def":"Foolish expenditure; waste.","pos":""}],"FOOLERY":[{"def":"The practice of folly; the behavior of a fool; absurdity.","pos":""},{"def":"An act of folly or weakness; a foolish practice; something absurd or nonsensical.","pos":""}],"FOOLHARDIHOOD":[{"def":"The state of being foolhardy; foolhardiness.","pos":""}],"FOOLHARDILY":[{"def":"In a foolhardy manner.","pos":""}],"FOOLHARDINESS":[{"def":"Courage without sense or judgment; foolish rashness; recklessness.","pos":""}],"FOOLHARDY":[{"def":"Daring without judgment; foolishly adventurous and bold.","pos":""}],"FOOLIFY":[{"def":"To make a fool of; to befool.","pos":""}],"FOOLISH":[{"def":"Marked with, or exhibiting, folly; void of understanding; weak in intellect; without judgment or discretion; silly; unwise.","pos":""},{"def":"Such as a fool would do; proceeding from weakness of mind or silliness; exhibiting a want of judgment or discretion; as, a foolish act.","pos":""}],"FOOLISHLY":[{"def":"In a foolish manner.","pos":""}],"FOOLISHNESS":[{"def":"The quality of being foolish.","pos":""},{"def":"A foolish practice; an absurdity.","pos":""}],"FOOLSCAP":[{"def":"A writing paper made in sheets, ordinarily 16 x 13 inches, and folded so as to make a page 13 x 8 inches.","pos":""}],"FOOT":[{"def":"The terminal part of the leg of man or an animal; esp.","pos":""},{"def":"The muscular locomotive organ of a mollusk.","pos":""}],"FOOT CANDLE":[{"def":"The amount of illumination produced by a standard candle at a distance of one foot.","pos":""}],"FOOT GUARDS":[{"def":"Infantry soldiers belonging to select regiments called the Guards.","pos":""}],"FOOT POUND":[{"def":"A unit of energy, or work, being equal to the work done in raising one pound avoirdupois against the force of gravity the height of one foot.","pos":""}],"FOOT POUNDAL":[{"def":"A unit of energy or work, equal to the work done in moving a body through one foot against the force of one poundal.","pos":""}],"FOOT TON":[{"def":"A unit of energy or work, being equal to the work done in raising one ton against the force of gravity through the height of one foot.","pos":""}],"FOOT VALVE":[{"def":"A suction valve or check valve at the lower end of a pipe; esp.","pos":""}],"FOOT-SORE":[{"def":"Having sore or tender feet, as by reason of much walking; as, foot-sore cattle.","pos":""}],"FOOTBALL":[{"def":"An inflated ball to be kicked in sport, usually made in India rubber, or a bladder incased in Leather.","pos":""}],"FOOTBAND":[{"def":"A band of foot soldiers.","pos":""}],"FOOTBATH":[{"def":"A bath for the feet; also, a vessel used in bathing the feet.","pos":""}],"FOOTBOARD":[{"def":"A board or narrow platfrom upon which one may stand or brace his feet; as: (a) The platform for the engineer and fireman of a locomotive.","pos":""},{"def":"A board forming the foot of a bedstead.","pos":""}],"FOOTBOY":[{"def":"A page; an attendant in livery; a lackey.","pos":""}],"FOOTBREADTH":[{"def":"The breadth of a foot; -- used as a measure.","pos":""}],"FOOTBRIDGE":[{"def":"A narrow bridge for foot passengers only.","pos":""}],"FOOTCLOTH":[{"def":"Formerly, a housing or caparison for a horse.","pos":""}],"FOOTED":[{"def":"Having a foot or feet; shaped in the foot.","pos":""},{"def":"Having a foothold; established.","pos":""}],"FOOTFALL":[{"def":"A setting down of the foot; a footstep; the sound of a footstep.","pos":""}],"FOOTFIGHT":[{"def":"A conflict by persons on foot; -- distinguished from a fight on horseback.","pos":""}],"FOOTGLOVE":[{"def":"A kind of stocking.","pos":""}],"FOOTHALT":[{"def":"A disease affecting the feet of sheep.","pos":""}],"FOOTHOLD":[{"def":"A holding with the feet; firm L'Estrange.","pos":""}],"FOOTHOT":[{"def":"Hastily; immediately; instantly; on the spot; hotfloot.","pos":""}],"FOOTING":[{"def":"The thickened or sloping portion of a wall, or of an embankment at its foot.","pos":""}],"FOOTLICKER":[{"def":"A sycophant; a fawner; a toady.","pos":""}],"FOOTLIGHT":[{"def":"One of a row of lights in the front of the stage in a theater, etc.","pos":""}],"FOOTMAN":[{"def":"A moth of the family Lithosidæ; -- so called from its livery- like colors.","pos":""}],"FOOTMANSHIP":[{"def":"Art or skill of a footman.","pos":""}],"FOOTMARK":[{"def":"A footprint; a track or vestige.","pos":""}],"FOOTNOTE":[{"def":"A note of reference or comment at the foot of a page.","pos":""}],"FOOTPACE":[{"def":"A walking pace or step.","pos":""},{"def":"A dais, or elevated platform; the highest step of the altar; a landing in a staircase.","pos":""}],"FOOTPAD":[{"def":"A highwayman or robber on foot.","pos":""}],"FOOTPATH":[{"def":"A narrow path or way for pedestrains only; a footway.","pos":""}],"FOOTPLATE":[{"def":"See Footboard (a).","pos":""}],"FOOTPRINT":[{"def":"The impression of the foot; a trace or footmark; as, \"Footprints of the Creator.","pos":""}],"FOOTS":[{"def":"The settlings of oil, molasses, etc.","pos":""}],"FOOTSTALK":[{"def":"The stalk of a leaf or of flower; a petiole, pedicel, or reduncle.","pos":""},{"def":"The lower part of a millstone spindle.","pos":""}],"FOOTSTALL":[{"def":"The plinth or base of a pillar.","pos":""}],"FOOTSTEP":[{"def":"The mark or impression of the foot; a track; hence, visible sign of a course pursued; token; mark; as, the footsteps of divine wisdom.","pos":""},{"def":"An inclined plane under a hand printing press.","pos":""}],"FOOTSTONE":[{"def":"The stone at the foot of a grave; -- opposed to headstone.","pos":""}],"FOOTSTOOL":[{"def":"A low stool to support the feet of one when sitting.","pos":""}],"FOOTWAY":[{"def":"A passage for pedestrians only.","pos":""}],"FOOTWORN":[{"def":"Worn by, or weared in, the feet; as, a footworn path; a footworn traveler.","pos":""}],"FOOTY":[{"def":"Having foots, or settlings; as, footy oil, molasses, etc.","pos":""}],"FOOZLE":[{"def":"To bungle; to manage awkwardly; to treat or play unskillfully; as, to foozle a stroke in golf.","pos":""}]}