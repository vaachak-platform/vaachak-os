{"ROUE":[{"def":"One devoted to a life of sensual pleasure; a debauchee; a rake.","pos":""}],"ROUET":[{"def":"A small wheel formerly fixed to the pan of firelocks for discharging them.","pos":""}],"ROUGE":[{"def":"A red amorphous powder consisting of ferric oxide.","pos":""}],"ROUGE DRAGON":[{"def":"One of the four pursuivants of the English college of arms.","pos":""}],"ROUGECROIX":[{"def":"One of the four pursuivants of the English college of arms.","pos":""}],"ROUGH":[{"def":"Having inequalities, small ridges, or points, on the surface; not smooth or plain; as, a rough board; a rough stone; rough cloth.","pos":""}],"ROUGH-FOOTED":[{"def":"Feather-footed; as, a rough-footed dove.","pos":""}],"ROUGH-GRAINED":[{"def":"Having a rough grain or fiber; hence, figuratively, having coarse traits of character; not polished; brisque.","pos":""}],"ROUGH-LEGGED":[{"def":"Having the legs covered with feathers; -- said of a bird.","pos":""}],"ROUGHCAST":[{"def":"To form in its first rudiments, without revision, correction, or polish.","pos":""},{"def":"To mold without nicety or elegance; to form with asperities and inequalities.","pos":""}],"ROUGHCASTER":[{"def":"One who roughcasts.","pos":""}],"ROUGHDRAW":[{"def":"To draw or delineate rapidly and by way of a first sketch.","pos":""}],"ROUGHDRY":[{"def":"in laundry work, to dry without smoothing or ironing.","pos":""}],"ROUGHEN":[{"def":"To grow or become rough.","pos":""}],"ROUGHHEW":[{"def":"To hew coarsely, without smoothing; as, to roughhew timber.","pos":""},{"def":"To give the first form or shape to; to form rudely; to shape appromaxitely and rudely; to roughcast.","pos":""}],"ROUGHHEWER":[{"def":"One who roughhews.","pos":""}],"ROUGHHEWN":[{"def":"Hewn coarsely without smoothing; unfinished; not polished.","pos":""},{"def":"Of coarse manners; rude; uncultivated; rough-grained.","pos":""}],"ROUGHING-IN":[{"def":"The first coat of plaster laid on brick; also, the process of applying it.","pos":""}],"ROUGHLEG":[{"def":"Any one of several species of large hawks of the genus Archibuteo, having the legs feathered to the toes.","pos":""}],"ROUGHLY":[{"def":"In a rough manner; unevenly; harshly; rudely; severely; austerely.","pos":""}],"ROUGHNESS":[{"def":"The quality or state of being rough.","pos":""}],"ROUGHRIDER":[{"def":"One who breaks horses; especially (Mil.","pos":""}],"ROUGHSCUFF":[{"def":"A rough, coarse fellow; collectively, the lowest class of the people; the rabble; the riffraff.","pos":""}],"ROUGHSETTER":[{"def":"A mason who builds rough stonework.","pos":""}],"ROUGHSHOD":[{"def":"Shod with shoes armed with points or calks; as, a roughshod horse.","pos":""}],"ROUGHSTRINGS":[{"def":"Pieces of undressed timber put under the steps of a wooden stair for their support.","pos":""}],"ROUGHTAIL":[{"def":"Any species of small ground snakes of the family Uropeltidæ; -- so called from their rough tails.","pos":""}],"ROUGHWORK":[{"def":"To work over coarsely, without regard to nicety, smoothness, or finish.","pos":""}],"ROUGHWROUGHT":[{"def":"Wrought in a rough, unfinished way; worked over coarsely.","pos":""}],"ROUK":[{"def":"See 5th Ruck, and Roke.","pos":""}],"ROULADE":[{"def":"A smoothly running passage of short notes (as semiquavers, or sixteenths) uniformly grouped, sung upon one long syllable, as in Handel's oratorios.","pos":""}],"ROULEAU":[{"def":"A little roll; a roll of coins put up in paper, or something resembling such a roll.","pos":""}],"ROULETTE":[{"def":"the curve traced by any point in the plane of a given curve when the latter rolls, without sliding, over another fixed curve.","pos":""}],"ROULY-POULY":[{"def":"See Rolly-pooly.","pos":""}],"ROUMANIAN":[{"def":"Of or pertaining to Roumania.","pos":""}],"ROUNCE":[{"def":"The handle by which the bed of a hand press, holding the form of type, etc.","pos":""}],"ROUNCEVAL":[{"def":"Large; strong; -- from the gigantic bones shown at Roncesvalles, and alleged to be those of old heroes.","pos":""}],"ROUNCY":[{"def":"A common hackney horse; a nag.","pos":""}],"ROUND":[{"def":"The Bishop of Glasgow rounding in his ear, \"Ye are not a wise man,\" .","pos":""}],"ROUND-ARM":[{"def":"Applied to the method delivering the ball in bowling, by swinging the arm horizontally.","pos":""}],"ROUND-BACKED":[{"def":"Having a round back or shoulders; round-shouldered.","pos":""}],"ROUND-SHOULDERED":[{"def":"Having the shoulders stooping or projecting; round-backed.","pos":""}],"ROUND-UP":[{"def":"The act of collecting or gathering together scattered cattle by riding around them and driving them in.","pos":""}],"ROUNDABOUT":[{"def":"Circuitous; going round; indirect; as, roundabout speech.","pos":""},{"def":"Encircling; enveloping; comprehensive.","pos":""}],"ROUNDABOUTNESS":[{"def":"The quality of being roundabout; circuitousness.","pos":""}],"ROUNDED":[{"def":"Modified by contraction of the lip opening; labialized; labial.","pos":""}],"ROUNDEL":[{"def":"Anything having a round form; a round figure; a circle.","pos":""}],"ROUNDELAY":[{"def":"See Rondeau, and Rondel.","pos":""}],"ROUNDER":[{"def":"An English game somewhat resembling baseball; also, another English game resembling the game of fives, but played with a football.","pos":""}],"ROUNDHEAD":[{"def":"A nickname for a Puritan.","pos":""}],"ROUNDHEADED":[{"def":"Having a round head or top.","pos":""}],"ROUNDHOUSE":[{"def":"A constable's prison; a lockup, watch-house, or station house.","pos":""},{"def":"A house for locomotive engines, built circularly around a turntable.","pos":""}],"ROUNDING":[{"def":"Round or nearly round; becoming round; roundish.","pos":""}],"ROUNDISH":[{"def":"Somewhat round; as, a roundish seed; a roundish figure.","pos":""}],"ROUNDLET":[{"def":"A little circle.","pos":""}],"ROUNDLY":[{"def":"In a round form or manner.","pos":""},{"def":"Openly; boldly; peremptorily; plumply.","pos":""}],"ROUNDNESS":[{"def":"The quality or state of being round in shape; as, the roundness of the globe, of the orb of the sun, of a ball, of a bowl, a column, etc.","pos":""},{"def":"Fullness; smoothness of flow; as, the roundness of a period; the roundness of a note; roundness of tone.","pos":""}],"ROUNDRIDGE":[{"def":"To form into round ridges by plowing.","pos":""}],"ROUNDSMAN":[{"def":"A patrolman; also, a policeman who acts as an inspector over the rounds of the patrolmen.","pos":""}],"ROUNDTOP":[{"def":"A top; a platform at a masthead; -- so called because formerly round in shape.","pos":""}],"ROUNDURE":[{"def":"Roundness; a round or circle.","pos":""}],"ROUNDWORM":[{"def":"A nematoid worm.","pos":""}],"ROUP":[{"def":"To cry or shout; hence, to sell by auction.","pos":""}],"ROUSANT":[{"def":"Rising; -- applied to a bird in the attitude of rising; also, sometmes, to a bird in profile with wings addorsed.","pos":""}],"ROUSE":[{"def":"To pull or haul strongly and all together, as upon a rope, without the assistance of mechanical appliances.","pos":""}],"ROUSER":[{"def":"A stirrer in a copper for boiling wort.","pos":""}],"ROUSING":[{"def":"Having power to awaken or excite; exciting.","pos":""},{"def":"Very great; violent; astounding; as, a rousing fire; a rousing lie.","pos":""}],"ROUSINGLY":[{"def":"In a rousing manner.","pos":""}],"ROUSSETTE":[{"def":"A fruit bat, especially the large species (Pieropus vulgaris) inhabiting the islands of the Indian ocean.","pos":""},{"def":"Any small shark of the genus Scyllium; -- called also dogfish.","pos":""}],"ROUST":[{"def":"To rouse; to disturb; as, to roust one out.","pos":""}],"ROUSTABOUT":[{"def":"A laborer, especially a deck hand, on a river steamboat, who moves the cargo, loads and unloads wood, and the like; in an opprobrious sense, a shiftless vagrant who lives by chance jobs.","pos":""}],"ROUT":[{"def":"To roar; to bellow; to snort; to snore loudly.","pos":""}],"ROUT CAKE":[{"def":"A kind of rich sweet cake made for routs, or evening parties.","pos":""}],"ROUTE":[{"def":"The course or way which is traveled or passed, or is to be passed; a passing; a course; a road or path; a march.","pos":""}],"ROUTINARY":[{"def":"Involving, or pertaining to, routine; ordinary; customary.","pos":""}],"ROUTINE":[{"def":"A round of business, amusement, or pleasure, daily or frequently pursued; especially, a course of business or offical duties regularly or frequently returning.","pos":""},{"def":"Any regular course of action or procedure rigidly adhered to by the mere force of habit.","pos":""}],"ROUTINISM":[{"def":"the practice of doing things with undiscriminating, mechanical regularity.","pos":""}],"ROUTINIST":[{"def":"One who habituated to a routine.","pos":""}],"ROUTISH":[{"def":"Uproarious; riotous.","pos":""}],"ROUTOUSLY":[{"def":"With that violation of law called a rout.","pos":""}],"ROUX":[{"def":"A thickening, made of flour, for soups and gravies.","pos":""}]}