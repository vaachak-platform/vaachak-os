{"VIBICES":[{"def":"More or less extensive patches of subcutaneous extravasation of blood.","pos":""}],"VIBRACULUM":[{"def":"One of the movable, slender, spinelike organs or parts with which certain bryozoans are furnished.","pos":""}],"VIBRANCY":[{"def":"The state of being vibrant; resonance.","pos":""}],"VIBRANT":[{"def":"Vibrating; tremulous; resonant; as, vibrant drums.","pos":""}],"VIBRATE":[{"def":"To brandish; to move to and fro; to swing; as, to vibrate a sword or a staff.","pos":""},{"def":"To mark or measure by moving to and fro; as, a pendulum vibrating seconds.","pos":""}],"VIBRATILE":[{"def":"Adapted to, or used in, vibratory motion; having the power of vibrating; vibratory; as, the vibratile organs of insects.","pos":""}],"VIBRATILITY":[{"def":"The quality or state of being vibratile; disposition to vibration or oscillation.","pos":""}],"VIBRATION":[{"def":"A limited reciprocating motion of a particle of an elastic body or medium in alternately opposite directions from its position of equilibrium, when that equilibrium has been disturbed, as when a stretched cord or other body produces musical notes, or particles of air transmit sounds to the ear.","pos":""}],"VIBRATIUNCLE":[{"def":"A small vibration.","pos":""}],"VIBRATOR":[{"def":"A trembler, as of an electric bell.","pos":""},{"def":"A vibrating reed for transmitting or receiving pulsating currents in a harmonic telegraph system.","pos":""}],"VIBRATORY":[{"def":"Consisting in, or causing, vibration, or oscillation; vibrating; as, a vibratory motion; a vibratory power.","pos":""}],"VIBRIO":[{"def":"A genus of motile bacteria characterized by short, slightly sinuous filaments and an undulatory motion; also, an individual of this genus.","pos":""}],"VIBRISSA":[{"def":"One of the specialized or tactile hairs which grow about the nostrils, or on other parts of the face, in many animals, as the so- called whiskers of the cat, and the hairs of the nostrils of man.","pos":""},{"def":"The bristlelike feathers near the mouth of many birds.","pos":""}],"VIBROGRAPH":[{"def":"An instrument to observe and record vibrations.","pos":""}],"VIBROSCOPE":[{"def":"An instrument for observing or tracing vibrations.","pos":""},{"def":"An instrument resembling the phenakistoscope.","pos":""}],"VIBURNUM":[{"def":"A genus of shrubs having opposite, petiolate leaves and cymose flowers, several species of which are cultivated as ornamental, as the laurestine and the guelder-rose.","pos":""}]}