{"POY":[{"def":"A support; -- used in composition; as, teapoy.","pos":""},{"def":"A ropedancer's balancing pole.","pos":""}],"POYNADO":[{"def":"See Poind, Poinder.","pos":""}],"POYNTEL":[{"def":"Paving or flooring made of small squares or lozenges set diagonally.","pos":""}],"POYOU":[{"def":"A South American armadillo (Dasypus sexcinctus).","pos":""}]}