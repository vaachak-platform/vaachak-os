{"MAJESTIC":[{"def":"Possessing or exhibiting majesty; of august dignity, stateliness, or imposing grandeur; lofty; noble; grand.","pos":""}],"MAJESTICAL":[{"def":"An older architecture, greater, cunninger, more majestical.","pos":""}],"MAJESTICNESS":[{"def":"The quality or state of being majestic.","pos":""}],"MAJESTY":[{"def":"The dignity and authority of sovereign power; quality or state which inspires awe or reverence; grandeur; exalted dignity, whether proceeding from rank, character, or bearing; imposing loftiness; stateliness; -- usually applied to the rank and dignity of sovereigns.","pos":""}],"MAJOLICA":[{"def":"A kind of pottery, with opaque glazing and showy, which reached its greatest perfection in Italy in the 16th century.","pos":""}],"MAJOR":[{"def":"Greater by a semitone, either in interval or in difference of pitch from another tone.","pos":""}],"MAJOR GENERAL":[{"def":"Ma\"jor gen\"er*al Defn: .","pos":""}],"MAJOR-DOMO":[{"def":"A man who has authority to act, within certain limits, as master of the house; a steward; also, a chief minister or officer.","pos":""}],"MAJORAT":[{"def":"Property, landed or funded, so attached to a title of honor as to descend with it.","pos":""}],"MAJORATE":[{"def":"The office or rank of a major.","pos":""}],"MAJORATION":[{"def":"Increase; enlargement.","pos":""}],"MAJORCAN":[{"def":"Of or pertaining to Majorca.","pos":""},{"def":"A native or inhabitant of Majorca.","pos":""}],"MAJORITY":[{"def":"Ancestors; ancestry.","pos":""}],"MAJORSHIP":[{"def":"The office of major.","pos":""}],"MAJUSCULAE":[{"def":"Capital letters, as found in manuscripts of the sixth century and earlier.","pos":""}],"MAJUSCULE":[{"def":"A capital letter; especially, one used in ancient manuscripts.","pos":""}]}