{"HONE":[{"def":"To pine; to lament; to long.","pos":""}],"HONEST":[{"def":"Decent; honorable; suitable; becoming.","pos":""},{"def":"Characterized by integrity or fairness and straightas, an honest judge or merchant; an honest statement; an honest bargain; an honest business; an honest book; an honest confession.","pos":""}],"HONESTATION":[{"def":"The act of honesting; grace; adornment.","pos":""}],"HONESTETEE":[{"def":"Honesty; honorableness.","pos":""}],"HONESTLY":[{"def":"Honorably; becomingly; decently.","pos":""},{"def":"In an honest manner; as, a contract honestly made; to live honestly; to speak honestly.","pos":""}],"HONESTY":[{"def":"Satin flower; the name of two cruciferous herbs having large flat pods, the round shining partitions of which are more beautiful than the blossom; -- called also lunary and moonwort.","pos":""}],"HONEWORT":[{"def":"An umbelliferous plant of the genus Sison (S.","pos":""}],"HONEY":[{"def":"A sweet viscid fluid, esp.","pos":""},{"def":"That which is sweet or pleasant, like honey.","pos":""}],"HONEY-BAG":[{"def":"The receptacle for honey in a honeybee.","pos":""}],"HONEY-MOUTHED":[{"def":"Soft to sweet in speech; persuasive.","pos":""}],"HONEY-TONGUED":[{"def":"Sweet speaking; persuasive; seductive.","pos":""}],"HONEYBEE":[{"def":"Any bee of the genus Apis, which lives in communities and collects honey, esp.","pos":""}],"HONEYBIRD":[{"def":"The honey guide.","pos":""}],"HONEYCOMB":[{"def":"A mass of hexagonal waxen cells, formed by bees, and used by them to hold their honey and their eggs.","pos":""},{"def":"Any substance, as a easting of iron, a piece of worm-eaten wood, or of triple, etc.","pos":""}],"HONEYCOMBED":[{"def":"Formed or perforated like a honeycomb.","pos":""}],"HONEYDEW":[{"def":"A sweet, saccharine substance, found on the leaves of trees and other plants in small drops, like dew.","pos":""},{"def":"A kind of tobacco moistened with molasses.","pos":""}],"HONEYED":[{"def":"Covered with honey.","pos":""},{"def":"Sweet, as, honeyed words.","pos":""}],"HONEYLESS":[{"def":"Destitute of honey.","pos":""}],"HONEYMOON":[{"def":"The first month after marriage.","pos":""}],"HONEYSUCKER":[{"def":"See Honey eater, under Honey.","pos":""}],"HONEYSUCKLE":[{"def":"One of several species of flowering plants, much admired for their beauty, and some for their fragrance.","pos":""}],"HONEYSUCKLED":[{"def":"Covered with honeysuckles.","pos":""}],"HONEYWARE":[{"def":"See Badderlocks.","pos":""}],"HONEYWORT":[{"def":"A European plant of the genus Cerinthe, whose flowers are very attractive to bees.","pos":""}],"HONG":[{"def":"A mercantile establishment or factory for foreign trade in China, as formerly at Canton; a succession of offices connected by a common passage and used for business or storage.","pos":""}],"HONITON LACE":[{"def":"Hon\"i*ton lace` Defn: .","pos":""}],"HONK":[{"def":"The cry of a wild goose.","pos":""}],"HONOR":[{"def":"A seigniory or lordship held of the king, on which other lordships and manors depended.","pos":""},{"def":"Academic or university prizes or distinctions; as, honors in classics.","pos":""}],"HONORABLE":[{"def":"Worthy of honor; fit to be esteemed or regarded; estimable; illustrious.","pos":""},{"def":"High-minded; actuated by principles of honor, or a scrupulous regard to probity, rectitude, or reputation.","pos":""}],"HONORABLENESS":[{"def":"The state of being honorable; eminence; distinction.","pos":""},{"def":"Conformity to the principles of honor, probity, or moral rectitude; fairness; uprightness; reputableness.","pos":""}],"HONORABLY":[{"def":"An honorary payment, usually in recognition of services for which it is not usual or not lawful to assign a fixed business price.","pos":""}],"HONORARY":[{"def":"Done as a sign or evidence of honor; as, honorary services.","pos":""},{"def":"Conferring honor, or intended merely to confer honor without emolument; as, an honorary degree.","pos":""}],"HONORIFIC":[{"def":"Conferring honor; tending to honor.","pos":""}],"HONORLESS":[{"def":"Destitute of honor; not honored.","pos":""}],"HONVED":[{"def":"The Hungarian army in the revolutionary war of 1848-49.","pos":""}],"HONVEDSEG":[{"def":"See Army organization, above.","pos":""}]}