{"ASCARIASIS":[{"def":"A disease, usually accompanied by colicky pains and diarrhea, caused by the presence of ascarids in the gastrointestinal canal.","pos":""}],"ASCARID":[{"def":"A parasitic nematoid worm, espec.","pos":""}],"ASCEND":[{"def":"To move upward; to mount; to go up; to rise; -- opposed to Ant: descend.","pos":""},{"def":"To rise, in a figurative sense; to proceed from an inferior to a superior degree, from mean to noble objects, from particulars to generals, from modern to ancient times, from one note to another more acute, etc.","pos":""}],"ASCENDABLE":[{"def":"Capable of being ascended.","pos":""},{"def":"Same as Ascendency.","pos":""}],"ASCENDANT":[{"def":"The horoscope, or that degree of the ecliptic which rises above the horizon at the moment of one's birth; supposed to have a commanding influence on a person's life and fortune.","pos":""}],"ASCENDENCY":[{"def":"Governing or controlling influence; domination; power.","pos":""}],"ASCENDIBLE":[{"def":"Capable of being ascended; climbable.","pos":""}],"ASCENDING":[{"def":"Rising; moving upward; as, an ascending kite.","pos":""}],"ASCENSION":[{"def":"The act of ascending; a rising; ascent.","pos":""},{"def":"Specifically: The visible ascent of our Savior on the fortieth day after his resurrection.","pos":""}],"ASCENSIONAL":[{"def":"Relating to ascension; connected with ascent; ascensive; tending upward; as, the ascensional power of a balloon.","pos":""}],"ASCENSIVE":[{"def":"Augmentative; intensive.","pos":""}],"ASCENT":[{"def":"The act of rising; motion upward; rise; a mounting upward; as, he made a tedious ascent; the ascent of vapors from the earth.","pos":""},{"def":"The way or means by which one ascends.","pos":""}],"ASCERTAIN":[{"def":"To render (a person) certain; to cause to feel certain; to make confident; to assure; to apprise.","pos":""},{"def":"To make (a thing) certain to the mind; to free from obscurity, doubt, or change; to make sure of; to fix; to determine.","pos":""}],"ASCERTAINABLE":[{"def":"That may be ascertained.","pos":""}],"ASCERTAINER":[{"def":"One who ascertains.","pos":""}],"ASCERTAINMENT":[{"def":"The act of ascertaining; a reducing to certainty; a finding out by investigation; discovery.","pos":""},{"def":"See Acescency, Acescent.","pos":""}],"ASCETIC":[{"def":"Extremely rigid in self-denial and devotions; austere; severe.","pos":""}],"ASCETICISM":[{"def":"The condition, practice, or mode of life, of ascetics.","pos":""}],"ASCHAM":[{"def":"A sort of cupboard, or case, to contain bows and other implements of archery.","pos":""}],"ASCIAN":[{"def":"One of the Ascii.","pos":""}],"ASCIDIAN":[{"def":"One of the Ascidioidea, or in a more general sense, one of the Tunicata.","pos":""}],"ASCIDIARIUM":[{"def":"The structure which unites together the ascidiozooids in a compound ascidian.","pos":""}],"ASCIDIFORM":[{"def":"Shaped like an ascidian.","pos":""}],"ASCIDIOIDEA":[{"def":"A group of Tunicata, often shaped like a two-necked bottle.","pos":""}],"ASCIDIOZOOID":[{"def":"One of the individual members of a compound ascidian.","pos":""}],"ASCIDIUM":[{"def":"A pitcher-shaped, or flask-shaped, organ or appendage of a plant, as the leaves of the pitcher plant, or the little bladderlike traps of the bladderwort (Utricularia).","pos":""},{"def":"A genus of simple ascidians, which formerly included most of the known species.","pos":""}],"ASCIGEROUS":[{"def":"Persons who, at certain times of the year, have no shadow at noon; -- applied to the inhabitants of the torrid zone, who have, twice a year, a vertical sun.","pos":""}],"ASCITES":[{"def":"A collection of serous fluid in the cavity of the abdomen; dropsy of the peritoneum.","pos":""},{"def":"Of, pertaining to, or affected by, ascites; dropsical.","pos":""}],"ASCITITIOUS":[{"def":"Supplemental; not inherent or original; adscititious; additional; assumed.","pos":""}],"ASCLEPIAD":[{"def":"A choriambic verse, first used by the Greek poet Asclepias, consisting of four feet, viz.","pos":""}],"ASCLEPIADACEOUS":[{"def":"Of, pertaining to, or resembling, plants of the Milkweed family.","pos":""}],"ASCLEPIAS":[{"def":"A genus of plants including the milkweed, swallowwort, and some other species having medicinal properties.","pos":""}],"ASCOCARP":[{"def":"In ascomycetous fungi, the spherical, discoid, or cup-shaped body within which the asci are collected, and which constitutes the mature fructification.","pos":""}],"ASCOCOCCUS":[{"def":"A form of micrococcus, found in putrid meat infusions, occurring in peculiar masses, each of which is inclosed in a hyaline capsule and contains a large number of spherical micrococci.","pos":""}],"ASCOMYCETES":[{"def":"A large class of higher fungi distinguished by septate hyphæ, and by having their spores formed in asci, or spore sacs.","pos":""}],"ASCOSPORE":[{"def":"One of the spores contained in the asci of lichens and fungi.","pos":""}],"ASCRIBABLE":[{"def":"Capable of being ascribed; attributable.","pos":""}],"ASCRIBE":[{"def":"To attribute, impute, or refer, as to a cause; as, his death was ascribed to a poison; to ascribe an effect to the right cause; to ascribe such a book to such an author.","pos":""},{"def":"To attribute, as a quality, or an appurtenance; to consider or allege to belong.","pos":""}],"ASCRIPTION":[{"def":"The act of ascribing, imputing, or affirming to belong; also, that which is ascribed.","pos":""}],"ASCRIPTITIOUS":[{"def":"Added; additional.","pos":""}],"ASCUS":[{"def":"A small membranous bladder or tube in which are inclosed the seedlike reproductive particles or sporules of lichens and certain fungi.","pos":""}]}