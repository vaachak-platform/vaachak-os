{"EBB":[{"def":"The European bunting.","pos":""}],"EBB TIDE":[{"def":"The reflux of tide water; the retiring tide; -- opposed to flood tide.","pos":""}],"EBIONITE":[{"def":"One of a sect of heretics, in the first centuries of the church, whose doctrine was a mixture of Judaism and Christianity.","pos":""}],"EBIONITISM":[{"def":"The system or doctrine of the Ebionites.","pos":""}],"EBLANIN":[{"def":"See Pyroxanthin.","pos":""}],"EBLIS":[{"def":"The prince of the evil spirits; Satan.","pos":""}],"EBON":[{"def":"Consisting of ebony.","pos":""},{"def":"Like ebony, especially in color; black; dark.","pos":""}],"EBONIST":[{"def":"One who works in ebony.","pos":""}],"EBONITE":[{"def":"A hard, black variety of vulcanite.","pos":""}],"EBONIZE":[{"def":"To make black, or stain black, in imitation of ebony; as, to ebonize wood.","pos":""}],"EBONY":[{"def":"A hard, heavy, and durable wood, which admits of a fine polish or gloss.","pos":""}],"EBRACTEOLATE":[{"def":"Without bracteoles, or little bracts; -- said of a pedicel or flower stalk.","pos":""}],"EBRIETY":[{"def":"Drunkenness; intoxication by spirituous liquors; inebriety.","pos":""}],"EBRILLADE":[{"def":"A bridle check; a jerk of one rein, given to a horse when he refuses to turn.","pos":""}],"EBRIOSITY":[{"def":"Addiction to drink; habitual drunkenness.","pos":""}],"EBRIOUS":[{"def":"Inclined to drink to excess; intoxicated; tipsy.","pos":""}],"EBULLIATE":[{"def":"To boil or bubble up.","pos":""},{"def":"A boiling up or over; effervescence.","pos":""}],"EBULLIENT":[{"def":"Boiling up or over; hence, manifesting exhilaration or excitement, as of feeling; effervescing.","pos":""}],"EBULLIOSCOPE":[{"def":"An instrument for observing the boiling point of liquids, especially for determining the alcoholic strength of a mixture by the temperature at which it boils.","pos":""}],"EBULLITION":[{"def":"A boiling or bubbling up of a liquid; the motion produced in a liquid by its rapid conversion into vapor.","pos":""},{"def":"Effervescence occasioned by fermentation or by any other process which causes the liberation of a gas or an aëriform fluid, as in the mixture of an acid with a carbonated alkali.","pos":""}],"EBURIN":[{"def":"A composition of dust of ivory or of bone with a cement; -- used for imitations of valuable stones and in making moldings, seals, etc.","pos":""}],"EBURNATION":[{"def":"A condition of bone cartilage occurring in certain diseases of these tissues, in which they acquire an unnatural density, and come to resemble ivory.","pos":""}],"EBURNEAN":[{"def":"Made of or relating to ivory.","pos":""}],"EBURNIFICATION":[{"def":"The conversion of certain substances into others which have the appearance or characteristics of ivory.","pos":""}],"EBURNINE":[{"def":"Of or pertaining to ivory.","pos":""}]}