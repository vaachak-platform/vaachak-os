{"FLAP":[{"def":"Anything broad and limber that hangs loose, or that is attached by one side or end and is easily moved; as, the flap of a garment.","pos":""},{"def":"A disease in the lips of horses.","pos":""}],"FLAP-EARED":[{"def":"Having broad, loose, dependent ears.","pos":""}],"FLAP-MOUTHED":[{"def":"Having broad, hangling lips.","pos":""}],"FLAPDRAGON":[{"def":"A game in which the players catch raisins out burning brandy, and swallow them blazing.","pos":""},{"def":"The thing thus caught abd eaten.","pos":""}],"FLAPJACK":[{"def":"A fklat cake turned on the griddle while cooking; a griddlecake or pacake.","pos":""},{"def":"A fried dough cake containing fruit; a turnover.","pos":""}],"FLAPPER":[{"def":"One who, or that which, flaps.","pos":""}]}