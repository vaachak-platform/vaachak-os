{"MYTACISM":[{"def":"Too frequent use of the letter m, or of the sound represented by it.","pos":""}],"MYTH":[{"def":"A story of great but unknown age which originally embodied a belief regarding some fact or phenomenon of experience, and in which often the forces of nature and of the soul are personified; an ancient legend of a god, a hero, the origin of a race, etc.","pos":""},{"def":"A person or thing existing only in imagination, or whose actual existence is not verifiable.","pos":""}],"MYTHE":[{"def":"Of or relating to myths; described in a myth; of the nature of a myth; fabulous; imaginary; fanciful.","pos":""}],"MYTHOGRAPHER":[{"def":"A composer of fables.","pos":""}],"MYTHOLOGIAN":[{"def":"Of or pertaining to mythology or to myths; mythical; fabulous.","pos":""}],"MYTHOLOGIST":[{"def":"One versed in, or who writes on, mythology or myths.","pos":""}],"MYTHOLOGIZE":[{"def":"To relate, classify, and explain, or attempt to explain, myths; to write upon myths.","pos":""},{"def":"To construct and propagate myths.","pos":""}],"MYTHOLOGIZER":[{"def":"One who, or that which, mythologizes.","pos":""}],"MYTHOLOGUE":[{"def":"A fabulous narrative; a myth.","pos":""}],"MYTHOLOGY":[{"def":"The science which treats of myths; a treatise on myths.","pos":""},{"def":"A body of myths; esp.","pos":""}],"MYTHOPLASM":[{"def":"A narration of mere fable.","pos":""}],"MYTHOPOEIC":[{"def":"Making or producing myths; giving rise to mythical narratives.","pos":""}],"MYTHOPOETIC":[{"def":"Making or producing myths or mythical tales.","pos":""}],"MYTILOID":[{"def":"Like, or pertaining to, the genus Mytilus, or family Mytilidæ.","pos":""}],"MYTILOTOXINE":[{"def":"A poisonous base (leucomaine) found in the common mussel.","pos":""}],"MYTILUS":[{"def":"A genus of marine bivalve shells, including the common mussel.","pos":""}]}