{"AFLAME":[{"def":"Inflames; glowing with light or passion; ablaze.","pos":""}],"AFLAT":[{"def":"Level with the ground; flat.","pos":""}],"AFLAUNT":[{"def":"In a flaunting state or position.","pos":""}],"AFLICKER":[{"def":"In a flickering state.","pos":""}],"AFLOAT":[{"def":"Borne on the water; floating; on board ship.","pos":""},{"def":"Moving; passing from place to place; in general circulation; as, a rumor is afloat.","pos":""}],"AFLOW":[{"def":"Their founts aflow with tears.","pos":""}],"AFLUSH":[{"def":"In a flushed or blushing state.","pos":""}],"AFLUTTER":[{"def":"In a flutter; agitated.","pos":""}]}