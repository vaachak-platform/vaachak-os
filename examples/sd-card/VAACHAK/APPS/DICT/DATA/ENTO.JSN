{"ENTO-":[{"def":"A combining form signifying within; as, entoblast.","pos":""}],"ENTOBLAST":[{"def":"The inner germ layer; endoderm.","pos":""}],"ENTOBRONCHIUM":[{"def":"One of the main bronchi in the lungs of birds.","pos":""},{"def":"One of the bones of the tarsus.","pos":""}],"ENTODERM":[{"def":"See Endoderm, and Illust.","pos":""},{"def":"Relating to the entoderm.","pos":""}],"ENTOGASTRIC":[{"def":"Pertaining to the interior of the stomach; -- applied to a mode of budding from the interior of the gastric cavity, in certain hydroids.","pos":""}],"ENTOGLOSSAL":[{"def":"Within the tongue; -- applied to the glossohyal bone.","pos":""}],"ENTOIL":[{"def":"To take with toils or bring into toils; to insnare.","pos":""}],"ENTOMB":[{"def":"To deposit in a tomb, as a dead body; to bury; to inter; to inhume.","pos":""}],"ENTOMBMENT":[{"def":"The act of entombing or burying, or state of being entombed; burial.","pos":""}],"ENTOMERE":[{"def":"The more granular cells, which finally become internal, in many segmenting ova, as those of mammals.","pos":""},{"def":"Relating to insects; entomological.","pos":""}],"ENTOMOID":[{"def":"Resembling an insect.","pos":""},{"def":"An object resembling an insect.","pos":""}],"ENTOMOLITE":[{"def":"A fossil insect.","pos":""},{"def":"Of or relating to entomology.","pos":""}],"ENTOMOLOGIST":[{"def":"One versed in entomology.","pos":""}],"ENTOMOLOGIZE":[{"def":"To collect specimens in the study of entomology.","pos":""}],"ENTOMOLOGY":[{"def":"That part of zoölogy which treats of insects.","pos":""},{"def":"A treatise on the science of entomology.","pos":""}],"ENTOMOPHAGA":[{"def":"One of a group of hymenopterous insects whose larvæ feed parasitically upon living insects.","pos":""},{"def":"A group of marsupials which are partly insectivorous, as the opossum.","pos":""}],"ENTOMOPHAGAN":[{"def":"Relating to the Entomophaga.","pos":""},{"def":"One of the Entomophaga.","pos":""}],"ENTOMOPHAGOUS":[{"def":"Feeding on insects; insectivorous.","pos":""}],"ENTOMOPHILOUS":[{"def":"Fertilized by the agency of insects; -- said of plants in which the pollen is carried to the stigma by insects.","pos":""}],"ENTOMOSTRACA":[{"def":"One of the subclasses of Crustacea, including a large number of species, many of them minute.","pos":""}],"ENTOMOSTRACAN":[{"def":"Relating to the Entomostraca.","pos":""},{"def":"One of the Entomostraca.","pos":""}],"ENTOMOSTRACOUS":[{"def":"Belonging to the Entomostracans.","pos":""}],"ENTOMOTOMIST":[{"def":"One who practices entomotomy.","pos":""}],"ENTOMOTOMY":[{"def":"The science of the dissection of insects.","pos":""}],"ENTONIC":[{"def":"Having great tension, or exaggerated action.","pos":""}],"ENTOPERIPHERAL":[{"def":"Being, or having its origin, within the external surface of the body; -- especially applied to feelings, such as hunger, produced by internal disturbances.","pos":""}],"ENTOPHYTE":[{"def":"A vegetable parasite subsisting in the interior of the body.","pos":""}],"ENTOPHYTIC":[{"def":"Of or pertaining to entophytes; as, an entophytic disease.","pos":""}],"ENTOPLASTIC":[{"def":"Pertaining to, or composed of, entoplasm; as, the entoplastic products of some Protozoa, or the entoplastic modification of the cell protoplasm, by which a nucleus is produced.","pos":""}],"ENTOPLASTRON":[{"def":"The median plate of the plastron of turtles; -- called also entosternum.","pos":""}],"ENTOPROCTA":[{"def":"A group of Bryozoa in which the anus is within the circle of tentacles.","pos":""}],"ENTOPTIC":[{"def":"Relating to objects situated within the eye; esp.","pos":""}],"ENTORGANISM":[{"def":"An internal parasitic organism.","pos":""}],"ENTORTILATION":[{"def":"A turning into a circle; round figures.","pos":""}],"ENTOSTERNUM":[{"def":"See Entoplastron.","pos":""}],"ENTOSTHOBLAST":[{"def":"The granule within the nucleolus or entoblast of a nucleated cell.","pos":""}],"ENTOTIC":[{"def":"Pertaining to the interior of the ear.","pos":""}],"ENTOURAGE":[{"def":"Surroundings; specif.","pos":""}],"ENTOZOA":[{"def":"Pertaining to, or consisting of, the Entozoa.","pos":""},{"def":"One versed in the science of the Entozoa.","pos":""}]}