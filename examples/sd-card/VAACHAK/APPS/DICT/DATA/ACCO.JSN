{"ACCOAST":[{"def":"To lie or sail along the coast or side of; to accost.","pos":""}],"ACCOIL":[{"def":"To coil together.","pos":""}],"ACCOLADE":[{"def":"A brace used to join two or more staves.","pos":""}],"ACCOMBINATION":[{"def":"A combining together.","pos":""}],"ACCOMMODABLE":[{"def":"That may be accommodated, fitted, or made to agree.","pos":""}],"ACCOMMODABLENESS":[{"def":"The quality or condition of being accommodable.","pos":""}],"ACCOMMODATE":[{"def":"To render fit, suitable, or correspondent; to adapt; to conform; as, to accommodate ourselves to circumstances.","pos":""},{"def":"To bring into agreement or harmony; to reconcile; to compose; to adjust; to settle; as, to accommodate differences, a dispute, etc.","pos":""}],"ACCOMMODATELY":[{"def":"Suitably; fitly.","pos":""}],"ACCOMMODATENESS":[{"def":"Ac*com\"mo*date*ness, n.","pos":""}],"ACCOMMODATING":[{"def":"Affording, or disposed to afford, accommodation; obliging; as an accommodating man, spirit, arrangement.","pos":""}],"ACCOMMODATION":[{"def":"The act of fitting or adapting, or the state of being fitted or adapted; adaptation; adjustment; -- followed by to.","pos":""},{"def":"Willingness to accommodate; obligingness.","pos":""}],"ACCOMMODATOR":[{"def":"He who, or that which, accommodates.","pos":""}],"ACCOMPANIER":[{"def":"He who, or that which, accompanies.","pos":""}],"ACCOMPANIMENT":[{"def":"That which accompanies; something that attends as a circumstance, or which is added to give greater completeness to the principal thing, or by way of ornament, or for the sake of symmetry.","pos":""},{"def":"A part performed by instruments, accompanying another part or parts performed by voices; the subordinate part, or parts, accompanying the voice or a principal instrument; also, the harmony of a figured bass.","pos":""}],"ACCOMPANIST":[{"def":"The performer in music who takes the accompanying part.","pos":""}],"ACCOMPANY":[{"def":"To go with or attend as a companion or associate; to keep company with; to go along with; -- followed by with or by; as, he accompanied his speech with a bow.","pos":""},{"def":"To cohabit with.","pos":""}],"ACCOMPLETIVE":[{"def":"Tending to accomplish.","pos":""}],"ACCOMPLICE":[{"def":"An associate in the commission of a crime; a participator in an offense, whether a principal or an accessory.","pos":""}],"ACCOMPLICESHIP":[{"def":"The state of being an accomplice.","pos":""}],"ACCOMPLICITY":[{"def":"The act or state of being an accomplice.","pos":""}],"ACCOMPLISH":[{"def":"To complete, as time or distance.","pos":""},{"def":"To bring to an issue of full success; to effect; to perform; to execute fully; to fulfill; as, to accomplish a design, an object, a promise.","pos":""}],"ACCOMPLISHABLE":[{"def":"Capable of being accomplished; practicable.","pos":""}],"ACCOMPLISHED":[{"def":"Completed; effected; established; as, an accomplished fact.","pos":""},{"def":"Complete in acquirements as the result usually of training; -- commonly in a good sense; as, an accomplished scholar, an accomplished villain.","pos":""}],"ACCOMPLISHER":[{"def":"One who accomplishes.","pos":""}],"ACCOMPLISHMENT":[{"def":"The act of accomplishing; entire performance; completion; fulfillment; as, the accomplishment of an enterprise, of a prophecy, etc.","pos":""},{"def":"That which completes, perfects, or equips thoroughly; acquirement; attainment; that which constitutes excellence of mind, or elegance of manners, acquired by education or training.","pos":""}],"ACCOMPT":[{"def":"Ac*compt\" (#; formerly #), n.","pos":""}],"ACCOMPTABLE":[{"def":"See Accountable.","pos":""}],"ACCORD":[{"def":"An agreement between parties in controversy, by which satisfaction for an injury is stipulated, and which, when executed, bars a suit.","pos":""}],"ACCORDABLE":[{"def":"Reconcilable; in accordance.","pos":""}],"ACCORDANCE":[{"def":"Agreement; harmony; conformity.","pos":""}],"ACCORDANT":[{"def":"Agreeing; consonant; harmonious; corresponding; conformable; -- followed by with or to.","pos":""}],"ACCORDANTLY":[{"def":"In accordance or agreement; agreeably; conformably; -- followed by with or to.","pos":""}],"ACCORDER":[{"def":"One who accords, assents, or concedes.","pos":""}],"ACCORDING":[{"def":"Agreeing; in agreement or harmony; harmonious.","pos":""}],"ACCORDINGLY":[{"def":"Agreeably; correspondingly; suitably; in a manner conformable.","pos":""},{"def":"In natural sequence; consequently; so.","pos":""}],"ACCORDION":[{"def":"A small, portable, keyed wind instrument, whose tones are generated by play of the wind upon free metallic reeds.","pos":""}],"ACCORDIONIST":[{"def":"A player on the accordion.","pos":""}],"ACCORDMENT":[{"def":"Agreement; reconcilement.","pos":""}],"ACCORPORATE":[{"def":"To unite; to attach; to incorporate.","pos":""}],"ACCOST":[{"def":"To join side to side; to border; hence, to sail along the coast or side of.","pos":""},{"def":"To approach; to make up to.","pos":""}],"ACCOSTABLE":[{"def":"Approachable; affable.","pos":""}],"ACCOSTED":[{"def":"Supported on both sides by other charges; also, side by side.","pos":""}],"ACCOUCHEMENT":[{"def":"Ac*couche\"ment (#; 277), n.","pos":""}],"ACCOUCHEUR":[{"def":"A man who assists women in childbirth; a man midwife; an obstetrician.","pos":""}],"ACCOUNT":[{"def":"A reckoning; computation; calculation; enumeration; a record of some reckoning; as, the Julian account of time.","pos":""},{"def":"A registry of pecuniary transactions; a written or printed statement of business dealings or debts and credits, and also of other things subjected to a reckoning or review; as, to keep one's account at the bank.","pos":""}],"ACCOUNT BOOK":[{"def":"A book in which accounts are kept.","pos":""}],"ACCOUNTABILITY":[{"def":"The state of being accountable; liability to be called on to render an account; accountableness.","pos":""}],"ACCOUNTABLE":[{"def":"Liable to be called on to render an account; answerable; as, every man is accountable to God for his conduct.","pos":""},{"def":"Capable of being accounted for; explicable.","pos":""}],"ACCOUNTABLENESS":[{"def":"The quality or state of being accountable; accountability.","pos":""}],"ACCOUNTABLY":[{"def":"In an accountable manner.","pos":""}],"ACCOUNTANCY":[{"def":"The art or employment of an accountant.","pos":""}],"ACCOUNTANT":[{"def":"One who renders account; one accountable.","pos":""}],"ACCOUNTANTSHIP":[{"def":"The office or employment of an accountant.","pos":""}],"ACCOUPLE":[{"def":"To join; to couple.","pos":""}],"ACCOUPLEMENT":[{"def":"The act of coupling, or the state of being coupled; union.","pos":""},{"def":"That which couples, as a tie or brace.","pos":""}],"ACCOURT":[{"def":"To treat courteously; to court.","pos":""},{"def":"To furnish with dress, or equipments, esp.","pos":""}],"ACCOY":[{"def":"To render quiet; to soothe.","pos":""},{"def":"To subdue; to tame; to daunt.","pos":""}]}