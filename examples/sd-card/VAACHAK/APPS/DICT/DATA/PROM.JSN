{"PROMANATION":[{"def":"The act of flowing forth; emanation; efflux.","pos":""}],"PROMENADE":[{"def":"A walk for pleasure, display, or exercise.","pos":""},{"def":"A place for walking; a public walk.","pos":""}],"PROMENADER":[{"def":"One who promenades.","pos":""}],"PROMERIT":[{"def":"To oblige; to confer a favor on.","pos":""},{"def":"To deserve; to procure by merit.","pos":""}],"PROMEROPS":[{"def":"Any one of several species of very brilliant birds belonging to Promerops, Epimarchus, and allied genera, closely related to the paradise birds, and mostly native of New Guinea.","pos":""}],"PROMETHEA":[{"def":"A large American bombycid moth (Callosamia promethea).","pos":""}],"PROMETHEAN":[{"def":"Of or pertaining to Prometheus.","pos":""},{"def":"Having a life-giving quality; inspiring.","pos":""}],"PROMETHEUS":[{"def":"The son of Iapetus (one of the Titans) and Clymene, fabled by the poets to have surpassed all mankind in knowledge, and to have formed men of clay to whom he gave life by means of fire stolen from heaven.","pos":""}],"PROMINENT":[{"def":"Standing out, or projecting, beyond the line surface of something; jutting; protuberant; in high relief; as, a prominent figure on a vase.","pos":""},{"def":"Hence; Distinctly manifest; likely to attract attention from its size or position; conspicuous; as, a prominent feature of the face; a prominent building.","pos":""}],"PROMINENTLY":[{"def":"In a prominent manner.","pos":""}],"PROMISCUITY":[{"def":"Promiscuousness; confusion.","pos":""}],"PROMISCUOUS":[{"def":"Consisting of individuals united in a body or mass without order; mingled; confused; undistinguished; as, a promiscuous crowd or mass.","pos":""},{"def":"Distributed or applied without order or discrimination; not restricted to an individual; common; indiscriminate; as, promiscuous love or intercourse.","pos":""}],"PROMISCUOUSLY":[{"def":"In a promiscuous manner.","pos":""}],"PROMISCUOUSNESS":[{"def":"The quality or state of being promiscuous.","pos":""}],"PROMISE":[{"def":"An engagement by one person to another, either in words or in writing, but properly not under seal, for the performance or nonperformance of some particular thing.","pos":""}],"PROMISEE":[{"def":"The person to whom a promise is made.","pos":""}],"PROMISER":[{"def":"One who promises.","pos":""}],"PROMISING":[{"def":"Making a promise or promises; affording hope or assurance; as, promising person; a promising day.","pos":""}],"PROMISOR":[{"def":"One who engages or undertakes; a promiser.","pos":""}],"PROMISSIVE":[{"def":"Making a promise; implying a promise; promising.","pos":""}],"PROMISSORILY":[{"def":"In a promissory manner.","pos":""}],"PROMISSORY":[{"def":"Containing a promise or binding declaration of something to be done or forborne.","pos":""}],"PROMONTORY":[{"def":"A high point of land or rock projecting into the sea beyond the line of coast; a headland; a high cape.","pos":""},{"def":"A projecting part.","pos":""}],"PROMORPHOLOGICAL":[{"def":"Relating to promorphology; as, a promorphological conception.","pos":""}],"PROMORPHOLOGIST":[{"def":"One versed in the science of promorphology.","pos":""}],"PROMORPHOLOGY":[{"def":"Crystallography of organic forms; -- a division of morphology created by Haeckel.","pos":""}],"PROMOTE":[{"def":"To contribute to the growth, enlargement, or prosperity of (any process or thing that is in course); to forward; to further; to encourage; to advance; to excite; as, to promote learning; to promote disorder; to promote a business venture.","pos":""},{"def":"To exalt in station, rank, or honor; to elevate; to raise; to prefer; to advance; as, to promote an officer.","pos":""}],"PROMOTER":[{"def":"One who, or that which, forwards, advances, or promotes; an encourager; as, a promoter of charity or philosophy.","pos":""},{"def":"Specifically, one who sets on foot, and takes the preliminary steps in, a scheme for the organization of a corporation, a joint- stock company, or the like.","pos":""}],"PROMOTION":[{"def":"The act of promoting, advancing, or encouraging; the act of exalting in rank or honor; also, the condition of being advanced, encouraged, or exalted in honor; preferment.","pos":""}],"PROMOTIVE":[{"def":"Tending to advance, promote, or encourage.","pos":""}],"PROMOVE":[{"def":"To move forward; to advance; to promote.","pos":""}],"PROMPT":[{"def":"Ready and quick to act as occasion demands; meeting requirements readily; not slow, dilatory, or hesitating in decision or action; responding on the instant; immediate; as, prompt in obedience or compliance; -- said of persons.","pos":""},{"def":"Done or rendered quickly, readily, or immediately; given without delay or hesitation; -- said of conduct; as, prompt assistance.","pos":""}],"PROMPT-BOOK":[{"def":"The book used by a prompter of a theater.","pos":""}],"PROMPT-NOTE":[{"def":"A memorandum of a sale, and time when payment is due, given to the purchaser at a sale of goods.","pos":""}],"PROMPTER":[{"def":"One who, or that which, prompts; one who admonishes or incites to action.","pos":""},{"def":"One who reminds another, as an actor or an orator, of the words to be spoken next; specifically, one employed for this purpose in a theater.","pos":""}],"PROMPTITUDE":[{"def":"The quality of being prompt; quickness of decision and action when occasion demands; alacrity; as, promptitude in obedience.","pos":""}],"PROMPTLY":[{"def":"In a prompt manner.","pos":""}],"PROMPTNESS":[{"def":"Promptitude; readiness; quickness of decision or action.","pos":""},{"def":"Cheerful willingness; alacrity.","pos":""}],"PROMPTUARY":[{"def":"Of or pertaining to preparation.","pos":""}],"PROMPTURE":[{"def":"Suggestion; incitement; prompting.","pos":""}],"PROMULGATE":[{"def":"To make known by open declaration, as laws, decrees, or tidings; to publish; as, to promulgate the secrets of a council.","pos":""}],"PROMULGATION":[{"def":"The act of promulgating; publication; open declaration; as, the promulgation of the gospel.","pos":""}],"PROMULGATOR":[{"def":"One who promulgates or publishes.","pos":""}],"PROMULGE":[{"def":"To promulgate; to publish or teach.","pos":""}],"PROMULGER":[{"def":"One who promulges or publishes what was before unknown.","pos":""}],"PROMUSCIS":[{"def":"The proboscis of hemipterous insects.","pos":""}]}