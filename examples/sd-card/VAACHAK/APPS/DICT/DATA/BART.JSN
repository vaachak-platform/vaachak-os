{"BARTER":[{"def":"To traffic or trade, by exchanging one commodity for another, in distinction from a sale and purchase, in which money is paid for the commodities transferred; to truck.","pos":""}],"BARTERER":[{"def":"One who barters.","pos":""}],"BARTH":[{"def":"A place of shelter for cattle.","pos":""}],"BARTHOLOMEW TIDE":[{"def":"Time of the festival of St.","pos":""}],"BARTIZAN":[{"def":"A small, overhanging structure for lookout or defense, usually projecting at an angle of a building or near an entrance gateway.","pos":""}],"BARTLETT":[{"def":"A Bartlett pear, a favorite kind of pear, which originated in England about 1770, and was called Williams' Bonchrétien.","pos":""}],"BARTON":[{"def":"The demesne lands of a manor; also, the manor itself.","pos":""}]}