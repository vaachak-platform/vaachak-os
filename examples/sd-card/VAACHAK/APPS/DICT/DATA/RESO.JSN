{"RESOLUBLE":[{"def":"Admitting of being resolved; resolvable; as, bodies resoluble by fire.","pos":""}],"RESOLUTE":[{"def":"Having a decided purpose; determined; resolved; fixed in a determination; hence, bold; firm; steady.","pos":""},{"def":"Convinced; satisfied; sure.","pos":""}],"RESOLUTELY":[{"def":"In a resolute manner; with fixed purpose; boldly; firmly; steadily; with perseverance.","pos":""}],"RESOLUTENESS":[{"def":"The quality of being resolute.","pos":""}],"RESOLUTION":[{"def":"The act or process of solving; solution; as, the resolution of an equation or problem.","pos":""},{"def":"A breaking up, disappearance; or termination, as of a fever, a tumor, or the like.","pos":""}],"RESOLUTIONER":[{"def":"One who makes a resolution; one who joins with others in a declaration or resolution; specifically, one of a party in the Scottish Church in the 17th century.","pos":""}],"RESOLUTIONIST":[{"def":"One who makes a resolution.","pos":""}],"RESOLUTIVE":[{"def":"Serving to dissolve or relax.","pos":""}],"RESOLUTORY":[{"def":"Res\"o*lu*to*ry (rz\"-l-t-r), a.","pos":""}],"RESOLVABILITY":[{"def":"The quality or condition of being resolvable; resolvableness.","pos":""}],"RESOLVABLE":[{"def":"Admitting of being resolved; admitting separation into constituent parts, or reduction to first principles; admitting solution or explanation; as, resolvable compounds; resolvable ideas or difficulties.","pos":""}],"RESOLVABLENESS":[{"def":"The quality of being resolvable; resolvability.","pos":""}],"RESOLVE":[{"def":"To solve, as a problem, by enumerating the several things to be done, in order to obtain what is required; to find the answer to, or the result of.","pos":""},{"def":"To dispere or scatter; to discuss, as an inflammation or a tumor.","pos":""}],"RESOLVED":[{"def":"Having a fixed purpose; determined; resolute; -- usually placed after its noun; as, a man resolved to be rich.","pos":""}],"RESOLVEDLY":[{"def":"So as to resolve or clear up difficulties; clearly.","pos":""},{"def":"Resolutely; decidedly; firmly.","pos":""}],"RESOLVEDNESS":[{"def":"Fixedness of purpose; firmness; resolution.","pos":""}],"RESOLVENT":[{"def":"Having power to resolve; causing solution; solvent.","pos":""}],"RESOLVER":[{"def":"That which decomposes, or dissolves.","pos":""},{"def":"That which clears up and removes difficulties, and makes the mind certain or determined.","pos":""}],"RESONANCE":[{"def":"A prolongation or increase of any sound, eithar by reflection, as in a cavern or apartment the walls of which are not distant enough to return a distinct echo, or by the production of vibrations in other bodies, as a sounding-board, or the bodies of musical instruments.","pos":""}],"RESONANCY":[{"def":"Res\"o*nan*cy (-nan-s), n.","pos":""}],"RESONANT":[{"def":"Returning, or capable of returning, sound; fitted to resound; resounding; echoing back.","pos":""}],"RESONANTLY":[{"def":"In a reasonant manner.","pos":""}],"RESONATOR":[{"def":"Anything which resounds; specifically, a vessel in the form of a cylinder open at one end, or a hollow ball of brass with two apertures, so contrived as to greatly intensify a musical tone by its resonance.","pos":""}],"RESORB":[{"def":"Now lifted by the tide, and now resorbed.","pos":""}],"RESORBENT":[{"def":"Re*sorb\"ent (-ent), a.","pos":""}],"RESORCIN":[{"def":"A colorless crystalline substance of the phenol series, obtained by melting certain resins, as galbanum, asafetida, etc.","pos":""}],"RESORCYLIC":[{"def":"Of, or pertaining to, or producing, resorcin; as, resorcylic acid.","pos":""}],"RESORPTION":[{"def":"The act of resorbing; also, the act of absorbing again; reabsorption.","pos":""}],"RESORT":[{"def":"Active power or movement; spring.","pos":""}],"RESORTER":[{"def":"One who resorts; a frequenter.","pos":""}],"RESOUND":[{"def":"To sound loudly; as, his voice resounded far.","pos":""},{"def":"To be filled with sound; to ring; as, the woods resound with song.","pos":""}],"RESOURCE":[{"def":"Pecuniary means; funds; money, or any property that can be converted into supplies; available means or capabilities of any kind.","pos":""}],"RESOURCEFUL":[{"def":"Full of resources.","pos":""}],"RESOURCELESS":[{"def":"Destitute of resources.","pos":""}],"RESOWN":[{"def":"Re*sown\" (r*zoun\"), v.","pos":""}]}