{"HEAR":[{"def":"To perceive by the ear; to apprehend or take cognizance of by the ear; as, to hear sounds; to hear a voice; to hear one call.","pos":""},{"def":"To give audience or attention to; to listen to; to heed; to accept the doctrines or advice of; to obey; to examine; to try in a judicial court; as, to hear a recitation; to hear a class; the case will be heard to-morrow.","pos":""}],"HEARER":[{"def":"One who hears; an auditor.","pos":""}],"HEARING":[{"def":"The act or power of perceiving sound; perception of sound; the faculty or sense by which sound is perceived; as, my hearing is good.","pos":""},{"def":"Attention to what is delivered; opportunity to be heard; audience; as, I could not obtain a hearing.","pos":""}],"HEARKEN":[{"def":"To listen; to lend the ear; to attend to what is uttered; to give heed; to hear, in order to obey or comply.","pos":""},{"def":"To inquire; to seek information.","pos":""}],"HEARKENER":[{"def":"One who hearkens; a listener.","pos":""}],"HEARSAY":[{"def":"Report; rumor; fame; common talk; something heard from another.","pos":""}],"HEARSE":[{"def":"A hind in the year of its age.","pos":""}],"HEARSECLOTH":[{"def":"A cloth for covering a coffin when on a bier; a pall.","pos":""}],"HEARSELIKE":[{"def":"Suitable to a funeral.","pos":""}],"HEART":[{"def":"A hollow, muscular organ, which, by contracting rhythmically, keeps up the circulation of the blood.","pos":""}],"HEART'S-EASE":[{"def":"A species of violet (Viola tricolor); -- called also pansy.","pos":""}],"HEART-EATING":[{"def":"Preying on the heart.","pos":""}],"HEART-ROBBING":[{"def":"Depriving of thought; ecstatic.","pos":""},{"def":"Stealing the heart or affections; winning.","pos":""}],"HEART-SPOON":[{"def":"A part of the breastbone.","pos":""}],"HEART-WHOLE":[{"def":"Having the heart or affections free; not in love.","pos":""},{"def":"With unbroken courage; undismayed.","pos":""}],"HEART-WOUNDED":[{"def":"Wounded to the heart with love or grief.","pos":""}],"HEARTACHE":[{"def":"Sorrow; anguish of mind; mental pang.","pos":""}],"HEARTBREAK":[{"def":"Crushing sorrow or grief; a yielding to such grief.","pos":""}],"HEARTBREAKING":[{"def":"Causing overpowering sorrow.","pos":""}],"HEARTBROKEN":[{"def":"Overcome by crushing sorrow; deeply grieved.","pos":""}],"HEARTBURN":[{"def":"An uneasy, burning sensation in the stomach, often attended with an inclination to vomit.","pos":""}],"HEARTBURNED":[{"def":"Having heartburn.","pos":""}],"HEARTBURNING":[{"def":"Causing discontent.","pos":""}],"HEARTDEAR":[{"def":"Sincerely beloved.","pos":""}],"HEARTDEEP":[{"def":"Rooted in the heart.","pos":""}],"HEARTED":[{"def":"Having a heart; having (such) a heart (regarded as the seat of the affections, disposition, or character).","pos":""},{"def":"Shaped like a heart; cordate.","pos":""}],"HEARTEDNESS":[{"def":"Earnestness; sincerity; heartiness.","pos":""}],"HEARTEN":[{"def":"To encourage; to animate; to incite or stimulate the courage of; to embolden.","pos":""},{"def":"To restore fertility or strength to, as to land.","pos":""}],"HEARTENER":[{"def":"One who, or that which, heartens, animates, or stirs up.","pos":""}],"HEARTFELT":[{"def":"Hearty; sincere.","pos":""}],"HEARTGRIEF":[{"def":"Heartache; sorrow.","pos":""}],"HEARTH":[{"def":"The floor of a furnace, on which the material to be heated lies, or the lowest part of a melting furnace, into which the melted material settles.","pos":""}],"HEARTHSTONE":[{"def":"Stone forming the hearth; hence, the fireside; home.","pos":""}],"HEARTILY":[{"def":"From the heart; with all the heart; with sincerity.","pos":""},{"def":"With zeal; actively; vigorously; willingly; cordially; as, he heartily assisted the prince.","pos":""}],"HEARTINESS":[{"def":"The quality of being hearty; as, the heartiness of a greeting.","pos":""}],"HEARTLESS":[{"def":"Without a heart.","pos":""},{"def":"Destitute of courage; spiritless; despodent.","pos":""}],"HEARTLINGS":[{"def":"An exclamation used in addressing a familiar acquaintance.","pos":""}],"HEARTPEA":[{"def":"Same as Heartseed.","pos":""}],"HEARTQUAKE":[{"def":"Trembling of the heart; trepidation; fear.","pos":""}],"HEARTRENDING":[{"def":"Causing intense grief; overpowering with anguish; very distressing.","pos":""}],"HEARTSEED":[{"def":"A climbing plant of the genus Cardiospermum, having round seeds which are marked with a spot like a heart.","pos":""}],"HEARTSHAPED":[{"def":"Having the shape of a heart; cordate.","pos":""}],"HEARTSICK":[{"def":"Sick at heart; extremely depressed in spirits; very despondent.","pos":""}],"HEARTSOME":[{"def":"Merry; cheerful; lively.","pos":""}],"HEARTSTRICKEN":[{"def":"Shocked; dismayed.","pos":""}],"HEARTSTRIKE":[{"def":"To affect at heart; to shock.","pos":""}],"HEARTSTRING":[{"def":"A nerve or tendon, supposed to brace and sustain the heart.","pos":""}],"HEARTSTRUCK":[{"def":"Driven to the heart; infixed in the mind.","pos":""},{"def":"Shocked with pain, fear, or remorse; dismayed; heartstricken.","pos":""}],"HEARTSWELLING":[{"def":"Rankling in, or swelling, the heart.","pos":""}],"HEARTWOOD":[{"def":"The hard, central part of the trunk of a tree, consisting of the old and matured wood, and usually differing in color from the outer layers.","pos":""}],"HEARTY":[{"def":"Pertaining to, or proceeding from, the heart; warm; cordial; bold; zealous; sincere; willing; also, energetic; active; eager; as, a hearty welcome; hearty in supporting the government.","pos":""},{"def":"Exhibiting strength; sound; healthy; firm; not weak; as, a hearty timber.","pos":""}],"HEARTYHALE":[{"def":"Good for the heart.","pos":""}]}