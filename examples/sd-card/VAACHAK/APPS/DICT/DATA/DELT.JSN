{"DELTA":[{"def":"A tract of land shaped like the letter delta (as, the delta of the Ganges, of the Nile, or of the Mississippi.","pos":""}],"DELTA CONNECTION":[{"def":"One of the usual forms or methods for connecting apparatus to a three-phase circuit, the three corners of the delta or triangle, as diagrammatically represented, being connected to the three wires of the supply circuit.","pos":""}],"DELTA CURRENT":[{"def":"The current flowing through a delta connection.","pos":""}],"DELTAFICATION":[{"def":"The formation of a delta or of deltas.","pos":""}],"DELTAIC":[{"def":"Relating to, or like, a delta.","pos":""}],"DELTHYRIS":[{"def":"A name formerly given to certain Silurian brachiopod shells of the genus Spirifer.","pos":""}],"DELTIDIUM":[{"def":"The triangular space under the beak of many brachiopod shells.","pos":""}],"DELTOHEDRON":[{"def":"A solid bounded by twelve quadrilateral faces.","pos":""}],"DELTOID":[{"def":"Shaped like the Greek Deltoid leaf (Bot.","pos":""}]}