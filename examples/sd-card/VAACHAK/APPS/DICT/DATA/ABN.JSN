{"ABNEGATE":[{"def":"To deny and reject; to abjure.","pos":""}],"ABNEGATION":[{"def":"a denial; a renunciation.","pos":""}],"ABNEGATIVE":[{"def":"Denying; renouncing; negative.","pos":""}],"ABNEGATOR":[{"def":"One who abnegates, denies, or rejects anything.","pos":""}],"ABNET":[{"def":"The girdle of a Jewish priest or officer.","pos":""}],"ABNODATE":[{"def":"To clear (tress) from knots.","pos":""}],"ABNODATION":[{"def":"The act of cutting away the knots of trees.","pos":""}],"ABNORMAL":[{"def":"Not conformed to rule or system; deviating from the type; anomalous; irregular.","pos":""}],"ABNORMALITY":[{"def":"The state or quality of being abnormal; variation; irregularity.","pos":""},{"def":"Something abnormal.","pos":""}],"ABNORMALLY":[{"def":"In an abnormal manner; irregularly.","pos":""}],"ABNORMITY":[{"def":"Departure from the ordinary type; irregularity; monstrosity.","pos":""}],"ABNORMOUS":[{"def":"Abnormal; irregular.","pos":""}]}