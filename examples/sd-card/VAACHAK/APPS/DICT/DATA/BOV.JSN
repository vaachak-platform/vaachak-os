{"BOVATE":[{"def":"An oxgang, or as much land as an ox can plow in a year; an ancient measure of land, of indefinite quantity, but usually estimated at fifteen acres.","pos":""}],"BOVEY COAL":[{"def":"A kind of mineral coal, or brown lignite, burning with a weak flame, and generally a disagreeable odor; -- found at Bovey Tracey, Devonshire, England.","pos":""}],"BOVID":[{"def":"Relating to that tribe of ruminant mammals of which the genus Bos is the type.","pos":""}],"BOVIFORM":[{"def":"Resembling an ox in form; ox-shaped.","pos":""}],"BOVINE":[{"def":"of or pertaining to the genus Bos; relating to, or resembling, the ox or cow; oxlike; as, the bovine genus; a bovine antelope.","pos":""}]}