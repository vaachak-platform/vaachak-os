{"DEMI-":[{"def":"A prefix, signifying half.","pos":""}],"DEMI-TASSE":[{"def":"A small cup for, or of, black coffee.","pos":""}],"DEMIBASTION":[{"def":"A half bastion, or that part of a bastion consisting of one face and one flank.","pos":""}],"DEMICADENCE":[{"def":"An imperfect or half cadence, falling on the dominant instead of on the key note.","pos":""}],"DEMICANNON":[{"def":"A kind of ordnance, carrying a ball weighing from thirty to thirty-six pounds.","pos":""}],"DEMICIRCLE":[{"def":"An instrument for measuring angles, in surveying, etc.","pos":""}],"DEMICULVERIN":[{"def":"A kind of ordnance, carrying a ball weighing from nine to thirteen pounds.","pos":""}],"DEMIDEIFY":[{"def":"To deify in part.","pos":""}],"DEMIGOD":[{"def":"A half god, or an inferior deity; a fabulous hero, the offspring of a deity and a mortal.","pos":""}],"DEMIGODDESS":[{"def":"A female demigod.","pos":""}],"DEMIGORGE":[{"def":"Half the gorge, or entrance into a bastion, taken from the angle of the flank to the center of the bastion.","pos":""}],"DEMIJOHN":[{"def":"A glass vessel or bottle with a large body and small neck, inclosed in wickerwork.","pos":""}],"DEMILANCE":[{"def":"A light lance; a short spear; a half pike; also, a demilancer.","pos":""}],"DEMILANCER":[{"def":"A soldier of light cavalry of the 16th century, who carried a demilance.","pos":""}],"DEMILUNE":[{"def":"A work constructed beyond the main ditch of a fortress, and in front of the curtain between two bastions, intended to defend the curtain; a ravelin.","pos":""},{"def":"A crescentic mass of granular protoplasm present in the salivary glands.","pos":""}],"DEMIMONDE":[{"def":"Persons of doubtful reputation; esp.","pos":""}],"DEMINATURED":[{"def":"Having half the nature of another.","pos":""}],"DEMIQUAVER":[{"def":"A note of half the length of the quaver; a semiquaver.","pos":""}],"DEMIREP":[{"def":"A woman of doubtful reputation or suspected character; an adventuress.","pos":""}],"DEMISABILITY":[{"def":"The state of being demisable.","pos":""}],"DEMISABLE":[{"def":"Capable of being leased; as, a demisable estate.","pos":""}],"DEMISE":[{"def":"The conveyance or transfer of an estate, either in fee for life or for years, most commonly the latter.","pos":""}],"DEMISEMIQUAVER":[{"def":"A short note, equal in time to the half of a semiquaver, or the thirty-second part of a whole note.","pos":""}],"DEMISS":[{"def":"Cast down; humble; submissive.","pos":""}],"DEMISSION":[{"def":"The act of demitting, or the state of being demitted; a letting down; a lowering; dejection.","pos":""},{"def":"Resignation of an office.","pos":""}],"DEMISSIONARY":[{"def":"Pertaining to transfer or conveyance; as, a demissionary deed.","pos":""},{"def":"Tending to lower, depress, or degrade.","pos":""}],"DEMISSIVE":[{"def":"Downcast; submissive; humble.","pos":""}],"DEMISSLY":[{"def":"In a humble manner.","pos":""}],"DEMISUIT":[{"def":"A suit of light armor covering less than the whole body, as having no protection for the legs below the things, no vizor to the helmet, and the like.","pos":""}],"DEMIT":[{"def":"To let fall; to depress.","pos":""},{"def":"To yield or submit; to humble; to lower; as, to demit one's self to humble duties.","pos":""}],"DEMIURGE":[{"def":"The chief magistrate in some of the Greek states.","pos":""}],"DEMIURGIC":[{"def":"Pertaining to a demiurge; formative; creative.","pos":""}],"DEMIVILL":[{"def":"A half-vill, consisting of five freemen or frankpledges.","pos":""}],"DEMIVOLT":[{"def":"A half vault; one of the seven artificial motions of a horse, in which he raises his fore legs in a particular manner.","pos":""}],"DEMIWOLF":[{"def":"A half wolf; a mongrel dog, between a dog and a wolf.","pos":""}]}