{"GRAM":[{"def":"The East Indian name of the chick-pea (Cicer arietinum) and its seeds; also, other similar seeds there used for food.","pos":""},{"def":"The unit of weight in the metric system.","pos":""}],"GRAMA GRASS":[{"def":"The name of several kinds of pasture grasses found in the Western United States, esp.","pos":""}],"GRAMARYE":[{"def":"Necromancy; magic.","pos":""}],"GRAMASHES":[{"def":"Gaiters reaching to the knee; leggings.","pos":""}],"GRAME":[{"def":"Anger; wrath; scorn.","pos":""},{"def":"Sorrow; grief; misery.","pos":""}],"GRAMERCY":[{"def":"A word formerly used to express thankfulness, with surprise; many thanks.","pos":""}],"GRAMINACEOUS":[{"def":"Pertaining to, or resembling, the grasses; gramineous; as, graminaceous plants.","pos":""}],"GRAMINEOUS":[{"def":"Like, Or pertaining to, grass.","pos":""}],"GRAMINIFOLIOUS":[{"def":"Bearing leaves resembling those of grass.","pos":""}],"GRAMINIVOROUS":[{"def":"Feeding or subsisting on grass, and the like food; -- said of horses, cattle, and other animals.","pos":""}],"GRAMMALOGUE":[{"def":"Literally, a letter word; a word represented by a logogram; as, it, represented by |, that is, t.","pos":""}],"GRAMMAR":[{"def":"The science which treats of the principles of language; the study of forms of speech, and their relations to one another; the art concerned with the right use aud application of the rules of a language, in speaking or writing.","pos":""},{"def":"The art of speaking or writing with correctness or according to established usage; speech considered with regard to the rules of a grammar.","pos":""}],"GRAMMARIAN":[{"def":"One versed in grammar, or the construction of languages; a philologist.","pos":""},{"def":"One who writes on, or teaches, grammar.","pos":""}],"GRAMMARIANISM":[{"def":"The principles, practices, or peculiarities of grammarians.","pos":""}],"GRAMMARLESS":[{"def":"Without grammar.","pos":""}],"GRAMMATES":[{"def":"Rudiments; first principles, as of grammar.","pos":""}],"GRAMMATICAL":[{"def":"Of or pertaining to grammar; of the nature of grammar; as, a grammatical rule.","pos":""},{"def":"According to the rules of grammar; grammatically correct; as, the sentence is not grammatical; the construction is not grammatical.","pos":""}],"GRAMMATICASTER":[{"def":"A petty grammarian; a grammatical pedant or pretender.","pos":""}],"GRAMMATICATION":[{"def":"A principle of grammar; a grammatical rule.","pos":""}],"GRAMMATICISM":[{"def":"A point or principle of grammar.","pos":""}],"GRAMMATICIZE":[{"def":"To render grammatical.","pos":""}],"GRAMMATIST":[{"def":"A petty grammarian.","pos":""}],"GRAMME":[{"def":"Same as Gram the weight.","pos":""}],"GRAMME MACHINE":[{"def":"A kind of dynamo-electric machine; -- so named from its French inventor, M.","pos":""}],"GRAMOPHONE":[{"def":"An instrument for recording, preserving, and reproducing sounds, the record being a tracing of a phonautograph etched in some solid material.","pos":""}],"GRAMPUS":[{"def":"A toothed delphinoid cetacean, of the genus Grampus, esp.","pos":""}]}