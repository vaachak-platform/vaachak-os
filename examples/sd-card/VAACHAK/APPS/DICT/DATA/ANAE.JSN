{"ANAEMIA":[{"def":"A morbid condition in which the blood is deficient in quality or in quantity.","pos":""}],"ANAEMIC":[{"def":"Of or pertaining to anæmia.","pos":""},{"def":"Anaërobic bacteria.","pos":""}],"ANAEROBIC":[{"def":"Relating to, or like, anaërobies; araërobiotic.","pos":""}],"ANAEROBIES":[{"def":"Microörganisms which do not require oxygen, but are killed by it.","pos":""}],"ANAEROBIOTIC":[{"def":"Related to, or of the nature of, anaërobies.","pos":""}],"ANAESTHESIA":[{"def":"Entire or partial loss or absence of feeling or sensation; a state of general or local insensibility produced by disease or by the inhalation or application of an anæsthetic.","pos":""}],"ANAESTHETIC":[{"def":"That which produces insensibility to pain, as chloroform, ether, etc.","pos":""}],"ANAESTHETIZATION":[{"def":"The process of anæsthetizing; also, the condition of the nervous system induced by anæsthetics.","pos":""}],"ANAESTHETIZE":[{"def":"To render insensible by an anæsthetic.","pos":""}]}