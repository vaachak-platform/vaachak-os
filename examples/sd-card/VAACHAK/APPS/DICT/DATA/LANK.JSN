{"LANK":[{"def":"Slender and thin; not well filled out; not plump; shrunken; lean.","pos":""},{"def":"Languid; drooping.","pos":""}],"LANKINESS":[{"def":"The condition or quality or being lanky.","pos":""}],"LANKLY":[{"def":"In a lank manner.","pos":""}],"LANKNESS":[{"def":"The state or quality of being lank.","pos":""}],"LANKY":[{"def":"A long-tailed falcon (Falco lanarius), of Southern Europe, Asia, and Northern Africa, resembling the American prairie falcon.","pos":""}]}