{"GALE":[{"def":"A strong current of air; a wind between a stiff breeze and a hurricane.","pos":""},{"def":"A moderate current of air; a breeze.","pos":""}],"GALEA":[{"def":"The upper lip or helmet-shaped part of a labiate flower.","pos":"noun"},{"def":"A kind of bandage for the head.","pos":"noun"}],"GALEAS":[{"def":"Helmeted; having a helmetlike part, as a crest, a flower, etc.","pos":""}],"GALEI":[{"def":"That division of elasmobranch fishes which includes the sharks.","pos":""}],"GALENA":[{"def":"A remedy or antidose for poison; theriaca.","pos":"noun"},{"def":"Lead sulphide; the principal ore of lead.","pos":"noun"}],"GALENISM":[{"def":"The doctrines of Galen.","pos":""}],"GALENIST":[{"def":"A follower of Galen.","pos":""}],"GALENITE":[{"def":"Galena; lead ore.","pos":""}],"GALEOPITHECUS":[{"def":"A genus of flying Insectivora, formerly called flying lemurs.","pos":""}],"GALERICULATE":[{"def":"Covered as with a hat or cap.","pos":""}],"GALERITE":[{"def":"A cretaceous fossil sea urchin of the genus Galerites.","pos":""}]}