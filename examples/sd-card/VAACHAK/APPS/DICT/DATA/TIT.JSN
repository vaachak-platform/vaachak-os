{"TIT":[{"def":"A woman; -- used in contempt.","pos":""}],"TITAN":[{"def":"The Titan physical difficulties of his enterprise.","pos":""}],"TITAN CRANE":[{"def":"A massive crane with an overhanging counterbalanced arm carrying a traveler and lifting crab, the whole supported by a carriage mounted on track rails.","pos":""}],"TITANATE":[{"def":"A salt of titanic acid.","pos":""}],"TITANIC":[{"def":"Of or relating to Titans, or fabled giants of ancient mythology; hence, enormous in size or strength; as, Titanic structures.","pos":""}],"TITANIFEROUS":[{"def":"Containing or affording titanium; as, titaniferous magnetite.","pos":""}],"TITANITIC":[{"def":"Pertaining to, or containing, titanium; as, a titanitic mineral.","pos":""}],"TITANIUM":[{"def":"An elementary substance found combined in the minerals manaccanite, rutile, sphene, etc.","pos":""}],"TITANO-":[{"def":"A combining form (also used adjectively) designating certain double compounds of titanium with some other elements; as, titano- cyanide, titano-fluoride, titano-silicate, etc.","pos":""}],"TITANOTHERIUM":[{"def":"A large American Miocene mammal, allied to the rhinoceros, and more nearly to the extinct Brontotherium.","pos":""}],"TITANOUS":[{"def":"Designating certain compounds of titanium in which that element has a lower valence as contrasted with titanic compounds.","pos":""}],"TITH":[{"def":"Of a good stirring strain too, she goes tith.","pos":""}],"TITHABLE":[{"def":"Subject to the payment of tithes; as, tithable lands.","pos":""}],"TITHE":[{"def":"A tenth; the tenth part of anything; specifically, the tenthpart of the increase arising from the profits of land and stock, allotted to the clergy for their support, as in England, or devoted to religious or charitable uses.","pos":""},{"def":"Hence, a small part or proportion.","pos":""}],"TITHER":[{"def":"One who collects tithes.","pos":""},{"def":"One who pays tithes.","pos":""}],"TITHING":[{"def":"A number or company of ten householders who, dwelling near each other, were sureties or frankpledges to the king for the good behavior of each other; a decennary.","pos":""}],"TITHINGMAN":[{"def":"The chief man of a tithing; a headborough; one elected to preside over the tithing.","pos":""},{"def":"A peace officer; an under constable.","pos":""}],"TITHLY":[{"def":"Tightly; nimbly.","pos":""}],"TITHONIC":[{"def":"Of, pertaining to, or denoting, those rays of light which produce chemical effects; actinic.","pos":""}],"TITHONICITY":[{"def":"The state or property of being tithonic; actinism.","pos":""}],"TITHONOGRAPHIC":[{"def":"Of, relating to, or produced by, the chemical action of rays of light; photographic.","pos":""}],"TITHONOMETER":[{"def":"An instrument or apparatus for measuring or detecting tithonicity; an actinometer.","pos":""}],"TITHYMAL":[{"def":"Any kind of spurge, esp.","pos":""}],"TITILLATE":[{"def":"To tickle; as, to titillate the nose with a feather.","pos":""}],"TITILLATION":[{"def":"The act of tickling, or the state of being tickled; a tickling sensation.","pos":""},{"def":"Any pleasurable sensation.","pos":""}],"TITILLATIVE":[{"def":"Tending or serving to titillate, or tickle; tickling.","pos":""},{"def":"To dress or smarten up; to spruce.","pos":""}],"TITLARK":[{"def":"Any one of numerous small spring birds belonging to Anthus, Corydalla, and allied genera, which resemble the true larks in color and in having a very long hind claw; especially, the European meadow pipit (Anthus pratensis).","pos":""}],"TITLE":[{"def":"The panel for the name, between the bands of the back of a book.","pos":""},{"def":"A church to which a priest was ordained, and where he was to reside.","pos":""}],"TITLE-PAGE":[{"def":"The page of a book which contains it title.","pos":""}],"TITLED":[{"def":"Having or bearing a title.","pos":""}],"TITLELESS":[{"def":"Not having a title or name; without legitimate title.","pos":""}],"TITLER":[{"def":"A large truncated cone of refined sugar.","pos":""}],"TITLING":[{"def":"Stockfish; -- formerly so called in customhouses.","pos":""}],"TITMAL":[{"def":"The blue titmouse.","pos":""}],"TITMOUSE":[{"def":"Any one of numerous species of small insectivorous singing birds belonging to Parus and allied genera; -- called also tit, and tomtit.","pos":""}],"TITRATE":[{"def":"To analyse, or determine the strength of, by means of standard solutions.","pos":""}],"TITRATED":[{"def":"Standardized; determined or analyzed by titration; as, titrated solutions.","pos":""}],"TITRATION":[{"def":"The act or process of titrating; a substance obtained by titrating.","pos":""}],"TITTER":[{"def":"To laugh with the tongue striking against the root of the upper teeth; to laugh with restraint, or without much noise; to giggle.","pos":""}],"TITTLE":[{"def":"A particle; a minute part; a jot; an iota.","pos":""}],"TITTLE-TATTLE":[{"def":"Idle, trifling talk; empty prattle.","pos":""},{"def":"An idle, trifling talker; a gossip.","pos":""}],"TITTLE-TATTLING":[{"def":"The act or habit of parting idly or gossiping.","pos":""}],"TITTLEBAT":[{"def":"The three-spined stickleback.","pos":""}],"TITTUP":[{"def":"To behave or move in a lively or restless manner, as an impatient horse; to caper; to prance; to frisk.","pos":""}],"TITTUPPY":[{"def":"Given to tittuping; gay; lively; prancing; also, shaky; unsteady.","pos":""}],"TITTY":[{"def":"A little teat; a nipple.","pos":""}],"TITUBATE":[{"def":"To rock or roll, as a curved body on a plane.","pos":""}],"TITUBATION":[{"def":"The act of stumbling, rocking, or rolling; a reeling.","pos":""}],"TITULAR":[{"def":"Existing in title or name only; nominal; having the title to an office or dignity without discharging its appropriate duties; as, a titular prince.","pos":""}],"TITULARITY":[{"def":"The quality or state of being titular.","pos":""}],"TITULARLY":[{"def":"In a titular manner; nominally; by title only.","pos":""}],"TITULARY":[{"def":"A person invested with a title, in virtue of which he holds an office or benefice, whether he performs the duties of it or not.","pos":""}]}