{"VAS":[{"def":"A vessel; a duct.","pos":""}],"VASCULAR":[{"def":"Of or pertaining to the higher division of plants, that is, the phænogamous plants, all of which are vascular, in distinction from the cryptogams, which to a large extent are cellular only.","pos":""}],"VASCULARITY":[{"def":"The quality or state of being vascular.","pos":""}],"VASCULOSE":[{"def":"One of the substances of which vegetable tissue is composed, differing from cellulose in its solubility in certain media.","pos":""}],"VASCULUM":[{"def":"Same as Ascidium, n.","pos":""}],"VASE":[{"def":"The calyx of a plant.","pos":""}],"VASE CLOCK":[{"def":"A clock whose decorative case has the general form of a vase, esp.","pos":""}],"VASE-SHAPED":[{"def":"Formed like a vase, or like a common flowerpot.","pos":""}],"VASECTOMY":[{"def":"Resection or excision of the vas deferens.","pos":""}],"VASELINE":[{"def":"A yellowish translucent substance, almost odorless and tasteless, obtained as a residue in the purification of crude petroleum, and consisting essentially of a mixture of several of the higher members of the paraffin series.","pos":""}],"VASIFORM":[{"def":"Having the form of a vessel, or duct.","pos":""}],"VASO-INHIBITORY":[{"def":"See Vasodilator.","pos":""}],"VASOCONSTRICTOR":[{"def":"Causing constriction of the blood vessels; as, the vasoconstrictor nerves, stimulation of which causes constriction of the blood vessels to which they go.","pos":""},{"def":"A substance which causes constriction of the blood vessels.","pos":""}],"VASODENTINE":[{"def":"A modified form of dentine, which is permeated by blood capillaries; vascular dentine.","pos":""}],"VASODILATOR":[{"def":"Causing dilation or relaxation of the blood vessels; as, the vasodilator nerves, stimulation of which causes dilation of the blood vessels to which they go.","pos":""}],"VASOFORMATIVE":[{"def":"Concerned in the development and formation of blood vessels and blood corpuscles; as, the vasoformative cells.","pos":""}],"VASOMOTOR":[{"def":"Causing movement in the walls of vessels; as, the vasomotor mechanisms; the vasomotor nerves, a system of nerves distributed over the muscular coats of the blood vessels.","pos":""}],"VASSAL":[{"def":"The grantee of a fief, feud, or fee; one who holds land of superior, and who vows fidelity and homage to him; a feudatory; a feudal tenant.","pos":""}],"VASSALAGE":[{"def":"The state of being a vassal, or feudatory.","pos":""},{"def":"Political servitude; dependence; subjection; slavery; as, the Greeks were held in vassalage by the Turks.","pos":""}],"VASSALESS":[{"def":"A female vassal.","pos":""}],"VASSALRY":[{"def":"The body of vassals.","pos":""}],"VAST":[{"def":"Waste; desert; desolate; lonely.","pos":""},{"def":"Of great extent; very spacious or large; also, huge in bulk; immense; enormous; as, the vast ocean; vast mountains; the vast empire of Russia.","pos":""}],"VASTATION":[{"def":"A laying waste; waste; depopulation; devastation.","pos":""}],"VASTIDITY":[{"def":"Vastness; immensity.","pos":""}],"VASTITUDE":[{"def":"Vastness; immense extent.","pos":""},{"def":"Destruction; vastation.","pos":""}],"VASTITY":[{"def":"The huge vastity of the world.","pos":""}],"VASTLY":[{"def":"To a vast extent or degree; very greatly; immensely.","pos":""}],"VASTNESS":[{"def":"The quality or state of being vast.","pos":""}],"VASTY":[{"def":"I can call spirits from the vasty deep.","pos":""}],"VASUM":[{"def":"A genus including several species of large marine gastropods having massive pyriform shells, with conspicuous folds on the columella.","pos":""}]}