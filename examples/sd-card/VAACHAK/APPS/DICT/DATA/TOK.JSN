{"TOKAY":[{"def":"A grape of an oval shape and whitish color.","pos":""}],"TOKEN":[{"def":"A livid spot upon the body, indicating, or supposed to indicate, the approach of death.","pos":""},{"def":"Ten and a half quires, or, commonly, 250 sheets, of paper printed on both sides; also, in some cases, the same number of sheets printed on one side, or half the number printed on both sides.","pos":""}],"TOKENED":[{"def":"Marked by tokens, or spots; as, the tokened pestilence.","pos":""}],"TOKENLESS":[{"def":"Without a token.","pos":""}]}