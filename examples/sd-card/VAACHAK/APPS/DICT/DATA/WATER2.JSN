{"WATER PLATE":[{"def":"A plate heated by hot water contained in a double bottom or jacket.","pos":""}],"WATER POA":[{"def":"Meadow reed grass.","pos":""}],"WATER POCKET":[{"def":"A water hole in the bed of an intermittent stream, esp.","pos":""}],"WATER PORE":[{"def":"A pore by which the water tubes of various invertebrates open externally.","pos":""},{"def":"One of certain minute pores in the leaves of some plants.","pos":""}],"WATER POWER":[{"def":"The power of water employed to move machinery, etc.","pos":""},{"def":"A fall of water which may be used to drive machinery; a site for a water mill; a water privilege.","pos":""}],"WATER POX":[{"def":"A variety of chicken pox, or varicella.","pos":""}],"WATER PRIVILEGE":[{"def":"The advantage of using water as a mechanical power; also, the place where water is, or may be, so used.","pos":""}],"WATER PURSLANE":[{"def":"See under Purslane.","pos":""}],"WATER QUALM":[{"def":"See Water brash, under Brash.","pos":""}],"WATER RADISH":[{"def":"A coarse yellow-flowered plant (Nasturtium amphibium) related to the water cress and to the horse-radish.","pos":""}],"WATER RAIL":[{"def":"Any one of numerous species of rails of the genus Rallus, as the common European species (Rallus aquaticus).","pos":""}],"WATER RAM":[{"def":"An hydraulic ram.","pos":""}],"WATER RAT":[{"def":"A thief on the water; a pirate.","pos":""}],"WATER RATE":[{"def":"A rate or tax for a supply of water.","pos":""},{"def":"The diamond rattlesnake (Crotalus adamanteus); -- so called from its preference for damp places near water.","pos":""}],"WATER ROCKET":[{"def":"A cruciferous plant (Nasturtium sylvestre) with small yellow flowers.","pos":""}],"WATER SAIL":[{"def":"A small sail sometimes set under a studding sail or under a driver boom, and reaching nearly to the water.","pos":""}],"WATER SAPPHIRE":[{"def":"A deep blue variety of iolite, sometimes used as a gem; -- called also saphir d'eau.","pos":""}],"WATER SCREW":[{"def":"A screw propeller.","pos":""}],"WATER SHIELD":[{"def":"An aquatic American plant (Brasenia peltata) having floating oval leaves, and the covered with a clear jelly.","pos":""}],"WATER SHREW":[{"def":"Any one of several species of shrews having fringed feet and capable of swimming actively.","pos":""}],"WATER SNAIL":[{"def":"Any aquatic pulmonate gastropod belonging to Planorbis, Limnæa, and allied genera; a pond snail.","pos":""},{"def":"The Archimedean screw.","pos":""}],"WATER SOLDIER":[{"def":"An aquatic European plant (Stratiotes aloides) with bayonet- shaped leaves.","pos":""}],"WATER SOUCHY":[{"def":"A dish consisting of small fish stewed and served in a little water.","pos":""}],"WATER SPANIEL":[{"def":"A curly-haired breed of spaniels, naturally very fond of the water.","pos":""}],"WATER SPEEDWELL":[{"def":"A kind of speedwell (Veronica Anagallis) found in wet places in Europe and America.","pos":""}],"WATER SPIDER":[{"def":"Called also diving spider.","pos":""}],"WATER SPINNER":[{"def":"The water spider.","pos":""}],"WATER SPRITE":[{"def":"A sprite, or spirit, imagined as inhabiting the water.","pos":""}],"WATER STAR GRASS":[{"def":"An aquatic plant (Schollera graminea) with grassy leaves, and yellow star-shaped blossoms.","pos":""}],"WATER STARWORT":[{"def":"See under Starwort.","pos":""}],"WATER SUPPLY":[{"def":"A supply of water; specifically, water collected, as in reservoirs, and conveyed, as by pipes, for use in a city, mill, or the like.","pos":""}],"WATER TABBY":[{"def":"A kind of waved or watered tabby.","pos":""}],"WATER TABLE":[{"def":"A molding, or other projection, in the wall of a building, to throw off the water, -- generally used in the United States for the first table above the surface of the ground (see Table, n.","pos":""}],"WATER TELESCOPE":[{"def":"A telescope devised for looking into a body of water.","pos":""}],"WATER TENDER":[{"def":"In the United States navy, a first-class petty officer in charge in a fireroom.","pos":""}],"WATER THERMOMETER":[{"def":"A thermometer filled with water instead of mercury, for ascertaining the precise temperature at which water attains its maximum density.","pos":""}],"WATER THRUSH":[{"def":"Warbler family, especially the common species (S.","pos":""}],"WATER TICK":[{"def":"Same as Water mite.","pos":""}],"WATER TIGER":[{"def":"A diving, or water, beetle, especially the larva of a water beetle.","pos":""}],"WATER TORCH":[{"def":"The common cat-tail (Typha latifolia), the spike of which makes a good torch soaked in oil.","pos":""}],"WATER TOWER":[{"def":"A large metal pipe made to be extended vertically by sections, and used for discharging water upon burning buildings.","pos":""}],"WATER TREE":[{"def":"A climbing shrub (Tetracera alnifolia, or potatoria) of Western Africa, which pours out a watery sap from the freshly cut stems.","pos":""}],"WATER TU TUYERE":[{"def":"A tuyère kept cool by water circulating within a casing.","pos":""}],"WATER TU TWIST":[{"def":"Yarn made by the throstle, or water frame.","pos":""}],"WATER TUBE":[{"def":"One of a system of tubular excretory organs having external openings, found in many invertebrates.","pos":""}],"WATER TUPELO":[{"def":"A species of large tupelo (Nyssa aquatica) growing in swamps in the southern of the United States.","pos":""}],"WATER TURKEY":[{"def":"The American snakebird.","pos":""}],"WATER VINE":[{"def":"Any plant of the genus Phytocrene, climbing shrubs of Asia and Africa, the stems of which are singularly porous, and when cut stream with a limpid potable juice.","pos":""}],"WATER VIOLET":[{"def":"See under Violet.","pos":""}],"WATER VIPER":[{"def":"See Water moccasin.","pos":""}],"WATER WAGTAIL":[{"def":"See under Wagtail.","pos":""}],"WATER WAY":[{"def":"Same as Water course.","pos":""}],"WATER WHEEL":[{"def":"The paddle wheel of a steam vessel.","pos":""}],"WATER WILLOW":[{"def":"An American aquatic plant (Dianthera Americana) with long willowlike leaves, and spikes of small purplish flowers.","pos":""}],"WATER WING":[{"def":"One of two walls built on either side of the junction of a bridge with the bank of a river, to protect the abutment of the bridge and the bank from the action of the current.","pos":""}],"WATER-BEARER":[{"def":"The constellation Aquarius.","pos":""}],"WATER-BOUND":[{"def":"Prevented by a flood from proceeding.","pos":""}],"WATER-CLOSET":[{"def":"A privy; especially, a privy furnished with a contrivance for introducing a stream of water to cleanse it.","pos":""}],"WATER-COLORIST":[{"def":"One who paints in water colors.","pos":""}],"WATER-FURROW":[{"def":"To make water furrows in.","pos":""}],"WATER-LAID":[{"def":"Having a left-hand twist; -- said of cordage; as, a water-laid, or left-hand, rope.","pos":""},{"def":"One of a body of Dutch Anabaptists who separated from the Mennonites in the sixteenth century; -- so called from a district in North Holland denominated Waterland.","pos":""}],"WATER-LOGGED":[{"def":"Filled or saturated with water so as to be heavy, unmanageable, or loglike; -- said of a vessel, when, by receiving a great quantity of water into her hold, she has become so heavy as not to be manageable by the helm.","pos":""}],"WATER-RET":[{"def":"To ret, or rot, in water, as flax; to water-rot.","pos":""}],"WATER-ROT":[{"def":"To rot by steeping in water; to water-ret; as, to water-rot hemp or flax.","pos":""}],"WATER-SOAK":[{"def":"To soak water; to fill the interstices of with water.","pos":""}],"WATER-TIGHT":[{"def":"So tight as to retain, or not to admit, water; not leaky.","pos":""}],"WATER-WHITE":[{"def":"A vinelike plant (Vitis Caribæa) growing in parched districts in the West Indies, and containing a great amount of sap which is sometimes used for quenching thirst.","pos":""}],"WATER-WITHE":[{"def":"A vinelike plant (Vitis Caribæa) growing in parched districts in the West Indies, and containing a great amount of sap which is sometimes used for quenching thirst.","pos":""}],"WATERAGE":[{"def":"Money paid for transportation of goods, etc.","pos":""}],"WATERBOARD":[{"def":"A board set up to windward in a boat, to keep out water.","pos":""}],"WATERCOURSE":[{"def":"One of the holes in floor or other plates to permit water to flow through.","pos":""}],"WATERER":[{"def":"One who, or that which, waters.","pos":""}],"WATERFALL":[{"def":"An arrangement of a woman's back hair over a cushion or frame in some resemblance to a waterfall.","pos":""},{"def":"The water violet (Hottonia palustris); also, the less showy American plant H.","pos":""}],"WATERFLOOD":[{"def":"A flood of water; an inundation.","pos":""}],"WATERFOWL":[{"def":"Any bird that frequents the water, or lives about rivers, lakes, etc.","pos":""}],"WATERHORSE":[{"def":"A pile of salted fish heaped up to drain.","pos":""}],"WATERIE":[{"def":"The pied wagtail; -- so called because it frequents ponds.","pos":""}],"WATERINESS":[{"def":"The quality or state of being watery; moisture; humidity.","pos":""}],"WATERING":[{"def":"Wa\"ter*ing, Defn: a.","pos":""}],"WATERISH":[{"def":"Resembling water; thin; watery.","pos":""},{"def":"Somewhat watery; moist; as, waterish land.","pos":""}],"WATERISHNESS":[{"def":"The quality of being waterish.","pos":""}],"WATERLEAF":[{"def":"Any plant of the American genus Hydrophyllum, herbs having white or pale blue bell-shaped flowers.","pos":""}],"WATERLESS":[{"def":"Destitute of water; dry.","pos":""}],"WATERMAN":[{"def":"A man who plies for hire on rivers, lakes, or canals, or in harbors, in distinction from a seaman who is engaged on the high seas; a man who manages fresh-water craft; a boatman; a ferryman.","pos":""},{"def":"An attendant on cab stands, etc.","pos":""}],"WATERMANSHIP":[{"def":"The business or skill of a waterman.","pos":""},{"def":"Art of, or skill in, rowing; oarsmanship; specif.","pos":""}],"WATERMARK":[{"def":"See Water line, 2.","pos":""}],"WATERMELON":[{"def":"The very large ovoid or roundish fruit of a cucurbitaceous plant (Citrullus vulgaris) of many varieties; also, the plant itself.","pos":""}],"WATERPOT":[{"def":"A vessel for holding or conveying water, or for sprinkling water on cloth, plants, etc.","pos":""}],"WATERPROOF":[{"def":"Proof against penetration or permeation by water; impervious to water; as, a waterproof garment; a waterproof roof.","pos":""}],"WATERPROOFING":[{"def":"The act or process of making waterproof.","pos":""},{"def":"Same as Waterproof, n.","pos":""}],"WATERSCAPE":[{"def":"A sea view; -- distinguished from landscape.","pos":""}],"WATERSHED":[{"def":"The whole region or extent of country which contributes to the supply of a river or lake.","pos":""},{"def":"The line of division between two adjacent rivers or lakes with respect to the flow of water by natural channels into them; the natural boundary of a basin.","pos":""}],"WATERSHOOT":[{"def":"That which serves to guard from falling water; a drip or dripstone.","pos":""}],"WATERSPOUT":[{"def":"A remarkable meteorological phenomenon, of the nature of a tornado or whirlwind, usually observed over the sea, but sometimes over the land.","pos":""}],"WATERTATH":[{"def":"A kind of coarse grass growing in wet grounds, and supposed to be injurious to sheep.","pos":""}],"WATERWAY":[{"def":"Heavy plank or timber extending fore and aft the whole length of a vessel's deck at the line of junction with the sides, forming a channel to the scuppers, which are cut through it.","pos":""}],"WATERWORK":[{"def":"Painting executed in size or distemper, on canvas or walls, -- formerly, frequently taking the place of tapestry.","pos":""}],"WATERWORN":[{"def":"Worn, smoothed, or polished by the action of water; as, waterworn stones.","pos":""}],"WATERWORT":[{"def":"Any plant of the natural order Elatineæ, consisting of two genera (Elatine, and Bergia), mostly small annual herbs growing in the edges of ponds.","pos":""}],"WATERY":[{"def":"Of or pertaining to water; consisting of water.","pos":""},{"def":"Abounding with water; wet; hence, tearful.","pos":""}]}