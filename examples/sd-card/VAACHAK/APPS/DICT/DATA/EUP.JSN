{"EUPATHY":[{"def":"A principle or mixture of principles extracted from various species of Eupatorium.","pos":""}],"EUPATORIUM":[{"def":"A genus of perennial, composite herbs including hemp agrimony, boneset, throughwort, etc.","pos":""}],"EUPATRID":[{"def":"One well born, or of noble birth.","pos":""},{"def":"Soundness of the nutritive or digestive organs; good concoction or digestion; -- opposed to dyspepsia.","pos":""}],"EUPEPTIC":[{"def":"Of or pertaining to good digestion; easy of digestion; having a good digestion; as, eupeptic food; an eupeptic man.","pos":""}],"EUPHEMISM":[{"def":"A figure in which a harts or indelicate word or expression is softened; a way of describing an offensive thing by an inoffensive expression; a mild name for something disagreeable.","pos":""},{"def":"Pertaining to euphemism; containing a euphemism; softened in expression.","pos":""}],"EUPHEMIZE":[{"def":"To express by a euphemism, or in delicate language; to make use of euphemistic expressions.","pos":""}],"EUPHONIAD":[{"def":"An instrument in which are combined the characteristic tones of the organ and various other instruments.","pos":""},{"def":"Pertaining to, or exhibiting, euphony; agreeable in sound; pleasing to the ear; euphonious; as, a euphonic expression; euphonical orthography.","pos":""}],"EUPHONICON":[{"def":"A kind of uptight piano.","pos":""}],"EUPHONIOUS":[{"def":"Pleasing or sweet in sound; euphonic; smooth-sounding.","pos":""}],"EUPHONISM":[{"def":"An agreeable combination of sounds; euphony.","pos":""}],"EUPHONIUM":[{"def":"A bass instrument of the saxhorn family.","pos":""}],"EUPHONIZE":[{"def":"To make euphonic.","pos":""}],"EUPHONON":[{"def":"An instrument resembling the organ in tine and the upright piano in form.","pos":""}],"EUPHONY":[{"def":"A pleasing or sweet sound; an easy, smooth enunciation of sounds; a pronunciation of letters and syllables which is pleasing to the ear.","pos":""}],"EUPHORBIA":[{"def":"Spurge, or bastard spurge, a genus of plants of many species, mostly shrubby, herbaceous succulents, affording an acrid, milky juice.","pos":""},{"def":"Of, relating to, or resembling, the Euphorbia family.","pos":""}],"EUPHORBIUM":[{"def":"An inodorous exudation, usually in the form of yellow tears, produced chiefly by the African Euphorbia resinifrea.","pos":""}],"EUPHOTIDE":[{"def":"A rock occurring in the Alps, consisting of saussurite and smaragdite; -- sometimes called gabbro.","pos":""}],"EUPHRASY":[{"def":"The plant eyesight (euphrasia officionalis), formerly regarded as beneficial in disorders of the eyes.","pos":""}],"EUPHROE":[{"def":"A block or long slat of wood, perforated for the passage of the crowfoot, or cords by which an awning is held up.","pos":""}],"EUPHUISM":[{"def":"An affectation of excessive elegance and refinement of language; high-flown diction.","pos":""}],"EUPHUIST":[{"def":"One who affects excessive refinement and elegance of language; -- applied esp.","pos":""}],"EUPHUISTIC":[{"def":"Belonging to the euphuists, or euphuism; affectedly refined.","pos":""}],"EUPHUIZE":[{"def":"To affect excessive refinement in language; to be overnice in expression.","pos":""}],"EUPIONE":[{"def":"A limpid, oily liquid obtained by the destructive distillation of various vegetable and animal substances; -- specifically, an oil consisting largely of the higher hydrocarbons of the paraffin series.","pos":""}],"EUPITTONE":[{"def":"A yellow, crystalline substance, resembling aurin, and obtained by the oxidation of pittacal; -- called also eupittonic acid.","pos":""}],"EUPITTONIC":[{"def":"Pertaining to, or derived from, eupittone.","pos":""}],"EUPLASTIC":[{"def":"Having the capacity of becoming organizable in a high degree, as the matter forming the false membranes which sometimes result from acute inflammation in a healthy person.","pos":""}],"EUPLECTELLA":[{"def":"A genus of elegant, glassy sponges, consisting of interwoven siliceous fibers, and growing in the form of a cornucopia; -- called also Venus's flower-basket.","pos":""}],"EUPLEXOPTERA":[{"def":"An order of insects, including the earwig.","pos":""}],"EUPNAEA":[{"def":"Normal breathing where arterialization of the blood is normal, in distinction from dyspnæa, in which the blood is insufficiently arterialized.","pos":""},{"def":"A contrivance for obtaining a light instantaneous, as a lucifer match.","pos":""}]}