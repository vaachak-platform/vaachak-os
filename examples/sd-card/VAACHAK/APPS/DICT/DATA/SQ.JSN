{"SQUAB":[{"def":"Fat; thick; plump; bulky.","pos":""},{"def":"Unfledged; unfeathered; as, a squab pigeon.","pos":""}],"SQUAB-CHICK":[{"def":"A young chicken before it is fully fledged.","pos":""}],"SQUABASH":[{"def":"To crush; to quash; to squash.","pos":""}],"SQUABBISH":[{"def":"Thick; fat; heavy.","pos":""}],"SQUABBLE":[{"def":"To contend for superiority in an unseemly maner; to scuffle; to struggle; to wrangle; to quarrel.","pos":""},{"def":"To debate peevishly; to dispute.","pos":""}],"SQUABBLER":[{"def":"One who squabbles; a contentious person; a brawler.","pos":""}],"SQUABBY":[{"def":"Short and thick; suqabbish.","pos":""}],"SQUACCO":[{"def":"A heron (Ardea comata) found in Asia, Northern Africa, and Southern Europe.","pos":""}],"SQUAD":[{"def":"A small party of men assembled for drill, inspection, or other purposes.","pos":""}],"SQUADRON":[{"def":"A body of cavarly comparising two companies or troops, and averging from one hundred and twenty to two hundred men.","pos":""},{"def":"A detachment of vessels employed on any particular service or station, under the command of the senior officer; as, the North Atlantic Squadron.","pos":""}],"SQUADRONED":[{"def":"Formed into squadrons, or squares.","pos":""}],"SQUAIL":[{"def":"To throw sticls at cocks; to throw anything about awkwardly or irregularly.","pos":""}],"SQUALI":[{"def":"The suborder of elasmobranch fishes which comprises the sharks.","pos":""}],"SQUALID":[{"def":"Dirty through neglect; foul; filthy; extremely dirty.","pos":""}],"SQUALIDITY":[{"def":"The quality or state of being squalid; foulness; filthiness.","pos":""}],"SQUALIDLY":[{"def":"In a squalid manner.","pos":""}],"SQUALIDNESS":[{"def":"Quality or state of being squalid.","pos":""}],"SQUALL":[{"def":"A sudden violent gust of wind often attended with rain or snow.","pos":""}],"SQUALLER":[{"def":"One who squalls; a screamer.","pos":""}],"SQUALLY":[{"def":"Interrupted by unproductive spots; -- said of a flied of turnips or grain.","pos":""},{"def":"Not equally good throughout; not uniform; uneven; faulty; -- said of cloth.","pos":""}],"SQUALODON":[{"def":"A genus of fossil whales belonging to the Phocodontia; -- so called because their are serrated, like a shark's.","pos":""}],"SQUALODONT":[{"def":"Pertaining to Squalodon.","pos":""}],"SQUALOID":[{"def":"Like or pertaining to a shark or sharks.","pos":""}],"SQUALOR":[{"def":"Squalidness; foulness; filthness; squalidity.","pos":""}],"SQUAM":[{"def":"An oilskin hat or southwester; -- a fisherman's name.","pos":""}],"SQUAMA":[{"def":"A scale cast off from the skin; a thin dry shred consisting of epithelium.","pos":""}],"SQUAMATA":[{"def":"A division of edentates having the body covered with large, imbricated horny scales.","pos":""},{"def":"Same as Squamose.","pos":""}],"SQUAMDUCK":[{"def":"The American eider duck.","pos":""}],"SQUAME":[{"def":"The scale, or exopodite, of an antenna of a crustacean.","pos":""}],"SQUAMELLA":[{"def":"A diminutive scale or bractlet, such as those found on the receptacle in many composite plants; a palea.","pos":""}],"SQUAMELLATE":[{"def":"Furnished or covered with little scales; squamulose.","pos":""}],"SQUAMIFORM":[{"def":"Having the shape of a scale.","pos":""}],"SQUAMIPEN":[{"def":"Any one of a group of fishes having the dorsal and anal fins partially covered with scales.","pos":""}],"SQUAMOID":[{"def":"Resembling a scale; also, covered with scales; scaly.","pos":""}],"SQUAMOSAL":[{"def":"The squamous part of the temporal bone, or a bone correspondending to it, under Temporal.","pos":""},{"def":"Of or pertaining to the squamosal bone; squamosal.","pos":""}],"SQUAMOZYGOMATIC":[{"def":"Of or pertaining to both the squamosal and zygomatic bones; -- applied to a bone, or a center of ossification, in some fetal skulls.","pos":""},{"def":"A squamozygomatic bone.","pos":""}],"SQUAMULA":[{"def":"One of the little hypogynous scales found in the flowers of grasses; a lodicule.","pos":""}],"SQUAMULATE":[{"def":"Same as Squamulose.","pos":""}],"SQUAMULE":[{"def":"Same as Squamula.","pos":""}],"SQUAMULOSE":[{"def":"Having little scales; squamellate; squamulate.","pos":""}],"SQUANDER":[{"def":"To scatter; to disperse.","pos":""},{"def":"To spend lavishly or profusely; to spend prodigally or wastefully; to use without economy or judgment; to dissipate; as, to squander an estate.","pos":""}],"SQUANDERER":[{"def":"One who squanders.","pos":""}],"SQUANDERINGLY":[{"def":"In a squandering manner.","pos":""}],"SQUARE":[{"def":"An instrument having at least one right angle and two or more straight edges, used to lay out or test square work.","pos":""},{"def":"The product of a number or quantity multiplied by itself; thus, 64 is the square of 8, for 8 × 8 = 64; the square of a + b is a2 + 2ab + b2.","pos":""}],"SQUARE-RIGGED":[{"def":"Having the sails extended upon yards suspended horizontally by the middle, as distinguished from fore-and-aft sails; thus, a ship and a brig are square-rigged vessels.","pos":""}],"SQUARE-TOED":[{"def":"Having the toe square.","pos":""}],"SQUARE-TOES":[{"def":"A precise person; -- used contemptuously or jocularly.","pos":""}],"SQUARELY":[{"def":"In a square form or manner.","pos":""}],"SQUARENESS":[{"def":"The quality of being square; as, an instrument to try the squareness of work.","pos":""}],"SQUARER":[{"def":"One who, or that which, squares.","pos":""},{"def":"One who squares, or quarrels; a hot-headed, contentious fellow.","pos":""}],"SQUARROSE":[{"def":"Ragged or full of lose scales or projecting parts; rough; jagged; as: (a) (Bot.","pos":""},{"def":"Divided into shreds or jags, raised above the plane of the leaf, and not parallel to it; said of a leaf.","pos":""}],"SQUARROSO-DENTATE":[{"def":"Having the teeth bent out of the plane of the lamina; -- said of a leaf.","pos":""}],"SQUARRULOSE":[{"def":"Somewhat squarrose; slightly squarrose.","pos":""}],"SQUASH":[{"def":"An American animal allied to the weasel.","pos":""}],"SQUASHER":[{"def":"One who, or that which, squashes.","pos":""}],"SQUASHINESS":[{"def":"The quality or state of being squashy, or soft.","pos":""}],"SQUASHY":[{"def":"Easily squashed; soft.","pos":""}],"SQUAT":[{"def":"To sit down upon the hams or heels; as, the savages squatted near the fire.","pos":""},{"def":"To sit close to the ground; to cower; to stoop, or lie close, to escape observation, as a partridge or rabbit.","pos":""}],"SQUATEROLE":[{"def":"The black-bellied plover.","pos":""}],"SQUATTER":[{"def":"See Squat snipe, under Squat.","pos":""}],"SQUAW":[{"def":"A female; a woman; -- in the language of Indian tribes of the Algonquin family, correlative of sannup.","pos":""}],"SQUAW MAN":[{"def":"A white man who has married an Indian squaw; sometimes, one who has gained tribal rights by such a marriage; -- often a term of contempt.","pos":""}],"SQUAW VINE":[{"def":"The partridge berry (Mitchella repens).","pos":""}],"SQUAWBERRY":[{"def":"A local name for the partridge berry; also, for the deerberry.","pos":""}],"SQUAWK":[{"def":"To utter a shrill, abrupt scream; to squeak harshly.","pos":""}],"SQUAWROOT":[{"def":"A scaly parasitic plant (Conopholis Americana) found in oak woods in the United States; -- called also cancer root.","pos":""}],"SQUAWWEED":[{"def":"The golden ragwort.","pos":""}],"SQUEAK":[{"def":"To utter a sharp, shrill cry, usually of short duration; to cry with an acute tone, as an animal; or, to make a sharp, disagreeable noise, as a pipe or quill, a wagon wheel, a door; to creak.","pos":""},{"def":"To break silence or secrecy for fear of pain or punishment; to speak; to confess.","pos":""}],"SQUEAKER":[{"def":"The Australian gray crow shrile (Strepera anaphonesis); -- so called from its note.","pos":""}],"SQUEAKINGLY":[{"def":"In a squeaking manner.","pos":""}],"SQUEAL":[{"def":"To cry with a sharp, shrill, prolonged sound, as certain animals do, indicating want, displeasure, or pain.","pos":""},{"def":"To turn informer; to betray a secret.","pos":""}],"SQUEALER":[{"def":"One who, or that which, squeals.","pos":""}],"SQUEAMISH":[{"def":"Having a stomach that is easily or nauseated; hence, nice to excess in taste; fastidious; easily disgusted; apt to be offended at trifling improprieties.","pos":""}],"SQUEASY":[{"def":"Queasy; nice; squeamish; fastidious; scrupulous.","pos":""}],"SQUEEGEE":[{"def":"Same as Squilgee.","pos":""}],"SQUEEGEE ROLLER":[{"def":"A small India-rubber roller with a handle, used esp.","pos":""}],"SQUEEZE":[{"def":"To press between two bodies; to press together closely; to compress; often, to compress so as to expel juice, moisture, etc.","pos":""}],"SQUEEZER":[{"def":"One who, or that which, squeezes; as, a lemon squeezer.","pos":""}],"SQUEEZING":[{"def":"That which is forced out by pressure; dregs.","pos":""}],"SQUELCH":[{"def":"To quell; to crush; to silence or put down.","pos":""}],"SQUETEAGUE":[{"def":"An American sciænoid fish (Cynoscion regalis), abundant on the Atlantic coast of the United States, and much valued as a food fish.","pos":""}],"SQUIB":[{"def":"A kind of slow match or safety fuse.","pos":""}],"SQUID":[{"def":"Any one of numerous species of ten-armed cephalopods having a long, tapered body, and a caudal fin on each side; especially, any species of Loligo, Ommastrephes, and related genera.","pos":""}],"SQUIER":[{"def":"A company of squires; the whole body of squires.","pos":""}],"SQUIFFY":[{"def":"Somewhat intoxicated; tipsy.","pos":""}],"SQUIGGLE":[{"def":"To shake and wash a fluid about in the mouth with the lips closed.","pos":""}],"SQUILGEE":[{"def":"Formerly, a small swab for drying a vessel's deck; now, a kind of scraper having a blade or edge of rubber or of leather, -- used for removing superfluous, water or other liquids, as from a vessel's deck after washing, from window panes, photographer's plates, etc.","pos":""}],"SQUILLA":[{"def":"Any one of numerous stomapod crustaceans of the genus Squilla and allied genera.","pos":""}],"SQUILLITIC":[{"def":"Of or pertaining to squills.","pos":""}],"SQUINCH":[{"def":"A small arch thrown across the corner of a square room to support a superimposed mass, as where an octagonal spire or drum rests upon a square tower; -- called also sconce, and sconcheon.","pos":""}],"SQUINT":[{"def":"Looking obliquely.","pos":""}],"SQUINT-EYE":[{"def":"An eye that squints.","pos":""}],"SQUINT-EYED":[{"def":"Having eyes that quint; having eyes with axes not coincident; cross-eyed.","pos":""},{"def":"Looking obliquely, or asquint; malignant; as, squint-eyed praise; squint-eyed jealousy.","pos":""}],"SQUINTER":[{"def":"One who squints.","pos":""}],"SQUINTING":[{"def":"Squint\"ing, Defn: a.","pos":""}],"SQUINZEY":[{"def":"To throw with a jerk; to throw edge foremost.","pos":""}],"SQUIRALTY":[{"def":"Same as Squirarchy.","pos":""}],"SQUIRARCH":[{"def":"One who belongs to the squirarchy.","pos":""}],"SQUIRARCHY":[{"def":"The gentlemen, or gentry, of a country, collectively.","pos":""}],"SQUIRE":[{"def":"A square; a measure; a rule.","pos":""}],"SQUIREEN":[{"def":"One who is half squire and half farmer; -- used humorously.","pos":""}],"SQUIREHOOD":[{"def":"The rank or state of a squire; squireship.","pos":""}],"SQUIRELY":[{"def":"Becoming a squire; like a squire.","pos":""}],"SQUIRREL":[{"def":"Any one of numerous species of small rodents belonging to the genus Sciurus and several allied genera of the famly Sciuridæ.","pos":""}],"SQUIRT":[{"def":"To drive or eject in a stream out of a narrow pipe or orifice; as, to squirt water.","pos":""}],"SQUIRTER":[{"def":"One who, or that which, squirts.","pos":""}],"SQUIRY":[{"def":"The body of squires, collectively considered; squirarchy.","pos":""}],"SQUITEE":[{"def":"The squeteague; -- called also squit.","pos":""}]}