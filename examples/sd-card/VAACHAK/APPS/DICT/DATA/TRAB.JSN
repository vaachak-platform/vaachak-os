{"TRABEA":[{"def":"A toga of purple, or ornamented with purple horizontal stripes.","pos":""}],"TRABEATED":[{"def":"Furnished with an entablature.","pos":""}],"TRABEATION":[{"def":"Same as Entablature.","pos":""}],"TRABECULA":[{"def":"A small bar, rod, bundle of fibers, or septal membrane, in the framework of an organ part.","pos":""}],"TRABECULAR":[{"def":"Of or pertaining to a trabecula or trabeculæ; composed of trabeculæ.","pos":""}],"TRABECULATE":[{"def":"Crossbarred, as the ducts in a banana stem.","pos":""}]}