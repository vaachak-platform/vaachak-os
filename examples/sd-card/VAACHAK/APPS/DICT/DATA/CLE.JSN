{"CLEADING":[{"def":"A jacket or outer covering of wood, etc.","pos":""},{"def":"The planking or boarding of a shaft, cofferdam, etc.","pos":""}],"CLEAN":[{"def":"Free from ceremonial defilement.","pos":""}],"CLEAN-LIMBED":[{"def":"With well-proportioned, unblemished limbs; as, a clean-limbed young fellow.","pos":""}],"CLEAN-TIMBERED":[{"def":"Well-propotioned; symmetrical.","pos":""}],"CLEANER":[{"def":"One who, or that which, cleans.","pos":""}],"CLEANING":[{"def":"The act of making clean.","pos":""},{"def":"The afterbirth of cows, ewes, etc.","pos":""}],"CLEANLILY":[{"def":"In a cleanly manner.","pos":""}],"CLEANLINESS":[{"def":"State of being cleanly; neatness of person or dress.","pos":""}],"CLEANLY":[{"def":"Habitually clean; pure; innocent.","pos":""},{"def":"Cleansing; fitted to remove moisture; dirt, etc.","pos":""}],"CLEANNESS":[{"def":"The state or quality of being clean.","pos":""},{"def":"Purity of life or language; freedom from licentious courses.","pos":""}],"CLEANSABLE":[{"def":"Capable of being cleansed.","pos":""}],"CLEANSE":[{"def":"To render clean; to free from fith, pollution, infection, guilt, etc.","pos":""}],"CLEANSER":[{"def":"One who, or that which, cleanses; a detergent.","pos":""}],"CLEAR":[{"def":"Free from opaqueness; transparent; bright; light; luminous; unclouded.","pos":""},{"def":"Free from ambiquity or indistinctness; lucid; perspicuous; plain; evident; manifest; indubitable.","pos":""}],"CLEAR-CUT":[{"def":"Having a sharp, distinct outline, like that of a cameo.","pos":""},{"def":"Concisely and distinctly expressed.","pos":""}],"CLEAR-HEADED":[{"def":"Having a clear understanding; quick of perception; intelligent.","pos":""}],"CLEAR-SEEING":[{"def":"Having a clear physical or mental vision; having a clear understanding.","pos":""}],"CLEAR-SHINING":[{"def":"Shining brightly.","pos":""}],"CLEAR-SIGHTEDNESS":[{"def":"Acute discernment.","pos":""}],"CLEARAGE":[{"def":"The act of reforming anything; clearance.","pos":""}],"CLEARANCE":[{"def":"The distance by which one object clears another, as the distance between the piston and cylinder head at the end of a stroke in a steam engine, or the least distance between the point of a cogwell tooth and the bottom of a space between teeth of a wheel with which it engages.","pos":""}],"CLEARCOLE":[{"def":"A priming of size mixed with whiting or white lead, used in house painting, etc.","pos":""}],"CLEAREDNESS":[{"def":"The quality of being cleared.","pos":""}],"CLEARER":[{"def":"A tool of which the hemp for lines and twines, used by sailmakers, is finished.","pos":""}],"CLEARING":[{"def":"The act or process of making clear.","pos":""},{"def":"A tract of land cleared of wood for cultivation.","pos":""}],"CLEARLY":[{"def":"In a clear manner.","pos":""}],"CLEARNESS":[{"def":"The quality or state of being clear.","pos":""}],"CLEARSTARCH":[{"def":"To stiffen with starch, and then make clear by clapping with the hands; as, to clearstarch muslin.","pos":""}],"CLEARSTARCHER":[{"def":"One who clearstarches.","pos":""},{"def":"The upper story of the nave of a church, containing windows, and rising above the aisle roofs.","pos":""}],"CLEARWING":[{"def":"A lepidop terous insect with partially transparent wings, of the family Ægeriadæ, of which the currant and peach-tree borers are examples.","pos":""}],"CLEAT":[{"def":"A strip of wood or iron fastened on transversely to something in order to give strength, prevent warping, hold position, etc.","pos":""},{"def":"A device made of wood or metal, having two arms, around which turns may be taken with a line or rope so as to hold securely and yet be readily released.","pos":""}],"CLEAVABLE":[{"def":"Capable of cleaving or being divided.","pos":""}],"CLEAVAGE":[{"def":"The quality possessed by many crystallized substances of splitting readily in one or more definite directions, in which the cohesive attraction is a minimum, affording more or less smooth surfaces; the direction of the dividing plane; a fragment obtained by cleaving, as of a diamond.","pos":""},{"def":"Division into laminæ, like slate, with the lamination not necessarily parallel to the plane of deposition; -- usually produced by pressure.","pos":""}],"CLEAVE":[{"def":"To adhere closely; to stick; to hold fast; to cling.","pos":""},{"def":"To unite or be united closely in interest or affection; to adhere with strong attachment.","pos":""}],"CLEAVELANDITE":[{"def":"A variety of albite, white and lamellar in structure.","pos":""}],"CLEAVER":[{"def":"One who cleaves, or that which cleaves; especially, a butcher's instrument for cutting animal bodies into joints or pieces.","pos":""}],"CLEAVERS":[{"def":"A species of Galium (G.","pos":""}],"CLECHE":[{"def":"Charged with another bearing of the same figure, and of the color of the field, so large that only a narrow border of the first bearing remains visible; -- said of any heraldic bearing.","pos":""}],"CLEDGE":[{"def":"The upper stratum of fuller's earth.","pos":""}],"CLEDGY":[{"def":"Stiff, stubborn, clayey, or tenacious; as, a cledgy soil.","pos":""}],"CLEEK":[{"def":"A large hook or crook, as for a pot over a fire; specif.","pos":""},{"def":"Act of cleeking; a clutch.","pos":""}],"CLEF":[{"def":"A character used in musical notation to determine the position and pitch of the scale as represented on the staff.","pos":""}],"CLEFT":[{"def":"Incised nearly to the midrob; as, a cleft leaf.","pos":""}],"CLEFT-FOOTED":[{"def":"Having a cloven foot.","pos":""}],"CLEFTGRAFT":[{"def":"To ingraft by cleaving the stock and inserting a scion.","pos":""}],"CLEG":[{"def":"A small breeze or horsefly.","pos":""},{"def":"Having, beside the usual flowers, other minute, closed flowers, without petals or with minute petals; -- said of certain species of plants which possess flowers of two or more kinds, the closed ones being so constituted as to insure self-fertilization.","pos":""}],"CLEM":[{"def":"To starve; to famish.","pos":""}],"CLEMATIS":[{"def":"A genus of flowering plants, of many species, mostly climbers, having feathery styles, which greatly enlarge in the fruit; -- called also virgin's bower.","pos":""}],"CLEMENCY":[{"def":"Disposition to forgive and spare, as offenders; mildness of temper; gentleness; tenderness; mercy.","pos":""},{"def":"Mildness or softness of the elements; as, the clemency of the season.","pos":""}],"CLEMENT":[{"def":"Mild in temper and disposition; merciful; compassionate.","pos":""}],"CLEMENTINE":[{"def":"Of or pertaining to Clement, esp.","pos":""}],"CLEOPATRA'S NEEDLE":[{"def":"Either of two obelisks which were moved in ancient times from Heliopolis to Alexandria, one of which is now on the Thames Embankment in London, and the other in Central Park, in the City of New York.","pos":""}],"CLEPE":[{"def":"To call, or name.","pos":""}],"CLEPSINE":[{"def":"A genus of freshwater leeches, furnished with a proboscis.","pos":""}],"CLEPSYDRA":[{"def":"A water clock; a contrivance for measuring time by the graduated flow of a liquid, as of water, through a small aperture.","pos":""}],"CLEPTOMANIA":[{"def":"See Kleptomania.","pos":""}],"CLERESTORY":[{"def":"Same as Clearstory.","pos":""}],"CLERGEON":[{"def":"A chorister boy.","pos":""}],"CLERGIAL":[{"def":"Learned; erudite; clercial.","pos":""}],"CLERGICAL":[{"def":"Of or pertaining to the clergy; clerical; clerkily; learned.","pos":""}],"CLERGY":[{"def":"The body of men set apart, by due ordination, to the service of God, in the Christian church, in distinction from the laity; in England, usually restricted to the ministers of the Established Church.","pos":""},{"def":"Learning; also, a learned profession.","pos":""}],"CLERGYABLE":[{"def":"Entitled to, or admitting, the benefit of clergy; as, a clergyable felony.","pos":""}],"CLERGYMAN":[{"def":"An ordained minister; a man regularly authorized to peach the gospel, and administer its ordinances; in England usually restricted to a minister of the Established Church.","pos":""}],"CLERIC":[{"def":"A clerk, a clergyman.","pos":""}],"CLERICAL":[{"def":"Of or pertaining to the clergy; suitable for the clergy.","pos":""},{"def":"Of or relating to a clerk or copyist, or to writing.","pos":""}],"CLERICALISM":[{"def":"An excessive devotion to the interests of the sacerdotal order; undue influence of the clergy; sacerdotalism.","pos":""}],"CLERICITY":[{"def":"The state of being a clergyman.","pos":""}],"CLERISY":[{"def":"The literati, or well educated class.","pos":""},{"def":"The clergy, or their opinions, as opposed to the laity.","pos":""}],"CLERK":[{"def":"A clergyman or ecclesiastic.","pos":""},{"def":"A man who could read; a scholar; a learned person; a man of letters.","pos":""}],"CLERK-ALE":[{"def":"A feast for the benefit of the parish clerk.","pos":""}],"CLERKLY":[{"def":"Of or pertaining to a clerk.","pos":""}],"CLERKSHIP":[{"def":"State, quality, or business of a clerk.","pos":""}],"CLEROMANCY":[{"def":"A divination by throwing dice or casting lots.","pos":""}],"CLERONOMY":[{"def":"Inheritance; heritage.","pos":""}],"CLEVER":[{"def":"Possessing quickness of intellect, skill, dexterity, talent, or adroitness; expert.","pos":""},{"def":"Showing skill or adroitness in the doer or former; as, a clever speech; a clever trick.","pos":""}],"CLEVERISH":[{"def":"Somewhat clever.","pos":""}],"CLEVERLY":[{"def":"In a clever manner.","pos":""}],"CLEVERNESS":[{"def":"The quality of being clever; skill; dexterity; adroitness.","pos":""}],"CLEVIS":[{"def":"A piece of metal bent in the form of an oxbow, with the two ends perforated to receive a pin, used on the end of the tongue of a plow, wagen, etc.","pos":""},{"def":"A lower corner of a square sail, or the after corner of a fore- and-aft sail.","pos":""}],"CLEW":[{"def":"To move of draw (a sail or yard) by means of the clew garnets, clew lines, etc.","pos":""}]}