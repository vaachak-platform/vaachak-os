{"BOT":[{"def":"Of or pertaining to botany; relating to the study of plants; as, a botanical system, arrangement, textbook, expedition.","pos":""}],"BOTANIST":[{"def":"One skilled in botany; one versed in the knowledge of plants.","pos":""}],"BOTANIZE":[{"def":"To seek after plants for botanical investigation; to study plants.","pos":""}],"BOTANIZER":[{"def":"One who botanizes.","pos":""}],"BOTANOLOGY":[{"def":"The science of botany.","pos":""}],"BOTANOMANCY":[{"def":"An ancient species of divination by means of plants, esp.","pos":""}],"BOTANY":[{"def":"The science which treats of the structure of plants, the functions of their parts, their places of growth, their classification, and the terms which are employed in their description and denomination.","pos":""},{"def":"A book which treats of the science of botany.","pos":""}],"BOTANY BAY":[{"def":"A harbor on the east coast of Australia, and an English convict settlement there; -- so called from the number of new plants found on its shore at its discovery by Cook in 1770.","pos":""}],"BOTARGO":[{"def":"A sort of cake or sausage, made of the salted roes of the mullet, much used on the coast of the Mediterranean as an incentive to drink.","pos":""}],"BOTCH":[{"def":"A swelling on the skin; a large ulcerous affection; a boil; an eruptive disease.","pos":""},{"def":"A patch put on, or a part of a garment patched or mended in a clumsy manner.","pos":""}],"BOTCHEDLY":[{"def":"In a clumsy manner.","pos":""}],"BOTCHER":[{"def":"A young salmon; a grilse.","pos":""}],"BOTCHERLY":[{"def":"Bungling; awkward.","pos":""}],"BOTCHERY":[{"def":"A botching, or that which is done by botching; clumsy or careless workmanship.","pos":""}],"BOTCHY":[{"def":"Marked with botches; full of botches; poorly done.","pos":""}],"BOTELESS":[{"def":"Unavailing; in vain.","pos":""}],"BOTFLY":[{"def":"A dipterous insect of the family (Estridæ, of many different species, some of which are particularly troublesome to domestic animals, as the horse, ox, and sheep, on which they deposit their eggs.","pos":""}],"BOTH":[{"def":"The one and the other; the two; the pair, without exception of either.","pos":""}],"BOTH-HANDS":[{"def":"He is his master's both-hands, I assure you.","pos":""}],"BOTHER":[{"def":"To annoy; to trouble; to worry; to perplex.","pos":""}],"BOTHERATION":[{"def":"The act of bothering, or state of being bothered; cause of trouble; perplexity; annoyance; vexation.","pos":""}],"BOTHERER":[{"def":"One who bothers.","pos":""}],"BOTHERSOME":[{"def":"Vexatious; causing bother; causing trouble or perplexity; troublesome.","pos":""}],"BOTHIE":[{"def":"Of or pertaining to Bothnia, a country of northern Europe, or to a gulf of the same name which forms the northern part of the Baltic sea.","pos":""}],"BOTHRENCHYMA":[{"def":"Dotted or pitted ducts or vessels forming the pores seen in many kinds of wood.","pos":""},{"def":"A wooden hut or humble cot, esp.","pos":""}],"BOTOCUDOS":[{"def":"A Brazilian tribe of Indians, noted for their use of poisons; - - also called Aymborés.","pos":""}],"BOTRYOGEN":[{"def":"A hydrous sulphate of iron of a deep red color.","pos":""},{"def":"Having the form of a bunch of grapes; like a cluster of grapes, as a mineral presenting an aggregation of small spherical or spheroidal prominences.","pos":""}],"BOTRYOLITE":[{"def":"A variety of datolite, usually having a botryoidal structure.","pos":""}],"BOTS":[{"def":"The larvæ of several species of botfly, especially those larvæ which infest the stomach, throat, or intestines of the horse, and are supposed to be the cause of various ailments.","pos":""}],"BOTTINE":[{"def":"A small boot; a lady's boot.","pos":""},{"def":"An appliance resembling a small boot furnished with straps, buckles, etc.","pos":""}],"BOTTLE":[{"def":"A hollow vessel, usually of glass or earthenware (but formerly of leather), with a narrow neck or mouth, for holding liquids.","pos":""},{"def":"The contents of a bottle; as much as a bottle contains; as, to drink a bottle of wine.","pos":""}],"BOTTLE GREEN":[{"def":"A dark shade of green, like that of bottle glass.","pos":""}],"BOTTLE-NECK FRAME":[{"def":"An inswept frame.","pos":""}],"BOTTLE-NOSE":[{"def":"A cetacean of the Dolphin family, of several species, as Delphinus Tursio and Lagenorhyncus leucopleurus, of Europe.","pos":""}],"BOTTLE-NOSED":[{"def":"Having the nose bottleshaped, or large at the end.","pos":""}],"BOTTLED":[{"def":"Put into bottles; inclosed in bottles; pent up in, or as in, a bottle.","pos":""},{"def":"Having the shape of a bottle; protuberant.","pos":""}],"BOTTLEHEAD":[{"def":"A cetacean allied to the grampus; -- called also bottle-nosed whale.","pos":""}],"BOTTLEHOLDER":[{"def":"One who attends a pugilist in a prize fight; -- so called from the bottle of water of which he has charge.","pos":""},{"def":"One who assists or supports another in a contest; an abettor; a backer.","pos":""}],"BOTTLER":[{"def":"One who bottles wine, beer, soda water, etc.","pos":""}],"BOTTLING":[{"def":"The act or the process of putting anything into bottles (as beer, mineral water, etc.","pos":""}],"BOTTOM":[{"def":"The part of a ship which is ordinarily under water; hence, the vessel itself; a ship.","pos":""}],"BOTTOM FERMENTATION":[{"def":"A slow alcoholic fermentation during which the yeast cells collect at the bottom of the fermenting liquid.","pos":""}],"BOTTOMED":[{"def":"Having at the bottom, or as a bottom; resting upon a bottom; grounded; -- mostly, in composition; as, sharp-bottomed; well- bottomed.","pos":""}],"BOTTOMLESS":[{"def":"Without a bottom; hence, fathomless; baseless; as, a bottomless abyss.","pos":""}],"BOTTOMRY":[{"def":"A contract in the nature of a mortgage, by which the owner of a ship, or the master as his agent, hypothecates and binds the ship (and sometimes the accruing freight) as security for the repayment of money advanced or lent for the use of the ship, if she terminates her voyage successfully.","pos":""},{"def":"Having a bud or button, or a kind of trefoil, at the end; furnished with knobs or buttons.","pos":""}],"BOTULIFORM":[{"def":"Having the shape of a sausage.","pos":""}]}