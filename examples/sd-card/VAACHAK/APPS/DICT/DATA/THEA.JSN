{"THEA":[{"def":"A genus of plants found in China and Japan; the tea plant.","pos":""}],"THEANDRIC":[{"def":"Relating to, or existing by, the union of divine and human operation in Christ, or the joint agency of the divine and human nature.","pos":""},{"def":"Partaking of, or combining, both divinity and humanity.","pos":""}],"THEANTHROPISM":[{"def":"A state of being God and man.","pos":""},{"def":"The ascription of human atributes to the Deity, or to a polytheistic deity; anthropomorphism.","pos":""}],"THEANTHROPIST":[{"def":"One who advocates, or believes in, theanthropism.","pos":""}],"THEARCHIC":[{"def":"Divinely sovereign or supreme.","pos":""}],"THEARCHY":[{"def":"Government by God; divine sovereignty; theocracy.","pos":""},{"def":"One of an order of nuns founded by Ursula Benincasa, who died in 1618.","pos":""}],"THEATRAL":[{"def":"Of or pertaining to a theater; theatrical.","pos":""}],"THEATRIC":[{"def":"Woods over woods in gay, theatric pride.","pos":""}],"THEATRICAL":[{"def":"Of or pertaining to a theater, or to the scenic representations; resembling the manner of dramatic performers; histrionic; hence, artificial; as, theatrical performances; theatrical gestures.","pos":""}],"THEATRICALS":[{"def":"Dramatic performances; especially, those produced by amateurs.","pos":""}],"THEAVE":[{"def":"A ewe lamb of the first year; also, a sheep three years old.","pos":""}]}