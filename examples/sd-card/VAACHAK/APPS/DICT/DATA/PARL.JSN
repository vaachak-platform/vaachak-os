{"PARLANCE":[{"def":"Conversation; discourse; talk; diction; phrase; as, in legal parlance; in common parlance.","pos":""},{"def":"Speaking; in a speaking or declamatory manner; to be sung or played in the style of a recitative.","pos":""}],"PARLE":[{"def":"To talk; to converse; to parley.","pos":""}],"PARLEY":[{"def":"Mutual discourse or conversation; discussion; hence, an oral conference with an enemy, as with regard to a truce.","pos":""}],"PARLIAMENT":[{"def":"A parleying; a discussion; a conference.","pos":""},{"def":"A formal conference on public affairs; a general council; esp.","pos":""}],"PARLIAMENTARIAN":[{"def":"Of or pertaining to Parliament.","pos":""}],"PARLIAMENTARILY":[{"def":"In a parliamentary manner.","pos":""}],"PARLIAMENTARY":[{"def":"Of or pertaining to Parliament; as, parliamentary authority.","pos":""},{"def":"Enacted or done by Parliament; as, a parliamentary act.","pos":""}],"PARLOR":[{"def":"A room for business or social conversation, for the reception of guests, etc.","pos":""}],"PARLOR MATCH":[{"def":"A friction match that contains little or no sulphur.","pos":""}],"PARLOUS":[{"def":"Attended with peril; dangerous; as, a parlous cough.","pos":""},{"def":"Venturesome; bold; mischievous; keen.","pos":""}]}