{"CARL":[{"def":"A rude, rustic man; a churl.","pos":""},{"def":"Large stalks of hemp which bear the seed; -- called also carl hemp.","pos":""}],"CARLIN":[{"def":"A silver coin once current in some parts of Italy, worth about seven cents.","pos":""}],"CARLINE THISTLE":[{"def":"A prickly plant of the genus Carlina (C.","pos":""}],"CARLINGS":[{"def":"Same as Carl, 3.","pos":""}],"CARLIST":[{"def":"A parisan of Charles X.","pos":""}],"CARLOCK":[{"def":"A sort of Russian isinglass, made from the air bladder of the sturgeon, and used in clarifying wine.","pos":""}],"CARLOT":[{"def":"A churl; a boor; a peasant or countryman.","pos":""}],"CARLOVINGIAN":[{"def":"Pertaining to, founded by, of descended from, Charlemagne; as, the Carlovingian race of kings.","pos":""}]}