{"ALCAHEST":[{"def":"Same as Alkahest.","pos":""}],"ALCAIC":[{"def":"Pertaining to Alcæus, a lyric poet of Mitylene, about 6000 b.","pos":""}],"ALCALDE":[{"def":"A magistrate or judge in Spain and in Spanish America, etc.","pos":""}],"ALCALDIA":[{"def":"The jurisdiction or office of an alcalde; also, the building or chamber in which he conducts the business of his office.","pos":""}],"ALCALIMETER":[{"def":"See Alkalimeter.","pos":""}],"ALCANNA":[{"def":"An oriental shrub (Lawsonia inermis) from which henna is obtained.","pos":""}],"ALCARRAZA":[{"def":"A vessel of porous earthenware, used for cooling liquids by evaporation from the exterior surface.","pos":""}],"ALCAZAR":[{"def":"A fortress; also, a royal palace.","pos":""}],"ALCEDO":[{"def":"A genus of perching birds, including the European kingfisher (Alcedo ispida).","pos":""},{"def":"Of or relating to alchemy.","pos":""}],"ALCHEMICALLY":[{"def":"In the manner of alchemy.","pos":""}],"ALCHEMIST":[{"def":"One who practices alchemy.","pos":""},{"def":"Relating to or practicing alchemy.","pos":""}],"ALCHEMIZE":[{"def":"To change by alchemy; to transmute.","pos":""}],"ALCHEMY":[{"def":"See Alchemic, Alchemist, Alchemistic, Alchemy.","pos":""}],"ALCO":[{"def":"A small South American dog, domesticated by the aborigines.","pos":""},{"def":"Shortened forms of Alcoholate.","pos":""}],"ALCOHOL":[{"def":"A class of compounds analogous to vinic alcohol in constitution.","pos":""}],"ALCOHOLATE":[{"def":"A crystallizable compound of a salt with alcohol, in which the latter plays a part analogous to that of water of crystallization.","pos":""}],"ALCOHOLATURE":[{"def":"An alcoholic tincture prepared with fresh plants.","pos":""}],"ALCOHOLIC":[{"def":"Of or pertaining to alcohol, or partaking of its qualities; derived from, or caused by, alcohol; containing alcohol; as, alcoholic mixtures; alcoholic gastritis; alcoholic odor.","pos":""}],"ALCOHOLISM":[{"def":"A diseased condition of the system, brought about by the continued use of alcoholic liquors.","pos":""}],"ALCOHOLIZATION":[{"def":"The act of reducing a substance to a fine or impalpable powder.","pos":""},{"def":"The act rectifying spirit.","pos":""}],"ALCOHOLIZE":[{"def":"An instrument for determining the strength of spirits, with a scale graduated so as to indicate the percentage of pure alcohol, either by weight or volume.","pos":""},{"def":"Relating to the alcoholometer or alcoholometry.","pos":""}],"ALCOHOLOMETRY":[{"def":"The process or method of ascertaining the proportion of pure alcohol which spirituous liquors contain.","pos":""},{"def":"Same as Alcoholometer, Alcoholometric.","pos":""}],"ALCORAN":[{"def":"The Mohammedan Scriptures; the Koran (now the usual form).","pos":""}],"ALCORANIC":[{"def":"Of or pertaining to the Koran.","pos":""}],"ALCORANIST":[{"def":"One who adheres to the letter of the Koran, rejecting all traditions.","pos":""}],"ALCORNOQUE":[{"def":"The bark of several trees, esp.","pos":""}],"ALCOVE":[{"def":"A recessed portion of a room, or a small room opening into a larger one; especially, a recess to contain a bed; a lateral recess in a library.","pos":""}],"ALCYONACEA":[{"def":"A group of soft-bodied Alcyonaria, of which Alcyonium is the type.","pos":""}],"ALCYONARIA":[{"def":"One of the orders of Anthozoa.","pos":""}],"ALCYONES":[{"def":"The kingfishers.","pos":""}],"ALCYONIC":[{"def":"Of or pertaining to the Alcyonaria.","pos":""}],"ALCYONIUM":[{"def":"A genus of fleshy Alcyonaria, its polyps somewhat resembling flowers with eight fringed rays.","pos":""}],"ALCYONOID":[{"def":"Like or pertaining to the Alcyonaria.","pos":""},{"def":"A zoöphyte of the order Alcyonaria.","pos":""}]}