{"PIRACY":[{"def":"Robbery on the high seas; the taking of property from others on the open sea by open violence; without lawful authority, and with intent to steal; -- a crime answering to robbery on land.","pos":""}],"PIRAMETER":[{"def":"A dynamometer for ascertaining the power required to draw carriages over roads.","pos":""}],"PIRARUCU":[{"def":"Same as Arapaima.","pos":""}],"PIRATE":[{"def":"A robber on the high seas; one who by open violence takes the property of another on the high seas; especially, one who makes it his business to cruise for robbery or plunder; a freebooter on the seas; also, one who steals in a harbor.","pos":""},{"def":"An armed ship or vessel which sails without a legal commission, for the purpose of plundering other vessels on the high seas.","pos":""}],"PIRATICAL":[{"def":"Of or pertaining to a pirate; acquired by, or practicing, piracy; as, a piratical undertaking.","pos":""}],"PIRAYA":[{"def":"A large voracious fresh-water fish (Serrasalmo piraya) of South America, having lancet-shaped teeth.","pos":""}],"PIRIRIGUA":[{"def":"A South American bird (Guira guira) allied to the cuckoos.","pos":""}],"PIRL":[{"def":"To spin, as a top.","pos":""},{"def":"To twist or twine, as hair in making fishing lines.","pos":""}],"PIRN":[{"def":"A quill or reed on which thread or yarn is wound; a bobbin; also, the wound yarn on a weaver's shuttle; also, the reel of a fishing rod.","pos":""}],"PIROGUE":[{"def":"A dugout canoe; by extension, any small boat.","pos":""}],"PIROUETTE":[{"def":"The whirling about of a horse.","pos":""}]}