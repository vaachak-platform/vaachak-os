{"DIZEN":[{"def":"To dress; to attire.","pos":""},{"def":"To dress gaudily; to overdress; to bedizen; to deck out.","pos":""}],"DIZZ":[{"def":"To make dizzy; to astonish; to puzzle.","pos":""}],"DIZZILY":[{"def":"In a dizzy manner or state.","pos":""}],"DIZZINESS":[{"def":"Giddiness; a whirling sensation in the head; vertigo.","pos":""}],"DIZZY":[{"def":"Having in the head a sensation of whirling, with a tendency to fall; vertiginous; giddy; hence, confused; indistinct.","pos":""},{"def":"Causing, or tending to cause, giddiness or vertigo.","pos":""}]}