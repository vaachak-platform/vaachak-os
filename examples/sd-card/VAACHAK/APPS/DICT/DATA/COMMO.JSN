{"COMMODATE":[{"def":"A gratuitous loan.","pos":""}],"COMMODE":[{"def":"A kind of headdress formerly worn by ladies, raising the hair and fore part of the cap to a great height.","pos":""},{"def":"A piece of furniture, so named according to temporary fashion; as: (a) A cheat of drawers or a bureau.","pos":""}],"COMMODIOUS":[{"def":"Adapted to its use or purpose, or to wants and necessities; serviceable; spacious and convenient; roomy and comfortable; as, a commodious house.","pos":""}],"COMMODIOUSLY":[{"def":"In a commodious manner.","pos":""}],"COMMODIOUSNESS":[{"def":"State of being commodious; suitableness for its purpose; convience; roominess.","pos":""}],"COMMODITY":[{"def":"Convenience; accommodation; profit; benefit; advantage; interest; commodiousness.","pos":""},{"def":"That which affords convenience, advantage, or profit, especially in commerce, including everything movable that is bought and sold (except animals), -- goods, wares, merchandise, produce of land and manufactures, etc.","pos":""}],"COMMODORE":[{"def":"An officer who ranks next above a captain; sometimes, by courtesy, the senior captain of a squadron.","pos":""},{"def":"A captain commanding a squadron, or a division of a fleet, or having the temporary rank of rear admiral.","pos":""}],"COMMON":[{"def":"Belonging or relating equally, or similary, to more than one; as, you and I have a common interest in the property.","pos":""},{"def":"Belonging to or shared by, affecting or serving, all the members of a class, consired together; general; public; as, propertis common to all plants; the common schools; the Book of Common Prayer.","pos":""}],"COMMON SENSE":[{"def":"See Common sense, under Sense.","pos":""}],"COMMONABLE":[{"def":"Allowed to pasture on public commons.","pos":""}],"COMMONAGE":[{"def":"The right of pasturing on a common; the right of using anything in common with others.","pos":""}],"COMMONALTY":[{"def":"The common people; those classes and conditions of people who are below the rank of nobility; the commons.","pos":""},{"def":"The majority or bulk of mankind.","pos":""}],"COMMONER":[{"def":"One of the common people; one having no rank of nobility.","pos":""},{"def":"A member of the House of Commons.","pos":""}],"COMMONISH":[{"def":"Somewhat common; commonplace; vulgar.","pos":""}],"COMMONITION":[{"def":"Advice; warning; instruction.","pos":""}],"COMMONITIVE":[{"def":"Only commemorative and commonitive.","pos":""}],"COMMONITORY":[{"def":"Calling to mind; giving admonition.","pos":""}],"COMMONLY":[{"def":"Usually; generally; ordinarily; frequently; for the most part; as, confirmed habits commonly continue trough life.","pos":""},{"def":"In common; familiary.","pos":""}],"COMMONNESS":[{"def":"State or quality of being common or usual; as, the commonness of sunlight.","pos":""},{"def":"Triteness; meanness.","pos":""}],"COMMONPLACE":[{"def":"Common; ordinary; trite; as, a commonplace person, or observation.","pos":""}],"COMMONPLACENESS":[{"def":"The quality of being commonplace; commonness.","pos":""}],"COMMONS":[{"def":"The mass of the people, as distinguished from the titled chasses or nobility; the commonalty; the common people.","pos":""},{"def":"The House of Commons, or lower house of the British Parliament, consisting of representatives elected by the qualified voters of counties, boroughs, and universities.","pos":""}],"COMMONTY":[{"def":"A common; a piece of land in which two or more persons have a common right.","pos":""}],"COMMONWEAL":[{"def":"Such a prince, So kind a father of the commonweal.","pos":""}],"COMMONWEALTH":[{"def":"Specifically, the form of government established on the death of Charles I.","pos":""}],"COMMORANCY":[{"def":"A dwelling or ordinary residence in a place; habitation.","pos":""},{"def":"Residence temporarily, or for a short time.","pos":""}],"COMMORANT":[{"def":"Ordinarily residing; inhabiting.","pos":""},{"def":"Inhabiting or occupying temporarily.","pos":""}],"COMMORATION":[{"def":"The act of staying or residing in a place.","pos":""}],"COMMORIENT":[{"def":"Dying together or at the same time.","pos":""}],"COMMOTE":[{"def":"To commove; to disturb; to stir up.","pos":""}],"COMMOTION":[{"def":"Disturbed or violent motion; agitation.","pos":""},{"def":"A popular tumult; public disturbance; riot.","pos":""}],"COMMOVE":[{"def":"To urge; to persuade; to incite.","pos":""},{"def":"To put in motion; to disturb; to unsettle.","pos":""}]}