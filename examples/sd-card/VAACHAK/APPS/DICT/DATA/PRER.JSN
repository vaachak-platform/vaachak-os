{"PRERAPHAELITE":[{"def":"Of or pertaining to the style called preraphaelitism; as, a preraphaelite figure; a preraphaelite landscape.","pos":""}],"PREREGNANT":[{"def":"One who reigns before another; a sovereign predecessor.","pos":""}],"PREREMOTE":[{"def":"More remote in previous time or prior order.","pos":""}],"PREREQUIRE":[{"def":"To require beforehand.","pos":""}],"PREREQUISITE":[{"def":"Previously required; necessary as a preliminary to any proposed effect or end; as, prerequisite conditions of success.","pos":""}],"PRERESOLVE":[{"def":"To resolve beforehand; to predetermine.","pos":""}],"PREROGATIVE":[{"def":"Precedence; preëminence; first rank.","pos":""}],"PREROGATIVED":[{"def":"Endowed with a prerogative, or exclusive privilege.","pos":""}],"PREROGATIVELY":[{"def":"Pre*rog\"a*tive*ly, adv.","pos":""}]}