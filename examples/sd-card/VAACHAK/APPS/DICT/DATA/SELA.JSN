{"SELACHIAN":[{"def":"One of the Selachii.","pos":""}],"SELACHII":[{"def":"An order of elasmobranchs including the sharks and rays; the Plagiostomi.","pos":""}],"SELACHOIDEI":[{"def":"Same as Selachii.","pos":""}],"SELACHOSTOMI":[{"def":"A division of ganoid fishes which includes the paddlefish, in which the mouth is armed with small teeth.","pos":""}],"SELAGINELLA":[{"def":"A genus of cryptogamous plants resembling Lycopodia, but producing two kinds of spores; also, any plant of this genus.","pos":""}],"SELAH":[{"def":"A word of doubtful meaning, occuring frequently in the Psalms; by some, supposed to signify silence or a pause in the musical performance of the song.","pos":""}]}