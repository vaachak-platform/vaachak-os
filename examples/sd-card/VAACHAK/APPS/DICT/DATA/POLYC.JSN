{"POLYCARPELLARY":[{"def":"Composed of several or numerous carpels; -- said of such fruits as the orange.","pos":""}],"POLYCHAETA":[{"def":"One of the two principal groups of Chætopoda.","pos":""}],"POLYCHLORIDE":[{"def":"A chloride containing more than one atom of chlorine in the molecule.","pos":""}],"POLYCHOERANY":[{"def":"A government by many chiefs, princes, or rules.","pos":""}],"POLYCHORD":[{"def":"Having many strings.","pos":""}],"POLYCHREST":[{"def":"A medicine that serves for many uses, or that cures many diseases.","pos":""}],"POLYCHROISM":[{"def":"Same as Pleochroism.","pos":""}],"POLYCHROITE":[{"def":"The coloring matter of saffron; -- formerly so called because of the change of color on treatment with certain acids; -- called also crocin, and safranin.","pos":""}],"POLYCHROMATE":[{"def":"A salt of a polychromic acid.","pos":""}],"POLYCHROMATIC":[{"def":"Showing a variety, or a change, of colors.","pos":""}],"POLYCHROME":[{"def":"Esculin; -- so called in allusion to its fluorescent solutions.","pos":""}],"POLYCHROMIC":[{"def":"Pertaining to, or designating, any one of several acids (known only in their salts) which contain more than one atom of chromium.","pos":""}],"POLYCHROMOUS":[{"def":"Of or pertaining to polychromy; many-colored; polychromatic.","pos":""}],"POLYCHROMY":[{"def":"The art or practice of combining different colors, especially brilliant ones, in an artistic way.","pos":""}],"POLYCHRONIOUS":[{"def":"Enduring through a long time; chronic.","pos":""}],"POLYCLINIC":[{"def":"A clinic in which diseases of many sorts are treated; especially, an institution in which clinical instruction is given in all kinds of disease.","pos":""}],"POLYCONIC":[{"def":"Pertaining to, or based upon, many cones.","pos":""}],"POLYCOTYLEDON":[{"def":"A plant that has many, or more than two, cotyledons in the seed.","pos":""}],"POLYCOTYLEDONARY":[{"def":"Having the villi of the placenta collected into definite patches, or cotyledons.","pos":""}],"POLYCRACY":[{"def":"Government by many rulers; polyarchy.","pos":""}],"POLYCROTIC":[{"def":"Of or pertaining to polycrotism; manifesting polycrotism; as, a polycrotic pulse; a polycrotic pulse curve.","pos":""}],"POLYCROTISM":[{"def":"That state or condition of the pulse in which the pulse curve, or sphygmogram, shows several secondary crests or elevations; -- contrasted with monocrotism and dicrotism.","pos":""}],"POLYCYSTID":[{"def":"Pertaining to the Polycystidea, or the Polycystina.","pos":""}],"POLYCYSTIDEA":[{"def":"A division of Gregarinæ including those that have two or more internal divisions of the body.","pos":""}],"POLYCYSTINA":[{"def":"A division of Radiolaria including numerous minute marine species.","pos":""}],"POLYCYSTINE":[{"def":"Pertaining to the Polycystina.","pos":""},{"def":"One of the Polycystina.","pos":""}],"POLYCYTTARIA":[{"def":"A division of Radiolaria.","pos":""}]}