{"MARK":[{"def":"A license of reprisals.","pos":""}],"MARKED":[{"def":"Designated or distinguished by, or as by, a mark; hence; noticeable; conspicuous; as, a marked card; a marked coin; a marked instance.","pos":""}],"MARKER":[{"def":"One who or that which marks.","pos":""}],"MARKET":[{"def":"The privelege granted to a town of having a public market.","pos":""}],"MARKETABLE":[{"def":"Fit to be offered for sale in a market; such as may be justly and lawfully sold; as, dacayemarketable.","pos":""},{"def":"Current in market; as, marketable value.","pos":""}],"MARKETABLENESS":[{"def":"Quality of being marketable.","pos":""}],"MARKETER":[{"def":"One who attends a market to buy or sell; one who carries goods to market.","pos":""}],"MARKETING":[{"def":"The act of selling or of purchasing in, or as in, a market.","pos":""},{"def":"Articles in, or from, a market; supplies.","pos":""}],"MARKHOOR":[{"def":"A large wild goat (Capra megaceros), having huge flattened spiral horns.","pos":""}],"MARKING":[{"def":"The act of one who, or that which, marks; the mark or marks made; arrangement or disposition of marks or coloring; as, the marking of a bird's plumage.","pos":""}],"MARKSMAN":[{"def":"One who makes his mark, instead of writing his name, in signing documents.","pos":""}],"MARKSMANSHIP":[{"def":"Skill of a marksman.","pos":""}]}