{"APIAN":[{"def":"Belonging to bees.","pos":""}],"APIARIAN":[{"def":"Of or relating to bees.","pos":""}],"APIARIST":[{"def":"One who keeps an apiary.","pos":""}],"APIARY":[{"def":"A place where bees are kept; a stand or shed for bees; a beehouse.","pos":""}],"APICAL":[{"def":"At or belonging to an apex, tip, or summit.","pos":""}],"APICIAN":[{"def":"Belonging to Apicius, a notorious Roman epicure; hence applied to whatever is peculiarly refined or dainty and expensive in cookery.","pos":""}],"APICULAR":[{"def":"Situated at, or near, the apex; apical.","pos":""},{"def":"Terminated abruptly by a small, distinct point, as a leaf.","pos":""}],"APICULTURE":[{"def":"Rearing of bees for their honey and wax.","pos":""}],"APIECE":[{"def":"Each by itself; by the single one; to each; as the share of each; as, these melons cost a shilling apiece.","pos":""}],"APIECES":[{"def":"In pieces or to pieces.","pos":""}],"APIKED":[{"def":"Full fresh and new here gear apiked was.","pos":""}],"APIOL":[{"def":"An oily liquid derived from parsley.","pos":""}],"APIOLOGIST":[{"def":"A student of bees.","pos":""}],"APIOLOGY":[{"def":"The scientific or systematic study of honey bees.","pos":""}],"APIS":[{"def":"A genus of insects of the order Hymenoptera, including the common honeybee (Apis mellifica) and other related species.","pos":""}],"APISH":[{"def":"Having the qualities of an ape; prone to imitate in a servile manner.","pos":""}],"APISHLY":[{"def":"In an apish manner; with servile imitation; foppishly.","pos":""}],"APISHNESS":[{"def":"The quality of being apish; mimicry; foppery.","pos":""}],"APITPAT":[{"def":"With quick beating or palpitation; pitapat.","pos":""}]}