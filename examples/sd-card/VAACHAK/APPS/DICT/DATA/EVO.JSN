{"EVOCATE":[{"def":"To call out or forth; to summon; to evoke.","pos":""}],"EVOCATION":[{"def":"The act of calling out or forth.","pos":""}],"EVOCATIVE":[{"def":"Calling forth; serving to evoke; developing.","pos":""}],"EVOCATOR":[{"def":"One who calls forth.","pos":""}],"EVOKE":[{"def":"Apt to fly away.","pos":""}],"EVOLATION":[{"def":"A flying out or up.","pos":""}],"EVOLUTE":[{"def":"A curve from which another curve, called the involute or evolvent, is described by the end of a thread gradually wound upon the former, or unwound from it.","pos":""}],"EVOLUTILITY":[{"def":"The faculty possessed by all substances capable of self- nourishment of manifesting the nutritive acts by changes of form, of volume, or of structure.","pos":""}],"EVOLUTION":[{"def":"The formation of an involute by unwrapping a thread from a curve as an evolute.","pos":""},{"def":"The extraction of roots; -- the reverse of involution.","pos":""}],"EVOLUTIONAL":[{"def":"Relating to evolution.","pos":""}],"EVOLUTIONARY":[{"def":"Relating to evolution; as, evolutionary discussions.","pos":""}],"EVOLUTIONISM":[{"def":"The theory of, or belief in, evolution.","pos":""}],"EVOLUTIONIST":[{"def":"One skilled in evolutions.","pos":""}],"EVOLVE":[{"def":"To unfold or unroll; to open and expand; to disentangle and exhibit clearly and satisfactorily; to develop; to derive; to educe.","pos":""},{"def":"To throw out; to emit; as, to evolve odors.","pos":""}],"EVOLVEMENT":[{"def":"The act of evolving, or the state of being evolved; evolution.","pos":""}],"EVOLVENT":[{"def":"The involute of a curve.","pos":""}],"EVOMITION":[{"def":"The act of vomiting.","pos":""}]}