{"GRAIL":[{"def":"A book of offices in the Roman Catholic Church; a gradual.","pos":""}],"GRAILLE":[{"def":"A halfround single-cut file or fioat, having one curved face and one straight face, -- used by comb makers.","pos":""}],"GRAIN":[{"def":"The remains of grain, etc.","pos":""},{"def":"A rounded prominence on the back of a sepal, as in the common dock.","pos":""}],"GRAINED":[{"def":"Having tubercles or grainlike processes, as the petals or sepals of some flowers.","pos":""}],"GRAINER":[{"def":"An infusion of pigeon's dung used by tanners to neutralize the effects of lime and give flexibility to skins; -- called also grains and bate.","pos":""},{"def":"A knife for taking the hair off skins.","pos":""}],"GRAINFIELD":[{"def":"A field where grain is grown.","pos":""}],"GRAINING":[{"def":"The process of separating soap from spent lye, as with salt.","pos":""}],"GRAINS":[{"def":"See 5th Grain, n.","pos":""},{"def":"Pigeon's dung used in tanning.","pos":""}],"GRAINY":[{"def":"Resembling grains; granular.","pos":""}],"GRAITH":[{"def":"Furniture; apparatus or accouterments for work, traveling, war, etc.","pos":""}]}