{"CETACEA":[{"def":"An order of marine mammals, including the whales.","pos":""}],"CETACEAN":[{"def":"One of the Cetacea.","pos":""}],"CETACEOUS":[{"def":"Of or pertaining to the Cetacea.","pos":""}],"CETE":[{"def":"One of the Cetacea, or collectively, the Cetacea.","pos":""}],"CETENE":[{"def":"An oily hydrocarbon, C16H32, of the ethylene series, obtained from spermaceti.","pos":""}],"CETERACH":[{"def":"A species of fern with fronds (Asplenium Ceterach).","pos":""}],"CETEWALE":[{"def":"Same as Zedoary.","pos":""}],"CETIC":[{"def":"Of or pertaining to a whale.","pos":""}],"CETIN":[{"def":"A white, waxy substance, forming the essential part of spermaceti.","pos":""}],"CETOLOGICAL":[{"def":"Of or pertaining to cetology.","pos":""}],"CETOLOGIST":[{"def":"One versed in cetology.","pos":""}],"CETOLOGY":[{"def":"The description or natural history of cetaceous animals.","pos":""}],"CETRARIC":[{"def":"Pertaining to, or derived from, the lichen, Iceland moss (Cetaria Islandica).","pos":""}],"CETRARIN":[{"def":"A white substance extracted from the lichen, Iceland moss (Cetraria Islandica).","pos":""}],"CETYL":[{"def":"A radical, C16H33, not yet isolated, but supposed to exist in a series of compounds homologous with the ethyl compounds, and derived from spermaceti.","pos":""}],"CETYLIC":[{"def":"Of, pertaining to, or derived from, spermaceti.","pos":""}]}