{"CATSKILL PERIOD":[{"def":"The closing subdivision of the Devonian age in America.","pos":""}],"CATSO":[{"def":"A base fellow; a rogue; a cheat.","pos":""}],"CATSTICK":[{"def":"A stick or club employed in the game of ball called cat or tipcat.","pos":""}],"CATSTITCH":[{"def":"To fold and sew down the edge of with a coarse zigzag stitch.","pos":""}],"CATSUP":[{"def":"Same as Catchup, and Ketchup.","pos":""}]}