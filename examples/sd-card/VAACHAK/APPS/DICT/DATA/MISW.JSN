{"MISWANDER":[{"def":"To wander in a wrong path; to stray; to go astray.","pos":""}],"MISWED":[{"def":"To wed improperly.","pos":""}],"MISWEEN":[{"def":"To ween amiss; to misjudge; to distrust; to be mistaken.","pos":""}],"MISWEND":[{"def":"To go wrong; to go astray.","pos":""}],"MISWORD":[{"def":"To word wrongly; as, to misword a message, or a sentence.","pos":""}],"MISWORSHIP":[{"def":"Wrong or false worship; mistaken practices in religion.","pos":""}],"MISWORSHIPER":[{"def":"One who worships wrongly.","pos":""}],"MISWRITE":[{"def":"To write incorrectly.","pos":""}]}