{"MUCAMIDE":[{"def":"The acid amide of mucic acid, obtained as a white crystalline substance.","pos":""}],"MUCATE":[{"def":"A salt of mucic acid.","pos":""}],"MUCE":[{"def":"See Muse, and Muset.","pos":""}],"MUCEDIN":[{"def":"A yellowish white, amorphous, nitrogenous substance found in wheat, rye, etc.","pos":""}],"MUCH":[{"def":"Great in quantity; long in duration; as, much rain has fallen; much time.","pos":""}],"MUCHNESS":[{"def":"Greatness; extent.","pos":""}],"MUCHWHAT":[{"def":"Nearly; almost; much.","pos":""}],"MUCIC":[{"def":"Pertaining to, or derived from, gums and micilaginous substances; specif.","pos":""}],"MUCID":[{"def":"Musty; moldy; slimy; mucous.","pos":""}],"MUCIFIC":[{"def":"Inducing or stimulating the secretion of mucus; blennogenous.","pos":""},{"def":"Secreting mucus.","pos":""}],"MUCIFORM":[{"def":"Resembling mucus; having the character or appearance of mucus.","pos":""}],"MUCIGEN":[{"def":"A substance which is formed in mucous epithelial cells, and gives rise to mucin.","pos":""}],"MUCIGENOUS":[{"def":"Connected with the formation of mucin; resembling mucin.","pos":""}],"MUCILAGE":[{"def":"A gummy or gelatinous substance produced in certain plants by the action of water on the cell wall, as in the seeds of quinces, of flax, etc.","pos":""}],"MUCILAGINOUS":[{"def":"Partaking of the nature of, or resembling, mucilage; moist, soft, and viscid; slimy; ropy; as, a mucilaginous liquid.","pos":""},{"def":"Of, pertaining to, or secreting, mucilage; as, the mucilaginous glands.","pos":""}],"MUCIN":[{"def":"An albuminoid substance which is contained in mucus, and gives to the latter secretion its peculiar ropy character.","pos":""}],"MUCINOGEN":[{"def":"Same as Mucigen.","pos":""}],"MUCIPAROUS":[{"def":"Secreting, or producing, mucus or mucin.","pos":""}],"MUCIVORE":[{"def":"An unsect which feeds on mucus, or the sap of plants, as certain Diptera, of the tribe Mucivora.","pos":""}],"MUCK":[{"def":", abbreviation of Amuck.","pos":""}],"MUCK RAKE":[{"def":"A rake for scraping up muck or dung.","pos":""},{"def":"To seek for, expose, or charge, esp.","pos":""}],"MUCKER":[{"def":"A term of reproach for a low or vulgar labor person.","pos":""}],"MUCKERER":[{"def":"A miser; a niggard.","pos":""}],"MUCKINESS":[{"def":"The quality of being mucky.","pos":""}],"MUCKSY":[{"def":"Somewhat mucky; soft, sticky, and dirty; muxy.","pos":""}],"MUCKWORM":[{"def":"A larva or grub that lives in muck or manure; -- applied to the larvæ of the tumbledung and allied beetles.","pos":""}],"MUCKY":[{"def":"Filthy with muck; miry; as, a mucky road.","pos":""},{"def":"Vile, in a moral sense; sordid.","pos":""}],"MUCOCELE":[{"def":"An enlargement or protrusion of the mucous membrane of the lachrymal passages, or dropsy of the lachrymal sac, dependent upon catarrhal inflammation of the latter.","pos":""}],"MUCOID":[{"def":"Resembling mucus.","pos":""}],"MUCONATE":[{"def":"A salt of muconic acid.","pos":""}],"MUCONIC":[{"def":"Of, pertaining to, or designating, an organic acid, obtained indirectly from mucic acid, and somewhat resembling itaconic acid.","pos":""}],"MUCOPURULENT":[{"def":"Having the character or appearance of both mucus and pus.","pos":""}],"MUCOR":[{"def":"A genus of minute fungi.","pos":""}],"MUCOSITY":[{"def":"The quality or state of being mucous or slimy; mucousness.","pos":""}],"MUCOUS":[{"def":"Of, pertaining to, or resembling, mucus; slimy, ropy, or stringy, and lubricous; as, a mucous substance.","pos":""},{"def":"Secreting a slimy or mucigenous substance; as, the mucous membrane.","pos":""}],"MUCOUSNESS":[{"def":"The quality or state of being mucous; sliminess.","pos":""}],"MUCRO":[{"def":"A minute abrupt point, as of a leaf; any small, sharp point or process, terminating a larger part or organ.","pos":""},{"def":"Ending abruptly in a sharp point; abruptly tipped with a short and sharp point; as, a mucronate leaf.","pos":""}],"MUCRONULATE":[{"def":"Having, or tipped with, a small point or points.","pos":""}],"MUCULENT":[{"def":"Slimy; moist, and moderately viscous.","pos":""}],"MUCUS":[{"def":"A viscid fluid secreted by mucous membranes, which it serves to moisten and protect.","pos":""},{"def":"Any other animal fluid of a viscid quality, as the synovial fluid, which lubricates the cavities of the joints; -- improperly so used.","pos":""}]}