{"ENS":[{"def":"Entity, being, or existence; an actually existing being; also, God, as the Being of Beings.","pos":""},{"def":"Something supposed to condense within itself all the virtues and qualities of a substance from which it is extracted; essence.","pos":""}],"ENSAMPLE":[{"def":"An example; a pattern or model for imitation.","pos":""}],"ENSANGUINE":[{"def":"To stain or cover with blood; to make bloody, or of a blood-red color; as, an ensanguined hue.","pos":""}],"ENSATE":[{"def":"Having sword-shaped leaves, or appendages; ensiform.","pos":""}],"ENSCALE":[{"def":"To cover with scales.","pos":""}],"ENSCHEDULE":[{"def":"To insert in a schedule.","pos":""}],"ENSCONCE":[{"def":"To cover or shelter, as with a sconce or fort; to place or hide securely; to conceal.","pos":""}],"ENSEAL":[{"def":"To impress with a seal; to mark as with a seal; hence, to ratify.","pos":""}],"ENSEAM":[{"def":"To sew up; to inclose by a seam; hence, to include; to contain.","pos":""}],"ENSEAR":[{"def":"To sear; to dry up.","pos":""}],"ENSEARCH":[{"def":"To make search; to try to find something.","pos":""}],"ENSEEL":[{"def":"To close eyes of; to seel; -- said in reference to a hawk.","pos":""}],"ENSEINT":[{"def":"With child; pregnant.","pos":""}],"ENSEMBLE":[{"def":"The whole; all the parts taken together.","pos":""}],"ENSHIELD":[{"def":"To defend, as with a shield; to shield.","pos":""}],"ENSHRINE":[{"def":"To inclose in a shrine or chest; hence, to preserve or cherish as something sacred; as, to enshrine something in memory.","pos":""}],"ENSHROUD":[{"def":"To cover with, or as with, a shroud; to shroud.","pos":""}],"ENSIFEROUS":[{"def":"Bearing a sword.","pos":""}],"ENSIFORM":[{"def":"Having the form of a sword blade; sword-shaped; as, an ensiform leaf.","pos":""}],"ENSIGN":[{"def":"A flag; a banner; a standard; esp.","pos":""},{"def":"A signal displayed like a standard, to give notice.","pos":""}],"ENSIGNCY":[{"def":"The rank or office of an ensign.","pos":""}],"ENSIGNSHIP":[{"def":"The state or rank of an ensign.","pos":""}],"ENSILAGE":[{"def":"The process of preserving fodder (such as cornstalks, rye, oats, millet, etc.","pos":""},{"def":"The fodder preserved in a silo.","pos":""}],"ENSILE":[{"def":"To store (green fodder) in a silo; to prepare as silage.","pos":""}],"ENSKY":[{"def":"To place in the sky or in heaven.","pos":""}],"ENSLAVE":[{"def":"To reduce to slavery; to make a slave of; to subject to a dominant influence.","pos":""}],"ENSLAVEDNESS":[{"def":"State of being enslaved.","pos":""}],"ENSLAVEMENT":[{"def":"The act of reducing to slavery; state of being enslaved; bondage; servitude.","pos":""}],"ENSLAVER":[{"def":"One who enslaves.","pos":""}],"ENSNARE":[{"def":"To catch in a snare.","pos":""}],"ENSOBER":[{"def":"Sad accidents to ensober his spirits.","pos":""}],"ENSOUL":[{"def":"To indue or imbue (a body) with soul.","pos":""}],"ENSPHERE":[{"def":"To place in a sphere; to envelop.","pos":""},{"def":"To form into a sphere.","pos":""}],"ENSTAMP":[{"def":"To stamp; to mark as It is the motive .","pos":""}],"ENSTATITE":[{"def":"A mineral of the pyroxene group, orthorhombic in crystallization; often fibrous and massive; color grayish white or greenish.","pos":""}],"ENSTATITIC":[{"def":"Relating to enstatite.","pos":""}],"ENSTYLE":[{"def":"To style; to name.","pos":""}],"ENSUABLE":[{"def":"Ensuing; following.","pos":""}],"ENSUE":[{"def":"To follow; to pursue; to follow and overtake.","pos":""}],"ENSWATHE":[{"def":"To swathe; to envelop, as in swaddling clothes.","pos":""}],"ENSWATHEMENT":[{"def":"The act of enswathing, or the state of being enswathed.","pos":""}],"ENSWEEP":[{"def":"To sweep over or across; to pass over rapidly.","pos":""}]}