{"AURA":[{"def":"The peculiar sensation, as of a light vapor, or cold air, rising from the trunk or limbs towards the head, a premonitory symptom of epilepsy or hysterics.","pos":""}],"AURAL":[{"def":"Of or pertaining to the air, or to an aura.","pos":""}],"AURANTIACEOUS":[{"def":"Pertaining to, or resembling, the Aurantiaceæ, an order of plants (formerly considered natural), of which the orange is the type.","pos":""}],"AURATE":[{"def":"A combination of auric acid with a base; as, aurate or potassium.","pos":""}],"AURATED":[{"def":"Combined with auric acid.","pos":""}],"AURELIAN":[{"def":"Of or pertaining to the aurelia.","pos":""}],"AURIC":[{"def":"Pertaining to, or derived from, gold; -- said of those compounds of gold in which this element has its higher valence; as, auric oxide; auric chloride.","pos":""}],"AURICHALCITE":[{"def":"A hydrous carbonate of copper and zinc, found in pale green or blue crystalline aggregations.","pos":""}],"AURICLE":[{"def":"An angular or ear-shaped lobe.","pos":""}],"AURICLED":[{"def":"Having ear-shaped appendages or lobes; auriculate; as, auricled leaves.","pos":""}],"AURICULAR":[{"def":"Pertaining to the auricles of the heart.","pos":""}],"AURICULARIA":[{"def":"A kind of holothurian larva, with soft, blunt appendages.","pos":""}],"AURICULARLY":[{"def":"In an auricular manner.","pos":""}],"AURICULARS":[{"def":"A circle of feathers surrounding the opening of the ear of birds.","pos":""},{"def":"Having ears or appendages like ears; eared.","pos":""}],"AURIFEROUS":[{"def":"Gold-bearing; containing or producing gold.","pos":""}],"AURIFORM":[{"def":"Having the form of the human ear; ear-shaped.","pos":""}],"AURIGA":[{"def":"The Charioteer, or Wagoner, a constellation in the northern hemisphere, situated between Perseus and Gemini.","pos":""}],"AURIGAL":[{"def":"Of or pertaining to a chariot.","pos":""}],"AURIGATION":[{"def":"The act of driving a chariot or a carriage.","pos":""}],"AURIGRAPHY":[{"def":"The art of writing with or in gold.","pos":""}],"AURILAVE":[{"def":"An instrument for cleansing the ear, consisting of a small piece of sponge on an ivory or bone handle.","pos":""}],"AURIN":[{"def":"A red coloring matter derived from phenol; -- called also, in commerce, yellow coralin.","pos":""}],"AURIPHRYGIATE":[{"def":"Embroidered or decorated with gold.","pos":""}],"AURISCOPE":[{"def":"An instrument for examining the condition of the ear.","pos":""}],"AURISCOPY":[{"def":"Examination of the ear by the aid of the auriscope.","pos":""}],"AURIST":[{"def":"One skilled in treating and curing disorders of the ear.","pos":""}],"AURITED":[{"def":"Having lobes like the ear; auriculate.","pos":""}],"AUROCEPHALOUS":[{"def":"Having a gold-colored head.","pos":""}],"AUROCHLORIDE":[{"def":"The trichloride of gold combination with the chloride of another metal, forming a double chloride; -- called also chloraurate.","pos":""}],"AUROCHS":[{"def":"The European bison (Bison bonasus, or Europæus), once widely distributed, but now nearly extinct, except where protected in the Lithuanian forests, and perhaps in the Caucasus.","pos":""}],"AUROCYANIDE":[{"def":"A double cyanide of gold and some other metal or radical; -- called also cyanaurate.","pos":""}],"AURORA":[{"def":"The Roman personification of the dawn of day; the goddess of the morning.","pos":""},{"def":"A species of crowfoot.","pos":""}],"AURORAL":[{"def":"Belonging to, or resembling, the aurora (the dawn or the northern lights); rosy.","pos":""}],"AUROUS":[{"def":"Pertaining to, or derived from, gold; -- said of those compounds of gold in which this element has its lower valence; as, aurous oxide.","pos":""}]}