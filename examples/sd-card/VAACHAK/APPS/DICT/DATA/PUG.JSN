{"PUG":[{"def":"To mix and stir when wet, as clay for bricks, pottery, etc.","pos":""},{"def":"To fill or stop with clay by tamping; to fill in or spread with mortar, as a floor or partition, for the purpose of deadening sound.","pos":""}],"PUG NOSE":[{"def":"A short, thick nose; a snubnose.","pos":""}],"PUG-FACED":[{"def":"Having a face like a monkey or a pug; monkey-faced.","pos":""}],"PUGGING":[{"def":"Mortar or the like, laid between the joists under the boards of a floor, or within a partition, to deaden sound; -- in the United States usually called deafening.","pos":""}],"PUGH":[{"def":"Pshaw! pish! -- a word used in contempt or disdain.","pos":""}],"PUGIL":[{"def":"As much as is taken up between the thumb and two first fingers.","pos":""}],"PUGILISM":[{"def":"The practice of boxing, or fighting with the fist.","pos":""}],"PUGILIST":[{"def":"One who fights with his fists; esp.","pos":""}],"PUGILISTIC":[{"def":"Of or pertaining to pugillism.","pos":""}],"PUGNACIOUS":[{"def":"Disposed to fight; inclined to fighting; quarrelsome; fighting.","pos":""}],"PUGNACITY":[{"def":"Inclination or readiness to fight; quarrelsomeness.","pos":""}]}