{"SPISS":[{"def":"Thick; crowded; compact; dense.","pos":""}],"SPISSATED":[{"def":"Rendered dense or compact, as by evaporation; inspissated; thickened.","pos":""}],"SPISSITUDE":[{"def":"The quality or state of being spissated; as, the spissitude of coagulated blood, or of any coagulum.","pos":""}]}