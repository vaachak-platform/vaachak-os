{"WHIM":[{"def":"The European widgeon.","pos":""}],"WHIMBREL":[{"def":"Any one of several species of small curlews, especially the European species (Numenius phæopus), called also Jack curlew, half curlew, stone curlew, and tang whaup.","pos":""}],"WHIMLING":[{"def":"One given to whims; hence, a weak, childish person; a child.","pos":""}],"WHIMMY":[{"def":"Full of whims; whimsical.","pos":""}],"WHIMPER":[{"def":"To cry with a low, whining, broken voice; to whine; to complain; as, a child whimpers.","pos":""}],"WHIMPERER":[{"def":"One who whimpers.","pos":""}],"WHIMPLE":[{"def":"To whiffle; to veer.","pos":""}],"WHIMSEY":[{"def":"To fill with whimseys, or whims; to make fantastic; to craze.","pos":""}],"WHIMSICAL":[{"def":"Full of, or characterized by, whims; actuated by a whim; having peculiar notions; queer; strange; freakish.","pos":""},{"def":"Odd or fantastic in appearance; quaintly devised; fantastic.","pos":""}],"WHIMSICALITY":[{"def":"The quality or state of being whimsical; whimsicalness.","pos":""}],"WHIMSICALLY":[{"def":"In a whimsical manner; freakishly.","pos":""}],"WHIMSICALNESS":[{"def":"The quality or state of being whimsical; freakishness; whimsical disposition.","pos":""}],"WHIMWHAM":[{"def":"A whimsical thing; an odd device; a trifle; a trinket; a gimcrack.","pos":""},{"def":"A whim, or whimsey; a freak.","pos":""}]}