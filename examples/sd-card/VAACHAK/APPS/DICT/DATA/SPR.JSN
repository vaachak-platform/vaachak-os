{"SPRACK":[{"def":"Quick; lively' alert.","pos":""}],"SPRAG":[{"def":"A billet of wood; a piece of timber used as a prop.","pos":""}],"SPRAIN":[{"def":"To weaken, as a joint, ligament, or muscle, by sudden and excessive exertion, as by wrenching; to overstrain, or stretch injuriously, but without luxation; as, to sprain one's ankle.","pos":""}],"SPRAINTS":[{"def":"The dung of an otter.","pos":""}],"SPRAWL":[{"def":"To spread and stretch the body or limbs carelessly in a horizontal position; to lie with the limbs stretched out ungracefully.","pos":""},{"def":"To spread irregularly, as vines, plants, or tress; to spread ungracefully, as chirography.","pos":""}],"SPRAWLS":[{"def":"Small branches of a tree; twigs; sprays.","pos":""}],"SPRAY":[{"def":"A small shoot or branch; a twig.","pos":""},{"def":"A collective body of small branches; as, the tree has a beautiful spray.","pos":""}],"SPRAYBOARD":[{"def":"See Dashboard, n.","pos":""}],"SPRAYER":[{"def":"One that sprays; any instrument for vaporizing and spraying liquids.","pos":""}],"SPREAD":[{"def":"To extend in length and breadth, or in breadth only; to stretch or expand to a broad or broader surface or extent; to open; to unfurl; as, to spread a carpet; to spread a tent or a sail.","pos":""},{"def":"To extend so as to cover something; to extend to a great or grater extent in every direction; to cause to fill or cover a wide or wider space.","pos":""}],"SPREAD-EAGLE":[{"def":"Characterized by a pretentious, boastful, exaggerated style; defiantly or extravagantly bombastic; as, a spread-eagle orator; a spread-eagle speech.","pos":""}],"SPREADER":[{"def":"One who, or that which, spreads, expands, or propogates.","pos":""},{"def":"A machine for combining and drawing fibers of flax to form a sliver preparatory to spinning.","pos":""}],"SPREADINGLY":[{"def":"Spread\"ing*ly Defn: , adv.","pos":""}],"SPRECHERY":[{"def":"Movables of an inferior description; especially, such as have been collected by depredation.","pos":""}],"SPREE":[{"def":"A merry frolic; especially, a drinking frolic; a carousal.","pos":""}],"SPRENGE":[{"def":"To sprinkle; to scatter.","pos":""}],"SPRENGEL PUMP":[{"def":"A form of air pump in which exhaustion is produced by a stream of mercury running down a narrow tube, in the manner of an aspirator; -- named from the inventor.","pos":""}],"SPRENT":[{"def":"All the ground with purple blood was sprent.","pos":""}],"SPREYND":[{"def":"When spreynd was holy water.","pos":""}],"SPRIG":[{"def":"A small eyebolt ragged or barbed at the point.","pos":""}],"SPRIGGY":[{"def":"Full of sprigs or small branches.","pos":""}],"SPRIGHT":[{"def":"Spirit; mind; soul; state of mind; mood.","pos":""},{"def":"A supernatural being; a spirit; a shade; an apparition; a ghost.","pos":""}],"SPRIGHTFUL":[{"def":"Full of spirit or of life; earnest; vivacious; lively; brisk; nimble; gay.","pos":""}],"SPRIGHTLESS":[{"def":"Destitute of life; dull; sluggish.","pos":""}],"SPRIGHTLINESS":[{"def":"The quality or state of being sprightly; liveliness; life; briskness; vigor; activity; gayety; vivacity.","pos":""}],"SPRIGHTLY":[{"def":"Sprightlike, or spiritlike; lively; brisk; animated; vigorous; airy; gay; as, a sprightly youth; a sprightly air; a sprightly dance.","pos":""}],"SPRING":[{"def":"To leap; to bound; to jump.","pos":""},{"def":"To issue with speed and violence; to move with activity; to dart; to shoot.","pos":""}],"SPRING STEEL":[{"def":"A variety of steel, elastic, strong, and tough, rolled for springs, etc.","pos":""}],"SPRINGAL":[{"def":"An ancient military engine for casting stones and arrows by means of a spring.","pos":""}],"SPRINGBOARD":[{"def":"An elastic board, secured at the ends, or at one end, often by elastic supports, used in performing feats of agility or in exercising.","pos":""},{"def":"A South African gazelle (Gazella euchore) noted for its graceful form and swiftness, and for its peculiar habit of springing lighty and suddenly into the air.","pos":""}],"SPRINGE":[{"def":"A noose fastened to an elastic body, and drawn close with a sudden spring, whereby it catches a bird or other animal; a gin; a snare.","pos":""}],"SPRINGER":[{"def":"A variety of the field spaniel.","pos":""}],"SPRINGHALT":[{"def":"A kind of lameness in horse.","pos":""}],"SPRINGHEAD":[{"def":"A fountain or source.","pos":""}],"SPRINGINESS":[{"def":"The state or quality of being springly.","pos":""}],"SPRINGING":[{"def":"The act or process of one who, or that which, springs.","pos":""},{"def":"Growth; increase; also, that which springs up; a shoot; a plant.","pos":""}],"SPRINGLET":[{"def":"A little spring.","pos":""}],"SPRINGTAIL":[{"def":"Any one of numerous species of small apterous insects belonging to the order Thysanura.","pos":""}],"SPRINGTIDE":[{"def":"The time of spring; springtime.","pos":""}],"SPRINGTIME":[{"def":"The season of spring; springtide.","pos":""}],"SPRINGY":[{"def":"Resembling, having the qualities of, or pertaining to, a spring; elastic; as, springy steel; a springy step.","pos":""},{"def":"Abounding with springs or fountains; wet; spongy; as, springy land.","pos":""}],"SPRINKLE":[{"def":"To scatter in small drops or particles, as water, seed, etc.","pos":""},{"def":"To scatter on; to disperse something over in small drops or particles; to besprinkle; as, to sprinkle the earth with water; to sprinkle a floor with sand.","pos":""}],"SPRINKLER":[{"def":"One who sprinkles.","pos":""},{"def":"An instrument or vessel used in sprinkling; specifically, a watering pot.","pos":""}],"SPRINKLING":[{"def":"The act of one who, or that which, sprinkles.","pos":""},{"def":"A small quantity falling in distinct drops or particles; as, a sprinkling of rain or snow.","pos":""}],"SPRINT":[{"def":"To run very rapidly; to run at full speed.","pos":""}],"SPRINTER":[{"def":"One who sprints; one who runs in sprint races; as, a champion sprinter.","pos":""}],"SPRIT":[{"def":"To throw out with force from a narrow orifice; to eject; to spurt out.","pos":""}],"SPRITE":[{"def":"The green woodpecker, or yaffle.","pos":""},{"def":"See Sprightful, Sprightfully, Sprightliness, Sprightly, etc.","pos":""}],"SPROCKET WHEEL":[{"def":"Same as Chain wheel.","pos":""}],"SPROD":[{"def":"A salmon in its second year.","pos":""}],"SPROUT":[{"def":"To shoot, as the seed of a plant; to germinate; to push out new shoots; hence, to grow like shoots of plants.","pos":""},{"def":"To shoot into ramifications.","pos":""}],"SPRUCE":[{"def":"Any coniferous tree of the genus Picea, as the Norway spruce (P.","pos":""}],"SPRUNG":[{"def":"Said of a spar that has been cracked or strained.","pos":""}],"SPRUNT":[{"def":"To spring up; to germinate; to spring forward or outward.","pos":""}],"SPRUNTLY":[{"def":"In a sprunt manner; smartly; vigorously; youthfully.","pos":""}],"SPRY":[{"def":"Having great power of leaping or running; nimble; active.","pos":""}]}