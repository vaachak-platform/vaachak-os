{"RECLAIM":[{"def":"To claim back; to demand the return of as a right; to attempt to recover possession of.","pos":""}],"RECLAIMABLE":[{"def":"That may be reclaimed.","pos":""}],"RECLAIMANT":[{"def":"One who reclaims; one who cries out against or contradicts.","pos":""}],"RECLAIMER":[{"def":"One who reclaims.","pos":""}],"RECLAIMLESS":[{"def":"That can not be reclaimed.","pos":""}],"RECLAMATION":[{"def":"The act or process of reclaiming.","pos":""},{"def":"Representation made in opposition; remonstrance.","pos":""}],"RECLASP":[{"def":"To clasp or unite again.","pos":""}],"RECLINANT":[{"def":"Bending or leaning backward.","pos":""}],"RECLINATE":[{"def":"Reclined, as a leaf; bent downward, so that the point, as of a stem or leaf, is lower than the base.","pos":""}],"RECLINATION":[{"def":"The angle which the plane of the dial makes with a vertical plane which it intersects in a horizontal line.","pos":""},{"def":"The act or process of removing a cataract, by applying the needle to its anterior surface, and depressing it into the vitreous humor in such a way that front surface of the cataract becomes the upper one and its back surface the lower one.","pos":""}],"RECLINE":[{"def":"To cause or permit to lean, incline, rest, etc.","pos":""}],"RECLINED":[{"def":"Falling or turned downward; reclinate.","pos":""}],"RECLINER":[{"def":"One who, or that which, reclines.","pos":""}],"RECLOTHE":[{"def":"To clothe again.","pos":""}],"RECLUDE":[{"def":"To open; to unclose.","pos":""}],"RECLUSE":[{"def":"Shut up, sequestered; retired from the world or from public notice; solitary; living apart; as, a recluse monk or hermit; a recluse life In meditation deep, recluse From human converse.","pos":""}],"RECLUSELY":[{"def":"In a recluse or solitary manner.","pos":""}],"RECLUSENESS":[{"def":"Quality or state of being recluse.","pos":""}],"RECLUSION":[{"def":"A state of retirement from the world; seclusion.","pos":""}],"RECLUSIVE":[{"def":"Affording retirement from society.","pos":""}],"RECLUSORY":[{"def":"The habitation of a recluse; a hermitage.","pos":""}]}