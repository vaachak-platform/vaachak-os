{"HOIDEN":[{"def":"A rude, clownish youth.","pos":""},{"def":"A rude, bold girl; a romp.","pos":""}],"HOIDENHOOD":[{"def":"State of being a hoiden.","pos":""}],"HOIDENISH":[{"def":"Like, or appropriate to, a hoiden.","pos":""}],"HOIST":[{"def":"To raise; to lift; to elevate; esp.","pos":""}],"HOISTAWAY":[{"def":"A mechanical lift.","pos":""}],"HOIT":[{"def":"To leap; to caper; to romp noisily.","pos":""}],"HOITY-TOITY":[{"def":"Thoughtless; giddy; flighty; also, haughty; patronizing; as, to be in hoity-toity spirits, or to assume hoity-toity airs; used also as an exclamation, denoting surprise or disapprobation, with some degree of contempt.","pos":""}]}