{"RUN":[{"def":"To move rapidly by springing steps so that there is an instant in each step when neither foot touches the ground; -- so distinguished from walking in athletic competition.","pos":""}],"RUN-AROUND":[{"def":"A whitlow running around the finger nail, but not affecting the bone.","pos":""}],"RUNAGATE":[{"def":"A fugitive; a vagabond; an apostate; a renegade.","pos":""}],"RUNAWAY":[{"def":"One who, or that which, flees from danger, duty, restraint, etc.","pos":""},{"def":"The act of running away, esp.","pos":""}],"RUNCH":[{"def":"The wild radish.","pos":""}],"RUNCINATE":[{"def":"Pinnately cut with the lobes pointing downwards, as the leaf of the dandelion.","pos":""}],"RUNDEL":[{"def":"A moat with water in it; also, a small stream; a runlet.","pos":""}],"RUNDLE":[{"def":"One of the pins or trundles of a lantern wheel.","pos":""}],"RUNDLET":[{"def":"A small barrel of no certain dimensions.","pos":""}],"RUNE":[{"def":"Old Norse poetry expressed in runes.","pos":""}],"RUNER":[{"def":"A bard, or learned man, among the ancient Goths.","pos":""}],"RUNG":[{"def":"A floor timber in a ship.","pos":""},{"def":"One of the radial handles projecting from the rim of a steering wheel; also, one of the pins or trundles of a lantern wheel.","pos":""}],"RUNGHEAD":[{"def":"The upper end of a floor timber in a ship.","pos":""}],"RUNIC":[{"def":"Of or pertaining to a rune, to runes, or to the Norsemen; as, runic verses; runic letters; runic names; runic rhyme.","pos":""}],"RUNLET":[{"def":"A little run or stream; a streamlet; a brook.","pos":""}],"RUNNEL":[{"def":"A rivulet or small brook.","pos":""}],"RUNNER":[{"def":"A slender trailing branch which takes root at the joints or end and there forms new plants, as in the strawberry and the common cinquefoil.","pos":""},{"def":"A rope through a block and used to increase the mechanical power of a tackle.","pos":""}],"RUNNING":[{"def":"Extending by a slender climbing or trailing stem; as, a running vine.","pos":""},{"def":"Discharging pus; as, a running sore.","pos":""}],"RUNNINGLY":[{"def":"In a running manner.","pos":""}],"RUNOLOGY":[{"def":"The science of runes.","pos":""}],"RUNROUND":[{"def":"A felon or whitlow.","pos":""}],"RUNT":[{"def":"Any animal which is unusually small, as compared with others of its kind; -- applied particulary to domestic animals.","pos":""},{"def":"A variety of domestic pigeon, related to the barb and carrier.","pos":""}],"RUNTY":[{"def":"Like a runt; diminutive; mean.","pos":""}],"RUNWAY":[{"def":"The channel of a stream.","pos":""},{"def":"The beaten path made, by deer or other animals in passing to and from their feeding grounds.","pos":""}]}