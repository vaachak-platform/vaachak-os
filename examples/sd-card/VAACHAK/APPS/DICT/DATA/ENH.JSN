{"ENHALO":[{"def":"To surround with a halo.","pos":""}],"ENHANCE":[{"def":"To raise or lift up; to exalt.","pos":""},{"def":"To advance; to augment; to increase; to heighten; to make more costly or attractive; as, to enhance the price of commodities; to enhance beauty or kindness; hence, also, to render more heinous; to aggravate; as, to enhance crime.","pos":""}],"ENHANCEMENT":[{"def":"The act of increasing, or state of being increased; augmentation; aggravation; as, the enhancement of value, price, enjoyments, crime.","pos":""}],"ENHANCER":[{"def":"One who enhances; one who, or that which, raises the amount, price, etc.","pos":""}],"ENHARBOR":[{"def":"To find harbor or safety in; to dwell in or inhabit.","pos":""}],"ENHARDEN":[{"def":"To harden; to embolden.","pos":""},{"def":"Of or pertaining to that one of the three kinds of musical scale (diatonic, chromatic, enharmonic) recognized by the ancient Greeks, which consisted of quarter tones and major thirds, and was regarded as the most accurate.","pos":""}],"ENHARMONICALLY":[{"def":"In the enharmonic style or system; in just intonation.","pos":""}],"ENHEARTEN":[{"def":"To give heart to; to fill with courage; to embolden.","pos":""}],"ENHEDGE":[{"def":"To surround as with a hedge.","pos":""}],"ENHUNGER":[{"def":"Those animal passions which vice had .","pos":""}],"ENHYDROS":[{"def":"A variety of chalcedony containing water.","pos":""}],"ENHYDROUS":[{"def":"Having water within; containing fluid drops; -- said of certain crystals.","pos":""}]}