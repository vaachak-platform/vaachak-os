{"CHEAP":[{"def":"A bargain; a purchase; cheapness.","pos":""}],"CHEAPEN":[{"def":"To beat down the price of; to lessen the value of; to depreciate.","pos":""}],"CHEAPENER":[{"def":"One who cheapens.","pos":""},{"def":"A seller of low-priced or second goods; a hawker.","pos":""}],"CHEAPLY":[{"def":"At a small price; at a low value; in a common or inferior manner.","pos":""}],"CHEAPNESS":[{"def":"Lowness in price, considering the usual price, or real value.","pos":""}],"CHEAT":[{"def":"A troublesome grass, growing as a weed in grain fields; -- called also chess.","pos":""},{"def":"The obtaining of property from another by an intentional active distortion of the truth.","pos":""}],"CHEATABLE":[{"def":"Capable of being cheated.","pos":""}],"CHEATABLENESS":[{"def":"Capability of being cheated.","pos":""}]}