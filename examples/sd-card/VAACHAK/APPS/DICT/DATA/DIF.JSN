{"DIFFAME":[{"def":"Evil name; bad reputation; defamation.","pos":""}],"DIFFARREATION":[{"def":"A form of divorce, among the ancient Romans, in which a cake was used.","pos":""}],"DIFFER":[{"def":"To be or stand apart; to disagree; to be unlike; to be distinguished; -- with from.","pos":""},{"def":"To be of unlike or opposite opinion; to disagree in sentiment; -- often with from or with.","pos":""}],"DIFFERENCE":[{"def":"An addition to a coat of arms to distinguish the bearings of two persons, which would otherwise be the same.","pos":""},{"def":"The quality or attribute which is added to those of the genus to constitute a species; a differentia.","pos":""}],"DIFFERENT":[{"def":"Distinct; separate; not the same; other.","pos":""},{"def":"Of various or contrary nature, form, or quality; partially or totally unlike; dissimilar; as, different kinds of food or drink; different states of health; different shapes; different degrees of excellence.","pos":""}],"DIFFERENTIA":[{"def":"The formal or distinguishing part of the essence of a species; the characteristic attribute of a species; specific difference.","pos":""}],"DIFFERENTIAL":[{"def":"Of or pertaining to a differential, or to differentials.","pos":""},{"def":"Relating to differences of motion or leverage; producing effects by such differences; said of mechanism.","pos":""}],"DIFFERENTIALLY":[{"def":"In the way of differentiation.","pos":""}],"DIFFERENTIATE":[{"def":"To obtain the differential, or differential coefficient, of; as, to differentiate an algebraic expression, or an equation.","pos":""}],"DIFFERENTIATION":[{"def":"The act of distinguishing or describing a thing, by giving its different, or specific difference; exact definition or determination.","pos":""}],"DIFFERENTIATOR":[{"def":"One who, or that which, differentiates.","pos":""}],"DIFFERENTLY":[{"def":"In a different manner; variously.","pos":""}],"DIFFERINGLY":[{"def":"In a differing or different manner.","pos":""}],"DIFFICILE":[{"def":"Difficult; hard to manage; stubborn.","pos":""}],"DIFFICILITATE":[{"def":"To make difficult.","pos":""}],"DIFFICULT":[{"def":"Hard to do or to make; beset with difficulty; attended with labor, trouble, or pains; not easy; arduous.","pos":""},{"def":"Hard to manage or to please; not easily wrought upon; austere; stubborn; as, a difficult person.","pos":""}],"DIFFICULTATE":[{"def":"To render difficult; to difficilitate.","pos":""}],"DIFFICULTLY":[{"def":"With difficulty.","pos":""}],"DIFFICULTY":[{"def":"The state of being difficult, or hard to do; hardness; arduousness; -- opposed to easiness or facility; as, the difficulty of a task or enterprise; a work of difficulty.","pos":""},{"def":"Something difficult; a thing hard to do or to understand; that which occasions labor or perplexity, and requires skill perseverance to overcome, solve, or achieve; a hard enterprise; an obstacle; an impediment; as, the difficulties of a science; difficulties in theology.","pos":""}],"DIFFIDE":[{"def":"To be distrustful.","pos":""}],"DIFFIDENCE":[{"def":"The state of being diffident; distrust; want of confidence; doubt of the power, ability, or disposition of others.","pos":""},{"def":"Distrust of one's self or one's own powers; lack of self-reliance; modesty; modest reserve; bashfulness.","pos":""}],"DIFFIDENT":[{"def":"Wanting confidence in others; distrustful.","pos":""},{"def":"Wanting confidence in one's self; distrustful of one's own powers; not self-reliant; timid; modest; bashful; characterized by modest reserve.","pos":""}],"DIFFIDENTLY":[{"def":"In a diffident manner.","pos":""}],"DIFFINITIVE":[{"def":"Definitive; determinate; final.","pos":""}],"DIFFISSION":[{"def":"Act of cleaving or splitting.","pos":""}],"DIFFLATION":[{"def":"A blowing apart or away.","pos":""},{"def":"A flowing off on all sides; fluidity.","pos":""}],"DIFFLUENT":[{"def":"Flowing apart or off; dissolving; not fixed.","pos":""}],"DIFFORM":[{"def":"Irregular in form; -- opposed to uniform; anomalous; hence, unlike; dissimilar; as, to difform corolla, the parts of which do not correspond in size or proportion; difform leaves.","pos":""}],"DIFFORMITY":[{"def":"Irregularity of form; diversity of form; want of uniformity.","pos":""}],"DIFFRACTION":[{"def":"The deflection and decomposition of light in passing by the edges of opaque bodies or through narrow slits, causing the appearance of parallel bands or fringes of prismatic colors, as by the action of a grating of fine lines or bars.","pos":""}],"DIFFRACTIVE":[{"def":"That produces diffraction.","pos":""},{"def":"See Disfranchise, Disfranchisement.","pos":""}],"DIFFUSATE":[{"def":"Material which, in the process of catalysis, has diffused or passed through the separating membrane.","pos":""}],"DIFFUSE":[{"def":"To pour out and cause to spread, as a fluid; to cause to flow on all sides; to send out, or extend, in all directions; to spread; to circulate; to disseminate; to scatter; as to diffuse information.","pos":""}],"DIFFUSED":[{"def":"Spread abroad; dispersed; loose; flowing; diffuse.","pos":""}],"DIFFUSELY":[{"def":"In a diffuse manner.","pos":""}],"DIFFUSENESS":[{"def":"The quality of being diffuse; especially, in writing, the use of a great or excessive number of word to express the meaning; copiousness; verbosity; prolixity.","pos":""}],"DIFFUSER":[{"def":"One who, or that which, diffuses.","pos":""}],"DIFFUSIBILITY":[{"def":"The quality of being diffusible; capability of being poured or spread out.","pos":""}],"DIFFUSIBLE":[{"def":"Capable of passing through animal membranes by osmosis.","pos":""}],"DIFFUSIBLENESS":[{"def":"Dif*fu\"si*ble*ness, n.","pos":""}],"DIFFUSION":[{"def":"The act of passing by osmosis through animal membranes, as in the distribution of poisons, gases, etc.","pos":""}],"DIFFUSIVE":[{"def":"Having the quality of diffusing; capable of spreading every way by flowing; spreading widely; widely reaching; copious; diffuse.","pos":""}],"DIFFUSIVELY":[{"def":"In a diffusive manner.","pos":""}],"DIFFUSIVENESS":[{"def":"The quality or state of being diffusive or diffuse; extensiveness; expansion; dispersion.","pos":""}],"DIFFUSIVITY":[{"def":"Tendency to become diffused; tendency, as of heat, to become equalized by spreading through a conducting medium.","pos":""}]}