{"GRALLAE":[{"def":"An order of birds which formerly included all the waders.","pos":""}],"GRALLATORES":[{"def":"Of or pertaining to the Grallatores, or waders.","pos":""}],"GRALLIC":[{"def":"Pertaining to the Grallæ.","pos":""}],"GRALLINE":[{"def":"Of or pertaining to the Grallæ.","pos":""}],"GRALLOCH":[{"def":"Offal of a deer.","pos":""},{"def":"To remove the offal from (a deer).","pos":""}]}