{"BDELLIUM":[{"def":"An unidentified substance mentioned in the Bible (Gen.","pos":""},{"def":"A gum resin of reddish brown color, brought from India, Persia, and Africa.","pos":""}],"BDELLOIDEA":[{"def":"The order of Annulata which includes the leeches.","pos":""}],"BDELLOMETER":[{"def":"A cupping glass to which are attached a scarificator and an exhausting syringe.","pos":""}],"BDELLOMORPHA":[{"def":"An order of Nemertina, including the large leechlike worms (Malacobdella) often parasitic in clams.","pos":""}]}