{"COIF":[{"def":"From point and saucy ermine down To the plain coif and russet gown.","pos":""}],"COIFFURE":[{"def":"A headdress, or manner of dressing the hair.","pos":""}],"COIGN":[{"def":"From some shielded nook or coign of vantage.","pos":""}],"COIGNE":[{"def":"The practice of quartering one's self as landlord on a tenant; a quartering of one's self on anybody.","pos":""}],"COIL":[{"def":"To wind cylindrically or spirally; as, to coil a rope when not in use; the snake coiled itself before springing.","pos":"verb"},{"def":"To encircle and hold with, or as with, coils.","pos":"verb"}],"COIN":[{"def":"A quoin; a corner or external angle; a wegde.","pos":""},{"def":"A piece of metal on which certain characters are stamped by government authority, making it legally current as money; -- much used in a collective sense.","pos":""}],"COINAGE":[{"def":"The act or process of converting metal into money.","pos":""},{"def":"Coins; the aggregate coin of a time or place.","pos":""}],"COINCIDE":[{"def":"To occupy the same place in space, as two equal triangles, when placed one on the other.","pos":""},{"def":"To occur at the same time; to be contemporaneous; as, the fall of Granada coincided with the discovery of America.","pos":""}],"COINCIDENCE":[{"def":"The condition of occupying the same place in space; as, the coincidence of circles, surfaces, etc.","pos":""},{"def":"The condition or fact of happening at the same time; as, the coincidence of the deaths of John Adams and Thomas Jefferson.","pos":""}],"COINCIDENT":[{"def":"Having coincidence; occupying the same place; contemporaneous; concurrent; -- followed by with.","pos":""}],"COINCIDENTLY":[{"def":"With coincidence.","pos":""}],"COINCIDER":[{"def":"One who coincides with another in an opinion.","pos":""}],"COINDICATION":[{"def":"One of several signs or sumptoms indicating the same fact; as, a coindication of disease.","pos":""}],"COINER":[{"def":"One who makes or stamps coin; a maker of money; -- usually, a maker of counterfeit money.","pos":""},{"def":"An inventor or maker, as of words.","pos":""}],"COINHABITANT":[{"def":"One who dwells with another, or with others.","pos":""}],"COINHERE":[{"def":"To inhere or exist together, as in one substance.","pos":""}],"COINHERITANCE":[{"def":"Joint inheritance.","pos":""}],"COINITIAL":[{"def":"Having a common beginning.","pos":""}],"COINSTANTANEOUS":[{"def":"Happening at the same instant.","pos":""}],"COINSURANCE":[{"def":"Insurance jointly with another or others; specif.","pos":""}],"COINTENSE":[{"def":"Equal in intensity or degree; as, the relations between 6 and 12, and 8 and 16, are cointense.","pos":""}],"COINTENSION":[{"def":"The condition of being of equal in intensity; -- applied to relations; as, 3 : 6 and 6 : 12 are relations of cointension.","pos":""}],"COIR":[{"def":"A material for cordage, matting, etc.","pos":""},{"def":"Cordage or cables, made of this material.","pos":""}],"COISTRIL":[{"def":"An inferior groom or lad employed by an esquire to carry the knight's arms and other necessaries.","pos":""},{"def":"A mean, paltry fellow; a coward.","pos":""}],"COIT":[{"def":"To throw, as a stone.","pos":""}],"COITION":[{"def":"A coming together; sexual intercourse; copulation.","pos":""}]}