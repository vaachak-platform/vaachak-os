{"MISS":[{"def":"In the game of three-card loo, an extra hand, dealt on the table, which may be substituted for the hand dealt to a player.","pos":""}],"MISSA":[{"def":"The service or sacrifice of the Mass.","pos":""}],"MISSAL":[{"def":"The book containing the service of the Mass for the entire year; a Mass book.","pos":""}],"MISSAY":[{"def":"To speak evil of; to slander.","pos":""}],"MISSEEK":[{"def":"To seek for wrongly.","pos":""}],"MISSEEM":[{"def":"To make a false appearance.","pos":""},{"def":"To misbecome; to be misbecoming.","pos":""}],"MISSEL":[{"def":"European thrush (Turdus viscivorus) which feeds on the berries of the mistletoe; -- called also mistletoe thrush and missel.","pos":""}],"MISSEMBLANCE":[{"def":"False resemblance or semblance.","pos":""}],"MISSEND":[{"def":"To send amiss or incorrectly.","pos":""}],"MISSERVE":[{"def":"To serve unfaithfully.","pos":""}],"MISSET":[{"def":"To set pr place wrongly.","pos":""}],"MISSHAPE":[{"def":"To shape ill; to give an ill or unnatural from to; to deform.","pos":""}],"MISSHAPEN":[{"def":"Having a bad or ugly form.","pos":""}],"MISSHEATHED":[{"def":"Sheathed by mistake; wrongly sheathed; sheathed in a wrong place.","pos":""}],"MISSIFICATE":[{"def":"To perform Mass.","pos":""}],"MISSILE":[{"def":"Capable of being thrown; adapted for hurling or to be projected from the hand, or from any instrument or rngine, so as to strike an object at a distance.","pos":""}],"MISSING":[{"def":"Absent from the place where it was expected to be found; lost; wanting; not present when called or looked for.","pos":""}],"MISSINGLY":[{"def":"With a sense of loss.","pos":""}],"MISSION":[{"def":"The act of sending, or the state of being sent; a being sent or delegated by authority, with certain powers for transacting business; comission.","pos":""},{"def":"That with which a messenger or agent is charged; an errand; business or duty on which one is sent; a commission.","pos":""}],"MISSIONARY":[{"def":"One who is sent on a mission; especially, one sent to propagate religion.","pos":""}],"MISSIONER":[{"def":"A missionary; an envoy; one who conducts a mission.","pos":""}],"MISSIS":[{"def":"A mistress; a wife; -- so used by the illiterate.","pos":""}],"MISSISH":[{"def":"Like a miss; prim; affected; sentimental.","pos":""}],"MISSIT":[{"def":"To sit badly or imperfectly upon; to misbecome.","pos":""}],"MISSIVE":[{"def":"Specially sent; intended or prepared to be sent; as, a letter missive.","pos":""}],"MISSOUND":[{"def":"To sound wrongly; to utter or pronounce incorrectly.","pos":""}],"MISSPEAK":[{"def":"To err in speaking.","pos":""}],"MISSPELL":[{"def":"To spell incorrectly.","pos":""}],"MISSPELLING":[{"def":"A wrong spelling.","pos":""}],"MISSPEND":[{"def":"To spend amiss or for wrong purposes; to aquander; to waste; as, to misspend time or money.","pos":""}],"MISSPENDER":[{"def":"One who misspends.","pos":""}],"MISSPENSE":[{"def":"A spending improperly; a wasting.","pos":""}],"MISSTATE":[{"def":"To state wrongly; as, to misstate a question in debate.","pos":""}],"MISSTATEMENT":[{"def":"An incorrect statement.","pos":""}],"MISSTAYED":[{"def":"Having missed stays; -- said of a ship.","pos":""}],"MISSTEP":[{"def":"A wrong step; an error of conduct.","pos":""}],"MISSUGGESTION":[{"def":"Wrong or evil suggestion.","pos":""}],"MISSUMMATION":[{"def":"Wrong summation.","pos":""}],"MISSWEAR":[{"def":"To swear falsely.","pos":""}],"MISSY":[{"def":"An affectionate, or contemptuous, form of miss; a young girl; a miss.","pos":""},{"def":"Like a miss, or girl.","pos":""}]}