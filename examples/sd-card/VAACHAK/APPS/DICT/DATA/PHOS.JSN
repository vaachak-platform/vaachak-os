{"PHOSGENE":[{"def":"Producing, or produced by, the action of light; -- formerly used specifically to designate a gas now called carbonyl chloride.","pos":""}],"PHOSGENITE":[{"def":"A rare mineral occurring in tetragonal crystals of a white, yellow, or grayish color and adamantine luster.","pos":""}],"PHOSPHAM":[{"def":"An inert amorphous white powder, PN2H, obtained by passing ammonia over heated phosphorus.","pos":""}],"PHOSPHATE":[{"def":"A salt of phosphoric acid.","pos":""}],"PHOSPHATIC":[{"def":"Pertaining to, or containing, phosphorus, phosphoric acid, or phosphates; as, phosphatic nodules.","pos":""}],"PHOSPHATURIA":[{"def":"The excessive discharge of phosphates in the urine.","pos":""}],"PHOSPHENE":[{"def":"A luminous impression produced through excitation of the retina by some cause other than the impingement upon it of rays of light, as by pressure upon the eyeball when the lids are closed.","pos":""}],"PHOSPHIDE":[{"def":"A binary compound of phosphorus.","pos":""}],"PHOSPHINE":[{"def":"A colorless gas, PH3, analogous to ammonia, and having a disagreeable odor resembling that of garlic.","pos":""}],"PHOSPHINIC":[{"def":"Pertaining to, or designating, certain acids analogous to the phosphonic acids, but containing two hydrocarbon radicals, and derived from the secondary phosphines by oxidation.","pos":""}],"PHOSPHITE":[{"def":"A salt of phosphorous acid.","pos":""}],"PHOSPHONIC":[{"def":"Pertaining to, or designating, certain derivatives of phosphorous acid containing a hydrocarbon radical, and analogous to the sulphonic acid.","pos":""}],"PHOSPHONIUM":[{"def":"The hypothetical radical PH4, analogous to ammonium, and regarded as the nucleus of certain derivatives of phosphine.","pos":""}],"PHOSPHOR":[{"def":"The planet Venus, when appearing as the morning star; Lucifer.","pos":""}],"PHOSPHOR-BRONZE":[{"def":"A variety of bronze possessing great hardness, elasticity, and toughness, obtained by melting copper with tin phosphide.","pos":""}],"PHOSPHORATE":[{"def":"To impregnate, or combine, with phosphorus or its compounds; as, phosphorated oil.","pos":""}],"PHOSPHORESCE":[{"def":"To shine as phosphorus; to be phosphorescent; to emit a phosphoric light.","pos":""}],"PHOSPHORESCENCE":[{"def":"The quality or state of being phosphorescent; or the act of phosphorescing.","pos":""},{"def":"A phosphoric light.","pos":""}],"PHOSPHORESCENT":[{"def":"Shining with a phosphoric light; luminous without sensible heat.","pos":""},{"def":"A phosphorescent substance.","pos":""}],"PHOSPHORITIC":[{"def":"Pertaining to phosphorite; resembling, or of the nature of, phosphorite.","pos":""}],"PHOSPHORIZED":[{"def":"Containing, or impregnated with, phosphorus.","pos":""}],"PHOSPHOROGENIC":[{"def":"Generating phosphorescence; as, phosphorogenic rays.","pos":""}],"PHOSPHOROSCOPE":[{"def":"An apparatus for observing the phosphorescence produced in different bodies by the action of light, and for measuring its duration.","pos":""}],"PHOSPHOROUS":[{"def":"Of or pertaining to phosphorus; resembling or containing phosphorus; specifically, designating those compounds in which phosphorus has a lower valence as contrasted with phosphoric compounds; as, phosphorous acid, H3PO3.","pos":""}],"PHOSPHORUS":[{"def":"A poisonous nonmetallic element of the nitrogen group, obtained as a white, or yellowish, translucent waxy substance, having a characteristic disagreeable smell.","pos":""},{"def":"Hence, any substance which shines in the dark like phosphorus, as certain phosphorescent bodies.","pos":""}],"PHOSPHORUS STEEL":[{"def":"A steel in which the amount of phosphorus exceeds that of carbon.","pos":""}],"PHOSPHORYL":[{"def":"The radical PO, regarded as the typical nucleus of certain compounds.","pos":""}],"PHOSPHURETED":[{"def":"Impregnated, or combined, with phosphorus.","pos":""}]}