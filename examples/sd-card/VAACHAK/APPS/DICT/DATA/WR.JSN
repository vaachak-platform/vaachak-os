{"WRACK":[{"def":"A thin, flying cloud; a rack.","pos":""}],"WRACKFUL":[{"def":"Ruinous; destructive.","pos":""}],"WRAIN-BOLT":[{"def":"Same as Wringbolt.","pos":""}],"WRAITH":[{"def":"An apparition of a person in his exact likeness, seen before death, or a little after; hence, an apparition; a specter; a vision; an unreal image.","pos":""},{"def":"Sometimes, improperly, a spirit thought to preside over the waters; -- called also water wraith.","pos":""}],"WRANGLE":[{"def":"To argue; to debate; to dispute.","pos":""},{"def":"To dispute angrily; to quarrel peevishly and noisily; to brawl; to altercate.","pos":""}],"WRANGLER":[{"def":"An angry disputant; one who disputes with heat or peevishness.","pos":""},{"def":"One of those who stand in the first rank of honors in the University of Cambridge, England.","pos":""}],"WRANGLERSHIP":[{"def":"The honor or position of being a wrangler at the University of Cambridge, England.","pos":""}],"WRANGLESOME":[{"def":"Contentious; quarrelsome.","pos":""},{"def":"The common wren.","pos":""}],"WRAP":[{"def":"To snatch up; transport; -- chiefly used in the p.","pos":""}],"WRAPPAGE":[{"def":"The act of wrapping.","pos":""},{"def":"That which wraps; envelope; covering.","pos":""}],"WRAPPER":[{"def":"One who, or that which, wraps.","pos":""},{"def":"That in which anything is wrapped, or inclosed; envelope; covering.","pos":""}],"WRAPRASCAL":[{"def":"A kind of coarse upper coat, or overcoat, formerly worn.","pos":""}],"WRASSE":[{"def":"Any one of numerous edible, marine, spiny-finned fishes of the genus Labrus, of which several species are found in the Mediterranean and on the Atlantic coast of Europe.","pos":""}],"WRASTLE":[{"def":"Who wrastleth best naked, with oil enoint.","pos":""}],"WRATH":[{"def":"Violent anger; vehement exasperation; indignation; rage; fury; ire.","pos":""},{"def":"The effects of anger or indignation; the just punishment of an offense or a crime.","pos":""}],"WRATHFUL":[{"def":"Full of wrath; very angry; greatly incensed; ireful; passionate; as, a wrathful man.","pos":""},{"def":"Springing from, or expressing, wrath; as, a wrathful countenance.","pos":""}],"WRATHILY":[{"def":"In a wrathy manner; very angrily; wrathfully.","pos":""}],"WRATHLESS":[{"def":"Free from anger or wrath.","pos":""}],"WRAW":[{"def":"Angry; vexed; wrathful.","pos":""}],"WRAWL":[{"def":"To cry, as a cat; to waul.","pos":""}],"WRAWNESS":[{"def":"Peevishness; ill temper; anger.","pos":""}],"WRAY":[{"def":"To reveal; to disclose.","pos":""}],"WREAK":[{"def":"To reck; to care.","pos":""}],"WREAKER":[{"def":"The stork, the wrekere of avouterye [adultery].","pos":""}],"WREAKFUL":[{"def":"Revengeful; angry; furious.","pos":""}],"WREAKLESS":[{"def":"Unrevengeful; weak.","pos":""}],"WREATH":[{"def":"An appendage to the shield, placed above it, and supporting the crest (see Illust.","pos":""}],"WREATH-SHELL":[{"def":"A marine shell of the genus Turbo.","pos":""}],"WREATHE":[{"def":"To cause to revolve or writhe; to twist about; to turn.","pos":""},{"def":"To twist; to convolve; to wind one about another; to entwine.","pos":""}],"WREATHEN":[{"def":"Twisted; made into a wreath.","pos":""}],"WREATHLESS":[{"def":"Destitute of a wreath.","pos":""}],"WREATHY":[{"def":"Wreathed; twisted; curled; spiral; also, full of wreaths.","pos":""}],"WRECK":[{"def":"See 2d & 3d Wreak.","pos":""}],"WRECK-MASTER":[{"def":"A person appointed by law to take charge of goods, etc.","pos":""}],"WRECKAGE":[{"def":"The act of wrecking, or state of being wrecked.","pos":""},{"def":"That which has been wrecked; remains of a wreck.","pos":""}],"WRECKER":[{"def":"One who causes a wreck, as by false lights, and the like.","pos":""},{"def":"One who searches fro, or works upon, the wrecks of vessels, etc.","pos":""}],"WRECKFUL":[{"def":"Causing wreck; involving ruin; destructive.","pos":""}],"WRECKING":[{"def":"Wreck\"ing, Defn: a.","pos":""}],"WREN":[{"def":"Any one of numerous species of small singing birds belonging to Troglodytes and numerous allied of the family Troglodytidæ.","pos":""},{"def":"Any one of numerous species of small singing birds more or less resembling the true wrens in size and habits.","pos":""}],"WRENCH":[{"def":"The system made up of a force and a couple of forces in a plane perpendicular to that force.","pos":""}],"WREST":[{"def":"To turn; to twist; esp.","pos":""},{"def":"To turn from truth; to twist from its natural or proper use or meaning by violence; to pervert; to distort.","pos":""}],"WRESTLE":[{"def":"To contend, by grappling with, and striving to trip or throw down, an opponent; as, they wrestled skillfully.","pos":""},{"def":"Hence, to struggle; to strive earnestly; to contend.","pos":""}],"WRESTLER":[{"def":"One who wrestles; one who is skillful in wrestling.","pos":""}],"WRESTLING":[{"def":"Act of one who wrestles; specif.","pos":""}],"WRETCH":[{"def":"A miserable person; one profoundly unhappy.","pos":""},{"def":"One sunk in vice or degradation; a base, despicable person; a vile knave; as, a profligate wretch.","pos":""}],"WRETCHED":[{"def":"Very miserable; sunk in, or accompanied by, deep affliction or distress, as from want, anxiety, or grief; calamitous; woeful; very afflicting.","pos":""},{"def":"Worthless; paltry; very poor or mean; miserable; as, a wretched poem; a wretched cabin.","pos":""}],"WRETCHEDLY":[{"def":"In a wretched manner; miserably; despicable.","pos":""}],"WRETCHEDNESS":[{"def":"The quality or state of being wretched; utter misery.","pos":""},{"def":"A wretched object; anything despicably.","pos":""}],"WRETCHLESS":[{"def":"Reckless; hence, disregarded.","pos":""}],"WRIGGLE":[{"def":"To move the body to and fro with short, writhing motions, like a worm; to squirm; to twist uneasily or quickly about.","pos":""}],"WRIGGLER":[{"def":"One who, or that which, wriggles.","pos":""}],"WRIGHT":[{"def":"One who is engaged in a mechanical or manufacturing business; an artificer; a workman; a manufacturer; a mechanic; esp.","pos":""}],"WRIGHTINE":[{"def":"A rare alkaloid found in the bark of an East Indian apocynaceous tree (Wrightia antidysenterica), and extracted as a bitter white crystalline substance.","pos":""}],"WRING":[{"def":"To bend or strain out of its position; as, to wring a mast.","pos":""}],"WRINGBOLT":[{"def":"A bolt used by shipwrights, to bend and secure the planks against the timbers till they are fastened by bolts, spikes, or treenails; -- not to be confounded with ringbolt.","pos":""}],"WRINGER":[{"def":"One who, or that which, wrings; hence, an extortioner.","pos":""},{"def":"A machine for pressing water out of anything, particularly from clothes after they have been washed.","pos":""}],"WRINGING":[{"def":"Wring\"ing, Defn: a.","pos":""}],"WRINGSTAFF":[{"def":"A strong piece of plank used in applying wringbolts.","pos":""}],"WRINKLE":[{"def":"A notion or fancy; a whim; as, to have a new wrinkle.","pos":""}],"WRINKLY":[{"def":"Full of wrinkles; having a tendency to be wrinkled; corrugated; puckered.","pos":""}],"WRIST":[{"def":"The joint, or the region of the joint, between the hand and the arm; the carpus.","pos":""},{"def":"A stud or pin which forms a journal; -- also called wrist pin.","pos":""}],"WRISTBAND":[{"def":"The band of the sleeve of a shirt, or other garment, which covers the wrist.","pos":""}],"WRISTER":[{"def":"A covering for the wrist.","pos":""}],"WRISTLET":[{"def":"An elastic band worn around the wrist, as for the purpose of securing the upper part of a glove.","pos":""}],"WRIT":[{"def":"Writ, archaic Defn: imp.","pos":""}],"WRITABILITY":[{"def":"Ability or capacity to write.","pos":""}],"WRITABLE":[{"def":"Capable of, or suitable for, being written down.","pos":""}],"WRITATIVE":[{"def":"Inclined to much writing; -- correlative to talkative.","pos":""}],"WRITE":[{"def":"To set down, as legible characters; to form the conveyance of meaning; to inscribe on any material by a suitable instrument; as, to write the characters called letters; to write figures.","pos":""},{"def":"To set down for reading; to express in legible or intelligible characters; to inscribe; as, to write a deed; to write a bill of divorcement; hence, specifically, to set down in an epistle; to communicate by letter.","pos":""}],"WRITER":[{"def":"One who writes, or has written; a scribe; a clerk.","pos":""},{"def":"One who is engaged in literary composition as a profession; an author; as, a writer of novels.","pos":""}],"WRITERSHIP":[{"def":"The office of a writer.","pos":""}],"WRITHE":[{"def":"To twist; to turn; now, usually, to twist or turn so as to distort; to wring.","pos":""},{"def":"To wrest; to distort; to pervert.","pos":""}],"WRITHEN":[{"def":"Having a twisted distorted from.","pos":""}],"WRITING":[{"def":"The act or art of forming letters and characters on paper, wood, stone, or other material, for the purpose of recording the ideas which characters and words express, or of communicating them to others by visible signs.","pos":""},{"def":"Anything written or printed; anything expressed in characters or letters; as: (a) Any legal instrument, as a deed, a receipt, a bond, an agreement, or the like.","pos":""}],"WRONG":[{"def":"Twisted; wry; as, a wrong nose.","pos":""},{"def":"Not according to the laws of good morals, whether divine or human; not suitable to the highest and best end; not morally right; deviating from rectitude or duty; not just or equitable; not true; not legal; as, a wrong practice; wrong ideas; wrong inclinations and desires.","pos":""}],"WRONG-TIMED":[{"def":"Done at an improper time; ill-timed.","pos":""}],"WRONGDOER":[{"def":"One who commits a tort or trespass; a trespasser; a tort feasor.","pos":""}],"WRONGDOING":[{"def":"Evil or wicked behavior or action.","pos":""}],"WRONGER":[{"def":"One who wrongs or injures another.","pos":""}],"WRONGFUL":[{"def":"Full of wrong; injurious; unjust; unfair; as, a wrongful taking of property; wrongful dealing.","pos":""}],"WRONGHEAD":[{"def":"A person of a perverse understanding or obstinate character.","pos":""}],"WRONGHEADED":[{"def":"Wrong in opinion or principle; having a perverse understanding; perverse.","pos":""}],"WRONGLESS":[{"def":"Not wrong; void or free from wrong.","pos":""}],"WRONGLY":[{"def":"In a wrong manner; unjustly; erroneously; wrong; amiss; as, he judges wrongly of my motives.","pos":""}],"WRONGNESS":[{"def":"The quality or state of being wrong; wrongfulness; error; fault.","pos":""}],"WRONGOUS":[{"def":"Not right; illegal; as, wrongous imprisonment.","pos":""}],"WROTE":[{"def":"To root with the snout.","pos":""}],"WROTH":[{"def":"Full of wrath; angry; incensed; much exasperated; wrathful.","pos":""}],"WROUGHT":[{"def":"Wrought, Defn: imp.","pos":""}],"WRY":[{"def":"Wrie you in that mantle.","pos":""}],"WRYMOUTH":[{"def":"Any one of several species of large, elongated, marine fishes of the genus Cryptacanthodes, especially C.","pos":""}],"WRYNECK":[{"def":"Any one of several species of Old World birds of the genus Jynx, allied to the woodpeckers; especially, the common European species (J.","pos":""}],"WRYNECKED":[{"def":"Having a distorted neck; having the deformity called wryneck.","pos":""}],"WRYNESS":[{"def":"The quality or state of being wry, or distorted.","pos":""}]}