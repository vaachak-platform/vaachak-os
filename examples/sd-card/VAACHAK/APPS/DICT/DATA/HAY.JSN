{"HAY":[{"def":"A net set around the haunt of an animal, especially of a rabbit.","pos":""}],"HAY-CUTTER":[{"def":"A machine in which hay is chopped short, as fodder for cattle.","pos":""}],"HAYBOTE":[{"def":"An allowance of wood to a tenant for repairing his hedges or fences; hedgebote.","pos":""}],"HAYCOCK":[{"def":"A conical pile or hear of hay in the field.","pos":""}],"HAYFIELD":[{"def":"A field where grass for hay has been cut; a meadow.","pos":""}],"HAYFORK":[{"def":"A fork for pitching and tedding hay.","pos":""}],"HAYLOFT":[{"def":"A loft or scaffold for hay.","pos":""}],"HAYMAKER":[{"def":"One who cuts and cures hay.","pos":""},{"def":"A machine for curing hay in rainy weather.","pos":""}],"HAYMAKING":[{"def":"The operation or work of cutting grass and curing it for hay.","pos":""}],"HAYMOW":[{"def":"A mow or mass of hay laid up in a barn for preservation.","pos":""},{"def":"The place in a barn where hay is deposited.","pos":""}],"HAYRACK":[{"def":"A frame mounted on the running gear of a wagon, and used in hauling hay, straw, sheaves, etc.","pos":""}],"HAYRAKE":[{"def":"A rake for collecting hay; especially, a large rake drawn by a horse or horses.","pos":""}],"HAYRICK":[{"def":"A heap or pile of hay, usually covered with thatch for preservation in the open air.","pos":""}],"HAYSTACK":[{"def":"A stack or conical pile of hay in the open air.","pos":""}],"HAYTIAN":[{"def":"Of pertaining to Hayti.","pos":""},{"def":"A native of Hayti.","pos":""}],"HAYWARD":[{"def":"An officer who is appointed to guard hedges, and to keep cattle from breaking or cropping them, and whose further duty it is to impound animals found running at large.","pos":""}]}