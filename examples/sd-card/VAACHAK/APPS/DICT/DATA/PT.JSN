{"PTARMIGAN":[{"def":"Any grouse of the genus Lagopus, of which numerous species are known.","pos":""}],"PTENOGLOSSA":[{"def":"A division of gastropod mollusks having the teeth of the radula arranged in long transverse rows, somewhat like the barbs of a feather.","pos":""}],"PTENOGLOSSATE":[{"def":"Of or pertaining to the Ptenoglossa.","pos":""}],"PTERANODON":[{"def":"A genus of American Cretaceous pterodactyls destitute of teeth.","pos":""}],"PTERANODONTIA":[{"def":"A group of pterodactyls destitute of teeth, as in the genus Pteranodon.","pos":""}],"PTERICHTHYS":[{"def":"A genus of Devonian fossil fishes with winglike appendages.","pos":""}],"PTERIDOLOGIST":[{"def":"One who is versed in pteridology.","pos":""}],"PTERIDOLOGY":[{"def":"That department of botany which treats of ferns.","pos":""}],"PTERIDOMANIA":[{"def":"A madness, craze, or strong fancy, for ferns.","pos":""}],"PTERIDOPHYTA":[{"def":"A class of flowerless plants, embracing ferns, horsetails, club mosses, quillworts, and other like plants.","pos":""}],"PTEROBRANCHIA":[{"def":"An order of marine Bryozoa, having a bilobed lophophore and an axial cord.","pos":""}],"PTEROCERAS":[{"def":"A genus of large marine gastropods having the outer border of the lip divided into lobes; -- called also scorpion shell.","pos":""}],"PTEROCLETES":[{"def":"A division of birds including the sand grouse.","pos":""}],"PTERODACTYL":[{"def":"An extinct flying reptile; one of the Pterosauria.","pos":""}],"PTERODACTYLI":[{"def":"Same as Pterosauria.","pos":""}],"PTEROGLOSSAL":[{"def":"Having the tongue finely notched along the sides, so as to have a featherlike appearance, as the toucans.","pos":""}],"PTERON":[{"def":"The region of the skull, in the temporal fossa back of the orbit, where the great wing of the sphenoid, the temporal, the parietal, and the frontal hones approach each other.","pos":""}],"PTEROPAPPI":[{"def":"Same as Odontotormæ.","pos":""}],"PTEROPHORE":[{"def":"Any moth of the genus Pterophorus and allied genera; a plume moth.","pos":""}],"PTEROPOD":[{"def":"One of the Pteropoda.","pos":""}],"PTEROPODA":[{"def":"A class of Mollusca in which the anterior lobes of the foot are developed in the form of broad, thin, winglike organs, with which they swim at near the surface of the sea.","pos":""}],"PTEROPODOUS":[{"def":"Of or pertaining to the Pteropoda.","pos":""}],"PTEROSAURIA":[{"def":"An extinct order of flying reptiles of the Mesozoic age; the pterodactyls; -- called also Pterodactyli, and Ornithosauria.","pos":""}],"PTEROSAURIAN":[{"def":"Of or pertaining to the Pterosauria.","pos":""}],"PTEROSTIGMA":[{"def":"A thickened opaque spot on the wings of certain insects.","pos":""}],"PTEROTIC":[{"def":"Of or pertaining to, or designating, a bone between the proötic and epiotic in the dorsal and outer part of the periotic capsule of many fishes.","pos":""},{"def":"The pterotic bone.","pos":""}],"PTERYGIUM":[{"def":"A superficial growth of vascular tissue radiating in a fanlike manner from the cornea over the surface of the eye.","pos":""}],"PTERYGOID":[{"def":"A pterygoid bone.","pos":""}],"PTERYGOMAXILLARY":[{"def":"Of or pertaining to the inner pterygoid plate, or pterygoid bone, and the lower jaw.","pos":""}],"PTERYGOPALATINE":[{"def":"Of or pertaining to the pterygoid processes and the palatine bones.","pos":""}],"PTERYGOPODIUM":[{"def":"A specially modified part of the ventral fin in male elasmobranchs, which serves as a copulatory organ, or clasper.","pos":""}],"PTERYGOQUADRATE":[{"def":"Of, pertaining to, or representing the pterygoid and quadrate bones or cartilages.","pos":""}],"PTERYLA":[{"def":"One of the definite areas of the skin of a bird on which feathers grow; -- contrasted with apteria.","pos":""}],"PTERYLOGRAPHY":[{"def":"The study or description of the arrangement of feathers, or of the pterylæ, of birds.","pos":""}],"PTERYLOSIS":[{"def":"The arrangement of feathers in definite areas.","pos":""}],"PTILOPAEDES":[{"def":"Same as Dasypædes.","pos":""}],"PTILOPAEDIC":[{"def":"Having nearly the whole surface of the skin covered with down; dasypædic; -- said of the young of certain birds.","pos":""}],"PTILOPTERI":[{"def":"An order of birds including only the penguins.","pos":""}],"PTILOSIS":[{"def":"Same as Pterylosis.","pos":""}],"PTISAN":[{"def":"An aqueous medicine, containing little, if any, medicinal agent; a tea or tisane.","pos":""}],"PTOLEMAIC":[{"def":"Of or pertaining to Ptolemy, the geographer and astronomer.","pos":""}],"PTOLEMAIST":[{"def":"One who accepts the astronomical system of Ptolemy.","pos":""}],"PTOMAINE":[{"def":"One of a class of animal bases or alkaloids formed in the putrefaction of various kinds of albuminous matter, and closely related to the vegetable alkaloids; a cadaveric poison.","pos":""}],"PTOSIS":[{"def":"Drooping of the upper eyelid, produced by paralysis of its levator muscle.","pos":""}],"PTYALIN":[{"def":"An unorganized amylolytic ferment, on enzyme, present in human mixed saliva and in the saliva of some animals.","pos":""}],"PTYALISM":[{"def":"Salivation, or an excessive flow of saliva.","pos":""}],"PTYSMAGOGUE":[{"def":"A medicine that promotes the discharge of saliva.","pos":""}],"PTYXIS":[{"def":"The way in which a leaf is sometimes folded in the bud.","pos":""}]}