{"CROFT":[{"def":"A small, inclosed field, adjoining a house; a small farm.","pos":""}],"CROFTER":[{"def":"One who rents and tills a small farm or helding; as, the crofters of Scotland.","pos":""}],"CROFTING":[{"def":"Exposing linen to the sun, on the grass, in the process of bleaching.","pos":""}],"CROFTLAND":[{"def":"Land of superior quality, on which successive crops are raised.","pos":""}],"CROFTON SYSTEM":[{"def":"A system of prison discipline employing for consecutive periods cellular confinement, associated imprisonment under the mark system, restraint intermediate between imprisonment and freedom, and liberation on ticket of leave.","pos":""}]}