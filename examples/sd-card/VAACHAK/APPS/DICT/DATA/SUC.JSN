{"SUCCADE":[{"def":"Sweetmeats, or preserves in sugar, whether fruit, vegetables, or confections.","pos":""}],"SUCCEDANEOUS":[{"def":"Pertaining to, or acting as, a succedaneum; supplying the place of something else; being, or employed as, a substitute for another.","pos":""}],"SUCCEDANEUM":[{"def":"One who, or that which, succeeds to the place of another; that which is used for something else; a substitute; specifically (Med.","pos":""},{"def":"a remedy used as a substitute for another.","pos":""}],"SUCCEED":[{"def":"To follow in order; to come next after; hence, to take the place of; as, the king's eldest son succeeds his father on the throne; autumn succeeds summer.","pos":""},{"def":"To fall heir to; to inherit.","pos":""}],"SUCCEEDANT":[{"def":"Succeeding one another; following.","pos":""}],"SUCCEEDING":[{"def":"The act of one who, or that which, succeeds; also, that which succeeds, or follows after; consequence.","pos":""}],"SUCCESS":[{"def":"Act of succeeding; succession.","pos":""},{"def":"That which comes after; hence, consequence, issue, or result, of an endeavor or undertaking, whether good or bad; the outcome of effort.","pos":""}],"SUCCESSARY":[{"def":"My peculiar honors, not derived From successary, but purchased with my blood.","pos":""}],"SUCCESSFUL":[{"def":"Resulting in success; assuring, or promotive of, success; accomplishing what was proposed; having the desired effect; hence, prosperous; fortunate; happy; as, a successful use of medicine; a successful experiment; a successful enterprise.","pos":""}],"SUCCESSION":[{"def":"The act of succeeding, or following after; a following of things in order of time or place, or a series of things so following; sequence; as, a succession of good crops; a succession of disasters.","pos":""},{"def":"A series of persons or things according to some established rule of precedence; as, a succession of kings, or of bishops; a succession of events in chronology.","pos":""}],"SUCCESSIONAL":[{"def":"Of or pertaining to a succession; existing in a regular order; consecutive.","pos":""}],"SUCCESSIONIST":[{"def":"A person who insists on the importance of a regular succession of events, offices, etc.","pos":""}],"SUCCESSIVE":[{"def":"Following in order or in uninterrupted course; coming after without interruption or interval; following one after another in a line or series; consecutive; as, the successive revolution of years; the successive kings of Egypt; successive strokes of a hammer.","pos":""},{"def":"Having or giving the right of succeeding to an inheritance; inherited by succession; hereditary; as, a successive title; a successive empire.","pos":""}],"SUCCESSIVELY":[{"def":"In a successive manner.","pos":""}],"SUCCESSIVENESS":[{"def":"The quality or state of being successive.","pos":""}],"SUCCESSLESS":[{"def":"Having no success.","pos":""}],"SUCCESSOR":[{"def":"One who succeeds or follows; one who takes the place which another has left, and sustains the like part or character; -- correlative to predecessor; as, the successor of a deceased king.","pos":""}],"SUCCIDUOUS":[{"def":"Ready to fall; falling.","pos":""}],"SUCCIFEROUS":[{"def":"Producing or conveying sap.","pos":""}],"SUCCINAMATE":[{"def":"A salt of succinamic acid.","pos":""}],"SUCCINAMIC":[{"def":"Of, pertaining to, or designating, an acid amide derivative of succinic acid, obtained as a white crystalline substance, and forming a series of salts.","pos":""}],"SUCCINATE":[{"def":"A salt of succinic acid.","pos":""}],"SUCCINCT":[{"def":"Girded or tucked up; bound; drawn tightly together.","pos":""},{"def":"Compressed into a narrow compass; brief; concise.","pos":""}],"SUCCINIC":[{"def":"Pertaining to, or derived from, amber; specif.","pos":""}],"SUCCINIMIDE":[{"def":"A white crystalline nitrogenous substance, C2H4.","pos":""}],"SUCCINURATE":[{"def":"A salt of succinuric acid.","pos":""}],"SUCCINURIC":[{"def":"Pertaining to, or designating, an acid amide, analogous to succinamic acid, which is obtained as a white crystalline substance by heating urea with succinic anhydride.","pos":""}],"SUCCINYL":[{"def":"A hypothetical radical characteristic of succinic acid and certain of its derivatives.","pos":""}],"SUCCISE":[{"def":"Appearing as if a part were cut off at the extremity.","pos":""}],"SUCCISION":[{"def":"The act of cutting down, as of trees; the act of cutting off.","pos":""}],"SUCCOR":[{"def":"tiono run to, or run to support; hence, to help or relieve when in difficulty, want, or distress; to assist and deliver from suffering; to relieve; as, to succor a besieged city.","pos":""}],"SUCCORABLE":[{"def":"Capable of being succored or assisted; admitting of relief.","pos":""}],"SUCCORER":[{"def":"One who affords succor; a helper.","pos":""}],"SUCCORLESS":[{"def":"Destitute of succor.","pos":""}],"SUCCORY":[{"def":"A plant of the genus Cichorium.","pos":""}],"SUCCOTASH":[{"def":"Green maize and beans boiled together.","pos":""}],"SUCCUBA":[{"def":"A female demon or fiend.","pos":""}],"SUCCUBINE":[{"def":"Of or pertaining to succuba.","pos":""}],"SUCCUBOUS":[{"def":"Having the leaves so placed that the upper part of each one is covered by the base of the next higher leaf, as in hepatic mosses of the genus Plagiochila.","pos":""}],"SUCCUBUS":[{"def":"A demon or fiend; especially, a lascivious spirit supposed to have sexual intercourse with the men by night; a succuba.","pos":""}],"SUCCULA":[{"def":"A bare axis or cylinder with staves or levers in it to turn it round, but without any drum.","pos":""},{"def":"The quality or condition of being succulent; juiciness; as, the succulence of a peach.","pos":""}],"SUCCULENT":[{"def":"Full of juice; juicy.","pos":""}],"SUCCULENTLY":[{"def":"In a succulent manner.","pos":""}],"SUCCULOUS":[{"def":"Succulent; juicy.","pos":""}],"SUCCUMB":[{"def":"To yield; to submit; to give up unresistingly; as, to succumb under calamities; to succumb to disease.","pos":""}],"SUCCUMBENT":[{"def":"Submissive; yielding.","pos":""}],"SUCCURSAL":[{"def":"Serving to aid or help; serving as a chapel of ease; tributary.","pos":""}],"SUCCUS":[{"def":"The expressed juice of a plant, for medicinal use.","pos":""}],"SUCCUSSATION":[{"def":"A trot or trotting.","pos":""},{"def":"A shaking; succussion.","pos":""}],"SUCCUSSION":[{"def":"The act of shaking; a shake; esp.","pos":""}],"SUCCUSSIVE":[{"def":"Characterized by a shaking motion, especially an up and down movement, and not merely tremulous oscillation; as, the succussive motion in earthquakes.","pos":""}],"SUCH":[{"def":"Having the particular quality or character specified.","pos":""}],"SUCHOSPONDYLOUS":[{"def":"Having dorsal vertebræ with long and divided transverse processes; -- applied to certain reptiles.","pos":""}],"SUCHWISE":[{"def":"In a such a manner; so.","pos":""}],"SUCK":[{"def":"To draw, as a liquid, by the action of the mouth and tongue, which tends to produce a vacuum, and causes the liquid to rush in by atmospheric pressure; to draw, or apply force to, by exhausting the air.","pos":""},{"def":"To draw liquid from by the action of the mouth; as, to suck an orange; specifically, to draw milk from (the mother, the breast, etc.","pos":""}],"SUCKANHOCK":[{"def":"A kind of seawan.","pos":""}],"SUCKEN":[{"def":"The jurisdiction of a mill, or that extent of ground astricted to it, the tenants of which are bound to bring their grain thither to be ground.","pos":""}],"SUCKER":[{"def":"A shoot from the roots or lower part of the stem of a plant; -- so called, perhaps, from diverting nourishment from the body of the plant.","pos":""}],"SUCKER STATE":[{"def":"Illinois; -- a nickname.","pos":""}],"SUCKET":[{"def":"A sweetmeat; a dainty morsel.","pos":""}],"SUCKING":[{"def":"Drawing milk from the mother or dam; hence, colloquially, young, inexperienced, as, a sucking infant; a sucking calf.","pos":""}],"SUCKLE":[{"def":"To give suck to; to nurse at the breast.","pos":""}],"SUCKLER":[{"def":"An animal that suckles its young; a mammal.","pos":""}],"SUCKLING":[{"def":"A young child or animal nursed at the breast.","pos":""},{"def":"A small kind of yellow clover (Trifolium filiforme) common in Southern Europe.","pos":""}],"SUCRATE":[{"def":"A compound of sucrose (or of some related carbohydrate) with some base, after the analogy of a salt; as, sodium sucrate.","pos":""}],"SUCRE":[{"def":"A silver coin of Ecuador, worth 68 cents.","pos":""}],"SUCROSE":[{"def":"A common variety of sugar found in the juices of many plants, as the sugar cane, sorghum, sugar maple, beet root, etc.","pos":""}],"SUCTION":[{"def":"The act or process of sucking; the act of drawing, as fluids, by exhausting the air.","pos":""}],"SUCTORIA":[{"def":"An order of Infusoria having the body armed with somewhat stiff, tubular processes which they use as suckers in obtaining their food.","pos":""},{"def":"Same as Rhizocephala.","pos":""}],"SUCTORIAL":[{"def":"Adapted for sucking; living by sucking; as, the humming birds are suctorial birds.","pos":""},{"def":"Capable of adhering by suction; as, the suctorial fishes.","pos":""}],"SUCTORIAN":[{"def":"A cartilaginous fish with a mouth adapted for suction, as the lampery.","pos":""},{"def":"One of the Suctoria.","pos":""}]}