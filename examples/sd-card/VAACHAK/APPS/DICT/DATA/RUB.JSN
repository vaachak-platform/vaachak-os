{"RUB":[{"def":"To subject (a body) to the action of something moving over its surface with pressure and friction, especially to the action of something moving back and forth; as, to rub the flesh with the hand; to rub wood with sandpaper.","pos":""},{"def":"To move over the surface of (a body) with pressure and friction; to graze; to chafe; as, the boat rubs the ground.","pos":""}],"RUBA-DUB":[{"def":"The sound of a drum when continuously beaten; hence, a clamorous, repeated sound; a clatter.","pos":""}],"RUBAIYAT":[{"def":"Quatrians; as, the Rubaiyat of Omar Khayyam.","pos":""}],"RUBATO":[{"def":"Robbed; borrowed.","pos":""}],"RUBBER":[{"def":"One who, or that which, rubs.","pos":""},{"def":"In some games, as whist, the odd game, as the third or the fifth, when there is a tie between the players; as, to play the rubber; also, a contest determined by the winning of two out of three games; as, to play a rubber of whist.","pos":""}],"RUBBERIZE":[{"def":"To coat or impregnate with rubber or a rubber solution or preparation, as silk.","pos":""}],"RUBBISH":[{"def":"Waste or rejected matter; anything worthless; valueless stuff; trash; especially, fragments of building materials or fallen buildings; ruins; débris.","pos":""}],"RUBBLE":[{"def":"A mass or stratum of fragments or rock lying under the alluvium, and derived from the neighboring rock.","pos":""},{"def":"The whole of the bran of wheat before it is sorted into pollard, bran, etc.","pos":""}],"RUBBLESTONE":[{"def":"See Rubble, 1 and 2.","pos":""}],"RUBBLEWORK":[{"def":"Masonry constructed of unsquared stones that are irregular in size and shape.","pos":""}],"RUBBLY":[{"def":"Relating to, or containing, rubble.","pos":""}],"RUBEFACIENT":[{"def":"An external application which produces redness of the skin.","pos":""}],"RUBEFACTION":[{"def":"The act or process of making red.","pos":""}],"RUBELET":[{"def":"A red color used in enameling.","pos":""}],"RUBELLA":[{"def":"An acute specific disease with a dusky red cutaneous eruption resembling that of measles, but unattended by catarrhal symptoms; -- called also German measles.","pos":""}],"RUBELLITE":[{"def":"A variety of tourmaline varying in color from a pale rose to a deep ruby, and containing lithium.","pos":""}],"RUBERYTHRINIC":[{"def":"Pertaining to, or designating, an acid extracted from madder root.","pos":""}],"RUBESCENCE":[{"def":"The quality or state of being rubescent; a reddening; a flush.","pos":""}],"RUBESCENT":[{"def":"Growing or becoming red; tending to redness.","pos":""}],"RUBIACEOUS":[{"def":"Of or pertaining to a very large natural order of plants (Rubiaceæ) named after the madder (Rubia tinctoria), and including about three hundred and seventy genera and over four thousand species.","pos":""}],"RUBIACIN":[{"def":"A substance found in madder root, and probably identical with ruberythrinic acid.","pos":""}],"RUBIAN":[{"def":"One of several color-producing glycosides found in madder root.","pos":""}],"RUBIANIC":[{"def":"pertaining to, or derived from, rubian; specifically, designating an acid called also ruberythrinic acid.","pos":""}],"RUBICAN":[{"def":"Colored a prevailing red, bay, or black, with flecks of white or gray especially on the flanks; -- said of horses.","pos":""}],"RUBICELLE":[{"def":"A variety of ruby of a yellowish red color, from Brazil.","pos":""}],"RUBICON":[{"def":"A small river which separated Italy from Cisalpine Gaul, the province alloted to Julius Cæsar.","pos":""}],"RUBICUND":[{"def":"Inclining to redness; ruddy; red.","pos":""}],"RUBICUNDITY":[{"def":"The quality or state of being rubicund; ruddiness.","pos":""}],"RUBIDIC":[{"def":"Of or pertaining to rubidium; containing rubidium.","pos":""}],"RUBIDINE":[{"def":"A nitrogenous base homologous with pyridine, obtained from coal tar as an oily liquid, C11H17N; also, any one of the group od metameric compounds of which rubidine is the type.","pos":""}],"RUBIDIUM":[{"def":"A rare metallic element.","pos":""}],"RUBIFIC":[{"def":"Making red; as, rubific rays.","pos":""}],"RUBIFICATION":[{"def":"The act of making red.","pos":""}],"RUBIFORM":[{"def":"Having the nature or quality of red; as, the rubiform rays of the sun.","pos":""}],"RUBIFY":[{"def":"Having the appearance or color of iron rust; rusty-looking.","pos":""}],"RUBIGO":[{"def":"same as Rust, n.","pos":""}],"RUBIRETIN":[{"def":"One of the red dye products extracted from madder root, and probably identical with ruberythrinic acid.","pos":""}],"RUBLE":[{"def":"The unit of monetary value in Russia.","pos":""}],"RUBRIC":[{"def":"That part of any work in the early manuscripts and typography which was colored red, to distinguish it from other portions.","pos":""}],"RUBRICATE":[{"def":"Marked with red.","pos":""}],"RUBSTONE":[{"def":"A stone for scouring or rubbing; a whetstone; a rub.","pos":""}],"RUBUS":[{"def":"A genus of rosaceous plants, including the raspberry and blackberry.","pos":""}],"RUBY":[{"def":"A precious stone of a carmine red color, sometimes verging to violet, or intermediate between carmine and hyacinth red.","pos":""}],"RUBY-TAILED":[{"def":"Having the tail, or lower part of the body, bright red.","pos":""}],"RUBYTAIL":[{"def":"A European gold wasp (Chrysis ignita) which has the under side of the abdomen bright red, and the other parts deep bluish green with a metallic luster.","pos":""}],"RUBYTHROAT":[{"def":"Any one of numerous species of humming birds belonging to Trochilus, Calypte, Stellula, and allies, in which the male has on the throat a brilliant patch of red feathers having metallic reflections; esp.","pos":""}]}