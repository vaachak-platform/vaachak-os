{"SCIAENOID":[{"def":"Of or pertaining to the Sciænidæ, a family of marine fishes which includes the meagre, the squeteague, and the kingfish.","pos":""}],"SCIAGRAPH":[{"def":"An old term for a vertical section of a building; -- called also sciagraphy.","pos":""}],"SCIAGRAPHICAL":[{"def":"Pertaining to sciagraphy.","pos":""}],"SCIAGRAPHY":[{"def":"Same as Siagraph.","pos":""}],"SCIAMACHY":[{"def":"Belonging to a sundial.","pos":""}],"SCIATIC":[{"def":"Of or pertaining to the hip; in the region of, or affecting, the hip; ischial; ischiatic; as, the sciatic nerve, sciatic pains.","pos":""}],"SCIATICA":[{"def":"Neuralgia of the sciatic nerve, an affection characterized by paroxysmal attacks of pain in the buttock, back of the thing, or in the leg or foot, following the course of the branches of the sciatic nerve.","pos":""}],"SCIATICALLY":[{"def":"With, or by means of, sciatica.","pos":""}],"SCIENCE":[{"def":"Knowledge; knowledge of principles and causes; ascertained truth of facts.","pos":""},{"def":"Accumulated and established knowledge, which has been systematized and formulated with reference to the discovery of general truths or the operation of general laws; knowledge classified and made available in work, life, or the search for truth; comprehensive, profound, or philosophical knowledge.","pos":""}],"SCIENT":[{"def":"Knowing; skillful.","pos":""}],"SCIENTER":[{"def":"Knowingly; willfully.","pos":""}],"SCIENTIAL":[{"def":"Pertaining to, or producing, science.","pos":""}],"SCIENTIFIC":[{"def":"Of or pertaining to science; used in science; as, scientific principles; scientific apparatus; scientific observations.","pos":""},{"def":"Agreeing with, or depending on, the rules or principles of science; as, a scientific classification; a scientific arrangement of fossils.","pos":""}],"SCIENTIFICALLY":[{"def":"In a scientific manner; according to the rules or principles of science.","pos":""}],"SCIENTIST":[{"def":"One learned in science; a scientific investigator; one devoted to scientific study; a savant.","pos":""}],"SCILICET":[{"def":"To wit; namely; videlicet; -- often abbreviated to sc.","pos":""}],"SCILLAIN":[{"def":"A glucoside extracted from squill (Scilla) as a light porous substance.","pos":""}],"SCILLITIN":[{"def":"A bitter principle extracted from the bulbs of the squill (Scilla), and probably consisting of a complex mixture of several substances.","pos":""}],"SCINCOID":[{"def":"Of or pertaining to the family Scincidæ, or skinks.","pos":""}],"SCINCOIDEA":[{"def":"A tribe of lizards including the skinks.","pos":""}],"SCINCOIDIAN":[{"def":"Any one of numerous species of lizards of the family Scincidæ or tribe Scincoidea.","pos":""}],"SCINIPH":[{"def":"Some kind of stinging or biting insect, as a flea, a gnat, a sandly, or the like.","pos":""}],"SCINTILLA":[{"def":"A spark; the least particle; an iota; a tittle.","pos":""}],"SCINTILLANT":[{"def":"Emitting sparks, or fine igneous particles; sparkling.","pos":""}],"SCINTILLATE":[{"def":"To emit sparks, or fine igneous particles.","pos":""},{"def":"To sparkle, as the fixed stars.","pos":""}],"SCINTILLATION":[{"def":"The act of scintillating.","pos":""},{"def":"A spark of flash emitted in scintillating.","pos":""}],"SCINTILLOUSLY":[{"def":"In a scintillant manner.","pos":""}],"SCIOLISM":[{"def":"The knowledge of a sciolist; superficial knowledge.","pos":""}],"SCIOLIST":[{"def":"One who knows many things superficially; a pretender to science; a smatterer.","pos":""}],"SCIOLISTIC":[{"def":"Of or pertaining to sciolism, or a sciolist; partaking of sciolism; resembling a sciolist.","pos":""}],"SCIOLOUS":[{"def":"Knowing superficially or imperfectly.","pos":""}],"SCIOMACHY":[{"def":"A fighting with a shadow; a mock contest; an imaginary or futile combat.","pos":""}],"SCIOMANCY":[{"def":"Divination by means of shadows.","pos":""}],"SCION":[{"def":"Hence, a descendant; an heir; as, a scion of a royal stock.","pos":""}],"SCIOPTIC":[{"def":"Of or pertaining to an optical arrangement for forming images in a darkened room, usually called scioptic ball.","pos":""}],"SCIOPTICON":[{"def":"A kind of magic lantorn.","pos":""}],"SCIOPTICS":[{"def":"The art or process of exhibiting luminous images, especially those of external objects, in a darkened room, by arrangements of lenses or mirrors.","pos":""}],"SCIOT":[{"def":"Of or pertaining to the island Scio (Chio or Chios).","pos":""},{"def":"A native or inhabitant of Scio.","pos":""}],"SCIOTHERIC":[{"def":"Of or pertaining to a sundial.","pos":""}],"SCIOUS":[{"def":"Knowing; having knowledge.","pos":""}],"SCIRE FACIAS":[{"def":"A judicial writ, founded upon some record, and requiring the party proceeded against to show cause why the party bringing it should not have advantage of such record, or (as in the case of scire facias to repeal letters patent) why the record should not be annulled or vacated.","pos":""}],"SCIRRHOID":[{"def":"Resembling scirrhus.","pos":""}],"SCIRRHOSITY":[{"def":"A morbid induration, as of a gland; stste of being scirrhous.","pos":""}],"SCIRRHOUS":[{"def":"Proceeding from scirrhus; of the nature of scirrhus; indurated; knotty; as, scirrhous affections; scirrhous disease.","pos":""}],"SCISCITATION":[{"def":"The act of inquiring; inquiry; demand.","pos":""}],"SCISE":[{"def":"To cut; to penetrate.","pos":""}],"SCISSEL":[{"def":"The clippings of metals made in various mechanical operations.","pos":""},{"def":"The slips or plates of metal out of which circular balnks have been cut for the purpose of coinage.","pos":""}],"SCISSIBLE":[{"def":"Capable of being cut or divided by a sharp instrument.","pos":""}],"SCISSILE":[{"def":"Capable of being cut smoothly; scissible.","pos":""}],"SCISSION":[{"def":"The act of dividing with an instrument having a sharp edge.","pos":""}],"SCISSIPARITY":[{"def":"Reproduction by fission.","pos":""}],"SCISSOR":[{"def":"To cut with scissors or shears; to prepare with the aid of scissors.","pos":""}],"SCISSORS":[{"def":"A cutting instrument resembling shears, but smaller, consisting of two cutting blades with handles, movable on a pin in the center, by which they are held together.","pos":""}],"SCISSORS-TAILED":[{"def":"Having the outer feathers much the longest, the others decreasing regularly to the median ones.","pos":""}],"SCISSORSTAIL":[{"def":"A tyrant flycatcher (Milvulus forficatus) of the Southern United States and Mexico, which has a deeply forked tail.","pos":""}],"SCISSURE":[{"def":"A longitudinal opening in a body, made by cutting; a cleft; a fissure.","pos":""}],"SCITAMINEOUS":[{"def":"Of or pertaining to a natural order of plants (Scitamimeæ), mostly tropical herbs, including the ginger, Indian shot, banana, and the plants producing turmeric and arrowroot.","pos":""}],"SCIURINE":[{"def":"Of or pertaining to the Squirrel family.","pos":""},{"def":"A rodent of the Squirrel family.","pos":""}],"SCIUROID":[{"def":"Resembling the tail of a squirrel; -- generally said of branches which are close and dense, or of spikes of grass like barley.","pos":""}],"SCIUROMORPHA":[{"def":"A tribe of rodents containing the squirrels and allied animals, such as the gophers, woodchucks, beavers, and others.","pos":""}],"SCIURUS":[{"def":"A genus of reodents comprising the common squirrels.","pos":""}]}