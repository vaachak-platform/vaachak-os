{"SUBJACENT":[{"def":"Lying under or below.","pos":""},{"def":"Being in a lower situation, though not directly beneath; as, hills and subjacent valleys.","pos":""}],"SUBJECT":[{"def":"Placed or situated under; lying below, or in a lower situation.","pos":""},{"def":"Placed under the power of another; specifically (International Law), owing allegiance to a particular sovereign or state; as, Jamaica is subject to Great Britain.","pos":""}],"SUBJECT-MATTER":[{"def":"The matter or thought presented for consideration in some statement or discussion; that which is made the object of thought or study.","pos":""}],"SUBJECTED":[{"def":"Reduced to subjection; brought under the dominion of another.","pos":""}],"SUBJECTION":[{"def":"The act of subjecting, or of bringing under the dominion of another; the act of subduing.","pos":""},{"def":"The state of being subject, or under the power, control, and government of another; a state of obedience or submissiveness; as, the safety of life, liberty, and property depends on our subjection to the laws.","pos":""}],"SUBJECTIST":[{"def":"One skilled in subjective philosophy; a subjectivist.","pos":""}],"SUBJECTIVE":[{"def":"Modified by, or making prominent, the individuality of a writer or an artist; as, a subjective drama or painting; a subjective writer.","pos":""}],"SUBJECTIVISM":[{"def":"Any philosophical doctrine which refers all knowledge to, and founds it upon, any subjective states; egoism.","pos":""}],"SUBJECTIVIST":[{"def":"One who holds to subjectivism; an egoist.","pos":""}],"SUBJECTIVITY":[{"def":"The quality or state of being subjective; character of the subject.","pos":""}],"SUBJECTLESS":[{"def":"Having no subject.","pos":""}],"SUBJECTNESS":[{"def":"Quality of being subject.","pos":""}],"SUBJICIBLE":[{"def":"Capable of being subjected.","pos":""}],"SUBJOIN":[{"def":"To add after something else has been said or written; to ANNEX; as, to subjoin an argument or reason.","pos":""}],"SUBJOINDER":[{"def":"An additional remark.","pos":""}],"SUBJUGATE":[{"def":"To subdue, and bring under the yoke of power or dominion; to conquer by force, and compel to submit to the government or absolute control of another; to vanquish.","pos":""}],"SUBJUGATION":[{"def":"The act of subjugating, or the state of being subjugated.","pos":""}],"SUBJUGATOR":[{"def":"One who subjugates; a conqueror.","pos":""}],"SUBJUNCTION":[{"def":"Act of subjoining, or state of being subjoined.","pos":""},{"def":"Something subjoined; as, a subjunction to a sentence.","pos":""}],"SUBJUNCTIVE":[{"def":"Subjoined or added to something before said or written.","pos":""}]}