{"MYRCIA":[{"def":"A large genus of tropical American trees and shrubs, nearly related to the true myrtles (Myrtus), from which they differ in having very few seeds in each berry.","pos":""}],"MYRIACANTHOUS":[{"def":"Having numerous spines, as certain fishes.","pos":""}],"MYRIAD":[{"def":"The number of ten thousand; ten thousand persons or things.","pos":""},{"def":"An immense number; a very great many; an indefinitely large number.","pos":""}],"MYRIAPOD":[{"def":"One of the Myriapoda.","pos":""}],"MYRIAPODA":[{"def":"A class, or subclass, of arthropods, related to the hexapod insects, from which they differ in having the body made up of numerous similar segments, nearly all of which bear true jointed legs.","pos":""}],"MYRIARCH":[{"def":"A captain or commander of ten thousand men.","pos":""}],"MYRIARE":[{"def":"A measure of surface in the metric system containing ten thousand ares, or one million square meters.","pos":""}],"MYRICA":[{"def":"A widely dispersed genus of shrubs and trees, usually with aromatic foliage.","pos":""}],"MYRICIN":[{"def":"A silky, crystalline, waxy substance, forming the less soluble part of beeswax, and regarded as a palmitate of a higher alcohol of the paraffin series; -- called also myricyl alcohol.","pos":""}],"MYRICYL":[{"def":"A hypothetical radical regarded as the essential residue of myricin; -- called also melissyl.","pos":""}],"MYRIOLOGICAL":[{"def":"Of or relating to a myriologue.","pos":""}],"MYRIOLOGIST":[{"def":"One who composes or sings a myriologue.","pos":""}],"MYRIOLOGUE":[{"def":"An extemporaneous funeral song, composed and sung by a woman on the death of a friend.","pos":""}],"MYRIOPHYLLOUS":[{"def":"Having an indefinitely great or countless number of leaves.","pos":""}],"MYRIORAMA":[{"def":"A picture made up of several smaller pictures, drawn upon separate pieces in such a manner as to admit of combination in many different ways, thus producing a great variety of scenes or landscapes.","pos":""}],"MYRIOSCOPE":[{"def":"A form of kaleidoscope.","pos":""}],"MYRISTATE":[{"def":"A salt of myristic acid.","pos":""}],"MYRISTIC":[{"def":"Pertaining to, or derived from, the nutmeg (Myristica).","pos":""}],"MYRISTIN":[{"def":"The myristate of glycerin, -- found as a vegetable fat in nutmeg butter, etc.","pos":""}],"MYRISTONE":[{"def":"The ketone of myristic acid, obtained as a white crystalline substance.","pos":""}],"MYRMECOPHYTE":[{"def":"A plant that affords shelter and food to certain species of ants which live in symbiotic relations with it.","pos":""}],"MYRMICINE":[{"def":"Of or pertaining to Myrmica, a genus of ants including the small house ant (M.","pos":""}],"MYRMIDON":[{"def":"One of a fierce tribe or troop who accompained Achilles, their king, to the Trojan war.","pos":""},{"def":"A soldier or a subordinate civil officer who executes cruel orders of a superior without protest or pity; -- sometimes applied to bailiffs, constables, etc.","pos":""}],"MYRMIDONIAN":[{"def":"Consisting of, or like, myrmidons.","pos":""}],"MYRMOTHERINE":[{"def":"Feeding upon ants; -- said of certain birds.","pos":""},{"def":"A dried astringent fruit much resembling a prune.","pos":""}],"MYRONIC":[{"def":"Pertaining to, or obtained from, mustard; -- used specifically to designate a glucoside called myronic acid, found in mustard seed.","pos":""}],"MYROPOLIST":[{"def":"One who sells unguents or perfumery.","pos":""}],"MYROSIN":[{"def":"A ferment, resembling diastase, found in mustard seeds.","pos":""}],"MYROXYLON":[{"def":"A genus of leguminous trees of tropical America, the different species of which yield balsamic products, among which are balsam of Peru, and balsam of Tolu.","pos":""}],"MYRRH":[{"def":"A gum resin, usually of a yellowish brown or amber color, of an aromatic odor, and a bitter, slightly pungent taste.","pos":""}],"MYRRHIC":[{"def":"Of, pertaining to, or obtained from, myrrh.","pos":""}],"MYRTACEOUS":[{"def":"Of, pertaining to, or resembling, a large and important natural order of trees and shrubs (Myrtaceæ), of which the myrtle is the type.","pos":""}],"MYRTIFORM":[{"def":"Resembling myrtle or myrtle berries; having the form of a myrtle leaf.","pos":""}],"MYRTLE":[{"def":"A species of the genus Myrtus, especially Myrtus communis.","pos":""}]}