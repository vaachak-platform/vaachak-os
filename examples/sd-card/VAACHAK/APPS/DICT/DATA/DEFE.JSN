{"DEFEASANCE":[{"def":"A condition, relating to a deed, which being performed, the deed is defeated or rendered void; or a collateral deed, made at the same time with a feoffment, or other conveyance, containing conditions, on the performance of which the estate then created may be defeated.","pos":""}],"DEFEASANCED":[{"def":"Liable to defeasance; capable of being made void or forfeited.","pos":""}],"DEFEASIBLE":[{"def":"Capable of being annulled or made void; as, a defeasible title.","pos":""}],"DEFEAT":[{"def":"To undo; to disfigure; to destroy.","pos":""},{"def":"To render null and void, as a title; to frustrate, as hope; to deprive, as of an estate.","pos":""}],"DEFEATURE":[{"def":"Overthrow; defeat.","pos":""},{"def":"Disfigurement; deformity.","pos":""}],"DEFEATURED":[{"def":"Changed in features; deformed.","pos":""}],"DEFECATE":[{"def":"Freed from anything that can pollute, as dregs, lees, etc.","pos":""}],"DEFECATION":[{"def":"The act or process of voiding excrement.","pos":""}],"DEFECATOR":[{"def":"That which cleanses or purifies; esp.","pos":""}],"DEFECT":[{"def":"Want or absence of something necessary for completeness or perfection; deficiency; -- opposed to superfluity.","pos":""},{"def":"Failing; fault; imperfection, whether physical or moral; blemish; as, a defect in the ear or eye; a defect in timber or iron; a defect of memory or judgment.","pos":""}],"DEFECTIBILITY":[{"def":"Deficiency; imperfection.","pos":""}],"DEFECTIBLE":[{"def":"Liable to defect; imperfect.","pos":""}],"DEFECTION":[{"def":"Act of abandoning a person or cause to which one is bound by allegiance or duty, or to which one has attached himself; desertion; failure in duty; a falling away; apostasy; backsliding.","pos":""}],"DEFECTIONIST":[{"def":"One who advocates or encourages defection.","pos":""}],"DEFECTIOUS":[{"def":"Having defects; imperfect.","pos":""}],"DEFECTIVE":[{"def":"Lacking some of the usual forms of declension or conjugation; as, a defective noun or verb.","pos":""}],"DEFECTUOSITY":[{"def":"Great imperfection.","pos":""}],"DEFECTUOUS":[{"def":"Full of defects; imperfect.","pos":""}],"DEFEDATION":[{"def":"The act of making foul; pollution.","pos":""}],"DEFEND":[{"def":"To deny the right of the plaintiff in regard to (the suit, or the wrong charged); to oppose or resist, as a claim at law; to contest, as a suit.","pos":""}],"DEFENDABLE":[{"def":"Capable of being defended; defensible.","pos":""}],"DEFENDANT":[{"def":"Serving, or suitable, for defense; defensive.","pos":""}],"DEFENDEE":[{"def":"One who is defended.","pos":""}],"DEFENDER":[{"def":"One who defends; one who maintains, supports, protects, or vindicates; a champion; an advocate; a vindicator.","pos":""}],"DEFENDRESS":[{"def":"A female defender.","pos":""}],"DEFENSATIVE":[{"def":"That which serves to protect or defend.","pos":""},{"def":"The defendant's answer or plea; an opposing or denial of the truth or validity of the plaintiff's or prosecutor's case; the method of proceeding adopted by the defendant to protect himself against the plaintiff's action.","pos":""}],"DEFENSE":[{"def":"To furnish with defenses; to fortify.","pos":""}],"DEFENSELESS":[{"def":"Destitute of defense; unprepared to resist attack; unable to oppose; unprotected.","pos":""}],"DEFENSIBILITY":[{"def":"Capability of being defended.","pos":""}],"DEFENSIBLE":[{"def":"Capable of being defended; as, a defensible city, or a defensible cause.","pos":""},{"def":"Capable of offering defense.","pos":""}],"DEFENSIBLENESS":[{"def":"Capability of being defended; defensibility.","pos":""}],"DEFENSIVE":[{"def":"Serving to defend or protect; proper for defense; opposed to offensive; as, defensive armor.","pos":""},{"def":"Carried on by resisting attack or aggression; -- opposed to offensive; as, defensive war.","pos":""}],"DEFENSIVELY":[{"def":"On the defensive.","pos":""}],"DEFENSOR":[{"def":"A defender or an advocate in court; a guardian or protector.","pos":""},{"def":"The patron of a church; an officer having charge of the temporal affairs of a church.","pos":""}],"DEFENSORY":[{"def":"Tending to defend; defensive; as, defensory preparations.","pos":""}],"DEFER":[{"def":"To put off; to postpone to a future time; to delay the execution of; to delay; to withhold.","pos":""}],"DEFERENCE":[{"def":"A yielding of judgment or preference from respect to the wishes or opinion of another; submission in opinion; regard; respect; complaisance.","pos":""}],"DEFERENT":[{"def":"Serving to carry; bearing.","pos":""}],"DEFERENTIAL":[{"def":"Expressing deference; accustomed to defer.","pos":""}],"DEFERENTIALLY":[{"def":"Def`er*en\"tial*ly, adv.","pos":""}],"DEFERMENT":[{"def":"The act of delaying; postponement.","pos":""}],"DEFERRER":[{"def":"One who defers or puts off.","pos":""},{"def":"The subsidence of a febrile process; as, the stage of defervescence in pneumonia.","pos":""}],"DEFEUDALIZE":[{"def":"To deprive of the feudal character or form.","pos":""}]}