{"POLO":[{"def":"A game of ball of Eastern origin, resembling hockey, with the players on horseback.","pos":""},{"def":"A similar game played on the ice, or on a prepared floor, by players wearing skates.","pos":""}],"POLONAISE":[{"def":"Of or pertaining to the Poles, or to Poland.","pos":""}],"POLONIUM":[{"def":"A supposed new element, a radioactive substance discovered by M.","pos":""}],"POLONY":[{"def":"A kind of sausage made of meat partly cooked.","pos":""}]}