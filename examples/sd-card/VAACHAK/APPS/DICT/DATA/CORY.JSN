{"CORYBANT":[{"def":"One of the priests of Cybele in Phrygia.","pos":""}],"CORYBANTIASM":[{"def":"A kind of frenzy in which the patient is tormented by fantastic visions and want of sleep.","pos":""}],"CORYBANTIC":[{"def":"Of, pertaining to, or resembling, the Corybantes or their rites; frantic; frenzied; as, a corybantic dance.","pos":""}],"CORYMB":[{"def":"Cor\"ymb (kr\"mb or -m; 220), n.","pos":""}],"CORYMBED":[{"def":"Cor\"ymbed (kr\"mbd), a.","pos":""}],"CORYMBIFEROUS":[{"def":"Bearing corymbs of flowers or fruit.","pos":""}],"CORYMBOSE":[{"def":"Consisting of corymbs, or resembling them in form.","pos":""}],"CORYPHAENOID":[{"def":"Belonging to, or like, the genus Coryphæna.","pos":""}],"CORYPHEE":[{"def":"A ballet dancer.","pos":""}],"CORYPHENE":[{"def":"A fish of the genus Coryphæna.","pos":""}],"CORYPHEUS":[{"def":"The conductor, chief, or leader of the dramatic chorus; hence, the chief or leader of a party or interest.","pos":""}],"CORYPHODON":[{"def":"A genus of extinct mammals from the eocene tertiary of Europe and America.","pos":""}],"CORYPHODONT":[{"def":"Pertaining to, or resembling, the genus Coryphodon.","pos":""}]}