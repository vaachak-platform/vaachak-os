{"SHRAG":[{"def":"A twig of a tree cut off.","pos":""}],"SHRAGGER":[{"def":"One who lops; one who trims trees.","pos":""}],"SHRAM":[{"def":"To cause to shrink or shrivel with cold; to benumb.","pos":""}],"SHRANK":[{"def":"A place baited with chaff to entice birds.","pos":""}],"SHRAPNEL":[{"def":"Applied as an appellation to a kind of shell invented by Gen.","pos":""},{"def":"A shrapnel shell; shrapnel shells, collectively.","pos":""}],"SHRED":[{"def":"A long, narrow piece cut or torn off; a strip.","pos":""},{"def":"In general, a fragment; a piece; a particle.","pos":""}],"SHREDCOOK":[{"def":"The fieldfare; -- so called from its harsh cry before rain.","pos":""}],"SHREDDING":[{"def":"The act of cutting or tearing into shreds.","pos":""},{"def":"That which is cut or torn off; a piece.","pos":""}],"SHREDDY":[{"def":"Consisting of shreds.","pos":""}],"SHREDLESS":[{"def":"Having no shreds; without a shred.","pos":""}],"SHREW":[{"def":"Wicked; malicious.","pos":""}],"SHREWD":[{"def":"Inclining to shrew; disposing to curse or scold; hence, vicious; malicious; evil; wicked; mischievous; vexatious; rough; unfair; shrewish.","pos":"verb"},{"def":"Artful; wily; cunning; arch.","pos":"verb"}],"SHREWISH":[{"def":"having the qualities of a shrew; having a scolding disposition; froward; peevish.","pos":""}],"SHREWMOUSE":[{"def":"A shrew; especially, the erd shrew.","pos":""}],"SHRIEK":[{"def":"To utter a loud, sharp, shrill sound or cry, as do some birds and beasts; to scream, as in a sudden fright, in horror or anguish.","pos":""}],"SHRIEKER":[{"def":"One who utters a shriek.","pos":""}],"SHRIEVAL":[{"def":"Of or pertaining to a sheriff.","pos":""}],"SHRIEVALTY":[{"def":"The office, or sphere of jurisdiction, of a sheriff; sheriffalty.","pos":""}],"SHRIEVE":[{"def":"To shrive; to question.","pos":""}],"SHRIFT":[{"def":"The act of shriving.","pos":""},{"def":"Confession made to a priest, and the absolution consequent upon it.","pos":""}],"SHRIGHT":[{"def":"She cried alway and shright.","pos":""}],"SHRIKE":[{"def":"Any one of numerous species of oscinine birds of the family Laniidæ, having a strong hooked bill, toothed at the tip.","pos":""}],"SHRILL":[{"def":"Acute; sharp; piercing; having or emitting a sharp, piercing tone or sound; -- said a sound, or of that which produces a sound.","pos":""}],"SHRILL-GORGED":[{"def":"Having a throat which produces a shrill note.","pos":""}],"SHRILL-TONGUED":[{"def":"Having a shrill voice.","pos":""}],"SHRILLNESS":[{"def":"The quality or state of being shrill.","pos":""}],"SHRILLY":[{"def":"In a shrill manner; acutely; with a sharp sound or voice.","pos":""}],"SHRIMP":[{"def":"To contract; to shrink.","pos":""}],"SHRIMPER":[{"def":"One who fishes for shrimps.","pos":""}],"SHRINE":[{"def":"A case, box, or receptacle, especially one in which are deposited sacred relics, as the bones of a saint.","pos":""},{"def":"Any sacred place, as an altar, tromb, or the like.","pos":""}],"SHRINK":[{"def":"To wrinkle, bend, or curl; to shrivel; hence, to contract into a less extent or compass; to gather together; to become compacted.","pos":""},{"def":"To withdraw or retire, as from danger; to decline action from fear; to recoil, as in fear, horror, or distress.","pos":""}],"SHRINKAGE":[{"def":"The act of shrinking; a contraction into less bulk or measurement.","pos":""},{"def":"The amount of such contraction; the bulk or dimension lost by shrinking, as of grain, castings, etc.","pos":""}],"SHRINKER":[{"def":"One who shrinks; one who withdraws from danger.","pos":""}],"SHRINKINGLY":[{"def":"In a shrinking manner.","pos":""}],"SHRIVE":[{"def":"To hear or receive the confession of; to administer confession and absolution to; -- said of a priest as the agent.","pos":""},{"def":"To confess, and receive absolution; -- used reflexively.","pos":""}],"SHRIVEL":[{"def":"To draw, or be drawn, into wrinkles; to shrink, and form corrugations; as, a leaf shriveles in the hot sun; the skin shrivels with age; -- often with up.","pos":""}],"SHRIVER":[{"def":"One who shrives; a confessor.","pos":""}],"SHRIVING":[{"def":"Shrift; confession.","pos":""}],"SHROFF":[{"def":"A banker, or changer of money.","pos":""}],"SHROFFAGE":[{"def":"The examination of coins, and the separation of the good from the debased.","pos":""}],"SHROOD":[{"def":"To trim; to lop.","pos":""}],"SHROPSHIRE":[{"def":"An English breed of black-faced hornless sheep similar to the Southdown, but larger, now extensively raised in many parts of the world.","pos":""}],"SHROUD":[{"def":"A set of ropes serving as stays to support the masts.","pos":""},{"def":"One of the two annular plates at the periphery of a water wheel, which form the sides of the buckets; a shroud plate.","pos":""}],"SHROUD-LAID":[{"def":"Composed of four strands, and laid right-handed with a heart, or center; -- said of rope.","pos":""}],"SHROUDED":[{"def":"Provided with a shroud or shrouds.","pos":""}],"SHROUDLESS":[{"def":"Without a shroud.","pos":""}],"SHROUDY":[{"def":"Affording shelter.","pos":""}],"SHROVE":[{"def":"Bell, and the day itself Pancake Tuesday.","pos":""}],"SHROVETIDE":[{"def":"The days immediately preceding Ash Widnesday, especially the period between the evening before Quinguagesima Sunday and the morning of Ash Wednesday.","pos":""}],"SHROVING":[{"def":"The festivity of Shrovetide.","pos":""}],"SHRUB":[{"def":"A liquor composed of vegetable acid, especially lemon juice, and sugar, with spirit to preserve it.","pos":""}],"SHRUBBERY":[{"def":"A collection of shrubs.","pos":""},{"def":"A place where shrubs are planted.","pos":""}],"SHRUBBINESS":[{"def":"Quality of being shrubby.","pos":""}],"SHRUBBY":[{"def":"Of the nature of a shrub; resembling a shrub.","pos":""}],"SHRUBLESS":[{"def":"having no shrubs.","pos":""}],"SHRUG":[{"def":"To draw up or contract (the shoulders), especially by way of expressing dislike, dread, doubt, or the like.","pos":""}]}