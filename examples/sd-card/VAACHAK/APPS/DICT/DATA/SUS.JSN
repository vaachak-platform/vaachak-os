{"SUSCEPTIBILITY":[{"def":"The state or quality of being susceptible; the capability of receiving impressions, or of being affected.","pos":""},{"def":"Specifically, capacity for deep feeling or emotional excitement; sensibility, in its broadest acceptation; impressibility; sensitiveness.","pos":""}],"SUSCEPTIBLE":[{"def":"Capable of admitting anything additional, or any change, affection, or influence; readily acted upon; as, a body susceptible of color or of alteration.","pos":""},{"def":"Capable of impression; having nice sensibility; impressible; tender; sensitive; as, children are more susceptible than adults; a man of a susceptible heart.","pos":""}],"SUSCEPTION":[{"def":"The act of taking; reception.","pos":""}],"SUSCEPTIVITY":[{"def":"Capacity for receiving; susceptibility.","pos":""}],"SUSCEPTOR":[{"def":"One who undertakes anything; specifically, a godfather; a sponsor; a guardian.","pos":""}],"SUSCIPIENT":[{"def":"Receiving; admitting.","pos":""}],"SUSCITABILITY":[{"def":"Capability of being suscitated; excitability.","pos":""}],"SUSCITATE":[{"def":"To rouse; to excite; to call into life and action.","pos":""}],"SUSCITATION":[{"def":"The act of raising or exciting.","pos":""}],"SUSLIK":[{"def":"A ground squirrel (Spermophilus citillus) of Europe and Asia.","pos":""}],"SUSPECT":[{"def":"Suspicious; inspiring distrust.","pos":""},{"def":"Suspected; distrusted.","pos":""}],"SUSPECTABLE":[{"def":"That may be suspected.","pos":""}],"SUSPECTED":[{"def":"Distrusted; doubted.","pos":""}],"SUSPECTER":[{"def":"One who suspects.","pos":""}],"SUSPECTFUL":[{"def":"Apt to suspect or mistrust; full of suspicion; suspicious; as, to be suspectful of the motives of others.","pos":""}],"SUSPECTIOUSNESS":[{"def":"Suspiciousness; cause for suspicion.","pos":""}],"SUSPECTLESS":[{"def":"Not suspecting; having no suspicion.","pos":""},{"def":"Not suspected; not mistrusted.","pos":""}],"SUSPEND":[{"def":"To support in a liquid, as an insoluble powder, by stirring, to facilitate chemical action.","pos":""}],"SUSPENDER":[{"def":"One who, or that which, suspends; esp.","pos":""}],"SUSPENSATION":[{"def":"The act of suspending, or the state of being suspended, especially for a short time; temporary suspension.","pos":""}],"SUSPENSE":[{"def":"Held or lifted up; held or prevented from proceeding.","pos":""},{"def":"Expressing, or proceeding from, suspense or doubt.","pos":""}],"SUSPENSIBILITY":[{"def":"The quality or state of being suspensible.","pos":""}],"SUSPENSIBLE":[{"def":"Capable of being suspended; capable of being held from sinking.","pos":""}],"SUSPENSION":[{"def":"A keeping of the hearer in doubt and in attentive expectation of what is to follow, or of what is to be the inference or conclusion from the arguments or observations employed.","pos":""},{"def":"A stay or postponement of execution of a sentence condemnatory by means of letters of suspension granted on application to the lord ordinary.","pos":""}],"SUSPENSIVE":[{"def":"Tending to suspend, or to keep in suspense; causing interruption or delay; uncertain; doubtful.","pos":""}],"SUSPENSOR":[{"def":"The cord which suspends the embryo; and which is attached to the radicle in the young state; the proembryo.","pos":""}],"SUSPENSORIUM":[{"def":"Anything which suspends or holds up a part: especially, the mandibular suspensorium (a series of bones, or of cartilages representing them) which connects the base of the lower jaw with the skull in most vertebrates below mammals.","pos":""}],"SUSPENSORY":[{"def":"Of or pertaining to a suspensorium.","pos":""}],"SUSPICABLE":[{"def":"Liable to suspicion; suspicious.","pos":""}],"SUSPICIENCY":[{"def":"Suspiciousness; suspicion.","pos":""}],"SUSPICION":[{"def":"The act of suspecting; the imagination or apprehension of the existence of something (esp.","pos":""},{"def":"Slight degree; suggestion; hint.","pos":""}],"SUSPICIOUS":[{"def":"Inclined to suspect; given or prone to suspicion; apt to imagine without proof.","pos":""},{"def":"Indicating suspicion, mistrust, or fear.","pos":""}],"SUSPIRAL":[{"def":"A breathing hole; a vent or ventiduct.","pos":""},{"def":"A spring of water passing under ground toward a cistern or conduit.","pos":""}],"SUSPIRATION":[{"def":"The act of sighing, or fetching a long and deep breath; a deep respiration; a sigh.","pos":""}],"SUSPIRE":[{"def":"To fetch a long, deep breath; to sigh; to breathe.","pos":""}],"SUSPIRED":[{"def":"Ardently desired or longed for; earnestly coveted.","pos":""}],"SUSTAIN":[{"def":"To keep from falling; to bear; to uphold; to support; as, a foundation sustains the superstructure; a beast sustains a load; a rope sustains a weight.","pos":""},{"def":"Hence, to keep from sinking, as in despondence, or the like; to support.","pos":""}],"SUSTAINABLE":[{"def":"Capable of being sustained or maintained; as, the action is not sustainable.","pos":""}],"SUSTAINED":[{"def":"Held up to a certain pitch, degree, or level; uniform; as, sustained pasion; a sustained style of writing; a sustained note in music.","pos":""}],"SUSTAINER":[{"def":"One who, or that which, sustains.","pos":""}],"SUSTAINMENT":[{"def":"The act of sustaining; maintenance; support.","pos":""}],"SUSTALTIC":[{"def":"Mournful; -- said of a species of music among the ancient Greeks.","pos":""}],"SUSTENANCE":[{"def":"The act of sustaining; support; maintenance; subsistence; as, the sustenance of the body; the sustenance of life.","pos":""},{"def":"That which supports life; food; victuals; provisions; means of living; as, the city has ample sustenance.","pos":""}],"SUSTENTACULAR":[{"def":"Supporting; sustaining; as, a sustentacular tissue.","pos":""}],"SUSTENTATION":[{"def":"The aggregate of the functions by which a living organism is maintained in a normal condition of weight and growth.","pos":""}],"SUSTENTATIVE":[{"def":"Adapted to sustain, strengthen, or corroborate; as, sustentative citations or quotations.","pos":""}],"SUSTENTION":[{"def":"In fine images, in sustention, in irony, they surpass anything that Burke ever wrote.","pos":""}],"SUSURRATION":[{"def":"A whispering; a soft murmur.","pos":""}],"SUSURRINGLY":[{"def":"In the manner of a whisper.","pos":""}],"SUSURROUS":[{"def":"Whispering; rustling; full of whispering sounds.","pos":""}],"SUSURRUS":[{"def":"The act of whispering; a whisper; a murmur.","pos":""}]}