{"BEMA":[{"def":"A platform from which speakers addressed an assembly.","pos":""}],"BEMANGLE":[{"def":"To mangle; to tear asunder.","pos":""}],"BEMASK":[{"def":"To mask; to conceal.","pos":""}],"BEMASTER":[{"def":"To master thoroughly.","pos":""}],"BEMAUL":[{"def":"To maul or beat severely; to bruise.","pos":""}],"BEMAZE":[{"def":"Intellects bemazed in endless doubt.","pos":""}],"BEMEAN":[{"def":"To make mean; to lower.","pos":""}],"BEMEET":[{"def":"Our very loving sister, well bemet.","pos":""}],"BEMINGLE":[{"def":"To mingle; to mix.","pos":""}],"BEMIRE":[{"def":"To drag through, encumber with, or fix in, the mire; to soil by passing through mud or dirt.","pos":""}],"BEMIST":[{"def":"To envelop in mist.","pos":""}],"BEMOAN":[{"def":"To express deep grief for by moaning; to express sorrow for; to lament; to bewail; to pity or sympathize with.","pos":""}],"BEMOANER":[{"def":"One who bemoans.","pos":""}],"BEMOCK":[{"def":"To mock; to ridicule.","pos":""}],"BEMOIL":[{"def":"To soil or encumber with mire and dirt.","pos":""}],"BEMONSTER":[{"def":"To make monstrous or like a monster.","pos":""}],"BEMUDDLE":[{"def":"To muddle; to stupefy or bewilder; to confuse.","pos":""}],"BEMUFFLE":[{"def":"To cover as with a muffler; to wrap up.","pos":""}],"BEMUSE":[{"def":"To muddle, daze, or partially stupefy, as with liquor.","pos":""},{"def":"The seed of one or more species of moringa; as, oil of ben.","pos":""}]}