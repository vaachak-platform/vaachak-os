{"MANIA":[{"def":"Violent derangement of mind; madness; insanity.","pos":""},{"def":"Excessive or unreasonable desire; insane passion affecting one or many people; as, the tulip mania.","pos":""}],"MANIAC":[{"def":"Raving with madness; raging with disordered intellect; affected with mania; mad.","pos":""}],"MANIACAL":[{"def":"Affected with, or characterized by, madness; maniac.","pos":""}],"MANICATE":[{"def":"Covered with hairs or pubescence so platted together and interwoven as to form a mass easily removed.","pos":""},{"def":"A believer in the doctrines of Manes, a Persian of the third century A.","pos":""}],"MANICHEIST":[{"def":"The clavichord or clarichord; -- called also dumb spinet.","pos":""}],"MANICURE":[{"def":"A person who makes a business of taking care of people's hands, especially their nails.","pos":""}],"MANID":[{"def":"Any species of the genus Manis, or family Manidæ.","pos":""}],"MANIE":[{"def":"Mania; insanity.","pos":""}],"MANIFEST":[{"def":"Evident to the senses, esp.","pos":""},{"def":"Detected; convicted; -- with of.","pos":""}],"MANIFESTABLE":[{"def":"Such as can be manifested.","pos":""}],"MANIFESTATION":[{"def":"The act of manifesting or disclosing, or the state of being manifested; discovery to the eye or to the understanding; also, that which manifests; exhibition; display; revelation; as, the manifestation of God's power in creation.","pos":""}],"MANIFESTLY":[{"def":"In a manifest manner.","pos":""}],"MANIFESTNESS":[{"def":"The quality or state of being manifest; obviousness.","pos":""}],"MANIFESTO":[{"def":"Frederick, in a public manifesto, appealed to the Empire against the insolent pretensions of the pope.","pos":""}],"MANIFOLD":[{"def":"Various in kind or quality; many in number; numerous; multiplied; complicated.","pos":""},{"def":"Exhibited at divers times or in various ways; -- used to qualify nouns in the singular number.","pos":""}],"MANIFOLDED":[{"def":"Having many folds, layers, or plates; as, a manifolded shield.","pos":""}],"MANIFOLDLY":[{"def":"In a manifold manner.","pos":""}],"MANIFOLDNESS":[{"def":"A generalized concept of magnitude.","pos":""}],"MANIFORM":[{"def":"Shaped like the hand.","pos":""}],"MANIGLION":[{"def":"Either one of two handles on the back of a piece of ordnance.","pos":""}],"MANIKIN":[{"def":"Of or pertaining to Manila or Manilla, the capital of the Philippine Islands; made in, or exported from, that city.","pos":""}],"MANILLA":[{"def":"A ring worn upon the arm or leg as an ornament, especially among the tribes of Africa.","pos":""},{"def":"A piece of copper of the shape of a horseshoe, used as money by certain tribes of the west coast of Africa.","pos":""}],"MANILLE":[{"def":"See 1st Manilla, 1.","pos":""}],"MANIOC":[{"def":"The tropical plants (Manihot utilissima, and M.","pos":""}],"MANIPLE":[{"def":"A division of the Roman army numbering sixty men exclusive of officers, any small body of soldiers; a company.","pos":""}],"MANIPULAR":[{"def":"Of or pertaining to the maniple, or company.","pos":""},{"def":"Manipulatory; as, manipular operations.","pos":""}],"MANIPULATE":[{"def":"To treat, work, or operate with the hands, especially when knowledge and dexterity are required; to manage in hand work; to handle; as, to manipulate scientific apparatus.","pos":""},{"def":"To control the action of, by management; as, to manipulate a convention of delegates; to manipulate the stock market; also, to manage artfully or fraudulently; as, to manipulate accounts, or election returns.","pos":""}],"MANIPULATION":[{"def":"The act or process of manipulating, or the state of being manipulated; the act of handling work by hand; use of the hands, in an artistic or skillful manner, in science or art.","pos":""},{"def":"The use of the hands in mesmeric operations.","pos":""}],"MANIPULATIVE":[{"def":"Of or pertaining to manipulation; performed by manipulation.","pos":""}],"MANIPULATORY":[{"def":"Of or pertaining to manipulation.","pos":""}],"MANIS":[{"def":"A genus of edentates, covered with large, hard, triangular scales, with sharp edges that overlap each other like tiles on a roof.","pos":""},{"def":"A name given by tribes of American Indians to a great spirit, whether good or evil, or to any object of worship.","pos":""}],"MANITRUNK":[{"def":"The anterior segment of the thorax in insects.","pos":""}]}