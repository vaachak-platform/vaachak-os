{"VIVA VOCE":[{"def":"By word of mouth; orally.","pos":""}],"VIVACE":[{"def":"Brisk; vivacious; with spirit; -- a direction to perform a passage in a brisk and lively manner.","pos":""}],"VIVACIOUS":[{"def":"Living through the winter, or from year to year; perennial.","pos":""}],"VIVACITY":[{"def":"The quality or state of being vivacious.","pos":""}],"VIVANDIER":[{"def":"In Continental armies, esp.","pos":""}],"VIVANDIERE":[{"def":"In Continental armies, especially in the French army, a woman accompanying a regiment, who sells provisions and liquor to the soldiers; a female sutler.","pos":""}],"VIVARIUM":[{"def":"A place artificially arranged for keeping or raising living animals, as a park, a pond, an aquarium, a warren, etc.","pos":""}],"VIVE":[{"def":"Long live, that is, success to; as, vive le roi, long live the king; vive la bagatelle, success to trifles or sport.","pos":""}],"VIVELY":[{"def":"In a lively manner.","pos":""}],"VIVENCY":[{"def":"Manner of supporting or continuing life or vegetation.","pos":""}],"VIVERRA":[{"def":"A genus of carnivores which comprises the civets.","pos":""}],"VIVERRINE":[{"def":"Of or pertaining to the Viverridæ, or Civet family.","pos":""}],"VIVERS":[{"def":"Provisions; victuals.","pos":""}],"VIVES":[{"def":"A disease of brute animals, especially of horses, seated in the glands under the ear, where a tumor is formed which sometimes ends in suppuration.","pos":""}],"VIVIANITE":[{"def":"A hydrous phosphate of iron of a blue to green color, growing darker on exposure.","pos":""}],"VIVID":[{"def":"True to the life; exhibiting the appearance of life or freshness; animated; spirited; bright; strong; intense; as, vivid colors.","pos":""},{"def":"Forming brilliant images, or painting in lively colors; lively; sprightly; as, a vivid imagination.","pos":""}],"VIVIDITY":[{"def":"The quality or state of being vivid; vividness.","pos":""},{"def":"Giving life; reviving; enlivening.","pos":""}],"VIVIFICATE":[{"def":"To bring back a metal to the metallic form, as from an oxide or solution; to reduce.","pos":""}],"VIVIFICATION":[{"def":"One of the changes of assimilation, in which proteid matter which has been transformed, and made a part of the tissue or tissue cells, is endowed with life, and thus enabled to manifest the phenomena of irritability, contractility, etc.","pos":""},{"def":"The act or process of vivificating.","pos":""}],"VIVIFICATIVE":[{"def":"Able or tending to vivify, animate, or give life; vivifying.","pos":""}],"VIVIFY":[{"def":"To endue with life; to make to be living; to quicken; to animate.","pos":""}],"VIVIPARA":[{"def":"An artificial division of vertebrates including those that produce their young alive; -- opposed to Ovipara.","pos":""}],"VIVIPARITY":[{"def":"The quality or condition of being viviparous.","pos":""}],"VIVIPAROUS":[{"def":"Producing young in a living state, as most mammals, or as those plants the offspring of which are produced alive, either by bulbs instead of seeds, or by the seeds themselves germinating on the plant, instead of falling, as they usually do; -- opposed to oviparous.","pos":""}],"VIVIPAROUSLY":[{"def":"In a viviparous manner.","pos":""}],"VIVIPAROUSNESS":[{"def":"The quality of being viviparous; viviparity.","pos":""}],"VIVISECT":[{"def":"To perform vivisection upon; to dissect alive.","pos":""}],"VIVISECTION":[{"def":"The dissection of an animal while alive, for the purpose of making physiological investigations.","pos":""}],"VIVISECTIONAL":[{"def":"Of or pertaining to vivisection.","pos":""}],"VIVISECTIONIST":[{"def":"One who practices or advocates vivisection; a vivisector.","pos":""}],"VIVISECTOR":[{"def":"A vivisectionist.","pos":""}]}