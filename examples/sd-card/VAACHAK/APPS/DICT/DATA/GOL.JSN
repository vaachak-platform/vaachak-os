{"GOLD":[{"def":"A metallic element, constituting the most precious metal used as a common commercial medium of exchange.","pos":""}],"GOLD-BEATING":[{"def":"The art or process of reducing gold to extremely thin leaves, by beating with a hammer.","pos":""}],"GOLD-BOUND":[{"def":"Encompassed with gold.","pos":""}],"GOLD-HAMMER":[{"def":"The yellow-hammer.","pos":""}],"GOLDCREST":[{"def":"The European golden-crested kinglet (Regulus cristatus, or R.","pos":""}],"GOLDEN":[{"def":"Made of gold; consisting of gold.","pos":""},{"def":"Having the color of gold; as, the golden grain.","pos":""}],"GOLDEN STATE":[{"def":"California; -- a nickname alluding to its rich gold deposits.","pos":""}],"GOLDEN-EYE":[{"def":"A duck (Glaucionetta clangula), found in Northern Europe, Asia, and America.","pos":""}],"GOLDEN-ROD":[{"def":"A tall herb (Solidago Virga-aurea), bearing yellow flowers in a graceful elongated cluster.","pos":""}],"GOLDENLY":[{"def":"In golden terms or a golden manner; splendidly; delightfully.","pos":""}],"GOLDFINCH":[{"def":"The name refers to the large patch of yellow on the wings.","pos":""}],"GOLDFINNY":[{"def":"One of two or more species of European labroid fishes (Crenilabrus melops, and Ctenolabrus rupestris); -- called also goldsinny, and goldney.","pos":""}],"GOLDILOCKS":[{"def":"Same as Goldylocks.","pos":""},{"def":"A conspicuous yellow flower, commonly the corn marigold (Chrysanthemum segetum).","pos":""}],"GOLDLESS":[{"def":"Destitute of gold.","pos":""}],"GOLDSEED":[{"def":"Dog's-tail grass.","pos":""}],"GOLDSMITH":[{"def":"An artisan who manufactures vessels and ornaments, etc.","pos":""}],"GOLDYLOCKS":[{"def":"A plant of several species of the genus Chrysocoma; -- so called from the tufts of yellow flowers which terminate the stems; also, the Ranunculus auricomus, a kind of buttercup.","pos":""}],"GOLET":[{"def":"A California trout.","pos":""}],"GOLF":[{"def":"A game played with a small ball and a bat or club crooked at the lower end.","pos":""}],"GOLFER":[{"def":"One who plays golf.","pos":""}],"GOLIARD":[{"def":"A buffoon in the Middle Ages, who attended rich men's tables to make sport for the guests by ribald stories and songs.","pos":""}],"GOLIARDERY":[{"def":"The satirical or ribald poetry of the Goliards.","pos":""}],"GOLIATH BEETLE":[{"def":"Any species of Goliathus, a genus of very large and handsome African beetles.","pos":""}],"GOLL":[{"def":"A hand, paw, or claw.","pos":""}],"GOLTSCHUT":[{"def":"A small ingot of gold.","pos":""},{"def":"A silver ingot, used in Japan as money.","pos":""}]}