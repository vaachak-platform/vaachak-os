{"MEN":[{"def":"A man; one; -- used with a verb in the singular, and corresponding to the present indefinite one or they.","pos":""}],"MEN-PLEASER":[{"def":"One whose motive is to please men or the world, rather than God.","pos":""}],"MENACCANITE":[{"def":"An iron-black or steel-gray mineral, consisting chiefly of the oxides of iron and titanium.","pos":""}],"MENACE":[{"def":"The show of an intention to inflict evil; a threat or threatening; indication of a probable evil or catastrophe to come.","pos":""}],"MENACER":[{"def":"One who menaces.","pos":""}],"MENACINGLY":[{"def":"In a threatening manner.","pos":""}],"MENAGE":[{"def":"A collection of animals; a menagerie.","pos":""}],"MENAGERIE":[{"def":"A piace where animals are kept and trained.","pos":""},{"def":"A collection of wild or exotic animals, kept for exhibition.","pos":""}],"MENAION":[{"def":"A work of twelve volumes, each containing the offices in the Greek Church for a month; also, each volume of the same.","pos":""},{"def":"Covered with spots; speckled; variegated.","pos":""}],"MEND":[{"def":"To repair, as anything that is torn, broken, defaced, decayed, or the like; to restore from partial decay, injury, or defacement; to patch up; to put in shape or order again; to re-create; as, to mend a garment or a machine.","pos":""},{"def":"To alter for the better; to set right; to reform; hence, to quicken; as, to mend one's manners or pace.","pos":""}],"MENDABLE":[{"def":"Capable of being mended.","pos":""}],"MENDACIOUS":[{"def":"Given to deception or falsehood; lying; as, a mendacious person.","pos":""},{"def":"False; counterfeit; containing falsehood; as, a mendacious statement.","pos":""}],"MENDACITY":[{"def":"The quality or state of being mendacious; a habit of lying.","pos":""},{"def":"A falsehood; a lie.","pos":""}],"MENDEL'S LAW":[{"def":"A principle governing the inheritance of many characters in animals and plants, discovered by Gregor J.","pos":""}],"MENDELIAN CHARACTER":[{"def":"A character which obeys Mendel's law in regard to its hereditary transmission.","pos":""}],"MENDER":[{"def":"One who mends or repairs.","pos":""}],"MENDICANCY":[{"def":"The condition of being mendicant; beggary; begging.","pos":""}],"MENDICANT":[{"def":"Practicing beggary; begging; living on alms; as, mendicant friars.","pos":""}],"MENDICATION":[{"def":"The act or practice of begging; beggary; mendicancy.","pos":""}],"MENDICITY":[{"def":"The practice of begging; the life of a beggar; mendicancy.","pos":""}],"MENDINANT":[{"def":"A mendicant or begging friar.","pos":""}],"MENHADEN":[{"def":"An American marine fish of the Herring familt (Brevoortia tyrannus), chiefly valuable for its oil and as a component of fertilizers; -- called also mossbunker, bony fish, chebog, pogy, hardhead, whitefish, etc.","pos":""}],"MENHIR":[{"def":"A large stone set upright in olden times as a memorial or monument.","pos":""}],"MENIAL":[{"def":"Belonging to a retinue or train of servants; performing servile office; serving.","pos":""},{"def":"Pertaining to servants, esp.","pos":""}],"MENIERE'S DISEASE":[{"def":"A disease characterized by deafness and vertigo, resulting in incoördination of movement.","pos":""}],"MENINGEAL":[{"def":"Of or pertaining to the meninges.","pos":""}],"MENINGES":[{"def":"The three membranes that envelop the brain and spinal cord; the pia mater, dura mater, and arachnoid membrane.","pos":""}],"MENINGITIS":[{"def":"Inflammation of the membranes of the brain or spinal cord.","pos":""}],"MENISCAL":[{"def":"Pertaining to, or having the form of, a meniscus.","pos":""}],"MENISCOID":[{"def":"Concavo-convex, like a meniscus.","pos":""}],"MENISCUS":[{"def":"A lens convex on one side and concave on the other.","pos":""},{"def":"An interarticular synovial cartilage or membrane; esp.","pos":""}],"MENISPERMACEOUS":[{"def":"Pertaining to a natural order (Menispermaceæ) of climbing plants of which moonseed (Menispermum) is the type.","pos":""}],"MENISPERMIC":[{"def":"Pertaining to, or obtained from, moonseed (Menispermum), or other plants of the same family, as the Anamirta Cocculus.","pos":""}],"MENISPERMINE":[{"def":"An alkaloid distinct from picrotoxin and obtained from the cocculus indicus (the fruit of Anamirta Cocculus, formerly Menispermum Cocculus) as a white, crystalline, tasteless powder; -- called also menispermina.","pos":""}],"MENIVER":[{"def":"Same as Miniver.","pos":""},{"def":"One of a small denomination of Christians, so called from Menno Simons of Friesland, their founder.","pos":""}],"MENOPAUSE":[{"def":"The period of natural cessation of menstruation.","pos":""}],"MENOSTASIS":[{"def":"Stoppage of the mences.","pos":""}],"MENOSTATION":[{"def":"Same as Menostasis.","pos":""}],"MENSAL":[{"def":"Belonging to the table; transacted at table; as, mensa conversation.","pos":""}],"MENSE":[{"def":"Manliness; dignity; comeliness; civility.","pos":""}],"MENSES":[{"def":"The catamenial or menstrual discharge, a periodic flow of blood or bloody fluid from the uterus or female generative organs.","pos":""}],"MENSTRUAL":[{"def":"Recurring once a month; monthly; gone through in a month; as, the menstrual revolution of the moon; pertaining to monthly changes; as, the menstrual equation of the sun's place.","pos":""},{"def":"Of or pertaining to the menses; as, menstrual discharges; the menstrual period.","pos":""}],"MENSTRUANT":[{"def":"Subject to monthly flowing or menses.","pos":""}],"MENSTRUATE":[{"def":"To discharge the menses; to have the catamenial flow.","pos":""}],"MENSTRUATION":[{"def":"The discharge of the menses; also, the state or the period of menstruating.","pos":""}],"MENSTRUE":[{"def":"The menstrual flux; menses.","pos":""}],"MENSTRUOUS":[{"def":"Having the monthly flow or discharge; menstruating.","pos":""},{"def":"Of or pertaining tj the monthly flow; catamenial.","pos":""}],"MENSTRUUM":[{"def":"Any substance which dissolves a solid body; a solvent.","pos":""}],"MENSURABILITY":[{"def":"The quality of being mensurable.","pos":""}],"MENSURABLE":[{"def":"Capable of being measured; measurable.","pos":""}],"MENSURABLENESS":[{"def":"The quality or state of being mensurable; measurableness.","pos":""}],"MENSURAL":[{"def":"Of or pertaining to measure.","pos":""}],"MENSURATION":[{"def":"The act, process, or art, of measuring.","pos":""},{"def":"That branch of applied geometry which gives rules for finding the length of lines, the areas of surfaces, or the volumes of solids, from certain simple data of lines and angles.","pos":""}],"MENTAL":[{"def":"Of or pertaining to the chin; genian; as, the mental nerve; the mental region.","pos":""}],"MENTALITY":[{"def":"Quality or state of mind.","pos":""}],"MENTALLY":[{"def":"In the mind; in thought or meditation; intellectually; in idea.","pos":""}],"MENTHA":[{"def":"A widely distributed genus of fragrant herbs, including the peppermint, spearmint, etc.","pos":""}],"MENTHENE":[{"def":"A colorless liquid hydrocarbon resembling oil of turpentine, obtained by dehydrating menthol.","pos":""}],"MENTHOL":[{"def":"A white, crystalline, aromatic substance resembling camphor, extracted from oil of peppermint (Mentha); -- called also mint camphor or peppermint camphor.","pos":""}],"MENTHYL":[{"def":"A compound radical forming the base of menthol.","pos":""}],"MENTICULTURAL":[{"def":"Of or pertaining to mental culture; serving to improve or strengthen the mind.","pos":""}],"MENTION":[{"def":"A speaking or notice of anything, -- usually in a brief or cursory manner.","pos":""}],"MENTIONABLE":[{"def":"Fit to be mentioned.","pos":""}],"MENTOMECKELIAN":[{"def":"Of or pertaining to the chin and lower jaw.","pos":""},{"def":"The bone or cartilage forming the anterior extremity of the lower jaw in some adult animals and the young of others.","pos":""}],"MENTOR":[{"def":"A wise and faithful counselor or monitor.","pos":""}],"MENTORIAL":[{"def":"Containing advice or admonition.","pos":""}],"MENTUM":[{"def":"The front median plate of the labium in insects.","pos":""}],"MENU":[{"def":"The details of a banquet; a bill of fare.","pos":""}]}