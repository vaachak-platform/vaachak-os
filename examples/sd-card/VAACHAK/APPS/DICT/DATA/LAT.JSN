{"LAT":[{"def":"To let; to allow.","pos":""},{"def":"A convulsive tic or hysteric neurosis prevalent among Malays, similar to or identical with miryachit and jumping disease, the person affected performing various involuntary actions and making rapid inarticulate ejaculations in imitation of the actions and words of another person.","pos":""}],"LATAKIA":[{"def":"A superior quality of Turkish smoking tobacco, so called from the place where produced, the ancient Laodicea.","pos":""}],"LATCH":[{"def":"To smear; to anoint.","pos":""}],"LATCHET":[{"def":"The string that fastens a shoe; a shoestring.","pos":""}],"LATCHING":[{"def":"A loop or eye formed on the head rope of a bonnet, by which it is attached to the foot of a sail; -- called also latch and lasket.","pos":""}],"LATCHKEY":[{"def":"A key used to raise, or throw back, the latch of a door, esp.","pos":""}],"LATCHSTRING":[{"def":"A string for raising the latch of a door by a person outside.","pos":""}],"LATE":[{"def":"Coming after the time when due, or after the usual or proper time; not early; slow; tardy; long delayed; as, a late spring.","pos":""},{"def":"Far advanced toward the end or close; as, a late hour of the day; a late period of life.","pos":""}],"LATED":[{"def":"Belated; too late.","pos":""}],"LATEEN":[{"def":"Of or pertaining to a peculiar rig used in the Mediterranean and adjacent waters, esp.","pos":""}],"LATELY":[{"def":"Not long ago; recently; as, he has lately arrived from Italy.","pos":""}],"LATENCY":[{"def":"The state or quality of being latent.","pos":""}],"LATENESS":[{"def":"The state, condition, or quality, of being late; as, the lateness of his arrival; the lateness of the hour; the lateness of the season.","pos":""}],"LATENT":[{"def":"Not visible or apparent; hidden; springs of action.","pos":""}],"LATENTLY":[{"def":"In a secret or concealed manner; invisibly.","pos":""}],"LATER":[{"def":"A brick or tile.","pos":""}],"LATERAD":[{"def":"Toward the side; away from the mesial plane; -- opposed to mesiad.","pos":""}],"LATERAL":[{"def":"Lying at, or extending toward, the side; away from the mesial plane; external; -- opposed to mesial.","pos":""}],"LATERALITY":[{"def":"The state or condition of being lateral.","pos":""}],"LATERALLY":[{"def":"By the side; sidewise; toward, or from, the side.","pos":""}],"LATERAN":[{"def":"The church and palace of St.","pos":""}],"LATERED":[{"def":"Inclined to delay; dilatory.","pos":""}],"LATERIFOLIOUS":[{"def":"Growing from the stem by the side of a leaf; as, a laterifolious flower.","pos":""}],"LATERITE":[{"def":"An argillaceous sandstone, of a red color, and much seamed; -- found in India.","pos":""}],"LATERITIC":[{"def":"consisting of, containing, or characterized by, laterite; as, lateritic formations.","pos":""}],"LATERITIOUS":[{"def":"Like bricks; of the color of red bricks.","pos":""}],"LATES":[{"def":"A genus of large percoid fishes, of which one species (Lates Niloticus) inhabits the Nile, and another (L.","pos":""}],"LATESCENCE":[{"def":"A slight withdrawal from view or knowledge.","pos":""}],"LATESCENT":[{"def":"Slightly withdrawn from view or knowledge; as, a latescent meaning.","pos":""}],"LATEWAKE":[{"def":"See Lich wake, under Lich.","pos":""}],"LATEWARD":[{"def":"Somewhat late; backward.","pos":""}],"LATEX":[{"def":"A milky or colored juice in certain plants in cavities (called latex cells or latex tubes).","pos":""}],"LATH":[{"def":"A thin, narrow strip of wood, nailed to the rafters, studs, or floor beams of a building, for the purpose of supporting the tiles, plastering, etc.","pos":""}],"LATH-SHAPED":[{"def":"Having a slender elongated form, like a lath; -- said of the feldspar of certain igneous rocks, as diabase, as seen in microscopic sections.","pos":""}],"LATHE":[{"def":"Formerly, a part or division of a county among the Anglo- Saxons.","pos":""}],"LATHER":[{"def":"Foam or froth made by soap moistened with water.","pos":""},{"def":"Foam from profuse sweating, as of a horse.","pos":""}],"LATHING":[{"def":"The act or process of covering with laths; laths, collectively; a covering of laths.","pos":""}],"LATHWORK":[{"def":"Same as Lathing.","pos":""}],"LATHY":[{"def":"Like a lath; long and slender.","pos":""}],"LATIAN":[{"def":"Belonging, or relating, to Latium, a country of ancient Italy.","pos":""}],"LATIBULIZE":[{"def":"To retire into a den, or hole, and lie dormant in winter; to retreat and lie hid.","pos":""}],"LATIBULUM":[{"def":"A concealed hiding place; a burrow; a lair; a hole.","pos":""}],"LATICIFEROUS":[{"def":"Containing the latex; -- applied to the tissue or tubular vessels in which the latex of the plant is found.","pos":""}],"LATICLAVE":[{"def":"A broad stripe of purple on the fore part of the tunic, worn by senators in ancient Rome as an emblem of office.","pos":""}],"LATIDENTATE":[{"def":"Having broad leaves.","pos":""}],"LATIGO":[{"def":"A strap for tightening a saddle girth.","pos":""}],"LATIGO HALTER":[{"def":"A kind of halter usually made of raw hide.","pos":""}],"LATIN":[{"def":"Of or pertaining to Latium, or to the Latins, a people of Latium; Roman; as, the Latin language.","pos":""},{"def":"Of, pertaining to, or composed in, the language used by the Romans or Latins; as, a Latin grammar; a Latin composition or idiom.","pos":""}],"LATINISM":[{"def":"A Latin idiom; a mode of speech peculiar to Latin; also, a mode of speech in another language, as English, formed on a Latin model.","pos":""}],"LATINIST":[{"def":"One skilled in Latin; a Latin scholar.","pos":""}],"LATINISTIC":[{"def":"Of, pertaining to, or derived from, Latin; in the Latin style or idiom.","pos":""}],"LATINITASTER":[{"def":"One who has but a smattering of Latin.","pos":""}],"LATINITY":[{"def":"The Latin tongue, style, or idiom, or the use thereof; specifically, purity of Latin style or idiom.","pos":""}],"LATINIZATION":[{"def":"The act or process of Latinizing, as a word, language, or country.","pos":""}],"LATINIZE":[{"def":"To give Latin terminations or forms to, as to foreign words, in writing Latin.","pos":""},{"def":"To bring under the power or influence of the Romans or Latins; to affect with the usages of the Latins, especially in speech.","pos":""}],"LATINLY":[{"def":"In the manner of the Latin language; in correct Latin.","pos":""}],"LATION":[{"def":"Transportation; conveyance.","pos":""},{"def":"Having a broad beak.","pos":""}],"LATIROSTRES":[{"def":"The broad-billed singing birds, such as the swallows, and their allies.","pos":""}],"LATISTERNAL":[{"def":"Having a broad breastbone, or sternum; -- said of anthropoid apes.","pos":""}],"LATITANCY":[{"def":"Act or state of lying hid, or lurking.","pos":""}],"LATITANT":[{"def":"Lying hid; concealed; latent.","pos":""}],"LATITAT":[{"def":"A writ based upon the presumption that the person summoned was hiding.","pos":""}],"LATITATION":[{"def":"A lying in concealment; hiding.","pos":""}],"LATITUDE":[{"def":"Distance north or south of the equator, measured on a meridian.","pos":""},{"def":"The angular distance of a heavenly body from the ecliptic.","pos":""}],"LATITUDINAL":[{"def":"Of or pertaining to latitude; in the direction of latitude.","pos":""}],"LATITUDINARIAN":[{"def":"Not restrained; not confined by precise limits.","pos":""},{"def":"Indifferent to a strict application of any standard of belief or opinion; hence, deviating more or less widely from such standard; lax in doctrine; as, latitudinarian divines; latitudinarian theology.","pos":""}],"LATITUDINARIANISM":[{"def":"A latitudinarian system or condition; freedom of opinion in matters pertaining to religious belief.","pos":""}],"LATITUDINOUS":[{"def":"Having latitude, or wide extent.","pos":""}],"LATRATE":[{"def":"To bark as a dog.","pos":""}],"LATREUTICAL":[{"def":"Acting as a hired servant; serving; ministering; assisting.","pos":""},{"def":"Of or pertaining to latria.","pos":""}],"LATRIA":[{"def":"The highest kind of worship, or that paid to God; -- distinguished by the Roman Catholics from dulia, or the inferior worship paid to saints.","pos":""}],"LATRINE":[{"def":"A privy, or water-closet, esp.","pos":""}],"LATTEN":[{"def":"A kind of brass hammered into thin sheets, formerly much used for making church utensils, as candlesticks, crosses, etc.","pos":""},{"def":"Sheet tin; iron plate, covered with tin; also, any metal in thin sheets; as, gold latten.","pos":""}],"LATTER":[{"def":"Later; more recent; coming or happening after something else; -- opposed to former; as, the former and latter rain.","pos":""},{"def":"Of two things, the one mentioned second.","pos":""}],"LATTER-DAY SAINT":[{"def":"A Mormon; -- the Church of Jesus Christ of Latter-day Saints being the name assumed by the whole body of Mormons.","pos":""}],"LATTERDAY":[{"def":"Belonging to present times or those recent by comparison.","pos":""}],"LATTERKIN":[{"def":"A pointed wooden tool used in glazing leaden lattice.","pos":""}],"LATTERLY":[{"def":"Lately; of late; recently; at a later, as distinguished from a former, period.","pos":""}],"LATTERMATH":[{"def":"The latter, or second, mowing; the aftermath.","pos":""}],"LATTICE":[{"def":"The representation of a piece of latticework used as a bearing, the bands being vertical and horizontal.","pos":""}],"LATTICEWORK":[{"def":"Same as Lattice, n.","pos":""}],"LATTICING":[{"def":"A system of bars crossing in the middle to form braces between principal longitudinal members, as of a strut.","pos":""}],"LATUS RECTUM":[{"def":"The line drawn through a focus of a conic section parallel to the directrix and terminated both ways by the curve.","pos":""}]}