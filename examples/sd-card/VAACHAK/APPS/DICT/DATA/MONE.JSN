{"MONE":[{"def":"See Monoecian, and Monoecious.","pos":""}],"MONEMBRYONY":[{"def":"The condition of an ovule having but a single embryo.","pos":""}],"MONER":[{"def":"One of the Monera.","pos":""}],"MONERA":[{"def":"The lowest division of rhizopods, including those which resemble the amoebas, but are destitute of a nucleus.","pos":""}],"MONERAL":[{"def":"Of or pertaining to the Monera.","pos":""}],"MONERAN":[{"def":"Of or pertaining to the Monera.","pos":""},{"def":"One of the Monera.","pos":""}],"MONERON":[{"def":"One of the Monera.","pos":""}],"MONERULA":[{"def":"A germ in that stage of development in which its form is simply that of a non-nucleated mass of protoplasm.","pos":""}],"MONESIA":[{"def":"The bark, or a vegetable extract brought in solid cakes from South America and believed to be derived from the bark, of the tree Chrysophyllum glycyphloeum.","pos":""}],"MONESIN":[{"def":"The acrid principle of Monesia, sometimes used as a medicine.","pos":""}],"MONEST":[{"def":"To warn; to admonish; to advise.","pos":""}],"MONETARY":[{"def":"Of or pertaining to money, or consisting of money; pecuniary.","pos":""}],"MONETIZATION":[{"def":"The act or process of converting into money, or of adopting as money; as, the monetization of silver.","pos":""}],"MONETIZE":[{"def":"To convert into money; to adopt as current money; as, to monetize silver.","pos":""}],"MONEY":[{"def":"A piece of metal, as gold, silver, copper, etc.","pos":""},{"def":"Any written or stamped promise, certificate, or order, as a government note, a bank note, a certificate of deposit, etc.","pos":""}],"MONEY-MAKER":[{"def":"One who coins or prints money; also, a counterfeiter of money.","pos":""},{"def":"One who accumulates money or wealth; specifically, one who makes money-getting his governing motive.","pos":""}],"MONEY-MAKING":[{"def":"The act or process of making money; the acquisition and accumulation of wealth.","pos":""}],"MONEYAGE":[{"def":"A tax paid to the first two Norman kings of England to prevent them from debashing the coin.","pos":""},{"def":"Mintage; coinage.","pos":""}],"MONEYED":[{"def":"Supplied with money; having money; wealthy; as, moneyey men.","pos":""},{"def":"Converted into money; coined.","pos":""}],"MONEYER":[{"def":"A person who deals in money; banker or broker.","pos":""},{"def":"An authorized coiner of money.","pos":""}],"MONEYLESS":[{"def":"Destitute of money; penniless; impecunious.","pos":""}],"MONEYWORT":[{"def":"A trailing plant (Lysimachia Nummularia), with rounded opposite leaves and solitary yellow flowers in their axils.","pos":""}]}