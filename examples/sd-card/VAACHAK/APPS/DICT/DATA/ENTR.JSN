{"ENTR'ACTE":[{"def":"The interval of time which occurs between the performance of any two acts of a drama.","pos":""},{"def":"A dance, piece of music, or interlude, performed between two acts of a drama.","pos":""}],"ENTRAIL":[{"def":"To interweave; to intertwine.","pos":""}],"ENTRAILS":[{"def":"The internal parts of animal bodies; the bowels; the guts; viscera; intestines.","pos":""},{"def":"The internal parts; as, the entrails of the earth.","pos":""}],"ENTRAIN":[{"def":"To draw along as a current does; as, water entrained by steam.","pos":""}],"ENTRAMMEL":[{"def":"To trammel; to entangle.","pos":""}],"ENTRANCE":[{"def":"The act of entering or going into; ingress; as, the entrance of a person into a house or an apartment; hence, the act of taking possession, as of property, or of office; as, the entrance of an heir upon his inheritance, or of a magistrate into office.","pos":""},{"def":"Liberty, power, or permission to enter; as, to give entrance to friends.","pos":""}],"ENTRANCEMENT":[{"def":"The act of entrancing, or the state of trance or ecstasy.","pos":""}],"ENTRANT":[{"def":"One who enters; a beginner.","pos":""},{"def":"An applicant for admission.","pos":""}],"ENTRAP":[{"def":"To catch in a trap; to insnare; hence, to catch, as in a trap, by artifices; to involve in difficulties or distresses; to catch or involve in contradictions; as, to be entrapped by the devices of evil men.","pos":""}],"ENTREAT":[{"def":"To treat, or conduct toward; to deal with; to use.","pos":""},{"def":"To treat with, or in respect to, a thing desired; hence, to ask earnestly; to beseech; to petition or pray with urgency; to supplicate; to importune.","pos":""}],"ENTREATABLE":[{"def":"That may be entreated.","pos":""}],"ENTREATER":[{"def":"One who entreats; one who asks earnestly; a beseecher.","pos":""}],"ENTREATFUL":[{"def":"Full of entreaty.","pos":""}],"ENTREATINGLY":[{"def":"In an entreating manner.","pos":""}],"ENTREATIVE":[{"def":"Used in entreaty; pleading.","pos":""}],"ENTREATMENT":[{"def":"Entreaty; invitation.","pos":""}],"ENTREATY":[{"def":"Treatment; reception; entertainment.","pos":""},{"def":"The act of entreating or beseeching; urgent prayer; earnest petition; pressing solicitation.","pos":""}],"ENTREE":[{"def":"In French usage, a dish served at the beginning of dinner to give zest to the appetite; in English usage, a side dish, served with a joint, or between the courses, as a cutlet, scalloped oysters, etc.","pos":""}],"ENTREMETS":[{"def":"A side dish; a dainty or relishing dish usually eaten after the joints or principal dish; also, a sweetmeat, served with a dinner.","pos":""}],"ENTREPOT":[{"def":"A warehouse; a magazine for depositing goods, stores, etc.","pos":""}],"ENTREPRENEUR":[{"def":"One who creates a product on his own account; whoever undertakes on his own account an industrial enterprise in which workmen are employed.","pos":""}],"ENTRESOL":[{"def":"A low story between two higher ones, usually between the ground floor and the first story; mezzanine.","pos":""}],"ENTRICK":[{"def":"To trick, to perplex.","pos":""}],"ENTROCHAL":[{"def":"Pertaining to, or consisting of, entrochites, or the joints of encrinites; -- used of a kind of stone or marble.","pos":""}],"ENTROCHITE":[{"def":"A fossil joint of a crinoid stem.","pos":""}],"ENTROPION":[{"def":"Same as Entropium.","pos":""}],"ENTROPIUM":[{"def":"The inversion or turning in of the border of the eyelids.","pos":""}],"ENTROPY":[{"def":"A certain property of a body, expressed as a measurable quantity, such that when there is no communication of heat the quantity remains constant, but when heat enters or leaves the body the quantity increases or diminishes.","pos":""}],"ENTRY":[{"def":"The exhibition or depositing of a ship's papers at the customhouse, to procure license to land goods; or the giving an account of a ship's cargo to the officer of the customs, and obtaining his permission to land the goods.","pos":""}],"ENTRYNG":[{"def":"So great an entryng and so large.","pos":""}]}