{"MEDAL":[{"def":"A piece of metal in the form of a coin, struck with a device, and intended to preserve the remembrance of a notable event or an illustrious person, or to serve as a reward.","pos":""}],"MEDAL PLAY":[{"def":"Play in which the score is reckoned by counting the number of strokes.","pos":""}],"MEDALIST":[{"def":"A person that is skilled or curious in medals; a collector of medals.","pos":""},{"def":"A designer of medals.","pos":""}],"MEDALLIC":[{"def":"Of or pertaining to a medal, or to medals.","pos":""}],"MEDALLION":[{"def":"A large medal or memorial coin.","pos":""},{"def":"A circular or oval (or, sometimes, square) tablet bearing a figure or figures represented in relief.","pos":""}],"MEDALURGY":[{"def":"The art of making and striking medals and coins.","pos":""}],"MEDDLE":[{"def":"To mix; to mingle.","pos":""},{"def":"To interest or engage one's self; to have to do; -- [Obs.","pos":""}],"MEDDLER":[{"def":"One who meddles; one who interferes or busies himself with things in which he has no concern; an officious person; a busybody.","pos":""}],"MEDDLESOME":[{"def":"Given to meddling; apt to interpose in the affairs of others; officiously intrusive.","pos":""}],"MEDDLINGLY":[{"def":"In a meddling manner.","pos":""}],"MEDE":[{"def":"A native or inhabitant of Media in Asia.","pos":""}],"MEDIA":[{"def":"One of the sonant mutes b, d, g (b, d, g), in Greek, or of their equivalents in other languages, so named as intermediate between the tenues, p, t, k (p, t, k), and the aspiratæ (aspirates) f, th, x (ph or f, th, ch).","pos":""}],"MEDIACY":[{"def":"The state or quality of being mediate.","pos":""}],"MEDIAEVAL":[{"def":"Of or relating to the Middle Ages; as, mediæval architecture.","pos":""}],"MEDIAEVALISM":[{"def":"The method or spirit of the Middle Ages; devotion to the institutions and practices of the Middle Ages; a survival from the Middle Ages.","pos":""}],"MEDIAEVALIST":[{"def":"One who has a taste for, or is versed in, the history of the Middle Ages; one in sympathy with the spirit or forms of the Middle Ages.","pos":""}],"MEDIAEVALLY":[{"def":"In the manner of the Middle Ages; in accordance with mediævalism.","pos":""}],"MEDIAEVALS":[{"def":"The people who lived in the Middle Ages.","pos":""}],"MEDIAL":[{"def":"Of or pertaining to a mean or average; mean; as, medial alligation.","pos":""}],"MEDIAN":[{"def":"Situated in the middle; lying in a plane dividing a bilateral animal into right and left halves; -- said of unpaired organs and parts; as, median coverts.","pos":""}],"MEDIANT":[{"def":"The third above the keynote; -- so called because it divides the interval between the tonic and dominant into two thirds.","pos":""}],"MEDIASTINAL":[{"def":"Of or pertaining to a mediastinum.","pos":""},{"def":"A partition; a septum; specifically, the folds of the pleura (and the space included between them) which divide the thorax into a right and left cavity.","pos":""}],"MEDIATE":[{"def":"Being between the two extremes; middle; interposed; intervening; intermediate.","pos":""},{"def":"Acting by means, or by an intervening cause or instrument; not direct or immediate; acting or suffering through an intervening agent or condition.","pos":""}],"MEDIATELY":[{"def":"In a mediate manner; by a secondary cause or agent; not directly or primarily; by means; -- opposed to immediately.","pos":""}],"MEDIATENESS":[{"def":"The state of being mediate.","pos":""}],"MEDIATION":[{"def":"The act of mediating; action or relation of anything interposed; action as a necessary condition, means, or instrument; interposition; intervention.","pos":""},{"def":"Hence, specifically, agency between parties at variance, with a view to reconcile them; entreaty for another; intercession.","pos":""}],"MEDIATIVE":[{"def":"Pertaining to mediation; used in mediation; as, mediative efforts.","pos":""}],"MEDIATIZATION":[{"def":"The act of mediatizing.","pos":""}],"MEDIATIZE":[{"def":"To cause to act through an agent or to hold a subordinate position; to annex; -- specifically applied to the annexation during the former German empire of a smaller German state to a larger, while allowing it a nominal sovereignty, and its prince his rank.","pos":""}],"MEDIATOR":[{"def":"One who mediates; especially, one who interposes between parties at variance for the purpose of reconciling them; hence, an intercessor.","pos":""}],"MEDIATORIAL":[{"def":"Of or pertaining to a mediator, or to mediation; mediatory; as, a mediatorial office.","pos":""}],"MEDIATORSHIP":[{"def":"The office or character of a mediator.","pos":""}],"MEDIATORY":[{"def":"A female mediator.","pos":""}],"MEDIC":[{"def":"A leguminous plant of the genus Medicago.","pos":""}],"MEDICABLE":[{"def":"Capable of being medicated; admitting of being cured or healed.","pos":""}],"MEDICAL":[{"def":"Of, pertaining to, or having to do with, the art of healing disease, or the science of medicine; as, the medical profession; medical services; a medical dictionary; medical jurisprudence.","pos":""},{"def":"Containing medicine; used in medicine; medicinal; as, the medical properties of a plant.","pos":""}],"MEDICALLY":[{"def":"In a medical manner; with reference to healing, or to the principles of the healing art.","pos":""}],"MEDICAMENT":[{"def":"Anything used for healing diseases or wounds; a medicine; a healing application.","pos":""}],"MEDICAMENTAL":[{"def":"Of or pertaining to medicaments or healing applications; having the qualities of medicaments.","pos":""}],"MEDICATE":[{"def":"To tincture or impregnate with anything medicinal; to drug.","pos":""},{"def":"To treat with medicine.","pos":""}],"MEDICATION":[{"def":"The act or process of medicating.","pos":""}],"MEDICATIVE":[{"def":"Medicinal; acting like a medicine.","pos":""}],"MEDICEAN":[{"def":"Of or relating to the Medici, a noted Italian family; as, the Medicean Venus.","pos":""}],"MEDICINABLE":[{"def":"Medicinal; having the power of healing.","pos":""}],"MEDICINAL":[{"def":"Having curative or palliative properties; used for the cure or alleviation of bodily disorders; as, medicinal tinctures, plants, or springs.","pos":""},{"def":"Of or pertaining to medicine; medical.","pos":""}],"MEDICINALLY":[{"def":"In a medicinal manner.","pos":""}],"MEDICINE":[{"def":"The science which relates to the prevention, cure, or alleviation of disease.","pos":""},{"def":"Any substance administered in the treatment of disease; a remedial agent; a remedy; physic.","pos":""}],"MEDICO-LEGAL":[{"def":"Of or pertaining to law as affected by medical facts.","pos":""}],"MEDICOMMISSURE":[{"def":"A large transverse commissure in the third ventricle of the brain; the middle or soft commissure.","pos":""}],"MEDICORNU":[{"def":"The middle or inferior horn of each lateral ventricle of the brain.","pos":""}],"MEDICS":[{"def":"Science of medicine.","pos":""}],"MEDIETY":[{"def":"The middle part; half; moiety.","pos":""},{"def":"Same as Medi, Medi, etc.","pos":""}],"MEDINA EPOCH":[{"def":"A subdivision of the Niagara period in the American upper Silurian, characterized by the formations known as the Oneida conglomerate, and the Medina sandstone.","pos":""}],"MEDIOCRE":[{"def":"Of a middle quality; of but a moderate or low degree of excellence; indifferent; ordinary.","pos":""}],"MEDIOCRIST":[{"def":"A mediocre person.","pos":""}],"MEDIOCRITY":[{"def":"The quality of being mediocre; a middle state or degree; a moderate degree or rate.","pos":""},{"def":"Moderation; temperance.","pos":""}],"MEDIOSTAPEDIAL":[{"def":"Pertaining to that part of the columella of the ear which, in some animals, connects the stapes with the other parts of the columella.","pos":""},{"def":"The mediostapedial part of the columella.","pos":""}],"MEDITATE":[{"def":"To keep the mind in a state of contemplation; to dwell on anything in thought; to think seriously; to muse; to cogitate; to reflect.","pos":""}],"MEDITATION":[{"def":"The act of meditating; close or continued thought; the turning or revolving of a subject in the mind; serious contemplation; reflection; musing.","pos":""},{"def":"Thought; -- without regard to kind.","pos":""}],"MEDITATIST":[{"def":"One who is given to meditation.","pos":""}],"MEDITATIVE":[{"def":"Disposed to meditate, or to meditation; as, a meditative man; a meditative mood.","pos":""}],"MEDITERRANEAN":[{"def":"Inclosed, or nearly inclosed, with land; as, the Mediterranean Sea, between Europe and Africa.","pos":""},{"def":"Inland; remote from the ocean.","pos":""}],"MEDITERRANEAN FRUIT FLY":[{"def":"A two-winged fly (Ceratitis capitata) with black and white markings, native of the Mediterranean countries, but now widely distributed.","pos":""}],"MEDITERRANEOUS":[{"def":"Med`i*ter*ra\"ne*ous, a.","pos":""}],"MEDIUM":[{"def":"The liquid vehicle with which dry colors are ground and prepared for application.","pos":""}],"MEDIUM-SIZED":[{"def":"Having a medium size; as, a medium-sized man.","pos":""}],"MEDIUS":[{"def":"The third or middle finger; the third digit, or that which corresponds to it.","pos":""}],"MEDLAR":[{"def":"A tree of the genus Mespilus (M.","pos":""}],"MEDLE":[{"def":"To mix; to mingle; to meddle.","pos":""}],"MEDLEY":[{"def":"A composition of passages detached from several different compositions; a potpourri.","pos":""}],"MEDOC":[{"def":"A class of claret wines, including several varieties, from the district of Médoc in the department of Gironde.","pos":""}],"MEDRICK":[{"def":"A species of gull or tern.","pos":""}],"MEDULLA":[{"def":"The marrow of bones; the deep or inner portion of an organ or part; as, the medulla, or medullary substance, of the kidney; specifically, the medula oblongata.","pos":""},{"def":"A soft tissue, occupying the center of the stem or branch of a plant; pith.","pos":""}],"MEDULLARY":[{"def":"Filled with spongy pith; pithy.","pos":""}],"MEDULLATED":[{"def":"Furnished with a medulla or marrow, or with a medullary sheath; as, a medullated nerve fiber.","pos":""}],"MEDULLIN":[{"def":"A variety of lignin or cellulose found in the medulla, or pith, of certain plants.","pos":""}],"MEDUSA":[{"def":"The Gorgon; or one of the Gorgons whose hair was changed into serpents, after which all who looked upon her were turned into stone.","pos":""},{"def":"Any free swimming acaleph; a jellyfish.","pos":""}],"MEDUSIFORM":[{"def":"Resembling a medusa in shape or structure.","pos":""}],"MEDUSOID":[{"def":"Like a medusa; having the fundamental structure of a medusa, but without a locomotive disk; -- said of the sessile gonophores of hydroids.","pos":""},{"def":"A sessile gonophore.","pos":""}]}