{"ANTI":[{"def":"A prefix meaning against, opposite or opposed to, contrary, or in place of; -- used in composition in many English words.","pos":""}],"ANTI-AMERICAN":[{"def":"Opposed to the Americans, their aims, or interests, or to the genius of American institutions.","pos":""}],"ANTI-FEDERALIST":[{"def":"One of party opposed to a federative government; -- applied particularly to the party which opposed the adoption of the constitution of the United States.","pos":""}],"ANTI-GALLICAN":[{"def":"Opposed to what is Gallic or French.","pos":""}],"ANTI-IMPERIALISM":[{"def":"Opposition to imperialism; -- applied specif.","pos":""}],"ANTI-SEMITISM":[{"def":"Opposition to, or hatred of, Semites, esp.","pos":""}],"ANTI-TRADE":[{"def":"A tropical wind blowing steadily in a direction opposite to the trade wind.","pos":""}]}