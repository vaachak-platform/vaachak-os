{"TRADE":[{"def":"The trade winds.","pos":""}],"TRADE NAME":[{"def":"The name or style under which a concern or firm does business.","pos":""}],"TRADE-MARK":[{"def":"A peculiar distinguishing mark or device affixed by a manufacturer or a merchant to his goods, the exclusive right of using which is recognized by law.","pos":""}],"TRADED":[{"def":"Professional; practiced.","pos":""}],"TRADEFUL":[{"def":"Full of trade; busy in traffic; commercial.","pos":""}],"TRADELESS":[{"def":"Having no trade or traffic.","pos":""}],"TRADER":[{"def":"One engaged in trade or commerce; one who makes a business of buying and selling or of barter; a merchant; a trafficker; as, a trader to the East Indies; a country trader.","pos":""},{"def":"A vessel engaged in the coasting or foreign trade.","pos":""}],"TRADESCANTIA":[{"def":"A genus including spiderwort and Wandering Jew.","pos":""}],"TRADESFOLK":[{"def":"People employed in trade; tradesmen.","pos":""}],"TRADESMAN":[{"def":"One who trades; a shopkeeper.","pos":""},{"def":"A mechanic or artificer; esp.","pos":""}],"TRADESPEOPLE":[{"def":"People engaged in trade; shopkeepers.","pos":""},{"def":"An organized combination among workmen for the purpose of maintaining their rights, privileges, and interests with respect to wages, hours of labor, customs, etc.","pos":""}],"TRADESWOMAN":[{"def":"A woman who trades, or is skilled in trade.","pos":""}],"TRADING":[{"def":"Carrying on trade or commerce; engaged in trade; as, a trading company.","pos":""},{"def":"Frequented by traders.","pos":""}],"TRADITION":[{"def":"The act of delivering into the hands of another; delivery.","pos":""},{"def":"The unwritten or oral delivery of information, opinions, doctrines, practices, rites, and customs, from father to son, or from ancestors to posterity; the transmission of any knowledge, opinions, or practice, from forefathers to descendants by oral communication, without written memorials.","pos":""}],"TRADITIONAL":[{"def":"Of or pertaining to tradition; derived from tradition; communicated from ancestors to descendants by word only; transmitted from age to age without writing; as, traditional opinions; traditional customs; traditional expositions of the Scriptures.","pos":""},{"def":"Observant of tradition; attached to old customs; old-fashioned.","pos":""}],"TRADITIONALISM":[{"def":"A system of faith founded on tradition; esp.","pos":""}],"TRADITIONALIST":[{"def":"An advocate of, or believer in, traditionalism; a traditionist.","pos":""}],"TRADITIONALLY":[{"def":"In a traditional manner.","pos":""}],"TRADITIONARILY":[{"def":"Tra*di\"tion*a*ri*ly, adv.","pos":""}],"TRADITIONARY":[{"def":"The reveries of the Talmud, a collection of Jewish traditionary interpolations.","pos":""}],"TRADITIVE":[{"def":"Transmitted or transmissible from father to son, or from age, by oral communication; traditional.","pos":""}],"TRADITOR":[{"def":"A deliverer; -- a name of infamy given to Christians who delivered the Scriptures, or the goods of the church, to their persecutors to save their lives.","pos":""}],"TRADUCE":[{"def":"To transfer; to transmit; to hand down; as, to traduce mental qualities to one's descendants.","pos":""},{"def":"To translate from one language to another; as, to traduce and compose works.","pos":""}],"TRADUCEMENT":[{"def":"The act of traducing; misrepresentation; ill-founded censure; defamation; calumny.","pos":""}],"TRADUCER":[{"def":"One who traduces; a slanderer; a calumniator.","pos":""},{"def":"One who derives or deduces.","pos":""}],"TRADUCIAN":[{"def":"A believer in traducianism.","pos":""}],"TRADUCIANISM":[{"def":"The doctrine that human souls are produced by the act of generation; -- opposed to creationism, and infusionism.","pos":""}],"TRADUCIBLE":[{"def":"Capable of being derived or propagated.","pos":""},{"def":"Capable of being traduced or calumniated.","pos":""}],"TRADUCINGLY":[{"def":"In a traducing manner; by traduction; slanderously.","pos":""}],"TRADUCT":[{"def":"To derive or deduce; also, to transmit; to transfer.","pos":""}],"TRADUCTION":[{"def":"A process of reasoning in which each conclusion applies to just such an object as each of the premises applies to.","pos":""}],"TRADUCTIVE":[{"def":"Capable of being deduced; derivable.","pos":""}]}