{"CARUCAGE":[{"def":"A tax on every plow or plowland.","pos":""}],"CARUCATE":[{"def":"A plowland; as much land as one team can plow in a year and a day; -- by some said to be about 100 acres.","pos":""},{"def":"A small fleshy prominence or excrescence; especially the small, reddish body, the caruncula lacrymalis, in the inner angle of the eye.","pos":""}],"CARUS":[{"def":"Coma with complete insensibility; deep lethargy.","pos":""}]}