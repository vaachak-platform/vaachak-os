{"PHLEBITIS":[{"def":"Inflammation of a vein.","pos":""}],"PHLEBOGRAM":[{"def":"A tracing (with the sphygmograph) of the movements of a vein, or of the venous pulse.","pos":""},{"def":"A small calcareous concretion formed in a vein; a vein stone.","pos":""}],"PHLEBOLOGY":[{"def":"A branch of anatomy which treats of the veins.","pos":""}],"PHLEBOTOMIST":[{"def":"One who practiced phlebotomy.","pos":""}],"PHLEBOTOMIZE":[{"def":"To let blood from by opening a vein; to bleed.","pos":""}],"PHLEBOTOMY":[{"def":"The act or practice of opening a vein for letting blood, in the treatment of disease; venesection; bloodletting.","pos":""}],"PHLEGETHON":[{"def":"One of the principal rivers of Hades, in the channel of which fire flowed instead of water.","pos":""}],"PHLEGM":[{"def":"Viscid mucus secreted in abnormal quantity in the respiratory and digestive passages.","pos":""},{"def":"A watery distilled liquor, in distinction from a spirituous liquor.","pos":""}],"PHLEGMAGOGUE":[{"def":"A medicine supposed to expel phlegm.","pos":""}],"PHLEGMASIA":[{"def":"An inflammation; more particularly, an inflammation of the internal organs.","pos":""}],"PHLEGMATIC":[{"def":"Abounding in phlegm; as, phlegmatic humors; a phlegmatic constitution.","pos":""}],"PHLEGMATICALLY":[{"def":"In a phlegmatic manner.","pos":""}],"PHLEGMON":[{"def":"Purulent inflammation of the cellular or areolar tissue.","pos":""}],"PHLEGMONOUS":[{"def":"Having the nature or properties of phlegmon; as, phlegmonous pneumonia.","pos":""}],"PHLEUM":[{"def":"A genus of grasses, including the timothy (Phleum pratense), which is highly valued for hay; cat's-tail grass.","pos":""}],"PHLOEM":[{"def":"That portion of fibrovascular bundles which corresponds to the inner bark; the liber tissue; -- distinguished from xylem.","pos":""}],"PHLOGISTIAN":[{"def":"A believer in the existence of phlogiston.","pos":""}],"PHLOGISTIC":[{"def":"Of or pertaining to phlogiston, or to belief in its existence.","pos":""},{"def":"Inflammatory; belonging to inflammations and fevers.","pos":""}],"PHLOGISTICATE":[{"def":"To combine phlogiston with; -- usually in the form and sense of the p.","pos":""}],"PHLOGISTICATION":[{"def":"The act or process of combining with phlogiston.","pos":""}],"PHLOGISTON":[{"def":"The hypothetical principle of fire, or inflammability, regarded by Stahl as a chemical element.","pos":""}],"PHLOGOGENOUS":[{"def":"Causing inflammation.","pos":""}],"PHLOGOPITE":[{"def":"A kind of mica having generally a peculiar bronze-red or copperlike color and a pearly luster.","pos":""}],"PHLOGOSIS":[{"def":"Inflammation of external parts of the body; erysipelatous inflammation.","pos":""}],"PHLOGOTIC":[{"def":"Of or pertaining to phlogisis.","pos":""}],"PHLORAMINE":[{"def":"A basic amido derivative of phloroglucin, having an astringent taste.","pos":""}],"PHLORETIC":[{"def":"Pertaining to, or derived from, or designating, an organic acid obtained by the decomposition of phloretin.","pos":""}],"PHLORETIN":[{"def":"A bitter white crystalline substance obtained by the decomposition of phlorizin, and formerly used to some extent as a substitute for quinine.","pos":""}],"PHLORIZIN":[{"def":"A bitter white crystalline glucoside extracted from the root bark of the apple, pear, cherry, plum, etc.","pos":""}],"PHLOROGLUCIN":[{"def":"A sweet white crystalline substance, metameric with pyrogallol, and obtained by the decomposition of phloretin, and from certain gums, as catechu, kino, etc.","pos":""}],"PHLOROL":[{"def":"A liquid metameric with xylenol, belonging to the class of phenols, and obtained by distilling certain salts of phloretic acid.","pos":""}],"PHLORONE":[{"def":"A yellow crystalline substance having a peculiar unpleasant odor, resembling the quinones, and obtained from beechwood tar and coal tar, as also by the oxidation of xylidine; -- called also xyloquinone.","pos":""}],"PHLOX":[{"def":"A genus of American herbs, having showy red, white, or purple flowers.","pos":""}],"PHLYCTENULAR":[{"def":"Characterized by the presence of small pustules, or whitish elevations resembling pustules; as, phlyctenular ophthalmia.","pos":""}]}