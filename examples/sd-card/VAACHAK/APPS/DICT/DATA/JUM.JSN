{"JUMART":[{"def":"The fabled offspring of a bull and a mare.","pos":""}],"JUMBLE":[{"def":"To mix in a confused mass; to put or throw together without order; -- often followed by together or up.","pos":""}],"JUMBLEMENT":[{"def":"Confused mixture.","pos":""}],"JUMBLER":[{"def":"One who confuses things.","pos":""}],"JUMBLINGLY":[{"def":"In a confused manner.","pos":""}],"JUMELLE":[{"def":"Twin; paired; -- said of various objects made or formed in pairs, as a binocular opera glass, a pair of gimmal rings, etc.","pos":""}],"JUMENT":[{"def":"A beast; especially, a beast of burden.","pos":""}],"JUMP":[{"def":"A bodice worn instead of stays by women in the 18th century.","pos":""}],"JUMP SPARK":[{"def":"A spark produced by the jumping of electricity across a permanent gap.","pos":""}],"JUMPER":[{"def":"The larva of the cheese fly.","pos":""},{"def":"A name applied in the 18th century to certain Calvinistic Methodists in Wales whose worship was characterized by violent convulsions.","pos":""}],"JUMPING":[{"def":"of Jump, to leap.","pos":""}],"JUMPING DISEASE":[{"def":"A convulsive tic similar to or identical with miryachit, observed among the woodsmen of Maine.","pos":""}],"JUMPWELD":[{"def":"See Buttweld, v.","pos":""}],"JUMPY":[{"def":"Jumping, or inducing to jump; characterized by jumps; hence, extremely nervous.","pos":""}]}