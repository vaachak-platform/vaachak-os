{"LOUCHETTES":[{"def":"Goggles intended to rectify strabismus by permitting vision only directly in front.","pos":""}],"LOUD":[{"def":"Having, making, or being a strong or great sound; noisy; striking the ear with great force; as, a loud cry; loud thunder.","pos":""},{"def":"Clamorous; boisterous.","pos":""}],"LOUD-MOUTHED":[{"def":"Having a loud voice; talking or sounding noisily; noisily impudent.","pos":""}],"LOUD-VOICED":[{"def":"Having a loud voice; noisy; clamorous.","pos":""}],"LOUDLY":[{"def":"In a loud manner.","pos":""}],"LOUDNESS":[{"def":"The quality or state of being loud.","pos":""}],"LOUGH":[{"def":"A loch or lake; -- so spelt in Ireland.","pos":""}],"LOUIS D'OR":[{"def":"Formerly, a gold coin of France nominally worth twenty shillings sterling, but of varying value; -- first struck in 1640.","pos":""}],"LOUIS QUATORZE":[{"def":"Of, pertaining to, or resembling, the art or style of the times of Louis XIV.","pos":""}],"LOUK":[{"def":"An accomplice; a \"pal.","pos":""}],"LOUNGE":[{"def":"To spend time lazily, whether lolling or idly sauntering; to pass time indolently; to stand, sit, or recline, in an indolent manner.","pos":""}],"LOUNGER":[{"def":"One who lounges; ar idler.","pos":""}],"LOUP-CERVIER":[{"def":"The Canada lynx.","pos":""}],"LOUP-GAROU":[{"def":"A werewolf; a lycanthrope.","pos":""}],"LOUP-LOUP":[{"def":"The Pomeranian or Spitz dog.","pos":""}],"LOUPING":[{"def":"An enzoötic, often fatal, disease of sheep and other domestic animals, of unknown cause.","pos":""}],"LOUPS":[{"def":"The Pawnees, a tribe of North American Indians whose principal totem was the wolf.","pos":""}],"LOUR":[{"def":"An Asiatic sardine (Clupea Neohowii), valued for its oil.","pos":""}],"LOUSE":[{"def":"Any one of numerous species of small, wingless, suctorial, parasitic insects belonging to a tribe (Pediculina), now usually regarded as degraded Hemiptera.","pos":""},{"def":"Any one of numerous small mandibulate insects, mostly parasitic on birds, and feeding on the feathers.","pos":""}],"LOUSEWORT":[{"def":"Any species of Pedicularis, a genus of perennial herbs.","pos":""}],"LOUSILY":[{"def":"In a lousy manner; in a mean, paltry manner; scurvily.","pos":""}],"LOUSINESS":[{"def":"The state or quality of being lousy.","pos":""}],"LOUSY":[{"def":"Infested with lice.","pos":""},{"def":"Mean; contemptible; as, lousy knave.","pos":""}],"LOUT":[{"def":"To bend; to box; to stoop.","pos":""}],"LOUTISH":[{"def":"Clownish; rude; awkward.","pos":""}],"LOUTOU":[{"def":"A crested black monkey (Semnopithecus maurus) of Java.","pos":""},{"def":"A small lantern.","pos":""}]}