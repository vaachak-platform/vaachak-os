{"ENTABLATURE":[{"def":"The superstructure which lies horizontally upon the columns.","pos":""}],"ENTABLEMENT":[{"def":"See Entablature.","pos":""}],"ENTACKLE":[{"def":"To supply with tackle.","pos":""}],"ENTAD":[{"def":"Toward the inside or central part; away from the surface; -- opposed to ectad.","pos":""}],"ENTAIL":[{"def":"That which is entailed.","pos":""},{"def":"Delicately carved ornamental work; intaglio.","pos":""}],"ENTAILMENT":[{"def":"The act of entailing or of giving, as an estate, and directing the mode of descent.","pos":""},{"def":"The condition of being entailed.","pos":""}],"ENTAL":[{"def":"Pertaining to, or situated near, central or deep parts; inner; -- opposed to ectal.","pos":""}],"ENTANGLE":[{"def":"To twist or interweave in such a manner as not to be easily separated; to make tangled, confused, and intricate; as, to entangle yarn or the hair.","pos":""},{"def":"To involve in such complications as to render extrication a bewildering difficulty; hence, metaphorically, to insnare; to perplex; to bewilder; to puzzle; as, to entangle the feet in a net, or in briers.","pos":""}],"ENTANGLEMENT":[{"def":"State of being entangled; intricate and confused involution; that which entangles; intricacy; perplexity.","pos":""}],"ENTANGLER":[{"def":"One that entangles.","pos":""}],"ENTASIA":[{"def":"Tonic spasm; -- applied generically to denote any disease characterized by tonic spasms, as tetanus, trismus, etc.","pos":""}],"ENTASIS":[{"def":"A slight convex swelling of the shaft of a column.","pos":""},{"def":"Same as Entasia.","pos":""}],"ENTASSMENT":[{"def":"A heap; accumulation.","pos":""}],"ENTASTIC":[{"def":"Relating to any disease characterized by tonic spasms.","pos":""}]}