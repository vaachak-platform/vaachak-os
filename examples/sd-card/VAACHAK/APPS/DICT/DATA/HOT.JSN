{"HOT":[{"def":"Having much sensible heat; exciting the feeling of warmth in a great degree; very warm; -- opposed to cold, and exceeding warm in degree; as, a hot stove; hot water or air.","pos":""},{"def":"Characterized by heat, ardor, or animation; easily excited; firely; vehement; passionate; violent; eager.","pos":""}],"HOT BLAST":[{"def":"See under Blast.","pos":""}],"HOT-BLOODED":[{"def":"Having hot blood; excitable; high-spirited; irritable; ardent; passionate.","pos":""}],"HOT-BRAINED":[{"def":"Ardent in temper; violent; rash; impetuous; as, hot-brained youth.","pos":""},{"def":"See Semi-diesel, below.","pos":""}],"HOT-HEAD":[{"def":"A violent, passionate person; a hasty or impetuous person; as, the rant of a hot-head.","pos":""}],"HOT-HEADED":[{"def":"Fiery; violent; rash; hasty; impetuous; vehement.","pos":""}],"HOT-LIVERED":[{"def":"Of an excitable or irritable temperament; irascible.","pos":""}],"HOT-MOUTHED":[{"def":"That hot-mouthed beast that bears against the curb.","pos":""}],"HOT-SHORT":[{"def":"More or less brittle when heated; as, hot-short iron.","pos":""}],"HOT-SPIRITED":[{"def":"Having a fierly spirit; hot-headed.","pos":""}],"HOTBED":[{"def":"A bed of earth heated by fermenting manure or other substances, and covered with glass, intended for raising early plants, or for nourishing exotics.","pos":""}],"HOTCHKISS GUN":[{"def":"A built-up, rifled, rapid-fire gun of oil-tempered steel, having a rectangular breechblock which moves horizontally or vertically in a mortise cut completely through the jacket.","pos":""},{"def":"A blending of property for equality of division, as when lands given in frank-marriage to one daughter were, after the death of the ancestor, blended with the lands descending to her and to her sisters from the same ancestor, and then divided in equal portions among all the daughters.","pos":""}],"HOTCOCKLES":[{"def":"A childish play, in which one covers his eyes, and guesses who strikes him or his hand placed behind him.","pos":""}],"HOTE":[{"def":"To command; to enjoin.","pos":""}],"HOTEL":[{"def":"A house for entertaining strangers or travelers; an inn or public house, of the better class.","pos":""},{"def":"In France, the mansion or town residence of a person of rank or wealth.","pos":""}],"HOTEL-DE-VILLE":[{"def":"A city hall or townhouse.","pos":""}],"HOTFOOT":[{"def":"In haste; foothot.","pos":""}],"HOTHOUSE":[{"def":"A heated room for drying green ware.","pos":""}],"HOTLY":[{"def":"In a hot or fiery manner; ardently; vehemently; violently; hastily; as, a hotly pursued.","pos":""},{"def":"In a lustful manner; lustfully.","pos":""}],"HOTNESS":[{"def":"The quality or state of being hot.","pos":""},{"def":"Heat or excitement of mind or manner; violence; vehemence; impetuousity; ardor; fury.","pos":""}],"HOTPRESS":[{"def":"To apply to, in conjunction with mechanical pressure, for the purpose of giving a smooth and glosay surface, or to express oil, etc.","pos":""}],"HOTPRESSED":[{"def":"Pressed while heat is applied.","pos":""}],"HOTSPUR":[{"def":"A rash, hot-headed man.","pos":""},{"def":"Violent; impetuous; headstrong.","pos":""}],"HOTTENTOT":[{"def":"One of a degraded and savage race of South Africa, with yellowish brown complexion, high cheek bones, and wooly hair growing in tufts.","pos":""}],"HOTTENTOTISM":[{"def":"A term employed to describe one of the varieties of stammering.","pos":""}]}