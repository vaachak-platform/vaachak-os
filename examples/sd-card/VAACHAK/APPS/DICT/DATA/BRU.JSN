{"BRUANG":[{"def":"The Malayan sun bear.","pos":""}],"BRUCINE":[{"def":"A poweful vegetable alkaloid, found, associated with strychnine, in the seeds of different species of Strychnos, especially in the Nux vomica.","pos":""}],"BRUCKELED":[{"def":"Wet and dirty; begrimed.","pos":""}],"BRUH":[{"def":"The rhesus monkey.","pos":""}],"BRUIN":[{"def":"A bear; -- so called in popular tales and fables.","pos":""}],"BRUISE":[{"def":"To injure, as by a blow or collision, without laceration; to contuse; as, to bruise one's finger with a hammer; to bruise the bark of a tree with a stone; to bruise an apple by letting it fall.","pos":""},{"def":"To break; as in a mortar; to bray, as minerals, roots, etc.","pos":""}],"BRUISER":[{"def":"One who, or that which, bruises.","pos":""},{"def":"A boxer; a pugilist.","pos":""}],"BRUISEWORT":[{"def":"A plant supposed to heal bruises, as the true daisy, the soapwort, and the comfrey.","pos":""}],"BRUIT":[{"def":"An abnormal sound of several kinds, heard on auscultation.","pos":""}],"BRUMAIRE":[{"def":"The second month of the calendar adopted by the first French republic.","pos":""}],"BRUMAL":[{"def":"Of or pertaining to winter.","pos":""}],"BRUME":[{"def":"Mist; fog; vapors.","pos":""}],"BRUMMAGEM":[{"def":"Counterfeit; gaudy but worthless; sham.","pos":""}],"BRUN":[{"def":"Same as Brun, a brook.","pos":""}],"BRUNETTE":[{"def":"A girl or woman with a somewhat brown or dark complexion.","pos":""},{"def":"Having a dark tint.","pos":""}],"BRUNSWICK BLACK":[{"def":"See Japan black.","pos":""}],"BRUNSWICK GREEN":[{"def":"An oxychloride of copper, used as a green pigment; also, a carbonate of copper similarly employed.","pos":""}],"BRUNT":[{"def":"The heat, or utmost violence, of an onset; the strength or greatest fury of any contention; as, the brunt of a battle.","pos":""},{"def":"The force of a blow; shock; collision.","pos":""}],"BRUSH":[{"def":"A tuft of hair on the mandibles.","pos":""},{"def":"A bundle of flexible wires or thin plates of metal, used to conduct an electrical current to or from the commutator of a dynamo, electric motor, or similar apparatus.","pos":""}],"BRUSH TURKEY":[{"def":"A large, edible, gregarious bird of Australia (Talegalla Lathami) of the family Megapodidæ.","pos":""}],"BRUSH WHEEL":[{"def":"A wheel without teeth, used to turn a similar one by the friction of bristles or something brushlike or soft attached to the circumference.","pos":""},{"def":"A circular revolving brush used by turners, lapidaries, silversmiths, etc.","pos":""}],"BRUSHER":[{"def":"One who, or that which, brushes.","pos":""}],"BRUSHINESS":[{"def":"The quality of resembling a brush; brushlike condition; shagginess.","pos":""}],"BRUSHING":[{"def":"Constructed or used to brush with; as a brushing machine.","pos":""},{"def":"Brisk; light; as, a brushing gallop.","pos":""}],"BRUSHITE":[{"def":"A white or gray crystalline mineral consisting of the acid phosphate of calcium.","pos":""}],"BRUSHWOOD":[{"def":"Brush; a thicket or coppice of small trees and shrubs.","pos":""},{"def":"Small branches of trees cut off.","pos":""}],"BRUSHY":[{"def":"Resembling a brush; shaggy; rough.","pos":""}],"BRUSK":[{"def":"Same as Brusque.","pos":""}],"BRUSQUE":[{"def":"Rough and prompt in manner; blunt; abrupt; hluff; as, a brusque man; a brusque style.","pos":""}],"BRUSQUENESS":[{"def":"Quality of being brusque; roughness joined with promptness; blutness.","pos":""}],"BRUSSELS":[{"def":"A city of Belgium, giving its name to a kind of carpet, a kind of lace, etc.","pos":""}],"BRUSTLE":[{"def":"To crackle; to rustle, as a silk garment.","pos":""},{"def":"To make a show of fireceness or defiance; to bristle.","pos":""}],"BRUTAL":[{"def":"Of or pertaining to a brute; as, brutal nature.","pos":""},{"def":"Like a brute; savage; cruel; inhuman; brutish; unfeeling; merciless; gross; as, brutal manners.","pos":""}],"BRUTALISM":[{"def":"Brutish quality; brutality.","pos":""}],"BRUTALITY":[{"def":"The quality of being brutal; inhumanity; savageness; pitilessness.","pos":""}],"BRUTALIZATION":[{"def":"The act or process of making brutal; state of being brutalized.","pos":""}],"BRUTALIZE":[{"def":"To make brutal; beasty; unfeeling; or inhuman.","pos":""}],"BRUTALLY":[{"def":"In a brutal manner; cruelly.","pos":""}],"BRUTE":[{"def":"Not having sensation; senseless; inanimate; unconscious; without intelligence or volition; as, the brute earth; the brute powers of nature.","pos":""},{"def":"Not possessing reason, irrational; unthinking; as, a brute beast; the brute creation.","pos":""}],"BRUTELY":[{"def":"In a rude or violent manner.","pos":""}],"BRUTIFY":[{"def":"To make like a brute; to make senseless, stupid, or unfeeling; to brutalize.","pos":""}],"BRUTISH":[{"def":"Pertaining to, or resembling, a brute or brutes; of a cruel, gross, and stupid nature; coarse; unfeeling; unintelligent.","pos":""}],"BRUTISM":[{"def":"The nature or characteristic qualities or actions of a brute; extreme stupidity, or beastly vulgarity.","pos":""}]}