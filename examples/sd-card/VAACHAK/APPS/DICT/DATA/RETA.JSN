{"RETABLE":[{"def":"A shelf behind the altar, for display of lights, vases of wlowers, etc.","pos":""}],"RETAIL":[{"def":"The sale of commodities in small quantities or parcels; -- opposed to wholesale; sometimes, the sale of commodities at second hand.","pos":""}],"RETAILER":[{"def":"One who retails anything; as, a retailer of merchandise; a retailer of gossip.","pos":""}],"RETAILMENT":[{"def":"The act of retailing.","pos":""}],"RETAIN":[{"def":"To continue to hold; to keep in possession; not to lose, part with, or dismiss; to retrain from departure, escape, or the like.","pos":""},{"def":"To keep in pay; to employ by a preliminary fee paid; to hire; to engage; as, to retain a counselor.","pos":""}],"RETAINABLE":[{"def":"Capable of being retained.","pos":""}],"RETAINAL":[{"def":"The act of retaining; retention.","pos":""}],"RETAINER":[{"def":"One who, or that which, retains.","pos":""},{"def":"One who is retained or kept in service; an attendant; an adherent; a hanger-on.","pos":""}],"RETAINMENT":[{"def":"The act of retaining; retention.","pos":""}],"RETAKE":[{"def":"To take or receive again.","pos":""},{"def":"To take from a captor; to recapture; as, to retake a ship or prisoners.","pos":""}],"RETAKER":[{"def":"One who takes again what has been taken; a recaptor.","pos":""}],"RETALIATE":[{"def":"To return the like for; to repay or requite by an act of the same kind; to return evil for (evil).","pos":""}],"RETALIATION":[{"def":"The act of retaliating, or of returning like for like; retribution; now, specifically, the return of evil for evil; e.","pos":""}],"RETALIATIVE":[{"def":"Same as Retaliatory.","pos":""}],"RETALIATORY":[{"def":"Tending to, or involving, retaliation; retaliative; as retaliatory measures.","pos":""}],"RETARD":[{"def":"To keep delaying; to continue to hinder; to prevent from progress; to render more slow in progress; to impede; to hinder; as, to retard the march of an army; to retard the motion of a ship; -- opposed to Ant: accelerate.","pos":""},{"def":"To put off; to postpone; as, to retard the attacks of old age; to retard a rupture between nations.","pos":""}],"RETARDATION":[{"def":"The keeping back of an approaching consonant chord by prolonging one or more tones of a previous chord into the intermediate chord which follows; -- differing from suspension by resolving upwards instead of downwards.","pos":""}],"RETARDATIVE":[{"def":"Tending, or serving, to retard.","pos":""}],"RETARDER":[{"def":"One who, or that which, retards.","pos":""}],"RETARDMENT":[{"def":"The act of retarding; retardation.","pos":""}]}