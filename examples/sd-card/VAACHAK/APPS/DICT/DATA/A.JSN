{"A B C":[{"def":"The first three letters of the alphabet, used for the whole alphabet.","pos":""},{"def":"A primer for teaching the alphabet and first elements of reading.","pos":""}],"A CHEVAL":[{"def":"Astride; with a part on each side; -- used specif.","pos":""}],"A FORTIORI":[{"def":"With stronger reason.","pos":""}],"A MENSA ET THORO":[{"def":"A kind of divorce which does not dissolve the marriage bond, but merely authorizes a separate life of the husband and wife.","pos":""}],"A POSTERIORI":[{"def":"Characterizing that kind of reasoning which derives propositions from the observation of facts, or by generalizations from facts arrives at principles and definitions, or infers causes from effects.","pos":""},{"def":"Applied to knowledge which is based upon or derived from facts through induction or experiment; inductive or empirical.","pos":""}],"A PRIORI":[{"def":"Characterizing that kind of reasoning which deduces consequences from definitions formed, or principles assumed, or which infers effects from causes previously known; deductive or deductively.","pos":""},{"def":"Applied to knowledge and conceptions assumed, or presupposed, as prior to experience, in order to make experience rational or possible.","pos":""}],"A-":[{"def":"A, as a prefix to English words, is derived from various sources.","pos":""}],"A-GOOD":[{"def":"In earnest; heartily.","pos":""}],"A-MORNINGS":[{"def":"In the morning; every morning.","pos":""}],"A-SEA":[{"def":"On the sea; at sea; toward the sea.","pos":""}],"A-TIPTOE":[{"def":"On tiptoe; eagerly expecting.","pos":""}]}