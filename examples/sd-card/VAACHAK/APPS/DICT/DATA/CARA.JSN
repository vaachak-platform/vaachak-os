{"CARABAO":[{"def":"The water buffalo.","pos":""}],"CARABID":[{"def":"Of, pertaining to, or resembling, the genus Carbus or family Carabidæ.","pos":""},{"def":"One of the Carabidæ, a family of active insectivorous beetles.","pos":""}],"CARABOID":[{"def":"Like, or pertaining to the genus Carabus.","pos":""}],"CARABUS":[{"def":"A genus of ground beetles, including numerous species.","pos":""}],"CARACAL":[{"def":"A lynx (Felis, or Lynx, caracal.","pos":""}],"CARACARA":[{"def":"A south American bird of several species and genera, resembling both the eagles and the vultures.","pos":""}],"CARACK":[{"def":"A kind of large ship formerly used by the Spaniards and Portuguese in the East India trade; a galleon.","pos":""}],"CARACOLE":[{"def":"A half turn which a horseman makes, either to the right or the left.","pos":""},{"def":"A staircase in a spiral form.","pos":""}],"CARACOLY":[{"def":"An alloy of gold, silver, and copper, of which an inferior quality of jewerly is made.","pos":""},{"def":"A light vessel or proa used by the people of Borneo, etc.","pos":""}],"CARAFE":[{"def":"A glass water bottle for the table or toilet; -- called also croft.","pos":""}],"CARAMBOLA":[{"def":"An East Indian tree (Averrhoa Carambola), and its acid, juicy fruit; called also Coromandel gooseberry.","pos":""}],"CARAMEL":[{"def":"Burnt sugar; a brown or black porous substance obtained by heating sugar.","pos":""}],"CARANGOID":[{"def":"Belonging to the Carangidæ, a family of fishes allied to the mackerels, and including the caranx, American bluefish, and the pilot fish.","pos":""}],"CARANX":[{"def":"A genus of fishes, common on the Atlantic coast, including the yellow or goldon mackerel.","pos":""}],"CARAPACE":[{"def":"The thick shell or sheild which cover the back of the tortoise, or turtle, the crab, and other crustaceous animals.","pos":""}],"CARAPATO":[{"def":"A south American tick of the genus Amblyamma.","pos":""}],"CARAT":[{"def":"The weight by which precious stones and pearls are weighed.","pos":""},{"def":"A twenty-fourth part; -- a term used in estimating the proportionate fineness of gold.","pos":""}],"CARAVAN":[{"def":"A company of travelers, pilgrims, or merchants, organized and equipped for a long journey, or marching or traveling together, esp.","pos":""},{"def":"A large, covered wagon, or a train of such wagons, for conveying wild beasts, etc.","pos":""}],"CARAVANEER":[{"def":"The leader or driver of the camels in caravan.","pos":""}],"CARAVANSARY":[{"def":"A kind of inn, in the East, where caravans rest at night, being a large, rude, unfurnished building, surrounding a court.","pos":""}],"CARAVEL":[{"def":"A name given to several kinds of vessels.","pos":""}],"CARAWAY":[{"def":"A biennial plant of the Parsley family (Carum Carui).","pos":""}]}