{"OBLANCEOLATE":[{"def":"Lanceolate in the reversed order, that is, narrowing toward the point of attachment more than toward the apex.","pos":""}],"OBLATE":[{"def":"Flattened or depressed at the poles; as, the earth is an oblate spheroid.","pos":""}],"OBLATENESS":[{"def":"The quality or state of being oblate.","pos":""}],"OBLATION":[{"def":"The act of offering, or of making an offering.","pos":""},{"def":"Anything offered or presented in worship or sacred service; an offering; a sacrifice.","pos":""}],"OBLATIONER":[{"def":"One who makes an offering as an act worship or reverence.","pos":""}],"OBLATRATE":[{"def":"To bark or snarl, as a dog.","pos":""}],"OBLATRATION":[{"def":"The act of oblatrating; a barking or snarling.","pos":""}],"OBLATUM":[{"def":"An oblate spheroid; a figure described by the revolution of an ellipse about its minor axis.","pos":""}],"OBLECTATE":[{"def":"To delight; to please greatly.","pos":""}],"OBLECTATION":[{"def":"The act of pleasing highly; the state of being greatly pleased; delight.","pos":""}],"OBLIGABLE":[{"def":"Acknowledging, or complying with, obligation; trustworthy.","pos":""}],"OBLIGATE":[{"def":"To bring or place under obligation, moral or legal; to hold by a constraining motive.","pos":""},{"def":"To bind or firmly hold to an act; to compel; to constrain; to bind to any act of duty or courtesy by a formal pledge.","pos":""}],"OBLIGATION":[{"def":"A bond with a condition annexed, and a penalty for nonfulfillment.","pos":""}],"OBLIGATORILY":[{"def":"In an obligatory manner; by reason of obligation.","pos":""}],"OBLIGATORINESS":[{"def":"The quality or state of being obligatory.","pos":""}],"OBLIGATORY":[{"def":"Binding in law or conscience; imposing duty or obligation; requiring performance or forbearance of some act; -- often followed by on or upon; as, obedience is obligatory on a soldier.","pos":""}],"OBLIGE":[{"def":"To attach, as by a bond.","pos":""},{"def":"To constrain by physical, moral, or legal force; to put under obligation to do or forbear something.","pos":""}],"OBLIGEE":[{"def":"The person to whom another is bound, or the person to whom a bond is given.","pos":""}],"OBLIGEMENT":[{"def":"I will not resist, therefore, whatever it is, either of divine or human obligement, that you lay upon me.","pos":""}],"OBLIGER":[{"def":"One who, or that which, obliges.","pos":""}],"OBLIGING":[{"def":"Putting under obligation; disposed to oblige or do favors; hence, helpful; civil; kind.","pos":""}],"OBLIGOR":[{"def":"The person who binds himself, or gives his bond to another.","pos":""}],"OBLIQUATION":[{"def":"The act of becoming oblique; a turning to one side; obliquity; as, the obliquation of the eyes.","pos":""},{"def":"Deviation from moral rectitude.","pos":""}],"OBLIQUE":[{"def":"Not erect or perpendicular; neither parallel to, nor at right angles from, the base; slanting; inclined.","pos":""},{"def":"Not straightforward; indirect; obscure; hence, disingenuous; underhand; perverse; sinister.","pos":""}],"OBLIQUE-ANGLED":[{"def":"Having oblique angles; as, an oblique-angled triangle.","pos":""}],"OBLIQUELY":[{"def":"In an oblique manner; not directly; indirectly.","pos":""}],"OBLIQUENESS":[{"def":"Quality or state of being oblique.","pos":""}],"OBLIQUITY":[{"def":"The condition of being oblique; deviation from a right line; deviation from parallelism or perpendicularity; the amount of such deviation; divergence; as, the obliquity of the ecliptic to the equator.","pos":""},{"def":"Deviation from ordinary rules; irregularity; deviation from moral rectitude.","pos":""}],"OBLITE":[{"def":"Indistinct; slurred over.","pos":""}],"OBLITERATE":[{"def":"To erase or blot out; to efface; to render undecipherable, as a writing.","pos":""},{"def":"To wear out; to remove or destroy utterly by any means; to render imperceptible; as.","pos":""}],"OBLITERATION":[{"def":"The act of obliterating, or the state of being obliterated; extinction.","pos":""}],"OBLITERATIVE":[{"def":"Tending or serving to obliterate.","pos":""}],"OBLIVION":[{"def":"The act of forgetting, or the state of being forgotten; cessation of remembrance; forgetfulness.","pos":""},{"def":"Official ignoring of offenses; amnesty, or general pardon; as, an act of oblivion.","pos":""}],"OBLIVIOUS":[{"def":"Promoting oblivion; causing forgetfulness.","pos":""},{"def":"Evincing oblivion; forgetful.","pos":""}],"OBLOCUTOR":[{"def":"A disputer; a gainsayer.","pos":""}],"OBLONG":[{"def":"Having greater length than breadth, esp.","pos":""}],"OBLONG-OVATE":[{"def":"Between oblong and ovate, but inclined to the latter.","pos":""}],"OBLONGATA":[{"def":"The medulla oblongata.","pos":""}],"OBLONGATAL":[{"def":"Of or pertaining to the medulla oblongata; medullar.","pos":""}],"OBLONGISH":[{"def":"Somewhat oblong.","pos":""}],"OBLONGLY":[{"def":"In an oblong form.","pos":""}],"OBLONGNESS":[{"def":"State or quality of being oblong.","pos":""}],"OBLONGUM":[{"def":"A prolate spheroid; a figure described by the revolution of an ellipse about its greater axis.","pos":""}],"OBLOQUIOUS":[{"def":"Containing obloquy; reproachful [R.","pos":""}],"OBLOQUY":[{"def":"Censorious speech; defamatory language; language that casts contempt on men or their actions; blame; reprehension.","pos":""},{"def":"Cause of reproach; disgrace.","pos":""}],"OBLUCTATION":[{"def":"A struggle against; resistance; opposition.","pos":""}]}