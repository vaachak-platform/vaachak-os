{"EX LIBRIS":[{"def":"An inscription, label, or the like, in a book indicating its ownership; esp.","pos":""}],"EX OFFICIO":[{"def":"From office; by virtue, or as a consequence, of an office; officially.","pos":""}],"EX PARTE":[{"def":"Upon or from one side only; one-sided; partial; as, an ex parte statement.","pos":""}],"EX-":[{"def":"The Greek form 'ex becomes ex in English, as in exarch; 'ek becomes ec, as in eccentric.","pos":""}],"EX-OFFICIAL":[{"def":"Proceeding from office or authority.","pos":""}],"EX-VOTO":[{"def":"An offering to a church in fulfillment of a vow.","pos":""}]}