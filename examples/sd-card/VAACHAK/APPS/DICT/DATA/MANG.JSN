{"MANGABEY":[{"def":"Any one of several African monkeys of the genus Cercocebus, as the sooty mangabey (C.","pos":""}],"MANGANATE":[{"def":"A salt of manganic acid.","pos":""}],"MANGANESE":[{"def":"An element obtained by reduction of its oxide, as a hard, grayish white metal, fusible with difficulty, but easily oxidized.","pos":""}],"MANGANESE STEEL":[{"def":"Cast steel containing a considerable percentage of manganese, which makes it very hard and tough.","pos":""}],"MANGANIC":[{"def":"Of, pertaining to resembling, or containing, manganese; specif.","pos":""}],"MANGANIFEROUS":[{"def":"Containing manganese.","pos":""}],"MANGANITE":[{"def":"One of the oxides of manganese; -- called also gray manganese ore.","pos":""},{"def":"A compound of manganese dioxide with a metallic oxide; so called as though derived from the hypothetical manganous acid.","pos":""}],"MANGANOUS":[{"def":"Of, pertaining to, designating, those compounds of manganese in which the element has a lower valence as contrasted with manganic compounds; as, manganous oxide.","pos":""}],"MANGCORN":[{"def":"A mixture of wheat and rye, or other species of grain.","pos":""}],"MANGE":[{"def":"The scab or itch in cattle, dogs, and other beasts.","pos":""}],"MANGEL-WURZEL":[{"def":"A kind of large field beet (B.","pos":""}],"MANGER":[{"def":"The fore part of the deck, having a bulkhead athwart ships high enough to prevent water which enters the hawse holes from running over it.","pos":""}],"MANGILY":[{"def":"In a mangy manner; scabbily.","pos":""}],"MANGINESS":[{"def":"The condition or quality of being mangy.","pos":""}],"MANGLE":[{"def":"To cut or bruise with repeated blows or strokes, making a ragged or torn wound, or covering with wounds; to tear in cutting; to cut in a bungling manner; to lacerate; to mutilate.","pos":""},{"def":"To mutilate or injure, in making, doing, or pertaining; as, to mangle a piece of music or a recitation.","pos":""}],"MANGLER":[{"def":"One who mangles or tears in cutting; one who mutilates any work in doing it.","pos":""}],"MANGO":[{"def":"The fruit of the mango tree.","pos":""},{"def":"A green muskmelon stuffed and pickled.","pos":""}],"MANGOLDWURZEL":[{"def":"See Mangel-wurzel.","pos":""}],"MANGONEL":[{"def":"A military engine formerly used for throwing stones and javelins.","pos":""}],"MANGONISM":[{"def":"The art of mangonizing, or setting off to advantage.","pos":""}],"MANGONIST":[{"def":"One who mangonizes.","pos":""},{"def":"A slave dealer; also, a strumpet.","pos":""}],"MANGONIZE":[{"def":"To furbish up for sale; to set off to advantage.","pos":""},{"def":"A tree of the East Indies of the genus Garcinia (G.","pos":""}],"MANGROVE":[{"def":"The name of one or two trees of the genus Rhizophora (R.","pos":""}],"MANGY":[{"def":"Infected with the mange; scabby.","pos":""}]}