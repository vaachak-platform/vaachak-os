{"CORSAGE":[{"def":"The waist or bodice of a lady's dress; as.","pos":""}],"CORSAIR":[{"def":"A pirate; one who cruises about without authorization from any government, to seize booty on sea or land.","pos":""},{"def":"A piratical vessel.","pos":""}],"CORSAK":[{"def":"A small foxlike mammal (Cynalopex corsac), found in Central Asia.","pos":""}],"CORSE":[{"def":"A living body or its bulk.","pos":""},{"def":"A corpse; the dead body of a human being.","pos":""}],"CORSELET":[{"def":"The thorax of an insect.","pos":""}],"CORSEPRESENT":[{"def":"An offering made to the church at the interment of a dead body.","pos":""}],"CORSET":[{"def":"In the Middle Ages, a gown or basque of which the body was close fitting, worn by both men and women.","pos":""},{"def":"An article of dress inclosing the chest and waist worn (chiefly by women) to support the body or to modify its shape; stays.","pos":""}],"CORSNED":[{"def":"The morsel of execration; a species of ordeal consisting in the eating of a piece of bread consecrated by imprecation.","pos":""}]}