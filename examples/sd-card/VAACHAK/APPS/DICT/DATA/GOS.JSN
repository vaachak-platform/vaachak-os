{"GOSHAWK":[{"def":"Any large hawk of the genus Astur, of which many species and varieties are known.","pos":""}],"GOSHERD":[{"def":"One who takes care of geese.","pos":""}],"GOSLET":[{"def":"One of several species of pygmy geese, of the genus Nettepus.","pos":""}],"GOSLING":[{"def":"A young or unfledged goose.","pos":""},{"def":"A catkin on nut trees and pines.","pos":""}],"GOSPEL":[{"def":"Glad tidings; especially, the good news concerning Christ, the Kingdom of God, and salvation.","pos":""},{"def":"One of the four narratives of the life and death of Jesus Christ, written by Matthew, Mark, Luke, and John.","pos":""}],"GOSPELER":[{"def":"One of the four evangelists.","pos":""},{"def":"A follower of Wyclif, the first English religious reformer; hence, a Puritan.","pos":""}],"GOSPELIZE":[{"def":"To form according to the gospel; as, a command gospelized to us.","pos":""},{"def":"To instruct in the gospel; to evangelize; as, to gospelize the savages.","pos":""}],"GOSSAMER":[{"def":"A fine, filmy substance, like cobwebs, floating in the air, in calm, clear weather, especially in autumn.","pos":""},{"def":"Any very thin gauzelike fabric; also, a thin waterproof stuff.","pos":""}],"GOSSAMERY":[{"def":"Like gossamer; flimsy.","pos":""}],"GOSSAN":[{"def":"Decomposed rock, usually reddish or ferruginous (owing to oxidized pyrites), forming the upper part of a metallic vein.","pos":""}],"GOSSANIFEROUS":[{"def":"Containing or producing gossan.","pos":""}],"GOSSAT":[{"def":"A small British marine fish (Motella tricirrata); -- called also whistler and three-bearded rockling.","pos":""}],"GOSSIP":[{"def":"A sponsor; a godfather or a godmother.","pos":""},{"def":"A friend or comrade; a companion; a familiar and customary acquaintance.","pos":""}],"GOSSIPER":[{"def":"One given to gossip.","pos":""}],"GOSSIPREDE":[{"def":"The relationship between a person and his sponsors.","pos":""}],"GOSSIPRY":[{"def":"Spiritual relationship or affinity; gossiprede; special intimacy.","pos":""},{"def":"Idle talk; gossip.","pos":""}],"GOSSIPY":[{"def":"Full of, or given to, gossip.","pos":""}],"GOSSOON":[{"def":"A boy; a servant.","pos":""}],"GOSSYPIUM":[{"def":"A genus of plants which yield the cotton of the arts.","pos":""}]}