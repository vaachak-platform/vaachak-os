{"MISBEAR":[{"def":"To carry improperly; to carry (one's self) wrongly; to misbehave.","pos":""}],"MISBECOME":[{"def":"Not to become; to suit ill; not to befit or be adapted to.","pos":""}],"MISBEDE":[{"def":"To wrong; to do injury to.","pos":""}],"MISBEFITTING":[{"def":"Unlawfully or irregularly begotten; of bad origin; pernicious.","pos":""}],"MISBEHAVE":[{"def":"To behave ill; to conduct one's self improperly; -- often used with a reciprocal pronoun.","pos":""}],"MISBEHAVED":[{"def":"Guilty of ill behavior; illbred; rude.","pos":""}],"MISBEHAVIOR":[{"def":"Improper, rude, or uncivil behavior; ill conduct.","pos":""}],"MISBELIEF":[{"def":"Erroneous or false belief.","pos":""}],"MISBELIEVE":[{"def":"To believe erroneously, or in a false religion.","pos":""}],"MISBELIEVER":[{"def":"One who believes wrongly; one who holds a false religion.","pos":""}],"MISBESTOW":[{"def":"To bestow improperly.","pos":""}],"MISBESTOWAL":[{"def":"The act of misbestowing.","pos":""}],"MISBILEVE":[{"def":"Misbelief; unbelief; suspicion.","pos":""}],"MISBORN":[{"def":"Born to misfortune.","pos":""}]}