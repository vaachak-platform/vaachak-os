{"PANT":[{"def":"To breathe quickly or in a labored manner, as after exertion or from eagerness or excitement; to respire with heaving of the breast; to gasp.","pos":""},{"def":"Hence: To long eagerly; to desire earnestly.","pos":""}],"PANTABLE":[{"def":"Pan\"ta*ble Defn: , n.","pos":""}],"PANTAGRUELISM":[{"def":"The theory or practice of the medical profession; -- used in burlesque or ridicule.","pos":""},{"def":"An assumption of buffoonery to cover some serious purpose.","pos":""}],"PANTALET":[{"def":"One of the legs of the loose drawers worn by children and women; particularly, the lower part of such a garment, coming below the knee, often made in a separate piece; -- chiefly in the plural.","pos":""}],"PANTALOON":[{"def":"A bifurcated garment for a man, covering the body from the waist downwards, and consisting of breeches and stockings in one.","pos":""},{"def":"In recent times, same as Trousers.","pos":""}],"PANTALOONERY":[{"def":"The character or performances of a pantaloon; buffoonery.","pos":""},{"def":"Materials for pantaloons.","pos":""}],"PANTAMORPH":[{"def":"That which assumes, or exists in, all forms.","pos":""}],"PANTAMORPHIC":[{"def":"Taking all forms.","pos":""}],"PANTASCOPE":[{"def":"A pantascopic camera.","pos":""}],"PANTASCOPIC":[{"def":"Viewing all; taking a view of the whole.","pos":""}],"PANTASTOMATA":[{"def":"One of the divisions of Flagellata, including the monads and allied forms.","pos":""}],"PANTECHNICON":[{"def":"A depository or place where all sorts of manufactured articles are collected for sale.","pos":""}],"PANTELEGRAPH":[{"def":"See under Telegraph.","pos":""}],"PANTER":[{"def":"A keeper of the pantry; a pantler.","pos":"noun"}],"PANTEUTONIC":[{"def":"Of or pertaining to all the Teutonic races.","pos":""}],"PANTHEISM":[{"def":"The doctrine that the universe, taken or conceived of as a whole, is God; the doctrine that there is no God but the combined force and laws which are manifested in the existing universe; cosmotheism.","pos":""}],"PANTHEIST":[{"def":"One who holds to pantheism.","pos":""},{"def":"Of or pertaining to pantheism; founded in, or leading to, pantheism.","pos":""}],"PANTHEOLOGIST":[{"def":"One versed in pantheology.","pos":""}],"PANTHEOLOGY":[{"def":"A system of theology embracing all religions; a complete system of theology.","pos":""}],"PANTHEON":[{"def":"A temple dedicated to all the gods; especially, the building so called at Rome.","pos":""},{"def":"The collective gods of a people, or a work treating of them; as, a divinity of the Greek pantheon.","pos":""}],"PANTHER":[{"def":"A large dark-colored variety of the leopard, by some zoölogists considered a distinct species.","pos":""},{"def":"In America, the name is applied to the puma, or cougar, and sometimes to the jaguar.","pos":""}],"PANTHERESS":[{"def":"A female panther.","pos":""}],"PANTHERINE":[{"def":"Like a panther, esp.","pos":""}],"PANTINGLY":[{"def":"With palpitation or rapid breathing.","pos":""}],"PANTISOCRACY":[{"def":"A Utopian community, in which all should rule equally, such as was devised by Coleridge, Lovell, and Southey, in their younger days.","pos":""}],"PANTISOCRAT":[{"def":"A pantisocratist.","pos":""}],"PANTISOCRATIC":[{"def":"Of or pertaining to a pantisocracy.","pos":""}],"PANTISOCRATIST":[{"def":"One who favors or supports the theory of a pantisocracy.","pos":""}],"PANTLER":[{"def":"The servant or officer, in a great family, who has charge of the bread and the pantry.","pos":""}],"PANTOCHRONOMETER":[{"def":"An instrument combining a compass, sundial, and universal time dial.","pos":""}],"PANTOFLE":[{"def":"A slipper for the foot.","pos":""}],"PANTOGRAPH":[{"def":"An instrument for copying plans, maps, and other drawings, on the same, or on a reduced or an enlarged, scale.","pos":""},{"def":"Of or pertaining to a pantograph; relating to pantography.","pos":""}],"PANTOGRAPHY":[{"def":"A general description; entire view of an object.","pos":""}],"PANTOLOGICAL":[{"def":"Of or pertaining to pantology.","pos":""}],"PANTOLOGIST":[{"def":"One versed in pantology; a writer of pantology.","pos":""}],"PANTOLOGY":[{"def":"A systematic view of all branches of human knowledge; a work of universal information.","pos":""}],"PANTOMETER":[{"def":"An instrument for measuring angles for determining elevations, distances, etc.","pos":""}],"PANTOMETRY":[{"def":"Universal measurement.","pos":""}],"PANTOMIME":[{"def":"A universal mimic; an actor who assumes many parts; also, any actor.","pos":""},{"def":"One who acts his part by gesticulation or dumb show only, without speaking; a pantomimist.","pos":""}],"PANTOMIMIST":[{"def":"An actor in pantomime; also, a composer of pantomimes.","pos":""}],"PANTON":[{"def":"A horseshoe to correct a narrow, hoofbound heel.","pos":""}],"PANTOPHAGIST":[{"def":"A person or an animal that has the habit of eating all kinds of food.","pos":""}],"PANTOPHAGOUS":[{"def":"Eating all kinds of food.","pos":""}],"PANTOPHAGY":[{"def":"The habit or power of eating all kinds of food.","pos":""}],"PANTOPODA":[{"def":"Same as Pycnogonida.","pos":""}],"PANTOSCOPIC":[{"def":"Literally, seeing everything; -- a term applied to eyeglasses or spectacles divided into two segments, the upper being designed for distant vision, the lower for vision of near objects.","pos":""}],"PANTRY":[{"def":"An apartment or closet in which bread and other provisions are kept.","pos":""}]}