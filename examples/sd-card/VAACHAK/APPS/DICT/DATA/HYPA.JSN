{"HYPALLAGE":[{"def":"A figure consisting of a transference of attributes from their proper subjects to other.","pos":""}],"HYPALLELOMORPH":[{"def":"See Allelomorph.","pos":""}],"HYPANTHIUM":[{"def":"A fruit consisting in large part of a receptacle, enlarged below the calyx, as in the alycanthus, the rose hip, and the pear.","pos":""}],"HYPAPOPHYSIS":[{"def":"A process, or other element, of a vertebra developed from the ventral side of the centrum, as hæmal spines, and chevron bones.","pos":""}],"HYPARTERIAL":[{"def":"Situated below an artery; applied esp.","pos":""}],"HYPASPIST":[{"def":"A shield-bearer or armor-bearer.","pos":""}],"HYPAXIAL":[{"def":"Beneath the axis of the skeleton; subvertebral; hyposkeletal.","pos":""}]}