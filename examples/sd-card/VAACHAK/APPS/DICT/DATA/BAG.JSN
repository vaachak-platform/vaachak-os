{"BAG":[{"def":"A certain quantity of a commodity, such as it is customary to carry to market in a sack; as, a bag of pepper or hops; a bag of coffee.","pos":""}],"BAG NET":[{"def":"A bag-shaped net for catching fish.","pos":""}],"BAGATELLE":[{"def":"A trifle; a thing of no importance.","pos":""},{"def":"A game played on an oblong board, having, at one end, cups or arches into or through which balls are to be driven by a rod held in the hand of the player.","pos":""}],"BAGGAGE":[{"def":"The clothes, tents, utensils, and provisions of an army.","pos":""},{"def":"The trunks, valises, satchels, etc.","pos":""}],"BAGGAGE MASTER":[{"def":"One who has charge of the baggage at a railway station or upon a line of public travel.","pos":""}],"BAGGAGER":[{"def":"One who takes care of baggage; a camp follower.","pos":""}],"BAGGALA":[{"def":"A two-masted Arab or Indian trading vessel, used in Indian Ocean.","pos":""}],"BAGGILY":[{"def":"In a loose, baggy way.","pos":""}],"BAGGING":[{"def":"Cloth or other material for bags.","pos":""},{"def":"The act of putting anything into, or as into, a bag.","pos":""}],"BAGGY":[{"def":"Resembling a bag; loose or puffed out, or pendent, like a bag; flabby; as, baggy trousers; baggy cheeks.","pos":""}],"BAGMAN":[{"def":"A commercial traveler; one employed to solicit orders for manufacturers and tradesmen.","pos":""}],"BAGNIO":[{"def":"A house for bathing, sweating, etc.","pos":""},{"def":"A brothel; a stew; a house of prostitution.","pos":""}],"BAGPIPE":[{"def":"A musical wind instrument, now used chiefly in the Highlands of Scotland.","pos":""}],"BAGPIPER":[{"def":"One who plays on a bagpipe; a piper.","pos":""}],"BAGREEF":[{"def":"The lower reef of fore and aft sails; also, the upper reef of topsails.","pos":""}],"BAGUE":[{"def":"The annular molding or group of moldings dividing a long shaft or clustered column into two or more parts.","pos":""},{"def":"A small molding, like the astragal, but smaller; a bead.","pos":""}],"BAGWIG":[{"def":"A wig, in use in the 18th century, with the hair at the back of the head in a bag.","pos":""}],"BAGWORM":[{"def":"One of several lepidopterous insects which construct, in the larval state, a baglike case which they carry about for protection.","pos":""}]}