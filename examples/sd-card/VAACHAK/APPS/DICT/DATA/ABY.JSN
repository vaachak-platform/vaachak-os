{"ABYSM":[{"def":"An abyss; a gulf.","pos":""}],"ABYSMAL":[{"def":"Pertaining to, or resembling, an abyss; bottomless; unending; profound.","pos":""}],"ABYSMALLY":[{"def":"To a fathomless depth; profoundly.","pos":""}],"ABYSS":[{"def":"The center of an escutcheon.","pos":""}],"ABYSSAL":[{"def":"Belonging to, or resembling, an abyss; unfathomable.","pos":""}],"ABYSSINIAN":[{"def":"Of or pertaining to Abyssinia.","pos":""}]}