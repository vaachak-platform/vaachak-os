{"SHAKE":[{"def":"To give a tremulous tone to; to trill; as, to shake a note in music.","pos":""}],"SHAKEDOWN":[{"def":"A temporary substitute for a bed, as one made on the floor or on chairs; -- perhaps originally from the shaking down of straw for this purpose.","pos":""}],"SHAKEFORK":[{"def":"A fork for shaking hay; a pitchfork.","pos":""}],"SHAKEN":[{"def":"Caused to shake; agitated; as, a shaken bough.","pos":""},{"def":"Cracked or checked; split.","pos":""}],"SHAKER":[{"def":"A variety of pigeon.","pos":""}],"SHAKERESS":[{"def":"A female Shaker.","pos":""}],"SHAKERISM":[{"def":"Doctrines of the Shakers.","pos":""}],"SHAKESPEAREAN":[{"def":"Of, pertaining to, or in the style of, Shakespeare or his works.","pos":""}],"SHAKINESS":[{"def":"Quality of being shaky.","pos":""}],"SHAKINGS":[{"def":"Deck sweepings, refuse of cordage, canvas, etc.","pos":""}],"SHAKO":[{"def":"A kind of military cap or headress.","pos":""}],"SHAKUDO":[{"def":"An alloy of copper, invented by the Japanese, having a very dark blue color approaching black.","pos":""}],"SHAKY":[{"def":"Shaking or trembling; as, a shaky spot in a marsh; a shaky hand.","pos":""},{"def":"Full of shakes or cracks; cracked; as, shaky timber.","pos":""}]}