{"FUCHS":[{"def":"A student of the first year.","pos":""}],"FUCHSIA":[{"def":"A genus of flowering plants having elegant drooping flowers, with four sepals, four petals, eight stamens, and a single pistil.","pos":""}],"FUCHSINE":[{"def":"Aniline red; an artificial coal-tar dyestuff, of a metallic green color superficially, resembling cantharides, but when dissolved forming a brilliant dark red.","pos":""}],"FUCIVOROUS":[{"def":"Eating fucus or other seaweeds.","pos":""}],"FUCOID":[{"def":"A plant, whether recent or fossil, which resembles a seaweed.","pos":""}],"FUCOIDAL":[{"def":"Containing impressions of fossil fucoids or seaweeds; as, fucoidal sandstone.","pos":""}],"FUCUS":[{"def":"A genus of tough, leathery seaweeds, usually of a dull brownish green color; rockweed.","pos":""}],"FUCUSOL":[{"def":"An oily liquid, resembling, and possibly identical with, furfurol, and obtained from fucus, and other seaweeds.","pos":""}]}