{"EMBILLOW":[{"def":"To swell or heave like a [R.","pos":""}],"EMBIOTOCOID":[{"def":"Belonging to, or resembling, the Embiotocidæ.","pos":""},{"def":"One of a family of fishes (Embiotocidæ) abundant on the coast of California, remarkable for being viviparous; -- also called surf fishes and viviparous fishes.","pos":""}],"EMBITTER":[{"def":"To make bitter or sad.","pos":""}],"EMBITTERMENT":[{"def":"The act of embittering; also, that which embitters.","pos":""}]}