{"STAPEDIAL":[{"def":"Of or pertaining to stapes.","pos":""}],"STAPELIA":[{"def":"An extensive and curious genus of African plants of the natural order Asclepiadaceæ (Milkweed family).","pos":""}],"STAPES":[{"def":"The innermost of the ossicles of the ear; the stirrup, or stirrup bone; -- so called from its form.","pos":""}],"STAPHYLINE":[{"def":"Of or pertaining to the uvula or the palate.","pos":""}],"STAPHYLINID":[{"def":"Any rove beetle.","pos":""}],"STAPHYLOMA":[{"def":"A protrusion of any part of the globe of the eye; as, a staphyloma of the cornea.","pos":""}],"STAPHYLOMATOUS":[{"def":"Of or pertaining to staphyloma; affected with staphyloma.","pos":""}],"STAPHYLOPLASTY":[{"def":"The operation for restoring or replacing the soft palate when it has been lost.","pos":""},{"def":"The operation of uniting a cleft palate, consisting in paring and bringing together the edges of the cleft.","pos":""}],"STAPHYLOTOMY":[{"def":"The operation of removing a staphyloma by cutting.","pos":""}],"STAPLE":[{"def":"A settled mart; an emporium; a city or town to which merchants brought commodities for sale or exportation in bulk; a place for wholesale traffic.","pos":""},{"def":"Hence: Place of supply; source; fountain head.","pos":""}],"STAPLER":[{"def":"A dealer in staple goods.","pos":""},{"def":"One employed to assort wool according to its staple.","pos":""}]}