{"FUGACIOUS":[{"def":"Fleeting; lasting but a short time; -- applied particularly to organs or parts which are short-lived as compared with the life of the individual.","pos":""}],"FUGACITY":[{"def":"The quality of being fugacious; fugaclousness; volatility; as, fugacity of spirits.","pos":""},{"def":"Uncertainty; instability.","pos":""}],"FUGATO":[{"def":"in the gugue style, but not strictly like a fugue.","pos":""},{"def":"A composition resembling a fugue.","pos":""}],"FUGH":[{"def":"An exclamation of disgust; foh; faugh.","pos":""}],"FUGHETTA":[{"def":"a short, condensed fugue.","pos":""}],"FUGITIVE":[{"def":"Fleeing from pursuit, danger, restraint, etc.","pos":""},{"def":"Not fixed; not durable; liable to disappear or fall away; volatile; uncertain; evanescent; liable to fade; -- applied to material and immaterial things; as, fugitive colors; a fugitive idea.","pos":""}],"FUGITIVELY":[{"def":"In a fugitive manner.","pos":""}],"FUGITIVENESS":[{"def":"The quality or condition of being fugitive; evanescence; volatility; fugacity; instability.","pos":""}],"FUGLE":[{"def":"To maneuver; to move hither and thither.","pos":""}],"FUGLEMAN":[{"def":"A soldier especially expert and well drilled, who takes his place in front of a military company, as a guide for the others in their exercises; a file leader.","pos":""}],"FUGUE":[{"def":"A polyphonic composition, developed from a given theme or themes, according to strict contrapuntal rules.","pos":""}],"FUGUIST":[{"def":"A musician who composes or performs fugues.","pos":""},{"def":"A suffix signifying full of, abounding with; as, boastful, harmful, woeful.","pos":""}]}