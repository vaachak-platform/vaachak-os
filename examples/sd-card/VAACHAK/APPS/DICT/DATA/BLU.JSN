{"BLUB":[{"def":"To swell; to puff out, as with weeping.","pos":""}],"BLUBBER":[{"def":"A large sea nettle or medusa.","pos":""}],"BLUBBERED":[{"def":"Swollen; turgid; as, a blubbered lip.","pos":""}],"BLUBBERING":[{"def":"The act of weeping noisily.","pos":""}],"BLUBBERY":[{"def":"Swollen; protuberant.","pos":""},{"def":"Like blubber; gelatinous and quivering; as, a blubbery mass.","pos":""}],"BLUCHER":[{"def":"A kind of half boot, named from the Prussian general Blücher.","pos":""}],"BLUDGEON":[{"def":"A short stick, with one end loaded, or thicker and heavier that the other, used as an offensive weapon.","pos":""}],"BLUE":[{"def":"Having the color of the clear sky, or a hue resembling it, whether lighter or darker; as, the deep, blue sea; as blue as a sapphire; blue violets.","pos":""},{"def":"Pale, without redness or glare, -- said of a flame; hence, of the color of burning brimstone, betokening the presence of ghosts or devils; as, the candle burns blue; the air was blue with oaths.","pos":""}],"BLUE BOOK":[{"def":"A parliamentary publication, so called from its blue paper covers.","pos":""},{"def":"The United States official \"Biennial Register.","pos":""}],"BLUE GRASS":[{"def":"A species of grass (Poa compressa) with bluish green stems, valuable in thin gravelly soils; wire grass.","pos":""}],"BLUE HEN STATE":[{"def":"The State of Delaware; -- a popular sobriquet.","pos":""}],"BLUE JAY":[{"def":"The common jay of the United States (Cyanocitta, or Cyanura, cristata).","pos":""}],"BLUE-EYE":[{"def":"The blue-cheeked honeysucker of Australia.","pos":""}],"BLUE-EYED":[{"def":"Having blue eyes.","pos":""}],"BLUE-EYED GRASS":[{"def":"a grasslike plant (Sisyrinchium anceps), with small flowers of a delicate blue color.","pos":""}],"BLUE-GRASS STATE":[{"def":"The Sate of Kentucky; -- a nickname alluding to the blue-grass region, where fine horses are bred.","pos":""}],"BLUE-JOHN":[{"def":"A name given to fluor spar in Derbyshire, where it is used for ornamental purposes.","pos":""}],"BLUE-VEINED":[{"def":"Having blue veins or blue streaks.","pos":""}],"BLUEBEARD":[{"def":"The hero of a mediæval French nursery legend, who, leaving home, enjoined his young wife not to open a certain room in his castle.","pos":""}],"BLUEBERRY":[{"def":"The berry of several species of Vaccinium, and ericaceous genus, differing from the American huckleberries in containing numerous minute seeds instead of ten nutlets.","pos":""}],"BLUEBILL":[{"def":"A duck of the genus Fuligula.","pos":""}],"BLUEBIRD":[{"def":"A small song bird (Sialia sialis), very common in the United States, and, in the north, one of the earliest to arrive in spring.","pos":""}],"BLUEBOTTLE":[{"def":"A plant (Centaurea cyanus) which grows in grain fields.","pos":""},{"def":"A large and troublesome species of blowfly (Musca vomitoria).","pos":""}],"BLUEBREAST":[{"def":"A small European bird; the blue-throated warbler.","pos":""}],"BLUECAP":[{"def":"A Scot; a Scotchman; -- so named from wearing a blue bonnet.","pos":""}],"BLUECOAT":[{"def":"One dressed in blue, as a soldier, a sailor, a beadle, etc.","pos":""}],"BLUEFIN":[{"def":"A species of whitefish (Coregonus nigripinnis) found in Lake Michigan.","pos":""}],"BLUEFISH":[{"def":"A large voracious fish (Pomatomus saitatrix), of the family Carangidæ, valued as a food fish, and widely distributed on the American coast.","pos":""},{"def":"A West Indian fish (Platyglossus radiatus), of the family Labridæ.","pos":""}],"BLUEGOWN":[{"def":"One of a class of paupers or pensioners, or licensed beggars, in Scotland, to whim annually on the king's birthday were distributed certain alms, including a blue gown; a beadsman.","pos":""}],"BLUELY":[{"def":"With a blue color.","pos":""}],"BLUENESS":[{"def":"The quality of being blue; a blue color.","pos":""}],"BLUENOSE":[{"def":"A nickname for a Nova Scotian.","pos":""},{"def":"A Nova Scotian; also, a Nova Scotian ship (called also Blue\"nos`er); a Nova Scotian potato, etc.","pos":""}],"BLUEPOLL":[{"def":"A kind of salmon (Salmo Cambricus) found in Wales.","pos":""}],"BLUEPRINT":[{"def":"See under Print.","pos":""}],"BLUESTOCKING":[{"def":"The American avocet (Recurvirostra Americana).","pos":""}],"BLUESTOCKINGISM":[{"def":"The character or manner of a bluestocking; female pedantry.","pos":""}],"BLUESTONE":[{"def":"A grayish blue building stone, as that commonly used in the eastern United States.","pos":""}],"BLUETHROAT":[{"def":"A singing bird of northern Europe and Asia (Cyanecula Suecica), related to the nightingales; -- called also blue-throated robin and blue-throated warbler.","pos":""}],"BLUETS":[{"def":"A name given to several different species of plants having blue flowers, as the Houstonia coerulea, the Centaurea cyanus or bluebottle, and the Vaccinium angustifolium.","pos":""}],"BLUEWING":[{"def":"The blue-winged teal.","pos":""}],"BLUFF":[{"def":"Having a broad, flattened front; as, the bluff bows of a ship.","pos":""},{"def":"Rising steeply with a flat or rounded front.","pos":""}],"BLUFF-BOWED":[{"def":"Built with the stem nearly straight up and down.","pos":""}],"BLUFF-HEADED":[{"def":"Built with the stem nearly straight up and down.","pos":""}],"BLUFFNESS":[{"def":"The quality or state of being bluff.","pos":""}],"BLUFFY":[{"def":"Having bluffs, or bold, steep banks.","pos":""},{"def":"Inclined to bo bluff; brusque.","pos":""}],"BLUING":[{"def":"The act of rendering blue; as, the bluing of steel.","pos":""},{"def":"Something to give a bluish tint, as indigo, or preparations used by washerwomen.","pos":""}],"BLUISH":[{"def":"Somewhat blue; as, bluish veins.","pos":""}],"BLUNDER":[{"def":"To make a gross error or mistake; as, to blunder in writing or preparing a medical prescription.","pos":""},{"def":"To move in an awkward, clumsy manner; to flounder and stumble.","pos":""}],"BLUNDERBUSS":[{"def":"A short gun or firearm, with a large bore, capable of holding a number of balls, and intended to do execution without exact aim.","pos":""},{"def":"A stupid, blundering fellow.","pos":""}],"BLUNDERER":[{"def":"One who is apt to blunder.","pos":""}],"BLUNDERHEAD":[{"def":"A stupid, blundering fellow.","pos":""}],"BLUNDERING":[{"def":"Characterized by blunders.","pos":""}],"BLUNDERINGLY":[{"def":"In a blundering manner.","pos":""}],"BLUNGE":[{"def":"To amalgamate and blend; to beat up or mix in water, as clay.","pos":""}],"BLUNGER":[{"def":"A wooden blade with a cross handle, used for mi Tomlinson.","pos":""}],"BLUNGING":[{"def":"The process of mixing clay in potteries with a blunger.","pos":""}],"BLUNT":[{"def":"Having a thick edge or point, as an instrument; dull; not sharp.","pos":""},{"def":"Dull in understanding; slow of discernment; stupid; -- opposed to acute.","pos":""}],"BLUNT-WITTED":[{"def":"Blunt-witted lord, ignoble in demeanor! Shak.","pos":""}],"BLUNTLY":[{"def":"In a blunt manner; coarsely; plainly; abruptly; without delicacy, or the usual forms of civility.","pos":""}],"BLUNTNESS":[{"def":"Want of edge or point; dullness; obtuseness; want of sharpness.","pos":""},{"def":"A bruptness of address; rude plainness.","pos":""}],"BLUR":[{"def":"To render obscure by making the form or outline of confused and uncertain, as by soiling; to smear; to make indistinct and confused; as, to blur manuscript by handling it while damp; to blur the impression of a woodcut by an excess of ink.","pos":""},{"def":"To cause imperfection of vision in; to dim; to darken.","pos":""}],"BLURRY":[{"def":"Full of blurs; blurred.","pos":""}],"BLURT":[{"def":"To utter suddenly and unadvisedly; to divulge inconsiderately; to ejaculate; -- commonly with out.","pos":""}],"BLUSH":[{"def":"To become suffused with red in the cheeks, as from a sense of shame, modesty, or confusion; to become red from such cause, as the cheeks or face.","pos":""},{"def":"To grow red; to have a red or rosy color.","pos":""}],"BLUSHER":[{"def":"One that blushes.","pos":""}],"BLUSHFUL":[{"def":"Full of blushes.","pos":""}],"BLUSHING":[{"def":"Showing blushes; rosy red; having a warm and delicate color like some roses and other flowers; blooming; ruddy; roseate.","pos":""}],"BLUSHINGLY":[{"def":"In a blushing manner; with a blush or blushes; as, to answer or confess blushingly.","pos":""}],"BLUSHLESS":[{"def":"Free from blushes; incapable of blushing; shameless; impudent.","pos":""}],"BLUSHY":[{"def":"Like a blush; having the color of a blush; rosy.","pos":""}],"BLUSTER":[{"def":"To blow fitfully with violence and noise, as wind; to be windy and boisterous, as the weather.","pos":""},{"def":"To talk with noisy violence; to swagger, as a turbulent or boasting person; to act in a noisy, tumultuous way; to play the bully; to storm; to rage.","pos":""}],"BLUSTERER":[{"def":"One who, or that which, blusters; a noisy swaggerer.","pos":""}],"BLUSTERING":[{"def":"Exhibiting noisy violence, as the wind; stormy; tumultuous.","pos":""},{"def":"Uttering noisy threats; noisy and swaggering; boisterous.","pos":""}],"BLUSTERINGLY":[{"def":"In a blustering manner.","pos":""}],"BLUSTEROUS":[{"def":"Inclined to bluster; given to blustering; blustering.","pos":""}]}