{"PAS":[{"def":"A pace; a step, as in a dance.","pos":""},{"def":"Right of going foremost; precedence.","pos":""}],"PASAN":[{"def":"The passover; the feast of Easter.","pos":""}],"PASCHAL":[{"def":"Of or pertaining to the passover, or to Easter; as, a paschal lamb; paschal eggs.","pos":""}],"PASENG":[{"def":"The wild or bezoar goat.","pos":""}],"PASH":[{"def":"To strike; to crush; to smash; to dash in pieces.","pos":""}],"PASHA":[{"def":"An honorary title given to officers of high rank in Turkey, as to governers of provinces, military commanders, etc.","pos":""}],"PASHALIC":[{"def":"The jurisdiction of a pasha.","pos":""}],"PASHAW":[{"def":"Of or pertaining to pasigraphy.","pos":""}],"PASIGRAPHY":[{"def":"A system of universal writing, or a manner of writing that may be understood and used by all nations.","pos":""}],"PASILALY":[{"def":"A form of speech adapted to be used by all mankind; universal language.","pos":""}],"PASPY":[{"def":"A kind of minuet, in triple time, of French origin, popular in the reign of Queen Elizabeth and for some time after; -- called also passing measure, and passymeasure.","pos":""}],"PASQUILANT":[{"def":"A lampooner; a pasquiler.","pos":""}],"PASQUIN":[{"def":"A lampooner; also, a lampoon.","pos":""}],"PASQUINADE":[{"def":"A lampoon or satirical writing.","pos":""}],"PASS":[{"def":"To be conveyed or transferred by will, deed, or other instrument of conveyance; as, an estate passes by a certain clause in a deed.","pos":""},{"def":"To make a lunge or pass; to thrust.","pos":""}],"PASS-KEY":[{"def":"A key for opening more locks than one; a master key.","pos":""}],"PASS-PAROLE":[{"def":"An order passed from front to rear by word of mouth.","pos":""}],"PASSABLE":[{"def":"Capable of being passed, traveled, navigated, traversed, penetrated, or the like; as, the roads are not passable; the stream is passablein boats.","pos":""},{"def":"Capable of being freely circulated or disseminated; acceptable; generally receivable; current.","pos":""}],"PASSABLENESS":[{"def":"The quality of being passable.","pos":""}],"PASSABLY":[{"def":"Tolerably; moderately.","pos":""},{"def":"An old Italian or Spanish dance tune, in slow three-four measure, with divisions on a ground bass, resembling a chaconne.","pos":""}],"PASSAGE":[{"def":"The act of passing; transit from one place to another; movement from point to point; a going by, over, across, or through; as, the passage of a man or a carriage; the passage of a ship or a bird; the passage of light; the passage of fluids through the pores or channels of the body.","pos":""},{"def":"Transit by means of conveyance; journey, as by water, carriage, car, or the like; travel; right, liberty, or means, of passing; conveyance.","pos":""}],"PASSAGER":[{"def":"A passenger; a bird or boat of passage.","pos":""}],"PASSAGEWAY":[{"def":"A way for passage; a hall.","pos":""}],"PASSANT":[{"def":"Walking; -- said of any animal on an escutcheon, which is represented as walking with the dexter paw raised.","pos":""},{"def":"Past; gone by; hence, past one's prime; worn; faded; as, a passée belle.","pos":""}],"PASSE PARTOUT":[{"def":"That by which one can pass anywhere; a safe-conduct.","pos":""},{"def":"A master key; a latchkey.","pos":""}],"PASSEGARDE":[{"def":"A ridge or projecting edge on a shoulder piece to turn the blow of a lance or other weapon from the joint of the armor.","pos":""}],"PASSEMENT":[{"def":"Lace, gimp, braid etc.","pos":""}],"PASSEMENTERIE":[{"def":"Beaded embroidery for women's dresses.","pos":""}],"PASSENGER":[{"def":"A passer or passer-by; a wayfarer.","pos":""},{"def":"A traveler by some established conveyance, as a coach, steamboat, railroad train, etc.","pos":""}],"PASSENGER MILE":[{"def":"A unit of measurement of the passenger transportation performed by a railroad during a given period, usually a year, the total of which consists of the sum of the miles traversed by all the passengers on the road in the period in question.","pos":""}],"PASSENGER MILEAGE":[{"def":"Passenger miles collectively; the total number of miles traveled by passengers on a railroad during a given period.","pos":""}],"PASSER":[{"def":"One who passes; a passenger.","pos":""}],"PASSER-BY":[{"def":"One who goes by; a passer.","pos":""}],"PASSERES":[{"def":"An order, or suborder, of birds, including more that half of all the known species.","pos":""}],"PASSERIFORM":[{"def":"Like or belonging to the Passeres.","pos":""}],"PASSERINE":[{"def":"Of or pertaining to the Passeres.","pos":""}],"PASSIBILITY":[{"def":"The quality or state of being passible; aptness to feel or suffer; sensibility.","pos":""}],"PASSIBLE":[{"def":"Susceptible of feeling or suffering, or of impressions from external agents.","pos":""}],"PASSIFLORA":[{"def":"A genus of plants, including the passion flower.","pos":""}],"PASSIM":[{"def":"Here and there; everywhere; as, this word occurs passim in the poem.","pos":""}],"PASSING":[{"def":"The act of one who, or that which, passes; the act of going by or away.","pos":""}],"PASSION":[{"def":"A suffering or enduring of imposed or inflicted pain; any suffering or distress (as, a cardiac passion); specifically, the suffering of Christ between the time of the last supper and his death, esp.","pos":""},{"def":"The state of being acted upon; subjection to an external agent or influence; a passive condition; -- opposed to action.","pos":""}],"PASSIONAL":[{"def":"Of or pertaining to passion or the passions; exciting, influenced by, or ministering to, the passions.","pos":""}],"PASSIONARY":[{"def":"A book in which are described the sufferings of saints and martyrs.","pos":""}],"PASSIONATE":[{"def":"Capable or susceptible of passion, or of different passions; easily moved, excited or agitated; specifically, easily moved to anger; irascible; quick-tempered; as, a passionate nature.","pos":""},{"def":"Characterized by passion; expressing passion; ardent in feeling or desire; vehement; warm; as, a passionate friendship.","pos":""}],"PASSIONATELY":[{"def":"In a passionate manner; with strong feeling; ardently.","pos":""},{"def":"Angrily; irascibly.","pos":""}],"PASSIONATENESS":[{"def":"The state or quality of being passionate.","pos":""}],"PASSIONIST":[{"def":"A member of a religious order founded in Italy in 1737, and introduced into the United States in 1852.","pos":""}],"PASSIONLESS":[{"def":"Void of passion; without anger or emotion; not easily excited; calm.","pos":""}],"PASSIONTIDE":[{"def":"The last fortnight of Lent.","pos":""}],"PASSIVE":[{"def":"Inactive; inert; not showing strong affinity; as, red phosphorus is comparatively passive.","pos":""},{"def":"Designating certain morbid conditions, as hemorrhage or dropsy, characterized by relaxation of the vessels and tissues, with deficient vitality and lack of reaction in the affected tissues.","pos":""}],"PASSIVE FLIGHT":[{"def":"Flight, such as gliding and soaring, accomplished without the use of motive power.","pos":""}],"PASSIVELY":[{"def":"In a passive manner; inertly; unresistingly.","pos":""},{"def":"As a passive verb; in the passive voice.","pos":""}],"PASSIVENESS":[{"def":"The quality or state of being passive; unresisting submission.","pos":""}],"PASSIVITY":[{"def":"The tendency of a body to remain in a given state, either of motion or rest, till disturbed by another body; inertia.","pos":""},{"def":"The quality or condition of any substance which has no inclination to chemical activity; inactivity.","pos":""}],"PASSLESS":[{"def":"Having no pass; impassable.","pos":""}],"PASSMAN":[{"def":"One who passes for a degree, without honors.","pos":""}],"PASSOVER":[{"def":"Hebrews in Egypt, when God, smiting the firstborn of the Egyptians, passed over the houses of the Israelites which were marked with the blood of a lamb.","pos":""}],"PASSPORT":[{"def":"Permission to pass; a document given by the competent officer of a state, permitting the person therein named to pass or travel from place to place, without molestation, by land or by water.","pos":""},{"def":"A document carried by neutral merchant vessels in time of war, to certify their nationality and protect them from belligerents; a sea letter.","pos":""}],"PASSUS":[{"def":"A division or part; a canto; as, the passus of Piers Plowman.","pos":""}],"PASSWORD":[{"def":"A word to be given before a person is allowed to pass; a watchword; a countersign.","pos":""}],"PAST":[{"def":"Of or pertaining to a former time or state; neither present nor future; gone by; elapsed; ended; spent; as, past troubles; past offences.","pos":""}],"PASTE":[{"def":"The mineral substance in which other minerals are imbedded.","pos":""}],"PASTEBOARD":[{"def":"A board on which pastry dough is rolled; a molding board.","pos":""}],"PASTEL":[{"def":"A plant affording a blue dye; the woad (Isatis tinctoria); also, the dye itself.","pos":""}],"PASTER":[{"def":"One who pastes; as, a paster in a government department.","pos":""},{"def":"A slip of paper, usually bearing a name, intended to be pasted by the voter, as a substitute, over another name on a printed ballot.","pos":""}],"PASTERN":[{"def":"The part of the foot of the horse, and allied animals, between the fetlock and the coffin joint.","pos":""},{"def":"A shackle for horses while pasturing.","pos":""}],"PASTEUR'S FLUID":[{"def":"An artificial nutrient fluid invented by Pasteur for the study of alcoholic fermentation, but used also for the cultivation of bacteria and other organisms.","pos":""}],"PASTEURIAN":[{"def":"Of or pertaining to Pasteur.","pos":""}],"PASTEURISM":[{"def":"A method of treatment, devised by Pasteur, for preventing certain diseases, as hydrophobia, by successive inoculations with an attenuated virus of gradually increasing strength.","pos":""}],"PASTEURIZATION":[{"def":"A process devised by Pasteur for preventing or checking fermentation in fluids, such as wines, milk, etc.","pos":""}],"PASTEURIZE":[{"def":"To subject to pasteurization.","pos":""},{"def":"To treat by pasteurizm.","pos":""}],"PASTEURIZER":[{"def":"One that Pasteurizes, specif.","pos":""}],"PASTICCIO":[{"def":"A small cone or mass made of paste of gum, benzoin, cinnamon, and other aromatics, -- used for fumigating or scenting the air of a room.","pos":""}],"PASTIME":[{"def":"That which amuses, and serves to make time pass agreeably; sport; amusement; diversion.","pos":""}],"PASTOR":[{"def":"A species of starling (Pastor roseus), native of the plains of Western Asia and Eastern Europe.","pos":""}],"PASTORAGE":[{"def":"The office, jurisdiction, or duty, of a pastor; pastorate.","pos":""}],"PASTORAL":[{"def":"Of or pertaining to shepherds; hence, relating to rural life and scenes; as, a pastoral life.","pos":""},{"def":"Relating to the care of souls, or to the pastor of a church; as, pastoral duties; a pastoral letter.","pos":""}],"PASTORALE":[{"def":"A composition in a soft, rural style, generally in 6-8 or 12-8 time.","pos":""}],"PASTORALLY":[{"def":"In a pastoral or rural manner.","pos":""},{"def":"In the manner of a pastor.","pos":""}],"PASTORATE":[{"def":"The office, state, or jurisdiction of a pastor.","pos":""}],"PASTORIUM":[{"def":"A parsonage; -- so called in some Baptist churches.","pos":""}],"PASTORLESS":[{"def":"Having no pastor.","pos":""}],"PASTORLING":[{"def":"An insignificant pastor.","pos":""}],"PASTORLY":[{"def":"Appropriate to a pastor.","pos":""}],"PASTRY":[{"def":"The place where pastry is made.","pos":""},{"def":"Articles of food made of paste, or having a crust made of paste, as pies, tarts, etc.","pos":""}],"PASTURABLE":[{"def":"Fit for pasture.","pos":""}],"PASTURAGE":[{"def":"Grazing ground; grass land used for pasturing; pasture.","pos":""},{"def":"Grass growing for feed; grazing.","pos":""}],"PASTURE":[{"def":"Food; nourishment.","pos":""},{"def":"Specifically: Grass growing for the food of cattle; the food of cattle taken by grazing.","pos":""}],"PASTURELESS":[{"def":"Destitute of pasture.","pos":""}],"PASTURER":[{"def":"One who pastures; one who takes cattle to graze.","pos":""}],"PASTY":[{"def":"Like paste, as in color, softness, stickness.","pos":""}]}