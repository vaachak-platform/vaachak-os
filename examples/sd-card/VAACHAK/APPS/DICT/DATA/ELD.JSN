{"ELD":[{"def":"Old times; former days; antiquity.","pos":""}],"ELDER":[{"def":"Older; more aged, or existing longer.","pos":""},{"def":"Born before another; prior in years; senior; earlier; older; as, his elder brother died in infancy; -- opposed to Ant: younger, and now commonly applied to a son, daughter, child, brother, etc.","pos":""}],"ELDERBERRY":[{"def":"The berrylike drupe of the elder.","pos":""}],"ELDERISH":[{"def":"Somewhat old; elderly.","pos":""}],"ELDERLY":[{"def":"Somewhat old; advanced beyond middle age; bordering on old age; as, elderly people.","pos":""}],"ELDERN":[{"def":"He would discharge us as boys do eldern guns.","pos":""}],"ELDERSHIP":[{"def":"The state of being older; seniority.","pos":""},{"def":"Office of an elder; collectively, a body of elders.","pos":""}],"ELDEST":[{"def":"Oldest; longest in duration.","pos":""},{"def":"Born or living first, or before the others, as a son, daughter, brother, etc.","pos":""}],"ELDRITCH":[{"def":"Hideous; ghastly; as, an eldritch shriek or laugh.","pos":""}]}