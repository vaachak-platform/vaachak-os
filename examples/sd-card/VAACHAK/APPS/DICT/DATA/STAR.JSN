{"STAR":[{"def":"A planet supposed to influence one's destiny; (usually pl.","pos":""},{"def":"A composition of combustible matter used in the heading of rockets, in mines, etc.","pos":""}],"STAR DRIFT":[{"def":"Similar and probably related motion of the stars of an asterism, as distinguished from apparent change of place due to solar motion.","pos":""}],"STAR STEREOGRAM":[{"def":"A view of the universe of brighter stars as it would appear to an observer transported into space outside or beyond our universe of stars.","pos":""}],"STAR-BOWLINES":[{"def":"The men in the starboard watch.","pos":""}],"STAR-CHAMBER":[{"def":"An ancient high court exercising jurisdiction in certain cases, mainly criminal, which sat without the intervention of a jury.","pos":""}],"STAR-CROSSED":[{"def":"Not favored by the stars; ill-fated.","pos":""}],"STAR-READ":[{"def":"Doctrine or knowledge of the stars; star lore; astrology; astronomy.","pos":""}],"STAR-SPANGLED":[{"def":"Spangled or studded with stars.","pos":""}],"STARBOARD":[{"def":"That side of a vessel which is one of the right hand of a person who stands on board facing the bow; -- opposed to Ant: larboard, or Ant: port.","pos":""}],"STARCH":[{"def":"Stiff; precise; rigid.","pos":""}],"STARCHED":[{"def":"Stiffened with starch.","pos":""},{"def":"Stiff; precise; formal.","pos":""}],"STARCHEDNESS":[{"def":"The quality or state of being starched; stiffness in manners; formality.","pos":""}],"STARCHER":[{"def":"One who starches.","pos":""}],"STARCHLY":[{"def":"In a starched or starch manner.","pos":""}],"STARCHNESS":[{"def":"Of or pertaining to starched or starch; stiffness of manner; preciseness.","pos":""}],"STARCHWORT":[{"def":"The cuckoopint, the tubers of which yield a fine quality of starch.","pos":""}],"STARCHY":[{"def":"Consisting of starch; resembling starch; stiff; precise.","pos":""}],"STARE":[{"def":"To look with fixed eyes wide open, as through fear, wonder, surprise, impudence, etc.","pos":""},{"def":"To be very conspicuous on account of size, prominence, color, or brilliancy; as, staring windows or colors.","pos":""}],"STARER":[{"def":"One who stares, or gazes.","pos":""}],"STARFINCH":[{"def":"The European redstart.","pos":""}],"STARFISH":[{"def":"Any one of numerous species of echinoderms belonging to the class Asterioidea, in which the body is star-shaped and usually has five rays, though the number of rays varies from five to forty or more.","pos":""},{"def":"The dollar fish, or butterfish.","pos":""}],"STARGASER":[{"def":"Any one of several species of spiny-rayed marine fishes belonging to Uranoscopus, Astroscopus, and allied genera, of the family Uranoscopidæ.","pos":""}],"STARGASING":[{"def":"The act or practice of observing the stars with attention; contemplation of the stars as connected with astrology or astronomy.","pos":""},{"def":"Hence, absent-mindedness; abstraction.","pos":""}],"STARINGLY":[{"def":"With a staring look.","pos":""}],"STARK":[{"def":"Complete; absolute; full; perfect; entire.","pos":""}],"STARKLY":[{"def":"In a stark manner; stiffly; strongly.","pos":""}],"STARKNESS":[{"def":"The quality or state of being stark.","pos":""}],"STARLESS":[{"def":"Being without stars; having no stars visible; as, a starless night.","pos":""}],"STARLIGHT":[{"def":"The light given by the stars.","pos":""}],"STARLIKE":[{"def":"Resembling a star; stellated; radiated like a star; as, starlike flowers.","pos":""},{"def":"Shining; bright; illustrious.","pos":""}],"STARLING":[{"def":"Any passerine bird belonging to Sturnus and allied genera.","pos":""},{"def":"A California fish; the rock trout.","pos":""}],"STARLIT":[{"def":"Lighted by the stars; starlight.","pos":""}],"STARMONGER":[{"def":"A fortune teller; an astrologer; -- used in contempt.","pos":""}],"STARN":[{"def":"The European starling.","pos":""}],"STARNOSE":[{"def":"A curious American mole (Condylura cristata) having the nose expanded at the end into a stellate disk; -- called also star-nosed mole.","pos":""}],"STAROST":[{"def":"A nobleman who possessed a starosty.","pos":""}],"STAROSTY":[{"def":"A castle and domain conferred on a nobleman for life.","pos":""}],"STARPROOF":[{"def":"Impervious to the light of the stars; as, a starproof elm.","pos":""}],"STARRED":[{"def":"Adorned or studded with stars; bespangled.","pos":""},{"def":"Influenced in fortune by the stars.","pos":""}],"STARRINESS":[{"def":"The quality or state of being starry; as, the starriness of the heavens.","pos":""}],"STARRY":[{"def":"Abounding with stars; adorned with stars.","pos":""},{"def":"Consisting of, or proceeding from, the stars; stellar; stellary; as, starry light; starry flame.","pos":""}],"STARSHINE":[{"def":"The light of the stars.","pos":""}],"STARSTONE":[{"def":"Asteriated sapphire.","pos":""}],"START":[{"def":"To leap; to jump.","pos":""},{"def":"To move suddenly, as with a spring or leap, from surprise, pain, or other sudden feeling or emotion, or by a voluntary act.","pos":""}],"START-UP":[{"def":"One who comes suddenly into notice; an upstart.","pos":""},{"def":"A kind of high rustic shoe.","pos":""}],"STARTER":[{"def":"One who, or that which, starts; as, a starter on a journey; the starter of a race.","pos":""},{"def":"A dog that rouses game.","pos":""}],"STARTFUL":[{"def":"Apt to start; skittish.","pos":""}],"STARTFULNESS":[{"def":"Aptness to start.","pos":""}],"STARTHROAT":[{"def":"Any humming bird of the genus Heliomaster.","pos":""}],"STARTINGLY":[{"def":"By sudden fits or starts; spasmodically.","pos":""}],"STARTISH":[{"def":"Apt to start; skittish; shy; -- said especially of a horse.","pos":""}],"STARTLE":[{"def":"To move suddenly, or be excited, on feeling alarm; to start.","pos":""}],"STARTLINGLY":[{"def":"In a startling manner.","pos":""}],"STARTLISH":[{"def":"Easily startled; apt to start; startish; skittish; -- said especially of a hourse.","pos":""}],"STARVATION":[{"def":"The act of starving, or the state of being starved.","pos":""}],"STARVE":[{"def":"To die; to perish.","pos":""},{"def":"To perish with hunger; to suffer extreme hunger or want; to be very indigent.","pos":""}],"STARVEDLY":[{"def":"In the condition of one starved or starving; parsimoniously.","pos":""}],"STARVELING":[{"def":"One who, or that which, pines from lack or food, or nutriment.","pos":""}]}