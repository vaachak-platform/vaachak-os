{"CHAM":[{"def":"The sovereign prince of Tartary; -- now usually written khan.","pos":""}],"CHAMADE":[{"def":"A signal made for a parley by beat of a drum.","pos":""}],"CHAMAL":[{"def":"The Angora goat.","pos":""}],"CHAMBER":[{"def":"Apartments in a lodging house.","pos":""},{"def":"A room or rooms where a lawyer transacts business; a room or rooms where a judge transacts such official business as may be done out of court.","pos":""}],"CHAMBERED":[{"def":"Having a chamber or chambers; as, a chambered shell; a chambered gun.","pos":""}],"CHAMBERER":[{"def":"One who attends in a chamber; a chambermaid.","pos":""},{"def":"A civilian; a carpetmonger.","pos":""}],"CHAMBERLAIN":[{"def":"An officer or servant who has charge of a chamber or chambers.","pos":""},{"def":"An upper servant of an inn.","pos":""}],"CHAMBERLAINSHIP":[{"def":"Office if a chamberlain.","pos":""}],"CHAMBERMAID":[{"def":"A maidservant who has the care of chambers, making the beds, sweeping, cleaning the rooms, etc.","pos":""}],"CHAMBERTIN":[{"def":"A red wine from Chambertin near Dijon, in Burgundy.","pos":""}],"CHAMBRANLE":[{"def":"An ornamental bordering or framelike decoration around the sides and top of a door, window, or fireplace.","pos":""}],"CHAMBRAY":[{"def":"A gingham woven in plain colors with linen finish.","pos":""}],"CHAMBREL":[{"def":"Same as Gambrel.","pos":""}],"CHAMECK":[{"def":"A kind of spider monkey (Ateles chameck), having the thumbs rudimentary and without a nail.","pos":""}],"CHAMELEON":[{"def":"A lizardlike reptile of the genus Chamæleo, of several species, found in Africa, Asia, and Europe.","pos":""}],"CHAMELEONIZE":[{"def":"To change into various colors.","pos":""}],"CHAMFER":[{"def":"The surface formed by cutting away the arris, or angle, formed by two faces of a piece of timber, stone, etc.","pos":""}],"CHAMFRET":[{"def":"A small gutter; a furrow; a groove.","pos":""}],"CHAMFRON":[{"def":"The frontlet, or head armor, of a horse.","pos":""}],"CHAMISAL":[{"def":"A California rosaceous shrub (Adenostoma fasciculatum) which often forms an impenetrable chaparral.","pos":""}],"CHAMOIS":[{"def":"A small species of antelope (Rupicapra tragus), living on the loftiest mountain ridges of Europe, as the Alps, Pyrenees, etc.","pos":""}],"CHAMP":[{"def":"To bite with repeated action of the teeth so as to be heard.","pos":""},{"def":"To bite into small pieces; to crunch.","pos":""}],"CHAMPAGNE":[{"def":"A light wine, of several kinds, originally made in the province of Champagne, in France.","pos":""}],"CHAMPAIGN":[{"def":"A flat, open country.","pos":""}],"CHAMPER":[{"def":"One who champs, or bites.","pos":""}],"CHAMPERTOR":[{"def":"One guilty of champerty; one who purchases a suit, or the right of suing, and carries it on at his own expense, in order to obtain a share of the gain.","pos":""}],"CHAMPERTY":[{"def":"Partnership in power; equal share of authority.","pos":""}],"CHAMPIGNON":[{"def":"An edible species of mushroom (Agaricus campestris).","pos":""}],"CHAMPION":[{"def":"One who engages in any contest; esp.","pos":""},{"def":"One who by defeating all rivals, has obtained an acknowledged supremacy in any branch of athetics or game of skill, and is ready to contend with any rival; as, the champion of England.","pos":""}],"CHAMPIONNESS":[{"def":"A female champion.","pos":""}],"CHAMPIONSHIP":[{"def":"State of being champion; leadership; supremancy.","pos":""}],"CHAMPLAIN PERIOD":[{"def":"A subdivision of the Quaternary age immediately following the Glacial period; -- so named from beds near Lake Champlain.","pos":""}],"CHAMPLEVE":[{"def":"Having the ground engraved or cut out in the parts to be enameled; inlaid in depressions made in the ground; -- said of a kind of enamel work in which depressions made in the surface are filled with enamel pastes, which are afterward fired; also, designating the process of making such enamel work.","pos":""},{"def":"A piece of champlevé enamel; also, the process or art of making such enamel work; champlevé work.","pos":""}]}