{"CATHARINE WHEEL":[{"def":"See catherine wheel.","pos":""}],"CATHARIST":[{"def":"One aiming at or pretending to a greater purity of like than others about him; -- applied to persons of various sects.","pos":""}],"CATHARSIS":[{"def":"A natural or artificial purgation of any passage, as of the mouth, bowels, etc.","pos":""},{"def":"Cleansing the bowels; promoting evacuations by stool; purgative.","pos":""}],"CATHARTIC":[{"def":"A medicine that promotes alvine discharges; a purge; a purgative of moderate activity.","pos":""}],"CATHARTIN":[{"def":"The bitter, purgative principle of senna.","pos":""}],"CATHAY":[{"def":"China; -- an old name for the Celestial Empire, said have been introduced by Marco Polo and to be a corruption of the Tartar name for North China (Khitai, the country of the Khitans.","pos":""}],"CATHEAD":[{"def":"A projecting piece of timber or iron near the bow of vessel, to which the anchor is hoisted and secured.","pos":""}],"CATHEDRA":[{"def":"The official chair or throne of a bishop, or of any person in high authority.","pos":""}],"CATHEDRAL":[{"def":"The principal church in a diocese, so called because in it the bishop has his official chair (Cathedra) or throne.","pos":""}],"CATHEDRATED":[{"def":"Relating to the chair or office of a teacher.","pos":""}],"CATHERETIC":[{"def":"A mild kind caustic used to reduce warts and other excrescences.","pos":""}],"CATHERINE WHEEL":[{"def":"Same as Rose window and Wheel window.","pos":""},{"def":"A revolving piece of fireworks resembling in form the window of the same name.","pos":""}],"CATHETER":[{"def":"The name of various instruments for passing along mucous canals, esp.","pos":""},{"def":"The operation of introducing a catheter.","pos":""}],"CATHETERIZE":[{"def":"To operate on with a catheter.","pos":""}],"CATHETOMETER":[{"def":"An instrument for the accurate measurement of small differences of height; esp.","pos":""}],"CATHETUS":[{"def":"One line or radius falling perpendicularly on another; as, the catheti of a right-angled triangle, that is, the two sides that include the right angle.","pos":""}],"CATHODE":[{"def":"The part of a voltaic battery by which the electric current leaves substances through which it passes, or the surface at which the electric current passes out of the electrolyte; the negative pole; -- opposed to anode.","pos":""}],"CATHODIC":[{"def":"A term applied to the centrifugal, or efferent course of the nervous infuence.","pos":""},{"def":"A picture produced by the Röntgen rays; a radiograph.","pos":""}],"CATHOLIC":[{"def":"Universal or general; as, the catholic faith.","pos":""},{"def":"Not narrow-minded, partial, or bigoted; liberal; as, catholic tastes.","pos":""}],"CATHOLICISM":[{"def":"The state or quality of being catholic or universal; catholicity.","pos":""},{"def":"Liberality of sentiment; breadth of view.","pos":""}],"CATHOLICITY":[{"def":"The state or quality of being catholic; universality.","pos":""},{"def":"Liberality of sentiments; catholicism.","pos":""}],"CATHOLICIZE":[{"def":"To make or to become catholic or Roman Catholic.","pos":""}],"CATHOLICLY":[{"def":"In a catholic manner; generally; universally.","pos":""}],"CATHOLICNESS":[{"def":"The quality of being catholic; universality; catholicity.","pos":""}],"CATHOLICON":[{"def":"A remedy for all diseases; a panacea.","pos":""}],"CATHOLICOS":[{"def":"The spiritual head of the Armenian church, who resides at Etchmiadzin, Russia, and has ecclesiastical jurisdiction over, and consecrates the holy oil for, the Armenians of Russia, Turkey, and Persia, including the Patriarchs of Constantinople, Jerusalem, and Sis.","pos":""}]}