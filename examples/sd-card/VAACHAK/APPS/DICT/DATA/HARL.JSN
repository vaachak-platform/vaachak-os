{"HARL":[{"def":"A filamentous substance; especially, the filaments of flax or hemp.","pos":""},{"def":"A barb, or barbs, of a fine large feather, as of a peacock or ostrich, -- used in dressing artificial flies.","pos":""}],"HARLE":[{"def":"The red-breasted merganser.","pos":""}],"HARLECH GROUP":[{"def":"A minor subdivision at the base of the Cambrian system in Wales.","pos":""}],"HARLEQUIN":[{"def":"A buffoon, dressed in party-colored clothes, who plays tricks, often without speaking, to divert the bystanders or an audience; a merry-andrew; originally, a droll rogue of Italian comedy.","pos":""}],"HARLEQUINADE":[{"def":"A play or part of play in which the harlequin is conspicuous; the part of a harlequin.","pos":""}],"HARLOCK":[{"def":"Probably a corruption either of charlock or hardock.","pos":""}],"HARLOT":[{"def":"A churl; a common man; a person, male or female, of low birth.","pos":""},{"def":"A person given to low conduct; a rogue; a cheat; a rascal.","pos":""}],"HARLOTRY":[{"def":"Ribaldry; buffoonery; a ribald story.","pos":""},{"def":"The trade or practice of prostitution; habitual or customary lewdness.","pos":""}]}