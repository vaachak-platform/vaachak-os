{"HERE":[{"def":"In this place; in the place where the speaker is; -- opposed to Ant: there.","pos":""},{"def":"In the present life or state.","pos":""}],"HERE-AT":[{"def":"At, or by reason of, this; as, he was offended hereat.","pos":""}],"HEREAFTER":[{"def":"In time to come; in some future time or state.","pos":""}],"HEREAFTERWARD":[{"def":"Here*aft\"er*ward, adv.","pos":""}],"HEREBY":[{"def":"By means of this.","pos":""},{"def":"Close by; very near.","pos":""}],"HEREDITABILITY":[{"def":"State of being hereditable.","pos":""}],"HEREDITABLE":[{"def":"Capable of being inherited.","pos":""},{"def":"Qualified to inherit; capable of inheriting.","pos":""}],"HEREDITAMENT":[{"def":"Any species of property that may be inherited; lands, tenements, anything corporeal or incorporeal, real, personal, or mixed, that may descend to an heir.","pos":""}],"HEREDITARILY":[{"def":"By inheritance; in an hereditary manner.","pos":""}],"HEREDITARY":[{"def":"Descended, or capable of descending, from an ancestor to an heir at law; received or passing by inheritance, or that must pass by inheritance; as, an hereditary estate or crown.","pos":""},{"def":"Transmitted, or capable of being transmitted, as a constitutional quality or condition from a parent to a child; as, hereditary pride, bravery, disease.","pos":""}],"HEREDITY":[{"def":"Hereditary transmission of the physical and psychical qualities of parents to their offspring; the biological law by which living beings tend to repeat their characteristics in their descendants.","pos":""}],"HEREFORD":[{"def":"One of a breed of cattle originating in Herefordshire, England.","pos":""}],"HEREIN":[{"def":"Herein is my Father glorified, that ye bear much fruit.","pos":""}],"HEREINAFTER":[{"def":"In the following part of this (writing, document, speech, and the like).","pos":""}],"HEREINBEFORE":[{"def":"In the preceding part of this (writing, document, book, etc.","pos":""}],"HEREINTO":[{"def":"HEREMIT; HEREMITE Her\"e*mit, Her\"e*mite, n.","pos":""}],"HEREMITICAL":[{"def":"Of or pertaining to a hermit; solitary; secluded from society.","pos":""}],"HEREOF":[{"def":"Of this; concerning this; from this; hence.","pos":""}],"HEREON":[{"def":"On or upon this; hereupon.","pos":""}],"HERESIARCH":[{"def":"A leader in heresy; the chief of a sect of heretics.","pos":""}],"HERESIARCHY":[{"def":"A chief or great heresy.","pos":""}],"HERESIOGRAPHER":[{"def":"One who writes on heresies.","pos":""}],"HERESIOGRAPHY":[{"def":"A treatise on heresy.","pos":""}],"HERESY":[{"def":"Religious opinion opposed to the authorized doctrinal standards of any particular church, especially when tending to promote schism or separation; lack of orthodox or sound belief; rejection of, or erroneous belief in regard to, some fundamental religious doctrine or truth; heterodoxy.","pos":""},{"def":"An offense against Christianity, consisting in a denial of some essential doctrine, which denial is publicly avowed, and obstinately maintained.","pos":""}],"HERETIC":[{"def":"One who having made a profession of Christian belief, deliberately and pertinaciously refuses to believe one or more of the articles of faith \"determined by the authority of the universal church.","pos":""}],"HERETICAL":[{"def":"Containing heresy; of the nature of, or characterized by, heresy.","pos":""}],"HERETICALLY":[{"def":"In an heretical manner.","pos":""}],"HERETICATE":[{"def":"To decide to be heresy or a heretic; to denounce as a heretic or heretical.","pos":""}],"HERETIFICATION":[{"def":"The act of hereticating or pronouncing heretical.","pos":""}],"HERETO":[{"def":"To this; hereunto.","pos":""},{"def":"The leader or commander of an army; also, a marshal.","pos":""}],"HERETOFORE":[{"def":"Up to this time; hitherto; before; in time past.","pos":""}],"HEREUNTO":[{"def":"Unto this; up to this time; hereto.","pos":""}],"HEREUPON":[{"def":"On this; hereon.","pos":""}]}