{"SEMIRADIAL ENGINE":[{"def":"See Radial engine, above.","pos":""}],"SEMIRECONDITE":[{"def":"Half hidden or half covered; said of the head of an insect when half covered by the shield of the thorax.","pos":""}],"SEMIRING":[{"def":"One of the incomplete rings of the upper part of the bronchial tubes of most birds.","pos":""}]}