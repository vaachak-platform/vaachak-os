{"OVERT":[{"def":"Not covert; open; public; manifest; as, an overt act of treason.","pos":""}],"OVERTAKE":[{"def":"To come up with in a course, pursuit, progress, or motion; to catch up with.","pos":""},{"def":"To come upon from behind; to discover; to surprise; to capture; to overcome.","pos":""}],"OVERTALK":[{"def":"To talk to excess.","pos":""}],"OVERTASK":[{"def":"To task too heavily.","pos":""}],"OVERTAX":[{"def":"To tax or to task too heavily.","pos":""}],"OVERTEMPT":[{"def":"To tempt exceedingly, or beyond the power of resistance.","pos":""}],"OVERTHROW":[{"def":"To throw over; to overturn; to upset; to turn upside down.","pos":""},{"def":"To cause to fall or to fail; to subvert; to defeat; to make a ruin of; to destroy.","pos":""}],"OVERTHWART":[{"def":"Having a transverse position; placed or situated across; hence, opposite.","pos":""},{"def":"Crossing in kind or disposition; perverse; adverse; opposing.","pos":""}],"OVERTHWARTLY":[{"def":"In an overthwart manner;across; also, perversely.","pos":""}],"OVERTHWARTNESS":[{"def":"The state of being overthwart; perverseness.","pos":""}],"OVERTILT":[{"def":"To tilt over; to overturn.","pos":""}],"OVERTIME":[{"def":"Time beyond, or in excess of, a limit; esp.","pos":""}],"OVERTIRE":[{"def":"To tire to excess; to exhaust.","pos":""}],"OVERTITLE":[{"def":"To give too high a title to.","pos":""}],"OVERTLY":[{"def":"Publicly; openly.","pos":""}],"OVERTOIL":[{"def":"To weary excessively; to exhaust.","pos":""}],"OVERTONE":[{"def":"One of the harmonics faintly heard with and above a tone as it dies away, produced by some aliquot portion of the vibrating sting or column of air which yields the fundamental tone; one of the natural harmonic scale of tones, as the octave, twelfth, fifteenth, etc.","pos":""}],"OVERTOP":[{"def":"To rise above the top of; to exceed in height; to tower above.","pos":""},{"def":"To go beyond; to transcend; to transgress.","pos":""}],"OVERTOWER":[{"def":"To tower over or above.","pos":""}],"OVERTRADE":[{"def":"To trade beyond one's capital; to buy goods beyond the means of paying for or seleng them; to overstock the market.","pos":""}],"OVERTRADING":[{"def":"The act or practice of buying goods beyond the means of payment; a glutting of the market.","pos":""}],"OVERTREAD":[{"def":"To tread over or upon.","pos":""}],"OVERTRIP":[{"def":"To trip over nimbly.","pos":""}],"OVERTROUBLED":[{"def":"Excessively troubled.","pos":""}],"OVERTROW":[{"def":"To be too trustful or confident; to trust too much.","pos":""}],"OVERTRUST":[{"def":"Excessive confidence.","pos":""}],"OVERTURE":[{"def":"A composition, for a full orchestra, designed as an introduction to an oratorio, opera, or ballet, or as an independent piece; -- called in the latter case a concert overture.","pos":""}],"OVERTURN":[{"def":"To turn or throw from a basis, foundation, or position; to overset; as, to overturn a carriage or a building.","pos":""},{"def":"To subvert; to destroy; to overthrow.","pos":""}],"OVERTURNABLE":[{"def":"Capable of being, or liable to be, overturned or subverted.","pos":""}],"OVERTURNER":[{"def":"One who overturns.","pos":""}]}