{"ASSUAGE":[{"def":"To soften, in a figurative sense; to allay, mitigate, ease, or lessen, as heat, pain, or grief; to appease or pacify, as passion or tumult; to satisfy, as appetite or desire.","pos":""}],"ASSUAGEMENT":[{"def":"Mitigation; abatement.","pos":""}],"ASSUAGER":[{"def":"One who, or that which, assuages.","pos":""}],"ASSUASIVE":[{"def":"Mitigating; tranquilizing; soothing.","pos":""}],"ASSUBJUGATE":[{"def":"To bring into subjection.","pos":""}],"ASSUEFACTION":[{"def":"The act of accustoming, or the state of being accustomed; habituation.","pos":""}],"ASSUETUDE":[{"def":"Accustomedness; habit; habitual use.","pos":""}],"ASSUMABLE":[{"def":"That may be assumed.","pos":""}],"ASSUMABLY":[{"def":"By way of assumption.","pos":""}],"ASSUME":[{"def":"To take to or upon one's self; to take formally and demonstratively; sometimes, to appropriate or take unjustly.","pos":""},{"def":"To take for granted, or without proof; to suppose as a fact; to suppose or take arbitrarily or tentatively.","pos":""}],"ASSUMED":[{"def":"Pretended; hypocritical; make-believe; as, an assumed character.","pos":""}],"ASSUMENT":[{"def":"A patch; an addition; a piece put on.","pos":""}],"ASSUMER":[{"def":"One who assumes, arrogates, pretends, or supposes.","pos":""}],"ASSUMING":[{"def":"Pretentious; taking much upon one's self; presumptuous.","pos":""}],"ASSUMPT":[{"def":"To take up; to elevate; to assume.","pos":""}],"ASSUMPTION":[{"def":"The minor or second proposition in a categorical syllogism.","pos":""},{"def":"A festival in honor of the ascent of the Virgin Mary into heaven.","pos":""}],"ASSUMPTIVE":[{"def":"Assumed, or capable of being assumed; characterized by assumption; making unwarranted claims.","pos":""}],"ASSURANCE":[{"def":"Any written or other legal evidence of the conveyance of property; a conveyance; a deed.","pos":""}],"ASSURE":[{"def":"To insure; to covenant to indemnify for loss, or to pay a specified sum at death.","pos":""}],"ASSURED":[{"def":"Made sure; safe; insured; certain; indubitable; not doubting; bold to excess.","pos":""}],"ASSUREDLY":[{"def":"Certainly; indubitably.","pos":""}],"ASSUREDNESS":[{"def":"The state of being assured; certainty; full confidence.","pos":""}],"ASSURER":[{"def":"One who assures.","pos":""},{"def":"One who takes out a life assurance policy.","pos":""}],"ASSURGENT":[{"def":"Ascending; (Bot.","pos":""},{"def":"rising obliquely; curving upward.","pos":""}],"ASSURING":[{"def":"That assures; tending to assure; giving confidence.","pos":""}]}