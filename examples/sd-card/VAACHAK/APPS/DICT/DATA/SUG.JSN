{"SUG":[{"def":"A kind of worm or larva.","pos":""}],"SUGAR":[{"def":"A sweet white (or brownish yellow) crystalline substance, of a sandy or granular consistency, obtained by crystallizing the evaporated juice of certain plants, as the sugar cane, sorghum, beet root, sugar maple, etc.","pos":""},{"def":"By extension, anything resembling sugar in taste or appearance; as, sugar of lead (lead acetate), a poisonous white crystalline substance having a sweet taste.","pos":""}],"SUGAR-HOUSE":[{"def":"A building in which sugar is made or refined; a sugar manufactory.","pos":""}],"SUGARED":[{"def":"Also used figuratively; as, sugared kisses.","pos":""}],"SUGARINESS":[{"def":"The quality or state of being sugary, or sweet.","pos":""}],"SUGARING":[{"def":"The act of covering or sweetening with sugar; also, the sugar thus used.","pos":""},{"def":"The act or process of making sugar.","pos":""}],"SUGARLESS":[{"def":"Without sugar; free from sugar.","pos":""}],"SUGARPLUM":[{"def":"A kind of candy or sweetneat made up in small balls or disks.","pos":""}],"SUGARY":[{"def":"Resembling or containing sugar; tasting of sugar; sweet.","pos":""},{"def":"Fond of sugar or sweet things; as, a sugary palate.","pos":""}],"SUGESCENT":[{"def":"Of or pertaining to sucking.","pos":""}],"SUGGEST":[{"def":"To introduce indirectly to the thoughts; to cause to be thought of, usually by the agency of other objects.","pos":""},{"def":"To propose with difference or modesty; to hint; to intimate; as, to suggest a difficulty.","pos":""}],"SUGGESTER":[{"def":"One who suggests.","pos":""}],"SUGGESTION":[{"def":"Information without oath; an entry of a material fact or circumstance on the record for the information of the court, at the death or insolvency of a party.","pos":""},{"def":"The act or power of originating or recalling ideas or relations, distinguished as original and relative; -- a term much used by Scottish metaphysicians from Hutcherson to Thomas Brown.","pos":""}],"SUGGESTIVE":[{"def":"Containing a suggestion, hint, or intimation.","pos":""}],"SUGGESTIVE MEDICINE":[{"def":"Treatment by commands or positive statements addressed to a more or less hypnotized patient.","pos":""}],"SUGGESTMENT":[{"def":"They fancy that every thought must needs have an immediate outward suggestment.","pos":""}],"SUGGESTRESS":[{"def":"A woman who suggests.","pos":""}],"SUGGILLATE":[{"def":"To beat livid, or black and blue.","pos":""}],"SUGGILLATION":[{"def":"A livid, or black and blue, mark; a blow; a bruise.","pos":""}]}