{"DIUREIDE":[{"def":"One of a series of complex nitrogenous substances regarded as containing two molecules of urea or their radicals, as uric acid or allantoin.","pos":""}],"DIURESIS":[{"def":"Free excretion of urine.","pos":""}],"DIURETIC":[{"def":"Tending to increase the secretion and discharge of urine.","pos":""},{"def":"A medicine with diuretic properties.","pos":""}],"DIURETICALNESS":[{"def":"The quality of being diuretical; diuretic property.","pos":""}],"DIURNA":[{"def":"A division of Lepidoptera, including the butterflies; -- so called because they fly only in the daytime.","pos":""}],"DIURNAL":[{"def":"Opening during the day, and closing at night; -- said of flowers or leaves.","pos":""},{"def":"Active by day; -- applied especially to the eagles and hawks among raptorial birds, and to butterflies (Diurna) among insects.","pos":""}],"DIURNALLY":[{"def":"Daily; every day.","pos":""}],"DIURNALNESS":[{"def":"The quality of being diurnal.","pos":""}],"DIURNATION":[{"def":"The condition of sleeping or becoming dormant by day, as is the case of the bats.","pos":""}],"DIUTURNAL":[{"def":"Of long continuance; lasting.","pos":""}],"DIUTURNITY":[{"def":"Long duration; lastingness.","pos":""}]}