{"MORT":[{"def":"A great quantity or number.","pos":""}],"MORTAL":[{"def":"Subject to death; destined to die; as, man is mortal.","pos":""},{"def":"Destructive to life; causing or occasioning death; terminating life; exposing to or deserving death; deadly; as, a mortal wound; a mortal sin.","pos":""}],"MORTALITY":[{"def":"The condition or quality of being mortal; subjection to death or to the necessity of dying.","pos":""},{"def":"Human life; the life of a mortal being.","pos":""}],"MORTALLY":[{"def":"In a mortal manner; so as to cause death; as, mortally wounded.","pos":""},{"def":"In the manner of a mortal or of mortal beings.","pos":""}],"MORTALNESS":[{"def":"Quality of being mortal; mortality.","pos":""}],"MORTAR":[{"def":"A short piece of ordnance, used for throwing bombs, carcasses, shells, etc.","pos":""}],"MORTGAGE":[{"def":"A conveyance of property, upon condition, as security for the payment of a debt or the preformance of a duty, and to become void upon payment or performance according to the stipulated terms; also, the written instrument by which the conveyance is made.","pos":""}],"MORTGAGEE":[{"def":"The person to whom property is mortgaged, or to whom a mortgage is made or given.","pos":""},{"def":"One who gives a mortgage.","pos":""}],"MORTGAGER":[{"def":"gives a mortgage.","pos":""}],"MORTIFEROUS":[{"def":"Bringing or producing death; deadly; destructive; as, a mortiferous herb.","pos":""}],"MORTIFICATION":[{"def":"A gift to some charitable or religious institution; -- nearly synonymous with mortmain.","pos":""}],"MORTIFIEDNESS":[{"def":"The state of being mortified; humiliation; subjection of the passions.","pos":""}],"MORTIFIER":[{"def":"One who, or that which, mortifies.","pos":""}],"MORTIFY":[{"def":"To destroy the organic texture and vital functions of; to produce gangrene in.","pos":""},{"def":"To destroy the active powers or essential qualities of; to change by chemical action.","pos":""}],"MORTIFYING":[{"def":"Tending to mortify; affected by, or having symptoms of, mortification; as, a mortifying wound; mortifying flesh.","pos":""},{"def":"Subduing the appetites, desires, etc.","pos":""}],"MORTIFYINGLY":[{"def":"In a mortifying manner.","pos":""}],"MORTISE":[{"def":"A cavity cut into a piece of timber, or other material, to receive something (as the end of another piece) made to fit it, and called a tenon.","pos":""}],"MORTLING":[{"def":"An animal, as a sheep, dead of disease or privation; a mortling.","pos":""},{"def":"Wool plucked from a dead sheep; morling.","pos":""}],"MORTMAIN":[{"def":"Possession of lands or tenements in, or conveyance to, dead hands, or hands that cannot alienate.","pos":""}],"MORTPAY":[{"def":"Dead pay; the crime of taking pay for the service of dead soldiers, or for services not actually rendered by soldiers.","pos":""},{"def":"A dish of meats and other ingredients, cooked together; an ollapodrida.","pos":""}],"MORTUARY":[{"def":"A sort of ecclesiastical heriot, a customary gift claimed by, and due to, the minister of a parish on the death of a parishioner.","pos":""},{"def":"A burial place; a place for the dead.","pos":""}]}