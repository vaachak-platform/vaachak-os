{"DISCEDE":[{"def":"To yield or give up; to depart.","pos":""}],"DISCEPT":[{"def":"To debate; to discuss.","pos":""}],"DISCEPTATION":[{"def":"Controversy; disputation; discussion.","pos":""}],"DISCEPTATOR":[{"def":"One who arbitrates or decides.","pos":""}],"DISCERN":[{"def":"To see and identify by noting a difference or differences; to note the distinctive character of; to discriminate; to distinguish.","pos":""},{"def":"To see by the eye or by the understanding; to perceive and recognize; as, to discern a difference.","pos":""}],"DISCERNER":[{"def":"One who, or that which, discerns, distinguishes, perceives, or judges; as, a discerner of truth, of right and wrong.","pos":""}],"DISCERNIBLE":[{"def":"Capable of being discerned by the eye or the understanding; as, a star is discernible by the eye; the identity of difference of ideas is discernible by the understanding.","pos":""}],"DISCERNIBLENESS":[{"def":"The quality of being discernible.","pos":""}],"DISCERNIBLY":[{"def":"In a manner to be discerned; perceptibly; visibly.","pos":""}],"DISCERNING":[{"def":"Acute; shrewd; sagacious; sharp-sighted.","pos":""}],"DISCERNINGLY":[{"def":"In a discerning manner; with judgment; judiciously; acutely.","pos":""}],"DISCERNMENT":[{"def":"The act of discerning.","pos":""}],"DISCERP":[{"def":"Capability or liableness to be discerped.","pos":""},{"def":"Capable of being discerped.","pos":""}],"DISCERPTION":[{"def":"The act of pulling to pieces, or of separating the parts.","pos":""}],"DISCERPTIVE":[{"def":"Tending to separate or disunite parts.","pos":""}]}