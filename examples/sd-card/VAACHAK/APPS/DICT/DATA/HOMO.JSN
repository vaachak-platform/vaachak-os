{"HOMO-":[{"def":"A combining form from Gr.","pos":""}],"HOMOCATEGORIC":[{"def":"Belonging to the same category of individuality; -- a morphological term applied to organisms so related.","pos":""}],"HOMOCENTRIC":[{"def":"Having the same center.","pos":""}],"HOMOCERCAL":[{"def":"Having the tail nearly or quite symmetrical, the vertebral column terminating near its base; -- opposed to heterocercal.","pos":""}],"HOMOCERCY":[{"def":"The possession of a homocercal tail.","pos":""}],"HOMOCEREBRIN":[{"def":"A body similar to, or identical with, cerebrin.","pos":""}],"HOMOCHROMOUS":[{"def":"Having all the florets in the same flower head of the same color.","pos":""}],"HOMODEMIC":[{"def":"A morphological term signifying development, in the case of multicellular organisms, from the same unit deme or unit of the inferior orders of individuality.","pos":""}],"HOMODERMIC":[{"def":"Relating to homodermy; originating from the same germ layer.","pos":""}],"HOMODERMY":[{"def":"Homology of the germinal layers.","pos":""}],"HOMODONT":[{"def":"Having all the teeth similar in front, as in the porpoises; -- opposed to heterodont.","pos":""},{"def":"Running in the same direction; -- said of stems twining round a support, or of the spiral succession of leaves on stems and their branches.","pos":""}],"HOMODYNAMOUS":[{"def":"Pertaining to, or involving, homodynamy; as, successive or homodynamous parts in plants and animals.","pos":""}],"HOMODYNAMY":[{"def":"The homology of metameres.","pos":""}],"HOMOEOMERIA":[{"def":"The state or quality of being homogeneous in elements or first principles; likeness or identity of parts.","pos":""},{"def":"Pertaining to, or characterized by, sameness of parts; receiving or advocating the doctrine of homogeneity of elements or first principles.","pos":""}],"HOMOEOMEROUS":[{"def":"Having the main artery of the leg parallel with the sciatic nerve; -- said of certain birds.","pos":""}],"HOMOEOMERY":[{"def":"Same as Homoeomeria.","pos":""}],"HOMOEOMORPHISM":[{"def":"A near similarity of crystalline forms between unlike chemical compounds.","pos":""}],"HOMOEOMORPHOUS":[{"def":"Manifesting homoeomorphism.","pos":""},{"def":"Same as Homeopathic, Homeopathist, Homeopathy.","pos":""}],"HOMOEOTHERMAL":[{"def":"See Homoiothermal.","pos":""}],"HOMOEOZOIC":[{"def":"Pertaining to, or including, similar forms or kinds of life; as, homoeozoic belts on the earth's surface.","pos":""}],"HOMOGAMOUS":[{"def":"Having all the flowers alike; -- said of such composite plants as Eupatorium, and the thistels.","pos":""}],"HOMOGAMY":[{"def":"The condition of being homogamous.","pos":""}],"HOMOGANGLIATE":[{"def":"Having the ganglia of the nervous system symmetrically arranged, as in certain invertebrates; -- opposed to heterogangliate.","pos":""}],"HOMOGENEALNESS":[{"def":"Homogeneousness.","pos":""}],"HOMOGENEITY":[{"def":"Same as Homogeneousness.","pos":""}],"HOMOGENEOUS":[{"def":"Possessing the same number of factors of a given kind; as, a homogeneous polynomial.","pos":""}],"HOMOGENEOUSNESS":[{"def":"Sameness 9kind or nature; uniformity of structure or material.","pos":""}],"HOMOGENESIS":[{"def":"That method of reproduction in which the successive generations are alike, the offspring, either animal or plant, running through the same cycle of existence as the parent; gamogenesis; -- opposed to heterogenesis.","pos":""}],"HOMOGENETIC":[{"def":"Homogenous; -- applied to that class of homologies which arise from similarity of structure, and which are taken as evidences of common ancestry.","pos":""}],"HOMOGENOUS":[{"def":"Having a resemblance in structure, due to descent from a common progenitor with subsequent modification; homogenetic; -- applied both to animals and plants.","pos":""}],"HOMOGENY":[{"def":"The correspondence of common descent; -- a term used to supersede homology by Lankester, who also used homoplasy to denote any superinduced correspondence of position and structure in parts embryonically distinct (other writers using the term homoplasmy).","pos":""}],"HOMOGONOUS":[{"def":"Having all the flowers of a plant alike in respect to the stamens and pistils.","pos":""}],"HOMOGONY":[{"def":"The condition of having homogonous flowers.","pos":""}],"HOMOGRAPH":[{"def":"One of two or more words identical in orthography, but having different derivations and meanings; as, fair, n.","pos":""}],"HOMOGRAPHIC":[{"def":"Possessing the property of homography.","pos":""}],"HOMOGRAPHY":[{"def":"A relation between two figures, such that to any point of the one corresponds one and but one point in the other, and vise versa.","pos":""}],"HOMOIOPTOTON":[{"def":"A figure in which the several parts of a sentence end with the same case, or inflection generally.","pos":""}],"HOMOIOUSIAN":[{"def":"One of the semi-Arians of the 4th century, who held that the Son was of like, but not the same, essence or substance with the Father; -- opposed to homoousian.","pos":""}],"HOMOLOGATE":[{"def":"To approve; to allow; to confirm; as, the court homologates a proceeding.","pos":""}],"HOMOLOGATION":[{"def":"Confirmation or ratification (as of something otherwise null and void), by a court or a grantor.","pos":""}],"HOMOLOGICAL":[{"def":"Pertaining to homology; having a structural affinity proceeding from, or base upon, that kind of relation termed homology.","pos":""}],"HOMOLOGINIC":[{"def":"Pertaining to, or characterized by, homology; as, homologinic qualities, or differences.","pos":""}],"HOMOLOGIZE":[{"def":"To determine the homologies or structural relations of.","pos":""}],"HOMOLOGOUMENA":[{"def":"Those books of the New Testament which were acknowledged as canonical by the early church; -- distinguished from antilegomena.","pos":""}],"HOMOLOGOUS":[{"def":"Having the same relative position, proportion, value, or structure.","pos":""},{"def":"Having the same relative proportion or value, as the two antecedents or the two consequents of a proportion.","pos":""}],"HOMOLOGRAPHIC":[{"def":"Preserving the mutual relations of parts, especially as to size and form; maintaining relative proportion.","pos":""}],"HOMOLOGUE":[{"def":"That which is homologous to something else; as, the corresponding sides, etc.","pos":""}],"HOMOLOGY":[{"def":"The quality of being homologous; correspondence; relation; as, the homologyof similar polygons.","pos":""}],"HOMOMALLOUS":[{"def":"Uniformly bending or curving to one side; -- said of leaves which grow on several sides of a stem.","pos":""},{"def":"Characterized by homomorphism.","pos":""}],"HOMOMORPHISM":[{"def":"Same as Homomorphy.","pos":""},{"def":"The possession, in one species of plants, of only one kind of flowers; -- opposed to heteromorphism, dimorphism, and trimorphism.","pos":""}],"HOMOMORPHY":[{"def":"Similarity of form; resemblance in external characters, while widely different in fundamental structure; resemblance in geometric ground form.","pos":""}],"HOMONOMOUS":[{"def":"Of or pertaining to homonomy.","pos":""}],"HOMONOMY":[{"def":"The homology of parts arranged on transverse axes.","pos":""}],"HOMONYM":[{"def":"A word having the same sound as another, but differing from it in meaning; as the noun bear and the verb bear.","pos":""}],"HOMONYMOUS":[{"def":"Having the same name or designation; standing in the same relation; -- opposed to heteronymous.","pos":""},{"def":"Having the same name or designation, but different meaning or relation; hence, equivocal; ambiguous.","pos":""}],"HOMONYMOUSLY":[{"def":"In an homonymous manner; so as to have the same name or relation.","pos":""},{"def":"Equivocally; ambiguously.","pos":""}],"HOMONYMY":[{"def":"Same as Homoplast.","pos":""}],"HOMOOUSIAN":[{"def":"One of those, in the 4th century, who accepted the Nicene creed, and maintained that the Son had the same essence or substance with the Father; -- opposed to homoiousian.","pos":""}],"HOMOPHONE":[{"def":"A letter or character which expresses a like sound with another.","pos":""},{"def":"A word having the same sound as another, but differing from it in meaning and usually in spelling; as, all and awl; bare and bear; rite, write, right, and wright.","pos":""}],"HOMOPHONY":[{"def":"Sameness of sound.","pos":""}],"HOMOPHYLIC":[{"def":"Relating to homophily.","pos":""}],"HOMOPHYLY":[{"def":"That form of homology due to common ancestry (phylogenetic homology), in opposition to homomorphy, to which genealogic basis is wanting.","pos":""}],"HOMOPLASMY":[{"def":"Resemblance between different plants or animals, in external shape, in general habit, or in organs, which is not due to descent from a common ancestor, but to similar surrounding circumstances.","pos":""}],"HOMOPLAST":[{"def":"One of the plastids composing the idorgan of Haeckel; -- also called homoörgan.","pos":""}],"HOMOPLASTIC":[{"def":"Of or pertaining to homoplasty; as, homoplasticorgans; homoplastic forms.","pos":""}],"HOMOPLASTY":[{"def":"The formation of homologous tissues.","pos":""}],"HOMOPOLIC":[{"def":"In promorphology, pertaining to or exhibiting that kind of organic form, in which the stereometric ground form is a pyramid, with similar poles.","pos":""}],"HOMOPTER":[{"def":"One of the Homoptera.","pos":""}],"HOMOPTERA":[{"def":"A suborder of Hemiptera, in which both pairs of wings are similar in texture, and do not overlap when folded, as in the cicada.","pos":""}],"HOMOPTEROUS":[{"def":"Of or pertaining to the Homoptera.","pos":""}],"HOMOSTYLED":[{"def":"Having only one form of pistils; -- said of the flowers of some plants.","pos":""}],"HOMOSYSTEMIC":[{"def":"Developing, in the case of multicellular organisms, from the same embryonic systems into which the secondary unit (gastrula or plant enbryo) differentiates.","pos":""}],"HOMOTAXIA":[{"def":"Same as Homotaxis.","pos":""},{"def":"Relating to homotaxis.","pos":""}],"HOMOTAXIS":[{"def":"Similarly in arrangement of parts; -- the opposite of heterotaxy.","pos":""}],"HOMOTAXY":[{"def":"Same as Homotaxis.","pos":""},{"def":"Warm-blooded; homoiothermal; hæmatothermal.","pos":""}],"HOMOTONOUS":[{"def":"Of the same tenor or tone; equable; without variation.","pos":""},{"def":"Having the radicle of the seed directed towards the hilum.","pos":""}],"HOMOTYPAL":[{"def":"Of the same type of structure; pertaining to a homotype; as, homotypal parts.","pos":""}],"HOMOTYPE":[{"def":"That which has the same fundamental type of structure with something else; thus, the right arm is the homotype of the right leg; one arm is the homotype of the other, etc.","pos":""},{"def":"Same as Homotypal.","pos":""}],"HOMOTYPY":[{"def":"A term suggested by Haeckel to be instead of serial homology.","pos":""}]}