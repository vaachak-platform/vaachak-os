{"THY":[{"def":"Of thee, or belonging to thee; the more common form of thine, possessive case of thou; -- used always attributively, and chiefly in the solemn or grave style, and in poetry.","pos":""}],"THYINE WOOD":[{"def":"The fragrant and beautiful wood of a North African tree (Callitris quadrivalvis), formerly called Thuja articulata.","pos":""}],"THYMATE":[{"def":"A compound of thymol analogous to a salt; as, sodium thymate.","pos":""}],"THYME":[{"def":"Any plant of the labiate genus Thymus.","pos":""}],"THYMENE":[{"def":"A liquid terpene obtained from oil of thyme.","pos":""}],"THYMIATECHNY":[{"def":"The art of employing perfumes in medicine.","pos":""}],"THYMIC":[{"def":"Of or pertaining to the thymus gland.","pos":""}],"THYMOL":[{"def":"A phenol derivative of cymene, C10H13.","pos":""}],"THYMUS":[{"def":"Of, pertaining to, or designating, the thymus gland.","pos":""},{"def":"The thymus gland.","pos":""}],"THYMY":[{"def":"Abounding with thyme; fragrant; as, a thymy vale.","pos":""}],"THYRO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the thyroid body or the thyroid cartilage; as, thyrohyal.","pos":""}],"THYROARYTENOID":[{"def":"Of or pertaining to both the thyroid and arytenoid cartilages of the larynx.","pos":""}],"THYROHYAL":[{"def":"One of the lower segments in the hyoid arch, often consolidated with the body of the hyoid bone and forming one of its great horns, as in man.","pos":""}],"THYROHYOID":[{"def":"Of or pertaining to the thyroid cartilage of the larynx and the hyoid arch.","pos":""}],"THYROID":[{"def":"Of or pertaining to the thyroid body, thyroid cartilage, or thyroid artery; thyroideal.","pos":""}],"THYROTOMY":[{"def":"The operation of cutting into the thyroid cartilage.","pos":""}],"THYRSE":[{"def":"Having somewhat the form of a thyrsus.","pos":""}],"THYRSUS":[{"def":"A species of inflorescence; a dense panicle, as in the lilac and horse-chestnut.","pos":""}],"THYSANOPTER":[{"def":"One of the Thysanoptera.","pos":""}],"THYSANOPTERA":[{"def":"A division of insects, considered by some writers a distinct order, but regarded by others as belonging to the Hemiptera.","pos":""}],"THYSANOPTERAN":[{"def":"One of the Thysanoptera.","pos":""}],"THYSANOPTEROUS":[{"def":"Of or pertaining to the Thysanoptera.","pos":""}],"THYSANURA":[{"def":"An order of wingless hexapod insects which have setiform caudal appendages, either bent beneath the body to form a spring, or projecting as bristles.","pos":""}],"THYSANURAN":[{"def":"One of the Thysanura.","pos":""}],"THYSANUROUS":[{"def":"Of or pertaining to the Thysanura.","pos":""}],"THYSBE":[{"def":"A common clearwing moth (Hemaris thysbe).","pos":""}],"THYSELF":[{"def":"An emphasized form of the personal pronoun of the second person; -- used as a subject commonly with thou; as, thou thyself shalt go; that is, thou shalt go, and no other.","pos":""}]}