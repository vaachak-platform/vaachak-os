{"ASBESTIC":[{"def":"Of, pertaining to, or resembling asbestus; inconsumable; asbestine.","pos":""}],"ASBESTIFORM":[{"def":"Having the form or structure of asbestus.","pos":""}],"ASBESTINE":[{"def":"Of or pertaining to asbestus, or partaking of its nature; incombustible; asbestic.","pos":""}],"ASBESTOUS":[{"def":"A variety of amphibole or of pyroxene, occurring in long and delicate fibers, or in fibrous masses or seams, usually of a white, gray, or green-gray color.","pos":""}],"ASBOLIN":[{"def":"A peculiar acrid and bitter oil, obtained from wood soot.","pos":""}]}