{"JEALOUS":[{"def":"Zealous; solicitous; vigilant; anxiously watchful.","pos":""},{"def":"Apprehensive; anxious; suspiciously watchful.","pos":""}],"JEALOUSLY":[{"def":"In a jealous manner.","pos":""}],"JEALOUSNESS":[{"def":"State or quality of being jealous.","pos":""}],"JEALOUSY":[{"def":"The quality of being jealous; earnest concern or solicitude; painful apprehension of rivalship in cases nearly affecting one's happiness; painful suspicion of the faithfulness of husband, wife, or lover.","pos":""}],"JEAMES":[{"def":"A footman; a flunky.","pos":""}],"JEAN":[{"def":"A twilled cotton cloth.","pos":""}],"JEARS":[{"def":"See 1st Jeer (b).","pos":""}],"JEDDING AX":[{"def":"A stone mason's tool, having a flat face and a pointed part.","pos":""}],"JEEL":[{"def":"A morass; a shallow lake.","pos":""}],"JEER":[{"def":"An assemblage or combination of tackles, for hoisting or lowering the lower yards of a ship.","pos":""}],"JEERER":[{"def":"A scoffer; a railer; a mocker.","pos":""}],"JEERING":[{"def":"Mocking; scoffing.","pos":""},{"def":"A mocking utterance.","pos":""}],"JEERS":[{"def":"See 1st Jeer (b).","pos":""}],"JEFFERSONIA":[{"def":"An American herb with a pretty, white, solitary blossom, and deeply two-cleft leaves (Jeffersonia diphylla); twinleaf.","pos":""}],"JEFFERSONIAN":[{"def":"Pertaining to, or characteristic of, Thomas Jefferson or his policy or political doctrines.","pos":""}],"JEFFERSONIAN SIMPLICITY":[{"def":"Jeffersonian simplicity.","pos":""}],"JEFFERSONITE":[{"def":"A variety of pyroxene of olive-green color passing into brown.","pos":""}],"JEHOVAH":[{"def":"A Scripture name of the Supreme Being, by which he was revealed to the Jews as their covenant God or Sovereign of the theocracy; the \"ineffable name\" of the Supreme Being, which was not pronounced by the Jews.","pos":""}],"JEHOVIST":[{"def":"One who maintains that the vowel points of the word Jehovah, in Hebrew, are the proper vowels of that word; -- opposed to adonist.","pos":""},{"def":"The writer of the passages of the Old Testament, especially those of the Pentateuch, in which the Supreme Being is styled Jehovah.","pos":""}],"JEHOVISTIC":[{"def":"Relating to, or containing, Jehovah, as a name of God; -- said of certain parts of the Old Testament, especially of the Pentateuch, in which Jehovah appears as the name of the Deity.","pos":""}],"JEHU":[{"def":"A coachman; a driver; especially, one who drives furiously.","pos":""}],"JEJUNAL":[{"def":"Pertaining to the jejunum.","pos":""}],"JEJUNE":[{"def":"Lacking matter; empty; void of substance.","pos":""},{"def":"Void of interest; barren; meager; dry; as, a jejune narrative.","pos":""}],"JEJUNITY":[{"def":"The quality of being jejune; jejuneness.","pos":""}],"JEJUNUM":[{"def":"The middle division of the small intestine, between the duodenum and ileum; -- so called because usually found empty after death.","pos":""}],"JELERANG":[{"def":"A large, handsome squirrel (Sciurus Javensis), native of Java and Southern Asia; -- called also Java squirrel.","pos":""}],"JELLIED":[{"def":"Brought to the state or consistence of jelly.","pos":""}],"JELLIFY":[{"def":"To make, or to become, gelatinous; to jelly.","pos":""}],"JELLY":[{"def":"Anything brought to a gelatinous condition; a viscous, translucent substance in a condition between liquid and solid; a stiffened solution of gelatin, gum, or the like.","pos":""},{"def":"The juice of fruits or meats boiled with sugar to an elastic consistence; as, currant jelly; calf's-foot jelly.","pos":""}],"JELLYFISH":[{"def":"Any one of the acalephs, esp.","pos":""}],"JEMIDAR":[{"def":"The chief or leader of a hand or body of persons; esp.","pos":""}],"JEMMY":[{"def":"A short crowbar.","pos":""},{"def":"A baked sheep's head.","pos":""}],"JENIQUEN":[{"def":"A Mexican name for the Sisal hemp (Agave rigida, var.","pos":""}],"JENKINS":[{"def":"name of contempt for a flatterer of persons high in social or official life; as, the Jenkins employed by a newspaper.","pos":""}],"JENNET":[{"def":"A small Spanish horse; a genet.","pos":""}],"JENNETING":[{"def":"A variety of early apple.","pos":""}],"JENNY":[{"def":"A familiar name of the European wren.","pos":""}],"JENTLING":[{"def":"A fish of the genus Leuciscus; the blue chub of the Danube.","pos":""}],"JEOFAIL":[{"def":"An oversight in pleading, or the acknowledgment of a mistake or oversight.","pos":""}],"JEOPARD":[{"def":"To put in jeopardy; to expose to loss or injury; to imperil; to hazard.","pos":""}],"JEOPARDER":[{"def":"One who puts in jeopardy.","pos":""}],"JEOPARDIZE":[{"def":"To expose to loss or injury; to risk; to jeopard.","pos":""}],"JEOPARDOUS":[{"def":"Perilous; hazardous.","pos":""}],"JEOPARDY":[{"def":"Exposure to death, loss, or injury; hazard; danger.","pos":""}],"JERBOA":[{"def":"Any small jumping rodent of the genus Dipus, esp.","pos":""}],"JEREED":[{"def":"A blunt javelin used by the people of the Levant, especially in mock fights.","pos":""},{"def":"A tale of sorrow, disappointment, or complaint; a doleful story; a dolorous tirade; -- generally used satirically.","pos":""}],"JERK":[{"def":"To cut into long slices or strips and dry in the sun; as, jerk beef.","pos":""}],"JERKER":[{"def":"A North American river chub (Hybopsis biguttatus).","pos":""}],"JERKIN":[{"def":"A jacket or short coat; a close waistcoat.","pos":""}],"JERKING":[{"def":"The act of pulling, pushing, or throwing, with a jerk.","pos":""}],"JERKINHEAD":[{"def":"The hipped part of a roof which is hipped only for a part of its height, leaving a truncated gable.","pos":""}],"JERKY":[{"def":"Moving by jerks and starts; characterized by abrupt transitions; as, a jerky vehicle; a jerky style.","pos":""}],"JERMOONAL":[{"def":"The Himalayan now partridge.","pos":""}],"JERONYMITE":[{"def":"One belonging of the mediæval religious orders called Hermits of St.","pos":""}],"JERQUER":[{"def":"A customhouse officer who searches ships for unentered goods.","pos":""}],"JERQUING":[{"def":"The searching of a ship for unentered goods.","pos":""}],"JERRY-BUILDER":[{"def":"A professional builder who erects cheap dwellings of poor materials and unsubstantial and slovenly construction.","pos":""}],"JERRY-BUILT":[{"def":"Built hastily and of bad materials; as, jerry-built houses.","pos":""}],"JERSEY":[{"def":"The finest of wool separated from the rest; combed wool; also, fine yarn of wool.","pos":""},{"def":"A kind of knitted jacket; hence, in general, a closefitting jacket or upper garment made of an elastic fabric (as stockinet).","pos":""}],"JERUSALEM":[{"def":"The chief city of Palestine, intimately associated with the glory of the Jewish nation, and the life and death of Jesus Christ.","pos":""}],"JERVINE":[{"def":"A poisonous alkaloid resembling veratrine, and found with it in white hellebore (Veratrum album); -- called also jervina.","pos":""}],"JESS":[{"def":"A short strap of leather or silk secured round the leg of a hawk, to which the leash or line, wrapped round the falconer's hand, was attached when used.","pos":""}],"JESSAMINE":[{"def":"Same as Jasmine.","pos":""}],"JESSANT":[{"def":"Springing up or emerging; -- said of a plant or animal.","pos":""}],"JESSE":[{"def":"Any representation or suggestion of the genealogy of Christ, in decorative art; as: (a) A genealogical tree represented in stained glass.","pos":""}],"JESSED":[{"def":"Having jesses on, as a hawk.","pos":""}],"JEST":[{"def":"A deed; an action; a gest.","pos":""},{"def":"A mask; a pageant; an interlude.","pos":""}],"JESTER":[{"def":"A buffoon; a merry-andrew; a court fool.","pos":""},{"def":"A person addicted to jesting, or to indulgence in light and amusing talk.","pos":""}],"JESTFUL":[{"def":"Given to jesting; full of jokes.","pos":""}],"JESTING":[{"def":"Sportive; not serious; fit for jests.","pos":""}],"JESTINGLY":[{"def":"In a jesting manner.","pos":""}],"JESU":[{"def":"Jesu, give the weary Calm and sweet repose.","pos":""}],"JESUIT":[{"def":"One of a religious order founded by Ignatius Loyola, and approved in 1540, under the title of The Society of Jesus.","pos":""}],"JESUITED":[{"def":"Conforming to the principles of the Jesuits.","pos":""}],"JESUITESS":[{"def":"One of an order of nuns established on the principles of the Jesuits, but suppressed by Pope Urban in 1633.","pos":""}],"JESUITICALLY":[{"def":"In a jesuitical manner.","pos":""}],"JESUITISM":[{"def":"The principles and practices of the Jesuits.","pos":""},{"def":"Cunning; deceit; deceptive practices to effect a purpose; subtle argument; -- an opprobrious use of the word.","pos":""}],"JESUITOCRACY":[{"def":"Government by Jesuits; also, the whole body of Jesuits in a country.","pos":""}],"JESUITRY":[{"def":"Jesuitism; subtle argument.","pos":""}],"JESUS":[{"def":"The Savior; the name of the Son of God as announced by the angel to his parents; the personal name of Our Lord, in distinction from Christ, his official appellation.","pos":""}],"JET":[{"def":"A variety of lignite, of a very compact texture and velvet black color, susceptible of a good polish, and often wrought into mourning jewelry, toys, buttons, etc.","pos":""}],"JET D'EAU":[{"def":"A stream of water spouting from a fountain or pipe (especially from one arranged to throw water upward), in a public place or in a garden, for ornament.","pos":""}],"JET-BLACK":[{"def":"Black as jet; deep black.","pos":""}],"JETERUS":[{"def":"A yellowness of the parts of plants which are normally green; yellows.","pos":""},{"def":"Goods which sink when cast into the sea, and remain under water; -- distinguished from flotsam, goods which float, and ligan, goods which are sunk attached to a buoy.","pos":""}],"JETTER":[{"def":"One who struts; one who bears himself jauntily; a fop.","pos":""}],"JETTINESS":[{"def":"The state of being jetty; blackness.","pos":""}],"JETTISON":[{"def":"The throwing overboard of goods from necessity, in order to lighten a vessel in danger of wreck.","pos":""}],"JETTON":[{"def":"A metal counter used in playing cards.","pos":""}],"JETTY":[{"def":"Made of jet, or like jet in color.","pos":""}],"JEW":[{"def":"Originally, one belonging to the tribe or kingdom of Judah; after the return from the Babylonish captivity, any member of the new state; a Hebrew; an Israelite.","pos":""}],"JEW'S-EAR":[{"def":"A species of fungus (Hirneola Auricula-Judæ, or Auricula), bearing some resemblance to the human ear.","pos":""}],"JEW'S-HARP":[{"def":"The shackle for joining a chain cable to an anchor.","pos":""},{"def":"A large clavate spine of a fossil sea urchin.","pos":""}],"JEWBUSH":[{"def":"A euphorbiaceous shrub of the genus Pedilanthus (P.","pos":""}],"JEWEL":[{"def":"An ornament of dress usually made of a precious metal, and having enamel or precious stones as a part of its design.","pos":""},{"def":"A precious stone; a gem.","pos":""}],"JEWELER":[{"def":"One who makes, or deals in, jewels, precious stones, and similar ornaments.","pos":""}],"JEWELRY":[{"def":"The art or trade of a jeweler.","pos":""},{"def":"Jewels, collectively; as, a bride's jewelry.","pos":""}],"JEWFISH":[{"def":"A very large serranoid fish (Promicrops itaiara) of Florida and the Gulf of Mexico.","pos":""},{"def":"A similar gigantic fish (Stereolepis gigas) of Southern California, valued as a food fish.","pos":""}],"JEWISH":[{"def":"Of or pertaining to the Jews or Hebrews; characteristic of or resembling the Jews or their customs; Israelitish.","pos":""}],"JEWISH CALENDAR":[{"def":"A lunisolar calendar in use among Hebraic peoples, reckoning from the year 3761 b.","pos":""}],"JEWRY":[{"def":"Judea; also, a district inhabited by Jews; a Jews' quarter.","pos":""}],"JEZEBEL":[{"def":"A bold, vicious woman; a termagant.","pos":""}]}