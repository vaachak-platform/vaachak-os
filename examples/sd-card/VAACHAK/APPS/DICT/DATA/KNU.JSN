{"KNUBS":[{"def":"Waste silk formed in winding off the threads from a cocoon.","pos":""}],"KNUCKLE":[{"def":"The joining pars of a hinge through which the pin or rivet passes; a knuckle joint.","pos":""},{"def":"A convex portion of a vessel's figure where a sudden change of shape occurs, as in a canal boat, where a nearly vertical side joins a nearly flat bottom.","pos":""}],"KNUFF":[{"def":"A lout; a clown.","pos":""}],"KNURL":[{"def":"A contorted knot in wood; a crossgrained protuberance; a nodule; a boss or projection.","pos":""}],"KNURLED":[{"def":"Full of knots; gnarled.","pos":""},{"def":"Milled, as the head of a screw, or the edge of a coin.","pos":""}],"KNURLY":[{"def":"Full of knots; hard; tough; hence, capable of enduring or resisting much.","pos":""}]}