{"HEDDLE":[{"def":"One of the sets of parallel doubled threads which, with mounting, compose the harness employed to guide the warp threads to the lathe or batten in a loom.","pos":""}],"HEDDLE-EYE":[{"def":"The eye or loop formed in each heddle to receive a warp thread.","pos":""}],"HEDDLING":[{"def":"The act of drawing the warp threads through the heddle-eyes of a weaver's harness; the harness itself.","pos":""}],"HEDERACEOUS":[{"def":"Of, pertaining to, or resembling, ivy.","pos":""}],"HEDERAL":[{"def":"Of or pertaining to ivy.","pos":""}],"HEDERIC":[{"def":"Pertaining to, or derived from, the ivy (Hedera); as, hederic acid, an acid of the acetylene series.","pos":""}],"HEDERIFEROUS":[{"def":"Producing ivy; ivy-bearing.","pos":""}],"HEDEROSE":[{"def":"Pertaining to, or of, ivy; full of ivy.","pos":""}],"HEDGE":[{"def":"The roughest berry on the rudest hedge.","pos":""}],"HEDGEBORN":[{"def":"Born under a hedge; of low birth.","pos":""}],"HEDGEBOTE":[{"def":"Same as Haybote.","pos":""}],"HEDGEHOG":[{"def":"A small European insectivore (Erinaceus Europæus), and other allied species of Asia and Africa, having the hair on the upper part of its body mixed with prickles or spines.","pos":""},{"def":"The Canadian porcupine.","pos":""}],"HEDGELESS":[{"def":"Having no hedge.","pos":""}],"HEDGEPIG":[{"def":"A young hedgehog.","pos":""}],"HEDGER":[{"def":"One who makes or mends hedges; also, one who hedges, as, in betting.","pos":""}],"HEDGEROW":[{"def":"A row of shrubs, or trees, planted for inclosure or separation of fields.","pos":""}],"HEDONIC":[{"def":"Pertaining to pleasure.","pos":""},{"def":"Of or relating to Hedonism or the Hedonic sect.","pos":""}],"HEDONICS":[{"def":"That branch of moral philosophy which treats of the relation of duty to pleasure; the science of practical, positive enjoyment or pleasure.","pos":""}],"HEDONISM":[{"def":"The doctrine of the Hedonic sect.","pos":""},{"def":"The ethical theory which finds the explanation and authority of duty in its tendency to give pleasure.","pos":""}],"HEDONIST":[{"def":"One who believes in hedonism.","pos":""}],"HEDONISTIC":[{"def":"Same as Hedonic, 2.","pos":""}]}