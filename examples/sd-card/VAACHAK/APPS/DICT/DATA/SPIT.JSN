{"SPIT":[{"def":"A long, slender, pointed rod, usually of iron, for holding meat while roasting.","pos":""},{"def":"A small point of land running into the sea, or a long, narrow shoal extending from the shore into the sea; as, a spit of sand.","pos":""}],"SPIT BALL":[{"def":"A pitched ball in throwing which the pitcher grips the ball between two, or three, fingers on one side (which is made slippery, as by saliva) and the thumb on the other side, and delivers it so that it slips off the fingers with the least possible friction.","pos":""}],"SPIT CURL":[{"def":"A little lock of hair, plastered in a spiral form on the temple or forehead with spittle, or other adhesive substance.","pos":""}],"SPIT-VENOM":[{"def":"Poison spittle; poison ejected from the mouth.","pos":""}],"SPITBALL":[{"def":"Paper chewed, and rolled into a ball, to be thrown as a missile.","pos":""}],"SPITBOX":[{"def":"A vessel to receive spittle.","pos":""}],"SPITCHCOCK":[{"def":"To split (as an eel) lengthwise, and broil it, or fry it in hot fat.","pos":""}],"SPITCHCOCKED":[{"def":"Broiled or fried after being split lengthwise; -- said of eels.","pos":""}],"SPITE":[{"def":"Ill-will or hatred toward another, accompanied with the disposition to irritate, annoy, or thwart; petty malice; grudge; rancor; despite.","pos":""},{"def":"Vexation; chargrin; mortification.","pos":""}],"SPITEFUL":[{"def":"Filled with, or showing, spite; having a desire to vex, annoy, or injure; malignant; malicious; as, a spiteful person or act.","pos":""}],"SPITFIRE":[{"def":"A violent, irascible, or passionate person.","pos":""}],"SPITOUS":[{"def":"Having spite; spiteful.","pos":""}],"SPITTED":[{"def":"Put upon a spit; pierced as if by a spit.","pos":""},{"def":"Shot out long; -- said of antlers.","pos":""}],"SPITTER":[{"def":"One who ejects saliva from the mouth.","pos":""}],"SPITTLE":[{"def":"To dig or stir with a small spade.","pos":""}],"SPITTLY":[{"def":"Like spittle; slimy.","pos":""}],"SPITTOON":[{"def":"A spitbox; a cuspidor.","pos":""}],"SPITZ DOG":[{"def":"A breed of dogs having erect ears and long silky hair, usually white; -- called also Pomeranian dog, and louploup.","pos":""}],"SPITZENBURGH":[{"def":"A kind of red and yellow apple, of medium size and spicy flavor.","pos":""}]}