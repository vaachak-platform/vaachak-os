{"TRANQUIL":[{"def":"Quiet; calm; undisturbed; peaceful; not agitated; as, the atmosphere is tranquil; the condition of the country is tranquil.","pos":""},{"def":"The act of tranquilizing, or the state of being tranquilized.","pos":""}],"TRANQUILLITY":[{"def":"The quality or state of being tranquil; calmness; composure.","pos":""}],"TRANQUILLY":[{"def":"In a tranquil manner; calmly.","pos":""}],"TRANQUILNESS":[{"def":"Quality or state of being tranquil.","pos":""}]}