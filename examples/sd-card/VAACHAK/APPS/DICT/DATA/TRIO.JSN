{"TRIO":[{"def":"Of the value of three oboli; hence, mean; worthless.","pos":""}],"TRIOCTILE":[{"def":"An aspect of two planets with regard to the earth when they are three octants, or three eighths of a circle, that is, 135 degrees, distant from each other.","pos":""}],"TRIOECIA":[{"def":"The third order of the Linnæan class Polygamia.","pos":""}],"TRIOECIOUS":[{"def":"Having three sorts of flowers on the same or on different plants, some of the flowers being staminate, others pistillate, and others both staminate and pistillate; belonging to the order Trioecia.","pos":""}],"TRIOLE":[{"def":"Same as Triplet.","pos":""}],"TRIOLET":[{"def":"A short poem or stanza of eight lines, in which the first line is repeated as the fourth and again as the seventh line, the second being, repeated as the eighth.","pos":""}],"TRIONAL":[{"def":"A compound similar to sulphonal, used as a hypnotic in medicine.","pos":""}],"TRIONYCHOIDEA":[{"def":"A division of chelonians which comprises Trionyx and allied genera; -- called also Trionychoides, and Trionychina.","pos":""}],"TRIONYX":[{"def":"A genus of fresh-water or river turtles which have the shell imperfectly developed and covered with a soft leathery skin.","pos":""}],"TRIOR":[{"def":"Same as Trier, 2 and 3.","pos":""}],"TRIOXIDE":[{"def":"An oxide containing three atoms of oxygen; as, sulphur trioxide, SO3; -- formerly called tritoxide.","pos":""}]}