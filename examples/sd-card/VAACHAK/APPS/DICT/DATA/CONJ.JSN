{"CONJECT":[{"def":"To throw together, or to throw.","pos":""}],"CONJECTOR":[{"def":"One who guesses or conjectures.","pos":""}],"CONJECTURABLE":[{"def":"Capable of being conjectured or guessed.","pos":""}],"CONJECTURAL":[{"def":"Dependent on conjecture; fancied; imagined; guessed at; undetermined; doubtful.","pos":""}],"CONJECTURALIST":[{"def":"Con*jec\"tur*al*ist, n.","pos":""}],"CONJECTURALLY":[{"def":"That which depends upon guess; guesswork.","pos":""}],"CONJECTURE":[{"def":"An opinion, or judgment, formed on defective or presumptive evidence; probable inference; surmise; guess; suspicion.","pos":""}],"CONJECTURER":[{"def":"One who conjectures.","pos":""}],"CONJOIN":[{"def":"To join together; to unite.","pos":""}],"CONJOINED":[{"def":"Joined together or touching.","pos":""}],"CONJOINT":[{"def":"United; connected; associated.","pos":""}],"CONJOINTLY":[{"def":"In a conjoint manner; untitedly; jointly; together.","pos":""}],"CONJOINTNESS":[{"def":"The qquality of being conjoint.","pos":""}],"CONJUBILANT":[{"def":"Shouting together for joy; rejoicing together.","pos":""}],"CONJUGAL":[{"def":"Belonging to marriage; suitable or appropriate to the marriage state or to married persons; matrimonial; connubial.","pos":""}],"CONJUGALITY":[{"def":"The conjugal state; sexual intercourse.","pos":""}],"CONJUGALLY":[{"def":"In a conjugal manner; matrimonially; connubially.","pos":""}],"CONJUGATE":[{"def":"In single pairs; coupled.","pos":""},{"def":"Containing two or more radicals supposed to act the part of a single one.","pos":""}],"CONJUGATION":[{"def":"A kind of sexual union; -- applied to a blending of the contents of two or more cells or individuals in some plants and lower animals, by which new spores or germs are developed.","pos":""}],"CONJUGATIONAL":[{"def":"relating to conjugation.","pos":""}],"CONJUGIUM":[{"def":"The marriage tie.","pos":""}],"CONJUNCT":[{"def":"Same as Conjoined.","pos":""}],"CONJUNCTION":[{"def":"The meeting of two or more stars or planets in the same degree of the zodiac; as, the conjunction of the moon with the sun, or of Jupiter and Saturn.","pos":""},{"def":"A connective or connecting word; an indeclinable word which serves to join together sentences, clauses of a sentence, or words; as, and, but, if.","pos":""}],"CONJUNCTIONAL":[{"def":"Relating to a conjunction.","pos":""}],"CONJUNCTIVA":[{"def":"The mucous membrane which covers the external surface of the ball of the eye and the inner surface of the lids; the conjunctival membrance.","pos":""}],"CONJUNCTIVAL":[{"def":"Of or pertaining to the conjunctiva.","pos":""}],"CONJUNCTIVE":[{"def":"Serving to unite; connecting together.","pos":""}],"CONJUNCTIVELY":[{"def":"In conjunction or union; together.","pos":""}],"CONJUNCTIVENESS":[{"def":"The state or quality of being conjunctive.","pos":""}],"CONJUNCTIVITIS":[{"def":"Inflammation of the conjunctiva.","pos":""}],"CONJUNCTLY":[{"def":"In union; conjointly; unitedly; together.","pos":""}],"CONJUNCTURE":[{"def":"The act of joining, or state of being joined; union; connection; combination.","pos":""},{"def":"A crisis produced by a combination of circumstances; complication or combination of events or circumstances; plight resulting from various conditions.","pos":""}],"CONJURATION":[{"def":"The act of calling or summoning by a sacred name, or in solemn manner; the act of binding by an oath; an earnest entreaty; adjuration.","pos":""},{"def":"The act or process of invoking supernatural aid by the use of a magical form of words; the practice of magic arts; incantation; enchantment.","pos":""}],"CONJURATOR":[{"def":"One who swears or is sworn with others; one bound by oath with others; a compurgator.","pos":""}],"CONJURE":[{"def":"To call on or summon by a sacred name or in solemn manner; to implore earnestly; to adjure.","pos":""}],"CONJUREMENT":[{"def":"Serious injunction; solemn demand or entreaty.","pos":""}],"CONJURER":[{"def":"One who conjures; one who calls, entreats, or charges in a solemn manner.","pos":""}],"CONJUROR":[{"def":"One bound by a common cath with others.","pos":""}],"CONJURY":[{"def":"The practice of magic; enchantment.","pos":""}]}