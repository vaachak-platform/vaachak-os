{"FAVAGINOUS":[{"def":"Formed like, or resembling, a honeycomb.","pos":""}],"FAVEL":[{"def":"Yellow; fal [Obs.","pos":""}],"FAVELLA":[{"def":"A group of spores arranged without order and covered with a thin gelatinous envelope, as in certain delicate red algæ.","pos":""}],"FAVEOLATE":[{"def":"Honeycomb; having cavities or cells, somewhat resembling those of a honeycomb; alveolate; favose.","pos":""}],"FAVIER EXPLOSIVE":[{"def":"Any of several explosive mixtures, chiefly of ammonium nitrate and a nitrate derivative of naphthalene.","pos":""}],"FAVILLOUS":[{"def":"Of or pertaining to ashes.","pos":""}],"FAVONIAN":[{"def":"Pertaining to the west wind; soft; mild; gentle.","pos":""}],"FAVOR":[{"def":"Partiality; bias.","pos":""}],"FAVORABLE":[{"def":"Full of favor; favoring; manifesting partiality; kind; propitious; friendly.","pos":""},{"def":"Conducive; contributing; tending to promote or facilitate; advantageous; convenient.","pos":""}],"FAVORED":[{"def":"Countenanced; aided; regarded with kidness; as, a favored friend.","pos":""},{"def":"Having a certain favor or appearance; featured; as, well-favored; hard-favored, etc.","pos":""}],"FAVOREDLY":[{"def":"In a favored or a favorable manner; favorably.","pos":""}],"FAVORER":[{"def":"One who favors; one who regards with kindness or friendship; a well-wisher; one who assists or promotes success or prosperity.","pos":""}],"FAVORESS":[{"def":"A woman who favors or gives countenance.","pos":""}],"FAVORITE":[{"def":"Short curls dangling over the temples; -- fashionable in the reign of Charles II.","pos":""},{"def":"The competitor (as a horse in a race) that is judged most likely to win; the competitor standing highest in the betting.","pos":""}],"FAVORITISM":[{"def":"The disposition to favor and promote the interest of one person or family, or of one class of men, to the neglect of others having equal claims; partiality.","pos":""}],"FAVORLESS":[{"def":"Unfavored; not regarded with favor; having no countenance or support.","pos":""},{"def":"Unpropitious; unfavorable.","pos":""}],"FAVOSE":[{"def":"Of or pertaining to the disease called favus.","pos":""}],"FAVOSITE":[{"def":"Like or pertaining to the genus Favosites.","pos":""}],"FAVOSITES":[{"def":"A genus of fossil corals abundant in the Silurian and Devonian rocks, having polygonal cells with perforated walls.","pos":""}],"FAVUS":[{"def":"A disease of the scalp, produced by a vegetable parasite.","pos":""}]}