{"INN":[{"def":"A place of shelter; hence, dwelling; habitation; residence; abode.","pos":""},{"def":"A house for the lodging and entertainment of travelers or wayfarers; a tavern; a public house; a hotel.","pos":""}],"INNATE":[{"def":"Originating in, or derived from, the constitution of the intellect, as opposed to acquired from experience; as, innate ideas.","pos":""},{"def":"Joined by the base to the very tip of a filament; as, an innate anther.","pos":""}],"INNATENESS":[{"def":"The quality of being innate.","pos":""}],"INNAVIGABLE":[{"def":"Incapable of being navigated; impassable by ships or vessels.","pos":""}],"INNE":[{"def":"And eke in what array that they were inne.","pos":""}],"INNER":[{"def":"Further in; interior; internal; not outward; as, an spirit or its phenomena.","pos":""},{"def":"Not obvious or easily discovered; obscure.","pos":""}],"INNERMOST":[{"def":"Farthest inward; most remote from the outward part; inmost; deepest within.","pos":""}],"INNERMOSTLY":[{"def":"In the innermost place.","pos":""}],"INNERVATE":[{"def":"To supply with nerves; as, the heart is innervated by pneumogastric and sympathetic branches.","pos":""}],"INNERVATION":[{"def":"Special activity excited in any part of the nervous system or in any organ of sense or motion; the nervous influence necessary for the maintenance of life,and the functions of the various organs.","pos":""},{"def":"The distribution of nerves in an animal, or to any of its parts.","pos":""}],"INNERVE":[{"def":"To give nervous energy or power to; to give increased energy,force,or courage to; to invigorate; to stimulate.","pos":""}],"INNHOLDER":[{"def":"One who keeps an inn.","pos":""}],"INNING":[{"def":"Lands recovered from the sea.","pos":""}],"INNITENCY":[{"def":"A leaning; pressure; weight.","pos":""}],"INNIXION":[{"def":"Act of leaning upon something; incumbency.","pos":""}],"INNOCENCE":[{"def":"The state or quality of being innocent; freedom from that which is harmful or infurious; harmlessness.","pos":""},{"def":"The state or quality of being morally free from guilt or sin; purity of heart; blamelessness.","pos":""}],"INNOCENT":[{"def":"Not harmful; free from that which can injure; innoxious; innocuous; harmless; as, an innocent medicine or remedy.","pos":""},{"def":"Morally free from guilt; guiltless; not tainted with sin; pure; upright.","pos":""}],"INNOCENTLY":[{"def":"In an innocent manner.","pos":""}],"INNOCUOUS":[{"def":"Harmless; producing no ill effect; innocent.","pos":""}],"INNODATE":[{"def":"To bind up,as in a knot; to include.","pos":""}],"INNOMINABLE":[{"def":"Not to be named.","pos":""}],"INNOMINATE":[{"def":"A term used in designating many parts otherwise unnamed; as, the innominate artery, a great branch of the arch of the aorta; the innominate vein, a great branch of the superior vena cava.","pos":""}],"INNOVATE":[{"def":"To bring in as new; to introduce as a novelty; as, to innovate a word or an act.","pos":""},{"def":"To change or alter by introducing something new; to remodel; to revolutionize.","pos":""}],"INNOVATION":[{"def":"A newly formed shoot, or the annually produced addition to the stems of many mosses.","pos":""}],"INNOVATIONIST":[{"def":"One who favors innovation.","pos":""}],"INNOVATIVE":[{"def":"Characterized by, or introducing, innovations.","pos":""}],"INNOVATOR":[{"def":"One who innovates.","pos":""}],"INNOXIOUS":[{"def":"Free from hurtful qualities or effects; harmless.","pos":""},{"def":"Free from crime; pure; innocent.","pos":""}],"INNUENDO":[{"def":"An averment employed in pleading, to point the application of matter otherwise unintelligible; an interpretative parenthesis thrown into quoted matter to explain an obscure word or words; -- as, the plaintiff avers that the defendant said that he (innuendo the plaintiff) was a thief.","pos":""}],"INNUENT":[{"def":"Conveying a hint; significant.","pos":""}],"INNUMERABILITY":[{"def":"State of being innumerable.","pos":""}],"INNUMERABLE":[{"def":"Not capable of being counted, enumerated, or numbered, for multitude; countless; numberless; unnumbered, hence, indefinitely numerous; of great number.","pos":""}],"INNUTRITION":[{"def":"Want of nutrition; failure of nourishment.","pos":""}],"INNUTRITIOUS":[{"def":"Not nutritious; not furnishing nourishment.","pos":""}],"INNYARD":[{"def":"The yard adjoining an inn.","pos":""}]}