{"CLAN":[{"def":"A tribe or collection of families, united under a chieftain, regarded as having the same common ancestor, and bearing the same surname; as, the clan of Macdonald.","pos":""},{"def":"A clique; a sect, society, or body of persons; esp.","pos":""}],"CLAN-NA-GAEL":[{"def":"A secret society of Irish Fenians founded in Philadelphia in 1881.","pos":""}],"CLANCULAR":[{"def":"Conducted with secrecy; clandestine; concealed.","pos":""}],"CLANCULARLY":[{"def":"privately; secretly.","pos":""}],"CLANDESTINE":[{"def":"Conducted with secrecy; withdrawn from public notice, usually for an evil purpose; kept secret; hidden; private; underhand; as, a clandestine marriage.","pos":""}],"CLANDESTINITY":[{"def":"Privacy or secrecy.","pos":""}],"CLANG":[{"def":"To strike together so as to produce a ringing metallic sound.","pos":""}],"CLANGOR":[{"def":"A sharp, harsh, ringing sound.","pos":""}],"CLANGOROUS":[{"def":"Making a clangor; having a ringing, metallic sound.","pos":""}],"CLANGOUS":[{"def":"Making a clang, or a ringing metallic sound.","pos":""}],"CLANJAMFRIE":[{"def":"Same as Clamjamphrie.","pos":""}],"CLANK":[{"def":"A sharp, brief, ringing sound, made by a collision of metallic or other sonorous bodies; -- usually expressing a duller or less resounding sound than clang, and a deeper and stronger sound than clink.","pos":""}],"CLANKLESS":[{"def":"Without a clank.","pos":""}],"CLANNISH":[{"def":"Of or pertaining to a clan; closely united, like a clan; disposed to associate only with one's clan or clique; actuated by the traditions, prejudices, habits, etc.","pos":""}],"CLANSHIP":[{"def":"A state of being united togheter as in a clan; an association under a chieftain.","pos":""}],"CLANSMAN":[{"def":"One belonging to the same clan with another.","pos":""}]}