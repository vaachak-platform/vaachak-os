{"ECONOMICALLY":[{"def":"With economy; with careful management; with prudence in expenditure.","pos":""}],"ECONOMICS":[{"def":"The science of household affairs, or of domestic management.","pos":""},{"def":"Political economy; the science of the utilities or the useful application of wealth or material resources.","pos":""}],"ECONOMIST":[{"def":"One who economizes, or manages domestic or other concerns with frugality; one who expends money, time, or labor, judiciously, and without waste.","pos":""},{"def":"One who is conversant with political economy; a student of economics.","pos":""}],"ECONOMIZATION":[{"def":"The act or practice of using to the best effect.","pos":""}],"ECONOMIZE":[{"def":"To manage with economy; to use with prudence; to expend with frugality; as, to economize one's income.","pos":""}],"ECONOMIZER":[{"def":"One who, or that which, economizes.","pos":""},{"def":"Specifically: (Steam Boilers) An arrangement of pipes for heating feed water by waste heat in the gases passing to the chimney.","pos":""}],"ECONOMY":[{"def":"The management of domestic affairs; the regulation and government of household matters; especially as they concern expense or disbursement; as, a careful economy.","pos":""},{"def":"Orderly arrangement and management of the internal affairs of a state or of any establishment kept up by production and consumption; esp.","pos":""}],"ECORCHE":[{"def":"A manikin, or image, representing an animal, especially man, with the skin removed so that the muscles are exposed for purposes of study.","pos":""}],"ECOSSAISE":[{"def":"A dancing tune in the Scotch style.","pos":""}],"ECOSTATE":[{"def":"Having no ribs or nerves; -- said of a leaf.","pos":""}],"ECOUTE":[{"def":"One of the small galleries run out in front of the glacis.","pos":""}]}