{"HESITANCY":[{"def":"The act of hesitating, or pausing to consider; slowness in deciding; vacillation; also, the manner of one who hesitates.","pos":""},{"def":"A stammering; a faltering in speech.","pos":""}],"HESITANT":[{"def":"Not prompt in deciding or acting; hesitating.","pos":""},{"def":"Unready in speech.","pos":""}],"HESITANTLY":[{"def":"With hesitancy or doubt.","pos":""}],"HESITATE":[{"def":"To stop or pause respecting decision or action; to be in suspense or uncertainty as to a determination; as, he hesitated whether to accept the offer or not; men often hesitate in forming a judgment.","pos":""},{"def":"To stammer; to falter in speaking.","pos":""}],"HESITATINGLY":[{"def":"With hesitation or doubt.","pos":""}],"HESITATION":[{"def":"The act of hesitating; suspension of opinion or action; doubt; vacillation.","pos":""},{"def":"A faltering in speech; stammering.","pos":""}],"HESITATIVE":[{"def":"Showing, or characterized by, hesitation.","pos":""}],"HESP":[{"def":"A measure of two hanks of linen thread.","pos":""}],"HESPER":[{"def":"The evening; Hesperus.","pos":""}],"HESPERETIN":[{"def":"A white, crystalline substance having a sweetish taste, obtained by the decomposition of hesperidin, and regarded as a complex derivative of caffeic acid.","pos":""}],"HESPERIAN":[{"def":"Western; being in the west; occidental.","pos":""}],"HESPERID":[{"def":"Same as 3d Hesperian.","pos":""}],"HESPERIDENE":[{"def":"An isomeric variety of terpene from orange oil.","pos":""}],"HESPERIDES":[{"def":"The daughters of Hesperus, or Night (brother of Atlas), and fabled possessors of a garden producing golden apples, in Africa, at the western extremity of the known world.","pos":""}],"HESPERIDIN":[{"def":"A glucoside found in ripe and unripe fruit (as the orange), and extracted as a white crystalline substance.","pos":""}],"HESPERIDIUM":[{"def":"A large berry with a thick rind, as a lemon or an orange.","pos":""}],"HESPERORNIS":[{"def":"A genus of large, extinct, wingless birds from the Cretaceous deposits of Kansas, belonging to the Odontornithes.","pos":""}],"HESPERUS":[{"def":"Venus when she is the evening star; Hesper.","pos":""}],"HESSIAN":[{"def":"Of or relating to Hesse, in Germany, or to the Hessians.","pos":""}],"HESSITE":[{"def":"A lead-gray sectile mineral.","pos":""}],"HEST":[{"def":"Command; precept; injunction.","pos":""},{"def":"Pertaining to yesterday.","pos":""}],"HESYCHAST":[{"def":"One of a mystical sect of the Greek Church in the fourteenth century; a quietist.","pos":""},{"def":"A female paramour; a mistress, concubine, or harlot.","pos":""}]}