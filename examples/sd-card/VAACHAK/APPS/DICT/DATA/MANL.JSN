{"MANLESS":[{"def":"Destitute of men.","pos":""},{"def":"Unmanly; inhuman.","pos":""}],"MANLIKE":[{"def":"Like man, or like a man, in form or nature; having the qualities of a man, esp.","pos":""}],"MANLINESS":[{"def":"The quality or state of being manly.","pos":""}],"MANLY":[{"def":"Having qualities becoming to a man; not childish or womanish; manlike, esp.","pos":""}]}