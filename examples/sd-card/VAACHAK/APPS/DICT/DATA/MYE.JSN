{"MYELENCEPHALA":[{"def":"Same as Vertebrata.","pos":""}],"MYELENCEPHALIC":[{"def":"Of or pertaining to the myelencephalon; cerebro-spinal.","pos":""}],"MYELENCEPHALON":[{"def":"My`e*len*ceph\"a*lon, n.","pos":""}],"MYELENCEPHALOUS":[{"def":"Of or pertaining to the Myelencephala.","pos":""}],"MYELITIS":[{"def":"Inflammation of the spinal marrow or its membranes.","pos":""}],"MYELOCOELE":[{"def":"The central canal of the spinal cord.","pos":""}],"MYELOGENIC":[{"def":"Derived from, or pertaining to, the bone marrow.","pos":""}],"MYELOID":[{"def":"Resembling marrow in appearance or consistency; as, a myeloid tumor.","pos":""}],"MYELOIDIN":[{"def":"A substance, present in the protoplasm of the retinal epithelium cells, and resembling, if not identical with, the substance (myelin) forming the medullary sheaths of nerve fibers.","pos":""}],"MYELON":[{"def":"The spinal cord.","pos":""}],"MYELONAL":[{"def":"Of or pertaining to the myelon; as, the myelonal, or spinal, nerves.","pos":""}],"MYELOPLAX":[{"def":"One of the huge multinucleated cells found in the marrow of bone and occasionally in other parts; a giant cell.","pos":""}]}