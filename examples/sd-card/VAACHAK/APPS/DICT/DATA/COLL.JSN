{"COLLABORATEUR":[{"def":"See Collaborator.","pos":""}],"COLLABORATION":[{"def":"The act ofworking together; united labor.","pos":""}],"COLLABORATOR":[{"def":"An associate in labor, especially in literary or scientific labor.","pos":""}],"COLLAGEN":[{"def":"The chemical basis of ordinary connective tissue, as of tendons or sinews and of bone.","pos":""}],"COLLAGENOUS":[{"def":"Containing or resembling collagen.","pos":""}],"COLLAPSE":[{"def":"To fall together suddenly, as the sides of a hollow vessel; to close by falling or shrinking together; to have the sides or parts of (a thing) fall in together, or be crushed in together; as, a flue in the boiler of a steam engine sometimes collapses.","pos":""},{"def":"To fail suddenly and completely, like something hollow when subject to too much pressure; to undergo a collapse; as, Maximilian's government collapsed soon after the French army left Mexico; many financial projects collapse after attaining some success and importance.","pos":""}],"COLLAR":[{"def":"The neck or line of junction between the root of a plant and its stem.","pos":""}],"COLLARDS":[{"def":"Young cabbage, used as \"greens\"; esp.","pos":""}],"COLLARED":[{"def":"Wearing a collar; -- said of a man or beast used as a bearing when a collar is represented as worn around the neck or loins.","pos":""},{"def":"A small collar; specif.","pos":""}],"COLLATABLE":[{"def":"Capable of being collated.","pos":""}],"COLLATE":[{"def":"To present and institute in a benefice, when the person presenting is both the patron and the ordinary; -- followed by to.","pos":""}],"COLLATERAL":[{"def":"Descending from the same stock or ancestor, but not in the same line or branch or one from the other; -- opposed to lineal.","pos":""}],"COLLATERALLY":[{"def":"Side by side; by the side.","pos":""},{"def":"In an indirect or subordinate manner; indirectly.","pos":""}],"COLLATERALNESS":[{"def":"The state of being collateral.","pos":""}],"COLLATION":[{"def":"The gathering and examination of sheets preparatory to binding.","pos":""},{"def":"The presentation of a clergyman to a benefice by a bishop, who has it in his own gift.","pos":""}],"COLLATIONER":[{"def":"One who examines the sheets of a book that has just been printed, to ascertain whether they are correctly printed, paged, etc.","pos":""}],"COLLATITIOUS":[{"def":"Brought together; contributed; done by contributions.","pos":""}],"COLLATIVE":[{"def":"Passing or held by collation; -- said of livings of which the bishop and the patron are the same person.","pos":""}],"COLLATOR":[{"def":"One who collates to a benefice.","pos":""}],"COLLAUD":[{"def":"To join in praising.","pos":""}],"COLLEAGUE":[{"def":"A partner or associate in some civil or ecclesiastical office or employment.","pos":""}],"COLLEAGUESHIP":[{"def":"Partnership in office.","pos":""}],"COLLECT":[{"def":"To gather into one body or place; to assemble or bring together; to obtain by gathering.","pos":""},{"def":"To demand and obtain payment of, as an account, or other indebtedness; as, to collect taxes.","pos":""}],"COLLECTANEA":[{"def":"Passages selected from various authors, usually for purposes of instruction; miscellany; anthology.","pos":""}],"COLLECTED":[{"def":"Gathered together.","pos":""},{"def":"Self-possessed; calm; composed.","pos":""}],"COLLECTEDLY":[{"def":"Composedly; coolly.","pos":""}],"COLLECTEDNESS":[{"def":"A collected state of the mind; self-possession.","pos":""}],"COLLECTIBLE":[{"def":"Capable of being collected.","pos":""}],"COLLECTION":[{"def":"The act or process of collecting or of gathering; as, the collection of specimens.","pos":""},{"def":"That which is collected; as: (a) A gathering or assemblage of objects or of persons.","pos":""}],"COLLECTIONAL":[{"def":"Of or pertaining to collecting.","pos":""}],"COLLECTIVE":[{"def":"Expressing a collection or aggregate of individuals, by a singular form; as, a collective name or noun, like assembly, army, juri, etc.","pos":""}],"COLLECTIVELY":[{"def":"In a mass, or body; in a collected state; in the aggregate; unitedly.","pos":""}],"COLLECTIVENESS":[{"def":"A state of union; mass.","pos":""}],"COLLECTIVISM":[{"def":"The doctrine that land and capital should be owned by society collectively or as a whole; communism.","pos":""}],"COLLECTIVIST":[{"def":"An advocate of collectivism.","pos":""},{"def":"Relating to, or characteristic of, collectivism.","pos":""}],"COLLECTIVITY":[{"def":"Quality or state of being collective.","pos":""},{"def":"The collective sum.","pos":""}],"COLLECTOR":[{"def":"An officer appointed and commissioned to collect and receive customs, duties, taxes, or toll.","pos":""}],"COLLECTORATE":[{"def":"The district of a collector of customs; a collectorship.","pos":""}],"COLLECTORSHIP":[{"def":"The office of a collector of customs or of taxes.","pos":""}],"COLLEEN":[{"def":"A girl; a maiden.","pos":""}],"COLLEGATARY":[{"def":"A joint legatee.","pos":""}],"COLLEGE":[{"def":"A collection, body, or society of persons engaged in common pursuits, or having common duties and interests, and sometimes, by charter, peculiar rights and privileges; as, a college of heralds; a college of electors; a college of bishops.","pos":""},{"def":"A society of scholars or friends of learning, incorporated for study or instruction, esp.","pos":""}],"COLLEGIAN":[{"def":"A member of a college, particularly of a literary institution so called; a student in a college.","pos":""}],"COLLEGIATE":[{"def":"Of or pertaining to a college; as, collegiate studies; a collegiate society.","pos":""}],"COLLEMBOLA":[{"def":"The division of Thysanura which includes Podura, and allied forms.","pos":""}],"COLLENCHYMA":[{"def":"A tissue of vegetable cells which are thickend at the angles and (usually) elongated.","pos":""}],"COLLET":[{"def":"A small metal ring; a small collar fastened on an arbor; as, the collet on the balance arbor of a watch; a small socket on a stem, for holding a drill.","pos":""}],"COLLETERIAL":[{"def":"Of or pertaining to the colleterium of insects.","pos":""}],"COLLETERIUM":[{"def":"An organ of female insects, containing a cement to unite the ejected ova.","pos":""}],"COLLIDE":[{"def":"To strike or dash against each other; to come into collision; to clash; as, the vessels collided; their interests collided.","pos":""}],"COLLIDINE":[{"def":"One of a class of organic bases, C8H11N, usually pungent oily liquids, belonging to the pyridine series, and obtained from bone oil, coal tar, naphtha, and certain alkaloids.","pos":""}],"COLLIE":[{"def":"The Scotch shepherd dog.","pos":""}],"COLLIER":[{"def":"One engaged in the business of digging mineral coal or making charcoal, or in transporting or dealing in coal.","pos":""},{"def":"A vessel employed in the coal trade.","pos":""}],"COLLIERY":[{"def":"The place where coal is dug; a coal mine, and the buildings, etc.","pos":""}],"COLLIFLOWER":[{"def":"See Cauliflower.","pos":""}],"COLLIGATE":[{"def":"To bring together by colligation; to sum up in a single proposition.","pos":""}],"COLLIGATION":[{"def":"That process by which a number of isolated facts are brought under one conception, or summed up in a general proposition, as when Kepler discovered that the various observed positions of the planet Mars were points in an ellipse.","pos":""}],"COLLIMATE":[{"def":"To render parallel to a certain line or direction; to bring into the same line, as the axes of telescopes, etc.","pos":""}],"COLLIMATION":[{"def":"The act of collimating; the adjustment of the line of the sights, as the axial line of the telescope of an instrument, into its proper position relative to the other parts of the instrument.","pos":""}],"COLLIMATOR":[{"def":"A telescope arranged and used to determine errors of collimation, both vertical and horizontal.","pos":""},{"def":"A tube having a convex lens at one end and at the other a small opening or slit which is at the principal focus of the lens, used for producing a beam of parallel rays; also, a lens so used.","pos":""}],"COLLIN":[{"def":"A very pure form of gelatin.","pos":""}],"COLLINE":[{"def":"A small hill or mount.","pos":""}],"COLLINEATION":[{"def":"The act of aiming at, or directing in a line with, a fixed object.","pos":""}],"COLLING":[{"def":"An embrace; dalliance.","pos":""}],"COLLINGUAL":[{"def":"Having, or pertaining to, the same language.","pos":""}],"COLLIQUABLE":[{"def":"Liable to melt, grow soft, or become fluid.","pos":""}],"COLLIQUAMENT":[{"def":"The first rudiments of an embryo in generation.","pos":""}],"COLLIQUATE":[{"def":"To change from solid to fluid; to make or become liquid; to melt.","pos":""}],"COLLIQUATION":[{"def":"A processive wasting or melting away of the solid parts of the animal system with copious excretions of liquids by one or more passages.","pos":""}],"COLLIQUATIVE":[{"def":"Causing rapid waste or exhaustion; melting; as, collequative sweats.","pos":""}],"COLLIQUEFACTION":[{"def":"A melting together; the reduction of different bodies into one mass by fusion.","pos":""}],"COLLISH":[{"def":"A tool to polish the edge of a sole.","pos":""}],"COLLISION":[{"def":"The act of striking together; a striking together, as of two hard bodies; a violent meeting, as of railroad trains; a clashing.","pos":""},{"def":"A state of opposition; antagonism; interference.","pos":""}],"COLLISIVE":[{"def":"Colliding; clashing.","pos":""}],"COLLITIGANT":[{"def":"Disputing or wrangling.","pos":""},{"def":"One who litigates or wrangles.","pos":""}],"COLLOCATE":[{"def":"To set or place; to set; to station.","pos":""}],"COLLOCATION":[{"def":"The act of placing; the state of being placed with something else; disposition in place; arrangement.","pos":""}],"COLLOCUTION":[{"def":"A speaking or conversing together; conference; mutual discourse.","pos":""}],"COLLOCUTOR":[{"def":"One of the speakers in a dialogue.","pos":""}],"COLLODION":[{"def":"A solution of pyroxylin (soluble gun cotton) in ether containing a varying proportion of alcohol.","pos":""}],"COLLODIONIZE":[{"def":"To prepare or treat with collodion.","pos":""}],"COLLODIOTYPE":[{"def":"A picture obtained by the collodion process; a melanotype or ambrotype.","pos":""}],"COLLOGUE":[{"def":"To talk or confer secretly and confidentially; to converse, especially with evil intentions; to plot mischief.","pos":""}],"COLLOID":[{"def":"Resembling glue or jelly; characterized by a jellylike appearance; gelatinous; as, colloid tumors.","pos":""}],"COLLOIDAL":[{"def":"Pertaining to, or of the nature of, colloids.","pos":""}],"COLLOIDALITY":[{"def":"The state or quality of being colloidal.","pos":""}],"COLLOP":[{"def":"A small slice of meat; a piece of flesh.","pos":""},{"def":"A part or piece of anything; a portion.","pos":""}],"COLLOPED":[{"def":"Having ridges or bunches of flesh, like collops.","pos":""}],"COLLOQUIAL":[{"def":"Pertaining to, or used in, conversation, esp.","pos":""}],"COLLOQUIALISM":[{"def":"A colloquial expression, not employed in formal discourse or writing.","pos":""}],"COLLOQUIALIZE":[{"def":"To make colloquial and familiar; as, to colloquialize one's style of writing.","pos":""}],"COLLOQUIST":[{"def":"A speaker in a colloquy or dialogue.","pos":""}],"COLLOQUY":[{"def":"Mutual discourse of two or more persons; conference; conversation.","pos":""},{"def":"In some American colleges, a part in exhibitions, assigned for a certain scholarship rank; a designation of rank in collegiate scholarship.","pos":""}],"COLLOTYPE":[{"def":"A photomechanical print made directly from a hardened film of gelatin or other colloid; also, the process of making such prints.","pos":""}],"COLLUCTANCY":[{"def":"A struggling to resist; a striving against; resistance; opposition of nature.","pos":""}],"COLLUCTATION":[{"def":"A struggling; a contention.","pos":""}],"COLLUDE":[{"def":"To have secretly a joint part or share in an action; to play into each other's hands; to conspire; to act in concert.","pos":""}],"COLLUDER":[{"def":"One who conspires in a fraud.","pos":""}],"COLLUM":[{"def":"A neck or cervix.","pos":""}],"COLLUSION":[{"def":"An agreement between two or more persons to defraud a person of his rights, by the forms of law, or to obtain an object forbidden by law.","pos":""}],"COLLUSIVE":[{"def":"Characterized by collusion; done or planned in collusion.","pos":""},{"def":"Acting in collusion.","pos":""}],"COLLUTORY":[{"def":"A medicated wash for the mouth.","pos":""}],"COLLUVIES":[{"def":"A collection or gathering, as of pus, or rubbish, or odds and ends.","pos":""},{"def":"A medley; offscourings or rabble.","pos":""}],"COLLY":[{"def":"The black grime or soot of coal.","pos":""}],"COLLYBIST":[{"def":"A money changer.","pos":""}],"COLLYRIUM":[{"def":"An application to the eye, usually an eyewater.","pos":""}]}