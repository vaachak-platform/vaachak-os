{"VIRAGINIAN":[{"def":"Of or pertaining to a virago; having the qualities of a virago.","pos":""}],"VIRAGINITY":[{"def":"The qualities or characteristics of a virago.","pos":""}],"VIRAGO":[{"def":"A woman of extraordinary stature, strength, and courage; a woman who has the robust body and masculine mind of a man; a female warrior.","pos":""},{"def":"Hence, a mannish woman; a bold, turbulent woman; a termagant; a vixen.","pos":""}],"VIRE":[{"def":"An arrow, having a rotary motion, formerly used with the crossbow.","pos":""}],"VIRELAY":[{"def":"An ancient French song, or short poem, wholly in two rhymes, and composed in short lines, with a refrain.","pos":""}],"VIRENT":[{"def":"Green; not withered.","pos":""}],"VIREO":[{"def":"Any one of numerous species of American singing birds belonging to Vireo and allied genera of the family Vireonidæ.","pos":""}],"VIRESCENCE":[{"def":"The act or state of becoming green through the formation of chlorophyll.","pos":""}],"VIRESCENT":[{"def":"Beginning to be green; slightly green; greenish.","pos":""}],"VIRETON":[{"def":"An arrow or bolt for a crossbow having feathers or brass placed at an angle with the shaft to make it spin in flying.","pos":""}],"VIRGALIEU":[{"def":"A valuable kind of pear, of an obovate shape and with melting flesh of delicious flavor; -- more properly called White Doyenné.","pos":""}],"VIRGATE":[{"def":"Having the form of a straight rod; wand-shaped; straight and slender.","pos":""}],"VIRGATED":[{"def":"Striped; streaked.","pos":""}],"VIRGILIAN":[{"def":"Of or pertaining to Virgil, the Roman poet; resembling the style of Virgil.","pos":""}],"VIRGIN":[{"def":"Any one of several species of gossamer-winged butterflies of the family Lycænidæ.","pos":""}],"VIRGINAL":[{"def":"Of or pertaining to a virgin; becoming a virgin; maidenly.","pos":""}],"VIRGINHOOD":[{"def":"Virginity; maidenhood.","pos":""}],"VIRGINIA":[{"def":"One of the States of the United States of America.","pos":""},{"def":"Of or pertaining to the State of Virginia.","pos":""}],"VIRGINITY":[{"def":"The quality or state of being a virgin; undefiled purity or chastity; maidenhood.","pos":""},{"def":"The unmarried life; celibacy.","pos":""}],"VIRGO":[{"def":"August, marked thus [ (b) A constellation of the zodiac, now occupying chiefly the sign Libra, and containing the bright star Spica.","pos":""}],"VIRGOULEUSE":[{"def":"An old French variety of pear, of little value.","pos":""}],"VIRGULARIAN":[{"def":"Any one of numerous species of long, slender Alcyonaria belonging to Virgularia and allied genera of the family Virgularidæ.","pos":""}],"VIRGULATE":[{"def":"Shaped like a little twig or rod.","pos":""}],"VIRIAL":[{"def":"A certain function relating to a system of forces and their points of application, -- first used by Clausius in the investigation of problems in molecular physics.","pos":""}],"VIRID":[{"def":"The virid marjoram Her sparkling beauty did but see.","pos":""}],"VIRIDESCENCE":[{"def":"Quality or state of being viridescent.","pos":""}],"VIRIDESCENT":[{"def":"Slightly green; greenish.","pos":""}],"VIRIDINE":[{"def":"A greenish, oily, nitrogenous hydrocarbon, C12H19N7, obtained from coal tar, and probably consisting of a mixture of several metameric compounds which are higher derivatives of the base pyridine.","pos":""}],"VIRIDITE":[{"def":"A greenish chloritic mineral common in certain igneous rocks, as diabase, as a result of alternation.","pos":""}],"VIRIDITY":[{"def":"Greenness; verdure; the color of grass and foliage.","pos":""},{"def":"Freshness; soundness.","pos":""}],"VIRIDNESS":[{"def":"Viridity; greenness.","pos":""}],"VIRILE":[{"def":"Having the nature, properties, or qualities, of an adult man; characteristic of developed manhood; hence, masterful; forceful; specifically, capable of begetting; -- opposed to womanly, feminine, and puerile; as, virile age, virile power, virile organs.","pos":""}],"VIRILITY":[{"def":"The quality or state of being virile; developed manhood; manliness; specif.","pos":""}],"VIRIPOTENT":[{"def":"Developed in manhood; hence, able to beget; marriageable.","pos":""}],"VIROLE":[{"def":"A ring surrounding a bugle or hunting horn.","pos":""}],"VIROLED":[{"def":"Furnished with a virole or viroles; -- said of a horn or a bugle when the rings are of different tincture from the rest of the horn.","pos":""}],"VIROSE":[{"def":"Having a nauseous odor; fetid; poisonous.","pos":""}],"VIRTU":[{"def":"A love of the fine arts; a taste for curiosities.","pos":""}],"VIRTUAL":[{"def":"Having the power of acting or of invisible efficacy without the agency of the material or sensible part; potential; energizing.","pos":""},{"def":"Being in essence or effect, not in fact; as, the virtual presence of a man in his agent or substitute.","pos":""}],"VIRTUALITY":[{"def":"The quality or state of being virtual.","pos":""},{"def":"Potentiality; efficacy; potential existence.","pos":""}],"VIRTUALLY":[{"def":"In a virtual manner; in efficacy or effect only, and not actually; to all intents and purposes; practically.","pos":""}],"VIRTUATE":[{"def":"To make efficacious; to give virtue of efficacy.","pos":""}],"VIRTUE":[{"def":"One of the orders of the celestial hierarchy.","pos":""}],"VIRTUELESS":[{"def":"Destitute of virtue; without efficacy or operating qualities; powerless.","pos":""}],"VIRTUOSITY":[{"def":"The quality or state of being a virtuoso; in a bad sense, the character of one in whom mere artistic feeling or æsthetic cultivation takes the place of religious character; sentimentalism.","pos":""},{"def":"Virtuosos, collectively.","pos":""}],"VIRTUOSO":[{"def":"A performer on some instrument, as the violin or the piano, who excels in the technical part of his art; a brilliant concert player.","pos":""}],"VIRTUOSOSHIP":[{"def":"The condition, pursuits, or occupation of a virtuoso.","pos":""}],"VIRTUOUS":[{"def":"Possessing or exhibiting virtue.","pos":""},{"def":"Chaste; pure; -- applied especially to women.","pos":""}],"VIRULENT":[{"def":"Extremely poisonous or venomous; very active in doing injury.","pos":""},{"def":"Very bitter in enmity; actuated by a desire to injure; malignant; as, a virulent invective.","pos":""}],"VIRULENTED":[{"def":"Made virulent; poisoned.","pos":""}],"VIRULENTLY":[{"def":"In a virulent manner.","pos":""}]}