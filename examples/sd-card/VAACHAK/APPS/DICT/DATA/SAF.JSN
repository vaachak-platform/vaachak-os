{"SAFE":[{"def":"Free from harm, injury, or risk; untouched or unthreatened by danger or injury; unharmed; unhurt; secure; whole; as, safe from disease; safe from storms; safe from foes.","pos":""},{"def":"Conferring safety; securing from harm; not exposing to danger; confining securely; to be relied upon; not dangerous; as, a safe harbor; a safe bridge, etc.","pos":""}],"SAFE-CONDUCT":[{"def":"That which gives a safe, passage; either (a) a convoy or guard to protect a person in an enemy's country or a foreign country, or (b) a writing, pass, or warrant of security, given to a person to enable him to travel with safety.","pos":""}],"SAFE-KEEPING":[{"def":"The act of keeping or preserving in safety from injury or from escape; care; custody.","pos":""}],"SAFE-PLEDGE":[{"def":"A surety for the appearance of a person at a given time.","pos":""}],"SAFEGUARD":[{"def":"One who, or that which, defends or protects; defense; protection.","pos":""},{"def":"A convoy or guard to protect a traveler or property.","pos":""}],"SAFELY":[{"def":"In a safe manner; danger, injury, loss, or evil consequences.","pos":""}],"SAFENESS":[{"def":"The quality or state of being safe; freedom from hazard, danger, harm, or loss; safety; security; as the safeness of an experiment, of a journey, or of a possession.","pos":""}],"SAFETY":[{"def":"Same as Safety touchdown, below.","pos":""}],"SAFETY BICYCLE":[{"def":"A bicycle with equal or nearly equal wheels, usually 28 inches diameter, driven by pedals connected to the rear (driving) wheel by a multiplying gear.","pos":""}],"SAFFLOWER":[{"def":"An annual composite plant (Carthamus tinctorius), the flowers of which are used as a dyestuff and in making rouge; bastard, or false, saffron.","pos":""}],"SAFFRON":[{"def":"A bulbous iridaceous plant (Crocus sativus) having blue flowers with large yellow stigmas.","pos":""}],"SAFFRONY":[{"def":"Having a color somewhat like saffron; yellowish.","pos":""}],"SAFRANIN":[{"def":"Spanish red, China lake, and carthamin.","pos":""}],"SAFRANINE":[{"def":"An orange-red nitrogenous dyestuff produced artificailly by oxidizing certain aniline derivatives, and used in dyeing silk and wool; also, any one of the series of which safranine proper is the type.","pos":""}]}