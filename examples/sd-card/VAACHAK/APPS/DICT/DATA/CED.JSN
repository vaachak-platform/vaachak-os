{"CEDAR":[{"def":"The name of several evergreen trees.","pos":""}],"CEDARED":[{"def":"Covered, or furnished with, cedars.","pos":""}],"CEDARN":[{"def":"Of or pertaining to the cedar or its wood.","pos":""}],"CEDE":[{"def":"To yield or surrender; to give up; to resign; as, to cede a fortress, a province, or country, to another nation, by treaty.","pos":""}],"CEDILLA":[{"def":"A mark placed under the letter c [thus, ç], to show that it is to be sounded like s, as in façade.","pos":""}],"CEDRAT":[{"def":"Properly the citron, a variety of Citrus medica, with large fruits, not acid, and having a high perfume.","pos":""}],"CEDRENE":[{"def":"A rich aromatic oil, C15H24, extracted from oil of red cedar, and regarded as a polymeric terpene; also any one of a class of similar substances, as the essential oils of cloves, cubebs, juniper, etc.","pos":""}],"CEDRINE":[{"def":"Of or pertaining to cedar or the cedar tree.","pos":""}],"CEDRIRET":[{"def":"Same as Coerulignone.","pos":""}],"CEDRY":[{"def":"Of the nature of cedar.","pos":""}],"CEDULE":[{"def":"A scroll; a writing; a schedule.","pos":""}],"CEDUOUS":[{"def":"Fit to be felled.","pos":""}]}