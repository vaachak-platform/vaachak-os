{"SYLE":[{"def":"A young herring (Clupea harengus).","pos":""}],"SYLLABARY":[{"def":"A table of syllables; more especially, a table of the indivisible syllabic symbols used in certain languages, as the Japanese and Cherokee, instead of letters.","pos":""}],"SYLLABE":[{"def":"Of or pertaining to a syllable or syllables; as, syllabic accent.","pos":""},{"def":"Consisting of a syllable or syllables; as, a syllabic augment.","pos":""}],"SYLLABICALLY":[{"def":"In a syllabic manner.","pos":""}],"SYLLABICATE":[{"def":"To form or divide into syllables; to syllabify.","pos":""}],"SYLLABICATION":[{"def":"The act of forming syllables; the act or method of dividing words into syllables.","pos":""}],"SYLLABIFICATION":[{"def":"Same as Syllabication.","pos":""}],"SYLLABIFY":[{"def":"To form or divide into syllables.","pos":""}],"SYLLABISM":[{"def":"The expressing of the sounds of a language by syllables, rather than by an alphabet or by signs for words.","pos":""}],"SYLLABIST":[{"def":"One who forms or divides words into syllables, or is skilled in doing this.","pos":""}],"SYLLABLE":[{"def":"An elementary sound, or a combination of elementary sounds, uttered together, or with a single effort or impulse of the voice, and constituting a word or a part of a word.","pos":""},{"def":"In writing and printing, a part of a word, separated from the rest, and capable of being pronounced by a single impulse of the voice.","pos":""}],"SYLLABUB":[{"def":"Same as Syllabub.","pos":""}],"SYLLABUS":[{"def":"A compendium containing the heads of a discourse, and the like; an abstract.","pos":""}],"SYLLEPSIS":[{"def":"A figure of speech by which a word is used in a literal and metaphorical sense at the same time.","pos":""},{"def":"The agreement of a verb or adjective with one, rather than another, of two nouns, with either of which it might agree in gender, number, etc.","pos":""}],"SYLLIDIAN":[{"def":"Any one of numerous species of marine annelids of the family Syllidæ.","pos":""}],"SYLLOGISM":[{"def":"The regular logical form of every argument, consisting of three propositions, of which the first two are called the premises, and the last, the conclusion.","pos":""},{"def":"Of or pertaining to a syllogism; consisting of a syllogism, or of the form of reasoning by syllogisms; as, syllogistic arguments or reasoning.","pos":""}],"SYLLOGISTICALLY":[{"def":"In a syllogistic manner.","pos":""}],"SYLLOGIZATION":[{"def":"A reasoning by syllogisms.","pos":""}],"SYLLOGIZE":[{"def":"To reason by means of syllogisms.","pos":""}],"SYLLOGIZER":[{"def":"One who syllogizes.","pos":""}],"SYLPH":[{"def":"Any one of several species of very brilliant South American humming birds, having a very long and deeply-forked tail; as, the blue-tailed sylph (Cynanthus cyanurus).","pos":""}],"SYLPHID":[{"def":"A little sylph; a young or diminutive sylph.","pos":""}],"SYLPHLIKE":[{"def":"Like a sylph; airy; graceful.","pos":""}],"SYLVAN":[{"def":"Of or pertaining to a sylva; forestlike; hence, rural; rustic.","pos":""},{"def":"Abounding in forests or in trees; woody.","pos":""}],"SYLVANITE":[{"def":"A mineral, a telluride of gold and silver, of a steel-gray, silver-white, or brass-yellow color.","pos":""}],"SYLVANIUM":[{"def":"An old name for tellurium.","pos":""}],"SYLVATE":[{"def":"A salt of sylvic acid.","pos":""}],"SYLVIC":[{"def":"Of, pertaining to, or resembling, pine or its products; specifically, designating an acid called also abeitic acid, which is the chief ingredient of common resin (obtained from Pinus sylvestris, and other species).","pos":""}],"SYLVICOLINE":[{"def":"Of or pertaining to the family of warblers (Sylvicolidæ).","pos":""}],"SYLVICULTURE":[{"def":"The cultivation of forest trees for timber or other purposes; forestry; arboriculture.","pos":""}],"SYLVICULTURIST":[{"def":"One who cultivates forest trees, especially as a business.","pos":""},{"def":"Native potassium chloride.","pos":""}]}