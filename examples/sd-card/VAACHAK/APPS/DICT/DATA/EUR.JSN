{"EURASIAN":[{"def":"A child of a European parent on the one side and an Asiatic on the other.","pos":""},{"def":"One born of European parents in Asia.","pos":""}],"EURASIATIO":[{"def":"Of or pertaining to the continents of Europe and Asia combined.","pos":""}],"EUREKA":[{"def":"The exclamation attributed to Archimedes, who is said to have cried out \"Eureka! eureka!\" (I have found it! I have found it!), upon suddenly discovering a method of finding out how much the gold of King Hiero's crown had been alloyed.","pos":""}],"EURHIPIDUROUS":[{"def":"Having a fanlike tail; belonging to the Eurhipiduræ, a division of Aves which includes all living birds.","pos":""}],"EURIPIZE":[{"def":"To whirl hither and thither.","pos":""}],"EURIPUS":[{"def":"A strait; a narrow tract of water, where the tide, or a current, flows and reflows with violence, as the ancient fright of this name between Eubæa and Bæotia.","pos":""}],"EURITE":[{"def":"A compact feldspathic rock; felsite.","pos":""}],"EURITIC":[{"def":"Of or pelating to eurite.","pos":""}],"EUROCLYDON":[{"def":"A tempestuous northeast wind which blows in the Mediterranean.","pos":""}],"EUROPEAN":[{"def":"Of or pertaining to Europe, or to its inhabitants.","pos":""}],"EUROPEANIZE":[{"def":"To cause to become like the Europeans in manners or character; to habituate or accustom to European usages.","pos":""}],"EUROPIUM":[{"def":"A metallic element of the rare-earth group, discovered spectroscopically by Demarcay in 1896.","pos":""}],"EURYALE":[{"def":"A genus of water lilies, growing in India and China.","pos":""},{"def":"A genus of ophiurans with much-branched arms.","pos":""}],"EURYALIDA":[{"def":"A tribe of Ophiuroidea, including the genera Euryale, Astrophyton, etc.","pos":""}],"EURYCEROUS":[{"def":"Having broad horns.","pos":""}],"EURYPTEROID":[{"def":"Like, or pertaining to, the genus Euryperus.","pos":""}],"EURYPTEROIDEA":[{"def":"An extinct order of Merostomata, of which the genus Eurypterus is the type.","pos":""}],"EURYPTERUS":[{"def":"A genus of extinct Merostomata, found in Silurian rocks.","pos":""}],"EURYTHMY":[{"def":"Just or harmonious proportion or movement, as in the composition of a poem, an edifice, a painting, or a statue.","pos":""},{"def":"Regularly of the pulse.","pos":""}]}