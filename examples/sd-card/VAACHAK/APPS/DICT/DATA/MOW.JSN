{"MOW":[{"def":"Nodding, becking, and mowing.","pos":""}],"MOWBURN":[{"def":"To heat and ferment in the mow, as hay when housed too green.","pos":""}],"MOWE":[{"def":"See 1st & 2d Mow.","pos":""}],"MOWER":[{"def":"One who, or that which, mows; a mowing machine; as, a lawn mower.","pos":""}],"MOWING":[{"def":"The act of one who, or the operation of that which, mows.","pos":""},{"def":"Land from which grass is cut; meadow land.","pos":""}],"MOWN":[{"def":"Cut down by mowing, as grass; deprived of grass by mowing; as, a mown field.","pos":""}]}