{"CID":[{"def":"Chief or commander; in Spanish literature, a title of Ruy Diaz, Count of Bivar, a champion of Christianity and of the old Spanish royalty, in the 11th century.","pos":""},{"def":"An epic poem, which celebrates the exploits of the Spanish national hero, Ruy Diaz.","pos":""}],"CIDER":[{"def":"The expressed juice of apples.","pos":""}],"CIDERIST":[{"def":"A maker of cider.","pos":""}],"CIDERKIN":[{"def":"A kind of weak cider made by steeping the refuse pomace in water.","pos":""}]}