{"ACCEDE":[{"def":"To approach; to come forward; -- opposed to recede.","pos":""},{"def":"To enter upon an office or dignity; to attain.","pos":""}],"ACCEDENCE":[{"def":"The act of acceding.","pos":""}],"ACCEDER":[{"def":"One who accedes.","pos":""}],"ACCELERANDO":[{"def":"Gradually accelerating the movement.","pos":""}],"ACCELERATE":[{"def":"To cause to move faster; to quicken the motion of; to add to the speed of; -- opposed to retard.","pos":""},{"def":"To quicken the natural or ordinary progression or process of; as, to accelerate the growth of a plant, the increase of wealth, etc.","pos":""}],"ACCELERATION":[{"def":"The act of accelerating, or the state of being accelerated; increase of motion or action; as, a falling body moves toward the earth with an acceleration of velocity; -- opposed to retardation.","pos":""}],"ACCELERATIVE":[{"def":"Relating to acceleration; adding to velocity; quickening.","pos":""}],"ACCELERATOR":[{"def":"One who, or that which, accelerates.","pos":""}],"ACCELEROGRAPH":[{"def":"An apparatus for studying the combustion of powder in guns, etc.","pos":""}],"ACCELEROMETER":[{"def":"An apparatus for measuring the velocity imparted by gunpowder.","pos":""}],"ACCEND":[{"def":"To set on fire; to kindle.","pos":""}],"ACCENDIBILITY":[{"def":"Capacity of being kindled, or of becoming inflamed; inflammability.","pos":""}],"ACCENDIBLE":[{"def":"Capable of being inflamed or kindled; combustible; inflammable.","pos":""}],"ACCENSION":[{"def":"The act of kindling or the state of being kindled; ignition.","pos":""}],"ACCENSOR":[{"def":"One of the functionaries who light and trim the tapers.","pos":""}],"ACCENT":[{"def":"Stress laid on certain syllables of a verse.","pos":""}],"ACCENTOR":[{"def":"One who sings the leading part; the director or leader.","pos":""},{"def":"A genus of European birds (so named from their sweet notes), including the hedge warbler.","pos":""}],"ACCENTUABLE":[{"def":"Capable of being accented.","pos":""}],"ACCENTUAL":[{"def":"Of or pertaining to accent; characterized or formed by accent.","pos":""}],"ACCENTUALITY":[{"def":"The quality of being accentual.","pos":""}],"ACCENTUALLY":[{"def":"In an accentual manner; in accordance with accent.","pos":""}],"ACCENTUATE":[{"def":"To pronounce with an accent or with accents.","pos":""},{"def":"To bring out distinctly; to make prominent; to emphasize.","pos":""}],"ACCENTUATION":[{"def":"Act of accentuating; applications of accent.","pos":""},{"def":"pitch or modulation of the voice in reciting portions of the liturgy.","pos":""}],"ACCEPT":[{"def":"To receive as obligatory and promise to pay; as, to accept a bill of exchange.","pos":""}],"ACCEPTABILITY":[{"def":"The quality of being acceptable; acceptableness.","pos":""}],"ACCEPTABLE":[{"def":"Capable, worthy, or sure of being accepted or received with pleasure; pleasing to a receiver; gratifying; agreeable; welcome; as, an acceptable present, one acceptable to us.","pos":""}],"ACCEPTABLENESS":[{"def":"The quality of being acceptable, or suitable to be favorably received; acceptability.","pos":""}],"ACCEPTABLY":[{"def":"In an acceptable manner; in a manner to please or give satisfaction.","pos":""}],"ACCEPTANCE":[{"def":"An agreeing to the action of another, by some act which binds the person in law.","pos":""}],"ACCEPTANCY":[{"def":"Here's a proof of gift, But here's no proof, sir, of acceptancy.","pos":""}],"ACCEPTANT":[{"def":"Accepting; receiving.","pos":""}],"ACCEPTATION":[{"def":"Acceptance; reception; favorable reception or regard; state of being acceptable.","pos":""},{"def":"The meaning in which a word or expression is understood, or generally received; as, term is to be used according to its usual acceptation.","pos":""}],"ACCEPTEDLY":[{"def":"In a accepted manner; admittedly.","pos":""}],"ACCEPTER":[{"def":"A person who accepts; a taker.","pos":""},{"def":"A respecter; a viewer with partiality.","pos":""}],"ACCEPTILATION":[{"def":"Gratuitous discharge; a release from debt or obligation without payment; free remission.","pos":""}],"ACCEPTION":[{"def":"Acceptation; the received meaning.","pos":""}],"ACCEPTIVE":[{"def":"Fit for acceptance.","pos":""},{"def":"Ready to accept.","pos":""}],"ACCEPTOR":[{"def":"One who accepts; specifically (Law & Com.","pos":""},{"def":"one who accepts an order or a bill of exchange; a drawee after he has accepted.","pos":""}],"ACCESS":[{"def":"A coming to, or near approach; admittance; admission; accessibility; as, to gain access to a prince.","pos":""},{"def":"The means, place, or way by which a thing may be approached; passage way; as, the access is by a neck of land.","pos":""}],"ACCESSARILY":[{"def":"In the manner of an accessary.","pos":""}],"ACCESSARINESS":[{"def":"The state of being accessary.","pos":""}],"ACCESSARY":[{"def":"Accompanying, as a subordinate; additional; accessory; esp.","pos":""}],"ACCESSIBILITY":[{"def":"The quality of being accessible, or of admitting approach; receptibility.","pos":""}],"ACCESSIBLE":[{"def":"Easy of access or approach; approachable; as, an accessible town or mountain, an accessible person.","pos":""},{"def":"Open to the influence of; -- with to.","pos":""}],"ACCESSIBLY":[{"def":"In an accessible manner.","pos":""}],"ACCESSION":[{"def":"The invasion, approach, or commencement of a disease; a fit or paroxysm.","pos":""}],"ACCESSIONAL":[{"def":"Pertaining to accession; additional.","pos":""}],"ACCESSORIAL":[{"def":"Of or pertaining to an accessory; as, accessorial agency, accessorial guilt.","pos":""}],"ACCESSORILY":[{"def":"In the manner of an accessory; auxiliary.","pos":""}],"ACCESSORINESS":[{"def":"The state of being accessory, or connected subordinately.","pos":""}],"ACCESSORY":[{"def":"Accompanying as a subordinate; aiding in a secondary way; additional; connected as an incident or subordinate to a principal; contributing or contributory; said of persons and things, and, when of persons, usually in a bad sense; as, he was accessory to the riot; accessory sounds in music.","pos":""}]}