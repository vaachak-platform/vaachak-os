{"WAFER":[{"def":"A thin cake made of flour and other ingredients.","pos":""},{"def":"A thin cake or piece of bread (commonly unleavened, circular, and stamped with a crucifix or with the sacred monogram) used in the Eucharist, as in the Roman Catholic Church.","pos":""}],"WAFERER":[{"def":"A dealer in the cakes called wafers; a confectioner.","pos":""}],"WAFFLE":[{"def":"A thin cake baked and then rolled; a wafer.","pos":""},{"def":"A soft indented cake cooked in a waffle iron.","pos":""}],"WAFT":[{"def":"To give notice to by waving something; to wave the hand to; to beckon.","pos":""},{"def":"To cause to move or go in a wavy manner, or by the impulse of waves, as of water or air; to bear along on a buoyant medium; as, a balloon was wafted over the channel.","pos":""}],"WAFTAGE":[{"def":"Conveyance on a buoyant medium, as air or water.","pos":""}],"WAFTER":[{"def":"One who, or that which, wafts.","pos":""},{"def":"A boat for passage.","pos":""}],"WAFTURE":[{"def":"The act of waving; a wavelike motion; a waft.","pos":""}]}