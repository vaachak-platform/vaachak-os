{"REPACE":[{"def":"To pace again; to walk over again in a contrary direction.","pos":""}],"REPACIFY":[{"def":"To pacify again.","pos":""}],"REPACK":[{"def":"To pack a second time or anew; as, to repack beef; to repack a trunk.","pos":""}],"REPACKER":[{"def":"One who repacks.","pos":""}],"REPAGANIZE":[{"def":"To paganize anew; to bring back to paganism.","pos":""}],"REPAID":[{"def":"Re*paid\" (r-pd\"), Defn: imp.","pos":""}],"REPAINT":[{"def":"To paint anew or again; as, to repaint a house; to repaint the ground of a picture.","pos":""}],"REPAIR":[{"def":"To go; to betake one's self; to resort; ass, to repair to sanctuary for safety.","pos":""}],"REPAIRABLE":[{"def":"Re*pair\"a*ble (-*b'l), a.","pos":""}],"REPAIRER":[{"def":"One who, or that which, repairs, restores, or makes amends.","pos":""}],"REPAIRMENT":[{"def":"Act of repairing.","pos":""}],"REPAND":[{"def":"Having a slightly undulating margin; -- said of leaves.","pos":""}],"REPARABILITY":[{"def":"The quality or state of being reparable.","pos":""}],"REPARABLE":[{"def":"Capable of being repaired, restored to a sound or good state, or made good; restorable; as, a reparable injury.","pos":""}],"REPARABLY":[{"def":"In a reparable manner.","pos":""}],"REPARATION":[{"def":"The act of renewing, restoring, etc.","pos":""},{"def":"The act of making amends or giving satisfaction or compensation for a wrong, injury, etc.","pos":""}],"REPARATIVE":[{"def":"Repairing, or tending to repair.","pos":""}],"REPAREL":[{"def":"A change of apparel; a second or different suit.","pos":""}],"REPARTEE":[{"def":"A smart, ready, and witty reply.","pos":""}],"REPARTIMIENTO":[{"def":"A partition or distribution, especially of slaves; also, an assessment of taxes.","pos":""}],"REPARTOTION":[{"def":"Another, or an additional, separation into parts.","pos":""}],"REPASS":[{"def":"To pass again; to pass or travel over in the opposite direction; to pass a second time; as, to repass a bridge or a river; to repass the sea.","pos":""}],"REPASSAGE":[{"def":"The act of repassing; passage back.","pos":""}],"REPASSANT":[{"def":"Re*pas\"sant (r-ps\"sant), a.","pos":""}],"REPAST":[{"def":"The act of taking food.","pos":""},{"def":"That which is taken as food; a meal; figuratively, any refreshment.","pos":""}],"REPASTER":[{"def":"One who takes a repast.","pos":""}],"REPASTURE":[{"def":"Food; entertainment.","pos":""}],"REPATRIATE":[{"def":"To restore to one's own country.","pos":""}],"REPATRIATION":[{"def":"Restoration to one's country.","pos":""}],"REPAY":[{"def":"To pay back; to refund; as, to repay money borrowed or advanced.","pos":""},{"def":"To make return or requital for; to recompense; -- in a good or bad sense; as, to repay kindness; to repay an injury.","pos":""}],"REPAYABLE":[{"def":"Capable of being, or proper to be , repaid; due; as, a loan repayable in ten days; services repayable in kind.","pos":""}],"REPAYMENT":[{"def":"The act of repaying; reimbursement.","pos":""},{"def":"The money or other thing repaid.","pos":""}]}