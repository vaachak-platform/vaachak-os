{"CROSIER":[{"def":"The pastoral staff of a bishop (also of an archbishop, being the symbol of his office as a shepherd of the flock of God.","pos":""}],"CROSIERED":[{"def":"Bearing a crosier.","pos":""}],"CROSLET":[{"def":"Cros\"let (krs\"lt; 115), n.","pos":""}],"CROSS":[{"def":"A monument in the form of a cross, or surmounted bu a cross, set up in a public place; as, a market cross; a boundary cross; Charing Cross in London.","pos":""},{"def":"A common heraldic bearing, of which there are many varieties.","pos":""}],"CROSS-ARMED":[{"def":"With arms crossed.","pos":""}],"CROSS-BANDED":[{"def":"A term used when a narrow ribbon of veneer is inserted into the surfase of any piece of furniture, wainscoting, etc.","pos":""}],"CROSS-BEARER":[{"def":"A subdeacon who bears a cross before an archbishop or primate on solemn occasions.","pos":""}],"CROSS-BIRTH":[{"def":"Any preternatural labor, in whiche the boly of the child lies across the pelvis of the mother, so that the shoulder, arm, or trunk is the part first presented at the mouth of the uterus.","pos":""}],"CROSS-BUN":[{"def":"A bun or cake marked with a cross, and intended to be eaten on Good Friday.","pos":""}],"CROSS-BUTTOCK":[{"def":"A throw in which the wrestler turns his left side to his opponent, places his left leg across both legs of his opponent, and pulls him forward over his hip; hence, an unexpected defeat or repulse.","pos":""}],"CROSS-CROSSLET":[{"def":"A cross having the three upper ends crossed, so as to from three small crosses.","pos":""}],"CROSS-DAYS":[{"def":"The three days preceding the Feast of the Ascension.","pos":""}],"CROSS-EXAMINATION":[{"def":"The interrogating or questioning of a witness by the party against whom he has been called and examined.","pos":""}],"CROSS-EXAMINE":[{"def":"To examine or question, as a witness who has been called and examined by the opposite party.","pos":""}],"CROSS-EXAMINER":[{"def":"One who cross-examines or conducts a crosse-examination.","pos":""}],"CROSS-EYED":[{"def":"Affected with strabismus; squint-eyed; squinting.","pos":""}],"CROSS-FERTILIZE":[{"def":"To fertilize, as the stigmas of a flower or plant, with the pollen from another individual of the same species.","pos":""}],"CROSS-GARNET":[{"def":"A hinge having one strap perpendicular and the other strap horizontal giving it the form of an Egyptian or T cross.","pos":""}],"CROSS-PAWL":[{"def":"Same as Cross-spale.","pos":""}],"CROSS-PURPOSE":[{"def":"A conversational game, in which questions and answers are made so as to involve ludicrous combinations of ideas.","pos":""}],"CROSS-QUESTION":[{"def":"To cross-examine; to subject to close questioning.","pos":""}],"CROSS-READING":[{"def":"The reading of the lines of a newspaper directly across the page, instead of down the columns, thus producing a ludicrous combination of ideas.","pos":""}],"CROSS-SPRINGER":[{"def":"One of the ribs in a groined arch, springing from the corners in a diagonal direction.","pos":""}],"CROSS-STAFF":[{"def":"An instrument formerly used at sea for taking the altitudes of celestial bodies.","pos":""},{"def":"A surveyor's instrument for measuring offsets.","pos":""}],"CROSS-STITCH":[{"def":"A form of stitch, where the stitches are diagonal and in pairs, the thread of one stitch crossing that of the other.","pos":""}],"CROSS-STONE":[{"def":"See Harmotome, and Staurotide.","pos":""}],"CROSS-TAIL":[{"def":"A bar connecting the ends of the side rods or levers of a backaction or side-lever engine.","pos":""}],"CROSS-TIE":[{"def":"A sleeper supporting and connecting the rails, and holding them in place.","pos":""}],"CROSS-TINING":[{"def":"A mode of harrowing crosswise, or transversely to the ridges.","pos":""}],"CROSS-VAULTING":[{"def":"Vaulting formed by the intersection of two or more simple vaults.","pos":""}],"CROSS-WEEK":[{"def":"Rogation week, when the cross was borne in processions.","pos":""}],"CROSSBAR":[{"def":"A transverse bar or piece, as a bar across a door, or as the iron bar or stock which passes through the shank of an anchor to insure its turning fluke down.","pos":""}],"CROSSBARRED":[{"def":"Secured by, or furnished with, crossbars.","pos":""},{"def":"Made or patterned in lines crossing each other; as, crossbarred muslin.","pos":""}],"CROSSBEAK":[{"def":"Same as Crossbill.","pos":""}],"CROSSBEAM":[{"def":"A beam laid across the bitts, to which the cable is fastened when riding at anchor.","pos":""}],"CROSSBILL":[{"def":"A bill brought by a defendant, in an equity or chancery suit, against the plaintiff, respecting the matter in question in that suit.","pos":""}],"CROSSBITE":[{"def":"A deeption; a cheat.","pos":""}],"CROSSBONES":[{"def":"A representation of two of the leg bones or arm bones of a skeleton, laid crosswise, often surmounted with a skull, and serving as a symbol of death.","pos":""}],"CROSSBOW":[{"def":"A weapon, used in discharging arrows, formed by placing a bow crosswise on a stock.","pos":""}],"CROSSBOWER":[{"def":"Cross\"bow`er (-b`r), n.","pos":""}],"CROSSBOWMAN":[{"def":"One who shoots with a crossbow.","pos":""}],"CROSSBRED":[{"def":"Produced by mixing distinct breeds; mongrel.","pos":""}],"CROSSBREED":[{"def":"A breed or an animal produced from parents of different breeds; a new variety, as of plants, combining the qualites of two parent varieties or stocks.","pos":""},{"def":"Anything partaking of the natures of two different things; a hybrid.","pos":""}],"CROSSCUT":[{"def":"Cross\"cut` (-kt`) Defn: , v.","pos":""}],"CROSSE":[{"def":"The implement with which the ball is thrown and caught in the game of lacrosse.","pos":""}],"CROSSETTE":[{"def":"Cros*sette\" (krs-st`), n.","pos":""}],"CROSSFISH":[{"def":"Cross\"fish` (-fsh`), n.","pos":""}],"CROSSFLOW":[{"def":"To flow across, or in a contrary direction.","pos":""}],"CROSSGRAINED":[{"def":"Having the grain or fibers run diagonally, or more or less transversely an irregularly, so as to interfere with splitting or planing.","pos":""},{"def":"Perverse; untractable; contrary.","pos":""}],"CROSSHATCH":[{"def":"To shade by means of crosshatching.","pos":""}],"CROSSHATCHING":[{"def":"In drawing and line engraving, shading with lines that cross one another at an angle.","pos":""}],"CROSSHEAD":[{"def":"A beam or bar across the head or end of a rod, etc.","pos":""}],"CROSSING":[{"def":"The act by which anything is crossed; as, the crossing of the ocean.","pos":""},{"def":"The act of making the sign of the cross.","pos":""}],"CROSSJACK":[{"def":"The lowest square sail, or the lower yard of the mizzenmast.","pos":""}],"CROSSLEGGED":[{"def":"Having the legs crossed.","pos":""}],"CROSSLET":[{"def":"Crossed again; -- said of a cross the arms of which are crossed.","pos":""}],"CROSSLY":[{"def":"Athwart; adversely; unfortunately; peevishly; fretfully; with ill humor.","pos":""}],"CROSSNESS":[{"def":"The quality or state of being cross; peevishness; fretfulness; ill humor.","pos":""}],"CROSSOPTERYGIAN":[{"def":"Of or pertaining to the Crossopterygii.","pos":""},{"def":"One of the Crossopterygii.","pos":""}],"CROSSOPTERYGII":[{"def":"An order of ganoid fishes including among living species the bichir (Polypterus).","pos":""}],"CROSSPATCH":[{"def":"An ill-natured person.","pos":""}],"CROSSPIECE":[{"def":"A bar or timber connecting two knightheads or two bitts.","pos":""}],"CROSSROAD":[{"def":"A road that crosses another; an obscure road intersecting or avoiding the main road.","pos":""}],"CROSSROW":[{"def":"The alphabet; -- called also Christcross-row.","pos":""},{"def":"A row that crosses others.","pos":""}],"CROSSRUFF":[{"def":"The play in whist where partners trump each a different suit, and lead to each other for that purpose; -- called also seesaw.","pos":""},{"def":"One of the temporary wooden braces, placed horizontally across a frame to hold it in position until the deck beams are in; a cross- pawl.","pos":""}],"CROSSTREES":[{"def":"Pieces of timber at a masthead, to which are attached the upper shrouds.","pos":""}],"CROSSWISE":[{"def":"In the form of a cross; across; transversely.","pos":""}],"CROSSWORT":[{"def":"A name given to several inconspicuous plants having leaves in whorls of four, as species of Crucianella, Valantia, etc.","pos":""}]}