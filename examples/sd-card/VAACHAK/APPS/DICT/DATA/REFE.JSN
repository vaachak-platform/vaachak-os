{"REFECT":[{"def":"To restore after hunger or fatique; to refresh.","pos":""}],"REFECTION":[{"def":"Refreshment after hunger or fatique; a repast; a lunch.","pos":""}],"REFECTIVE":[{"def":"Refreshing; restoring.","pos":""}],"REFECTORY":[{"def":"A room for refreshment; originally, a dining hall in monasteries or convents.","pos":""}],"REFEL":[{"def":"To refute; to disprove; as, to refel the tricks of a sophister.","pos":""}],"REFER":[{"def":"To carry or send back.","pos":""},{"def":"Hence: To send or direct away; to send or direct elsewhere, as for treatment, aid, infirmation, decision, etc.","pos":""}],"REFERABLE":[{"def":"Capable of being referred, or considered in relation to something else; assignable; ascribable.","pos":""}],"REFEREE":[{"def":"One to whom a thing is referred; a person to whom a matter in dispute has been referred, in order that he may settle it.","pos":""}],"REFERENCE":[{"def":"The process of sending any matter, for inquiry in a cause, to a master or other officer, in order that he may ascertain facts and report to the court.","pos":""}],"REFERENDARY":[{"def":"One to whose decision a cause is referred; a referee.","pos":""},{"def":"An officer who delivered the royal answer to petitions.","pos":""}],"REFERENDUM":[{"def":"A diplomatic agent's note asking for instructions from his government concerning a particular matter or point.","pos":""},{"def":"The right to approve or reject by popular vote a meassure passed upon by a legislature.","pos":""}],"REFERENTIAL":[{"def":"Containing a reference; pointing to something out of itself; as, notes for referential use.","pos":""}],"REFERMENT":[{"def":"The act of referring; reference.","pos":""}],"REFERRER":[{"def":"Re*fer\"rer (r*fr\"rr), n.","pos":""}],"REFERRIBLE":[{"def":"Re*fer\"ri*ble (-r*b'l), a.","pos":""}]}