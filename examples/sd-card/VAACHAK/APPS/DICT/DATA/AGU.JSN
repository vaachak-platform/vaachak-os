{"AGUARDIENTE":[{"def":"A inferior brandy of Spain and Portugal.","pos":""},{"def":"A strong alcoholic drink, especially pulque.","pos":""}],"AGUE":[{"def":"An intermittent fever, attended by alternate cold and hot fits.","pos":""}],"AGUILT":[{"def":"To be guilty of; to offend; to sin against; to wrong.","pos":""}],"AGUISE":[{"def":"To dress; to attire; to adorn.","pos":""}],"AGUISH":[{"def":"Having the qualities of an ague; somewhat cold or shivering; chilly; shaky.","pos":""},{"def":"Productive of, or affected by, ague; as, the aguish districts of England.","pos":""}],"AGUSH":[{"def":"In a gushing state.","pos":""}]}