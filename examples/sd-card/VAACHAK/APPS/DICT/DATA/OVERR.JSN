{"OVERRAKE":[{"def":"To rake over, or sweep across, from end to end, as waves that break over a vessel anchored with head to the sea.","pos":""}],"OVERRANK":[{"def":"Too rank or luxuriant.","pos":""}],"OVERRATE":[{"def":"To rate or value too highly.","pos":""}],"OVERREACH":[{"def":"To reach above or beyond in any direction.","pos":""},{"def":"To deceive, or get the better of, by artifice or cunning; to outwit; to cheat.","pos":""}],"OVERREACHER":[{"def":"One who overreaches; one who cheats; a cheat.","pos":""}],"OVERREAD":[{"def":"To read over, or peruse.","pos":""}],"OVERRECKON":[{"def":"To reckon too highly.","pos":""}],"OVERRED":[{"def":"To smear with red.","pos":""}],"OVERREFINE":[{"def":"To refine too much.","pos":""}],"OVERREFINEMENT":[{"def":"Excessive refinement.","pos":""}],"OVERRENT":[{"def":"To rent for too much.","pos":""}],"OVERRICH":[{"def":"Exccessively rich.","pos":""}],"OVERRIDE":[{"def":"To ride over or across; to ride upon; to trample down.","pos":""},{"def":"To suppress; to destroy; to supersede; to annul; as, one low overrides another; to override a veto.","pos":""}],"OVERRIGGED":[{"def":"Having too much rigging.","pos":""}],"OVERRIGHTEOUS":[{"def":"Excessively righteous; -- usually implying hypocrisy.","pos":""}],"OVERRIGID":[{"def":"Too rigid; too severe.","pos":""}],"OVERRIGOROUS":[{"def":"Too rigorous; harsh.","pos":""}],"OVERRIPE":[{"def":"Matured to excess.","pos":""}],"OVERRIPEN":[{"def":"To make too ripe.","pos":""}],"OVERROAST":[{"def":"To roast too much.","pos":""}],"OVERRULE":[{"def":"To supersede, reject, annul, or rule against; as, the plea, or the decision, was overruled by the court.","pos":""}],"OVERRULER":[{"def":"One who, or that which, controls, governs, or determines.","pos":""}],"OVERRULING":[{"def":"Exerting controlling power; as, an overruling Providence.","pos":""}],"OVERRUN":[{"def":"To run over; to grow or spread over in excess; to invade and occupy; to take possession of; as, the vine overran its trellis; the farm is overrun with witch grass.","pos":""},{"def":"To exceed in distance or speed of running; to go beyond or pass in running.","pos":""}],"OVERRUNNER":[{"def":"One that overruns.","pos":""}]}