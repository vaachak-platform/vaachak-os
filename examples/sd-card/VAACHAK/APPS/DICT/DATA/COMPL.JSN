{"COMPLACENT":[{"def":"Self-satisfied; contented; kindly; as, a complacent temper; a complacent smile.","pos":""}],"COMPLACENTIAL":[{"def":"Marked by, or causing, complacence.","pos":""}],"COMPLACENTLY":[{"def":"In a complacent manner.","pos":""}],"COMPLAIN":[{"def":"To give utterance to expression of grief, pain, censure, regret.","pos":""},{"def":"To make a formal accusation; to make a charge.","pos":""}],"COMPLAINABLE":[{"def":"That may be complained of.","pos":""}],"COMPLAINANT":[{"def":"One who makes complaint.","pos":""}],"COMPLAINER":[{"def":"One who complains or laments; one who finds fault; a murmurer.","pos":""}],"COMPLAINT":[{"def":"A formal allegation or charge against a party made or presented to the appropriate court or officer, as for a wrong done or a crime committed (in the latter case, generally under oath); an information; accusation; the initial bill in proceedings in equity.","pos":""}],"COMPLAINTFUL":[{"def":"Full of complaint.","pos":""}],"COMPLAISANCE":[{"def":"Disposition to please or oblige; obliging compliance with the wishes of others; a deportment indicative of a desire to please; courtesy; civility.","pos":""}],"COMPLAISANT":[{"def":"Desirous to please; courteous; obliging; compliant; as, a complaisant gentleman.","pos":""}],"COMPLANATE":[{"def":"Flattened to a level surface.","pos":""}],"COMPLEMENT":[{"def":"A second quantity added to a given quantity to make equal to a third given quantity.","pos":""},{"def":"The whole working force of a vessel.","pos":""}],"COMPLEMENTAL":[{"def":"Supplying, or tending to supply, a deficiency; fully completing.","pos":""},{"def":"Complimentary; courteous.","pos":""}],"COMPLEMENTARY":[{"def":"Serving to fill out or to complete; as, complementary numbers.","pos":""}],"COMPLETE":[{"def":"Having all the parts or organs which belong to it or to the typical form; having calyx, corolla, stamens, and pistil.","pos":""}],"COMPLETELY":[{"def":"In a complete manner; fully.","pos":""}],"COMPLETEMENT":[{"def":"Act of completing or perfecting; completion.","pos":""}],"COMPLETENESS":[{"def":"The state of being complete.","pos":""}],"COMPLETION":[{"def":"The act or process of making complete; the getting through to the end; as, the completion of an undertaking, an education, a service.","pos":""},{"def":"State of being complete; fulfillment; accomplishment; realization.","pos":""}],"COMPLETIVE":[{"def":"Making complete.","pos":""}],"COMPLETORY":[{"def":"Serving to fulfill.","pos":""}],"COMPLEX":[{"def":"Composed of two or more parts; composite; not simple; as, a complex being; a complex idea.","pos":""},{"def":"Involving many parts; complicated; intricate.","pos":""}],"COMPLEXED":[{"def":"Complex, complicated.","pos":""}],"COMPLEXEDNESS":[{"def":"The quality or state of being complex or involved; complication.","pos":""}],"COMPLEXION":[{"def":"The state of being complex; complexity.","pos":""},{"def":"A combination; a complex.","pos":""}],"COMPLEXIONAL":[{"def":"Of or pertaining to constitutional complexion.","pos":""}],"COMPLEXIONALLY":[{"def":"Constitutionally.","pos":""}],"COMPLEXIONARY":[{"def":"Pertaining to the complexion, or to the care of it.","pos":""}],"COMPLEXIONED":[{"def":"Having (such) a complexion; -- used in composition; as, a dark- complexioned or a ruddy-complexioned person.","pos":""}],"COMPLEXITY":[{"def":"The state of being complex; intricacy; entanglement.","pos":""},{"def":"That which is complex; intricacy; complication.","pos":""}],"COMPLEXLY":[{"def":"In a complex manner; not simply.","pos":""}],"COMPLEXNESS":[{"def":"The state of being complex; complexity.","pos":""}],"COMPLEXUS":[{"def":"A complex; an aggregate of parts; a complication.","pos":""}],"COMPLIABLE":[{"def":"Capable of bending or yielding; apt to yield; compliant.","pos":""}],"COMPLIANCE":[{"def":"The act of complying; a yielding; as to a desire, demand, or proposal; concession; submission.","pos":""},{"def":"A disposition to yield to others; complaisance.","pos":""}],"COMPLIANCY":[{"def":"Compliance; disposition to yield to others.","pos":""}],"COMPLIANT":[{"def":"Yielding; bending; pliant; submissive.","pos":""}],"COMPLIANTLY":[{"def":"In a compliant manner.","pos":""}],"COMPLICACY":[{"def":"A state of being complicate or intricate.","pos":""}],"COMPLICANT":[{"def":"Overlapping, as the elytra of certain beetles.","pos":""}],"COMPLICATE":[{"def":"Folded together, or upon itself, with the fold running lengthwise.","pos":""}],"COMPLICATELY":[{"def":"In a complex manner.","pos":""}],"COMPLICATION":[{"def":"A disease or diseases, or adventitious circumstances or conditions, coexistent with and modifying a primary disease, but not necessarily connected with it.","pos":""}],"COMPLICE":[{"def":"To quell the rebels and their complices.","pos":""}],"COMPLICITY":[{"def":"The state of being an accomplice; participation in guilt.","pos":""}],"COMPLIER":[{"def":"One who complies, yields, or obeys; one of an easy, yieldy temper.","pos":""}],"COMPLIMENT":[{"def":"An expression, by word or act, of approbation, regard, confidence, civility, or admiration; a flattering speech or attention; a ceremonious greeting; as, to send one's compliments to a friend.","pos":""}],"COMPLIMENTARY":[{"def":"Expressive of regard or praise; of the nature of, or containing, a compliment; as, a complimentary remark; a complimentary ticket.","pos":""}],"COMPLIMENTATIVE":[{"def":"Com`pli*men\"ta*tive, a.","pos":""}],"COMPLIMENTER":[{"def":"One who compliments; one given to complimenting; a flatterer.","pos":""},{"def":"The last division of the Roman Catholic breviary; the seventh and last of the canonical hours of the Western church; the last prayer of the day, to be said after sunset.","pos":""}],"COMPLOT":[{"def":"A plotting together; a confederacy in some evil design; a conspiracy.","pos":""}],"COMPLOTMENT":[{"def":"A plotting together.","pos":""}],"COMPLOTTER":[{"def":"One joined in a plot.","pos":""}],"COMPLUTENSIAN":[{"def":"Of or pertaining to Complutum (now Alcala de Henares) a city near Madrid; as, the Complutensian Bible.","pos":""}],"COMPLUVIUM":[{"def":"A space left unroofed over the court of a Roman dwelling, through which the rain fell into the impluvium or cistern.","pos":""}],"COMPLY":[{"def":"To yield assent; to accord; agree, or acquiesce; to adapt one's self; to consent or conform; -- usually followed by with.","pos":""},{"def":"To be ceremoniously courteous; to make one's compliments.","pos":""}]}