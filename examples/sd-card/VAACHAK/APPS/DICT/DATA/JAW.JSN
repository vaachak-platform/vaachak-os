{"JAW":[{"def":"The inner end of a boom or gaff, hollowed in a half circle so as to move freely on a mast.","pos":""},{"def":"Impudent or abusive talk.","pos":""}],"JAW-FALL":[{"def":"Depression of the jaw; hence, depression of spirits.","pos":""}],"JAW-FALLEN":[{"def":"Dejected; chopfallen.","pos":""}],"JAWBONE":[{"def":"The bone of either jaw; a maxilla or a mandible.","pos":""}],"JAWED":[{"def":"Having jaws; -- chiefly in composition; as, lantern-jawed.","pos":""}],"JAWING":[{"def":"Scolding; clamorous or abusive talk.","pos":""}],"JAWY":[{"def":"Relating to the jaws.","pos":""}]}