{"TUN":[{"def":"A fermenting vat.","pos":""},{"def":"A weight of 2,240 pounds.","pos":""}],"TUN-BELLIED":[{"def":"Having a large, protuberant belly, or one shaped like a tun; pot-bellied.","pos":""}],"TUN-GREAT":[{"def":"Having the circumference of a tun.","pos":""}],"TUNA":[{"def":"The Opuntia Tuna.","pos":""}],"TUNABLE":[{"def":"Capable of being tuned, or made harmonious; hence, harmonious; musical; tuneful.","pos":""}],"TUNDRA":[{"def":"A rolling, marshy, mossy plain of Northern Siberia.","pos":""}],"TUNE":[{"def":"A sound; a note; a tone.","pos":""},{"def":"Order; harmony; concord; fit disposition, temper, or humor; right mood.","pos":""}],"TUNEFUL":[{"def":"Harmonious; melodious; musical; as, tuneful notes.","pos":""}],"TUNELESS":[{"def":"Without tune; inharmonious; unmusical.","pos":""},{"def":"Not employed in making music; as, tuneless harps.","pos":""}],"TUNER":[{"def":"One who tunes; especially, one whose occupation is to tune musical instruments.","pos":""}],"TUNGSTATE":[{"def":"A salt of tungstic acid; a wolframate.","pos":""}],"TUNGSTEN":[{"def":"A rare element of the chromium group found in certain minerals, as wolfram and scheelite, and isolated as a heavy steel-gray metal which is very hard and infusible.","pos":""},{"def":"Scheelite, or calcium tungstate.","pos":""}],"TUNGSTEN LAMP":[{"def":"An electric glow lamp having filaments of metallic tungsten.","pos":""}],"TUNGSTEN STEEL":[{"def":"A steel containing a small amount of tungsten, noted for tenacity and hardness, even under a considerable degree of heat.","pos":""}],"TUNGSTENIC":[{"def":"Of or pertaining to tungsten; containing tungsten; as, tungstenic ores.","pos":""}],"TUNGSTIC":[{"def":"Of or pertaining to tungsten; derived from, or resembling, tungsten; wolframic; as, tungstic oxide.","pos":""}],"TUNGSTITE":[{"def":"The oxide of tungsten, a yellow mineral occurring in a pulverulent form.","pos":""}],"TUNGUSES":[{"def":"A group of roving Turanian tribes occupying Eastern Siberia and the Amoor valley.","pos":""}],"TUNGUSIC":[{"def":"Of or pertaining to the Tunguses; as, the Tungusic dialects.","pos":""}],"TUNHOOF":[{"def":"Ground ivy; alehoof.","pos":""}],"TUNIC":[{"def":"An under-garment worn by the ancient Romans of both sexes.","pos":""},{"def":"Same as Tunicle.","pos":""}],"TUNICARY":[{"def":"One of the Tunicata.","pos":""}],"TUNICATA":[{"def":"A grand division of the animal kingdom, intermediate, in some respects, between the invertebrates and vertebrates, and by some writers united with the latter.","pos":""},{"def":"Covered with a tunic; covered or coated with layers; as, a tunicated bulb.","pos":""}],"TUNICATE":[{"def":"One of the Tunicata.","pos":""}],"TUNICIN":[{"def":"Animal cellulose; a substance present in the mantle, or tunic, of the Tunicates, which resembles, or is identical with, the cellulose of the vegetable kingdom.","pos":""}],"TUNICLE":[{"def":"A short, close-fitting vestment worn by bishops under the dalmatic, and by subdeacons.","pos":""}],"TUNK":[{"def":"A sharp blow; a thump.","pos":""}],"TUNNEL":[{"def":"A level passage driven across the measures, or at right angles to veins which it is desired to reach; -- distinguished from the drift, or gangway, which is led along the vein when reached by the tunnel.","pos":""}],"TUNNEL STERN":[{"def":"A design of motor-boat stern, for use in shallow waters, in which the propeller is housed in a tunnel and does not extend below the greatest draft.","pos":""}],"TUNNY":[{"def":"Any one of several species of large oceanic fishes belonging to the Mackerel family, especially the common or great tunny (Orcynus or Albacora thynnus) native of the Mediterranean Sea and the Atlantic Ocean.","pos":""}]}