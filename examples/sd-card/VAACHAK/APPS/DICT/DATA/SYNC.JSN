{"SYNCARP":[{"def":"A kind of aggregate fruit in which the ovaries cohere in a solid mass, with a slender receptacle, as in the magnolia; also, a similar multiple fruit, as a mulberry.","pos":""}],"SYNCARPIUM":[{"def":"Same as Syncarp.","pos":""}],"SYNCARPOUS":[{"def":"Composed of several carpels consolidated into one ovary.","pos":""}],"SYNCATEGOREMATIC":[{"def":"Not capable of being used as a term by itself; -- said of words, as an adverb or preposition.","pos":""}],"SYNCHONDROSIS":[{"def":"An immovable articulation in which the union is formed by cartilage.","pos":""}],"SYNCHORESIS":[{"def":"A concession made for the purpose of retorting with greater force.","pos":""}],"SYNCHRONAL":[{"def":"Happening at, or belonging to, the same time; synchronous; simultaneous.","pos":""}],"SYNCHRONICAL":[{"def":"Happening at the same time; synchronous.","pos":""}],"SYNCHRONISM":[{"def":"A representation, in the same picture, of two or events which occured at different times.","pos":""}],"SYNCHRONISTIC":[{"def":"Of or pertaining to synchronism; arranged according to correspondence in time; as, synchronistic tables.","pos":""}],"SYNCHRONIZATION":[{"def":"The act of synchronizing; concurrence of events in respect to time.","pos":""}],"SYNCHRONIZE":[{"def":"To agree in time; to be simultaneous.","pos":""}],"SYNCHRONOLOGY":[{"def":"Contemporaneous chronology.","pos":""}],"SYNCHRONOUS":[{"def":"Happening at the same time; simultaneous.","pos":""}],"SYNCHRONY":[{"def":"The concurrence of events in time; synchronism.","pos":""}],"SYNCHYSIS":[{"def":"A derangement or confusion of any kind, as of words in a sentence, or of humors in the eye.","pos":""}],"SYNCLASTIC":[{"def":"Curved toward the same side in all directions; -- said of surfaces which in all directions around any point bend away from a tangent plane toward the same side, as the surface of a sphere; -- opposed to anticlastic.","pos":""}],"SYNCLINAL":[{"def":"Formed by strata dipping toward a common line or plane; as, a synclinal trough or valley; a synclinal fold; -- opposed to anticlinal.","pos":""}],"SYNCLINE":[{"def":"A synclinal fold.","pos":""}],"SYNCLINORIUM":[{"def":"A mountain range owing its origin to the progress of a geosynclinal, and ending in a catastrophe of displacement and upturning.","pos":""}],"SYNCOPAL":[{"def":"Of or pertaining to syncope; resembling syncope.","pos":""}],"SYNCOPATE":[{"def":"To contract, as a word, by taking one or more letters or syllables from the middle; as, \"Gloster\" is a syncopated form of \"Gloucester.","pos":""},{"def":"To commence, as a tone, on an unaccented part of a measure, and continue it into the following accented part, so that the accent is driven back upon the weak part and the rhythm drags.","pos":""}],"SYNCOPATION":[{"def":"The act of syncopating; the contraction of a word by taking one or more letters or syllables from the middle; syncope.","pos":""},{"def":"The act of syncopating; a peculiar figure of rhythm, or rhythmical alteration, which consists in welding into one tone the second half of one beat with the first half of the beat which follows.","pos":""}],"SYNCOPE":[{"def":"An elision or retrenchment of one or more letters or syllables from the middle of a word; as, ne'er for never, ev'ry for every.","pos":""},{"def":"Same as Syncopation.","pos":""}],"SYNCOPIST":[{"def":"One who syncopates.","pos":""}],"SYNCOTYLEDONOUS":[{"def":"Having united cotyledonous.","pos":""}],"SYNCRETIC":[{"def":"Uniting and blending together different systems, as of philosophy, morals, or religion.","pos":""}],"SYNCRETISM":[{"def":"Attempted union of principles or parties irreconcilably at variance with each other.","pos":""}],"SYNCRETIST":[{"def":"One who attempts to unite principles or parties which are irreconcilably at variance; specifically (Eccl.","pos":""},{"def":"an adherent of George Calixtus and other Germans of the seventeenth century, who sought to unite or reconcile the Protestant sects with each other and with the Roman Catholics, and thus occasioned a long and violent controversy in the Lutheran church.","pos":""}],"SYNCRETISTIC":[{"def":"Pertaining to, or characterized by, syncretism; as, a syncretistic mixture of the service of Jehovah and the worship of idols.","pos":""},{"def":"Of or pertaining to Syncretists.","pos":""}],"SYNCRISIS":[{"def":"A figure of speech in which opposite things or persons are compared.","pos":""}],"SYNCYTIUM":[{"def":"Tissue in which the cell or partition walls are wholly wanting and the cell bodies fused together, so that the tissue consists of a continuous mass of protoplasm in which nuclei are imbedded, as in ordinary striped muscle.","pos":""},{"def":"The ectoderm of a sponge.","pos":""}]}