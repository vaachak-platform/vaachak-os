{"PLECTOGNATH":[{"def":"Of or pertaining to the Plectognathi.","pos":""},{"def":"One of the Plectognathi.","pos":""}],"PLECTOGNATHI":[{"def":"An order of fishes generally having the maxillary bone united with the premaxillary, and the articular united with the dentary.","pos":""},{"def":"Of or pertaining to the Plectognathi.","pos":""}],"PLECTOSPONDYLI":[{"def":"An extensive suborder of fresh-water physostomous fishes having the anterior vertebræ united and much modified; the Eventognathi.","pos":""}],"PLECTOSPONDYLOUS":[{"def":"Of or pertaining to the Plectospondyli.","pos":""}],"PLECTRUM":[{"def":"A small instrument of ivory, wood, metal, or quill, used in playing upon the lyre and other stringed instruments.","pos":""}]}