{"APPEACH":[{"def":"To impeach; to accuse; to asperse; to inform against; to reproach.","pos":""}],"APPEAL":[{"def":"To summon; to challenge.","pos":""}],"APPEALABLE":[{"def":"Capable of being appealed against; that may be removed to a higher tribunal for decision; as, the cause is appealable.","pos":""},{"def":"That may be accused or called to answer by appeal; as, a criminal is appealable for manslaughter.","pos":""}],"APPEALER":[{"def":"One who makes an appeal.","pos":""}],"APPEALING":[{"def":"That appeals; imploring.","pos":""}],"APPEAR":[{"def":"To come or be in sight; to be in view; to become visible.","pos":""},{"def":"To come before the public; as, a great writer appeared at that time.","pos":""}],"APPEARANCE":[{"def":"The act of appearing or coming into sight; the act of becoming visible to the eye; as, his sudden appearance surprised me.","pos":""},{"def":"A thing seed; a phenomenon; a phase; an apparition; as, an appearance in the sky.","pos":""}],"APPEARER":[{"def":"One who appears.","pos":""}],"APPEASABLE":[{"def":"Capable of being appeased or pacified; placable.","pos":""}],"APPEASE":[{"def":"To make quiet; to calm; to reduce to a state of peace; to still; to pacify; to dispel (anger or hatred); as, to appease the tumult of the ocean, or of the passions; to appease hunger or thirst.","pos":""}],"APPEASEMENT":[{"def":"The act of appeasing, or the state of being appeased; pacification.","pos":""}],"APPEASER":[{"def":"One who appeases; a pacifier.","pos":""}],"APPEASIVE":[{"def":"Tending to appease.","pos":""}],"APPEL":[{"def":"A tap or stamp of the foot as a warning of intent to attack; -- called also attack.","pos":""}],"APPELLANCY":[{"def":"Capability of appeal.","pos":""}],"APPELLANT":[{"def":"Relating to an appeal; appellate.","pos":""}],"APPELLATE":[{"def":"Pertaining to, or taking cognizance of, appeals.","pos":""}],"APPELLATION":[{"def":"The act of appealing; appeal.","pos":""},{"def":"The act of calling by a name.","pos":""}],"APPELLATIVE":[{"def":"Common, as opposed to proper; denominative of a class.","pos":""}],"APPELLATIVELY":[{"def":"After the manner of nouns appellative; in a manner to express whole classes or species; as, Hercules is sometimes used appellatively, that is, as a common name, to signify a strong man.","pos":""}],"APPELLATIVENESS":[{"def":"The quality of being appellative.","pos":""}],"APPELLATORY":[{"def":"Containing an appeal.","pos":""}],"APPELLOR":[{"def":"Note: This word is rarely or never used for the plaintiff in appeal from a lower court, who is called the appellant.","pos":""}],"APPEND":[{"def":"To hang or attach to, as by a string, so that the thing is suspended; as, a seal appended to a record; the inscription was appended to the column.","pos":""},{"def":"To add, as an accessory to the principal thing; to annex; as, notes appended to this chapter.","pos":""}],"APPENDAGE":[{"def":"A subordinate or subsidiary part or organ; an external organ or limb, esp.","pos":""}],"APPENDAGED":[{"def":"Furnished with, or supplemented by, an appendage.","pos":""}],"APPENDANCE":[{"def":"Something appendant.","pos":""}],"APPENDANT":[{"def":"Appended by prescription, that is, a personal usage for a considerable time; -- said of a thing of inheritance belonging to another inheritance which is superior or more worthy; as, an advowson, common, etc.","pos":""}],"APPENDICAL":[{"def":"Of or like an appendix.","pos":""}],"APPENDICITIS":[{"def":"Inflammation of the vermiform appendix.","pos":""}],"APPENDICLE":[{"def":"A small appendage.","pos":""}],"APPENDICULAR":[{"def":"Relating to an appendicle; appendiculate.","pos":""}],"APPENDICULARIA":[{"def":"A genus of small free-swimming Tunicata, shaped somewhat like a tadpole, and remarkable for resemblances to the larvæ of other Tunicata.","pos":""}],"APPENDICULATA":[{"def":"An order of annelids; the Polychæta.","pos":""}],"APPENDICULATE":[{"def":"Having small appendages; forming an appendage.","pos":""}],"APPENDIX":[{"def":"Something appended or added; an appendage, adjunct, or concomitant.","pos":""},{"def":"Any literary matter added to a book, but not necessarily essential to its completeness, and thus distinguished from supplement, which is intended to supply deficiencies and correct inaccuracies.","pos":""}],"APPENDIX VERMIFORMIS":[{"def":"The vermiform appendix.","pos":""}],"APPENSION":[{"def":"The act of appending.","pos":""}],"APPERCEIVE":[{"def":"To perceive; to comprehend.","pos":""}],"APPERCEPTION":[{"def":"The mind's perception of itself as the subject or actor in its own states; perception that reflects upon itself; sometimes, intensified or energetic perception.","pos":""}],"APPERTAIN":[{"def":"To belong or pertain, whether by right, nature, appointment, or custom; to relate.","pos":""}],"APPERTAINMENT":[{"def":"That which appertains to a person; an appurtenance.","pos":""},{"def":"See Appurtenance.","pos":""}],"APPERTINENT":[{"def":"Belonging; appertaining.","pos":""}],"APPETE":[{"def":"To seek for; to desire.","pos":""}],"APPETENCE":[{"def":"A longing; a desire; especially an ardent desire; appetite; appetency.","pos":""}],"APPETENCY":[{"def":"Fixed and strong desire; esp.","pos":""},{"def":"Specifically: An instinctive inclination or propensity in animals to perform certain actions, as in the young to suck, in aquatic fowls to enter into water and to swim; the tendency of an organized body to seek what satisfies the wants of its organism.","pos":""}],"APPETENT":[{"def":"Desiring; eagerly desirous.","pos":""}],"APPETIBILITY":[{"def":"The quality of being desirable.","pos":""}],"APPETIBLE":[{"def":"Desirable; capable or worthy of being the object of desire.","pos":""}],"APPETITE":[{"def":"The desire for some personal gratification, either of the body or of the mind.","pos":""},{"def":"Desire for, or relish of, food or drink; hunger.","pos":""}],"APPETITION":[{"def":"Desire; a longing for, or seeking after, something.","pos":""}],"APPETITIVE":[{"def":"Having the quality of desiring gratification; as, appetitive power or faculty.","pos":""}],"APPETIZE":[{"def":"To make hungry; to whet the appetite of.","pos":""}],"APPETIZER":[{"def":"Something which creates or whets an appetite.","pos":""}],"APPETIZING":[{"def":"Exciting appetite; as, appetizing food.","pos":""}]}