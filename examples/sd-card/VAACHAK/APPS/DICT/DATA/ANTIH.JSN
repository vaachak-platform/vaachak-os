{"ANTIHELIX":[{"def":"The curved elevation of the cartilage of the ear, within or in front of the helix.","pos":""}],"ANTIHEMORRHAGIC":[{"def":"Tending to stop hemorrhage.","pos":""},{"def":"A remedy for hemorrhage.","pos":""}],"ANTIHYDROPHOBIC":[{"def":"Counteracting or preventing hydrophobia.","pos":""},{"def":"A remedy for hydrophobia.","pos":""}],"ANTIHYDROPIC":[{"def":"Good against dropsy.","pos":""},{"def":"A remedy for dropsy.","pos":""}],"ANTIHYPNOTIC":[{"def":"Tending to prevent sleep.","pos":""},{"def":"An antihypnotic agent.","pos":""}],"ANTIHYPOCHONDRIAC":[{"def":"Counteractive of hypochondria.","pos":""},{"def":"A remedy for hypochondria.","pos":""}],"ANTIHYSTERIC":[{"def":"Counteracting hysteria.","pos":""},{"def":"A remedy for hysteria.","pos":""}]}