{"SCRIBABLE":[{"def":"Capable of being written, or of being written upon.","pos":""}],"SCRIBATIOUS":[{"def":"Skillful in, or fond of, writing.","pos":""}],"SCRIBBET":[{"def":"A painter's pencil.","pos":""}],"SCRIBBLE":[{"def":"To card coarsely; to run through the scribling machine.","pos":""}],"SCRIBBLER":[{"def":"One who scribles; a literary hack.","pos":""}],"SCRIBBLING":[{"def":"The act or process of carding coarsely.","pos":""}],"SCRIBBLINGLY":[{"def":"In a scribbling manner.","pos":""}],"SCRIBE":[{"def":"A writer and doctor of the law; one skilled in the law and traditions; one who read and explained the law to the people.","pos":""}],"SCRIBER":[{"def":"A sharp-pointed tool, used by joiners for drawing lines on stuff; a marking awl.","pos":""}],"SCRIBISM":[{"def":"The character and opinions of a Jewish scribe in the time of Christ.","pos":""}],"SCRID":[{"def":"A screed; a shred; a fragment.","pos":""}],"SCRIM":[{"def":"Thin canvas glued on the inside of panels to prevent shrinking, checking, etc.","pos":""}],"SCRIMER":[{"def":"A fencing master.","pos":""}],"SCRIMMAGE":[{"def":"The struggle in the rush lines after the ball is put in play.","pos":""}],"SCRIMP":[{"def":"To make too small or short; to limit or straiten; to put on short allowance; to scant; to contract; to shorten; as, to scrimp the pattern of a coat.","pos":""}],"SCRIMPING":[{"def":"Scrimp\"ing, Defn: a.","pos":""}],"SCRIMPINGLY":[{"def":"In a scrimping manner.","pos":""}],"SCRIMPNESS":[{"def":"The state of being scrimp.","pos":""}],"SCRIMPTION":[{"def":"A small portion; a pittance; a little bit.","pos":""}],"SCRIMSHAW":[{"def":"To ornament, as shells, ivory, etc.","pos":""}],"SCRINE":[{"def":"A chest, bookcase, or other place, where writings or curiosities are deposited; a shrine.","pos":""}],"SCRIP":[{"def":"A small bag; a wallet; a satchel.","pos":""}],"SCRIPPAGE":[{"def":"The contents of a scrip, or wallet.","pos":""}],"SCRIPT":[{"def":"Type made in imitation of handwriting.","pos":""},{"def":"An original instrument or document.","pos":""}],"SCRIPTORIUM":[{"def":"In an abbey or monastery, the room set apart for writing or copying manuscripts; in general, a room devoted to writing.","pos":""}],"SCRIPTORY":[{"def":"Of or pertaining to writing; expressed in writing; used in writing; as, scriptory wills; a scriptory reed.","pos":""}],"SCRIPTURAL":[{"def":"Contained in the Scriptures; according to the Scriptures, or sacred oracles; biblical; as, a scriptural doctrine.","pos":""}],"SCRIPTURALISM":[{"def":"The quality or state of being scriptural; literal adherence to the Scriptures.","pos":""}],"SCRIPTURALIST":[{"def":"One who adheres literally to the Scriptures.","pos":""}],"SCRIPTURALLY":[{"def":"In a scriptural manner.","pos":""}],"SCRIPTURALNESS":[{"def":"Quality of being scriptural.","pos":""}],"SCRIPTURE":[{"def":"Anything written; a writing; a document; an inscription.","pos":""},{"def":"The books of the Old and the new Testament, or of either of them; the Bible; -- used by way of eminence or distinction, and chiefly in the plural.","pos":""}],"SCRIPTURIST":[{"def":"One who is strongly attached to, or versed in, the Scriptures, or who endeavors to regulate his life by them.","pos":""}],"SCRIT":[{"def":"Writing; document; scroll.","pos":""}],"SCRITCH":[{"def":"Perhaps it is the owlet's scritch.","pos":""}],"SCRIVENER":[{"def":"A professional writer; one whose occupation is to draw contracts or prepare writings.","pos":""},{"def":"One whose business is to place money at interest; a broker.","pos":""}]}