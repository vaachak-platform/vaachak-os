{"SEMI CIRCUMFERENCE":[{"def":"Half of a circumference.","pos":""}],"SEMI CRUSTACEOUS":[{"def":"Half crustaceous; partially crustaceous.","pos":""}],"SEMI PUPA":[{"def":"The young of an insect in a stage between the larva and pupa.","pos":""},{"def":"An aspect of the planets when distant from each other the half of a quadrant, or forty-five degrees, or one sign and a half.","pos":""}],"SEMI-":[{"def":"A prefix signifying half, and sometimes partly or imperfectly; as, semiannual, half yearly; semitransparent, imperfectly transparent.","pos":""}],"SEMI-ARIAN":[{"def":"A member of a branch of the Arians which did not acknowledge the Son to be consubstantial with the Father, that is, of the same substance, but admitted him to be of a like substance with the Father, not by nature, but by a peculiar privilege.","pos":""}],"SEMI-ARIANISM":[{"def":"The doctrines or tenets of the Semi-Arians.","pos":""}],"SEMI-CHRISTIANIZED":[{"def":"Half Christianized.","pos":""}],"SEMI-DIESEL":[{"def":"Designating an internal-combustion engine of a type resembling the Diesel engine in using as fuel heavy oil which is injected in a spray just before the end of the compression stroke and is fired without electrical ignition.","pos":""}],"SEMI-PELAGIAN":[{"def":"Of or pertaining to the Semi-Pelagians, or their tenets.","pos":""}],"SEMI-PELAGIANISM":[{"def":"The doctrines or tenets of the Semi-Pelagians.","pos":""}],"SEMI-SAXON":[{"def":"Half Saxon; -- specifically applied to the language intermediate between Saxon and English, belonging to the period 1150- 1250.","pos":""}]}