{"OVERSATURATE":[{"def":"To saturate to excess.","pos":""}],"OVERSAY":[{"def":"To say over; to repeat.","pos":""}],"OVERSCENTED":[{"def":"Scented excessively.","pos":""},{"def":"Covered or concealed by a different odor.","pos":""}],"OVERSCRUPULOSITY":[{"def":"Overscrupulousness.","pos":""}],"OVERSCRUPULOUS":[{"def":"Scrupulous to excess.","pos":""}],"OVERSCRUPULOUSNESS":[{"def":"The quality or state of being overscrupulous; excess of scrupulousness.","pos":""}],"OVERSEA":[{"def":"Beyond the sea; foreign.","pos":""},{"def":"Over the sea; abroad.","pos":""}],"OVERSEARCH":[{"def":"To search all over.","pos":""}],"OVERSEASON":[{"def":"To season too highly.","pos":""}],"OVERSEE":[{"def":"To superintend; to watch over; to direct; to look or see after; to overlook.","pos":""},{"def":"To omit or neglect seeing.","pos":""}],"OVERSEER":[{"def":"One who oversees; a superintendent; a supervisor; as, an overseer of a mill; specifically, one or certain public officers; as, an overseer of the poor; an overseer of highways.","pos":""}],"OVERSEERSHIP":[{"def":"The office of an overseer.","pos":""}],"OVERSELL":[{"def":"To sell for a higher price than; to exceed in selling price.","pos":""},{"def":"To sell beyond means of delivery.","pos":""}],"OVERSET":[{"def":"To turn or tip (anything) over from an upright, or a proper, position so that it lies upon its side or bottom upwards; to upset; as, to overset a chair, a coach, a ship, or a building.","pos":""},{"def":"To cause to fall, or to tail; to subvert; to overthrow; as, to overset a government or a plot.","pos":""}],"OVERSHADE":[{"def":"To cover with shade; to render dark or gloomy; to overshadow.","pos":""}],"OVERSHADOW":[{"def":"To throw a shadow, or shade, over; to darken; to obscure.","pos":""}],"OVERSHADOWER":[{"def":"One that throws a shade, or shadow, over anything.","pos":""}],"OVERSHAKE":[{"def":"To shake over or away; to drive away; to disperse.","pos":""}],"OVERSHINE":[{"def":"To shine over or upon; to illumine.","pos":""},{"def":"To excel in shining; to outshine.","pos":""}],"OVERSHOE":[{"def":"A shoe that is worn over another for protection from wet or for extra warmth; esp.","pos":""}],"OVERSHOOT":[{"def":"To shoot over or beyond.","pos":""},{"def":"To pass swiftly over; to fly beyond.","pos":""}],"OVERSHOT":[{"def":"From Overshoot, v.","pos":""}],"OVERSIGHT":[{"def":"Watchful care; superintendence; general supervision.","pos":""},{"def":"An overlooking; an omission; an error.","pos":""}],"OVERSIZE":[{"def":"To surpass in size.","pos":""}],"OVERSKIP":[{"def":"To skip or leap over; to treat with indifference.","pos":""}],"OVERSKIRT":[{"def":"An upper skirt, shorter than the dress, and usually draped.","pos":""}],"OVERSLAUGH":[{"def":"A bar in a river; as, the overslaugh in the Hudson River.","pos":""}],"OVERSLEEP":[{"def":"To sleep beyond; as, to oversleep one's self or one's usual hour of rising.","pos":""}],"OVERSLIDE":[{"def":"To slide over or by.","pos":""}],"OVERSLIP":[{"def":"To slip or slide over; to pass easily or carelessly beyond; to omit; to neglect; as, to overslip time or opportunity.","pos":""}],"OVERSLOP":[{"def":"An outer garment, or slop.","pos":""}],"OVERSLOW":[{"def":"To render slow; to check; to curb.","pos":""}],"OVERSMAN":[{"def":"An umpire; a third arbiter, appointed when two arbiters, previously selected, disagree.","pos":""}],"OVERSNOW":[{"def":"To cover with snow, or as with snow.","pos":""}],"OVERSORROW":[{"def":"To grieve or afflict to excess.","pos":""}],"OVERSOUL":[{"def":"The all-containing soul.","pos":""}],"OVERSOW":[{"def":"To sow where something has already been sown.","pos":""}],"OVERSPAN":[{"def":"To reach or extend over.","pos":""}],"OVERSPEAK":[{"def":"To exceed in speaking; to speak too much; to use too many words.","pos":""}],"OVERSPIN":[{"def":"To spin out to too great length; to protract unduly.","pos":""}],"OVERSPREAD":[{"def":"To spread over; to cover; as, the deluge overspread the earth.","pos":""}],"OVERSPRING":[{"def":"To spring or leap over.","pos":""}],"OVERSTAND":[{"def":"To stand on the price or conditions of, so as to lose a sale; to lose by an extravagant price or hard conditions.","pos":""}],"OVERSTARE":[{"def":"To stare wildly.","pos":""}],"OVERSTATE":[{"def":"To state in too strong terms; to exaggerate.","pos":""}],"OVERSTATEMENT":[{"def":"An exaggerated statement or account.","pos":""}],"OVERSTAY":[{"def":"To stay beyond the time or the limits of; as, to overstay the appointed time.","pos":""}],"OVERSTEP":[{"def":"To step over or beyond; to transgress.","pos":""}],"OVERSTOCK":[{"def":"Stock in excess.","pos":""}],"OVERSTRAIN":[{"def":"To strain one's self to excess.","pos":""}],"OVERSTRAITLY":[{"def":"Too straitly or strictly.","pos":""}],"OVERSTREW":[{"def":"To strew or scatter over.","pos":""}],"OVERSTRICT":[{"def":"Excessively strict.","pos":""}],"OVERSTRIDE":[{"def":"To stride over or beyond.","pos":""}],"OVERSTRIKE":[{"def":"To strike beyond.","pos":""}],"OVERSUBTILE":[{"def":"Excessively subtile.","pos":""}],"OVERSUM":[{"def":"A sum or quantity over; surplus.","pos":""}],"OVERSUPPLY":[{"def":"To supply in excess.","pos":""}],"OVERSURE":[{"def":"Excessively sure.","pos":""}],"OVERSWAY":[{"def":"To bear sway over.","pos":""}],"OVERSWELL":[{"def":"To swell or rise above; to overflow.","pos":""}]}