{"TASCO":[{"def":"A kind of clay for making melting pots.","pos":""}],"TASIMER":[{"def":"An instrument for detecting or measuring minute extension or movements of solid bodies.","pos":""}],"TASK":[{"def":"Labor or study imposed by another, often in a definite quantity or amount.","pos":""},{"def":"Business; employment; undertaking; labor.","pos":""}],"TASK WAGE":[{"def":"A wage paid by the day, or some fixed period, on condition that a minimum task be performed.","pos":""}],"TASKER":[{"def":"One who imposes a task.","pos":""},{"def":"One who performs a task, as a day-laborer.","pos":""}],"TASKMASTER":[{"def":"One who imposes a task, or burdens another with labor; one whose duty is to assign tasks; an overseer.","pos":""}],"TASKWORK":[{"def":"Work done as a task; also, work done by the job; piecework.","pos":""}],"TASLET":[{"def":"A piece of armor formerly worn to guard the things; a tasse.","pos":""}],"TASMANIAN":[{"def":"Of or pertaining to Tasmania, or Van Diemen's Land.","pos":""}],"TASSE":[{"def":"A piece of armor for the thighs, forming an appendage to the ancient corselet.","pos":""}],"TASSEL":[{"def":"A kind of bur used in dressing cloth; a teasel.","pos":""}],"TASSET":[{"def":"A defense for the front of the thigh, consisting of one or more iron plates hanging from the belt on the lower edge of the corselet.","pos":""}],"TASTABLE":[{"def":"Capable of worthy of being tasted; savory; relishing.","pos":""}],"TASTE":[{"def":"To try by the touch; to handle; as, to taste a bow.","pos":""},{"def":"To try by the touch of the tongue; to perceive the relish or flavor of (anything) by taking a small quantity into a mouth.","pos":""}],"TASTEFUL":[{"def":"Having a high relish; savory.","pos":""},{"def":"Having or exhibiting good taste; in accordance with good taste; tasty; as, a tasteful drapery.","pos":""}],"TASTELESS":[{"def":"Having no taste; insipid; flat; as, tasteless fruit.","pos":""},{"def":"Destitute of the sense of taste; or of good taste; as, a tasteless age.","pos":""}],"TASTER":[{"def":"One of a peculiar kind of zooids situated on the polyp-stem of certain Siphonophora.","pos":""}],"TASTILY":[{"def":"In a tasty manner.","pos":""}],"TASTING":[{"def":"The act of perceiving or tasting by the organs of taste; the faculty or sense by which we perceive or distinguish savors.","pos":""}],"TASTO":[{"def":"A key or thing touched to produce a tone.","pos":""}],"TASTY":[{"def":"Having a good taste; -- applied to persons; as, a tasty woman.","pos":""},{"def":"Being in conformity to the principles of good taste; elegant; as, tasty furniture; a tasty dress.","pos":""}]}