{"ENVASSAL":[{"def":"To make a vassal of.","pos":""}],"ENVAULT":[{"def":"To inclose in a vault; to entomb.","pos":""}],"ENVELOP":[{"def":"To put a covering about; to wrap up or in; to inclose within a case, wrapper, integument or the like; to surround entirely; as, to envelop goods or a letter; the fog envelops a ship.","pos":""},{"def":"The nebulous covering of the head or nucleus of a comet; -- called also coma.","pos":""}],"ENVELOPMENT":[{"def":"The act of enveloping or wrapping; an inclosing or covering on all sides.","pos":""},{"def":"That which envelops or surrounds; an envelop.","pos":""}],"ENVENOM":[{"def":"To taint or impregnate with venom, or any substance noxious to life; to poison; to render dangerous or deadly by poison, as food, drink, a weapon; as, envenomed meat, wine, or arrow; also, to poison (a person) by impregnating with venom.","pos":""},{"def":"To taint or impregnate with bitterness, malice, or hatred; to imbue as with venom; to imbitter.","pos":""}],"ENVERMEIL":[{"def":"To color with, or as with, vermilion; to dye red.","pos":""}],"ENVIABLE":[{"def":"Fitted to excite envy; capable of awakening an ardent desire to posses or to resemble.","pos":""}],"ENVIE":[{"def":"To vie; to emulate; to strive.","pos":""}],"ENVIER":[{"def":"One who envies; one who desires inordinately what another possesses.","pos":""}],"ENVIOUS":[{"def":"Malignant; mischievous; spiteful.","pos":""},{"def":"Feeling or exhibiting envy; actuated or directed by, or proceeding from, envy; -- said of a person, disposition, feeling, act, etc.","pos":""}],"ENVIRON":[{"def":"To surround; to encompass; to encircle; to hem in; to be round about; to involve or envelop.","pos":""}],"ENVIRONMENT":[{"def":"Act of environing; state of being environed.","pos":""},{"def":"That which environs or surrounds; surrounding conditions, influences, or forces, by which living forms are influenced and modified in their growth and development.","pos":""}],"ENVIRONS":[{"def":"The parts or places which surround another place, or lie in its neighborhood; suburbs; as, the environs of a city or town.","pos":""}],"ENVISAGE":[{"def":"To look in the face of; to apprehend; to regard.","pos":""}],"ENVISAGEMENT":[{"def":"The act of envisaging.","pos":""}],"ENVOLUME":[{"def":"To form into, or incorporate with, a volume.","pos":""}],"ENVOLUP":[{"def":"To wrap up; to envelop.","pos":""}],"ENVOY":[{"def":"An explanatory or commendatory postscript to a poem, essay, or book; -- also in the French from, l'envoi.","pos":""}],"ENVOYSHIP":[{"def":"The office or position of an envoy.","pos":""}],"ENVY":[{"def":"Malice; ill will; spite.","pos":""},{"def":"Chagrin, mortification, discontent, or uneasiness at the sight of another's excellence or good fortune, accompanied with some degree of hatred and a desire to possess equal advantages; malicious grudging; -- usually followed by of; as, they did this in envy of Cæsar.","pos":""}],"ENVYNED":[{"def":"Stored or furnished with wine.","pos":""}]}