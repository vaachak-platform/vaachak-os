{"PERN":[{"def":"To take profit of; to make profitable.","pos":""}],"PERNANCY":[{"def":"A taking or reception, as the receiving of rents or tithes in kind, the receiving of profits.","pos":""}],"PERNICION":[{"def":"Destruction; perdition.","pos":""}],"PERNICIOUS":[{"def":"Quick; swift (to burn).","pos":""}],"PERNICITY":[{"def":"Swiftness; celerity.","pos":""}],"PERNICKETY PERNICKETTY":[{"def":"Finical or fussy; full of petty details.","pos":""}],"PERNOCTALIAN":[{"def":"One who watches or keeps awake all night.","pos":""}],"PERNOCTATION":[{"def":"The act or state of passing the whole night; a remaining all night.","pos":""}],"PERNOR":[{"def":"One who receives the profits, as of an estate.","pos":""}],"PERNOT FURNACE":[{"def":"A reverberatory furnace with a circular revolving hearth, -- used in making steel.","pos":""}],"PERNYI MOTH":[{"def":"A silk-producing moth (Attacus Pernyi) which feeds upon the oak.","pos":""}]}