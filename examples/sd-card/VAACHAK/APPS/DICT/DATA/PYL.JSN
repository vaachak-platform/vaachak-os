{"PYLA":[{"def":"The passage between the iter and optocoele in the brain.","pos":""}],"PYLAGORE":[{"def":"a deputy of a State at the Amphictyonic council.","pos":""}],"PYLANGIUM":[{"def":"The first and undivided part of the aortic trunk in the amphibian heart.","pos":""}],"PYLON":[{"def":"Massive pylons adorned with obelisks in front.","pos":""}],"PYLORIC":[{"def":"Of, pertaining to, or in the region of, the pylorus; as, the pyloric end of the stomach.","pos":""}]}