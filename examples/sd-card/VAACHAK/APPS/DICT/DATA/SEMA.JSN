{"SEMAEOSTOMATA":[{"def":"A division of Discophora having large free mouth lobes.","pos":""}],"SEMAPHORE":[{"def":"A signal telegraph; an apparatus for giving signals by the disposition of lanterns, flags, oscillating arms, etc.","pos":""},{"def":"Of or pertaining to a semaphore, or semaphores; telegraphic.","pos":""}],"SEMAPHORICALLY":[{"def":"By means a semaphore.","pos":""}],"SEMAPHORIST":[{"def":"One who manages or operates a semaphore.","pos":""}],"SEMASIOLOGY":[{"def":"The science of meanings or sense development (of words); the explanation of the development and changes of the meanings of words.","pos":""}],"SEMATIC":[{"def":"Significant; ominous; serving as a warning of danger; --applied esp.","pos":""}],"SEMATOLOGY":[{"def":"The doctrine of signs as the expression of thought or reasoning; the science of indicating thought by signs.","pos":""}],"SEMATROPE":[{"def":"An instrument for signaling by reflecting the rays of the sun in different directions.","pos":""}]}