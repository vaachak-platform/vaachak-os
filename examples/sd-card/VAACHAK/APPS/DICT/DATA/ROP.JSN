{"ROPE":[{"def":"The small intestines; as, the ropes of birds.","pos":""}],"ROPE'S-END":[{"def":"To punish with a rope's end.","pos":""}],"ROPE-YARN":[{"def":"the yarn or thread of any stuff of which the strands of a rope are made.","pos":""}],"ROPEBAND":[{"def":"A small piece of spun yarn or marline, used to fasten the head of the sail to the spar.","pos":""}],"ROPEDANCER":[{"def":"One who dances, walks, or performs acrobatic feats, on a rope extended through the air at some height.","pos":""}],"ROPER":[{"def":"A maker of ropes.","pos":""},{"def":"One who ropes goods; a packer.","pos":""}],"ROPERY":[{"def":"A place where ropes are made.","pos":""},{"def":"Tricks deserving the halter; roguery.","pos":""}],"ROPEWALK":[{"def":"A long, covered walk, or a low, level building, where ropes are manufactured.","pos":""}],"ROPILY":[{"def":"In a ropy manner; in a viscous or glutinous manner.","pos":""}],"ROPINESS":[{"def":"Quality of being ropy; viscosity.","pos":""}],"ROPY":[{"def":"capable of being drawn into a thread, as a glutinous substance; stringy; viscous; tenacious; glutinous; as ropy sirup; ropy lees.","pos":""}]}