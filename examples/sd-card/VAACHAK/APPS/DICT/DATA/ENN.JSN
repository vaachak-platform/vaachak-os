{"ENNATION":[{"def":"The ninth segment in insects.","pos":""}],"ENNEAD":[{"def":"The number nine or a group of nine.","pos":""}],"ENNEAGON":[{"def":"A polygon or plane figure with nine sides and nine angles; a nonagon.","pos":""}],"ENNEAGONAL":[{"def":"Belonging to an enneagon; having nine angles.","pos":""}],"ENNEAGYNOUS":[{"def":"Having or producing nine pistils or styles; -- said of a flower or plant.","pos":""}],"ENNEAHEDRAL":[{"def":"Having nine sides.","pos":""},{"def":"A figure having nine sides; a nonagon.","pos":""}],"ENNEANDRIA":[{"def":"A Linnæan class of plants having nine stamens.","pos":""},{"def":"Having nine stamens.","pos":""}],"ENNEAPETALOUS":[{"def":"Having nine petals, or flower leaves.","pos":""}],"ENNEASPERMOUS":[{"def":"Having nine seeds; -- said of fruits.","pos":""},{"def":"Occurring once in every nine times, days, years, etc.","pos":""}],"ENNICHE":[{"def":"To place in a niche.","pos":""}],"ENNOBLE":[{"def":"To make noble; to elevate in degree, qualities, or excellence; to dignify.","pos":""},{"def":"To raise to the rank of nobility; as, to ennoble a commoner.","pos":""}],"ENNOBLEMENT":[{"def":"The act of making noble, or of exalting, dignifying, or advancing to nobility.","pos":""},{"def":"That which ennobles; excellence; dignity.","pos":""}],"ENNOBLER":[{"def":"One who ennobles.","pos":""}],"ENNUI":[{"def":"A feeling of weariness and disgust; dullness and languor of spirits, arising from satiety or want of interest; tedium.","pos":""}],"ENNUYE":[{"def":"Affected with ennui; weary in spirits; emotionally exhausted.","pos":""}],"ENNUYEE":[{"def":"A woman affected with ennui.","pos":""}]}