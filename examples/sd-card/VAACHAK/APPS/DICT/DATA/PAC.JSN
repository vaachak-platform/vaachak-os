{"PAC":[{"def":"A kind of moccasin, having the edges of the sole turned up and sewed to the upper.","pos":""}],"PACA":[{"def":"A small South American rodent (Cologenys paca), having blackish brown fur, with four parallel rows of white spots along its sides; the spotted cavy.","pos":""}],"PACANE":[{"def":"A species of hickory.","pos":""}],"PACATE":[{"def":"Appeased; pacified; tranquil.","pos":""}],"PACATED":[{"def":"Pacified; pacate.","pos":""}],"PACATION":[{"def":"The act of pacifying; a peacemaking.","pos":""}],"PACER":[{"def":"One who, or that which, paces; especially, a horse that paces.","pos":""}],"PACHACAMAC":[{"def":"A divinity worshiped by the ancient Peruvians as the creator of the universe.","pos":""}],"PACHAK":[{"def":"The fragrant roots of the Saussurea Costus, exported from India to China, and used for burning as incense.","pos":""}],"PACHALIC":[{"def":"A game adopted from the Indian game, using disks, as of pasteboard, and dice.","pos":""}],"PACHOMETER":[{"def":"An instrument for measuring thickness, as of the glass of a mirror, or of paper; a pachymeter.","pos":""}],"PACHONTA":[{"def":"A substance resembling gutta-percha, and used to adulterate it, obtained from the East Indian tree Isonandra acuminata.","pos":""}],"PACHUCA TANK":[{"def":"Zealand, it was first practically introduced in Pachuca, Mexico.","pos":""}],"PACHY-":[{"def":"A combining form meaning thick; as, pachyderm, pachydactyl.","pos":""}],"PACHYCARPOUS":[{"def":"Having the pericarp thick.","pos":""}],"PACHYDACTYL":[{"def":"A bird or other animal having thick toes.","pos":""}],"PACHYDACTYLOUS":[{"def":"Having thick toes.","pos":""}],"PACHYDERM":[{"def":"One of the Pachydermata.","pos":""}],"PACHYDERMAL":[{"def":"Of or relating to the pachyderms; as, pachydermal dentition.","pos":""}],"PACHYDERMATA":[{"def":"A group of hoofed mammals distinguished for the thickness of their skins, including the elephant, hippopotamus, rhinoceros, tapir, horse, and hog.","pos":""}],"PACHYDERMATOUS":[{"def":"Thick-skinned; not sensitive to ridicule.","pos":""}],"PACHYDERMOID":[{"def":"Related to the pachyderms.","pos":""}],"PACHYGLOSSAL":[{"def":"Having a thick tongue; --applied to a group of lizards (Pachyglossæ), including the iguanas and agamas.","pos":""}],"PACHYMENINGITIS":[{"def":"Inflammation of the dura mater or outer membrane of the brain.","pos":""}],"PACHYMETER":[{"def":"Same as Pachometer.","pos":""}],"PACHYOTE":[{"def":"One of a family of bats, including those which have thick external ears.","pos":""}],"PACIFIABLE":[{"def":"Capable of being pacified or appeased; placable.","pos":""}],"PACIFIC":[{"def":"Of or pertaining to peace; suited to make or restore peace; of a peaceful character; not warlike; not quarrelsome; conciliatory; as, pacific words or acts; a pacific nature or condition.","pos":""}],"PACIFICAL":[{"def":"Of or pertaining to peace; pacific.","pos":""}],"PACIFICATION":[{"def":"The act or process of pacifying, or of making peace between parties at variance; reconciliation.","pos":""}],"PACIFICATOR":[{"def":"One who, or that which, pacifies; a peacemaker.","pos":""}],"PACIFICATORY":[{"def":"Tending to make peace; conciliatory.","pos":""}],"PACIFICO":[{"def":"A peaceful person; -- applied specif.","pos":""}],"PACIFIER":[{"def":"One who pacifies.","pos":""}],"PACIFY":[{"def":"To make to be at peace; to appease; to calm; to still; to quiet; to allay the agitation, excitement, or resentment of; to tranquillize; as, to pacify a man when angry; to pacify pride, appetite, or importunity.","pos":""}],"PACINIAN":[{"def":"Of, pertaining to, or discovered by, Filippo Pacini, an Italian physician of the 19th century.","pos":""}],"PACK":[{"def":"To envelop in a wet or dry sheet, within numerous coverings.","pos":""},{"def":"To render impervious, as by filling or surrounding with suitable material, or to fit or adjust so as to move without giving passage to air, water, or steam; as, to pack a joint; to pack the piston of a steam engine.","pos":""}],"PACK HERSE":[{"def":"See under 2d Pack.","pos":""}],"PACKAGE":[{"def":"Act or process of packing.","pos":""},{"def":"A bundle made up for transportation; a packet; a bale; a parcel; as, a package of goods.","pos":""}],"PACKER":[{"def":"A person whose business is to pack things; especially, one who packs food for preservation; as, a pork packer.","pos":""}],"PACKET":[{"def":"A small pack or package; a little bundle or parcel; as, a packet of letters.","pos":""},{"def":"Originally, a vessel employed by government to convey dispatches or mails; hence, a vessel employed in conveying dispatches, mails, passengers, and goods, and having fixed days of sailing; a mail boat.","pos":""}],"PACKFONG":[{"def":"A Chinese alloy of nickel, zinc, and copper, resembling German silver.","pos":""}],"PACKHOUSE":[{"def":"Warehouse for storing goods.","pos":""}],"PACKING":[{"def":"A substance or piece used to make a joint impervious; as: (a) A thin layer, or sheet, of yielding or elastic material inserted between the surfaces of a flange joint.","pos":""},{"def":"Same as Filling.","pos":""}],"PACKMAN":[{"def":"One who bears a pack; a peddler.","pos":""},{"def":"See under 2d Pack.","pos":""}],"PACKWAY":[{"def":"A path, as over mountains, followed by pack animals.","pos":""}],"PACT":[{"def":"An agreement; a league; a compact; a covenant.","pos":""}],"PACTION":[{"def":"An agreement; a compact; a bargain.","pos":""}],"PACTIONAL":[{"def":"Of the nature of, or by means of, a paction.","pos":""}],"PACTITIOUS":[{"def":"Setted by a pact, or agreement.","pos":""}],"PACTOLIAN":[{"def":"Pertaining to the Pactolus, a river in ancient Lydia famous for its golden sands.","pos":""}],"PACU":[{"def":"A South American freah-water fish (Myleies pacu), of the family Characinidæ.","pos":""}]}