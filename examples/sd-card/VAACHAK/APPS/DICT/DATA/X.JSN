{"X-RAY TUBE":[{"def":"A vacuum tube suitable for producing Röntgen rays.","pos":""}],"XANTHAMIDE":[{"def":"An amido derivative of xanthic acid obtained as a white crystalline substance, C2H5O.","pos":""}],"XANTHATE":[{"def":"A salt of xanthic; a xanthogenate.","pos":""}],"XANTHIAN":[{"def":"Of or pertaining to Xanthus, an ancient town on Asia Minor; -- applied especially to certain marbles found near that place, and now in the British Museum.","pos":""}],"XANTHIC":[{"def":"Tending toward a yellow color, or to one of those colors, green being excepted, in which yellow is a constituent, as scarlet, orange, etc.","pos":""}],"XANTHIDE":[{"def":"A compound or derivative of xanthogen.","pos":""}],"XANTHIDIUM":[{"def":"A genus of minute unicellular algæ of the desmids.","pos":""}],"XANTHIN":[{"def":"XANTHINE; XANTHIN Xan\"thine, n.","pos":""}],"XANTHININE":[{"def":"A complex nitrogenous substance related to urea and uric acid, produced as a white powder; -- so called because it forms yellow salts, and because its solution forms a blue fluorescence like quinine.","pos":""}],"XANTHIUM":[{"def":"A genus of composite plants in which the scales of the involucre are united so as to form a kind of bur; cocklebur; clotbur.","pos":""}],"XANTHO-":[{"def":"A combining form from Gr.","pos":""}],"XANTHOCARPOUS":[{"def":"Having yellow fruit.","pos":""}],"XANTHOCHROI":[{"def":"A division of the Caucasian races, comprising the lighter- colored members.","pos":""}],"XANTHOCHROIC":[{"def":"Having a yellowish or fair complexion; of or pertaining to the Xanthochroi.","pos":""}],"XANTHOCHROID":[{"def":"Having a yellowish or fair complexion.","pos":""},{"def":"A person having xanthochroid traits.","pos":""}],"XANTHOCHROISM":[{"def":"Abnormal coloration of feathers in which yellow replaces the normal color, as in certain parrots.","pos":""}],"XANTHODONTOUS":[{"def":"Having yellow teeth.","pos":""}],"XANTHOGENATE":[{"def":"A salt of xanthic acid.","pos":""}],"XANTHOGENIC":[{"def":"Producing a yellow color or compound; xanthic.","pos":""}],"XANTHOMA":[{"def":"A skin disease marked by the development or irregular yellowish patches upon the skin, especially upon the eyelids; -- called also xanthelasma.","pos":""}],"XANTHOMATOUS":[{"def":"Of or pertaining to xanthoma.","pos":""}],"XANTHOMELANOUS":[{"def":"Of or pertaining to the lighter division of the Melanochroi, or those races having an olive or yellow complexion and black hair.","pos":""}],"XANTHOPHANE":[{"def":"The yellow pigment present in the inner segments of the retina in animals.","pos":""}],"XANTHOPHYLL":[{"def":"A yellow coloring matter found in yellow autumn leaves, and also produced artificially from chlorophyll; -- formerly called also phylloxanthin.","pos":""}],"XANTHOPOUS":[{"def":"Having a yellow stipe, or stem.","pos":""}],"XANTHOPROTEIC":[{"def":"Pertaining to, or derived from, xanthoprotein; showing the characters of xanthoprotein; as, xanthoproteic acid; the xanthoproteic reaction for albumin.","pos":""}],"XANTHOPROTEIN":[{"def":"A yellow acid substance formed by the action of hot nitric acid on albuminous or proteid matter.","pos":""}],"XANTHOPUCCINE":[{"def":"One of three alkaloids found in the root of the yellow puccoon (Hydrastis Canadensis).","pos":""}],"XANTHORHAMNIN":[{"def":"A glucoside extracted from Persian berries as a yellow crystalline powder, used as a dyestuff.","pos":""}],"XANTHORHIZA":[{"def":"A genus of shrubby ranunculaceous plants of North America, including only the species Xanthorhiza apiifolia, which has roots of a deep yellow color; yellowroot.","pos":""}],"XANTHORHOEA":[{"def":"A genus of endogenous plants, native to Australia, having a thick, sometimes arborescent, stem, and long grasslike leaves.","pos":""}],"XANTHOSE":[{"def":"An orange-yellow substance found in pigment spots of certain crabs.","pos":""}],"XANTHOSIS":[{"def":"The yellow discoloration often observed in cancerous tumors.","pos":""}],"XANTHOSPERMOUS":[{"def":"Having yellow seeds.","pos":""}],"XANTHOUS":[{"def":"Yellow; specifically (Ethnol.","pos":""}],"XANTHOXYLENE":[{"def":"A liquid hydrocarbon of the terpene series extracted from the seeds of a Japanese prickly ash (Xanthoxylum pipertium) as an aromatic oil.","pos":""}],"XANTHOXYLUM":[{"def":"A genus of prickly shrubs or small trees, the bark and rots of which are of a deep yellow color; prickly ash.","pos":""}],"XEBEC":[{"def":"A small three-masted vessel, with projecting bow stern and convex decks, used in the Mediterranean for transporting merchandise, etc.","pos":""}],"XEME":[{"def":"An Arctic fork-tailed gull (Xema Sabinii).","pos":""}],"XENELASIA":[{"def":"A Spartan institution which prohibited strangers from residing in Sparta without permission, its object probably being to preserve the national simplicity of manners.","pos":""}],"XENIUM":[{"def":"A present given to a guest or stranger, or to a foreign ambassador.","pos":""}],"XENODOCHIUM":[{"def":"A house for the reception of strangers.","pos":""}],"XENODOCHY":[{"def":"Reception of strangers; hospitality.","pos":""}],"XENOGAMY":[{"def":"Cross fertilization.","pos":""}],"XENOGENETIC":[{"def":"Of or pertaining to xenogenesis; as, the xenogenetic origin of microzymes.","pos":""}],"XENOMANIA":[{"def":"A mania for, or an inordinate attachment to, foreign customs, institutions, manners, fashions, etc.","pos":""}],"XENOMI":[{"def":"A suborder of soft-rayed fresh-water fishes of which the blackfish of Alaska (Dallia pectoralis) is the type.","pos":""}],"XENON":[{"def":"A very heavy, inert gaseous element occurring in the atmosphere in the proportion of one volume is about 20 millions.","pos":""}],"XENOPTERYGII":[{"def":"A suborder of fishes including Gobiesox and allied genera.","pos":""}],"XENOTIME":[{"def":"A native phosphate of yttrium occurring in yellowish-brown tetragonal crystals.","pos":""}],"XENYL":[{"def":"The radical characteristic of xenylic compounds.","pos":""}],"XENYLIC":[{"def":"Pertaining to, derived from, designating, certain amido compounds obtained by reducing certain nitro derivatives of diphenyl.","pos":""}],"XERAPHIM":[{"def":"An old money of account in Bombay, equal to three fifths of a rupee.","pos":""}],"XERIFF":[{"def":"A gold coin formerly current in Egypt and Turkey, of the value of about 9s.","pos":""}],"XERONATE":[{"def":"A salt of xeronic acid.","pos":""}],"XERONIC":[{"def":"Pertaining to, or designating, an acid, C8H12O4, related to fumaric acid, and obtained from citraconic acid as an oily substance having a bittersweet taste; -- so called from its tendency to form its anhydride.","pos":""}],"XEROPHAGY":[{"def":"Among the primitive Christians, the living on a diet of dry food in Lent and on other fasts.","pos":""}],"XEROPHILOUS":[{"def":"Drought-loving; able withstand the absence or lack of moisture.","pos":""}],"XEROPHTHALMIA":[{"def":"An abnormal dryness of the eyeball produced usually by long- continued inflammation and subsequent atrophy of the conjunctiva.","pos":""}],"XIPHIAS":[{"def":"A genus of fishes comprising the common swordfish.","pos":""}],"XIPHIDIUM":[{"def":"A genus of plants of the order Hæmodraceæ, having two-ranked, sword-shaped leaves.","pos":""}],"XIPHIOID":[{"def":"Of, pertaining to, or resembling, a cetacean of the genus Xiphius or family Xiphiidæ.","pos":""}],"XIPHIPLASTRON":[{"def":"The posterior, or fourth, lateral plate in the plastron of turtles; -- called also xiphisternum.","pos":""}],"XIPHIUS":[{"def":"A genus of cetaceans having a long, pointed, bony beak, usually two tusklike teeth in the lower jaw, but no teeth in the upper jaw.","pos":""}],"XIPHODON":[{"def":"An extinct genus of artiodactylous mammals found in the European Tertiary formations.","pos":""}],"XIPHOPHYLLOUS":[{"def":"Having sword-shaped leaves.","pos":""}],"XIPHURA":[{"def":"Same as Limuloidea.","pos":""}],"XP":[{"def":"The first two letters of the Greek word XRISTOS, Christ; -- an abbreviation used with the letters separate or, oftener, in a monogram, often inclosed in a circle, as a symbol or emblem of Christ.","pos":""},{"def":"The Röntgen rays; -- so called by their discoverer because of their enigmatical character.","pos":""}],"XYLAMIDE":[{"def":"An acid amide derivative of xylic acid, obtained as a white crystalline substance.","pos":""}],"XYLAN":[{"def":"A gummy substance of the pentosan class, present in woody tissue, and yielding xylose on hydrolysis; wood gum.","pos":""}],"XYLANTHRAX":[{"def":"Wood coal, or charcoal; -- so called in distinction from mineral coal.","pos":""}],"XYLATE":[{"def":"A salt of xylic acid.","pos":""}],"XYLEM":[{"def":"That portion of a fibrovascular bundle which has developed, or will develop, into wood cells; -- distinguished from phloëm.","pos":""}],"XYLENE":[{"def":"Any of a group of three metameric hydrocarbons of the aromatic series, found in coal and wood tar, and so named because found in crude wood spirit.","pos":""}],"XYLENOL":[{"def":"Any one of six metameric phenol derivatives of xylene, obtained as crystalline substances, (CH3)2.","pos":""}],"XYLETIC":[{"def":"Pertaining to, or designating, a complex acid related to mesitylenic acid, obtained as a white crystalline substance by the action of sodium and carbon dioxide on crude xylenol.","pos":""}],"XYLIC":[{"def":"Pertaining to, derived from, or related to, xylene; specifically, designating any one of several metameric acids produced by the partial oxidation of mesitylene and pseudo-cumene.","pos":""}],"XYLIDIC":[{"def":"Pertaining to, or designating, either one of two distinct acids which are derived from xylic acid and related compounds, and are metameric with uvitic acid.","pos":""}],"XYLIDINE":[{"def":"Any one of six metameric hydrocarbons, (CH3)2.","pos":""}],"XYLINDEIN":[{"def":"A green or blue pigment produced by Peziza in certain kinds of decayed wood, as the beech, oak, birch, etc.","pos":""}],"XYLITE":[{"def":"A liquid hydrocarbon found in crude wood spirits.","pos":""}],"XYLITONE":[{"def":"A yellow oil having a geraniumlike odor, produced as a side product in making phorone; -- called also xylite oil.","pos":""}],"XYLO-":[{"def":"A combining form from Gr.","pos":""}],"XYLOBALSAMUM":[{"def":"The dried twigs of a Syrian tree (Balsamodendron Gileadense).","pos":""}],"XYLOCARPOUS":[{"def":"Bearing fruit which becomes hard or woody.","pos":""}],"XYLOCOPA":[{"def":"A genus of hymenopterous insects including the carpenter.","pos":""}],"XYLOGRAPH":[{"def":"An engraving on wood, or the impression from such an engraving; a print by xylography.","pos":""}],"XYLOGRAPHER":[{"def":"One who practices xylography.","pos":""},{"def":"Of or pertaining to xylography, or wood engraving.","pos":""}],"XYLOGRAPHY":[{"def":"The art of engraving on wood.","pos":""},{"def":"The art of making prints from the natural grain of wood.","pos":""}],"XYLOID":[{"def":"Resembling wood; having the nature of wood.","pos":""}],"XYLOIDIN":[{"def":"A substance resembling pyroxylin, obtained by the action of nitric acid on starch; -- called also nitramidin.","pos":""}],"XYLOLOGY":[{"def":"The branch of dendrology treating of the gross and minute structure of wood.","pos":""}],"XYLOPHAGA":[{"def":"A genus of marine bivalves which bore holes in wood.","pos":""}],"XYLOPHAGIDES":[{"def":"A tribe or family of dipterous flies whose larvæ live in decayed wood.","pos":""}],"XYLOPHILAN":[{"def":"One of a tribe of beetles (Xylophili) whose larvæ live on decayed wood.","pos":""}],"XYLOPHILOUS":[{"def":"Of or pertaining to the xylophilans.","pos":""}],"XYLOPHONE":[{"def":"An instrument common among the Russians, Poles, and Tartars, consisting of a series of strips of wood or glass graduated in length to the musical scale, resting on belts of straw, and struck with two small hammers.","pos":""}],"XYLOPLASTIC":[{"def":"Formed of wood pulp by molds; relating to casts made of wood pulp in molds.","pos":""}],"XYLOPYROGRAPHY":[{"def":"The art or practice of burning pictures on wood with a hot iron; -- called also poker painting.","pos":""}],"XYLOQUINONE":[{"def":"Any one of a group of quinone compounds obtained respectively by the oxidation of certain xylidine compounds.","pos":""}],"XYLORCIN":[{"def":"A derivative of xylene obtained as a white crystalline substance which on exposure in the air becomes red; -- called also betaorcin.","pos":""}],"XYLOSE":[{"def":"An unfermentable sugar of the pentose class, C5H10O5, formed by the hydrolysis of xylan; wood sugar.","pos":""}],"XYLOSTEIN":[{"def":"A glucoside found in the poisonous berries of a species of honeysuckle (Lonicera xylosteum), and extracted as a bitter, white, crystalline substance.","pos":""}],"XYLOTILE":[{"def":"Same as Parkesine.","pos":""}],"XYLOTOMIST":[{"def":"One versed or engaged in xylotomy.","pos":""}],"XYLOTOMOUS":[{"def":"Capable of boring or cutting wood; -- said of many insects.","pos":""}],"XYLOTOMY":[{"def":"Art of preparing sections (transverse, tangential, or radial) of wood, esp.","pos":""}],"XYLOTRYA":[{"def":"A genus of marine bivalves closely allied to Teredo, and equally destructive to timber.","pos":""}],"XYLYL":[{"def":"Any one of three metameric radicals which are characteristic respectively of the three xylenes.","pos":""}],"XYLYLENE":[{"def":"Any one of three metameric radicals, CH2.","pos":""}],"XYRIDACEOUS":[{"def":"Of or pertaining to a natural order (Xyrideæ) of endogenous plants, of which Xyris is the type.","pos":""}],"XYRIS":[{"def":"A genus of endogenous herbs with grassy leaves and small yellow flowers in short, scaly-bracted spikes; yellow-eyed grass.","pos":""},{"def":"A long and open portico, for athletic exercises, as wrestling, running, etc.","pos":""}],"XYSTER":[{"def":"An instrument for scraping bone.","pos":""},{"def":"Y, the twenty-fifth letter of the English alphabet, at the beginning of a word or syllable, except when a prefix (see Y-), is usually a fricative vocal consonant; as a prefix, and usually in the middle or at the end of a syllable, it is a vowel.","pos":""}]}