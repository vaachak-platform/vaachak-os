{"COP":[{"def":"A more or less viscid, vellowish liquid, the bitter oleoresin of several species of Copaifera, a genus of trees growing in South America and the West Indies.","pos":""}],"COP-ROSE":[{"def":"The red, or corn, poppy.","pos":""}],"COPAL":[{"def":"A resinous substance flowing spontaneously from trees of Zanzibar, Madagascar, and South America (Trachylobium Hornemannianum, T.","pos":""}],"COPALM":[{"def":"The yellowish, fragrant balsam yielded by the sweet gum; also, the tree itself.","pos":""}],"COPARCENARY":[{"def":"Partnership in inheritance; joint heirship; joint right of sucession to an inheritance.","pos":""}],"COPARCENER":[{"def":"One who has an equal portion with others of an inheritance.","pos":""}],"COPARCENY":[{"def":"An equal share of an inheritance.","pos":""}],"COPART":[{"def":"For, of all miserias, I hold that chief Wretched to be, when none coparts our grief.","pos":""}],"COPARTNER":[{"def":"One who is jointly concerned with one or more persons in business, etc.","pos":""}],"COPARTNERSHIP":[{"def":"The state of being a copartner or of having a joint interest in any matter.","pos":""},{"def":"A partnership or firm; as, A.","pos":""}],"COPARTNERY":[{"def":"the state of being copartners in any undertaking.","pos":""}],"COPATAIN":[{"def":"Having a high crown, or a point or peak at top.","pos":""}],"COPATRIOT":[{"def":"A joint patriot.","pos":""}],"COPE":[{"def":"The top part of a flask or mold; the outer part of a loam mold.","pos":""}],"COPE-CHISEL":[{"def":"A narrow chisel adapted for cutting a groove.","pos":""}],"COPECK":[{"def":"A Russian copper coin.","pos":""}],"COPEMAN":[{"def":"A chapman; a dealer; a merchant.","pos":""}],"COPENHAGEN":[{"def":"A sweetened hot drink of spirit and beaten eggs.","pos":""}],"COPEPOD":[{"def":"Of or pertaining to the Copepoda.","pos":""},{"def":"One of the Copepoda.","pos":""}],"COPEPODA":[{"def":"An order of Entomastraca, including many minute Crustacea, both freshwater and marine.","pos":""}],"COPERNICAN":[{"def":"Pertaining to Copernicus, a Prussian by birth (b.","pos":""}],"COPESMATE":[{"def":"An associate or companion; a friend; a partner.","pos":""}],"COPESTONE":[{"def":"A stone for coping.","pos":""}],"COPIER":[{"def":"One who copies; one who writes or transcribes from an original; a transcriber.","pos":""},{"def":"An imitator; one who imitates an example; hence, a plagiarist.","pos":""}],"COPING":[{"def":"The highest or covering course of masonry in a wall, often with sloping edges to carry off water; -- sometimes called capping.","pos":""}],"COPIOUS":[{"def":"Large in quantity or amount; plentiful; abundant; fruitful.","pos":""}],"COPIOUSLY":[{"def":"In a copious manner.","pos":""}],"COPIOUSNESS":[{"def":"The state or quality of being copious; abudance; plenty; also, diffuseness in style.","pos":""}],"COPLANAR":[{"def":"Situated in one plane.","pos":""}],"COPLAND":[{"def":"A piece of ground terminating in a point or acute angle.","pos":""}],"COPPED":[{"def":"Rising to a point or head; conical; pointed; crested.","pos":""}],"COPPER":[{"def":"the boilers in the galley for cooking; as, a ship's coppers.","pos":""}],"COPPER WORKS":[{"def":"A place where copper is wrought or manufactured.","pos":""}],"COPPER-BOTTOMED":[{"def":"Having a bottom made of copper, as a tin boiler or other vessel, or sheathed with copper, as a ship.","pos":""}],"COPPER-FACED":[{"def":"Faced or covered with copper; as, copper-faced type.","pos":""}],"COPPER-FASTENED":[{"def":"Fastened with copper bolts, as the planks of ships, etc.","pos":""}],"COPPERAS":[{"def":"Green vitriol, or sulphate of iron; a green crystalline substance, of an astringent taste, used in making ink, in dyeing black, as a tonic in medicine, etc.","pos":""}],"COPPERHEAD":[{"def":"A poisonous American serpent (Ancistrodon conotortrix), closely allied to the rattlesnake, but without rattles; -- called also copper-belly, and red viper.","pos":""}],"COPPERING":[{"def":"The act of covering with copper.","pos":""},{"def":"An envelope or covering of copper.","pos":""}],"COPPERISH":[{"def":"Containing, or partaking of the nature of, copper; like copper; as, a copperish taste.","pos":""}],"COPPERSMITH":[{"def":"One whose occupation is to manufacture copper utensils; a worker in copper.","pos":""}],"COPPERY":[{"def":"Mixed with copper; containing copper, or made of copper; like copper.","pos":""}],"COPPICE":[{"def":"A grove of small growth; a thicket of brushwood; a wood cut at certain times for fuel or other purposes.","pos":""}],"COPPIN":[{"def":"A cop of thread.","pos":"noun"}],"COPPLE":[{"def":"Something rising in a conical shape; specifically, a hill rising to a point.","pos":""}],"COPPLE DUST":[{"def":"Powder of steel, or copple dust.","pos":""}],"COPPLE-CROWN":[{"def":"A created or high-topped crown or head.","pos":""}],"COPPLED":[{"def":"Rising to a point; conical; copped.","pos":""}],"COPRA":[{"def":"The dried meat of the cocoanut, from which cocoanut oil is expressed.","pos":""}],"COPROLITE":[{"def":"A piece of petrified dung; a fossil excrement.","pos":""}],"COPROLITIC":[{"def":"Containing, pertaining to, or of the nature of, coprolites.","pos":""}],"COPROPHAGAN":[{"def":"A kind of beetle which feeds upon dung.","pos":""}],"COPROPHAGOUS":[{"def":"Feeding upon dung, as certain insects.","pos":""}],"COPS":[{"def":"The connecting crook of a harrow.","pos":""}],"COPSE":[{"def":"A wood of small growth; a thicket of brushwood.","pos":""}],"COPSEWOOD":[{"def":"Brushwood; coppice.","pos":""}],"COPSY":[{"def":"Characterized by copses.","pos":""}],"COPTIC":[{"def":"Of or pertaining to the Copts.","pos":""},{"def":"The language of the Copts.","pos":""}],"COPTIC CHURCH":[{"def":"The native church of Egypt or church of Alexandria, which in general organization and doctrines resembles the Roman Catholic Church, except that it holds to the Monophysitic doctrine which was condemned (a.","pos":""}],"COPTS":[{"def":"An Egyptian race thought to be descendants of the ancient Egyptians.","pos":""},{"def":"The principal sect of Christians in Egypt and the valley of the Nile.","pos":""}],"COPULA":[{"def":"The word which unites the subject and predicate.","pos":""},{"def":"The stop which connects the manuals, or the manuals with the pedals; -- called also coupler.","pos":""}],"COPULATE":[{"def":"Joining subject and predicate; copulative.","pos":""}],"COPULATION":[{"def":"The act of coupling or joining; union; conjunction.","pos":""},{"def":"The coming together of male and female in the act of generation; sexual union; coition.","pos":""}],"COPULATIVE":[{"def":"Serving to couple, unite, or connect; as, a copulative conjunction like \"and\".","pos":""}],"COPULATIVELY":[{"def":"In a copulative manner.","pos":""}],"COPULATORY":[{"def":"Used in sexual union; as, the copulatory organs of insects.","pos":""}],"COPY":[{"def":"Manuscript or printed matter to be set up in type; as, the printers are calling for more copy.","pos":""}],"COPYGRAPH":[{"def":"A contrivance for producing manifold copies of a writing or drawing.","pos":""}],"COPYHOLD":[{"def":"Note: Copyholds do not exist in the United States.","pos":""}],"COPYHOLDER":[{"def":"One possessed of land in copyhold.","pos":""}],"COPYIST":[{"def":"A copier; a transcriber; an imitator; a plagiarist.","pos":""}],"COPYRIGHT":[{"def":"The right of an author or his assignee, under statute, to print and publish his literary or artistic work, exclusively of all other persons.","pos":""}]}