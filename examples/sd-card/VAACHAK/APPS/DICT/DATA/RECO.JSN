{"RECOCT":[{"def":"To boil or cook again; hence, to make over; to vamp up; to reconstruct.","pos":""}],"RECOCTION":[{"def":"A second coction or preparation; a vamping up.","pos":""}],"RECOGNITION":[{"def":"The act of recognizing, or the state of being recognized; acknowledgment; formal avowal; knowledge confessed or avowed; notice.","pos":""}],"RECOGNITOR":[{"def":"One of a jury impaneled on an assize.","pos":""}],"RECOGNITORY":[{"def":"Pertaining to, or connected with, recognition.","pos":""}],"RECOGNIZABILITY":[{"def":"The quality or condition of being recognizable.","pos":""}],"RECOGNIZABLE":[{"def":"Capable of being recognized.","pos":""}],"RECOGNIZANCE":[{"def":"A token; a symbol; a pledge; a badge.","pos":""},{"def":"Acknowledgment of a person or thing; avowal; profession; recognition.","pos":""}],"RECOGNIZE":[{"def":"To know again; to perceive the identity of, with a person or thing previously known; to recover or recall knowledge of.","pos":""},{"def":"To avow knowledge of; to allow that one knows; to consent to admit, hold, or the like; to admit with a formal acknowledgment; as, to recognize an obligation; to recognize a consul.","pos":""}],"RECOGNIZEE":[{"def":"The person in whose favor a recognizance is made.","pos":""}],"RECOGNIZER":[{"def":"One who recognizes; a recognizor.","pos":""},{"def":"One who enters into a recognizance.","pos":""}],"RECOIL":[{"def":"To start, roll, bound, spring, or fall back; to take a reverse motion; to be driven or forced backward; to return.","pos":""},{"def":"To draw back, as from anything repugnant, distressing, alarming, or the like; to shrink.","pos":""}],"RECOILER":[{"def":"One who, or that which, recoils.","pos":""}],"RECOILINGLY":[{"def":"In the manner of a recoil.","pos":""}],"RECOIN":[{"def":"To coin anew or again.","pos":""}],"RECOINAGE":[{"def":"The act of coining anew.","pos":""},{"def":"That which is coined anew.","pos":""}],"RECOLLECT":[{"def":"To recover or recall the knowledge of; to bring back to the mind or memory; to remember.","pos":""},{"def":"Reflexively, to compose one's self; to recover self-command; as, to recollect one's self after a burst of anger; -- sometimes, formerly, in the perfect participle.","pos":""}],"RECOLLECTION":[{"def":"The act of recollecting, or recalling to the memory; the operation by which objects are recalled to the memory, or ideas revived in the mind; reminiscence; remembrance.","pos":""},{"def":"The power of recalling ideas to the mind, or the period within which things can be recollected; remembrance; memory; as, an event within my recollection.","pos":""}],"RECOLLECTIVE":[{"def":"Having the power of recollecting.","pos":""}],"RECOLLET":[{"def":"Same as Recollect, n.","pos":""}],"RECOLONIZATION":[{"def":"A second or renewed colonization.","pos":""}],"RECOLONIZE":[{"def":"To colonize again.","pos":""}],"RECOMBINATION":[{"def":"Combination a second or additional time.","pos":""}],"RECOMBINE":[{"def":"To combine again.","pos":""}],"RECOMFORT":[{"def":"To comfort again; to console anew; to give new strength to.","pos":""}],"RECOMFORTLESS":[{"def":"Without comfort.","pos":""}],"RECOMFORTURE":[{"def":"The act of recomforting; restoration of comfort.","pos":""}],"RECOMMENCE":[{"def":"To commence or begin again.","pos":""},{"def":"To begin anew to be; to act again as.","pos":""}],"RECOMMENCEMENT":[{"def":"A commencement made anew.","pos":""}],"RECOMMEND":[{"def":"To commend to the favorable notice of another; to commit to another's care, confidence, or acceptance, with favoring representations; to put in a favorable light before any one; to bestow commendation on; as, he recommended resting the mind and exercising the body.","pos":""},{"def":"To make acceptable; to attract favor to.","pos":""}],"RECOMMENDABLE":[{"def":"Suitable to be recommended; worthy of praise; commendable.","pos":""}],"RECOMMENDATION":[{"def":"The act of recommending.","pos":""},{"def":"That which recommends, or commends to favor; anything procuring, or tending to procure, a favorable reception, or to secure acceptance and adoption; as, he brought excellent recommendations.","pos":""}],"RECOMMENDATIVE":[{"def":"That which recommends; a recommendation.","pos":""}],"RECOMMENDATORY":[{"def":"Serving to recommend; recommending; commendatory.","pos":""}],"RECOMMENDER":[{"def":"One who recommends.","pos":""}],"RECOMMISSION":[{"def":"To commission again; to give a new commission to.","pos":""}],"RECOMMIT":[{"def":"To commit again; to give back into keeping; specifically, to refer again to a committee; as, to recommit a bill to the same committee.","pos":""},{"def":"A second or renewed commitment; a renewed reference to a committee.","pos":""}],"RECOMPACT":[{"def":"To compact or join anew.","pos":""}],"RECOMPENSATION":[{"def":"Used to denote a case where a set-off pleaded by the defendant is met by a set-off pleaded by the plaintiff.","pos":""}],"RECOMPENSE":[{"def":"To render an equivalent to, for service, loss, etc.","pos":""},{"def":"To return an equivalent for; to give compensation for; to atone for; to pay for.","pos":""}],"RECOMPENSEMENT":[{"def":"Recompense; requital.","pos":""}],"RECOMPENSER":[{"def":"One who recompenses.","pos":""}],"RECOMPENSIVE":[{"def":"Of the nature of recompense; serving to recompense.","pos":""}],"RECOMPILATION":[{"def":"A new compilation.","pos":""}],"RECOMPILE":[{"def":"To compile anew.","pos":""}],"RECOMPILEMENT":[{"def":"The act of recompiling; new compilation or digest; as, a recompilement of the laws.","pos":""}],"RECOMPOSE":[{"def":"To compose again; to form anew; to put together again or repeatedly.","pos":""},{"def":"To restore to composure; to quiet anew; to tranquilize; as, to recompose the mind.","pos":""}],"RECOMPOSER":[{"def":"One who recomposes.","pos":""}],"RECOMPOSITION":[{"def":"The act of recomposing.","pos":""}],"RECONCENTRATE":[{"def":"To concentrate again; to concentrate thoroughly.","pos":""}],"RECONCENTRATION":[{"def":"The act of reconcentrating or the state of being reconcentrated; esp.","pos":""}],"RECONCILABLE":[{"def":"Capable of being reconciled; as, reconcilable adversaries; an act reconciable with previous acts.","pos":""}],"RECONCILE":[{"def":"To cause to be friendly again; to conciliate anew; to restore to friendship; to bring back to harmony; to cause to be no longer at variance; as, to reconcile persons who have quarreled.","pos":""},{"def":"To bring to acquiescence, content, or quiet submission; as, to reconcile one's self to affictions.","pos":""}],"RECONCILEMENT":[{"def":"Rec\"on*cile`ment (-ment), n.","pos":""}],"RECONCILER":[{"def":"One who reconciles.","pos":""}],"RECONCILIATION":[{"def":"The act of reconciling, or the state of being reconciled; reconcilenment; restoration to harmony; renewal of friendship.","pos":""},{"def":"Reduction to congruence or consistency; removal of inconsistency; harmony.","pos":""}],"RECONCILIATORY":[{"def":"Serving or tending to reconcile.","pos":""}],"RECONDENSATION":[{"def":"The act or process of recondensing.","pos":""}],"RECONDENSE":[{"def":"To condense again.","pos":""}],"RECONDITE":[{"def":"Hidden from the mental or intellectual view; secret; abstruse; as, recondite causes of things.","pos":""},{"def":"Dealing in things abstruse; profound; searching; as, recondite studies.","pos":""}],"RECONDITORY":[{"def":"A repository; a storehouse.","pos":""}],"RECONDUCT":[{"def":"To conduct back or again.","pos":""}],"RECONFIRM":[{"def":"To confirm anew.","pos":""}],"RECONFORT":[{"def":"To recomfort; to comfort.","pos":""}],"RECONJOIN":[{"def":"To join or conjoin anew.","pos":""},{"def":"The act of reconnoitering; preliminary examination or survey.","pos":""}],"RECONQUER":[{"def":"To conquer again; to recover by conquest; as, to reconquer a revolted province.","pos":""}],"RECONQUEST":[{"def":"A second conquest.","pos":""}],"RECONSECRATE":[{"def":"To consecrate anew or again.","pos":""}],"RECONSECRATION":[{"def":"Renewed consecration.","pos":""}],"RECONSIDER":[{"def":"To take up for renewed consideration, as a motion or a vote which has been previously acted upon.","pos":""}],"RECONSIDERATION":[{"def":"The act of reconsidering, or the state of being reconsidered; as, the reconsideration of a vote in a legislative body.","pos":""}],"RECONSOLATE":[{"def":"To console or comfort again.","pos":""}],"RECONSOLIDATE":[{"def":"To consolidate anew or again.","pos":""}],"RECONSOLIDATION":[{"def":"The act or process of reconsolidating; the state of being reconsolidated.","pos":""}],"RECONSTRUCT":[{"def":"To construct again; to rebuild; to remodel; to form again or anew.","pos":""}],"RECONSTRUCTION":[{"def":"The act or process of reorganizing the governments of the States which had passed ordinances of secession, and of reëstablishing their constitutional relations to the national government, after the close of the Civil War.","pos":""}],"RECONSTRUCTIVE":[{"def":"Reconstructing; tending to reconstruct; as, a reconstructive policy.","pos":""}],"RECONTINUANCE":[{"def":"The act or state of recontinuing.","pos":""}],"RECONTINUE":[{"def":"To continue anew.","pos":""}],"RECONVENE":[{"def":"To convene or assemble again; to call or come together again.","pos":""}],"RECONVENTION":[{"def":"A cross demand; an action brought by the defendant against the plaintiff before the same judge.","pos":""}],"RECONVERSION":[{"def":"A second conversion.","pos":""}],"RECONVERT":[{"def":"To convert again.","pos":""}],"RECONVERTIBLE":[{"def":"Capable of being reconverted; convertible again to the original form or condition.","pos":""}],"RECONVEY":[{"def":"To convey back or to the former place; as, to reconvey goods.","pos":""},{"def":"To transfer back to a former owner; as, to reconvey an estate.","pos":""}],"RECONVEYANCE":[{"def":"Act of reconveying.","pos":""}],"RECORD":[{"def":"To recall to mind; to recollect; to remember; to meditate.","pos":""},{"def":"To repeat; to recite; to sing or play.","pos":""}],"RECORDANCE":[{"def":"Re*cord\"ance (r*krd\"ns), n.","pos":""}],"RECORDATION":[{"def":"Remembrance; recollection; also, a record.","pos":""}],"RECORDER":[{"def":"A kind of wind instrument resembling the flageolet.","pos":""}],"RECORDERSHIP":[{"def":"The office of a recorder.","pos":""}],"RECORDING":[{"def":"Keeping a record or a register; as, a recording secretary; -- applied to numerous instruments with an automatic appliance which makes a record of their action; as, a recording gauge or telegraph.","pos":""}],"RECORPORIFICATION":[{"def":"The act of investing again with a body; the state of being furnished anew with a body.","pos":""}],"RECOUCH":[{"def":"To retire again to a couch; to lie down again.","pos":""}],"RECOUNT":[{"def":"To count or reckon again.","pos":""}],"RECOUNTMENT":[{"def":"To keep back rightfully (a part), as if by cutting off, so as to diminish a sum due; to take off (a part) from damages; to deduct; as, where a landlord recouped the rent of premises from damages awarded to the plaintiff for eviction.","pos":""}],"RECOUPER":[{"def":"One who recoups.","pos":""}],"RECOUPMENT":[{"def":"The act of recouping.","pos":""}],"RECOURSE":[{"def":"A coursing back, or coursing again, along the line of a previous coursing; renewed course; return; retreat; recurence.","pos":""},{"def":"Recurrence in difficulty, perplexity, need, or the like; access or application for aid; resort.","pos":""}],"RECOURSEFUL":[{"def":"Having recurring flow and ebb; moving alternately.","pos":""}],"RECOVER":[{"def":"Re*cov\"er (r*kv\"r), v.","pos":""}],"RECOVERABLE":[{"def":"Capable of being recovered or regained; capable of being brought back to a former condition, as from sickness, misfortune, etc.","pos":""}],"RECOVERANCE":[{"def":"Re*cov\"er*ance (ans), n.","pos":""}],"RECOVEREE":[{"def":"The person against whom a judgment is obtained in common recovery.","pos":""}],"RECOVERER":[{"def":"One who recovers.","pos":""}],"RECOVEROR":[{"def":"The demandant in a common recovery after judgment.","pos":""}],"RECOVERY":[{"def":"The obtaining in a suit at law of a right to something by a verdict and judgment of court.","pos":""}]}