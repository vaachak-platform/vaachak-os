{"FLUAVIL":[{"def":"A hydrocarbon extracted from gutta-percha, as a yellow, resinous substance; -- called also fluanil.","pos":""}],"FLUCAN":[{"def":"Soft clayey matter in the vein, or surrounding it.","pos":""}],"FLUCTIFEROUS":[{"def":"Tending to produce waves.","pos":""}],"FLUCTISONOUS":[{"def":"Sounding like waves.","pos":""}],"FLUCTUABILITY":[{"def":"The capacity or ability to fluctuate.","pos":""}],"FLUCTUANT":[{"def":"showing undulation or fluctuation; as, a fluctuant tumor.","pos":""}],"FLUCTUATE":[{"def":"To move as a wave; to roll hither and thither; to wave; to float backward and forward, as on waves; as, a fluctuating field of air.","pos":""},{"def":"To move now in one direction and now in another; to be wavering or unsteady; to be irresolute or undetermined; to vacillate.","pos":""}],"FLUCTUATION":[{"def":"The motion or undulation of a fluid collected in a natural or artifical cavity, which is felt when it is subjected to pressure or percussion.","pos":""}],"FLUE":[{"def":"An inclosed passage way for establishing and directing a current of air, gases, etc.","pos":""}],"FLUENCY":[{"def":"The quality of being fluent; smoothness; readiness of utterance; volubility.","pos":""}],"FLUENT":[{"def":"Flowing or capable of flowing; liquid; glodding; easily moving.","pos":""},{"def":"Ready in the use of words; voluble; copious; having words at command; and uttering them with facility and smoothness; as, a fluent speaker; hence, flowing; voluble; smooth; -- said of language; as, fluent speech.","pos":""}],"FLUENTLY":[{"def":"In a fluent manner.","pos":""}],"FLUENTNESS":[{"def":"The quality of being fluent.","pos":""}],"FLUEWORK":[{"def":"A general name for organ stops in which the sound is caused by wind passing through a flue or fissure and striking an edge above; -- in distinction from reedwork.","pos":""}],"FLUFF":[{"def":"Nap or down; flue; soft, downy feathers.","pos":""}],"FLUFFY":[{"def":"Pertaining to, or resembling, fluff or nap; soft and downy.","pos":""},{"def":"A grand piano or a harpsichord, both being wing-shaped.","pos":""}],"FLUGELMAN":[{"def":"Same as Fugleman.","pos":""}],"FLUID":[{"def":"Having particles which easily move and change their relative position without a separation of the mass, and which easily yield to pressure; capable of flowing; liquid or gaseous.","pos":""}],"FLUIDAL":[{"def":"Pertaining to a fluid, or to its flowing motion.","pos":""}],"FLUIDITY":[{"def":"The quality of being fluid or capable of flowing; a liquid, aëriform.","pos":""}],"FLUIDIZE":[{"def":"To render fluid.","pos":""}],"FLUIDNESS":[{"def":"The state of being flluid; fluidity.","pos":""}],"FLUIDOUNCE":[{"def":"See Fluid ounce, under Fluid.","pos":""}],"FLUIDRACHM":[{"def":"See Fluid dram, under Fluid.","pos":""}],"FLUKE":[{"def":"One of the lobes of a whale's tail, so called from the resemblance to the fluke of an anchor.","pos":""}],"FLUKEWORM":[{"def":"Same as 1st Fluke, 2.","pos":""}],"FLUKY":[{"def":"Formed like, or having, a fluke.","pos":""}],"FLUME":[{"def":"A stream; especially, a passage channel, or conduit for the water that drives a mill wheel; or an artifical channel of water for hydraulic or placer mining; also, a chute for conveying logs or lumber down a declivity.","pos":""}],"FLUMINOUS":[{"def":"Pertaining to rivers; abounding in streama.","pos":""}],"FLUMMERY":[{"def":"A light kind of food, formerly made of flour or meal; a sort of pap.","pos":""},{"def":"Something insipid, or not worth having; empty compliment; trash; unsubstantial talk of writing.","pos":""}],"FLUNK":[{"def":"To fail, as on a lesson; to back out, as from an undertaking, through fear.","pos":""}],"FLUNKY":[{"def":"A contemptuous name for a liveried servant or a footman.","pos":""},{"def":"One who is obsequious or cringing; a snob.","pos":""}],"FLUNKYDOM":[{"def":"The place or region of flunkies.","pos":""}],"FLUNLYISM":[{"def":"The quality or characteristics of a flunky; readiness to cringe to those who are superior in wealth or position; toadyism.","pos":""}],"FLUO-":[{"def":"A combining form indicating fluorine as an ingredient; as in fluosilicate, fluobenzene.","pos":""}],"FLUOBORATE":[{"def":"A salt of fluoboric acid; a fluoboride.","pos":""}],"FLUOBORIC":[{"def":"Pertaining to, derived from, or consisting of, fluorine and boron.","pos":""}],"FLUOBORIDE":[{"def":"See Borofluoride.","pos":""},{"def":"A fluoride of cerium, occuring near Fahlun in Sweden.","pos":""}],"FLUOHYDRIC":[{"def":"See Hydrofluoric.","pos":""}],"FLUOPHOSPHATE":[{"def":"A double salt of fluoric and phosphoric acids.","pos":""}],"FLUOR":[{"def":"Menstrual flux; catamenia; menses.","pos":""}],"FLUOR ALBUS":[{"def":"The whites; leucorrhæa.","pos":""}],"FLUORATED":[{"def":"Combined with fluorine; subjected to the action of fluoride.","pos":""}],"FLUORENE":[{"def":"A colorless, crystalline hydrocarbon, C13H10 having a beautiful violet fluorescence; whence its name.","pos":""}],"FLUORESCEIN":[{"def":"A yellowish red, crystalline substance, C20H12O5, produced by heating together phthalic anhydride and resorcin; -- so called, from the very brilliant yellowish green fluorescence of its alkaline solutions.","pos":""}],"FLUORESCENCE":[{"def":"That property which some transparent bodies have of producing at their surface, or within their substance, light different in color from the mass of the material, as when green crystals of fluor spar afford blue reflections.","pos":""}],"FLUORESCENT":[{"def":"Having the property of fluorescence.","pos":""}],"FLUORESCIN":[{"def":"A colorless, amorphous substance which is produced by the reduction of fluoresceïn, and from which the latter may be formed by oxidation.","pos":""}],"FLUORIC":[{"def":"Pertaining to, obtained from, or containing, fluorine.","pos":""}],"FLUORIDE":[{"def":"A binary compound of fluorine with another element or radical.","pos":""}],"FLUORINE":[{"def":"A non-metallic, gaseous element, strongly acid or negative, or associated with chlorine, bromine, and iodine, in the halogen group of which it is the first member.","pos":""}],"FLUORITE":[{"def":"Calcium fluoride, a mineral of many different colors, white, yellow, purple, green, red, etc.","pos":""}],"FLUOROID":[{"def":"A tetrahexahedron; -- so called because it is a common form of fluorite.","pos":""}],"FLUOROSCOPE":[{"def":"An instrument for observing or exhibiting fluorescence.","pos":""}],"FLUOROSCOPY":[{"def":"Examination of an object, as the human body, by exposing it to the X rays and observing the shadow cast upon a fluorescent screen; cryptoscopy.","pos":""}],"FLUOROUS":[{"def":"Pertaining to fluor.","pos":""}],"FLUOSILICATE":[{"def":"A double fluoride of silicon and some other (usually basic) element or radical, regarded as a salt of fluosilicic acid; -- called also silicofluoride.","pos":""}],"FLUOSILICIC":[{"def":"Composed of, or derived from, silicon and fluorine.","pos":""}],"FLURRIED":[{"def":"Agitated; excited.","pos":""}],"FLURRY":[{"def":"A sudden and brief blast or gust; a light, temporary breeze; as, a flurry of wind.","pos":""},{"def":"A light shower or snowfall accompanied with wind.","pos":""}],"FLUSH":[{"def":"To flow and spread suddenly; to rush; as, blood flushes into the face.","pos":""},{"def":"To become suddenly suffused, as the cheeks; to turn red; to blush.","pos":""}],"FLUSHBOARD":[{"def":"Same as Flashboard.","pos":""}],"FLUSHER":[{"def":"The red-backed shrike.","pos":""}],"FLUSHING":[{"def":"A surface formed of floating threads.","pos":""}],"FLUSHINGLY":[{"def":"In a flushing manner.","pos":""}],"FLUSHNESS":[{"def":"The state of being flush; abundance.","pos":""}],"FLUSTER":[{"def":"To make hot and rosy, as with drinking; to heat; hence, to throw into agitation and confusion; to confuse; to muddle.","pos":""}],"FLUSTERATION":[{"def":"The act of flustering, or the state of being flustered; fluster.","pos":""}],"FLUSTRATION":[{"def":"The act of flustrating; confusion; flurry.","pos":""}],"FLUTE":[{"def":"A channel of curved section; -- usually applied to one of a vertical series of such channels used to decorate columns and pilasters in classical architecture.","pos":""}],"FLUTE A BEC":[{"def":"A beak flute, an older form of the flute, played with a mouthpiece resembling a beak, and held like a flageolet.","pos":""}],"FLUTED":[{"def":"Thin; fine; clear and mellow; flutelike; as, fluted notes.","pos":""},{"def":"Decorated with flutes; channeled; grooved; as, a fluted column; a fluted ruffle; a fluted spectrum.","pos":""}],"FLUTEMOUTH":[{"def":"A fish of the genus Aulostoma, having a much elongated tubular snout.","pos":""}],"FLUTER":[{"def":"One who plays on the flute; a flutist or flautist.","pos":""},{"def":"One who makes grooves or flutings.","pos":""}],"FLUTING":[{"def":"Decoration by means of flutes or channels; a flute, or flutes collectively; as, the fluting of a column or pilaster; the fluting of a lady's ruffle.","pos":""}],"FLUTIST":[{"def":"A performer on the flute; a flautist.","pos":""}],"FLUTTER":[{"def":"To vibrate or move quickly; as, a bird flutters its wings.","pos":""},{"def":"To drive in disorder; to throw into confusion.","pos":""}],"FLUTTERER":[{"def":"One who, or that which, flutters.","pos":""}],"FLUTTERINGLY":[{"def":"In a fluttering manner.","pos":""}],"FLUTY":[{"def":"Soft and clear in tone, like a flute.","pos":""}],"FLUVIAL":[{"def":"Belonging to rivers; growing or living in streams or ponds; as, a fluvial plant.","pos":""}],"FLUVIALIST":[{"def":"One who exlpains geological phenomena by the action of streams.","pos":""}],"FLUVIATIC":[{"def":"Belonging to rivers or streams; fluviatile.","pos":""}],"FLUVIATILE":[{"def":"Belonging to rivers or streams; existing in or about rivers; produced by river action; fluvial; as, fluviatile starta, plants.","pos":""}],"FLUVIO-MARINE":[{"def":"Formed by the joint action of a river and the sea, as deposits at the mouths of rivers.","pos":""}],"FLUVIOGRAPH":[{"def":"An instrument for measuring and recording automatically the rise and fall of a river.","pos":""}],"FLUVIOMETER":[{"def":"An instrument for measuring the height of water in a river; a river gauge.","pos":""}],"FLUX":[{"def":"Any substance or mixture used to promote the fusion of metals or minerals, as alkalies, borax, lime, fluorite.","pos":""},{"def":"The quantity of a fluid that crosses a unit area of a given surface in a unit of time.","pos":""}],"FLUXATION":[{"def":"The act of fluxing.","pos":""}],"FLUXIBILITY":[{"def":"The quality of being fluxible.","pos":""}],"FLUXIBLE":[{"def":"Capable of being melted or fused, as a mineral.","pos":""}],"FLUXILITY":[{"def":"State of being fluxible.","pos":""}],"FLUXION":[{"def":"The act of flowing.","pos":""},{"def":"An unnatural or excessive flow of blood or fluid toward any organ; a determination.","pos":""}],"FLUXIONAL":[{"def":"Pertaining to, or having the nature of, fluxion or fluxions; variable; inconstant.","pos":""}],"FLUXIONARY":[{"def":"Pertaining to, or caused by, an increased flow of blood to a part; congestive; as, a fluxionary hemorrhage.","pos":""}],"FLUXIONIST":[{"def":"One skilled in fluxions.","pos":""}],"FLUXIONS":[{"def":"See Fluxion, 6(b).","pos":""}],"FLUXIVE":[{"def":"Flowing; also, wanting solidity.","pos":""}],"FLUXURE":[{"def":"The quality of being fluid.","pos":""}]}