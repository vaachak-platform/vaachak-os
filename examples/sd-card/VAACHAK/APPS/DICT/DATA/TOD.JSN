{"TOD":[{"def":"A bush; a thick shrub; a bushy clump.","pos":""},{"def":"An old weight used in weighing wool, being usually twenty-eight pounds.","pos":""}],"TODDLE":[{"def":"To walk with short, tottering steps, as a child.","pos":""}],"TODDLER":[{"def":"One who toddles; especially, a young child.","pos":""}],"TODDY":[{"def":"A juice drawn from various kinds of palms in the East Indies; or, a spirituous liquor procured from it by fermentation.","pos":""},{"def":"A mixture of spirit and hot water sweetened.","pos":""}],"TODY":[{"def":"Any one of several species of small insectivorous West Indian birds of the genus Todus.","pos":""}]}