{"ANUBIS":[{"def":"An Egyptian deity, the conductor of departed spirits, represented by a human figure with the head of a dog or fox.","pos":""}],"ANURA":[{"def":"One of the orders of amphibians characterized by the absence of a tail, as the frogs and toads.","pos":""}],"ANUROUS":[{"def":"Destitute of a tail, as the frogs and toads.","pos":""}],"ANURY":[{"def":"Nonsecretion or defective secretion of urine; ischury.","pos":""}],"ANUS":[{"def":"The posterior opening of the alimentary canal, through which the excrements are expelled.","pos":""}]}