{"UNNAIL":[{"def":"To remove the nails from; to unfasten by removing nails.","pos":""}],"UNNAPPED":[{"def":"Finished without a nap.","pos":""}],"UNNATURAL":[{"def":"Not natural; contrary, or not conforming, to the order of nature; being without natural traits; as, unnatural crimes.","pos":""}],"UNNATURALIZE":[{"def":"To make unnatural.","pos":""}],"UNNATURE":[{"def":"To change the nature of; to invest with a different or contrary nature.","pos":""}],"UNNEAR":[{"def":"Not near; not close to; at a distance from.","pos":""}],"UNNECESSARY":[{"def":"Not necessary; not required under the circumstances; unless; needless; as, unnecessary labor, care, or rigor.","pos":""}],"UNNECESSITY":[{"def":"The state of being unnecessary; something unnecessary.","pos":""}],"UNNEIGHBORED":[{"def":"Being without neigbors.","pos":""}],"UNNEIGHBORLY":[{"def":"Not neighborly; distant; reserved; solitary; exclusive.","pos":""},{"def":"Not in a neighborly manner.","pos":""}],"UNNERVE":[{"def":"To deprive of nerve, force, or strength; to weaken; to enfeeble; as, to unnerve the arm.","pos":""}],"UNNEST":[{"def":"To eject from a nest; to unnestle.","pos":""}],"UNNESTLE":[{"def":"With difficulty.","pos":""}],"UNNOOKED":[{"def":"Without nooks and corners; guileless.","pos":""}],"UNNOTIFY":[{"def":"To retract or withdraw a notice of.","pos":""}],"UNNUMBERED":[{"def":"Not numbered; not counted or estimated; innumerable.","pos":""}],"UNNUN":[{"def":"To remove from condition of being a nun.","pos":""}]}