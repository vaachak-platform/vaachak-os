{"PLAT":[{"def":"To form by interlaying interweaving; to braid; to plait.","pos":""}],"PLATANUS":[{"def":"A genus of trees; the plane tree.","pos":""}],"PLATBAND":[{"def":"A border of flowers in a garden, along a wall or a parterre; hence, a border.","pos":""}],"PLATE":[{"def":"A piece of money, usually silver money.","pos":""},{"def":"A horizontal timber laid upon a wall, or upon corbels projecting from a wall, and supporting the ends of other timbers; also used specifically of the roof plate which supports the ends of the roof trusses or, in simple work, the feet of the rafters.","pos":""}],"PLATE-GILLED":[{"def":"Having flat, or leaflike, gills, as the bivalve mollusks.","pos":""}],"PLATEAU":[{"def":"A flat surface; especially, a broad, level, elevated area of land; a table-land.","pos":""},{"def":"An ornamental dish for the table; a tray or salver.","pos":""}],"PLATEFUL":[{"def":"Enough to fill a plate; as much as a plate will hold.","pos":""}],"PLATER":[{"def":"One who plates or coats articles with gold or silver; as, a silver plater.","pos":""}],"PLATERESQUE":[{"def":"Resembling silver plate; -- said of certain architectural ornaments.","pos":""}],"PLATETROPE":[{"def":"One of a pair of a paired organs.","pos":""}],"PLATFORM":[{"def":"A light deck, usually placed in a section of the hold or over the floor of the magazine.","pos":""}],"PLATHELMINTH":[{"def":"One of the Platyelminthes.","pos":""}],"PLATHELMINTHES":[{"def":"Same as Platyelminthes.","pos":""}],"PLATING":[{"def":"The art or process of covering anything with a plate or plates, or with metal, particularly of overlaying a base or dull metal with a thin plate of precious or bright metal, as by mechanical means or by electro-magnetic deposition.","pos":""},{"def":"A thin coating of metal laid upon another metal.","pos":""}],"PLATINIC":[{"def":"Of, pertaining to, or containing, platinum; -- used specifically to designate those compounds in which the element has a higher valence, as contrasted with the platinous compounds; as, platinic chloride (PtCl4).","pos":""}],"PLATINICHLORIC":[{"def":"Of, pertaining to, or designating, an acid consisting of platinic chloride and hydrochloric acid, and obtained as a brownish red crystalline substance, called platinichloric, or chloroplatinic, acid.","pos":""}],"PLATINIFEROUS":[{"def":"Yielding platinum; as, platiniferous sand.","pos":""}],"PLATINIRIDIUM":[{"def":"A natural alloy of platinum and iridium occurring in grayish metallic rounded or cubical grains with platinum.","pos":""}],"PLATINIZE":[{"def":"To cover or combine with platinum.","pos":""}],"PLATINOCHLORIC":[{"def":"Pertaining to, derived from, or designating, an acid consisting of platinous chloride and hydrochloric acid, called platinochloric, or chloroplatinous, acid.","pos":""}],"PLATINOCHLORIDE":[{"def":"A double chloride of platinum and some other metal or radical; a salt of platinochloric acid.","pos":""}],"PLATINOCYANIC":[{"def":"Pertaining to, derived from, or designating, an acid compound of platinous cyanide and hydrocyanic acid.","pos":""}],"PLATINOCYANIDE":[{"def":"A double cyanide of platinum and some other metal or radical; a salt of platinocyanic acid.","pos":""}],"PLATINOID":[{"def":"Resembling platinum.","pos":""}],"PLATINOTYPE":[{"def":"A permanent photographic picture or print in platinum black.","pos":""},{"def":"The process by which such pictures are produced.","pos":""}],"PLATINOUS":[{"def":"Of, pertaining to, or containing, platinum; -- used specifically to designate those compounds in which the element has a lower valence, as contrasted with the platinic compounds; as, platinous chloride (PtCl2).","pos":""}],"PLATINUM":[{"def":"A metallic element, intermediate in value between silver and gold, occurring native or alloyed with other metals, also as the platinum arsenide (sperrylite).","pos":""}],"PLATITUDE":[{"def":"The quality or state of being flat, thin, or insipid; flat commonness; triteness; staleness of ideas of language.","pos":""},{"def":"A thought or remark which is flat, dull, trite, or weak; a truism; a commonplace.","pos":""}],"PLATITUDINARIAN":[{"def":"One addicted to uttering platitudes, or stale and insipid truisms.","pos":""}],"PLATITUDINIZE":[{"def":"To utter platitudes or truisms.","pos":""}],"PLATITUDINOUS":[{"def":"Abounding in platitudes; of the nature of platitudes; uttering platitudes.","pos":""}],"PLATOMETER":[{"def":"Of or pertaining to Plato, or his philosophy, school, or opinions.","pos":""},{"def":"Pure, passionless; nonsexual; philosophical.","pos":""}],"PLATONIC":[{"def":"A follower of Plato; a Platonist.","pos":""}],"PLATONICALLY":[{"def":"In a Platonic manner.","pos":""}],"PLATONISM":[{"def":"The doctrines or philosophy by Plato or of his followers.","pos":""},{"def":"An elevated rational and ethical conception of the laws and forces of the universe; sometimes, imaginative or fantastic philosophical notions.","pos":""}],"PLATONIST":[{"def":"One who adheres to the philosophy of Plato; a follower of Plato.","pos":""}],"PLATONIZE":[{"def":"To adopt the opinion of Plato or his followers.","pos":""}],"PLATONIZER":[{"def":"One who Platonizes.","pos":""}],"PLATTDEUTSCH":[{"def":"The modern dialects spoken in the north of Germany, taken collectively; modern Low German.","pos":""}],"PLATTEN":[{"def":"To flatten and make into sheets or plates; as, to platten cylinder glass.","pos":""}],"PLATTER":[{"def":"One who plats or braids.","pos":""}],"PLATTER-FACED":[{"def":"Having a broad, flat face.","pos":""}],"PLATTING":[{"def":"Plaited strips or bark, cane, straw, etc.","pos":""}],"PLATY":[{"def":"Like a plate; consisting of plates.","pos":""}],"PLATY-":[{"def":"A combining form from Gr.","pos":""}],"PLATYCNEMIC":[{"def":"Of, relating to, or characterized by, platycnemism.","pos":""}],"PLATYCNEMISM":[{"def":"Lateral flattening of the tibia.","pos":""}],"PLATYCOELIAN":[{"def":"Flat at the anterior and concave at the posterior end; -- said of the centra of the vertebræ of some extinct dinouaurs.","pos":""}],"PLATYELMINTHES":[{"def":"A class of helminthes including the cestodes, or tapeworms, the trematodes, and the turbellarians.","pos":""}],"PLATYHELMIA":[{"def":"Same as Platyelminthes.","pos":""}],"PLATYMETER":[{"def":"An apparatus for measuring the capacity of condensers, or the inductive capacity of dielectrics.","pos":""}],"PLATYPOD":[{"def":"An animal having broad feet, or a broad foot.","pos":""}],"PLATYPODA":[{"def":"Same as Prosobranchiata.","pos":""}],"PLATYPTERA":[{"def":"A division of Pseudoneuroptera including the species which have four broad, flat wings, as the termites, or white-ants, and the stone flies (Perla).","pos":""}],"PLATYRHINE":[{"def":"Having the nose broad; -- opposed to Ant: leptorhine.","pos":""},{"def":"One of the Platyrhini.","pos":""}],"PLATYRHINI":[{"def":"A division of monkeys, including the American species, which have a broad nasal septum, thirty-six teeth, and usually a prehensile tail.","pos":""}]}