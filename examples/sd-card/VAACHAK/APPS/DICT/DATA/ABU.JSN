{"ABUNA":[{"def":"The Patriarch, or head of the Abyssinian Church.","pos":""}],"ABUNDANCE":[{"def":"An overflowing fullness; ample sufficiency; great plenty; profusion; copious supply; superfluity; wealth: -- strictly applicable to quantity only, but sometimes used of number.","pos":""}],"ABUNDANT":[{"def":"Fully sufficient; plentiful; in copious supply; -- followed by in, rarely by with.","pos":""}],"ABUNDANTLY":[{"def":"In a sufficient degree; fully; amply; plentifully; in large measure.","pos":""}],"ABURST":[{"def":"In a bursting condition.","pos":""}],"ABUSABLE":[{"def":"That may be abused.","pos":""}],"ABUSE":[{"def":"To put to a wrong use; to misapply; to misuse; to put to a bad use; to use for a wrong purpose or end; to pervert; as, to abuse inherited gold; to make an excessive use of; as, to abuse one's authority.","pos":""},{"def":"To use ill; to maltreat; to act injuriously to; to punish or to tax excessively; to hurt; as, to abuse prisoners, to abuse one's powers, one's patience.","pos":""}],"ABUSEFUL":[{"def":"Full of abuse; abusive.","pos":""}],"ABUSER":[{"def":"One who abuses [in the various senses of the verb].","pos":""}],"ABUSION":[{"def":"Evil or corrupt usage; abuse; wrong; reproach; deception; cheat.","pos":""}],"ABUSIVE":[{"def":"Wrongly used; perverted; misapplied.","pos":""},{"def":"Given to misusing; also, full of abuses.","pos":""}],"ABUSIVELY":[{"def":"In an abusive manner; rudely; with abusive language.","pos":""}],"ABUSIVENESS":[{"def":"The quality of being abusive; rudeness of language, or violence to the person.","pos":""}],"ABUT":[{"def":"To project; to terminate or border; to be contiguous; to meet; -- with on, upon, or against; as, his land abuts on the road.","pos":""}],"ABUTILON":[{"def":"A genus of malvaceous plants of many species, found in the torrid and temperate zones of both continents; -- called also Indian mallow.","pos":""}],"ABUTMENT":[{"def":"State of abutting.","pos":""},{"def":"That on or against which a body abuts or presses; as (a) (Arch.","pos":""}],"ABUTTAL":[{"def":"The butting or boundary of land, particularly at the end; a headland.","pos":""}],"ABUTTER":[{"def":"One who, or that which, abuts.","pos":""}],"ABUZZ":[{"def":"In a buzz; buzzing.","pos":""}]}