{"SURA":[{"def":"One of the sections or chapters of the Koran, which are one hundred and fourteen in number.","pos":""}],"SURADANNI":[{"def":"A valuable kind of wood obtained on the shores of the Demerara River in South America, much used for timbers, rails, naves and fellies of wheels, and the like.","pos":""}],"SURADDITION":[{"def":"Something added or appended, as to a name.","pos":""}],"SURAH":[{"def":"A soft twilled silk fabric much used for women's dresses; -- called also surah silk.","pos":""}],"SURAL":[{"def":"Of or pertaining to the calf of the leg; as, the sural arteries.","pos":""}],"SURANGULAR":[{"def":"Above the angular bone; supra-angular; -- applied to a bone of the lower jaw in many reptiles and birds.","pos":""},{"def":"The surangular bone.","pos":""}]}