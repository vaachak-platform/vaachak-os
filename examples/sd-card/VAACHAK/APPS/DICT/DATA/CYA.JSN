{"CYAMELIDE":[{"def":"A white amorphous substance, regarded as a polymeric modification of isocyanic acid.","pos":""}],"CYAMELLONE":[{"def":"A complex derivative of cyanogen, regarded as an acid, and known chiefly in its salts; -- called also hydromellonic acid.","pos":""}],"CYANATE":[{"def":"A salt of cyanic acid.","pos":""}],"CYANAURATE":[{"def":"See Aurocyanide.","pos":""}],"CYANEAN":[{"def":"Having an azure color.","pos":""}],"CYANIC":[{"def":"Pertaining to, or containing, cyanogen.","pos":""},{"def":"Of or pertaining to a blue color.","pos":""}],"CYANIDE":[{"def":"A compound formed by the union of cyanogen with an element or radical.","pos":""}],"CYANIN":[{"def":"The blue coloring matter of flowers; -- called also anthokyan and anthocyanin.","pos":""}],"CYANINE":[{"def":"One of a series of artificial blue or red dyes obtained from quinoline and lepidine and used in calico printing.","pos":""}],"CYANITE":[{"def":"A mineral occuring in thin-bladed crystals and crystalline aggregates, of a sky-blue color.","pos":""}],"CYANOGEN":[{"def":"A colorless, inflammable, poisonous gas, C2N2, with a peach- blossom odor, so called from its tendency to form blue compounds; obtained by heating ammonium oxalate, mercuric cyanide, etc.","pos":""}],"CYANOMETER":[{"def":"An instrument for measuring degress of blueness.","pos":""}],"CYANOPATHY":[{"def":"A disease in which the body is colored blue in its surface, arising usually from a malformation of the heart, which causes an imperfect arterialization of the blood; blue jaundice.","pos":""}],"CYANOPHYLL":[{"def":"A blue coloring matter supposed by some to be one of the component parts ofchlorophyll.","pos":""}],"CYANOSED":[{"def":"Cy\"a*nosed (s\"-nst), a.","pos":""}],"CYANOSIS":[{"def":"A condition in which, from insufficient aCyanopathy.","pos":""}],"CYANOSITE":[{"def":"Native sulphate of copper.","pos":""}],"CYANOTIC":[{"def":"Relating to cyanosis; affected with cyanosis; as, a cyanotic patient; having the hue caused by cyanosis; as, a cyanitic skin.","pos":""}],"CYANOTYPE":[{"def":"A photographic picture obtained by the use of a cyanide.","pos":""}],"CYANURATE":[{"def":"A salt of cyanuric acid.","pos":""}],"CYANURIC":[{"def":"Pertaining to, or derived from, cyanic and uric acids.","pos":""}],"CYANURIC ACID":[{"def":"an organic acid, C3O3N3H3, first obtained by heating uric acid or urea, and called pyrouric acid; afterwards obtained from isocyanic acid.","pos":""}],"CYATHIFORM":[{"def":"In the form of a cup, a little widened at the top.","pos":""}],"CYATHOLITH":[{"def":"Cy*ath\"olith (s-th\"-lth), n.","pos":""}],"CYATHOPHYLLOID":[{"def":"Like, or pertaining to, the family Cyathophyllidæ.","pos":""}]}