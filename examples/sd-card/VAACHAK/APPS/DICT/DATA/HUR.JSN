{"HURDEN":[{"def":"A coarse kind of linen; -- called also harden.","pos":""}],"HURDLE":[{"def":"A movable frame of wattled twigs, osiers, or withes and stakes, or sometimes of iron, used for inclosing land, for folding sheep and cattle, for gates, etc.","pos":""},{"def":"In England, a sled or crate on which criminals were formerly drawn to the place of execution.","pos":""}],"HURDLEWORK":[{"def":"Work after manner of a hurdle.","pos":""}],"HURDS":[{"def":"The coarse part of flax or hemp; hards.","pos":""}],"HURDY-GURDY":[{"def":"A stringled instrument, lutelike in shape, in which the sound is produced by the friction of a wheel turned by a crank at the end, instead of by a bow, two of the strings being tuned as drones, while two or more, tuned in unison, are modulated by keys.","pos":""},{"def":"In California, a water wheel with radial buckets, driven by the impact of a jet.","pos":""}],"HURKARU":[{"def":"In India, a running footman; a messenger.","pos":""}],"HURL":[{"def":"To twist or turn.","pos":""}],"HURLBONE":[{"def":"A bone near the middle of the buttock of a horse.","pos":""}],"HURLER":[{"def":"One who hurls, or plays at hurling.","pos":""}],"HURLING":[{"def":"The act of throwing with force.","pos":""},{"def":"A kind of game at ball, formerly played.","pos":""}],"HURLY":[{"def":"Noise; confusion; uproar.","pos":""}],"HURLY-BURLY":[{"def":"Tumult; bustle; confusion.","pos":""}],"HURON-IROQUOUS":[{"def":"A linguistic group of warlike North American Indians, belonging to the same stock as the Algonquins, and including several tribes, among which were the Five Nations.","pos":""}],"HURONIAN":[{"def":"Of or pertaining to certain non-fossiliferous rocks on the borders of Lake Huron, which are supposed to correspond in time to the latter part of the Archæan age.","pos":""}],"HURONS":[{"def":"American Indians of the Algonquin stock.","pos":""}],"HURR":[{"def":"To make a rolling or burring sound.","pos":""},{"def":"A word used as a shout of joy, triumph, applause, encouragement, or welcome.","pos":""}],"HURRAH":[{"def":"A cheer; a shout of joy, etc.","pos":""}],"HURRICANE":[{"def":"A violent storm, characterized by extreme fury and sudden changes of the wind, and generally accompanied by rain, thunder, and lightning; -- especially prevalent in the East and West Indies.","pos":""}],"HURRICANO":[{"def":"A waterspout; a hurricane.","pos":""}],"HURRIED":[{"def":"Urged on; hastened; going or working at speed; as, a hurried writer; a hurried life.","pos":""},{"def":"Done in a hurry; hence, imperfect; careless; as, a hurried job.","pos":""}],"HURRIER":[{"def":"One who hurries or urges.","pos":""}],"HURRIES":[{"def":"A staith or framework from which coal is discharged from cars into vessels.","pos":""}],"HURRY":[{"def":"To hasten; to impel to greater speed; to urge on.","pos":""},{"def":"To impel to precipitate or thoughtless action; to urge to confused or irregular activity.","pos":""}],"HURRY-SKURRY":[{"def":"Confusedly; in a bustle.","pos":""}],"HURRYINGLY":[{"def":"In a hurrying manner.","pos":""}],"HURST":[{"def":"A wood or grove; -- a word used in the composition of many names, as in Hazlehurst.","pos":""}],"HURT":[{"def":"To cause physical pain to; to do bodily harm to; to wound or bruise painfully.","pos":""},{"def":"To impar the value, usefulness, beauty, or pleasure of; to damage; to injure; to harm.","pos":""}],"HURTER":[{"def":"A bodily injury causing pain; a wound, bruise, or the like.","pos":""},{"def":"An injury causing pain of mind or conscience; a slight; a stain; as of sin.","pos":""}],"HURTFUL":[{"def":"Tending to impair or damage; injurious; mischievous; occasioning loss or injury; as, hurtful words or conduct.","pos":""}],"HURTLE":[{"def":"To meet with violence or shock; to clash; to jostle.","pos":""},{"def":"To move rapidly; to wheel or rush suddenly or with violence; to whirl round rapidly; to skirmish.","pos":""}],"HURTLEBERRY":[{"def":"See Whortleberry.","pos":""}],"HURTLESS":[{"def":"Doing no injury; harmless; also, unhurt; without injury or harm.","pos":""}]}