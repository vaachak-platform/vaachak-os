{"METASILICATE":[{"def":"A salt of metasilicic acid.","pos":""}],"METASILICIC":[{"def":"Designating an acid derived from silicic acid by the removal of water; of or pertaining to such an acid.","pos":""}],"METASOMATISM":[{"def":"An alteration in a mineral or rock mass when involving a chemical change of the substance, as of chrysolite to serpentine; -- opposed to ordinary metamorphism, as implying simply a recrystallization.","pos":""}],"METASOME":[{"def":"One of the component segments of the body of an animal.","pos":""}],"METASTANNATE":[{"def":"A salt of metastannic acid.","pos":""}],"METASTANNIC":[{"def":"Pertaining to, or designating, a compound of tin (metastannic acid), obtained, as an isomeric modification of stannic acid, in the form of a white amorphous substance.","pos":""}],"METASTASIS":[{"def":"A spiritual change, as during baptism.","pos":""},{"def":"A change in the location of a disease, as from one part to another.","pos":""}],"METASTATIC":[{"def":"Of, pertaining to, or caused by, metastasis; as, a metastatic abscess; the metastatic processes of growth.","pos":""}],"METASTERNAL":[{"def":"Of or pertaining to the metasternum.","pos":""}],"METASTERNUM":[{"def":"The most posterior element of the sternum; the ensiform process; xiphisternum.","pos":""},{"def":"The ventral plate of the third or last segment of the thorax of insects.","pos":""}]}