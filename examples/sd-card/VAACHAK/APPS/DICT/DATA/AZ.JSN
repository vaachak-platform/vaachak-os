{"AZALEA":[{"def":"A genus of showy flowering shrubs, mostly natives of China or of North America; false honeysuckle.","pos":""}],"AZAROLE":[{"def":"The Neapolitan medlar (Cratægus azarolus), a shrub of southern Europe; also, its fruit.","pos":""}],"AZEDARACH":[{"def":"A handsome Asiatic tree (Melia azedarach), common in the southern United States; -- called also, Pride of India, Pride of China, and Bead tree.","pos":""},{"def":"The bark of the roots of the azedarach, used as a cathartic and emetic.","pos":""}],"AZIMUTH":[{"def":"Note: In trigonometrical surveying, it is customary to reckon the azimuth of a line from the south point of the horizon around by the west from 0º to 360º.","pos":""}],"AZIMUTHAL":[{"def":"Of or pertaining to the azimuth; in a horizontal circle.","pos":""}],"AZO-":[{"def":"A combining form of azote; (a) Applied loosely to compounds having nitrogen variously combined, as in cyanides, nitrates, etc.","pos":""}],"AZOBENZENE":[{"def":"A substance (C6H5.","pos":""}],"AZOGUE":[{"def":"Silver ores suitable for treatment by amalgamation with mercury.","pos":""}],"AZOIC":[{"def":"Destitute of any vestige of organic life, or at least of animal life; anterior to the existence of animal life; formed when there was no animal life on the globe; as, the azoic.","pos":""}],"AZOLE":[{"def":"Any of a large class of compounds characterized by a five- membered ring which contains an atom of nitrogen and at least one other noncarbon atom (nitrogen, oxygen, sulphur).","pos":""}],"AZOLEIC":[{"def":"Pertaining to an acid produced by treating oleic with nitric acid.","pos":""}],"AZONIC":[{"def":"Confined to no zone or region; not local.","pos":""}],"AZORIAN":[{"def":"Of or pertaining to the Azores.","pos":""},{"def":"A native of the Azores.","pos":""}],"AZOTE":[{"def":"Same as Nitrogen.","pos":""}],"AZOTED":[{"def":"Nitrogenized; nitrogenous.","pos":""}],"AZOTIC":[{"def":"Pertaining to azote, or nitrogen; formed or consisting of azote; nitric; as, azotic gas; azotic acid.","pos":""},{"def":"An explosive consisting of sodium nitrate, charcoal, sulphur, and petroleum.","pos":""}],"AZOTITE":[{"def":"A salt formed by the combination of azotous, or nitrous, acid with a base; a nitrite.","pos":""}],"AZOTIZE":[{"def":"To impregnate with azote, or nitrogen; to nitrogenize.","pos":""}],"AZOTOMETER":[{"def":"An apparatus for measuring or determining the proportion of nitrogen; a nitrometer.","pos":""}],"AZOTOUS":[{"def":": Nitrous; as, azotous acid.","pos":""}],"AZOTURIA":[{"def":"Excess of urea or other nitrogenous substances in the urine.","pos":""}],"AZTEC":[{"def":"Of or relating to one of the early races in Mexico that inhabited the great plateau of that country at the time of the Spanish conquest in 1519.","pos":""},{"def":"One of the Aztec race or people.","pos":""}],"AZURE":[{"def":"Sky-blue; resembling the clear blue color of the unclouded sky; cerulean; also, cloudless.","pos":""}],"AZURED":[{"def":"Of an azure color; sky-blue.","pos":""}],"AZUREOUS":[{"def":"Of a fine blue color; azure.","pos":""}],"AZURINE":[{"def":"The blue roach of Europe (Leuciscus cæruleus); -- so called from its color.","pos":""}],"AZURITE":[{"def":"Blue carbonate of copper; blue malachite.","pos":""}],"AZURN":[{"def":"Thick set with agate, and the azurn sheen Of turkis blue, and emerald green.","pos":""}],"AZYGOUS":[{"def":"Odd; having no fellow; not one of a pair; single; as, the azygous muscle of the uvula.","pos":""},{"def":"Unleavened bread.","pos":""}],"AZYMITE":[{"def":"One who administered the Eucharist with unleavened bread; -- a name of reproach given by those of the Greek church to the Latins.","pos":""}],"AZYMOUS":[{"def":"Unleavened; unfermented.","pos":""},{"def":"is the second letter of the English alphabet.","pos":""}]}