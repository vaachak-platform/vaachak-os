{"CURL":[{"def":"To shape (the brim) into a curve.","pos":""}],"CURLED":[{"def":"Having curls; curly; sinuous; wavy; as, curled maple (maple having fibers which take a sinnuous course).","pos":""}],"CURLEDNESS":[{"def":"State of being curled; curliness.","pos":""}],"CURLER":[{"def":"One who, or that which, curls.","pos":""},{"def":"A player at the game called curling.","pos":""}],"CURLEW":[{"def":"A wading bird of the genus Numenius, remarkable for its long, slender, curved bill.","pos":""}],"CURLINESS":[{"def":"State of being curly.","pos":""}],"CURLING":[{"def":"The act or state of that which curls; as, the curling of smoke when it rises; the curling of a ringlet; also, the act or process of one who curls something, as hair, or the brim of hats.","pos":""},{"def":"A scottish game in which heavy weights of stone or iron are propelled by hand over the ice towards a mark.","pos":""}],"CURLINGLY":[{"def":"With a curl, or curls.","pos":""}],"CURLY":[{"def":"Curling or tending to curl; having curls; full of ripples; crinkled.","pos":""}],"CURLYCUE":[{"def":"Some thing curled or spiral,, as a flourish made with a pen on paper, or with skates on the ice; a trick; a frolicsome caper.","pos":""}]}