{"NAZARENE":[{"def":"One of a sect of Judaizing Christians in the first and second centuries, who observed the laws of Moses, and held to certain heresies.","pos":""}],"NAZARITE":[{"def":"A Jew bound by a vow to lave the hair uncut, to abstain from wine and strong drink, and to practice extraordinary purity of life and devotion, the obligation being for life, or for a certain time.","pos":""}],"NAZARITESHIP":[{"def":"The state of a Nazarite.","pos":""}],"NAZARITIC":[{"def":"Of or pertaining to a Nazarite, or to Nazarites.","pos":""}],"NAZARITISM":[{"def":"The vow and practice of a Nazarite.","pos":""}],"NAZE":[{"def":"A promotory or headland.","pos":""}]}