{"VEX":[{"def":"To to White curl the waves, and the vexed ocean roars.","pos":""},{"def":"To make angry or annoyed by little provocations; to irritate; to plague; to torment; to harass; to afflict; to trouble; to tease.","pos":""}],"VEXATION":[{"def":"The act of vexing, or the state of being vexed; agitation; disquiet; trouble; irritation.","pos":""},{"def":"The cause of trouble or disquiet; affliction.","pos":""}],"VEXATIOUS":[{"def":"Causing vexation; agitating; afflictive; annoying; as, a vexatious controversy; a vexatious neighbor.","pos":""},{"def":"Full or vexation, trouble, or disquiet; disturbed.","pos":""}],"VEXED":[{"def":"Annoyed; harassed; troubled.","pos":""},{"def":"Much debated or contested; causing discussion; as, a vexed question.","pos":""}],"VEXER":[{"def":"One who vexes or troubles.","pos":""}],"VEXIL":[{"def":"Of or pertaining to the vexillum, or upper petal of papilionaceous flowers.","pos":""}],"VEXILLARY":[{"def":"A standard bearer.","pos":""}],"VEXILLATION":[{"def":"A company of troops under one vexillum.","pos":""}],"VEXILLUM":[{"def":"The upper petal of a papilionaceous flower; the standard.","pos":""},{"def":"The rhachis and web of a feather taken together; the vane.","pos":""}],"VEXINGLY":[{"def":"In a vexing manner; so as to vex, tease, or irritate.","pos":""}]}