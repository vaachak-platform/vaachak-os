{"EQUABILITY":[{"def":"The quality or condition of being equable; evenness or uniformity; as, equability of temperature; the equability of the mind.","pos":""}],"EQUABLE":[{"def":"Equal and uniform; continuing the same at different times; -- said of motion, and the like; uniform in surface; smooth; as, an equable plain or globe.","pos":""},{"def":"Uniform in action or intensity; not variable or changing; -- said of the feelings or temper.","pos":""}],"EQUABLENESS":[{"def":"Quality or state of being equable.","pos":""}],"EQUABLY":[{"def":"In an equable manner.","pos":""}],"EQUAL":[{"def":"Intended for voices of one kind only, either all male or all female; -- opposed to mixed.","pos":""},{"def":"Exactly agreeing with respect to quantity.","pos":""}],"EQUALITARIAN":[{"def":"One who believes in equalizing the condition of men; a leveler.","pos":""}],"EQUALITY":[{"def":"Exact agreement between two expressions or magnitudes with respect to quantity; -- denoted by the symbol =; thus, a = x signifies that a contains the same number and kind of units of measure that x does.","pos":""}],"EQUALIZATION":[{"def":"The act of equalizing, or state of being equalized.","pos":""}],"EQUALIZE":[{"def":"To make equal; to cause to correspond, or be like, in amount or degree as compared; as, to equalize accounts, burdens, or taxes.","pos":""},{"def":"To pronounce equal; to compare as equal.","pos":""}],"EQUALIZER":[{"def":"One who, or that which, equalizes anything.","pos":""}],"EQUALLY":[{"def":"In an equal manner or degree in equal shares or proportion; with equal and impartial justice; without difference; alike; evenly; justly; as, equally taxed, furnished, etc.","pos":""}],"EQUALNESS":[{"def":"Equality; evenness.","pos":""}],"EQUANGULAR":[{"def":"Having equal angles; equiangular.","pos":""}],"EQUANIMITY":[{"def":"Evenness of mind; that calm temper or firmness of mind which is not easily elated or depressed; patience; calmness; composure; as, to bear misfortunes with equanimity.","pos":""}],"EQUANIMOUS":[{"def":"Of an even, composed frame of mind; of a steady temper; not easily elated or depressed.","pos":""}],"EQUANT":[{"def":"A circle around whose circumference a planet or the center of ann epicycle was conceived to move uniformly; -- called also eccentric equator.","pos":""}],"EQUATE":[{"def":"To make equal; to reduce to an average; to make such an allowance or correction in as will reduce to a common standard of comparison; to reduce to mean time or motion; as, to equate payments; to equate lines of railroad for grades or curves; equated distances.","pos":""}],"EQUATION":[{"def":"A making equal; equal division; equality; equilibrium.","pos":""}],"EQUATOR":[{"def":"The imaginary great circle on the earth's surface, everywhere equally distant from the two poles, and dividing the earth's surface into two hemispheres.","pos":""},{"def":"The great circle of the celestial sphere, coincident with the plane of the earth's equator; -- so called because when the sun is in it, the days and nights are of equal length; hence called also the equinoctial, and on maps, globes, etc.","pos":""}],"EQUATORIAL":[{"def":"Of or pertaining to the equator; as, equatorial climates; also, pertaining to an equatorial instrument.","pos":""}],"EQUATORIALLY":[{"def":"So as to have motion or direction parallel to the equator.","pos":""}],"EQUERRY":[{"def":"A large stable or lodge for horses.","pos":""},{"def":"An officer of princes or nobles, charged with the care of their horses.","pos":""}],"EQUERY":[{"def":"Same as Equerry.","pos":""}],"EQUESTRIAN":[{"def":"Of or pertaining to horses or horsemen, or to horsemanship; as, equestrian feats, or games.","pos":""},{"def":"Being or riding on horseback; mounted; as, an equestrian statue.","pos":""}],"EQUESTRIANISM":[{"def":"The art of riding on horseback; performance on horseback; horsemanship; as, feats equestrianism.","pos":""}],"EQUESTRIENNE":[{"def":"A woman skilled in equestrianism; a horsewoman.","pos":""}],"EQUI-":[{"def":"A prefix, meaning equally; as, equidistant; equiangular.","pos":""}],"EQUIANGULAR":[{"def":"Having equal angles; as, an equiangular figure; a square is equiangular.","pos":""}],"EQUIBALANCE":[{"def":"Equal weight; equiponderance.","pos":""}],"EQUICRESCENT":[{"def":"Increasing by equal increments; as, an equicrescent variable.","pos":""}],"EQUICRURAL":[{"def":"Having equal legs or sides; isosceles.","pos":""}],"EQUIDIFFERENT":[{"def":"Having equal differences; as, the terms of arithmetical progression are equidifferent.","pos":""}],"EQUIDISTANT":[{"def":"Being at an equal distance from the same point or thing.","pos":""}],"EQUIDIURNAL":[{"def":"Pertaining to the time of equal day and night; -- applied to the equinoctial line.","pos":""}],"EQUIFORM":[{"def":"Having the same form; uniform.","pos":""}],"EQUILATERAL":[{"def":"Having all the sides equal; as, an equilateral triangle; an equilateral polygon.","pos":""}],"EQUILIBRATE":[{"def":"To balance two scales, sides, or ends; to keep even with equal weight on each side; to keep in equipoise.","pos":""}],"EQUILIBRATION":[{"def":"The process by which animal and vegetable organisms preserve a physiological balance.","pos":""}],"EQUILIBRIOUS":[{"def":"Evenly poised; balanced.","pos":""}],"EQUILIBRIST":[{"def":"One who balances himself in unnatural positions and hazardous movements; a balancer.","pos":""}],"EQUILIBRITY":[{"def":"The state of being balanced; equality of weight.","pos":""}],"EQUILIBRIUM":[{"def":"Equality of weight or force; an equipoise or a state of rest produced by the mutual counteraction of two or more forces.","pos":""},{"def":"A level position; a just poise or balance in respect to an object, so that it remains firm; equipoise; as, to preserve the equilibrium of the body.","pos":""}],"EQUIMOMENTAL":[{"def":"Having equal moments of inertia.","pos":""}],"EQUIMULTIPLE":[{"def":"Multiplied by the same number or quantity.","pos":""}],"EQUINE":[{"def":"Of, pertaining to, or resembling, a horse.","pos":""}],"EQUINOCTIAL":[{"def":"Pertaining to an equinox, or the equinoxes, or to the time of equal day and night; as, the equinoctial line.","pos":""},{"def":"Pertaining to the regions or climate of the equinoctial line or equator; in or near that line; as, equinoctial heat; an equinoctial sun.","pos":""}],"EQUINOCTIALLY":[{"def":"Towards the equinox.","pos":""}],"EQUINOX":[{"def":"The time when the sun enters one of the equinoctial points, that is, about March 21 and September 22.","pos":""},{"def":"Equinoctial wind or storm.","pos":""}],"EQUINUMERANT":[{"def":"Equal as to number.","pos":""}],"EQUIP":[{"def":"To furnish for service, or against a need or exigency; to fit out; to supply with whatever is necessary to efficient action in any way; to provide with arms or an armament, stores, munitions, rigging, etc.","pos":""},{"def":"To dress up; to array; accouter.","pos":""}],"EQUIPAGE":[{"def":"Retinue; train; suite.","pos":""}],"EQUIPAGED":[{"def":"Furnished with equipage.","pos":""}],"EQUIPEDAL":[{"def":"Equal-footed; having the pairs of feet equal.","pos":""}],"EQUIPENDENCY":[{"def":"The act or condition of hanging in equipoise; not inclined or determined either way.","pos":""}],"EQUIPENSATE":[{"def":"To weigh equally; to esteem alike.","pos":""}],"EQUIPMENT":[{"def":"The act of equipping, or the state of being equipped, as for a voyage or expedition.","pos":""},{"def":"Whatever is used in equipping; necessaries for an expedition or voyage; the collective designation for the articles comprising an outfit; equipage; as, a railroad equipment (locomotives, cars, etc.","pos":""}],"EQUIPOISE":[{"def":"Sameness of signification of two or more propositions which differ in language.","pos":""}],"EQUIPOLLENT":[{"def":"Having equivalent signification and reach; expressing the same thing, but differently.","pos":""}],"EQUIPOLLENTLY":[{"def":"With equal power.","pos":""},{"def":"Equality of weight; equipoise.","pos":""}],"EQUIPONDERANT":[{"def":"Being of the same weight.","pos":""}],"EQUIPONDERATE":[{"def":"To be equal in weight; to weigh as much as another thing.","pos":""}],"EQUIPONDEROUS":[{"def":"Having equal weight.","pos":""}],"EQUIPONDIOUS":[{"def":"Of equal weight on both sides; balanced.","pos":""}],"EQUIPOTENTIAL":[{"def":"Having the same potential.","pos":""}],"EQUIRADICAL":[{"def":"Equally radical.","pos":""}],"EQUIROTAL":[{"def":"Having wheels of the same size or diameter; having equal rotation.","pos":""}],"EQUISETACEOUS":[{"def":"Belonging to the Equisetaceæ, or Horsetail family.","pos":""}],"EQUISETIFORM":[{"def":"Having the form of the equisetum.","pos":""}],"EQUISETUM":[{"def":"A genus of vascular, cryptogamic, herbaceous plants; -- also called horsetails.","pos":""}],"EQUISONANCE":[{"def":"An equal sounding; the consonance of the unison and its octaves.","pos":""}],"EQUISONANT":[{"def":"Of the same or like sound.","pos":""}],"EQUITABLE":[{"def":"That can be sustained or made available or effective in a court of equity, or upon principles of equity jurisprudence; as, an equitable estate; equitable assets, assignment, mortgage, etc.","pos":""}],"EQUITABLENESS":[{"def":"The quality of being equitable, just, or impartial; as, the equitableness of a judge, a decision, or distribution of property.","pos":""}],"EQUITABLY":[{"def":"In an equitable manner; justly; as, the laws should be equitably administered.","pos":""}],"EQUITANT":[{"def":"Overlapping each other; -- said of leaves whose bases are folded so as to overlap and bestride the leaves within or above them, as in the iris.","pos":""}],"EQUITATION":[{"def":"A riding, or the act of riding, on horseback; horsemanship.","pos":""}],"EQUITEMPORANEOUS":[{"def":"Contemporaneous.","pos":""}],"EQUITES":[{"def":"An order of knights holding a middle place between the senate and the commonalty; members of the Roman equestrian order.","pos":""}],"EQUITY":[{"def":"An equitable claim; an equity of redemption; as, an equity to a settlement, or wife's equity, etc.","pos":""},{"def":"A system of jurisprudence, supplemental to law, properly so called, and complemental of it.","pos":""}],"EQUIVALENCE":[{"def":"The condition of being equivalent or equal; equality of worth, value, signification, or force; as, an equivalence of definitions.","pos":""},{"def":"Equal power or force; equivalent amount.","pos":""}],"EQUIVALENCY":[{"def":"Same as Equivalence.","pos":""}],"EQUIVALENT":[{"def":"Equal in measure but not admitting of superposition; -- applied to magnitudes; as, a square may be equivalent to a triangle.","pos":""},{"def":"Contemporaneous in origin; as, the equivalent strata of different countries.","pos":""}],"EQUIVALENTLY":[{"def":"In an equal manner.","pos":""}],"EQUIVALUE":[{"def":"To put an equal value upon; to put (something) on a par with another thing.","pos":""},{"def":"Having the valves equal in size and from, as in most bivalve shells.","pos":""}],"EQUIVALVULAR":[{"def":"Same as Equivalve or Equivalved.","pos":""}],"EQUIVOCAL":[{"def":"Capable of being ascribed to different motives, or of signifying opposite feelings, purposes, or characters; deserving to be suspected; as, his actions are equivocal.","pos":""},{"def":"Uncertain, as an indication or sign; doubtful.","pos":""}],"EQUIVOCALLY":[{"def":"In an equivocal manner.","pos":""}],"EQUIVOCALNESS":[{"def":"The state of being equivocal.","pos":""}],"EQUIVOCATE":[{"def":"To use words of equivocal or doubtful signification; to express one's opinions in terms which admit of different senses, with intent to deceive; to use ambiguous expressions with a view to mislead; as, to equivocate is the work of duplicity.","pos":""}],"EQUIVOCATION":[{"def":"The use of expressions susceptible of a double signification, with a purpose to mislead.","pos":""}],"EQUIVOCATOR":[{"def":"One who equivocates.","pos":""}],"EQUIVOCATORY":[{"def":"Indicating, or characterized by, equivocation.","pos":""}],"EQUIVOROUS":[{"def":"Feeding on horseflesh; as, equivorous Tartars.","pos":""}],"EQUUS":[{"def":"A genus of mammals, including the horse, ass, etc.","pos":""}]}