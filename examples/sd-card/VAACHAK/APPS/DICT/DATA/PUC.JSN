{"PUCCOON":[{"def":"Any one of several plants yielding a red pigment which is used by the North American Indians, as the bloodroot and two species of Lithospermum (L.","pos":""}],"PUCE":[{"def":"Of a dark brown or brownish purple color.","pos":""}],"PUCELLE":[{"def":"A maid; a virgin.","pos":""}],"PUCERON":[{"def":"Any plant louse, or aphis.","pos":""}],"PUCHERITE":[{"def":"Vanadate of bismuth, occurring in minute reddish brown crystals.","pos":""}],"PUCK":[{"def":"A celebrated fairy, \"the merry wanderer of the night;\" -- called also Robin Goodfellow, Friar Rush, Pug, etc.","pos":""}],"PUCKA":[{"def":"Good of its kind; -- variously used as implying substantial, real, fixed, sure, etc.","pos":""}],"PUCKER":[{"def":"To gather into small folds or wrinkles; to contract into ridges and furrows; to corrugate; -- often with up; as, to pucker up the mouth.","pos":""}],"PUCKERER":[{"def":"One who, or that which, puckers.","pos":""}],"PUCKERY":[{"def":"Producing, or tending to produce, a pucker; as, a puckery taste.","pos":""},{"def":"Inclined to become puckered or wrinkled; full of puckers or wrinkles.","pos":""}],"PUCKISH":[{"def":"Resembling Puck; merry; mischievous.","pos":""}]}