{"GEAN":[{"def":"A species of cherry tree common in Europe (Prunus avium); also, the fruit, which is usually small and dark in color.","pos":""}],"GEANTICLINAL":[{"def":"An upward bend or flexure of a considerable portion of the earth's crust, resulting in the formation of a class of mountain elevations called anticlinoria; -- opposed to geosynclinal.","pos":""}],"GEAR":[{"def":"See 1st Jeer (b).","pos":""}],"GEARING":[{"def":"The parts by which motion imparted to one portion of an engine or machine is transmitted to another, considered collectively; as, the valve gearing of locomotive engine; belt gearing; esp.","pos":""}],"GEASON":[{"def":"Rare; wonderful.","pos":""}],"GEAT":[{"def":"The channel or spout through which molten metal runs into a mold in casting.","pos":""}]}