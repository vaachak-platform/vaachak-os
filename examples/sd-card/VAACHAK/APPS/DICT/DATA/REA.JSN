{"REABSORB":[{"def":"To absorb again; to draw in, or imbibe, again what has been effused, extravasated, or thrown off; to swallow up again; as, to reabsorb chyle, lymph, etc.","pos":""}],"REABSORPTION":[{"def":"The act or process of rearbsorbing.","pos":""}],"REACCESS":[{"def":"A second access or approach; a return.","pos":""}],"REACCUSE":[{"def":"To accuse again.","pos":""}],"REACH":[{"def":"An effort to vomit.","pos":""}],"REACHABLE":[{"def":"Being within reach.","pos":""}],"REACHER":[{"def":"One who reaches.","pos":""},{"def":"An exaggeration.","pos":""}],"REACHLESS":[{"def":"Being beyond reach; lofty.","pos":""}],"REACT":[{"def":"To act or perform a second time; to do over again; as, to react a play; the same scenes were reacted at Rome.","pos":""}],"REACTANCE":[{"def":"The influence of a coil of wire upon an alternating current passing through it, tending to choke or diminish the current, or the similar influence of a condenser; inductive resistance.","pos":""}],"REACTION":[{"def":"An action included by vital resistance to some other action; depression or exhaustion of vital force consequent on overexertion or overstimulation; heightened activity and overaction succeeding depression or shock.","pos":""}],"REACTIONARY":[{"def":"Being, causing, or favoring reaction; as, reactionary movements.","pos":""}],"REACTIVE":[{"def":"Having power to react; tending to reaction; of the nature of reaction.","pos":""}],"READ":[{"def":"To advise; to counsel.","pos":""},{"def":"To interpret; to explain; as, to read a riddle.","pos":""}],"READABILITY":[{"def":"The state of being readable; readableness.","pos":""}],"READABLE":[{"def":"Such as can be read; legible; fit or suitable to be read; worth reading; interesting.","pos":""}],"READDRESS":[{"def":"To address a second time; -- often used reflexively.","pos":""}],"READEPT":[{"def":"To regain; to recover.","pos":""}],"READEPTION":[{"def":"A regaining; recovery of something lost.","pos":""}],"READER":[{"def":"One who reads much; one who is studious.","pos":""}],"READERSHIP":[{"def":"The office of reader.","pos":""}],"READILY":[{"def":"In a ready manner; quickly; promptly.","pos":""},{"def":"Without delay or objection; without reluctance; willingly; cheerfully.","pos":""}],"READINESS":[{"def":"The state or quality of being ready; preparation; promptness; aptitude; willingness.","pos":""}],"READING":[{"def":"The act of one who reads; perusal; also, printed or written matter to be read.","pos":""},{"def":"Study of books; literary scholarship; as, a man of extensive reading.","pos":""}],"READJOURN":[{"def":"To adjourn a second time; to adjourn again.","pos":""}],"READJOURNMENT":[{"def":"The act of readjourning; a second or repeated adjournment.","pos":""}],"READJUST":[{"def":"To adjust or settle again; to put in a different order or relation; to rearrange.","pos":""}],"READJUSTER":[{"def":"One who, or that which, readjusts; in some of the States of the United States, one who advocates a refunding, and sometimes a partial repudiation, of the State debt without the consent of the State's creditors.","pos":""}],"READJUSTMENT":[{"def":"A second adjustment; a new or different adjustment.","pos":""}],"READMISSION":[{"def":"The act of admitting again, or the state of being readmitted; as, the readmission fresh air into an exhausted receiver; the readmission of a student into a seminary.","pos":""}],"READMIT":[{"def":"To admit again; to give entrance or access to again.","pos":""}],"READMITTANCE":[{"def":"Allowance to enter again; a second admission.","pos":""}],"READORN":[{"def":"To adorn again or anew.","pos":""}],"READVANCE":[{"def":"To advance again.","pos":""}],"READVERTENCY":[{"def":"The act of adverting to again, or of reviewing.","pos":""}],"READY":[{"def":"A word of command, or a position, in the manual of arms, at which the piece is cocked and held in position to execute promptly the next command, which is, aim.","pos":""}],"READY-MADE":[{"def":"Made already, or beforehand, in anticipation of need; not made to order; as, ready-made clothing; ready-made jokes.","pos":""}],"READY-WITTED":[{"def":"Having ready wit.","pos":""}],"REAFFIRM":[{"def":"To affirm again.","pos":""},{"def":"A second affirmation.","pos":""}],"REAFFOREST":[{"def":"To convert again into the forest, as a region of country.","pos":""}],"REAFFORESTATION":[{"def":"The act or process of converting again into a forest.","pos":""}],"REAGENT":[{"def":"A substance capable of producing with another a reaction, especially when employed to detect the presence of other bodies; a test.","pos":""}],"REAGGRAVATION":[{"def":"The last monitory, published after three admonitions and before the last excommunication.","pos":""}],"REAL":[{"def":"A small Spanish silver coin; also, a denomination of money of account, formerly the unit of the Spanish monetary system.","pos":""}],"REALGAR":[{"def":"Arsenic sulphide, a mineral of a brilliant red color; red orpiment.","pos":""}],"REALISM":[{"def":"Fidelity to nature or to real life; representation without idealization, and making no appeal to the imagination; adherence to the actual fact.","pos":""}],"REALIST":[{"def":"One who believes in realism; esp.","pos":""},{"def":"An artist or writer who aims at realism in his work.","pos":""}],"REALISTIC":[{"def":"Of or pertaining to the realists; in the manner of the realists; characterized by realism rather than by imagination.","pos":""}],"REALISTICALLY":[{"def":"In the realistic manner.","pos":""}],"REALITY":[{"def":"Loyalty; devotion.","pos":""},{"def":"See 2d Realty, 2.","pos":""}],"REALIZABLE":[{"def":"Capable of being realized.","pos":""}],"REALIZATION":[{"def":"The act of realizing, or the state of being realized.","pos":""}],"REALIZE":[{"def":"To make real; to convert from the imaginary or fictitious into the actual; to bring into concrete existence; to accomplish; as, to realize a scheme or project.","pos":""},{"def":"To cause to seem real; to impress upon the mind as actual; to feel vividly or strongly; to make one's own in apprehension or experience.","pos":""}],"REALIZER":[{"def":"One who realizes.","pos":""}],"REALIZING":[{"def":"Serving to make real, or to impress on the mind as a reality; as, a realizing view of the danger incurred.","pos":""}],"REALLEGE":[{"def":"To allege again.","pos":""}],"REALLIANCE":[{"def":"A renewed alliance.","pos":""}],"REALLY":[{"def":"In a real manner; with or in reality; actually; in truth.","pos":""}],"REALM":[{"def":"A royal jurisdiction or domain; a region which is under the dominion of a king; a kingdom.","pos":""},{"def":"Hence, in general, province; region; country; domain; department; division; as, the realm of fancy.","pos":""}],"REALMLESS":[{"def":"Destitute of a realm.","pos":""}],"REALNESS":[{"def":"The quality or condition of being real; reality.","pos":""}],"REALTY":[{"def":"Loyalty; faithfulness.","pos":""}],"REAM":[{"def":"Cream; also, the cream or froth on ale.","pos":""}],"REAMER":[{"def":"One who, or that which, reams; specifically, an instrument with cutting or scraping edges, used, with a twisting motion, for enlarging a round hole, as a bore of a cannon, etc.","pos":""}],"REAMPUTATION":[{"def":"The second of two amputations performed upon the same member.","pos":""}],"REANIMATE":[{"def":"To animate anew; to restore to animation or life; to infuse new life, vigor, spirit, or courage into; to revive; to reinvigorate; as, to reanimate a drowned person; to reanimate disheartened troops; to reanimate languid spirits.","pos":""}],"REANIMATION":[{"def":"The act or operation of reanimating, or the state of being reanimated; reinvigoration; revival.","pos":""}],"REANNEX":[{"def":"To annex again or anew; to reunite.","pos":""}],"REANNEXATION":[{"def":"Act of reannexing.","pos":""}],"REANSWER":[{"def":"To answer in return; to repay; to compensate; to make amends for.","pos":""}],"REAP":[{"def":"To cut with a sickle, scythe, or reaping machine, as grain; to gather, as a harvest, by cutting.","pos":""},{"def":"To gather; to obtain; to receive as a reward or harvest, or as the fruit of labor or of works; -- in a good or a bad sense; as, to reap a benefit from exertions.","pos":""}],"REAPER":[{"def":"A reaping machine.","pos":""}],"REAPPAREL":[{"def":"To clothe again.","pos":""}],"REAPPEAR":[{"def":"To appear again.","pos":""}],"REAPPEARANCE":[{"def":"A second or new appearance; the act or state of appearing again.","pos":""}],"REAPPLICATION":[{"def":"The act of reapplying, or the state of being reapplied.","pos":""}],"REAPPOINT":[{"def":"To appoint again.","pos":""}],"REAPPOINTMENT":[{"def":"The act of reappointing, or the state of being reappointed.","pos":""}],"REAPPORTION":[{"def":"To apportion again.","pos":""}],"REAPPORTIONMENT":[{"def":"A second or a new apportionment.","pos":""}],"REAPPROACH":[{"def":"To approach again or anew.","pos":""}],"REAR":[{"def":"Then why does Cuddy leave his cot so rear! Gay.","pos":""}],"REARER":[{"def":"One he, or that which, rears.","pos":""}],"REARGUE":[{"def":"To argue anew or again.","pos":""}],"REARGUMENT":[{"def":"An arguing over again, as of a motion made in court.","pos":""}],"REARMOST":[{"def":"Farthest in the rear; last.","pos":""},{"def":"The leather-winged bat (Vespertilio murinus).","pos":""}],"REARRANGE":[{"def":"To arrange again; to arrange in a different way.","pos":""}],"REARRANGEMENT":[{"def":"The act of rearranging, or the state of being rearranged.","pos":""}],"REARWARD":[{"def":"The last troop; the rear of an army; a rear guard.","pos":""}],"REASCEND":[{"def":"To rise, mount, or climb again.","pos":""}],"REASCENSION":[{"def":"The act of reascending; a remounting.","pos":""}],"REASCENT":[{"def":"A returning ascent or ascension; acclivity.","pos":""}],"REASON":[{"def":"Ratio; proportion.","pos":""}],"REASONABLE":[{"def":"Having the faculty of reason; endued with reason; rational; as, a reasonable being.","pos":""},{"def":"Governed by reason; being under influence of reason; thinking, speaking or acting rationally, or according to the dictates of reason; agreeable to reason; just; rational; as, the measure must satisfy all reasonable men.","pos":""}],"REASONABLENESS":[{"def":"Quality of being reasonable.","pos":""}],"REASONABLY":[{"def":"In a reasonable manner.","pos":""},{"def":"Moderately; tolerably.","pos":""}],"REASONER":[{"def":"One who reasons or argues; as, a fair reasoner; a close reasoner; a logical reasoner.","pos":""}],"REASONING":[{"def":"The act or process of adducing a reason or reasons; manner of presenting one's reasons.","pos":""},{"def":"That which is offered in argument; proofs or reasons when arranged and developed; course of argument.","pos":""}],"REASONIST":[{"def":"Such persons are now commonly called \"reasonists\" and \"rationalists,\" to distinguish them from true reasoners and rational inquirers.","pos":""}],"REASONLESS":[{"def":"Destitute of reason; as, a reasonless man or mind.","pos":""},{"def":"Void of reason; not warranted or supported by reason; unreasonable.","pos":""}],"REASSEMBLAGE":[{"def":"Assemblage a second time or again.","pos":""}],"REASSEMBLE":[{"def":"To assemble again.","pos":""}],"REASSERT":[{"def":"To assert again or anew; to maintain after an omission to do so.","pos":""}],"REASSERTION":[{"def":"A second or renewed assertion of the same thing.","pos":""}],"REASSESSMENT":[{"def":"A renewed or second assessment.","pos":""}],"REASSIGN":[{"def":"To assign back or again; to transfer back what has been assigned.","pos":""}],"REASSIGNMENT":[{"def":"The act of reassigning.","pos":""}],"REASSIMILATE":[{"def":"To assimilate again.","pos":""}],"REASSOCIATE":[{"def":"To associate again; to bring again into close relatoins.","pos":""}],"REASSUME":[{"def":"To assume again or anew; to resume.","pos":""}],"REASSURANCE":[{"def":"Same as Reinsurance.","pos":""}],"REASSURE":[{"def":"To assure anew; to restore confidence to; to free from fear or terror.","pos":""}],"REASSURER":[{"def":"One who reassures.","pos":""}],"REASTY":[{"def":"Rusty and rancid; -- applied to salt meat.","pos":""}],"REATTACH":[{"def":"To attach again.","pos":""}],"REATTACHMENT":[{"def":"The act of reattaching; a second attachment.","pos":""}],"REATTAIN":[{"def":"To attain again.","pos":""}],"REATTAINMENT":[{"def":"The act of reattaining.","pos":""}],"REATTEMPT":[{"def":"To attempt again.","pos":""}],"REAUMUR":[{"def":"Of or pertaining to René Antoine Ferchault de Réaumur; conformed to the scale adopted by Réaumur in graduating the thermometer he invented.","pos":""},{"def":"A Réaumur thermometer or scale.","pos":""}],"REAVE":[{"def":"To take away by violence or by stealth; to snatch away; to rob; to despoil; to bereave.","pos":""}]}