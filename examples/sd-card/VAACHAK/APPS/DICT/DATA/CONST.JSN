{"CONSTABLE":[{"def":"An officer of the peace having power as a conservator of the public peace, and bound to exeute the warrants of judicial offiers.","pos":""}],"CONSTABLERY":[{"def":"The constabulary.","pos":""},{"def":"The distrit or jurisdiction of a constable.","pos":""}],"CONSTABLESHIP":[{"def":"The office or functions of a constable.","pos":""}],"CONSTABLESS":[{"def":"The wife of a constable.","pos":""}],"CONSTABLEWICK":[{"def":"The district to which a constable's power is limited.","pos":""}],"CONSTABULARY":[{"def":"Of or pertaining to constables; consisting of constables.","pos":""}],"CONSTABULATORY":[{"def":"Con*stab\"u*la*to*ry, n.","pos":""}],"CONSTANCY":[{"def":"The state or quality of being constant or steadfast; freedom from hange; stability; fixedness; immutabilitu; asm the constancy of God in his nature and attributes.","pos":""},{"def":"Fixedness or firmness of mind; persevering resolution; especially, firmness of mind under sufferings, steadiness in attashments, or perseverance in enterprise; stability; fidelity.","pos":""}],"CONSTANT":[{"def":"Remaining unchanged or invariable, as a quantity, forc, law, etc.","pos":""}],"CONSTANTIA":[{"def":"A superior wine, white and red, from Constantia, in Cape Colony.","pos":""}],"CONSTANTLY":[{"def":"With constancy; steadily; continually; perseveringly; without cessation; uniformly.","pos":""}],"CONSTAT":[{"def":"A certificate showing what appears upon record touching a matter in question.","pos":""}],"CONSTATE":[{"def":"To ascertain; to verify; to establish; to prove.","pos":""}],"CONSTELLATE":[{"def":"To join luster; to shine with united radiance, or one general light.","pos":""}],"CONSTELLATION":[{"def":"A cluster or group of fixed stars, or dvision of the heavens, designated in most cases by the name of some animal, or of some mythologial personage, within whose imaginary outline, as traced upon the heavens, the group is included.","pos":""},{"def":"An assemblage of splendors or excellences.","pos":""}],"CONSTERNATION":[{"def":"Amazement or horror that confounds the faculties, and incapacitates for refletion; terror, combined with amaxement; dismay.","pos":""}],"CONSTIPATE":[{"def":"To render costive; to cause constipation in.","pos":""}],"CONSTIPATION":[{"def":"Act of crowding anything into a less compass, or the state of being crowded or pressed together; condensation.","pos":""},{"def":"A state of the bowels in which the evacuations are infrequent and difficult, or the intestines become filled with hardened faces; costiveness.","pos":""}],"CONSTITUENCY":[{"def":"A body of constituents, as the body of citizens or voters in a representative district.","pos":""}],"CONSTITUENT":[{"def":"Serving to form, compose, or make up; elemental; component.","pos":""},{"def":"Having the power of electing or appointing.","pos":""}],"CONSTITUTE":[{"def":"To cause to stand; to establish; to enact.","pos":""},{"def":"To make up; to compose; to form.","pos":""}],"CONSTITUTER":[{"def":"One who constitutes or appoints.","pos":""}],"CONSTITUTION":[{"def":"The act or process of constituting; the action of enacting, establishing, or appointing; enactment; establishment; formation.","pos":""},{"def":"The state of being; that form of being, or structure and connection of parts, which constitutes and characterizes a system or body; natural condition; structure; texture; conformation.","pos":""}],"CONSTITUTIONAL":[{"def":"Belonging to, or inherent in, the constitution, or in the structure of body or mind; as, a constitutional infirmity; constitutional ardor or dullness.","pos":""},{"def":"In accordance with, or authorized by, the constitution of a state or a society; as, constitutional reforms.","pos":""}],"CONSTITUTIONALISM":[{"def":"The theory, principles, or authority of constitutional government; attachment or adherene to a constitution or constitutional government.","pos":""}],"CONSTITUTIONALIST":[{"def":"One who advocates a constitutional form of government; a constitutionalist.","pos":""}],"CONSTITUTIONALITY":[{"def":"The quality or state of being constitutional, or inherent in the natural frame.","pos":""},{"def":"The state of being consistent with the constitution or frame of government, or of being authorized by its provisions.","pos":""}],"CONSTITUTIONALLY":[{"def":"In accordance with the constitution or natural disposition of the mind or body; naturally; as, he was constitutionally timid.","pos":""},{"def":"In accordance with the constitution or fundamental law; legally; as, he was not constitutionally appointed.","pos":""}],"CONSTITUTIONIST":[{"def":"One who adheres to the constitution of the country.","pos":""}],"CONSTITUTIVE":[{"def":"Tending or assisting to constitute or compose; elemental; essential.","pos":""},{"def":"Having power to enact, establish, or create; instituting; determining.","pos":""}],"CONSTITUTIVELY":[{"def":"In a constitutive manner.","pos":""}],"CONSTRAIN":[{"def":"To secure by bonds; to chain; to bond or con He binds in hains The droway prophet, and his limbs constrains.","pos":""},{"def":"To bring into a narrow compass; to compress.","pos":""}],"CONSTRAINABLE":[{"def":"Capable of being constrained; liable to constraint, or to restraint.","pos":""}],"CONSTRAINED":[{"def":"Marked by constraint; not free; not voluntary; embarrassed; as, a constrained manner; a constrained tone.","pos":""}],"CONSTRAINEDLY":[{"def":"By constraint or compulsion; in a constrained manner.","pos":""}],"CONSTRAINER":[{"def":"One who constrains.","pos":""}],"CONSTRAINT":[{"def":"The act of constraining, or the state of being constrained; that which compels to, or restrains from, action; compulsion; restraint; necessity.","pos":""}],"CONSTRAINTIVE":[{"def":"Constraining; compulsory.","pos":""}],"CONSTRICT":[{"def":"To draw together; to render narrower or smaller; to bind; to cramp; to contract or ause to shrink.","pos":""}],"CONSTRICTED":[{"def":"Contracted or compressed so as to be smaller in certain places or parts than in others.","pos":""}],"CONSTRICTION":[{"def":"The act of constricting by means of some inherent power or by movement or change in the thing itself, as distinguished from compression.","pos":""},{"def":"The state of being constricted; the point where a thing is constricted; a narrowing or binding.","pos":""}],"CONSTRICTIVE":[{"def":"Serving or tending to bind or constrict.","pos":""}],"CONSTRICTOR":[{"def":"A muscle which contracts or closes an orifice, or which compresses an organ; a sphincter.","pos":""},{"def":"A serpent that kills its prey by inclosing and crushing it with its folds; as, the boa constrictor.","pos":""}],"CONSTRINGE":[{"def":"To dawn together; to contract; to force to contract itself; to constrict; to cause to shrink.","pos":""}],"CONSTRINGENT":[{"def":"Having the quality of contracting, binding, or compressing.","pos":""}],"CONSTRUCT":[{"def":"To put together the constituent parts of (something) in their proper place and order; to build; to form; to make; as, to construct an edlifice.","pos":""},{"def":"To devise; to invent; to set in order; to arrange; as, to construct a theory of ethics.","pos":""}],"CONSTRUCTER":[{"def":"One who, or that which, constructs or frames.","pos":""}],"CONSTRUCTION":[{"def":"The arrangement and connection of words in a sentence; syntactical arrangement.","pos":""}],"CONSTRUCTIONAL":[{"def":"Pertaining to, or deduced from, construction or interpretation.","pos":""}],"CONSTRUCTIONIST":[{"def":"One who puts a certain construction upon some writing or instrument, as the Constitutions of the United States; as, a strict constructionist; a broad constructionist.","pos":""}],"CONSTRUCTIVE":[{"def":"Having ability to construct or form; employed in construction; as, to exhibit constructive power.","pos":""},{"def":"Derived from, or depending on, construction or interpretation; not directly expressed, but inferred.","pos":""}],"CONSTRUCTIVELY":[{"def":"In a constructive manner; by construction or inference.","pos":""}],"CONSTRUCTIVENESS":[{"def":"The faculty which enables one to construct, as in mechanical, artistic, or literary matters.","pos":""}],"CONSTRUCTURE":[{"def":"That which is constructed or formed; an edifice; a fabric.","pos":""}],"CONSTRUE":[{"def":"To apply the rules of syntax to (a sentence or clause) so as to exhibit the structure, arrangement, or connection of, or to discover the sense; to explain the construction of; to interpret; to translate.","pos":""},{"def":"To put a construction upon; to explain the sense or intention of; to interpret; to understand.","pos":""}],"CONSTUPRATE":[{"def":"To ravish; to debauch.","pos":""}],"CONSTUPRATION":[{"def":"The act of ravishing; violation; defilement.","pos":""}]}