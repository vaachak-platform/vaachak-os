{"RE":[{"def":"A syllable applied in solmization to the second tone of the diatonic scale of C; in the American system, to the second tone of any diatonic scale.","pos":""}],"RE-":[{"def":"A prefix signifying back, against, again, anew; as, recline, to lean back; recall, to call back; recede; remove; reclaim, to call out against; repugn, to fight against; recognition, a knowing again; rejoin, to join again; reiterate, reassure.","pos":""}],"RE-ALLY":[{"def":"To bring together again; to compose or form anew.","pos":""}],"RE-COLLECT":[{"def":"To collect again; to gather what has been scattered; as, to re- collect routed troops.","pos":""}],"RE-CREATE":[{"def":"To create or form anew.","pos":""}],"RE-CREATION":[{"def":"A forming anew; a new creation or formation.","pos":""}],"RE-CREATIVE":[{"def":"Creating anew; as, re-creative power.","pos":""}],"RE-DEMPTION":[{"def":"The act of redeeming, or the state of being redeemed; repurchase; ransom; release; rescue; deliverance; as, the redemption of prisoners taken in war; the redemption of a ship and cargo.","pos":""}],"RE-FERMENT":[{"def":"To ferment, or cause to ferment, again.","pos":""}],"RE-FORM":[{"def":"To give a new form to; to form anew; to take form again, or to take a new form; as, to re-form the line after a charge.","pos":""}],"RE-FORMATION":[{"def":"The act of forming anew; a second forming in order; as, the reformation of a column of troops into a hollow square.","pos":""}],"RE-LET":[{"def":"To let anew, as a hous.","pos":""},{"def":"Sufficiency to infer the conclusion.","pos":""}],"RE-MARK":[{"def":"To mark again, or a second time; to mark anew.","pos":""}],"RE-PRESENT":[{"def":"To present again; as, to re-present the points of an argument.","pos":""}],"RE-PRESENTATION":[{"def":"The act of re-presenting, or the state of being presented again; a new presentation; as, re-presentation of facts previously stated.","pos":""}],"RE-REITERATE":[{"def":"To reiterate many times.","pos":""}],"RE-RESOLVE":[{"def":"To resolve again.","pos":""}],"RE-SEARCH":[{"def":"To search again; to examine anew.","pos":""}],"RE-SIGN":[{"def":"To affix one's signature to, a second time; to sign again.","pos":""}],"RE-SOUND":[{"def":"To sound again or anew.","pos":""}],"RE-STORE":[{"def":"To store again; as, the goods taken out were re-stored.","pos":""}]}