{"LOO":[{"def":"Loo table, a round table adapted for a circle of persons playing loo.","pos":""}],"LOOB":[{"def":"The clay or slimes washed from tin ore in dressing.","pos":""}],"LOOBILY":[{"def":"Loobylike; awkward.","pos":""}],"LOOBY":[{"def":"An awkward, clumsy fellow; a lubber.","pos":""}],"LOOF":[{"def":"The spongelike fibers of the fruit of a cucurbitaceous plant (Luffa Ægyptiaca); called also vegetable sponge.","pos":""}],"LOOK":[{"def":"To direct the eyes for the purpose of seeing something; to direct the eyes toward an object; to observe with the eyes while keeping them directed; -- with various prepositions, often in a special or figurative sense.","pos":""},{"def":"To direct the attention (to something); to consider; to examine; as, to look at an action.","pos":""}],"LOOKDOWN":[{"def":"See Moonfish (b).","pos":""}],"LOOKER":[{"def":"Did not this fatal war affront thy coast, Yet sattest thou an idle looker-on Fairfax.","pos":""}],"LOOKING":[{"def":"Having a certain look or appearance; -- often compounded with adjectives; as, good-looking, grand-looking, etc.","pos":""}],"LOOKING-GLASS":[{"def":"A mirror made of glass on which has been placed a backing of some reflecting substance, as quicksilver.","pos":""}],"LOOKOUT":[{"def":"A careful looking or watching for any object or event.","pos":""},{"def":"The place from which such observation is made.","pos":""}],"LOOL":[{"def":"A vessel used to receive the washings of ores of metals.","pos":""}],"LOOM":[{"def":"See Loon, the bird.","pos":""}],"LOOM-GALE":[{"def":"A gentle gale of wind.","pos":""}],"LOOMING":[{"def":"The indistinct and magnified appearance of objects seen in particular states of the atmosphere.","pos":""}],"LOON":[{"def":"A sorry fellow; a worthless person; a rogue.","pos":""}],"LOOP":[{"def":"A mass of iron in a pasty condition gathered into a ball for the tilt hammer or rolls.","pos":""}],"LOOPED":[{"def":"Bent, folded, or tied, so as to make a loop; as, a looped wire or string.","pos":""}],"LOOPER":[{"def":"The larva of any species of geometrid moths.","pos":""}],"LOOPHOLE":[{"def":"A small opening, as in the walls of fortification, or in the bulkhead of a ship, through which small arms or other weapons may be discharged at an enemy.","pos":""}],"LOOPHOLED":[{"def":"Provided with loopholes.","pos":""}],"LOOPIE":[{"def":"Deceitful; cunning; sly.","pos":""}],"LOOPING":[{"def":"The running together of the matter of an ore into a mass, when the ore is only heated for calcination.","pos":""}],"LOOPLIGHT":[{"def":"A small narrow opening or window in a tower or fortified wall; a loophole.","pos":""}],"LOORD":[{"def":"A dull, stupid fellow; a drone.","pos":""}],"LOOS":[{"def":"Praise; fame; reputation.","pos":""}],"LOOSE":[{"def":"Unbound; untied; unsewed; not attached, fastened, fixed, or confined; as, the loose sheets of a book.","pos":""},{"def":"Free from constraint or obligation; not bound by duty, habit, etc.","pos":""}],"LOOSELY":[{"def":"In a loose manner.","pos":""}],"LOOSEN":[{"def":"To make loose; to free from tightness, tension, firmness, or fixedness; to make less dense or compact; as, to loosen a string, or a knot; to loosen a rock in the earth.","pos":""},{"def":"To free from restraint; to set at liberty.","pos":""}],"LOOSENER":[{"def":"One who, or that which, loosens.","pos":""}],"LOOSENESS":[{"def":"The state, condition, or quality, of being loose; as, the looseness of a cord; looseness of style; looseness of morals or of principles.","pos":""}],"LOOSESTRIFE":[{"def":"False loosestrife, a plant of the genus Ludwigia, which includes several species, most of which are found in the United States.","pos":""}],"LOOT":[{"def":"The act of plundering.","pos":""},{"def":"Plunder; booty; especially, the boot taken in a conquered or sacked city.","pos":""}]}