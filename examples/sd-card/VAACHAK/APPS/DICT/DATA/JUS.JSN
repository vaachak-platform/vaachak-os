{"JUSSI":[{"def":"A delicate fiber, produced in the Philippine Islands from an unidentified plant, of which dresses, etc.","pos":""}],"JUST":[{"def":"Conforming or conformable to rectitude or justice; not doing wrong to any; violating no right or obligation; upright; righteous; honest; true; -- said both of persons and things.","pos":""},{"def":"Not transgressing the requirement of truth and propriety; conformed to the truth of things, to reason, or to a proper standard; exact; normal; reasonable; regular; due; as, a just statement; a just inference.","pos":""}],"JUSTICE":[{"def":"The quality of being just; conformity to the principles of righteousness and rectitude in all things; strict performance of moral obligations; practical conformity to human or divine law; integrity in the dealings of men with each other; rectitude; equity; uprightness.","pos":""},{"def":"The king-becoming graces, As justice, verity, temperance, stableness, .","pos":""}],"JUSTICEABLE":[{"def":"Liable to trial in a court of justice.","pos":""}],"JUSTICEMENT":[{"def":"Administration of justice; procedure in courts of justice.","pos":""}],"JUSTICER":[{"def":"One who administers justice; a judge.","pos":""}],"JUSTICESHIP":[{"def":"The office or dignity of a justice.","pos":""}],"JUSTICIABLE":[{"def":"Proper to be examined in a court of justice.","pos":""}],"JUSTICIAR":[{"def":"Same as Justiciary.","pos":""}],"JUSTICIARY":[{"def":"An old name for the judges of the higher English courts.","pos":""},{"def":"Formerly, a close coat or waistcoat with sleeves.","pos":""}],"JUSTIFIABLE":[{"def":"Capable of being justified, or shown to be just.","pos":""}],"JUSTIFICATION":[{"def":"The showing in court of a sufficient lawful reason why a party charged or accused did that for which he is called to answer.","pos":""},{"def":"The act of justifying, or the state of being justified, in respect to God's requirements.","pos":""}],"JUSTIFICATIVE":[{"def":"Having power to justify; justificatory.","pos":""}],"JUSTIFICATOR":[{"def":"One who justifies or vindicates; a justifier.","pos":""}],"JUSTIFICATORY":[{"def":"Vindicatory; defensory; justificative.","pos":""}],"JUSTIFIER":[{"def":"One who justifies; one who vindicates, supports, defends, or absolves.","pos":""}],"JUSTIFY":[{"def":"To treat as if righteous and just; to pardon; to exculpate; to absolve.","pos":""},{"def":"To make even or true, as lines of type, by proper spacing; to adjust, as type.","pos":""}],"JUSTINIAN":[{"def":"Of or pertaining to the Institutes or laws of the Roman Justinian.","pos":""}],"JUSTLE":[{"def":"To run or strike against each other; to encounter; to clash; to jostle.","pos":""}],"JUSTLY":[{"def":"In a just manner; in conformity to law, justice, or propriety; by right; honestly; fairly; accurately.","pos":""}],"JUSTNESS":[{"def":"The quality of being just; conformity to truth, propriety, accuracy, exactness, and the like; justice; reasonableness; fairness; equity; as, justness of proportions; the justness of a description or representation; the justness of a cause.","pos":""}]}