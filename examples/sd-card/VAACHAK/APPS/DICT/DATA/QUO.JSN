{"QUO WARRANTO":[{"def":"A writ brought before a proper tribunal, to inquire by what warrant a person or a corporation acts, or exercises certain powers.","pos":""}],"QUOB":[{"def":"To throb; to quiver.","pos":""}],"QUOD":[{"def":"A quadrangle or court, as of a prison; hence, a prison.","pos":""}],"QUODDIES":[{"def":"Herring taken and cured or smoked near Quoddy Head, Maine, or near the entrance of Passamaquoddy Ray.","pos":""}],"QUODLIBET":[{"def":"A medley improvised by several performers.","pos":""}],"QUODLIBETARIAN":[{"def":"One who discusses any subject at pleasure.","pos":""}],"QUODLIBETICAL":[{"def":"Not restricted to a particular subject; discussed for curiosity or entertainment.","pos":""}],"QUOIN":[{"def":"Originally, a solid exterior angle, as of a building; now, commonly, one of the selected pieces of material by which the corner is marked.","pos":""},{"def":"to support and steady a stone.","pos":""}],"QUOIT":[{"def":"A game played with quoits.","pos":""}],"QUOLL":[{"def":"A marsupial of Australia (Dasyurus macrurus), about the size of a cat.","pos":""}],"QUONDAM":[{"def":"Having been formerly; former; sometime.","pos":""}],"QUORUM":[{"def":"Such a number of the officers or members of any body as is competent by law or constitution to transact business; as, a quorum of the House of Representatives; a constitutional quorum was not present.","pos":""}],"QUOTA":[{"def":"A proportional part or share; the share or proportion assigned to each in a division.","pos":""}],"QUOTABLE":[{"def":"Capable or worthy of being quoted; as, a quotable writer; a quotable sentence.","pos":""}],"QUOTATION":[{"def":"The naming or publishing of the current price of stocks, bonds, or any commodity; also the price named.","pos":""},{"def":"A piece of hollow type metal, lower than type, and measuring two or more pica ems in length and breadth, used in the blank spaces at the beginning and end of chapters, etc.","pos":""}],"QUOTATIONIST":[{"def":"One who makes, or is given to making, quotations.","pos":""}],"QUOTE":[{"def":"To name the current price of.","pos":""}],"QUOTER":[{"def":"One who quotes the words of another.","pos":""}],"QUOTH":[{"def":"Said; spoke; uttered; -- used only in the first and third persons in the past tenses, and always followed by its nominative, the word or words said being the object; as, quoth I.","pos":""}],"QUOTHA":[{"def":"Indeed; forsooth.","pos":""}],"QUOTIDIAN":[{"def":"Occurring or returning daily; as, a quotidian fever.","pos":""}],"QUOTIENT":[{"def":"The number resulting from the division of one number by another, and showing how often a less number is contained in a greater; thus, the quotient of twelve divided by four is three.","pos":""},{"def":"The result of any process inverse to multiplication.","pos":""}],"QUOTIETY":[{"def":"The relation of an object to number.","pos":""}],"QUOTUM":[{"def":"Part or proportion; quota.","pos":""}]}