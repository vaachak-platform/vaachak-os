{"SAW":[{"def":"Something said; speech; discourse.","pos":""},{"def":"A saying; a proverb; a maxim.","pos":""}],"SAW PALMETTO":[{"def":"See under Palmetto.","pos":""}],"SAW-SET":[{"def":"An instrument used to set or turn the teeth of a saw a little sidewise, that they may make a kerf somewhat wider than the thickness of the blade, to prevent friction; -- called also saw-wrest.","pos":""}],"SAW-TOOTHED":[{"def":"Having a tooth or teeth like those of a saw; serrate.","pos":""}],"SAW-WHET":[{"def":"A small North American owl (Nyctale Acadica), destitute of ear tufts and having feathered toes; -- called also Acadian owl.","pos":""}],"SAW-WORT":[{"def":"Any plant of the composite genus Serratula; -- so named from the serrated leaves of most of the species.","pos":""}],"SAWBONES":[{"def":"A nickname for a surgeon.","pos":""}],"SAWDER":[{"def":"A corrupt spelling and pronunciation of solder.","pos":""}],"SAWDUST":[{"def":"Dust or small fragments of wood 9or of stone, etc.","pos":""}],"SAWER":[{"def":"One who saws; a sawyer.","pos":""}],"SAWFISH":[{"def":"Any one of several species of elasmobranch fishes of the genus Pristis.","pos":""}],"SAWFLY":[{"def":"Any one of numerous species of hymenopterous insects belonging to the family Tenthredinidæ.","pos":""}],"SAWHORSE":[{"def":"A kind of rack, shaped like a double St.","pos":""}],"SAWMILL":[{"def":"A mill for sawing, especially one for sawing timber or lumber.","pos":""}],"SAWTOOTH":[{"def":"An arctic seal (Lobodon carcinophaga), having the molars serrated; -- called also crabeating seal.","pos":""}],"SAWYER":[{"def":"One whose occupation is to saw timber into planks or boards, or to saw wood for fuel; a sawer.","pos":""},{"def":"A tree which has fallen into a stream so that its branches project above the surface, rising and falling with a rocking or swaying motion in the current.","pos":""}]}