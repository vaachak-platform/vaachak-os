{"GENEAGENESIS":[{"def":"Alternate generation.","pos":""}],"GENEALOGICAL":[{"def":"Of or pertaining to genealogy; as, a genealogical table; genealogical order.","pos":""}],"GENEALOGIST":[{"def":"One who traces genealogies or the descent of persons or families.","pos":""}],"GENEALOGIZE":[{"def":"To investigate, or relate the history of, descents.","pos":""}],"GENEALOGY":[{"def":"An account or history of the descent of a person or family from an ancestor; enumeration of ancestors and their children in the natural order of succession; a pedigree.","pos":""},{"def":"Regular descent of a person or family from a progenitor; pedigree; lineage.","pos":""}],"GENEARCH":[{"def":"The chief of a family or tribe.","pos":""}],"GENERABILITY":[{"def":"Capability of being generated.","pos":""}],"GENERABLE":[{"def":"Capable of being generated or produced.","pos":""}],"GENERAL":[{"def":"One of the chief military officers of a government or country; the commander of an army, of a body of men not less than a brigade.","pos":""},{"def":"The roll of the drum which calls the troops together; as, to beat the general.","pos":""}],"GENERALIA":[{"def":"Generalities; general terms.","pos":""}],"GENERALISSIMO":[{"def":"The chief commander of an army; especially, the commander in chief of an army consisting of two or more grand divisions under separate commanders; -- a title used in most foreign countries.","pos":""}],"GENERALITY":[{"def":"The state of being general; the quality of including species or particulars.","pos":""},{"def":"That which is general; that which lacks specificalness, practicalness, or application; a general or vague statement or phrase.","pos":""}],"GENERALIZABLE":[{"def":"Capable of being generalized, or reduced to a general form of statement, or brought under a general rule.","pos":""}],"GENERALIZATION":[{"def":"The act or process of generalizing; the act of bringing individuals or particulars under a genus or class; deduction of a general principle from particulars.","pos":""},{"def":"A general inference.","pos":""}],"GENERALIZE":[{"def":"To bring under a genus or under genera; to view in relation to a genus or to genera.","pos":""},{"def":"To apply to other genera or classes; to use with a more extensive application; to extend so as to include all special cases; to make universal in application, as a formula or rule.","pos":""}],"GENERALIZED":[{"def":"Comprising structural characters which are separated in more specialized forms; synthetic; as, a generalized type.","pos":""}],"GENERALIZER":[{"def":"One who takes general or comprehensive views.","pos":""}],"GENERALLY":[{"def":"In general; commonly; extensively, though not universally; most frequently.","pos":""},{"def":"In a general way, or in general relation; in the main; upon the whole; comprehensively.","pos":""}],"GENERALNESS":[{"def":"The condition or quality of being general; frequency; commonness.","pos":""}],"GENERALSHIP":[{"def":"The office of a general; the exercise of the functions of a general; -- sometimes, with the possessive pronoun, the personality of a general.","pos":""},{"def":"Military skill in a general officer or commander.","pos":""}],"GENERANT":[{"def":"Generative; producing; esp.","pos":""},{"def":"acting as a generant.","pos":""}],"GENERATE":[{"def":"To trace out, as a line, figure, or solid, by the motion of a point or a magnitude of inferior order.","pos":""}],"GENERATION":[{"def":"The formation or production of any geometrical magnitude, as a line, a surface, a solid, by the motion, in accordance with a mathematical law, of a point or a magnitude; as, the generation of a line or curve by the motion of a point, of a surface by a line, a sphere by a semicircle, etc.","pos":""},{"def":"The aggregate of the functions and phenomene which attend reproduction.","pos":""}],"GENERATIVE":[{"def":"Having the power of generating, propagating, originating, or producing.","pos":""}],"GENERATOR":[{"def":"The principal sound or sounds by which others are produced; the fundamental note or root of the common chord; -- called also generating tone.","pos":""}],"GENERATRIX":[{"def":"That which generates; the point, or the mathematical magnitude, which, by its motion, generates another magnitude, as a line, surface, or solid; -- called also describent.","pos":""},{"def":"Pertaining to a genus or kind; relating to a genus, as distinct from a species, or from another genus; as, a generic description; a generic difference; a generic name.","pos":""}],"GENERICALLY":[{"def":"With regard to a genus, or an extensive class; as, an animal generically distinct from another, or two animals or plants generically allied.","pos":""}],"GENERICALNESS":[{"def":"The quality of being generic.","pos":""}],"GENERIFICATION":[{"def":"The act or process of generalizing.","pos":""}],"GENEROSITY":[{"def":"The quality of being noble; noble-mindedness.","pos":""}],"GENEROUS":[{"def":"Of honorable birth or origin; highborn.","pos":""},{"def":"Exhibiting those qualities which are popularly reregarded as belonging to high birth; noble; honorable; magnanimous; spirited; courageous.","pos":""}],"GENESEE EPOCH":[{"def":"The closing subdivision of the Hamilton period in the American Devonian system; -- so called because the formations of this period crop out in Genesee, New York.","pos":""}],"GENESIAL":[{"def":"Of or relating to generation.","pos":""}],"GENESIOLGY":[{"def":"The doctrine or science of generation.","pos":""}],"GENESIS":[{"def":"Same as Generation.","pos":""},{"def":"One of several species of small Carnivora of the genus Genetta, allied to the civets, but having the scent glands less developed, and without a pouch.","pos":""}],"GENET":[{"def":"A small-sized, well-proportioned, Spanish horse; a jennet.","pos":""}],"GENETHLIAC":[{"def":"Pertaining to nativities; calculated by astrologers; showing position of stars at one's birth.","pos":""}],"GENETHLIACS":[{"def":"The science of calculating nativities, or predicting the future events of life from the stars which preside at birth.","pos":""}],"GENETHLIALOGY":[{"def":"Divination as to the destinies of one newly born; the act or art of casting nativities; astrology.","pos":""}],"GENETHLIATIC":[{"def":"One who calculates nativities.","pos":""}],"GENETIC":[{"def":"Same as Genetical.","pos":""}],"GENETICAL":[{"def":"Pertaining to, concerned with, or determined by, the genesis of anything, or its natural mode of production or development.","pos":""}],"GENETICALLY":[{"def":"In a genetical manner.","pos":""}],"GENEVA":[{"def":"The chief city of Switzerland.","pos":""}],"GENEVAN":[{"def":"Of or pertaining to Geneva, in Switzerland; Genevese.","pos":""}],"GENEVANISM":[{"def":"Strict Calvinism.","pos":""}],"GENEVESE":[{"def":"Of or pertaining to Geneva, in Switzerland; Genevan.","pos":""},{"def":"A native or inhabitant of Geneva; collectively, the inhabitants of Geneva; people of Geneva.","pos":""}]}