{"TENON":[{"def":"A projecting member left by cutting away the wood around it, and made to insert into a mortise, and in this way secure together the parts of a frame; especially, such a member when it passes entirely through the thickness of the piece in which the mortise is cut, and shows on the other side.","pos":""}],"TENONIAN":[{"def":"Discovered or described by M.","pos":""}],"TENONITIS":[{"def":"Inflammation of a tendon.","pos":""}],"TENOR":[{"def":"An exact copy of a writing, set forth in the words and figures of it.","pos":""}],"TENORRHAPHY":[{"def":"Suture of a tendon.","pos":""}],"TENOSITIS":[{"def":"Inflammation of a tendon.","pos":""}],"TENOSYNOVITIS":[{"def":"Inflammation of the synovial sheath enveloping a tendon.","pos":""}],"TENOTOME":[{"def":"A slender knife for use in the operation of tenotomy.","pos":""}],"TENOTOMY":[{"def":"The division of a tendon, or the act of dividing a tendon.","pos":""}]}