{"VALANCE":[{"def":"Hanging drapery for a bed, couch, window, or the like, especially that which hangs around a bedstead, from the bed to the floor.","pos":""},{"def":"The drooping edging of the lid of a trunk.","pos":""}],"VALE":[{"def":"A tract of low ground, or of land between hills; a valley.","pos":""}],"VALEDICTION":[{"def":"A farewell; a bidding farewell.","pos":""}],"VALEDICTORIAN":[{"def":"One who pronounces a valedictory address; especially, in American colleges, the student who pronounces the valedictory of the graduating class at the annual commencement, usually the student who ranks first in scholarship.","pos":""}],"VALEDICTORY":[{"def":"Bidding farewell; suitable or designed for an occasion of leave-taking; as, a valedictory oration.","pos":""}],"VALENCE":[{"def":"The degree of combining power of an atom (or radical) as shown by the number of atoms of hydrogen (or of other monads, as chlorine, sodium, etc.","pos":""}],"VALENCIA":[{"def":"A kind of woven fabric for waistcoats, having the weft of wool and the warp of silk or cotton.","pos":""}],"VALENCIENNES LACE":[{"def":"A rich kind of lace made at Valenciennes, in France.","pos":""}],"VALENTINE":[{"def":"A sweetheart chosen on St.","pos":""},{"def":"A letter containing professions of love, or a missive of a sentimental, comic, or burlesque character, sent on St.","pos":""}],"VALENTINIAN":[{"def":"One of a school of Judaizing Gnostics in the second century; -- so called from Valentinus, the founder.","pos":""}],"VALERAMIDE":[{"def":"The acid amide derivative of valeric acid, obtained as a white crystalline substance.","pos":""}],"VALERATE":[{"def":"A salt of valeric acid.","pos":""}],"VALERIAN":[{"def":"Any plant of the genus Valeriana.","pos":""}],"VALERIANACEOUS":[{"def":"Of, pertaining to, or resembling, plants of a natural order (Valerianaccæ) of which the valerian is the type.","pos":""}],"VALERIANIC":[{"def":"Performance to, or obtained from, valerian root; specifically, designating an acid which is usually called valeric acid.","pos":""}],"VALERIC":[{"def":"Valerianic; specifically, designating any one of three metameric acids, of which the typical one (called also inactive valeric acid), C4H9CO2H, is obtained from valerian root and other sources, as a corrosive, mobile, oily liquid, having a strong acid taste, and an odor of old cheese.","pos":""}],"VALERIDINE":[{"def":"A base, C10H19N, produced by heating valeric aldehyde with ammonia.","pos":""}],"VALERIN":[{"def":"A salt of valeric acid with glycerin, occurring in butter, dolphin oil.","pos":""}],"VALERITRINE":[{"def":"A base, C15H27N, produced together with valeridine, which it resembles.","pos":""}],"VALERO-":[{"def":"A combining form (also used adjectively) indicating derivation from, or relation to, valerian or some of its products, as valeric acid; as in valerolactone, a colorless oily liquid produced as the anhydride of an hydroxy valeric acid.","pos":""}],"VALERONE":[{"def":"A ketone of valeric acid obtained as an oily liquid.","pos":""}],"VALERYL":[{"def":"The hypothetical radical C5H9O, regarded as the essential nucleus of certain valeric acid derivatives.","pos":""}],"VALERYLENE":[{"def":"A liquid hydrocarbon, C5H8; -- called also pentine.","pos":""}],"VALET":[{"def":"A kind of goad or stick with a point of iron.","pos":""}],"VALETUDINARIAN":[{"def":"Of infirm health; seeking to recover health; sickly; weakly; infirm.","pos":""}],"VALETUDINARIANISM":[{"def":"The condition of a valetudinarian; a state of feeble health; infirmity.","pos":""}],"VALETUDINARY":[{"def":"Infirm; sickly; valetudinarian.","pos":""}],"VALHALLA":[{"def":"The palace of immortality, inhabited by the souls of heroes slain in battle.","pos":""},{"def":"The quality or state of being valiant; bravery; valor.","pos":""}],"VALIANT":[{"def":"Vigorous in body; strong; powerful; as, a valiant fencer.","pos":""},{"def":"Intrepid in danger; courageous; brave.","pos":""}],"VALID":[{"def":"Having legal strength or force; executed with the proper formalities; incapable of being rightfully overthrown or set aside; as, a valid deed; a valid covenant; a valid instrument of any kind; a valid claim or title; a valid marriage.","pos":""}],"VALIDATE":[{"def":"To confirm; to render valid; to give legal force to.","pos":""}],"VALIDATION":[{"def":"The act of giving validity.","pos":""}],"VALIDITY":[{"def":"Legal strength, force, or authority; that quality of a thing which renders it supportable in law, or equity; as, the validity of a will; the validity of a contract, claim, or title.","pos":""}],"VALIDLY":[{"def":"In a valid manner; so as to be valid.","pos":""}],"VALIDNESS":[{"def":"The quality or state of being valid.","pos":""}],"VALINCH":[{"def":"A tube for drawing liquors from a cask by the bunghole.","pos":""}],"VALISE":[{"def":"A small sack or case, usually of leather, but sometimes of other material, for containing the clothes, toilet articles, etc.","pos":""}],"VALKYRIA":[{"def":"One of the maidens of Odin, represented as awful and beautiful, who presided over battle and marked out those who were to be slain, and who also ministered at the feasts of heroes in Valhalla.","pos":""}],"VALKYRIAN":[{"def":"Of or pertaining to the Valkyrias; hence, relating to battle.","pos":""}],"VALLANCY":[{"def":"A large wig that shades the face.","pos":""}],"VALLAR":[{"def":"Of or pertaining to a rampart.","pos":""}],"VALLATION":[{"def":"A rampart or intrenchment.","pos":""}],"VALLATORY":[{"def":"Of or pertaining to a vallation; used for a vallation; as, vallatory reads.","pos":""}],"VALLECULA":[{"def":"A groove; a fossa; as, the vallecula, or fossa, which separates the hemispheres of the cerebellum.","pos":""},{"def":"One of the grooves, or hollows, between the ribs of the fruit of umbelliferous plants.","pos":""}],"VALLET'S PILLS":[{"def":"Pills containing sulphate of iron and carbonate of sodium, mixed with saccharine matter; -- called also Vallet's mass.","pos":""}],"VALLEY":[{"def":"The space inclosed between ranges of hills or mountains; the strip of land at the bottom of the depressions intersecting a country, including usually the bed of a stream, with frequently broad alluvial plains on one or both sides of the stream.","pos":""}],"VALLUM":[{"def":"A rampart; a wall, as in a fortification.","pos":""}],"VALONIA":[{"def":"A genus of marine green algæ, in which the whole frond consists of a single oval or cylindrical cell, often an inch in length.","pos":""}],"VALOR":[{"def":"Strength of mind in regard to danger; that quality which enables a man to encounter danger with firmness; personal bravery; courage; prowess; intrepidity.","pos":""}],"VALORIZATION":[{"def":"Act or process of attempting to give an arbitrary market value or price to a commodity by governmental interference, as by maintaining a purchasing fund, making loans to producers to enable them to hold their products, etc.","pos":""}],"VALOROUS":[{"def":"Possessing or exhibiting valor; brave; courageous; valiant; intrepid.","pos":""}],"VALSALVIAN":[{"def":"Of or pertaining to Valsalva, an Italian anatomist of the 17th century.","pos":""}],"VALUABLE":[{"def":"Having value or worth; possessing qualities which are useful and esteemed; precious; costly; as, a valuable horse; valuable land; a valuable cargo.","pos":""},{"def":"Worthy; estimable; deserving esteem; as, a valuable friend; a valuable companion.","pos":""}],"VALUABLENESS":[{"def":"The quality of being valuable.","pos":""}],"VALUABLY":[{"def":"So as to be of value.","pos":""}],"VALUATION":[{"def":"The act of valuing, or of estimating value or worth; the act of setting a price; estimation; appraisement; as, a valuation of lands for the purpose of taxation.","pos":""},{"def":"Value set upon a thing; estimated value or worth; as, the goods sold for more than their valuation.","pos":""}],"VALUATOR":[{"def":"One who assesses, or sets a value on, anything; an appraiser.","pos":""}],"VALUE":[{"def":"Worth estimated by any standard of purchasing power, especially by the market price, or the amount of money agreed upon as an equivalent to the utility and cost of anything.","pos":""},{"def":"The relative length or duration of a tone or note, answering to quantity in prosody; thus, a quarter note [value of two eighth notes [ 6.","pos":""}],"VALUED":[{"def":"Highly regarded; esteemed; prized; as, a valued contributor; a valued friend.","pos":""}],"VALUED POLICY":[{"def":"A policy in which the value of the goods, property, or interest insured is specified; -- opposed to open policy.","pos":""}],"VALUED-POLICY LAW":[{"def":"A law requiring insurance companies to pay to the insured, in case of total loss, the full amount of the insurance, regardless of the actual value of the property at the time of the loss.","pos":""}],"VALUELESS":[{"def":"Being of no value; having no worth.","pos":""}],"VALUER":[{"def":"One who values; an appraiser.","pos":""}],"VALURE":[{"def":"VALVAL; VALVAR Valv\"al, Valv\"ar, a.","pos":""}],"VALVATA":[{"def":"A genus of small spiral fresh-water gastropods having an operculum.","pos":""}],"VALVATE":[{"def":"Resembling, or serving as, a valve; consisting of, or opening by, a valve or valves; valvular.","pos":""}],"VALVE":[{"def":"One or more membranous partitions, flaps, or folds, which permit the passage of the contents of a vessel or cavity in one direction, but stop or retard the flow in the opposite direction; as, the ileocolic, mitral, and semilunar valves.","pos":""},{"def":"One of the pieces or divisions of bivalve or multivalve shells.","pos":""}],"VALVE-SHELL":[{"def":"Any fresh-water gastropod of the genus Valvata.","pos":""}],"VALVED":[{"def":"Having a valve or valve; valvate.","pos":""}],"VALVELET":[{"def":"A little valve; a valvule; especially, one of the pieces which compose the outer covering of a pericarp.","pos":""}],"VALVULA":[{"def":"A little valve or fold; a valvelet; a valvule.","pos":""}],"VALVULAR":[{"def":"Of or pertaining to a valve or valves; specifically (Med.","pos":""},{"def":"Containing valves; serving as a valve; opening by valves; valvate; as, a valvular capsule.","pos":""}],"VALVULE":[{"def":"A small valvelike process.","pos":""}],"VALYLENE":[{"def":"A volatile liquid hydrocarbon, C5H6, related to ethylene and acetylene, but possessing the property of unsaturation in the third degree.","pos":""}]}