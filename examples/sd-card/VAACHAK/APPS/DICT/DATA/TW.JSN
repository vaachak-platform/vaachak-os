{"TWADDLE":[{"def":"To talk a weak and silly manner, like one whose faculties are decayed; to prate; to prattle.","pos":""}],"TWADDLER":[{"def":"One who prates in a weak and silly manner, like one whose faculties are decayed.","pos":""}],"TWADDLING":[{"def":"Twad\"dling, Defn: a.","pos":""}],"TWADDY":[{"def":"Idle trifling; twaddle.","pos":""}],"TWAIN":[{"def":"Two;- nearly obsolete in common discourse, but used in poetry and burlesque.","pos":""}],"TWAITE":[{"def":"A European shad; -- called also twaite shad.","pos":""}],"TWANG":[{"def":"To sound with a quick, harsh noise; to make the sound of a tense string pulled and suddenly let go; as, the bowstring twanged.","pos":""}],"TWANGLE":[{"def":"While the twangling violin Struck up with Soldier-laddie.","pos":""}],"TWANK":[{"def":"To cause to make a sharp twanging sound; to twang, or twangle.","pos":""}],"TWANKAY":[{"def":"See Note under Tea, n.","pos":""},{"def":"A contraction of it was.","pos":""}],"TWATTLE":[{"def":"To prate; to talk much and idly; to gabble; to chatter; to twaddle; as, a twattling gossip.","pos":""}],"TWATTLER":[{"def":"One who twattles; a twaddler.","pos":""}],"TWAYBLADE":[{"def":"Any one of several orchidaceous plants which have only two leaves, as the species of Listera and of Liparis.","pos":""}],"TWEAG":[{"def":"A pinching condition; perplexity; trouble; distress.","pos":""}],"TWEAK":[{"def":"To pinch and pull with a sudden jerk and twist; to twitch; as, to tweak the nose.","pos":""}],"TWEED":[{"def":"A soft and flexible fabric for men's wear, made wholly of wool except in some inferior kinds, the wool being dyed, usually in two colors, before weaving.","pos":""}],"TWEEDLE":[{"def":"To handle lightly; -- said with reference to awkward fiddling; hence, to influence as if by fiddling; to coax; to allure.","pos":""}],"TWEEDLEDUM AND TWEEDLEDEE":[{"def":"Two things practically alike; -- a phrase coined by John Byrom (1692-1793) in his satire \"On the Feuds between Handel and Bononcini.","pos":""}],"TWEER":[{"def":"A surgeon's case of instruments.","pos":""}],"TWEEZERS":[{"def":"Small pinchers used to pluck out hairs, and for other purposes.","pos":""}],"TWELFTH":[{"def":"Next in order after the eleventh; coming after eleven others; -- the ordinal of twelve.","pos":""},{"def":"Consisting, or being one of, twelve equal parts into which anything is divided.","pos":""}],"TWELFTH-CAKE":[{"def":"An ornamented cake distributed among friends or visitors on the festival of Twelfth-night.","pos":""}],"TWELFTH-DAY":[{"def":"See Twelfthtide.","pos":""}],"TWELFTH-NIGHT":[{"def":"The evening of Epiphany, or the twelfth day after Christmas, observed as a festival by various churches.","pos":""}],"TWELFTH-SECOND":[{"def":"A unit for the measurement of small intervals of time, such that 1012 (ten trillion) of these units make one second.","pos":""}],"TWELFTHTIDE":[{"def":"The twelfth day after Christmas; Epiphany; -- called also Twelfth-day.","pos":""}],"TWELVE":[{"def":"One more that eleven; two and ten; twice six; a dozen.","pos":""}],"TWELVEMONTH":[{"def":"A year which consists of twelve calendar months.","pos":""}],"TWELVEPENCE":[{"def":"A shilling sterling, being about twenty-four cents.","pos":""}],"TWELVEPENNY":[{"def":", Sold for a shilling; worth or costing a shilling.","pos":""}],"TWELVESCORE":[{"def":"Twelve times twenty; two hundred and forty.","pos":""}],"TWENTIETH":[{"def":"Next in order after the nineteenth; tenth after the tenth; coming after nineteen others; -- the ordinal of twenty.","pos":""},{"def":"Consisting, or being, one of twenty equal parts into which anything is divided.","pos":""}],"TWENTY":[{"def":"One more that nineteen; twice; as, twenty men.","pos":""},{"def":"An indefinite number more or less that twenty.","pos":""}],"TWENTY-FOURMO":[{"def":"Having twenty-four leaves to a sheet; as, a twenty-fourmo form, book, leaf, size, etc.","pos":""},{"def":"A book composed of sheets, each of which is folded into twenty- four leaves; hence, indicating more or less definitely a size of book whose sheets are so folded; -- usually written 24mo, or 24º.","pos":""}],"TWENTYFOLD":[{"def":"Twenty times as many.","pos":""}],"TWIBIL":[{"def":"A kind of mattock, or ax; esp.","pos":""},{"def":"A tool for making mortises.","pos":""}],"TWIBILLED":[{"def":"Armed or provided with a twibil or twibils.","pos":""}],"TWICE":[{"def":"Two times; once and again.","pos":""},{"def":"Doubly; in twofold quantity or degree; as, twice the sum; he is twice as fortunate as his neighbor.","pos":""}],"TWIDDLE":[{"def":"To touch lightly, or play with; to tweedle; to twirl; as, to twiddle one's thumbs; to twiddle a watch key.","pos":""}],"TWIFALLOW":[{"def":"To plow, or fallow, a second time (land that has been once fallowed).","pos":""}],"TWIFOLD":[{"def":"Twofold; double.","pos":""}],"TWIG":[{"def":"To twitch; to pull; to tweak.","pos":""}],"TWIGGEN":[{"def":"Made of twigs; wicker.","pos":""}],"TWIGGY":[{"def":"Of or pertaining to a twig or twigs; like a twig or twigs; full of twigs; abounding with shoots.","pos":""}],"TWIGLESS":[{"def":"Having no twigs.","pos":""}],"TWIGSOME":[{"def":"Full of, or abounding in, twigs; twiggy.","pos":""}],"TWILIGHT":[{"def":"The light perceived before the rising, and after the setting, of the sun, or when the sun is less than 18º below the horizon, occasioned by the illumination of the earth's atmosphere by the direct rays of the sun and their reflection on the earth.","pos":""}],"TWILL":[{"def":"To weave, as cloth, so as to produce the appearance of diagonal lines or ribs on the surface.","pos":""}],"TWILLY":[{"def":"A machine for cleansing or loosening wool by the action of a revolving cylinder covered with long iron spikes or teeth; a willy or willying machine; -- called also twilly devil, and devil.","pos":""}],"TWIN":[{"def":"Double; consisting of two similar and corresponding parts.","pos":""},{"def":"Composed of parts united according to some definite law of twinning.","pos":""}],"TWINBORN":[{"def":"Born at the same birth.","pos":""}],"TWINE":[{"def":"A twist; a convolution.","pos":""},{"def":"A strong thread composed of two or three smaller threads or strands twisted together, and used for various purposes, as for binding small parcels, making nets, and the like; a small cord or string.","pos":""}],"TWINER":[{"def":"Any plant which twines about a support.","pos":""}],"TWINGE":[{"def":"To pull with a twitch; to pinch; to tweak.","pos":""},{"def":"To affect with a sharp, sudden pain; to torment with pinching or sharp pains.","pos":""}],"TWINING":[{"def":"Winding around something; twisting; embracing; climbing by winding about a support; as, the hop is a twinning plant.","pos":""}],"TWINK":[{"def":"A wink; a twinkling.","pos":""}],"TWINKLE":[{"def":"To open and shut the eye rapidly; to blink; to wink.","pos":""},{"def":"To shine with an intermitted or a broken, quavering light; to flash at intervals; to sparkle; to scintillate.","pos":""}],"TWINKLER":[{"def":"One who, or that which, twinkles, or winks; a winker; an eye.","pos":""}],"TWINKLING":[{"def":"The act of one who, or of that which, twinkles; a quick movement of the eye; a wink; a twinkle.","pos":""},{"def":"A shining with intermitted light; a scintillation; a sparkling; as, the twinkling of the stars.","pos":""}],"TWINLEAF":[{"def":"See Jeffersonia.","pos":""}],"TWINLIKE":[{"def":"Closely resembling; being a counterpart.","pos":""}],"TWINLING":[{"def":"A young or little twin, especially a twin lamb.","pos":""}],"TWINNED":[{"def":"Composed of parts united according to a law of twinning.","pos":""}],"TWINNER":[{"def":"One who gives birth to twins; a breeder of twins.","pos":""}],"TWINNING":[{"def":"The assemblage of two or more crystals, or parts of crystals, in reversed position with reference to each other in accordance with some definite law; also, rarely, in artificial twinning (accomplished for example by pressure), the process by which this reversal is brought about.","pos":""}],"TWINTER":[{"def":"A domestic animal two winters old.","pos":""}],"TWIRE":[{"def":"A twisted filament; a thread.","pos":""}],"TWIRE-PIPE":[{"def":"A vagabond musician.","pos":""}],"TWIRL":[{"def":"To move or turn round rapidly; to whirl round; to move and turn rapidly with the fingers.","pos":""}],"TWIST":[{"def":"To contort; to writhe; to complicate; to crook spirally; to convolve.","pos":""},{"def":"Hence, to turn from the true form or meaning; to pervert; as, to twist a passage cited from an author.","pos":""}],"TWISTED":[{"def":"Contorted; crooked spirally; subjected to torsion; hence, perverted.","pos":""}],"TWISTER":[{"def":"The inner part of the thigh, the proper place to rest upon when on horseback.","pos":""}],"TWISTICAL":[{"def":"Crooked; tortuous; hence, perverse; unfair; dishonest.","pos":""}],"TWISTING":[{"def":"Twist\"ing, Defn: a.","pos":""}],"TWIT":[{"def":"To vex by bringing to notice, or reminding of, a fault, defect, misfortune, or the like; to revile; to reproach; to upbraid; to taunt; as, he twitted his friend of falsehood.","pos":""}],"TWITCH":[{"def":"To pull with a sudden jerk; to pluck with a short, quick motion; to snatch; as, to twitch one by the sleeve; to twitch a thing out of another's hand; to twitch off clusters of grapes.","pos":""}],"TWITCH GRASS":[{"def":"See Quitch grass.","pos":""}],"TWITCHER":[{"def":"One who, or that which, twitches.","pos":""}],"TWITLARK":[{"def":"The meadow pipit.","pos":""}],"TWITTER":[{"def":"One who twits, or reproaches; an upbraider.","pos":""}],"TWITTERING":[{"def":"The act of one who, or that which, twitters.","pos":""},{"def":"A slight nervous excitement or agitation, such as is caused by desire, expectation, or suspense.","pos":""}],"TWITTINGLY":[{"def":"In a twitting manner; with upbraiding.","pos":""}],"TWITTLE-TWATTLE":[{"def":"An abbreviation of Betwixt, used in poetry, or in colloquial language.","pos":""}],"TWO":[{"def":"One and one; twice one.","pos":""}],"TWO-CAPSULED":[{"def":"Having two distinct capsules; bicapsular.","pos":""}],"TWO-CLEFT":[{"def":"Divided about half way from the border to the base into two segments; bifid.","pos":""}],"TWO-CYCLE":[{"def":"A two-stroke cycle for an internal-combustion engine.","pos":""}],"TWO-DECKER":[{"def":"A vessel of war carrying guns on two decks.","pos":""}],"TWO-EDGED":[{"def":"Having two edges, or edges on both sides; as, a two-edged sword.","pos":""}],"TWO-FOOT":[{"def":"Measuring two feet; two feet long, thick, or wide; as, a two- foot rule.","pos":""}],"TWO-FORKED":[{"def":"Divided into two parts, somewhat after the manner of a fork; dichotomous.","pos":""}],"TWO-HAND":[{"def":"Employing two hangs; as, the two-hand alphabet.","pos":""}],"TWO-HANDED":[{"def":"Having two hands; -- often used as an epithet equivalent to large, stout, strong, or powerful.","pos":""},{"def":"Used with both hands; as, a two-nanded sword.","pos":""}],"TWO-LIPPED":[{"def":"Divided in such a manner as to resemble the two lips when the mouth is more or less open; bilabiate.","pos":""}],"TWO-NAME":[{"def":"Having or bearing two names; as, two-name paper, that is, negotiable paper on which at least two persons are severally liable as separate makers, or, usually, one as maker and one as indorser.","pos":""}],"TWO-PARTED":[{"def":"Divided from the border to the base into two distinct parts; bipartite.","pos":""}],"TWO-PLY":[{"def":"Consisting of two thicknesses, as cloth; double.","pos":""},{"def":"Woven double, as cloth or carpeting, by incorporating two sets of warp thread and two of weft.","pos":""}],"TWO-PORT":[{"def":"Having two ports; specif.","pos":""}],"TWO-RANKED":[{"def":"Alternately disposed on exactly opposite sides of the stem so as to from two ranks; distichous.","pos":""}],"TWO-SIDED":[{"def":"Having two sides only; hence, double-faced; hypocritical.","pos":""}],"TWO-SPEED":[{"def":"Adapted for producing or for receiving either of two speeds; -- said of a power-transmitting device.","pos":""}],"TWO-STEP":[{"def":"A kind of round dance in march or polka time; also, a piece of music for this dance.","pos":""}],"TWO-TO-ONE":[{"def":"Designating, or pert.","pos":""}],"TWO-TONGUED":[{"def":"Double-tongued; deceitful.","pos":""}],"TWO-WAY":[{"def":"Serving to connect at will one pipe or channel with either of two others; as, a two-way cock.","pos":""}],"TWOFOLD":[{"def":"Double; duplicate; multiplied by two; as, a twofold nature; a twofold sense; a twofold argument.","pos":""}],"TWOPENCE":[{"def":"A small coin, and money of account, in England, equivalent to two pennies, -- minted to a fixed annual amount, for almsgiving by the sovereign on Maundy Thursday.","pos":""}],"TWOPENNY":[{"def":"Of the value of twopence.","pos":""},{"def":"Same as Diphase, Diphaser.","pos":""}]}