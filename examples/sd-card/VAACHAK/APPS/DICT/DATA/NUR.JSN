{"NUR":[{"def":"A hard knot in wood; also, a hard knob of wood used by boys in playing hockey.","pos":""},{"def":"One of the prehistoric towerlike structures found in Sardinia.","pos":""}],"NURL":[{"def":"To cut with reeding or fluting on the edge of, as coins, the heads of screws, etc.","pos":""}],"NURSE":[{"def":"A lieutenant or first officer, who is the real commander when the captain is unfit for his place.","pos":""}],"NURSEMAID":[{"def":"A girl employed to attend children.","pos":""}],"NURSEPOND":[{"def":"A pond where fish are fed.","pos":""}],"NURSER":[{"def":"One who nurses; a nurse; one who cherishes or encourages growth.","pos":""}],"NURSERY":[{"def":"The act of nursing.","pos":""},{"def":"The place where nursing is carried on; as: (a) The place, or apartment, in a house, appropriated to the care of children.","pos":""}],"NURSERYMAN":[{"def":"One who cultivates or keeps a nursery, or place for rearing trees, etc.","pos":""}],"NURSING":[{"def":"Supplying or taking nourishment from, or as from, the breast; as, a nursing mother; a nursing infant.","pos":""}],"NURSLING":[{"def":"One who, or that which, is nursed; an infant; a fondling.","pos":""}],"NURTURE":[{"def":"The act of nourishing or nursing; thender care; education; training.","pos":""},{"def":"That which nourishes; food; diet.","pos":""}]}