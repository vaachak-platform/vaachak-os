{"COZ":[{"def":"A contraction of cousin.","pos":""}],"COZEN":[{"def":"To cheat; to defrand; to beguile; to deceive, usually by small arts, or in a pitiful way.","pos":""}],"COZENAGE":[{"def":"The art or practice of cozening; artifice; fraud.","pos":""}],"COZENER":[{"def":"One who cheats or defrauds.","pos":""}],"COZILY":[{"def":"Snugly; comfortably.","pos":""}],"COZINESS":[{"def":"The state or quality of being cozy.","pos":""}],"COZY":[{"def":"Chatty; talkative; sociable; familiar.","pos":""}]}