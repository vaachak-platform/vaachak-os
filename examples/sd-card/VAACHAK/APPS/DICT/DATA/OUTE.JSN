{"OUTER":[{"def":"Being on the outside; external; farthest or farther from the interior, from a given station, or from any space or position regarded as a center or starting place; -- opposed to inner; as, the outer wall; the outer court or gate; the outer stump in cricket; the outer world.","pos":""}],"OUTERLY":[{"def":"Utterly; entirely.","pos":""},{"def":"Toward the outside.","pos":""}],"OUTERMOST":[{"def":"Being on the extreme external part; farthest outward; as, the outermost row.","pos":""}]}