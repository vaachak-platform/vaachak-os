{"SIS":[{"def":"A colloquial abbreviation of Sister.","pos":""}],"SISCOWET":[{"def":"A large, fat variety of the namaycusa found in Lake Superior; - - called also siskawet, siskiwit.","pos":""}],"SISE":[{"def":"Six; the highest number on a die; the cast of six in throwing dice.","pos":""}],"SISER":[{"def":"SISERARA; SISERARY Sis\"e*ra*ra, Sis\"e*ra*ry, n.","pos":""}],"SISKIN":[{"def":"Carduelis spinus); -- called also aberdevine.","pos":""}],"SISMOGRAPH":[{"def":"See Seismograph.","pos":""}],"SISMOMETER":[{"def":"See Seismometer.","pos":""}],"SISS":[{"def":"To make a hissing sound; as, a flatiron hot enough to siss when touched with a wet finger.","pos":""}],"SISSOO":[{"def":"A leguminous tree (Dalbergia Sissoo) of the northern parts of India; also, the dark brown compact and durable timber obtained from it.","pos":""}],"SIST":[{"def":"To stay, as judicial proceedings; to delay or suspend; to stop.","pos":""}],"SISTER":[{"def":"A female who has the same parents with another person, or who has one of them only.","pos":""},{"def":"A woman who is closely allied to, or assocciated with, another person, as in the sdame faith, society, order, or community.","pos":""}],"SISTER-IN-LAW":[{"def":"The sister of one's husband or wife; also, the wife of one's brother; sometimes, the wife of one's husband's or wife's brother.","pos":""}],"SISTERHOOD":[{"def":"The state or relation of being a sister; the office or duty of a sister.","pos":""},{"def":"A society of sisters; a society of women united in one faith or order; sisters, collectively.","pos":""}],"SISTERLY":[{"def":"Like a sister; becoming a sister, affectionate; as, sisterly kindness; sisterly remorse.","pos":""}],"SISTINE":[{"def":"Of or pertaining to Pope Sixtus.","pos":""}],"SISTRUM":[{"def":"An instrument consisting of a thin metal frame, through which passed a number of metal rods, and furnished with a handle by which it was shaken and made to rattle.","pos":""}],"SISYPHEAN":[{"def":"Relating to Sisyphus; incessantly recurring; as, Sisyphean labors.","pos":""}],"SISYPHUS":[{"def":"A king of Corinth, son of Æolus, famed for his cunning.","pos":""}]}