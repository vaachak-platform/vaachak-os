{"KIP":[{"def":"The hide of a young or small beef creature, or leather made from it; kipskin.","pos":""}],"KIPE":[{"def":"An osier basket used for catching fish.","pos":""}],"KIPPER":[{"def":"A salmon after spawning.","pos":""}],"KIPPERNUT":[{"def":"A name given to earthnuts of several kinds.","pos":""}],"KIPSKIN":[{"def":"Leather prepared from the skin of young or small cattle, intermediate in grade between calfskin and cowhide.","pos":""}]}