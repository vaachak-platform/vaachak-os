{"UNDAM":[{"def":"To free from a dam, mound, or other obstruction.","pos":""}],"UNDATED":[{"def":"Rising and falling in waves toward the margin, as a leaf; waved.","pos":""}],"UNDAUNTABLE":[{"def":"Incapable of being daunted; intrepid; fearless; indomitable.","pos":""}],"UNDAUNTED":[{"def":"Not daunted; not subdued or depressed by fear.","pos":""}]}