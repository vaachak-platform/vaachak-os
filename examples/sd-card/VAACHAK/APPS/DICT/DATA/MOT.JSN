{"MOT":[{"def":"May; must; might.","pos":""}],"MOTACIL":[{"def":"Any singing bird of the genus Motacilla; a wagtail.","pos":""}],"MOTATION":[{"def":"The act of moving; motion.","pos":""}],"MOTE":[{"def":"A meeting of persons for discussion; as, a wardmote in the city of London.","pos":""},{"def":"A body of persons who meet for discussion, esp.","pos":""}],"MOTED":[{"def":"Filled with motes, or fine floating dust; as, the air.","pos":""}],"MOTET":[{"def":"A composition adapted to sacred words in the elaborate polyphonic church style; an anthem.","pos":""}],"MOTH":[{"def":"Any nocturnal lepidopterous insect, or any not included among the butterflies; as, the luna moth; Io moth; hawk moth.","pos":""},{"def":"Any lepidopterous insect that feeds upon garments, grain, etc.","pos":""}],"MOTH-EAT":[{"def":"To eat or prey upon, as a moth eats a garment.","pos":""}],"MOTHER":[{"def":"A female parent; especially, one of the human race; a woman who has borne a child.","pos":""},{"def":"That which has produced or nurtured anything; source of birth or origin; generatrix.","pos":""}],"MOTHER'S DAY":[{"def":"A day appointed for the honor and uplift of motherhood by the loving remembrance of each person of his mother through the performance of some act of kindness, visit, tribute, or letter.","pos":""}],"MOTHER-IN-LAW":[{"def":"The mother of one's husband or wife.","pos":""}],"MOTHER-NAKED":[{"def":"Naked as when born.","pos":""}],"MOTHER-OF-PEARL":[{"def":"The hard pearly internal layer of several kinds of shells, esp.","pos":""}],"MOTHER-OF-THYME":[{"def":"An aromatic plant (Thymus Serphyllum); -- called also wild thyme.","pos":""}],"MOTHERED":[{"def":"Thick, like mother; viscid.","pos":""}],"MOTHERHOOD":[{"def":"The state of being a mother; the character or office of a mother.","pos":""}],"MOTHERING":[{"def":"A rural custom in England, of visiting one's parents on Midlent Sunday, -- supposed to have been originally visiting the mother church to make offerings at the high altar.","pos":""}],"MOTHERLAND":[{"def":"The country of one's ancestors; -- same as fatherland.","pos":""}],"MOTHERLESS":[{"def":"Destitute of a mother; having lost a mother; as, motherless children.","pos":""}],"MOTHERLINESS":[{"def":"The state or quality of being motherly.","pos":""}],"MOTHERLY":[{"def":"Of or pertaining to a mother; like, or suitable for, a mother; tender; maternal; as, motherly authority, love, or care.","pos":""}],"MOTHERY":[{"def":"Consisting of, containing, or resembling, mother (in vinegar).","pos":""}],"MOTHY":[{"def":"Infested with moths; moth-eaten.","pos":""}],"MOTIFIC":[{"def":"Producing motion.","pos":""}],"MOTILE":[{"def":"Having powers of self-motion, though unconscious; as, the motile spores of certain seaweeds.","pos":""}],"MOTILITY":[{"def":"Capability of motion; contractility.","pos":""}],"MOTION":[{"def":"An application made to a court or judge orally in open court.","pos":""},{"def":"Change of pitch in successive sounds, whether in the same part or in groups of parts.","pos":""}],"MOTION PICTURE":[{"def":"A moving picture.","pos":""}],"MOTIONER":[{"def":"One who makes a motion; a mover.","pos":""}],"MOTIONLESS":[{"def":"Without motion; being at rest.","pos":""}],"MOTIVATE":[{"def":"To provide with a motive; to move; impel; induce; incite.","pos":""}],"MOTIVE":[{"def":"The theme or subject; a leading phrase or passage which is reproduced and varied through the course of a comor a movement; a short figure, or melodic germ, out of which a whole movement is develpoed.","pos":""},{"def":"That which produces conception, invention, or creation in the mind of the artist in undertaking his subject; the guiding or controlling idea manifested in a work of art, or any part of one.","pos":""}],"MOTIVELESS":[{"def":"Destitute of a motive; not incited by a motive.","pos":""}],"MOTIVITY":[{"def":"The power of moving or producing motion.","pos":""},{"def":"The quality of being influenced by motives.","pos":""}],"MOTLEY":[{"def":"Variegated in color; consisting of different colors; dappled; party-colored; as, a motley coat.","pos":""},{"def":"Wearing motley or party-colored clothing.","pos":""}],"MOTLEY-MINDED":[{"def":"Having a mind of a jester; foolish.","pos":""}],"MOTMOT":[{"def":"Any one of several species of long-tailed, passerine birds of the genus Momotus, having a strong serrated beak.","pos":""}],"MOTO":[{"def":"Movement; manner of movement; particularly, movement with increased rapidity; -- used especially in the phrase con moto, directing to a somewhat quicker movement; as, andante con moto, a little more rapidly than andante, etc.","pos":""}],"MOTOGRAPH":[{"def":"A device utilized in the making of a loud-speaking telephone, depending on the fact that the friction between a metallic point and a moving cylinder of moistened chalk, or a moving slip of paper, on which it rests is diminished by the passage of a current between the point and the moving surface.","pos":""}],"MOTON":[{"def":"A small plate covering the armpit in armor of the 14th century and later.","pos":""}],"MOTOR":[{"def":"A prime mover; a machine by means of which a source of power, as steam, moving water, electricity, etc.","pos":""},{"def":"Causing or setting up motion; pertaining to organs of motion; - - applied especially in physiology to those nerves or nerve fibers which only convey impressions from a nerve center to muscles, thereby causing motion.","pos":""}],"MOTOR GENERATOR":[{"def":"The combination consisting of a generator and a driving motor mechanically connected, usually on a common bedplate and with the two shafts directly coupled or combined into a single shaft.","pos":""}],"MOTOR-DRIVEN":[{"def":"Driven or actuated by a motor, esp.","pos":""}],"MOTORING":[{"def":"Act or recreation of riding in or driving a motor car or automobile.","pos":""}],"MOTORIZE":[{"def":"To substitute motor-driven vehicles, or automobiles, for the horses and horse-drawn vehicles of (a fire department, city, etc.","pos":""}],"MOTORMAN":[{"def":"A man who controls a motor.","pos":""}],"MOTORPATHIC":[{"def":"Of or pertaining to motorpathy.","pos":""}],"MOTTE":[{"def":"A clump of trees in a prairie.","pos":""}],"MOTTLE":[{"def":"To mark with spots of different color, or shades of color, as if stained; to spot; to maculate.","pos":""}],"MOTTLED":[{"def":"Marked with spots of different colors; variegated; spotted; as, mottled wood.","pos":""}],"MOTTO":[{"def":"A sentence, phrase, or word, forming part of an heraldic achievment.","pos":""}],"MOTTOED":[{"def":"Bearing or having a motto; as, a mottoed coat or device.","pos":""}],"MOTTY":[{"def":"Full of, or consisting of, motes.","pos":""}]}