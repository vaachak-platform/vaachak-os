{"WET":[{"def":"Employing, or done by means of, water or some other liquid; as, the wet extraction of copper, in distinction from dry extraction in which dry heat or fusion is employed.","pos":""}],"WET NURSE":[{"def":"A nurse who suckles a child, especially the child of another woman.","pos":""}],"WET PLATE":[{"def":"A plate the film of which retains its sensitiveness only while wet.","pos":""}],"WET-BULB THERMOMETER":[{"def":"That one of the two similar thermometers of a psychrometer the bulb of which is moistened; also, the entire instrument.","pos":""}],"WET-SHOD":[{"def":"Having the feet, or the shoes on the feet, wet.","pos":""}],"WETBIRD":[{"def":"The chaffinch, whose cry is thought to foretell rain.","pos":""}],"WETHER":[{"def":"A castrated ram.","pos":""}],"WETNESS":[{"def":"The quality or state of being wet; moisture; humidity; as, the wetness of land; the wetness of a cloth.","pos":""},{"def":"A watery or moist state of the atmosphere; a state of being rainy, foggy, or misty; as, the wetness of weather or the season.","pos":""}],"WETTISH":[{"def":"Somewhat wet; moist; humid.","pos":""}]}