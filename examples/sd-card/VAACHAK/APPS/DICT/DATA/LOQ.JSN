{"LOQUACIOUS":[{"def":"Given to continual talking; talkative; garrulous.","pos":""},{"def":"Speaking; expressive.","pos":""}],"LOQUACIOUSLY":[{"def":"In a loquacious manner.","pos":""}],"LOQUACITY":[{"def":"The habit or practice of talking continually or excessively; inclination to talk too much; talkativeness; garrulity.","pos":""}],"LOQUAT":[{"def":"The fruit of the Japanese medlar (Photinia Japonica).","pos":""}]}