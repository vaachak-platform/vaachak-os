{"CHRYSALID":[{"def":"Pertaining to a chrysalis; resembling a chrysalis.","pos":""}],"CHRYSALIS":[{"def":"The pupa state of certain insects, esp.","pos":""}],"CHRYSANILINE":[{"def":"A yellow substance obtained as a by-product in the manufacture of rosaniline.","pos":""}],"CHRYSANTHEMUM":[{"def":"A genus of composite plants, mostly perennial, and of many species including the many varieties of garden chrysanthemums (annual and perennial), and also the feverfew and the oxeye daisy.","pos":""}],"CHRYSAROBIN":[{"def":"A bitter, yellow substance forming the essential constituent of Goa powder, and yielding chrysophanic acid proper; hence formerly called also chrysphanic acid.","pos":""}],"CHRYSAURIN":[{"def":"An orange-colored dyestuff, of artificial production.","pos":""}],"CHRYSELEPHANTINE":[{"def":"Composed of, or adorned with, gold and ivory.","pos":""}],"CHRYSENE":[{"def":"One of the higher aromatic hydrocarbons of coal tar, allied to napthalene and anthracene.","pos":""}],"CHRYSOBERYL":[{"def":"A mineral, found in crystals, of a yellow to green or brown color, and consisting of aluminia and glucina.","pos":""}],"CHRYSOCHLORE":[{"def":"A South African mole of the genus Chrysochloris; the golden mole, the fur of which reflects brilliant metallic hues of green and gold.","pos":""}],"CHRYSOCOLLA":[{"def":"A hydrous silicate of copper, occurring massive, of a blue or greenish blue color.","pos":""}],"CHRYSOGEN":[{"def":"A yellow crystalline substance extracted from crude anthracene.","pos":""}],"CHRYSOGRAPHY":[{"def":"The art of writing in letters of gold.","pos":""},{"def":"A writing executed in letters of gold.","pos":""}],"CHRYSOIDINE":[{"def":"An artificial, yellow, crystalline dye, C6H5N2.","pos":""}],"CHRYSOLITE":[{"def":"A mineral, composed of silica, magnesia, and iron, of a yellow to green color.","pos":""}],"CHRYSOLOGY":[{"def":"That branch of political economy which relates to the production of wealth.","pos":""}],"CHRYSOPA":[{"def":"A genus of neuropterous insects.","pos":""}],"CHRYSOPHANE":[{"def":"A glucoside extracted from rhubarb as a bitter, yellow, crystalline powder, and yielding chrysophanic acid on decomposition.","pos":""}],"CHRYSOPHANIC":[{"def":"Pertaining to, or derived from, or resembling, chrysophane.","pos":""}],"CHRYSOPRASE":[{"def":"An apple-green variety of chalcedony, colored by nickel.","pos":""}],"CHRYSOPRASUS":[{"def":"See Chrysoprase.","pos":""}],"CHRYSOSPERM":[{"def":"The seed of gold; a means of creating gold.","pos":""}],"CHRYSOTYPE":[{"def":"A photographic picture taken upon paper prepared by the use of a sensitive salt of iron and developed by the application of chloride of gold.","pos":""}]}