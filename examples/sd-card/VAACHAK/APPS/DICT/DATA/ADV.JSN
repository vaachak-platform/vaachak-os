{"ADVANCE":[{"def":"To bring forward; to move towards the van or front; to make to go on.","pos":""},{"def":"To raise; to elevate.","pos":""}],"ADVANCED":[{"def":"In the van or front.","pos":""},{"def":"In the front or before others, as regards progress or ideas; as, advanced opinions, advanced thinkers.","pos":""}],"ADVANCEMENT":[{"def":"Property given, usually by a parent to a child, in advance of a future distribution.","pos":""}],"ADVANCER":[{"def":"One who advances; a promoter.","pos":""},{"def":"A second branch of a buck's antler.","pos":""}],"ADVANCING EDGE":[{"def":"The front edge (in direction of motion) of a supporting surface; -- contr.","pos":""}],"ADVANCING SURFACE":[{"def":"The first of two or more surfaces arranged in tandem; -- contr.","pos":""}],"ADVANCIVE":[{"def":"Tending to advance.","pos":""}],"ADVANTAGE":[{"def":"Any condition, circumstance, opportunity, or means, particularly favorable to success, or to any desired end; benefit; as, the enemy had the advantage of a more elevated position.","pos":""},{"def":"Superiority; mastery; -- with of or over.","pos":""}],"ADVANTAGEOUS":[{"def":"Being of advantage; conferring advantage; gainful; profitable; useful; beneficial; as, an advantageous position; trade is advantageous to a nation.","pos":""}],"ADVANTAGEOUSLY":[{"def":"Profitably; with advantage.","pos":""}],"ADVANTAGEOUSNESS":[{"def":"Ad`van*ta\"geous*ness, n.","pos":""}],"ADVENE":[{"def":"To accede, or come (to); to be added to something or become a part of it, though not essential.","pos":""}],"ADVENIENT":[{"def":"Coming from outward causes; superadded.","pos":""}],"ADVENT":[{"def":"The period including the four Sundays before Christmas.","pos":""}],"ADVENTIST":[{"def":"One of a religious body, embracing several branches, who look for the proximate personal coming of Christ; -- called also Second Adventists.","pos":""}],"ADVENTITIOUS":[{"def":"Out of the proper or usual place; as, adventitious buds or roots.","pos":""},{"def":"Accidentally or sparingly spontaneous in a country or district; not fully naturalized; adventive; -- applied to foreign plants.","pos":""}],"ADVENTIVE":[{"def":"A thing or person coming from without; an immigrant.","pos":""}],"ADVENTUAL":[{"def":"Relating to the season of advent.","pos":""}],"ADVENTURE":[{"def":"That which happens without design; chance; hazard; hap; hence, chance of danger or loss.","pos":""},{"def":"Risk; danger; peril.","pos":""}],"ADVENTUREFUL":[{"def":"Given to adventure.","pos":""}],"ADVENTURER":[{"def":"One who adventures; as, the merchant adventurers; one who seeks his fortune in new and hazardous or perilous enterprises.","pos":""},{"def":"A social pretender on the lookout for advancement.","pos":""}],"ADVENTURESOME":[{"def":"Full of risk; adventurous; venturesome.","pos":""}],"ADVENTURESS":[{"def":"A female adventurer; a woman who tries to gain position by equivocal means.","pos":""}],"ADVENTUROUS":[{"def":"Inclined to adventure; willing to incur hazard; prone to embark in hazardous enterprise; rashly daring; -- applied to persons.","pos":""},{"def":"Full of hazard; attended with risk; exposing to danger; requiring courage; rash; -- applied to acts; as, an adventurous undertaking, deed, song.","pos":""}],"ADVENTUROUSLY":[{"def":"In an adventurous manner; venturesomely; boldly; daringly.","pos":""}],"ADVENTUROUSNESS":[{"def":"The quality or state of being adventurous; daring; venturesomeness.","pos":""}],"ADVERB":[{"def":"A word used to modify the sense of a verb, participle, adjective, or other adverb, and usually placed near it; as, he writes well; paper extremely white.","pos":""}],"ADVERBIAL":[{"def":"Of or pertaining to an adverb; of the nature of an adverb; as, an adverbial phrase or form.","pos":""}],"ADVERBIALITY":[{"def":"The quality of being adverbial.","pos":""}],"ADVERBIALIZE":[{"def":"To give the force or form of an adverb to.","pos":""}],"ADVERBIALLY":[{"def":"In the manner of an adverb.","pos":""}],"ADVERSARIA":[{"def":"A miscellaneous collection of notes, remarks, or selections; a commonplace book; also, commentaries or notes.","pos":""}],"ADVERSARY":[{"def":"One who is turned against another or others with a design to oppose or resist them; a member of an opposing or hostile party; an opponent; an antagonist; an enemy; a foe.","pos":""}],"ADVERSATIVE":[{"def":"Expressing contrariety, opposition, or antithesis; as, an adversative conjunction (but, however, yet, etc.","pos":""}],"ADVERSE":[{"def":"Acting against, or in a contrary direction; opposed; contrary; opposite; conflicting; as, adverse winds; an adverse party; a spirit adverse to distinctions of caste.","pos":""}],"ADVERSELY":[{"def":"In an adverse manner; inimically; unfortunately; contrariwise.","pos":""}],"ADVERSENESS":[{"def":"The quality or state of being adverse; opposition.","pos":""},{"def":"Having opposite leaves, as plants which have the leaves so arranged on the stem.","pos":""}],"ADVERSION":[{"def":"A turning towards; attention.","pos":"noun"}],"ADVERSITY":[{"def":"Opposition; contrariety.","pos":""}],"ADVERT":[{"def":"To turn the mind or attention; to refer; to take heed or notice; -- with to; as, he adverted to what was said.","pos":""},{"def":"The act of adverting, of the quality of being advertent; attention; notice; regard; heedfulness.","pos":""}],"ADVERTENT":[{"def":"Attentive; heedful; regardful.","pos":""}],"ADVERTISE":[{"def":"To give notice to; to inform or apprise; to notify; to make known; hence, to warn; -- often followed by of before the subject of information; as, to advertise a man of his loss.","pos":""}],"ADVERTISEMENT":[{"def":"The act of informing or notifying; notification.","pos":""},{"def":"Admonition; advice; warning.","pos":""}],"ADVERTISER":[{"def":"One who, or that which, advertises.","pos":""}],"ADVICE":[{"def":"Counseling to perform a specific illegal act.","pos":""}],"ADVISABILITY":[{"def":"The quality of being advisable; advisableness.","pos":""}],"ADVISABLE":[{"def":"Proper to be advised or to be done; expedient; prudent.","pos":""},{"def":"Ready to receive advice.","pos":""}],"ADVISABLE-NESS":[{"def":"The quality of being advisable or expedient; expediency; advisability.","pos":""}],"ADVISABLY":[{"def":"With advice; wisely.","pos":""}],"ADVISE":[{"def":"To give advice to; to offer an opinion, as worthy or expedient to be followed; to counsel; to warn.","pos":""},{"def":"To give information or notice to; to inform; -- with of before the thing communicated; as, we were advised of the risk.","pos":""}],"ADVISEDLY":[{"def":"Circumspectly; deliberately; leisurely.","pos":""},{"def":"With deliberate purpose; purposely; by design.","pos":""}],"ADVISEDNESS":[{"def":"Deliberate consideration; prudent procedure; caution.","pos":""}],"ADVISEMENT":[{"def":"Counsel; advise; information.","pos":""},{"def":"Consideration; deliberation; consultation.","pos":""}],"ADVISER":[{"def":"One who advises.","pos":""}],"ADVISERSHIP":[{"def":"The office of an adviser.","pos":""}],"ADVISO":[{"def":"Advice; counsel; suggestion; also, a dispatch or advice boat.","pos":""}],"ADVISORY":[{"def":"Having power to advise; containing advice; as, an advisory council; their opinion is merely advisory.","pos":""}],"ADVOCACY":[{"def":"The act of pleading for or supporting; work of advocating; intercession.","pos":""}],"ADVOCATE":[{"def":"One who pleads the cause of another.","pos":""},{"def":"One who defends, vindicates, or espouses any cause by argument; a pleader; as, an advocate of free trade, an advocate of truth.","pos":""}],"ADVOCATESHIP":[{"def":"Office or duty of an advocate.","pos":""}],"ADVOCATION":[{"def":"The process of removing a cause from an inferior court to the supreme court.","pos":""}],"ADVOCATORY":[{"def":"Of or pertaining to an advocate.","pos":""}],"ADVOKE":[{"def":"To summon; to call.","pos":""}],"ADVOLUTION":[{"def":"A rolling toward something.","pos":""}],"ADVOUTRESS":[{"def":"ADVOUTRY; ADVOWTRY Ad*vou\"try, Ad*vow\"try, n.","pos":""}],"ADVOWEE":[{"def":"One who has an advowson.","pos":""}],"ADVOWSON":[{"def":"The right of presenting to a vacant benefice or living in the church.","pos":""}]}