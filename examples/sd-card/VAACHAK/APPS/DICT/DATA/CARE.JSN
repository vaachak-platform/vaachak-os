{"CARE":[{"def":"A burdensome sense of responsibility; trouble caused by onerous duties; anxiety; concern; solicitude.","pos":""},{"def":"Charge, oversight, or management, implying responsibility for safety and prosperity.","pos":""}],"CARE-TUNED":[{"def":"Weary; mournful.","pos":""}],"CAREEN":[{"def":"To cause (a vessel) to lean over so that she floats on one side, leaving the other side out of water and accessible for repairs below the water line; to case to be off the keel.","pos":""}],"CAREER":[{"def":"The fight of a hawk.","pos":""}],"CAREFUL":[{"def":"Full of care; anxious; solicitous [Archaic] Be careful [Rev.","pos":""},{"def":"Filling with care or colicitube; exposing to concern, anxiety, or trouble; painful.","pos":""}],"CAREFULLY":[{"def":"In a careful manner.","pos":""}],"CAREFULNESS":[{"def":"Quality or state of being careful.","pos":""}],"CARELESS":[{"def":"Free from care or anxiety.","pos":""},{"def":"Having no care; not taking ordinary or proper care; negligent; unconcerned; heedless; inattentive; unmindful; regardless.","pos":""}],"CARELESSLY":[{"def":"In a careless manner.","pos":""}],"CARELESSNESS":[{"def":"The quality or state of being careless; heedlessness; negligenece; inattention.","pos":""}],"CARENE":[{"def":"A fast of forty days on bread and water.","pos":""}],"CARESS":[{"def":"An act of endearment; any act or expression of affection; an embracing, or touching, with tenderness.","pos":""}],"CARESSINGLY":[{"def":"In caressing manner.","pos":""}],"CARET":[{"def":"A mark [^] used by writers and proof readers to indicate that something is interlined above, or inserted in the margin, which belongs in the place marked by the caret.","pos":""}],"CARETUNED":[{"def":"Weary; mournful.","pos":""}],"CAREWORN":[{"def":"Worn or burdened with care; as, careworn look or face.","pos":""}],"CAREX":[{"def":"A numerous and widely distributed genus of perennial herbaceous plants of the order Cypreaceæ; the sedges.","pos":""}]}