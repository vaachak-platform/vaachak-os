{"KIMBO":[{"def":"Crooked; arched; bent.","pos":""}],"KIMNEL":[{"def":"She knew not what a kimnel was Beau.","pos":""}],"KIMONO":[{"def":"A kind of loose robe or gown tied with a sash, worn as an outer garment by Japanese men and women.","pos":""},{"def":"A similar gown worn as a dressing gown by women of Western nations.","pos":""}]}