{"HART":[{"def":"A stag; the male of the red deer.","pos":""}],"HART'S CLOVER":[{"def":"Melilot or sweet clover.","pos":""}],"HART'S-EAR":[{"def":"An Asiatic species of Cacalia (C.","pos":""}],"HARTBEEST":[{"def":"A large South African antelope (Alcelaphus caama), formerly much more abundant than it is now.","pos":""}],"HARTEN":[{"def":"To hearten; to encourage; to incite.","pos":""}],"HARTFORD":[{"def":"The Hartford grape, a variety of grape first raised at Hartford, Connecticut, from the Northern fox grape.","pos":""}],"HARTSHORN":[{"def":"The horn or antler of the hart, or male red deer.","pos":""},{"def":"Spirits of hartshorn (see below); volatile salts.","pos":""}],"HARTWORT":[{"def":"A coarse umbelliferous plant of Europe (Tordylium maximum).","pos":""}]}