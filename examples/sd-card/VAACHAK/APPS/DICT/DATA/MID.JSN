{"MID":[{"def":"Made with a somewhat elevated position of some certain part of the tongue, in relation to the palate; midway between the high and the low; -- said of certain vowel sounds; as, a (ale), ê (êll), o (old).","pos":""}],"MIDA":[{"def":"The larva of the bean fly.","pos":""}],"MIDAS":[{"def":"A genus of longeared South American monkeys, including numerous species of marmosets.","pos":""}],"MIDAS'S EAR":[{"def":"A pulmonate mollusk (Auricula, or Ellobium, aurismidæ); -- so called from resemblance to a human ear.","pos":""}],"MIDBRAIN":[{"def":"The middle segment of the brain; the mesencephalon.","pos":""}],"MIDDAY":[{"def":"The middle part of the day; noon.","pos":""}],"MIDDEN":[{"def":"An accumulation of refuse about a dwelling place; especially, an accumulation of shells or of cinders, bones, and other refuse on the supposed site of the dwelling places of prehistoric tribes, -- as on the shores of the Baltic Sea and in many other places.","pos":""}],"MIDDEN CROW":[{"def":"The common European crow.","pos":""}],"MIDDEST":[{"def":"Situated most nearly in the middle; middlemost; midmost.","pos":""}],"MIDDLE":[{"def":"Equally distant from the extreme either of a number of things or of one thing; mean; medial; as, the middle house in a row; a middle rank or station in life; flowers of middle summer; men of middle age.","pos":""},{"def":"Intermediate; intervening.","pos":""}],"MIDDLE-AGE":[{"def":"Of or pertaining to the Middle Ages; mediæval.","pos":""}],"MIDDLE-AGED":[{"def":"Being about the middle of the ordinary age of man; between 30 and 50 years old.","pos":""}],"MIDDLE-EARTH":[{"def":"The world, considered as lying between heaven and hell.","pos":""}],"MIDDLE-GROUND":[{"def":"That part of a picture between the foreground and the background.","pos":""}],"MIDDLEMAN":[{"def":"The man who occupies a central position in a file of soldiers.","pos":""}],"MIDDLEMOST":[{"def":"Being in the middle, or nearest the middle; midmost.","pos":""}],"MIDDLER":[{"def":"One of a middle or intermediate class in some schools and seminaries.","pos":""}],"MIDDLING":[{"def":"Of middle rank, state, size, or quality; about equally distant from the extremes; medium; moderate; mediocre; ordinary.","pos":""}],"MIDDLINGS":[{"def":"A combination of the coarser parts of ground wheat the finest bran, separated from the fine flour and coarse bran in bolting; -- formerly regarded as valuable only for feed; but now, after separation of the bran, used for making the best quality of flour.","pos":""},{"def":"In the southern and western parts of the United States, the portion of the hog between the ham and the shoulder; bacon; -- called also middles.","pos":""}],"MIDDY":[{"def":"A colloquial abbreviation of midshipman.","pos":""}],"MIDFEATHER":[{"def":"A vertical water space in a fire box or combustion chamber.","pos":""},{"def":"A support for the center of a tunnel.","pos":""}],"MIDGARD":[{"def":"The middle space or region between heaven and hell; the abode of human beings; the earth.","pos":""},{"def":"The middle space or region between heaven and hell, the abode of human beings; the earth.","pos":""}],"MIDGE":[{"def":"Any one of many small, delicate, long-legged flies of the Chironomus, and allied genera, which do not bite.","pos":""},{"def":"A very small fly, abundant in many parts of the United States and Canada, noted for the irritating quality of its bite.","pos":""}],"MIDGET":[{"def":"A minute bloodsucking fly.","pos":""}],"MIDGUT":[{"def":"The middle part of the alimentary canal from the stomach, or entrance of the bile duct, to, or including, the large intestine.","pos":""}],"MIDHEAVEN":[{"def":"The meridian, or middle line of the heavens; the point of the ecliptic on the meridian.","pos":""}],"MIDLAND":[{"def":"Being in the interior country; distant from the coast or seashore; as, midland towns or inhabitants.","pos":""},{"def":"Surrounded by the land; mediterranean.","pos":""}],"MIDMAIN":[{"def":"The middle part of the main or sea.","pos":""}],"MIDMOST":[{"def":"Middle; middlemost.","pos":""}],"MIDNIGHT":[{"def":"The middle of the night; twelve o'clock at night.","pos":""}],"MIDNIGHT SUN":[{"def":"The sun shining at midnight in the arctic or antarctic summer.","pos":""}],"MIDRASH":[{"def":"A talmudic exposition of the Hebrew law, or of some part of it.","pos":""}],"MIDRIB":[{"def":"A continuation of the petiole, extending from the base to the apex of the lamina of a leaf.","pos":""}],"MIDRIFF":[{"def":"See Diaphragm, n.","pos":""},{"def":"The middle part of the sea or ocean.","pos":""}],"MIDSHIP":[{"def":"Of or pertaining to, or being in, the middle of a ship.","pos":""}],"MIDSHIPMAN":[{"def":"An American marine fish of the genus Porichthys, allied to the toadfish.","pos":""}],"MIDSHIPS":[{"def":"In the middle of a ship; -- properly amidships.","pos":""}],"MIDST":[{"def":"The interior or central part or place; the middle; -- used chiefly in the objective case after in; as, in the midst of the forest.","pos":""},{"def":"Hence, figuratively, the condition of being surrounded or beset; the press; the burden; as, in the midst of official duties; in the midst of secular affairs.","pos":""}],"MIDSUMMER":[{"def":"The middle of summer.","pos":""}],"MIDWARD":[{"def":"Situated in the middle.","pos":""}],"MIDWAY":[{"def":"The middle of the way or distance; a middle way or course.","pos":""}],"MIDWEEK":[{"def":"The middle of the week.","pos":""}],"MIDWIFE":[{"def":"A woman who assists other women in childbirth; a female practitioner of the obstetric art.","pos":""}],"MIDWIFERY":[{"def":"The art or practice of assisting women in childbirth; obstetrics.","pos":""},{"def":"Assistance at childbirth; help or coöperation in production.","pos":""}],"MIDWINTER":[{"def":"The middle of winter.","pos":""}]}