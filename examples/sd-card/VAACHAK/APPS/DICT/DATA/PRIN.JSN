{"PRINCE":[{"def":"The one of highest rank; one holding the highest place and authority; a sovereign; a monarch; -- originally applied to either sex, but now rarely applied to a female.","pos":""},{"def":"The son of a king or emperor, or the issue of a royal family; as, princes of the blood.","pos":""}],"PRINCEDOM":[{"def":"The jurisdiction, sovereignty, rank, or estate of a prince.","pos":""}],"PRINCEKIN":[{"def":"A petty prince; a princeling.","pos":""}],"PRINCELESS":[{"def":"Without a prince.","pos":""}],"PRINCELINESS":[{"def":"The quality of being princely; the state, manner, or dignity of a prince.","pos":""}],"PRINCELING":[{"def":"A petty prince; a young prince.","pos":""}],"PRINCELY":[{"def":"Of or relating to a prince; regal; royal; of highest rank or authority; as, princely birth, character, fortune, etc.","pos":""},{"def":"Suitable for, or becoming to, a prince; grand; august; munificent; magnificent; as, princely virtues; a princely fortune.","pos":""}],"PRINCESS":[{"def":"A female prince; a woman having sovereign power, or the rank of a prince.","pos":""},{"def":"The daughter of a sovereign; a female member of a royal family.","pos":""}],"PRINCESSE":[{"def":"A term applied to a lady's long, close-fitting dress made with waist and skirt in one.","pos":""}],"PRINCESSLIKE":[{"def":"Like a princess.","pos":""}],"PRINCEWOOD":[{"def":"The wood of two small tropical American trees (Hamelia ventricosa, and Cordia gerascanthoides).","pos":""}],"PRINCIFIED":[{"def":"Imitative of a prince.","pos":""}],"PRINCIPAL":[{"def":"Highest in rank, authority, character, importance, or degree; most considerable or important; chief; main; as, the principal officers of a Government; the principal men of a state; the principal productions of a country; the principal arguments in a case.","pos":""},{"def":"Of or pertaining to a prince; princely.","pos":""}],"PRINCIPALITY":[{"def":"Sovereignty; supreme power; hence, superiority; predominance; high, or the highest, station.","pos":""},{"def":"A prince; one invested with sovereignty.","pos":""}],"PRINCIPALLY":[{"def":"In a principal manner; primarily; above all; chiefly; mainly.","pos":""}],"PRINCIPALNESS":[{"def":"The quality of being principal.","pos":""}],"PRINCIPATE":[{"def":"Principality; supreme rule.","pos":""}],"PRINCIPIA":[{"def":"First principles; fundamental beginnings; elements; as.","pos":""}],"PRINCIPIANT":[{"def":"Relating to principles or beginnings.","pos":""}],"PRINCIPIATE":[{"def":"To begin; to initiate.","pos":""}],"PRINCIPIATION":[{"def":"Analysis into primary or elemental parts.","pos":""}],"PRINCIPLE":[{"def":"Any original inherent constituent which characterizes a substance, or gives it its essential properties, and which can usually be separated by analysis; -- applied especially to drugs, plant extracts, etc.","pos":""}],"PRINK":[{"def":"To dress or adjust one's self for show; to prank.","pos":""}],"PRINPRIDDLE":[{"def":"The longtailed titmouse.","pos":""}],"PRINT":[{"def":"To strike off an impression or impressions of, from type, or from stereotype, electrotype, or engraved plates, or the like; in a wider sense, to do the typesetting, presswork, etc.","pos":""},{"def":"To take (a copy, a positive picture, etc.","pos":""}],"PRINTA-BLE":[{"def":"Worthy to be published.","pos":""}],"PRINTER":[{"def":"One who prints; especially, one who prints books, newspapers, engravings, etc.","pos":""}],"PRINTERY":[{"def":"A place where cloth is printed; print works; also, a printing office.","pos":""}],"PRINTING":[{"def":"The act, art, or practice of impressing letters, characters, or figures on paper, cloth, or other material; the business of a printer, including typesetting and presswork, with their adjuncts; typography; also, the act of producing photographic prints.","pos":""}],"PRINTING IN":[{"def":"A process by which cloud effects or other features not in the original negative are introduced into a photograph.","pos":""}],"PRINTING OUT":[{"def":"A method of printing, in which the image is fully brought out by the direct actinic action of light without subsequent development by means of chemicals.","pos":""}],"PRINTLESS":[{"def":"Making no imprint.","pos":""}],"PRINTSHOP":[{"def":"A shop where prints are sold.","pos":""}]}