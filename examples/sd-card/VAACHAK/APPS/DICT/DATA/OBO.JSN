{"OBOE":[{"def":"One of the higher wind instruments in the modern orchestra, yet of great antiquity, having a penetrating pastoral quality of tone, somewhat like the clarinet in form, but more slender, and sounded by means of a double reed; a hautboy.","pos":""}],"OBOIST":[{"def":"A performer on the oboe.","pos":""}],"OBOLARY":[{"def":"Possessing only small coins; impoverished.","pos":""}],"OBOLE":[{"def":"A weight of twelve grains; or, according to some, of ten grains, or half a scruple.","pos":""}],"OBOLO":[{"def":"A copper coin, used in the Ionian Islands, about one cent in value.","pos":""}],"OBOMEGOID":[{"def":"Obversely omegoid.","pos":""}],"OBOVATE":[{"def":"Inversely ovate; ovate with the narrow end downward; as, an obovate leaf.","pos":""}]}