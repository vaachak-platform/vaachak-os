{"GOPHER":[{"def":"One of several North American burrowing rodents of the genera Geomys and Thomomys, of the family Geomyidæ; -- called also pocket gopher and pouched rat.","pos":""},{"def":"One of several western American species of the genus Spermophilus, of the family Sciuridæ; as, the gray gopher (Spermophilus Franklini) and the striped gopher (S.","pos":""}],"GOPHER STATE":[{"def":"Minnesota; -- a nickname alluding to the abundance of gophers.","pos":""}],"GOPHER WOOD":[{"def":"A species of wood used in the construction of Noah's ark.","pos":""}]}