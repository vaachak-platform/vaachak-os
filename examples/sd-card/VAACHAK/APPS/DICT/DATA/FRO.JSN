{"FRO":[{"def":"From; away; back or backward; -- now used only in oppositionto the word to, in the phrase to and fro, that is, to and from.","pos":""}],"FROCK":[{"def":"A loose outer garment; especially, a gown forming a part of European modern costume for women and children; also, a coarse hirtlike garment worn by some workmen over their ther clothes; a smock frock; as, a marketman's frock.","pos":""},{"def":"A coarse gown worn by monks or friars, and supposed to take the place of all, or nearly all, other garments.","pos":""}],"FROCKED":[{"def":"Clothed in a frock.","pos":""}],"FROCKLESS":[{"def":"Destitute of a frock.","pos":""}],"FROE":[{"def":"A dirty woman; a slattern; a frow.","pos":""}],"FROEBELIAN":[{"def":"Pertaining to, or derived from, Friedrich Froebel, or the kindergarten system of education, which he organized.","pos":""},{"def":"One who teaches by, or advocates the use of, the kindergarten system.","pos":""}],"FROG":[{"def":"The triangular prominence of the hoof, in the middle of the sole of the foot of the horse, and other animals; the fourchette.","pos":""}],"FROG-EYED":[{"def":"Spotted with whitish specks due to a disease, or produced artificially by spraying; -- said of tobacco used for cigar wrappers.","pos":""}],"FROGGED":[{"def":"Provided or ornamented with frogs; as, a frogged coat.","pos":""}],"FROGGY":[{"def":"Abounding in frogs.","pos":""}],"FROGMOUTH":[{"def":"One of several species of Asiatic and East Indian birds of the genus Batrachostomus (family Podargidæ); -- so called from their very broad, flat bills.","pos":""}],"FROGSHELL":[{"def":"One of numerous species of marine gastropod shells, belonging to Ranella and allied genera.","pos":""}],"FROISE":[{"def":"A kind of pancake.","pos":""}],"FROLIC":[{"def":"Full of levity; dancing, playing, or frisking about; full of pranks; frolicsome; gay; merry.","pos":""}],"FROLICLY":[{"def":"In a frolicsome manner; with mirth and gayety.","pos":""}],"FROLICSOME":[{"def":"Full of gayety and mirth; given to pranks; sportive.","pos":""}],"FROM":[{"def":"Out of the neighborhood of; lessening or losing proximity to; leaving behind; by reason of; out of; by aid of; -- used whenever departure, setting out, commencement of action, being, state, occurrence, etc.","pos":""},{"def":"A way from; -- the contrary of toward.","pos":""}],"FROND":[{"def":"The organ formed by the combination or union into one body of stem and leaf, and often bearing the fructification; as, the frond of a fern or of a lichen or seaweed; also, the peculiar leaf of a palm tree.","pos":""}],"FRONDATION":[{"def":"The act of stripping, as trees, of leaves or branches; a kind of pruning.","pos":""}],"FRONDE":[{"def":"A political party in France, during the minority of Louis XIV.","pos":""}],"FRONDED":[{"def":"Furnished with fronds.","pos":""}],"FRONDENT":[{"def":"Covered with leaves; leafy; as, a frondent tree.","pos":""}],"FRONDESCE":[{"def":"To unfold leaves, as plants.","pos":""}],"FRONDEUR":[{"def":"A member of the Fronde.","pos":""}],"FRONDIFEROUS":[{"def":"Producing fronds.","pos":""}],"FRONDLET":[{"def":"A very small frond, or distinct portion of a compound frond.","pos":""}],"FRONS":[{"def":"The forehead; the part of the cranium between the orbits and the vertex.","pos":""}],"FRONT":[{"def":"The forehead or brow, the part of the face above the eyes; sometimes, also, the whole face.","pos":""},{"def":"The forehead, countenance, or personal presence, as expressive of character or temper, and especially, of boldness of disposition, sometimes of impudence; seeming; as, a bold front; a hardened front.","pos":""}],"FRONTAGE":[{"def":"The front part of an edifice or lot; extent of front.","pos":""}],"FRONTAL":[{"def":"Belonging to the front part; being in front; esp.","pos":""},{"def":"Of or pertaining to the forehead or the anterior part of the roof of the brain case; as, the frontal bones.","pos":""}],"FRONTED":[{"def":"Formed with a front; drawn up in line.","pos":""}],"FRONTIER":[{"def":"That part of a country which fronts or faces another country or an unsettled region; the marches; the border, confine, or extreme part of a country, bordering on another country; the border of the settled and cultivated part of a country; as, the frontier of civilization.","pos":""}],"FRONTIERED":[{"def":"Placed on the frontiers.","pos":""}],"FRONTIERSMAN":[{"def":"A man living on the frontier.","pos":""},{"def":"A grape of many varieties and colors.","pos":""}],"FRONTINGLY":[{"def":"In a fronting or facing position; opposingly.","pos":""}],"FRONTISPIECE":[{"def":"The part which first meets the eye; as: (a) (Arch.","pos":""}],"FRONTLESS":[{"def":"Without face or front; shameless; not diffident; impudent.","pos":""}],"FRONTLESSLY":[{"def":"Shamelessly; impudently.","pos":""}],"FRONTLET":[{"def":"The margin of the head, behind the bill of birds, often bearing rigid bristles.","pos":""}],"FRONTO-":[{"def":"A combining form signifying relating to the forehead or the frontal bone; as, fronto-parietal, relating to the frontal and the parietal bones; fronto-nasal, etc.","pos":""}],"FRONTON":[{"def":"Same as Frontal, 2.","pos":""}],"FROPPISH":[{"def":"Peevish; froward.","pos":""}],"FRORE":[{"def":"The parching air Burns frore, and cold performs the effect of fire.","pos":""}],"FRORN":[{"def":"Well nigh frorn I feel.","pos":""}],"FRORY":[{"def":"Frozen; stiff with cold.","pos":""},{"def":"Covered with a froth like hoarfrost.","pos":""}],"FROST":[{"def":"The act of freezing; -- applied chiefly to the congelation of water; congelation of fluids.","pos":""},{"def":"The state or temperature of the air which occasions congelation, or the freezing of water; severe cold or freezing weather.","pos":""}],"FROST SIGNAL":[{"def":"A signal consisting of a white flag with a black center, used by the United States Weather Bureau to indicate that a local frost is expected.","pos":""}],"FROST-BITTEN":[{"def":"Nipped, withered, or injured, by frost or freezing.","pos":""}],"FROSTBIRD":[{"def":"The golden plover.","pos":""}],"FROSTBITE":[{"def":"The freezing, or effect of a freezing, of some part of the body, as the ears or nose.","pos":""}],"FROSTBOW":[{"def":"A white arc or circle in the sky attending frosty weather and formed by reflection of sunlight from ice crystals floating in the air; the parhelic circle whose center is at the zenith.","pos":""}],"FROSTED":[{"def":"Covered with hoarfrost or anything resembling hoarfrost; ornamented with frosting; also, frost-bitten; as, a frosted cake; frosted glass.","pos":""}],"FROSTFISH":[{"def":"England coast in autumn at about the commencement of frost.","pos":""}],"FROSTILY":[{"def":"In a frosty manner.","pos":""}],"FROSTINESS":[{"def":"State or quality of being frosty.","pos":""}],"FROSTING":[{"def":"A composition of sugar and beaten egg, used to cover or ornament cake, pudding, etc.","pos":""},{"def":"A lusterless finish of metal or glass; the process of producing such a finish.","pos":""}],"FROSTLESS":[{"def":"Free from frost; as, a frostless winter.","pos":""}],"FROSTWEED":[{"def":"An American species of rockrose (Helianthemum Canadense), sometimes used in medicine as an astringent or aromatic tonic.","pos":""}],"FROSTWORK":[{"def":"The figurework, often fantastic and delicate, which moisture sometimes forms in freezing, as upon a window pane or a flagstone.","pos":""}],"FROSTWORT":[{"def":"Same as Frostweed.","pos":""}],"FROSTY":[{"def":"Attended with, or producing, frost; having power to congeal water; cold; freezing; as, a frosty night.","pos":""},{"def":"Covered with frost; as, the grass is frosty.","pos":""}],"FROTE":[{"def":"To rub or wear by rubbing; to chafe.","pos":""}],"FROTERER":[{"def":"One who frotes; one who rubs or chafes.","pos":""}],"FROTH":[{"def":"The bubbles caused in fluids or liquors by fermentation or agitation; spume; foam; esp.","pos":""},{"def":"Any empty, senseless show of wit or eloquence; rhetoric without thought.","pos":""}],"FROTHILY":[{"def":"In a frothy manner.","pos":""}],"FROTHINESS":[{"def":"State or quality of being frothy.","pos":""}],"FROTHING":[{"def":"Exaggerated declamation; rant.","pos":""}],"FROTHLESS":[{"def":"Free from froth.","pos":""}],"FROTHY":[{"def":"Full of foam or froth, or consisting of froth or light bubbles; spumous; foamy.","pos":""},{"def":"Not firm or solid; soft; unstable.","pos":""}],"FROUFROU":[{"def":"A rustling, esp.","pos":""}],"FROUNCE":[{"def":"To gather into or adorn with plaits, as a dress; to form wrinkles in or upon; to curl or frizzle, as the hair.","pos":""}],"FROUNCELESS":[{"def":"Without frounces.","pos":""}],"FROUZY":[{"def":"Fetid, musty; rank; disordered and offensive to the smell or sight; slovenly; dingy.","pos":""}],"FROW":[{"def":"A woman; especially, a Dutch or German woman.","pos":""},{"def":"A dirty woman; a slattern.","pos":""}],"FROWARD":[{"def":"Not willing to yield or compIy with what is required or is reasonable; perverse; disobedient; peevish; as, a froward child.","pos":""}],"FROWEY":[{"def":"Working smoothly, or without splitting; -- said of timber.","pos":""}],"FROWN":[{"def":"To contract the brow in displeasure, severity, or sternness; to scowl; to put on a stern, grim, or surly look.","pos":""},{"def":"To manifest displeasure or disapprobation; to look with disfavor or threateningly; to lower; as, polite society frowns upon rudeness.","pos":""}],"FROWNINGLY":[{"def":"In a frowning manner.","pos":""}],"FROWNY":[{"def":"Frowning; scowling.","pos":""}],"FROWZY":[{"def":"Slovenly; unkempt; untidy; frouzy.","pos":""}],"FROZEN":[{"def":"Congealed with cold; affected by freezing; as, a frozen brook.","pos":""},{"def":"Subject to frost, or to long and severe cold; chilly; as, the frozen north; the frozen zones.","pos":""}],"FROZENNESS":[{"def":"A state of being frozen.","pos":""}]}