{"TON":[{"def":"The common tunny, or house mackerel.","pos":""}],"TON MILEAGE":[{"def":"Ton miles collectively; esp.","pos":""}],"TONALITY":[{"def":"The principle of key in music; the character which a composition has by virtue of the key in which it is written, or through the family relationship of all its tones and chords to the keynote, or tonic, of the whole.","pos":""}],"TONE":[{"def":"Accent, or inflection or modulation of the voice, as adapted to express emotion or passion.","pos":""},{"def":"That state of a body, or of any of its organs or parts, in which the animal functions are healthy and performed with due vigor.","pos":""}],"TONED":[{"def":"Having (such) a tone; -- chiefly used in composition; as, high- toned; sweet-toned.","pos":""}],"TONELESS":[{"def":"Having no tone; unmusical.","pos":""}],"TONGA":[{"def":"A drug useful in neuralgia, derived from a Fijian plant supposed to be of the aroid genus Epipremnum.","pos":""}],"TONGKANG":[{"def":"A kind of boat or junk used in the seas of the Malay Archipelago.","pos":""}],"TONGO":[{"def":"The mangrove; -- so called in the Pacific Islands.","pos":""}],"TONGS":[{"def":"An instrument, usually of metal, consisting of two parts, or long shafts, jointed together at or near one end, or united by an elastic bow, used for handling things, especially hot coals or metals; -- often called a pair of tongs.","pos":""}],"TONGUE":[{"def":"an organ situated in the floor of the mouth of most vertebrates and connected with the hyoid arch.","pos":""}],"TONGUE-SHAPED":[{"def":"Shaped like a tongue; specifically (Bot.","pos":""}],"TONGUE-SHELL":[{"def":"Any species of Lingula.","pos":""}],"TONGUE-TIE":[{"def":"Impeded motion of the tongue because of the shortness of the frænum, or of the adhesion of its margins to the gums.","pos":""}],"TONGUE-TIED":[{"def":"Destitute of the power of distinct articulation; having an impediment in the speech, esp.","pos":""},{"def":"Unable to speak freely, from whatever cause.","pos":""}],"TONGUED":[{"def":"Having a tongue.","pos":""}],"TONGUEFISH":[{"def":"A flounder (Symphurus plagiusa) native of the southern coast of the United States.","pos":""}],"TONGUELESS":[{"def":"Having no tongue.","pos":""},{"def":"Hence, speechless; mute.","pos":""}],"TONGUELET":[{"def":"A little tongue.","pos":""}],"TONGUESTER":[{"def":"One who uses his tongue; a talker; a story-teller; a gossip.","pos":""}],"TONGUEWORM":[{"def":"Any species of Linguatulina.","pos":""}],"TONGUY":[{"def":"Ready or voluble in speaking; as, a tonguy speaker.","pos":""}],"TONIC":[{"def":"Increasing strength, or the tone of the animal system; obviating the effects of debility, and restoring heatly functions.","pos":""}],"TONICITY":[{"def":"The state of healty tension or partial contraction of muscle fibers while at rest; tone; tonus.","pos":""}],"TONIGHT":[{"def":"On this present or coming night.","pos":""},{"def":"On the last night past.","pos":""}],"TONITE":[{"def":"An explosive compound; a preparation of gun cotton.","pos":""}],"TONKA BEAN":[{"def":"The seed of a leguminous tree (Dipteryx odorata), native of Guiana.","pos":""}],"TONNAGE":[{"def":"The weight of goods carried in a boat or a ship.","pos":""},{"def":"The cubical content or burden of a vessel, or vessels, in tons; or, the amount of weight which one or several vessels may carry.","pos":""}],"TONNEAU":[{"def":"In France, a light-wheeled vehicle with square or rounded body and rear entrance.","pos":""}],"TONNIHOOD":[{"def":"The female of the bullfinch; -- called also tonyhoop.","pos":""}],"TONNISH":[{"def":"In the ton; fashionable; modish.","pos":""}],"TONOMETER":[{"def":"An instrument for determining the rate of vibrations in tones.","pos":""}],"TONOMETRY":[{"def":"The act of measuring with a tonometer; specifically (Med.","pos":""}],"TONOPHANT":[{"def":"A modification of the kaleidophon, for showing composition of acoustic vibrations.","pos":""}],"TONOUS":[{"def":"Abounding in tone or sound.","pos":""}],"TONQUIN BEAN":[{"def":"Ton\"quin bean` Defn: See Tonka bean.","pos":""}],"TONSIL":[{"def":"One of the two glandular organs situated in the throat at the sides of the fauces.","pos":""}],"TONSILAR":[{"def":"Of or pertaining to the tonsils; tonsilitic.","pos":""}],"TONSILE":[{"def":"Capable of being clipped.","pos":""}],"TONSILITIS":[{"def":"Inflammation of the tonsil; quinsy.","pos":""}],"TONSILOTOME":[{"def":"An instrument for removing the tonsils.","pos":""}],"TONSILOTOMY":[{"def":"The operation of removing the tonsil, or a portion thereof.","pos":""}],"TONSORIAL":[{"def":"Of or pertaining to a barber, or shaving.","pos":""}],"TONSURE":[{"def":"The act of clipping the hair, or of shaving the crown of the head; also, the state of being shorn.","pos":""}],"TONSURED":[{"def":"Having the tonsure; shaven; shorn; clipped; hence, bald.","pos":""}],"TONTINE":[{"def":"An annuity, with the benefit of survivorship, or a loan raised on life annuities with the benefit of survivorship.","pos":""}],"TONTINE INSURANCE":[{"def":"Insurance in which the benefits of the insurance are distributed upon the tontine principle.","pos":""}],"TONUS":[{"def":"Tonicity, or tone; as, muscular tonus.","pos":""}],"TONY":[{"def":"A pattern and companion fit For all the keeping tonies of the pit.","pos":""}]}