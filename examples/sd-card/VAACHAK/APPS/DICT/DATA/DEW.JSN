{"DEW":[{"def":"Moisture from the atmosphere condensed by cool bodies upon their surfaces, particularly at night.","pos":""},{"def":"Figuratively, anything which falls lightly and in a refreshing manner.","pos":""}],"DEW-POINT":[{"def":"The temperature at which dew begins to form.","pos":""}],"DEWAR VESSEL":[{"def":"A double-walled glass vessel for holding liquid air, etc.","pos":""}],"DEWBERRY":[{"def":"Feed him with apricots and dewberries.","pos":""}],"DEWCLAW":[{"def":"In any animal, esp.","pos":""}],"DEWFALL":[{"def":"The falling of dew; the time when dew begins to fall.","pos":""}],"DEWINESS":[{"def":"State of being dewy.","pos":""}],"DEWLAP":[{"def":"The pendulous skin under the neck of an ox, which laps or licks the dew in grazing.","pos":""},{"def":"The flesh upon the human throat, especially when with age.","pos":""}],"DEWLAPPED":[{"def":"Furnished with a dewlap.","pos":""}],"DEWRET":[{"def":"To ret or rot by the process called dewretting.","pos":""}],"DEWRETTING":[{"def":"Dewrotting; the process of decomposing the gummy matter of flax and hemp and setting the fibrous part, by exposure on a sward to dew, rain, and sunshine.","pos":""}],"DEWROT":[{"def":"To rot, as flax or hemp, by exposure to rain, dew, and sun.","pos":""}],"DEWY":[{"def":"Resembling a dew-covered surface; appearing as if covered with dew.","pos":""}]}