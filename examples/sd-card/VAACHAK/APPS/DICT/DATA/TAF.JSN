{"TAFFERER":[{"def":"A fine, smooth stuff of silk, having usually the wavy luster called watering.","pos":""}],"TAFFRAIL":[{"def":"The upper part of a ship's stern, which is flat like a table on the top, and sometimes ornamented with carved work; the rail around a ship's stern.","pos":""}],"TAFFY":[{"def":"A kind of candy made of molasses or brown sugar boiled down and poured out in shallow pans.","pos":""},{"def":"Flattery; soft phrases.","pos":""}],"TAFIA":[{"def":"A variety of rum.","pos":""}]}