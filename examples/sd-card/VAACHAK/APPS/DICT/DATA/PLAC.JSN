{"PLACABILITY":[{"def":"The quality or state of being placable or appeasable; placable disposition.","pos":""}],"PLACABLE":[{"def":"Capable of being appeased or pacified; ready or willing to be pacified; willing to forgive or condone.","pos":""}],"PLACABLENESS":[{"def":"The quality of being placable.","pos":""}],"PLACARD":[{"def":"An extra plate on the lower part of the breastplate or backplate.","pos":""},{"def":"A kind of stomacher, often adorned with jewels, worn in the fifteenth century and later.","pos":""}],"PLACATE":[{"def":"Same as Placard, 4 & 5.","pos":""}],"PLACATION":[{"def":"The act of placating.","pos":""}],"PLACE":[{"def":"Position in the heavens, as of a heavenly body; -- usually defined by its right ascension and declination, or by its latitude and longitude.","pos":""}],"PLACE-KICK":[{"def":"To make a place kick; to make (a goal) by a place kick.","pos":""}],"PLACE-PROUD":[{"def":"Proud of rank or office.","pos":""}],"PLACEBO":[{"def":"The first antiphon of the vespers for the dead.","pos":""},{"def":"A prescription intended to humor or satisfy.","pos":""}],"PLACEFUL":[{"def":"In the appointed place.","pos":""}],"PLACELESS":[{"def":"Having no place or office.","pos":""}],"PLACEMAN":[{"def":"One who holds or occupies a place; one who has office under government.","pos":""}],"PLACEMENT":[{"def":"The act of placing, or the state of being placed.","pos":""},{"def":"Position; place.","pos":""}],"PLACENTA":[{"def":"The vascular appendage which connects the fetus with the parent, and is cast off in parturition with the afterbirth.","pos":""},{"def":"The part of a pistil or fruit to which the ovules or seeds are attached.","pos":""}],"PLACENTAL":[{"def":"Of or pertaining to the Placentalia.","pos":""}],"PLACENTALIA":[{"def":"A division of Mammalia including those that have a placenta, or all the orders above the marsupials.","pos":""}],"PLACENTARY":[{"def":"Having reference to the placenta; as, the placentary system of classification.","pos":""}],"PLACENTATION":[{"def":"The mode of formation of the placenta in different animals; as, the placentation of mammals.","pos":""},{"def":"The mode in which the placenta is arranged or composed; as, axile placentation; parietal placentation.","pos":""}],"PLACENTIFEROUS":[{"def":"Having or producing a placenta.","pos":""}],"PLACENTIFORM":[{"def":"Having the shape of a placenta, or circular thickened disk somewhat thinner about the middle.","pos":""}],"PLACENTIOUS":[{"def":"Pleasing; amiable.","pos":""}],"PLACER":[{"def":"One who places or sets.","pos":""}],"PLACET":[{"def":"A vote of assent, as of the governing body of a university, of an ecclesiastical council, etc.","pos":""},{"def":"The assent of the civil power to the promulgation of an ecclesiastical ordinance.","pos":""}],"PLACID":[{"def":"Pleased; contented; unruffied; undisturbed; serene; peaceful; tranquil; quiet; gentle.","pos":""}],"PLACIDITY":[{"def":"The quality or state of being placid; calmness; serenity.","pos":""}],"PLACIDLY":[{"def":"In a placid manner.","pos":""}],"PLACIDNESS":[{"def":"The quality or state of being placid.","pos":""}],"PLACIT":[{"def":"A decree or determination; a dictum.","pos":""}],"PLACITORY":[{"def":"Of or pertaining to pleas or pleading, in courts of law.","pos":""}],"PLACITUM":[{"def":"A court, or cause in court.","pos":""},{"def":"A plea; a pleading; a judicial proceeding; a suit.","pos":""}],"PLACK":[{"def":"A small copper coin formerly current in Scotland, worth less than a cent.","pos":""}],"PLACKET":[{"def":"A petticoat, esp.","pos":""},{"def":"The opening or slit left in a petticoat or skirt for convenience in putting it on; -- called also placket hole.","pos":""}],"PLACODERM":[{"def":"One of the Placodermi.","pos":""}],"PLACODERMAL":[{"def":"Of or pertaining to the placoderms; like the placoderms.","pos":""}],"PLACODERMATA":[{"def":"Same as Placodermi.","pos":""}],"PLACODERMI":[{"def":"An extinct group of fishes, supposed to be ganoids.","pos":""}],"PLACOGANOID":[{"def":"Pertaining to the Placoganoidei.","pos":""}],"PLACOGANOIDEI":[{"def":"A division of ganoid fishes including those that have large external bony plates and a cartilaginous skeleton.","pos":""}],"PLACOID":[{"def":"Platelike; having irregular, platelike, bony scales, often bearing spines; pertaining to the placoids.","pos":""}],"PLACOIDES":[{"def":"A group of fishes including the sharks and rays; the Elasmobranchii; -- called also Placoidei.","pos":""}],"PLACOIDIAN":[{"def":"One of the placoids.","pos":""}],"PLACOPHORA":[{"def":"A division of gastropod Mollusca, including the chitons.","pos":""}]}