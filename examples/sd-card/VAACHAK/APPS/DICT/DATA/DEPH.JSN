{"DEPHASE":[{"def":"To put out of phase, as two parts of a single alternating current.","pos":""}],"DEPHLEGM":[{"def":"To rid of phlegm or water; to dephlegmate.","pos":""}],"DEPHLEGMATE":[{"def":"To deprive of superabundant water, as by evaporation or distillation; to clear of aqueous matter; to rectify; -- used of spirits and acids.","pos":""}],"DEPHLEGMATION":[{"def":"The operation of separating water from spirits and acids, by evaporation or repeated distillation; -- called also concentration, especially when acids are the subject of it.","pos":""}],"DEPHLEGMATOR":[{"def":"An instrument or apparatus in which water is separated by evaporation or distillation; the part of a distilling apparatus in which the separation of the vapors is effected.","pos":""}],"DEPHLEGMATORY":[{"def":"Pertaining to, or producing, dephlegmation.","pos":""}],"DEPHLEGMEDNESS":[{"def":"A state of being freed from water.","pos":""}],"DEPHLOGISTICCATE":[{"def":"To deprive of phlogiston, or the supposed principle of inflammability.","pos":""}],"DEPHOSPHORIZATION":[{"def":"The act of freeing from phosphorous.","pos":""}]}