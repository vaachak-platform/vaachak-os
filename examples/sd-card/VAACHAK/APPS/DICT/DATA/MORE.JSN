{"MORE":[{"def":"Greater; superior; increased; as: (a) Greater in quality, amount, degree, quality, and the like; with the singular.","pos":""},{"def":"Wrong not that wrong with a more contempt.","pos":""}],"MOREEN":[{"def":"A thick woolen fabric, watered or with embossed figures; -- used in upholstery, for curtains, etc.","pos":""}],"MOREL":[{"def":"An edible fungus (Morchella esculenta), the upper part of which is covered with a reticulated and pitted hymenium.","pos":""}],"MORELLO":[{"def":"A kind of nearly black cherry with dark red flesh and juice, -- used chiefly for preserving.","pos":""}],"MORENDO":[{"def":"Dying; a gradual decrescendo at the end of a strain or cadence.","pos":""}],"MOREOVER":[{"def":"Beyond what has been said; further; besides; in addition; furthermore; also; likewise.","pos":""}],"MOREPORK":[{"def":"The Australian crested goatsucker (Ægotheles Novæ-Hollandiæ).","pos":""}],"MORES":[{"def":"Customs; habits; esp.","pos":""}],"MORESQUE":[{"def":"Of or pertaining to, or in the manner or style of, the Moors; Moorish.","pos":""},{"def":"The Moresque style of architecture or decoration.","pos":""}]}