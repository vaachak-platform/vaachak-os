{"INDIA":[{"def":"A country in Southern Asia; the two peninsulas of Hither and Farther India; in a restricted sense, Hither India, or Hindostan.","pos":""}],"INDIA RUBBER":[{"def":"In\"di*a rub\"ber Defn: .","pos":""}],"INDIADEM":[{"def":"To place or set in a diadem, as a gem or gems.","pos":""}],"INDIAMAN":[{"def":"A large vessel in the India trade.","pos":""}],"INDIAN":[{"def":"Of or pertaining to India proper; also to the East Indies, or, sometimes, to the West Indies.","pos":""},{"def":"Of or pertaining to the aborigines, or Indians, of America; as, Indian wars; the Indian tomahawk.","pos":""}]}