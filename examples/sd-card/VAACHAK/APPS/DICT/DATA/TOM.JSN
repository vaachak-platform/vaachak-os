{"TOM":[{"def":"The knave of trumps at gleek.","pos":""}],"TOM ' BEDLAM":[{"def":"Formerly, a wandering mendicant discharged as incurable from Bethlehem Hospitel, Eng.","pos":""}],"TOM AND JERRY":[{"def":"A hot sweetened drink of rum and water spiced with cinnamon, cloves, etc.","pos":""}],"TOMAHAWK":[{"def":"A kind of war hatchet used by the American Indians.","pos":""}],"TOMALEY":[{"def":"The liver of the lobster, which becomes green when boiled; -- called also tomalline.","pos":""}],"TOMAN":[{"def":"A money of account in Persia, whose value varies greatly at different times and places.","pos":""}],"TOMATO":[{"def":"The fruit of a plant of the Nightshade family (Lycopersicum esculentun); also, the plant itself.","pos":""}],"TOMB":[{"def":"A pit in which the dead body of a human being is deposited; a grave; a sepulcher.","pos":""},{"def":"A house or vault, formed wholly or partly in the earth, with walls and a roof, for the reception of the dead.","pos":""}],"TOMBAC":[{"def":"An alloy of copper and zinc, resembling brass, and containing about 84 per cent of copper; -- called also German, or Dutch, brass.","pos":""}],"TOMBESTER":[{"def":"A female dancer.","pos":""}],"TOMBLESS":[{"def":"Destitute of a tomb.","pos":""}],"TOMBOY":[{"def":"A romping girl; a hoiden.","pos":""}],"TOMBSTONE":[{"def":"A stone erected over a grave, to preserve the memory of the deceased.","pos":""}],"TOMCAT":[{"def":"A male cat, especially when full grown or of large size.","pos":""}],"TOMCOD":[{"def":"United States; -- called also frostfish.","pos":""}],"TOME":[{"def":"As many writings as are bound in a volume, forming part of a larger work; a book; -- usually applied to a ponderous volume.","pos":""}],"TOMELET":[{"def":"All small tome, or volume.","pos":""}],"TOMENTOSE":[{"def":"Covered with matted woolly hairs; as, a tomentose leaf; a tomentose leaf; a tomentose membrane.","pos":""}],"TOMENTUM":[{"def":"The closely matted hair or downy nap covering the leaves or stems of some plants.","pos":""}],"TOMFOOL":[{"def":"A great fool; a trifler.","pos":""}],"TOMFOOLERY":[{"def":"Folly; trifling.","pos":""}],"TOMIUM":[{"def":"The cutting edge of the bill of a bird.","pos":""}],"TOMJOHN":[{"def":"A kind of open sedan used in Ceylon, carried by a single pole on men's shoulders.","pos":""}],"TOMMY":[{"def":"Bread, -- generally a penny roll; the supply of food carried by workmen as their daily allowance.","pos":""},{"def":"A truck, or barter; the exchange of labor for goods, not money.","pos":""}],"TOMMY ATKINS":[{"def":"Any white regular soldier of the British army; also, such soldiers collectively; -- said to be fictitious name inserted in the models given to soldiers to guide them in filling out account blanks, etc.","pos":""}],"TOMNODDY":[{"def":"A sea bird, the puffin.","pos":""}],"TOMOPTERIS":[{"def":"A genus of transparent marine annelids which swim actively at the surface of the sea.","pos":""}],"TOMORROW":[{"def":"On the day after the present day; on the next day; on the morrow.","pos":""}],"TOMPION":[{"def":"A plug in a flute or an organ pipe, to modulate the tone.","pos":""}],"TOMPON":[{"def":"An inking pad used in lithographic printing.","pos":""}],"TOMRIG":[{"def":"A rude, wild, wanton girl; a hoiden; a tomboy.","pos":""}],"TOMTATE":[{"def":"A Florida and West Indian grunt (Bathystoma, or Hæmulon, rimator); also, any of various allied species.","pos":""}]}