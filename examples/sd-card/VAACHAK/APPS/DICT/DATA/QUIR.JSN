{"QUIRBOILLY":[{"def":"Leather softened by boiling so as to take any required shape.","pos":""}],"QUIRE":[{"def":"A quire of such enticing birds.","pos":""}],"QUIRINAL":[{"def":"Of, pertaining to, or designating, the hill Collis Quirinalis, now Monte Quirinale (one of the seven hills of Rome), or a modern royal place situated upon it.","pos":""}],"QUIRITATION":[{"def":"A crying for help.","pos":""}],"QUIRITE":[{"def":"One of the Quirites.","pos":""}],"QUIRITES":[{"def":"Quirites, while in a political and military capacity they retained the name of Romani.","pos":""}],"QUIRK":[{"def":"A piece of ground taken out of any regular ground plot or floor, so as to make a court, yard, etc.","pos":""},{"def":"A small channel, deeply recessed in proportion to its width, used to insulate and give relief to a convex rounded molding.","pos":""}],"QUIRKED":[{"def":"Having, or formed with, a quirk or quirks.","pos":""}],"QUIRKISH":[{"def":", Consisting of quirks; resembling a quirk.","pos":""}],"QUIRKY":[{"def":"Full of quirks; tricky; as, a quirky lawyer.","pos":""}],"QUIRPELE":[{"def":"The Indian ferret.","pos":""}],"QUIRT":[{"def":"A rawhide whip plaited with two thongs of buffalo hide T.","pos":""}]}