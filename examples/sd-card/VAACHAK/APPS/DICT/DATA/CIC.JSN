{"CICADA":[{"def":"Any species of the genus Cicada.","pos":""}],"CICATRICIAL":[{"def":"Relating to, or having the character of, a cicatrix.","pos":""}],"CICATRICLE":[{"def":"The germinating point in the embryo of a seed; the point in the yolk of an egg at which development begins.","pos":""}],"CICATRISIVE":[{"def":"Tending to promote the formation of a cicatrix; good for healing of a wound.","pos":""}],"CICATRIX":[{"def":"The pellicle which forms over a wound or breach of continuity and completes the process of healing in the latter, and which subsequently contracts and becomes white, forming the scar.","pos":""}],"CICATRIZANT":[{"def":"A medicine or application that promotes the healing of a sore or wound, or the formation of a cicatrix.","pos":""}],"CICATRIZATION":[{"def":"The process of forming a cicatrix, or the state of being cicatrized.","pos":""}],"CICATRIZE":[{"def":"To heal or induce the formation of a cicatrix in, as in wounded or ulcerated flesh.","pos":""}],"CICELY":[{"def":"Any one of several umbelliferous plants, of the genera Myrrhis, Osmorrhiza, etc.","pos":""}],"CICERO":[{"def":"Pica type; -- so called by French printers.","pos":""}],"CICERONE":[{"def":"One who shows strangers the curiosities of a place; a guide.","pos":""}],"CICERONIAN":[{"def":"Resembling Cicero in style or action; eloquent.","pos":""}],"CICERONIANISM":[{"def":"Imitation of, or resemblance to, the style or action Cicero; a Ciceronian phrase or expression.","pos":""}],"CICHORACEOUS":[{"def":"Belonging to, or resembling, a suborder of composite plants of which the chicory (Cichorium) is the type.","pos":""}],"CICISBEISM":[{"def":"The state or conduct of a cicisbeo.","pos":""}],"CICISBEO":[{"def":"A professed admirer of a married woman; a dangler about women.","pos":""},{"def":"A knot of silk or ribbon attached to a fan, walking stick, etc.","pos":""}],"CICLATOUN":[{"def":"A costly cloth, of uncertain material, used in the Middle Ages.","pos":""}],"CICURATION":[{"def":"The act of taming.","pos":""}],"CICUTA":[{"def":"a genus of poisonous umbelliferous plants, of which the water hemlock or cowbane is best known.","pos":""}],"CICUTOXIN":[{"def":"The active principle of the water hemlock (Cicuta) extracted as a poisonous gummy substance.","pos":""}]}