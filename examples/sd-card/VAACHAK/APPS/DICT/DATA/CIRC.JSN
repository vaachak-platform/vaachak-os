{"CIRC":[{"def":"An amphitheatrical circle for sports; a circus.","pos":""}],"CIRCAR":[{"def":"A district, or part of a province.","pos":""}],"CIRCASSIAN":[{"def":"Of or pertaining to Circassia, in Asia.","pos":""},{"def":"A native or inhabitant of Circassia.","pos":""}],"CIRCEAN":[{"def":"Having the characteristics of Circe, daughter of Sol and Perseis, a mythological enchantress, who first charmed her victims and then changed them to the forms of beasts; pleasing, but noxious; as, a Circean draught.","pos":""},{"def":"Of or pertaining to, or held in, the Circus, In Rome.","pos":""}],"CIRCINATE":[{"def":"Rolled together downward, the tip occupying the center; -- a term used in reference to foliation or leafing, as in ferns.","pos":""}],"CIRCINATION":[{"def":"An orbicular motion.","pos":""},{"def":"A circle; a concentric layer.","pos":""}],"CIRCLE":[{"def":"An instrument of observation, the graduated limb of which consists of an entire circle.","pos":""},{"def":"A form of argument in which two or more unproved statements are used to prove each other; inconclusive reasoning.","pos":""}],"CIRCLED":[{"def":"Having the form of a circle; round.","pos":""}],"CIRCLER":[{"def":"A mean or inferior poet, perhaps from his habit of wandering around as a stroller; an itinerant poet.","pos":""}],"CIRCLET":[{"def":"A little circle; esp.","pos":""},{"def":"A round body; an orb.","pos":""}],"CIRCUIT":[{"def":"The act of moving or revolving around, or as in a circle or orbit; a revolution; as, the periodical circuit of the earth round the sun.","pos":""},{"def":"The circumference of, or distance round, any space; the measure of a line round an area.","pos":""}],"CIRCUITER":[{"def":"One who travels a circuit, as a circuit judge.","pos":""}],"CIRCUITION":[{"def":"The act of going round; circumlocution.","pos":""}],"CIRCUITOUS":[{"def":"Going round in a circuit; roundabout; indirect; as, a circuitous road; a circuitous manner of accompalishing an end.","pos":""}],"CIRCUITY":[{"def":"A going round in a circle; a course not direct; a roundabout way of proceeding.","pos":""}],"CIRCULABLE":[{"def":"That may be circulated.","pos":""}],"CIRCULAR":[{"def":"In the form of, or bounded by, a circle; round.","pos":""},{"def":"Adhering to a fixed circle of legends; cyclic; hence, mean; inferior.","pos":""}],"CIRCULARITY":[{"def":"The quality or state of being circular; a circular form.","pos":""}],"CIRCULARLY":[{"def":"In a circular manner.","pos":""}],"CIRCULARY":[{"def":"Circular; illogical.","pos":""}],"CIRCULATE":[{"def":"To move in a circle or circuitously; to move round and return to the same point; as, the blood circulates in the body.","pos":""},{"def":"To pass from place to place, from person to person, or from hand to hand; to be diffused; as, money circulates; a story circulates.","pos":""}],"CIRCULATION":[{"def":"The movement of the blood in the blood-vascular system, by which it is brought into close relations with almost every living elementary constituent.","pos":""}],"CIRCULATIVE":[{"def":"Promoting circulation; circulating.","pos":""}],"CIRCULATOR":[{"def":"One who, or that which, circulates.","pos":""}],"CIRCULATORIOUS":[{"def":"Travelling from house to house or from town to town; itinerant.","pos":""}],"CIRCULATORY":[{"def":"Subserving the purposes of circulation; as, circulatory organs; of or pertaining to the organs of circulation; as, circulatory diseases.","pos":""}],"CIRCULINE":[{"def":"Proceeding in a circle; circular.","pos":""}],"CIRCUM-":[{"def":"A Latin preposition, used as a prefix in many English words, and signifying around or about.","pos":""}],"CIRCUMAGITATE":[{"def":"To agitate on all sides.","pos":""}],"CIRCUMAMBAGE":[{"def":"A roundabout or indirect course; indirectness.","pos":""}],"CIRCUMAMBIENCY":[{"def":"The act of surrounding or encompassing.","pos":""}],"CIRCUMAMBIENT":[{"def":"Surrounding; inclosing or being on all sides; encompassing.","pos":""}],"CIRCUMAMBULATE":[{"def":"To walk round about.","pos":""}],"CIRCUMBENDIBUS":[{"def":"A roundabout or indirect way.","pos":""}],"CIRCUMCENTER":[{"def":"The center of a circle that circumscribes a triangle.","pos":""}],"CIRCUMCISE":[{"def":"To purify spiritually.","pos":""}],"CIRCUMCISER":[{"def":"One who performs circumcision.","pos":""}],"CIRCUMCISION":[{"def":"The act of cutting off the prepuce or foreskin of males, or the internal labia of females.","pos":""}],"CIRCUMCLUSION":[{"def":"Act of inclosing on all sides.","pos":""}],"CIRCUMCURSATION":[{"def":"The act of running about; also, rambling language.","pos":""}],"CIRCUMDENUDATION":[{"def":"Denudation around or in the neighborhood of an object.","pos":""}],"CIRCUMDUCE":[{"def":"To declare elapsed, as the time allowed for introducing evidence.","pos":""}],"CIRCUMDUCT":[{"def":"To contravene; to nullify; as, to circumduct acts of judicature.","pos":""}],"CIRCUMDUCTION":[{"def":"The rotation of a limb round an imaginary axis, so as to describe a concial surface.","pos":""}],"CIRCUMESOPHAGAL":[{"def":"Surrounding the esophagus; -- in Zool.","pos":""}],"CIRCUMESOPHAGEAL":[{"def":"Circumesophagal.","pos":""}],"CIRCUMFER":[{"def":"To bear or carry round.","pos":""}],"CIRCUMFERENCE":[{"def":"The line that goes round or encompasses a circular figure; a periphery.","pos":""},{"def":"A circle; anything circular.","pos":""}],"CIRCUMFERENTIAL":[{"def":"Pertaining to the circumference; encompassing; encircling; circuitous.","pos":""}],"CIRCUMFERENTIALLY":[{"def":"So as to surround or encircle.","pos":""}],"CIRCUMFERENTOR":[{"def":"A surveying instrument, for taking horizontal angles and bearings; a surveyor's compass.","pos":""},{"def":"A graduated wheel for measuring tires; a tire circle.","pos":""}],"CIRCUMFLECT":[{"def":"To mark with the circumflex accent, as a vowel.","pos":""}],"CIRCUMFLECTION":[{"def":"See Circumflexion.","pos":""}],"CIRCUMFLEX":[{"def":"A wave of the voice embracing both a rise and fall or a fall and a rise on the same a syllable.","pos":""},{"def":"A character, or accent, denoting in Greek a rise and of the voice on the same long syllable, marked thus [~ or Accent, n.","pos":""}],"CIRCUMFLEXION":[{"def":"The act of bending, or causing to assume a curved form.","pos":""},{"def":"A winding about; a turning; a circuity; a fold.","pos":""}],"CIRCUMFLUENCE":[{"def":"A flowing round on all sides; an inclosing with a fluid.","pos":""},{"def":"Flowing round; surrounding in the manner of a fluid.","pos":""}],"CIRCUMFULGENT":[{"def":"Shining around or about.","pos":""}],"CIRCUMFUSE":[{"def":"To pour round; to spread round.","pos":""}],"CIRCUMFUSILE":[{"def":"Capable of being poured or spread round.","pos":""}],"CIRCUMFUSION":[{"def":"The act of pouring or spreading round; the state of being spread round.","pos":""}],"CIRCUMGESTATION":[{"def":"The act or process of carrying about.","pos":""}],"CIRCUMGYRATE":[{"def":"To roll or turn round; to cause to perform a rotary or circular motion.","pos":""}],"CIRCUMGYRATION":[{"def":"The act of turning, rolling, or whirling round.","pos":""}],"CIRCUMGYRATORY":[{"def":"Moving in a circle; turning round.","pos":""}],"CIRCUMGYRE":[{"def":"To circumgyrate.","pos":""}],"CIRCUMINCESSION":[{"def":"The reciprocal existence in each other of the three persons of the Trinity.","pos":""}],"CIRCUMJACENCE":[{"def":"Condition of being circumjacent, or of bordering ou every side.","pos":""}],"CIRCUMJACENT":[{"def":"Lying round; borderong on every side.","pos":""}],"CIRCUMJOVIAL":[{"def":"One of the moons or satellites of the planet Jupiter.","pos":""}],"CIRCUMLITTORAL":[{"def":"Adjointing the shore.","pos":""}],"CIRCUMLOCUTION":[{"def":"The use of many words to express an idea that might be expressed by few; indirect or roundabout language; a periphrese.","pos":""}],"CIRCUMLOCUTIONAL":[{"def":"Relating to, or consisting of, circumlocutions; periphrastic; circuitous.","pos":""}],"CIRCUMLOCUTORY":[{"def":"Characterised by circumlocution; periphrastic.","pos":""}],"CIRCUMMERIDIAN":[{"def":"About, or near, the meridian.","pos":""}],"CIRCUMMURE":[{"def":"To encompass with a wall.","pos":""}],"CIRCUMNAVIGABLE":[{"def":"Capable of being sailed round.","pos":""}],"CIRCUMNAVIGATE":[{"def":"To sail completely round.","pos":""}],"CIRCUMNAVIGATION":[{"def":"The act of circumnavigating, or sailing round.","pos":""}],"CIRCUMNAVIGATOR":[{"def":"One who sails round.","pos":""}],"CIRCUMNUTATE":[{"def":"To pass through the stages of circumnutation.","pos":""}],"CIRCUMNUTATION":[{"def":"The successive bowing or bending in different directions of the growing tip of the stems of many plants, especially seen in climbing plants.","pos":""}],"CIRCUMPOLAR":[{"def":"About the pole; -- applied to stars that revolve around the pole without setting; as, circumpolar stars.","pos":""}],"CIRCUMPOSITION":[{"def":"The act of placing in a circle, or round about, or the state of being so placed.","pos":""},{"def":"turning, rolling, or whirling round.","pos":""}],"CIRCUMROTATE":[{"def":"To rotate about.","pos":""}],"CIRCUMROTATION":[{"def":"The act of rolling or revolving round, as a wheel; circumvolution; the state of being whirled round.","pos":""}],"CIRCUMSCISSILE":[{"def":"Dehiscing or opening by a transverse fissure extending around (a capsule or pod).","pos":""}],"CIRCUMSCRIBABLE":[{"def":"Capable of being circumscribed.","pos":""}],"CIRCUMSCRIBE":[{"def":"To draw a line around si as to touch at certain points without cutting.","pos":""}],"CIRCUMSCRIBER":[{"def":"One who, or that which, circumscribes.","pos":""}],"CIRCUMSCRIPTIBLE":[{"def":"Capable of being circumscribed or limited by bounds.","pos":""}],"CIRCUMSCRIPTION":[{"def":"An inscription written around anything.","pos":""},{"def":"The exterior line which determines the form or magnitude of a body; outline; periphery.","pos":""}],"CIRCUMSCRIPTIVE":[{"def":"Circumscribing or tending to circumscribe; marcing the limits or form of.","pos":""}],"CIRCUMSCRIPTIVELY":[{"def":"In a limited manner.","pos":""}],"CIRCUMSCRIPTLY":[{"def":"In a literal, limited, or narrow manner.","pos":""}],"CIRCUMSPECT":[{"def":"Attentive to all the circustances of a case or the probable consequences of an action; cautious; prudent; wary.","pos":""}],"CIRCUMSPECTION":[{"def":"Attention to all the facts and circumstances of a case; caution; watchfulness.","pos":""}],"CIRCUMSPECTIVE":[{"def":"Looking around everi way; cautious; careful of consequences; watchful of danger.","pos":""}],"CIRCUMSPECTIVELY":[{"def":"Cir`cum*spec\"tive*ly, adv.","pos":""}],"CIRCUMSPECTLY":[{"def":"In a circumspect manner; cautiously; warily.","pos":""}],"CIRCUMSPECTNESS":[{"def":"Vigilance un guarding against evil from every quarter; caution.","pos":""}],"CIRCUMSTANCE":[{"def":"Condition in regard to worldly estate; state of property; situation; surroundings.","pos":""}],"CIRCUMSTANCED":[{"def":"Placed in a particular position or condition; situated.","pos":""},{"def":"Governed by events or circumstances.","pos":""}],"CIRCUMSTANT":[{"def":"Standing or placed around; surrounding.","pos":""}],"CIRCUMSTANTIABLE":[{"def":"Capable of being circumstantiated.","pos":""}],"CIRCUMSTANTIAL":[{"def":"Consisting in, or pertaining to, circumstances or particular incidents.","pos":""},{"def":"Incidental; relating to, but not essential.","pos":""}],"CIRCUMSTANTIALITY":[{"def":"The state, characteristic, or quality of being circumstantial; particularity or minuteness of detail.","pos":""}],"CIRCUMSTANTIALLY":[{"def":"In respect to circumstances; not essentially; accidentally.","pos":""},{"def":"In every circumstance or particular; minutely.","pos":""}],"CIRCUMSTANTIATE":[{"def":"To place in particular circumstances; to invest with particular accidents or adjuncts.","pos":""},{"def":"To prove or confirm by circumstances; to entr into details concerning.","pos":""}],"CIRCUMTERRANEOUS":[{"def":"Being or dwelling around the earth.","pos":""}],"CIRCUMUNDULATE":[{"def":"To flow round, as waves.","pos":""}],"CIRCUMVALLATE":[{"def":"To surround with a rampart or wall.","pos":""}],"CIRCUMVALLATION":[{"def":"Cir`cum*val*la\"tion, n.","pos":""}],"CIRCUMVECTION":[{"def":"The act of carrying anything around, or the state of being so carried.","pos":""}],"CIRCUMVENT":[{"def":"To gain advantage over by arts, stratagem, or deception; to decieve; to delude; to get around.","pos":""}],"CIRCUMVENTION":[{"def":"The act of prevailing over another by arts, address, or fraud; deception; fraud; imposture; delusion.","pos":""}],"CIRCUMVENTIVE":[{"def":"Tending to circumvent; deceiving by artifices; deluding.","pos":""}],"CIRCUMVENTOR":[{"def":"One who circumvents; one who gains his purpose by cunning.","pos":""}],"CIRCUMVEST":[{"def":"To cover round, as woth a garment; to invest.","pos":""}],"CIRCUMVOLANT":[{"def":"The circumvolant troubles of humanity.","pos":""}],"CIRCUMVOLATION":[{"def":"The act of flying round.","pos":""}],"CIRCUMVOLUTION":[{"def":"The act of rolling round; the state of being rolled.","pos":""},{"def":"A thing rolled round another.","pos":""}],"CIRCUMVOLVE":[{"def":"To roll round; to cause to revolve; to put into a circular motion.","pos":""}],"CIRCUS":[{"def":"A level oblong space surrounded on three sides by seats of wood, earth, or stone, rising in tiers one above another, and divided lengthwise through the middle by a barrier around which the track or course was laid out.","pos":""}]}