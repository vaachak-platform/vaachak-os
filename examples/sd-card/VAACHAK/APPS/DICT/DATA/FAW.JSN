{"FAWE":[{"def":"Fain; glad; delighted.","pos":""}],"FAWN":[{"def":"A young deer; a buck or doe of the first year.","pos":""}],"FAWN-COLORED":[{"def":"Of the color of a fawn; light yellowish brown.","pos":""}],"FAWNER":[{"def":"One who fawns; a sycophant.","pos":""}],"FAWNINGLY":[{"def":"In a fawning manner.","pos":""}]}