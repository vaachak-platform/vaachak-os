{"FOX":[{"def":"A carnivorous animal of the genus Vulpes, family Canidæ, of many species.","pos":""},{"def":"The European dragonet.","pos":""}],"FOX-HUNTING":[{"def":"Pertaining to or engaged in the hunting of foxes; fond of hunting foxes.","pos":""}],"FOXEARTH":[{"def":"A hole in the earth to which a fox resorts to hide himself.","pos":""}],"FOXED":[{"def":"Discolored or stained; -- said of timber, and also of the paper of books or engravings.","pos":""},{"def":"Repaired by foxing; as, foxed boots.","pos":""}],"FOXERY":[{"def":"Behavior like that of a fox; [Obs.","pos":""}],"FOXGLOVE":[{"def":"Any plant of the genus Digitalis.","pos":""}],"FOXHOUND":[{"def":"One of a special breed of hounds used for chasing foxes.","pos":""}],"FOXINESS":[{"def":"The state or quality of being foxy, or foxlike; craftiness; shrewdness.","pos":""},{"def":"The state of being foxed or discolored, as books; decay; deterioration.","pos":""}],"FOXLIKE":[{"def":"Resembling a fox in his characteristic qualities; cunning; artful; foxy.","pos":""}],"FOXSHIP":[{"def":"Foxiness; craftiness.","pos":""}],"FOXTAIL":[{"def":"The name of several kinds of grass having a soft dense head of flowers, mostly the species of Alopecurus and Setaria.","pos":""},{"def":"The last cinders obtained in the fining process.","pos":""}],"FOXY":[{"def":"Like or pertaining to the fox; foxlike in disposition or looks; wily.","pos":""},{"def":"Having the color of a fox; of a yellowish or reddish brown color; -- applied sometimes to paintings when they have too much of this color.","pos":""}]}