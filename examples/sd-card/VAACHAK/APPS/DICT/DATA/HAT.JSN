{"HAT":[{"def":"A covering for the head; esp.","pos":""}],"HATABLE":[{"def":"Capable of being, or deserving to be, hated; odious; detestable.","pos":""}],"HATBAND":[{"def":"A band round the crown of a hat; sometimes, a band of black cloth, crape, etc.","pos":""}],"HATBOX":[{"def":"A box for a hat.","pos":""}],"HATCH":[{"def":"To cross with lines in a peculiar manneHatching.","pos":""},{"def":"To cross; to spot; to stain; to steep.","pos":""}],"HATCH-BOAT":[{"def":"A vessel whose deck consists almost wholly of movable hatches; -- used mostly in the fisheries.","pos":""}],"HATCHEL":[{"def":"An instrument with long iron teeth set in a board, for cleansing flax or hemp from the tow, hards, or coarse part; a kind of large comb; -- called also hackle and heckle.","pos":""}],"HATCHELER":[{"def":"One who uses a hatchel.","pos":""}],"HATCHER":[{"def":"One who hatches, or that which hatches; a hatching apparatus; an incubator.","pos":""},{"def":"One who contrives or originates; a plotter.","pos":""}],"HATCHERY":[{"def":"A house for hatching fish, etc.","pos":""}],"HATCHET":[{"def":"A small ax with a short handle, to be used with one hand.","pos":""},{"def":"Specifically, a tomahawk.","pos":""}],"HATCHET MAN":[{"def":"Hatchet man Defn: 1.","pos":""}],"HATCHING":[{"def":"A mode of execution in engraving, drawing, and miniature painting, in which shading is produced by lines crossing each other at angles more or less acute; -- called also crosshatching.","pos":""}],"HATCHMENT":[{"def":"A sort of panel, upon which the arms of a deceased person are temporarily displayed, -- usually on the walls of his dwelling.","pos":""}],"HATCHURE":[{"def":"Same as Hachure.","pos":""}],"HATCHWAY":[{"def":"A square or oblong opening in a deck or floor, affording passage from one deck or story to another; the entrance to a cellar.","pos":""}],"HATE":[{"def":"To love less, relatively.","pos":""}],"HATEFUL":[{"def":"Manifesting hate or hatred; malignant; malevolent.","pos":""},{"def":"Exciting or deserving great dislike, aversion, or disgust; odious.","pos":""}],"HATEL":[{"def":"Hateful; detestable.","pos":""}],"HATER":[{"def":"An enemy to God, and a hater of all good.","pos":""}],"HATRACK":[{"def":"A hatstand; hattree.","pos":""}],"HATRED":[{"def":"Strong aversion; intense dislike; hate; an affection of the mind awakened by something regarded as evil.","pos":""}],"HATSTAND":[{"def":"A stand of wood or iron, with hooks or pegs upon which to hang hats, etc.","pos":""}],"HATTE":[{"def":"Hat`te, Defn: pres.","pos":""}],"HATTED":[{"def":"Covered with a hat.","pos":""}],"HATTER":[{"def":"To tire or worry; -- out.","pos":""}],"HATTERIA":[{"def":"A New Zealand lizard, which, in anatomical character, differs widely from all other existing lizards.","pos":""}],"HATTI-SHERIF":[{"def":"A irrevocable Turkish decree countersigned by the sultan.","pos":""}],"HATTING":[{"def":"The business of making hats; also, stuff for hats.","pos":""}]}