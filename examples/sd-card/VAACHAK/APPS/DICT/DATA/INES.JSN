{"INESCATE":[{"def":"To allure; to lay a bait for.","pos":""}],"INESCATION":[{"def":"The act of baiting; allurement.","pos":""}],"INESCUTCHEON":[{"def":"A small escutcheon borne within a shield.","pos":""}],"INESSENTIAL":[{"def":"Having no essence or being.","pos":""},{"def":"Not essential; unessential.","pos":""}],"INESTIMABLE":[{"def":"Incapable of being estimated or computed; especially, too valuable or excellent to be measured or fully appreciated; above all price; as, inestimable rights or privileges.","pos":""}],"INESTIMABLY":[{"def":"In a manner, or to a degree, above estimation; as, things inestimably excellent.","pos":""}]}