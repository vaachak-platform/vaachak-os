{"FIT":[{"def":"In Old English, a song; a strain; a canto or portion of a ballad; a passus.","pos":""}],"FITCH":[{"def":"A word found in the Authorized Version of the Bible, representing different Hebrew originals.","pos":""}],"FITCHE":[{"def":"Sharpened to a point; pointed.","pos":""}],"FITCHED":[{"def":"The European polecat (Putorius foetidus).","pos":""}],"FITCHY":[{"def":"Having fitches or vetches.","pos":""}],"FITFUL":[{"def":"Full of fits; irregularly variable; impulsive and unstable.","pos":""}],"FITLY":[{"def":"In a fit manner; suitably; properly; conveniently; as, a maxim fitly applied.","pos":""}],"FITMENT":[{"def":"The act of fitting; that which is proper or becoming; equipment.","pos":""}],"FITNESS":[{"def":"The state or quality of being fit; as, the fitness of measures or laws; a person's fitness for office.","pos":""}],"FITTEDNESS":[{"def":"The state or quality of being fitted; adaptation.","pos":""}],"FITTER":[{"def":"One who fits or makes to fit; esp.","pos":""},{"def":"A coal broker who conducts the sales between the owner of a coal pit and the shipper.","pos":""}],"FITTING":[{"def":"Anything used in fitting up; especially (pl.","pos":""},{"def":"necessary fixtures or apparatus; as, the fittings of a church or study; gas fittings.","pos":""}],"FITWEED":[{"def":"A plant (Eryngium foetidum) supposed to be a remedy for fits.","pos":""}],"FITZ":[{"def":"A son; -- used in compound names, to indicate paternity, esp.","pos":""}]}