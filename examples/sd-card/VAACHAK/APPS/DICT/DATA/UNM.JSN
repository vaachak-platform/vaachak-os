{"UNMADE":[{"def":"Not yet made or formed; as, an unmade grave.","pos":""},{"def":"Deprived of form, character, etc.","pos":""}],"UNMAGISTRATE":[{"def":"To divest of the office or authority of a magistrate.","pos":""}],"UNMAIDEN":[{"def":"To ravish; to deflower.","pos":""}],"UNMAKE":[{"def":"To destroy the form and qualities of; to deprive of being; to uncreate.","pos":""}],"UNMAN":[{"def":"To deprive of the distinctive qualities of a human being, as reason, or the like.","pos":""},{"def":"To emasculate; to deprive of virility.","pos":""}],"UNMANACLE":[{"def":"To free from manacles.","pos":""}],"UNMANHOOD":[{"def":"Absence or lack of manhood.","pos":""}],"UNMANNED":[{"def":"Deprived of manly qualities; deficient in vigor, strength, courage, etc.","pos":""},{"def":"Not tamed; not made familiar with, or subject to, man; -- also used figuratively.","pos":""}],"UNMANNERLY":[{"def":"Not mannerly; ill-bred; rude.","pos":""},{"def":"Uncivilly; rudely.","pos":""}],"UNMANTLE":[{"def":"To divest of a mantle; to uncover.","pos":""}],"UNMARRY":[{"def":"To annul the marriage of; to divorce.","pos":""}],"UNMARTYR":[{"def":"To degrade from the rank of a martyr.","pos":""}],"UNMASK":[{"def":"To strip of a mask or disguise; to lay open; to expose.","pos":""}],"UNMASTERABLE":[{"def":"Incapable of being mastered or subdued.","pos":""}],"UNMATERIAL":[{"def":"Not material; immaterial.","pos":""}],"UNMEANING":[{"def":"Having no meaning or signification; as, unmeaning words.","pos":""},{"def":"Not indicating intelligence or sense; senseless; expressionless; as, an unmeaning face.","pos":""}],"UNMEANT":[{"def":"Not meant or intended; unintentional.","pos":""}],"UNMECHANIZE":[{"def":"To undo the mechanism of; to unmake; as, to unmechanize a structure.","pos":""}],"UNMEET":[{"def":"Not meet or fit; not proper; unbecoming; unsuitable; -- usually followed by for.","pos":""}],"UNMEMBER":[{"def":"To deprive of membership, as in a church.","pos":""}],"UNMENTIONABLES":[{"def":"The breeches; trousers.","pos":""}],"UNMERCHANTABLE":[{"def":"Not merchantable; not fit for market; being of a kind, quality, or quantity that is unsalable.","pos":""}],"UNMERCIED":[{"def":"Unmerciful; merciless.","pos":""}],"UNMERCIFUL":[{"def":"Not merciful; indisposed to mercy or grace; cruel; inhuman; merciless; unkind.","pos":""}],"UNMERCILESS":[{"def":"Utterly merciless.","pos":""}],"UNMEW":[{"def":"To release from confinement or restraint.","pos":""}],"UNMINGLE":[{"def":"To separate, as things mixed.","pos":""}],"UNMISTAKABLE":[{"def":"Incapable of being mistaken or misunderstood; clear; plain; obvious; evident.","pos":""},{"def":"To deprive of a miter; to depose or degrade from the rank of a bishop.","pos":""}],"UNMONEYED":[{"def":"Destitute of money; not rich.","pos":""}],"UNMONOPOLIZE":[{"def":"To recover or release from the state of being monopolized.","pos":""}],"UNMOOR":[{"def":"To weigh anchor.","pos":""}],"UNMORAL":[{"def":"Having no moral perception, quality, or relation; involving no idea of morality; -- distinguished from both moral and immoral.","pos":""}],"UNMORALIZED":[{"def":"Not restrained or tutored by morality.","pos":""}],"UNMORRISED":[{"def":"Not arrayed in the dress of a morris dancer.","pos":""}],"UNMORTISE":[{"def":"To loosen, unfix, or separate, as things mortised together.","pos":""}],"UNMOTHERED":[{"def":"Deprived of a mother; motherless.","pos":""}],"UNMOVED":[{"def":"Not moved; fixed; firm; unshaken; calm; apathetic.","pos":""}],"UNMUFFLE":[{"def":"To take a covering from, as the face; to uncover.","pos":""},{"def":"To remove the muffling of, as a drum.","pos":""}],"UNMUZZLE":[{"def":"To loose from a muzzle; to remove a muzzle from.","pos":""}]}