{"UNSEAL":[{"def":"To break or remove the seal of; to open, as what is sealed; as, to unseal a letter.","pos":""},{"def":"To disclose, as a secret.","pos":""}],"UNSEAM":[{"def":"To open the seam or seams of; to rip; to cut; to cut open.","pos":""}],"UNSEARCHABLE":[{"def":"Not searchable; inscrutable; hidden; mysterious.","pos":""}],"UNSEASON":[{"def":"To make unseasoned; to deprive of seasoning.","pos":""},{"def":"To strike unseasonably; to affect disagreeably or unfavorably.","pos":""}],"UNSEASONABLE":[{"def":"Not seasonable; being, done, or occurring out of the proper season; ill-timed; untimely; too early or too late; as, he called at an unseasonable hour; unseasonable advice; unseasonable frosts; unseasonable food.","pos":""}],"UNSEASONED":[{"def":"Untimely; ill-timed.","pos":""}],"UNSEAT":[{"def":"To throw from one's seat; to deprive of a seat.","pos":""},{"def":"Specifically, to deprive of the right to sit in a legislative body, as for fraud in election.","pos":""}],"UNSECONDED":[{"def":"Not seconded; not supported, aided, or assisted; as, the motion was unseconded; the attempt was unseconded.","pos":""},{"def":"Not exemplified a second time.","pos":""}],"UNSECRET":[{"def":"To disclose; to divulge.","pos":""}],"UNSECULARIZE":[{"def":"To cause to become not secular; to detach from secular things; to alienate from the world.","pos":""}],"UNSEEL":[{"def":"To open, as the eyes of a hawk that have been seeled; hence, to give light to; to enlighten.","pos":""}],"UNSEEMING":[{"def":"Unbeseeming; not fit or becoming.","pos":""}],"UNSEEMLINESS":[{"def":"The quality or state of being unseemly; unbecomingness.","pos":""}],"UNSEEMLY":[{"def":"Not seemly; unbecoming; indecent.","pos":""}],"UNSEEN":[{"def":"Not seen or discovered.","pos":""},{"def":"Unskilled; inexperienced.","pos":""}],"UNSELDOM":[{"def":"Not seldom; frequently.","pos":""}],"UNSELY":[{"def":"Not blessed or happy; wretched; unfortunate.","pos":""}],"UNSEMINARED":[{"def":"Deprived of virility, or seminal energy; made a eunuch.","pos":""}],"UNSENSED":[{"def":"Wanting a distinct meaning; having no certain signification.","pos":""}],"UNSENSUALIZE":[{"def":"To elevate from the domain of the senses; to purify.","pos":""}],"UNSERVICE":[{"def":"Neglect of duty; idleness; indolence.","pos":""}],"UNSET":[{"def":"Not set; not fixed or appointed.","pos":""}],"UNSETTLE":[{"def":"To move or loosen from a settled position or state; to unfix; to displace; to disorder; to confuse.","pos":""}],"UNSETTLEDNESS":[{"def":"The quality or state of being unsettled.","pos":""}],"UNSETTLEMENT":[{"def":"The act of unsettling, or state of being unsettled; disturbance.","pos":""}],"UNSEVEN":[{"def":"To render other than seven; to make to be no longer seven.","pos":""}],"UNSEW":[{"def":"To undo, as something sewn, or something inclosed by sewing; to rip apart; to take out the stitches of.","pos":""}],"UNSEX":[{"def":"To deprive of sex, or of qualities becoming to one's sex; esp.","pos":""}],"UNSEXUAL":[{"def":"Not sexual; not proper or peculiar to one of the sexes.","pos":""}]}