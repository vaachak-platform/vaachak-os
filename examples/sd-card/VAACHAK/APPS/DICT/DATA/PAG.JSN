{"PAGAN":[{"def":"One who worships false goods; an idolater; a heathen; one who is neither a Christian, a Mohammedan, nor a Jew.","pos":""}],"PAGANDOM":[{"def":"The pagan lands; pagans, collectively; paganism.","pos":""},{"def":"Of or pertaining to pagans or paganism; heathenish; paganish.","pos":""}],"PAGANISH":[{"def":"Of or pertaining to pagans; heathenish.","pos":""}],"PAGANISM":[{"def":"The state of being pagan; pagan characteristics; esp.","pos":""}],"PAGANITY":[{"def":"The state of being a pagan; paganism.","pos":""}],"PAGANIZE":[{"def":"To render pagan or heathenish; to convert to paganism.","pos":""}],"PAGANLY":[{"def":"In a pagan manner.","pos":""}],"PAGE":[{"def":"A track along which pallets carrying newly molded bricks are conveyed to the hack.","pos":""},{"def":"Any one of several species of beautiful South American moths of the genus Urania.","pos":""}],"PAGEANT":[{"def":"A theatrical exhibition; a spectacle.","pos":""},{"def":"An elaborate exhibition devised for the entertainmeut of a distinguished personage, or of the public; a show, spectacle, or display.","pos":""}],"PAGEANTRY":[{"def":"Scenic shows or spectacles, taken collectivelly; spectacular guality; splendor.","pos":""}],"PAGEHOOD":[{"def":"The state of being a page.","pos":""}],"PAGINA":[{"def":"The surface of a leaf or of a flattened thallus.","pos":""}],"PAGINAL":[{"def":"Consisting of pages.","pos":""}],"PAGINATION":[{"def":"The act or process of paging a book; also, the characters used in numbering the pages; page number.","pos":""}],"PAGING":[{"def":"The marking or numbering of the pages of a book.","pos":""}],"PAGODA":[{"def":"A gold or silver coin, of various kinds and values, formerly current in India.","pos":""}],"PAGODA SLEEVE":[{"def":"A funnel-shaped sleeve arranged to show the sleeve lining and an inner sleeve.","pos":""}],"PAGODITE":[{"def":"Agalmatolite; -- so called because sometimes carved by the Chinese into the form of pagodas.","pos":""}],"PAGUMA":[{"def":"Any one of several species of East Indian viverrine mammals of the genus Paguma.","pos":""}],"PAGURIAN":[{"def":"Any one of a tribe of anomuran crustaceans, of which Pagurus is a type; the hermit crab.","pos":""}]}