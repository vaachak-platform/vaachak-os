{"STATABLE":[{"def":"That can be stated; as, a statablegrievance; the question at issue is statable.","pos":""}],"STATAL":[{"def":"Of, pertaining to, or existing with reference to, a State of the American Union, as distinguished from the general government.","pos":""}],"STATANT":[{"def":"In a standing position; as, a lion statant.","pos":""}],"STATARIAN":[{"def":"Fixed; settled; steady; statary.","pos":""}],"STATARIANLY":[{"def":"Fixedly; steadly.","pos":""}],"STATE":[{"def":"The circumstances or condition of a being or thing at any given time.","pos":""},{"def":"Rank; condition; quality; as, the state of honor.","pos":""}],"STATE SOCIALISM":[{"def":"A form of socialism, esp.","pos":""}],"STATECRAFT":[{"def":"The art of conducting state affairs; state management; statesmanship.","pos":""}],"STATED":[{"def":"Settled; established; fixed.","pos":""},{"def":"Recurring at regular time; not occasional; as, stated preaching; stated business hours.","pos":""}],"STATEDLY":[{"def":"At stated times; regularly.","pos":""}],"STATEFUL":[{"def":"Full of state; stately.","pos":""}],"STATEHOOD":[{"def":"The condition of being a State; as, a territory seeking Statehood.","pos":""}],"STATEHOUSE":[{"def":"The building in which a State legislature holds its sessions; a State capitol.","pos":""}],"STATELESS":[{"def":"Without state or pomp.","pos":""}],"STATELILY":[{"def":"In a stately manner.","pos":""}],"STATELINESS":[{"def":"The quality or state of being stately.","pos":""}],"STATELY":[{"def":"Evincing state or dignity; lofty; majestic; grand; as, statelymanners; a stately gait.","pos":""}],"STATEMENT":[{"def":"The act of stating, reciting, or presenting, orally or in paper; as, to interrupt a speaker in the statement of his case.","pos":""},{"def":"That which is stated; a formal embodiment in language of facts or opinions; a narrative; a recital.","pos":""}],"STATEMONGER":[{"def":"One versed in politics, or one who dabbles in state affairs.","pos":""}],"STATEPRISON":[{"def":"See under State, n.","pos":""}],"STATER":[{"def":"The principal gold coin of ancient Grece.","pos":""}],"STATEROOM":[{"def":"A magnificent room in a place or great house.","pos":""},{"def":"A small apartment for lodging or sleeping in the cabin, or on the deck, of a vessel; also, a somewhat similar apartment in a railway sleeping car.","pos":""}],"STATES-GENERAL":[{"def":"In France, before the Revolution, the assembly of the three orders of the kingdom, namely, the clergy, the nobility, and the third estate, or commonalty.","pos":""},{"def":"In the Netherlands, the legislative body, composed of two chambers.","pos":""}],"STATESMAN":[{"def":"A man versed in public affairs and in the principles and art of government; especially, one eminent for political abilities.","pos":""},{"def":"One occupied with the affairs of government, and influental in shaping its policy.","pos":""}],"STATESMANLIKE":[{"def":"Having the manner or wisdom of statesmen; becoming a statesman.","pos":""}],"STATESMANLY":[{"def":"Becoming a statesman.","pos":""}],"STATESMANSHIP":[{"def":"The qualifications, duties, or employments of a statesman.","pos":""}],"STATESWOMAN":[{"def":"A woman concerned in public affairs.","pos":""}],"STATHMOGRAPH":[{"def":"A contrivance for recording the speed of a railway train.","pos":""}],"STATICALLY":[{"def":"In a statical manner.","pos":""}],"STATICS":[{"def":"That branch of mechanics which treats of the equilibrium of forces, or relates to bodies as held at rest by the forces acting on them; -- distinguished from dynamics.","pos":""}],"STATING":[{"def":"The act of one who states anything; statement; as, the statingof one's opinions.","pos":""}],"STATION":[{"def":"The particular place, or kind of situation, in which a species naturally occurs; a habitat.","pos":""},{"def":"A place to which ships may resort, and where they may anchor safely.","pos":""}],"STATIONAL":[{"def":"Of or pertaining to a station.","pos":""}],"STATIONARINESS":[{"def":"The quality or state of being stationary; fixity.","pos":""}],"STATIONARY":[{"def":"Not moving; not appearing to move; stable; fixed.","pos":""},{"def":"Not improving or getting worse; not growing wiser, greater, better, more excellent, or the contrary.","pos":""}],"STATIONER":[{"def":"A bookseller or publisher; -- formerly so called from his occupying a stand, or station, in the market place or elsewhere.","pos":""},{"def":"One who sells paper, pens, quills, inkstands, pencils, blank books, and other articles used in writing.","pos":""}],"STATIONERY":[{"def":"The articles usually sold by stationers, as paper, pens, ink, quills, blank books, etc.","pos":""}],"STATISM":[{"def":"The art of governing a state; statecraft; policy.","pos":""}],"STATIST":[{"def":"Of or pertaining to statistics; as, statistical knowledge, statistical tabulation.","pos":""}],"STATISTICALLY":[{"def":"In the way of statistics.","pos":""}],"STATISTICIAN":[{"def":"One versed in statistics; one who collects and classifies facts for statistics.","pos":""}],"STATISTICS":[{"def":"Classified facts respecting the condition of the people in a state, their health, their longevity, domestic economy, arts, property, and political strength, their resources, the state of the country, etc.","pos":""},{"def":"The branch of mathematics which studies methods for the calculation of probabilities.","pos":""}],"STATISTOLOGY":[{"def":"See Statistics, 2.","pos":""}],"STATIVE":[{"def":"Of or pertaining to a fixed camp, or military posts or quarters.","pos":""}],"STATOBLAST":[{"def":"One of a peculiar kind of internal buds, or germs, produced in the interior of certain Bryozoa and sponges, especially in the fresh- water species; -- also called winter buds.","pos":""}],"STATOCRACY":[{"def":"Government by the state, or by political power, in distinction from government by ecclesiastical power.","pos":""}],"STATOR":[{"def":"A stationary part in or about which another part (the rotor) revolves, esp.","pos":""}],"STATUA":[{"def":"They spake not a word; But, like dumb statuas or breathing stones, Gazed each on other.","pos":""}],"STATUARY":[{"def":"The art of carving statues or images as representatives of real persons or things; a branch of sculpture.","pos":""}],"STATUE":[{"def":"The likeness of a living being sculptured or modeled in some solid substance, as marble, bronze, or wax; an image; as, a statue of Hercules, or of a lion.","pos":""}],"STATUED":[{"def":"Adorned with statues.","pos":""}],"STATUELESS":[{"def":"Without a statue.","pos":""}],"STATUELIKE":[{"def":"Like a statue; motionless.","pos":""}],"STATUESQUE":[{"def":"Partaking of, or exemplifying, the characteristics of a statue; having the symmetry, or other excellence, of a statue artistically made; as, statuesquelimbs; a statuesque attitude.","pos":""}],"STATUESQUELY":[{"def":"In a statuesque manner; in a way suggestive of a statue; like a statue.","pos":""}],"STATUETTE":[{"def":"A small statue; -- usually applied to a figure much less than life size, especially when of marble or bronze, or of plaster or clay as a preparation for the marble or bronze, as distinguished from a figure in terra cotta or the like.","pos":""}],"STATUMINATE":[{"def":"To prop or support.","pos":""}],"STATURE":[{"def":"The natural height of an animal body; -- generally used of the human body.","pos":""}],"STATURED":[{"def":"Arrived at full stature.","pos":""}],"STATUS":[{"def":"State; condition; position of affairs.","pos":""},{"def":"The state in which anything is already.","pos":""}],"STATUTABLE":[{"def":"Made or introduced by statute; proceeding from an act of the legistature; as, a statutable provision or remedy.","pos":""},{"def":"Made or being in conformity to statute; standard; as, statutable measures.","pos":""}],"STATUTABLY":[{"def":"Conformably to statute.","pos":""}],"STATUTE":[{"def":"An act of the legislature of a state or country, declaring, commanding, or prohibiting something; a positive law; the written will of the legislature expressed with all the requisite forms of legislation; -- used in distinction fraom common law.","pos":""},{"def":"An act of a corporation or of its founder, intended as a permanent rule or law; as, the statutes of a university.","pos":""}],"STATUTORY":[{"def":"Enacted by statute; depending on statute for its authority; as, a statutory provision.","pos":""},{"def":"See Stanch, Stanchly, etc.","pos":""}]}