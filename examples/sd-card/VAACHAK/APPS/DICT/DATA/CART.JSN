{"CART":[{"def":"A common name for various kinds of vehicles, as a Scythian dwelling on wheels, or a chariot.","pos":""},{"def":"A two-wheeled vehicle for the ordinary purposes of husbandry, or for transporting bulky and heavy articles.","pos":""}],"CARTAGE":[{"def":"The act of carrying in a cart.","pos":""},{"def":"The price paid for carting.","pos":""}],"CARTBOTE":[{"def":"Wood to which a tenant is entitled for making and repairing carts and other instruments of husbandry.","pos":""}],"CARTE":[{"def":"Short for Carte de visite.","pos":""}],"CARTE BLANCHE":[{"def":"A blank paper, with a person's signature, etc.","pos":""}],"CARTE DE VISITE":[{"def":"A visiting card.","pos":""},{"def":"A photographic picture of the size formerly in use for a visiting card.","pos":""}],"CARTE QUARTE":[{"def":"A position in thrusting or parrying, with the inside of the hand turned upward and the point of the weapon toward the adversary's right breast.","pos":""}],"CARTEL":[{"def":"An agreement between belligerents for the exchange of prisoners.","pos":""}],"CARTER":[{"def":"A man who drives a cart; a teamster.","pos":""}],"CARTESIAN":[{"def":"Of or pertaining to the French philosopher René Descartes, or his philosophy.","pos":""}],"CARTESIANISM":[{"def":"The philosophy of Descartes.","pos":""}],"CARTHAGINIAN":[{"def":"Of a pertaining to ancient Carthage, a city of northern Africa.","pos":""},{"def":"A native or inhabitant of Carthage.","pos":""}],"CARTHAMIN":[{"def":"A red coloring matter obtained from the safflower, or Carthamus tinctorius.","pos":""}],"CARTHUSIAN":[{"def":"A member of an exceeding austere religious order, founded at Chartreuse in France by St.","pos":""}],"CARTILAGE":[{"def":"A translucent, elastic tissue; gristle.","pos":""}],"CARTILAGINEOUS":[{"def":"See Cartilaginous.","pos":""}],"CARTILAGINIFICATION":[{"def":"The act or process of forming cartilage.","pos":""}],"CARTILAGINOUS":[{"def":"Having the skeleton in the state of cartilage, the bones containing little or no calcareous matter; said of certain fishes, as the sturgeon and the sharks.","pos":""}],"CARTIST":[{"def":"In Spain and Portugal, one who supports the constitution.","pos":""}],"CARTMAN":[{"def":"One who drives or uses a cart; a teamster; a carter.","pos":""}],"CARTOGRAM":[{"def":"A map showing geographically, by shades or curves, statistics of various kinds; a statistical map.","pos":""}],"CARTOGRAPHER":[{"def":"One who make charts or maps.","pos":""},{"def":"Of or pertaining to cartography.","pos":""}],"CARTOGRAPHICALLY":[{"def":"Car`to*graph\"ic*al*ly, adv.","pos":""}],"CARTOGRAPHY":[{"def":"The act business of forming chart's or maps.","pos":""}],"CARTOMANCY":[{"def":"The act of telling fortunes with cards.","pos":""}],"CARTON":[{"def":"Pasteboard for paper boxes; also, a pasteboard box.","pos":""}],"CARTOON":[{"def":"A design or study drawn of the full size, to serve as a model for transferring or copying; -- used in the making of mosaics, tapestries, fresco pantings and the like; as, the cartoons of Raphael.","pos":""},{"def":"A large pictorial sketch, as in a journal or magazine; esp.","pos":""}],"CARTOONIST":[{"def":"One skilled in drawing cartoons.","pos":""}],"CARTOUCH":[{"def":"An oval figure on monuments, and in papyri, containing the name of a sovereign.","pos":""}],"CARTRIDGE":[{"def":"A complete charge for a firearm, contained in, or held together by, a case, capsule, or shell of metal, pasteboard, or other material.","pos":""}],"CARTULARY":[{"def":"A register, or record, as of a monastery or church.","pos":""},{"def":"An ecclesiastical officer who had charge of records or other public papers.","pos":""}],"CARTWAY":[{"def":"A way or road for carts.","pos":""}],"CARTWRIGHT":[{"def":"An artificer who makes carts; a cart maker.","pos":""}]}