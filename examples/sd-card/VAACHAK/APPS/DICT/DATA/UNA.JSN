{"UNA BOAT":[{"def":"The English name for a catboat; -- so called because Una was the name of the first boat of this kind taken to England.","pos":""}],"UNABLE":[{"def":"Not able; not having sufficient strength, means, knowledge, skill, or the like; impotent' weak; helpless; incapable; -- now usually followed by an infinitive or an adverbial phrase; as, unable for work; unable to bear fatigue.","pos":""}],"UNABRIDGED":[{"def":"Not abridged, or shortened; full; complete; entire; whole.","pos":""}],"UNABSORBABLE":[{"def":"Not absorbable; specifically (Physiol.","pos":""}],"UNACCEPTABILITY":[{"def":"The quality of being unacceptable; unacceptableness.","pos":""}],"UNACCEPTABLE":[{"def":"Not acceptable; not pleasing; not welcome; unpleasant; disagreeable; displeasing; offensive.","pos":""}],"UNACCOMPLISHED":[{"def":"Not accomplished or performed; unfinished; also, deficient in accomplishment; unrefined.","pos":""}],"UNACCOMPLISHMENT":[{"def":"The state of being unaccomplished.","pos":""}],"UNACCOUNTABILITY":[{"def":"The quality or state of being unaccountable.","pos":""}],"UNACCOUNTABLE":[{"def":"Not accountable or responsible; free from control.","pos":""},{"def":"Not to be accounted for; inexplicable; not consonant with reason or rule; strange; mysterious.","pos":""}],"UNACCURATENESS":[{"def":"Un*ac\"cu*rate*ness, n.","pos":""}],"UNACCUSTOMED":[{"def":"Not used; not habituated; unfamiliar; unused; -- which to.","pos":""},{"def":"Not usual; uncommon; strange; new.","pos":""}],"UNACQUAINTANCE":[{"def":"The quality or state of being unacquainted; want of acquaintance; ignorance.","pos":""}],"UNACQUAINTED":[{"def":"Not usual; unfamiliar; strange.","pos":""}],"UNACQUAINTEDNESS":[{"def":"Un`ac*quaint\"ed*ness, n.","pos":""}],"UNACTIVE":[{"def":"Inactive; listless.","pos":""}],"UNACTIVENESS":[{"def":"UNADMISSIBLE; UNADMITTABLE Un`ad*mis\"si*ble, Un`ad*mit\"ta*ble, a.","pos":""}],"UNADVISABLE":[{"def":"Not advisable; inadvisable; inexpedient.","pos":""}],"UNADVISED":[{"def":"Not prudent; not discreet; ill advised.","pos":""},{"def":"Done without due consideration; wanton; rash; inconsiderate; as, an unadvised proceeding.","pos":""}],"UNAFFECTED":[{"def":"Not affected or moved; destitute of affection or emotion; uninfluenced.","pos":""},{"def":"Free from affectation; plain; simple; natural; real; sincere; genuine; as, unaffected sorrow.","pos":""}],"UNAGREEABLE":[{"def":"Not agreeing or consistent; unsuitable.","pos":""}],"UNAIDABLE":[{"def":"Incapable of being aided.","pos":""}],"UNALIENABLE":[{"def":"Inalienable; as, unalienable rights.","pos":""}],"UNALIST":[{"def":"An ecclesiastical who holds but one benefice; -- distinguished from pluralist.","pos":""}],"UNALLIED":[{"def":"Not allied; having no ally; having no connection or relation; as, unallied species or genera.","pos":""}],"UNALLOYED":[{"def":"Not alloyed; not reduced by foreign admixture; unmixed; unqualified; pure; as, unalloyed metals; unalloyed happiness.","pos":""}],"UNALMSED":[{"def":"Not having received alms.","pos":""}],"UNAMBIGUITY":[{"def":"Absence of ambiguity; clearness; perspicuity.","pos":""}],"UNAMBITION":[{"def":"The absence of ambition.","pos":""}],"UNAMIABILITY":[{"def":"The quality or state of being unamiable; moroseness.","pos":""}],"UNAMIABLE":[{"def":"Not amiable; morose; ill-natured; repulsive.","pos":""}],"UNANCHOR":[{"def":"To loose from the anchor, as a ship.","pos":""}],"UNANELED":[{"def":"Not aneled; not having received extreme unction.","pos":""}],"UNANIMITY":[{"def":"The quality or state of being unanimous.","pos":""}],"UNANIMOUS":[{"def":"Being of one mind; agreeing in opinion, design, or determination; consentient; not discordant or dissentient; harmonious; as, the assembly was unanimous; the members of the council were unanimous.","pos":""},{"def":"Formed with unanimity; indicating unanimity; having the agreement and consent of all; agreed upon without the opposition or contradiction of any; as, a unanimous opinion; a unanimous vote.","pos":""}],"UNANSWERABILITY":[{"def":"The quality of being unanswerable; unanswerableness.","pos":""}],"UNANSWERABLE":[{"def":"Not answerable; irrefutable; conclusive; decisive; as, he have an unanswerable argument.","pos":""}],"UNANSWERED":[{"def":"Not answered; not replied; as, an unanswered letter.","pos":""},{"def":"Not refuted; as, an unanswered argument.","pos":""}],"UNAPPALLED":[{"def":"Not appalled; not frightened; dauntless; undaunted.","pos":""}],"UNAPPAREL":[{"def":"To divest of clothing; to strip.","pos":""}],"UNAPPEALABLE":[{"def":"Not appealable; that can not be carried to a higher tribunal by appeal; as, an unappealable suit or action.","pos":""},{"def":"Not to be appealed from; -- said of a judge or a judgment that can not be overruled.","pos":""}],"UNAPPROPRIATE":[{"def":"Inappropriate; unsuitable.","pos":""},{"def":"Not appropriated.","pos":""}],"UNAPPROPRIATED":[{"def":"Not specially appropriate; having not special application.","pos":""},{"def":"Not granted to any person, corporation, or the like, to the exclusion of others; as, unappropriated lands.","pos":""}],"UNAPT":[{"def":"Inapt; slow; dull.","pos":""},{"def":"Unsuitable; unfit; inappropriate.","pos":""}],"UNARGUED":[{"def":"Not argued or debated.","pos":""},{"def":"Not argued against; undisputed.","pos":""}],"UNARM":[{"def":"To puff off, or lay down, one's arms or armor.","pos":""}],"UNARMED":[{"def":"Having no hard and sharp projections, as spines, prickles, spurs, claws, etc.","pos":""}],"UNARTED":[{"def":"Ignorant of the arts.","pos":""},{"def":"Not artificial; plain; simple.","pos":""}],"UNARTFUL":[{"def":"Lacking art or skill; artless.","pos":""}],"UNASSENTED":[{"def":"Not assented; -- said specif.","pos":""}],"UNASSUMING":[{"def":"Not assuming; not bold or forward; not arrogant or presuming; humble; modest; retiring; as, an unassuming youth; unassuming manners.","pos":""}],"UNASSURED":[{"def":"Not assured; not bold or confident.","pos":""},{"def":"Not to be trusted.","pos":""}],"UNATONABLE":[{"def":"Not capable of being brought into harmony; irreconcilable.","pos":""},{"def":"Incapable of being atoned for; inexpiable.","pos":""}],"UNATTACHED":[{"def":"Not assigned to any company or regiment.","pos":""},{"def":"Not taken or arrested.","pos":""}],"UNATTENTIVE":[{"def":"Inattentive; careless.","pos":""}],"UNATTIRE":[{"def":"To divest of attire; to undress.","pos":""}],"UNAU":[{"def":"The two-toed sloth (Cholopus didactylus), native of South America.","pos":""}],"UNAUDIENCED":[{"def":"Not given an audience; not received or heard.","pos":""}],"UNAUTHORIZE":[{"def":"To disown the authority of; to repudiate.","pos":""}],"UNAVOIDABLE":[{"def":"Not voidable; incapable of being made null or void.","pos":""}],"UNAVOIDED":[{"def":"Not avoided or shunned.","pos":""},{"def":"Unavoidable; inevitable.","pos":""}],"UNAWARE":[{"def":"Not aware; not noticing; giving no heed; thoughtless; inattentive.","pos":""}],"UNAWARES":[{"def":", Without design or preparation; suddenly; without premeditation, unexpectedly.","pos":""}]}