{"TAR":[{"def":"A sailor; a seaman.","pos":""}],"TARANIS":[{"def":"A Celtic divinity, regarded as the evil principle, but confounded by the Romans with Jupiter.","pos":""}],"TARANTASS":[{"def":"A low four-wheeled carriage used in Russia.","pos":""}],"TARANTISM":[{"def":"A nervous affection producing melancholy, stupor, and an uncontrollable desire to dance.","pos":""}],"TARANTULA":[{"def":"Any one of several species of large spiders, popularly supposed to be very venomous, especially the European species (Tarantula apuliæ).","pos":""}],"TARANTULATED":[{"def":"Bitten by a tarantula; affected with tarantism.","pos":""}],"TARBOOSH":[{"def":"A red cap worn by Turks and other Eastern nations, sometimes alone and sometimes swathed with linen or other stuff to make a turban.","pos":""}],"TARDATION":[{"def":"The act of retarding, or delaying; retardation.","pos":""}],"TARDIGRADA":[{"def":"A tribe of edentates comprising the sloths.","pos":""},{"def":"An order of minute aquatic arachnids; -- called also bear animalcules, sloth animalcules, and water bears.","pos":""}],"TARDIGRADE":[{"def":"Of or pertaining to the Tardigrada.","pos":""}],"TARDIGRADOUS":[{"def":"Moving slowly; slow-paced.","pos":""}],"TARDILY":[{"def":"In a tardy manner; slowly.","pos":""}],"TARDINESS":[{"def":"The quality or state of being tardy.","pos":""}],"TARDITATION":[{"def":"To instruct them to avoid all snares of tarditation, in the Lord's affairs.","pos":""}],"TARDITY":[{"def":"Slowness; tardiness.","pos":""}],"TARDO":[{"def":"Slow; -- a direction to perform a passage slowly.","pos":""}],"TARDY":[{"def":"Moving with a slow pace or motion; slow; not swift.","pos":""},{"def":"Not being inseason; late; dilatory; -- opposed to prompt; as, to be tardy in one's payments.","pos":""}],"TARE":[{"def":"A name of several climbing or diffuse leguminous herbs of the genus Vicia; especially, the V.","pos":""}],"TARED":[{"def":"Weighed; determined; reduced to equal or standard weight; as, tared filter papers, used in weighing precipitates.","pos":""}],"TARENTE":[{"def":"A harmless lizard of the Gecko family (Platydactylus Mauritianicus) found in Southern Europe and adjacent countries, especially among old walls and ruins.","pos":""}],"TARGE":[{"def":"A shield or target.","pos":""}],"TARGET":[{"def":"The sliding crosspiece, or vane, on a leveling staff.","pos":""},{"def":"A conspicuous disk attached to a switch lever to show its position, or for use as a signal.","pos":""}],"TARGETED":[{"def":"Furnished, armed, or protected, with a target.","pos":""}],"TARGETEER":[{"def":"One who is armed with a target or shield.","pos":""}],"TARGUM":[{"def":"A translation or paraphrase of some portion of the Old Testament Scriptures in the Chaldee or Aramaic language or dialect.","pos":""}],"TARGUMIST":[{"def":"The writer of a Targum; one versed in the Targums.","pos":""}],"TARIFF":[{"def":"A schedule, system, or scheme of duties imposed by the government of a country upon goods imported or exported; as, a revenue tariff; a protective tariff; Clay's compromise tariff.","pos":""},{"def":"The duty, or rate of duty, so imposed; as, the tariff on wool; a tariff of two cents a pound.","pos":""}],"TARING":[{"def":"The common tern; -- called also tarret, and tarrock.","pos":""}],"TARLATAN":[{"def":"A kind of thin, transparent muslin, used for dresses.","pos":""}],"TARN":[{"def":"A mountain lake or pool.","pos":""}],"TARNISH":[{"def":"To soil, or change the appearance of, especially by an alternation induced by the air, or by dust, or the like; to diminish, dull, or destroy the luster of; to sully; as, to tarnish a metal; to tarnish gilding; to tarnish the purity of color.","pos":""}],"TARNISHER":[{"def":"One who, or that which, tarnishes.","pos":""}],"TARO":[{"def":"A name for several aroid plants (Colocasia antiquorum, var.","pos":""}],"TAROT":[{"def":"A game of cards; -- called also taroc.","pos":""}],"TARPAN":[{"def":"A wild horse found in the region of the Caspian Sea.","pos":""}],"TARPAULIN":[{"def":"A piece of canvas covered with tar or a waterproof composition, used for covering the hatches of a ship, hammocks, boats, etc.","pos":""},{"def":"A hat made of, or covered with, painted or tarred cloth, worn by sailors and others.","pos":""}],"TARPEIAN":[{"def":"Pertaining to or designating a rock or peak of the Capitoline hill, Rome, from which condemned criminals were hurled.","pos":""}],"TARPUM":[{"def":"A very large marine fish (Megapolis Atlanticus) of the Southern United States and the West Indies.","pos":""}],"TARQUINISH":[{"def":"Like a Tarquin, a king of ancient Rome; proud; haughty; overbearing.","pos":""}],"TARRAGON":[{"def":"A plant of the genus Artemisa (A.","pos":""}],"TARRE":[{"def":"To set on, as a dog; to incite.","pos":"verb"}],"TARRIANCE":[{"def":"The act or time of tarrying; delay; lateness.","pos":""}],"TARRIER":[{"def":"One who, or that which, tarries.","pos":""}],"TARRY":[{"def":"Consisting of, or covered with, tar; like tar.","pos":""}],"TARSAL":[{"def":"Of or pertaining to the tarsus (either of the foot or eye).","pos":""},{"def":"A tarsal bone or cartilage; a tarsale.","pos":""}],"TARSALE":[{"def":"One of the bones or cartilages of the tarsus; esp.","pos":""}],"TARSE":[{"def":"The male falcon.","pos":""}],"TARSECTOMY":[{"def":"The operation of excising one or more of the bones of the tarsus.","pos":""}],"TARSI":[{"def":"TARSIA; TARSIATURA Tar\"si*a, Tar`si*a*tu\"ra, n.","pos":""}],"TARSIUS":[{"def":"A genus of nocturnal lemurine mammals having very large eyes and ears, a long tail, and very long proximal tarsal bones; -- called also malmag, spectral lemur, podji, and tarsier.","pos":""}],"TARSO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the tarsus; as, tarsometatarsus.","pos":""}],"TARSOMETATARSAL":[{"def":"Tar`so*met`a*tar\"sal, a.","pos":""}],"TARSOMETATARSUS":[{"def":"The large bone next the foot in the leg of a bird.","pos":""}],"TARSORRHAPHY":[{"def":"An operation to diminish the size of the opening between eyelids when enlarged by surrounding cicatrices.","pos":""}],"TARSOTOMY":[{"def":"The operation of cutting or removing the tarsal cartilages.","pos":""}],"TARSUS":[{"def":"The foot of an insect or a crustacean.","pos":""}],"TART":[{"def":"Sharp to the taste; acid; sour; as, a tart apple.","pos":""}],"TARTAN":[{"def":"Woolen cloth, checkered or crossbarred with narrow bands of various colors, much worn in the Highlands of Scotland; hence, any pattern of tartan; also, other material of a similar pattern.","pos":""}],"TARTAR":[{"def":"A reddish crust or sediment in wine casks, consisting essentially of crude cream of tartar, and used in marking pure cream of tartar, tartaric acid, potassium carbonate, black flux, etc.","pos":""}],"TARTARATED":[{"def":"Of or pertaining to Tartarus; hellish.","pos":""}],"TARTAREOUS":[{"def":"Having the surface rough and crumbling; as, many lichens are tartareous.","pos":""},{"def":"Of or pertaining to Tartary in Asia, or the Tartars.","pos":""}],"TARTARIAN":[{"def":"The name of some kinds of cherries, as the Black Tartarian, or the White Tartarian.","pos":""}],"TARTARIC":[{"def":"Of or pertaining to tartar; derived from, or resembling, tartar.","pos":""}],"TARTARINE":[{"def":"Potassium carbonate, obtained by the incineration of tartar.","pos":""}],"TARTARIZE":[{"def":"To impregnate with, or subject to the action of, tartar.","pos":""}],"TARTAROUS":[{"def":"Containing tartar; consisting of tartar, or partaking of its qualities; tartareous.","pos":""}],"TARTARUS":[{"def":"The infernal regions, described in the Iliad as situated as far below Hades as heaven is above the earth, and by later writers as the place of punishment for the spirits of the wicked.","pos":""}],"TARTINI'S TONES":[{"def":"See the Note under Tone.","pos":""}],"TARTLY":[{"def":"In a tart manner; with acidity.","pos":""}],"TARTNESS":[{"def":"The quality or state of being tart.","pos":""}],"TARTRALIC":[{"def":"Pertaining to, or designating, an acid obtained as a white amorphous deliquescent substance, C8H10O11; -- called also ditartaric, tartrilic, or tartrylic acid.","pos":""}],"TARTRAMATE":[{"def":"A salt of tartramic acid.","pos":""}],"TARTRAMIC":[{"def":"Of, pertaining to, or designating, an acid which is the primary acid amide derivative of tartaric acid.","pos":""}],"TARTRAMIDE":[{"def":"An acid amide derivative of tartaric acid, obtained as a white crystalline substance.","pos":""}],"TARTRATE":[{"def":"A salt of tartaric acid.","pos":""}],"TARTRATED":[{"def":"Containing, or derived from, tartar; combined with tartaric acid.","pos":""}],"TARTRAZINE":[{"def":"An artificial dyestuff obtained as an orange-yellow powder, and regarded as a phenyl hydrazine derivative of tartaric and sulphonic acids.","pos":""}],"TARTRELIC":[{"def":"Of, pertaining to, or designating, an anhydride, C4H4O5, of tartaric acid, obtained as a white crystalline deliquescent substance.","pos":""}],"TARTRO-":[{"def":"A combining form (also used adjectively) used in chemistry to denote the presence of tartar or of some of its compounds or derivatives.","pos":""}],"TARTRONATE":[{"def":"A salt of tartronic acid.","pos":""}],"TARTRONIC":[{"def":"Of, pertaining to, or designating, an organic acid (called also hydroxy malonic acid) obtained, by reducing mesoxalic acid, as a white crystalline substance.","pos":""}],"TARTRONYL":[{"def":"A hypothetical radical constituting the characteristic residue of tartronic acid and certain of its derivatives.","pos":""}],"TARTROVINIC":[{"def":"Of, pertaining to, or designating, a certain acid composed of tartaric acid in combination with ethyl, and now called ethyltartaric acid.","pos":""},{"def":"A hypocritical devotee.","pos":""}],"TARWEED":[{"def":"A name given to several resinous-glandular composite plants of California, esp.","pos":""}]}