{"DERACINATE":[{"def":"To pluck up by the roots; to extirpate.","pos":""}],"DERACINATION":[{"def":"The act of pulling up by the roots; eradication.","pos":""},{"def":"To prove or to refute by proof; to clear (one's self).","pos":""}],"DERAIL":[{"def":"To cause to run off from the rails of a railroad, as a locomotive.","pos":""}],"DERAILMENT":[{"def":"The act of going off, or the state of being off, the rails of a railroad.","pos":""}],"DERANGE":[{"def":"To put out of place, order, or rank; to disturb the proper arrangement or order of; to throw into disorder, confusion, or embarrassment; to disorder; to disarrange; as, to derange the plans of a commander, or the affairs of a nation.","pos":""},{"def":"To disturb in action or function, as a part or organ, or the whole of a machine or organism.","pos":""}],"DERANGED":[{"def":"Disordered; especially, disordered in mind; crazy; insane.","pos":""}],"DERANGEMENT":[{"def":"The act of deranging or putting out of order, or the state of being deranged; disarrangement; disorder; confusion; especially, mental disorder; insanity.","pos":""}],"DERANGER":[{"def":"One who deranges.","pos":""}],"DERAY":[{"def":"Disorder; merriment.","pos":""}],"DERBIO":[{"def":"A large European food fish (Lichia glauca).","pos":""}],"DERBY":[{"def":"A race for three-old horses, run annually at Epsom (near London), for the Derby stakes.","pos":""},{"def":"Derby Day, the day of the annual race for the Derby stakes, -- Wednesday of the week before Whitsuntide.","pos":""}],"DERBYSHIRE SPAR":[{"def":"A massive variety of fluor spar, found in Derbyshire, England, and wrought into vases and other ornamental work.","pos":""}],"DERDOING":[{"def":"Doing daring or chivalrous deeds.","pos":""}],"DERE":[{"def":"To hurt; to harm; to injure.","pos":""}],"DERECHO":[{"def":"A straight wind without apparent cyclonic tendency, usually accompanied with rain and often destructive, common in the prairie regions of the United States.","pos":""},{"def":"Same as Darraign.","pos":""}],"DERELICT":[{"def":"Given up or forsaken by the natural owner or guardian; left and abandoned; as, derelict lands.","pos":""},{"def":"Lost; adrift; hence, wanting; careless; neglectful; unfaithful.","pos":""}],"DERELICTION":[{"def":"A retiring of the sea, occasioning a change of high-water mark, whereby land is gained.","pos":""}],"DERELIGIONIZE":[{"def":"To make irreligious; to turn from religion.","pos":""}],"DERF":[{"def":"Strong; powerful; fierce.","pos":""}],"DERIDE":[{"def":"To laugh at with contempt; to laugh to scorn; to turn to ridicule or make sport of; to mock; to scoff at.","pos":""}],"DERIDER":[{"def":"One who derides, or laughs at, another in contempt; a mocker; a scoffer.","pos":""}],"DERIDINGLY":[{"def":"By way of derision or mockery.","pos":""}],"DERISION":[{"def":"The act of deriding, or the state of being derided; mockery; scornful or contemptuous treatment which holds one up to ridicule.","pos":""},{"def":"An object of derision or scorn; a laughing-stock.","pos":""}],"DERISIVE":[{"def":"Expressing, serving for, or characterized by, derision.","pos":""}],"DERISORY":[{"def":"Derisive; mocking.","pos":""}],"DERIVABLE":[{"def":"That can be derived; obtainable by transmission; capable of being known by inference, as from premises or data; capable of being traced, as from a radical; as, income is derivable from various sources.","pos":""}],"DERIVAL":[{"def":"The derival of e from a.","pos":""}],"DERIVATE":[{"def":"Derived; derivative.","pos":""},{"def":"A thing derived; a derivative.","pos":""}],"DERIVATION":[{"def":"The operation of deducing one function from another according to some fixed law, called the law of derivation, as the of differentiation or of integration.","pos":""},{"def":"A drawing of humors or fluids from one part of the body to another, to relieve or lessen a morbid process.","pos":""}],"DERIVATIONAL":[{"def":"Relating to derivation.","pos":""}],"DERIVATIVE":[{"def":"Obtained by derivation; derived; not radical, original, or fundamental; originating, deduced, or formed from something else; secondary; as, a derivative conveyance; a derivative word.","pos":""}],"DERIVE":[{"def":"To obtain one substance from another by actual or theoretical substitution; as, to derive an organic acid from its corresponding hydrocarbon.","pos":""}],"DERIVEMENT":[{"def":"That which is derived; deduction; inference.","pos":""}],"DERIVER":[{"def":"One who derives.","pos":""}],"DERK":[{"def":"A suffix or terminal formative, much used in anatomical terms, and signifying skin, integument, covering; as, blastoderm, ectoderm, etc.","pos":""}],"DERM":[{"def":"The integument of animal; the skin.","pos":""}],"DERMAL":[{"def":"Pertaining to the dermis or true skin.","pos":""},{"def":"See Dermoptera, Dermopteran.","pos":""}],"DERMATITIS":[{"def":"Inflammation of the skin.","pos":""}],"DERMATOGEN":[{"def":"Nascent epidermis, or external cuticle of plants in a forming condition.","pos":""}],"DERMATOGRAPHY":[{"def":"An anatomical description of, or treatise on, the skin.","pos":""}],"DERMATOLOGIST":[{"def":"One who discourses on the skin and its diseases; one versed in dermatology.","pos":""}],"DERMATOLOGY":[{"def":"The science which treats of the skin, its structure, functions, and diseases.","pos":""}],"DERMATOPATHIC":[{"def":"Of or pertaining to skin diseases, or their cure.","pos":""}],"DERMATOPHYTE":[{"def":"A vegetable parasite, infesting the skin.","pos":""}],"DERMESTES":[{"def":"A genus of coleopterous insects, the larvæ of which feed animal substances.","pos":""}],"DERMESTOID":[{"def":"Pertaining to or resembling the genus Dermestes.","pos":""}],"DERMIC":[{"def":"Pertaining to the dermis; dermal.","pos":""}],"DERMIS":[{"def":"The deep sensitive layer of the skin beneath the scarfskin or epidermis; -- called also true skin, derm, derma, corium, cutis, and enderon.","pos":""}],"DERMOBRANCHIATA":[{"def":"A group of nudibranch mollusks without special gills.","pos":""}],"DERMOBRANCHIATE":[{"def":"Having the skin modified to serve as a gill.","pos":""}],"DERMOHAEMAL":[{"def":"Pertaining to, or in relation with, both dermal and hæmal structures; as, the dermohæmal spines or ventral fin rays of fishes.","pos":""}],"DERMOID":[{"def":"Same as Dermatoid.","pos":""}],"DERMONEURAL":[{"def":"Pertaining to, or in relation with, both dermal and neural structures; as, the dermoneural spines or dorsal fin rays of fishes.","pos":""}],"DERMOPTERA":[{"def":"The division of insects which includes the earwigs (Forticulidæ).","pos":""},{"def":"A group of lemuroid mammals having a parachutelike web of skin between the fore and hind legs, of which the colugo (Galeopithecus) is the type.","pos":""}],"DERMOPTERAN":[{"def":"An insect which has the anterior pair of wings coriaceous, and does not use them in flight, as the earwig.","pos":""}],"DERMOPTERI":[{"def":"Same as Dermopterygii.","pos":""}],"DERMOPTERYGII":[{"def":"A group of fishlike animals including the Marsipobranchiata and Leptocardia.","pos":""}],"DERMOSKELETON":[{"def":"See Exoskeleton.","pos":""}],"DERMOSTOSIS":[{"def":"Ossification of the dermis.","pos":""}],"DERN":[{"def":"A gatepost or doorpost.","pos":""}],"DERNE":[{"def":"To hide; to skulk.","pos":""}],"DERNFUL":[{"def":"Secret; hence, lonely; sad; mournful.","pos":""}],"DERNLY":[{"def":"Secretly; grievously; mournfully.","pos":""}],"DEROGATE":[{"def":"To annul in part; to repeal partly; to restrict; to limit the action of; -- said of a law.","pos":""},{"def":"To lessen; to detract from; to disparage; to depreciate; -- said of a person or thing.","pos":""}],"DEROGATELY":[{"def":"In a derogatory manner.","pos":""}],"DEROGATION":[{"def":"An alteration of, or subtraction from, a contract for a sale of stocks.","pos":""}],"DEROGATORILY":[{"def":"In a derogatory manner; disparagingly.","pos":""}],"DEROGATORINESS":[{"def":"Quality of being derogatory.","pos":""}],"DEROGATORY":[{"def":"Tending to derogate, or lessen in value; expressing derogation; detracting; injurious; -- with from to, or unto.","pos":""}],"DEROTREMATA":[{"def":"The tribe of aquatic Amphibia which includes Amphiuma, Menopoma, etc.","pos":""}],"DERRICK":[{"def":"A mast, spar, or tall frame, supported at the top by stays or guys, with suitable tackle for hoisting heavy weights, as stones in building.","pos":""}],"DERRING":[{"def":"Daring or warlike.","pos":""}],"DERRINGER":[{"def":"A kind of short-barreled pocket pistol, of very large caliber, often carrying a half-ounce ball.","pos":""}],"DERTH":[{"def":"Dearth; scarcity.","pos":""}],"DERTROTHECA":[{"def":"The horny covering of the end of the bill of birds.","pos":""},{"def":"A Turkish or Persian monk, especially one who professes extreme poverty and leads an austere life.","pos":""}]}