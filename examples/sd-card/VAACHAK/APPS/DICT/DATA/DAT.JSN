{"DATABLE":[{"def":"That may be dated; having a known or ascertainable date.","pos":""}],"DATARIA":[{"def":"Formerly, a part of the Roman chancery; now, a separate office from which are sent graces or favors, cognizable in foro externo, such as appointments to benefices.","pos":""}],"DATARY":[{"def":"An officer in the pope's court, having charge of the Dataria.","pos":""}],"DATE":[{"def":"The fruit of the date palm; also, the date palm itself.","pos":"noun"}],"DATE LINE":[{"def":"The hypothetical line on the surface of the earth fixed by international or general agreement as a boundary on one side of which the same day shall have a different name and date in the calendar from its name and date on the other side.","pos":""}],"DATELESS":[{"def":"Without date; having no fixed time.","pos":""}],"DATISCIN":[{"def":"A white crystalline glucoside extracted from the bastard hemp (Datisca cannabina).","pos":""}],"DATIVE":[{"def":"Noting the case of a noun which expresses the remoter object, and is generally indicated in English by to or for with the objective.","pos":""}],"DATOLITE":[{"def":"A borosilicate of lime commonly occuring in glassy,, greenish crystals.","pos":""}],"DATUM":[{"def":"The quantities or relations which are assumed to be given in any problem.","pos":""}],"DATURA":[{"def":"A genus of solanaceous plants, with large funnel-shaped flowers and a four-celled, capsular fruit.","pos":""}],"DATURINE":[{"def":"Atropine; -- called also daturia and daturina.","pos":""}]}