{"LUBBER":[{"def":"A heavy, clumsy, or awkward fellow; a sturdy drone; a clown.","pos":""}],"LUBBERLY":[{"def":"Like a lubber; clumsy.","pos":""}],"LUBRICANT":[{"def":"That which lubricates; specifically, a substance, as oil, grease, plumbago, etc.","pos":""}],"LUBRICATE":[{"def":"To make smooth or slippery; as, mucilaginous and saponaceous remedies lubricate the parts to which they are applied.","pos":""},{"def":"To apply a lubricant to, as oil or tallow.","pos":""}],"LUBRICATION":[{"def":"The act of lubricating; the act of making slippery.","pos":""}],"LUBRICATOR":[{"def":"One who, or that which, lubricates.","pos":""},{"def":"A contrivance, as an oil cup, for supplying a lubricant to machinery.","pos":""}],"LUBRICITY":[{"def":"Smoothness; freedom from friction; also, property, which diminishes friction; as, the lubricity of oil.","pos":""},{"def":"Slipperiness; instability; as, the lubricity of fortune.","pos":""}],"LUBRICOUS":[{"def":"The act of lubricating, or making smooth.","pos":""}]}