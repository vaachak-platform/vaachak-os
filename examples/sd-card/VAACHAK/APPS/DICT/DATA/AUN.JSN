{"AUNCEL":[{"def":"A rude balance for weighing, and a kind of weight, formerly used in England.","pos":""}],"AUNE":[{"def":"A French cloth measure, of different parts of the country (at Paris, 0.","pos":""}],"AUNT":[{"def":"The sister of one's father or mother; -- correlative to nephew or niece.","pos":""},{"def":"An old woman; and old gossip.","pos":""}],"AUNTER":[{"def":"To venture; to dare.","pos":""}]}