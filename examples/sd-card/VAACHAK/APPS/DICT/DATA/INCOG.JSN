{"INCOG":[{"def":"Depend upon it -- he'll remain incog.","pos":""}],"INCOGITABLE":[{"def":"Not cogitable; inconceivable.","pos":""},{"def":"Want of thought, or of the power of thinking; thoughtlessness; unreasonableness.","pos":""}],"INCOGITANT":[{"def":"Toughtless; inconsiderate.","pos":""}],"INCOGITANTLY":[{"def":"In an incogitant manner.","pos":""}],"INCOGITATIVE":[{"def":"Not cogitative; not thinking; wanting the power of thought; as, a vegetable is an incogitative being.","pos":""}],"INCOGITATIVITY":[{"def":"The quality of being incogitative; want of thought or of the power of thinking.","pos":""}],"INCOGNITA":[{"def":"A woman who is unknown or in disguise.","pos":""},{"def":"The state of being in disguise; -- said of a woman.","pos":""}],"INCOGNITO":[{"def":"Without being known; in disguise; in an assumed character, or under an assumed title; -- said esp.","pos":""}],"INCOGNIZABLE":[{"def":"Not cognizable; incapable of being recognized, known, or distinguished.","pos":""}],"INCOGNIZANCE":[{"def":"Failure to cognize, apprehended, or notice.","pos":""}],"INCOGNIZANT":[{"def":"Not cognizant; failing to apprehended or notice.","pos":""}],"INCOGNOSCIBLE":[{"def":"The quality or state of being incoherent; want of coherence; want of cohesion or adherence.","pos":""},{"def":"Want of connection; incongruity; inconsistency; want of agreement or dependence of one part on another; as, the incoherence of arguments, facts, etc.","pos":""}]}