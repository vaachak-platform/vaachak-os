{"PERIBLAST":[{"def":"The protoplasmic matter which surrounds the entoblast, or cell nucleus, and undergoes segmentation.","pos":""}],"PERIBLEM":[{"def":"Nascent cortex, or immature cellular bark.","pos":""}],"PERIBOLOS":[{"def":"In ancient architecture, an inclosed court, esp.","pos":""}],"PERIBRANCHIAL":[{"def":"Surrounding the branchiæ; as, a peribranchial cavity.","pos":""}]}