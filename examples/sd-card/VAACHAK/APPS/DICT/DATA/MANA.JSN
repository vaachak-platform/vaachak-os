{"MANACLE":[{"def":"A handcuff; a shackle for the hand or wrist; -- usually in the plural.","pos":""}],"MANAGE":[{"def":"The handling or government of anything, but esp.","pos":""}],"MANAGEABILITY":[{"def":"The state or quality of being manageable; manageableness.","pos":""}],"MANAGEABLE":[{"def":"Such as can be managed or used; suffering control; governable; tractable; subservient; as, a manageable horse.","pos":""}],"MANAGEMENT":[{"def":"The act or art of managing; the manner of treating, directing, carrying on, or using, for a purpose; conduct; administration; guidance; control; as, the management of a family or of a farm; the management of state affairs.","pos":""},{"def":"Business dealing; negotiation; arrangement.","pos":""}],"MANAGER":[{"def":"One who manages; a conductor or director; as, the manager of a theater.","pos":""},{"def":"A person who conducts business or household affairs with economy and frugality; a good economist.","pos":""}],"MANAGERIAL":[{"def":"Of or pertaining to management or a manager; as, managerial qualities.","pos":""}],"MANAGERSHIP":[{"def":"The office or position of a manager.","pos":""}],"MANAGERY":[{"def":"Management; manner of using; conduct; direction.","pos":""},{"def":"Husbandry; economy; frugality.","pos":""}],"MANAKIN":[{"def":"Any one of numerous small birds belonging to Pipra, Manacus, and other genera of the family Pipridæ.","pos":""}],"MANATEE":[{"def":"Any species of Trichechus, a genus of sirenians; -- called alsosea cow.","pos":""}],"MANATION":[{"def":"The act of issuing or flowing out.","pos":"noun"}]}