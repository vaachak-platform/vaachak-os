{"NAVAJOES":[{"def":"A tribe of Indians inhabiting New Mexico and Arizona, allied to the Apaches.","pos":""}],"NAVAL":[{"def":"Having to do with shipping; of or pertaining to ships or a navy; consisting of ships; as, naval forces, successes, stores, etc.","pos":""}],"NAVARCH":[{"def":"The commander of a fleet.","pos":""}],"NAVARCHY":[{"def":"Nautical skill or experience.","pos":""}],"NAVARRESE":[{"def":"Of or pertaining to Navarre.","pos":""},{"def":"A native or inhabitant of Navarre; the people of Navarre.","pos":""}],"NAVE":[{"def":"The block in the center of a wheel, from which the spokes radiate, and through which the axle passes; -- called also hub or hob.","pos":""}],"NAVEL":[{"def":"A mark or depression in the middle of the abdomen; the umbilicus.","pos":""},{"def":"An eye on the under side of a carronade for securing it to a carriage.","pos":""}],"NAVEL ORANGE":[{"def":"A type of orange in which the fruit incloses a small secondary fruit, the rind showing on the exterior a navel-like pit or depression at the apex.","pos":""}],"NAVEL-STRING":[{"def":"The umbilical cord.","pos":""}],"NAVELWORT":[{"def":"A European perennial succulent herb (Cotyledon umbilicus), having round, peltate leaves with a central depression; -- also called pennywort, and kidneywort.","pos":""}],"NAVEW":[{"def":"A kind of small turnip, a variety of Brassica campestris.","pos":""}],"NAVICULAR":[{"def":"Of, pertaining to, or resembling, a boat or ship.","pos":""},{"def":"Shaped like a boat; cymbiform; scaphoid; as, the navicular glumes of most grasses; the navicular bone.","pos":""}],"NAVIGABILITY":[{"def":"The quality or condition of being navigable; navigableness.","pos":""}],"NAVIGABLE":[{"def":"Capable of being navigated; deep enough and wide enough to afford passage to vessels; as, a navigable river.","pos":""}],"NAVIGATE":[{"def":"To joirney by water; to go in a vessel or ship; to perform the duties of a navigator; to use the waters as a highway or channel for commerce or communication; to sail.","pos":"verb"}],"NAVIGATION":[{"def":"The act of navigating; the act of passing on water in ships or other vessels; the state of being navigable.","pos":""},{"def":"Ships in general.","pos":""}],"NAVIGATOR":[{"def":"One who navigates or sails; esp.","pos":""}],"NAVIGEROUS":[{"def":"Bearing ships; capable of floating vessels.","pos":""}],"NAVVY":[{"def":"Originally, a laborer on canals for internal navigation; hence, a laborer on other public works, as in building railroads, embankments, etc.","pos":""}],"NAVY":[{"def":"A fleet of ships; an assemblage of merchantmen, or so many as sail in company.","pos":""},{"def":"The whole of the war vessels belonging to a nation or ruler, considered collectively; as, the navy of Italy.","pos":""}]}