{"UNSTABLE":[{"def":"Not stable; not firm, fixed, or constant; subject to change or overthrow.","pos":""}],"UNSTACK":[{"def":"To remove, or take away, from a stack; to remove, as something constituting a stack.","pos":""}],"UNSTARCH":[{"def":"To free from starch; to make limp or pliable.","pos":""}],"UNSTATE":[{"def":"To deprive of state or dignity.","pos":""}],"UNSTEEL":[{"def":"To disarm; to soften.","pos":""}],"UNSTEP":[{"def":"To remove, as a mast, from its step.","pos":""}],"UNSTICK":[{"def":"To release, as one thing stuck to another.","pos":""}],"UNSTILL":[{"def":"Not still; restless.","pos":""}],"UNSTING":[{"def":"To disarm of a sting; to remove the sting of.","pos":""}],"UNSTITCH":[{"def":"To open by picking out stitches; to take out, or undo, the stitches of; as, to unstitch a seam.","pos":""}],"UNSTOCK":[{"def":"To deprive of a stock; to remove the stock from; to loose from that which fixes, or holds fast.","pos":""},{"def":"To remove from the stocks, as a ship.","pos":""}],"UNSTOCKINGED":[{"def":"Destitute of stockings.","pos":""},{"def":"Deprived of stockings.","pos":""}],"UNSTOP":[{"def":"To take the stopple or stopper from; as, to unstop a bottle or a cask.","pos":""},{"def":"To free from any obstruction; to open.","pos":""}],"UNSTRAIN":[{"def":"To relieve from a strain; to relax.","pos":""}],"UNSTRAINED":[{"def":"Not strained; not cleared or purified by straining; as, unstrained oil or milk.","pos":""},{"def":"Not forced; easy; natural; as, a unstrained deduction or inference.","pos":""}],"UNSTRATIFIED":[{"def":"Not stratified; -- applied to massive rocks, as granite, porphyry, etc.","pos":""}],"UNSTRENGTH":[{"def":"Want of strength; weakness; feebleness.","pos":""}],"UNSTRIATED":[{"def":"Nonstriated; unstriped.","pos":""}],"UNSTRING":[{"def":"Used also figuratively; as, his nerves were unstrung by fear.","pos":""}],"UNSTRIPED":[{"def":"Without marks or striations; nonstriated; as, unstriped muscle fibers.","pos":""}],"UNSTUDIED":[{"def":"Not studied; not acquired by study; unlabored; natural.","pos":""},{"def":"Not skilled; unversed; -- followed by in.","pos":""}]}