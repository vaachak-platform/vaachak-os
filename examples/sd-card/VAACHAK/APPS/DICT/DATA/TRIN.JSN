{"TRINAL":[{"def":"In their trinal triplicities on high.","pos":""}],"TRINE":[{"def":"Threefold; triple; as, trine dimensions, or length, breadth, and thickness.","pos":""}],"TRINERVATE":[{"def":"Having three ribs or nerves extending unbranched from the base to the apex; -- said of a leaf.","pos":""},{"def":"Same as Trinervate.","pos":""}],"TRINGA":[{"def":"A genus of limicoline birds including many species of sandpipers.","pos":""}],"TRINGLE":[{"def":"A curtain rod for a bedstead.","pos":""}],"TRINGOID":[{"def":"Of or pertaining to Tringa, or the Sandpiper family.","pos":""}],"TRINITARIAN":[{"def":"Of or pertaining to the Trinity, the doctrine of the Trinity, or believers in that doctrine.","pos":""}],"TRINITARIANISM":[{"def":"The doctrine of the Trinity; the doctrine that there are three distinct persons in the Godhead.","pos":""}],"TRINITROCELLULOSE":[{"def":"Gun cotton; -- so called because regarded as containing three nitro groups.","pos":""}],"TRINITROPHENOL":[{"def":"Tri*ni`tro*phe\"nol, n.","pos":""}],"TRINITY":[{"def":"The union of three persons (the Father, the Son, and the Holy Ghost) in one Godhead, so that all the three are one God as to substance, but three persons as to individuality.","pos":""}],"TRINIUNITY":[{"def":"Triunity; trinity.","pos":""}],"TRINK":[{"def":"A kind of fishing net.","pos":""}],"TRINKET":[{"def":"A three-cornered sail formerly carried on a ship's foremast, probably on a lateen yard.","pos":""}],"TRINKETER":[{"def":"One who trinkets.","pos":""}],"TRINKETRY":[{"def":"Ornaments of dress; trinkets, collectively.","pos":""}],"TRINKLE":[{"def":"To act secretly, or in an underhand way; to tamper.","pos":""}],"TRINOCTIAL":[{"def":"Lasting during three nights; comprising three nights.","pos":""}],"TRINODAL":[{"def":"Having three knots or nodes; having three points from which a leaf may shoot; as, a trinodal stem.","pos":""},{"def":"Having three nodal points.","pos":""}],"TRINOMIAL":[{"def":"A quantity consisting of three terms, connected by the sign + or -; as, x + y + z, or ax + 2b - c2.","pos":""}],"TRINUCLEUS":[{"def":"A genus of Lower Silurian trilobites in which the glabella and cheeks form three rounded elevations on the head.","pos":""}]}