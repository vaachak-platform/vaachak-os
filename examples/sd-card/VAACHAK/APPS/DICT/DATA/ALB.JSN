{"ALB":[{"def":"A vestment of white linen, reaching to the feet, an enveloping the person; -- in the Roman Catholic church, worn by those in holy orders when officiating at mass.","pos":""}],"ALB SUNDAY":[{"def":"The first Sunday after Easter Sunday, properly Albless Sunday, because in the early church those who had been baptized on Easter eve laid aside on the following Saturday their white albs which had been put on after baptism.","pos":""}],"ALBAN":[{"def":"A white crystalline resinous substance extracted from gutta- percha by the action of alcohol or ether.","pos":""}],"ALBANIAN":[{"def":"Of or pertaining to Albania, a province of Turkey.","pos":""},{"def":"A native of Albania.","pos":""}],"ALBATA":[{"def":"A white metallic alloy; which is made into spoons, forks, teapots, etc.","pos":""}],"ALBATROSS":[{"def":"A web-footed bird, of the genus Diomedea, of which there are several species.","pos":""},{"def":"Although; albeit.","pos":""}],"ALBEIT":[{"def":"Even though; although; notwithstanding.","pos":""}],"ALBERT WARE":[{"def":"A soft ornamental terra-cotta pottery, sold in the biscuit state for decorating.","pos":""}],"ALBERTITE":[{"def":"A bituminous mineral resembling asphaltum, found in the county of A.","pos":""}],"ALBERTYPE":[{"def":"A picture printed from a kind of gelatine plate produced by means of a photographic negative.","pos":""}],"ALBESCENCE":[{"def":"The act of becoming white; whitishness.","pos":""}],"ALBESCENT":[{"def":"Becoming white or whitish; moderately white.","pos":""}],"ALBICANT":[{"def":"Growing or becoming white.","pos":""}],"ALBICATION":[{"def":"The process of becoming white, or developing white patches, or streaks.","pos":""}],"ALBICORE":[{"def":"A name applied to several large fishes of the Mackerel family, esp.","pos":""}],"ALBIFICATION":[{"def":"The act or process of making white.","pos":""},{"def":"A sect of reformers opposed to the church of Rome in the 12th centuries.","pos":""}],"ALBIGENSIAN":[{"def":"Of or pertaining to the Albigenses.","pos":""}],"ALBINESS":[{"def":"A female albino.","pos":""}],"ALBINISM":[{"def":"The state or condition of being an albino: abinoism; leucopathy.","pos":""}],"ALBINISTIC":[{"def":"Affected with albinism.","pos":""}],"ALBINO":[{"def":"A person, whether negro, Indian, or white, in whom by some defect of organization the substance which gives color to the skin, hair, and eyes is deficient or in a morbid state.","pos":""}],"ALBINOISM":[{"def":"The state or condition of being an albino; albinism.","pos":""}],"ALBINOTIC":[{"def":"Affected with albinism.","pos":""}],"ALBION":[{"def":"An ancient name of England, still retained in poetry.","pos":""}],"ALBITE":[{"def":"A mineral of the feldspar family, triclinic in crystallization, and in composition a silicate of alumina and soda.","pos":""}],"ALBOLITH":[{"def":"A kind of plastic cement, or artificial stone, consisting chiefly of magnesia and silica; -- called also albolite.","pos":""}],"ALBORAK":[{"def":"The imaginary milk-white animal on which Mohammed was said to have been carried up to heaven; a white mule.","pos":""}],"ALBUGINEOUS":[{"def":"Of the nature of, or resembling, the white of the eye, or of an egg; albuminous; -- a term applied to textures, humors, etc.","pos":""}],"ALBUGO":[{"def":"Same as Leucoma.","pos":""}],"ALBUM":[{"def":"A white tablet on which anything was inscribed, as a list of names, etc.","pos":""}],"ALBUM GRAECUM":[{"def":"Dung of dogs or hyenas, which becomes white by exposure to air.","pos":""}],"ALBUMEN":[{"def":"Nourishing matter stored up within the integuments of the seed in many plants, but not incorporated in the embryo.","pos":""},{"def":"Same as Albumin.","pos":""}],"ALBUMENIZE":[{"def":"To cover or saturate with albumen; to coat or treat with an albuminous solution; as, to albuminize paper.","pos":""}],"ALBUMIN":[{"def":"A thick, viscous nitrogenous substance, which is the chief and characteristic constituent of white of eggs and of the serum of blood, and is found in other animal substances, both fluid and solid, also in many plants.","pos":""}],"ALBUMINATE":[{"def":"A substance produced by the action of an alkali upon albumin, and resembling casein in its properties; also, a compound formed by the union of albumin with another substance.","pos":""}],"ALBUMINIFEROUS":[{"def":"Supplying albumen.","pos":""}],"ALBUMINIMETER":[{"def":"An instrument for ascertaining the quantity of albumen in a liquid.","pos":""}],"ALBUMININ":[{"def":"The substance of the cells which inclose the white of birds' eggs.","pos":""}],"ALBUMINIPAROUS":[{"def":"Producing albumin.","pos":""}],"ALBUMINOID":[{"def":"Resembling albumin.","pos":""},{"def":"One of a class of organic principles (called also proteids) which form the main part of organized tissues.","pos":""}],"ALBUMINOIDAL":[{"def":"Of the nature of an albuminoid.","pos":""}],"ALBUMINOSE":[{"def":"A diffusible substance formed from albumin by the action of natural or artificial gastric juice.","pos":""}],"ALBUMINOSIS":[{"def":"A morbid condition due to excessive increase of albuminous elements in the blood.","pos":""},{"def":"Pertaining to, or containing, albumen; having the properties of, or resembling, albumen or albumin.","pos":""}],"ALBUMINURIA":[{"def":"A morbid condition in which albumin is present in the urine.","pos":""}],"ALBUMOSE":[{"def":"A compound or class of compounds formed from albumin by dilute acids or by an acid solution of pepsin.","pos":""}],"ALBURN":[{"def":"The bleak, a small European fish having scales of a peculiarly silvery color which are used in making artificial pearls.","pos":""}],"ALBURNOUS":[{"def":"Of or pertaining to alburnum; of the alburnum; as, alburnous substances.","pos":""}],"ALBURNUM":[{"def":"The white and softer part of wood, between the inner bark and the hard wood or duramen; sapwood.","pos":""}]}