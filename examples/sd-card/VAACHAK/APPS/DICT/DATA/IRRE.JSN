{"IRREBUTTABLE":[{"def":"Incapable of being rebutted.","pos":""}],"IRRECEPTIVE":[{"def":"Not receiving; incapable of receiving.","pos":""}],"IRRECLAIMABLE":[{"def":"Incapable of being reclaimed.","pos":""}],"IRRECOGNITION":[{"def":"A failure to recognize; absence of recognition.","pos":""}],"IRRECOGNIZABLE":[{"def":"Not recognizable.","pos":""}],"IRRECONCILABILITY":[{"def":"The quality or state of being irreconcilable; irreconcilableness.","pos":""}],"IRRECONCILABLE":[{"def":"Not reconcilable; implacable; incompatible; inconsistent; disagreeing; as, irreconcilable enemies, statements.","pos":""}],"IRRECONCILE":[{"def":"To prevent from being reconciled; to alienate or disaffect.","pos":""}],"IRRECONCILEMENT":[{"def":"The state or quality of being unreconciled; disagreement.","pos":""}],"IRRECONCILIATION":[{"def":"Want of reconciliation; disagreement.","pos":""}],"IRRECORDABLE":[{"def":"Not fit or possible to be recorded.","pos":""}],"IRRECOVERABLE":[{"def":"Not capable of being recovered, regained, or remedied; irreparable; as, an irrecoverable loss, debt, or injury.","pos":""}],"IRRECUPERABLE":[{"def":"Ir`re*cu\"per*a*ble, a.","pos":""}],"IRRECUSABLE":[{"def":"Not liable to exception or rejection.","pos":""}],"IRREDEEMABILITY":[{"def":"The state or quality of being irredeemable; irredeemableness.","pos":""}],"IRREDEEMABLE":[{"def":"Not redeemable; that can not be redeemed; not payable in gold or silver, as a bond; -- used especially of such government notes, issued as currency, as are not convertible into coin at the pleasure of the holder.","pos":""}],"IRREDUCIBILITY":[{"def":"The state or quality of being irreducible.","pos":""}],"IRREDUCIBLE":[{"def":"Incapable of being reduced to a simpler form of expression; as, an irreducible formula.","pos":""}],"IRREFLECTION":[{"def":"Want of reflection.","pos":""}],"IRREFORMABLE":[{"def":"Incapable of being reformed; incorrigible.","pos":""}],"IRREFRAGABILITY":[{"def":"The quality or state of being irrefragable; incapability of being refuted.","pos":""}],"IRREFRAGABLE":[{"def":"Not refragable; not to be gainsaid or denied; not to be refuted or overthrown; unanswerable; incontestable; undeniable; as, an irrefragable argument; irrefragable evidence.","pos":""}],"IRREFRANGIBILITY":[{"def":"The quality or state of being irrefrangible; irrefrangibleness.","pos":""}],"IRREFRANGIBLE":[{"def":"Not refrangible; that can not be refracted in passing from one medium to another.","pos":""}],"IRREFUTABLE":[{"def":"Incapable of being refuted or disproved; indisputable.","pos":""}],"IRREGENERATION":[{"def":"An unregenerate state.","pos":""}],"IRREGULAR":[{"def":"Mazes intricate, Eccentric, intervolved, yet regular Then most when most irregular they seem.","pos":""}],"IRREGULARIST":[{"def":"One who is irregular.","pos":""}],"IRREGULARITY":[{"def":"The state or quality of being irregular; that which is irregular.","pos":""}],"IRREGULARLY":[{"def":"In an irregular manner.","pos":""}],"IRREGULATE":[{"def":"To make irregular; to disorder.","pos":""}],"IRREJECTABLE":[{"def":"That can not be rejected; irresistible.","pos":""}],"IRRELAPSABLE":[{"def":"Not liable to relapse; secure.","pos":""}],"IRRELATION":[{"def":"The quality or state of being irrelative; want of connection or relation.","pos":""}],"IRRELATIVE":[{"def":"Not relative; without mutual relations; unconnected.","pos":""}],"IRRELAVANCY":[{"def":"The quality or state of being irrelevant; as, the irrelevancy of an argument.","pos":""}],"IRRELAVANT":[{"def":"Not relevant; not applicable or pertinent; not bearing upon or serving to support; foreign; extraneous; as, testimony or arguments irrelevant to a case.","pos":""}],"IRRELIEVABLE":[{"def":"Not admitting relief; incurable; hopeless.","pos":""}],"IRRELIGION":[{"def":"The state of being irreligious; want of religion; impiety.","pos":""}],"IRRELIGIONIST":[{"def":"One who is irreligious.","pos":""}],"IRRELIGIOUS":[{"def":"Destitute of religion; not controlled by religious motives or principles; ungodly.","pos":""},{"def":"Indicating a want of religion; profane; wicked; as, irreligious speech.","pos":""}],"IRRELIGIOUSLY":[{"def":"In an irreligious manner.","pos":""}],"IRRELIGIOUSNESS":[{"def":"The state or quality of being irreligious; ungodliness.","pos":""}],"IRREMEABLE":[{"def":"Admitting no return; as, an irremeable way.","pos":""}],"IRREMEDIABLE":[{"def":"Not to be remedied, corrected, or redressed; incurable; as, an irremediable disease or evil.","pos":""}],"IRREMEDIABLENESS":[{"def":"The state or quality of being irremediable.","pos":""}],"IRREMEDIABLY":[{"def":"In a manner, or to a degree, that precludes remedy, cure, or correction.","pos":""}],"IRREMISSIBLE":[{"def":"Not remissible; unpardonable; as, irremissible crimes.","pos":""}],"IRREMISSION":[{"def":"Refusal of pardon.","pos":""}],"IRREMISSIVE":[{"def":"Not remitting; unforgiving.","pos":""}],"IRREMITTABLE":[{"def":"Not capable of being remitted; irremissible.","pos":""}],"IRREMOVABILITY":[{"def":"The quality or state of being irremovable; immovableness.","pos":""}],"IRREMOVABLE":[{"def":"Not removable; immovable; inflexible.","pos":""}],"IRREMOVAL":[{"def":"Absence of removal.","pos":""}],"IRREMUNERABLE":[{"def":"Not remunerable; not capable of remuneration.","pos":""}],"IRREPARABILITY":[{"def":"The quality or state of being irreparable; irreparableness.","pos":""}],"IRREPARABLE":[{"def":"Not reparable; not capable of being repaired, recovered, regained, or remedied; irretrievable; irremediable; as, an irreparable breach; an irreparable loss.","pos":""}],"IRREPARABLENESS":[{"def":"Quality of being irreparable.","pos":""}],"IRREPARABLY":[{"def":"In an irreparable manner.","pos":""}],"IRREPEALABILITY":[{"def":"The quality or state of being irrepealable.","pos":""}],"IRREPEALABLE":[{"def":"Not repealable; not capable of being repealed or revoked, as a law.","pos":""}],"IRREPENTANCE":[{"def":"Want of repentance; impenitence.","pos":""},{"def":"Not capable of being replevied.","pos":""}],"IRREPREHENSIBLE":[{"def":"Not reprehensible; blameless; innocent.","pos":""}],"IRREPRESENTABLE":[{"def":"Not capable of being represented or portrayed.","pos":""}],"IRREPRESSIBLE":[{"def":"Not capable of being repressed, restrained, or controlled; as, irrepressible joy; an irrepressible conflict.","pos":""}],"IRREPRESSIBLY":[{"def":"In a manner or to a degree that can not be repressed.","pos":""}],"IRREPROACHABLE":[{"def":"Not reproachable; above reproach; not deserving reproach; blameless.","pos":""}],"IRREPROACHABLENESS":[{"def":"The quality or state of being irreproachable; integrity; innocence.","pos":""}],"IRREPROACHABLY":[{"def":"In an irreproachable manner; blamelessly.","pos":""}],"IRREPROVABLE":[{"def":"Incapable of being justly reproved; irreproachable; blameless; upright.","pos":""}],"IRREPTITIOUS":[{"def":"Surreptitious; spurious.","pos":""}],"IRRESILIENT":[{"def":"Not resilient; not recoiling or rebounding; inelastic.","pos":""}],"IRRESISTANCE":[{"def":"Nonresistance; passive submission.","pos":""}],"IRRESISTIBILITY":[{"def":"The quality or state of being irrestible, irresistibleness.","pos":""}],"IRRESISTIBLE":[{"def":"That can not be successfully resisted or opposed; superior to opposition; resistless; overpowering; as, an irresistible attraction.","pos":""}],"IRRESISTIBLENESS":[{"def":"Quality of being irrestible.","pos":""}],"IRRESISTIBLY":[{"def":"In an irrestible manner.","pos":""}],"IRRESOLUBLE":[{"def":"Incapable of being dissolved or resolved into parts; insoluble.","pos":""},{"def":"Incapable of being relieved or assisted.","pos":""}],"IRRESOLUBLENESS":[{"def":"The state or quality of being irresoluble; insolubility.","pos":""}],"IRRESOLUTE":[{"def":"Not resolute; not decided or determined; wavering; given to doubt or irresolution.","pos":""}],"IRRESOLUTION":[{"def":"Want of resolution; want of decision in purpose; a fluctuation of mind, as in doubt, or between hope and fear; irresoluteness; indecision; vacillation.","pos":""}],"IRRESOLVABILITY":[{"def":"The quality of being irresolvable; irresolvableness.","pos":""}],"IRRESOLVABLE":[{"def":"Incapable of being resolved; not separable into component parts.","pos":""}],"IRRESOLVABLENESS":[{"def":"The quality or state of being irresolvable; irresolvability.","pos":""}],"IRRESOLVEDLY":[{"def":"Without settled determination; in a hesitating manner; doubtfully.","pos":""}],"IRRESPECTIVE":[{"def":"Without regard for conditions, circumstances, or consequences; unbiased; independent; impartial; as, an irrespective judgment.","pos":""}],"IRRESPECTIVELY":[{"def":"Without regard to conditions; not making circumstances into consideration.","pos":""}],"IRRESPIRABLE":[{"def":"Unfit for respiration; not having the qualities necessary to support animal life; as, irrespirable air.","pos":""}],"IRRESPONSIBILITY":[{"def":"Want of, or freedom from, responsibility or accountability.","pos":""}],"IRRESPONSIBLE":[{"def":"Nor responsible; not liable or able to answer fro consequences; innocent.","pos":""},{"def":"Not to be trusted; unreliable.","pos":""}],"IRRESPONSIBLY":[{"def":"So as not to be responsible.","pos":""}],"IRRESPONSIVE":[{"def":"Not responsive; not able, ready, or inclined to respond.","pos":""}],"IRRESUSCITABLE":[{"def":"Incapable of being resuscitated or revived.","pos":""}],"IRRETENTION":[{"def":"Want of retaining power; forgetfulness.","pos":""}],"IRRETENTIVE":[{"def":"Not retentive; as, an irretentive memory.","pos":""}],"IRRETRACEABLE":[{"def":"Incapable of being retraced; not retraceable.","pos":""}],"IRRETRACTILE":[{"def":"Not tractile or ductile.","pos":""}],"IRRETRIEVABLE":[{"def":"Not retrievable; irrecoverable; irreparable; as, an irretrievable loss.","pos":""}],"IRRETRIEVABLENESS":[{"def":"The state or quality of being irretrievable.","pos":""}],"IRRETRIEVABLY":[{"def":"In an irretrievable manner.","pos":""}],"IRRETURNABLE":[{"def":"Not to be returned.","pos":""}],"IRREVEALABLE":[{"def":"Incapable of being revealed.","pos":""}],"IRREVERENCE":[{"def":"The state or quality of being irreverent; want of proper reverence; disregard of the authority and character of a superior.","pos":""}],"IRREVEREND":[{"def":"Immodest speech, or irreverend gesture.","pos":""}],"IRREVERENT":[{"def":"Not reverent; showing a want of reverence; expressive of a want of veneration; as, an irreverent babbler; an irreverent jest.","pos":""}],"IRREVERENTLY":[{"def":"In an irreverent manner.","pos":""}],"IRREVERSIBILITY":[{"def":"The state or quality of being irreversible; irreversibleness.","pos":""}],"IRREVERSIBLE":[{"def":"Incapable of being reversed or turned about or back; incapable of being made to run backward; as, an irreversible engine.","pos":""},{"def":"Incapable of being reversed, recalled, repealed, or annulled; as, an irreversible sentence or decree.","pos":""}],"IRREVERSIBLE STEERING GEAR":[{"def":"A steering gear, esp.","pos":""}],"IRREVERSIBLENESS":[{"def":"The state or quality of being irreversible.","pos":""}],"IRREVERSIBLY":[{"def":"In an irreversible manner.","pos":""}],"IRREVOCABILITY":[{"def":"The state or quality of being irrevocable; irrevocableness.","pos":""}],"IRREVOCABLE":[{"def":"Incapable of being recalled or revoked; unchangeable; irreversible; unalterable; as, an irrevocable promise or decree; irrevocable fate.","pos":""}],"IRREVOLUBLE":[{"def":"That has no finite period of revolution; not revolving.","pos":""}]}