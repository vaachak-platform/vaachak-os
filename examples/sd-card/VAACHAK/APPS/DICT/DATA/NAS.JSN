{"NASAL":[{"def":"Of or pertaining to the nose.","pos":""}],"NASALITY":[{"def":"The quality or state of being nasal.","pos":""}],"NASALIZATION":[{"def":"The act of nasalizing, or the state of being nasalized.","pos":""}],"NASALIZE":[{"def":"To render nasal, as sound; to insert a nasal or sound in.","pos":""}],"NASALLY":[{"def":"In a nasal manner; by the nose.","pos":""}],"NASCAL":[{"def":"A kind of pessary of medicated wool or cotton, formerly used.","pos":""}],"NASCENCY":[{"def":"State of being nascent; birth; beginning; origin.","pos":""}],"NASCENT":[{"def":"Evolving; being evolved or produced.","pos":""}],"NASEBERRY":[{"def":"A tropical fruit.","pos":""}],"NASH":[{"def":"Firm; stiff; hard; also, chilly.","pos":""}],"NASICORNOUS":[{"def":"Bearing a horn, or horns, on the nose, as the rhinoceros.","pos":""}],"NASIFORM":[{"def":"Having the shape of a nose.","pos":""}],"NASION":[{"def":"The middle point of the nasofrontal suture.","pos":""}],"NASO-":[{"def":"A combining form denoting pertaining to, or connected with, the nose; as, nasofrontal.","pos":""}],"NASOBUCCAL":[{"def":"Connected with both the nose and the mouth; as, the nasobuccal groove in the skate.","pos":""}],"NASOFRONTAL":[{"def":"of or pertaining to the nose and the front of the head; as, the embryonic nasofrontal process which forms the anterior boundary of the mouth.","pos":""}],"NASOLACHRYMAL":[{"def":"Connected with the lachrymal apparatus and the nose; as, the nasolachrymal, or lachrymal duct.","pos":""},{"def":"Connected with both the nose and the palate; as, the nasopalatine or incisor, canal connecting the mouth and the nasal chamber in some animals; the nasopalatine nerve.","pos":""}],"NASOPHARYNGEAL":[{"def":"Of or pertaining to both throat and nose; as, a nasopharyngeal polypus.","pos":""}],"NASOSEPTAL":[{"def":"Of or pertaining to the internasal septum.","pos":""}],"NASOTURBINAL":[{"def":"Connected with, or near, both the turbinal and the nasal bones; as, the nasalturbinal bone, made up of the uppermost lammelæ of the ethmoturbinal, and sometimes united with the nasal.","pos":""},{"def":"The nasoturbinal bone.","pos":""}],"NASSA":[{"def":"Any species of marine gastropods, of the genera Nassa, Tritia, and other allied genera of the family Nassidæ; a dog whelk.","pos":""}],"NASTILY":[{"def":"In a nasty manner.","pos":""}],"NASTINESS":[{"def":"The quality or state of being nasty; extreme filthness; dirtiness; also, indecency; obscenity.","pos":""}],"NASTURTION":[{"def":"Same as Nasturtium.","pos":""}],"NASTURTIUM":[{"def":"A genus of cruciferous plants, having white or yellowish flowers, including several species of cress.","pos":""},{"def":"Any plant of the genus Tropæolum, geraniaceous herbs, having mostly climbing stems, peltate leaves, and spurred flowers, and including the common Indian cress (Tropæolum majus), the canary-bird flower (T.","pos":""}],"NASTY":[{"def":"Offensively filthy; very dirty, foul, or defiled; disgusting; nauseous.","pos":""},{"def":"Hence, loosely: Offensive; disagreeable; unpropitious; wet; drizzling; as, a nasty rain, day, sky.","pos":""}],"NASUTE":[{"def":"Having a nice sense of smell.","pos":""},{"def":"Critically nice; captious.","pos":""}],"NASUTNESS":[{"def":"Quickness of scent; hence, nice discernment; acuteness.","pos":""}]}