{"VACANCY":[{"def":"The quality or state of being vacant; emptiness; hence, freedom from employment; intermission; leisure; idleness; listlessness.","pos":""},{"def":"That which is vacant.","pos":""}],"VACANT":[{"def":"Abandoned; having no heir, possessor, claimant, or occupier; as, a vacant estate.","pos":""}],"VACANTLY":[{"def":"In a vacant manner; inanely.","pos":""}],"VACATE":[{"def":"To make vacant; to leave empty; to cease from filling or occupying; as, it was resolved by Parliament that James had vacated the throne of England; the tenant vacated the house.","pos":""},{"def":"To annul; to make void; to deprive of force; to make of no authority or validity; as, to vacate a commission or a charter; to vacate proceedings in a cause.","pos":""}],"VACATION":[{"def":"Intermission of judicial proceedings; the space of time between the end of one term and the beginning of the next; nonterm; recess.","pos":""}],"VACATUR":[{"def":"An order of court by which a proceeding is set aside or annulled.","pos":""}],"VACCARY":[{"def":"A cow house, dairy house, or cow pasture.","pos":""}],"VACCINAL":[{"def":"Of or pertaining to vaccinia or vaccination.","pos":""}],"VACCINATE":[{"def":"To inoculate with the cowpox by means of a virus, called vaccine, taken either directly or indirectly from cows.","pos":""}],"VACCINATION":[{"def":"The act, art, or practice of vaccinating, or inoculating with the cowpox, in order to prevent or mitigate an attack of smallpox.","pos":""}],"VACCINATOR":[{"def":"One who, or that which, vaccinates.","pos":""}],"VACCINE":[{"def":"Of or pertaining to cows; pertaining to, derived from, or caused by, vaccinia; as, vaccine virus; the vaccine disease.","pos":""},{"def":"The virus of vaccinia used in vaccination.","pos":""}],"VACCINIA":[{"def":"Cowpox; vaccina.","pos":""}],"VACCINIUM":[{"def":"A genus of ericaceous shrubs including the various kinds of blueberries and the true cranberries.","pos":""}],"VACHER":[{"def":"A keeper of stock or cattle; a herdsman.","pos":""}],"VACHERY":[{"def":"An inclosure for cows.","pos":""}],"VACHETTE CLASP":[{"def":"A piece of strong steel wire with the ends curved and pointed, used on toe or quarter cracks to bind the edges together and prevent motion.","pos":""}],"VACILLANCY":[{"def":"The quality or state of being vacillant, or wavering.","pos":""}],"VACILLANT":[{"def":"Vacillating; wavering; fluctuating; irresolute.","pos":""}],"VACILLATE":[{"def":"To move one way and the other; to reel or stagger; to waver.","pos":""},{"def":"To fluctuate in mind or opinion; to be unsteady or inconstant; to waver.","pos":""}],"VACILLATING":[{"def":"Inclined to fluctuate; wavering.","pos":""}],"VACILLATION":[{"def":"The act of vacillating; a moving one way and the other; a wavering.","pos":""}],"VACILLATORY":[{"def":"Inclined to vacillate; wavering; irresolute.","pos":""}],"VACUATE":[{"def":"To make void, or empty.","pos":""}],"VACUATION":[{"def":"The act of emptying; evacuation.","pos":""}],"VACUIST":[{"def":"One who holds the doctrine that the space between the bodies of the universe, or the molecules and atoms of matter.","pos":""}],"VACUITY":[{"def":"The quality or state of being vacuous, or not filled; emptiness; vacancy; as, vacuity of mind; vacuity of countenance.","pos":""},{"def":"Space unfilled or unoccupied, or occupied with an invisible fluid only; emptiness; void; vacuum.","pos":""}],"VACUNA":[{"def":"The goddess of rural leisure, to whom the husbandmen sacrificed at the close of the harvest.","pos":""}],"VACUOLATED":[{"def":"Full of vacuoles, or small air cavities; as, vacuolated cells.","pos":""}],"VACUOLATION":[{"def":"Formation into, or multiplication of, vacuoles.","pos":""}],"VACUOLE":[{"def":"A small air cell, or globular space, in the interior of organic cells, either containing air, or a pellucid watery liquid, or some special chemical secretions of the cell protoplasm.","pos":""}],"VACUOUS":[{"def":"Empty; unfilled; void; vacant.","pos":""}],"VACUOUSNESS":[{"def":"The quality or state of being vacuous; emptiness; vacuity.","pos":""}],"VACUUM":[{"def":"The condition of rarefaction, or reduction of pressure below that of the atmosphere, in a vessel, as the condenser of a steam engine, which is nearly exhausted of air or steam, etc.","pos":""}],"VACUUM CLEANER":[{"def":"A machine for cleaning carpets, tapestry, upholstered work, etc.","pos":""}]}