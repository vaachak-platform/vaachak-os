{"SPIRABLE":[{"def":"Capable of being breathed; respirable.","pos":""}],"SPIRACLE":[{"def":"The nostril, or one of the nostrils, of whales, porpoises, and allied animals.","pos":"noun"}],"SPIRACULAR":[{"def":"Of or pertaining to a spiracle.","pos":""}],"SPIRAEA":[{"def":"A genus of shrubs or perennial herbs including the meadowsweet and the hardhack.","pos":""}],"SPIRAEIC":[{"def":"Of, pertaining to, or derived from, the meadowsweet (Spiræa); formerly, designating an acid which is now called salicylic acid.","pos":""}],"SPIRAL":[{"def":"Of or pertaining to a spiral; like a spiral.","pos":""}],"SPIRALITY":[{"def":"The quality or states of being spiral.","pos":""}],"SPIRALLY":[{"def":"In a spiral form, manner, or direction.","pos":""}],"SPIRALOZOOID":[{"def":"One of the special defensive zooids of certain hydroids.","pos":""}],"SPIRANTHY":[{"def":"The occasional twisted growth of the parts of a flower.","pos":""}],"SPIRATION":[{"def":"The act of breathing.","pos":""}],"SPIRE":[{"def":"A tube or fuse for communicating fire to the chargen in blasting.","pos":""}],"SPIRED":[{"def":"Having a spire; being in the form of a spire; as, a spired steeple.","pos":""}],"SPIRICLE":[{"def":"One of certain minute coiled threads in the coating of some seeds.","pos":""}],"SPIRIFER":[{"def":"Any one of numerous species of fossil brachipods of the genus Spirifer, or Delthyris, and allied genera, in which the long calcareous supports of the arms form a large spiral, or helix, on each side.","pos":""}],"SPIRILLUM":[{"def":"A genus of common motile microörganisms (Spirobacteria) having the form of spiral-shaped filaments.","pos":""}],"SPIRING":[{"def":"Shooting up in a spire or spires.","pos":""}],"SPIRIT":[{"def":"Rum, whisky, brandy, gin, and other distilled liquors having much alcohol, in distinction from wine and malt liquors.","pos":""},{"def":"A solution in alcohol of a volatile principle.","pos":""}],"SPIRITALLY":[{"def":"By means of the breath.","pos":"adverb"}],"SPIRITED":[{"def":"Animated or possessed by a spirit.","pos":""},{"def":"Animated; full of life or vigor; lively; full of spirit or fire; as, a spirited oration; a spirited answer.","pos":""}],"SPIRITFUL":[{"def":"Full of spirit; spirited.","pos":""}],"SPIRITLESS":[{"def":"Destitute of spirit; wanting animation; wanting cheerfulness; dejected; depressed.","pos":""},{"def":"Destitute of vigor; wanting life, courage, or fire.","pos":""}],"SPIRITOSO":[{"def":"Spirited; spiritedly; -- a direction to perform a passage in an animated, lively manner.","pos":""}],"SPIRITOUS":[{"def":"Like spirit; refined; defecated; pure.","pos":""}],"SPIRITOUSNESS":[{"def":"Quality of being spiritous.","pos":""}],"SPIRITUAL":[{"def":"Consisting of spirit; not material; incorporeal; as, a spiritual substance or being.","pos":""},{"def":"Of or pertaining to the intellectual and higher endowments of the mind; mental; intellectual.","pos":""}],"SPIRITUAL-MINDED":[{"def":"Having the mind set on spiritual things, or filled with holy desires and affections.","pos":""}],"SPIRITUALISM":[{"def":"The doctrine, in opposition to the materialists, that all which exists is spirit, or soul -- that what is called the external world is either a succession of notions impressed on the mind by the Deity, as maintained by Berkeley, or else the mere educt of the mind itself, as taught by Fichte.","pos":""}],"SPIRITUALIST":[{"def":"One who professes a regard for spiritual things only; one whose employment is of a spiritual character; an ecclesiastic.","pos":""},{"def":"One who maintains the doctrine of spiritualism.","pos":""}],"SPIRITUALISTIC":[{"def":"Relating to, or connected with, spiritualism.","pos":""}],"SPIRITUALITY":[{"def":"That which belongs to the church, or to a person as an ecclesiastic, or to religion, as distinct from temporalities.","pos":""}],"SPIRITUALIZATION":[{"def":"The act of spiritualizing, or the state of being spiritualized.","pos":""}],"SPIRITUALIZE":[{"def":"To extract spirit from; also, to convert into, or impregnate with, spirit.","pos":""}],"SPIRITUALIZER":[{"def":"One who spiritualizes.","pos":""}],"SPIRITUALLY":[{"def":"In a spiritual manner; with purity of spirit; like a spirit.","pos":""}],"SPIRITUALNESS":[{"def":"The quality or state of being spiritual or spiritual-minded; spirituality.","pos":""}],"SPIRITUALTY":[{"def":"An ecclesiastical body; a spirituality.","pos":""}],"SPIRITUELLE":[{"def":"Of the nature, or having the appearance, of a spirit; pure; refined; ethereal.","pos":""}],"SPIRITUOSITY":[{"def":"The quality or state of being spirituous; spirituousness.","pos":""}],"SPIRITUOUS":[{"def":"Having the quality of spirit; tenuous in substance, and having active powers or properties; ethereal; immaterial; spiritual; pure.","pos":""},{"def":"Containing, or of the nature of, alcoholic (esp.","pos":""}],"SPIRITUOUSNESS":[{"def":"The quality or state of being spirituous.","pos":""}],"SPIRKETING":[{"def":"The planking from the waterways up to the port sills.","pos":""}],"SPIROBACTERIA":[{"def":"See the Note under Microbacteria.","pos":""},{"def":"A genus of Spirobacteria similar to Spirillum, but distinguished by its motility.","pos":""}],"SPIROGRAPH":[{"def":"An instrument for recording the respiratory movements, as the sphygmograph does those of the pulse.","pos":""}],"SPIROMETER":[{"def":"An instrument for measuring the vital capacity of the lungs, or the volume of air which can be expelled from the chest after the deepest possible inspiration.","pos":""}],"SPIROMETRY":[{"def":"The act or process of measuring the chest capacity by means of a spirometer.","pos":""}],"SPIROSCOPE":[{"def":"A wet meter used to determine the breathing capacity of the lungs.","pos":""},{"def":"Pertaining to, or designating, a substance now called salicylal.","pos":""}],"SPIRTLE":[{"def":"To spirt in a scattering manner.","pos":""}],"SPIRULA":[{"def":"A genus of cephalopods having a multilocular, internal, siphunculated shell in the form of a flat spiral, the coils of which are not in contact.","pos":""}],"SPIRULATE":[{"def":"Having the color spots, or structural parts, arranged spirally.","pos":""}],"SPIRY":[{"def":"Of a spiral form; wreathed; curled; serpentine.","pos":""}]}