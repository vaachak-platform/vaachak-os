{"OPHELIC":[{"def":"Of, pertaining to, or designating, a substance (called ophelic acid) extracted from a plant (Ophelia) of the Gentian family as a bitter yellowish sirup, used in India as a febrifuge and tonic.","pos":""}],"OPHICLEIDE":[{"def":"A large brass wind instrument, formerly used in the orchestra and in military bands, having a loud tone, deep pitch, and a compass of three octaves; -- now generally supplanted by bass and contrabass tubas.","pos":""}],"OPHIDIA":[{"def":"The order of reptiles which includes the serpents.","pos":""}],"OPHIDIAN":[{"def":"One of the Ophidia; a snake or serpent.","pos":""}],"OPHIDIOID":[{"def":"Of or pertaining to the Ophidiidæ, a family of fishes which includes many slender species.","pos":""},{"def":"One of the Ophidiidæ.","pos":""}],"OPHIDION":[{"def":"The typical genus of ophidioid fishes.","pos":""}],"OPHIOLATRY":[{"def":"The worship of serpents.","pos":""},{"def":"Of or pertaining to ophiology.","pos":""}],"OPHIOLOGIST":[{"def":"One versed in the natural history of serpents.","pos":""}],"OPHIOLOGY":[{"def":"That part of natural history which treats of the ophidians, or serpents.","pos":""}],"OPHIOMANCY":[{"def":"Divination by serpents, as by their manner of eating, or by their coils.","pos":""}],"OPHIOMORPHA":[{"def":"An order of tailless amphibians having a slender, wormlike body with regular annulations, and usually with minute scales imbedded in the skin.","pos":""}],"OPHIOMORPHOUS":[{"def":"Having the form of a serpent.","pos":""}],"OPHIOPHAGOUS":[{"def":"Feeding on serpents; -- said of certain birds and reptiles.","pos":""}],"OPHIOPHAGUS":[{"def":"A genus of venomous East Indian snakes, which feed on other snakes.","pos":""}],"OPHISM":[{"def":"Doctrines and rites of the Ophites.","pos":""},{"def":"Serpent worship or the use of serpents as magical agencies.","pos":""}],"OPHITE":[{"def":"Of or pertaining to a serpent.","pos":""}],"OPHIUCHUS":[{"def":"A constellation in the Northern Hemisphere, delineated as a man holding a serpent in his hands; -- called also Serpentarius.","pos":""}],"OPHIURA":[{"def":"A genus of ophiurioid starfishes.","pos":""}],"OPHIURAN":[{"def":"Of or pertaining to the Ophiurioidea.","pos":""},{"def":"One of the Ophiurioidea.","pos":""}],"OPHIURID":[{"def":"Same as Ophiurioid.","pos":""}],"OPHIURIDA":[{"def":"Same as Ophiurioidea.","pos":""}],"OPHIURIOID":[{"def":"Of or pertaining to the Ophiurioidea.","pos":""},{"def":"One of the Ophiurioidea.","pos":""}],"OPHRYON":[{"def":"The supraorbital point.","pos":""}],"OPHTHALMIA":[{"def":"An inflammation of the membranes or coats of the eye or of the eyeball.","pos":""}],"OPHTHALMIC":[{"def":"Of, pertaining to, or in the region of, the eye; ocular; as the ophthalmic, or orbitonasal, nerve, a division of the trigeminal, which gives branches to the lachrymal gland, eyelids, nose, and forehead.","pos":""}],"OPHTHALMITE":[{"def":"An eyestalk; the organ which bears the compound eyes of decapod Crustacea.","pos":""}],"OPHTHALMOLOGICAL":[{"def":"Of or pertaining to ophthalmology.","pos":""}],"OPHTHALMOLOGIST":[{"def":"One skilled in ophthalmology; an oculist.","pos":""}],"OPHTHALMOLOGY":[{"def":"The science which treats of the structure, functions, and diseases of the eye.","pos":""}],"OPHTHALMOMETER":[{"def":"An instrument devised by Helmholtz for measuring the size of a reflected image on the convex surface of the cornea and lens of the eye, by which their curvature can be ascertained.","pos":""}],"OPHTHALMOSCOPE":[{"def":"An instrument for viewing the interior of the eye, particularly the retina.","pos":""}],"OPHTHALMOSCOPY":[{"def":"A branch of physiognomy which deduces the knowledge of a person's temper and character from the appearance of the eyes.","pos":""},{"def":"Examination of the eye with the ophthalmoscope.","pos":""}],"OPHTHALMY":[{"def":"Same as Ophthalmia.","pos":""}]}