{"CEPACEOUS":[{"def":"Of the nature of an onion, as in odor; alliaceous.","pos":""}],"CEPEVOROUS":[{"def":"Feeding upon onions.","pos":""}],"CEPHALAD":[{"def":"Forwards; towards the head or anterior extremity of the body; opposed to caudad.","pos":""},{"def":"Pain in the head; headache.","pos":""}],"CEPHALALGIC":[{"def":"Relating to, or affected with, headache.","pos":""},{"def":"A remedy for the headache.","pos":""}],"CEPHALANTHIUM":[{"def":"Same as Anthodium.","pos":""}],"CEPHALASPIS":[{"def":"A genus of fossil ganoid fishes found in the old red sandstone or Devonian formation.","pos":""}],"CEPHALATA":[{"def":"A large division of Mollusca, including all except the bivalves; -- so called because the head is distinctly developed.","pos":""}],"CEPHALIC":[{"def":"Of or pertaining to the head.","pos":""}],"CEPHALISM":[{"def":"Form or development of the skull; as, the races of man differ greatly in cephalism.","pos":""}],"CEPHALITIS":[{"def":"Same as Phrenitis.","pos":""}],"CEPHALIZATION":[{"def":"Domination of the head in animal life as expressed in the physical structure; localization of important organs or parts in or near the head, in animal development.","pos":""},{"def":"A combining form denoting the head, of the head, connected with the head; as, cephalosome, cephalopod.","pos":""}],"CEPHALOCERCAL":[{"def":"Relating to the long axis of the body.","pos":""}],"CEPHALOID":[{"def":"Shaped like the head.","pos":""}],"CEPHALOLOGY":[{"def":"The science which treats of the head.","pos":""}],"CEPHALOMERE":[{"def":"One of the somites (arthromeres) which make up the head of arthropods.","pos":""}],"CEPHALOMETER":[{"def":"An instrument measuring the dimensions of the head of a fetus during delivery.","pos":""}],"CEPHALOMETRY":[{"def":"The measurement of the heads of living persons.","pos":""}],"CEPHALOPHORA":[{"def":"One of the Cephalopoda.","pos":""}],"CEPHALOPODA":[{"def":"The highest class of Mollusca.","pos":""},{"def":"Belonging to, or resembling, the cephalopods.","pos":""}],"CEPHALOPTERA":[{"def":"One of the generic names of the gigantic ray (Manta birostris), known as devilfish and sea devil.","pos":""}],"CEPHALOSOME":[{"def":"The anterior region or head of insects and other arthropods.","pos":""}],"CEPHALOSTYLE":[{"def":"The anterior end of the notochord and its bony sheath in the base of cartilaginous crania.","pos":""}],"CEPHALOTHORAX":[{"def":"The anterior portion of any one of the Arachnida and higher Crustacea, consisting of the united head and thorax.","pos":""}],"CEPHALOTOME":[{"def":"An instrument for cutting into the fetal head, to facilitate delivery.","pos":""}],"CEPHALOTOMY":[{"def":"Craniotomy; -- usually applied to bisection of the fetal head with a saw.","pos":""}],"CEPHALOTRIBE":[{"def":"An obstetrical instrument for performing cephalotripsy.","pos":""}],"CEPHALOTRIPSY":[{"def":"The act or operation of crushing the head of a fetus in the womb in order to effect delivery.","pos":""}],"CEPHALOTROCHA":[{"def":"A kind of annelid larva with a circle of cilia around the head.","pos":""}],"CEPHALOUS":[{"def":"Having a head; -- applied chiefly to the Cephalata, a division of mollusks.","pos":""}]}