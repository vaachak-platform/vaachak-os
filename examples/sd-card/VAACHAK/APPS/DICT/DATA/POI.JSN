{"POI":[{"def":"A national food of the Hawaiians, made by baking and pounding the kalo (or taro) root, and reducing it to a thin paste, which is allowed to ferment.","pos":""},{"def":"The frescoed porch or gallery in Athens where Zeno taught.","pos":""}],"POIGNANCY":[{"def":"The quality or state of being poignant; as, the poignancy of satire; the poignancy of grief.","pos":""}],"POIGNANT":[{"def":"Pricking; piercing; sharp; pungent.","pos":""}],"POIGNANTLY":[{"def":"In a poignant manner.","pos":""}],"POIKILOCYTE":[{"def":"An irregular form of corpuscle found in the blood in cases of profound anæmia, probably a degenerated red blood corpuscle.","pos":""},{"def":"Having a varying body temperature.","pos":""}],"POIKILOTHERMOUS":[{"def":"Poi`ki*lo*ther\"mous, a.","pos":""}],"POINCIANA":[{"def":"A prickly tropical shrub (Cæsalpinia, formerly Poinciana, pulcherrima), with bipinnate leaves, and racemes of showy orange-red flowers with long crimson filaments.","pos":""}],"POIND":[{"def":"To impound, as cattle.","pos":""}],"POINDER":[{"def":"The keeper of a cattle pound; a pinder.","pos":""},{"def":"One who distrains property.","pos":""}],"POINSETTIA":[{"def":"A Mexican shrub (Euphorbia pulcherrima) with very large and conspicuous vermilion bracts below the yellowish flowers.","pos":""}],"POINT":[{"def":"A dot or mark used to designate certain tones or time; as: (a) (Anc.","pos":""}],"POINT ALPHABET":[{"def":"An alphabet for the blind with a system of raised points corresponding to letters.","pos":""}],"POINT APPLIQUE":[{"def":"Lace having a needle-made design applied to a net ground, this ground often being machine-made.","pos":""}],"POINT D'APPUI":[{"def":"See under Appui.","pos":""},{"def":"Uncommonly nice and exact; precise; particular.","pos":""}],"POINT SWITCH":[{"def":"A switch made up of a rail from each track, both rails being tapered far back and connected to throw alongside the through rail of either track.","pos":""}],"POINT-BLANK":[{"def":"The white spot on a target, at which an arrow or other missile is aimed.","pos":""}],"POINTAL":[{"def":"The pistil of a plant.","pos":""}],"POINTED":[{"def":"Sharp; having a sharp point; as, a pointed rock.","pos":""},{"def":"Characterized by sharpness, directness, or pithiness of expression; terse; epigrammatic; especially, directed to a particular person or thing.","pos":""}],"POINTER":[{"def":"One who, or that which, points.","pos":""},{"def":"The two stars (Merak and Dubhe) in the Great Bear, the line between which points nearly in the direction of the north star.","pos":""}],"POINTING":[{"def":"The act or process of measuring, at the various distances from the surface of a block of marble, the surface of a future piece of statuary; also, a process used in cutting the statue from the artist's model.","pos":""}],"POINTINGSTOCK":[{"def":"An object of ridicule or scorn; a laughingstock.","pos":""}],"POINTLESS":[{"def":"Having no point; blunt; wanting keenness; obtuse; as, a pointless sword; a pointless remark.","pos":""}],"POINTLETED":[{"def":"Having a small, distinct point; apiculate.","pos":""}],"POINTSMAN":[{"def":"A man who has charge of railroad points or switches.","pos":""}],"POISE":[{"def":"Weight; gravity; that which causes a body to descend; heaviness.","pos":""},{"def":"The weight, or mass of metal, used in weighing, to balance the substance weighed.","pos":""}],"POISER":[{"def":"The balancer of dipterous insects.","pos":""}],"POISON":[{"def":"Any agent which, when introduced into the animal organism, is capable of producing a morbid, noxious, or deadly effect upon it; as, morphine is a deadly poison; the poison of pestilential diseases.","pos":""},{"def":"That which taints or destroys moral purity or health; as, the poison of evil example; the poison of sin.","pos":""}],"POISON CUP":[{"def":"A cup containing poison.","pos":""},{"def":"A cup that was supposed to break on having poison put into it.","pos":""}],"POISONABLE":[{"def":"Capable of poisoning; poisonous.","pos":""},{"def":"Capable of being poisoned.","pos":""}],"POISONER":[{"def":"One who poisons.","pos":""}],"POISONOUS":[{"def":"Having the qualities or effects of poison; venomous; baneful; corrupting; noxious.","pos":""}],"POITREL":[{"def":"The breastplate of the armor of a horse.","pos":""}]}