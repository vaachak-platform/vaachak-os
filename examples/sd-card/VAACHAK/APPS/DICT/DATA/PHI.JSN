{"PHIAL":[{"def":"A glass vessel or bottle, especially a small bottle for medicines; a vial.","pos":""}],"PHILADELPHIAN":[{"def":"Of or pertaining to Ptolemy Philadelphus, or to one of the cities named Philadelphia, esp.","pos":""}],"PHILALETHIST":[{"def":"A lover of the truth.","pos":""}],"PHILANDER":[{"def":"To make love to women; to play the male flirt.","pos":""}],"PHILANDERER":[{"def":"One who hangs about women; a male flirt.","pos":""}],"PHILANTHROPE":[{"def":"A philanthropist.","pos":""},{"def":"Of or pertaining to philanthropy; characterized by philanthropy; loving or helping mankind; as, a philanthropic enterprise.","pos":""}],"PHILANTHROPINISM":[{"def":"A system of education on so-called natural principles, attempted in Germany in the last century by Basedow, of Dessau.","pos":""}],"PHILANTHROPINIST":[{"def":"An advocate of, or believer in, philanthropinism.","pos":""}],"PHILANTHROPIST":[{"def":"One who practices philanthropy; one who loves mankind, and seeks to promote the good of others.","pos":""}],"PHILANTHROPISTIC":[{"def":"Pertaining to, or characteristic of, a philanthropist.","pos":""}],"PHILANTHROPY":[{"def":"Love to mankind; benevolence toward the whole human family; universal good will; desire and readiness to do good to all men; -- opposed to misanthropy.","pos":""}],"PHILATELIC":[{"def":"Of or pertaining to philately.","pos":""}],"PHILATELIST":[{"def":"One versed in philately; one who collects postage stamps.","pos":""}],"PHILATELY":[{"def":"The collection of postage stamps of various issues.","pos":""}],"PHILATHEA":[{"def":"An international, interdenominational organization of Bible classes of young women.","pos":""}],"PHILATORY":[{"def":"A kind of transparent reliquary with an ornamental top.","pos":""}],"PHILAUTY":[{"def":"Self-love; selfishness.","pos":""}],"PHILHARMONIC":[{"def":"Loving harmony or music.","pos":""}],"PHILHELLENE":[{"def":"A friend of Greece, or of the Greeks; a philhellenist.","pos":""}],"PHILHELLENIC":[{"def":"Of or pertaining to philhellenism.","pos":""}],"PHILHELLENIST":[{"def":"A friend of Greece; one who supports the cause of the Greeks; particularly, one who supported them in their struggle for independence against the Turks; a philhellene.","pos":""}],"PHILIPPIAN":[{"def":"Of or pertaining to Philippi, a city of ancient Macedonia.","pos":""},{"def":"A native or an inhabitant of Philippi.","pos":""}],"PHILIPPIC":[{"def":"Any one of the series of famous orations of Demosthenes, the Grecian orator, denouncing Philip, king of Macedon.","pos":""},{"def":"Hence: Any discourse or declamation abounding in acrimonious invective.","pos":""}],"PHILIPPIUM":[{"def":"A rare and doubtful metallic element said to have been discovered in the mineral samarskite.","pos":""}],"PHILIPPIZE":[{"def":"To write or speak in the style of a philippic.","pos":""}],"PHILISTER":[{"def":"A Philistine; -- a cant name given to townsmen by students in German universities.","pos":""}],"PHILISTINE":[{"def":"A native or an inhabitant of ancient Philistia, a coast region of southern Palestine.","pos":""}],"PHILISTINISM":[{"def":"The condition, character, aims, and habits of the class called Philistines.","pos":""}],"PHILLYGENIN":[{"def":"A pearly crystalline substance obtained by the decomposition of phillyrin.","pos":""}],"PHILLYREA":[{"def":"A genus of evergreen plants growing along the shores of the Mediterranean, and breading a fruit resembling that of the olive.","pos":""}],"PHILLYRIN":[{"def":"A glucoside extracted from Phillyrea as a bitter white crystalline substance.","pos":""}],"PHILO-":[{"def":"A combining form from Gr.","pos":""}],"PHILOGYNIST":[{"def":"A lover or friend of women; one who esteems woman as the higher type of humanity; -- opposed to Ant: misogynist.","pos":""}],"PHILOGYNY":[{"def":"Fondness for women; uxoriousness; -- opposed to Ant: misogyny.","pos":""}],"PHILOHELLENIAN":[{"def":"A philhellenist.","pos":""}],"PHILOLOGIAN":[{"def":"Of or pertaining to philology.","pos":""}],"PHILOLOGIST":[{"def":"One versed in philology.","pos":""}],"PHILOLOGIZE":[{"def":"To study, or make critical comments on, language.","pos":""}],"PHILOLOGY":[{"def":"Criticism; grammatical learning.","pos":""},{"def":"The study of language, especially in a philosophical manner and as a science; the investigation of the laws of human speech, the relation of different tongues to one another, and historical development of languages; linguistic science.","pos":""}],"PHILOMATH":[{"def":"A lover of learning; a scholar.","pos":""}],"PHILOMATHEMATIC":[{"def":"Phil`o*math`e*mat\"ic, n.","pos":""}],"PHILOMATHIC":[{"def":"Of or pertaining to philomathy.","pos":""},{"def":"Having love of learning or letters.","pos":""}],"PHILOMATHY":[{"def":"The love of learning or letters.","pos":""}],"PHILOMEL":[{"def":"Same as Philomela, the nightingale.","pos":""}],"PHILOMELA":[{"def":"A genus of birds including the nightingales.","pos":""}],"PHILOMENE":[{"def":"The nightingale.","pos":""}],"PHILOMOT":[{"def":"Of the color of a dead leaf.","pos":""}],"PHILOPENA":[{"def":"A present or gift which is made as a forfeit in a social game that is played in various ways; also, the game itself.","pos":""},{"def":"Fond of polemics or controversy.","pos":""}],"PHILOPROGENITIVE":[{"def":"Having the love of offspring; fond of children.","pos":""}],"PHILOPROGENITIVENESS":[{"def":"The love of offspring; fondness for children.","pos":""}],"PHILOSOPHASTER":[{"def":"A pretender to philosophy.","pos":""}],"PHILOSOPHATE":[{"def":"To play the philosopher; to moralize.","pos":""}],"PHILOSOPHATION":[{"def":"Philosophical speculation and discussion.","pos":""}],"PHILOSOPHE":[{"def":"A philosophaster; a philosopher.","pos":""}],"PHILOSOPHEME":[{"def":"A philosophical proposition, doctrine, or principle of reasoning.","pos":""}],"PHILOSOPHER":[{"def":"Of or pertaining to philosophy; versed in, or imbued with, the principles of philosophy; hence, characterizing a philosopher; rational; wise; temperate; calm; cool.","pos":""}],"PHILOSOPHISM":[{"def":"Spurious philosophy; the love or practice of sophistry.","pos":""}],"PHILOSOPHIST":[{"def":"A pretender in philosophy.","pos":""},{"def":"Of or pertaining to the love or practice of sophistry.","pos":""}],"PHILOSOPHIZE":[{"def":"To reason like a philosopher; to search into the reason and nature of things; to investigate phenomena, and assign rational causes for their existence.","pos":""}],"PHILOSOPHIZER":[{"def":"One who philosophizes.","pos":""}],"PHILOSOPHY":[{"def":"Literally, the love of, including the search after, wisdom; in actual usage, the knowledge of phenomena as explained by, and resolved into, causes and reasons, powers and laws.","pos":""},{"def":"A particular philosophical system or theory; the hypothesis by which particular phenomena are explained.","pos":""}],"PHILOSTORGY":[{"def":"Natural affection, as of parents for their children.","pos":""},{"def":"Fond of the arts.","pos":""}],"PHILTER":[{"def":"A potion or charm intended to excite the passion of love.","pos":""}],"PHIMOSIS":[{"def":"A condition of the penis in which the prepuce can not be drawn back so as to uncover the glans penis.","pos":""}],"PHITONESS":[{"def":"Pythoness; witch.","pos":""}],"PHIZ":[{"def":"The face or visage.","pos":""}]}