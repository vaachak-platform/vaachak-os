{"NOEMATACHOGRAPH":[{"def":"An instrument for determining and registering the duration of more or less complex operations of the mind.","pos":""},{"def":"Of or pertaining to the understanding.","pos":""}],"NOEMICS":[{"def":"The science of the understanding; intellectual science.","pos":""}],"NOETIAN":[{"def":"One of the followers of Noetus, who lived in the third century.","pos":""},{"def":"Of or pertaining to the intellect; intellectual.","pos":""}]}