{"FORECAST":[{"def":"To plan beforehand; to scheme; to project.","pos":""},{"def":"To foresee; to calculate beforehand, so as to provide for.","pos":""}],"FORECASTER":[{"def":"One who forecast.","pos":""}],"FORECASTLE":[{"def":"Fore\"cas`tle (; sailors say , n.","pos":""}],"FORECHOSEN":[{"def":"Chosen beforehand.","pos":""}],"FORECITED":[{"def":"Cited or quoted before or above.","pos":""}],"FORECLOSE":[{"def":"To shut up or out; to preclude; to stop; to prevent; to bar; to exclude.","pos":""}],"FORECLOSURE":[{"def":"The act or process of foreclosing; a proceeding which bars or extinguishes a mortgager's right of redeeming a mortgaged estate.","pos":""}],"FORECONCEIVE":[{"def":"To preconceive; to imagine beforehand.","pos":""}]}