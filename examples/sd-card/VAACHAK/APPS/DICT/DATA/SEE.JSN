{"SEE":[{"def":"A seat; a site; a place where sovereign power is exercised.","pos":""},{"def":"Specifically: (a) The seat of episcopal power; a diocese; the jurisdiction of a bishop; as, the see of New York.","pos":""}],"SEECATCH":[{"def":"A full-grown male fur seal.","pos":""}],"SEED":[{"def":"The generative fluid of the male; semen; sperm; -- not used in the plural.","pos":""}],"SEED-LAC":[{"def":"A species of lac.","pos":""}],"SEEDCAKE":[{"def":"A sweet cake or cooky containing aromatic seeds, as caraway.","pos":""}],"SEEDER":[{"def":"One who, or that which, sows or plants seed.","pos":""}],"SEEDINESS":[{"def":"The quality or state of being seedy, shabby, or worn out; a state of wretchedness or exhaustion.","pos":""}],"SEEDLESS":[{"def":"Without seed or seeds.","pos":""}],"SEEDLING":[{"def":"A plant reared from the seed, as distinguished from one propagated by layers, buds, or the like.","pos":""},{"def":"A vessel in which a sower carries the seed to be scattered.","pos":""}],"SEEDMAN":[{"def":"Seed\"man, See Defn: Seedsman.","pos":""}],"SEEDSMAN":[{"def":"A sower; one who sows or scatters seed.","pos":""},{"def":"A person who deals in seeds.","pos":""}],"SEEDTIME":[{"def":"The season proper for sowing.","pos":""}],"SEEDY":[{"def":"Abounding with seeds; bearing seeds; having run to seeds.","pos":""},{"def":"Having a peculiar flavor supposed to be derived from the weeds growing among the vines; -- said of certain kinds of FRench brandy.","pos":""}],"SEEING":[{"def":"(but originally a present participle).","pos":""}],"SEEK":[{"def":"To go in search of; to look for; to search for; to try to find.","pos":""},{"def":"To inquire for; to ask for; to solicit; to bessech.","pos":""}],"SEEK-NO-FURTHER":[{"def":"A kind of choice winter apple, having a subacid taste; -- formerly called go-no-further.","pos":""}],"SEEK-SORROW":[{"def":"One who contrives to give himself vexation.","pos":""}],"SEEKER":[{"def":"One of a small heterogeneous sect of the 17th century, in Great Britain, who professed to be seeking the true church, ministry, and sacraments.","pos":""}],"SEEL":[{"def":"To close the eyes of (a hawk or other bird) by drawing through the lids threads which were fastened over the head.","pos":""}],"SEELILY":[{"def":"In a silly manner.","pos":""}],"SEEM":[{"def":"To appear, or to appear to be; to have a show or semblance; to present an appearance; to look; to strike one's apprehension or fancy as being; to be taken as.","pos":""}],"SEEMER":[{"def":"One who seems; one who carries or assumes an appearance or semblance.","pos":""}],"SEEMING":[{"def":"Having a semblance, whether with or without reality; apparent; specious; befitting; as, seeming friendship; seeming truth.","pos":""}],"SEEMINGLY":[{"def":"In appearance; in show; in semblance; apparently; ostensibly.","pos":""}],"SEEMINGNESS":[{"def":"Semblance; fair appearance; plausibility.","pos":""}],"SEEMLILY":[{"def":"In a seemly manner.","pos":""}],"SEEMLINESS":[{"def":"The quality or state of being seemly: comeliness; propriety.","pos":""}],"SEEMLY":[{"def":"Suited to the object, occasion, purpose, or character; suitable; fit; becoming; comely; decorous.","pos":""}],"SEEMLYHED":[{"def":"Comely or decent appearance.","pos":""}],"SEEN":[{"def":"Versed; skilled; accomplished.","pos":""},{"def":"To run or soak through fine pores and interstices; to ooze.","pos":""}],"SEER":[{"def":"A person who foresees events; a prophet.","pos":""}],"SEERESS":[{"def":"A female seer; a prophetess.","pos":""}],"SEERFISH":[{"def":"A scombroid food fish of Maderia (Cybium Commersonii).","pos":""}],"SEERHAND":[{"def":"A kind of muslin of a texture between nainsook and mull.","pos":""}],"SEERSHIP":[{"def":"The office or quality of a seer.","pos":""}],"SEERSUCKER":[{"def":"A light fabric, originally made in the East Indies, of silk and linen, usually having alternating stripes, and a slightly craped or puckered surface; also, a cotton fabric of similar appearance.","pos":""}],"SEESAW":[{"def":"Same as Crossruff.","pos":""}],"SEETHE":[{"def":"To decoct or prepare for food in hot liquid; to boil; as, to seethe flesh.","pos":""}],"SEETHER":[{"def":"A pot for boiling things; a boiler.","pos":""}]}