{"BEN":[{"def":"Within; in; in or into the interior; toward the inner apartment.","pos":""}],"BENAME":[{"def":"To promise; to name.","pos":""}],"BENCH":[{"def":"A long seat, differing from a stool in its greater length.","pos":""},{"def":"A long table at which mechanics and other work; as, a carpenter's bench.","pos":""}],"BENCH MARK":[{"def":"Any permanent mark to which other levels may be referred.","pos":""}],"BENCH WARRANT":[{"def":"A process issued by a presiding judge or by a court against a person guilty of some contempt, or indicted for some crime; -- so called in distinction from a justice's warrant.","pos":""}],"BENCHER":[{"def":"One of the senior and governing members of an Inn of Court.","pos":""}],"BEND":[{"def":"To fasten, as one rope to another, or as a sail to its yard or stay; or as a cable to the ring of an anchor.","pos":""}],"BENDABLE":[{"def":"Capable of being bent.","pos":""}],"BENDER":[{"def":"One who, or that which, bends.","pos":""},{"def":"An instrument used for bending.","pos":""}],"BENDING":[{"def":"The marking of the clothes with stripes or horizontal bands.","pos":""}],"BENDLET":[{"def":"A narrow bend, esp.","pos":""}],"BENDY":[{"def":"Divided into an even number of bends; -- said of a shield or its charge.","pos":""}],"BENE":[{"def":"A hoglike mammal of New Guinea (Porcula papuensis).","pos":""}],"BENE PLACITO":[{"def":"At pleasure; ad libitum.","pos":""}],"BENEATH":[{"def":"Lower in place, with something directly over or on; under; underneath; hence, at the foot of.","pos":""},{"def":"Beneath a rude and nameless stone he lies.","pos":""}],"BENEDICITE":[{"def":"A canticle (the Latin version of which begins with this word) which may be used in the order for morning prayer in the Church of England.","pos":""}],"BENEDICT":[{"def":"Having mild and salubrious qualities.","pos":""}],"BENEDICTINE":[{"def":"Pertaining to the monks of St.","pos":""}],"BENEDICTION":[{"def":"The short prayer which closes public worship; as, to give the benediction.","pos":""},{"def":"The form of instituting an abbot, answering to the consecration of a bishop.","pos":""}],"BENEDICTIONAL":[{"def":"A book of benedictions.","pos":""}],"BENEDICTIONARY":[{"def":"A collected series of benedictions.","pos":""}],"BENEDICTIVE":[{"def":"Tending to bless.","pos":""}],"BENEDICTORY":[{"def":"Expressing wishes for good; as, a benedictory prayer.","pos":""}],"BENEDICTUS":[{"def":"The song of Zacharias at the birth of John the Baptist (Luke i.","pos":""}],"BENEFACTION":[{"def":"The act of conferring a benefit.","pos":""},{"def":"A benefit conferred; esp.","pos":""}],"BENEFACTOR":[{"def":"One who confers a benefit or benefits.","pos":""}],"BENEFACTRESS":[{"def":"A woman who confers a benefit.","pos":""}],"BENEFIC":[{"def":"Favorable; beneficent.","pos":""}],"BENEFICE":[{"def":"An estate in lands; a fief.","pos":""}],"BENEFICED":[{"def":"Possessed of a benefice o \"Beneficed clergymen.","pos":""}],"BENEFICELESS":[{"def":"Having no benefice.","pos":""}],"BENEFICENCE":[{"def":"The practice of doing good; active goodness, kindness, or charity; bounty springing from purity and goodness.","pos":""}],"BENEFICENT":[{"def":"Be*nef`i*cent Defn: , a.","pos":""}],"BENEFICENTIAL":[{"def":"Relating to beneficence.","pos":""}],"BENEFICENTLY":[{"def":"In a beneficent manner; with beneficence.","pos":""}],"BENEFICIAL":[{"def":"Receiving, or entitled to have or receive, advantage, use, or benefit; as, the beneficial owner of an estate.","pos":""}],"BENEFICIALLY":[{"def":"In a beneficial or advantageous manner; profitably; helpfully.","pos":""}],"BENEFICIALNESS":[{"def":"The quality of being beneficial; profitableness.","pos":""}],"BENEFICIARY":[{"def":"Holding some office or valuable possession, in subordination to another; holding under a feudal or other superior; having a dependent and secondary possession.","pos":""},{"def":"Bestowed as a gratuity; as, beneficiary gifts.","pos":""}],"BENEFICIATE":[{"def":"To reduce (ores).","pos":""}],"BENEFIT":[{"def":"Natural advantaged; endowments; accomplishments.","pos":""}],"BENEFIT SOCIETY":[{"def":"A society or association formed for mutual insurance, as among tradesmen or in labor unions, to provide for relief in sickness, old age, and for the expenses of burial.","pos":""}],"BENEFITER":[{"def":"One who confers a benefit; -- also, one who receives a benefit.","pos":""}],"BENEME":[{"def":"To deprive (of), or take away (from).","pos":""}],"BENEMPT":[{"def":"Promised; vowed.","pos":""}],"BENET":[{"def":"To catch in a net; to insnare.","pos":""}],"BENEVOLENCE":[{"def":"The disposition to do good; good will; charitableness; love of mankind, accompanied with a desire to promote their happiness.","pos":""},{"def":"An act of kindness; good done; charity given.","pos":""}],"BENEVOLENT":[{"def":"Having a disposition to do good; possessing or manifesting love to mankind, and a desire to promote their prosperity and happiness; disposed to give to good objects; kind; charitable.","pos":""}],"BENEVOLOUS":[{"def":"Kind; benevolent.","pos":""}],"BENGAL":[{"def":"The language spoken in Bengal.","pos":""}],"BENGALESE":[{"def":"Of or pertaining to Bengal.","pos":""}],"BENIGHT":[{"def":"To involve in darkness; to shroud with the shades of night; to obscure.","pos":""},{"def":"To overtake with night or darkness, especially before the end of a day's journey or task.","pos":""}],"BENIGHTMENT":[{"def":"The condition of being benighted.","pos":""}],"BENIGN":[{"def":"Of a kind or gentle disposition; gracious; generous; favorable; benignant.","pos":""},{"def":"Exhibiting or manifesting kindness, gentleness, favor, etc.","pos":""}],"BENIGNANCY":[{"def":"Benignant quality; kindliness.","pos":""}],"BENIGNANT":[{"def":"Kind; gracious; favorable.","pos":""}],"BENIGNITY":[{"def":"The quality of being benign; goodness; kindness; graciousness.","pos":""},{"def":"Mildness; gentleness.","pos":""}],"BENIGNLY":[{"def":"In a benign manner.","pos":""}],"BENISON":[{"def":"Blessing; beatitude; benediction.","pos":""}],"BENITIER":[{"def":"A holy-water stoup.","pos":""}],"BENJAMIN":[{"def":"A kind of upper coat for men.","pos":""}],"BENJAMITE":[{"def":"A descendant of Benjamin; one of the tribe of Benjamin.","pos":""}],"BENNE":[{"def":"The name of two plants (Sesamum orientale and S.","pos":""}],"BENNET":[{"def":"The common yellow-flowered avens of Europe (Geum urbanum); herb bennet.","pos":""}],"BENT":[{"def":"Changed by pressure so as to be no longer straight; crooked; as, a bent pin; a bent lever.","pos":""},{"def":"Strongly inclined toward something, so as to be resolved, determined, set, etc.","pos":""}],"BENT GRASS":[{"def":"Same as Bent, a kind of grass.","pos":""}],"BENTHAL":[{"def":"Relating to the deepest zone or region of the ocean.","pos":""}],"BENTHAMIC":[{"def":"Of or pertaining to Bentham or Benthamism.","pos":""}],"BENTHAMITE":[{"def":"One who believes in Benthamism.","pos":""}],"BENTHOS":[{"def":"The bottom of the sea, esp.","pos":""}],"BENTING TIME":[{"def":"The season when pigeons are said to feed on bents, before peas are ripe.","pos":""}],"BENTY":[{"def":"A bounding in bents, or the stalks of coarse, stiff, withered grass; as, benty fields.","pos":""},{"def":"Resembling bent.","pos":""}],"BENUMB":[{"def":"To make torpid; to deprive of sensation or sensibility; to stupefy; as, a hand or foot benumbed by cold.","pos":""}],"BENUMBED":[{"def":"Made torpid; numbed; stupefied; deadened; as, a benumbed body and mind.","pos":""}],"BENUMBMENT":[{"def":"Act of benumbing, or state of being benumbed; torpor.","pos":""}],"BENZAMIDE":[{"def":"A transparent crystalline substance, C6H5.","pos":""}],"BENZENE":[{"def":"A volatile, very inflammable liquid, C6H6, contained in the naphtha produced by the destructive distillation of coal, from which it is separated by fractional distillation.","pos":""}],"BENZILE":[{"def":"A yellowish crystalline substance, C6H5.","pos":""}],"BENZINE":[{"def":"A liquid consisting mainly of the lighter and more volatile hydrocarbons of petroleum or kerosene oil, used as a solvent and for cleansing soiled fabrics; -- called also petroleum spirit, petroleum benzine.","pos":""},{"def":"Same as Benzene.","pos":""}],"BENZOATE":[{"def":"A salt formed by the union of benzoic acid with any salifiable base.","pos":""}],"BENZOIC":[{"def":"Pertaining to, or obtained from, benzoin.","pos":""}],"BENZOIN":[{"def":"The spicebush (Lindera benzoin).","pos":""}],"BENZOINATED":[{"def":"Containing or impregnated with benzoin; as, benzoinated lard.","pos":""},{"def":"An impure benzene, used in the arts as a solvent, and for various other purposes.","pos":""}],"BENZOLINE":[{"def":"A white crystalline powder used as an intestinal antiseptic; beta-naphthol benzoate.","pos":""}],"BENZOSOL":[{"def":"Guaiacol benzoate, used as an intestinal antiseptic and as a substitute for creosote in phthisis.","pos":""}],"BENZOYL":[{"def":"A compound radical, C6H5.","pos":""}],"BENZYL":[{"def":"A compound radical, C6H5.","pos":""}]}