{"UNIVALENCE":[{"def":"The quality or state of being univalent.","pos":""}],"UNIVALENT":[{"def":"Having a valence of one; capable of combining with, or of being substituted for, one atom of hydrogen; monovalent; -- said of certain atoms and radicals.","pos":""}],"UNIVALVE":[{"def":"A shell consisting of one valve only; a mollusk whose shell is composed of a single piece, as the snails and conchs.","pos":""},{"def":"Having one valve; as, a univalve shell or pericarp.","pos":""}],"UNIVALVIA":[{"def":"Same as Gastropoda.","pos":""}],"UNIVALVULAR":[{"def":"Same as Univalve, a.","pos":""}],"UNIVARIANT":[{"def":"Having one degree of freedom or variability.","pos":""}],"UNIVERSAL":[{"def":"Adapted or adaptable to all or to various uses, shapes, sizes, etc.","pos":""},{"def":"Forming the whole of a genus; relatively unlimited in extension; affirmed or denied of the whole of a subject; as, a universal proposition; -- opposed to particular; e.","pos":""}],"UNIVERSALIAN":[{"def":"Of or pertaining to Universalism; Universalist.","pos":""}],"UNIVERSALISM":[{"def":"The doctrine or belief that all men will be saved, or made happy, in the future state.","pos":""}],"UNIVERSALIST":[{"def":"One who believes in Universalism; one of a denomination of Christians holding this faith.","pos":""}],"UNIVERSALISTIC":[{"def":"Of or pertaining to the whole; universal.","pos":""}],"UNIVERSALITY":[{"def":"The quality or state of being universal; unlimited extension or application; generality; -- distinguished from particularity; as, the unversality of a proposition; the unversality of sin; the unversality of the Deluge.","pos":""}],"UNIVERSALIZE":[{"def":"To make universal; to generalize.","pos":""}],"UNIVERSALLY":[{"def":"In a universal manner; without exception; as, God's laws are universally binding on his creatures.","pos":""}],"UNIVERSALNESS":[{"def":"The quality or state of being universal; universality.","pos":""}],"UNIVERSE":[{"def":"All created things viewed as constituting one system or whole; the whole body of things, or of phenomena; the mundus of the Latins; the world; creation.","pos":""}],"UNIVERSITY":[{"def":"The universe; the whole.","pos":""},{"def":"An association, society, guild, or corporation, esp.","pos":""}],"UNIVERSITY EXTENSION":[{"def":"The extension of the advantages of university instruction by means of lectures and classes at various centers.","pos":""}],"UNIVERSOLOGICAL":[{"def":"Of or pertaining to universology.","pos":""}],"UNIVERSOLOGIST":[{"def":"One who is versed in universology.","pos":""}],"UNIVERSOLOGY":[{"def":"The science of the universe, and the relations which it involves.","pos":""}],"UNIVOCACY":[{"def":"The quality or state of being univocal.","pos":""}],"UNIVOCAL":[{"def":"Having one meaning only; -- contrasted with equivocal.","pos":""},{"def":"Having unison of sound, as the octave in music.","pos":""}],"UNIVOCALLY":[{"def":"In a univocal manner; in one term; in one sense; not equivocally.","pos":""}],"UNIVOCATION":[{"def":"Agreement of name and meaning.","pos":""}]}