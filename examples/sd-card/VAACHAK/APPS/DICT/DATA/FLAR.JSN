{"FLARE":[{"def":"To burn with an unsteady or waving flame; as, the candle flares.","pos":""},{"def":"To shine out with a sudden and unsteady light; to emit a dazzling or painfully bright light.","pos":""}],"FLARE-UP":[{"def":"A sudden burst of anger or passion; an angry dispute.","pos":""}],"FLARING":[{"def":"That flares; flaming or blazing unsteadily; shining out with a dazzling light.","pos":""},{"def":"Opening or speading outwards.","pos":""}],"FLARINGLY":[{"def":"In a flaring manner.","pos":""}]}