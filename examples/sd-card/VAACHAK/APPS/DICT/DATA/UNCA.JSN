{"UNCAGE":[{"def":"To loose, or release, from, or as from, a cage.","pos":""}],"UNCALLED-FOR":[{"def":"Not called for; not required or needed; improper; gratuitous; wanton.","pos":""}],"UNCALM":[{"def":"To disturb; to disquiet.","pos":""}],"UNCAMP":[{"def":"To break up the camp of; to dislodge from camp.","pos":""}],"UNCANNY":[{"def":"Not canny; unsafe; strange; weird; ghostly.","pos":""}],"UNCANONIZE":[{"def":"To deprive of canonical authority.","pos":""},{"def":"To reduce from the rank of a canonized saint.","pos":""}],"UNCAP":[{"def":"To remove a cap or cover from.","pos":""}],"UNCAPE":[{"def":"To remove a cap or cape from.","pos":""}],"UNCAPPER":[{"def":"An instrument for removing an explode cap from a cartridge shell.","pos":""}],"UNCARDINAL":[{"def":"To degrade from the cardinalship.","pos":""}],"UNCARED":[{"def":"Not cared for; not heeded; -- with for.","pos":""}],"UNCARNATE":[{"def":"Not fleshy; specifically, not made flesh; not incarnate.","pos":""}],"UNCART":[{"def":"To take from, or set free from, a cart; to unload.","pos":""}],"UNCASE":[{"def":"To display, or spread to view, as a flag, or the colors of a military body.","pos":""}],"UNCASTLE":[{"def":"To take a castle from; to turn out of a castle.","pos":""}],"UNCAUSED":[{"def":"Having no antecedent cause; uncreated; self-existent; eternal.","pos":""}]}