{"BAROCYCLONOMETER":[{"def":"An aneroid barometer for use with accompanying graphic diagrams and printed directions designed to aid mariners to interpret the indications of the barometer so as to determine the existence of a violent storm at a distance of several hundred miles.","pos":""}],"BAROGRAM":[{"def":"A tracing, usually made by the barograph, showing graphically the variations of atmospheric pressure for a given time.","pos":""}],"BAROGRAPH":[{"def":"An instrument for recording automatically the variations of atmospheric pressure.","pos":""}],"BAROKO":[{"def":"A form or mode of syllogism of which the first proposition is a universal affirmative, and the other two are particular negative.","pos":""}],"BAROLOGY":[{"def":"The science of weight or gravity.","pos":""}],"BAROMACROMETER":[{"def":"An instrument for ascertaining the weight and length of a newborn infant.","pos":""}],"BAROMETER":[{"def":"An instrument for determining the weight or pressure of the atmosphere, and hence for judging of the probable changes of weather, or for ascertaining the height of any ascent.","pos":""},{"def":"Pertaining to the barometer; made or indicated by a barometer; as, barometric changes; barometrical observations.","pos":""}],"BAROMETRICALLY":[{"def":"By means of a barometer, or according to barometric observations.","pos":""}],"BAROMETROGRAPH":[{"def":"A form of barometer so constructed as to inscribe of itself upon paper a record of the variations of atmospheric pressure.","pos":""}],"BAROMETRY":[{"def":"The art or process of making barometrical measurements.","pos":""}],"BAROMETZ":[{"def":"The woolly-skinned rhizoma or rootstock of a fern (Dicksonia barometz), which, when specially prepared and inverted, somewhat resembles a lamb; -- called also Scythian lamb.","pos":""}],"BARON":[{"def":"A husband; as, baron and feme, husband and wife.","pos":""}],"BARONAGE":[{"def":"The whole body of barons or peers.","pos":""},{"def":"The dignity or rank of a baron.","pos":""}],"BARONESS":[{"def":"A baron's wife; also, a lady who holds the baronial title in her own right; as, the Baroness Burdett-Coutts.","pos":""}],"BARONET":[{"def":"A dignity or degree of honor next below a baron and above a knight, having precedency of all orders of knights except those of the Garter.","pos":""}],"BARONETAGE":[{"def":"State or rank of a baronet.","pos":""},{"def":"The collective body of baronets.","pos":""}],"BARONETCY":[{"def":"The rank or patent of a baronet.","pos":""}],"BARONG":[{"def":"A kind of cutting weapon with a thick back and thin razorlike edge, used by the Moros of the Philippine Islands.","pos":""}],"BARONIAL":[{"def":"Pertaining to a baron or a barony.","pos":""}],"BARONY":[{"def":"The fee or domain of a baron; the lordship, dignity, or rank of a baron.","pos":""},{"def":"In Ireland, a territorial division, corresponding nearly to the English hundred, and supposed to have been originally the district of a native chief.","pos":""}],"BAROQUE":[{"def":"In bad taste; grotesque; odd.","pos":""}],"BAROSCOPE":[{"def":"Any instrument showing the changes in the weight of the atmosphere; also, less appropriately, any instrument that indicates - or foreshadows changes of the weather, as a deep vial of liquid holding in suspension some substance which rises and falls with atmospheric changes.","pos":""},{"def":"Pertaining to, or determined by, the baroscope.","pos":""}],"BAROTHERMOGRAPH":[{"def":"An instrument for recording both pressure and temperature, as of the atmosphere.","pos":""}],"BAROUCHE":[{"def":"A four-wheeled carriage, with a falling top, a seat on the outside for the driver, and two double seats on the inside arranged so that the sitters on the front seat face those on the back seat.","pos":""}],"BAROUCHET":[{"def":"A kind of light barouche.","pos":""}]}