{"SEN":[{"def":"A Japanese coin, worth about one half of a cent.","pos":""}],"SENARY":[{"def":"Of six; belonging to six; containing six.","pos":""}],"SENATE":[{"def":"A body of elders appointed or elected from among the nobles of the nation, and having supreme legislative authority.","pos":""}],"SENATOR":[{"def":"A member of the king's council; a king's councilor.","pos":""}],"SENATORIAL":[{"def":"Of or pertaining to a senator, or a senate; becoming to a senator, or a senate; as, senatorial duties; senatorial dignity.","pos":""},{"def":"Entitled to elect a senator, or by senators; as, the senatorial districts of a State.","pos":""}],"SENATORIALLY":[{"def":"In a senatorial manner.","pos":""}],"SENATORSHIP":[{"def":"The office or dignity of a senator.","pos":""}],"SENATUSCONSULT":[{"def":"A decree of the Roman senate.","pos":""}],"SEND":[{"def":"To cause to go in any manner; to dispatch; to commission or direct to go; as, to send a messenger.","pos":""},{"def":"To give motion to; to cause to be borne or carried; to procure the going, transmission, or delivery of; as, to send a message.","pos":""}],"SENDAL":[{"def":"A light thin stuff of silk.","pos":""}],"SENECAS":[{"def":"A tribe of Indians who formerly inhabited a part of Western New York.","pos":""}],"SENECIO":[{"def":"A very large genus of composite plants including the groundsel and the golden ragwort.","pos":""}],"SENEGIN":[{"def":"A substance extracted from the rootstock of the Polygala Senega (Seneca root), and probably identical with polygalic acid.","pos":""}],"SENESCENCE":[{"def":"The state of growing old; decay by time.","pos":""}],"SENESCENT":[{"def":"Growing old; decaying with the lapse of time.","pos":""}],"SENESCHAL":[{"def":"An officer in the houses of princes and dignitaries, in the Middle Ages, who had the superintendence of feasts and domestic ceremonies; a steward.","pos":""}],"SENESCHALSHIP":[{"def":"The office, dignity, or jurisdiction of a seneschal.","pos":""}],"SENILE":[{"def":"Of or pertaining to old age; proceeding from, or characteristic of, old age; affected with the infirmities of old age; as, senile weakness.","pos":""}],"SENILITY":[{"def":"The quality or state of being senile; old age.","pos":""}],"SENIOR":[{"def":"More advanced than another in age; prior in age; elder; hence, more advanced in dignity, rank, or office; superior; as, senior member; senior counsel.","pos":""},{"def":"Belonging to the final year of the regular course in American colleges, or in professional schools.","pos":""}],"SENIORITY":[{"def":"The quality or state of being senior.","pos":""}],"SENIORIZE":[{"def":"To exercise authority; to rule; to lord it.","pos":""}],"SENNA":[{"def":"The leaves of several leguminous plants of the genus Cassia.","pos":""},{"def":"The plants themselves, native to the East, but now cultivated largely in the south of Europe and in the West Indies.","pos":""}],"SENNET":[{"def":"A signal call on a trumpet or cornet for entrance or exit on the stage.","pos":""}],"SENNIGHT":[{"def":"The space of seven nights and days; a week.","pos":""}],"SENNIT":[{"def":"A braided cord or fabric formed by plaiting together rope yarns or other small stuff.","pos":""}],"SENOCULAR":[{"def":"Having six eyes.","pos":""}],"SENONIAN":[{"def":"In european geology, a name given to the middle division of the Upper Cretaceous formation.","pos":""},{"def":"A Spanish title of courtesy corresponding to the English Mr.","pos":""}],"SENSATE":[{"def":"To feel or apprehend more or less distinctly through a sense, or the senses; as, to sensate light, or an odor.","pos":""},{"def":"Felt or apprehended through a sense, or the senses.","pos":""}],"SENSATION":[{"def":"A purely spiritual or psychical affection; agreeable or disagreeable feelings occasioned by objects that are not corporeal or material.","pos":""},{"def":"A state of excited interest or feeling, or that which causes it.","pos":""}],"SENSATIONAL":[{"def":"Of or pertaining to sensation; as, sensational nerves.","pos":""},{"def":"Of or pertaining to sensationalism, or the doctrine that sensation is the sole origin of knowledge.","pos":""}],"SENSATIONALISM":[{"def":"The doctrine held by Condillac, and by some ascribed to Locke, that our ideas originate solely in sensation, and consist of sensations transformed; sensualism; -- opposed to intuitionalism, and rationalism.","pos":""}],"SENSATIONALIST":[{"def":"An advocate of, or believer in, philosophical sensationalism.","pos":""}],"SENSE":[{"def":"A faculty, possessed by animals, of perceiving external objects by means of impressions made upon certain organs (sensory or sense organs) of the body, or of perceiving changes in the condition of the body; as, the senses of sight, smell, hearing, taste, and touch.","pos":""},{"def":"One of two opposite directions in which a line, surface, or volume, may be supposed to be described by the motion of a point, line, or surface.","pos":""}],"SENSEFUL":[{"def":"Full of sense, meaning, or reason; reasonable; judicious.","pos":""}],"SENSELESS":[{"def":"Destitute of, deficient in, or contrary to, sense; without sensibility or feeling; unconscious; stupid; foolish; unwise; unreasonable.","pos":""}],"SENSIBILITY":[{"def":"The quality or state of being sensible, or capable of sensation; capacity to feel or perceive.","pos":""}],"SENSIBLE":[{"def":"Capable of being perceived by the senses; apprehensible through the bodily organs; hence, also, perceptible to the mind; making an impression upon the sense, reason, or understanding; sensible resistance.","pos":""},{"def":"Having the capacity of receiving impressions from external objects; capable of perceiving by the instrumentality of the proper organs; liable to be affected physsically or mentally; impressible.","pos":""}],"SENSIBLENESS":[{"def":"The quality or state of being sensible; sensibility; appreciation; capacity of perception; susceptibility.","pos":""},{"def":"Intelligence; reasonableness; good sense.","pos":""}],"SENSIBLY":[{"def":"In a sensible manner; so as to be perceptible to the senses or to the mind; appreciably; with perception; susceptibly; sensitively.","pos":""},{"def":"With intelligence or good sense; judiciously.","pos":""}],"SENSIFACIENT":[{"def":"Converting into sensation.","pos":""}],"SENSIFEROUS":[{"def":"Exciting sensation; conveying sensation.","pos":""}],"SENSIFIC":[{"def":"Exciting sensation.","pos":""}],"SENSIFICATORY":[{"def":"Susceptible of, or converting into, sensation; as, the sensificatory part of a nervous system.","pos":""}],"SENSIGENOUS":[{"def":"Causing or exciting sensation.","pos":""}],"SENSISM":[{"def":"Same as Sensualism, 2 & 3.","pos":""}],"SENSIST":[{"def":"One who, in philosophy, holds to sensism.","pos":""}],"SENSITIVE":[{"def":"Having sense of feeling; possessing or exhibiting the capacity of receiving impressions from external objects; as, a sensitive soul.","pos":""},{"def":"Having quick and acute sensibility, either to the action of external objects, or to impressions upon the mind and feelings; highly susceptible; easily and acutely affected.","pos":""}],"SENSITIVITY":[{"def":"The quality or state of being sensitive; -- used chiefly in science and the arts; as, the sensitivity of iodized silver.","pos":""}],"SENSITIZE":[{"def":"To render sensitive, or susceptible of being easily acted on by the actinic rays of the sun; as, sensitized paper or plate.","pos":""}],"SENSITIZER":[{"def":"An agent that sensitizes.","pos":""}],"SENSITOMETER":[{"def":"An instrument or apparatus for comparing and grading the sensitiveness of plates, films, etc.","pos":""}],"SENSIVE":[{"def":"Having sense or sensibility; sensitive.","pos":""}],"SENSOR":[{"def":"Sensory; as, the sensor nerves.","pos":""}],"SENSORI-VOLITIONAL":[{"def":"Concerned both in sensation and volition; -- applied to those nerve fibers which pass to and from the cerebro-spinal axis, and are respectively concerned in sensation and volition.","pos":""}],"SENSORIAL":[{"def":"Of or pertaining to the sensorium; as, sensorial faculties, motions, powers.","pos":""}],"SENSORY":[{"def":"Same as Sensorium.","pos":""}],"SENSUAL":[{"def":"Pertaining to, consisting in, or affecting, the sense, or bodily organs of perception; relating to, or concerning, the body, in distinction from the spirit.","pos":""},{"def":"Hence, not spiritual or intellectual; carnal; fleshly; pertaining to, or consisting in, the gratification of the senses, or the indulgence of appetites; wordly.","pos":""}],"SENSUALISM":[{"def":"The doctrine that all our ideas, or the operations of the understanding, not only originate in sensation, but are transformed sensations, copies or relics of sensations; sensationalism; sensism.","pos":""},{"def":"The regarding of the gratification of the senses as the highest good.","pos":""}],"SENSUALIST":[{"def":"One who is sensual; one given to the indulgence of the appetites or senses as the means of happiness.","pos":""},{"def":"One who holds to the doctrine of sensualism.","pos":""}],"SENSUALISTIC":[{"def":"Adopting or teaching the doctrines of sensualism.","pos":""}],"SENSUALITY":[{"def":"The quality or state of being sensual; devotedness to the gratification of the bodily appetites; free indulgence in carnal or sensual pleasures; luxuriousness; voluptuousness; lewdness.","pos":""}],"SENSUALIZATION":[{"def":"The act of sensualizing, or the state of being sensualized.","pos":""}],"SENSUALIZE":[{"def":"To make sensual; to subject to the love of sensual pleasure; to debase by carnal gratifications; to carnalize; as, sensualized by pleasure.","pos":""}],"SENSUALLY":[{"def":"In a sensual manner.","pos":""}],"SENSUALNESS":[{"def":"Sensuality; fleshliness.","pos":""}],"SENSUOSITY":[{"def":"The quality or state of being sensuous; sensuousness.","pos":""}],"SENSUOUS":[{"def":"Of or pertaining to the senses, or sensible objects; addressing the senses; suggesting pictures or images of sense.","pos":""},{"def":"Highly susceptible to influence through the senses.","pos":""}],"SENTENCE":[{"def":"In civil and admiralty law, the judgment of a court pronounced in a cause; in criminal and ecclesiastical courts, a judgment passed on a criminal by a court or judge; condemnation pronounced by a judgical tribunal; doom.","pos":""},{"def":"A combination of words which is complete as expressing a thought, and in writing is marked at the close by a period, or full point.","pos":""}],"SENTENCE METHOD":[{"def":"A method of teaching reading by giving first attention to phrases and sentences and later analyzing these into their verbal and alphabetic components; -- contrasted with alphabet and word methods.","pos":""}],"SENTENCER":[{"def":"One who pronounced a sentence or condemnation.","pos":""}],"SENTENTIAL":[{"def":"Comprising sentences; as, a sentential translation.","pos":""},{"def":"Of or pertaining to a sentence, or full period; as, a sentential pause.","pos":""}],"SENTENTIALLY":[{"def":"In a sentential manner.","pos":""}],"SENTENTIARY":[{"def":"One who read lectures, or commented, on the Sentences of Peter Lombard, Bishop of Paris (1159-1160), a school divine.","pos":""}],"SENTENTIOSITY":[{"def":"The quality or state of being sententious.","pos":""}],"SENTENTIOUS":[{"def":"Abounding with sentences, axioms, and maxims; full of meaning; terse and energetic in expression; pithy; as, a sententious style or discourse; sententious truth.","pos":""},{"def":"Comprising or representing sentences; sentential.","pos":""}],"SENTEUR":[{"def":"The quality or state of being sentient; esp.","pos":""}],"SENTIENT":[{"def":"Having a faculty, or faculties, of sensation and perception.","pos":""}],"SENTIENTLY":[{"def":"In a sentient or perceptive way.","pos":""}],"SENTIMENT":[{"def":"A thought prompted by passion or feeling; a state of mind in view of some subject; feeling toward or respecting some person or thing; disposition prompting to action or expression.","pos":""},{"def":"Hence, generally, a decision of the mind formed by deliberation or reasoning; thought; opinion; notion; judgment; as, to express one's sentiments on a subject.","pos":""}],"SENTIMENTAL":[{"def":"Having, expressing, or containing a sentiment or sentiments; abounding with moral reflections; containing a moral reflection; didactic.","pos":""},{"def":"Inclined to sentiment; having an excess of sentiment or sensibility; indulging the sensibilities for their own sake; artificially or affectedly tender; -- often in a reproachful sense.","pos":""}],"SENTIMENTALISM":[{"def":"The quality of being sentimental; the character or behavior of a sentimentalist; sentimentality.","pos":""}],"SENTIMENTALIST":[{"def":"One who has, or affects, sentiment or fine feeling.","pos":""}],"SENTIMENTALITY":[{"def":"The quality or state of being sentimental.","pos":""}],"SENTIMENTALIZE":[{"def":"To regard in a sentimental manner; as, to sentimentalize a subject.","pos":""}],"SENTIMENTALLY":[{"def":"In a sentimental manner.","pos":""}],"SENTINE":[{"def":"A place for dregs and dirt; a sink; a sewer.","pos":""}],"SENTINEL":[{"def":"A marine crab (Podophthalmus vigil) native of the Indian Ocean, remarkable for the great length of its eyestalks; -- called also sentinel crab.","pos":""}],"SENTISECTION":[{"def":"Painful vivisection; -- opposed to callisection.","pos":""}],"SENTRY":[{"def":"A soldier placed on guard; a sentinel.","pos":""}],"SENZA":[{"def":"Without; as, senza stromenti, without instruments.","pos":""}]}