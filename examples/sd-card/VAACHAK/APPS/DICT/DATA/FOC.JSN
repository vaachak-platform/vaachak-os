{"FOCAL":[{"def":"Belonging to,or concerning, a focus; as, a focal point.","pos":""}],"FOCALIZATION":[{"def":"The act of focalizing or bringing to a focus, or the state of being focalized.","pos":""}],"FOCALIZE":[{"def":"To bring to a focus; to focus; to concentrate.","pos":""}],"FOCILLATION":[{"def":"Comfort; support.","pos":""}],"FOCUS":[{"def":"A point in which the rays of light meet, after being reflected or refrcted, and at which the image is formed; as, the focus of a lens or mirror.","pos":""},{"def":"A point so related to a conic section and certain straight line called the directrix that the ratio of the distace between any point of the curve and the focus to the distance of the same point from the directrix is constant.","pos":""}]}