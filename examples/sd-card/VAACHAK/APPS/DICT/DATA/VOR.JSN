{"VORACIOUS":[{"def":"Greedy in eating; very hungry; eager to devour or swallow; ravenous; gluttonous; edacious; rapacious; as, a voracious man or appetite; a voracious gulf or whirlpool.","pos":""}],"VORACITY":[{"def":"The quality of being voracious; voraciousness.","pos":""}],"VORAGINOUS":[{"def":"Pertaining to a gulf; full of gulfs; hence, devouring.","pos":""}],"VORTEX":[{"def":"A supposed collection of particles of very subtile matter, endowed with a rapid rotary motion around an axis which was also the axis of a sun or a planet.","pos":""},{"def":"Any one of numerous species of small Turbellaria belonging to Vortex and allied genera.","pos":""}],"VORTEX FILAMENT":[{"def":"A vortex tube of infinitesimal cross section.","pos":""}],"VORTEX FRINGE":[{"def":"The region immediately surrounding a disk moving flatwise through air; -- so called because the air has a cyclic motion as in vortex ring.","pos":""}],"VORTEX LINE":[{"def":"A line, within a rotating fluid, whose tangent at every point is the instantaneous axis of rotation as that point of the fluid.","pos":""}],"VORTEX RING":[{"def":"A ring-shaped mass of moving fluid which, by virtue of its motion of rotation around an axis disposed in circular form, attains a more or less distinct separation from the surrounding medium and has many of the properties of a solid.","pos":""}],"VORTEX THEORY":[{"def":"The theory, advanced by Thomson (Lord Kelvin) on the basis of investigation by Helmholtz, that the atoms are vortically moving ring-shaped masses (or masses of other forms having a similar internal motion) of a homogeneous, incompressible, frictionless fluid.","pos":""}],"VORTEX TUBE":[{"def":"An imaginary tube within a rotating fluid, formed by drawing the vortex lines through all points of a closed curve.","pos":""}],"VORTICAL":[{"def":"Of or pertaining to a vortex or vortexes; resembling a vortex in form or motion; whirling; as, a vortical motion.","pos":""}],"VORTICELLA":[{"def":"Any one of numerous species of ciliated Infusoria belonging to Vorticella and many other genera of the family Vorticellidæ.","pos":""}],"VORTICOSE":[{"def":"Vortical; whirling; as, a vorticose motion.","pos":""}],"VORTIGINOUS":[{"def":"Moving rapidly round a center; vortical.","pos":""}]}