{"INRACINATE":[{"def":"To enroot or implant.","pos":""}],"INRAIL":[{"def":"To rail in; to inclose or surround, as with rails.","pos":""}],"INREGISTER":[{"def":"To register; to enter, as in a register.","pos":""}],"INRO":[{"def":"A small closed receptacle or set of receptacles of hard material, as lacquered wood, iron, bronze, or ivory, used by the Japanese to hold medicines, perfumes, and the like, and carried in the girdle.","pos":""}],"INROAD":[{"def":"The entrance of an enemy into a country with purposes of hostility; a sudden or desultory incursion or invasion; raid; encroachment.","pos":""}],"INRUNNING":[{"def":"The act or the place of entrance; an inlet.","pos":""}],"INRUSH":[{"def":"A rush inwards; as, the inrush of the tide.","pos":""}]}