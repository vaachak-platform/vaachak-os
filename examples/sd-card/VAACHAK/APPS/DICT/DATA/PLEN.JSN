{"PLENAL":[{"def":"Full; complete; as, a plenal view or act.","pos":""}],"PLENARILY":[{"def":"In a plenary manner.","pos":""}],"PLENARINESS":[{"def":"Quality or state of being plenary.","pos":""}],"PLENARTY":[{"def":"The state of a benefice when occupied.","pos":""}],"PLENARY":[{"def":"Full; entire; complete; absolute; as, a plenary license; plenary authority.","pos":""}],"PLENE":[{"def":"Full; complete; plenary.","pos":""}],"PLENICORN":[{"def":"A ruminant having solid horns or antlers, as the deer.","pos":""}],"PLENILUNARY":[{"def":"Of or pertaining to the full moon.","pos":""}],"PLENILUNE":[{"def":"The quality or state of being plenipotent.","pos":""}],"PLENIPOTENT":[{"def":"Possessing full power.","pos":""}],"PLENIPOTENTIARY":[{"def":"A person invested with full power to transact any business; especially, an ambassador or envoy to a foreign court, with full power to negotiate a treaty, or to transact other business.","pos":""}],"PLENISH":[{"def":"To furnish; to stock, as a house or farm.","pos":""}],"PLENISHING":[{"def":"Household furniture; stock.","pos":""}],"PLENIST":[{"def":"One who holds that all space is full of matter.","pos":""}],"PLENITUDE":[{"def":"The quality or state of being full or complete; fullness; completeness; abundance; as, the plenitude of space or power.","pos":""},{"def":"Animal fullness; repletion; plethora.","pos":""}],"PLENITUDINARIAN":[{"def":"Plen`i*tu`di*na\"ri*an, n.","pos":""}],"PLENITUDINARY":[{"def":"Having plenitude; full; complete; thorough.","pos":""}],"PLENTEOUS":[{"def":"Containing plenty; abundant; copious; plentiful; sufficient for every purpose; as, a plenteous supply.","pos":""},{"def":"Yielding abundance; productive; fruitful.","pos":""}],"PLENTIFUL":[{"def":"Containing plenty; copious; abundant; ample; as, a plentiful harvest; a plentiful supply of water.","pos":""},{"def":"Yielding abundance; prolific; fruitful.","pos":""}],"PLENTY":[{"def":"Full or adequate supply; enough and to spare; sufficiency; specifically, abundant productiveness of the earth; ample supply for human wants; abundance; copiousness.","pos":""}],"PLENUM":[{"def":"That state in which every part of space is supposed to be full of matter; -- opposed to vacuum.","pos":""}]}