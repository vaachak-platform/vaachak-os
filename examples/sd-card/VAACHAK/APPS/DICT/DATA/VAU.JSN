{"VAUDEVILLE":[{"def":"A kind of song of a lively character, frequently embodying a satire on some person or event, sung to a familiar air in couplets with a refrain; a street song; a topical song.","pos":""},{"def":"A theatrical piece, usually a comedy, the dialogue of which is intermingled with light or satirical songs, set to familiar airs.","pos":""}],"VAUDOIS":[{"def":"An inhabitant, or the inhabitants, of the Swiss canton of Vaud.","pos":""},{"def":"A modern name of the Waldenses.","pos":""}],"VAULT":[{"def":"An arched structure of masonry, forming a ceiling or canopy.","pos":""},{"def":"A leap or bound.","pos":""}],"VAULTAGE":[{"def":"Vaulted work; also, a vaulted place; an arched cellar.","pos":""}],"VAULTED":[{"def":"Arched like the roof of the mouth, as the upper lip of many ringent flowers.","pos":""}],"VAULTER":[{"def":"One who vaults; a leaper; a tumbler.","pos":""}],"VAULTING":[{"def":"The act of constructing vaults; a vaulted construction.","pos":""},{"def":"Act of one who vaults or leaps.","pos":""}],"VAULTY":[{"def":"Arched; concave.","pos":""}],"VAUNT":[{"def":"To boast; to make a vain display of one's own worth, attainments, decorations, or the like; to talk ostentatiously; to brag.","pos":""}],"VAUNT-COURIER":[{"def":"See Van-courier.","pos":""}],"VAUNTER":[{"def":"One who vaunts; a boaster.","pos":""}],"VAUNTFUL":[{"def":"Given to vaunting or boasting; vainly ostentatious; boastful; vainglorious.","pos":""}],"VAUNTINGLY":[{"def":"In a vaunting manner.","pos":""}],"VAUNTMURE":[{"def":"A false wall; a work raised in front of the main wall.","pos":""}],"VAUQUELINITE":[{"def":"Chromate of copper and lead, of various shades of green.","pos":""}],"VAUT":[{"def":"To vault; to leap.","pos":""}]}