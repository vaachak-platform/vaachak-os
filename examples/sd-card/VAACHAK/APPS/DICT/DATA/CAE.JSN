{"CAECAL":[{"def":"Of or pertaining to the cæcum, or blind gut.","pos":""},{"def":"Having the form of a cæcum, or bag with one opening; baglike; as, the cæcal extremity of a duct.","pos":""}],"CAECIAS":[{"def":"A wind from the northeast.","pos":""}],"CAECILIAN":[{"def":"A limbless amphibian belonging to the order Cæciliæ or Ophimorpha.","pos":""}],"CAECUM":[{"def":"Note: The cæcum is comparatively small in man, and ends in a slender portion, the vermiform appendix; but in herbivorous mammals it is often as large as the rest of the large intestine.","pos":""}],"CAELATURA":[{"def":"Art of producing metal decorative work other than statuary, as reliefs, intaglios, engraving, chasing, etc.","pos":""}],"CAEN STONE":[{"def":"A cream-colored limestone for building, found near Caen, France.","pos":""}],"CAESAR":[{"def":"A Roman emperor, as being the successor of Augustus Cæsar.","pos":""},{"def":"Of or pertaining to Cæsar or the Cæsars; imperial.","pos":""}],"CAESARISM":[{"def":"A system of government in which unrestricted power is exercised by a single person, to whom, as Cæsar or emperor, it has been committed by the popular will; imperialism; also, advocacy or support of such a system of government.","pos":""}],"CAESIOUS":[{"def":"Of the color of lavender; pale blue with a slight mixture of gray.","pos":""}],"CAESIUM":[{"def":"A rare alkaline metal found in mineral water; -- so called from the two characteristic blue lines in its spectrum.","pos":""}],"CAESPITOSE":[{"def":"Same as Cespitose.","pos":""}],"CAESURA":[{"def":"A metrical break in a verse, occurring in the middle of a foot and commonly near the middle of the verse; a sense pause in the middle of a foot.","pos":""}],"CAESURAL":[{"def":"Of or pertaining to a cæsura.","pos":""}]}