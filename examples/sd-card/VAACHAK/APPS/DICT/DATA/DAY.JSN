{"DAY":[{"def":"The time of light, or interval between one night and the next; the time between sunrise and sunset, or from dawn to darkness; hence, the light; sunshine.","pos":""},{"def":"The period of the earth's revolution on its axis.","pos":""}],"DAY-COAL":[{"def":"The upper stratum of coal, as nearest the light or surface.","pos":""}],"DAY-LABOR":[{"def":"Labor hired or performed by the day.","pos":""}],"DAY-LABORER":[{"def":"One who works by the day; -- usually applied to a farm laborer, or to a workman who does not work at any particular trade.","pos":""}],"DAY-NET":[{"def":"A net for catching small birds.","pos":""}],"DAY-STAR":[{"def":"The morning star; the star which ushers in the day.","pos":""},{"def":"The sun, as the orb of day.","pos":""}],"DAYBOOK":[{"def":"A journal of accounts; a primary record book in which are recorded the debts and credits, or accounts of the day, in their order, and from which they are transferred to the journal.","pos":""}],"DAYBREAK":[{"def":"The time of the first appearance of light in the morning.","pos":""}],"DAYDREAM":[{"def":"A vain fancy speculation; a reverie; a castle in the air; unfounded hope.","pos":""}],"DAYDREAMER":[{"def":"One given to draydreams.","pos":""}],"DAYFLOWER":[{"def":"A genus consisting mostly of tropical perennial herbs (Commelina), having ephemeral flowers.","pos":""}],"DAYFLY":[{"def":"A neuropterous insect of the genus Ephemera and related genera, of many species, and inhabiting fresh water in the larval state; the ephemeral fly; -- so called because it commonly lives but one day in the winged or adult state.","pos":""}],"DAYLIGHT":[{"def":"The light of day as opposed to the darkness of night; the light of the sun, as opposed to that of the moon or to artificial light.","pos":""}],"DAYMARE":[{"def":"A kind of incubus which occurs during wakefulness, attended by the peculiar pressure on the chest which characterizes nightmare.","pos":""}],"DAYSMAN":[{"def":"An umpire or arbiter; a mediator.","pos":""}],"DAYSPRING":[{"def":"The beginning of the day, or first appearance of light; the dawn; hence, the beginning.","pos":""}],"DAYTIME":[{"def":"The time during which there is daylight, as distinguished from the night.","pos":""}]}