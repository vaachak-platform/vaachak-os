{"GAP":[{"def":"An opening in anything made by breaking or parting; as, a gap in a fence; an opening for a passage or entrance; an opening which implies a breach or defect; a vacant space or time; a hiatus; a mountain pass.","pos":""}],"GAP-TOOTHED":[{"def":"Having interstices between the teeth.","pos":""}],"GAPE":[{"def":"To open the mouth wide; as: (a) Expressing a desire for food; as, young birds gape.","pos":""},{"def":"To pen or part widely; to exhibit a gap, fissure, or hiatus.","pos":""}],"GAPESEED":[{"def":"Any strange sight.","pos":""}],"GAPESING":[{"def":"Act of gazing about; sightseeing.","pos":""}],"GAPEWORM":[{"def":"The parasitic worm that causes the gapes in birds.","pos":""}],"GAPINGSTOCK":[{"def":"One who is an object of open-mouthed wonder.","pos":""}]}