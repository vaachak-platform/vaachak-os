{"FORM":[{"def":"A suffix used to denote in the form or shape of, resembling, etc.","pos":""}],"FORMAL":[{"def":"Belonging to the form, shape, frame, external appearance, or organization of a thing.","pos":""},{"def":"Belonging to the constitution of a thing, as distinguished from the matter composing it; having the power of making a thing what it is; constituent; essential; pertaining to oe depending on the forms, so called of the human intellect.","pos":""}],"FORMALDEHYDE":[{"def":"A colorless, volatile liquid, H2CO, resembling acetic or ethyl aldehyde, and chemically intermediate between methyl alcohol and formic acid.","pos":""}],"FORMALIN":[{"def":"An aqueous solution of formaldehyde, used as a preservative in museums and as a disinfectant.","pos":""}],"FORMALISM":[{"def":"The practice or the doctrine of strict adherence to, or dependence on, external forms, esp.","pos":""}],"FORMALIST":[{"def":"One overattentive to forms, or too much confined to them; esp.","pos":""}],"FORMALITY":[{"def":"The dress prescribed for any body of men, academical, municipal, or sacerdotal.","pos":""},{"def":"The manner in which a thing is conceived or constituted by an act of human thinking; the result of such an act; as, animality and rationality are formalities.","pos":""}],"FORMALIZE":[{"def":"To give form, or a certain form, to; to model.","pos":""},{"def":"To render formal.","pos":""}],"FORMALLY":[{"def":"In a formal manner; essentially; characteristically; expressly; regularly; ceremoniously; precisely.","pos":""}],"FORMAT":[{"def":"The shape and size of a book; hence, its external form.","pos":""}],"FORMATE":[{"def":"A salt of formic acid.","pos":""}],"FORMATION":[{"def":"The arrangement of a body of troops, as in a square, column, etc.","pos":""}],"FORMATIVE":[{"def":"Serving to form; derivative; not radical; as, a termination merely formative.","pos":""},{"def":"Capable of growth and development; germinal; as, living or formative matter.","pos":""}],"FORME":[{"def":"Same as Paté or Patté.","pos":""}],"FORMED":[{"def":"Arranged, as stars in a constellation; as, formed stars.","pos":""},{"def":"Having structure; capable of growth and development; organized; as, the formed or organized ferments.","pos":""}],"FORMEDON":[{"def":"A writ of right for a tenant in tail in case of a discontinuance of the estate tail.","pos":""}],"FORMELL":[{"def":"The female of a hawk or falcon.","pos":""}],"FORMER":[{"def":"One who forms; a maker; a creator.","pos":""}],"FORMERET":[{"def":"One of the half ribs against the walls in a ceiling vaulted with ribs.","pos":""}],"FORMERLY":[{"def":"In time past, either in time immediately preceding or at any indefinite distance; of old; heretofore.","pos":""}],"FORMFUL":[{"def":"Creative; imaginative.","pos":""}],"FORMIC":[{"def":"Pertaining to, or derived from, ants; as, formic acid; in an extended sense, pertaining to, or derived from, formic acid; as, formic ether.","pos":""}],"FORMICA":[{"def":"A Linnæan genus of hymenopterous insects, including the common ants.","pos":""}],"FORMICAROID":[{"def":"Like or pertaining to the family Formicaridæ or ant thrushes.","pos":""}],"FORMICARY":[{"def":"The nest or dwelling of a swarm of ants; an ant-hill.","pos":""}],"FORMICATE":[{"def":"Resembling, or pertaining to, an ant or ants.","pos":""}],"FORMICATION":[{"def":"A sensation resembling that made by the creeping of ants on the skin.","pos":""}],"FORMICID":[{"def":"Pertaining to the ants.","pos":""},{"def":"One of the family Formicidæ, or ants.","pos":""}],"FORMIDABILITY":[{"def":"For`mi*da*bil\"i*ty, n.","pos":""}],"FORMIDABLE":[{"def":"Exciting fear or apprehension; impressing dread; adapted to excite fear and deter from approach, encounter, or undertaking; alarming.","pos":""}],"FORMIDABLENESS":[{"def":"The quality of being formidable, or adapted to excite dread.","pos":""}],"FORMIDABLY":[{"def":"In a formidable manner.","pos":""}],"FORMIDOLOSE":[{"def":"Very much afraid.","pos":""}],"FORMING":[{"def":"The act or process of giving form or shape to anything; as, in shipbuilding, the exact shaping of partially shaped timbers.","pos":""}],"FORMLESS":[{"def":"Shapeless; without a determinate form; wanting regularity of shape.","pos":""}],"FORMULA":[{"def":"A written confession of faith; a formal statement of foctrines.","pos":""},{"def":"A rule or principle expressed in algebraic language; as, the binominal formula.","pos":""}],"FORMULARISTIC":[{"def":"Pertaining to, or exhibiting, formularization.","pos":""}],"FORMULARIZATION":[{"def":"The act of formularizing; a formularized or formulated statement or exhibition.","pos":""}],"FORMULARIZE":[{"def":"To reduce to a forula; to formulate.","pos":""}],"FORMULARY":[{"def":"Stated; prescribed; ritual.","pos":""}],"FORMULATE":[{"def":"To reduce to, or express in, a formula; to put in a clear and definite form of statement or expression.","pos":""}],"FORMULATION":[{"def":"The act, process, or result of formulating or reducing to a formula.","pos":""}],"FORMULE":[{"def":"A set or prescribed model; a formula.","pos":""}],"FORMULIZATION":[{"def":"The act or process of reducing to a formula; the state of being formulized.","pos":""}],"FORMULIZE":[{"def":"To reduce to a formula; to formulate.","pos":""}]}