{"ARPEGGIO":[{"def":"The production of the tones of a chord in rapid succession, as in playing the harp, and not simultaneously; a strain thus played.","pos":""},{"def":"Formerly, a measure of land in France, varying in different parts of the country.","pos":""}],"ARPENTATOR":[{"def":"The Anglicized form of the French arpenteur, a land surveyor.","pos":""}]}