{"ROE":[{"def":"The ova or spawn of fishes and amphibians, especially when still inclosed in the ovarian membranes.","pos":""}],"ROEBUCK":[{"def":"A small European and Asiatic deer (Capreolus capræa) having erect, cylindrical, branched antlers, forked at the summit.","pos":""}],"ROED":[{"def":"Filled with roe.","pos":""}],"ROEDEER":[{"def":"A fictious name for a party, real or fictious, to an act or proceeding.","pos":""}]}