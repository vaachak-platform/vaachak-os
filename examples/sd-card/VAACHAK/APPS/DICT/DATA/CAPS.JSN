{"CAPSAICIN":[{"def":"A colorless crystalline substance extracted from the Capsicum annuum, and giving off vapors of intense acridity.","pos":""}],"CAPSHEAF":[{"def":"The top sheaf of a stack of grain: (fig.","pos":""}],"CAPSICIN":[{"def":"A red liquid or soft resin extracted from various species of capsicum.","pos":""}],"CAPSICINE":[{"def":"A valatile alkaloid extracted from Capsicum annuum or from capsicin.","pos":""}],"CAPSICUM":[{"def":"A genus of plants of many species, producing capsules or dry berries of various forms, which have an exceedingly pungent, biting taste, and when ground form the red of Cayenne pepper of commerce.","pos":""}],"CAPSIZE":[{"def":"To upset or overturn, as a vessel or other body.","pos":""}],"CAPSQUARE":[{"def":"A metal covering plate which passes over the trunnions of a cannon, and holds it in place.","pos":""}],"CAPSTAN":[{"def":"A vertical cleated drum or cylinder, revolving on an upright spindle, and surmounted by a drumhead with sockets for bars or levers.","pos":""}],"CAPSTONE":[{"def":"A fossil echinus of the genus Cannulus; -- so called from its supposed resemblance to a cap.","pos":""},{"def":"Of or pertaining to a capsule; having the nature of a capsula; hollow and fibrous.","pos":""}],"CAPSULE":[{"def":"a dry fruit or pod which is made up of several parts or carpels, and opens to discharge the seeds, as, the capsule of the poppy, the flax, the lily, etc.","pos":""},{"def":"A small cylindrical or spherical gelatinous envelope in which nauseous or acrid doses are inclosed to be swallowed.","pos":""}],"CAPSULITIS":[{"def":"Inflammation of a capsule, as that of the crystalline lens.","pos":""}],"CAPSULOTOMY":[{"def":"The incision of a capsule, esp.","pos":""}]}