{"FORFEIT":[{"def":"Injury; wrong; mischief.","pos":""},{"def":"A thing forfeit or forfeited; what is or may be taken from one in requital of a misdeed committed; that which is lost, or the right to which is alienated, by a crime, offense, neglect of duty, or breach of contract; hence, a fine; a mulct; a penalty; as, he who murders pays the forfeit of his life.","pos":""}],"FORFEITABLE":[{"def":"Liable to be forfeited; subject to forfeiture.","pos":""}],"FORFEITER":[{"def":"One who incurs a penalty of forfeiture.","pos":""}],"FORFEITURE":[{"def":"The act of forfeiting; the loss of some right, privilege, estate, honor, office, or effects, by an offense, crime, breach of condition, or other act.","pos":""},{"def":"That which is forfeited; a penalty; a fine or mulct.","pos":""}],"FORFEND":[{"def":"To prohibit; to forbid; to avert.","pos":""}],"FORFERED":[{"def":"Excessively alarmed; in great fear.","pos":""}],"FORFETE":[{"def":"To incur a penalty; to transgress.","pos":""}],"FORFEX":[{"def":"A pair of shears.","pos":""}],"FORFICATE":[{"def":"Deeply forked, as the tail of certain birds.","pos":""}],"FORFICULA":[{"def":"A genus of insects including the earwigs.","pos":""}]}