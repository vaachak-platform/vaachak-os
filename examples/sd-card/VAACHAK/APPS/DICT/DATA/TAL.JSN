{"TALAPOIN":[{"def":"A small African monkey (Cercopithecus, or Miopithecus, talapoin) -- called also melarhine.","pos":""}],"TALARIA":[{"def":"Small wings or winged shoes represented as fastened to the ankles, -- chiefly used as an attribute of Mercury.","pos":""}],"TALBOT":[{"def":"A sort of dog, noted for quick scent and eager pursuit of game.","pos":""}],"TALBOTYPE":[{"def":"Same as Calotype.","pos":""}],"TALC":[{"def":"A soft mineral of a soapy feel and a greenish, whitish, or grayish color, usually occurring in foliated masses.","pos":""},{"def":"Of or pertaining to talc; composed of, or resembling, talc.","pos":""}],"TALE":[{"def":"A count or declaration.","pos":""}],"TALEBEARER":[{"def":"One who officiously tells tales; one who impertinently or maliciously communicates intelligence, scandal, etc.","pos":""}],"TALEBEARING":[{"def":"Telling tales officiously.","pos":""}],"TALED":[{"def":"A kind of quadrangular piece of cloth put on by the Jews when repeating prayers in the synagogues.","pos":""}],"TALEFUL":[{"def":"Full of stories.","pos":""}],"TALEGALLA":[{"def":"A genus of Australian birds which includes the brush turkey.","pos":""}],"TALENT":[{"def":"Among the ancient Greeks, a weight and a denomination of money equal to 60 minæ or 6,000 drachmæ.","pos":""},{"def":"Among the Hebrews, a weight and denomination of money.","pos":""}],"TALENTED":[{"def":"Furnished with talents; possessing skill or talent; mentally gifted.","pos":""}],"TALES":[{"def":"Persons added to a jury, commonly from those in or about the courthouse, to make up any deficiency in the number of jurors regularly summoned, being like, or such as, the latter.","pos":""},{"def":"The writ by which such persons are summoned.","pos":""}],"TALESMAN":[{"def":"A person called to make up a deficiency in the number of jurors when a tales is awarded.","pos":""}],"TALETELLER":[{"def":"One who tells tales or stories, especially in a mischievous or officious manner; a talebearer; a telltale; a tattler.","pos":""}],"TALEWISE":[{"def":"In a way of a tale or story.","pos":""}],"TALIACOTIAN":[{"def":"See Tagliacotian.","pos":""}],"TALIATION":[{"def":"Just heav'n this taliation did decree.","pos":""}],"TALIPES":[{"def":"The deformity called clubfoot.","pos":""}],"TALIPOT":[{"def":"A beautiful tropical palm tree (Corypha umbraculifera), a native of Ceylon and the Malabar coast.","pos":""}],"TALISMAN":[{"def":"Of or pertaining to a talisman; having the properties of a talisman, or preservative against evils by occult influence; magical.","pos":""}],"TALK":[{"def":"To utter words; esp.","pos":""},{"def":"To confer; to reason; to consult.","pos":""}],"TALKATIVE":[{"def":"Given to much talking.","pos":""}],"TALKER":[{"def":"One who talks; especially, one who is noted for his power of conversing readily or agreeably; a conversationist.","pos":""},{"def":"A loquacious person, male or female; a prattler; a babbler; also, a boaster; a braggart; -- used in contempt or reproach.","pos":""}],"TALKING":[{"def":"That talks; able to utter words; as, a talking parrot.","pos":""},{"def":"Given to talk; loquacious.","pos":""}],"TALL":[{"def":"A certain rate or tax paid by barons, knights, and inferior tenants, toward the public expenses.","pos":""}],"TALLAGE":[{"def":"To lay an impost upon; to cause to pay tallage.","pos":""}],"TALLBOY":[{"def":"A kind of long-stemmed wineglass or cup.","pos":""},{"def":"A piece of household furniture common in the eighteenth century, usually in two separate parts, with larger drawers above and smaller ones below and raised on legs fifteen inches or more in height; -- called also highboy.","pos":""}],"TALLIER":[{"def":"One who keeps tally.","pos":""}],"TALLIS":[{"def":"Same as Tallith.","pos":""}],"TALLNESS":[{"def":"The quality or state of being tall; height of stature.","pos":""}],"TALLOW":[{"def":"The suet or fat of animals of the sheep and ox kinds, separated from membranous and fibrous matter by melting.","pos":""},{"def":"The fat of some other animals, or the fat obtained from certain plants, or from other sources, resembling the fat of animals of the sheep and ox kinds.","pos":""}],"TALLOW-FACE":[{"def":"One who has a sickly, pale complexion.","pos":""}],"TALLOW-FACED":[{"def":"Having a sickly complexion; pale.","pos":""}],"TALLOWER":[{"def":"An animal which produces tallow.","pos":""}],"TALLOWING":[{"def":"The act, or art, of causing animals to produce tallow; also, the property in animals of producing tallow.","pos":""}],"TALLOWISH":[{"def":"Having the qualities of tallow.","pos":""}],"TALLOWY":[{"def":"Of the nature of tallow; resembling tallow; greasy.","pos":""}],"TALLWOOD":[{"def":"Firewood cut into billets of a certain length.","pos":""}],"TALLY":[{"def":"Originally, a piece of wood on which notches or scores were cut, as the marks of number; later, one of two books, sheets of paper, etc.","pos":""},{"def":"Hence, any account or score kept by notches or marks, whether on wood or paper, or in a book; especially, one kept in duplicate.","pos":""}],"TALLYHO":[{"def":"The huntsman's cry to incite or urge on his hounds.","pos":""},{"def":"A tallyho coach.","pos":""}],"TALLYMAN":[{"def":"One who keeps the tally, or marks the sticks.","pos":""},{"def":"One who keeps a tally shop, or conducts his business as tally trade.","pos":""}],"TALMUD":[{"def":"The body of the Jewish civil and canonical law not comprised in the Pentateuch.","pos":""},{"def":"Of or pertaining to the Talmud; contained in the Talmud; as, Talmudic Greek; Talmudical phrases.","pos":""}],"TALMUDISM":[{"def":"The teachings of the Talmud, or adherence to them.","pos":""}],"TALMUDIST":[{"def":"One versed in the Talmud; one who adheres to the teachings of the Talmud.","pos":""}],"TALMUDISTIC":[{"def":"Resembling the Talmud; Talmudic.","pos":""}],"TALON":[{"def":"One of certain small prominences on the hind part of the face of an elephant's tooth.","pos":""},{"def":"A kind of molding, concave at the bottom and convex at the top; -- usually called an ogee.","pos":""}],"TALPA":[{"def":"A genus of small insectivores including the common European mole.","pos":""}],"TALUS":[{"def":"A variety of clubfoot (Talipes calcaneus).","pos":""}]}