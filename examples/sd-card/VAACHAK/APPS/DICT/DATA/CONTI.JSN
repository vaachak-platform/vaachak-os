{"CONTIGNATION":[{"def":"The act or process of framing together, or uniting, as beams in a fabric.","pos":""},{"def":"A framework or fabric, as of beams.","pos":""}],"CONTIGUATE":[{"def":"Contiguous; touching.","pos":""}],"CONTIGUITY":[{"def":"The state of being contiguous; intimate association; nearness; proximity.","pos":""}],"CONTIGUOUS":[{"def":"In actual contact; touching; also, adjacent; near; neighboring; adjoining.","pos":""}],"CONTINENT":[{"def":"Serving to restrain or limit; restraining; opposing.","pos":""},{"def":"Exercising restraint as to the indulgence of desires or passions; temperate; moderate.","pos":""}],"CONTINENTAL":[{"def":"Of or pertaining to the confederated colonies collectively, in the time of the Revolutionary War; as, Continental money.","pos":""}],"CONTINENTAL DRIVE":[{"def":"A transmission arrangement in which the longitudinal crank shaft drives the rear wheels through a clutch, change-speed gear, countershaft, and two parallel side chains, in order.","pos":""}],"CONTINENTAL GLACIER":[{"def":"A broad ice sheet resting on a plain or plateau and spreading outward from a central névé, or region of accumulation.","pos":""}],"CONTINENTAL PRONUNCIATION":[{"def":"A method of pronouncing Latin and Greek in which the vowels have their more familiar Continental values, as in German and Italian, the consonants being pronounced mostly as in English.","pos":""}],"CONTINENTAL SYSTEM":[{"def":"The system of commercial blockade aiming to exclude England from commerce with the Continent instituted by the Berlin decree, which Napoleon I.","pos":""}],"CONTINENTLY":[{"def":"In a continent manner; chastely; moderately; temperately.","pos":""}],"CONTINGENCE":[{"def":"See Contingency.","pos":""}],"CONTINGENCY":[{"def":"A certain possible event that may or may not happen, by which, when happening, some particular title may be affected.","pos":""}],"CONTINGENT":[{"def":"Dependent for effect on something that may or may not occur; as, a contingent estate.","pos":""}],"CONTINGENTLY":[{"def":"In a contingent manner; without design or foresight; accidentally.","pos":""}],"CONTINGENTNESS":[{"def":"The state of being contingent; fortuitousness.","pos":""}],"CONTINUABLE":[{"def":"Capable of being continued [R.","pos":""}],"CONTINUAL":[{"def":"Proceeding without interruption or cesstaion; continuous; unceasing; lasting; abiding.","pos":""},{"def":"Occuring in steady and rapid succession; very frequent; often repeated.","pos":""}],"CONTINUALLY":[{"def":"Without cessation; unceasingly; continuously; as, the current flows continually.","pos":""},{"def":"In regular or repeated succession; very often.","pos":""}],"CONTINUANCE":[{"def":"A holding on, or remaining in a particular state; permanence, as of condition, habits, abode, etc.","pos":""},{"def":"Uninterrupted succession; continuation; constant renewell; perpetuation; propagation.","pos":""}],"CONTINUANT":[{"def":"Continuing; prolonged; sustained; as, a continuant sound.","pos":""},{"def":"A continuant sound; a letter whose sound may be prolonged.","pos":""}],"CONTINUATE":[{"def":"Immediately united together; intimately connocted.","pos":""},{"def":"Uninterrupted; unbroken; continual; continued.","pos":""}],"CONTINUATION":[{"def":"That act or state of continuing; the state of being continued; uninterrupted extension or succession; prolongation; propagation.","pos":""},{"def":"That which extends, increases, supplements, or carries on; as, the continuation of a story.","pos":""}],"CONTINUATIVE":[{"def":"A term or expression denoting continuance.","pos":""},{"def":"A word that continues the connection of sentences or subjects; a connective; a conjunction.","pos":""}],"CONTINUATOR":[{"def":"One who, or that which, continues; esp.","pos":""}],"CONTINUE":[{"def":"To remain ina given place or condition; to remain in connection with; to abide; to stay.","pos":""},{"def":"To be permanent or durable; to endure; to last.","pos":""}],"CONTINUED":[{"def":"Having extension of time, space, order of events, exertion of energy, etc.","pos":""}],"CONTINUEDLY":[{"def":"Con*tin\"u*ed*ly ( or , adv.","pos":""}],"CONTINUER":[{"def":"One who continues; one who has the power of perseverance or persistence.","pos":""}],"CONTINUITY":[{"def":"the state of being continuous; uninterupted connection or succession; close union of parts; cohesion; as, the continuity of fibers.","pos":""}],"CONTINUO":[{"def":"Basso continuo, or continued bass.","pos":""}],"CONTINUOUS":[{"def":"Not deviating or varying from uninformity; not interrupted; not joined or articulated.","pos":""}],"CONTINUOUSLY":[{"def":"In a continuous maner; without interruption.","pos":""}]}