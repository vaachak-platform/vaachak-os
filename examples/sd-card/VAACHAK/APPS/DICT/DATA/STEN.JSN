{"STENCH":[{"def":"A smell; an odor.","pos":""},{"def":"An ill smell; an offensive odor; a stink.","pos":""}],"STENCHY":[{"def":"Having a stench.","pos":""}],"STENCIL":[{"def":"A thin plate of metal, leather, or other material, used in painting, marking, etc.","pos":""}],"STENCILER":[{"def":"One who paints or colors in figures by means of stencil.","pos":""}],"STENODERM":[{"def":"Any species of bat belonging to the genus Stenoderma, native of the West Indies and South America.","pos":""}],"STENODERMINE":[{"def":"Of or pertaining to the genus Stenoderma, which includes several West Indian and South American nose-leaf bats.","pos":""}],"STENOGRAPH":[{"def":"To write or report in stenographic characters.","pos":""}],"STENOGRAPHER":[{"def":"One who is skilled in stenography; a writer of shorthand.","pos":""},{"def":"Of or pertaining to stenography.","pos":""}],"STENOGRAPHY":[{"def":"The art of writing in shorthand, by using abbreviations or characters for whole words; shorthand.","pos":""}],"STENOPHYLLOUS":[{"def":"Having narrow leaves.","pos":""}],"STENOSIS":[{"def":"A narrowing of the opening or hollow of any passage, tube, or orifice; as, stenosis of the pylorus.","pos":""}],"STENOSTOME":[{"def":"Having a small or narrow mouth; -- said of certain small ground snakes (Opoterodonta), which are unable to dilate their jaws.","pos":""}],"STENT":[{"def":"To keep within limits; to restain; to cause to stop, or cease; to stint.","pos":""}],"STENTING":[{"def":"An opening in a wall in a coal mine.","pos":""}],"STENTOR":[{"def":"Any species of ciliated Infusoria belonging to the genus Stentor and allied genera, common in fresh water.","pos":""},{"def":"A howling monkey, or howler.","pos":""}],"STENTORIAN":[{"def":"Of or pertaining to a stentor; extremely loud; powerful; as, a stentorian voice; stentorian lungs.","pos":""}],"STENTORIN":[{"def":"A blue coloring matter found in some stentors.","pos":""}],"STENTOROPHONIC":[{"def":"Speaking or sounding very loud; stentorian.","pos":""}]}