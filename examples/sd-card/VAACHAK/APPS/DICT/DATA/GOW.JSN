{"GOWAN":[{"def":"Decomposed granite.","pos":""}],"GOWANY":[{"def":"Having, abounding in, or decked with, daisies.","pos":""}],"GOWD":[{"def":"The man's the gowd for a' that.","pos":""}],"GOWDNOOK":[{"def":"The saury pike; -- called also gofnick.","pos":""}],"GOWK":[{"def":"To make a, booby of one); to stupefy.","pos":""}],"GOWN":[{"def":"A loose, flowing upper garment; especially: (a) The ordinary outer dress of a woman; as, a calico or silk gown.","pos":""},{"def":"Any sort of dress or garb.","pos":""}],"GOWNED":[{"def":"Dressed in a gown; clad.","pos":""},{"def":"One whose professional habit is a gown, as a divine or lawyer, and particularly a member of an English university; hence, a civilian, in distinction from a soldier.","pos":""}]}