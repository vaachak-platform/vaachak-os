{"ENCAGE":[{"def":"To confine in a cage; to coop up.","pos":""}],"ENCALENDAR":[{"def":"To register in a calendar; to calendar.","pos":""}],"ENCAMP":[{"def":"To form and occupy a camp; to prepare and settle in temporary habitations, as tents or huts; to halt on a march, pitch tents, or form huts, and remain for the night or for a longer time, as an army or a company traveling.","pos":""}],"ENCAMPMENT":[{"def":"The act of pitching tents or forming huts, as by an army or traveling company, for temporary lodging or rest.","pos":""},{"def":"The place where an army or a company is encamped; a camp; tents pitched or huts erected for temporary lodgings.","pos":""}],"ENCAPSULATION":[{"def":"The act of inclosing in a capsule; the growth of a membrane around (any part) so as to inclose it in a capsule.","pos":""}],"ENCARNALIZE":[{"def":"To carnalize; to make gross.","pos":""}],"ENCARPUS":[{"def":"An ornament on a frieze or capital, consisting of festoons of fruit, flowers, leaves, etc.","pos":""}],"ENCASE":[{"def":"To inclose as in a case.","pos":""}],"ENCASEMENT":[{"def":"An old theory of generation similar to emboOvulist.","pos":""}],"ENCASH":[{"def":"To turn into cash; to cash.","pos":""}],"ENCASHMENT":[{"def":"The payment in cash of a note, draft, etc.","pos":""}],"ENCAUMA":[{"def":"An ulcer in the eye, upon the cornea, which causes the loss of the humors.","pos":""}],"ENCAUSTIC":[{"def":"Prepared by means of heat; burned in.","pos":""}],"ENCAVE":[{"def":"To hide in, or as in, a cave or recess.","pos":""},{"def":"A noun suffix signifying action, state, or quality; also, that which relates to the action or state; as in emergence, diffidence, diligence, influence, difference, excellence.","pos":""}],"ENCEINTE":[{"def":"The line of works which forms the main inclosure of a fortress or place; -- called also body of the place.","pos":""}],"ENCENIA":[{"def":"A festival commemorative of the founding of a city or the consecration of a church; also, the ceremonies (as at Oxford and Cambridge, England) commemorative of founders or benefactors.","pos":""}],"ENCENSE":[{"def":"To offer incense to or upon; to burn incense.","pos":""}],"ENCEPHALIC":[{"def":"Pertaining to the encephalon or brain.","pos":""}],"ENCEPHALITIS":[{"def":"Inflammation of the brain.","pos":""}],"ENCEPHALOCELE":[{"def":"Hernia of the brain.","pos":""}],"ENCEPHALOID":[{"def":"Resembling the material of the brain; cerebriform.","pos":""}],"ENCEPHALOLOGY":[{"def":"The science which treats of the brain, its structure and functions.","pos":""}],"ENCEPHALON":[{"def":"The contents of the cranium; the brain.","pos":""}],"ENCEPHALOPATHY":[{"def":"Any disease or symptoms of disease referable to disorders of the brain; as, lead encephalopathy, the cerebral symptoms attending chronic lead poisoning.","pos":""}],"ENCEPHALOS":[{"def":"In man the encephalos reaches its full size about seven years of age.","pos":""}],"ENCEPHALOTOMY":[{"def":"The act or art of dissecting the brain.","pos":""}],"ENCEPHALOUS":[{"def":"Having a head; -- said of most Mollusca; -- opposed to acephalous.","pos":""}],"ENCHAFE":[{"def":"To chafe; to enrage; to heat.","pos":""}],"ENCHAFING":[{"def":"Heating; burning.","pos":""}],"ENCHAIN":[{"def":"To bind with a chain; to hold in chains.","pos":""},{"def":"To hold fast; to confine; as, to enchain attention.","pos":""}],"ENCHAINMENT":[{"def":"The act of enchaining, or state of being enchained.","pos":""}],"ENCHAIR":[{"def":"To seat in a chair.","pos":""}],"ENCHANNEL":[{"def":"To make run in a channel.","pos":""}],"ENCHANT":[{"def":"To charm by sorcery; to act on by enchantment; to get control of by magical words and rites.","pos":""},{"def":"To delight in a high degree; to charm; to enrapture; as, music enchants the ear.","pos":""}],"ENCHANTED":[{"def":"Under the power of enchantment; possessed or exercised by enchanters; as, an enchanted castle.","pos":""}],"ENCHANTER":[{"def":"One who enchants; a sorcerer or magician; also, one who delights as by an enchantment.","pos":""}],"ENCHANTING":[{"def":"Having a power of enchantment; charming; fascinating.","pos":""}],"ENCHANTMENT":[{"def":"The act of enchanting; the production of certain wonderful effects by the aid of demons, or the agency of supposed spirits; the use of magic arts, spells, or charms; incantation.","pos":""},{"def":"The effect produced by the act; the state of being enchanted; as, to break an enchantment.","pos":""}],"ENCHANTRESS":[{"def":"A woman versed in magical arts; a sorceress; also, a woman who fascinates.","pos":""}],"ENCHARGE":[{"def":"To charge (with); to impose (a charge) upon.","pos":""}],"ENCHASE":[{"def":"To incase or inclose in a border or rim; to surround with an ornamental casing, as a gem with gold; to encircle; to inclose; to adorn.","pos":""},{"def":"To chase; to ornament by embossing or engraving; as, to enchase a watch case.","pos":""}],"ENCHASER":[{"def":"One who enchases.","pos":""}],"ENCHASTEN":[{"def":"Occasion, cause, or reason.","pos":""}],"ENCHEST":[{"def":"To inclose in a chest.","pos":""}],"ENCHIRIDION":[{"def":"Handbook; a manual of devotions.","pos":""}],"ENCHISEL":[{"def":"To cut with a chisel.","pos":""}],"ENCHODUS":[{"def":"A genus of extinct Cretaceous fishes; -- so named from their spear-shaped teeth.","pos":""}],"ENCHONDROMA":[{"def":"A cartilaginous tumor growing from the interior of a bone.","pos":""},{"def":"Belonging to, or used in, a country; native; domestic; popular; common; -- said especially of the written characters employed by the common people of ancient Egypt, in distinction from the hieroglyphics.","pos":""}],"ENCHYLEMMA":[{"def":"The basal substance of the cell nucleus; a hyaline or granular substance, more or less fluid during life, in which the other parts of the nucleus are imbedded.","pos":""}],"ENCHYMA":[{"def":"The primitive formative juice, from which the tissues, particularly the cellular tissue, are formed.","pos":""}],"ENCINCTURE":[{"def":"The vast encincture of that gloomy sea.","pos":""}],"ENCINDERED":[{"def":"Burnt to cinders.","pos":""}],"ENCIRCLE":[{"def":"To form a circle about; to inclose within a circle or ring; to surround; as, to encircle one in the arms; the army encircled the city.","pos":""}],"ENCIRCLET":[{"def":"A small circle; a ring.","pos":""}],"ENCLAVE":[{"def":"A tract of land or a territory inclosed within another territory of which it is independent.","pos":""}],"ENCLAVEMENT":[{"def":"The state of being an enclave.","pos":""},{"def":"Affixed; subjoined; -- said of a word or particle which leans back upon the preceding word so as to become a part of it, and to lose its own independent accent, generally varying also the accent of the preceding word.","pos":""}],"ENCLITIC":[{"def":"A word which is joined to another so closely as to lose its proper accent, as the pronoun thee in prithee (pray thee).","pos":""}],"ENCLITICALLY":[{"def":"In an enclitic manner; by throwing the accent back.","pos":""}],"ENCLITICS":[{"def":"The art of declining and conjugating words.","pos":""}],"ENCLOISTER":[{"def":"To shut up in a cloister; to cloister.","pos":""}],"ENCLOSURE":[{"def":"Note: The words enclose and enclosure are written indiscriminately enclose or inclose and enclosure or inclosure.","pos":""}],"ENCLOUD":[{"def":"To envelop in clouds; to cloud.","pos":""}],"ENCOACH":[{"def":"To carry in a coach.","pos":""}],"ENCOFFIN":[{"def":"To put in a coffin.","pos":""}],"ENCOLLAR":[{"def":"To furnish or surround with a collar.","pos":""}],"ENCOLURE":[{"def":"The neck of horse.","pos":""}],"ENCOMBERMENT":[{"def":"Hindrance; molestation.","pos":""}],"ENCOMIAST":[{"def":"One who praises; a panegyrist.","pos":""},{"def":"Bestowing praise; praising; eulogistic; laudatory; as, an encomiastic address or discourse.","pos":""}],"ENCOMION":[{"def":"Encomium; panegyric.","pos":""}],"ENCOMIUM":[{"def":"Warm or high praise; panegyric; strong commendation.","pos":""}],"ENCOMPASS":[{"def":"To circumscribe or go round so as to surround closely; to encircle; to inclose; to environ; as, a ring encompasses the finger; an army encompasses a city; a voyage encompassing the world.","pos":""}],"ENCOMPASSMENT":[{"def":"The act of surrounding, or the state of being surrounded; circumvention.","pos":""}],"ENCORE":[{"def":"Once more; again; -- used by the auditors and spectators of plays, concerts, and other entertainments, to call for a repetition of a particular part.","pos":""}],"ENCOUBERT":[{"def":"One of several species of armadillos of the genera Dasypus and Euphractus, having five toes both on the fore and hind feet.","pos":""}],"ENCOUNTER":[{"def":"Then certain philosophers of the Epicureans, and of the Stoics, encountered him.","pos":""}],"ENCOUNTERER":[{"def":"One who encounters; an opponent; an antagonist.","pos":""}],"ENCOURAGE":[{"def":"To give courage to; to inspire with courage, spirit, or hope; to raise, or to increase, the confidence of; to animate; enhearten; to incite; to help forward; -- the opposite of discourage.","pos":""}],"ENCOURAGEMENT":[{"def":"The act of encouraging; incitement to action or to practice; as, the encouragement of youth in generosity.","pos":""},{"def":"That which serves to incite, support, promote, or advance, as favor, countenance, reward, etc.","pos":""}],"ENCOURAGER":[{"def":"One who encourages, incites, or helps forward; a favorer.","pos":""}],"ENCOURAGING":[{"def":"Furnishing ground to hope; inspiriting; favoring.","pos":""}],"ENCOWL":[{"def":"To make a monk (or wearer of a cowl) of.","pos":""}],"ENCRADLE":[{"def":"To lay in a cradle.","pos":""}],"ENCRATITE":[{"def":"One of a sect in the 2d century who abstained from marriage, wine, and animal food; -- called also Continent.","pos":""}],"ENCRIMSON":[{"def":"To give a crimson or red color to; to crimson.","pos":""},{"def":"Relating to encrinites; containing encrinites, as certain kinds of limestone.","pos":""}],"ENCRINITE":[{"def":"A fossil crinoid, esp.","pos":""},{"def":"Pertaining to encrinites; encrinal.","pos":""}],"ENCRINOIDEA":[{"def":"That order of the Crinoidea which includes most of the living and many fossil forms, having jointed arms around the margin of the oral disk; -- also called Brachiata and Articulata.","pos":""}],"ENCRINUS":[{"def":"A genus of fossil encrinoidea, from the Mesozoic rocks.","pos":""}],"ENCROACH":[{"def":"To enter by gradual steps or by stealth into the possessions or rights of another; to trespass; to intrude; to trench; -- commonly with on or upon; as, to encroach on a neighbor; to encroach on the highway.","pos":""}],"ENCROACHER":[{"def":"One who by gradual steps enters on, and takes possession of, what is not his own.","pos":""}],"ENCROACHINGLY":[{"def":"By way of encroachment.","pos":""}],"ENCROACHMENT":[{"def":"An unlawful diminution of the possessions of another.","pos":""}],"ENCRUSTMENT":[{"def":"That which is formed as a crust; incrustment; incrustation.","pos":""}],"ENCUMBER":[{"def":"To impede the motion or action of, as with a burden; to retard with something superfluous; to weigh down; to obstruct or embarrass; as, his movements were encumbered by his mantle; his mind is encumbered with useless learning.","pos":""},{"def":"To load with debts, or other legal claims; as, to encumber an estate with mortgages.","pos":""}],"ENCUMBRANCE":[{"def":"Same as Incumbrance.","pos":""}],"ENCUMBRANCER":[{"def":"Same as Incumbrancer.","pos":""}],"ENCURTAIN":[{"def":"To inclose with curtains.","pos":""},{"def":"A noun suffix having much the same meaning as -ence, but more commonly signifying the quality or state; as, emergency, efficiency.","pos":""}],"ENCYCLOPEDIACAL":[{"def":"En*cy`clo*pe*di\"a*cal, a.","pos":""}],"ENCYCLOPEDIAN":[{"def":"Embracing the whole circle of learning, or a wide range of subjects.","pos":""},{"def":"Pertaining to, or of the nature of, an encyclopedia; embracing a wide range of subjects.","pos":""}],"ENCYCLOPEDISM":[{"def":"The art of writing or compiling encyclopedias; also, possession of the whole range of knowledge; encyclopedic learning.","pos":""}],"ENCYCLOPEDIST":[{"def":"The compiler of an encyclopedia, or one who assists in such compilation; also, one whose knowledge embraces the whole range of the sciences.","pos":""}],"ENCYST":[{"def":"To inclose in a cyst.","pos":""}],"ENCYSTED":[{"def":"Inclosed in a cyst, or a sac, bladder, or vesicle; as, an encysted tumor.","pos":""}],"ENCYSTMENT":[{"def":"A process which, among some of the lower forms of life, precedes reproduction by budding, fission, spore formation, etc.","pos":""},{"def":"A process by which many internal parasites, esp.","pos":""}]}