{"SUBHASTATION":[{"def":"A public sale or auction.","pos":""}],"SUBHEPATIC":[{"def":"Situated under, or on the ventral side of, the liver; -- applied to the interlobular branches of the portal vein.","pos":""}],"SUBHORNBLENDIC":[{"def":"Containing hornblende in a scattered state; of or relating to rocks containing disseminated hornblende.","pos":""}],"SUBHUMERATE":[{"def":"To place the shoulders under; to bear.","pos":""}],"SUBHYALOID":[{"def":"Situated under the hyaliod membrane.","pos":""}],"SUBHYOIDEAN":[{"def":"Situated or performed beneath the hyoid bone; as, subhyoidean laryngotomy.","pos":""}]}