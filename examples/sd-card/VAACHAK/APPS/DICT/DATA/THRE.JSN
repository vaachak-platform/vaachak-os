{"THREAD":[{"def":"A very small twist of flax, wool, cotton, silk, or other fibrous substance, drawn out to considerable length; a compound cord consisting of two or more single yarns doubled, or joined together, and twisted.","pos":""},{"def":"A filament, as of a flower, or of any fibrous substance, as of bark; also, a line of gold or silver.","pos":""}],"THREAD-SHAPED":[{"def":"Having the form of a thread; filiform.","pos":""}],"THREADBARE":[{"def":"Worn to the naked thread; having the nap worn off; threadbare clothes.","pos":""}],"THREADBARENESS":[{"def":"The state of being threadbare.","pos":""}],"THREADEN":[{"def":"Made of thread; as, threaden sails; a threaden fillet.","pos":""}],"THREADER":[{"def":"A device for assisting in threading a needle.","pos":""},{"def":"A tool or machine for forming a thread on a screw or in a nut.","pos":""}],"THREADFIN":[{"def":"Any one of several species of fishes belonging to Polynemus and allied genera.","pos":""}],"THREADINESS":[{"def":"Quality of being thready.","pos":""}],"THREADWORM":[{"def":"Any long, slender nematode worm, especially the pinworm and filaria.","pos":""}],"THREADY":[{"def":"Like thread or filaments; slender; as, the thready roots of a shrub.","pos":""},{"def":"Containing, or consisting of, thread.","pos":""}],"THREAP":[{"def":"To call; to name.","pos":""},{"def":"To maintain obstinately against denial or contradiction; also, to contend or argue against (another) with obstinacy; to chide; as, he threaped me down that it was so.","pos":""}],"THREAT":[{"def":"The expression of an intention to inflict evil or injury on another; the declaration of an evil, loss, or pain to come; meance; threatening; denunciation.","pos":""}],"THREATEN":[{"def":"To utter threats against; to menace; to inspire with apprehension; to alarm, or attempt to alarm, as with the promise of something evil or disagreeable; to warn.","pos":""},{"def":"To exhibit the appearance of (something evil or unpleasant) as approaching; to indicate as impending; to announce the conditional infliction of; as, to threaten war; to threaten death.","pos":""}],"THREATENER":[{"def":"One who threatens.","pos":""}],"THREATENING":[{"def":"Threat\"en*ing, Defn: a.","pos":""}],"THREATFUL":[{"def":"Full of threats; having a menacing appearance.","pos":""}],"THREE":[{"def":"One more than two; two and one.","pos":""}],"THREE-COAT":[{"def":"Having or consisting of three coats; -- applied to plastering which consists of pricking-up, floating, and a finishing coat; or, as called in the United States, a scratch coat, browning, and finishing coat.","pos":""}],"THREE-COLOR":[{"def":"Designating, or pert.","pos":""}],"THREE-CORNERED":[{"def":"Having three prominent longitudinal angles; as, a three- cornered stem.","pos":""}],"THREE-DECKER":[{"def":"A vessel of war carrying guns on three decks.","pos":""}],"THREE-FLOWERED":[{"def":"Bearing three flowers together, or only three flowers.","pos":""}],"THREE-HANDED":[{"def":"Said of games or contests where three persons play against each other, or two against one; as, a three-handed game of cards.","pos":""}],"THREE-LOBED":[{"def":"Having three lobes.","pos":""}],"THREE-MILE":[{"def":"Of or pertaining to three miles; as, the three-mile limit, or the limit of the marine belt (the three-mile belt or zone) of three miles included in territorial waters (which see) of a state.","pos":""}],"THREE-NERVED":[{"def":"Having three nerves.","pos":""}],"THREE-PARTED":[{"def":"Divided into, or consisting of, three parts; tripartite.","pos":""}],"THREE-PILE":[{"def":"An old name for the finest and most costly kind of velvet, having a fine, thick pile.","pos":""}],"THREE-PILED":[{"def":"Having the quality of three-pile; best; most costly.","pos":""}],"THREE-PLY":[{"def":"Consisting of three distinct webs inwrought together in weaving, as cloth or carpeting; having three strands; threefold.","pos":""}],"THREE-POINTED":[{"def":"Having three acute or setigerous points; tricuspidate.","pos":""}],"THREE-PORT":[{"def":"Having three ports; specif.","pos":""}],"THREE-QUARTER":[{"def":"Measuring thirty inches by twenty-five; -- said of portraitures.","pos":""}],"THREE-SCORE":[{"def":"Thrice twenty; sixty.","pos":""}],"THREE-SIDED":[{"def":"Having three sides, especially three plane sides; as, a three- sided stem, leaf, petiole, peduncle, scape, or pericarp.","pos":""}],"THREE-SQUARE":[{"def":"Having a cross section in the form of an equilateral triangle; -- said especially of a kind of file.","pos":""},{"def":"Any system of rudders by which the pilot can exert a turning moment about each of the three rectangular axes of an aëroplane or airship.","pos":""}],"THREE-VALVED":[{"def":"Consisting of, or having, three valves; opening with three valves; as, a three-valved pericarp.","pos":""}],"THREE-WAY":[{"def":"Connected with, or serving to connect, three channels or pipes; as, a three-way cock or valve.","pos":""}],"THREEFOLD":[{"def":"Consisting of three, or thrice repeated; triple; as, threefold justice.","pos":""}],"THREEPENCE":[{"def":"A small silver coin of three times the value of a penny.","pos":""}],"THREEPENNY":[{"def":"Costing or worth three pence; hence, worth but little; poor; mean.","pos":""}],"THRENE":[{"def":"Lamentation; threnody; a dirge.","pos":""},{"def":"Pertaining to a threne; sorrowful; mournful.","pos":""}],"THRENODE":[{"def":"A threne, or threnody; a dirge; a funeral song.","pos":""}],"THRENODIST":[{"def":"One who composes, delivers, or utters, a threnode, or threnody.","pos":""}],"THRENODY":[{"def":"A song of lamentation; a threnode.","pos":""}],"THREPE":[{"def":"To call; to term.","pos":""}],"THREPSOLOGY":[{"def":"The doctrine of nutrition; a treatise on nutrition.","pos":""}],"THRESH":[{"def":"He would thresh, and thereto dike and delve.","pos":""}],"THRESHER":[{"def":"Same as Thrasher.","pos":""}],"THRESHOLD":[{"def":"The plank, stone, or piece of timber, which lies under a door, especially of a dwelling house, church, temple, or the like; the doorsill; hence, entrance; gate; door.","pos":""}]}