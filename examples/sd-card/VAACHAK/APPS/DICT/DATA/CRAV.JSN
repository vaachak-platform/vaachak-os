{"CRAVAT":[{"def":"A neckcloth; a piece of silk, fine muslin, or other cloth, worn by men about the neck.","pos":""}],"CRAVATTED":[{"def":"Wearing a cravat.","pos":""}],"CRAVE":[{"def":"To ask with earnestness or importunity; to ask with submission or humility; to beg; to entreat; to beseech; to implore.","pos":""},{"def":"To call for, as a gratification; to long for; hence, to require or demand; as, the stomach craves food.","pos":""}],"CRAVEN":[{"def":"Cowardly; fainthearted; spiritless.","pos":""}],"CRAVER":[{"def":"One who craves or begs.","pos":""}],"CRAVING":[{"def":"Vehement or urgent desire; longing for; beseeching.","pos":""}]}