{"MONOGAM":[{"def":"One of the Monogamia.","pos":""}],"MONOGAMIA":[{"def":"A Linnæan order of plants, having solitary flowers with united anthers, as in the genus Lobelia.","pos":""},{"def":"Of or pertaining to the Monogamia; having a simple flower with united anthers.","pos":""}],"MONOGAMIST":[{"def":"One who practices or upholds monogamy.","pos":""}],"MONOGAMOUS":[{"def":"Same as Monogamian.","pos":""},{"def":"Mating with but one of the opposite sex; -- said of birds and mammals.","pos":""}],"MONOGAMY":[{"def":"State of being paired with a single mate.","pos":""}],"MONOGASTRIC":[{"def":"Having but a single stomach.","pos":""}],"MONOGENESIS":[{"def":"That form of reproduction which requires but one parent, as in reproduction by fission or in the formation of buds, etc.","pos":""},{"def":"The direct development of an embryo, without metamorphosis, into an organism similar to the parent organism; -- opposed to metagenesis.","pos":""}],"MONOGENETIC":[{"def":"One in genesis; resulting from one process of formation; -- used of a mountain range.","pos":""},{"def":"Relating to, or involving, monogenesis; as, the monogenetic school of physiologists, who admit but one cell as the source of all beings.","pos":""}],"MONOGENIC":[{"def":"Of or pertaining to monogenesis.","pos":""},{"def":"Producing only one kind of germs, or young; developing only in one way.","pos":""}],"MONOGENISM":[{"def":"The theory or doctrine that the human races have a common origin, or constitute a single species.","pos":""}],"MONOGENIST":[{"def":"One who maintains that the human races are all of one species; -- opposed to polygenist.","pos":""}],"MONOGENOUS":[{"def":"Of or pertaining to monogenesis; as, monogenous, or asexual, reproduction.","pos":""}],"MONOGENY":[{"def":"The doctrine that the members of the human race have all a common origin.","pos":""}],"MONOGONEUTIC":[{"def":"Having but one brood in a season.","pos":""}],"MONOGRAM":[{"def":"A character or cipher composed of two or more letters interwoven or combined so as to represent a name, or a part of it (usually the initials).","pos":""},{"def":"A picture in lines; a sketch.","pos":""}],"MONOGRAMMAL":[{"def":"See Monogrammic.","pos":""}],"MONOGRAMMIC":[{"def":"Of, pertaining to, or resembling, a monogram.","pos":""}],"MONOGRAPH":[{"def":"A written account or description of a single thing, or class of things; a special treatise on a particular subject of limited range.","pos":""}],"MONOGRAPHER":[{"def":"A writer of a monograph.","pos":""},{"def":"Of or pertaining to a monograph, or to a monography; as, a monographic writing; a monographic picture.","pos":""}],"MONOGRAPHIST":[{"def":"One who writes a monograph.","pos":""}],"MONOGRAPHY":[{"def":"Representation by lines without color; an outline drawing.","pos":""}],"MONOGYN":[{"def":"One of the Monogynia.","pos":""}],"MONOGYNIA":[{"def":"A Linnæan order of plants, including those which have only one style or stigma.","pos":""}],"MONOGYNIAN":[{"def":"Pertaining to the Monogynia; monogynous.","pos":""},{"def":"One of the Monogynia.","pos":""}],"MONOGYNOUS":[{"def":"Of or pertaining to Monogynia; having only one style or stigma.","pos":""}],"MONOGYNY":[{"def":"The state or condition of being monogynous.","pos":""}]}