{"SALVABILITY":[{"def":"The quality or condition of being salvable; salvableness.","pos":""}],"SALVABLE":[{"def":"Capable of being saved; admitting of salvation.","pos":""}],"SALVAGE":[{"def":"The act of saving a vessel, goods, or life, goods, or life, from perils of the sea.","pos":""}],"SALVATION":[{"def":"The redemption of man from the bondage of sin and liability to eternal death, and the conferring on him of everlasting happiness.","pos":""}],"SALVATIONIST":[{"def":"An evangelist, a member, or a recruit, of the Salvation Army.","pos":""}],"SALVATORY":[{"def":"A place where things are preserved; a repository.","pos":""}],"SALVE":[{"def":"To say \"Salve\" to; to greet; to salute.","pos":""}],"SALVER":[{"def":"One who salves, or uses salve as a remedy; hence, a quacksalver, or quack.","pos":""}],"SALVER-SHAPED":[{"def":"Tubular, with a speading border.","pos":""}],"SALVIA":[{"def":"A genus of plants including the sage.","pos":""}],"SALVIFIC":[{"def":"Tending to save or secure safety.","pos":""}],"SALVO":[{"def":"An exception; a reservation; an excuse.","pos":""}],"SALVOR":[{"def":"One who assists in saving a ship or goods at sea, without being under special obligation to do so.","pos":""}]}