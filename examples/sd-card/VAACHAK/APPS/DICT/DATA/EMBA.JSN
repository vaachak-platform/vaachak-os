{"EMBALE":[{"def":"To make up into a bale or pack.","pos":""},{"def":"To bind up; to inclose.","pos":""}],"EMBALL":[{"def":"To encircle or embrace.","pos":""}],"EMBALM":[{"def":"To anoint all over with balm; especially, to preserve from decay by means of balm or other aromatic oils, or spices; to fill or impregnate (a dead body), with aromatics and drugs that it may resist putrefaction.","pos":""},{"def":"To fill or imbue with sweet odor; to perfume.","pos":""}],"EMBALMER":[{"def":"One who embalms.","pos":""}],"EMBALMMENT":[{"def":"The act of embalming.","pos":""}],"EMBANK":[{"def":"To throw up a bank so as to confine or to defend; to protect by a bank of earth or stone.","pos":""}],"EMBANKMENT":[{"def":"The act of surrounding or defending with a bank.","pos":""},{"def":"A structure of earth, gravel, etc.","pos":""}],"EMBAR":[{"def":"To bar or shut in; to inclose securely, as with bars.","pos":""},{"def":"To stop; to hinder by prohibition; to block up.","pos":""}],"EMBARCATION":[{"def":"Same as Embarkation.","pos":""}],"EMBARGE":[{"def":"To put in a barge.","pos":""}],"EMBARGO":[{"def":"An edict or order of the government prohibiting the departure of ships of commerce from some or all of the ports within its dominions; a prohibition to sail.","pos":""}],"EMBARK":[{"def":"To cause to go on board a vessel or boat; to put on shipboard.","pos":""},{"def":"To engage, enlist, or invest (as persons, money, etc.","pos":""}],"EMBARKATION":[{"def":"The act of putting or going on board of a vessel; as, the embarkation of troops.","pos":""},{"def":"That which is embarked; as, an embarkation of Jesuits.","pos":""}],"EMBARRASS":[{"def":"To involve in difficulties concerning money matters; to incumber with debt; to beset with urgent claims or demands; -- said of a person or his affairs; as, a man or his business is embarrassed when he can not meet his pecuniary engagements.","pos":""}],"EMBARRASSMENT":[{"def":"A state of being embarrassed; perplexity; impediment to freedom of action; entanglement; hindrance; confusion or discomposure of mind, as from not knowing what to do or to say; disconcertedness.","pos":""},{"def":"Difficulty or perplexity arising from the want of money to pay debts.","pos":""}],"EMBASE":[{"def":"To bring down or lower, as in position, value, etc.","pos":""}],"EMBASEMENT":[{"def":"Act of bringing down; depravation; deterioration.","pos":""}],"EMBASSADOR":[{"def":"Same as Ambassador.","pos":""}],"EMBASSADORIAL":[{"def":"Same as Ambassadorial.","pos":""}],"EMBASSADRESS":[{"def":"Same as Ambassadress.","pos":""}],"EMBASSAGE":[{"def":"Message; errand.","pos":""}],"EMBASSY":[{"def":"The public function of an ambassador; the charge or business intrusted to an ambassador or to envoys; a public message to; foreign court concerning state affairs; hence, any solemn message.","pos":""},{"def":"The person or persons sent as ambassadors or envoys; the ambassador and his suite; envoys.","pos":""}],"EMBATHE":[{"def":"To bathe; to imbathe.","pos":""}],"EMBATTAIL":[{"def":"To furnish with battlements; to fortify as with battlements.","pos":""}],"EMBATTLE":[{"def":"To arrange in order of battle; to array for battle; also, to prepare or arm for battle; to equip as for battle.","pos":""}],"EMBATTLED":[{"def":"Having the edge broken like battlements; -- said of a bearing such as a fess, bend, or the like.","pos":""}],"EMBATTLEMENT":[{"def":"An intended parapet; a battlement.","pos":""},{"def":"The fortifying of a building or a wall by means of battlements.","pos":""}],"EMBAY":[{"def":"To bathe; to soothe or lull as by bathing.","pos":""}],"EMBAYMENT":[{"def":"The embayment which is terminated by the land of North Berwick.","pos":""}]}