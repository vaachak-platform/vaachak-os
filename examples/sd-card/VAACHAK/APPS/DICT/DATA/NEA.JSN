{"NEAL":[{"def":"To be tempered by heat.","pos":""},{"def":"Of, pertaining to, or named from, the Neanderthal, a valley in the Rhine Province, in which were found parts of a skeleton of an early type of man.","pos":""}],"NEANDERTHALOID":[{"def":"Like, or pertaining to, the Neanderthal skull, or the type of man it represents.","pos":""}],"NEAP":[{"def":"The tongue or pole of a cart or other vehicle drawn by two animals.","pos":""}],"NEAPED":[{"def":"Left aground on the height of a spring tide, so that it will not float till the next spring tide; -- called also beneaped.","pos":""}],"NEAPOLITAN":[{"def":"Of of pertaining to Maples in Italy.","pos":""},{"def":"A native or citizen of Naples.","pos":""}],"NEAR":[{"def":"At a little distance, in place, time, manner, or degree; not remote; nigh.","pos":""},{"def":"Nearly; almost; well-nigh.","pos":""}],"NEAR BEER":[{"def":"Any of various malt liquors (see Citation).","pos":""}],"NEAR-LEGGED":[{"def":"Having the feet so near together that they interfere in traveling.","pos":""}],"NEARCTIC":[{"def":"Of or pertaining to a region of the earth's surface including all of temperate and arctic North America and Greenland.","pos":""}],"NEARHAND":[{"def":"Near; near at hand; closely.","pos":""}],"NEARLY":[{"def":"In a near manner; not remotely; closely; intimately; almost.","pos":""}],"NEARNESS":[{"def":"The state or quality of being near; -- used in the various senses of the adjective.","pos":""},{"def":"Seeing distinctly at short distances only; shortsighted.","pos":""}],"NEAT":[{"def":"Cattle of the genus Bos, as distinguished from horses, sheep, and goats; an animal of the genus Bos; as, a neat's tongue; a neat's foot.","pos":""}],"NEATHERD":[{"def":"A person who has the care of neat cattle; a cowherd.","pos":""}],"NEATHOUSE":[{"def":"A building for the shelter of neat cattle.","pos":""}],"NEATLY":[{"def":"In a neat manner; tidily; tastefully.","pos":""}],"NEATNESS":[{"def":"The state or quality of being neat.","pos":""}],"NEATRESS":[{"def":"A woman who takes care of cattle.","pos":""}]}