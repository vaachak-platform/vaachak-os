{"AGIBLE":[{"def":"Possible to be done; practicable.","pos":""}],"AGILE":[{"def":"Having the faculty of quick motion in the limbs; apt or ready to move; nimble; active; as, an agile boy; an agile tongue.","pos":""}],"AGILELY":[{"def":"In an agile manner; nimbly.","pos":""}],"AGILENESS":[{"def":"Agility; nimbleness.","pos":""}],"AGILITY":[{"def":"The quality of being agile; the power of moving the limbs quickly and easily; nimbleness; activity; quickness of motion; as, strength and agility of body.","pos":""},{"def":"Activity; powerful agency.","pos":""}],"AGIO":[{"def":"The premium or percentage on a better sort of money when it is given in exchange for an inferior sort.","pos":""}],"AGIOTAGE":[{"def":"Exchange business; also, stockjobbing; the maneuvers of speculators to raise or lower the price of stocks or public funds.","pos":""}],"AGIST":[{"def":"To take to graze or pasture, at a certain sum; -- used originally of the feeding of cattle in the king's forests, and collecting the money for the same.","pos":""}],"AGISTATOR":[{"def":"AGISTER; AGISTOR A*gist\"er, A*gist\"or, n.","pos":""}],"AGITABLE":[{"def":"Capable of being agitated, or easily moved.","pos":""}],"AGITATE":[{"def":"To move with a violent, irregular action; as, the wind agitates the sea; to agitate water in a vessel.","pos":""},{"def":"To move or actuate.","pos":""}],"AGITATEDLY":[{"def":"In an agitated manner.","pos":""}],"AGITATION":[{"def":"The act of agitating, or the state of being agitated; the state of being moved with violence, or with irregular action; commotion; as, the sea after a storm is in agitation.","pos":""},{"def":"A stirring up or arousing; disturbance of tranquillity; disturbance of mind which shows itself by physical excitement; perturbation; as, to cause any one agitation.","pos":""}],"AGITATIVE":[{"def":"Tending to agitate.","pos":""}],"AGITATO":[{"def":"Sung or played in a restless, hurried, and spasmodic manner.","pos":""}],"AGITATOR":[{"def":"One of a body of men appointed by the army, in Cromwell's time, to look after their interests; -- called also adjutators.","pos":""}]}