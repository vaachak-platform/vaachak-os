{"CONSOCIATE":[{"def":"An associate; an accomplice.","pos":""}],"CONSOCIATION":[{"def":"Intimate union; fellowship; alliance; companionship; confederation; association; intimacy.","pos":""},{"def":"A voluntary and permanent council or union of neighboring Congregational churches, for mutual advice and co Note: In Connecticut some of the Congregational churhes are associated in consociations and the others in conferences.","pos":""}],"CONSOCIATIONAL":[{"def":"Of or pertaining to a consociation.","pos":""}],"CONSOL":[{"def":"A consolidated annuity (see Consols); -- chiefly in combination or attributively.","pos":""}],"CONSOLABLE":[{"def":"Capable of receiving consolation.","pos":""}],"CONSOLATE":[{"def":"To console; to comfort.","pos":""}],"CONSOLATION":[{"def":"The act of consoling; the state of being consoled; allevation of misery or distress of mind; refreshment of spirit; comfort; that which consoles or comforts the spirit.","pos":""}],"CONSOLATO DEL MARE":[{"def":"A collection of maritime laws of disputed origin, supposed to have been first published at Barcelona early in the 14th century.","pos":""}],"CONSOLATOR":[{"def":"One who consoles or comforts.","pos":""}],"CONSOLATORY":[{"def":"Of a consoling or comforting nature.","pos":""}],"CONSOLE":[{"def":"To cheer in distress or depression; to alleviate the grief and raise the spirits of; to relieve; to comfort; to soothe.","pos":""}],"CONSOLER":[{"def":"One who gives consolation.","pos":""}],"CONSOLIDANT":[{"def":"Serving to unite or consolidate; having the quality of consolidating or making firm.","pos":""}],"CONSOLIDATE":[{"def":"Formed into a solid mass; made firm; consolidated.","pos":""}],"CONSOLIDATED":[{"def":"Having a small surface in proportion to bulk, as in the cactus.","pos":""}],"CONSOLIDATION":[{"def":"To organic cohesion of different circled in a flower; adnation.","pos":""},{"def":"The combination of several actions into one.","pos":""}],"CONSOLIDATIVE":[{"def":"Tending or having power to consolidate; healing.","pos":""}],"CONSOLING":[{"def":"Adapted to console or comfort; cheering; as, this is consoling news.","pos":""}],"CONSOLS":[{"def":"The leading British funded government security.","pos":""}],"CONSOMME":[{"def":"A clear soup or bouillion boiled down so as to be very rich.","pos":""},{"def":"Accord or agreement of sounds produced simultaneously, as a note with its third, fifth, and eighth.","pos":""}],"CONSONANT":[{"def":"harmonizing together; accordant; as, consonant tones, consonant chords.","pos":""}],"CONSONANTIZE":[{"def":"To change into, or use as, a consonant.","pos":""}],"CONSONANTLY":[{"def":"In a consonant, consistent, or congruous manner; agreeably.","pos":""}],"CONSONANTNESS":[{"def":"The quality or condition of being consonant, agreeable, or consistent.","pos":""}],"CONSONOUS":[{"def":"Agreeing in sound; symphonious.","pos":""}],"CONSOPIATION":[{"def":"The act of sleeping, or of lulling, to sleep.","pos":""}],"CONSOPITE":[{"def":"Lulled to sleep.","pos":""}],"CONSORT":[{"def":"A ship keeping company with another.","pos":""},{"def":"An assembly or association of persons; a company; a group; a combination.","pos":""}],"CONSORTABLE":[{"def":"Suitable for association or companionship.","pos":""}],"CONSORTION":[{"def":"Fellowship; association; companionship.","pos":""}],"CONSORTSHIP":[{"def":"The condition of a consort; fellowship; partnership.","pos":""}],"CONSOUND":[{"def":"A name applied loosely to several plants of different genera, esp.","pos":""}]}