{"EMBEAM":[{"def":"To make brilliant with beams.","pos":""}],"EMBED":[{"def":"To lay as in a bed; to lay in surrounding matter; to bed; as, to embed a thing in clay, mortar, or sand.","pos":""}],"EMBEDMENT":[{"def":"The act of embedding, or the state of being embedded.","pos":""}],"EMBELLISH":[{"def":"To make beautiful or elegant by ornaments; to decorate; to adorn; as, to embellish a book with pictures, a garden with shrubs and flowers, a narrative with striking anecdotes, or style with metaphors.","pos":""}],"EMBELLISHER":[{"def":"One who embellishes.","pos":""}],"EMBELLISHMENT":[{"def":"The act of adorning, or the state of being adorned; adornment.","pos":""},{"def":"That which adds beauty or elegance; ornament; decoration; as, pictorial embellishments.","pos":""}],"EMBER":[{"def":"A lighted coal, smoldering amid ashes; -- used chiefly in the plural, to signify mingled coals and ashes; the smoldering remains of a fire.","pos":""}],"EMBER-GOOSE":[{"def":"The loon or great northern diver.","pos":""}],"EMBERIZIDAE":[{"def":"a natural subfamily including buntings and some New World sparrows.","pos":""}],"EMBEZZLE":[{"def":"To appropriate fraudulently to one's own use, as property intrusted to one's care; to apply to one's private uses by a breach of trust; as, to embezzle money held in trust.","pos":""},{"def":"To misappropriate; to waste; to dissipate in extravagance.","pos":""}],"EMBEZZLEMENT":[{"def":"The fraudulent appropriation of property by a person to whom it has been intrusted; as, the embezzlement by a clerk of his employer's; embezzlement of public funds by the public officer having them in charge.","pos":""}],"EMBEZZLER":[{"def":"One who embezzles.","pos":""}]}