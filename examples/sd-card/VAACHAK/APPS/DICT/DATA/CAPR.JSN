{"CAPRA":[{"def":"A genus of ruminants, including the common goat.","pos":""}],"CAPRATE":[{"def":"A salt of capric acid.","pos":""}],"CAPREOLATE":[{"def":"Having a tendril or tendrils.","pos":""}],"CAPREOLINE":[{"def":"Of or pertaining to the roebuck.","pos":""}],"CAPRI":[{"def":"Wine produced on the island of Capri, commonly a light, dry, white wine.","pos":""}],"CAPRIC":[{"def":"Of or pertaining to capric acid or its derivatives.","pos":""}],"CAPRICCIO":[{"def":"A piece in a free form, with frequent digressions from the theme; a fantasia; -- often called caprice.","pos":""}],"CAPRICE":[{"def":"In a free, fantastic style.","pos":""}],"CAPRICIOUS":[{"def":"Governed or characterized by caprice; apt to change suddenly; freakish; whimsical; changeable.","pos":""}],"CAPRICORN":[{"def":"The tenth sign of zodiac, into which the sun enters at the winter solstice, about December 21.","pos":""},{"def":"A southern constellation, represented on ancient monuments by the figure of a goat, or a figure with its fore part like a fish.","pos":""}],"CAPRID":[{"def":"Of or pertaining to the tribe of ruminants of which the goat, or genus Capra, is the type.","pos":""}],"CAPRIFICATION":[{"def":"The practice of hanging, upon the cultivated fig tree, branches of the wild fig infested with minute hymenopterous insects.","pos":""}],"CAPRIFOLE":[{"def":"The woodbine or honeysuckle.","pos":""}],"CAPRIFOLIACEOUS":[{"def":"Of, pertaining to, or resembling, the Honeysuckle family of plants (Caprifoliacæ.","pos":""}],"CAPRIFORM":[{"def":"Having the form of a goat.","pos":""}],"CAPRIGENOUS":[{"def":"Of the goat kind.","pos":""}],"CAPRINE":[{"def":"Of or pertaining to a goat; as, caprine gambols.","pos":""}],"CAPRIOLE":[{"def":"A leap that a horse makes with all fours, upwards only, without advancing, but with a kick or jerk of the hind legs when at the height of the leap.","pos":""}],"CAPRIPED":[{"def":"Having feet like those of a goat.","pos":""}],"CAPROATE":[{"def":"A salt of caproic acid.","pos":""}],"CAPROIC":[{"def":"See under Capric.","pos":""}],"CAPRYLATE":[{"def":"A salt of caprylic acid.","pos":""}],"CAPRYLIC":[{"def":"See under Capric.","pos":""}]}