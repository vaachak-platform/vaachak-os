{"YE":[{"def":"an old method of printing the article the (AS.","pos":""}],"YEA":[{"def":"Yes; ay; a word expressing assent, or an affirmative, or an affirmative answer to a question, now superseded by yes.","pos":""},{"def":"More than this; not only so, but; -- used to mark the addition of a more specific or more emphatic clause.","pos":""}],"YEAD":[{"def":"Properly, a variant of the defective imperfect yode, but sometimes mistaken for a present.","pos":""}],"YEAN":[{"def":"To bring forth young, as a goat or a sheep; to ean.","pos":""}],"YEANLING":[{"def":"A lamb or a kid; an eanling.","pos":""}],"YEAR":[{"def":"Age, or old age; as, a man in years.","pos":""}],"YEAR'S PURCHASE":[{"def":"The amount that is yielded by the annual income of property; -- used in expressing the value of a thing in the number of years required for its income to yield its purchase price, in reckoning the amount to be paid for annuities, etc.","pos":""}],"YEARA":[{"def":"The California poison oak (Rhus diversiloba).","pos":""}],"YEARBOOK":[{"def":"A book containing annual reports of cases adjudged in the courts of England.","pos":""}],"YEARED":[{"def":"Containing years; having existed or continued many years; aged.","pos":""}],"YEARLING":[{"def":"An animal one year old, or in the second year of its age; -- applied chiefly to cattle, sheep, and horses.","pos":""}],"YEARLY":[{"def":"Happening, accruing, or coming every year; annual; as, a yearly income; a yearly feast.","pos":""},{"def":"Lasting a year; as, a yearly plant.","pos":""}],"YEARN":[{"def":"To pain; to grieve; to vex.","pos":""}],"YEARNINGS":[{"def":"The maws, or stomachs, of young calves, used a rennet for curdling milk.","pos":""}],"YEAST":[{"def":"A form of fungus which grows as indvidual rounded cells, rather than in a mycelium, and reproduces by budding; esp.","pos":""}],"YEAST-BITTEN":[{"def":"A term used of beer when the froth of the yeast has reëntered the body of the beer.","pos":""}],"YEASTINESS":[{"def":"The quality or state of being yeasty, or frothy.","pos":""}],"YEASTY":[{"def":"Frothy; foamy; spumy, like yeast.","pos":""}],"YEDDING":[{"def":"The song of a minstrel; hence, any song.","pos":""}],"YEDE":[{"def":"All as he bade fulfilled was indeed This ilke servant anon right out yede.","pos":""}],"YELDHALL":[{"def":"The yellow-hammer; -- called also yeldrock, and yoldrin.","pos":""}],"YELL":[{"def":"To cry out, or shriek, with a hideous noise; to cry or scream as with agony or horror.","pos":""}],"YELLOW":[{"def":"Being of a bright saffronlike color; of the color of gold or brass; having the hue of that part of the rainbow, or of the solar spectrum, which is between the orange and the green.","pos":""}],"YELLOW BOOK":[{"def":"In France, an official government publication bound in yellow covers.","pos":""}],"YELLOW-COVERED":[{"def":"Covered or bound in yellow paper.","pos":""}],"YELLOW-EYED":[{"def":"Having yellow eyes.","pos":""}],"YELLOW-GOLDS":[{"def":"A certain plant, probably the yellow oxeye.","pos":""}],"YELLOWAMMER":[{"def":"See Yellow-hammer.","pos":""}],"YELLOWBILL":[{"def":"The American scoter.","pos":""}],"YELLOWFIN":[{"def":"A large squeteague.","pos":""}],"YELLOWFISH":[{"def":"A rock trout (Pleurogrammus monopterygius) found on the coast of Alaska; -- called also striped fish, and Atka mackerel.","pos":""}],"YELLOWING":[{"def":"The act or process of making yellow.","pos":""}],"YELLOWISH":[{"def":"Somewhat yellow; as, amber is of a yellowish color.","pos":""}],"YELLOWLEGS":[{"def":"Any one of several species of long-legged sandpipers of the genus Totanus, in which the legs are bright yellow; -- called also stone snipe, tattler, telltale, yellowshanks; and yellowshins.","pos":""}],"YELLOWNESS":[{"def":"The quality or state of being yellow; as, the yellowness of an orange.","pos":""}],"YELLOWROOT":[{"def":"Any one of several plants with yellow roots.","pos":""}],"YELLOWS":[{"def":"A disease of the bile in horses, cattle, and sheep, causing yellowness of the eyes; jaundice.","pos":""},{"def":"A disease of plants, esp.","pos":""}],"YELLOWSEED":[{"def":"A kind of pepper grass (Lepidium campestre).","pos":""}],"YELLOWTAIL":[{"def":"Note: Several other fishes are also locally called yellowtail.","pos":""}],"YELLOWTHROAT":[{"def":"Any one of several species of American ground warblers of the genus Geothlypis, esp.","pos":""}],"YELLOWTOP":[{"def":"A kind of grass, perhaps a species of Agrostis.","pos":""}],"YELLOWWOOD":[{"def":"The wood of any one of several different kinds of trees; also, any one of the trees themselves.","pos":""}],"YELLOWWORT":[{"def":"A European yellow-flowered, gentianaceous (Chlora perfoliata).","pos":""}],"YELP":[{"def":"To utter a sharp, quick cry, as a hound; to bark shrilly with eagerness, pain, or fear; to yaup.","pos":""}],"YELPER":[{"def":"An animal that yelps, or makes a yelping noise.","pos":""}],"YELTING":[{"def":"The Florida and West Indian red snapper (Lutianus aya); also, sometimes, one of certain other allied species, as L.","pos":""}],"YEN":[{"def":"The unit of value and account in Japan.","pos":""}],"YEND":[{"def":"To throw; to cast.","pos":""}],"YENITE":[{"def":"A silicate of iron and lime occurring in black prismatic crystals; -- also called ilvaite.","pos":""}],"YEOMAN":[{"def":"An interior officer under the boatswain, gunner, or carpenters, charged with the stowage, account, and distribution of the stores.","pos":""}],"YEOMANLIKE":[{"def":"Resembling, or suitable to, a yeoman; yeomanly.","pos":""}],"YEOMANLY":[{"def":"Pertaining to a yeoman; becoming or suitable to, a yeoman; yeomanlike.","pos":""}],"YEOMANRY":[{"def":"The position or rank of a yeoman.","pos":""},{"def":"The collective body of yeomen, or freeholders.","pos":""}],"YEORLING":[{"def":"The European yellow-hammer.","pos":""}],"YERBA":[{"def":"An herb; a plant.","pos":""}],"YERD":[{"def":"See 1st & 2d Yard.","pos":""}],"YERK":[{"def":"To throw or thrust with a sudden, smart movement; to kick or strike suddenly; to jerk.","pos":""},{"def":"To strike or lash with a whip.","pos":""}],"YERN":[{"def":"Eager; brisk; quick; active.","pos":""}],"YERNE":[{"def":"Eagerly; briskly; quickly.","pos":""}],"YERNUT":[{"def":"An earthnut, or groundnut.","pos":""}],"YES":[{"def":"Ay; yea; -- a word which expresses affirmation or consent; -- opposed to Ant: no.","pos":""}],"YESTER":[{"def":"Last; last past; next before; of or pertaining to yesterday.","pos":""}],"YESTERDAY":[{"def":"The day last past; the day next before the present.","pos":""}],"YESTERN":[{"def":"Of or pertaining to yesterday; relating to the day last past.","pos":""}],"YESTERNIGHT":[{"def":"The last night; the night last past.","pos":""}],"YESTERNOON":[{"def":"The noon of yesterday; the noon last past.","pos":""}],"YESTERWEEK":[{"def":"The week last past; last week.","pos":""}],"YESTERYEAR":[{"def":"The year last past; last year.","pos":""}],"YESTREEN":[{"def":"Yester-evening; yesternight; last night.","pos":""}],"YET":[{"def":"Any one of several species of large marine gastropods belonging to the genus Yetus, or Cymba; a boat shell.","pos":""}],"YEW":[{"def":"An evergreen tree (Taxus baccata) of Europe, allied to the pines, but having a peculiar berrylike fruit instead of a cone.","pos":""}],"YEWEN":[{"def":"Made of yew; as, yewen bows.","pos":""}],"YEX":[{"def":"He yexeth and he speaketh through the nose.","pos":""}],"YEZDEGERDIAN":[{"def":"Of or pertaining to Yezdegerd, the last Sassanian monarch of Persia, who was overthrown by the Mohammedans; as, the Yezdegerdian era, which began on the 16th of June, a.","pos":""}],"YEZDI":[{"def":"YEZIDEE; YEZIDI Yez\"i*dee, Yez\"i*di, n.","pos":""}]}