{"CAR":[{"def":"The stars also called Charles's Wain, the Great Bear, or the Dipper.","pos":""}],"CAR MILE":[{"def":"A mile traveled by a single car, taken as a unit of computation, as in computing the average travel of each car of a system during a given period.","pos":""}],"CAR WHEEL":[{"def":"A flanged wheel of a railway car or truck.","pos":""},{"def":"Of or pertaining to a caryatid.","pos":""}]}