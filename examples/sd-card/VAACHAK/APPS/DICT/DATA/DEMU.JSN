{"DEMULCE":[{"def":"To soothe; to mollify; to pacify; to soften.","pos":""}],"DEMULCENT":[{"def":"Softening; mollifying; soothing; assuasive; as, oil is demulcent.","pos":""}],"DEMULSION":[{"def":"The act of soothing; that which soothes.","pos":""}],"DEMUR":[{"def":"To interpose a demurrer.","pos":""}],"DEMURE":[{"def":"Of sober or serious mien; composed and decorous in bearing; of modest look; staid; grave.","pos":""},{"def":"Affectedly modest, decorous, or serious; making a show of gravity.","pos":""}],"DEMURELY":[{"def":"In a demure manner; soberly; gravely; -- now, commonly, with a mere show of gravity or modesty.","pos":""}],"DEMURENESS":[{"def":"The state of being demure; gravity; the show of gravity or modesty.","pos":""}],"DEMURITY":[{"def":"Demureness; also, one who is demure.","pos":""}],"DEMURRABLE":[{"def":"That may be demurred to.","pos":""}],"DEMURRAGE":[{"def":"The claim for demurrage ceases as soon as the ship is cleared out and ready for sailing.","pos":""}],"DEMURRAL":[{"def":"Demur; delay in acting or deciding.","pos":""}],"DEMURRER":[{"def":"A stop or pause by a party to an action, for the judgment of the court on the question, whether, assuming the truth of the matter alleged by the opposite party, it is sufficient in law to sustain the action or defense, and hence whether the party resting is bound to answer or proceed further.","pos":""}]}