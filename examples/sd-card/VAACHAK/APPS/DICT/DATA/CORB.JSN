{"CORB":[{"def":"An ornament in a building; a corbel.","pos":""}],"CORBAN":[{"def":"An alms basket; a vessel to receive gifts of charity; a treasury of the church, where offerings are deposited.","pos":""}],"CORBEIL":[{"def":"A sculptured basket of flowers; a corbel.","pos":""}],"CORBEL":[{"def":"A bracket supporting a superincumbent object, or receiving the spring of an arch.","pos":""}],"CORBEL-TABLE":[{"def":"A horizontal row of corbels, with the panels or filling between them; also, less properly used to include the stringcourse on them.","pos":""}],"CORBIESTEP":[{"def":"One of the steps in which a gable wall is often finished in place of a continuous slope; -- also called crowstep.","pos":""}]}