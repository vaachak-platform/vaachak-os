{"SEW":[{"def":"Juice; gravy; a seasoned dish; a delicacy.","pos":"noun"}],"SEWAGE":[{"def":"The contents of a sewer or drain; refuse liquids or matter carried off by sewers 2.","pos":""}],"SEWE":[{"def":"To perform the duties of a sewer.","pos":""}],"SEWEL":[{"def":"A scarecrow, generally made of feathers tied to a string, hung up to prevent deer from breaking into a place.","pos":""}],"SEWELLEL":[{"def":"A peculiar gregarious burrowing rodent (Haplodon rufus), native of the coast region of the Northwestern United States.","pos":""}],"SEWEN":[{"def":"A British trout usually regarded as a variety (var.","pos":""}],"SEWER":[{"def":"One who sews, or stitches.","pos":""}],"SEWERAGE":[{"def":"The construction of a sewer or sewers.","pos":""},{"def":"The system of sewers in a city, town, etc.","pos":""}],"SEWING":[{"def":"The act or occupation of one who sews.","pos":""},{"def":"That which is sewed with the needle.","pos":""}]}