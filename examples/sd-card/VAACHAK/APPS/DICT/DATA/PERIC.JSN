{"PERICAMBIUM":[{"def":"A layer of thin-walled young cells in a growing stem, in which layer certain new vessels originate.","pos":""},{"def":"Of or pertaining to pericardium; situated around the heart.","pos":""}],"PERICARDITUS":[{"def":"Inflammation of the pericardium.","pos":""}],"PERICARDIUM":[{"def":"The double baglike fold of serous membrane which incloses the heart.","pos":""}],"PERICARP":[{"def":"The ripened ovary; the walls of the fruit.","pos":""},{"def":"Of or pertaining to a pericarp.","pos":""}],"PERICELLULAR":[{"def":"Surrounding a cell; as, the pericellular lymph spaces surrounding ganglion cells.","pos":""}],"PERICHAETH":[{"def":"The leafy involucre surrounding the fruit stalk of mosses; perichætium; perichete.","pos":""}],"PERICHAETIAL":[{"def":"Of or pertaining to the perichæth.","pos":""}],"PERICHAETIUM":[{"def":"Same as Perichæth.","pos":""}],"PERICHAETOUS":[{"def":"Surrounded by setæ; -- said of certain earthworms (genus Perichætus).","pos":""}],"PERICHETE":[{"def":"Same as Perichæth.","pos":""}],"PERICHONDRIAL":[{"def":"Of or pertaining to the perichondrium; situated around cartilage.","pos":""}],"PERICHONDRITIS":[{"def":"Inflammation of the perichondrium.","pos":""}],"PERICHONDRIUM":[{"def":"The membrane of fibrous connective tissue which closely invests cartilage, except where covering articular surfaces.","pos":""}],"PERICHORDAL":[{"def":"Around the notochord; as, a perichordal column.","pos":""},{"def":"A grayish or dark green mineral, consisting essentially of magnesia (magnesium oxide), occurring in granular forms or in isometric crystals.","pos":""}],"PERICLINIUM":[{"def":"The involucre which surrounds the common receptacle in composite flowers.","pos":""}],"PERICLITATE":[{"def":"Periclitating, pardi! the whole family.","pos":""}],"PERICLITATION":[{"def":"Trial; experiment.","pos":""},{"def":"The state of being in peril.","pos":""}],"PERICOPE":[{"def":"A selection or extract from a book; especially (Theol.","pos":""}],"PERICRANIAL":[{"def":"Of or pertaining to the pericranium.","pos":""}],"PERICRANIUM":[{"def":"The periosteum which covers the cranium externally; the region around the cranium.","pos":""}],"PERICULOUS":[{"def":"Dangerous; full of peril.","pos":""}],"PERICULUM":[{"def":"In a narrower, judicial sense: Accident or casus, as distinguished from dolus and culpa, and hence relieving one from the duty of performing an obligation.","pos":""}],"PERICYSTITIS":[{"def":"Inflammation of the tissues surrounding the bladder.","pos":""}]}