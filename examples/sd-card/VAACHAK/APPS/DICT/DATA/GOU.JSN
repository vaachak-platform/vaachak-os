{"GOUACHE":[{"def":"A method of painting with opaque colors, which have been ground in water and mingled with a preparation of gum; also, a picture thus painted.","pos":""}],"GOUDRON":[{"def":"a small fascine or fagot, steeped in wax, pitch, and glue, used in various ways, as for igniting buildings or works, or to light ditches and ramparts.","pos":""}],"GOUGE":[{"def":"Soft material lying between the wall of a vein aud the solid vein.","pos":""}],"GOUGER":[{"def":"See Plum Gouger.","pos":""}],"GOUGESHELL":[{"def":"A sharp-edged, tubular, marine shell, of the genus Vermetus; also, the pinna.","pos":""}],"GOUJERE":[{"def":"The venereal disease.","pos":""}],"GOULARDS EXTRACT":[{"def":"An aqueous solution of the subacetate of lead, used as a lotion in cases of inflammation.","pos":""}],"GOUR":[{"def":"A fire worshiper; a Gheber or Gueber.","pos":""}],"GOURA":[{"def":"One of several species of large, crested ground pigeons of the genus Goura, inhabiting New Guinea and adjacent islands.","pos":""}],"GOURAMI":[{"def":"A very largo East Indian freshwater fish (Osphromenus gorami), extensively reared in artificial ponds in tropical countries, and highly valued as a food fish.","pos":""}],"GOURD":[{"def":"A fleshy, three-celled, many-seeded fruit, as the melon, pumpkin, cucumber, etc.","pos":""}],"GOURD TREE":[{"def":"A tree (the Crescentia Cujete, or calabash tree) of the West Indies and Central America.","pos":""}],"GOURDINESS":[{"def":"The state of being gourdy.","pos":""}],"GOURDWORM":[{"def":"The fluke of sheep.","pos":""}],"GOURDY":[{"def":"Swelled in the legs.","pos":""}],"GOURMAND":[{"def":"A greedy or ravenous eater; a glutton.","pos":""}],"GOURMET":[{"def":"A connoisseur in eating and drinking; an epicure.","pos":""}],"GOUT":[{"def":"A constitutional disease, occurring by paroxysms.","pos":""}],"GOUTILY":[{"def":"In a gouty manner.","pos":""}],"GOUTINESS":[{"def":"The state of being gouty; gout.","pos":""},{"def":"A coarse umbelliferous plant of Europe (Ægopodium Podagraria); -- called also bishop's weed, ashweed, and herb gerard.","pos":""}],"GOUTY":[{"def":"Diseased with, or subject to, the gout; as, a gouty person; a gouty joint.","pos":""},{"def":"Pertaining to the gout.","pos":""}]}