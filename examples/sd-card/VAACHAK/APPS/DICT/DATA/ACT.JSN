{"ACT":[{"def":"That which is done or doing; the exercise of power, or the effect, of which power exerted is the cause; a performance; a deed.","pos":""},{"def":"A state of reality or real existence as opposed to a possibility or possible existence.","pos":""}],"ACTABLE":[{"def":"Capable of being acted.","pos":""}],"ACTINAL":[{"def":"Pertaining to the part of a radiate animal which contains the mouth.","pos":""}],"ACTINARIA":[{"def":"A large division of Anthozoa, including those which have simple tentacles and do not form stony corals.","pos":""}],"ACTING":[{"def":"Operating in any way.","pos":""},{"def":"Doing duty for another; officiating; as, an superintendent.","pos":""}],"ACTINIC":[{"def":"Of or pertaining to actinism; as, actinic rays.","pos":""}],"ACTINIFORM":[{"def":"Having a radiated form, like a sea anemone.","pos":""}],"ACTINISM":[{"def":"The property of radiant energy (found chiefly in solar or electric light) by which chemical changes are produced, as in photography.","pos":""}],"ACTINIUM":[{"def":"A supposed metal, said by Phipson to be contained in commercial zinc; -- so called because certain of its compounds are darkened by exposure to light.","pos":""}],"ACTINO-CHEMISTRY":[{"def":"Chemistry in its relations to actinism.","pos":""}],"ACTINOGRAM":[{"def":"A record made by the actinograph.","pos":""}],"ACTINOGRAPH":[{"def":"An instrument for measuring and recording the variations in the actinic or chemical force of rays of light.","pos":""}],"ACTINOID":[{"def":"Having the form of rays; radiated, as an actinia.","pos":""}],"ACTINOLITE":[{"def":"A bright green variety of amphibole occurring usually in fibrous or columnar masses.","pos":""}],"ACTINOLITIC":[{"def":"Of the nature of, or containing, actinolite.","pos":""}],"ACTINOLOGY":[{"def":"The science which treats of rays of light, especially of the actinic or chemical rays.","pos":""}],"ACTINOMERE":[{"def":"One of the radial segments composing the body of one of the Coelenterata.","pos":""}],"ACTINOMETRIC":[{"def":"Pertaining to the measurement of the intensity of the solar rays, either (a) heating, or (b) actinic.","pos":""}],"ACTINOMETRY":[{"def":"The measurement of the force of solar radiation.","pos":""},{"def":"The measurement of the chemical or actinic energy of light.","pos":""}],"ACTINOMYCOSIS":[{"def":"A chronic infectious disease of cattle and man due to the presence of Actinomyces bovis.","pos":""}],"ACTINOPHONE":[{"def":"An apparatus for the production of sound by the action of the actinic, or ultraviolet, rays.","pos":""}],"ACTINOPHONIC":[{"def":"Pertaining to, or causing the production of, sound by means of the actinic, or ultraviolet, rays; as, actinophonic phenomena.","pos":""}],"ACTINOPHOROUS":[{"def":"Having straight projecting spines.","pos":""}],"ACTINOSOME":[{"def":"The entire body of a coelenterate.","pos":""}],"ACTINOSTOME":[{"def":"The mouth or anterior opening of a coelenterate animal.","pos":""}],"ACTINOTROCHA":[{"def":"A peculiar larval form of Phoronis, a genus of marine worms, having a circle of ciliated tentacles.","pos":""}],"ACTINOZOA":[{"def":"A group of Coelenterata, comprising the Anthozoa Ctenophora.","pos":""}],"ACTINOZOAL":[{"def":"Of or pertaining to the Actinozoa.","pos":""},{"def":"One of the Actinozoa.","pos":""}],"ACTINULA":[{"def":"A kind of embryo of certain hydroids (Tubularia), having a stellate form.","pos":""}],"ACTION":[{"def":"Effective motion; also, mechanism; as, the breech action of a gun.","pos":""},{"def":"Any one of the active processes going on in an organism; the performance of a function; as, the action of the heart, the muscles, or the gastric juice.","pos":""}],"ACTIONABLE":[{"def":"That may be the subject of an action or suit at law; as, to call a man a thief is actionable.","pos":""}],"ACTIONABLY":[{"def":"In an actionable manner.","pos":""},{"def":"A shareholder in joint-stock company.","pos":""}],"ACTIVE":[{"def":"Having the power or quality of acting; causing change; communicating action or motion; acting; -- opposed to Ant: passive, that receives; as, certain active principles; the powers of the mind.","pos":""},{"def":"Quick in physical movement; of an agile and vigorous body; nimble; as, an active child or animal.","pos":""}],"ACTIVELY":[{"def":"In an active signification; as, a word used actively.","pos":""}],"ACTIVENESS":[{"def":"The quality of being active; nimbleness; quickness of motion; activity.","pos":""}],"ACTIVITY":[{"def":"The state or quality of being active; nimbleness; agility; vigorous action or operation; energy; active force; as, an increasing variety of human activities.","pos":""}],"ACTLESS":[{"def":"Without action or spirit.","pos":""}],"ACTON":[{"def":"A stuffed jacket worn under the mail, or (later) a jacket plated with mail.","pos":""}],"ACTOR":[{"def":"One who acts, or takes part in any affair; a doer.","pos":""},{"def":"A theatrical performer; a stageplayer.","pos":""}],"ACTRESS":[{"def":"A female actor or doer.","pos":""},{"def":"A female stageplayer; a woman who acts a part.","pos":""}],"ACTUAL":[{"def":"Involving or comprising action; active.","pos":""},{"def":"Existing in act or reality; really acted or acting; in fact; real; -- opposed to potential, possible, virtual, speculative, coceivable, theoretical, or nominal; as, the actual cost of goods; the actual case under discussion.","pos":""}],"ACTUALIST":[{"def":"One who deals with or considers actually existing facts and conditions, rather than fancies or theories; -- opposed to idealist.","pos":""}],"ACTUALITY":[{"def":"The state of being actual; reality; as, the actuality of God's nature.","pos":""}],"ACTUALIZATION":[{"def":"A making actual or really existent.","pos":""}],"ACTUALIZE":[{"def":"To make actual; to realize in action.","pos":""}],"ACTUALLY":[{"def":"In act or in fact; really; in truth; positively.","pos":""}],"ACTUALNESS":[{"def":"Quality of being actual; actuality.","pos":""}],"ACTUARIAL":[{"def":"Of or pertaining to actuaries; as, the actuarial value of an annuity.","pos":""}],"ACTUARY":[{"def":"A registar or clerk; -- used originally in courts of civil law jurisdiction, but in Europe used for a clerk or registar generally.","pos":""}],"ACTUATE":[{"def":"To put into action or motion; to move or incite to action; to influence actively; to move as motives do; -- more commonly used of persons.","pos":""},{"def":"To carry out in practice; to perform.","pos":""}],"ACTUATION":[{"def":"A bringing into action; movement.","pos":""}],"ACTUATOR":[{"def":"One who actuates, or puts into action.","pos":""}],"ACTUOSITY":[{"def":"Abundant activity.","pos":""}],"ACTURIENCE":[{"def":"Tendency or impulse to act.","pos":""}]}