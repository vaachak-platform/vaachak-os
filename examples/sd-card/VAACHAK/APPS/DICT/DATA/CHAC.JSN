{"CHACE":[{"def":"See 3d Chase, n.","pos":""}],"CHACHALACA":[{"def":"The texan guan (Ortalis vetula).","pos":""}],"CHACMA":[{"def":"A large species of African baboon (Cynocephalus porcarius); -- called also ursine baboon.","pos":""}],"CHACONNE":[{"def":"An old Spanish dance in moderate three-four measure, like the Passacaglia, which is slower.","pos":""}]}