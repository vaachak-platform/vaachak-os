{"ISOBAR":[{"def":"A line connecting or marking places upon the surface of the earth where height of the barometer reduced to sea level is the same either at a given time, or for a certain period (mean height), as for a year; an isopiestic line.","pos":""}],"ISOBARIC":[{"def":"Denoting equal pressure; as, an isobaric line; specifically, of or pertaining to isobars.","pos":""}],"ISOBARISM":[{"def":"The quality or state of being equal in weight, especially in atmospheric pressure.","pos":""}],"ISOBAROMETRIC":[{"def":"Indicating equal barometric pressure.","pos":""}],"ISOBATHYTHERM":[{"def":"A line connecting the points on the surface of the earth where a certain temperature is found at the same depth.","pos":""}],"ISOBATHYTHERMIC":[{"def":"Of or pertaining to an isobathytherm; possessing or indicating the same temperature at the same depth.","pos":""}],"ISOBRONT":[{"def":"An imaginary line, or a line on a chart, marking the simultaneous development of a thunderstorm, as noted by observing the time when the thunder is heard at different places.","pos":""}],"ISOCEPHALISM":[{"def":"A peculiarity in the design of bas-relief by which the heads of human figures are kept at the same height from the ground, whether the personages are seated, standing, or mounted on horseback; -- called also isokephaleia.","pos":""}],"ISOCHASM":[{"def":"A line connecting places on the earth's surface at which there is the same mean frequency of auroras.","pos":""}],"ISOCHASMIC":[{"def":"Indicating equal auroral display; as, an isochasmic line.","pos":""}],"ISOCHEIM":[{"def":"A line connecting places on the earth having the same mean winter temperature.","pos":""},{"def":"Pertaining to, having the nature of, or making, isocheims; as, an isocheimal line; an isocheimal chart.","pos":""}],"ISOCHEIMIC":[{"def":"The same as Isocheimal.","pos":""}],"ISOCHIMENE":[{"def":"The same as Isocheim.","pos":""}],"ISOCHOR":[{"def":"A line upon a thermodynamic diagram so drawn as to represent the pressures corresponding to changes of temperature when the volume of the gas operated on is constant.","pos":""}],"ISOCHROMATIC":[{"def":"Having the same color; connecting parts having the same color, as lines drawn through certain points in experiments on the chromatic effects of polarized light in crystals.","pos":""}],"ISOCHRONAL":[{"def":"Uniform in time; of equal time; performed in equal times; recurring at regular intervals; isochronal vibrations or oscillations.","pos":""}],"ISOCHRONISM":[{"def":"The state or quality of being isochronous.","pos":""}],"ISOCHRONIZE":[{"def":"To make, or tend to make (the motion of a moving body), uniform in rate of rotation, or in frequency of vibration.","pos":""}],"ISOCHRONON":[{"def":"A clock that is designed to keep very accurate time.","pos":""}],"ISOCHRONOUS":[{"def":"Same as Isochronal.","pos":""}],"ISOCHROOUS":[{"def":"Having the same tint or color throughout; uniformly or evenly colored.","pos":""},{"def":"Of or pertaining to, or indicating, equality of inclination or dip; having equal inclination or dip.","pos":""}],"ISOCRYMAL":[{"def":"Pertaining to, having the nature of, or illustrating, an isocryme; as, an isocrymal line; an isocrymal chart.","pos":""}],"ISOCRYME":[{"def":"A line connecting points on the earth's surface having the same mean temperature in the coldest month of the year.","pos":""}],"ISOCYANIC":[{"def":"Designating an acid isomeric with cyanic acid.","pos":""}],"ISOCYANURIC":[{"def":"Designating, or pertaining to, an acid isomeric with cyanuric acid, and called also fulminuric acid.","pos":""}],"ISODIABATIC":[{"def":"Pertaining to the reception or the giving out of equal quantities of heat by a substance.","pos":""}],"ISODIAMETRIC":[{"def":"Developed alike in the directions of the several lateral axes; -- said of crystals of both the tetragonal and hexagonal systems.","pos":""},{"def":"Having the several diameters nearly equal; -- said of the cells of ordinary parenchyma.","pos":""}],"ISODIMORPHISM":[{"def":"Isomorphism between the two forms severally of two dimorphous substances.","pos":""}],"ISODIMORPHOUS":[{"def":"Having the quality of isodimorphism.","pos":""}],"ISODROME":[{"def":"A method of moving a fleet from one formation to another, the direction usually being changed eight points (90º), by means of paths of equal length for each ship.","pos":""}],"ISODULCITE":[{"def":"A white, crystalline, sugarlike substance, obtained by the decomposition of certain glucosides, and intermediate in nature between the hexacid alcohols (ductile, mannite, etc.","pos":""}],"ISODYNAMIC":[{"def":"Of, pertaining to, having, or denoting, equality of force.","pos":""}],"ISODYNAMOUS":[{"def":"Of equal force or size.","pos":""}],"ISOGEOTHERM":[{"def":"A line or curved surface passing beneath the earth's surface through points having the same mean temperature.","pos":""},{"def":"Pertaining to, having the nature of, or marking, isogeotherms; as, an isogeothermal line or surface; as isogeothermal chart.","pos":""}],"ISOGONIC":[{"def":"Pertaining to, or noting, equal angles.","pos":""}],"ISOGONISM":[{"def":"The quality of having similar sexual zooids or gonophores and dissimilar hydrants; -- said of certain hydroids.","pos":""}],"ISOGRAPHIC":[{"def":"Of or pertaining to isography.","pos":""}],"ISOHYETOSE":[{"def":"Of or pertaining to lines connecting places on the earth's surface which have a mean annual rainfall.","pos":""},{"def":"An isohyetose line.","pos":""}],"ISOLABLE":[{"def":"Capable of being isolated, or of being obtained in a pure state; as, gold is isolable.","pos":""}],"ISOLATE":[{"def":"To separate from all foreign substances; to make pure; to obtain in a free state.","pos":""}],"ISOLATED":[{"def":"Placed or standing alone; detached; separated from others.","pos":""}],"ISOLATEDLY":[{"def":"In an isolated manner.","pos":""}],"ISOLATION":[{"def":"The act of isolating, or the state of being isolated; insulation; separation; loneliness.","pos":""}],"ISOLATOR":[{"def":"One who, or that which, isolates.","pos":""}],"ISOLOGOUS":[{"def":"Having similar proportions, similar relations, or similar differences of composition; -- said specifically of groups or series which differ by a constant difference; as, ethane, ethylene, an acetylene, or their analogous compounds, form an isologous series.","pos":""}],"ISOMER":[{"def":"A body or compound which is isomeric with another body or compound; a member of an isomeric series.","pos":""}],"ISOMERE":[{"def":"A homologous or corresponding part or segment.","pos":""}],"ISOMERIC":[{"def":"Having the same percentage composition; -- said of two or more different substances which contain the same ingredients in the same proportions by weight, often used with with.","pos":""}],"ISOMERISM":[{"def":"The state, quality, or relation, of two or more isomeric substances.","pos":""}],"ISOMEROMORPHISM":[{"def":"Isomorphism between substances that are isomeric.","pos":""},{"def":"Noting, or conforming to, that system of crystallization in which the three axes are of equal length and at right angles to each other; monometric; regular; cubic.","pos":""}],"ISOMORPH":[{"def":"A substance which is similar to another in crystalline form and composition.","pos":""}],"ISOMORPHISM":[{"def":"A similarity of crystalline form between substances of similar composition, as between the sulphates of barium (BaSO4) and strontium (SrSO4).","pos":""}],"ISOMORPHOUS":[{"def":"Having the quality of isomorphism.","pos":""}],"ISONANDRA":[{"def":"A genus of sapotaceous trees of India.","pos":""}],"ISONEPHELIC":[{"def":"Having, or indicating, an equal amount of cloudiness for a given period; as, isonephelic regions; an isonephelic line.","pos":""}],"ISONICOTINE":[{"def":"A crystalline, nitrogenous base, C10H14N2, isomeric with nicotine.","pos":""}],"ISONITROSO-":[{"def":"A combining from (also used adjectively), signifying: Pertaining to, or designating, the characteristic, nitrogenous radical, NOH, called the isonitroso group.","pos":""}],"ISONOMIC":[{"def":"The same, or equal, in law or right; one in kind or origin; analogous; similar.","pos":""}],"ISONOMY":[{"def":"Equal law or right; equal distribution of rights and privileges; similarity.","pos":""}],"ISOPEPSIN":[{"def":"Pepsin modified by exposure to a temperature of from 40º to 60º C.","pos":""}],"ISOPERIMETRICAL":[{"def":"Having equal perimeters of circumferences; as, isoperimetrical figures or bodies.","pos":""}],"ISOPERIMETRY":[{"def":"The science of figures having equal perimeters or boundaries.","pos":""}],"ISOPIESTIC":[{"def":"Having equal pressure.","pos":""}],"ISOPLEURA":[{"def":"A subclass of Gastropoda, in which the body is symmetrical, the right and left sides being equal.","pos":""}],"ISOPOD":[{"def":"Having the legs similar in structure; belonging to the Isopoda.","pos":""},{"def":"One of the Isopoda.","pos":""}],"ISOPODA":[{"def":"An order of sessile-eyed Crustacea, usually having seven pairs of legs, which are all similar in structure.","pos":""}],"ISOPODIFORM":[{"def":"Having the shape of an isopod; -- said of the larvæ of certain insects.","pos":""}],"ISOPOGONOUS":[{"def":"Having the two webs equal in breath; -- said of feathers.","pos":""}],"ISOPRENE":[{"def":"An oily, volatile hydrocarbon, obtained by the distillation of caoutchouc or guttaipercha.","pos":""}],"ISOPYCNIC":[{"def":"Having equal density, as different regions of a medium; passing through points at which the density is equal; as, an isopycnic line or surface.","pos":""}],"ISORCIN":[{"def":"A crystalline hydrocarbon derivative, metameric with orcin, but produced artificially; -- called also cresorcin.","pos":""}],"ISOSCELES":[{"def":"Having two legs or sides that are equal; -- said of a triangle.","pos":""}],"ISOSPONDYLI":[{"def":"An extensive order of fishes, including the salmons, herrings, and many allied forms.","pos":""}],"ISOSPONDYLOUS":[{"def":"Of or pertaining to the Isospondyli; having the anterior vertebræ separate and normal.","pos":""}],"ISOSPORIC":[{"def":"Producing but one kind of spore, as the ferns and Equiseta.","pos":""}],"ISOSPOROUS":[{"def":"Producing but one kind of spore, as the ferns.","pos":""}],"ISOSTASY":[{"def":"The state or quality of being isostatic.","pos":""},{"def":"general equilibrium in the earth's crust, supposed to be maintained by the yielding or flow of rock material beneath the surface under gravitative stress.","pos":""}],"ISOSTATIC":[{"def":"Subjected to equal pressure from every side; being in hydrostatic equilibrium, as a body submerged in a liquid at rest; pertaining to, or characterized by, isostasy.","pos":""}],"ISOSTEMONOUS":[{"def":"Having exactly as many stamens as petals.","pos":""}],"ISOSTEMONY":[{"def":"The quality or state of being isostemonous.","pos":""}],"ISOSULPHOCYANATE":[{"def":"A salt of isosulphocyanic acid.","pos":""}],"ISOSULPHOCYANIC":[{"def":"Pertaining to, or designating, an acid, HNCS, isomeric with sulphocyanic acid.","pos":""}],"ISOTHERAL":[{"def":"Having the nature of an isothere; indicating the distribution of temperature by means of an isothere; as, an isotheral chart or line.","pos":""}],"ISOTHERE":[{"def":"A line connecting points on the earth's surface having the same mean summer temperature.","pos":""}],"ISOTHERM":[{"def":"A line connecting or marking points on the earth's surface having the same temperature.","pos":""}],"ISOTHERMOBATH":[{"def":"A line drawn through points of equal temperature in a vertical section of the ocean.","pos":""}],"ISOTHERMOBATHIC":[{"def":"Of or pertaining to an isothermobath; possessing or indicating equal temperatures in a vertical section, as of the ocean.","pos":""}],"ISOTHEROMBROSE":[{"def":"A line connecting or marking points on the earth's surface, which have the same mean summer rainfall.","pos":""}],"ISOTONIC":[{"def":"Having or indicating, equal tones, or tension.","pos":""}],"ISOTRIMORPHISM":[{"def":"Isomorphism between the three forms, severally, of two trimorphous substances.","pos":""}],"ISOTRIMORPHOUS":[{"def":"Having the quality of isotrimorphism; isotrimorphic.","pos":""}],"ISOTROPIC":[{"def":"Having the same properties in all directions; specifically, equally elastic in all directions.","pos":""}],"ISOTROPY":[{"def":"Uniformity of physical properties in all directions in a body; absence of all kinds of polarity; specifically, equal elasticity in all directions.","pos":""}],"ISOURIC":[{"def":"Pertaining to, or designating, a complex nitrogenous acid, isomeric with uric acid.","pos":""}]}