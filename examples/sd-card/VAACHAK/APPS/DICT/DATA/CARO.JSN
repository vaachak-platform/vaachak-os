{"CAROB":[{"def":"An evergreen leguminous tree (Ceratania Siliqua) found in the countries bordering the Mediterranean; the St.","pos":""}],"CAROCHE":[{"def":"A kind of pleasure carriage; a coach.","pos":""}],"CAROCHED":[{"def":"Placed in a caroche.","pos":""}],"CAROIGNE":[{"def":"Dead body; carrion.","pos":""}],"CAROL":[{"def":"A song of joy, exultation, or mirth; a lay.","pos":""}],"CAROLIN":[{"def":"A former gold coin of Germany worth nearly five dollars; also, a gold coin of Sweden worth nearly five dollars.","pos":""}],"CAROLING":[{"def":"A song of joy or devotion; a singing, as of carols.","pos":""}],"CAROLINIAN":[{"def":"A native or inhabitant of north or South Carolina.","pos":""}],"CAROLITIC":[{"def":"Adorned with sculptured leaves and branches.","pos":""}],"CAROLUS":[{"def":"An English gold coin of the value of twenty or twenty-three shillings.","pos":""}],"CAROM":[{"def":"A shot in which the ball struck with the cue comes in contact with two or more balls on the table; a hitting of two or more balls with the player's ball.","pos":""}],"CAROTEEL":[{"def":"A tierce or cask for dried fruits, etc.","pos":""}],"CAROTIC":[{"def":"Carotid; as, the carotic arteries.","pos":""}],"CAROTID":[{"def":"One of the two main arteries of the neck, by which blood is conveyed from the aorta to the head.","pos":""},{"def":"Pertaining to, or near, the carotids or one of them; as, the carotid gland.","pos":""}],"CAROTIN":[{"def":"A red crystallizable tasteless substance, extracted from the carrot.","pos":""}],"CAROTTE":[{"def":"A cylindrical roll of tobacco; as, a carotte of perique.","pos":""}],"CAROUSAL":[{"def":"A jovial feast or festival; a drunken revel; a carouse.","pos":""}],"CAROUSE":[{"def":"A large draught of liguor.","pos":""},{"def":"A drinking match; a carousal.","pos":""}],"CAROUSER":[{"def":"One who carouses; a reveler.","pos":""}],"CAROUSING":[{"def":"That carouses; relating to a carouse.","pos":""}],"CAROUSINGLY":[{"def":"In the manner of a carouser.","pos":""}]