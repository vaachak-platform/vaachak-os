{"ALMA MATER":[{"def":"A college or seminary where one is educated.","pos":""}],"ALMACANTAR":[{"def":"ALMADIA; ALMADIE Al`ma*di\"a, Al\"ma*die, n.","pos":""}],"ALMAGEST":[{"def":"The celebrated work of Ptolemy of Alexandria, which contains nearly all that is known of the astronomical observations and theories of the ancients.","pos":""}],"ALMAGRA":[{"def":"A fine, deep red ocher, somewhat purplish, found in Spain.","pos":""}],"ALMANAC":[{"def":"A book or table, containing a calendar of days, and months, to which astronomical data and various statistics are often added, such as the times of the rising and setting of the sun and moon, eclipses, hours of full tide, stated festivals of churches, terms of courts, etc.","pos":""}],"ALMANDINE":[{"def":"The common red variety of garnet.","pos":""},{"def":"An Egyptian dancing girl; an Alma.","pos":""}],"ALMENDRON":[{"def":"The lofty Brazil-nut tree.","pos":""}],"ALMESSE":[{"def":"All-powerful; almighty.","pos":""}],"ALMIGHTILY":[{"def":"With almighty power.","pos":""}],"ALMIGHTINESS":[{"def":"Omnipotence; infinite or boundless power; unlimited might.","pos":""}],"ALMIGHTY":[{"def":"Unlimited in might; omnipotent; all-powerful; irresistible.","pos":""},{"def":"Great; extreme; terrible.","pos":""}],"ALMOND":[{"def":"One of the tonsils.","pos":""}],"ALMOND FURNACE":[{"def":"A kind of furnace used in refining, to separate the metal from cinders and other foreign matter.","pos":""}],"ALMONER":[{"def":"One who distributes alms, esp.","pos":""}],"ALMONERSHIP":[{"def":"The office of an almoner.","pos":""}],"ALMONRY":[{"def":"The place where an almoner resides, or where alms are distributed.","pos":""}],"ALMOST":[{"def":"Nearly; well nigh; all but; for the greatest part.","pos":""}],"ALMS":[{"def":"Anything given gratuitously to relieve the poor, as money, food, or clothing; a gift of charity.","pos":""}],"ALMSDEED":[{"def":"An act of charity.","pos":""}],"ALMSFOLK":[{"def":"Persons supported by alms; almsmen.","pos":""}],"ALMSGIVER":[{"def":"A giver of alms.","pos":""}],"ALMSGIVING":[{"def":"The giving of alms.","pos":""}],"ALMSHOUSE":[{"def":"A house appropriated for the use of the poor; a poorhouse.","pos":""}],"ALMSMAN":[{"def":"A recipient of alms.","pos":""},{"def":"A giver of alms.","pos":""}],"ALMUCANTAR":[{"def":"A small circle of the sphere parallel to the horizon; a circle or parallel of altitude.","pos":""}],"ALMUCE":[{"def":"Same as Amice, a hood or cape.","pos":""}],"ALMUDE":[{"def":"A measure for liquids in several countries.","pos":""},{"def":"A tree or wood of the Bible (2 Chron.","pos":""}]}