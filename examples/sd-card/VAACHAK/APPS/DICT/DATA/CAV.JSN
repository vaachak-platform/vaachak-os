{"CAVALCADE":[{"def":"A procession of persons on horseback; a formal, pompous march of horsemen by way of parade.","pos":""},{"def":"A cavalier; a gallant; a libertine.","pos":""}],"CAVALIER":[{"def":"A work of more that ordinary heigh, rising from the level ground of a bastion, etc.","pos":""}],"CAVALIERISH":[{"def":"Somewhat like a cavalier.","pos":""}],"CAVALIERISM":[{"def":"The practice or principles of cavaliers.","pos":""}],"CAVALIERLY":[{"def":"In a supercilious, disdainful, or haughty manner; arroganty.","pos":""}],"CAVALIERNESS":[{"def":"A disdanful manner.","pos":""}],"CAVALLY":[{"def":"A carangoid fish of the Atlantic coast (Caranx hippos): -- called also horse crevallé.","pos":""}],"CAVALRY":[{"def":"That part of military force which serves on horseback.","pos":""}],"CAVALRYMAN":[{"def":"One of a body of cavalry.","pos":""}],"CAVATINA":[{"def":"Originally, a melody of simpler form than the aria; a song without a second part and a da capo; -- a term now variously and vaguely used.","pos":""}],"CAVE":[{"def":"A hollow place in the earth, either natural or artificial; a subterraneous cavity; a cavern; a den.","pos":""},{"def":"Any hollow place, or part; a cavity.","pos":""}],"CAVEAT":[{"def":"A notice given by an interested party to some officer not to do a certain act until the party is heard in opposition; as, a caveat entered in a probate court to stop the proving of a will or the taking out of letters of administration, etc.","pos":""},{"def":"A description of some invention, designed to be patented, lodged in the patent office before the patent right is applied for, and operating as a bar to the issue of letters patent to any other person, respecting the same invention.","pos":""}],"CAVEATING":[{"def":"Shifting the sword from one side of an adversary's sword to the other.","pos":""}],"CAVEATOR":[{"def":"One who enters a caveat.","pos":""}],"CAVENDISH":[{"def":"Leaf tobacco softened, sweetened, and pressed into plugs or cakes.","pos":""}],"CAVERN":[{"def":"A large, deep, hollow place in the earth; a large cave.","pos":""}],"CAVERNED":[{"def":"Containing caverns.","pos":""},{"def":"Living in a cavern.","pos":""}],"CAVERNOUS":[{"def":"Full of caverns; resembling a cavern or large cavity; hollow.","pos":""},{"def":"Filled with small cavities or cells.","pos":""}],"CAVERNULOUS":[{"def":"Full of little cavities; as, cavernulous metal.","pos":""},{"def":"A kind of noseband used in breaking and training horses.","pos":""}],"CAVETTO":[{"def":"A concave molding; -- used chiefly in classical architecture.","pos":""},{"def":"The roes of the sturgeon, prepared and salted; -- used as a relish, esp.","pos":""}],"CAVICORN":[{"def":"Having hollow horns.","pos":""}],"CAVICORNIA":[{"def":"A group of ruminants whose horns are hollow, and planted on a bony process of the front, as the ox.","pos":""}],"CAVIL":[{"def":"To raise captious and frivolous objections; to find fault without good reason.","pos":""}],"CAVILING":[{"def":"Disposed to cavil; finding fault without good reason.","pos":""}],"CAVILINGLY":[{"def":"In a caviling manner.","pos":""}],"CAVILLATION":[{"def":"Frivolous or sophistical objection.","pos":"noun"},{"def":"Characterized by caviling, or disposed to cavil; quibbing.","pos":"noun"}],"CAVIN":[{"def":"A hollow way, adapted to cover troops, and facilitate their aproach to a place.","pos":""}],"CAVITARY":[{"def":"Containing a body cavity; as, the cavitary or nematoid worms.","pos":""}],"CAVITY":[{"def":"A hollow place; a hollow; as, the abdominal cavity.","pos":""}],"CAVO-RILIEVO":[{"def":"Hollow relief; sculpture in relief within a sinking made for the purpose, so no part of it projects beyond the plain surface around.","pos":""}],"CAVORT":[{"def":"To prance ostentatiously; -- said of a horse or his rider.","pos":""}],"CAVY":[{"def":"A rodent of the genera cavia and Dolichotis, as the guinea pig (Cavia cabaya).","pos":""}]}