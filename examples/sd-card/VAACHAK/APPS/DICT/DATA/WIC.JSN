{"WICH":[{"def":"A variant of 1st Wick.","pos":""}],"WICHITAS":[{"def":"A tribe of Indians native of the region between the Arkansas and Red rivers.","pos":""},{"def":"A narrow port or passage in the rink or course, flanked by the stones of previous players.","pos":""}],"WICK":[{"def":"But true it is, that when the oil is spent The light goes out, and wick is thrown away.","pos":""}],"WICKED":[{"def":"Having a wick; -- used chiefly in composition; as, a two-wicked lamp.","pos":""}],"WICKEDLY":[{"def":"In a wicked manner; in a manner, or with motives and designs, contrary to the divine law or the law of morality; viciously; corruptly; immorally.","pos":""}],"WICKEDNESS":[{"def":"The quality or state of being wicked; departure from the rules of the divine or the moral law; evil disposition or practices; immorality; depravity; sinfulness.","pos":""},{"def":"A wicked thing or act; crime; sin; iniquity.","pos":""}],"WICKEN TREE":[{"def":"Same as Quicken tree.","pos":""}],"WICKER":[{"def":"A small pliant twig or osier; a rod for making basketwork and the like; a withe.","pos":""},{"def":"Wickerwork; a piece of wickerwork, esp.","pos":""}],"WICKERED":[{"def":"Made of, secured by, or covered with, wickers or wickerwork.","pos":""}],"WICKERWORK":[{"def":"A texture of osiers, twigs, or rods; articles made of such a texture.","pos":""}],"WICKET":[{"def":"The space between the pillars, in postand-stall working.","pos":""}],"WICKING":[{"def":"the material of which wicks are made; esp.","pos":""}],"WICKIUP WICKYUP":[{"def":"WICLIFITE; WICKLIFFITE Wic\"lif*ite, Wick\"liff*ite, n.","pos":""}],"WICOPY":[{"def":"See Leatherwood.","pos":""},{"def":"A test for typhoid fever based on the fact that blood serum of one affected, in a bouillon culture of typhoid bacilli, causes the bacilli to agglutinate and lose their motility.","pos":""}]}