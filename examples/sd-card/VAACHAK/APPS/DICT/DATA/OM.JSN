{"OM":[{"def":"A mystic syllable or ejaculation used by Hindus and Buddhists in religious rites, -- orig.","pos":""},{"def":"A suffix used in medical terms to denote a morbid condition of some part, usually some kind of tumor; as in fibroma, glaucoma.","pos":""}],"OMAGRA":[{"def":"Gout in the shoulder.","pos":""}],"OMAHAS":[{"def":"A tribe of Indians who inhabited the south side of the Missouri River.","pos":""}],"OMANDER WOOD":[{"def":"The wood of Diospyros ebenaster, a kind of ebony found in Ceylon.","pos":""}],"OMASUM":[{"def":"The third division of the stomach of ruminants.","pos":""},{"def":"A game at cards, borrowed from the Spaniards, and usually played by three persons.","pos":""}],"OMBRE":[{"def":"A large Mediterranean food fish (Umbrina cirrhosa): -- called also umbra, and umbrine.","pos":""}],"OMBROMETER":[{"def":"An instrument for measuring the rain that falls; a rain gauge.","pos":""}],"OMEGA":[{"def":"The last letter of the Greek alphabet.","pos":""},{"def":"The last; the end; hence, death.","pos":""}],"OMELET":[{"def":"Eggs beaten up with a little flour, etc.","pos":""}],"OMEN":[{"def":"An occurrence supposed to portend, or show the character of, some future event; any indication or action regarded as a foreshowing; a foreboding; a presage; an augury.","pos":""}],"OMENED":[{"def":"Attended by, or containing, an omen or omens; as, happy-omened day.","pos":""}],"OMENTAL":[{"def":"Of or pertaining to an omentum or the omenta.","pos":""}],"OMENTUM":[{"def":"A free fold of the peritoneum, or one serving to connect viscera, support blood vessels, etc.","pos":""}],"OMER":[{"def":"A Hebrew measure, the tenth of an ephah.","pos":""}],"OMINATE":[{"def":"To presage; to foreshow; to foretoken.","pos":""}],"OMINATION":[{"def":"The act of ominating; presaging.","pos":""}],"OMINOUS":[{"def":"Of or pertaining to an omen or to omens; being or exhibiting an omen; significant; portentous; -- formerly used both in a favorable and unfavorable sense; now chiefly in the latter; foreboding or foreshowing evil; inauspicious; as, an ominous dread.","pos":""}],"OMISSIBLE":[{"def":"Capable of being omitted; that may be omitted.","pos":""}],"OMISSION":[{"def":"The act of omitting; neglect or failure to do something required by propriety or duty.","pos":""},{"def":"That which is omitted or is left undone.","pos":""}],"OMISSIVE":[{"def":"Leaving out; omitting.","pos":""}],"OMIT":[{"def":"To let go; to leave unmentioned; not to insert or name; to drop.","pos":""},{"def":"To pass by; to forbear or fail to perform or to make use of; to leave undone; to neglect.","pos":""}],"OMITTANCE":[{"def":"The act of omitting, or the state of being omitted; forbearance; neglect.","pos":""}],"OMMATEAL":[{"def":"Of or pertaining to an ommateum.","pos":""}],"OMMATEUM":[{"def":"A compound eye, as of insects and crustaceans.","pos":""}],"OMMATIDIUM":[{"def":"One of the single eyes forming the compound eyes of crustaceans, insects, and other invertebrates.","pos":""}],"OMNI-":[{"def":"A combining form denoting all, every, everywhere; as in omnipotent, all-powerful; omnipresent.","pos":""}],"OMNIBUS":[{"def":"A sheet-iron cover for articles in a leer or annealing arch, to protect them from drafts.","pos":""}],"OMNICORPOREAL":[{"def":"Comprehending or including all bodies; embracing all substance.","pos":""}],"OMNIETY":[{"def":"That which is all-pervading or all-comprehensive; hence, the Deity.","pos":""}],"OMNIFARIOUS":[{"def":"Of all varieties, forms, or kinds.","pos":""}],"OMNIFEROUS":[{"def":"All-bearing; producing all kinds.","pos":""}],"OMNIFORM":[{"def":"Having every form or shape.","pos":""}],"OMNIFORMITY":[{"def":"The condition or quality of having every form.","pos":""}],"OMNIFY":[{"def":"To render universal; to enlarge.","pos":""}],"OMNIGENOUS":[{"def":"Consisting of all kinds.","pos":""}],"OMNIPARIENT":[{"def":"Producing or bringing forth all things; all-producing.","pos":""}],"OMNIPARITY":[{"def":"Equality in every part; general equality.","pos":""}],"OMNIPAROUS":[{"def":"Producing all things; omniparient.","pos":""}],"OMNIPATIENT":[{"def":"Capable of enduring all things.","pos":""},{"def":"Perception of everything.","pos":""}],"OMNIPERCIPIENT":[{"def":"Perceiving everything.","pos":""}],"OMNIPOTENT":[{"def":"Able in every respect and for every work; unlimited in ability; all-powerful; almighty; as, the Being that can create worlds must be omnipotent.","pos":""},{"def":"Having unlimited power of a particular kind; as, omnipotent love.","pos":""}],"OMNIPOTENTLY":[{"def":"In an omnipotent manner.","pos":""}],"OMNIPRESENCE":[{"def":"Presence in every place at the same time; unbounded or universal presence; ubiquity.","pos":""}],"OMNIPRESENT":[{"def":"Present in all places at the same time; ubiquitous; as, the omnipresent Jehovah.","pos":""}],"OMNIPRESENTIAL":[{"def":"Implying universal presence.","pos":""}],"OMNIPREVALENT":[{"def":"Prevalent everywhere or in all things.","pos":""}],"OMNISCIENCE":[{"def":"The quality or state of being omniscient; -- an attribute peculiar to God.","pos":""}],"OMNISCIENT":[{"def":"Having universal knowledge; knowing all things; infinitely knowing or wise; as, the omniscient God.","pos":""}],"OMNISPECTIVE":[{"def":"Beholding everything; capable of seeing all things; all-seeing.","pos":""}],"OMNIUM":[{"def":"The aggregate value of the different stocks in which a loan to government is now usually funded.","pos":""}],"OMNIUM-GATHERUM":[{"def":"A miscellaneous collection of things or persons; a confused mixture; a medley.","pos":""}],"OMNIVAGANT":[{"def":"Wandering anywhere and everywhere.","pos":""}],"OMNIVORA":[{"def":"A group of ungulate mammals including the hog and the hippopotamus.","pos":""}],"OMNIVOROUS":[{"def":"All-devouring; eating everything indiscriminately; as, omnivorous vanity; esp.","pos":""}],"OMO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the shoulder or the scapula.","pos":""}],"OMOHYOID":[{"def":"Of or pertaining to the shoulder and the hyoid bone; as, the omohyoid muscle.","pos":""}],"OMOPHAGIC":[{"def":"Eating raw flesh; using uncooked meat as food; as, omophagic feasts, rites.","pos":""}],"OMOPLATE":[{"def":"The shoulder blade, or scapula.","pos":""}],"OMOSTEGITE":[{"def":"The part of the carapace of a crustacean situated behind the cervical groove.","pos":""}],"OMOSTERNAL":[{"def":"Of or pertaining to the omosternum.","pos":""}],"OMPHACINE":[{"def":"Of, pertaining to, or expressed from, unripe fruit; as, omphacine oil.","pos":""}],"OMPHALIC":[{"def":"Of or pertaining to the umbilicus, or navel.","pos":""}],"OMPHALO-":[{"def":"A combining form indicating connection with, or relation to, the umbilicus, or navel.","pos":""}],"OMPHALOCELE":[{"def":"A hernia at the navel.","pos":""}],"OMPHALODE":[{"def":"The central part of the hilum of a seed, through which the nutrient vessels pass into the rhaphe or the chalaza; -- called also omphalodium.","pos":""}],"OMPHALOMANCY":[{"def":"Divination by means of a child's navel, to learn how many children the mother may have.","pos":""}],"OMPHALOMESARAIC":[{"def":"Omphalomesenteric.","pos":""}],"OMPHALOMESENTERIC":[{"def":"Of or pertaining to the umbilicus and mesentery; omphalomesaraic; as, the omphalomesenteric arteries and veins of a fetus.","pos":""}],"OMPHALOPSYCHITE":[{"def":"A name of the Hesychasts, from their habit of gazing upon the navel.","pos":""},{"def":"An optical glass that is convex on both sides.","pos":""}],"OMPHALOTOMY":[{"def":"The operation of dividing the navel-string.","pos":""}],"OMY":[{"def":"Mellow, as land.","pos":""}]}