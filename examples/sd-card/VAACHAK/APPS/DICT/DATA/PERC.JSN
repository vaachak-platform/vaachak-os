{"PERCA":[{"def":"A genus of fishes, including the fresh-water perch.","pos":""}],"PERCALE":[{"def":"A fine cotton fabric, having a linen finish, and often printed on one side, -- used for women's and children's wear.","pos":""}],"PERCALINE":[{"def":"A fine kind of French cotton goods, usually of one color.","pos":""}],"PERCARBIDE":[{"def":"A compound containing a relatively large amount of carbon.","pos":""}],"PERCARBURETED":[{"def":"Combined with a relatively large amount of carbon.","pos":""}],"PERCASE":[{"def":"Perhaps; perchance.","pos":""}],"PERCEIVABLE":[{"def":"Capable of being perceived; perceptible.","pos":""}],"PERCEIVANCE":[{"def":"Power of perceiving.","pos":""}],"PERCEIVE":[{"def":"To obtain knowledge of through the senses; to receive impressions from by means of the bodily organs; to take cognizance of the existence, character, or identity of, by means of the senses; to see, hear, or feel; as, to perceive a distant ship; to perceive a discord.","pos":""},{"def":"To take intellectual cognizance of; to apprehend by the mind; to be convinced of by direct intuition; to note; to remark; to discern; to see; to understand.","pos":""}],"PERCEIVER":[{"def":"One who perceives (in any of the senses of the verb).","pos":""}],"PERCENTAGE":[{"def":"A certain rate per cent; the allowance, duty, rate of interest, discount, or commission, on a hundred.","pos":""}],"PERCEPT":[{"def":"That which is perceived.","pos":""}],"PERCEPTIBILITY":[{"def":"The quality or state of being perceptible; as, the perceptibility of light or color.","pos":""}],"PERCEPTIBLE":[{"def":"Capable of being perceived; cognizable; discernible; perceivable.","pos":""}],"PERCEPTION":[{"def":"The faculty of perceiving; the faculty, or peculiar part, of man's constitution by which he has knowledge through the medium or instrumentality of the bodily organs; the act of apperhending material objects or qualities through the senses; -- distinguished from conception.","pos":""}],"PERCEPTIVE":[{"def":"Of or pertaining to the act or power of perceiving; having the faculty or power of perceiving; used in perception.","pos":""}],"PERCEPTIVITY":[{"def":"The quality or state of being perceptive; power of perception.","pos":""}],"PERCESOCES":[{"def":"An order of fishes including the gray mullets (Mugil), the barracudas, the silversides, and other related fishes.","pos":""}],"PERCH":[{"def":"Any fresh-water fish of the genus Perca and of several other allied genera of the family Percidæ, as the common American or yellow perch (Perca flavescens, or Americana), and the European perch (P.","pos":""},{"def":"Any one of numerous species of spiny-finned fishes belonging to the Percidæ, Serranidæ, and related families, and resembling, more or less, the true perches.","pos":""}],"PERCHANCE":[{"def":"By chance; perhaps; peradventure.","pos":""}],"PERCHANT":[{"def":"A bird tied by the foot, to serve as decoy to other birds by its fluttering.","pos":""}],"PERCHER":[{"def":"A Paris candle anciently used in England; also, a large wax candle formerly set upon the altar.","pos":""}],"PERCHERON":[{"def":"One of a breed of draught horses originating in Perche, an old district of France; -- called also Percheron-Norman.","pos":""}],"PERCHLORATE":[{"def":"A salt of perchloric acid.","pos":""}],"PERCHLORIC":[{"def":"Pertaining to, or designating, the highest oxygen acid (HClO4), of chlorine; -- called also hyperchloric.","pos":""}],"PERCHLORIDE":[{"def":"A chloride having a higher proportion of chlorine than any other chloride of the same substance or series.","pos":""}],"PERCHROMIC":[{"def":"Pertaining to, or designating, a certain one of the highly oxidized compounds of chromium, which has a deep blue color, and is produced by the action of hydrogen peroxide.","pos":""}],"PERCIFORM":[{"def":"Pertaining to the Perciformes.","pos":""}],"PERCIFORMES":[{"def":"An extensive tribe or suborder of fishes, including the true perches (Percidæ); the pondfishes (Centrarchidæ); the sciænoids (Sciænidæ); the sparoids (Sparidæ); the serranoids (Serranidæ), and some other related families.","pos":""},{"def":"The faculty, act or power of perceiving; perception.","pos":""}],"PERCIPIENT":[{"def":"Having the faculty of perception; perceiving; as, a percipient being.","pos":""},{"def":"One who, or that which, is percipient.","pos":""}],"PERCLOSE":[{"def":"Same as Parclose.","pos":""}],"PERCOID":[{"def":"Belonging to, or resembling, the perches, or family Percidæ.","pos":""},{"def":"Any fish of the genus Perca, or allied genera of the family Percidæ.","pos":""}],"PERCOIDEA":[{"def":"Same as Perciformes.","pos":""}],"PERCOLATE":[{"def":"To cause to pass through fine interstices, as a liquor; to filter; to strain.","pos":""}],"PERCOLATION":[{"def":"The act or process of percolating, or filtering; filtration; straining.","pos":""}],"PERCOLATOR":[{"def":"One who, or that which, filters.","pos":""}],"PERCOMORPHI":[{"def":"A division of fishes including the perches and related kinds.","pos":""}],"PERCURRENT":[{"def":"Running through the entire length.","pos":""}],"PERCURSORY":[{"def":"Running over slightly or in haste; cursory.","pos":""}],"PERCUSS":[{"def":"To strike smartly; to strike upon or against; as, to percuss the chest in medical examination.","pos":""}],"PERCUSSION":[{"def":"The act of tapping or striking the surface of the body in order to learn the condition of the parts beneath by the sound emitted or the sensation imparted to the fingers.","pos":""}],"PERCUSSIVE":[{"def":"Striking against; percutient; as, percussive force.","pos":""}],"PERCUTIENT":[{"def":"Striking; having the power of striking.","pos":""},{"def":"That which strikes, or has power to strike.","pos":""}]}