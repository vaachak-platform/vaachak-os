{"STIVE":[{"def":"To stuff; to crowd; to fill full; hence, to make hot and close; to render stifling.","pos":""}],"STIVER":[{"def":"A Dutch coin, and money of account, of the value of two cents, or about one penny sterling; hence, figuratively, anything of little worth.","pos":""}],"STIVES":[{"def":"Stews; a brothel.","pos":""}]}