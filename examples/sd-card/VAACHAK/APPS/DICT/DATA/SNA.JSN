{"SNACK":[{"def":"A share; a part or portion; -- obsolete, except in the colloquial phrase, to go snacks, i.","pos":""},{"def":"A slight, hasty repast.","pos":""}],"SNACOT":[{"def":"A pipefish of the genus Syngnathus.","pos":""}],"SNAFFLE":[{"def":"A kind of bridle bit, having a joint in the part to be placed in the mouth, and rings and cheek pieces at the ends, but having no curb; -- called also snaffle bit.","pos":""}],"SNAG":[{"def":"One of the secondary branches of an antler.","pos":""}],"SNAGGED":[{"def":"Full of snags; snaggy.","pos":""}],"SNAGGY":[{"def":"Full of snags; full of short, rough branches or sharp points; abounding with knots.","pos":""},{"def":"Snappish; cross; ill-tempered.","pos":""}],"SNAIL":[{"def":"A spiral cam, or a flat piece of metal of spirally curved outline, used for giving motion to, or changing the position of, another part, as the hammer tail of a striking clock.","pos":""},{"def":"The pod of the sanil clover.","pos":""}],"SNAIL-LIKE":[{"def":"Like or suiting a snail; as, snail-like progress.","pos":""}],"SNAIL-PACED":[{"def":"Slow-moving, like a snail.","pos":""},{"def":"God's nails, or His nails, that is, the nails with which the Savior was fastened to the cross; -- an ancient form of oath, corresponding to 'Od's bodikins (dim.","pos":""}],"SNAILFISH":[{"def":"See Sea snail (a).","pos":""}],"SNAKE":[{"def":"Any species of the order Ophidia; an ophidian; a serpent, whether harmless or venomous.","pos":""}],"SNAKE'S-HEAD":[{"def":"The Guinea-hen flower; -- so called in England because its spotted petals resemble the scales of a snake's head.","pos":""}],"SNAKE'S-TONGUE":[{"def":"Same as Adder's-tongue.","pos":""}],"SNAKEBIRD":[{"def":"Any one of four species of aquatic birds of the genus Anhinga or Plotus.","pos":""}],"SNAKEHEAD":[{"def":"A loose, bent-up end of one of the strap rails, or flat rails, formerly used on American railroads.","pos":""}],"SNAKENECK":[{"def":"The snakebird, 1.","pos":""}],"SNAKEROOT":[{"def":"Any one of several plants of different genera and species, most of which are (or were formerly) reputed to be efficacious as remedies for the bites of serpents; also, the roots of any of these.","pos":""}],"SNAKESTONE":[{"def":"An ammonite; -- so called from its form, which resembles that of a coiled snake.","pos":""}],"SNAKISH":[{"def":"Having the qualities or characteristics of a snake; snaky.","pos":""}],"SNAKY":[{"def":"Of or pertaining to a snake or snakes; resembling a snake; serpentine; winding.","pos":""},{"def":"Sly; cunning; insinuating; deceitful.","pos":""}],"SNAP":[{"def":"To break at once; to break short, as substances that are brittle.","pos":""},{"def":"To strike, to hit, or to shut, with a sharp sound.","pos":""}],"SNAPDRAGON":[{"def":"A play in which raisins are snatched from a vessel containing burning brandy, and eaten; also, that which is so eaten.","pos":""}],"SNAPE":[{"def":"To bevel the end of a timber to fit against an inclined surface.","pos":""}],"SNAPHANCE":[{"def":"A spring lock for discharging a firearm; also, the firearm to which it is attached.","pos":""},{"def":"A trifling or second-rate thing or person.","pos":""}],"SNAPHEAD":[{"def":"A hemispherical or rounded head to a rivet or bolt; also, a swaging tool with a cavity in its face for forming such a rounded head.","pos":""}],"SNAPPER":[{"def":"Any one of several species of large sparoid food fishes of the genus Lutjanus, abundant on the southern coasts of the United States and on both coasts of tropical America.","pos":""},{"def":"A snapping turtle; as, the alligator snapper.","pos":""}],"SNAPPING":[{"def":"Snap\"ping, Defn: a.","pos":""}],"SNAPPISH":[{"def":"Apt to snap at persons or things; eager to bite; as, a snapping cur.","pos":""},{"def":"Sharp in reply; apt to speak angrily or testily; easily provoked; tart; peevish.","pos":""}],"SNAPSACK":[{"def":"Commonly Snap shot.","pos":""},{"def":"An instantaneous photograph made, usually with a hand camera, without formal posing of, and often without the foreknowledge of, the subject.","pos":""}],"SNARE":[{"def":"An instrument, consisting usually of a wireloop or noose, for removing tumors, etc.","pos":""}],"SNARER":[{"def":"One who lays snares, or entraps.","pos":""}],"SNARL":[{"def":"To form raised work upon the outer surface of (thin metal ware) by the repercussion of a snarling iron upon the inner surface.","pos":""}],"SNARLER":[{"def":"One who snarls; a surly, growling animal; a grumbling, quarrelsome fellow.","pos":""}],"SNARY":[{"def":"Resembling, or consisting of, snares; entangling; insidious.","pos":""}],"SNAST":[{"def":"The snuff, or burnt wick, of a candle.","pos":""}],"SNATCH":[{"def":"To take or seize hastily, abruptly, or without permission or ceremony; as, to snatch a loaf or a kiss.","pos":""},{"def":"To seize and transport away; to rap.","pos":""}],"SNATCH BLOCK":[{"def":"a kind of block with an opening in one side to receive the bight of a rope.","pos":""}],"SNATCHER":[{"def":"One who snatches, or takes abruptly.","pos":""}],"SNATCHINGLY":[{"def":"By snatching; abruptly.","pos":""}],"SNATH":[{"def":"The handle of a scythe; a snead.","pos":""}],"SNATHE":[{"def":"To lop; to prune.","pos":""}],"SNATTOCK":[{"def":"A chip; a alice.","pos":""}]}