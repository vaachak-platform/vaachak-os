{"ENGAGE":[{"def":"To come into gear with; as, the teeth of one cogwheel engage those of another, or one part of a clutch engages the other part.","pos":""}],"ENGAGED":[{"def":"Occupied; employed; busy.","pos":""},{"def":"Pledged; promised; especially, having the affections pledged; promised in marriage; affianced; betrothed.","pos":""}],"ENGAGEDLY":[{"def":"With attachment; with interest; earnestly.","pos":""}],"ENGAGEDNESS":[{"def":"The state of being deeply interested; earnestness; zeal.","pos":""}],"ENGAGEMENT":[{"def":"An action; a fight; a battle.","pos":""},{"def":"The state of being in gear; as, one part of a clutch is brought into engagement with the other part.","pos":""}],"ENGAGER":[{"def":"One who enters into an engagement or agreement; a surety.","pos":""}],"ENGAGING":[{"def":"Tending to draw the attention or affections; attractive; as, engaging manners or address.","pos":""}],"ENGALLANT":[{"def":"To make a gallant of.","pos":""}],"ENGAOL":[{"def":"To put in jail; to imprison.","pos":""}],"ENGARBOIL":[{"def":"To throw into disorder; to disturb.","pos":""}],"ENGARLAND":[{"def":"To encircle with a garland, or with garlands.","pos":""}],"ENGARRISON":[{"def":"To garrison; to put in garrison, or to protect by a garrison.","pos":""}],"ENGASTRIMUTH":[{"def":"An ventriloquist.","pos":""}],"ENGENDER":[{"def":"To produce by the union of the sexes; to beget.","pos":""},{"def":"To cause to exist; to bring forth; to produce; to sow the seeds of; as, angry words engender strife.","pos":""}],"ENGENDRURE":[{"def":"The act of generation.","pos":""}],"ENGILD":[{"def":"To gild; to make splendent.","pos":""}],"ENGINE":[{"def":"A compound machine by which any physical power is applied to produce a given physical effect.","pos":""}],"ENGINE-SIZED":[{"def":"Sized by a machine, and not while in the pulp; -- said of paper.","pos":""}],"ENGINE-TYPE GENERATOR":[{"def":"A generator having its revolving part carried on the shaft of the driving engine.","pos":""}],"ENGINEER":[{"def":"A person skilled in the principles and practice of any branch of engineering.","pos":""},{"def":"One who manages as engine, particularly a steam engine; an engine driver.","pos":""}],"ENGINEERING":[{"def":"Originally, the art of managing engines; in its modern and extended sense, the art and science by which the mechanical properties of matter are made useful to man in structures and machines; the occupation and work of an engineer.","pos":""}],"ENGINEMAN":[{"def":"A man who manages, or waits on, an engine.","pos":""}],"ENGINER":[{"def":"A contriver; an inventor; a contriver of engines.","pos":""}],"ENGINERY":[{"def":"The act or art of managing engines, or artillery.","pos":""},{"def":"Engines, in general; instruments of war.","pos":""}],"ENGINOUS":[{"def":"Pertaining to an engine.","pos":""},{"def":"Contrived with care; ingenious.","pos":""}],"ENGIRD":[{"def":"To gird; to encompass.","pos":""}],"ENGIRDLE":[{"def":"To surround as with a girdle; to girdle.","pos":""}],"ENGISCOPE":[{"def":"A kind of reflecting microscope.","pos":""}],"ENGLE":[{"def":"A favorite; a paramour; an ingle.","pos":""}],"ENGLISH":[{"def":"Of or pertaining to England, or to its inhabitants, or to the present so-called Anglo-Saxon race.","pos":""},{"def":"See 1st Bond, n.","pos":""}],"ENGLISHABLE":[{"def":"Capable of being translated into, or expressed in, English.","pos":""}],"ENGLISHISM":[{"def":"A quality or characteristic peculiar to the English.","pos":""},{"def":"A form of expression peculiar to the English language as spoken in England; an Anglicism.","pos":""}],"ENGLISHMAN":[{"def":"A native or a naturalized inhabitant of England.","pos":""}],"ENGLISHRY":[{"def":"The state or privilege of being an Englishman.","pos":""},{"def":"A body of English or people of English descent; -- commonly applied to English people in Ireland.","pos":""}],"ENGLUE":[{"def":"To join or close fast together, as with glue; as, a coffer well englued.","pos":""}],"ENGLUT":[{"def":"To swallow or gulp down.","pos":""}],"ENGORE":[{"def":"To gore; to pierce; to lacerate.","pos":""}],"ENGORGE":[{"def":"To gorge; to glut.","pos":""},{"def":"To swallow with greediness or in large quantities; to devour.","pos":""}],"ENGORGED":[{"def":"Filled to excess with blood or other liquid; congested.","pos":""}],"ENGORGEMENT":[{"def":"An overfullness or obstruction of the vessels in some part of the system; congestion.","pos":""},{"def":"The clogging of a blast furnace.","pos":""}],"ENGOULED":[{"def":"Partly swallowed; disappearing in the jaws of anything; as, an infant engouled by a serpent; said also of an ordinary, when its two ends to issue from the mouths of lions, or the like; as, a bend engouled.","pos":""}],"ENGOULEE":[{"def":"Same as Engouled.","pos":""}],"ENGRAFF":[{"def":"To graft; to fix deeply.","pos":""}],"ENGRAFFMENT":[{"def":"See Ingraftment.","pos":""}],"ENGRAFT":[{"def":"The act of ingrafting; ingraftment.","pos":""}],"ENGRAIL":[{"def":"To indent with small curves.","pos":""}],"ENGRAILED":[{"def":"Indented with small concave curves, as the edge of a bordure, bend, or the like.","pos":""}],"ENGRAILMENT":[{"def":"Indentation in curved lines, as of a line of division or the edge of an ordinary.","pos":""}],"ENGRAIN":[{"def":"To dye in grain, or of a fast color.","pos":""},{"def":"To incorporate with the grain or texture of anything; to infuse deeply.","pos":""}],"ENGRASP":[{"def":"To grasp; to grip.","pos":""}],"ENGRAVE":[{"def":"To deposit in the grave; to bury.","pos":""}],"ENGRAVED":[{"def":"Having the surface covered with irregular, impressed lines.","pos":""}],"ENGRAVER":[{"def":"One who engraves; a person whose business it is to produce engraved work, especially on metal or wood.","pos":""}],"ENGRAVERY":[{"def":"The trade or work of an engraver.","pos":""}],"ENGRAVING":[{"def":"The act or art of producing upon hard material incised or raised patterns, characters, lines, and the like; especially, the art of producing such lines, etc.","pos":""},{"def":"That which is engraved; an engraved plate.","pos":""}],"ENGREGGE":[{"def":"To aggravate; to make worse; to lie heavy on.","pos":""}],"ENGROSS":[{"def":"To make gross, thick, or large; to thicken; to increase in bulk or quantity.","pos":""}],"ENGROSSER":[{"def":"One who copies a writing in large, fair characters.","pos":""},{"def":"One who takes the whole; a person who purchases such quantities of articles in a market as to raise the price; a forestaller.","pos":""}],"ENGROSSMENT":[{"def":"The act of engrossing; as, the engrossment of a deed.","pos":""},{"def":"That which has been engrossed, as an instrument, legislative bill, goods, etc.","pos":""}],"ENGUARD":[{"def":"To surround as with a guard.","pos":""}],"ENGULF":[{"def":"To absorb or swallow up as in a gulf.","pos":""}],"ENGULFMENT":[{"def":"A swallowing up as if in a gulf.","pos":""}],"ENGYN":[{"def":"Variant of Engine.","pos":""}]}