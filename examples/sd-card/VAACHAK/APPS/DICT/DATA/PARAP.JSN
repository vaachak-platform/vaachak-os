{"PARAPECTIN":[{"def":"A gelatinous modification of pectin.","pos":""}],"PARAPEGM":[{"def":"An engraved tablet, usually of brass, set up in a public place.","pos":""}],"PARAPEPTONE":[{"def":"An albuminous body formed in small quantity by the peptic digestion of proteids.","pos":""}],"PARAPET":[{"def":"A low wall, especially one serving to protect the edge of a platform, roof, bridge, or the like.","pos":""},{"def":"A wall, rampart, or elevation of earth, for covering soldiers from an enemy's fire; a breastwork.","pos":""}],"PARAPETALOUS":[{"def":"Growing by the side of a petal, as a stamen.","pos":""}],"PARAPETED":[{"def":"Having a parapet.","pos":""}],"PARAPH":[{"def":"A flourish made with the pen at the end of a signature.","pos":""}],"PARAPHERNA":[{"def":"The property of a woman which, on her marriage, was not made a part of her dower, but remained her own.","pos":""}],"PARAPHERNAL":[{"def":"Of or pertaining to paraphernalia; as, paraphernal property.","pos":""}],"PARAPHERNALIA":[{"def":"Something reserved to a wife, over and above her dower, being chiefly apparel and ornaments suited to her degree.","pos":""}],"PARAPHIMOSIS":[{"def":"A condition in which the prepuce, after being retracted behind the glans penis, is constricted there, and can not be brought forward into place again.","pos":""}],"PARAPHOSPHORIC":[{"def":"Par`a*phos*phor\"ic, a.","pos":""}],"PARAPHRAGMA":[{"def":"One of the outer divisions of an endosternite of Crustacea.","pos":""}],"PARAPHRASE":[{"def":"A restatement of a text, passage, or work, expressing the meaning of the original in another form, generally for the sake of its clearer and fuller exposition; a setting forth the signification of a text in other and ampler terms; a free translation or rendering; -- opposed to metaphrase.","pos":""}],"PARAPHRASER":[{"def":"One who paraphrases.","pos":""}],"PARAPHRAST":[{"def":"Paraphrasing; of the nature of paraphrase; explaining, or translating in words more clear and ample than those of the author; not literal; free.","pos":""}],"PARAPHYSIS":[{"def":"A minute jointed filament growing among the archegonia and antheridia of mosses, or with the spore cases, etc.","pos":""},{"def":"Palsy of the lower half of the body on both sides, caused usually by disease of the spinal cord.","pos":""}],"PARAPLEURA":[{"def":"A chitinous piece between the metasternum and the pleuron of certain insects.","pos":""}],"PARAPODIUM":[{"def":"One of the lateral appendages of an annelid; -- called also foot tubercle.","pos":""}],"PARAPOPHYSIS":[{"def":"The ventral transverse, or capitular, process of a vertebra.","pos":""}],"PARAPTERUM":[{"def":"A special plate situated on the sides of the mesothorax and metathorax of certain insects.","pos":""}]}