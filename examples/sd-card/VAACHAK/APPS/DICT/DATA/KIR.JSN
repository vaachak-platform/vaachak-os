{"KIRK":[{"def":"A church or the church, in the various senses of the word; esp.","pos":""}],"KIRKED":[{"def":"Turned upward; bent.","pos":""}],"KIRKMAN":[{"def":"A clergyman or officer in a kirk.","pos":""},{"def":"A member of the Church of Scotland, as distinguished from a member of another communion.","pos":""}],"KIRMESS":[{"def":"In Europe, particularly in Belgium and Holland, and outdoor festival and fair; in the United States, generally an indoor entertainment and fair combined.","pos":""}],"KIRSCHWASSER":[{"def":"An alcoholic liquor, obtained by distilling the fermented juice of the small black cherry.","pos":""}],"KIRSOME":[{"def":"Christian; christened.","pos":""}],"KIRTLE":[{"def":"A garment varying in form and use at different times, and worn doth by men and women.","pos":""}],"KIRTLED":[{"def":"Wearing a kirtle.","pos":""}],"KIRUMBO":[{"def":"A bird of Madagascar (Leptosomus discolor), the only living type of a family allied to the rollers.","pos":""}]}