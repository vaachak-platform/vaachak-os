{"MORBID":[{"def":"Not sound and healthful; induced by a diseased or abnormal condition; diseased; sickly; as, morbid humors; a morbid constitution; a morbid state of the juices of a plant.","pos":""},{"def":"Of or pertaining to disease or diseased parts; as, morbid anatomy.","pos":""}],"MORBIDEZZA":[{"def":"Delicacy or softness in the representation of flesh.","pos":""},{"def":"A term used as a direction in execution, signifying, with extreme delicacy.","pos":""}],"MORBIDITY":[{"def":"The quality or state of being morbid.","pos":""},{"def":"Morbid quality; disease; sickness.","pos":""}],"MORBIDLY":[{"def":"In a morbid manner.","pos":""}],"MORBIDNESS":[{"def":"The quality or state of being morbid; morbidity.","pos":""},{"def":"Causing disease; generating a sickly state; as, a morbific matter.","pos":""}],"MORBILLOUS":[{"def":"Pertaining to the measles; partaking of the nature of measels, or resembling the eruptions of that disease; measly.","pos":""}],"MORBOSE":[{"def":"Proceeding from disease; morbid; unhealthy.","pos":""}],"MORBOSITY":[{"def":"A diseased state; unhealthiness.","pos":""}]}