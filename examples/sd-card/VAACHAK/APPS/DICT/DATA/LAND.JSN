{"LAND":[{"def":"The ground left unplowed between furrows; any one of several portions into which a field is divided for convenience in plowing.","pos":""},{"def":"Any ground, soil, or earth whatsoever, as meadows, pastures, woods, etc.","pos":""}],"LAND LEAGUE":[{"def":"In Ireland, a combination of tenant farmers and other, organized, with Charles Stewart Parnell as president, in 1879 with a view to the reduction of farm rents and a reconstruction of the land laws.","pos":""}],"LAND OF STEADY HABITS":[{"def":"Connecticut; -- a nickname alluding to the moral character of its inhabitants, implied by the rigid laws (see Blue laws) of the early period.","pos":""}],"LAND-POOR":[{"def":"Pecuniarily embarrassed through owning much unprofitable land.","pos":""}],"LANDAMMAN":[{"def":"A chief magistrate in some of the Swiss cantons.","pos":""},{"def":"The president of the diet of the Helvetic republic.","pos":""}],"LANDAU":[{"def":"A four-wheeled covered vehicle, the top of which is divided into two sections which can be let down, or thrown back, in such a manner as to make an open carriage.","pos":""}],"LANDAULET":[{"def":"LANDDROST; LANDTROST Land\"drost`, n.","pos":""}],"LANDED":[{"def":"Having an estate in land.","pos":""},{"def":"Consisting in real estate or land; as, landed property; landed security.","pos":""}],"LANDER":[{"def":"A person who waits at the mouth of the shaft to receive the kibble of ore.","pos":""}],"LANDFALL":[{"def":"Sighting or making land when at sea.","pos":""}],"LANDFLOOD":[{"def":"An overflowing of land by river; an inundation; a freshet.","pos":""}],"LANDGRAVE":[{"def":"A German nobleman of a rank corresponding to that of an earl in England and of a count in France.","pos":""}],"LANDGRAVIATE":[{"def":"The territory held by a landgrave.","pos":""},{"def":"The office, jurisdiction, or authority of a landgrave.","pos":""}],"LANDGRAVINE":[{"def":"The wife of a landgrave.","pos":""}],"LANDHOLDER":[{"def":"A holder, owner, or proprietor of land.","pos":""}],"LANDING":[{"def":"Of, pertaining to or used for, setting, bringing, or going, on shore.","pos":""}],"LANDLADY":[{"def":"A woman having real estate which she leases to a tenant or tenants.","pos":""},{"def":"The mistress of an inn or lodging house.","pos":""}],"LANDLESS":[{"def":"Having no property in land.","pos":""}],"LANDLOCK":[{"def":"To inclose, or nearly inclose, as a harbor or a vessel, with land.","pos":""}],"LANDLOCKED":[{"def":"Confined to a fresh-water lake by reason of waterfalls or dams; -- said of fishes that would naturally seek the sea, after spawning; as, the landlocked salmon.","pos":""}],"LANDLOPER":[{"def":"Same as Landlouper.","pos":""}],"LANDLORD":[{"def":"The lord of a manor, or of land; the owner of land or houses which he leases to a tenant or tenants.","pos":""},{"def":"The master of an inn or of a lodging house.","pos":""}],"LANDLORDISM":[{"def":"The state of being a landlord; the characteristics of a landlord; specifically, in Great Britain, the relation of landlords to tenants, especially as regards leased agricultural lands.","pos":""}],"LANDLORDRY":[{"def":"The state of a landlord.","pos":""}],"LANDLOUPER":[{"def":"A vagabond; a vagrant.","pos":""}],"LANDLOUPING":[{"def":"Vagrant; wandering about.","pos":""}],"LANDLUBBER":[{"def":"One who passes his life on land; -- so called among seamen in contempt or ridicule.","pos":""}],"LANDMAN":[{"def":"An occupier of land.","pos":""}],"LANDMARK":[{"def":"A mark to designate the boundary of land; any , mark or fixed object (as a marked tree, a stone, a ditch, or a heap of stones) by which the limits of a farm, a town, or other portion of territory may be known and preserved.","pos":""},{"def":"Any conspicuous object on land that serves as a guide; some prominent object, as a hill or steeple.","pos":""}],"LANDOWNER":[{"def":"An owner of land.","pos":""}],"LANDOWNING":[{"def":"The owning of land.","pos":""},{"def":"Having property in land; of or pertaining to landowners.","pos":""}],"LANDREEVE":[{"def":"A subordinate officer on an extensive estate, who acts as an assistant to the steward.","pos":""}],"LANDSCAPE":[{"def":"A portion of land or territory which the eye can comprehend in a single view, including all the objects it contains.","pos":""},{"def":"A picture representing a scene by land or sea, actual or fancied, the chief subject being the general aspect of nature, as fields, hills, forests, water.","pos":""}],"LANDSCAPIST":[{"def":"A painter of landscapes.","pos":""}],"LANDSKIP":[{"def":"The slipping down of a mass of land from a mountain, hill, etc.","pos":""},{"def":"The land which slips down.","pos":""}],"LANDSMAN":[{"def":"A sailor on his first voyage.","pos":""}],"LANDSTHING":[{"def":"See Legislature, below.","pos":""}],"LANDSTORM":[{"def":"See Varnpligtige.","pos":""}],"LANDSTREIGHT":[{"def":"A narrow strip of land.","pos":""}],"LANDSTURM":[{"def":"That part of the reserve force in Germany which is called out last.","pos":""}],"LANDTAG":[{"def":"The diet or legislative body; as, the Landtag of Prussia.","pos":""}],"LANDWAITER":[{"def":"See Landing waiter, under Landing, a.","pos":""}],"LANDWARD":[{"def":"Toward the land.","pos":""}],"LANDWEHR":[{"def":"That part of the army, in Germany and Austria, which has completed the usual military service and is exempt from duty in time of peace, except that it is called out occasionally for drill.","pos":""}]}