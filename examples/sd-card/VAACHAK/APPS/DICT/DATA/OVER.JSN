{"OVER":[{"def":"Above, or higher than, in place or position, with the idea of covering; -- opposed to Ant: under; as, clouds are over our heads; the smoke rises over the city.","pos":""},{"def":"Across; from side to side of; -- implying a passing or moving, either above the substance or thing, or on the surface of it; as, a dog leaps over a stream or a table.","pos":""}],"OVER-ARM":[{"def":"Done (as bowling or pitching) with the arm raised above the shoulder.","pos":""}],"OVER-BUSY":[{"def":"Too busy; officious.","pos":""}],"OVER-GARMENT":[{"def":"An outer garment.","pos":""}],"OVER-STORY":[{"def":"The clearstory, or upper story, of a building.","pos":""}]}