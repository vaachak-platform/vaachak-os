{"SPEECH":[{"def":"The faculty of uttering articulate sounds or words; the faculty of expressing thoughts by words or articulate sounds; the power of speaking.","pos":""},{"def":"A particular language, as distinct from others; a tongue; a dialect.","pos":""}],"SPEECHFUL":[{"def":"Full of speech or words; voluble; loquacious.","pos":""}],"SPEECHIFICATION":[{"def":"The act of speechifying.","pos":"noun"}],"SPEECHIFIER":[{"def":"One who makes a speech or speeches; an orator; a declaimer.","pos":""}],"SPEECHIFY":[{"def":"To make a speech; to harangue.","pos":""}],"SPEECHIFYING":[{"def":"The act of making a speech or speeches.","pos":""}],"SPEECHING":[{"def":"The act of making a speech.","pos":""}],"SPEECHLESS":[{"def":"Destitute or deprived of the faculty of speech.","pos":""},{"def":"Not speaking for a time; dumb; mute; silent.","pos":""}],"SPEECHMAKER":[{"def":"One who makes speeches; one accustomed to speak in a public assembly.","pos":""}],"SPEED":[{"def":"Prosperity in an undertaking; favorable issue; success.","pos":""},{"def":"The act or state of moving swiftly; swiftness; velocity; rapidly; rate of motion; dispatch; as, the speed a horse or a vessel.","pos":""}],"SPEED COUNTER":[{"def":"A device for automatically counting the revolutions or pulsations of an engine or other machine; -- called also simply counter.","pos":""}],"SPEEDER":[{"def":"A machine for drawing and twisting slivers to form rovings.","pos":""}],"SPEEDFUL":[{"def":"Full of speed (in any sense).","pos":""}],"SPEEDFULLY":[{"def":"In a speedful manner.","pos":""}],"SPEEDILY":[{"def":"In a speedy manner.","pos":""}],"SPEEDINESS":[{"def":"The quality or state of being speedy.","pos":""}],"SPEEDLESS":[{"def":"Being without speed.","pos":""}],"SPEEDWELL":[{"def":"Any plant of the genus Veronica, mostly low herbs with pale blue corollas, which quickly fall off.","pos":""}],"SPEEDY":[{"def":"Not dilatory or slow; quick; swift; nimble; hasty; rapid in motion or performance; as, a speedy flight; on speedy foot.","pos":""}]}