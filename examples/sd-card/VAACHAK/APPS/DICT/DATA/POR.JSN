{"PORAILLE":[{"def":"Poor people; the poor.","pos":""}],"PORBEAGLE":[{"def":"A species of shark (Lamna cornubica), about eight feet long, having a pointed nose and a crescent-shaped tail; -- called also mackerel shark.","pos":""}],"PORCATE":[{"def":"Having grooves or furrows broader than the intervening ridges; furrowed.","pos":""}],"PORCELAIN":[{"def":"A fine translucent or semitransculent kind of earthenware, made first in China and Japan, but now also in Europe and America; -- called also China, or China ware.","pos":""}],"PORCELAINIZED":[{"def":"Baked like potter's lay; -- applied to clay shales that have been converted by heat into a substance resembling porcelain.","pos":""},{"def":"Having a smooth, compact shell without pores; -- said of certain Foraminifera.","pos":""}],"PORCELANITE":[{"def":"A semivitrified clay or shale, somewhat resembling jasper; -- called also porcelain jasper.","pos":""}],"PORCH":[{"def":"A covered and inclosed entrance to a building, whether taken from the interior, and forming a sort of vestibule within the main wall, or projecting without and with a separate roof.","pos":""}],"PORCINE":[{"def":"Of or pertaining to swine; characteristic of the hog.","pos":""}],"PORCUPINE":[{"def":"Any Old Word rodent of the genus Hystrix, having the back covered with long, sharp, erectile spines or quills, sometimes a foot long.","pos":""},{"def":"Any species of Erethizon and related genera, native of America.","pos":""}],"PORE":[{"def":"One of the minute orifices in an animal or vegetable membrane, for transpiration, absorption, etc.","pos":""},{"def":"A minute opening or passageway; an interstice between the constituent particles or molecules of a body; as, the pores of stones.","pos":""}],"POREBLIND":[{"def":"Nearsighted; shortsighted; purblind.","pos":""}],"PORIFERA":[{"def":"A grand division of the Invertebrata, including the sponges; -- called also Spongiæ, Spongida, and Spongiozoa.","pos":""}],"PORIFERAN":[{"def":"One of the Polifera.","pos":""}],"PORIFORM":[{"def":"Resembling a pore, or small puncture.","pos":""}],"PORIME":[{"def":"A theorem or proposition so easy of demonstration as to be almost self-evident.","pos":""}],"PORISM":[{"def":"A proposition affirming the possibility of finding such conditions as will render a certain determinate problem indeterminate or capable of innumerable solutions.","pos":""}],"PORITE":[{"def":"Any coral of the genus Porites, or family Poritidæ.","pos":""}],"PORITES":[{"def":"An important genus of reef-building corals having small twelve- rayed calicles, and a very porous coral.","pos":""}],"PORK":[{"def":"The flesh of swine, fresh or salted, used for food.","pos":""}],"PORKET":[{"def":"A young hog; a pig.","pos":""}],"PORKLING":[{"def":"A pig; a porket.","pos":""}],"PORKWOOD":[{"def":"The coarse-grained brownish yellow wood of a small tree (Pisonia obtusata) of Florida and the West Indies.","pos":""}],"PORNERASTIC":[{"def":"Lascivious; licentious.","pos":""}],"PORNOGRAPHIC":[{"def":"Of or pertaining to pornography; lascivious; licentious; as, pornographic writing.","pos":""}],"PORNOGRAPHY":[{"def":"A treatise on prostitutes, or prostitution.","pos":""}],"POROSITY":[{"def":"The quality or state of being porous; -- opposed to density.","pos":""}],"POROTIC":[{"def":"A medicine supposed to promote the formation of callus.","pos":""}],"POROTYPE":[{"def":"A copy of a print, writing, etc.","pos":""}],"POROUS":[{"def":"Full of pores; having interstices in the skin or in the substance of the body; having spiracles or passages for fluids; permeable by liquids; as, a porous skin; porous wood.","pos":""}],"POROUSLY":[{"def":"In a porous manner.","pos":""}],"POROUSNESS":[{"def":"The quality of being porous.","pos":""},{"def":"The open parts; the interstices of anything.","pos":""}],"PORPHYRITE":[{"def":"A rock with a porphyritic structure; as, augite porphyrite.","pos":""}],"PORPHYRITIC":[{"def":"Relating to, or resembling, porphyry, that is, characterized by the presence of distinct crystals, as of feldspar, quartz, or augite, in a relatively fine-grained base, often aphanitic or cryptocrystalline.","pos":""}],"PORPHYRIZATION":[{"def":"The act of porphyrizing, or the state of being porphyrized.","pos":""}],"PORPHYRIZE":[{"def":"To cause to resemble porphyry; to make spotted in composition, like porphyry.","pos":""}],"PORPHYROGENITISM":[{"def":"The principle of succession in royal families, especially among the Eastern Roman emperors, by which a younger son, if born after the accession of his father to the throne, was preferred to an elder son who was not so born.","pos":""}],"PORPHYRY":[{"def":"A term used somewhat loosely to designate a rock consisting of a fine-grained base (usually feldspathic) through which crystals, as of feldspar or quartz, are disseminated.","pos":""}],"PORPITA":[{"def":"A genus of bright-colored Siphonophora found floating in the warmer parts of the ocean.","pos":""}],"PORPOISE":[{"def":"Any small cetacean of the genus Phocæna, especially P.","pos":""},{"def":"A true dolphin (Delphinus); -- often so called by sailors.","pos":""}],"PORPORINO":[{"def":"A composition of quicksilver, tin, and sulphur, forming a yellow powder, sometimes used by mediæval artists, for the sake of economy, instead of gold.","pos":""}],"PORRACEOUS":[{"def":"Resembling the leek in color; greenish.","pos":""}],"PORRECT":[{"def":"Extended horizontally; stretched out.","pos":""}],"PORRECTION":[{"def":"The act of stretching forth.","pos":""}],"PORRET":[{"def":"A scallion; a leek or small onion.","pos":""}],"PORRIDGE":[{"def":"A food made by boiling some leguminous or farinaceous substance, or the meal of it, in water or in milk, making of broth or thin pudding; as, barley porridge, milk porridge, bean porridge, etc.","pos":""}],"PORRINGER":[{"def":"A porridge dish; esp.","pos":""}],"PORT":[{"def":"A dark red or purple astringent wine made in Portugal.","pos":""}],"PORT-ROYALIST":[{"def":"One of the dwellers in the Cistercian convent of Port Royal des Champs, near Paris, when it was the home of the Jansenists in the 17th century, among them being Arnauld, Pascal, and other famous scholars.","pos":""}],"PORTABILITY":[{"def":"The quality or state of being portable; fitness to be carried.","pos":""}],"PORTABLE":[{"def":"Capable of being borne or carried; easily transported; conveyed without difficulty; as, a portable bed, desk, engine.","pos":""},{"def":"Possible to be endured; supportable.","pos":""}],"PORTABLENESS":[{"def":"The quality or state of being portable; portability.","pos":""}],"PORTAGE":[{"def":"The act of carrying or transporting.","pos":""},{"def":"The price of carriage; porterage.","pos":""}],"PORTAGE GROUP":[{"def":"A subdivision of the Chemung period in American geology.","pos":""}],"PORTAGUE":[{"def":"A Portuguese gold coin formerly current, and variously estimated to be worth from three and one half to four and one half pounds sterling.","pos":""}],"PORTAL":[{"def":"The space, at one end, between opposite trusses when these are terminated by inclined braces.","pos":""}],"PORTAMENTO":[{"def":"In singing, or in the use of the bow, a gradual carrying or lifting of the voice or sound very smoothly from one note to another; a gliding from tone to tone.","pos":""}],"PORTANCE":[{"def":"See Port, carriage, demeanor.","pos":""}],"PORTASS":[{"def":"A breviary; a prayer book.","pos":""}],"PORTATE":[{"def":"Borne not erect, but diagonally athwart an escutcheon; as, a cross portate.","pos":""}],"PORTATIVE":[{"def":"Capable of holding up or carrying; as, the portative force of a magnet, of atmospheric pressure, or of capillarity.","pos":""}],"PORTCRAYON":[{"def":"A metallic handle with a clasp for holding a crayon.","pos":""}],"PORTCULLIS":[{"def":"A grating of iron or of timbers pointed with iron, hung over the gateway of a fortress, to be let down to prevent the entrance of an enemy.","pos":""}],"PORTE":[{"def":"The Ottoman court; the government of the Turkish empire, officially called the Sublime Porte, from the gate (port) of the sultan's palace at which justice was administered.","pos":""}],"PORTE-COCHERE":[{"def":"A large doorway allowing vehicles to drive into or through a building.","pos":""}],"PORTED":[{"def":"We took the sevenfold-ported Thebes.","pos":""}],"PORTEMONNAIE":[{"def":"A small pocketbook or wallet for carrying money.","pos":""}],"PORTEND":[{"def":"To indicate (events, misfortunes, etc.","pos":""},{"def":"To stretch out before.","pos":""}],"PORTENSION":[{"def":"The act of foreshowing; foreboding.","pos":""}],"PORTENT":[{"def":"That which portends, or foretoken; esp.","pos":""}],"PORTENTIVE":[{"def":"Presaging; foreshadowing.","pos":""}],"PORTENTOUS":[{"def":"Of the nature of a portent; containing portents; foreschadowing, esp.","pos":""},{"def":"Hence: Monstrous; prodigious; wonderful; dreadful; as, a beast of portentous size.","pos":""}],"PORTER":[{"def":"A man who has charge of a door or gate; a doorkeeper; one who waits at the door to receive messages.","pos":""}],"PORTERAGE":[{"def":"The work of a porter; the occupation of a carrier or of a doorkeeper.","pos":""},{"def":"Money charged or paid for the carriage of burdens or parcels by a porter.","pos":""}],"PORTERHOUSE":[{"def":"A house where porter is sold.","pos":""}],"PORTFIRE":[{"def":"A case of strong paper filled with a composition of niter, sulphur, and mealed powder, -- used principally to ignite the priming in proving guns, and as an incendiary material in shells.","pos":""}],"PORTFOLIO":[{"def":"A portable case for holding loose papers, prints, drawings, etc.","pos":""},{"def":"Hence: The office and functions of a minister of state or member of the cabinet; as, to receive the portfolio of war; to resign the portfolio.","pos":""}],"PORTGLAVE":[{"def":"In old English law, the chief magistrate of a port or maritime town.","pos":""}],"PORTHOLE":[{"def":"An embrasure in a ship's side.","pos":""}],"PORTHOOK":[{"def":"One of the iron hooks to which the port hinges are attached.","pos":""}],"PORTICO":[{"def":"A colonnade or covered ambulatory, especially in classical styles of architecture; usually, a colonnade at the entrance of a building.","pos":""}],"PORTICOED":[{"def":"Furnished with a portico.","pos":""}],"PORTIERE":[{"def":"A curtain hanging across a doorway.","pos":""}],"PORTINGAL":[{"def":"Of or pertaining to Portugal; Portuguese.","pos":""}],"PORTION":[{"def":"That which is divided off or separated, as a part from a whole; a separated part of anything.","pos":""},{"def":"A part considered by itself, though not actually cut off or separated from the whole.","pos":""}],"PORTIONER":[{"def":"See Portionist, 2.","pos":""}],"PORTIONIST":[{"def":"One of the incumbents of a benefice which has two or more rectors or vicars.","pos":""}],"PORTIONLESS":[{"def":"Having no portion.","pos":""}],"PORTLAND CEMENT":[{"def":"A cement having the color of the Portland stone of England, made by calcining an artificial mixture of carbonate of lime and clay, or sometimes certain natural limestones or chalky clays.","pos":""}],"PORTLAND STONE":[{"def":"A yellowish-white calcareous freestone from the Isle of Portland in England, much used in building.","pos":""}],"PORTLAND VASE":[{"def":"A celebrated cinerary urn or vase found in the tomb of the Emperor Alexander Severus.","pos":""}],"PORTLINESS":[{"def":"The quality or state of being portly; dignity of mien or of personal appearance; stateliness.","pos":""},{"def":"Bulkiness; corpulence.","pos":""}],"PORTLY":[{"def":"Having a dignified port or mien; of a noble appearance; imposing.","pos":""},{"def":"Bulky; corpulent.","pos":""}],"PORTMAN":[{"def":"An inhabitant or burgess of a port, esp.","pos":""}],"PORTMANTEAU":[{"def":"A bag or case, usually of leather, for carrying wearing apparel, etc.","pos":""}],"PORTMOTE":[{"def":"In old English law, a court, or mote, held in a port town.","pos":""}],"PORTOIR":[{"def":"One who, or that which, bears; hence, one who, or that which, produces.","pos":""}],"PORTOISE":[{"def":"The gunwale of a ship.","pos":""}],"PORTPANE":[{"def":"A cloth for carrying bread, so as not to touch it with the hands.","pos":""}],"PORTRAIT":[{"def":"The likeness of a person, painted, drawn, or engraved; commonly, a representation of the human face painted from real life.","pos":""},{"def":"Hence, any graphic or vivid delineation or description of a person; as, a portrait in words.","pos":""}],"PORTRAITIST":[{"def":"A portrait painter.","pos":""}],"PORTRAITURE":[{"def":"A portrait; a likeness; a painted resemblance; hence, that which is copied from some example or model.","pos":""},{"def":"Pictures, collectively; painting.","pos":""}],"PORTRAY":[{"def":"To paint or draw the likeness of; as, to portray a king on horseback.","pos":""},{"def":"Hence, figuratively, to describe in words.","pos":""}],"PORTRAYAL":[{"def":"The act or process of portraying; description; delineation.","pos":""}],"PORTRAYER":[{"def":"One who portrays.","pos":""}],"PORTRESS":[{"def":"A female porter.","pos":""}],"PORTSALE":[{"def":"Public or open sale; auction.","pos":""}],"PORTUGUESE":[{"def":"Of or pertaining to Portugal, or its inhabitants.","pos":""},{"def":"A native or inhabitant of Portugal; people of Portugal.","pos":""}],"PORTULACA":[{"def":"A genus of polypetalous plants; also, any plant of the genus.","pos":""}],"PORTULACACEOUS":[{"def":"Of or pertaining to a natural order of plants (Portulacaceæ), of which Portulaca is the type, and which includes also the spring beauty (Claytonia) and other genera.","pos":""}],"PORY":[{"def":"Porous; as, pory stone.","pos":""}]}