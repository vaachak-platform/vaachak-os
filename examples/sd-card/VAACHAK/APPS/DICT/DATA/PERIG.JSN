{"PERIGANGLIONIC":[{"def":"Surrounding a ganglion; as, the periganglionic glands of the frog.","pos":""}],"PERIGASTRIC":[{"def":"Surrounding the stomach; -- applied to the body cavity of Bryozoa and various other Invertebrata.","pos":""}],"PERIGEAN":[{"def":"Pertaining to the perigee.","pos":""},{"def":"That point in the orbit of the moon which is nearest to the earth; -- opposed to Ant: apogee.","pos":""}],"PERIGENESIS":[{"def":"A theory which explains inheritance by the transmission of the type of growth force possessed by one generation to another.","pos":""}],"PERIGENETIC":[{"def":"Of or pertaining to perigenesis.","pos":""}],"PERIGONE":[{"def":"A sac which surrounds the generative bodies in the gonophore of a hydroid.","pos":""}],"PERIGONIUM":[{"def":"Same as Perigone.","pos":""}],"PERIGORD PIE":[{"def":"A pie made of truffles, much esteemed by epicures.","pos":""}],"PERIGRAPH":[{"def":"A careless or inaccurate delineation of anything.","pos":""}],"PERIGYNIUM":[{"def":"Some unusual appendage about the pistil, as the bottle-shaped body in the sedges, and the bristles or scales in some other genera of the Sedge family, or Cyperaceæ.","pos":""}],"PERIGYNOUS":[{"def":"Having the ovary free, but the petals and stamens borne on the calyx; -- said of flower such as that of the cherry or peach.","pos":""},{"def":"That point of the orbit of a planet or comet which is nearest to the sun; -- opposed to Ant: aphelion.","pos":""}]}