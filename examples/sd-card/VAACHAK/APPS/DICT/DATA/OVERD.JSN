{"OVERDARE":[{"def":"To dare too much or rashly; to be too daring.","pos":""}],"OVERDATE":[{"def":"To date later than the true or proper period.","pos":""}],"OVERDEAL":[{"def":"The overdeal in the price will be double.","pos":""}],"OVERDELIGHTED":[{"def":"Delighted beyond measure.","pos":""}],"OVERDEVELOP":[{"def":"To develop excessively; specif.","pos":""},{"def":"to subject (a plate or film) too long to the developing process.","pos":""}],"OVERDO":[{"def":"To do too much; to exceed what is proper or true in doing; to exaggerate; to carry too far.","pos":""}],"OVERDOER":[{"def":"One who overdoes.","pos":""}],"OVERDOSE":[{"def":"To dose to excess; to give an overdose, or too many doses, to.","pos":""}],"OVERDRAFT":[{"def":"The act of overdrawing; also, the amount or sum overdrawn.","pos":""}],"OVERDRAW":[{"def":"To make drafts upon or against, in excess of the proper amount or limit.","pos":""}],"OVERDRESS":[{"def":"To dress or adorn to excess; to dress too much.","pos":""}],"OVERDRINK":[{"def":"To drink to excess.","pos":""}],"OVERDRIVE":[{"def":"To drive too hard, or far, or beyond strength.","pos":""}],"OVERDROWN":[{"def":"To wet or drench to excess.","pos":""}],"OVERDRY":[{"def":"To dry too much.","pos":""}],"OVERDUE":[{"def":"Due and more than due; delayed beyond the proper time of arrival or payment, etc.","pos":""}],"OVERDYE":[{"def":"To dye with excess of color; to put one color over (another).","pos":""}]}