{"PRESS":[{"def":"An East Indian insectivore (Tupaia ferruginea).","pos":""}],"PRESS CAKE":[{"def":"A cake of compressed substance, as: in gunpowder manufacture, the cake resulting from compressing the meal powder; in the treatment of coal tar, the pressed product at various stages of the process; or, in beet-sugar manufacture, the vegetable residue after the sugar juice has been expressed.","pos":""}],"PRESS REVISE":[{"def":"A proof for final revision.","pos":""}],"PRESSBOARD":[{"def":"A kind of highly sized rag paper or board, sometimes containing a small admixture of wood pulp; -- so called because used originally, as now, in presses for pressing and finishing knit underwear.","pos":""}],"PRESSER":[{"def":"One who, or that which, presses.","pos":""}],"PRESSGANG":[{"def":"See Press gang, under Press.","pos":""}],"PRESSING":[{"def":"Urgent; exacting; importunate; as, a pressing necessity.","pos":""}],"PRESSION":[{"def":"An endeavor to move.","pos":""}],"PRESSIROSTER":[{"def":"One of a tribe of wading birds (Pressirostres) including those which have a compressed beak, as the plovers.","pos":""}],"PRESSIROSTRAL":[{"def":"Of or pertaining to the pressirosters.","pos":""}],"PRESSITANT":[{"def":"Gravitating; heavy.","pos":""}],"PRESSIVE":[{"def":"Pressing; urgent; also, oppressive; as, pressive taxation.","pos":""}],"PRESSLY":[{"def":"Closely; concisely.","pos":""}],"PRESSMAN":[{"def":"One who manages, or attends to, a press, esp.","pos":""},{"def":"One who presses clothes; as, a tailor's pressman.","pos":""}],"PRESSOR":[{"def":"Causing, or giving rise to, pressure or to an increase of pressure; as, pressor nerve fibers, stimulation of which excites the vasomotor center, thus causing a stronger contraction of the arteries and consequently an increase of the arterial blood pressure; -- opposed to depressor.","pos":""}],"PRESSPACK":[{"def":"To pack, or prepare for packing, by means of a press.","pos":""}],"PRESSURAGE":[{"def":"The juice of the grape extracted by the press; also, a fee paid for the use of a wine press.","pos":""}],"PRESSURE":[{"def":"The action of a force against some obstacle or opposing force; a force in the nature of a thrust, distributed over a surface, often estimated with reference to the upon a unit's area.","pos":""}],"PRESSURE WIRES":[{"def":"Wires leading from various points of an electric system to a central station, where a voltmeter indicates the potential of the system at those points.","pos":""}],"PRESSWORK":[{"def":"The art of printing from the surface of type, plates, or engravings in relief, by means of a press; the work so done.","pos":""}]}