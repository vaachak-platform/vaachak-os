{"OVERPAINT":[{"def":"To color or describe too strongly.","pos":""}],"OVERPAMPER":[{"def":"To pamper excessively; to feed or dress too much.","pos":""}],"OVERPART":[{"def":"To give too important or difficult a part to.","pos":""}],"OVERPASS":[{"def":"To go over or beyond; to cross; as, to overpass a river; to overpass limits.","pos":""},{"def":"To pass over; to omit; to overlook; to disregard.","pos":""}],"OVERPASSIONATE":[{"def":"Passionate to excess.","pos":""}],"OVERPATIENT":[{"def":"Patient to excess.","pos":""}],"OVERPAY":[{"def":"To pay too much to; to reward too highly.","pos":""}],"OVERPEER":[{"def":"To peer over; to rise above.","pos":""}],"OVERPEOPLE":[{"def":"To people too densely.","pos":""}],"OVERPERCH":[{"def":"To perch upon; to fly over.","pos":""}],"OVERPERSUADE":[{"def":"To persuade or influence against one's inclination or judgment.","pos":""}],"OVERPESTER":[{"def":"To pester exceedingly or excessively.","pos":""}],"OVERPICTURE":[{"def":"To surpass nature in the picture or representation of.","pos":""}],"OVERPLEASE":[{"def":"To please excessively.","pos":""}],"OVERPLUS":[{"def":"That which remains after a supply, or beyond a quantity proposed; surplus.","pos":""}],"OVERPLY":[{"def":"To ply to excess; to exert with too much vigor; to overwork.","pos":""}],"OVERPOISE":[{"def":"To outweigh; to overbalance.","pos":""}],"OVERPOLISH":[{"def":"To polish too much.","pos":""}],"OVERPOST":[{"def":"To post over; to pass over swiftly, as by post.","pos":""}],"OVERPOTENT":[{"def":"Too potent or powerful.","pos":""}],"OVERPOWER":[{"def":"To excel or exceed in power; to cause to yield; to vanquish; to subdue; as, the light overpowers the eyes.","pos":""}],"OVERPOWERING":[{"def":"Excelling in power; too powerful; irresistible.","pos":""}],"OVERPRAISE":[{"def":"To praise excessively or unduly.","pos":""}],"OVERPRAISING":[{"def":"The act of praising unduly; excessive praise.","pos":""}],"OVERPRESS":[{"def":"To bear upon with irresistible force; to crush; to overwhelm.","pos":""},{"def":"To overcome by importunity.","pos":""}],"OVERPRESSURE":[{"def":"Excessive pressure or urging.","pos":""}],"OVERPRIZE":[{"def":"Toprize excessively; to overvalue.","pos":""}],"OVERPRODUCTION":[{"def":"Excessive production; supply beyond the demand.","pos":""}],"OVERPROMPT":[{"def":"Too prompt; too ready or eager; precipitate.","pos":""}],"OVERPROOF":[{"def":"Containing more alcohol than proof spirit; stronger than proof spirit; that is, containing more than 49.","pos":""}],"OVERPROPORTION":[{"def":"To make of too great proportion.","pos":""}],"OVERPROUD":[{"def":"Exceedingly or unduly proud.","pos":""}],"OVERPROVOKE":[{"def":"To provoke excessively.","pos":""}]}