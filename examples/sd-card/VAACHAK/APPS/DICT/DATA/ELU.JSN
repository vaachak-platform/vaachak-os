{"ELUCIDATE":[{"def":"To make clear or manifest; to render more intelligible; to illustrate; as, an example will elucidate the subject.","pos":""}],"ELUCIDATION":[{"def":"A making clear; the act of elucidating or that which elucidates, as an explanation, an exposition, an illustration; as, one example may serve for further elucidation of the subject.","pos":""}],"ELUCIDATIVE":[{"def":"Making clear; tending to elucidate; as, an elucidative note.","pos":""}],"ELUCIDATOR":[{"def":"One who explains or elucidates; an expositor.","pos":""}],"ELUCIDATORY":[{"def":"Tending to elucidate; elucidative.","pos":""}],"ELUCTATE":[{"def":"To struggle out; -- with out.","pos":""}],"ELUCTATION":[{"def":"A struggling out of any difficulty.","pos":""}],"ELUCUBRATION":[{"def":"See Lucubration.","pos":""}],"ELUDE":[{"def":"To avoid slyly, by artifice, stratagem, or dexterity; to escape from in a covert manner; to mock by an unexpected escape; to baffle; as, to elude an officer; to elude detection, inquiry, search, comprehension; to elude the force of an argument or a blow.","pos":""}],"ELUDIBLE":[{"def":"Capable of being eluded; evadible.","pos":""}],"ELUL":[{"def":"The sixth month of the Jewish year, by the sacred reckoning, or the twelfth, by the civil reckoning, corresponding nearly to the month of September.","pos":""}],"ELUMBATED":[{"def":"Weak or lame in the loins.","pos":""}],"ELUSION":[{"def":"Act of eluding; adroit escape, as by artifice; a mockery; a cheat; trickery.","pos":""}],"ELUSIVE":[{"def":"Tending to elude; using arts or deception to escape; adroitly escaping or evading; eluding the grasp; fallacious.","pos":""}],"ELUSORY":[{"def":"Tending to elude or deceive; evasive; fraudulent; fallacious; deceitful; deceptive.","pos":""}],"ELUTRIATE":[{"def":"To wash or strain out so as to purify; as, to elutriate the blood as it passes through the lungs; to strain off or decant, as a powder which is separated from heavier particles by being drawn off with water; to cleanse, as by washing.","pos":""}],"ELUTRIATION":[{"def":"The process of elutriating; a decanting or racking off by means of water, as finer particles from heavier.","pos":""}],"ELUXATE":[{"def":"To dislocate; to luxate.","pos":""}],"ELUXATION":[{"def":"Dislocation; luxation.","pos":""}]}