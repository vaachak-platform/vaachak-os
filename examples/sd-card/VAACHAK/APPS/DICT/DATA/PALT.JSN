{"PALTER":[{"def":"To act in insincere or deceitful manner; to play false; to equivocate; to shift; to dodge; to trifle.","pos":""}],"PALTERER":[{"def":"One who palters.","pos":""}],"PALTERLY":[{"def":"Paltry; shabby; shabbily; paltrily.","pos":""}],"PALTOCK":[{"def":"A kind of doublet; a jacket.","pos":""}],"PALTRILY":[{"def":"In a paltry manner.","pos":""}],"PALTRINESS":[{"def":"The state or quality of being paltry.","pos":""}],"PALTRY":[{"def":"Mean; vile; worthless; despicable; contemptible; pitiful; trifling; as, a paltry excuse; paltry gold.","pos":""}]}