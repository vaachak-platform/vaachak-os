{"MAMALUKE":[{"def":"Same as Mameluke.","pos":""}],"MAMELON":[{"def":"A rounded hillock; a rounded elevation or protuberance.","pos":""}],"MAMELUCO":[{"def":"A child born of a white father and Indian mother.","pos":""}],"MAMELUKE":[{"def":"One of a body of mounted soldiers recruited from slaves converted to Mohammedanism, who, during several centuries, had more or less control of the government of Egypt, until exterminated or dispersed by Mehemet Ali in 1811.","pos":""}],"MAMILLATED":[{"def":"See Mammillated.","pos":""}],"MAMMA":[{"def":"Mother; -- word of tenderness and familiarity.","pos":""}],"MAMMAL":[{"def":"One of the Mammalia.","pos":""}],"MAMMALIA":[{"def":"The highest class of Vertebrata.","pos":""}],"MAMMALIAN":[{"def":"Of or pertaining to the Mammalia or mammals.","pos":""}],"MAMMALIFEROUS":[{"def":"Containing mammalian remains; -- said of certain strata.","pos":""}],"MAMMALOGICAL":[{"def":"Of or pertaining to mammalogy.","pos":""}],"MAMMALOGIST":[{"def":"One versed in mammalogy.","pos":""}],"MAMMALOGY":[{"def":"The science which relates to mammals or the Mammalia.","pos":""}],"MAMMARY":[{"def":"Of or pertaining to the mammæ or breasts; as, the mammary arteries and veins.","pos":""}],"MAMMEE":[{"def":"A fruit tree of tropical America, belonging to the genus Mammea (M.","pos":""}],"MAMMER":[{"def":"To hesitate; to mutter doubtfully.","pos":""}],"MAMMET":[{"def":"An idol; a puppet; a doll.","pos":""}],"MAMMIFEROUS":[{"def":"Having breasts; of, pertaining to, or derived from, the Mammalia.","pos":""}],"MAMMIFORM":[{"def":"Having the form of a mamma (breast) or mammæ.","pos":""}],"MAMMILLARY":[{"def":"Composed of convex convex concretions, somewhat resembling the breasts in form; studded with small mammiform protuberances.","pos":""},{"def":"Bounded like a nipple; -- said of the apex of some shells.","pos":""}],"MAMMILLIFORM":[{"def":"Having the form of a mammilla.","pos":""}],"MAMMILLOID":[{"def":"Like a mammilla or nipple; mammilliform.","pos":""}],"MAMMOCK":[{"def":"A shapeless piece; a fragment.","pos":""}],"MAMMODIS":[{"def":"Coarse plain India muslins.","pos":""}],"MAMMON":[{"def":"Riches; wealth; the god of riches; riches, personified.","pos":""}],"MAMMONISH":[{"def":"Actuated or prompted by a devotion to money getting or the service of Mammon.","pos":""}],"MAMMONISM":[{"def":"Devotion to the pursuit of wealth; worldliness.","pos":""}],"MAMMONITE":[{"def":"One devoted to the acquisition of wealth or the service of Mammon.","pos":""}],"MAMMONIZATION":[{"def":"The process of making mammonish; the state of being under the influence of mammonism.","pos":""}],"MAMMONIZE":[{"def":"To make mammonish.","pos":""}],"MAMMOSE":[{"def":"Having the form of the breast; breast-shaped.","pos":""}],"MAMMOTH":[{"def":"An extinct, hairy, maned elephant (Elephas primigenius), of enormous size, remains of which are found in the northern parts of both continents.","pos":""}],"MAMMOTHREPT":[{"def":"A child brought up by its grandmother; a spoiled child.","pos":""}],"MAMMY":[{"def":"A child's name for mamma, mother.","pos":""}],"MAMZER":[{"def":"A person born of relations between whom marriage was forbidden by the Mosaic law; a bastard.","pos":""}]}