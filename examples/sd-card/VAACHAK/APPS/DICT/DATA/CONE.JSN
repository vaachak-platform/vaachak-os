{"CONE":[{"def":"A solid of the form described by the revolution of a right- angled triangle about one of the sides adjacent to the right angle; - - called also a right cone.","pos":""},{"def":"The fruit or strobile of the Coniferæ, as of the pine, fir, cedar, and cypress.","pos":""}],"CONE CLUTCH":[{"def":"A friction clutch with conical bearing surfaces.","pos":""}],"CONE PULLEY":[{"def":"A pulley for driving machines, etc.","pos":""},{"def":"A kind of large broad-wheeled wagon, usually covered, for traveling in soft soil and on prairies.","pos":""}],"CONE-IN-CONE":[{"def":"Consisting of a series of parallel cones, each made up of many concentric cones closely packed together; -- said of a kind of structure sometimes observed in sedimentary rocks.","pos":""}],"CONE-NOSE":[{"def":"A large hemipterous insect of the family Reduviidæ, often found in houses, esp.","pos":""}],"CONEFLOWER":[{"def":"Any plant of the genus Rudbeckia; -- so called from the cone- shaped disk of the flower head.","pos":""}],"CONEINE":[{"def":"Co*ne\"ine ( or ; 104), n.","pos":""}]}