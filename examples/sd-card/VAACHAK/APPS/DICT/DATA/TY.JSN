{"TY-ALL":[{"def":"Something serving to tie or secure.","pos":""}],"TYBURN TICKET":[{"def":"A certificate given to one who prosecutes a felon to conviction, exempting him from certain parish and ward offices.","pos":""}],"TYCHISM":[{"def":"Any theory which conceives chance as an objective reality; esp.","pos":""}],"TYCHONIC":[{"def":"Of or pertaining to Tycho Brahe, or his system of astronomy.","pos":""}],"TYCOON":[{"def":"The title by which the shogun, or former commander in chief of the Japanese army, was known to foreigners.","pos":""}],"TYE":[{"def":"A chain or rope, one end of which passes through the mast, and is made fast to the center of a yard; the other end is attached to a tackle, by means of which the yard is hoisted or lowered.","pos":""},{"def":"A trough for washing ores.","pos":""}],"TYER":[{"def":"One who ties, or unites.","pos":""}],"TYING":[{"def":"The act or process of washing ores in a buddle.","pos":""}],"TYLARUS":[{"def":"One of the pads on the under surface of the toes of birds.","pos":""}],"TYLOPODA":[{"def":"A tribe of ungulates comprising the camels.","pos":""}],"TYLOSIS":[{"def":"An intrusion of one vegetable cell into the cavity of another, sometimes forming there an irregular mass of cells.","pos":""}],"TYMBAL":[{"def":"A kind of kettledrum.","pos":""}],"TYMP":[{"def":"A hollow water-cooled iron casting in the upper part of the archway in which the dam stands.","pos":""}],"TYMPAN":[{"def":"A panel; a tympanum.","pos":""},{"def":"A frame covered with parchment or cloth, on which the blank sheets are put, in order to be laid on the form to be impressed.","pos":""}],"TYMPANIC":[{"def":"Of or pertaining to the tympanum.","pos":""}],"TYMPANIST":[{"def":"One who beats a drum.","pos":""}],"TYMPANITES":[{"def":"A flatulent distention of the belly; tympany.","pos":""}],"TYMPANITIC":[{"def":"Of, pertaining to, or affected with, tympanites.","pos":""}],"TYMPANITIS":[{"def":"Inflammation of the lining membrane of the middle ear.","pos":""}],"TYMPANIZE":[{"def":"To stretch, as a skin over the head of a drum; to make into a drum or drumhead, or cause to act or sound like a drum.","pos":""}],"TYMPANO":[{"def":"A kettledrum; -- chiefly used in the plural to denote the kettledrums of an orchestra.","pos":""}],"TYMPANO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the tympanum; as in tympanohyal, tympano-Eustachian.","pos":""}],"TYMPANOHYAL":[{"def":"Of or pertaining to the tympanum and the hyoidean arch.","pos":""},{"def":"The proximal segment in the hyoidean arch, becoming a part of the styloid process of the temporal bone in adult man.","pos":""}],"TYMPANUM":[{"def":"One of the naked, inflatable air sacs on the neck of the prairie chicken and other species of grouse.","pos":""},{"def":"A drum-shaped wheel with spirally curved partitions by which water is raised to the axis when the wheel revolves with the lower part of the circumference submerged, -- used for raising water, as for irrigation.","pos":""}],"TYMPANY":[{"def":"A flatulent distention of the belly; tympanites.","pos":""}],"TYND":[{"def":"To shut; to close.","pos":""}],"TYNE":[{"def":"To become lost; to perish.","pos":""}],"TYPAL":[{"def":"Relating to a type or types; belonging to types; serving as a type; typical.","pos":""},{"def":"A combining form signifying impressed form; stamp; print; type; typical form; representative; as in stereotype phototype, ferrotype, monotype.","pos":""}],"TYPE":[{"def":"A general form or structure common to a number of individuals; hence, the ideal representation of a species, genus, or other group, combining the essential characteristics; an animal or plant possessing or exemplifying the essential characteristics of a species, genus, or other group.","pos":""},{"def":"The original object, or class of objects, scene, face, or conception, which becomes the subject of a copy; esp.","pos":""}],"TYPESETTER":[{"def":"One who, or that which, sets type; a compositor; a machine for setting type.","pos":""}],"TYPESETTING":[{"def":"The act or art of setting type.","pos":""}],"TYPEWRITE":[{"def":"To write with a typewriter.","pos":""}],"TYPEWRITER":[{"def":"An instrument for writing by means of type, a typewheel, or the like, in which the operator makes use of a sort of keyboard, in order to obtain printed impressions of the characters upon paper.","pos":""},{"def":"One who uses such an instrument.","pos":""}],"TYPEWRITING":[{"def":"The act or art of using a typewriter; also, a print made with a typewriter.","pos":""}],"TYPHLITIS":[{"def":"Inflammation of the cæcum.","pos":""}],"TYPHLOSOLE":[{"def":"A fold of the wall which projects into the cavity of the intestine in bivalve mollusks, certain annelids, starfishes, and some other animals.","pos":""}],"TYPHOEAN":[{"def":"Of or pertaining to Typhoeus (ti*fo\"us), the fabled giant of Greek mythology, having a hundred heads; resembling Typhoeus.","pos":""}],"TYPHOID":[{"def":"Of or pertaining to typhus; resembling typhus; of a low grade like typhus; as, typhoid symptoms.","pos":""}],"TYPHOMALARIAL":[{"def":"Pertaining to typhoid fever and malaria; as, typhomalarial fever, a form of fever having symptoms both of malarial and typhoid fever.","pos":""}],"TYPHOMANIA":[{"def":"A low delirium common in typhus fever.","pos":""}],"TYPHON":[{"def":"According to Hesiod, the son of Typhoeus, and father of the winds, but later identified with him.","pos":""},{"def":"A violent whirlwind; a typhoon.","pos":""}],"TYPHOON":[{"def":"A violent whirlwind; specifically, a violent whirlwind occurring in the Chinese seas.","pos":""}],"TYPHOTOXIN":[{"def":"A basic substance, C7H17NO2, formed from the growth of the typhoid bacillus on meat pulp.","pos":""}],"TYPHOUS":[{"def":"Of or pertaining to typhus; of the nature of typhus.","pos":""}],"TYPHUS":[{"def":"A contagious continued fever lasting from two to three weeks, attended with great prostration and cerebral disorder, and marked by a copious eruption of red spots upon the body.","pos":""}],"TYPICAL":[{"def":"Combining or exhibiting the essential characteristics of a group; as, a typical genus.","pos":""}],"TYPIFICATION":[{"def":"The act of typifying, or representing by a figure.","pos":""}],"TYPIFIER":[{"def":"One who, or that which, typifies.","pos":""}],"TYPIFY":[{"def":"To represent by an image, form, model, or resemblance.","pos":""}],"TYPIST":[{"def":"A person who operates a typewriting machine; a typewriter.","pos":""}],"TYPOCOSMY":[{"def":"A representation of the world.","pos":""}],"TYPOGRAPH":[{"def":"A machine for setting type or for casting lines of type and setting them.","pos":""}],"TYPOGRAPHER":[{"def":"Of or pertaining to the act or act of representing by types or symbols; emblematic; figurative; typical.","pos":""},{"def":"Of or pertaining to typography or printing; as, the typographic art.","pos":""}],"TYPOGRAPHY":[{"def":"The act or art of expressing by means of types or symbols; emblematical or hieroglyphic representation.","pos":""},{"def":"The art of printing with types; the use of types to produce impressions on paper, vellum, etc.","pos":""}],"TYPOLITE":[{"def":"A stone or fossil which has on it impressions or figures of plants and animals.","pos":""}],"TYPOLITHOGRAPHY":[{"def":"A branch of lithography in which impressions from printers' types are transferred to stone for reproduction.","pos":""}],"TYPOLOGY":[{"def":"A discourse or treatise on types.","pos":""},{"def":"The doctrine of types.","pos":""}],"TYPOTHETAE":[{"def":"Printers; -- used in the name of an association of the master printers of the United States and Canada, called The United Typothetæ of America.","pos":""}],"TYRAN":[{"def":"Lordly love is such a tyran fell.","pos":""}],"TYRANNESS":[{"def":"A female tyrant.","pos":""},{"def":"Of or pertaining to a tyrant; suiting a tyrant; unjustly severe in government; absolute; imperious; despotic; cruel; arbitrary; as, a tyrannical prince; a tyrannical master; tyrannical government.","pos":""}],"TYRANNICIDAL":[{"def":"Of or pertaining to tyrannicide, or the murder of a tyrant.","pos":""}],"TYRANNICIDE":[{"def":"The act of killing a tyrant.","pos":""},{"def":"One who kills a tyrant.","pos":""}],"TYRANNISH":[{"def":"Like a tyrant; tyrannical.","pos":""}],"TYRANNIZE":[{"def":"To subject to arbitrary, oppressive, or tyrannical treatment; to oppress.","pos":""}],"TYRANNOUS":[{"def":"Tyrannical; arbitrary; unjustly severe; despotic.","pos":""}],"TYRANNY":[{"def":"The government or authority of a tyrant; a country governed by an absolute ruler; hence, arbitrary or despotic exercise of power; exercise of power over subjects and others with a rigor not authorized by law or justice, or not requisite for the purposes of government.","pos":""},{"def":"Cruel government or discipline; as, the tyranny of a schoolmaster.","pos":""}],"TYRANT":[{"def":"Any one of numerous species of American clamatorial birds belonging to the family Tyrannidæ; -- called also tyrant bird.","pos":""}],"TYRE":[{"def":"Tyre, Etym: [Tamil tayir.","pos":""}],"TYRIAN":[{"def":"Of or pertaining to Tyre or its people.","pos":""},{"def":"Being of the color called Tyrian purple.","pos":""}],"TYRO":[{"def":"A beginner in learning; one who is in the rudiments of any branch of study; a person imperfectly acquainted with a subject; a novice.","pos":""}],"TYROCINY":[{"def":"The state of being a tyro, or beginner; apprenticeship.","pos":""}],"TYROLITE":[{"def":"A translucent mineral of a green color and pearly or vitreous luster.","pos":""}],"TYRONISM":[{"def":"The state of being a tyro, or beginner.","pos":""}],"TYROSIN":[{"def":"A white crystalline nitrogenous substance present in small amount in the pancreas and spleen, and formed in large quantity from the decomposition of proteid matter by various means, -- as by pancreatic digestion, by putrefaction as of cheese, by the action of boiling acids, etc.","pos":""}],"TYROTOXICON":[{"def":"A ptomaine discovered by Vaughan in putrid cheese and other dairy products, and producing symptoms similar to cholera infantum.","pos":""}],"TYROTOXINE":[{"def":"Same as Tyrotoxicon.","pos":""}],"TYSONITE":[{"def":"A fluoride of the cerium metals occurring in hexagonal crystals of a pale yellow color.","pos":""}],"TYSTIE":[{"def":"The black guillemot.","pos":""}]}