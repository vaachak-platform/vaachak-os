{"PROD":[{"def":"A pointed instrument for pricking or puncturing, as a goad, an awl, a skewer, etc.","pos":""},{"def":"A prick or stab which a pointed instrument.","pos":""}],"PRODIGAL":[{"def":"Given to extravagant expenditure; expending money or other things without necessity; recklessly or viciously profuse; lavish; wasteful; not frugal or economical; as, a prodigal man; the prodigal son; prodigal giving; prodigal expenses.","pos":""}],"PRODIGALITY":[{"def":"Extravagance in expenditure, particularly of money; excessive liberality; profusion; waste; -- opposed to frugality, economy, and parsimony.","pos":""}],"PRODIGALIZE":[{"def":"To act as a prodigal; to spend liberally.","pos":""}],"PRODIGALLY":[{"def":"In a prodigal manner; with profusion of expense; extravagantly; wasteful; profusely; lavishly; as, an estate prodigally dissipated.","pos":""}],"PRODIGENCE":[{"def":"Waste; profusion; prodigality.","pos":""}],"PRODIGIOUS":[{"def":"Of the nature of a prodigy; marvelous; wonderful; portentous.","pos":""},{"def":"Extraordinary in bulk, extent, quantity, or degree; very great; vast; huge; immense; as, a prodigious mountain; a prodigious creature; a prodigious blunder.","pos":""}],"PRODIGIOUSLY":[{"def":"Enormously; wonderfully; astonishingly; as, prodigiously great.","pos":""},{"def":"Very much; extremely; as, he was prodigiously pleased.","pos":""}],"PRODIGIOUSNESS":[{"def":"The quality or state of being prodigious; the state of having qualities that excite wonder or astonishment; enormousness; vastness.","pos":""}],"PRODIGY":[{"def":"Something extraordinary, or out of the usual course of nature, from which omens are drawn; a portent; as, eclipses and meteors were anciently deemed prodigies.","pos":""},{"def":"Anything so extraordinary as to excite wonder or astonishment; a marvel; as, a prodigy of learning.","pos":""}],"PRODITION":[{"def":"Disclosure; treachery; treason.","pos":""}],"PRODITORIOUS":[{"def":"Treacherous; perfidious; traitorous.","pos":""},{"def":"Apt to make unexpected revelations.","pos":""}],"PRODROMAL":[{"def":"Of or pertaining to prodromes; as, the prodromal stage of a disease.","pos":""}],"PRODROME":[{"def":"A forerunner; a precursor.","pos":""}],"PRODROMUS":[{"def":"A preliminary course or publication; -- used esp.","pos":""}],"PRODUCE":[{"def":"To extend; -- applied to a line, surface, or solid; as, to produce a side of a triangle.","pos":""}],"PRODUCE RACE":[{"def":"A race to be run by the produce of horses named or described at the time of entry.","pos":""}],"PRODUCENT":[{"def":"One who produces, or offers to notice.","pos":""}],"PRODUCER":[{"def":"A furnace for producing combustible gas which is used for fuel.","pos":""}],"PRODUCER'S GOODS":[{"def":"Goods that satisfy wants only indirectly as factors in the production of other goods, such as tools and raw material; -- called also instrumental goods, auxiliary goods, intermediate goods, or goods of the second and higher orders, and disting.","pos":""},{"def":"Any profit above the normal rate of interest and wages accruing to a producer on account of some monopoly (temporary or permanent) of the means or materials of production; -- called also Producer's rent.","pos":""}],"PRODUCIBILITY":[{"def":"The quality or state of being producible.","pos":""}],"PRODUCIBLE":[{"def":"Capable of being produced, brought forward, brought forth, generated, made, or extended.","pos":""}],"PRODUCT":[{"def":"The number or sum obtained by adding one number or quantity to itself as many times as there are units in another number; the number resulting from the multiplication of two or more numbers; as, the product of the multiplication of 7 by 5 is 35.","pos":""}],"PRODUCTIBILITY":[{"def":"The state of being productible; producibility.","pos":""}],"PRODUCTIBLE":[{"def":"Capable of being produced; producible.","pos":""}],"PRODUCTILE":[{"def":"Capable of being extended or prolonged; extensible; ductile.","pos":""}],"PRODUCTION":[{"def":"The act or process or producing, bringing forth, or exhibiting to view; as, the production of commodities, of a witness.","pos":""},{"def":"That which is produced, yielded, or made, whether naturally, or by the application of intelligence and labor; as, the productions of the earth; the productions of handicraft; the productions of intellect or genius.","pos":""}],"PRODUCTIVE":[{"def":"Having the quality or power of producing; yielding or furnishing results; as, productive soil; productive enterprises; productive labor, that which increases the number or amount of products.","pos":""},{"def":"Bringing into being; causing to exist; producing; originative; as, an age productive of great men; a spirit productive of heroic achievements.","pos":""}],"PRODUCTIVITY":[{"def":"The quality or state of being productive; productiveness.","pos":""}],"PRODUCTRESS":[{"def":"A female producer.","pos":""}],"PRODUCTUS":[{"def":"An extinct genus of brachiopods, very characteristic of the Carboniferous rocks.","pos":""}]}