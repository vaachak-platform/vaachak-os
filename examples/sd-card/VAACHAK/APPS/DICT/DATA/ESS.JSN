{"ESSAY":[{"def":"A composition treating of any particular subject; -- usually shorter and less methodical than a formal, finished treatise; as, an essay on the life and writings of Homer; an essay on fossils, or on commerce.","pos":""}],"ESSAYIST":[{"def":"A writer of an essay, or of essays.","pos":""}],"ESSENCE":[{"def":"The constituent elementary notions which constitute a complex notion, and must be enumerated to define it; sometimes called the nominal essence.","pos":""}],"ESSENE":[{"def":"One of a sect among the Jews in the time of our Savior, remarkable for their strictness and abstinence.","pos":""}],"ESSENISM":[{"def":"The doctrine or the practices of the Essenes.","pos":""}],"ESSENTIAL":[{"def":"Necessary; indispensable; -- said of those tones which constitute a chord, in distinction from ornamental or passing tones.","pos":""},{"def":"Idiopathic; independent of other diseases.","pos":""}],"ESSENTIALITY":[{"def":"The quality of being essential; the essential part.","pos":""}],"ESSENTIALLY":[{"def":"In an essential manner or degree; in an indispensable degree; really; as, essentially different.","pos":""}],"ESSENTIATE":[{"def":"To form or constitute the essence or being of.","pos":""}],"ESSOIN":[{"def":"To excuse for nonappearance in court.","pos":""}],"ESSOINER":[{"def":"An attorney who sufficiently excuses the absence of another.","pos":""}],"ESSONITE":[{"def":"Cinnamon stone, a variety of garnet.","pos":""}],"ESSORANT":[{"def":"Standing, but with the wings spread, as if about to fly; -- said of a bird borne as a charge on an escutcheon.","pos":""}]}