{"BROCADE":[{"def":"Silk stuff, woven with gold and silver threads, or ornamented with raised flowers, foliage, etc.","pos":""}],"BROCADED":[{"def":"Woven or worked, as brocade, with gold and silver, or with raised flowers, etc.","pos":""},{"def":"Dressed in brocade.","pos":""}],"BROCARD":[{"def":"An elementary principle or maximum; a short, proverbial rule, in law, ethics, or metaphysics.","pos":""}],"BROCATEL":[{"def":"A kind of coarse brocade, or figured fabric, used chiefly for tapestry, linings for carriages, etc.","pos":""},{"def":"A marble, clouded and veined with white, gray, yellow, and red, in which the yellow usually prevails.","pos":""}],"BROCATELLO":[{"def":"Same as Brocatel.","pos":""}],"BROCCOLI":[{"def":"A plant of the Cabbage species (Brassica oleracea) of many varieties, resembling the cauliflower.","pos":""}],"BROCHANTITE":[{"def":"A basic sulphate of copper, occurring in emerald-green crystals.","pos":""}],"BROCHE":[{"def":"Woven with a figure; as, broché goods.","pos":""}],"BROCHETTE":[{"def":"A small spit or skewer.","pos":""}],"BROCHURE":[{"def":"A printed and stitched book containing only a few leaves; a pamphlet.","pos":""}],"BROCK":[{"def":"Or with pretense of chasing thence the brock.","pos":""}],"BROCKET":[{"def":"A male red deer two years old; -- sometimes called brock.","pos":""},{"def":"A small South American deer, of several species (Coassus superciliaris, C.","pos":""}],"BROCKISH":[{"def":"Beastly; brutal.","pos":""}]}