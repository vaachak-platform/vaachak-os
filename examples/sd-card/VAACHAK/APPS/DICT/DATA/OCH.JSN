{"OCHLESIS":[{"def":"A general morbid condition induced by the crowding together of many persons, esp.","pos":""}],"OCHLOCRACY":[{"def":"A form of government by the multitude; a mobocracy.","pos":""},{"def":"Of or pertaining to ochlocracy; having the form or character of an ochlocracy; mobocratic.","pos":""}],"OCHREA":[{"def":"A greave or legging.","pos":""},{"def":"A kind of sheath formed by two stipules united round a stem.","pos":""}],"OCHROLEUCOUS":[{"def":"Yellowish white; having a faint tint of dingy yellow.","pos":""}],"OCHYMY":[{"def":"A suffix used to form diminutives; as, bullock, hillock.","pos":""}]}