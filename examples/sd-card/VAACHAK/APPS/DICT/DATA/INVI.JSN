{"INVIDIOUS":[{"def":"Want of vigilance; neglect of watching; carelessness.","pos":""}],"INVIGORATE":[{"def":"To give vigor to; to strengthen; to animate; to give life and energy to.","pos":""}],"INVIGORATION":[{"def":"The act of invigorating, or the state of being invigorated.","pos":""}],"INVILLAGED":[{"def":"Turned into, or reduced to, a village.","pos":""}],"INVINCIBILITY":[{"def":"The quality or state of being invincible; invincibleness.","pos":""}],"INVINCIBLE":[{"def":"Incapable of being conquered, overcome, or subdued; unconquerable; insuperable; as, an invincible army, or obstacle.","pos":""}],"INVIOLABILITY":[{"def":"The quality or state of being inviolable; inviolableness.","pos":""}],"INVIOLABLE":[{"def":"Not violable; not susceptible of hurt, wound, or harm (used with respect to either physical or moral damage); not susceptible of being profaned or corrupted; sacred; holy; as, inviolable honor or chastity; an inviolable shrine.","pos":""},{"def":"Unviolated; uninjured; undefiled; uncorrupted.","pos":""}],"INVIOLABLENESS":[{"def":"The quality or state of being inviolable; as, the inviolableness of divine justice.","pos":""}],"INVIOLABLY":[{"def":"Without violation.","pos":""}],"INVIOLACY":[{"def":"The state or quality of being inviolate; as, the inviolacy of an oath.","pos":""}],"INVIOLATELY":[{"def":"In an inviolate manner.","pos":""}],"INVIOLATENESS":[{"def":"The state of being inviolate.","pos":""}],"INVIRILE":[{"def":"Deficient in manhood; unmanly; effeminate.","pos":""}],"INVIRILITY":[{"def":"Absence of virility or manhood; effeminacy.","pos":""}],"INVISCATE":[{"def":"To daub or catch with glue or birdlime; to entangle with glutinous matter.","pos":""}],"INVISCERATE":[{"def":"To breed; to nourish.","pos":""}],"INVISIBILITY":[{"def":"The state or quality of being invisible; also, that which is invisible.","pos":""}],"INVISIBLE":[{"def":"Incapable of being seen; not perceptible by vision; not visible.","pos":""}],"INVISIBLENESS":[{"def":"The quality or state of being invisible; invisibility.","pos":""}],"INVISIBLY":[{"def":"In an invisible manner, Denham.","pos":""}],"INVISION":[{"def":"Want of vision or of the power of seeing.","pos":""}],"INVITATION":[{"def":"The act of inviting; solicitation; the requesting of a person's company; as, an invitation to a party, to a dinner, or to visit a friend.","pos":""},{"def":"A document written or printed, or spoken words, 3.","pos":""}],"INVITATORY":[{"def":"Using or containing invitations.","pos":""}],"INVITE":[{"def":"To ask; to request; to bid; to summon; to ask to do some act, or go to some place; esp.","pos":""},{"def":"To allure; to draw to; to tempt to come; to induce by pleasure or hope; to attract.","pos":""}],"INVITER":[{"def":"One who, or that which, invites.","pos":""}],"INVITING":[{"def":"Alluring; tempting; as, an inviting amusement or prospect.","pos":""}],"INVITRIFIABLE":[{"def":"Not admitting of being vitrified, or converted into glass.","pos":""}]}