{"DROCK":[{"def":"An ancient yearly payment made by some tenants to the king, or to their landlords, for the privilege of driving their cattle through a manor to fairs or markets.","pos":""}],"DROGHER":[{"def":"A small craft used in the West India Islands to take off sugars, rum, etc.","pos":""}],"DROIL":[{"def":"To work sluggishly or slowly; to plod.","pos":""}],"DROIT":[{"def":"A right; law in its aspect of the foundation of rights; also, in old law, the writ of right.","pos":""}],"DROITURAL":[{"def":"relating to the mere right of property, as distinguished from the right of possession; as, droitural actions.","pos":""}],"DROLL":[{"def":"Queer, and fitted to provoke laughter; ludicrous from oddity; amusing and strange.","pos":""}],"DROLLER":[{"def":"A jester; a droll.","pos":""}],"DROLLERY":[{"def":"The quality of being droll; sportive tricks; buffoonery; droll stories; comical gestures or manners.","pos":""},{"def":"Something which serves to raise mirth; as: (a) A puppet show; also, a puppet.","pos":""}],"DROLLINGLY":[{"def":"In a jesting manner.","pos":""}],"DROMAEOGNATHOUS":[{"def":"Having the structure of the palate like that of the ostrich and emu.","pos":""}],"DROMATHERIUM":[{"def":"A small extinct triassic mammal from North Carolina, the earliest yet found in America.","pos":""}],"DROME":[{"def":"The crab plover (Dromas ardeola), a peculiar North African bird, allied to the oyster catcher.","pos":""}],"DROMEDARY":[{"def":"The Arabian camel (Camelus dromedarius), having one hump or protuberance on the back, in distinction from the Bactrian camel, which has two humps.","pos":""},{"def":"In the Middle Ages, a large, fast-sailing galley, or cutter; a large, swift war vessel.","pos":""}],"DRONE":[{"def":"The male of bees, esp.","pos":""},{"def":"A monotonous bass, as in a pastoral composition.","pos":""}],"DRONE BEE":[{"def":"The male of the honeybee; a drone.","pos":""}],"DRONE FLY":[{"def":"A dipterous insect (Eristalis tenax), resembling the drone bee.","pos":""}],"DRONEPIPE":[{"def":"One of the low-toned tubes of a bagpipe.","pos":""}],"DRONGO":[{"def":"A passerine bird of the family Dicruridæ.","pos":""}],"DRONISH":[{"def":"Like a drone; indolent; slow.","pos":""}],"DRONKELEWE":[{"def":"Given to drink; drunken.","pos":""}],"DRONY":[{"def":"Like a drone; sluggish; lazy.","pos":""}],"DROOL":[{"def":"To drivel, or drop saliva; as, the child drools.","pos":""}],"DROOP":[{"def":"To hang bending downward; to sink or hang down, as an animal, plant, etc.","pos":""},{"def":"To grow weak or faint with disappointment, grief, or like causes; to be dispirited or depressed; to languish; as, her spirits drooped.","pos":""}],"DROOPER":[{"def":"One who, or that which, droops.","pos":""}],"DROOPINGLY":[{"def":"In a drooping manner.","pos":""}],"DROP":[{"def":"Any medicine the dose of which is measured by drops; as, lavender drops.","pos":""},{"def":"The depth of a square sail; -- generally applied to the courses only.","pos":""}],"DROPLET":[{"def":"A little drop; a tear.","pos":""}],"DROPLIGHT":[{"def":"An apparatus for bringing artificial light down from a chandelier nearer to a table or desk; a pendant.","pos":""},{"def":"By drops or small portions.","pos":""}],"DROPPER":[{"def":"A branch vein which drops off from, or leaves, the main lode.","pos":""},{"def":"A dog which suddenly drops upon the ground when it sights game, -- formerly a common, and still an occasional, habit of the setter.","pos":""}],"DROPPING":[{"def":"That which falls in drops; the excrement or dung of animals.","pos":""}],"DROPSICAL":[{"def":"Diseased with dropsy; hydropical; tending to dropsy; as, a dropsical patient.","pos":""},{"def":"Of or pertaining to dropsy.","pos":""}],"DROPSICALNESS":[{"def":"State of being dropsical.","pos":""}],"DROPSIED":[{"def":"Diseased with drops.","pos":""}],"DROPSY":[{"def":"An unnatural collection of serous fluid in any serous cavity of the body, or in the subcutaneous cellular tissue.","pos":""}],"DROPWISE":[{"def":"After the manner of a drop; in the form of drops.","pos":""}],"DROPWORM":[{"def":"The larva of any geometrid moth, which drops from trees by means of a thread of silk, as the cankerworm.","pos":""}],"DROPWORT":[{"def":"An Old World species of Spiræa (S.","pos":""}],"DROSERA":[{"def":"A genus of low perennial or biennial plants, the leaves of which are beset with gland-tipped bristles.","pos":""}],"DROSKY":[{"def":"A low, four-wheeled, open carriage, used in Russia, consisting of a kind of long, narrow bench, on which the passengers ride as on a saddle, with their feet reaching nearly to the ground.","pos":""}],"DROSOMETER":[{"def":"An instrument for measuring the quantity of dew on the surface of a body in the open air.","pos":""}],"DROSS":[{"def":"The scum or refuse matter which is thrown off, or falls from, metals in smelting the ore, or in the process of melting; recrement.","pos":""}],"DROSSEL":[{"def":"A slut; a hussy; a drazel.","pos":""}],"DROSSLESS":[{"def":"Free from dross.","pos":""}],"DROSSY":[{"def":"Of, pertaining to, resembling, dross; full of dross; impure; worthless.","pos":""}],"DROUGHT":[{"def":"Dryness; want of rain or of water; especially, such dryness of the weather as affects the earth, and prevents the growth of plants; aridity.","pos":""},{"def":"Thirst; want of drink.","pos":""}],"DROUGHTINESS":[{"def":"A state of dryness of the weather; want of rain.","pos":""}],"DROUGHTY":[{"def":"Characterized by drought; wanting rain; arid; adust.","pos":""},{"def":"Dry; thirsty; wanting drink.","pos":""}],"DROUMY":[{"def":"Troubled; muddy.","pos":""}],"DROUTH":[{"def":"Same as Drought.","pos":""}],"DROVE":[{"def":"A narrow drain or channel used in the irrigation of land.","pos":""}],"DROVER":[{"def":"One who drives cattle or sheep to market; one who makes it his business to purchase cattle, and drive them to market.","pos":""},{"def":"A boat driven by the tide.","pos":""}],"DROVY":[{"def":"Turbid; muddy; filthy.","pos":""}],"DROWN":[{"def":"To be suffocated in water or other fluid; to perish in water.","pos":""}],"DROWNAGE":[{"def":"The act of drowning.","pos":""}],"DROWNER":[{"def":"One who, or that which, drowns.","pos":""}],"DROWSE":[{"def":"To sleep imperfectly or unsoundly; to slumber; to be heavy with sleepiness; to doze.","pos":""}],"DROWSILY":[{"def":"In a drowsy manner.","pos":""}],"DROWSINESS":[{"def":"State of being drowsy.","pos":""}],"DROWSY":[{"def":"Inclined to drowse; heavy with sleepiness; lethargic; dozy.","pos":""},{"def":"Disposing to sleep; lulling; soporific.","pos":""}]}