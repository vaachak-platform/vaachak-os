{"INDAGATE":[{"def":"To seek or search out.","pos":""}],"INDAGATION":[{"def":"Search; inquiry; investigation.","pos":""}],"INDAGATIVE":[{"def":"Searching; exploring; investigating.","pos":""}],"INDAGATOR":[{"def":"A searcher; an explorer; an investigator.","pos":""}],"INDART":[{"def":"To pierce, as with a dart.","pos":""}],"INDAZOL":[{"def":"A nitrogenous compound, C7H6N2, analogous to indol, and produced from a diazo derivative or cinnamic acid.","pos":""}]}