{"TERZA RIMA":[{"def":"A peculiar and complicated system of versification, borrowed by the early Italian poets from the Troubadours.","pos":""}],"TERZETTO":[{"def":"A composition in three voice parts; a vocal (rarely an instrumental) trio.","pos":""},{"def":"A transformer without iron, for high frequency alternating or oscillating currents; an oscillation transformer.","pos":""}]}