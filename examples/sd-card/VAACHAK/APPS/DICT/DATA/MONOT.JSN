{"MONOTESSARON":[{"def":"A single narrative framed from the statements of the four evangelists; a gospel harmony.","pos":""}],"MONOTHALAMA":[{"def":"A division of Foraminifera including those that have only one chamber.","pos":""}],"MONOTHALAMAN":[{"def":"A foraminifer having but one chamber.","pos":""}],"MONOTHALMIC":[{"def":"Formed from one pistil; -- said of fruits.","pos":""}],"MONOTHECAL":[{"def":"Having a single loculament.","pos":""}],"MONOTHEISM":[{"def":"The doctrine or belief that there is but one God.","pos":""}],"MONOTHEIST":[{"def":"One who believes that there is but one God.","pos":""}],"MONOTHEISTIC":[{"def":"Of or pertaining to monotheism.","pos":""},{"def":"The doctrine of the Monothelites.","pos":""}],"MONOTHELITE":[{"def":"One of an ancient sect who held that Christ had but one will as he had but one nature.","pos":""}],"MONOTHELITIC":[{"def":"Of or pertaining to the Monothelites, or their doctrine.","pos":""}],"MONOTOCOUS":[{"def":"Bearing fruit but once; monocarpic.","pos":""},{"def":"Uniparous; laying a single egg.","pos":""}],"MONOTOMOUS":[{"def":"Having a distinct cleavage in a single direction only.","pos":""}],"MONOTONE":[{"def":"A single unvaried tone or sound.","pos":""},{"def":"The utterance of successive syllables, words, or sentences, on one unvaried key or line of pitch.","pos":""}],"MONOTONIST":[{"def":"One who talks in the same strain or on the same subject until weariness is produced.","pos":""}],"MONOTONOUS":[{"def":"Uttered in one unvarying tone; continued with dull uniformity; characterized by monotony; without change or variety; wearisome.","pos":""}],"MONOTONY":[{"def":"A frequent recurrence of the same tone or sound, producing a dull uniformity; absence of variety, as in speaking or singing.","pos":""},{"def":"Any irksome sameness, or want of variety.","pos":""}],"MONOTREMATA":[{"def":"A subclass of Mammalia, having a cloaca in which the ducts of the urinary, genital, and alimentary systems terminate, as in birds.","pos":""}],"MONOTREMATOUS":[{"def":"Of or pertaining to the Monotremata.","pos":""}],"MONOTREME":[{"def":"One of the Monotremata.","pos":""}],"MONOTRIGLYPH":[{"def":"A kind of intercolumniation in an entablature, in which only one triglyph and two metopes are introduced.","pos":""}],"MONOTROPA":[{"def":"A genus of parasitic or saprophytic plants including the Indian pipe and pine sap.","pos":""},{"def":"Having but one type; containing but one representative; as, a monotypic genus, which contains but one species.","pos":""}]}