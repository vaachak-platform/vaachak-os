{"SERGE":[{"def":"A woolen twilled stuff, much used as material for clothing for both sexes.","pos":""}],"SERGEANCY":[{"def":"The office of a sergeant; sergeantship.","pos":""}],"SERGEANT":[{"def":"A lawyer of the highest rank, answering to the doctor of the civil law; -- called also serjeant at law.","pos":""}],"SERGEANTCY":[{"def":"Same as Sergeancy.","pos":""}],"SERGEANTSHIP":[{"def":"The office of sergeant.","pos":""}],"SERGEANTY":[{"def":"Tenure of lands of the crown by an honorary kind of service not due to any lord, but to the king only.","pos":""}]}