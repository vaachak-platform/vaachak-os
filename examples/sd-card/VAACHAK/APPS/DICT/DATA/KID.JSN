{"KID":[{"def":"Gloves made of kid.","pos":""}],"KIDDERMINSTER":[{"def":"A kind of ingrain carpeting, named from the English town where formerly most of it was manufactured.","pos":""}],"KIDDIER":[{"def":"A huckster; a cadger.","pos":""}],"KIDDLE":[{"def":"A kind of basketwork wear in a river, for catching fish.","pos":""}],"KIDDY":[{"def":"To deceive; to outwit; to hoax.","pos":""}],"KIDDYISH":[{"def":"Frolicsome; sportive.","pos":""},{"def":"A young fox Shak.","pos":""}],"KIDNAP":[{"def":"To take (any one) by force or fear, and against one's will, with intent to carry to another place.","pos":""},{"def":"One who steals or forcibly carries away a human being; a manstealer.","pos":""}],"KIDNEY":[{"def":"A glandular organ which excretes urea and other waste products from the animal body; a urinary gland.","pos":""},{"def":"Having the form or shape of a kidney; reniform; as, a kidney- shaped leaf.","pos":""}]}