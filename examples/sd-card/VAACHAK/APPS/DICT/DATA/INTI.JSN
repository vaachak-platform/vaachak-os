{"INTIMACY":[{"def":"The state of being intimate; close familiarity or association; nearness in friendship.","pos":""}],"INTIMATE":[{"def":"Innermost; inward; internal; deep-seated; hearty.","pos":""},{"def":"Near; close; direct; thorough; complete.","pos":""}],"INTIMATELY":[{"def":"In an intimate manner.","pos":""}],"INTIMATION":[{"def":"The act of intimating; also, the thing intimated.","pos":""},{"def":"Announcement; declaration.","pos":""}],"INTIME":[{"def":"Inward; internal; intimate.","pos":""}],"INTIMIDATE":[{"def":"To make timid or fearful; to inspire of affect with fear; to deter, as by threats; to dishearten; to abash.","pos":""}],"INTIMIDATION":[{"def":"The act of making timid or fearful or of deterring by threats; the state of being intimidated; as, the voters were kept from the polls by intimidation.","pos":""}],"INTIMIDATORY":[{"def":"Tending or serving to intimidate.","pos":""}],"INTINCTION":[{"def":"A method or practice of the administration of the sacrament by dipping the bread or wafer in the wine and administering both together.","pos":""}],"INTINCTIVITY":[{"def":"The want of the quality of coloring or tingeing other bodies.","pos":""}],"INTINE":[{"def":"A transparent, extensible membrane of extreme tenuity, which forms the innermost coating of grains of pollen.","pos":""}],"INTITULE":[{"def":"To entitle; to give a title to.","pos":""}]}