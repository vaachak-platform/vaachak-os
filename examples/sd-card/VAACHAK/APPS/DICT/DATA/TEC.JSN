{"TECHILY":[{"def":"In a techy manner.","pos":""}],"TECHINESS":[{"def":"The quality or state of being techy.","pos":""}],"TECHNIC":[{"def":"Technical terms or objects; things pertaining to the practice of an art or science.","pos":""}],"TECHNICAL":[{"def":"Of or pertaining to the useful or mechanic arts, or to any science, business, or the like; specially appropriate to any art, science, or business; as, the words of an indictment must be technical.","pos":""}],"TECHNICALITY":[{"def":"The quality or state of being technical; technicalness.","pos":""},{"def":"That which is technical, or peculiar to any trade, profession, sect, or the like.","pos":""}],"TECHNICALLY":[{"def":"In a technical manner; according to the signification of terms as used in any art, business, or profession.","pos":""}],"TECHNICALNESS":[{"def":"The quality or state of being technical; technicality.","pos":""}],"TECHNICALS":[{"def":"Those things which pertain to the practical part of an art, science, or profession; technical terms; technics.","pos":""}],"TECHNICIAN":[{"def":"A technicist; esp.","pos":""}],"TECHNICIST":[{"def":"One skilled to technics or in one or more of the practical arts.","pos":""}],"TECHNICOLOGICAL":[{"def":"Technological; technical.","pos":""}],"TECHNICS":[{"def":"The doctrine of arts in general; such branches of learning as respect the arts.","pos":""}],"TECHNIPHONE":[{"def":"A dumb gymnastic apparatus for training the hands of pianists and organists, as to a legato touch.","pos":""}],"TECHNIQUE":[{"def":"Same as Technic, n.","pos":""}],"TECHNOGRAPHY":[{"def":"Description of the arts and crafts of tribes and peoples.","pos":""}],"TECHNOLOGICAL":[{"def":"Of or pertaining to technology.","pos":""}],"TECHNOLOGIST":[{"def":"One skilled in technology; one who treats of arts, or of the terms of arts.","pos":""}],"TECHNOLOGY":[{"def":"Industrial science; the science of systematic knowledge of the industrial arts, especially of the more important manufactures, as spinning, weaving, metallurgy, etc.","pos":""}],"TECHY":[{"def":"Peevish; fretful; irritable.","pos":""}],"TECTIBRANCH":[{"def":"One of the Tectibranchiata.","pos":""}],"TECTIBRANCHIA":[{"def":"Same as Tectibranchiata.","pos":""}],"TECTIBRANCHIATA":[{"def":"An order, or suborder, of gastropod Mollusca in which the gills are usually situated on one side of the back, and protected by a fold of the mantle.","pos":""}],"TECTIBRANCHIATE":[{"def":"Having the gills covered by the mantle; of or pertaining to the Tectibranchiata.","pos":""},{"def":"A tectibranchiate mollusk.","pos":""}],"TECTLY":[{"def":"Covertly; privately; secretly.","pos":""}],"TECTOLOGY":[{"def":"A division of morphology created by Haeckel; the science of organic individuality constituting the purely structural portion of morphology, in which the organism is regarded as composed of organic individuals of different orders, each organ being considered an individual.","pos":""}],"TECTONIC":[{"def":"Of or pertaining to building or construction; architectural.","pos":""}],"TECTONICS":[{"def":"The science, or the art, by which implements, vessels, dwellings, or other edifices, are constructed, both agreeably to the end for which they are designed, and in conformity with artistic sentiments and ideas.","pos":""}],"TECTORIAL":[{"def":"Of or pertaining to covering; -- applied to a membrane immediately over the organ of Corti in the internal ear.","pos":""}],"TECTRICES":[{"def":"The wing coverts of a bird.","pos":""}]}