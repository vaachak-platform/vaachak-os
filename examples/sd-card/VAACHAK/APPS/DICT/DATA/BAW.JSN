{"BAWBLING":[{"def":"Insignificant; contemptible.","pos":""}],"BAWCOCK":[{"def":"A fine fellow; -- a term of endearment.","pos":""}],"BAWD":[{"def":"A person who keeps a house of prostitution, or procures women for a lewd purpose; a procurer or procuress; a lewd person; -- usually applied to a woman.","pos":""}],"BAWDILY":[{"def":"Obscenely; lewdly.","pos":""}],"BAWDINESS":[{"def":"Obscenity; lewdness.","pos":""}],"BAWDRY":[{"def":"The practice of procuring women for the gratification of lust.","pos":""},{"def":"Illicit intercourse; fornication.","pos":""}],"BAWDY":[{"def":"Dirty; foul; -- said of clothes.","pos":""},{"def":"Obscene; filthy; unchaste.","pos":""}],"BAWDYHOUSE":[{"def":"A house of prostitution; a house of ill fame; a brothel.","pos":""}],"BAWHORSE":[{"def":"Same as Bathorse.","pos":""}],"BAWL":[{"def":"To cry out with a loud, full sound; to cry with vehemence, as in calling or exultation; to shout; to vociferate.","pos":""},{"def":"To cry loudly, as a child from pain or vexation.","pos":""}],"BAWN":[{"def":"An inclosure with mud or stone walls, for keeping cattle; a fortified inclosure.","pos":""}],"BAWREL":[{"def":"A large, unwieldy person.","pos":""}]}