{"ARQUATED":[{"def":"Shaped like a bow; arcuate; curved.","pos":""},{"def":"A sort of hand gun or firearm a contrivance answering to a trigger, by which the burning match was applied.","pos":""}],"ARQUEBUSADE":[{"def":"The shot of an arquebus.","pos":""},{"def":"A distilled water from a variety of aromatic plants, as rosemary, millefoil, etc.","pos":""}],"ARQUEBUSIER":[{"def":"A soldier armed with an arquebus.","pos":""}],"ARQUIFOUX":[{"def":"Same as Alquifou.","pos":""}]}