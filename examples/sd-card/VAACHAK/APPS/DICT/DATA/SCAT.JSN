{"SCAT":[{"def":"Go away; begone; away; -- chiefly used in driving off a cat.","pos":""}],"SCATCH":[{"def":"A kind of bit for the bridle of a horse; -- called also scatchmouth.","pos":""}],"SCATE":[{"def":"See Skate, for the foot.","pos":""}],"SCATEBROUS":[{"def":"Abounding with springs.","pos":""}],"SCATH":[{"def":"Harm; damage; injury; hurt; waste; misfortune.","pos":""},{"def":"To do harm to; to injure; to damage; to waste; to destroy.","pos":""}],"SCATHFUL":[{"def":"Harmful; doing damage; pernicious.","pos":""}],"SCATHLY":[{"def":"Injurious; scathful.","pos":""}],"SCATTER":[{"def":"To strew about; to sprinkle around; to throw down loosely; to deposit or place here and there, esp.","pos":""},{"def":"To cause to separate in different directions; to reduce from a close or compact to a loose or broken order; to dissipate; to disperse.","pos":""}],"SCATTER-BRAIN":[{"def":"A giddy or thoughtless person; one incapable of concentration or attention.","pos":""}],"SCATTER-BRAINED":[{"def":"Giddy; thoughtless.","pos":""}],"SCATTERED":[{"def":"Irregular in position; having no regular order; as, scattered leaves.","pos":""}],"SCATTERGOOD":[{"def":"One who wastes; a spendthrift.","pos":""}],"SCATTERING":[{"def":"Going or falling in various directions; not united or agregated; divided among many; as, scattering votes.","pos":""}],"SCATTERINGLY":[{"def":"In a scattering manner; dispersedly.","pos":""}],"SCATTERLING":[{"def":"One who has no fixed habitation or residence; a vagabond.","pos":""}],"SCATURIENT":[{"def":"Gushing forth; full to overflowing; effusive.","pos":""}],"SCATURIGINOUS":[{"def":"Abounding with springs.","pos":""}]}