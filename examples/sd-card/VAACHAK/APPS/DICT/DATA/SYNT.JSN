{"SYNTAX":[{"def":"Connected system or order; union of things; a number of things jointed together; organism.","pos":""},{"def":"That part of grammar which treats of the construction of sentences; the due arrangement of words in sentences in their necessary relations, according to established usage in any language.","pos":""}],"SYNTERESIS":[{"def":"Conscience viewed as the internal repository of the laws of duty.","pos":""}],"SYNTERETIC":[{"def":"Preserving health; prophylactic.","pos":""}],"SYNTERETICS":[{"def":"That department of medicine which relates to the preservation of health; prophylaxis.","pos":""}],"SYNTHERMAL":[{"def":"Having the same degree of heat.","pos":""}],"SYNTHESIS":[{"def":"The combination of separate elements of thought into a whole, as of simple into complex conceptions, species into genera, individual propositions into systems; -- the opposite of Ant: analysis.","pos":""}],"SYNTHESIST":[{"def":"One who employs synthesis, or who follows synthetic methods.","pos":""}],"SYNTHESIZE":[{"def":"Comprising within itself structural or other characters which are usually found only in two or more diverse groups; -- said of species, genera, and higher groups.","pos":""}],"SYNTHETICALLY":[{"def":"In a synthetic manner.","pos":""}],"SYNTHETIZE":[{"def":"To combine; to unite in regular structure.","pos":""}],"SYNTOMY":[{"def":"Brevity; conciseness.","pos":""}],"SYNTONIN":[{"def":"A proteid substance (acid albumin) formed from the albuminous matter of muscle by the action of dilute acids; -- formerly called musculin.","pos":""}],"SYNTONIZE":[{"def":"To adjust or devise so as to emit or respond to electric oscillations of a certain wave length; to tune; specif.","pos":""}],"SYNTONIZER":[{"def":"One that syntonizes; specif.","pos":""}],"SYNTONY":[{"def":"State of being adjusted to a certain wave length; agreement or tuning between the time period of an apparatus emitting electric oscillations and that of a receiving apparatus, esp.","pos":""}]}