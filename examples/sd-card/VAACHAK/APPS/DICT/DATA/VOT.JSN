{"VOTARESS":[{"def":"A woman who is a votary.","pos":""}],"VOTARIST":[{"def":"Like a sad votarist in palmer's weed.","pos":""}],"VOTARY":[{"def":"Consecrated by a vow or promise; consequent on a vow; devoted; promised.","pos":""}],"VOTE":[{"def":"An ardent wish or desire; a vow; a prayer.","pos":""}],"VOTER":[{"def":"One who votes; one who has a legal right to vote, or give his suffrage; an elector; a suffragist; as, as, an independent voter.","pos":""}],"VOTIST":[{"def":"One who makes a vow.","pos":""}],"VOTIVE":[{"def":"Given by vow, or in fulfillment of a vow; consecrated by a vow; devoted; as, votive offerings; a votive tablet.","pos":""}]}