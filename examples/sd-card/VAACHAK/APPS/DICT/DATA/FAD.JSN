{"FAD":[{"def":"A hobby ; freak; whim.","pos":""}],"FADAISE":[{"def":"A vapid or meaningless remark; a commonplace; nonsense.","pos":""}],"FADDLE":[{"def":"To trifle; to toy.","pos":""},{"def":"To fondle; to dandle.","pos":""}],"FADE":[{"def":"Weak; insipid; tasteless; commonplace.","pos":""}],"FADED":[{"def":"That has lost freshness, color, or brightness; grown dim.","pos":""}],"FADEDLY":[{"def":"In a faded manner.","pos":""}],"FADELESS":[{"def":"Not liable to fade; unfading.","pos":""}],"FADGE":[{"def":"To fit; to suit; to agree.","pos":""}],"FADING":[{"def":"Losing freshness, color, brightness, or vigor.","pos":""},{"def":"Loss of color, freshness, or vigor.","pos":""}]}