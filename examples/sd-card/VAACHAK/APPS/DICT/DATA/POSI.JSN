{"POSIED":[{"def":"Inscribed with a posy.","pos":""}],"POSINGLY":[{"def":"So as to pose or puzzle.","pos":""}],"POSIT":[{"def":"To assume as real or conceded; as, to posit a principle.","pos":""}],"POSITION":[{"def":"A method of solving a problem by one or two suppositions; -- called also the rule of trial and error.","pos":""}],"POSITIONAL":[{"def":"Of or pertaining to position.","pos":""}],"POSITIVE":[{"def":"Corresponding with the original in respect to the position of lights and shades, instead of having the lights and shades reversed; as, a positive picture.","pos":""}],"POSITIVELY":[{"def":"In a positive manner; absolutely; really; expressly; with certainty; indubitably; peremptorily; dogmatically; -- opposed to negatively.","pos":""}],"POSITIVENESS":[{"def":"The quality or state of being positive; reality; actualness; certainty; confidence; peremptoriness; dogmatism.","pos":""}],"POSITIVISM":[{"def":"A system of philosophy originated by M.","pos":""}],"POSITIVIST":[{"def":"A believer in positivism.","pos":""},{"def":"Relating to positivism.","pos":""}]}