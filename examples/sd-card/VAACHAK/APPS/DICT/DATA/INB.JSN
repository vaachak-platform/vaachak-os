{"INBARGE":[{"def":"To embark; to go or put into a barge.","pos":""}],"INBEING":[{"def":"Inherence; inherent existence.","pos":""}],"INBLOWN":[{"def":"Blown in or into.","pos":""}],"INBOARD":[{"def":"Inside the line of a vessel's bulwarks or hull; the opposite of outboard; as, an inboard cargo; haul the boom inboard.","pos":""},{"def":"From without inward; toward the inside; as, the inboard stroke of a steam engine piston, the inward or return stroke.","pos":""}],"INBORN":[{"def":"Born in or with; implanted by nature; innate; as, inborn passions.","pos":""},{"def":"A breaking in; inroad; invasion.","pos":""}],"INBREATHE":[{"def":"To infuse by breathing; to inspire.","pos":""}],"INBRED":[{"def":"Bred within; innate; as, inbred worth.","pos":""}],"INBREED":[{"def":"To produce or generate within.","pos":""},{"def":"To breed in and in.","pos":""}],"INBURNING":[{"def":"Her inburning wrath she gan abate.","pos":""}],"INBURNT":[{"def":"Burnt in; ineffaceable.","pos":""}],"INBURST":[{"def":"A bursting in or into.","pos":""}]}