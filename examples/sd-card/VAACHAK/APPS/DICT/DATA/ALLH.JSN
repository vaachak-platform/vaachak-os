{"ALLHALLOW":[{"def":"The evening before Allhallows.","pos":""}],"ALLHALLOW EVE":[{"def":"The evening before Allhallows.","pos":""}],"ALLHALLOWMAS":[{"def":"The feast of All Saints.","pos":""}],"ALLHALLOWN":[{"def":"Of or pertaining to the time of Allhallows.","pos":""}],"ALLHALLOWTIDE":[{"def":"The time at or near All Saints, or November 1st.","pos":""}],"ALLHEAL":[{"def":"A name popularly given to the officinal valerian, and to some other plants.","pos":""}]}