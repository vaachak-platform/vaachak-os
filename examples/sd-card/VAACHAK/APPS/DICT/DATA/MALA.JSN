{"MALA":[{"def":"Evils; wrongs; offenses against right and law.","pos":""}],"MALABAR":[{"def":"A region in the western part of the Peninsula of India, between the mountains and the sea.","pos":""}],"MALACCA":[{"def":"A town and district upon the seacoast of the Malay Peninsula.","pos":""}],"MALACHITE":[{"def":"Native hydrous carbonate of copper, usually occurring in green mammillary masses with concentric fibrous structure.","pos":""}],"MALACISSANT":[{"def":"Softening; relaxing.","pos":""}],"MALACISSATION":[{"def":"The act of making soft or supple.","pos":""}],"MALACOBDELLA":[{"def":"A genus of nemertean worms, parasitic in the gill cavity of clams and other bivalves.","pos":""}],"MALACODERM":[{"def":"One of a tribe of beetles (Malacodermata), with a soft and flexible body, as the fireflies.","pos":""}],"MALACOLITE":[{"def":"A variety of pyroxene.","pos":""}],"MALACOLOGIST":[{"def":"One versed in the science of malacology.","pos":""}],"MALACOLOGY":[{"def":"The science which relates to the structure and habits of mollusks.","pos":""}],"MALACOPODA":[{"def":"A class of air-breathing Arthropoda; -- called also Protracheata, and Onychophora.","pos":""}],"MALACOPTERYGIAN":[{"def":"One of the Malacopterygii.","pos":""}],"MALACOPTERYGII":[{"def":"An order of fishes in which the fin rays, except the anterior ray of the pectoral and dorsal fins, are closely jointed, and not spiny.","pos":""}],"MALACOPTERYGIOUS":[{"def":"Belonging to the Malacopterygii.","pos":""}],"MALACOSTEON":[{"def":"A peculiar disease of the bones, in consequence of which they become softened and capable of being bent without breaking.","pos":""}],"MALACOSTOMOUS":[{"def":"Having soft jaws without teeth, as certain fishes.","pos":""}],"MALACOSTRACA":[{"def":"A subclass of Crustacea, including Arthrostraca and Thoracostraca, or all those higher than the Entomostraca.","pos":""}],"MALACOSTRACAN":[{"def":"One of the Malacostraca.","pos":""}],"MALACOSTRACOLOGY":[{"def":"That branch of zoölogical science which relates to the crustaceans; -- called also carcinology.","pos":""}],"MALACOSTRACOUS":[{"def":"Belonging to the Malacostraca.","pos":""}],"MALACOZOA":[{"def":"An extensive group of Invertebrata, including the Mollusca, Brachiopoda, and Bryozoa.","pos":""}],"MALACOZOIC":[{"def":"Of or pertaining to the Malacozoa.","pos":""}],"MALADDRESS":[{"def":"Bad address; an awkward, tactless, or offensive way of accosting one or talking with one.","pos":""}],"MALADJUSTMENT":[{"def":"A bad adjustment.","pos":""}],"MALADMINISTRATION":[{"def":"Bad administration; bad management of any business, especially of public affairs.","pos":""}],"MALADROIT":[{"def":"Of a quality opposed to adroitness; clumsy; awkward; unskillful.","pos":""}],"MALADY":[{"def":"Any disease of the human body; a distemper, disorder, or indisposition, proceeding from impaired, defective, or morbid organic functions; especially, a lingering or deep-seated disorder.","pos":""},{"def":"A moral or mental defect or disorder.","pos":""}],"MALAGA":[{"def":"A city and a province of Spain, on the Mediterranean.","pos":""}],"MALAGASH":[{"def":"Same as Malagasy.","pos":""}],"MALAGASY":[{"def":"A native or natives of Madagascar; also (sing.","pos":""}],"MALAISE":[{"def":"An indefinite feeling of uneasiness, or of being sick or ill at ease.","pos":""}],"MALAMATE":[{"def":"A salt of malamic acid.","pos":""}],"MALAMBO":[{"def":"A yellowish aromatic bark, used in medicine and perfumery, said to be from the South American shrub Croton Malambo.","pos":""}],"MALAMETHANE":[{"def":"A white crystalline substance forming the ethyl salt of malamic acid.","pos":""}],"MALAMIC":[{"def":"Of or pertaining an acid intermediate between malic acid and malamide, and known only by its salts.","pos":""}],"MALAMIDE":[{"def":"The acid amide derived from malic acid, as a white crystalline substance metameric with asparagine.","pos":""}],"MALANDERS":[{"def":"A scurfy eruption in the bend of the knee of the fore leg of a horse.","pos":""}],"MALAPERT":[{"def":"Bold; forward; impudent; saucy; pert.","pos":""},{"def":"A malapert person.","pos":""}],"MALAPROPISM":[{"def":"A grotesque misuse of a word; a word so used.","pos":""}],"MALAPROPOS":[{"def":"Unseasonable or unseasonably; unsuitable or unsuitably.","pos":""}],"MALAPTERURUS":[{"def":"A genus of African siluroid fishes, including the electric catfishes.","pos":""}],"MALAR":[{"def":"Of or pertaining to the region of the cheek bone, or to the malar bone; jugal.","pos":""}],"MALARIA":[{"def":"A morbid condition produced by exhalations from decaying vegetable matter in contact with moisture, giving rise to fever and ague and many other symptoms characterized by their tendency to recur at definite and usually uniform intervals.","pos":""},{"def":"Of or pertaining, to or infected by, malaria.","pos":""}],"MALARIA PARASITE":[{"def":"Any of several minute protozoans of the genus Plasmodium (syn.","pos":""}],"MALASHAGANAY":[{"def":"The fresh-water drumfish (Haploidonotus grunniens).","pos":""}],"MALASSIMILATION":[{"def":"Mal`as*sim`i*la\"tion, n.","pos":""}],"MALATE":[{"def":"A salt of malic acid.","pos":""},{"def":"To soften by kneading or stirring with some thinner substance.","pos":""}],"MALAXATION":[{"def":"The act of softening by mixing with a thinner substance; the formation of ingredients into a mass for pills or plasters.","pos":""}],"MALAXATOR":[{"def":"One who, or that which, malaxates; esp.","pos":""}],"MALAY":[{"def":"One of a race of a brown or copper complexion in the Malay Peninsula and the western islands of the Indian Archipelago.","pos":""},{"def":"Of or pertaining to the Malays or their country.","pos":""}],"MALAYALAM":[{"def":"The name given to one the cultivated Dravidian languages, closely related to the Tamil.","pos":""}]}