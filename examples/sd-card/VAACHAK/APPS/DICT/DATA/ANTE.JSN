{"ANTE":[{"def":"Each player's stake, which is put into the pool before (ante) the game begins.","pos":""}],"ANTE MORTEM":[{"def":"Before death; -- generally used adjectivelly; as, an ante- mortem statement; ante-mortem examination.","pos":""}],"ANTE-":[{"def":"A Latin preposition and prefix; akin to Gr.","pos":""}],"ANTEACT":[{"def":"A preceding act.","pos":""}],"ANTEAL":[{"def":"Being before, or in front.","pos":""}],"ANTECEDANEOUS":[{"def":"Antecedent; preceding in time.","pos":""}],"ANTECEDE":[{"def":"To go before in time or place; to precede; to surpass.","pos":""}],"ANTECEDENCE":[{"def":"An apparent motion of a planet toward the west; retrogradation.","pos":""}],"ANTECEDENCY":[{"def":"The state or condition of being antecedent; priority.","pos":""}],"ANTECEDENT":[{"def":"Going before in time; prior; anterior; preceding; as, an event antecedent to the Deluge; an antecedent cause.","pos":""},{"def":"Presumptive; as, an antecedent improbability.","pos":""}],"ANTECEDENTLY":[{"def":"Previously; before in time; at a time preceding; as, antecedently to conversion.","pos":""}],"ANTECESSOR":[{"def":"One who goes before; a predecessor.","pos":""},{"def":"An ancestor; a progenitor.","pos":""}],"ANTECHAMBER":[{"def":"A chamber or apartment before the chief apartment and leading into it, in which persons wait for audience; an outer chamber.","pos":""},{"def":"A space viewed as the outer chamber or the entrance to an interior part.","pos":""}],"ANTECHAPEL":[{"def":"The outer part of the west end of a collegiate or other chapel.","pos":""}],"ANTECOMMUNION":[{"def":"A name given to that part of the Anglican liturgy for the communion, which precedes the consecration of the elements.","pos":""}],"ANTECURSOR":[{"def":"A forerunner; a precursor.","pos":""}],"ANTEDATE":[{"def":"Prior date; a date antecedent to another which is the actual date.","pos":""}],"ANTEDILUVIAL":[{"def":"Before the flood, or Deluge, in Noah's time.","pos":""}],"ANTEDILUVIAN":[{"def":"Of or relating to the period before the Deluge in Noah's time; hence, antiquated; as, an antediluvian vehicle.","pos":""},{"def":"One who lived before the Deluge.","pos":""}],"ANTEFACT":[{"def":"Something done before another act.","pos":""}],"ANTEFLEXION":[{"def":"A displacement forward of an organ, esp.","pos":""}],"ANTELOPE":[{"def":"One of a group of ruminant quadrupeds, intermediate between the deer and the goat.","pos":""}],"ANTELUCAN":[{"def":"Held or being before light; -- a word applied to assemblies of Christians, in ancient times of persecution, held before light in the morning.","pos":""}],"ANTEMERIDIAN":[{"def":"Being before noon; in or pertaining to the forenoon.","pos":""}],"ANTEMETIC":[{"def":"Tending to check vomiting.","pos":""},{"def":"A remedy to check or allay vomiting.","pos":""}],"ANTEMOSAIC":[{"def":"Being before the time of Moses.","pos":""}],"ANTEMUNDANE":[{"def":"Being or occurring before the creation of the world.","pos":""}],"ANTEMURAL":[{"def":"An outwork of a strong, high wall, with turrets, in front gateway (as of an old castle), for defending the entrance.","pos":""}],"ANTENICENE":[{"def":"Of or in the Christian church or era, anterior to the first council of Nice, held a.","pos":""}],"ANTENNA":[{"def":"A movable, articulated organ of sensation, attached to the heads of insects and Crustacea.","pos":""}],"ANTENNAL":[{"def":"Belonging to the antennæ.","pos":""}],"ANTENNIFEROUS":[{"def":"Bearing or having antennæ.","pos":""}],"ANTENNIFORM":[{"def":"Shaped like antennæ.","pos":""}],"ANTENNULE":[{"def":"A small antenna; -- applied to the smaller pair of antennæ or feelers of Crustacea.","pos":""}],"ANTENUMBER":[{"def":"A number that precedes another.","pos":""}],"ANTENUPTIAL":[{"def":"Preceding marriage; as, an antenuptial agreement.","pos":""}],"ANTEORBITAL":[{"def":"Same as Antorbital.","pos":""}],"ANTEPASCHAL":[{"def":"Pertaining to the time before the Passover, or before Easter.","pos":""}],"ANTEPAST":[{"def":"Antepasts of joy and comforts.","pos":""}],"ANTEPENDIUM":[{"def":"The hangings or screen in front of the altar; an altar cloth; the frontal.","pos":""},{"def":"The last syllable of a word except two, as -syl in monosyllable.","pos":""}],"ANTEPENULTIMATE":[{"def":"Of or pertaining to the last syllable but two.","pos":""}],"ANTEPHIALTIC":[{"def":"Good against nightmare.","pos":""},{"def":"A remedy nightmare.","pos":""}],"ANTEPILEPTIC":[{"def":"Good against epilepsy.","pos":""},{"def":"A medicine for epilepsy.","pos":""}],"ANTEPONE":[{"def":"To put before; to prefer.","pos":""}],"ANTEPORT":[{"def":"An outer port, gate, or door.","pos":""}],"ANTEPORTICO":[{"def":"An outer porch or vestibule.","pos":""}],"ANTEPOSITION":[{"def":"The placing of a before another, which, by ordinary rules, ought to follow it.","pos":""}],"ANTEPRANDIAL":[{"def":"Preceding dinner.","pos":""}],"ANTEPREDICAMENT":[{"def":"A prerequisite to a clear understanding of the predicaments and categories, such as definitions of common terms.","pos":""}],"ANTERIOR":[{"def":"Before in time; antecedent.","pos":""},{"def":"Before, or toward the front, in place; as, the anterior part of the mouth; -- opposed to posterior.","pos":""}],"ANTERIORITY":[{"def":"The state of being anterior or preceding in time or in situation; priority.","pos":""}],"ANTERIORLY":[{"def":"In an anterior manner; before.","pos":""}],"ANTERO-":[{"def":"A combining form meaning anterior, front; as, antero-posterior, front and back; antero-lateral, front side, anterior and at the side.","pos":""}],"ANTEROOM":[{"def":"A room before, or forming an entrance to, another; a waiting room.","pos":""}],"ANTESTATURE":[{"def":"A small intrenchment or work of palisades, or of sacks of earth.","pos":""}],"ANTESTOMACH":[{"def":"A cavity which leads into the stomach, as in birds.","pos":""}],"ANTETEMPLE":[{"def":"The portico, or narthex in an ancient temple or church.","pos":""}],"ANTEVERSION":[{"def":"A displacement of an organ, esp.","pos":""}],"ANTEVERT":[{"def":"To displace by anteversion.","pos":""}]}