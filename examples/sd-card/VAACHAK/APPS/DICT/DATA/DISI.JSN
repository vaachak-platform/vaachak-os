{"DISILLUSION":[{"def":"The act or process of freeing from an illusion, or the state of being freed therefrom.","pos":""}],"DISILLUSIONIZE":[{"def":"To disenchant; to free from illusion.","pos":""}],"DISILLUSIONMENT":[{"def":"The act of freeing from an illusion, or the state of being freed therefrom.","pos":""}],"DISIMBITTER":[{"def":"To free from bitterness.","pos":""}],"DISIMPARK":[{"def":"To free from the barriers or restrictions of a park.","pos":""}],"DISIMPASSIONED":[{"def":"Free from warmth of passion or feeling.","pos":""}],"DISIMPROVE":[{"def":"To make worse; -- the opposite of improve.","pos":""}],"DISIMPROVEMENT":[{"def":"Reduction from a better to a worse state; as, disimprovement of the earth.","pos":""}],"DISINCARCERATE":[{"def":"To liberate from prison.","pos":""}],"DISINCLINATION":[{"def":"The state of being disinclined; want of propensity, desire, or affection; slight aversion or dislike; indisposition.","pos":""}],"DISINCLINE":[{"def":"To incline away the affections of; to excite a slight aversion in; to indispose; to make unwilling; to alienate.","pos":""}],"DISINCLOSE":[{"def":"To free from being inclosed.","pos":""}],"DISINCORPORATE":[{"def":"To deprive of corporate powers, rights, or privileges; to divest of the condition of a corporate body.","pos":""},{"def":"To detach or separate from a corporation.","pos":""}],"DISINCORPORATION":[{"def":"Deprivation of the rights and privileges of a corporation.","pos":""}],"DISINFECT":[{"def":"To free from infectious or contagious matter; to destroy putrefaction; to purify; to make innocuous.","pos":""}],"DISINFECTANT":[{"def":"That which disinfects; an agent for removing the causes of infection, as chlorine.","pos":""}],"DISINFECTION":[{"def":"The act of disinfecting; purification from infecting matter.","pos":""}],"DISINFECTOR":[{"def":"One who, or that which, disinfects; an apparatus for applying disinfectants.","pos":""}],"DISINFLAME":[{"def":"To divest of flame or ardor.","pos":""}],"DISINGENUITY":[{"def":"Disingenuousness.","pos":""}],"DISINGENUOUS":[{"def":"Not noble; unbecoming true honor or dignity; mean; unworthy; as, disingenuous conduct or schemes.","pos":""},{"def":"Not ingenuous; wanting in noble candor or frankness; not frank or open; uncandid; unworthily or meanly artful.","pos":""}],"DISINHERISON":[{"def":"Same as Disherison.","pos":""}],"DISINHERIT":[{"def":"To cut off from an inheritance or from hereditary succession; to prevent, as an heir, from coming into possession of any property or right, which, by law or custom, would devolve on him in the course of descent.","pos":""},{"def":"To deprive of heritage; to dispossess.","pos":""}],"DISINHERITANCE":[{"def":"The act of disinheriting, or the condition of being; disinherited; disherison.","pos":""}],"DISINSURE":[{"def":"To render insecure; to put in danger.","pos":""}],"DISINTEGRABLE":[{"def":"Capable of being disintegrated, or reduced to fragments or powder.","pos":""}],"DISINTEGRATE":[{"def":"To separate into integrant parts; to reduce to fragments or to powder; to break up, or cause to fall to pieces, as a rock, by blows of a hammer, frost, rain, and other mechanical or atmospheric influences.","pos":""}],"DISINTEGRATION":[{"def":"Dis*in`te*gra\"tion, n.","pos":""}],"DISINTEGRATOR":[{"def":"A machine for grinding or pulverizing by percussion.","pos":""}],"DISINTER":[{"def":"To take out of the grave or tomb; to unbury; to exhume; to dig up.","pos":""},{"def":"To bring out, as from a grave or hiding place; to bring from obscurity into view.","pos":""}],"DISINTERESS":[{"def":"To deprive or rid of interest in, or regard for; to disengage.","pos":""}],"DISINTERESSMENT":[{"def":"Disinterestedness; impartiality; fairness.","pos":""}],"DISINTEREST":[{"def":"The measures they shall walk by shall be disinterest and even.","pos":""}],"DISINTERESTED":[{"def":"Not influenced by regard to personal interest or advantage; free from selfish motive; having no relation of interest or feeling; not biased or prejudiced; as, a disinterested decision or judge.","pos":""}],"DISINTERESTEDLY":[{"def":"In a disinterested manner; without bias or prejudice.","pos":""}],"DISINTERESTEDNESS":[{"def":"The state or quality of being disinterested; impartiality.","pos":""}],"DISINTERESTING":[{"def":"Dis*in\"ter*est*ing, a.","pos":""}],"DISINTERMENT":[{"def":"The act of disinterring, or taking out of the earth; exhumation.","pos":""}],"DISINTHRALL":[{"def":"To free from thralldom; to disenthrall.","pos":""}],"DISINTHRALLMENT":[{"def":"A releasing from thralldom or slavery; disenthrallment.","pos":""}],"DISINURE":[{"def":"To render unaccustomed or unfamiliar.","pos":""}],"DISINVESTITURE":[{"def":"The act of depriving of investiture.","pos":""}],"DISINVIGORATE":[{"def":"To enervate; to weaken.","pos":""}],"DISINVOLVE":[{"def":"To uncover; to unfold or unroll; to disentangle.","pos":""}]}