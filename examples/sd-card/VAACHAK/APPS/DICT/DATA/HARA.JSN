{"HARA-KIRI":[{"def":"Suicide, by slashing the abdomen, formerly practiced in Japan, and commanded by the government in the cases of disgraced officials; disembowelment; -- also written, but incorrectly, hari-kari.","pos":""}],"HARANGUE":[{"def":"A speech addressed to a large public assembly; a popular oration; a loud address a multitude; in a bad sense, a noisy or pompous speech; declamation; ranting.","pos":""}],"HARANGUEFUL":[{"def":"Full of harangue.","pos":""}],"HARANGUER":[{"def":"One who harangues, or is fond of haranguing; a declaimer.","pos":""}],"HARASS":[{"def":"To fatigue; to tire with repeated and exhausting efforts; esp.","pos":""}],"HARASSER":[{"def":"One who harasses.","pos":""}],"HARASSMENT":[{"def":"The act of harassing, or state of being harassed; worry; annoyance; anxiety.","pos":""}]}