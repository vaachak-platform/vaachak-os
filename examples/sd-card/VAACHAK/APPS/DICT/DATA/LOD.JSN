{"LODE":[{"def":"A metallic vein; any regular vein or course, whether metallic or not.","pos":""}],"LODE-SHIP":[{"def":"An old name for a pilot boat.","pos":""}],"LODESMAN":[{"def":"Same as Loadsman.","pos":""}],"LODESTAR":[{"def":"Same as Loadstar.","pos":""}],"LODESTONE":[{"def":"Same as Loadstone.","pos":""}],"LODGE":[{"def":"The space at the mouth of a level next the shaft, widened to permit wagons to pass, or ore to be deposited for hoisting; -- called also platt.","pos":""}],"LODGEABLE":[{"def":"That may be or can be lodged; as, so many persons are not lodgeable in this village.","pos":""},{"def":"Capable of affording lodging; fit for lodging in.","pos":""}],"LODGED":[{"def":"Lying down; -- used of beasts of the chase, as couchant is of beasts of prey.","pos":""}],"LODGER":[{"def":"One who, or that which, lodges; one who occupies a hired room in another's house.","pos":""}],"LODGING":[{"def":"The act of one who, or that which, lodges.","pos":""},{"def":"A place of rest, or of temporary habitation; esp.","pos":""}],"LODGMENT":[{"def":"The occupation and holding of a position, as by a besieging party; an instrument thrown up in a captured position; as, to effect a lodgment.","pos":""}],"LODICULE":[{"def":"One of the two or three delicate membranous scales which are next to the stamens in grasses.","pos":""}]}