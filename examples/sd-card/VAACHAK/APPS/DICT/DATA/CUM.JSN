{"CUMACEA":[{"def":"An order of marine Crustacea, mostly of small size.","pos":""}],"CUMBENT":[{"def":"Lying down; recumbent.","pos":""}],"CUMBER":[{"def":"To rest upon as a troublesome or useless weight or load; to be burdensome or oppressive to; to hinder or embarrass in attaining an object, to obstruct or occupy uselessly; to embarrass; to trouble.","pos":""}],"CUMBERSOME":[{"def":"Burdensome or hindering, as a weight or drag; embarrassing; vexatious; cumbrous.","pos":""},{"def":"Not easily managed; as, a cumbersome contrivance or machine.","pos":""}],"CUMBRANCE":[{"def":"Cum\"brance (km\"brans), n.","pos":""}],"CUMBRIAN":[{"def":"Pertaining to Cumberland, England, or to a system of rocks found there.","pos":""}],"CUMBROUS":[{"def":"Rendering action or motion difficult or toilsome; serving to obstruct or hinder; burdensome; clogging.","pos":""},{"def":"Giving trouble; vexatious.","pos":""}],"CUMENE":[{"def":"A colorless oily hydrocarbon, C6H5.","pos":""}],"CUMIDINE":[{"def":"A strong, liquid, organic base, C3H7.","pos":""}],"CUMIN":[{"def":"A dwarf umbelliferous plant, somewhat resembling fennel (Cuminum Cyminum), cultivated for its seeds, which have a bitterish, warm taste, with an aromatic flavor, and are used like those of anise and caraway.","pos":""}],"CUMINIC":[{"def":"Pertaining to, or derived from, cumin, or from oil of caraway; as, cuminic acid.","pos":""}],"CUMINIL":[{"def":"A substance, analogous to benzil, obtained from oil of caraway.","pos":""}],"CUMMERBUND":[{"def":"A sash for the waist; a girdle.","pos":""}],"CUMMIN":[{"def":"Ye pay tithe of mint, and cummin.","pos":""}],"CUMSHAW":[{"def":"A present or bonus; -- originally applied to that paid on ships which entered the port of Canton.","pos":""}],"CUMU-CIRRO-STRATUS":[{"def":"Nimbus, or rain cloud.","pos":""}],"CUMULATE":[{"def":"To gather or throw into a heap; to heap together; to accumulate.","pos":""}],"CUMULATION":[{"def":"The act of heaping together; a heap.","pos":""}],"CUMULATIST":[{"def":"One who accumulates; one who collects.","pos":""}],"CUMULATIVE":[{"def":"Composed of parts in a heap; forming a mass; agregated.","pos":""},{"def":"Augmenting, gaining, or giving force, by successive additions; as, a cumulative argument, i.","pos":""}],"CUMULOSE":[{"def":"Cu\"mu*lose` (k\"m-ls`), a.","pos":""}],"CUMULOSTRATUS":[{"def":"A form of cloud.","pos":""}],"CUMULUS":[{"def":"One of the four principal forms of clouds.","pos":""}]}