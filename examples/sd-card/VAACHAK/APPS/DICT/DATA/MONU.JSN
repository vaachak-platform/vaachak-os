{"MONUMENT":[{"def":"Something which stands, or remains, to keep in remembrance what is past; a memorial.","pos":""},{"def":"A building, pillar, stone, or the like, erected to preserve the remembrance of a person, event, action, etc.","pos":""}],"MONUMENTAL":[{"def":"Of, pertaining to, or suitable for, a monument; as, a monumental inscription.","pos":""},{"def":"Serving as a monument; memorial; preserving memory.","pos":""}],"MONUMENTALLY":[{"def":"By way of memorial.","pos":""},{"def":"By means of monuments.","pos":""}],"MONUREID":[{"def":"Any one of a series of complex nitrogenous substances regarded as derived from one molecule of urea; as, alloxan is a monureid.","pos":""}]}