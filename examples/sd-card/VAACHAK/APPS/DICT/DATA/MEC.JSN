{"MECATE":[{"def":"A rope of hair or of maguey fiber, for tying horses, etc.","pos":""}],"MECCAWEE":[{"def":"Of or pertaining to Mecca, in Arabia.","pos":""},{"def":"A native or inhabitant of Mecca.","pos":""}],"MECHANIC":[{"def":"The art of the application of the laws of motion or force to construction.","pos":""},{"def":"A mechanician; an artisan; an artificer; one who practices any mechanic art; one skilled or employed in shaping and uniting materials, as wood, metal, etc.","pos":""}],"MECHANICAL":[{"def":"Pertaining to, governed by, or in accordance with, mechanics, or the laws of motion; pertaining to the quantitative relations of force and matter, as distinguished from mental, vital, chemical, etc.","pos":""},{"def":"Of or pertaining to a machine or to machinery or tools; made or formed by a machine or with tools; as, mechanical precision; mechanical products.","pos":""}],"MECHANICALIZE":[{"def":"To cause to become mechanical.","pos":""}],"MECHANICALLY":[{"def":"In a mechanical manner.","pos":""}],"MECHANICALNESS":[{"def":"The state or quality of being mechanical.","pos":""}],"MECHANICIAN":[{"def":"One skilled in the theory or construction of machines; a machinist.","pos":""}],"MECHANICO-CHEMICAL":[{"def":"Pertaining to, connected with, or dependent upon, both mechanics and chemistry; -- said especially of those sciences which treat of such phenomena as seem to depend on the laws both of mechanics and chemistry, as electricity and magnetism.","pos":""}],"MECHANICS":[{"def":"That science, or branch of applied mathematics, which treats of the action of forces on bodies.","pos":""}],"MECHANISM":[{"def":"An ideal machine; a combination of movable bodies constituting a machine, but considered only with regard to relative movements.","pos":""}],"MECHANIST":[{"def":"A maker of machines; one skilled in mechanics.","pos":""},{"def":"One who regards the phenomena of nature as the effects of forces merely mechanical.","pos":""}],"MECHANIZE":[{"def":"To cause to be mechanical.","pos":""}],"MECHANOGRAPH":[{"def":"One of a number of copies of anything multiplied mechanically.","pos":""}],"MECHANOGRAPHIC":[{"def":"Treating of mechanics.","pos":""},{"def":"Written, copied, or recorded by machinery; produced by mechanography; as, a mechanographic record of changes of temperature; mechanographic prints.","pos":""}],"MECHANOGRAPHIST":[{"def":"An artist who, by mechanical means, multiplies copies of works of art.","pos":""}],"MECHANOGRAPHY":[{"def":"The art of mechanically multiplying copies of a writing, or any work of art.","pos":""}],"MECHANURGY":[{"def":"That branch of science which treats of moving machines.","pos":""}],"MECHITARIST":[{"def":"One of a religious congregation of the Roman Catholic Church devoted to the improvement of Armenians.","pos":""}],"MECHLIN":[{"def":"A kind of lace made at, or originating in, Mechlin, in Belgium.","pos":""}],"MECHOACAN":[{"def":"A species of jalap, of very feeble properties, said to be obtained from the root of a species of Convolvulus (C.","pos":""}],"MECKELIAN":[{"def":"Pertaining to, or discovered by, J.","pos":""}],"MECONATE":[{"def":"A salt of meconic acid.","pos":""}],"MECONIC":[{"def":"Pertaining to, or obtained from, the poppy or opium; specif.","pos":""}],"MECONIDINE":[{"def":"An alkaloid found in opium, and extracted as a yellow amorphous substance which is easily decomposed.","pos":""}],"MECONIDIUM":[{"def":"A kind of gonophore produced by hydroids of the genus Gonothyræa.","pos":""}],"MECONIN":[{"def":"A substance regarded as an anhydride of meconinic acid, existing in opium and extracted as a white crystalline substance.","pos":""}],"MECONINIC":[{"def":"Pertaining to, or designating, an acid which occurs in opium, and which may be obtained by oxidizing narcotine.","pos":""}]}