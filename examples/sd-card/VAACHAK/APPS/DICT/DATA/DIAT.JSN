{"DIATESSARON":[{"def":"The interval of a fourth.","pos":""},{"def":"A continuous narrative arranged from the first four books of the New Testament.","pos":""}],"DIATHERMAL":[{"def":"Freely permeable by radiant heat.","pos":""},{"def":"The property of transmitting radiant heat; the quality of being diathermous.","pos":""}],"DIATHERMANISM":[{"def":"The doctrine or the phenomena of the transmission of radiant heat.","pos":""}],"DIATHERMANOUS":[{"def":"Having the property of transmitting radiant heat; diathermal; - - opposed to athermanous.","pos":""}],"DIATHERMIC":[{"def":"Affording a free passage to heat; as, diathermic substances.","pos":""}],"DIATHERMOMETER":[{"def":"An instrument for examining the thermal resistance or heat- conducting power of liquids.","pos":""}],"DIATHERMOUS":[{"def":"Same as Diathermal.","pos":""}],"DIATHESIS":[{"def":"Bodily condition or constitution, esp.","pos":""}],"DIATHETIC":[{"def":"Pertaining to, or dependent on, a diathesis or special constitution of the body; as, diathetic disease.","pos":""}],"DIATOM":[{"def":"One of the Diatomaceæ, a family of minute unicellular Algæ having a siliceous covering of great delicacy, each individual multiplying by spontaneous division.","pos":""}],"DIATOMOUS":[{"def":"Having a single, distinct, diagonal cleavage; -- said of crystals.","pos":""}],"DIATONIC":[{"def":"Pertaining to the scale of eight tones, the eighth of which is the octave of the first.","pos":""}],"DIATONICALLY":[{"def":"In a diatonic manner.","pos":""}],"DIATRIBE":[{"def":"A prolonged or exhaustive discussion; especially, an acrimonious or invective harangue; a strain of abusive or railing language; a philippic.","pos":""}],"DIATRIBIST":[{"def":"One who makes a diatribe or diatribes.","pos":""}],"DIATRYMA":[{"def":"An extinct eocene bird from New Mexico, larger than the ostrich.","pos":""},{"def":"Disjoining two fourths; as, the diazeutic tone, which, like that from F to G in modern music, lay between two fourths, and, being joined to either, made a fifth.","pos":""}]}