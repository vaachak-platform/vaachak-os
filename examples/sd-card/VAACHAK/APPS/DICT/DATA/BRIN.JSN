{"BRIN":[{"def":"One of the radiating sticks of a fan.","pos":""}],"BRINDED":[{"def":"Of a gray or tawny color with streaks of darker hue; streaked; brindled.","pos":""}],"BRINDLE":[{"def":"The state of being brindled.","pos":""},{"def":"A brindled color; also, that which is brindled.","pos":""}],"BRINDLED":[{"def":"Having dark streaks or spots on a gray or tawny ground; brinded.","pos":""}],"BRINE":[{"def":"Water saturated or strongly inpregnated with salt; pickle; hence, any strong saline solution; also, the saline residue or strong mother liquor resulting from the evaporation of natural or artificial waters.","pos":""},{"def":"The ocean; the water of an ocean, sea, or salt lake.","pos":""}],"BRING":[{"def":"To convey to the place where the speaker is or is to be; to bear from a more distant to a nearer place; to fetch.","pos":""},{"def":"To cause the accession or obtaining of; to procure; to make to come; to produce; to draw to.","pos":""}],"BRINGER":[{"def":"Yet the first bringer of unwelcome news Hath but a losing office.","pos":""}],"BRININESS":[{"def":"The state or quality of being briny; saltness; brinishness.","pos":""}],"BRINISH":[{"def":"Like brine; somewhat salt; saltish.","pos":""}],"BRINISHNESS":[{"def":"State or quality of being brinish.","pos":""}],"BRINJAREE":[{"def":"A rough-haired East Indian variety of the greyhound.","pos":""}],"BRINK":[{"def":"The edge, margin, or border of a steep place, as of a precipice; a bank or edge, as of a river or pit; a verge; a border; as, the brink of a chasm.","pos":""}],"BRINY":[{"def":"Of or pertaining to brine, or to the sea; partaking of the nature of brine; salt; as, a briny taste; the briny flood.","pos":""}]}