{"PANG":[{"def":"A paroxysm of extreme pain or anguish; a sudden and transitory agony; a throe; as, the pangs of death.","pos":""}],"PANGENESIS":[{"def":"An hypothesis advanced by Darwin in explanation of heredity.","pos":""}],"PANGENETIC":[{"def":"Of or pertaining to pangenesis.","pos":""}],"PANGLESS":[{"def":"Without a pang; painless.","pos":""}],"PANGOLIN":[{"def":"Any one of several species of Manis, Pholidotus, and related genera, found in Africa and Asia.","pos":""}],"PANGOTHIC":[{"def":"Of, pertaining to, or including, all the Gothic races.","pos":""}]}