{"SLAB":[{"def":"The slack part of a sail.","pos":""}],"SLAB-SIDED":[{"def":"Having flat sides; hence, tall, or long and lank.","pos":""}],"SLABBER":[{"def":"To let saliva or some liquid fall from the mouth carelessly, like a child or an idiot; to drivel; to drool.","pos":""}],"SLABBERER":[{"def":"One who slabbers, or drools; hence, an idiot.","pos":""}],"SLABBERY":[{"def":"Like, or covered with, slabber or slab; slippery; sloppy.","pos":""}],"SLABBINESS":[{"def":"Quality of being slabby.","pos":""}],"SLABBING":[{"def":"Adapted for forming slabs, or for dressing flat surfaces.","pos":""}],"SLABBY":[{"def":"Sloppy; slimy; miry.","pos":""}],"SLACK":[{"def":"Small coal; also, coal dust; culm.","pos":""}],"SLACKEN":[{"def":"A spongy, semivitrifled substance which miners or smelters mix with the ores of metals to prevent their fusion.","pos":""}],"SLACKLY":[{"def":"In a slack manner.","pos":""}],"SLACKNESS":[{"def":"The quality or state of being slack.","pos":""}],"SLADE":[{"def":"A little dell or valley; a flat piece of low, moist ground.","pos":""},{"def":"The sole of a plow.","pos":""}],"SLAG":[{"def":"The dross, or recrement, of a metal; also, vitrified cinders.","pos":""},{"def":"The scoria of a volcano.","pos":""}],"SLAGGY":[{"def":"Of or pertaining to slag; resembling slag; as, slaggy cobalt.","pos":""}],"SLAIE":[{"def":"A weaver's reed; a sley.","pos":""}],"SLAKE":[{"def":"To allay; to quench; to extinguish; as, to slake thirst.","pos":""},{"def":"To mix with water, so that a true chemical combination shall take place; to slack; as, to slake lime.","pos":""}],"SLAKELESS":[{"def":"Not capable of being slaked.","pos":""}],"SLAM":[{"def":"To shut with force and a loud noise; to bang; as, he slammed the door.","pos":""},{"def":"To put in or on some place with force and loud noise; -- usually with down; as, to slam a trunk down on the pavement.","pos":""}],"SLAM-BANG":[{"def":"With great violence; with a slamming or banging noise.","pos":""},{"def":"A slut; a slatternly woman.","pos":""}],"SLANDER":[{"def":"Formerly, defamation generally, whether oral or written; in modern usage, defamation by words spoken; utterance of false, malicious, and defamatory words, tending to the damage and derogation of another; calumny.","pos":""}],"SLANDERER":[{"def":"One who slanders; a defamer; a calumniator.","pos":""}],"SLANDEROUS":[{"def":"Given or disposed to slander; uttering slander.","pos":""},{"def":"Embodying or containing slander; calumnious; as, slanderous words, speeches, or reports.","pos":""}],"SLANG":[{"def":"Any long, narrow piece of land; a promontory.","pos":""}],"SLANG-WHANGER":[{"def":"One who uses abusive slang; a ranting partisan.","pos":""}],"SLANGINESS":[{"def":"Quality of being slangy.","pos":""}],"SLANGY":[{"def":"Of or pertaining to slang; of the nature of slang; disposed to use slang.","pos":""}],"SLANT":[{"def":"To be turned or inclined from a right line or level; to lie obliquely; to slope.","pos":""}],"SLANTING":[{"def":"Oblique; sloping.","pos":""},{"def":"In an inclined direction; obliquely; slopingly.","pos":""}],"SLAP":[{"def":"To strike with the open hand, or with something broad.","pos":""}],"SLAPDASH":[{"def":"In a bold, careless manner; at random.","pos":""},{"def":"With a slap; all at once; slap.","pos":""}],"SLAPE":[{"def":"Slippery; smooth; crafty; hypocritical.","pos":""}],"SLAPEFACE":[{"def":"A soft-spoken, crafty hypocrite.","pos":""}],"SLAPJACK":[{"def":"A flat batter cake cooked on a griddle; a flapjack; a griddlecake.","pos":""}],"SLAPPER":[{"def":"Very large; monstrous; big.","pos":""}],"SLASH":[{"def":"To cut by striking violently and at random; to cut in long slits.","pos":""},{"def":"To lash; to ply the whip to.","pos":""}],"SLASH PINE":[{"def":"A kind of pine tree (Pinus Cubensis) found in Southern Florida and the West Indies; -- so called because it grows in \"slashes.","pos":""}],"SLASHED":[{"def":"Divided into many narrow parts or segments by sharp incisions; laciniate.","pos":""}],"SLASHER":[{"def":"A machine for applying size to warp yarns.","pos":""}],"SLASHY":[{"def":"Wet and dirty; slushy.","pos":""}],"SLAT":[{"def":"A thin, narrow strip or bar of wood or metal; as, the slats of a window blind.","pos":""}],"SLATE":[{"def":"An argillaceous rock which readily splits into thin plates; argillite; argillaceous schist.","pos":""},{"def":"A list of candidates, prepared for nomination or for election; a list of candidates, or a programme of action, devised beforehand.","pos":""}],"SLATE-COLOR":[{"def":"A dark bluish gray color.","pos":""}],"SLATE-GRAY":[{"def":"Of a dark gray, like slate.","pos":""}],"SLATER":[{"def":"One who lays slates, or whose occupation is to slate buildings.","pos":""}],"SLATING":[{"def":"The act of covering with slate, slates, or a substance resembling slate; the work of a slater.","pos":""},{"def":"Slates, collectively; also, material for slating.","pos":""}],"SLATT":[{"def":"A slab of stone used as a veneer for coarse masonry.","pos":""}],"SLATTER":[{"def":"To be careless, negligent, or aswkward, esp.","pos":""}],"SLATTERN":[{"def":"A woman who is negligent of her dress or house; one who is not neat and nice.","pos":""}],"SLATTERNLINESS":[{"def":"The quality or state of being slatternly; slovenliness; untidiness.","pos":""}],"SLATTERNLY":[{"def":"Resembling a slattern; sluttish; negligent; dirty.","pos":""},{"def":"In a slatternly manner.","pos":""}],"SLATTERPOUCH":[{"def":"A dance or game played by boys, requiring active exercise.","pos":""}],"SLATTING":[{"def":"Slats, collectively.","pos":""}],"SLATY":[{"def":"Resembling slate; having the nature, appearance, or properties, of slate; composed of thin parallel plates, capable of being separated by splitting; as, a slaty color or texture.","pos":""}],"SLAUGHTER":[{"def":"The act of killing.","pos":""}],"SLAUGHTERER":[{"def":"One who slaughters.","pos":""}],"SLAUGHTERHOUSE":[{"def":"A house where beasts are butchered for the market.","pos":""}],"SLAUGHTERMAN":[{"def":"One employed in slaughtering.","pos":""}],"SLAUGHTEROUS":[{"def":"Destructive; murderous.","pos":""}],"SLAV":[{"def":"One of a race of people occupying a large part of Eastern and Northern Europe, including the Russians, Bulgarians, Roumanians, Servo-Croats, Slovenes, Poles, Czechs, Wends or Sorbs, Slovaks, etc.","pos":""}],"SLAVE":[{"def":"A person who is held in bondage to another; one who is wholly subject to the will of another; one who is held as a chattel; one who has no freedom of action, but whose person and services are wholly under the control of another.","pos":""},{"def":"One who has lost the power of resistance; one who surrenders himself to any power whatever; as, a slave to passion, to lust, to strong drink, to ambition.","pos":""}],"SLAVEBORN":[{"def":"Born in slavery.","pos":""}],"SLAVEHOLDER":[{"def":"One who holds slaves.","pos":""}],"SLAVEHOLDING":[{"def":"Holding persons in slavery.","pos":""}],"SLAVER":[{"def":"A vessel engaged in the slave trade; a slave ship.","pos":""},{"def":"A person engaged in the purchase and sale of slaves; a slave merchant, or slave trader.","pos":""}],"SLAVERER":[{"def":"A driveler; an idiot.","pos":""}],"SLAVERING":[{"def":"Drooling; defiling with saliva.","pos":""}],"SLAVERY":[{"def":"The condition of a slave; the state of entire subjection of one person to the will of another.","pos":""},{"def":"A condition of subjection or submission characterized by lack of freedom of action or of will.","pos":""}],"SLAVIC":[{"def":"The group of allied languages spoken by the Slavs.","pos":""}],"SLAVISH":[{"def":"Of or pertaining to slaves; such as becomes or befits a slave; servile; excessively laborious; as, a slavish life; a slavish dependance on the great.","pos":""}],"SLAVISM":[{"def":"The common feeling and interest of the Slavonic race.","pos":""}],"SLAVOCRACY":[{"def":"The persons or interest formerly representing slavery politically, or wielding political power for the preservation or advancement of slavery.","pos":""}],"SLAVONIAN":[{"def":"A native or inhabitant of Slavonia; ethnologically, a Slav.","pos":""},{"def":"One, not being a Slav, who is interested in the development and prosperity of that race.","pos":""}],"SLAW":[{"def":"Sliced cabbage served as a salad, cooked or uncooked.","pos":""}],"SLAY":[{"def":"To put to death with a weapon, or by violence; hence, to kill; to put an end to; to destroy.","pos":""}],"SLAYER":[{"def":"One who slays; a killer; a murderer; a destrroyer of life.","pos":""}]}