{"ORA":[{"def":"A money of account among the Anglo-Saxons, valued, in the Domesday Book, at twenty pence sterling.","pos":""}],"ORABASSU":[{"def":"A South American monkey of the genus Callithrix, esp.","pos":""},{"def":"A genus (Atriplex) of herbs or low shrubs of the Goosefoot family, most of them with a mealy surface.","pos":""}],"ORACLE":[{"def":"The sanctuary, or Most Holy place in the temple; also, the temple itself.","pos":""}],"ORACULAR":[{"def":"Of or pertaining to an oracle; uttering oracles; forecasting the future; as, an oracular tongue.","pos":""},{"def":"Resembling an oracle in some way, as in solemnity, wisdom, authority, obscurity, ambiguity, dogmatism.","pos":""}],"ORACULOUS":[{"def":"Oracular; of the nature of an oracle.","pos":""}],"ORAL":[{"def":"Uttered by the mouth, or in words; spoken, not written; verbal; as, oral traditions; oral testimony; oral law.","pos":""},{"def":"Of or pertaining to the mouth; surrounding or lining the mouth; as, oral cilia or cirri.","pos":""}],"ORALLY":[{"def":"In an oral manner.","pos":""},{"def":"By, with, or in, the mouth; as, to receive the sacrament orally.","pos":""}],"ORANG":[{"def":"See Orang-outang.","pos":""}],"ORANG-OUTANG":[{"def":"An arboreal anthropoid ape (Simia satyrus), which inhabits Borneo and Sumatra.","pos":""}],"ORANGE":[{"def":"The tree that bears oranges; the orange tree.","pos":""}],"ORANGEADE":[{"def":"A drink made of orange juice and water, corresponding to lemonade; orange sherbet.","pos":""}],"ORANGEAT":[{"def":"Candied orange peel; also, orangeade.","pos":""}],"ORANGEISM":[{"def":"Attachment to the principles of the society of Orangemen; the tenets or practices of the Orangemen.","pos":""}],"ORANGEMAN":[{"def":"One of a secret society, organized in the north of Ireland in 1795, the professed objects of which are the defense of the regning sovereign of Great Britain, the support of the Protestant religion, the maintenance of the laws of the kingdom, etc.","pos":""}],"ORANGEROOT":[{"def":"An American ranunculaceous plant (Hidrastis Canadensis), having a yellow tuberous root; -- also called yellowroot, golden seal, etc.","pos":""}],"ORANGERY":[{"def":"A place for raising oranges; a plantation of orange trees.","pos":""}],"ORANGETAWNY":[{"def":"Deep orange-yellow; dark yellow.","pos":""}],"ORANGITE":[{"def":"An orange-yellow variety of the mineral thorite, found in Norway.","pos":""}],"ORARIAN":[{"def":"Of or pertaining to a coast.","pos":""}],"ORATION":[{"def":"Webster's oration at Bunker Hill.","pos":"noun"}],"ORATOR":[{"def":"An officer who is the voice of the university upon all public occasions, who writes, reads, and records all letters of a public nature, presents, with an appropriate address, those persons on whom honorary degrees are to be conferred, and performs other like duties; -- called also public orator.","pos":""}],"ORATORIAN":[{"def":"See Fathers of the Oratory, under Oratory.","pos":""}],"ORATORICAL":[{"def":"Of or pertaining to an orator or to oratory; characterized by oratory; rhetorical; becoming to an orator; as, an oratorical triumph; an oratorical essay.","pos":""}],"ORATORIO":[{"def":"A more or less dramatic text or poem, founded on some Scripture nerrative, or great divine event, elaborately set to music, in recitative, arias, grand choruses, etc.","pos":""}],"ORATORIZE":[{"def":"To play the orator.","pos":""}],"ORATORY":[{"def":"A place of orisons, or prayer; especially, a chapel or small room set apart for private devotions.","pos":""}],"ORATRESS":[{"def":"A woman who makes public addresses.","pos":""}],"ORATRIX":[{"def":"A woman plaintiff, or complainant, in equity pleading.","pos":""}]}