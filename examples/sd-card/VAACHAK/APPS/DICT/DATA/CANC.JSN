{"CANCAN":[{"def":"A rollicking French dance, accompanied by indecorous or extravagant postures and gestures.","pos":""}],"CANCEL":[{"def":"To suppress or omit; to strike out, as matter in type.","pos":""}],"CANCELIER":[{"def":"To turn in flight; -- said of a hawk.","pos":""},{"def":"The turn of a hawk upon the wing to recover herself, when she misses her aim in the stoop.","pos":""}],"CANCELLATE":[{"def":"Consisting of a network of veins, without intermediate parenchyma, as the leaves of certain plant; latticelike.","pos":""},{"def":"Having the surface coveres with raised lines, crossing at right angles.","pos":""}],"CANCELLATED":[{"def":"Open or spongy, as some porous bones.","pos":""}],"CANCELLATION":[{"def":"The operation of striking out common factora, in both the dividend and divisor.","pos":""}],"CANCELLI":[{"def":"The interlacing osseous plates constituting the elastic porous tissue of certain parts of the bones, esp.","pos":""}],"CANCELLOUS":[{"def":"Having a spongy or porous stracture; made up of cancelli; cancellated; as, the cancellous texture of parts of many bones.","pos":""}],"CANCER":[{"def":"A genus of decapod Crustacea, including some of the most common shore crabs of Europe and North America, as the rock crab, Jonah crab, etc.","pos":""},{"def":"Formerly, any malignant growth, esp.","pos":""}],"CANCERATE":[{"def":"To grow into a canser; to become cancerous.","pos":""}],"CANCERATION":[{"def":"The act or state of becoming cancerous or growing into a cancer.","pos":""}],"CANCERITE":[{"def":"Like a cancer; having the qualities or virulence of a cancer; affected with cancer.","pos":""}],"CANCEROUS":[{"def":"Like a cancer; having the qualities or virulence of a cancer; affected with cancer.","pos":""}],"CANCRIFORM":[{"def":"Having the form of, or resembling, a crab; crab-shaped.","pos":""},{"def":"Like a cancer; cancerous.","pos":""}],"CANCRINE":[{"def":"Having the qualities of a crab; crablike.","pos":""}],"CANCRINITE":[{"def":"A mineral occurring in hexagonal crystals, also massive, generally of a yellow color, containing silica, alumina, lime, soda, and carbon dioxide.","pos":""}],"CANCROID":[{"def":"Resembling a crab; pertaining to the Cancroidea, one of the families of crabs, including the genus Cancer.","pos":""}]}