{"GLYCERATE":[{"def":"A salt of glyceric acid.","pos":""}],"GLYCERIC":[{"def":"Pertaining to, or derived from, glycerin.","pos":""}],"GLYCERIDE":[{"def":"A compound ether (formed from glycerin).","pos":""},{"def":"An oily, viscous liquid, C3H5(OH)3, colorless and odorless, and with a hot, sweetish taste, existing in the natural fats and oils as the base, combined with various acids, as oleic, margaric, stearic, and palmitic.","pos":""}],"GLYCERITE":[{"def":"A medicinal preparation made by mixing or dissolving a substance in glycerin.","pos":""}],"GLYCEROL":[{"def":"Same as Glycerin.","pos":""}],"GLYCEROLE":[{"def":"Same as Glycerite.","pos":""}],"GLYCERYL":[{"def":"A compound radical, C3H5, regarded as the essential radical of glycerin.","pos":""}],"GLYCIDE":[{"def":"A colorless liquid, obtained from certain derivatives of glycerin, and regarded as a partially dehydrated glycerin; -- called also glycidic alcohol.","pos":""}],"GLYCIDIC":[{"def":"Pertaining to, or derived from, glycide; as, glycidic acid.","pos":""}],"GLYCIN":[{"def":"Same as Glycocoll.","pos":""}],"GLYCOCHOLATE":[{"def":"A salt of glycocholic acid; as, sodium glycocholate.","pos":""}],"GLYCOCHOLIC":[{"def":"Pertaining to, or composed of, glycocoll and cholic acid.","pos":""}],"GLYCOCIN":[{"def":"Same as Glycocoll.","pos":""}],"GLYCOCOLL":[{"def":"A crystalline, nitrogenous substance, with a sweet taste, formed from hippuric acid by boiling with hydrochloric acid, and present in bile united with cholic acid.","pos":""}],"GLYCOGEN":[{"def":"A white, amorphous, tasteless substance resembling starch, soluble in water to an opalescent fluid.","pos":""}],"GLYCOGENIC":[{"def":"Pertaining to, or caused by, glycogen; as, the glycogenic function of the liver.","pos":""},{"def":"The production or formation of sugar from gycogen, as in the liver.","pos":""}],"GLYCOLIC":[{"def":"Pertaining to, or derived from, glycol; as, glycolic ether; glycolic acid.","pos":""}],"GLYCOLIDE":[{"def":"A white amorphous powder, C4H4O, obtained by heating and dehydrating glycolic acid.","pos":""}],"GLYCOLURIC":[{"def":"Pertaining to, derived from, glycol and urea; as, glycoluric acid, which is called also hydantoic acid.","pos":""}],"GLYCOLURIL":[{"def":"A white, crystalline, nitrogenous substance, obtained by the reduction of allantoïn.","pos":""}],"GLYCOLYL":[{"def":"A divalent, compound radical, CO.","pos":""}],"GLYCONIC":[{"def":"Consisting of a spondee, a choriamb, and a pyrrhic; -- applied to a kind of verse in Greek and Latin poetry.","pos":""},{"def":"A glyconic verse.","pos":""}],"GLYCONIN":[{"def":"An emulsion of glycerin and the yolk of eggs, used as an ointment, as a vehicle for medicines, etc.","pos":""}],"GLYCOSE":[{"def":"One of a class of carbohydrates having from three to nine atoms of carbon in the molecules and having the constitution either of an aldehyde alcohol or of a ketone alcohol.","pos":""}],"GLYCOSINE":[{"def":"An organic base, C6H6N4, produced artificially as a white, crystalline powder, by the action of ammonia on glyoxal.","pos":""}],"GLYCOSOMETER":[{"def":"An apparatus for determining the amount of sugar in diabetic urine.","pos":""}],"GLYCOSURIA":[{"def":"Same as Gluoosuria.","pos":""}],"GLYCYRRHIZA":[{"def":"A genus of papilionaceous herbaceous plants, one species of which (G.","pos":""},{"def":"The root of Glycyrrhiza glabra (liquorice root), used as a demulcent, etc.","pos":""}],"GLYCYRRHIZIMIC":[{"def":"From, or pertaining to, glycyrrhizin; as, glycyrrhizimic acid.","pos":""}],"GLYCYRRHIZIN":[{"def":"A glucoside found in licorice root (Glycyrrhiza), in monesia bark (Chrysophyllum), in the root of the walnut, etc.","pos":""}],"GLYOXAL":[{"def":"A white, amorphous, deliquescent powder, (CO.","pos":""}],"GLYOXALIC":[{"def":"Pertaining to, or designating, an aldehyde acid, intermediate between glycol and oxalic acid.","pos":""}],"GLYOXALINE":[{"def":"A white, crystalline, organic base, C3H4N2, produced by the action of ammonia on glyoxal, and forming the origin of a large class of derivatives hence, any one of the series of which glyoxaline is a type; -- called also oxaline.","pos":""}],"GLYOXIME":[{"def":"A white, crystalline, nitrogenous substance, produced by the action of hydroxylamine on glyoxal, and belonging to the class of oximes; also, any one of a group of substances resembling glyoxime proper, and of which it is a type.","pos":""}],"GLYPH":[{"def":"A sunken channel or groove, usually vertical.","pos":""}],"GLYPHIC":[{"def":"Of or pertaining to sculpture or carving of any sort, esp.","pos":""}],"GLYPHOGRAPH":[{"def":"A plate made by glyphography, or an impression taken from such a plate.","pos":""}],"GLYPHOGRAPHIC":[{"def":"Of or pertaining to glyphography.","pos":""}],"GLYPHOGRAPHY":[{"def":"A process similar to etching, in which, by means of voltaic electricity, a raised copy of a drawing is made, so that it can be used to print from.","pos":""}],"GLYPTIC":[{"def":"Figured; marked as with figures.","pos":""}],"GLYPTICS":[{"def":"The art of engraving on precious stones.","pos":""}],"GLYPTODON":[{"def":"An extinct South American quaternary mammal, allied to the armadillos.","pos":""}],"GLYPTODONT":[{"def":"One of a family (glyptodontidæ) of extinct South American edentates, of which Glyptodon is the type.","pos":""}],"GLYPTOGRAPHIC":[{"def":"Relating to glyptography, or the art of engraving on precious stones.","pos":""}],"GLYPTOGRAPHY":[{"def":"The art or process of engraving on precious stones.","pos":""}],"GLYPTOTHECA":[{"def":"A building or room devoted to works of sculpture.","pos":""}],"GLYSTER":[{"def":"Same as Clyster.","pos":""}]}