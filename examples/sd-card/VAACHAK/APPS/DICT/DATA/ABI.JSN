{"ABIB":[{"def":"The first month of the Jewish ecclesiastical year, corresponding nearly to our April.","pos":""}],"ABIDANCE":[{"def":"The state of abiding; abode; continuance; compliance (with).","pos":""}],"ABIDE":[{"def":"To wait; to pause; to delay.","pos":""},{"def":"To stay; to continue in a place; to have one's abode; to dwell; to sojourn; -- with with before a person, and commonly with at or in before a place.","pos":""}],"ABIDER":[{"def":"One who abides, or continues.","pos":""},{"def":"One who dwells; a resident.","pos":""}],"ABIDING":[{"def":"Continuing; lasting.","pos":""}],"ABIES":[{"def":"A genus of coniferous trees, properly called Fir, as the balsam fir and the silver fir.","pos":""}],"ABIETENE":[{"def":"A volatile oil distilled from the resin or balsam of the nut pine (Pinus sabiniana) of California.","pos":""}],"ABIETIC":[{"def":"Of or pertaining to the fir tree or its products; as, abietic acid, called also sylvic acid.","pos":""},{"def":"A resinous obtained from Strasburg turpentine or Canada balsam.","pos":""}],"ABIETINIC":[{"def":"Of or pertaining to abietin; as, abietinic acid.","pos":""}],"ABIETITE":[{"def":"A substance resembling mannite, found in the needles of the common silver fir of Europe (Abies pectinata).","pos":""}],"ABIGAIL":[{"def":"A lady's waiting-maid.","pos":""}],"ABILITY":[{"def":"The quality or state of being able; power to perform, whether physical, moral, intellectual, conventional, or legal; capacity; skill or competence in doing; sufficiency of strength, skill, resources, etc.","pos":""}],"ABIOGENESIS":[{"def":"The supposed origination of living organisms from lifeless matter; such genesis as does not involve the action of living parents; spontaneous generation; -- called also abiogeny, and opposed to biogenesis.","pos":""}],"ABIOGENETIC":[{"def":"Of or pertaining to abiogenesis.","pos":""}],"ABIOGENIST":[{"def":"One who believes that life can be produced independently of antecedent.","pos":""}],"ABIOGENOUS":[{"def":"Produced by spontaneous generation.","pos":""}],"ABIOGENY":[{"def":"Same as Abiogenesis.","pos":""}],"ABIOLOGICAL":[{"def":"Pertaining to the study of inanimate things.","pos":""}],"ABIRRITANT":[{"def":"A medicine that diminishes irritation.","pos":""}],"ABIRRITATE":[{"def":"To diminish the sensibility of; to debilitate.","pos":""}],"ABIRRITATION":[{"def":"A pathological condition opposite to that of irritation; debility; want of strength; asthenia.","pos":""}],"ABIRRITATIVE":[{"def":"Characterized by abirritation or debility.","pos":""}],"ABIT":[{"def":"A*bit\", Defn: 3d sing.","pos":""}]}