{"RHIGOLENE":[{"def":"A mixture of volatile hydrocarbons intermediate between gsolene and cymogene.","pos":""}],"RHINAL":[{"def":"Og or pertaining to the nose or olfactory organs.","pos":""}],"RHINE":[{"def":"A water course; a ditch.","pos":""}],"RHINENCEPHALIC":[{"def":"Of or pertaining to the rhinencephalon.","pos":""}],"RHINENCEPHALON":[{"def":"The division of the brain in front of the prosencephalon, consisting of the two olfactory lobes from which the olfactory nerves arise.","pos":""}],"RHINESTONE":[{"def":"A colorless stone of high luster, made of paste.","pos":""}],"RHINITIS":[{"def":"Infllammation of the nose; esp.","pos":""}],"RHINO":[{"def":"Gold and silver, or money.","pos":""}],"RHINO-":[{"def":"A combining form from Greek the nose, as in rhinolith, rhinology.","pos":""},{"def":"Of or pertaining to the rhinoceros; resembling the rhinoceros, or his horn.","pos":""}],"RHINOCEROS":[{"def":"Any pachyderm belonging to the genera Rhinoceros, Atelodus, and several allied genera of the family Rhinocerotidæ, of which several living, and many extinct, species are known.","pos":""}],"RHINOCEROTIC":[{"def":"Of or pertaining to the rhinoceros.","pos":""},{"def":"A concretion formed within the cavities of the nose.","pos":""}],"RHINOLOGICAL":[{"def":"Of or pertaining to rhinology.","pos":""}],"RHINOLOGIST":[{"def":"One skilled in rhinology.","pos":""}],"RHINOLOGY":[{"def":"The science which treats of the nose, and its diseases.","pos":""}],"RHINOLOPHID":[{"def":"Any species of the genus Rhinilophus, or family Rhinolophidæ, having a horseshoe-shaped nasal crest; a horseshoe bat.","pos":""}],"RHINOLOPHINE":[{"def":"Like or pertaining to the rhinolophids, or horseshoe bats.","pos":""}],"RHINOPHORE":[{"def":"One of the two tentacle-like organs on the back of the head or neck of a nudibranch or tectibranch mollusk.","pos":""}],"RHINOPLASTIC":[{"def":"Of or pertaining to rhinoplasty; as, a rhinoplastic operation.","pos":""}],"RHINOPLASTY":[{"def":"Plastic surgery of the nose to correct deformity or to replace lost tissue.","pos":""}],"RHINOPOME":[{"def":"Any old-world bat of the genus Rhinopoma.","pos":""}],"RHINOSCLEROMA":[{"def":"A rare disease of the skin, characterized by the development of very hard, more or less flattened, prominences, appearing first upon the nose and subsequently upon the neighboring parts, esp.","pos":""}],"RHINOSCOPE":[{"def":"A small mirror for use in rhinoscopy.","pos":""}],"RHINOSCOPIC":[{"def":"Of or pertaining to rhinoscopy.","pos":""}],"RHINOSCOPY":[{"def":"The examination or study of the soft palate, posterior nares, etc.","pos":""}],"RHINOTHECA":[{"def":"The sheath of the upper mandible of a bird.","pos":""}],"RHIPIDOGLOSSA":[{"def":"A division of gastropod mollusks having a large number of long, divergent, hooklike, lingual teeth in each transverse row.","pos":"noun"}],"RHIPIPTER":[{"def":"One of the Rhipiptera, a group of insects having wings which fold like a fan; a strepsipter.","pos":""}],"RHIPIPTERAN":[{"def":"Same as Rhipipter.","pos":""}],"RHIZANTHOUS":[{"def":"Producing flowers from a rootstock, or apparently from a root.","pos":""}],"RHIZINE":[{"def":"A rootlike filament or hair growing from the stems of mosses or on lichens; a rhizoid.","pos":""}],"RHIZOCARPOUS":[{"def":"Having perennial rootstocks or bulbs, but annual flowering stems; -- said of all perennial herbs.","pos":""}],"RHIZOCEPHALA":[{"def":"A division of Pectostraca including saclike parasites of Crustacea.","pos":""}],"RHIZODONT":[{"def":"A reptile whose teeth are rooted in sockets, as the crocodile.","pos":""}],"RHIZOGAN":[{"def":"Prodicing roots.","pos":""}],"RHIZOGEN":[{"def":"One of a proposed class of flowering plants growning on the roots of other plants and destitute of green foliage.","pos":""}],"RHIZOID":[{"def":"A rootlike appendage.","pos":""}],"RHIZOMA":[{"def":"SAme as Rhizome.","pos":""}],"RHIZOMATOUS":[{"def":"Having the nature or habit of a rhizome or rootstock.","pos":""}],"RHIZOPHAGA":[{"def":"A division of marsupials.","pos":"noun"}],"RHIZOPHAGOUS":[{"def":"Feeding on roots; root-eating.","pos":""}],"RHIZOPHORA":[{"def":"A genus of trees including the mangrove.","pos":""}],"RHIZOPOD":[{"def":"One of the Rhizopoda.","pos":""}],"RHIZOPODA":[{"def":"An extensive class of Protozoa, including those which have pseudopodia, by means of which they move about and take their food.","pos":""}],"RHIZOPODOUS":[{"def":"Of or pertaining to the rhizopods.","pos":""}],"RHIZOSTOMATA":[{"def":"A suborder of Medusæ which includes very large species without marginal tentacles, but having large mouth lobes closely united at the edges.","pos":"noun"}],"RHIZOSTOME":[{"def":"One of the Rhizostomata.","pos":""}],"RHIZOTAXIS":[{"def":"The arrangement of the roots of plants.","pos":""}]}