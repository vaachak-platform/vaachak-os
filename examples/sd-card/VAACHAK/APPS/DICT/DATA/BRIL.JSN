{"BRILL":[{"def":"A fish allied to the turbot (Rhombus levis), much esteemed in England for food; -- called also bret, pearl, prill.","pos":""}],"BRILLANTE":[{"def":"In a gay, showy, and sparkling style.","pos":""}],"BRILLIANCY":[{"def":"The quality of being brilliant; splendor; glitter; great brighness, whether in a literal or figurative sense.","pos":""}],"BRILLIANT":[{"def":"Sparkling with luster; glittering; very bright; as, a brilliant star.","pos":""},{"def":"Distinguished by qualities which excite admiration; splended; shining; as, brilliant talents.","pos":""}],"BRILLIANTINE":[{"def":"An oily composition used to make the hair glossy.","pos":""},{"def":"A dress fabric having a glossy finish on both sides, resembling alpaca but of superior quality.","pos":""}],"BRILLIANTLY":[{"def":"In a brilliant manner.","pos":""}],"BRILLIANTNESS":[{"def":"Brilliancy; splendor; glitter.","pos":""}],"BRILLS":[{"def":"The hair on the eyelids of a horse.","pos":""}]}