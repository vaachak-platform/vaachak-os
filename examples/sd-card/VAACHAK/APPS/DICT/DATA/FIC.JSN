{"FICE":[{"def":"A small dog; -- written also fise, fyce, fiste, etc.","pos":""}],"FICHTELITE":[{"def":"A white crystallized mineral resin from the Fichtelgebirge, Bavaria.","pos":""}],"FICHU":[{"def":"A light cape, usually of lace, worn by women, to cover the neck and throat, and extending to the shoulders.","pos":""}],"FICKLE":[{"def":"Not fixed or firm; liable to change; unstable; of a changeable mind; not firm in opinion or purpose; inconstant; capricious; as, Fortune's fickle wheel.","pos":""}],"FICKLENESS":[{"def":"The quality of being fickle; instability; inconsonancy.","pos":""}],"FICKLY":[{"def":"In a fickle manner.","pos":""}],"FICO":[{"def":"A fig; an insignificant trifle, no more than the snap of one's thumb; a sign of contempt made by the fingers, expressing.","pos":""}],"FICTILE":[{"def":"Molded, or capable of being molded, into form by art; relating to pottery or to molding in any soft material.","pos":""}],"FICTION":[{"def":"An assumption of a possible thing as a fact, irrespective of the question of its truth.","pos":""}],"FICTIONAL":[{"def":"Pertaining to, or characterized by, fiction; fictitious; romantic.","pos":""}],"FICTIONIST":[{"def":"A writer of fiction.","pos":""}],"FICTITIOUS":[{"def":"Feigned; imaginary; not real; fabulous; counterfeit; false; not genuine; as, fictitious fame.","pos":""}],"FICTIVE":[{"def":"Feigned; counterfeit.","pos":""}],"FICTOR":[{"def":"An artist who models or forms statues and reliefs in any plastic material.","pos":""}],"FICUS":[{"def":"A genus of trees or shrubs, one species of which (F.","pos":""}]}