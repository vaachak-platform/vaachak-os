{"DISOBEDIENCE":[{"def":"Neglect or refusal to obey; violation of a command or prohibition.","pos":""}],"DISOBEDIENT":[{"def":"Neglecting or refusing to obey; omitting to do what is commanded, or doing what is prohibited; refractory; not observant of duty or rules prescribed by authority; -- applied to persons and acts.","pos":""}],"DISOBEDIENTLY":[{"def":"In a disobedient manner.","pos":""}],"DISOBEY":[{"def":"Not to obey; to neglect or refuse to obey (a superior or his commands, the laws, etc.","pos":""}],"DISOBEYER":[{"def":"One who disobeys.","pos":""}],"DISOBLIGATION":[{"def":"The act of disobliging.","pos":""},{"def":"A disobliging act; an offense.","pos":""}],"DISOBLIGATORY":[{"def":"Releasing from obligation.","pos":""}],"DISOBLIGE":[{"def":"To do an act which contravenes the will or desires of; to offend by an act of unkindness or incivility; to displease; to refrain from obliging; to be unaccommodating to.","pos":""},{"def":"To release from obligation.","pos":""}],"DISOBLIGEMENT":[{"def":"Release from obligation.","pos":""}],"DISOBLIGER":[{"def":"One who disobliges.","pos":""}],"DISOBLIGING":[{"def":"Not obliging; not disposed to do a favor; unaccommodating; as, a disobliging person or act.","pos":""},{"def":"Displeasing; offensive.","pos":""}],"DISOCCIDENT":[{"def":"To turn away from the west; to throw out of reckoning as to longitude.","pos":""}],"DISOCCUPATION":[{"def":"The state of being unemployed; want of occupation.","pos":""}],"DISOPINION":[{"def":"Want or difference of belief; disbelief.","pos":""}],"DISORB":[{"def":"To throw out of the proper orbit; to unsphere.","pos":""}],"DISORDEINED":[{"def":"Inordinate; irregular; vicious.","pos":""}],"DISORDER":[{"def":"Want of order or regular disposition; lack of arrangement; confusion; disarray; as, the troops were thrown into disorder; the papers are in disorder.","pos":""},{"def":"Neglect of order or system; irregularity.","pos":""}],"DISORDERED":[{"def":"Thrown into disorder; deranged; as, a disordered house, judgment.","pos":""}],"DISORDERLINESS":[{"def":"The state of being disorderly.","pos":""}],"DISORDERLY":[{"def":"Offensive to good morals and public decency; notoriously offensive; as, a disorderly house.","pos":""}],"DISORDINANCE":[{"def":"Disarrangement; disturbance.","pos":""}],"DISORDINATE":[{"def":"Inordinate; disorderly.","pos":""}],"DISORDINATELY":[{"def":"Dis*or\"di*nate*ly, adv.","pos":""}],"DISORDINATION":[{"def":"The state of being in disorder; derangement; confusion.","pos":""}],"DISORGANIZATION":[{"def":"The act of disorganizing; destruction of system.","pos":""},{"def":"The state of being disorganized; as, the disorganization of the body, or of government.","pos":""}],"DISORGANIZE":[{"def":"To destroy the organic structure or regular system of (a government, a society, a party, etc.","pos":""}],"DISORGANIZER":[{"def":"One who disorganizes or causes disorder and confusion.","pos":""}],"DISORIENT":[{"def":"To turn away from the cast; to confuse as to which way is east; to cause to lose one's bearings.","pos":""}],"DISORIENTATE":[{"def":"To turn away from the east, or (figuratively) from the right or the truth.","pos":""}],"DISOWN":[{"def":"To refuse to own or acknowledge as belonging to one's self; to disavow or deny, as connected with one's self personally; as, a parent can hardly disown his child; an author will sometimes disown his writings.","pos":""},{"def":"To refuse to acknowledge or allow; to deny.","pos":""}],"DISOWNMENT":[{"def":"Act of disowning.","pos":""}],"DISOXIDATE":[{"def":"To deoxidate; to deoxidize.","pos":""}],"DISOXYGENATE":[{"def":"To deprive of oxygen; to deoxidize.","pos":""}],"DISOXYGENATION":[{"def":"Dis*ox`y*gen*a\"tion, n.","pos":""}]}