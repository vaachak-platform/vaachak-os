{"POT":[{"def":"A metallic or earthen vessel, appropriated to any of a great variety of uses, as for boiling meat or vegetables, for holding liquids, for plants, etc.","pos":""},{"def":"An earthen or pewter cup for liquors; a mug.","pos":""}],"POT LACE":[{"def":"Lace whose pattern includes one or more representations of baskets or bowls from which flowers spring.","pos":""}],"POT LEAD":[{"def":"Graphite, or black lead, often used on the bottoms of racing vessels to diminish friction.","pos":""}],"POT-AU-FEU":[{"def":"A dish of broth, meat, and vegetables prepared by boiling in a pot, -- a dish esp.","pos":""}],"POT-BELLIED":[{"def":"Having a protuberant belly, like the bottom of a pot.","pos":""}],"POT-BELLY":[{"def":"A protuberant belly.","pos":""}],"POT-SURE":[{"def":"Made confident by drink.","pos":""}],"POT-VALIANT":[{"def":"Having the courage given by drink.","pos":""}],"POT-WALLOPER":[{"def":"A voter in certain boroughs of England, where, before the passage of the reform bill of 1832, the qualification for suffrage was to have boiled (walloped) his own pot in the parish for six months.","pos":""},{"def":"One who cleans pots; a scullion.","pos":""}],"POTABLE":[{"def":"Fit to be drunk; drinkable.","pos":""},{"def":"A potable liquid; a beverage.","pos":""}],"POTABLENESS":[{"def":"The quality of being drinkable.","pos":""}],"POTALE":[{"def":"The refuse from a grain distillery, used to fatten swine.","pos":""}],"POTAMIAN":[{"def":"A river tortoise; one of a group of tortoises (Potamites, or Trionychoidea) having a soft shell, webbed feet, and a sharp beak.","pos":""}],"POTAMOGRAPHY":[{"def":"An account or description of rivers; potamology.","pos":""}],"POTAMOLOGY":[{"def":"A scientific account or discussion of rivers; a treatise on rivers; potamography.","pos":""}],"POTAMOSPONGIAE":[{"def":"The fresh-water sponges.","pos":""}],"POTANCE":[{"def":"The stud in which the bearing for the lower pivot of the verge is made.","pos":""}],"POTARGO":[{"def":"A kind of sauce or pickle.","pos":""}],"POTASSAMIDE":[{"def":"A yellowish brown substance obtained by heating potassium in ammonia.","pos":""}],"POTASSIC":[{"def":"Pertaining to, or containing, potassium.","pos":""}],"POTASSIUM":[{"def":"An Alkali element, occurring abundantly but always combined, as in the chloride, sulphate, carbonate, or silicate, in the minerals sylvite, kainite, orthoclase, muscovite, etc.","pos":""}],"POTASSOXYL":[{"def":"The radical KO, derived from, and supposed to exist in, potassium hydroxide and other compounds.","pos":""}],"POTATION":[{"def":"The act of drinking.","pos":""}],"POTATORY":[{"def":"Of or pertaining to drinking.","pos":""}],"POTBOILER":[{"def":"A term applied derisively to any literary or artistic work, and esp.","pos":""}],"POTBOY":[{"def":"A boy who carries pots of ale, beer, etc.","pos":""}],"POTCH":[{"def":"To thrust; to push.","pos":""}],"POTCHER":[{"def":"One who, or that which, potches.","pos":""}],"POTEEN":[{"def":"Whisky; especially, whisky illicitly distilled by the Irish peasantry.","pos":""}],"POTELOT":[{"def":"Molybdenum sulphide.","pos":""}],"POTENCE":[{"def":"Potency; capacity.","pos":""}],"POTENCY":[{"def":"The quality or state of being potent; physical or moral power; inherent strength; energy; ability to effect a purpose; capability; efficacy; influence.","pos":""}],"POTENT":[{"def":"Producing great physical effects; forcible; powerful' efficacious; as, a potent medicine.","pos":""},{"def":"Having great authority, control, or dominion; puissant; mighty; influential; as, a potent prince.","pos":""}],"POTENTATE":[{"def":"One who is potent; one who possesses great power or sway; a prince, sovereign, or monarch.","pos":""}],"POTENTIAL":[{"def":"Being potent; endowed with energy adequate to a result; efficacious; influential.","pos":""},{"def":"Existing in possibility, not in actuality.","pos":""}],"POTENTIALITY":[{"def":"The quality or state of being potential; possibility, not actuality; inherent capability or disposition, not actually exhibited.","pos":""}],"POTENTIALLY":[{"def":"With power; potently.","pos":""},{"def":"In a potential manner; possibly, not positively.","pos":""}],"POTENTIATE":[{"def":"To render active or potent.","pos":""}],"POTENTIOMETER":[{"def":"An instrument for measuring or comparing electrial potentials or electro-motive forces.","pos":""}],"POTENTIZE":[{"def":"To render the latent power of (anything) available.","pos":""}],"POTENTLY":[{"def":"With great force or energy; powerfully; efficaciously.","pos":""}],"POTENTNESS":[{"def":"The quality or state of being potent; powerfulness; potency; efficacy.","pos":""}],"POTESTATE":[{"def":"A chief ruler; a potentate.","pos":""}],"POTGUN":[{"def":"A pot-shaped cannon; a mortar.","pos":""}],"POTHER":[{"def":"Bustle; confusion; tumult; flutter; bother.","pos":""}],"POTHOLE":[{"def":"A circular hole formed in the rocky beds of rivers by the grinding action of stones or gravel whirled round by the water in what was at first a natural depression of the rock.","pos":""}],"POTICHE":[{"def":"A vase with a separate cover, the body usually rounded or polygonal in plan with nearly vertical sides, a neck of smaller size, and a rounded shoulder.","pos":""},{"def":"The art or process of coating the inside of glass vessels with engravings or paintings, so as to give them the appearance of painted ware.","pos":""}],"POTION":[{"def":"A draught; a dose; usually, a draught or dose of a liquid medicine.","pos":""}],"POTLATCH":[{"def":"Among the Kwakiutl, Chimmesyan, and other Indians of the northwestern coast of North America, a ceremonial distribution by a man of gifts to his own and neighboring tribesmen, often, formerly, to his own impoverishment.","pos":""},{"def":"Hence, a feast given to a large number of persons, often accompanied by gifts.","pos":""}],"POTLID":[{"def":"The lid or cover of a pot.","pos":""}],"POTLUCK":[{"def":"Whatever may chance to be in the pot, or may be provided for a meal.","pos":""}],"POTMAN":[{"def":"A pot companion.","pos":""},{"def":"A servant in a public house; a potboy.","pos":""}],"POTOO":[{"def":"A large South American goatsucker (Nyctibius grandis).","pos":""}],"POTOROO":[{"def":"Any small kangaroo belonging to Hypsiprymnus, Bettongia, and allied genera, native of Australia and Tasmania.","pos":""}],"POTPIE":[{"def":"A meat pie which is boiled instead of being baked.","pos":""}],"POTPOURRI":[{"def":"A medley or mixture.","pos":""}],"POTSDAM GROUP":[{"def":"A subdivision of the Primordial or Cambrian period in American geology; -- so named from the sandstone of Potsdam, New York.","pos":""}],"POTSHERD":[{"def":"A piece or fragment of a broken pot.","pos":""}],"POTSTONE":[{"def":"A variety of steatite sometimes manufactured into culinary vessels.","pos":""}],"POTSURE":[{"def":"Made confident by drink.","pos":""}],"POTT":[{"def":"A size of paper.","pos":""}],"POTT'S DISEASE":[{"def":"Caries of the vertebræ, frequently resulting in curvature of the spine and paralysis of the lower extremities; -- so named from Percival Pott, an English surgeon.","pos":""}],"POTTAGE":[{"def":"A kind of food made by boiling vegetables or meat, or both together, in water, until soft; a thick soup or porridge.","pos":""}],"POTTER":[{"def":"The red-bellied terrapin.","pos":""}],"POTTERN":[{"def":"Of or pertaining to potters.","pos":""}],"POTTERY":[{"def":"The vessels or ware made by potters; earthenware, glazed and baked.","pos":""},{"def":"The place where earthen vessels are made.","pos":""}],"POTTING":[{"def":"The act of placing in a pot; as, the potting of plants; the potting of meats for preservation.","pos":""}],"POTTLE":[{"def":"A liquid measure of four pints.","pos":""},{"def":"A pot or tankard.","pos":""}],"POTULENT":[{"def":"Fit to drink; potable.","pos":""},{"def":"Nearly drunk; tipsy.","pos":""}]}