{"PROFACE":[{"def":"Much good may it do you! -- a familiar salutation or welcome.","pos":""}],"PROFANATION":[{"def":"The act of violating sacred things, or of treating them with contempt or irreverence; irreverent or too familiar treatment or use of what is sacred; desecration; as, the profanation of the Sabbath; the profanation of a sanctuary; the profanation of the name of God.","pos":""},{"def":"The act of treating with abuse or disrespect, or with undue publicity, or lack of delicacy.","pos":""}],"PROFANE":[{"def":"Not sacred or holy; not possessing peculiar sanctity; unconsecrated; hence, relating to matters other than sacred; secular; -- opposed to sacred, religious, or inspired; as, a profane place.","pos":""},{"def":"Unclean; impure; polluted; unholy.","pos":""}],"PROFANELY":[{"def":"In a profane manner.","pos":""}],"PROFANENESS":[{"def":"The quality or state of being profane; especially, the use of profane language.","pos":""}],"PROFANER":[{"def":"One who treats sacred things with irreverence, or defiles what is holy; one who uses profane language.","pos":""}],"PROFANITY":[{"def":"The quality or state of being profane; profaneness; irreverence; esp.","pos":""},{"def":"That which is profane; profane language or acts.","pos":""}],"PROFECTION":[{"def":"A setting out; a going forward; advance; progression.","pos":""}],"PROFECTITIOUS":[{"def":"Proceeding from, as from a parent; derived, as from an ancestor.","pos":""}],"PROFERT":[{"def":"The exhibition or production of a record or paper in open court, or an allegation that it is in court.","pos":""}],"PROFESS":[{"def":"To make open declaration of, as of one's knowledge, belief, action, etc.","pos":""},{"def":"To set up a claim to; to make presence to; hence, to put on or present an appearance of.","pos":""}],"PROFESSED":[{"def":"Openly declared, avowed, acknowledged, or claimed; as, a professed foe; a professed tyrant; a professed Christian.","pos":""}],"PROFESSION":[{"def":"The act of entering, or becoming a member of, a religious order.","pos":""}],"PROFESSIONAL":[{"def":"Of or pertaining to a profession, or calling; conforming to the rules or standards of a profession; following a profession; as, professional knowledge; professional conduct.","pos":""},{"def":"Engaged in by professionals; as, a professional race; -- opposed to amateur.","pos":""}],"PROFESSIONALISM":[{"def":"The following of a profession, sport, etc.","pos":""}],"PROFESSIONALIST":[{"def":"professional person.","pos":""}],"PROFESSIONALLY":[{"def":"In a professional manner or capacity; by profession or calling; in the exercise of one's profession; one employed professionally.","pos":""}],"PROFESSOR":[{"def":"One who professed, or makes open declaration of, his sentiments or opinions; especially, one who makes a public avowal of his belief in the Scriptures and his faith in Christ, and thus unites himself to the visible church.","pos":""}],"PROFESSORIAL":[{"def":"Of or pertaining to a professor; as, the professional chair; professional interest.","pos":""}],"PROFESSORIALISM":[{"def":"The character, manners, or habits of a professor.","pos":""}],"PROFESSORIAT":[{"def":"See Professoriate.","pos":""}],"PROFESSORIATE":[{"def":"The body of professors, or the professorial staff, in a university or college.","pos":""},{"def":"A professorship.","pos":""}],"PROFESSORSHIP":[{"def":"The office or position of a professor, or public teacher.","pos":""}],"PROFESSORY":[{"def":"Of or pertaining to a professor; professorial.","pos":""}],"PROFFER":[{"def":"To offer for acceptance; to propose to give; to make a tender of; as, to proffer a gift; to proffer services; to proffer friendship.","pos":""},{"def":"To essay or attempt of one's own accord; to undertake, or propose to undertake.","pos":""}],"PROFFERER":[{"def":"One who proffers something.","pos":""},{"def":"The quality of state of being proficient; advance in the acquisition of any art, science, or knowledge; progression in knowledge; improvement; adeptness; as, to acquire proficiency in music.","pos":""}],"PROFICIENT":[{"def":"One who has made considerable advances in any business, art, science, or branch of learning; an expert; an adept; as, proficient in a trade; a proficient in mathematics, music, etc.","pos":""}],"PROFICIENTLY":[{"def":"In a proficient manner.","pos":""}],"PROFICUOUS":[{"def":"Profitable; advantageous; useful.","pos":""}],"PROFILE":[{"def":"A human head represented sidewise, or in a side view; the side face or half face.","pos":""}],"PROFILING":[{"def":"In the construction of fieldworks, the erection at proper intervals of wooden profiles, to show to the workmen the sectional form of the parapets at those points.","pos":""}],"PROFILIST":[{"def":"One who takes profiles.","pos":""}],"PROFIT":[{"def":"Acquisition beyond expenditure; excess of value received for producing, keeping, or selling, over cost; hence, pecuniary gain in any transaction or occupation; emolument; as, a profit on the sale of goods.","pos":""},{"def":"Accession of good; valuable results; useful consequences; benefit; avail; gain; as, an office of profit, This I speak for your own profit.","pos":""}],"PROFITABLE":[{"def":"Yielding or bringing profit or gain; gainful; lucrative; useful; helpful; advantageous; beneficial; as, a profitable trade; profitable business; a profitable study or profession.","pos":""}],"PROFITING":[{"def":"Gain; advantage; profit.","pos":""}],"PROFITLESS":[{"def":"Without profit; unprofitable.","pos":""}],"PROFLIGACY":[{"def":"The quality of state of being profligate; a profligate or very vicious course of life; a state of being abandoned in moral principle and in vice; dissoluteness.","pos":""}],"PROFLIGATE":[{"def":"Overthrown; beaten; conquered.","pos":""},{"def":"Broken down in respect of rectitude, principle, virtue, or decency; openly and shamelessly immoral or vicious; dissolute; as, profligate man or wretch.","pos":""}],"PROFLIGATELY":[{"def":"In a profligate manner.","pos":""}],"PROFLIGATENESS":[{"def":"The quality of being profligate; an abandoned course of life; profligacy.","pos":""}],"PROFLIGATION":[{"def":"Defeat; rout; overthrow.","pos":""}],"PROFLUENCE":[{"def":"Quality of being profluent; course.","pos":""}],"PROFLUENT":[{"def":"Flowing forward, [R.","pos":""}],"PROFOUND":[{"def":"Descending far below the surface; opening or reaching to a great depth; deep.","pos":""},{"def":"Intellectually deep; entering far into subjects; reaching to the bottom of a matter, or of a branch of learning; thorough; as, a profound investigation or treatise; a profound scholar; profound wisdom.","pos":""}],"PROFOUNDLY":[{"def":"In a profound manner.","pos":""}],"PROFOUNDNESS":[{"def":"The quality or state of being profound; profundity; depth.","pos":""}],"PROFULGENT":[{"def":"Shining forth; brilliant; effulgent.","pos":""}],"PROFUNDITY":[{"def":"The quality or state of being profound; depth of place, knowledge, feeling, etc.","pos":""}],"PROFUSE":[{"def":"Pouring forth with fullness or exuberance; bountiful; exceedingly liberal; giving without stint; as, a profuse government; profuse hospitality.","pos":""},{"def":"Superabundant; excessive; prodigal; lavish; as, profuse expenditure.","pos":""}],"PROFUSELY":[{"def":"In a profuse manner.","pos":""}],"PROFUSENESS":[{"def":"Extravagance; profusion.","pos":""}],"PROFUSION":[{"def":"The act of one who is profuse; a lavishing or pouring out without sting.","pos":""},{"def":"Abundance; exuberant plenty; lavish supply; as, a profusion of commodities.","pos":""}],"PROFUSIVE":[{"def":"Profuse; lavish; prodigal.","pos":""}]}