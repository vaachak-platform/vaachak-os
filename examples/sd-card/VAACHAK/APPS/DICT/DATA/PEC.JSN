{"PECAN":[{"def":"A species of hickory (Carya olivæformis), growing in North America, chiefly in the Mississippi valley and in Texas, where it is one of the largest of forest trees; also, its fruit, a smooth, oblong nut, an inch or an inch and a half long, with a thin shell and well- flavored meat.","pos":""}],"PECCABILITY":[{"def":"The state or quality of being peccable; lability to sin.","pos":""}],"PECCABLE":[{"def":"Liable to sin; subject to transgress the divine law.","pos":""}],"PECCADILLO":[{"def":"A slight trespass or offense; a petty crime or fault.","pos":""}],"PECCANCY":[{"def":"The quality or state of being peccant.","pos":""},{"def":"A sin; an offense.","pos":""}],"PECCANT":[{"def":"Sinning; guilty of transgression; criminal; as, peccant angels.","pos":""},{"def":"Morbid; corrupt; as, peccant humors.","pos":""}],"PECCANTLY":[{"def":"In a peccant manner.","pos":""}],"PECCARY":[{"def":"A pachyderm of the genus Dicotyles.","pos":""}],"PECCAVI":[{"def":"I have sinned; -- used colloquially to express confession or acknowledgment of an offense.","pos":""}],"PECK":[{"def":"The fourth part of a bushel; a dry measure of eight quarts; as, a peck of wheat.","pos":""},{"def":"A great deal; a large or excessive quantity.","pos":""}],"PECKER":[{"def":"One who, or that which, pecks; specif.","pos":""},{"def":"An instrument for pecking; a pick.","pos":""}],"PECKISH":[{"def":"Inclined to eat; hungry.","pos":""}],"PECKLED":[{"def":"Speckled; spotted.","pos":""}],"PECOPTERIS":[{"def":"An extensive genus of fossil ferns; -- so named from the regular comblike arrangement of the leaflets.","pos":""}],"PECORA":[{"def":"An extensive division of ruminants, including the antelopes, deer, and cattle.","pos":""}],"PECTATE":[{"def":"A salt of pectic acid.","pos":""}],"PECTEN":[{"def":"Any species of bivalve mollusks of the genus Pecten, and numerous allied genera (family Pectinidæ); a scallop.","pos":""},{"def":"The comb of a scorpion.","pos":""}],"PECTIC":[{"def":"Of or pertaining to pectin; specifically, designating an acid obtained from ordinary vegetable jelly (pectin) as an amorphous substance, tough and horny when dry, but gelatinous when moist.","pos":""}],"PECTIN":[{"def":"One of a series of carbohydrates, commonly called vegetable jelly, found very widely distributed in the vegetable kingdom, especially in ripe fleshy fruits, as apples, cranberries, etc.","pos":""}],"PECTINAL":[{"def":"Of or pertaining to a comb; resembling a comb.","pos":""}],"PECTINATELY":[{"def":"In a pectinate manner.","pos":""}],"PECTINATION":[{"def":"Comblike toothing.","pos":""}],"PECTINIBRANCH":[{"def":"One of the Pectinibranchiata.","pos":""}],"PECTINIBRANCHIATA":[{"def":"A division of Gastropoda, including those that have a comblike gill upon the neck.","pos":""}],"PECTINIBRANCHIATE":[{"def":"Having pectinated gills.","pos":""}],"PECTINIFORM":[{"def":"Comblike in form.","pos":""}],"PECTIZE":[{"def":"To congeal; to change into a gelatinous mass.","pos":""}],"PECTOLITE":[{"def":"A whitish mineral occurring in radiated or fibrous crystalline masses.","pos":""}],"PECTORAL":[{"def":"Having the breast conspicuously colored; as, the pectoral sandpiper.","pos":""}],"PECTORALLY":[{"def":"As connected with the breast.","pos":""}],"PECTORILOQUIAL":[{"def":"Pertaining to, or of the nature of, pectoriloquy.","pos":""}],"PECTORILOQUISM":[{"def":"Pec`to*ril\"o*quism, n.","pos":""}],"PECTORILOQUOUS":[{"def":"Pec`to*ril\"o*quous, a.","pos":""}],"PECTORILOQUY":[{"def":"The distinct articulation of the sounds of a patient's voice, heard on applying the ear to the chest in auscultation.","pos":""}],"PECTOSE":[{"def":"An amorphous carbohydrate found in the vegetable kingdom, esp.","pos":""}],"PECTOSIC":[{"def":"Of, pertaining to, resembling, or derived from, pectose; specifically, designating an acid supposed to constitute largely ordinary pectin or vegetable jelly.","pos":""}],"PECTOSTRACA":[{"def":"A degenerate order of Crustacea, including the Rhizocephala and Cirripedia.","pos":""}],"PECTOUS":[{"def":"Of, pertaining to, or consisting of, pectose.","pos":""}],"PECTUS":[{"def":"The breast of a bird.","pos":""}],"PECULATE":[{"def":"To appropriate to one's own use the property of the public; to steal public moneys intrusted to one's care; to embezzle.","pos":""}],"PECULATION":[{"def":"The act or practice of peculating, or of defrauding the public by appropriating to one's own use the money or goods intrusted to one's care for management or disbursement; embezzlement.","pos":""}],"PECULATOR":[{"def":"One who peculates.","pos":""}],"PECULIAR":[{"def":"One's own; belonging solely or especially to an individual; not possessed by others; of private, personal, or characteristic possession and use; not owned in common or in participation.","pos":""},{"def":"Particular; individual; special; appropriate.","pos":""}],"PECULIARITY":[{"def":"The quality or state of being peculiar; individuality; singularity.","pos":""},{"def":"That which is peculiar; a special and distinctive characteristic or habit; particularity.","pos":""}],"PECULIARIZE":[{"def":"To make peculiar; to set appart or assign, as an exclusive possession.","pos":""}],"PECULIARLY":[{"def":"In a peculiar manner; particulary; in a rare and striking degree; unusually.","pos":""}],"PECULIARNESS":[{"def":"The quality or state of being peculiar; peculiarity.","pos":""}],"PECULIUM":[{"def":"The saving of a son or a slave with the father's or master's consent; a little property or stock of one's own; any exclusive personal or separate property.","pos":""}],"PECUNIARILY":[{"def":"In a pecuniary manner; as regards money.","pos":""}],"PECUNIARY":[{"def":"Relating to money; monetary; as, a pecuniary penalty; a pecuniary reward.","pos":""}],"PECUNIOUS":[{"def":"Abounding in money; wealthy; rich.","pos":""}]}