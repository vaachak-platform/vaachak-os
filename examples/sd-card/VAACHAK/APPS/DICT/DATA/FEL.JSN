{"FELANDERS":[{"def":"A name given to a group of minerals, closely related in crystalline form, and all silicates of alumina with either potash, soda, lime, or, in one case, baryta.","pos":""}],"FELICIFY":[{"def":"To make happy; to felicitate.","pos":""}],"FELICITATE":[{"def":"Made very happy.","pos":""}],"FELICITATION":[{"def":"The act of felicitating; a wishing of joy or happiness; congratulation.","pos":""}],"FELICITOUS":[{"def":"Characterized by felicity; happy; prosperous; delightful; skilful; successful; happily applied or expressed; appropriate.","pos":""}],"FELICITY":[{"def":"The state of being happy; blessedness; blissfulness; enjoyment of good.","pos":""},{"def":"That which promotes happiness; a successful or gratifying event; prosperity; blessing.","pos":""}],"FELINE":[{"def":"Catlike; of or pertaining to the genus Felis, or family Felidæ; as, the feline race; feline voracity.","pos":""}],"FELIS":[{"def":"A genus of carnivorous mammals, including the domestic cat, the lion, tiger, panther, and similar animals.","pos":""}],"FELL":[{"def":"Cruel; barbarous; inhuman; fierce; savage; ravenous.","pos":""},{"def":"Eager; earnest; intent.","pos":""}],"FELLABLE":[{"def":"Fit to be felled.","pos":""}],"FELLAH":[{"def":"A peasant or cultivator of the soil among the Egyptians, Syrians, etc.","pos":""}],"FELLER":[{"def":"One who, or that which, fells, knocks or cuts down; a machine for felling trees.","pos":""}],"FELLIFLUOUS":[{"def":"Flowing with gall.","pos":""}],"FELLINIC":[{"def":"Of, relating to, or derived from, bile or gall; as, fellinic acid.","pos":""}],"FELLMONGER":[{"def":"A dealer in fells or sheepskins, who separates the wool from the pelts.","pos":""}],"FELLNESS":[{"def":"The quality or state of being fell or cruel; fierce barbarity.","pos":""}],"FELLON":[{"def":"Variant of Felon.","pos":""}],"FELLOW":[{"def":"A companion; a comrade; an associate; a partner; a sharer.","pos":""},{"def":"A man without good breeding or worth; an ignoble or mean man.","pos":""}],"FELLOW-COMMONER":[{"def":"A student at Cambridge University, England, who commons, or dines, at the Fellow's table.","pos":""}],"FELLOW-CREATURE":[{"def":"One of the same race or kind; one made by the same Creator.","pos":""}],"FELLOW-FEELING":[{"def":"Sympathy; a like feeling.","pos":""}],"FELLOWFEEL":[{"def":"To share through sympathy; to participate in.","pos":""}],"FELLOWLESS":[{"def":"Without fellow or equal; peerless.","pos":""}],"FELLOWLIKE":[{"def":"Like a companion; companionable; on equal terms; sympathetic.","pos":""}],"FELLOWSHIP":[{"def":"The state or relation of being or associate.","pos":""},{"def":"Companionship of persons on equal and friendly terms; frequent and familiar intercourse.","pos":""}],"FELLY":[{"def":"Fel\"ly Defn: , adv.","pos":""}],"FELO-DE-SE":[{"def":"One who deliberately puts an end to his own existence, or loses his life while engaged in the commission of an unlawful or malicious act; a suicide.","pos":""}],"FELON":[{"def":"A person who has committed a felony.","pos":""},{"def":"A kind of whitlow; a painful imflammation of the periosteum of a finger, usually of the last joint.","pos":""}],"FELONIOUS":[{"def":"Having the quality of felony; malignant; malicious; villainous; traitorous; perfidious; in a legal sense, done with intent to commit a crime; as, felonious homicide.","pos":""}],"FELONOUS":[{"def":"Wicked; felonious.","pos":""}],"FELONRY":[{"def":"A body of felons; specifically, the convict population of a penal colony.","pos":""}],"FELONWORT":[{"def":"The bittersweet nightshade (Solanum Dulcamara).","pos":""}],"FELONY":[{"def":"An act on the part of the vassal which cost him his fee by forfeiture.","pos":""},{"def":"An offense which occasions a total forfeiture either lands or goods, or both, at the common law, and to which capital or other punishment may be added, according to the degree of guilt.","pos":""}],"FELSITE":[{"def":"A finegrained rock, flintlike in fracture, consisting essentially of orthoclase feldspar with occasional grains of quartz.","pos":""}],"FELSITIC":[{"def":"relating to, composed of, or containing, felsite.","pos":""}],"FELSPATHIC":[{"def":"See Feldspathic.","pos":""}],"FELT":[{"def":"A cloth or stuff made of matted fibers of wool, or wool and fur, fulled or wrought into a compact substance by rolling and pressure, with lees or size, without spinning or weaving.","pos":""},{"def":"A hat made of felt.","pos":""}],"FELT GRAIN":[{"def":", the grain of timber which is transverse to the annular rings or plates; the direction of the medullary rays in oak and some other timber.","pos":""}],"FELTER":[{"def":"To clot or mat together like felt.","pos":""}],"FELTING":[{"def":"The material of which felt is made; also, felted cloth; also, the process by which it is made.","pos":""},{"def":"The act of splitting timber by the felt grain.","pos":""}],"FELUCCA":[{"def":"A small, swift-sailing vessel, propelled by oars and lateen sails, -- once common in the Mediterranean.","pos":""}],"FELWORT":[{"def":"A European herb (Swertia perennis) of the Gentian family.","pos":""}]}