{"RAIA":[{"def":"A genus of rays which includes the skates.","pos":""}],"RAIAE":[{"def":"The order of elasmobranch fishes which includes the sawfishes, skates, and rays; -- called also Rajæ, and Rajii.","pos":""}],"RAID":[{"def":"A hostile or predatory incursion; an inroad or incursion of mounted men; a sudden and rapid invasion by a cavalry force; a foray.","pos":""},{"def":"An attack or invasion for the purpose of making arrests, seizing property, or plundering; as, a raid of the police upon a gambling house; a raid of contractors on the public treasury.","pos":""}],"RAIDER":[{"def":"One who engages in a raid.","pos":""}],"RAIFFEISEN":[{"def":"Designating, or pertaining to, a form of coöperative bank founded among the German agrarian population by Friedrich Wilhelm Raiffeisen (1818-88); as, Raiffeisen banks, the Raiffeisen system, etc.","pos":""}],"RAIL":[{"def":"An outer cloak or covering; a neckerchief for women.","pos":""}],"RAILER":[{"def":"One who rails; one who scoffs, insults, censures, or reproaches with opprobrious language.","pos":""}],"RAILING":[{"def":"Expressing reproach; insulting.","pos":""}],"RAILINGLY":[{"def":"With scoffing or insulting language.","pos":""}],"RAILLERY":[{"def":"Pleasantry or slight satire; banter; jesting language; satirical merriment.","pos":""}],"RAILLEUR":[{"def":"A banterer; a jester; a mocker.","pos":""}],"RAILROADING":[{"def":"The construction of a railroad; the business of managing or operating a railroad.","pos":""}],"RAIMENT":[{"def":"Clothing in general; vesture; garments; -- usually singular in form, with a collective sense.","pos":""},{"def":"An article of dress.","pos":""}],"RAIN":[{"def":"Water falling in drops from the clouds; the descent of water from the clouds in drops.","pos":""}],"RAIN-TIGHT":[{"def":"So tight as to exclude rain as, a rain-tight roof.","pos":""}],"RAINBOW":[{"def":"A bow or arch exhibiting, in concentric bands, the several colors of the spectrum, and formed in the part of the hemisphere opposite to the sun by the refraction and reflection of the sun's rays in drops of falling rain.","pos":""}],"RAINBOWED":[{"def":"Formed with or like a rainbow.","pos":""}],"RAINFALL":[{"def":"A fall or descent of rain; the water, or amount of water, that falls in rain; as, the average annual rainfall of a region.","pos":""}],"RAININESS":[{"def":"The state of being rainy.","pos":""}],"RAINLESS":[{"def":"Destitute of rain; as, a rainless region.","pos":""}],"RAINY":[{"def":"Abounding with rain; wet; showery; as, rainy day or season.","pos":""}],"RAIP":[{"def":"A rope; also, a measure equal to a rod.","pos":""}],"RAIS":[{"def":"Same as 2d Reis.","pos":""}],"RAISABLE":[{"def":"Capable of being raised.","pos":""}],"RAISE":[{"def":"To create or constitute; as, to raise a use that is, to create it.","pos":""}],"RAISED":[{"def":"Lifted up; showing above the surroundings; as, raised or embossed metal work.","pos":""},{"def":"Leavened; made with leaven, or yeast; -- used of bread, cake, etc.","pos":""}],"RAISER":[{"def":"One who, or that which, raises (in various senses of the verb).","pos":""}],"RAISIN":[{"def":"A grape, or a bunch of grapes.","pos":""},{"def":"A grape dried in the sun or by artificial heat.","pos":""}],"RAISING":[{"def":"The act of lifting, setting up, elevating, exalting, producing, or restoring to life.","pos":""},{"def":"Specifically, the operation or work of setting up the frame of a building; as, to help at a raising.","pos":""}],"RAISONNE":[{"def":"Arranged systematically, or according to classes or subjects; as, a catalogue raisonné.","pos":""}]}