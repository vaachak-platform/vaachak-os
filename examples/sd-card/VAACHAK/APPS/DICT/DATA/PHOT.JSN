{"PHOTIC":[{"def":"Relating to the production of light by the lower animals.","pos":""}],"PHOTIC REGION":[{"def":"The uppermost zone of the sea, which receives the most light.","pos":""}],"PHOTICS":[{"def":"The science of light; -- a general term sometimes employed when optics is restricted to light as a producing vision.","pos":""}],"PHOTISM":[{"def":"A luminous image or appearance of a hallucinatory character.","pos":""}],"PHOTO":[{"def":"A contraction of Photograph.","pos":""}],"PHOTO-":[{"def":"A combining form from Gr.","pos":""}],"PHOTO-ELECTRIC":[{"def":"Acting by the operation of both light and electricity; -- said of apparatus for producing pictures by electric light.","pos":""}],"PHOTO-ELECTRIC CELL":[{"def":"A cell (as one of two electrodes embedded in selenium) which by exposure to light generates an electric current.","pos":""}],"PHOTO-ELECTRICITY":[{"def":"Electricity produced by light.","pos":""}],"PHOTO-ELECTROGRAPH":[{"def":"An electrometer registering by photography.","pos":""}],"PHOTO-ELECTROTYPE":[{"def":"An electrotype plate formed in a mold made by photographing on prepared gelatine, etc.","pos":""}],"PHOTO-ENGRAVE":[{"def":"To engrave by a photomechanical process; to make a photo- engraving of.","pos":""}],"PHOTO-ENGRAVING":[{"def":"The process of obtaining an etched or engraved plate from the photographic image, to be used in printing; also, a picture produced by such a process.","pos":""}],"PHOTO-EPINASTY":[{"def":"A disproportionately rapid growth of the upper surface of dorsiventral organs, such as leaves, through the stimulus of exposure to light.","pos":""}],"PHOTO-ETCH":[{"def":"To engrave, or make an engraving of, by any photomechanical process involving etching of the plate.","pos":""}],"PHOTO-ETCHING":[{"def":"A photo-engraving produced by any process involving the etching of the plate.","pos":""}],"PHOTOBACTERIUM":[{"def":"A genus including certain comma-shaped marine bacteria which emit bluish or greenish phosphorescence.","pos":""}],"PHOTOBIOTIC":[{"def":"Requiring light to live; incapable of living without light; as, photobiotic plant cells.","pos":""}],"PHOTOCERAMICS":[{"def":"Art or process of decorating pottery with photographically prepared designs.","pos":""}],"PHOTOCHEMICAL":[{"def":"Of or pertaining to chemical action of light, or produced by it; as, the photochemical changes of the visual purple of the retina.","pos":""}],"PHOTOCHEMISTRY":[{"def":"The branch of chemistry which relates to the effect of light in producing chemical changes, as in photography.","pos":""},{"def":"Of or pertaining to photochromy; produced by photochromy.","pos":""}],"PHOTOCHROMOGRAPHY":[{"def":"Art or process of printing colored photographs.","pos":""}],"PHOTOCHROMOSCOPE":[{"def":"A device for giving shifting effects of color to a photograph.","pos":""},{"def":"A combination of three optical lanterns for projecting objects on a screen in the colors of nature.","pos":""}],"PHOTOCHROMOTYPE":[{"def":"A colored print made photomechanically.","pos":""}],"PHOTOCHROMOTYPY":[{"def":"The art of making photochromotypes.","pos":""}],"PHOTOCHROMY":[{"def":"The art or process of reproducing colors by photography.","pos":""}],"PHOTOCHRONOGRAPH":[{"def":"Pho`to*chron\"o*graph, n.","pos":""}],"PHOTOCHRONOGRAPHY":[{"def":"Art of recording or measuring intervals of time by the photochronograph.","pos":""}],"PHOTODROME":[{"def":"An apparatus consisting of a large wheel with spokes, which when turning very rapidly is illuminated by momentary flashes of light passing through slits in a rotating disk.","pos":""}],"PHOTODYNAMICS":[{"def":"The relation of light to the movements of plants and their organs; the study of the phenomena of curvatures induced by the stimulus of light.","pos":""}],"PHOTOGALVANOGRAPHY":[{"def":"The art or process of making photo-electrotypes.","pos":""}],"PHOTOGEN":[{"def":"A light hydrocarbon oil resembling kerosene.","pos":""}],"PHOTOGENE":[{"def":"A more or less continued impression or image on the retina.","pos":""}],"PHOTOGENIC":[{"def":"Of or pertaining to photogeny; producing or generating light.","pos":""}],"PHOTOGENY":[{"def":"See Photography.","pos":""}],"PHOTOGLYPHIC":[{"def":"Pertaining to the art of engraving by the action of light.","pos":""}],"PHOTOGLYPHY":[{"def":"Photoglyphic engraving.","pos":""}],"PHOTOGLYPTIC":[{"def":"Same as Photoglyphic.","pos":""}],"PHOTOGRAMMETER":[{"def":"A phototheodolite, or a camera designed for use in photogrammetry.","pos":""}],"PHOTOGRAMMETRY":[{"def":"A method of surveying or map making by photography, used also in determining the height and motions of clouds, sea waves, and the like.","pos":""}],"PHOTOGRAPH":[{"def":"A picture or likeness obtained by photography.","pos":""}],"PHOTOGRAPHER":[{"def":"One who practices, or is skilled in, photography.","pos":""},{"def":"Of or pertaining to photography; obtained by photography; used ib photography; as a photographic picture; a photographic camera.","pos":""}],"PHOTOGRAPHOMETER":[{"def":"An instrument for determining the sensibility of the plates employed in photographic processes to luminous rays.","pos":""}],"PHOTOGRAPHONE":[{"def":"A device, consisting essentially of an electric arc and a camera, by which a series of photographs of the variations of the arc due to sound waves are obtained for reproduction by means of a selenium cell and a telephone.","pos":""}],"PHOTOGRAPHY":[{"def":"The science which relates to the action of light on sensitive bodies in the production of pictures, the fixation of images, and the like.","pos":""},{"def":"The art or process of producing pictures by this action of light.","pos":""}],"PHOTOGRAVURE":[{"def":"A photoengraving; also, the process by which such a picture is produced.","pos":""}],"PHOTOHELIOGRAPH":[{"def":"A modified kind of telescope adapted to taking photographs of the sun.","pos":""}],"PHOTOHELIOMETER":[{"def":"A double-lens instrument for measuring slight variations of the sun's diameter by photography, utilizing the common chord of two overlapping images.","pos":""}],"PHOTOLITHOGRAPH":[{"def":"A lithographic picture or copy from a stone prepared by the aid of photography.","pos":""}],"PHOTOLITHOGRAPHER":[{"def":"One who practices, or one who employs, photolithography.","pos":""}],"PHOTOLITHOGRAPHIC":[{"def":"Of or pertaining to photolithography; produced by photolithography.","pos":""}],"PHOTOLITHOGRAPHY":[{"def":"The art or process of producing photolithographs.","pos":""},{"def":"Pertaining to photology, or the doctrine of light.","pos":""}],"PHOTOLOGIST":[{"def":"One who studies or expounds the laws of light.","pos":""}],"PHOTOLOGY":[{"def":"The doctrine or science of light, explaining its nature and phenomena; optics.","pos":""}],"PHOTOLUMINESCENT":[{"def":"Luminescent by exposure to light waves.","pos":""}],"PHOTOMAGNETIC":[{"def":"Of or pertaining to photomagnetism.","pos":""}],"PHOTOMAGNETISM":[{"def":"The branch of science which treats of the relation of magnetism to light.","pos":""}],"PHOTOMECHANICAL":[{"def":"Pertaining to, or designating, any photographic process in which a printing surface is obtained without the intervention of hand engraving.","pos":""}],"PHOTOMETER":[{"def":"An instrument for measuring the intensity of light, or, more especially, for comparing the relative intensities of different lights, or their relative illuminating power.","pos":""},{"def":"Of or pertaining to photometry, or to a photometer.","pos":""}],"PHOTOMETRICIAN":[{"def":"One engaged in the scientific measurement of light.","pos":""},{"def":"A specialist in photometry.","pos":""}],"PHOTOMETRY":[{"def":"That branch of science which treats of the measurement of the intensity of light.","pos":""}],"PHOTOMEZZOTYPE":[{"def":"A photomechanical process similar to collotype.","pos":""}],"PHOTOMICROGRAPH":[{"def":"An enlarged or macroscopic photograph of a microscopic object.","pos":""},{"def":"A microscopically small photograph of an object.","pos":""}],"PHOTOMICROGRAPHY":[{"def":"The art of producing photomicrographs.","pos":""}],"PHOTONEPHOGRAPH":[{"def":"A nephoscope registering by photography, commonly consisting of a pair of cameras used simultaneously.","pos":""}],"PHOTOPHILOUS":[{"def":"Light-loving; growing in strong light, as many plants.","pos":""}],"PHOTOPHOBIA":[{"def":"A dread or intolerance of light.","pos":""}],"PHOTOPHONE":[{"def":"An apparatus for the production of sound by the action of rays of light.","pos":""}],"PHOTOPHONIC":[{"def":"Of or pertaining to photophone.","pos":""}],"PHOTOPHONY":[{"def":"The art or practice of using the photophone.","pos":""}],"PHOTOPLAY":[{"def":"A play for representation or exhibition by moving pictures; also, the moving-picture representation of a play.","pos":""}],"PHOTOPRINT":[{"def":"Any print made by a photomechanical process.","pos":""}],"PHOTOPSIA":[{"def":"An affection of the eye, in which the patient perceives luminous rays, flashes, coruscations, etc.","pos":""}],"PHOTOPSY":[{"def":"Same as Photopsia.","pos":""}],"PHOTORELIEF":[{"def":"A printing surface in relief, obtained by photographic means and subsequent manipulations.","pos":""}],"PHOTOSCOPE":[{"def":"Anything employed for the observation of light or luminous effects.","pos":""}],"PHOTOSCOPIC":[{"def":"Of or pertaining to the photoscope or its uses.","pos":""}],"PHOTOSCULPTURE":[{"def":"A process in which, by means of a number of photographs simultaneously taken from different points of view on the same level, rough models of the figure or bust of a person or animal may be made with great expedition.","pos":""}],"PHOTOSPHERE":[{"def":"A sphere of light; esp.","pos":""}],"PHOTOSPHERIC":[{"def":"Of or pertaining to the photosphere.","pos":""}],"PHOTOSYNTHESIS":[{"def":"The process of constructive metabolism by which carbohydrates are formed from water vapor and the carbon dioxide of the air in the chlorophyll-containing tissues of plants exposed to the action of light.","pos":""},{"def":"The influence of light on the movements of low organisms, as various infusorians, the zoöspores of certain algæ, etc.","pos":""}],"PHOTOTELEGRAPHY":[{"def":"Telegraphy by means of light, as by the heliograph or the photophone.","pos":""}],"PHOTOTELESCOPE":[{"def":"A telescope adapted for taking photographs of the heavenly bodies.","pos":""}],"PHOTOTHEODOLITE":[{"def":"An arrangement of two photographic cameras, the plates of which may be brought into exactly the same plane, used in surveying and map making.","pos":""}],"PHOTOTHERAPY":[{"def":"The application of light for therapeutic purposes, esp.","pos":""}],"PHOTOTHERMIC":[{"def":"Of or pertaining to both light and heat.","pos":""}],"PHOTOTONUS":[{"def":"A motile condition in plants resulting from exposure to light.","pos":""}],"PHOTOTOPOGRAPHY":[{"def":"Pho`to*to*pog\"ra*phy, n.","pos":""}],"PHOTOTRICHROMATIC":[{"def":"Designating a photomechanical process for making reproductions in natural colors by three printings.","pos":""}],"PHOTOTROPIC":[{"def":"Same as Heliotropic.","pos":""}],"PHOTOTROPISM":[{"def":"The tendency of growing plant organs to move or curve under the influence of light.","pos":""}],"PHOTOTYPE":[{"def":"A plate or block with a printing surface (usually in relief) obtained from a photograph; also, any one of the many methods of processes by which such a printing surface is obtained.","pos":""}],"PHOTOTYPIC":[{"def":"Of or pertaining to a phototype or phototypy.","pos":""}],"PHOTOTYPOGRAPHY":[{"def":"Same as Phototypy.","pos":""}],"PHOTOTYPY":[{"def":"The art or process of producing phototypes.","pos":""}],"PHOTOVISUAL":[{"def":"Of certain achromatic lenses, having the same focus for the actinic and for the brightest of the visual rays.","pos":""}],"PHOTOXYLOGRAPHY":[{"def":"The process of producing a representation of an object on wood, by photography, for the use of the wood engraver.","pos":""}],"PHOTOZINCOGRAPH":[{"def":"A print made by photozincography.","pos":""}],"PHOTOZINCOGRAPHY":[{"def":"A process, analogous to photolithography, for reproducing photographed impressions transferred to zinc plate.","pos":""}]}