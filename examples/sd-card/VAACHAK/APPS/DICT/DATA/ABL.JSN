{"ABLACTATION":[{"def":"The process of grafting now called inarching, or grafting by approach.","pos":""}],"ABLAQUEATE":[{"def":"To lay bare, as the roots of a tree.","pos":""}],"ABLAQUEATION":[{"def":"The act or process of laying bare the roots of trees to expose them to the air and water.","pos":""}],"ABLATION":[{"def":"Wearing away; superficial waste.","pos":""}],"ABLATITIOUS":[{"def":"Diminishing; as, an ablatitious force.","pos":""}],"ABLATIVE":[{"def":"Applied to one of the cases of the noun in Latin and some other languages, -- the fundamental meaning of the case being removal, separation, or taking away.","pos":""}],"ABLAUT":[{"def":"The substitution of one root vowel for another, thus indicating a corresponding modification of use or meaning; vowel permutation; as, get, gat, got; sing, song; hang, hung.","pos":""}],"ABLAZE":[{"def":"On fire; in a blaze, gleaming.","pos":""},{"def":"In a state of glowing excitement or ardent desire.","pos":""}],"ABLE":[{"def":"Legally qualified; possessed of legal competence; as, able to inherit or devise property.","pos":""}],"ABLE-BODIED":[{"def":"Having a sound, strong body; physically competent; robust.","pos":""}],"ABLE-MINDED":[{"def":"Having much intellectual power.","pos":""}],"ABLEGATE":[{"def":"A representative of the pope charged with important commissions in foreign countries, one of his duties being to bring to a newly named cardinal his insignia of office.","pos":""}],"ABLEGATION":[{"def":"The act of sending abroad.","pos":""}],"ABLENESS":[{"def":"Ability of body or mind; force; vigor.","pos":""}],"ABLER":[{"def":"ABLET; ABLEN Ab\"let, Ab\"len Etym: [F.","pos":""}],"ABLIGATE":[{"def":"To tie up so as to hinder from.","pos":""}],"ABLIGURITION":[{"def":"Prodigal expense for food.","pos":""}],"ABLOOM":[{"def":"In or into bloom; in a blooming state.","pos":""}],"ABLUDE":[{"def":"To be unlike; to differ.","pos":""}],"ABLUENT":[{"def":"Washing away; carrying off impurities; detergent.","pos":""}],"ABLUSH":[{"def":"Blushing; ruddy.","pos":""}],"ABLUTION":[{"def":"A small quantity of wine and water, which is used to wash the priest's thumb and index finger after the communion, and which then, as perhaps containing portions of the consecrated elements, is drunk by the priest.","pos":""}],"ABLUTIONARY":[{"def":"Pertaining to ablution.","pos":""}],"ABLUVION":[{"def":"That which is washed off.","pos":""}],"ABLY":[{"def":"In an able manner; with great ability; as, ably done, planned, said.","pos":""},{"def":"A suffix composed of -able and the adverbial suffix -ly; as, favorably.","pos":""}]}