{"BOUCHE":[{"def":"Same as Bush, a lining.","pos":""}],"BOUCHERIZE":[{"def":"To impregnate with a preservative solution of copper sulphate, as timber, railroad ties, etc.","pos":""}],"BOUD":[{"def":"A weevil; a worm that breeds in malt, biscuit, etc.","pos":""},{"def":"A small room, esp.","pos":""}],"BOUDOIR":[{"def":"A small room, esp.","pos":""}],"BOUGAINVILLAEA":[{"def":"A genus of plants of the order Nyctoginaceæ, from tropical South America, having the flowers surrounded by large bracts.","pos":""}],"BOUGE":[{"def":"To stave in; to bilge.","pos":""}],"BOUGET":[{"def":"A charge representing a leather vessel for carrying water; -- also called water bouget.","pos":""}],"BOUGH":[{"def":"An arm or branch of a tree, esp.","pos":""}],"BOUGHT":[{"def":"A flexure; a bend; a twist; a turn; a coil, as in a rope; as the boughts of a serpent.","pos":""},{"def":"The part of a sling that contains the stone.","pos":""}],"BOUGHTEN":[{"def":"Purchased; not obtained or produced at home.","pos":""}],"BOUGIE":[{"def":"A long, flexible instrument, that is Note: introduced into the urethra, esophagus, etc.","pos":""},{"def":"A long slender rod consisting of gelatin or some other substance that melts at the temperature of the body.","pos":""}],"BOUGIE DECIMALE":[{"def":"A photometric standard used in France, having the value of one twentieth of the Violle platinum standard, or slightly less than a British standard candle.","pos":""}],"BOUILLI":[{"def":"Boiled or stewed meat; beef boiled with vegetables in water from which its gravy is to be made; beef from which bouillon or soup has been made.","pos":""}],"BOUILLON":[{"def":"An excrescence on a horse's frush or frog.","pos":""}],"BOUL":[{"def":"A curved handle.","pos":""}],"BOULANGERITE":[{"def":"A mineral of a bluish gray color and metallic luster, usually in plumose masses, also compact.","pos":""}],"BOULANGISM":[{"def":"The spirit or principles of a French political movement identified with Gen.","pos":""}],"BOULDER":[{"def":"Same as Bowlder.","pos":""}],"BOULDERY":[{"def":"Characterized by bowlders.","pos":""},{"def":"Same as Buhl, Buhlwork.","pos":""}],"BOULEVARD":[{"def":"Originally, a bulwark or rampart of fortification or fortified town.","pos":""},{"def":"A public walk or street occupying the site of demolished fortifications.","pos":""}],"BOULEVARDIER":[{"def":"A frequenter of a city boulevard, esp.","pos":""}],"BOULEVERSEMENT":[{"def":"Complete overthrow; disorder; a turning upside down.","pos":""}],"BOULT":[{"def":"Corrupted form Bolt.","pos":""}],"BOULTER":[{"def":"A long, stout fishing line to which many hooks are attached.","pos":""}],"BOUN":[{"def":"Ready; prepared; destined; tending.","pos":""}],"BOUNCE":[{"def":"To strike or thump, so as to rebound, or to make a sudden noise; a knock loudly.","pos":""},{"def":"To leap or spring suddenly or unceremoniously; to bound; as, she bounced into the room.","pos":""}],"BOUNCER":[{"def":"One who bounces; a large, heavy person who makes much noise in moving.","pos":""},{"def":"A boaster; a bully.","pos":""}],"BOUNCING":[{"def":"Stout; plump and healthy; lusty; buxom.","pos":""}],"BOUND":[{"def":"The external or limiting line, either real or imaginary, of any object or space; that which limits or restrains, or within which something is limited or restrained; limit; confine; extent; boundary.","pos":""}],"BOUNDARY":[{"def":"That which indicates or fixes a limit or extent, or marks a bound, as of a territory; a bounding or separating line; a real or imaginary limit.","pos":""}],"BOUNDEN":[{"def":"Bound; fastened by bonds.","pos":""},{"def":"Under obligation; bound by some favor rendered; obliged; beholden.","pos":""}],"BOUNDER":[{"def":"One who, or that which, limits; a boundary.","pos":""}],"BOUNDING":[{"def":"Moving with a bound or bounds.","pos":""}],"BOUNDLESS":[{"def":"Without bounds or confines; illimitable; vast; unlimited.","pos":""}],"BOUNTEOUS":[{"def":"Liberal in charity; disposed to give freely; generously liberal; munificent; beneficent; free in bestowing gifts; as, bounteous production.","pos":""}],"BOUNTIFUL":[{"def":"Goodness; generosity.","pos":""}],"BOUNTY":[{"def":"Goodness, kindness; virtue; worth.","pos":""},{"def":"Liberality in bestowing gifts or favors; gracious or liberal giving; generosity; munificence.","pos":""}],"BOUQUET":[{"def":"A nosegay; a bunch of flowers.","pos":""},{"def":"A perfume; an aroma; as, the bouquet of wine.","pos":""}],"BOUR":[{"def":"A chamber or a cottage.","pos":""}],"BOURBON":[{"def":"A member of a family which has occupied several European thrones, and whose descendants still claim the throne of France.","pos":""},{"def":"A politician who is behind the age; a ruler or politician who neither forgets nor learns anything; an obstinate conservative.","pos":""}],"BOURBON WHISKY":[{"def":"See under Whisky.","pos":""}],"BOURBONISM":[{"def":"The principles of those adhering to the house of Bourbon; obstinate conservatism.","pos":""}],"BOURBONIST":[{"def":"One who adheres to the house of Bourbon; a legitimist.","pos":""}],"BOURDON":[{"def":"A pilgrim's staff.","pos":""}],"BOURGEOIS":[{"def":"A size of type between long primer and brevier.","pos":""}],"BOURGEOISIE":[{"def":"The French middle class, particularly such as are concerned in, or dependent on, trade.","pos":""}],"BOURGEON":[{"def":"To sprout; to put forth buds; to shoot forth, as a branch.","pos":""}],"BOURI":[{"def":"A mullet (Mugil capito) found in the rivers of Southern Europe and in Africa.","pos":""},{"def":"A stream or rivulet; a burn.","pos":""}],"BOURNLESS":[{"def":"Without a bourn or limit.","pos":""}],"BOURNONITE":[{"def":"A mineral of a steel-gray to black color and metallic luster, occurring crystallized, often in twin crystals shaped like cogwheels (wheel ore), also massive.","pos":""}],"BOURREE":[{"def":"An old French dance tune in common time.","pos":""}],"BOURSE":[{"def":"An exchange, or place where merchants, bankers, etc.","pos":""}],"BOUSE":[{"def":"To drink immoderately; to carouse; to booze.","pos":""}],"BOUSER":[{"def":"A toper; a boozer.","pos":""}],"BOUSTROPHEDON":[{"def":"An ancient mode of writing, in alternate directions, one line from left to right, and the next from right to left (as fields are plowed), as in early Greek and Hittite.","pos":""}],"BOUSTROPHEDONIC":[{"def":"Relating to the boustrophedon mode of writing.","pos":""}],"BOUSTROPHIC":[{"def":"Boustrophedonic.","pos":""}],"BOUSY":[{"def":"Drunken; sotted; boozy.","pos":""}],"BOUT":[{"def":"As much of an action as is performed at one time; a going and returning, as of workmen in reaping, mowing, etc.","pos":""},{"def":"A conflict; contest; attempt; trial; a set-to at anything; as, a fencing bout; a drinking bout.","pos":""}],"BOUTADE":[{"def":"An outbreak; a caprice; a whim.","pos":""}],"BOUTEFEU":[{"def":"An incendiary; an inciter of quarrels.","pos":""}],"BOUTONNIERE":[{"def":"A bouquet worn in a buttonhole.","pos":""}],"BOUTS-RIMES":[{"def":"Words that rhyme, proposed as the ends of verses, to be filled out by the ingenuity of the person to whom they are offered.","pos":""}]}