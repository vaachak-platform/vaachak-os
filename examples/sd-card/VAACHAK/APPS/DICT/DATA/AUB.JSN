{"AUBADE":[{"def":"An open air concert in the morning, as distinguished from an evening serenade; also, a pianoforte composition suggestive of morning.","pos":""}],"AUBAINE":[{"def":"Succession to the goods of a stranger not naturalized.","pos":""}],"AUBIN":[{"def":"A broken gait of a horse, between an amble and a gallop; -- commonly called a Canterbury gallop.","pos":""}],"AUBURN":[{"def":"His auburn locks on either shoulder flowed.","pos":""}]}