{"COUNT":[{"def":"To tell or name one by one, or by groups, for the purpose of ascertaining the whole number of units in a collection; to number; to enumerate; to compute; to reckon.","pos":""},{"def":"To place to an account; to ascribe or impute; to consider or esteem as belonging.","pos":""}],"COUNT-WHEEL":[{"def":"The wheel in a clock which regulates the number of strokes.","pos":""}],"COUNTABLE":[{"def":"Capable of being numbered.","pos":""}],"COUNTENANCE":[{"def":"Appearance or expression of the face; look; aspect; mien.","pos":""},{"def":"The face; the features.","pos":""}],"COUNTENANCER":[{"def":"One who countenances, favors, or supports.","pos":""}],"COUNTER":[{"def":"A prefix meaning contrary, opposite, in opposition; as, counteract, counterbalance, countercheck.","pos":""}],"COUNTER BRACE":[{"def":"The brace of the fore-topsail on the leeward side of a vessel.","pos":""},{"def":"A brace, in a framed structure, which resists a strain of a character opposite to that which a main brace is designed to receive.","pos":""}],"COUNTER TENOR":[{"def":"One of the middle parts in music, between the tenor and the treble; high tenor.","pos":""}],"COUNTER WEIGHT":[{"def":"Coun\"ter *weight` (-wt`), n.","pos":""}],"COUNTER-COMPONY":[{"def":"Coun\"ter-com*po`ny (-km-p`n), a.","pos":""}],"COUNTER-COUCHANT":[{"def":"Lying down, with their heads in opposite directions; -- said of animals borne in a coat of arms.","pos":""}],"COUNTER-COURANT":[{"def":"Running in opposite directions; -- said of animals borne in a coast of arms.","pos":""}],"COUNTER-PALY":[{"def":"Paly, and then divided fesswise, so that each vertical piece is cut into two, having the colors used alternately or counterchanged.","pos":""}],"COUNTER-ROLL":[{"def":"A duplicate roll (record or account) kept by an officer as a check upon another officer's roll.","pos":""}],"COUNTER-SALIENT":[{"def":"Leaping from each other; -- said of two figures on a coast of arms.","pos":""}],"COUNTERACT":[{"def":"To act in opposition to; to hinder, defeat, or frustrate, by contrary agency or influence; as, to counteract the effect of medicines; to counteract good advice.","pos":""}],"COUNTERACTION":[{"def":"Action in opposition; hindrance resistance.","pos":""}],"COUNTERACTIVE":[{"def":"Tending to counteract.","pos":""}],"COUNTERACTIVELY":[{"def":"By counteraction.","pos":""}],"COUNTERBALANCE":[{"def":"To oppose with an equal weight or power; to counteract the power or effect of; to countervail; to equiponderate; to balance.","pos":""}],"COUNTERBORE":[{"def":"A flat-bottomed cylindrical enlargement of the mouth of a hole, usually of slight depth, as for receiving a cylindrical screw head.","pos":""},{"def":"A kind of pin drill with the cutting edge or edges normal to the axis; -- used for enlarging a hole, or for forming a flat-bottomed recess at its mouth.","pos":""}],"COUNTERBRACE":[{"def":"To brace in opposite directions; as, to counterbrace the yards, i.","pos":""},{"def":"To brace in such a way that opposite strains are resisted; to apply counter braces to.","pos":""}],"COUNTERBUFF":[{"def":"To strike or drive back or in an opposite direction; to stop by a blow or impulse in front.","pos":""}],"COUNTERCAST":[{"def":"A trick; a delusive contrivance.","pos":""}],"COUNTERCASTER":[{"def":"A caster of accounts; a reckoner; a bookkeeper; -- used conteptuously.","pos":""}],"COUNTERCHANGE":[{"def":"To give and receive; to cause to change places; to exchange.","pos":""},{"def":"To checker; to diversify, as in heraldic counterchanging.","pos":""}],"COUNTERCHANGED":[{"def":"Having the tinctures exchanged mutually; thus, if the field is divided palewise, or and azure, and cross is borne counterchanged, that part of the cross which comes on the azure side will be or, and that on the or side will be azure.","pos":""}],"COUNTERCHARGE":[{"def":"An opposing charge.","pos":""}],"COUNTERCHARM":[{"def":"To destroy the effect of a charm upon.","pos":""}],"COUNTERCHECK":[{"def":"To oppose or check by some obstacle; to check by a return check.","pos":""}],"COUNTERCLAIM":[{"def":"A claim made by a person as an offset to a claim made on him.","pos":""}],"COUNTERCURRENT":[{"def":"Running in an opposite direction.","pos":""}],"COUNTERDRAW":[{"def":"To copy, as a design or painting, by tracing with a pencil on oiled paper, or other transparent substance.","pos":""}],"COUNTERFAISANCE":[{"def":"See Counterfesance.","pos":""}],"COUNTERFEIT":[{"def":"Representing by imitation or likeness; having a resemblance to something else; portrayed.","pos":""},{"def":"Fabricated in imitation of something else, with a view to defraud by passing the false copy for genuine or original; as, counterfeit antiques; counterfeit coin.","pos":""}],"COUNTERFEITER":[{"def":"One who counterfeits; one who copies or imitates; especially, one who copies or forges bank notes or coin; a forger.","pos":""},{"def":"One who assumes a false appearance or semblance; one who makes false pretenses.","pos":""}],"COUNTERFEITLY":[{"def":"By forgery; falsely.","pos":""}],"COUNTERFESANCE":[{"def":"The act of forging; forgery.","pos":""}],"COUNTERFLEURY":[{"def":"Coun\"ter*fleu`ry (koun\"tr-fl`r), a.","pos":""}],"COUNTERFLORY":[{"def":"Adorned with flowers (usually fleurs-de-lis) so divided that the tops appear on one side and the bottoms on the others; -- said of any ordinary.","pos":""}],"COUNTERFOIL":[{"def":"That part of a tally, formerly in the exchequer, which was kept by an officer in that court, the other, called the stock, being delivered to the person who had lent the king money on the account; - - called also counterstock.","pos":""},{"def":"The part of a writing (as the stub of a bank check) in which are noted the main particulars contained in the corresponding part, which has been issued.","pos":""}],"COUNTERFORCE":[{"def":"An opposing force.","pos":""}],"COUNTERFORT":[{"def":"A kind of buttress of masonry to strengthen a revetment wall.","pos":""}],"COUNTERGAGE":[{"def":"An adjustable gage, with double points for transferring measurements from one timber to another, as the breadth of a mortise to the place where the tenon is to be made.","pos":""}],"COUNTERGLOW":[{"def":"An exceedingly faint roundish or somewhat oblong nebulous light near the ecliptic and opposite the sun, best seen during September and October, when in the constellations Sagittarius and Pisces.","pos":""}],"COUNTERGUARD":[{"def":"A low outwork before a bastion or ravelin, consisting of two lines of rampart parallel to the faces of the bastion, and protecting them from a breaching fire.","pos":""},{"def":"See Counter irritant, etc.","pos":""}],"COUNTERIRRITATE":[{"def":"To produce counter irritation in; to treat with one morbid process for the purpose of curing another.","pos":""}],"COUNTERJUMPER":[{"def":"A salesman in a shop; a shopman; -- used contemtuously.","pos":""}],"COUNTERMAN":[{"def":"A man who attends at the counter of a shop to sell goods.","pos":""}],"COUNTERMAND":[{"def":"To revoke (a former command); to cancel or rescind by giving an order contrary to one previously given; as, to countermand an order for goods.","pos":""},{"def":"To prohibit; to forbid.","pos":""}],"COUNTERMANDABLE":[{"def":"Capable of being countermanded; revocable.","pos":""}],"COUNTERMARCH":[{"def":"To march back, or to march in reversed order.","pos":""}],"COUNTERMARK":[{"def":"An artificial cavity made in the teeth of horses that have outgrown their natural mark, to disguise their age.","pos":""}],"COUNTERMINE":[{"def":"An underground gallery excavated to intercept and destroy the mining of an enemy.","pos":""}],"COUNTERMOVE":[{"def":"To move in a contrary direction to.","pos":""},{"def":"A movement in opposition to another.","pos":""}],"COUNTERMURE":[{"def":"A wall raised behind another, to supply its place when breached or destroyed.","pos":""}],"COUNTERNATURAL":[{"def":"Contrary to nature.","pos":""}],"COUNTERPANE":[{"def":"A coverlet for a bed, -- originally stitched or woven in squares or figures.","pos":""}],"COUNTERPART":[{"def":"One of two corresponding copies of an instrument; a duplicate.","pos":""}],"COUNTERPASSANT":[{"def":"Passant in opposite directions; -- said of two animals.","pos":""}],"COUNTERPLEAD":[{"def":"To plead the contrary of; to plead against; to deny.","pos":""}],"COUNTERPLOT":[{"def":"To oppose, as another plot, by plotting; to attempt to frustrate, as a stratagem, by stratagem.","pos":""}],"COUNTERPOINT":[{"def":"An opposite point [Obs.","pos":""}],"COUNTERPOISE":[{"def":"To act against with equal weight; to equal in weght; to balance the weight of; to counterbalance.","pos":""},{"def":"To act against with equal power; to balance.","pos":""}],"COUNTERPOLE":[{"def":"The exact opposite.","pos":""}],"COUNTERPONDERATE":[{"def":"TO equal in weight; to counterpoise; to equiponderate.","pos":""}],"COUNTERPROVE":[{"def":"To take a counter proof of, or a copy in reverse, by taking an impression directly from the face of an original.","pos":""},{"def":"marked by opposition or antipathy to revolution; as, ostracized for his counterrevolutionary tendencies.","pos":""}],"COUNTERROLMENT":[{"def":"A counter account.","pos":""}],"COUNTERSCALE":[{"def":"Counterbalance; balance, as of one scale against another.","pos":""}],"COUNTERSCARF":[{"def":"The exterior slope or wall of the ditch; -- sometimes, the whole covered way, beyond the ditch, with its parapet and glacis; as, the enemy have lodged themselves on the counterscarp.","pos":""}],"COUNTERSEAL":[{"def":"To seal or ratify with another or others.","pos":""}],"COUNTERSECURE":[{"def":"To give additional security to or for.","pos":""}],"COUNTERSHAFT":[{"def":"An intermediate shaft; esp.","pos":""}],"COUNTERSIGN":[{"def":"To sign on the opposite side of (an instrument or writing); hence, to sign in addition to the signature of a principal or superior, in order to attest the authenticity of a writing.","pos":""}],"COUNTERSINK":[{"def":"To chamfer or form a depression around the top of (a hole in wood, metal, etc.","pos":""},{"def":"To cause to sink even with or below the surface; as, to countersink a screw or bolt into woodwork.","pos":""}],"COUNTERSTAND":[{"def":"Resistance; opposition; a stand against.","pos":""}],"COUNTERSTEP":[{"def":"A contrary method of procedure; opposite course of action.","pos":""}],"COUNTERSTOCK":[{"def":"See Counterfoil.","pos":""}],"COUNTERSTROKE":[{"def":"A stroke or blow in return.","pos":""}],"COUNTERSUNK":[{"def":"Chamfered at the top; -- said of a hole.","pos":""},{"def":"Sunk into a chamfer; as, a countersunk bolt.","pos":""}],"COUNTERSWAY":[{"def":"A swaying in a contrary direction; an opposing influence.","pos":""}],"COUNTERTERM":[{"def":"A term or word which is the opposite of, or antithesis to, another; an antonym; -- the opposite of synonym; as, \"foe\" is the counterterm of \"friend\".","pos":""}],"COUNTERTIME":[{"def":"The resistance of a horse, that interrupts his cadence and the measure of his manege, occasioned by a bad horseman, or the bad temper of the horse.","pos":""}],"COUNTERTRIPPANT":[{"def":"Trippant in opposite directions.","pos":""}],"COUNTERTRIPPING":[{"def":"Same as Countertrippant.","pos":""}],"COUNTERTURN":[{"def":"The critical moment in a play, when, contrary to expectation, the action is embroiled in new difficulties.","pos":""}],"COUNTERVAIL":[{"def":"To act against with equal force, power, or effect; to thwart or overcome by such action; to furnish an equivalent to or for; to counterbalance; to compensate.","pos":""}],"COUNTERVALLATION":[{"def":"See Contravallation.","pos":""}],"COUNTERVIEW":[{"def":"An opposite or opposing view; opposition; a posture in which two persons front each other.","pos":""},{"def":"A position in which two dissimilar things illustrate each other by opposition; contrast.","pos":""}],"COUNTERVOTE":[{"def":"To vote in opposition ti; to balance or overcome by viting; to outvote.","pos":""}],"COUNTERWAIT":[{"def":"To wait or watch for; to be on guard against.","pos":""}],"COUNTERWEIGH":[{"def":"To weigh against; to counterbalance.","pos":""}],"COUNTERWHEEL":[{"def":"To cause to wheel or turn in an opposite direction.","pos":""}],"COUNTERWORK":[{"def":"To work in oppositeion to; to counteract.","pos":""}],"COUNTESS":[{"def":"The wife of an earl in the British peerage, or of a count in the Continental nobility; also, a lady possessed of the same dignity in her own right.","pos":""},{"def":"The house or room in which a merchant, trader, or manufacturer keeps his books and transacts business.","pos":""}],"COUNTLESS":[{"def":"Incapable of being counted; not ascertainable; innumerable.","pos":""}],"COUNTOR":[{"def":"An advocate or professional pleader; one who counted for his client, that is, orally pleaded his cause.","pos":""},{"def":"A merchant's office; a countinghouse.","pos":""}],"COUNTRE-":[{"def":"Same as prefix Counter-.","pos":""}],"COUNTREPLETE":[{"def":"To counterplead.","pos":""}],"COUNTRETAILLE":[{"def":"A counter tally; correspondence (in sound).","pos":""}],"COUNTRIFIED":[{"def":"Having the appearance and manners of a rustic; rude.","pos":""}],"COUNTRIFY":[{"def":"To give a rural appearance to; to cause to appear rustic.","pos":""}],"COUNTRY":[{"def":"The rock through which a vein runs.","pos":""}],"COUNTRY BANK":[{"def":"A national bank not in a reserve city.","pos":""}],"COUNTRY CLUB":[{"def":"A club usually located in the suburbs or vicinity of a city or town and devoted mainly to outdoor sports.","pos":""}],"COUNTRY COUSIN":[{"def":"A relative from the country visiting the city and unfamiliar with city manners and sights.","pos":""}],"COUNTRY SEAT":[{"def":"A dwelling in the country, used as a place of retirement from the city.","pos":""}],"COUNTRY-BASE":[{"def":"Same as Prison base.","pos":""}],"COUNTRY-DANCE":[{"def":"See Contradance.","pos":""}],"COUNTRYMAN":[{"def":"An inhabitant or native of a region.","pos":""},{"def":"One born in the same country with another; a compatriot; -- used with a possessive pronoun.","pos":""}],"COUNTRYSIDE":[{"def":"A particular rural district; a country neighborhood.","pos":""}],"COUNTRYWOMAN":[{"def":"A woman born, or dwelling, in the country, as opposed to the city; a woman born or dwelling in the same country with another native or inhabitant.","pos":""}]}