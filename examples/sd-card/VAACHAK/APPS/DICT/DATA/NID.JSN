{"NIDAMENTAL":[{"def":"of, pertaining to, or baring, eggs or egg capsules; as, the nidament capsules of certain gastropods; nidamental glands.","pos":""}],"NIDARY":[{"def":"A collection of nests.","pos":""}],"NIDE":[{"def":"A nestful; a brood; as, a nide of pheasants.","pos":""}],"NIDERING":[{"def":"Infamous; dastardly.","pos":""}],"NIDGERY":[{"def":"A trifle; a piece of foolery.","pos":""}],"NIDGET":[{"def":"A fool; an idiot, a coward.","pos":""}],"NIDIFICATE":[{"def":"Where are the fishes which nidificated in trees Lowell.","pos":""}],"NIDIFICATION":[{"def":"The act or process of building a nest.","pos":""}],"NIDING":[{"def":"A coward; a dastard; -- a term of utmost opprobrium.","pos":""}],"NIDOR":[{"def":"Scent or savor of meat or food, cooked or cooking.","pos":""}],"NIDOROUS":[{"def":"Resembling the smell or taste of roast meat, or of corrupt animal matter.","pos":""}],"NIDULANT":[{"def":"Lying loose in pulp or cotton within a berry or pericarp, as in a nest.","pos":""}],"NIDULATE":[{"def":"To make a nest, as a bird.","pos":""}],"NIDULATION":[{"def":"The time of remaining in the nest.","pos":""}],"NIDULITE":[{"def":"A Silurian fossil, formerly supposed to consist of eggs.","pos":""}],"NIDUS":[{"def":"A nest: a repository for the eggs of birds, insects, etc.","pos":""}]}