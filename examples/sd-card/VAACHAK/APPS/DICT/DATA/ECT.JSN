{"ECTAD":[{"def":"Toward the outside or surface; -- opposed to entad.","pos":""}],"ECTAL":[{"def":"Pertaining to, or situated near, the surface; outer; -- opposed to ental.","pos":""}],"ECTASIA":[{"def":"A dilatation of a hollow organ or of a canal.","pos":""}],"ECTASIS":[{"def":"The lengthening of a syllable from short to long.","pos":""}],"ECTENTAL":[{"def":"Relating to, or connected with, the two primitive germ layers, the ectoderm and ectoderm; as, the \"ectental line\" or line of juncture of the two layers in the segmentation of the ovum.","pos":""}],"ECTERON":[{"def":"The external layer of the skin and mucous membranes; epithelium; ecderon.","pos":""}],"ECTETHMOID":[{"def":"External to the ethmoid; prefrontal.","pos":""}],"ECTHLIPSIS":[{"def":"The elision of a final m, with the preceding vowel, before a word beginning with a vowel.","pos":""}],"ECTHOREUM":[{"def":"The slender, hollow thread of a nettling cell or cnida.","pos":""}],"ECTHYMA":[{"def":"A cutaneous eruption, consisting of large, round pustules, upon an indurated and inflamed base.","pos":""}],"ECTOBRONCHIUM":[{"def":"One of the dorsal branches of the main bronchi in the lungs of birds.","pos":""},{"def":"One of the bones of the tarsus.","pos":""}],"ECTOCYST":[{"def":"The outside covering of the Bryozoa.","pos":""}],"ECTODERM":[{"def":"Of or relating to the ectoderm.","pos":""}],"ECTOLECITHAL":[{"def":"Having the food yolk, at the commencement of segmentation, in a peripheral position, and the cleavage process confined to the center of the egg; as, ectolecithal ova.","pos":""}],"ECTOMERE":[{"def":"The more transparent cells, which finally become external, in many segmenting ova, as those of mammals.","pos":""}],"ECTOPARASITE":[{"def":"Any parasite which lives on the exterior of animals; -- opposed to endoparasite.","pos":""}],"ECTOPIA":[{"def":"A morbid displacement of parts, especially such as is congenial; as, ectopia of the heart, or of the bladder.","pos":""}],"ECTOPIC":[{"def":"Out of place; congenitally displaced; as, an ectopic organ.","pos":""}],"ECTOPLASTIC":[{"def":"Pertaining to, or composed of, ectoplasm.","pos":""}],"ECTOPROCTA":[{"def":"An order of Bryozoa in which the anus lies outside the circle of tentacles.","pos":""}],"ECTOPY":[{"def":"Same as Ectopia.","pos":""}],"ECTORGANISM":[{"def":"An external parasitic organism.","pos":""}],"ECTOSARC":[{"def":"The semisolid external layer of protoplasm in some unicellular organisms, as the amoeba; ectoplasm; exoplasm.","pos":""}],"ECTOSTEAL":[{"def":"Of or pertaining to ectostosis; as, ectosteal ossification.","pos":""}],"ECTOSTOSIS":[{"def":"A process of bone formation in which ossification takes place in the perichondrium and either surrounds or gradually replaces the cartilage.","pos":""}],"ECTOZOIC":[{"def":"ECTOZOON; ECTOZOOEN Ec`to*zo\"ön, n.","pos":""}],"ECTROPION":[{"def":"An unnatural eversion of the eyelids.","pos":""}],"ECTROPIUM":[{"def":"Same as Ectropion.","pos":""}],"ECTROTIC":[{"def":"Having a tendency to prevent the development of anything, especially of a disease.","pos":""}],"ECTYPAL":[{"def":"Copied, reproduced as a molding or cast, in contradistinction from the original model.","pos":""}],"ECTYPE":[{"def":"A copy from an original; a type of something that has previously existed.","pos":""}],"ECTYPOGRAPHY":[{"def":"A method of etching in which the design upon the plate is produced in relief.","pos":""},{"def":"General; universal; in ecclesiastical usage, that which concerns the whole church; as, an ecumenical council.","pos":""}]}