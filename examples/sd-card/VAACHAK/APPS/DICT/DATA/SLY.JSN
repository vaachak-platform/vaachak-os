{"SLY":[{"def":"Dexterous in performing an action, so as to escape notice; nimble; skillful; cautious; shrewd; knowing; -- in a good sense.","pos":"verb"},{"def":"Artfully cunning; secretly mischievous; wily.","pos":"verb"}],"SLYBOOTS":[{"def":"A humerous appellation for a sly, cunning, or waggish person.","pos":""}],"SLYLY":[{"def":"In a sly manner; shrewdly; craftily.","pos":""}],"SLYNESS":[{"def":"The quality or state of being sly.","pos":""}],"SLYPE":[{"def":"A narrow passage between two buildings, as between the transept and chapter house of a monastery.","pos":""}]}