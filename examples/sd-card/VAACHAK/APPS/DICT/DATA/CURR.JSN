{"CURR":[{"def":"The owlets hoot, the owlets curr.","pos":""}],"CURRANT":[{"def":"A shrub or bush of several species of the genus Ribes (a genus also including the gooseberry); esp.","pos":""}],"CURRENCY":[{"def":"A continued or uninterrupted course or flow like that of a sream; as, the currency of time.","pos":""},{"def":"The state or quality of being current; general acceptance or reception; a passing from person to person, or from hand to hand; circulation; as, a report has had a long or general currency; the currency of bank notes.","pos":""}],"CURRENT":[{"def":"Running or moving rapidly.","pos":""},{"def":"Now passing, as time; as, the current month.","pos":""}],"CURRENTLY":[{"def":"In a current manner; generally; commonly; as, it is currently believed.","pos":""}],"CURRENTNESS":[{"def":"The quality of being current; currency; circulation; general reception.","pos":""},{"def":"Easiness of pronunciation; fluency.","pos":""}],"CURRICLE":[{"def":"A small or short course.","pos":""},{"def":"A two-wheeled chaise drawn by two horses abreast.","pos":""}],"CURRICULUM":[{"def":"A race course; a place for running.","pos":""},{"def":"A course; particularly, a specified fixed course of study, as in a university.","pos":""}],"CURRIE":[{"def":"See 2d & 3d Curry.","pos":""}],"CURRIED":[{"def":"Dressed by currying; cleaned; prepared.","pos":""},{"def":"Prepared with curry; as, curried rice, fowl, etc.","pos":""}],"CURRIER":[{"def":"One who curries and dresses leather, after it is tanned.","pos":""}],"CURRISH":[{"def":"Having the qualities, or exhibiting the characteristics, of a cur; snarling; quarrelsome; snappish; churlish; hence, also malicious; malignant; brutal.","pos":""}],"CURRY":[{"def":"To dress or prepare for use by a process of scraping, cleansing, beating, smoothing, and coloring; -- said of leather.","pos":""},{"def":"To dress the hair or coat of (a horse, ox, or the like) with a currycomb and brush; to comb, as a horse, in order to make clean.","pos":""}],"CURRYCOMB":[{"def":"A kind of card or comb having rows of metallic teeth or serrated ridges, used in curryng a horse.","pos":""}]}