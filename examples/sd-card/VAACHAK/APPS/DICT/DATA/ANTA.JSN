{"ANTA":[{"def":"A species of pier produced by thickening a wall at its termination, treated architecturally as a pilaster, with capital and base.","pos":""}],"ANTACID":[{"def":"A remedy for acidity of the stomach, as an alkali or absorbent.","pos":""},{"def":"Counteractive of acidity.","pos":""}],"ANTACRID":[{"def":"Corrective of acrimony of the humors.","pos":""}],"ANTAEAN":[{"def":"Pertaining to Antæus, a giant athlete slain by Hercules.","pos":""}],"ANTAGONISM":[{"def":"Opposition of action; counteraction or contrariety of things or principles.","pos":""}],"ANTAGONIST":[{"def":"A muscle which acts in opposition to another; as a flexor, which bends a part, is the antagonist of an extensor, which extends it.","pos":""},{"def":"A medicine which opposes the action of another medicine or of a poison when absorbed into the blood or tissues.","pos":""}],"ANTAGONIZE":[{"def":"To contend with; to oppose actively; to counteract.","pos":""}],"ANTAGONY":[{"def":"Contest; opposition; antagonism.","pos":""}],"ANTALGIC":[{"def":"Alleviating pain.","pos":""},{"def":"A medicine to alleviate pain; an anodyne.","pos":""}],"ANTALKALINE":[{"def":"Of power to counteract alkalies.","pos":""}],"ANTAMBULACRAL":[{"def":"Away from the ambulacral region.","pos":""}],"ANTANAGOGE":[{"def":"A figure which consists in answering the charge of an adversary, by a counter charge.","pos":""}],"ANTAPHRODISIAC":[{"def":"Capable of blunting the venereal appetite.","pos":""},{"def":"Anything that quells the venereal appetite.","pos":""}],"ANTAPHRODITIC":[{"def":"An antaphroditic medicine.","pos":""}],"ANTAPOPLECTIC":[{"def":"Good against apoplexy.","pos":""},{"def":"A medicine used against apoplexy.","pos":""}],"ANTARCHISM":[{"def":"Opposition to government in general.","pos":""}],"ANTARCHIST":[{"def":"One who opposes all government.","pos":""},{"def":"Opposed to all human government.","pos":""}],"ANTARCTIC":[{"def":"Opposite to the northern or arctic pole; relating to the southern pole or to the region near it, and applied especially to a circle, distant from the pole 23º 28min.","pos":""}],"ANTARES":[{"def":"The principal star in Scorpio: -- called also the Scorpion's Heart.","pos":""}],"ANTARTHRITIC":[{"def":"A remedy against gout.","pos":""}],"ANTASTHMATIC":[{"def":"Opposing, or fitted to relieve, asthma.","pos":""},{"def":"A remedy for asthma.","pos":""}]}