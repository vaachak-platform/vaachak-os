{"ACKNOW":[{"def":"To acknowledge; to confess.","pos":""}],"ACKNOWLEDGE":[{"def":"To of or admit the knowledge of; to recognize as a fact or truth; to declare one's belief in; as, to acknowledge the being of a God.","pos":""},{"def":"To own or recognize in a particular character or relationship; to admit the claims or authority of; to give recognition to.","pos":""}],"ACKNOWLEDGEDLY":[{"def":"Ac*knowl\"edged*ly, adv.","pos":""}],"ACKNOWLEDGER":[{"def":"One who acknowledges.","pos":""}],"ACKNOWLEDGMENT":[{"def":"The act of acknowledging; admission; avowal; owning; confession.","pos":""},{"def":"The act of owning or recognized in a particular character or relationship; recognition as regards the existence, authority, truth, or genuineness.","pos":""}]}