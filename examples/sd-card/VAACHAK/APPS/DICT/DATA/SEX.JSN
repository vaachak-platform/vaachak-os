{"SEX":[{"def":"The distinguishing peculiarity of male or female in both animals and plants; the physical difference between male and female; the assemblage of properties or qualities by which male is distinguished from female.","pos":""},{"def":"One of the two divisions of organic beings formed on the distinction of male and female.","pos":""}],"SEX-":[{"def":"A combining form meaning six; as, sexdigitism; sexennial.","pos":""}],"SEXAGENARIAN":[{"def":"A person who is sixty years old.","pos":""}],"SEXAGENARY":[{"def":"Pertaining to, or designating, the number sixty; poceeding by sixties; sixty years old.","pos":""}],"SEXAGESIMA":[{"def":"The second Sunday before Lent; -- so called as being about the sixtieth day before Easter.","pos":""}],"SEXAGESIMAL":[{"def":"Pertaining to, or founded on, the number sixty.","pos":""}],"SEXANGLE":[{"def":"Having six angles; hexagonal.","pos":""}],"SEXANGULARLY":[{"def":"Sex*an\"gu*lar*ly, adv.","pos":""}],"SEXDIGITISM":[{"def":"The state of having six fingers on a hand, or six toes on a foot.","pos":""}],"SEXDIGITIST":[{"def":"One who has six fingers on a hand, or six toes on a foot.","pos":""}],"SEXED":[{"def":"Belonging to sex; having sex; distinctively male of female; as, the sexed condition.","pos":""}],"SEXENARY":[{"def":"Proceeding by sixes; sextuple; -- applied especially to a system of arithmetical computation in which the base is six.","pos":""}],"SEXENNIAL":[{"def":"Lasting six years, or happening once in six years.","pos":""},{"def":"A sexennial event.","pos":""}],"SEXENNIALLY":[{"def":"Once in six years.","pos":""},{"def":"Six-cleft; as, a sexfid calyx or nectary.","pos":""}],"SEXISYLLABIC":[{"def":"Having six syllables.","pos":""}],"SEXISYLLABLE":[{"def":"A word of six syllables.","pos":""}],"SEXLOCULAR":[{"def":"Having six cells for seeds; six-celled; as, a sexlocular pericarp.","pos":""}],"SEXLY":[{"def":"Pertaining to sex.","pos":""}],"SEXRADIATE":[{"def":"Having six rays; -- said of certain sponge spicules.","pos":""}],"SEXTAIN":[{"def":"A stanza of six lines; a sestine.","pos":""}],"SEXTANS":[{"def":"A Roman coin, the sixth part of an as.","pos":""},{"def":"A constellation on the equator south of Leo; the Sextant.","pos":""}],"SEXTANT":[{"def":"The sixth part of a circle.","pos":""},{"def":"The constellation Sextans.","pos":""}],"SEXTARY":[{"def":"An ancient Roman liquid and dry measure, about equal to an English pint.","pos":""}],"SEXTIC":[{"def":"Of the sixth degree or order.","pos":""},{"def":"A quantic of the sixth degree.","pos":""}],"SEXTILE":[{"def":"Measured by sixty degrees; fixed or indicated by a distance of sixty degrees.","pos":""}],"SEXTILLION":[{"def":"According to the method of numeration (which is followed also in the United States), the number expressed by a unit with twenty-one ciphers annexed.","pos":""}],"SEXTO":[{"def":"A book consisting of sheets each of which is folded into six leaves.","pos":""}],"SEXTODECIMO":[{"def":"Having sixteen leaves to a sheet; of, or equal to, the size of one fold of a sheet of printing paper when folded so as to make sixteen leaves, or thirty-two pages; as, a sextodecimo volume.","pos":""}],"SEXTOLET":[{"def":"A double triplet; a group of six equal notes played in the time of four.","pos":""}],"SEXTON":[{"def":"An under officer of a church, whose business is to take care of the church building and the vessels, vestments, etc.","pos":""}],"SEXTONESS":[{"def":"A female sexton; a sexton's wife.","pos":""}],"SEXTONSHIP":[{"def":"The office of a sexton.","pos":""}],"SEXTUPLE":[{"def":"Divisible by six; having six beats; as, sixtuple measure.","pos":""}],"SEXUAL":[{"def":"Linnæus, founded mainly on difference in number and position of the stamens and pistils of plants.","pos":""}],"SEXUALIST":[{"def":"One who classifies plants by the sexual method of Linnæus.","pos":""}],"SEXUALITY":[{"def":"The quality or state of being distinguished by sex.","pos":""}],"SEXUALIZE":[{"def":"To attribute sex to.","pos":""}],"SEXUALLY":[{"def":"In a sexual manner or relation.","pos":""}]}