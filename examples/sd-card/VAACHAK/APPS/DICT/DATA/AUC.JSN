{"AUCHENIUM":[{"def":"The part of the neck nearest the back.","pos":""}],"AUCTARY":[{"def":"That which is superadded; augmentation.","pos":""}],"AUCTION":[{"def":"A public sale of property to the highest bidder, esp.","pos":""},{"def":"The things sold by auction or put up to auction.","pos":""}],"AUCTION BRIDGE":[{"def":"A variety of the game of bridge in which the players, beginning with the dealer, bid for the privilege of naming the trump and playing with the dummy for that deal, there being heavy penalties for a player's failure to make good his bid.","pos":""}],"AUCTION PITCH":[{"def":"A game of cards in which the players bid for the privilege of determining or \"pitching\" the trump suit.","pos":""}],"AUCTIONARY":[{"def":"Of or pertaining to an auction or an auctioneer.","pos":""}],"AUCTIONEER":[{"def":"A person who sells by auction; a person whose business it is to dispose of goods or lands by public sale to the highest or best bidder.","pos":""}],"AUCUPATION":[{"def":"Birdcatching; fowling.","pos":""}]}