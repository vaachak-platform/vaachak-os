{"URO-":[{"def":"A combining form fr.","pos":""}],"UROBILIN":[{"def":"A yellow pigment identical with hydrobilirubin, abundant in the highly colored urine of fever, and also present in normal urine.","pos":""}],"UROCELE":[{"def":"A morbid swelling of the scrotum due to extravasation of urine into it.","pos":""}],"UROCERATA":[{"def":"A division of boring Hymenoptera, including Tremex and allied genera.","pos":""}],"UROCHORD":[{"def":"The central axis or cord in the tail of larval ascidians and of certain adult tunicates.","pos":""}],"UROCHORDA":[{"def":"Same as Tunicata.","pos":""}],"UROCHORDAL":[{"def":"Of or pertaining to the Urochorda.","pos":""}],"UROCHROME":[{"def":"A yellow urinary pigment, considered by Thudichum as the only pigment present in normal urine.","pos":""}],"UROCYST":[{"def":"The urinary bladder.","pos":""}],"URODELA":[{"def":"An order of amphibians having the tail well developed and often long.","pos":""}],"URODELE":[{"def":"One of the Urodela.","pos":""}],"URODELIAN":[{"def":"Of or pertaining to the Urodela.","pos":""},{"def":"One of the Urodela.","pos":""}],"UROERYTHRIN":[{"def":"A reddish urinary pigment, considered as the substance which gives to the urine of rheumatism its characteristic color.","pos":""}],"UROGASTRIC":[{"def":"Behind the stomach; -- said of two lobes of the carapace of certain crustaceans.","pos":""}],"UROGENITAL":[{"def":"Same as Urinogenital.","pos":""}],"UROGLAUCIN":[{"def":"A body identical with indigo blue, occasionally found in the urine in degeneration of the kidneys.","pos":""}],"UROHAEMATIN":[{"def":"Urinary hæmatin; -- applied to the normal coloring matter of the urine, on the supposition that it is formed either directly or indirectly (through bilirubin) from the hæmatin of the blood.","pos":""}],"UROHYAL":[{"def":"Of or pertaining to one or more median and posterior elements in the hyoidean arch of fishes.","pos":""},{"def":"A urohyal bone or cartilage.","pos":""}],"UROMERE":[{"def":"Any one of the abdominal segments of an arthropod.","pos":""}],"URONOLOGY":[{"def":"That part of medicine which treats of urine.","pos":""}],"UROPOD":[{"def":"Any one of the abdominal appendages of a crustacean, especially one of the posterior ones, which are often larger than the rest, and different in structure, and are used chiefly in locomotion.","pos":""}],"UROPODAL":[{"def":"Of or pertaining to a uropod.","pos":""}],"UROPOETIC":[{"def":"Producing, or favoring the production of, urine.","pos":""},{"def":"Of, pertaining to, or designating, a system of organs which eliminate nitrogenous waste matter from the blood of certain invertebrates.","pos":""}],"UROPYGIAL":[{"def":"Of or pertaining to the uropygium, or prominence at the base of the tail feathers, in birds.","pos":""}],"UROPYGIUM":[{"def":"The prominence at the posterior extremity of a bird's body, which supports the feathers of the tail; the rump; -- sometimes called pope's nose.","pos":""}],"UROSACRAL":[{"def":"Of or pertaining to both the caudal and sacral parts of the vertebral column; as, the urosacral vertebræ of birds.","pos":""}],"UROSCOPY":[{"def":"The diagnosis of diseases by inspection of urine.","pos":""}],"UROSOME":[{"def":"The abdomen, or post-abdomen, of arthropods.","pos":""}],"UROSTEGE":[{"def":"One of the plates on the under side of the tail of a serpent.","pos":""}],"UROSTEON":[{"def":"A median ossification back of the lophosteon in the sternum of some birds.","pos":""}],"UROSTERNITE":[{"def":"The sternal, or under piece, of any one of the uromeres of insects and other arthropods.","pos":""}],"UROSTYLE":[{"def":"A styliform process forming the posterior extremity of the vertebral column in some fishes and amphibians.","pos":""}],"UROXANATE":[{"def":"A salt of uroxanic acid.","pos":""}],"UROXANIC":[{"def":"Pertaining to, or designating, an acid, C5H8N4O6, which is obtained, as a white crystalline substance, by the slow oxidation of uric acid in alkaline solution.","pos":""}],"UROXANTHIN":[{"def":"Same as Indican.","pos":""}]}