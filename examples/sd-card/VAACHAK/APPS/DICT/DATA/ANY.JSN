{"ANY":[{"def":"One indifferently, out of an indefinite number; one indefinitely, whosoever or whatsoever it may be.","pos":""},{"def":"Some, of whatever kind, quantity, or number; as, are there any witnesses present are there any other houses like it \"Who will show us any good\" Ps.","pos":""}],"ANYBODY":[{"def":"Any one out of an indefinite number of persons; anyone; any person.","pos":""},{"def":"A person of consideration or standing.","pos":""}],"ANYHOW":[{"def":"In any way or manner whatever; at any rate; in any event.","pos":""}],"ANYONE":[{"def":"One taken at random rather than by selection; anybody.","pos":""}],"ANYTHING":[{"def":"Any object, act, state, event, or fact whatever; thing of any kind; something or other; aught; as, I would not do it for anything.","pos":""},{"def":"Expressing an indefinite comparison; -- with as or like.","pos":""}],"ANYTHINGARIAN":[{"def":"One who holds to no particular creed or dogma.","pos":""},{"def":"Anywise; at all.","pos":""}],"ANYWHITHER":[{"def":"To or towards any place.","pos":""}],"ANYWISE":[{"def":"In any wise or way; at all.","pos":""}]}