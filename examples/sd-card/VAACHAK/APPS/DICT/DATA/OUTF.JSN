{"OUTFACE":[{"def":"To face or look (one) out of countenance; to resist or bear down by bold looks or effrontery; to brave.","pos":""}],"OUTFALL":[{"def":"The mouth of a river; the lower end of a water course; the open end of a drain, culvert, etc.","pos":""},{"def":"A quarrel; a falling out.","pos":""}],"OUTFAWN":[{"def":"To exceed in fawning.","pos":""}],"OUTFEAST":[{"def":"To exceed in feasting.","pos":""}],"OUTFEAT":[{"def":"To surpass in feats.","pos":""}],"OUTFIELD":[{"def":"The part of the field beyond the diamond, or infield.","pos":""},{"def":"The part of the field farthest from the batsman.","pos":""}],"OUTFIT":[{"def":"States to a diplomatic agent going abroad.","pos":""}],"OUTFITTER":[{"def":"One who furnishes outfits for a voyage, a journey, or a business.","pos":""}],"OUTFLANK":[{"def":"To go beyond, or be superior to, on the flank; to pass around or turn the flank or flanks of.","pos":""}],"OUTFLATTER":[{"def":"To exceed in flattering.","pos":""}],"OUTFLING":[{"def":"A gibe; a contemptuous remark.","pos":""}],"OUTFLOW":[{"def":"A flowing out; efflux.","pos":""}],"OUTFLY":[{"def":"To surpass in flying; to fly beyond or faster than.","pos":""}],"OUTFOOL":[{"def":"To exceed in folly.","pos":""}],"OUTFOOT":[{"def":"To outrun or outwalk; hence, of a vessel, to outsail.","pos":""}],"OUTFORM":[{"def":"External appearance.","pos":""}],"OUTFROWN":[{"def":"To frown down; to overbear by frowning.","pos":""}]}