{"HYPO":[{"def":"Sodium hyposulphite, or thiosulphate, a solution of which is used as a bath to wash out the unchanged silver salts in a picture.","pos":""}],"HYPO-":[{"def":"A prefix denoting that the element to the name of which it is prefixed enters with a low valence, or in a low state of oxidization, usually the lowest, into the compounds indicated; as, hyposulphurous acid.","pos":""}],"HYPOARIAN":[{"def":"Of or pertaining to a hypoarion.","pos":""}],"HYPOARION":[{"def":"An oval lobe beneath each of the optic lobes in many fishes; one of the inferior lobes.","pos":""}],"HYPOBLAST":[{"def":"The inner or lower layer of the blastoderm; -- called also endoderm, entoderm, and sometimes hypoderm.","pos":""}],"HYPOBLASTIC":[{"def":"Relating to, or connected with, the hypoblast; as, the hypoic sac.","pos":""}],"HYPOBOLE":[{"def":"A figure in which several things are mentioned that seem to make against the argument, or in favor of the opposite side, each of them being refuted in order.","pos":""}],"HYPOBRANCHIAL":[{"def":"Pertaining to the segment between the basibranchial and the ceratobranchial in a branchial arch.","pos":""},{"def":"A hypobranchial bone or cartilage.","pos":""}],"HYPOCARPOGEAN":[{"def":"Producing fruit below the ground.","pos":""}],"HYPOCHLORITE":[{"def":"A salt of hypochlorous acid; as, a calcium hypochloride.","pos":""}],"HYPOCHLOROUS":[{"def":"Pertaining to, or derived from, chlorine having a valence lower than in chlorous compounds.","pos":""}],"HYPOCHONDRES":[{"def":"The hypochondriac regions.","pos":""}],"HYPOCHONDRIA":[{"def":"Hypochondriasis; melancholy; the blues.","pos":""}],"HYPOCHONDRIAC":[{"def":"Of or pertaining to hypochondria, or the hypochondriac regions.","pos":""},{"def":"Affected, characterized, or produced, by hypochondriasis.","pos":""}],"HYPOCHONDRIACAL":[{"def":"Same as Hypochondriac, 2.","pos":""}],"HYPOCHONDRIACISM":[{"def":"Hypochondriasis.","pos":""}],"HYPOCHONDRIASIS":[{"def":"A mental disorder in which melancholy and gloomy views torment the affected person, particularly concerning his own health.","pos":""}],"HYPOCHONDRIASM":[{"def":"Hypochondriasis.","pos":""}],"HYPOCHONDRIUM":[{"def":"Either of the hypochondriac regions.","pos":""}],"HYPOCHONDRY":[{"def":"Hypochondriasis.","pos":""}],"HYPOCIST":[{"def":"An astringent inspissated juice obtained from the fruit of a plant (Cytinus hypocistis), growing from the roots of the Cistus, a small European shrub.","pos":""}],"HYPOCLEIDIUM":[{"def":"A median process on the furculum, or merrythought, of many birds, where it is connected with the sternum.","pos":""}],"HYPOCORISTIC":[{"def":"Endearing; diminutive; as, the hypocoristic form of a name.","pos":""}],"HYPOCRATERIFORM":[{"def":"hypocraterimorphous; salver-shaped.","pos":""}],"HYPOCRATERIMORPHOUS":[{"def":"Salver-shaped; having a slender tube, expanding suddenly above into a bowl-shaped or spreading border, as in the blossom of the phlox and the lilac.","pos":""}],"HYPOCRISY":[{"def":"The act or practice of a hypocrite; a feigning to be what one is not, or to feel what one does not feel; a dissimulation, or a concealment of one's real character, disposition, or motives; especially, the assuming of false appearance of virtue or religion; a simulation of goodness.","pos":""}],"HYPOCRITE":[{"def":"One who plays a part; especially, one who, for the purpose of winning approbation of favor, puts on a fair outside seeming; one who feigns to be other and better than he is; a false pretender to virtue or piety; one who simulates virtue or piety.","pos":""}],"HYPOCRITIC":[{"def":"See Hypocritical.","pos":""}],"HYPOCRITICAL":[{"def":"Of or pertaining to a hypocrite, or to hypocrisy; as, a hypocriticalperson; a hypocritical look; a hypocritical action.","pos":""}],"HYPOCRYSTALLINE":[{"def":"Partly crystalline; -- said of rock which consists of crystals imbedded in a glassy ground mass.","pos":""}],"HYPOCYCLOID":[{"def":"A curve traced by a point in the circumference of a circle which rolls on the concave side in the fixed circle.","pos":""}],"HYPODACTYLUM":[{"def":"The under side of the toes.","pos":""}],"HYPODERM":[{"def":"Same as Hypoblast.","pos":""}],"HYPODERMA":[{"def":"A layer of tissue beneath the epidermis in plants, and performing the physiological function of strengthening the epidermal tissue.","pos":""},{"def":"An inner cellular layer which lies beneath the chitinous cuticle of arthropods, annelids, and some other invertebrates.","pos":""}],"HYPODERMIC":[{"def":"Of or pertaining to the parts under the skin.","pos":""}],"HYPODERMIS":[{"def":"Same as Hypoblast.","pos":""},{"def":"Same as Hypoderma, 2.","pos":""}],"HYPOGAEIC":[{"def":"Pertaining to, or obtained from, the peanut, or earthnut (Arachis hypogæa).","pos":""}],"HYPOGASTRIC":[{"def":"Of or pertaining to the hypogastrium or the hypogastric region.","pos":""}],"HYPOGASTRIUM":[{"def":"The lower part of the abdomen.","pos":""}],"HYPOGENE":[{"def":"Formed or crystallized at depths the earth's surface; -- said of granite, gneiss, and other rocks, whose crystallization is believed of have taken place beneath a great thickness of overlying rocks.","pos":""}],"HYPOGEOUS":[{"def":"Growing under ground; remaining under ground; ripening its fruit under ground.","pos":""}],"HYPOGEUM":[{"def":"The subterraneous portion of a building, as in amphitheaters, for the service of the games; also, subterranean galleries, as the catacombs.","pos":""}],"HYPOGLOSSAL":[{"def":"Under the tongue; -- applied esp.","pos":""},{"def":"One of the hypoglossal nerves.","pos":""}],"HYPOGNATOUS":[{"def":"Having the maxilla, or lower jaw, longer than the upper, as in the skimmer.","pos":""}],"HYPOGYN":[{"def":"An hypogynous plant.","pos":""}],"HYPOGYNOUS":[{"def":"Inserted below the pistil or pistils; -- said of sepals, petals, and stamens; having the sepals, petals, and stamens inserted below the pistil; -- said of a flower or a plant.","pos":""}],"HYPOHYAL":[{"def":"Pertaining to one or more small elements in the hyoidean arch of fishes, between the caratohyal and urohyal.","pos":""},{"def":"One of the hypohyal bones or cartilages.","pos":""}],"HYPONASTIC":[{"def":"Exhibiting a downward convexity caused by unequal growth.","pos":""}],"HYPONASTY":[{"def":"Downward convexity, or convexity of the inferior surface.","pos":""}],"HYPONITRITE":[{"def":"A salt of hyponitrous acid.","pos":""}],"HYPONITROUS":[{"def":"Containing or derived from nitrogen having a lower valence than in nitrous compounds.","pos":""}],"HYPOPHARYNX":[{"def":"An appendage or fold on the lower side of the pharynx, in certain insects.","pos":""}],"HYPOPHOSPHATE":[{"def":"A salt of hypophosphoric acid.","pos":""}],"HYPOPHOSPHITE":[{"def":"A salt of hypophosphorous acid.","pos":""}],"HYPOPHOSPHORIC":[{"def":"Pertaining to, or derived from, or containing, phosphorus in a lower state of oxidation than in phosphoric compounds; as, hypophosphoric acid.","pos":""}],"HYPOPHOSPHOROUS":[{"def":"Pertaining to, or containing, phosphorus in a lower state of oxidation than in phosphoric compounds; as, hypophosphorous acid.","pos":""}],"HYPOPHYLLOUS":[{"def":"Being or growing on the under side of a leaf, as the fruit dots of ferns.","pos":""}],"HYPOPHYSIAL":[{"def":"Of or pertaining to the hypophysis; pituitary.","pos":""}],"HYPOPHYSIS":[{"def":"See Pituitary body, under Pituitary.","pos":""}],"HYPOPLASTRON":[{"def":"The third lateral plate in the plastron of turtles; -- called also hyposternum.","pos":""}],"HYPOPTILUM":[{"def":"An accessory plume arising from the posterior side of the stem of the contour feathers of many birds; -- called also aftershaft.","pos":""}],"HYPORADIUS":[{"def":"One of the barbs of the hypoptilum, or aftershaft of a feather.","pos":""}],"HYPORHACHIS":[{"def":"The stem of an aftershaft or hypoptilum.","pos":""}],"HYPOSKELETAL":[{"def":"Beneath the endoskeleton; hypaxial; as, the hyposkeletal muscles; -- opposed to episkeletal.","pos":""}],"HYPOSPADIAS":[{"def":"A deformity of the penis, in which the urethra opens upon its under surface.","pos":""}],"HYPOSTASIS":[{"def":"Substance; subsistence; essence; person; personality; -- used by the early theologians to denote any one of the three subdivisions of the Godhead, the Father, Son, and Holy Spirit.","pos":""},{"def":"That which is deposited at the bottom of a fluid; sediment.","pos":""}],"HYPOSTASIZE":[{"def":"To make into a distinct substance; to conceive or treat as an existing being; to hypostatize.","pos":""},{"def":"Depending upon, or due to, deposition or setting; as, hypostatic cognestion, cognestion due to setting of blood by gravitation.","pos":""}],"HYPOSTATICALLY":[{"def":"In a hypostatic manner.","pos":""}],"HYPOSTATIZE":[{"def":"To make into, or regarded as, a separate and distinct substance.","pos":""},{"def":"To attribute actual or personal existence to.","pos":""}],"HYPOSTERNUM":[{"def":"See Hypoplastron.","pos":""},{"def":"The lower lip of trilobites, crustaceans, etc.","pos":""}],"HYPOSTYLE":[{"def":"Resting upon columns; constructed by means of columns; -- especially applied to the great hall at Karnak.","pos":""}],"HYPOSULPHATE":[{"def":"A salt of hyposulphuric acid.","pos":""}],"HYPOSULPHURIC":[{"def":"Pertaining to, or containing, sulphur in a lower state of oxidation than in the sulphuric compounds; as, hyposulphuric acid.","pos":""}],"HYPOSULPHUROUS":[{"def":"Pertaining to, or containing, sulphur, all, or a part, in a low state of oxidation.","pos":""}],"HYPOTARSUS":[{"def":"A process on the posterior side of the tarsometatarsus of many birds; the calcaneal process.","pos":""},{"def":"The side of a right-angled triangle that is opposite to the right angle.","pos":""}],"HYPOTHEC":[{"def":"A landlord's right, independently of stipulation, over the stocking (cattle, implements, etc.","pos":""}],"HYPOTHECA":[{"def":"An obligation by which property of a debtor was made over to his creditor in security of his debt.","pos":""}],"HYPOTHECATE":[{"def":"To subject, as property, to liability for a debt or engagement without delivery of possession or transfer of title; to pledge without delivery of possession; to mortgage, as ships, or other personal property; to make a contract by bottomry.","pos":""}],"HYPOTHECATION":[{"def":"The act or contract by which property is hypothecated; a right which a creditor has in or to the property of his debtor, in virtue of which he may cause it to be sold and the price appropriated in payment of his debt.","pos":""},{"def":"A contract whereby, in consideration of money advanced for the necessities of the ship, the vessel, freight, or cargo is made liable for its repayment, provided the ship arrives in safety.","pos":""}],"HYPOTHECATOR":[{"def":"One who hypothecates or pledges anything as security for the repayment of money borrowed.","pos":""},{"def":"Of or pertaining to the prominent part of the palm of the hand above the base of the little finger, or a corresponding part in the forefoot of an animal; as, the hypothenar eminence.","pos":""}],"HYPOTHENAR":[{"def":"The hypothenar eminence.","pos":""}],"HYPOTHENUSAL":[{"def":"Of or pertaining to hypothenuse.","pos":""}],"HYPOTHENUSE":[{"def":"Same as Hypotenuse.","pos":""}],"HYPOTHESIS":[{"def":"A tentative theory or supposition provisionally adopted to explain certain facts, and to guide in the investigation of others; hence, frequently called a working hypothesis.","pos":""},{"def":"Characterized by, or of the nature of, an hypothesis; conditional; assumed without proof, for the purpose of reasoning and deducing proof, or of accounting for some fact or phenomenon.","pos":""}],"HYPOTHETIST":[{"def":"One who proposes or supports an hypothesis.","pos":""}],"HYPOTRACHELIUM":[{"def":"Same as Gorgerin.","pos":""}],"HYPOTRICHA":[{"def":"A division of ciliated Infusoria in which the cilia cover only the under side of the body.","pos":""}],"HYPOTROCHOID":[{"def":"A curve, traced by a point in the radius, or radius produced, of a circle which rolls upon the concave side of a fixed circle.","pos":""}],"HYPOTYPOSIS":[{"def":"A vivid, picturesque description of scenes or events.","pos":""}],"HYPOXANTHIN":[{"def":"A crystalline, nitrogenous substance, closely related to xanthin and uric acid, widely distributed through the animal body, but especially in muscle tissue; -- called also sarcin, sarkin.","pos":""}],"HYPOZOIC":[{"def":"Anterior in age to the lowest rocks which contain organic remains.","pos":""}]}