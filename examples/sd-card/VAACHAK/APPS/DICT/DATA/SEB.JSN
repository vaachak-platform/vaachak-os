{"SEBACEOUS":[{"def":"Pertaining to, or secreting, fat; composed of fat; having the appearance of fat; as, the sebaceous secretions of some plants, or the sebaceous humor of animals.","pos":""}],"SEBACIC":[{"def":"Of or pertaining to fat; derived from, or resembling, fat; specifically, designating an acid (formerly called also sebic, and pyroleic, acid), obtained by the distillation or saponification of certain oils (as castor oil) as a white crystalline substance.","pos":""}],"SEBAT":[{"def":"The eleventh month of the ancient Hebrew year, approximately corresponding with February.","pos":""}],"SEBATE":[{"def":"A salt of sebacic acid.","pos":""}],"SEBESTEN":[{"def":"The mucilaginous drupaceous fruit of two East Indian trees (Cordia Myxa, and C.","pos":""}],"SEBIFEROUS":[{"def":"Producing vegetable tallow.","pos":""},{"def":"Producing fat; sebaceous; as, the sebiferous, or sebaceous, glands.","pos":""}],"SEBIPAROUS":[{"def":"Same as Sebiferous.","pos":""}],"SEBORRHEA":[{"def":"A morbidly increased discharge of sebaceous matter upon the skin; stearrhea.","pos":""}]}