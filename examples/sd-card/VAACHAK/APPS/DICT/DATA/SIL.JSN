{"SILAGE":[{"def":"Short for Ensilage.","pos":""}],"SILE":[{"def":"To strain, as fresh milk.","pos":""}],"SILENCE":[{"def":"The state of being silent; entire absence of sound or noise; absolute stillness.","pos":""},{"def":"Forbearance from, or absence of, speech; taciturnity; muteness.","pos":""}],"SILENE":[{"def":"A genus of caryophyllaceous plants, usually covered with a viscid secretion by which insects are caught; catchfly.","pos":""}],"SILENT":[{"def":"Not pronounced; having no sound; quiescent; as, e is silent in \"fable.","pos":""}],"SILENTIOUS":[{"def":"Habitually silent; taciturn; reticent.","pos":""}],"SILENTLY":[{"def":"In a silent manner.","pos":""}],"SILENTNESS":[{"def":"State of being silent; silence.","pos":""}],"SILESIA":[{"def":"A kind of linen cloth, originally made in Silesia, a province of Prussia.","pos":""},{"def":"A twilled cotton fabric, used for dress linings.","pos":""}],"SILESIAN":[{"def":"Of or pertaining to Silesia.","pos":""},{"def":"A native or inhabitant of Silesia.","pos":""}],"SILEX":[{"def":"Silica, SiO2 as found in nature, constituting quarz, and most sands and sandstones.","pos":""}],"SILHOUETTE":[{"def":"A representation of the outlines of an object filled in with a black color; a profile portrait in black, such as a shadow appears to be.","pos":""}],"SILICATE":[{"def":"A salt of silicic acid.","pos":"noun"}],"SILICATED":[{"def":"Combined or impregnated with silicon or silica; as, silicated hydrogen; silicated rocks.","pos":""}],"SILICATIZATION":[{"def":"Sil`i*ca*ti*za\"tion, n.","pos":""}],"SILICEA":[{"def":"Same as Silicoidea.","pos":""}],"SILICEOUS":[{"def":"Of or pertaining to silica; containing silica, or partaking of its nature.","pos":""}],"SILICIC":[{"def":"Pertaining to, derived from, or resembling, silica; specifically, designating compounds of silicon; as, silicic acid.","pos":""}],"SILICICALCAREOUS":[{"def":"Consisting of silica and calcareous matter.","pos":""}],"SILICIDE":[{"def":"A binary compound of silicon, or one regarded as binary.","pos":""}],"SILICIFEROUS":[{"def":"Producing silica; united with silica.","pos":""}],"SILICIFICATION":[{"def":"Thae act or process of combining or impregnating with silicon or silica; the state of being so combined or impregnated; as, the silicification of wood.","pos":""}],"SILICIFIED":[{"def":"Combined or impregnated with silicon or silica, especially the latter; as, silicified wood.","pos":""}],"SILICIFY":[{"def":"To convert into, or to impregnate with, silica, or with the compounds of silicon.","pos":""}],"SILICIOIDEA":[{"def":"Same as Silicoidea.","pos":""}],"SILICISPONGIAE":[{"def":"Same as Silicoidea.","pos":""}],"SILICIURETED":[{"def":"Combined or impregnated with silicon.","pos":""}],"SILICLE":[{"def":"A seed vessel resembling a silique, but about as broad as it is long.","pos":""}],"SILICO-":[{"def":"A combining form (also used adjectively) denoting the presence of silicon or its compounds; as, silicobenzoic, silicofluoride, etc.","pos":""}],"SILICOFLUORIC":[{"def":"Containing, or composed of, silicon and fluorine; especially, denoting the compounds called silicofluorides.","pos":""}],"SILICOFLUORIDE":[{"def":"A fluosilicate; a salt of silicofluoric acid.","pos":""}],"SILICOIDEA":[{"def":"An extensive order of Porifera, which includes those that have the skeleton composed mainly of siliceous fibers or spicules.","pos":""}],"SILICON":[{"def":"A nonmetalic element analogous to carbon.","pos":""}],"SILICOTUNGSTIC":[{"def":"Of, pertaining to, or designating, any one of a series of double acids of silicon and tungsten, known in the free state, and also in their salts (called silicotungstates).","pos":""}],"SILICULOSE":[{"def":"Bearing silicles; pertaining to, or resembling, silicles.","pos":""}],"SILIGINOSE":[{"def":"Made of fine wheat.","pos":""}],"SILING":[{"def":"from Sile to strain.","pos":""}],"SILIQUA":[{"def":"Same as Silique.","pos":""}],"SILIQUE":[{"def":"An oblong or elongated seed vessel, consisting of two valves with a dissepiment between, and opening by sutures at either margin.","pos":""}],"SILIQUIFORM":[{"def":"Having the form of a silique.","pos":""}],"SILIQUOSA":[{"def":"A Linnæan order of plants including those which bear siliques.","pos":""},{"def":"Bearing siliques; as, siliquose plants; pertaining to, or resembling, siliques; as, siliquose capsules.","pos":""}],"SILK":[{"def":"The fine, soft thread produced by various species of caterpillars in forming the cocoons within which the worm is inclosed during the pupa state, especially that produced by the larvæ of Bombyx mori.","pos":""},{"def":"Hence, thread spun, or cloth woven, from the above-named material.","pos":""}],"SILK-STOCKING":[{"def":"Wearing silk stockings (which among men were formerly worn chiefly by the luxurious or aristocratic); hence, elegantly dressed; aristocratic; luxurious; -- chiefly applied to men, often by way of reproach.","pos":""}],"SILKEN":[{"def":"Of or pertaining to silk; made of, or resembling, silk; as, silken cloth; a silken veil.","pos":""}],"SILKINESS":[{"def":"The quality or state of being silky or silken; softness and smoothness.","pos":""}],"SILKMAN":[{"def":"A dealer in silks; a silk mercer.","pos":""}],"SILKWEED":[{"def":"Any plant of the genera Asclepias and Acerates whose seed vessels contain a long, silky down; milkweed.","pos":""}],"SILKWORM":[{"def":"The larva of any one of numerous species of bombycid moths, which spins a large amount of strong silk in constructing its cocoon before changing to a pupa.","pos":""}],"SILKY":[{"def":"Of or pertaining to silk; made of, or resembling, silk; silken; silklike; as, a silky luster.","pos":""},{"def":"Hence, soft and smooth; as, silky wine.","pos":""}],"SILL":[{"def":"The basis or foundation of a thing; especially, a horizontal piece, as a timber, which forms the lower member of a frame, or supports a structure; as, the sills of a house, of a bridge, of a loom, and the like.","pos":""}],"SILLABUB":[{"def":"A dish made by mixing wine or cider with milk, and thus forming a soft curd; also, sweetened cream, flavored with wine and beaten to a stiff froth.","pos":""}],"SILLILY":[{"def":"In a silly manner; foolishly.","pos":""}],"SILLIMANITE":[{"def":"Same as Fibrolite.","pos":""}],"SILLINESS":[{"def":"The quality or state of being silly.","pos":""}],"SILLOCK":[{"def":"The pollock, or coalfish.","pos":""}],"SILLON":[{"def":"A work raised in the middle of a wide ditch, to defend it.","pos":""}],"SILLY":[{"def":"Happy; fortunate; blessed.","pos":""},{"def":"Harmless; innocent; inoffensive.","pos":""}],"SILO":[{"def":"A pit or vat for packing away green fodder for winter use so as to exclude air and outside moisture.","pos":""}],"SILT":[{"def":"Mud or fine earth deposited from running or standing water.","pos":""}],"SILTY":[{"def":"Full of silt; resembling silt.","pos":""}],"SILUNDUM":[{"def":"A form of silicon carbide, produced in the electric furnace, possessing great hardness, and high electrical resistance, and not subject to oxidation below 2880º F.","pos":""}],"SILURE":[{"def":"A fish of the genus Silurus, as the sheatfish; a siluroid.","pos":""}],"SILURIAN":[{"def":"Of or pertaining to the country of the ancient Silures; -- a term applied to the earliest of the Paleozoic eras, and also to the strata of the era, because most plainly developed in that country.","pos":""}],"SILURIDAN":[{"def":"Any fish of the family Silurid or of the order Siluroidei.","pos":""}],"SILUROID":[{"def":"Belonging to the Siluroidei, or Nematognathi, an order of fishes including numerous species, among which are the American catfishes and numerous allied fresh-water species of the Old World, as the sheatfish (Silurus glanis) of Europe.","pos":""},{"def":"A siluroid fish.","pos":""}],"SILUROIDEI":[{"def":"An order of fishes, the Nematognathi.","pos":""}],"SILURUS":[{"def":"A genus of large malacopterygious fishes of the order Siluroidei.","pos":""}],"SILVAN":[{"def":"Of or pertaining to woods; composed of woods or groves; woody.","pos":""}],"SILVANITE":[{"def":"Vast woodland plains of South America.","pos":""}],"SILVATE":[{"def":"Same as Sylvate.","pos":""}],"SILVER":[{"def":"A soft white metallic element, sonorous, ductile, very malleable, and capable of a high degree of polish.","pos":""}],"SILVER CERTIFICATE":[{"def":"A certificate issued by a government that there has been deposited with it silver to a specified amount, payable to the bearer on demand.","pos":""}],"SILVER STATE":[{"def":"Nevada; -- a nickname alluding to its silver mines.","pos":""}],"SILVER-GRAY":[{"def":"Having a gray color with a silvery luster; as, silver-gray hair.","pos":""}],"SILVERBERRY":[{"def":"A tree or shrub (Elæagnus argentea) with silvery foliage and fruit.","pos":""}],"SILVERBILL":[{"def":"An Old World finch of the genus Minia, as the M.","pos":""}],"SILVERBOOM":[{"def":"See Leucadendron.","pos":""}],"SILVERFIN":[{"def":"A small North American fresh-water cyprinoid fish (Notropis Whipplei).","pos":""}],"SILVERINESS":[{"def":"The state of being silvery.","pos":""}],"SILVERING":[{"def":"The art or process of covering metals, wood, paper, glass, etc.","pos":""}],"SILVERITE":[{"def":"One who favors the use or establishment of silver as a monetary standard; -- so called by those who favor the gold standard.","pos":""}],"SILVERIZE":[{"def":"To cover with silver.","pos":""}],"SILVERLESS":[{"def":"Having no silcver; hence, without money; impecunious.","pos":""}],"SILVERLING":[{"def":"A small silver coin.","pos":""}],"SILVERLY":[{"def":"Like silver in appearance or in sound.","pos":""}],"SILVERN":[{"def":"Speech is silvern; silence is golden.","pos":""}],"SILVERSIDES":[{"def":"Any one of several species of small fishes of the family Atherinidæ, having a silvery stripe along each side of the body.","pos":""}],"SILVERSMITH":[{"def":"One whose occupation is to manufacture utensils, ornaments, etc.","pos":""}],"SILVERSPOT":[{"def":"Any one of numerous species of butterflies of the genus Argynnis and allied genera, having silvery spots on the under side of the wings.","pos":""}],"SILVERWARE":[{"def":"Dishes, vases, ornaments, and utensils of various sorts, made of silver.","pos":""}],"SILVERWEED":[{"def":"A perennial rosaceous herb (Potentilla Anserina) having the leaves silvery white beneath.","pos":""}],"SILVERY":[{"def":"Resembling, or having the luster of, silver; grayish white and lustrous; of a mild luster; bright.","pos":""},{"def":"Besprinkled or covered with silver.","pos":""}],"SILVICS":[{"def":"The science treating of the life of trees in the forest.","pos":""},{"def":"Habit or behavior of a forest tree.","pos":""}],"SILVICULTURE":[{"def":"See Sylviculture.","pos":""}]}