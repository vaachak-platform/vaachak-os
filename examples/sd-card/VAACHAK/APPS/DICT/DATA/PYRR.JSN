{"PYRRHIC":[{"def":"Of or pertaining to a pyrrhic, or to pyrrhics; containing pyrrhic; as, a pyrrhic verse.","pos":""}],"PYRRHICIST":[{"def":"One two danced the pyrrhic.","pos":""},{"def":"Of or pertaining to pyrrhonism.","pos":""}],"PYRRHONISM":[{"def":"Skepticism; universal doubt.","pos":""}],"PYRRHONIST":[{"def":"A follower of Pyrrho; a skeptic.","pos":""},{"def":"A bronze-colored mineral, of metallic luster.","pos":""}],"PYRROL":[{"def":"A nitrogenous base found in coal tar, bone oil, and other distillates of organic substances, and also produced synthetically as a colorless liquid, C4H5N, having on odor like that of chloroform.","pos":""}],"PYRROLINE":[{"def":"A nitrogenous base, C4H7N, obtained as a colorless liquid by the reduction of pyrrol.","pos":""}]}