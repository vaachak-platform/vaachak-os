{"CLAP":[{"def":"To strike; to slap; to strike, or strike together, with a quick motion, so, as to make a sharp noise; as, to clap one's hands; a clapping of wings.","pos":"verb"},{"def":"To thrust, drive, put, or close, in a hasty or abrupt manner; -- often followed by to, into, on, or upon.","pos":"verb"}],"CLAPBOARD":[{"def":"A narrow board, thicker at one edge than at the other; -- used for weatherboarding the outside of houses.","pos":""},{"def":"A stave for a cask.","pos":""}],"CLAPE":[{"def":"A bird; the flicker.","pos":""}],"CLAPPER":[{"def":"A person who claps.","pos":""},{"def":"That which strikes or claps, as the tongue of a bell, or the piece of wood that strikes a mill hopper, etc.","pos":""}],"CLAPPERCLAW":[{"def":"To fight and scratch.","pos":""},{"def":"To abuse with the tongue; to revile; to scold.","pos":""}],"CLAPS":[{"def":"Variant of Clasp [Obs.","pos":""}],"CLAPTRAP":[{"def":"A contrivance for clapping in theaters.","pos":""},{"def":"A trick or device to gain applause; humbug.","pos":""}]}