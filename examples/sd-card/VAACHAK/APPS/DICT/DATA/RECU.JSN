{"RECUBATION":[{"def":"Rec`u*ba\"tion (rk`*b\"shn), n.","pos":""}],"RECULE":[{"def":"RECULE; RECULEMENT Re*cule\" (r*kl\"), Re*cule\"ment (-ment), n.","pos":""}],"RECUMB":[{"def":"To lean; to recline; to repose.","pos":""}],"RECUMBENCE":[{"def":"The act of leaning, resting, or reclining; the state of being recumbent.","pos":""}],"RECUMBENCY":[{"def":"Re*cum\"ben*cy (-ben*s), n.","pos":""}],"RECUMBENT":[{"def":"Leaning; reclining; lying; as, the recumbent posture of the Romans at their meals.","pos":""}],"RECUPERABLE":[{"def":"Re*cu\"per*a*ble (r*k\"pr**b'l), a.","pos":""}],"RECUPERATE":[{"def":"To recover health; to regain strength; to convalesce.","pos":""}],"RECUPERATION":[{"def":"Recovery, as of anything lost, especially of the health or strength.","pos":""},{"def":"Of or pertaining to recuperation; tending to recovery.","pos":""}],"RECUPERATOR":[{"def":"Same as Regenerator.","pos":""}],"RECUR":[{"def":"To come back; to return again or repeatedly; to come again to mind.","pos":""},{"def":"To occur at a stated interval, or according to some regular rule; as, the fever will recur to-night.","pos":""}],"RECURE":[{"def":"To arrive at; to reach; to attain.","pos":""},{"def":"To recover; to regain; to repossess.","pos":""}],"RECURELESS":[{"def":"Incapable of cure.","pos":""},{"def":"The act of recurring, or state of being recurrent; return; resort; recourse.","pos":""}],"RECURRENT":[{"def":"Running back toward its origin; as, a recurrent nerve or artery.","pos":""}],"RECURSANT":[{"def":"Displayed with the back toward the spectator; -- said especially of an eagle.","pos":""}],"RECURSION":[{"def":"The act of recurring; return.","pos":""}],"RECURVATE":[{"def":"Re*cur\"vate (r*kr\"vt), a.","pos":""}],"RECURVATION":[{"def":"The act of recurving, or the state of being recurved; a bending or flexure backward.","pos":""}],"RECURVE":[{"def":"To curve in an opposite or unusual direction; to bend back or down.","pos":""}],"RECURVED":[{"def":"Curved in an opposite or uncommon direction; bent back; as, a bird with a recurved bill; flowers with recurved petals.","pos":""}],"RECURVIROSTER":[{"def":"A bird whose beak bends upward, as the avocet.","pos":""}],"RECURVIROSTRAL":[{"def":"Having the beak bent upwards.","pos":""}],"RECURVITY":[{"def":"Re*cur\"vi*ty (r*kr\"v*t), n.","pos":""}],"RECUSANCY":[{"def":"The state of being recusant; nonconformity.","pos":""}],"RECUSANT":[{"def":"Obstinate in refusal; specifically, in English history, refusing to acknowledge the supremacy of the king in the churc, or to conform to the established rites of the church; as, a recusant lord.","pos":""}],"RECUSATION":[{"def":"The act of refusing a judge or challenging that he shall not try the cause, on account of his supposed partiality.","pos":""}],"RECUSATIVE":[{"def":"Refusing; denying; negative.","pos":""}],"RECUSE":[{"def":"To refuse or reject, as a judge; to challenge that the judge shall not try the cause.","pos":""}],"RECUSSION":[{"def":"The act of beating or striking back.","pos":""}]}