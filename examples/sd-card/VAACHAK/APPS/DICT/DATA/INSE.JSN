{"INSEAM":[{"def":"To impress or mark with a seam or cicatrix.","pos":""}],"INSEARCH":[{"def":"To make search after; to investigate or examine; to ensearch.","pos":""}],"INSECABLE":[{"def":"Incapable of being divided by cutting; indivisible.","pos":""}],"INSECT":[{"def":"One of the Insecta; esp.","pos":""},{"def":"Any air-breathing arthropod, as a spider or scorpion.","pos":""}],"INSECTA":[{"def":"One of the classes of Arthropoda, including those that have one pair of antennæ, three pairs of mouth organs, and breathe air by means of tracheæ, opening by spiracles along the sides of the body.","pos":""},{"def":"In a more restricted sense, the Hexapoda alone.","pos":""}],"INSECTARY":[{"def":"A place for keeping living insects.","pos":""}],"INSECTATION":[{"def":"The act of pursuing; pursuit; harassment; persecution.","pos":""}],"INSECTATOR":[{"def":"A pursuer; a persecutor; a censorious critic.","pos":""}],"INSECTED":[{"def":"Pertaining to, having the nature of, or resembling, an insect.","pos":""}],"INSECTICIDE":[{"def":"An agent or preparation for destroying insects; an insect powder.","pos":""}],"INSECTILE":[{"def":"Pertaining to, or having the nature of, insects.","pos":""}],"INSECTION":[{"def":"A cutting in; incisure; incision.","pos":""}],"INSECTIVORA":[{"def":"An order of mammals which feed principally upon insects.","pos":""},{"def":"A division of the Cheiroptera, including the common or insect- eating bats.","pos":""}],"INSECTIVORE":[{"def":"One of the Insectivora.","pos":""}],"INSECTIVOROUS":[{"def":"Feeding or subsisting on insects; carnivorous.","pos":""},{"def":"plants which have some special adaptation for catching and digesting insects, as the sundew, Venus's flytrap, Sarracenia, etc.","pos":""}],"INSECTOLOGER":[{"def":"An entomologist.","pos":""}],"INSECURE":[{"def":"Not secure; not confident of safety or permanence; distrustful; suspicious; apprehensive of danger or loss.","pos":""},{"def":"Not effectually guarded, protected, or sustained; unsafe; unstable; exposed to danger or loss.","pos":""}],"INSECURELY":[{"def":"In an insecure manner.","pos":""}],"INSECURITY":[{"def":"The condition or quality of being insecure; want of safety; danger; hazard; as, the insecurity of a building liable to fire; insecurity of a debt.","pos":""},{"def":"The state of feeling insecure; uncertainty; want of confidence.","pos":""}],"INSECUTION":[{"def":"A following after; close pursuit.","pos":""}],"INSEMINATE":[{"def":"To sow; to impregnate.","pos":""}],"INSENSATE":[{"def":"Wanting sensibility; destitute of sense; stupid; foolish.","pos":""}],"INSENSE":[{"def":"To make to understand; to instruct.","pos":""}],"INSENSIBILITY":[{"def":"The state or quality of being insensible; want of sensibility; torpor; unconsciousness; as, the insensibility produced by a fall, or by opiates.","pos":""},{"def":"Want of tenderness or susceptibility of emotion or passion; dullness; stupidity.","pos":""}],"INSENSIBLE":[{"def":"Destitute of the power of feeling or perceiving; wanting bodily sensibility.","pos":""},{"def":"Not susceptible of emotion or passion; void of feeling; apathetic; unconcerned; indifferent; as, insensible to danger, fear, love, etc.","pos":""}],"INSENSIBLENESS":[{"def":"In*sen\"si*ble*ness, n.","pos":""}],"INSENSIBLY":[{"def":"In a manner not to be felt or perceived; imperceptibly; gradually.","pos":""}],"INSENSITIVE":[{"def":"Not sensitive; wanting sensation, or wanting acute sensibility.","pos":""}],"INSENSUOUS":[{"def":"Not sensuous; not pertaining to, affecting, or addressing, the senses.","pos":""}],"INSENTIENT":[{"def":"Not sentient; not having perception, or the power of perception.","pos":""}],"INSEPARABILITY":[{"def":"The quality or state of being inseparable; inseparableness.","pos":""}],"INSEPARABLE":[{"def":"Invariably attached to some word, stem, or root; as, the inseparable particle un-.","pos":""}],"INSEPARABLENESS":[{"def":"The quality or state of being inseparable; inseparability.","pos":""}],"INSEPARABLY":[{"def":"In an inseparable manner or condition; so as not to be separable.","pos":""}],"INSEPARATE":[{"def":"Not separate; together; united.","pos":""}],"INSEPARATELY":[{"def":"In*sep\"a*rate*ly, adv.","pos":""}],"INSERT":[{"def":"To set within something; to put or thrust in; to introduce; to cause to enter, or be included, or contained; as, to insert a scion in a stock; to insert a letter, word, or passage in a composition; to insert an advertisement in a newspaper.","pos":""}],"INSERTED":[{"def":"Situated upon, attached to, or growing out of, some part; -- said especially of the parts of the flower; as, the calyx, corolla, and stamens of many flowers are inserted upon the receptacle.","pos":""}],"INSERTING":[{"def":"Something inserted or set in, as lace, etc.","pos":""}],"INSERTION":[{"def":"The point or part by which a muscle or tendon is attached to the part to be moved; -- in contradistinction to its origin.","pos":""}],"INSERVE":[{"def":"To be of use to an end; to serve.","pos":""}],"INSERVIENT":[{"def":"Conducive; instrumental.","pos":""}],"INSESSION":[{"def":"The act of sitting, as in a tub or bath.","pos":""},{"def":"That in which one sits, as a bathing tub.","pos":""}],"INSESSOR":[{"def":"One of the Insessores.","pos":""}],"INSESSORES":[{"def":"An order of birds, formerly established to include the perching birds, but now generally regarded as an artificial group.","pos":""}],"INSESSORIAL":[{"def":"Pertaining to, or having the character of, perching birds.","pos":""},{"def":"Belonging or pertaining to the Insessores.","pos":""}],"INSET":[{"def":"One or more separate leaves inserted in a volume before binding; as: (a) A portion of the printed sheet in certain sizes of books which is cut off before folding, and set into the middle of the folded sheet to complete the succession of paging; -- also called offcut.","pos":""}],"INSEVERABLE":[{"def":"Incapable of being severed; indivisible; inseparable.","pos":""}]}