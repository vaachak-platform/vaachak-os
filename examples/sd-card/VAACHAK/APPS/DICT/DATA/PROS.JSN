{"PROSAICISM":[{"def":"The quality or state of being prosaic; a prosaic manner or style.","pos":""}],"PROSAISM":[{"def":"That which is in the form of prose writing; a prosaic manner.","pos":""}],"PROSAIST":[{"def":"A writer of prose; an unpoetical writer.","pos":""}],"PROSAL":[{"def":"Of or pertaining to prose; prosaic.","pos":""}],"PROSCENIUM":[{"def":"The part where the actors performed; the stage.","pos":""},{"def":"The part of the stage in front of the curtain; sometimes, the curtain and its framework.","pos":""}],"PROSCOLEX":[{"def":"An early larval form of a trematode worm; a redia.","pos":""}],"PROSCRIBE":[{"def":"To doom to destruction; to put out of the protection of law; to outlaw; to exile; as, Sylla and Marius proscribed each other's adherents.","pos":""},{"def":"To denounce and condemn; to interdict; to prohibit; as, the Puritans proscribed theaters.","pos":""}],"PROSCRIBER":[{"def":"One who, or that which, proscribes, denounces, or prohibits.","pos":""}],"PROSCRIPT":[{"def":"A proscription; a prohibition; an interdict.","pos":""},{"def":"One who is proscribed.","pos":""}],"PROSCRIPTION":[{"def":"The act of proscribing; a dooming to death or exile; outlawry; specifically, among the ancient Romans, the public offer of a reward for the head of a political enemy; as, under the triumvirate, many of the best Roman citizens fell by proscription.","pos":""},{"def":"The state of being proscribed; denunciation; interdiction; prohibition.","pos":""}],"PROSCRIPTIONIST":[{"def":"One who proscribes.","pos":""}],"PROSCRIPTIVE":[{"def":"Of or pertaining to proscription; consisting in, or of the nature of, proscription; proscribing.","pos":""}],"PROSE":[{"def":"A hymn with no regular meter, sometimes introduced into the Mass.","pos":""}],"PROSECTOR":[{"def":"One who makes dissections for anatomical illustration; usually, the assistant of a professional anatomist.","pos":""}],"PROSECUTABLE":[{"def":"Capable of being prosecuted; liable to prosecution.","pos":""}],"PROSECUTE":[{"def":"To pursue with the intention of punishing; to accuse of some crime or breach of law, or to pursue for redress or punishment, before a legal tribunal; to proceed against judicially; as, to prosecute a man for trespass, or for a riot.","pos":""}],"PROSECUTION":[{"def":"The act or process of prosecuting, or of endeavoring to gain or accomplish something; pursuit by efforts of body or mind; as, the prosecution of a scheme, plan, design, or undertaking; the prosecution of war.","pos":""}],"PROSECUTOR":[{"def":"The person who institutes and carries on a criminal suit against another in the name of the government.","pos":""}],"PROSECUTRIX":[{"def":"A female prosecutor.","pos":""}],"PROSELYTE":[{"def":"A new convert especially a convert to some religion or religious sect, or to some particular opinion, system, or party; thus, a Gentile converted to Judaism, or a pagan converted to Christianity, is a proselyte.","pos":""}],"PROSELYTISM":[{"def":"The act or practice of proselyting; the making of converts to a religion or a religious sect, or to any opinion, system, or party.","pos":""},{"def":"Conversion to a religion, system, or party.","pos":""}],"PROSELYTIZE":[{"def":"To convert to some religion, system, opinion, or the like; to bring, or cause to come, over; to proselyte.","pos":""}],"PROSELYTIZER":[{"def":"One who proselytes.","pos":""}],"PROSEMAN":[{"def":"A writer of prose.","pos":""}],"PROSEMINARY":[{"def":"A seminary which prepares pupils for a higher institution.","pos":""}],"PROSEMINATION":[{"def":"Propagation by seed.","pos":""}],"PROSENCEPHALIC":[{"def":"Of or pertaining to the prosencephalon.","pos":""}],"PROSENCEPHALON":[{"def":"Pros`en*ceph\"a*lon, n.","pos":""}],"PROSENCHYMA":[{"def":"A general term applied to the tissues formed of elongated cells, especially those with pointed or oblique extremities, as the principal cells of ordinary wood.","pos":""}],"PROSER":[{"def":"A writer of prose.","pos":""},{"def":"One who talks or writes tediously.","pos":""}],"PROSILIENCY":[{"def":"The act of leaping forth or forward; projection.","pos":""}],"PROSILY":[{"def":"In a prosy manner.","pos":""}],"PROSIMETRICAL":[{"def":"Consisting both of prose and verse.","pos":""}],"PROSIMIAE":[{"def":"Same as Lemuroidea.","pos":""}],"PROSINESS":[{"def":"The quality or state of being prosy; tediousness; tiresomeness.","pos":""}],"PROSING":[{"def":"Writing prose; speaking or writing in a tedious or prosy manner.","pos":""}],"PROSLAVERY":[{"def":"Favoring slavery.","pos":""},{"def":"Advocacy of slavery.","pos":""}],"PROSOBRANCH":[{"def":"One of the Prosobranchiata.","pos":""}],"PROSOBRANCHIATA":[{"def":"The highest division, or subclass, of gastropod mollusks, including those that have the gills situated anteriorly, or forward of the heart, and the sexes separate.","pos":""}],"PROSOCOELE":[{"def":"The entire cavity of the prosencephalon.","pos":""}],"PROSOCOELIA":[{"def":"Same as Prosocoele.","pos":""}],"PROSODIACALLY":[{"def":"Pros`o*di\"a*cal*ly, adv.","pos":""}],"PROSODICAL":[{"def":"Of or pertaining to prosody; according to the rules of prosody.","pos":""}],"PROSODIST":[{"def":"One skilled in prosody.","pos":""}],"PROSODY":[{"def":"That part of grammar which treats of the quantity of syllables, of accent, and of the laws of versification or metrical composition.","pos":""}],"PROSOMA":[{"def":"The anterior of the body of an animal, as of a cephalopod; the thorax of an arthropod.","pos":""}],"PROSOPALGIA":[{"def":"Facial neuralgia.","pos":""}],"PROSOPOCEPHALA":[{"def":"Same as Scaphopoda.","pos":""}],"PROSOPOLEPSY":[{"def":"Respect of persons; especially, a premature opinion or prejudice against a person, formed from his external appearance.","pos":""}],"PROSOPOPOEIA":[{"def":"A figure by which things are represented as persons, or by which things inanimate are spoken of as animated beings; also, a figure by which an absent person is introduced as speaking, or a deceased person is represented as alive and present.","pos":""}],"PROSOPULMONATA":[{"def":"A division of pulmonate mollusks having the breathing organ situated on the neck, as in the common snail.","pos":""}],"PROSPECT":[{"def":"That which is embraced by eye in vision; the region which the eye overlooks at one time; view; scene; outlook.","pos":""},{"def":"Especially, a picturesque or widely extended view; a landscape; hence, a sketch of a landscape.","pos":""}],"PROSPECTION":[{"def":"The act of looking forward, or of providing for future wants; foresight.","pos":""}],"PROSPECTIVE":[{"def":"Of or pertaining to a prospect; furnishing a prospect; perspective.","pos":""},{"def":"Looking forward in time; acting with foresight; -- opposed to retrospective.","pos":""}],"PROSPECTIVELY":[{"def":"In a prospective manner.","pos":""}],"PROSPECTIVENESS":[{"def":"Quality of being prospective.","pos":""}],"PROSPECTLESS":[{"def":"Having no prospect.","pos":""}],"PROSPECTOR":[{"def":"One who prospects; especially, one who explores a region for minerals and precious metals.","pos":""}],"PROSPECTUS":[{"def":"A summary, plan, or scheme of something proposed, affording a prospect of its nature; especially, an exposition of the scheme of an unpublished literary work.","pos":""}],"PROSPER":[{"def":"To favor; to render successful.","pos":""}],"PROSPERITY":[{"def":"The state of being prosperous; advance or gain in anything good or desirable; successful progress in any business or enterprise; attainment of the object desired; good fortune; success; as, commercial prosperity; national prosperity.","pos":""}],"PROSPEROUS":[{"def":"Tending to prosperity; favoring; favorable; helpful.","pos":""},{"def":"Being prospered; advancing in the pursuit of anything desirable; making gain, or increase; thriving; successful; as, a prosperous voyage; a prosperous undertaking; a prosperous man or nation.","pos":""}],"PROSPHYSIS":[{"def":"A growing together of parts; specifically, a morbid adhesion of the eyelids to each other or to the eyeball.","pos":""}],"PROSPICIENCE":[{"def":"The act of looking forward.","pos":""}],"PROSTATE":[{"def":"Standing before; -- applied to a gland which is found in the males of most mammals, and is situated at the neck of the bladder where this joins the urethra.","pos":""},{"def":"The prostate gland.","pos":""}],"PROSTATIC":[{"def":"Of or pertaining to the prostate gland.","pos":""}],"PROSTATITIS":[{"def":"Inflammation of the prostate.","pos":""}],"PROSTERNATION":[{"def":"Dejection; depression.","pos":""}],"PROSTERNUM":[{"def":"The ventral plate of the prothorax of an insect.","pos":""}],"PROSTHESIS":[{"def":"The addition to the human body of some artificial part, to replace one that is wanting, as a log or an eye; -- called also prothesis.","pos":""},{"def":"The prefixing of one or more letters to the beginning of a word, as in beloved.","pos":""}],"PROSTHETIC":[{"def":"Of or pertaining to prosthesis; prefixed, as a letter or letters to a word.","pos":""}],"PROSTIBULOUS":[{"def":"Of or pertaining to prostitutes or prostitution; meretricious.","pos":""}],"PROSTITUTE":[{"def":"To offer, as a woman, to a lewd use; to give up to lewdness for hire.","pos":""},{"def":"To devote to base or unworthy purposes; to give up to low or indiscriminate use; as, to prostitute talents; to prostitute official powers.","pos":""}],"PROSTITUTION":[{"def":"The act or practice of prostituting or offering the body to an indiscriminate intercourse with men; common lewdness of a woman.","pos":""},{"def":"The act of setting one's self to sale, or of devoting to infamous purposes what is in one's power; as, the prostitution of abilities; the prostitution of the press.","pos":""}],"PROSTITUTOR":[{"def":"One who prostitutes; one who submits himself, of or offers another, to vile purposes.","pos":""}],"PROSTOMIUM":[{"def":"That portion of the head of an annelid situated in front of the mouth.","pos":""}],"PROSTRATE":[{"def":"Trailing on the ground; procumbent.","pos":""}],"PROSTRATION":[{"def":"A latent, not an exhausted, state of the vital energies; great oppression of natural strength and vigor.","pos":""}],"PROSTYLE":[{"def":"Having columns in front.","pos":""},{"def":"A prostyle portico or building.","pos":""}],"PROSY":[{"def":"Of or pertaining to prose; like prose.","pos":""},{"def":"Dull and tedious in discourse or writing; prosaic.","pos":""}],"PROSYLOGISM":[{"def":"A syllogism preliminary or logically essential to another syllogism; the conclusion of such a syllogism, which becomes a premise of the following syllogism.","pos":""}]}