{"HAM":[{"def":"The region back of the knee joint; the popliteal space; the hock.","pos":""}],"HAMADRYAD":[{"def":"A tree nymph whose life ended with that of the particular tree, usually an oak, which had been her abode.","pos":""},{"def":"A large venomous East Indian snake (Orhiophagus bungarus), allied to the cobras.","pos":""}],"HAMADRYAS":[{"def":"The sacred baboon of Egypt (Cynocephalus Hamadryas).","pos":""}],"HAMAL":[{"def":"In Turkey and other Oriental countries, a porter or burden bearer; specif.","pos":""}],"HAMAMELIS":[{"def":"A genus of plants which includes the witch-hazel (Hamamelis Virginica), a preparation of which is used medicinally.","pos":""}],"HAMATE":[{"def":"Hooked; bent at the end into a hook; hamous.","pos":""}],"HAMATED":[{"def":"Hooked, or set with hooks; hamate.","pos":""}],"HAMBURG":[{"def":"A commercial city of Germany, near the mouth of the Elbe.","pos":""}],"HAME":[{"def":"One of the two curved pieces of wood or metal, in the harness of a draught horse, to which the traces are fastened.","pos":""}],"HAMEL":[{"def":"The felonious seeking and invasion of a person in his dwelling house.","pos":""}],"HAMFATTER":[{"def":"A low-grade actor or performer.","pos":""}],"HAMILTON PERIOD":[{"def":"A subdivision of the Devonian system of America; -- so named from Hamilton, Madison Co.","pos":""}],"HAMINURA":[{"def":"A large edible river fish (Erythrinus macrodon) of Guiana.","pos":""}],"HAMITE":[{"def":"A fossil cephalopod of the genus Hamites, related to the ammonites, but having the last whorl bent into a hooklike form.","pos":"noun"}],"HAMITIC":[{"def":"Pertaining to Ham or his descendants.","pos":""}],"HAMLET":[{"def":"A small village; a little cluster of houses in the country.","pos":""}],"HAMLETED":[{"def":"Confined to a hamlet.","pos":""}],"HAMMER":[{"def":"That part of a gunlock which strikes the percussion cap, or firing pin; the cock; formerly, however, a piece of steel covering the pan of a flintlock musket and struck by the flint of the cock to ignite the priming.","pos":""}],"HAMMER BREAK":[{"def":"An interrupter in which contact is broken by the movement of an automatically vibrating hammer between a contact piece and an electromagnet, or of a rapidly moving piece mechanically driven.","pos":""}],"HAMMER LOCK":[{"def":"A hold in which an arm of one contestant is held twisted and bent behind his back by his opponent.","pos":""}],"HAMMER-BEAM":[{"def":"A member of one description of roof truss, called hammer-beam truss, which is so framed as not to have a tiebeam at the top of the wall.","pos":""}],"HAMMER-DRESSED":[{"def":"Having the surface roughly shaped or faced with the stonecutter's hammer; -- said of building stone.","pos":""}],"HAMMER-HARDEN":[{"def":"To harden, as a metal, by hammering it in the cold state.","pos":""}],"HAMMER-LESS":[{"def":"Without a visible hammer; -- said of a gun having a cock or striker concealed from sight, and out of the way of an accidental touch.","pos":""}],"HAMMERABLE":[{"def":"Capable of being formed or shaped by a hammer.","pos":""}],"HAMMERCLOTH":[{"def":"The cloth which covers a coach box.","pos":""}],"HAMMERER":[{"def":"One who works with a hammer.","pos":""}],"HAMMERHEAD":[{"def":"A shark of the genus Sphyrna or Zygæna, having the eyes set on projections from the sides of the head, which gives it a hammer shape.","pos":""},{"def":"A fresh-water fish; the stone-roller.","pos":""}],"HAMMERKOP":[{"def":"A bird of the Heron family; the umber.","pos":""}],"HAMMERMAN":[{"def":"A hammerer; a forgeman.","pos":""}],"HAMMOCHRYSOS":[{"def":"A stone with spangles of gold color in it.","pos":""}],"HAMMOCK":[{"def":"Having the end hooked or curved.","pos":""}],"HAMPER":[{"def":"A large basket, usually with a cover, used for the packing and carrying of articles; as, a hamper of wine; a clothes hamper; an oyster hamper, which contains two bushels.","pos":""}],"HAMSHACKLE":[{"def":"To fasten (an animal) by a rope binding the head to one of the fore legs; as, to hamshackle a horse or cow; hence, to bind or restrain; to curb.","pos":""}],"HAMSTER":[{"def":"A small European rodent (Cricetus frumentarius).","pos":""}],"HAMSTRING":[{"def":"One of the great tendons situated in each side of the ham, or space back of the knee, and connected with the muscles of the back of the thigh.","pos":""}],"HAMULAR":[{"def":"Hooked; hooklike; hamate; as, the hamular process of the sphenoid bone.","pos":""}],"HAMULATE":[{"def":"Furnished with a small hook; hook-shaped.","pos":""}],"HAMULOSE":[{"def":"Bearing a small hook at the end.","pos":""}],"HAMULUS":[{"def":"A hook, or hooklike process.","pos":""},{"def":"A hooked barbicel of a feather.","pos":""}]}