{"INCRASSATE":[{"def":"To make thick or thicker; to thicken; especially, in pharmacy, to thicken (a liquid) by the mixture of another substance, or by evaporating the thinner parts.","pos":""}],"INCRASSATION":[{"def":"The act or process of thickening or making thick; the process of becoming thick or thicker.","pos":""},{"def":"The state of being incrassated or made thick; inspissation.","pos":""}],"INCRASSATIVE":[{"def":"Having the quality of thickening; tending to thicken.","pos":""}],"INCREASABLE":[{"def":"Capable of being increased.","pos":""}],"INCREASE":[{"def":"To become more nearly full; to show more of the surface; to wax; as, the moon increases.","pos":""}],"INCREASEFUL":[{"def":"Full of increase; abundant in produce.","pos":""}],"INCREASER":[{"def":"One who, or that, increases.","pos":""}],"INCREATE":[{"def":"To create within.","pos":""},{"def":"Uncreated; self-existent.","pos":""}],"INCREDIBILITY":[{"def":"The quality or state of being incredible; incredibleness.","pos":""},{"def":"That which is incredible.","pos":""}],"INCREDIBLE":[{"def":"Not credible; surpassing belief; too extraordinary and improbable to admit of belief; unlikely; marvelous; fabulous.","pos":""}],"INCREDIBLENESS":[{"def":"In*cred\"i*ble*ness, n.","pos":""}],"INCREDIBLY":[{"def":"In an incredible manner.","pos":""}],"INCREDULITY":[{"def":"The state or quality of being i Of every species of incredulity, religious unbelief is the most irrational.","pos":""}],"INCREDULOUS":[{"def":"Not credulous; indisposed to admit or accept that which is related as true, skeptical; unbelieving.","pos":""},{"def":"Indicating, or caused by, disbelief or incredulity.","pos":""}],"INCREDULOUSLY":[{"def":"In an incredulous manner; with incredulity.","pos":""}],"INCREDULOUSNESS":[{"def":"In*cred\"u*lous*ness, n.","pos":""}],"INCREMABLE":[{"def":"Incapable of being burnt; incombustibe.","pos":""}],"INCREMATE":[{"def":"To consume or reduce to ashes by burning, as a dead body; to cremate.","pos":""}],"INCREMENT":[{"def":"The increase of a variable quantity or fraction from its present value to its next ascending value; the finite quantity, generally variable, by which a variable quantity is increased.","pos":""},{"def":"An amplification without strict climax, as in the following passage: Finally, brethren, whatsoever things are true, whatsoever things are honest, whatsoever things are just, whatsoever things are pure, whatsoever things are lovely, whatsoever things are of good report, .","pos":""}],"INCREMENTAL":[{"def":"Pertaining to, or resulting from, the process of growth; as, the incremental lines in the dentine of teeth.","pos":""}],"INCREPATE":[{"def":"To chide; to rebuke; to reprove.","pos":""}],"INCREPATION":[{"def":"A chiding; rebuke; reproof.","pos":""}],"INCRESCENT":[{"def":"Increasing; on the increase; -- said of the moon represented as the new moon, with the points turned toward the dexter side.","pos":""}],"INCREST":[{"def":"To adorn with a crest.","pos":""}],"INCRIMINATE":[{"def":"To accuse; to charge with a crime or fault; to criminate.","pos":""}],"INCRIMINATION":[{"def":"The act of incriminating; crimination.","pos":""}],"INCRIMINATORY":[{"def":"Of or pertaining to crimination; tending to incriminate; criminatory.","pos":""}],"INCROYABLE":[{"def":"A French fop or dandy of the time of the Directory; hence, any fop.","pos":""}],"INCRUENTAL":[{"def":"Unbloody; not attended with blood; as, an incruental sacrifice.","pos":""}],"INCRUST":[{"def":"To inlay into, as a piece of carving or other ornamental object.","pos":""}],"INCRUSTATION":[{"def":"A covering or inlaying of marble, mosaic, etc.","pos":""},{"def":"Anything inlaid or imbedded.","pos":""}],"INCRYSTALLIZABLE":[{"def":"Not crystallizable; incapable of being formed into crystals.","pos":""}]}