{"PREACCUSATION":[{"def":"Previous accusation.","pos":""}],"PREACH":[{"def":"To proclaim or publish tidings; specifically, to proclaim the gospel; to discourse publicly on a religious subject, or from a text of Scripture; to deliver a sermon.","pos":""},{"def":"To give serious advice on morals or religion; to discourse in the manner of a preacher.","pos":""}],"PREACHER":[{"def":"One who preaches; one who discourses publicly on religious subjects.","pos":""},{"def":"One who inculcates anything with earnestness.","pos":""}],"PREACHERSHIP":[{"def":"The office of a preacher.","pos":""}],"PREACHIFY":[{"def":"To discourse in the manner of a preacher.","pos":""}],"PREACHING":[{"def":"The act of delivering a religious discourse; the art of sermonizing; also, a sermon; a public religious discourse; serious, earnest advice.","pos":""}],"PREACHMAN":[{"def":"A preacher; -- so called in contempt.","pos":""}],"PREACHMENT":[{"def":"A religious harangue; a sermon; -- used derogatively.","pos":""}],"PREACQUAINT":[{"def":"To acquaint previously or beforehand.","pos":""}],"PREACQUAINTANCE":[{"def":"Previous acquaintance or knowledge.","pos":""}],"PREACT":[{"def":"To act beforehand; to perform previously.","pos":""}],"PREACTION":[{"def":"Previous action.","pos":""}],"PREADAMITE":[{"def":"An inhabitant of the earth before Adam.","pos":""},{"def":"One who holds that men existed before Adam.","pos":""}],"PREADAMITIC":[{"def":"Existing or occurring before Adam; preadamic; as, preadamitic periods.","pos":""}],"PREADJUSTMENT":[{"def":"Previous adjustment.","pos":""}],"PREADMINISTRATION":[{"def":"Previous administration.","pos":""}],"PREADMISSION":[{"def":"admission, as of steam, to the engine cylinder before the back stroke is completed, thus increasing the cushioning.","pos":""}],"PREADMONISH":[{"def":"To admonish previously.","pos":""}],"PREADMONITION":[{"def":"Previous warning or admonition; forewarning.","pos":""}],"PREADVERTISE":[{"def":"To advertise beforehand; to preannounce publicly.","pos":""}],"PREAMBLE":[{"def":"A introductory portion; an introduction or preface, as to a book, document, etc.","pos":""}],"PREAMBULARY":[{"def":"Of or pertaining to a preamble; introductory; contained or provided for in a preamble.","pos":""}],"PREAMBULATION":[{"def":"A walking or going before; precedence.","pos":""}],"PREAMBULATORY":[{"def":"Preceding; going before; introductory.","pos":""}],"PREAMBULOUS":[{"def":"See Perambulatory.","pos":""}],"PREANNOUNCE":[{"def":"To announce beforehand.","pos":""}],"PREANTENULTIMATE":[{"def":"Being or indicating the fourth syllable from the end of a word, or that before the antepenult.","pos":""}],"PREAORTIC":[{"def":"In front, or on the ventral side, of the aorta.","pos":""}],"PREAPPOINT":[{"def":"To appoint previously, or beforehand.","pos":""}],"PREAPPOINTMENT":[{"def":"Previous appointment.","pos":""}],"PREAPPREHENSION":[{"def":"An apprehension or opinion formed before examination or knowledge.","pos":""}],"PREARRANGE":[{"def":"To arrange beforehand.","pos":""}],"PREASE":[{"def":"To press; to crowd.","pos":""},{"def":"A press; a crowd.","pos":""}],"PREASSURANCE":[{"def":"Previous assurance.","pos":""}],"PREATAXIC":[{"def":"Occurring before the symptom ataxia has developed; -- applied to the early symptoms of locomotor ataxia.","pos":""}],"PREAUDIENCE":[{"def":"Precedence of rank at the bar among lawyers.","pos":""}],"PREAXIAL":[{"def":"Situated in front of any transverse axis in the body of an animal; anterior; cephalic; esp.","pos":""}]}