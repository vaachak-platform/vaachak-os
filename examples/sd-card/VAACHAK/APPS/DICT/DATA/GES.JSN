{"GESSO":[{"def":"Plaster of Paris, or gypsum, esp.","pos":""},{"def":"A work of art done in gesso.","pos":""}],"GESSO DURO":[{"def":"A variety of gesso which when dried becomes hard and durable, often used in making bas-relief casts, which are colored and mounted in elaborate frames.","pos":""}],"GEST":[{"def":"Something done or achieved; a deed or an action; an adventure.","pos":""},{"def":"An action represented in sports, plays, or on the stage; show; ceremony.","pos":""}],"GESTANT":[{"def":"Bearing within; laden; burdened; pregnant.","pos":""}],"GESTATION":[{"def":"The act of wearing (clothes or ornaments).","pos":""},{"def":"The act of carrying young in the womb from conception to delivery; pregnancy.","pos":""}],"GESTATORY":[{"def":"Pertaining to gestation or pregnancy.","pos":""},{"def":"Capable of being carried or worn.","pos":""}],"GESTE":[{"def":"To tell stories or gests.","pos":""}],"GESTIC":[{"def":"Pertaining to deeds or feats of arms; legendary.","pos":""},{"def":"Relating to bodily motion; consisting of gestures; -- said especially with reference to dancing.","pos":""}],"GESTICULATE":[{"def":"To make gestures or motions, as in speaking; to use postures.","pos":""}],"GESTICULATION":[{"def":"The act of gesticulating, or making gestures to express passion or enforce sentiments.","pos":""},{"def":"A gesture; a motion of the body or limbs in speaking, or in representing action or passion, and enforcing arguments and sentiments.","pos":""}],"GESTICULATOR":[{"def":"One who gesticulates.","pos":""}],"GESTICULATORY":[{"def":"Representing by, or belonging to, gestures.","pos":""}],"GESTOUR":[{"def":"A reciter of gests or legendary tales; a story-teller.","pos":""}],"GESTURAL":[{"def":"Relating to gesture.","pos":""}],"GESTURE":[{"def":"Manner of carrying the body; position of the body or limbs; posture.","pos":""},{"def":"A motion of the body or limbs expressive of sentiment or passion; any action or posture intended to express an idea or a passion, or to enforce or emphasize an argument, assertion, or opinion.","pos":""}],"GESTURELESS":[{"def":"Free from gestures.","pos":""}],"GESTUREMENT":[{"def":"Act of making gestures; gesturing.","pos":""}]}