{"PEMBROKE TABLE":[{"def":"A style of four-legged table in vogue in England, chiefly in the later Georgian period.","pos":""}],"PEMMICAN":[{"def":"Among the North American Indians, meat cut in thin slices, divested of fat, and dried in the sun.","pos":""},{"def":"Meat, without the fat, cut in thin slices, dried in the sun, pounded, then mixed with melted fat and sometimes dried fruit, and compressed into cakes or in bags.","pos":""}],"PEMPHIGUS":[{"def":"A somewhat rare skin disease, characterized by the development of blebs upon different part of the body.","pos":""}]}