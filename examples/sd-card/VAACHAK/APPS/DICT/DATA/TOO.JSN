{"TOO":[{"def":"Over; more than enough; -- noting excess; as, a thing is too long, too short, or too wide; too high; too many; too much.","pos":""},{"def":"Likewise; also; in addition.","pos":""}],"TOOL":[{"def":"An instrument such as a hammer, saw, plane, file, and the like, used in the manual arts, to facilitate mechanical operations; any instrument used by a craftsman or laborer at his work; an implement; as, the tools of a joiner, smith, shoe-maker, etc.","pos":""},{"def":"A machine for cutting or shaping materials; -- also called machine tool.","pos":""}],"TOOL STEEL":[{"def":"Hard steel, usually crucible steel, capable of being tempered so as to be suitable for tools.","pos":""}],"TOOL-REST":[{"def":"the part that supports a tool-post or a tool.","pos":""}],"TOOLING":[{"def":"Work perfomed with a tool.","pos":""},{"def":"The part of a toolrest in which a cutting tool is clamped.","pos":""}],"TOON":[{"def":"The reddish brown wood of an East Indian tree (Cedrela Toona) closely resembling the Spanish cedar; also.","pos":""}],"TOOT":[{"def":"To stand out, or be prominent.","pos":""},{"def":"To peep; to look narrowly.","pos":""}],"TOOTER":[{"def":"One who toots; one who plays upon a pipe or horn.","pos":""}],"TOOTH":[{"def":"One of the hard, bony appendages which are borne on the jaws, or on other bones in the walls of the mouth or pharynx of most vertebrates, and which usually aid in the prehension and mastication of food.","pos":""},{"def":"An angular or prominence on any edge; as, a tooth on the scale of a fish, or on a leaf of a plant; specifically (Bot.","pos":""}],"TOOTHACHE":[{"def":"Pain in a tooth or in the teeth; odontalgia.","pos":""}],"TOOTHBACK":[{"def":"Any notodontian.","pos":""}],"TOOTHBILL":[{"def":"A peculiar fruit-eating ground pigeon (Didunculus strigiostris) native of the Samoan Islands, and noted for its resemblance, in several characteristics, to the extinct dodo.","pos":""}],"TOOTHBRUSH":[{"def":"A brush for cleaning the teeth.","pos":""}],"TOOTHDRAWER":[{"def":"One whose business it is to extract teeth with instruments; a dentist.","pos":""}],"TOOTHED":[{"def":"Having marginal projecting points; dentate.","pos":""}],"TOOTHING":[{"def":"Bricks alternately projecting at the end of a wall, in order that they may be bonded into a continuation of it when the remainder is carried up.","pos":""}],"TOOTHLESS":[{"def":"Having no teeth.","pos":""}],"TOOTHLET":[{"def":"A little tooth, or like projection.","pos":""}],"TOOTHLETED":[{"def":"Having a toothlet or toothlets; as, a toothleted leaf.","pos":""}],"TOOTHPICK":[{"def":"A pointed instument for clearing the teeth of substances lodged between them.","pos":""}],"TOOTHSHELL":[{"def":"Any species of Dentalium and allied genera having a tooth- shaped shell.","pos":""}],"TOOTHSOME":[{"def":"Grateful to the taste; palable.","pos":""}],"TOOTHWORT":[{"def":"A plant whose roots are fancied to resemble teeth, as certain plants of the genus Lathræa, and various species of Dentaria.","pos":""}],"TOOTHY":[{"def":"Toothed; with teeth.","pos":""}],"TOOTLE":[{"def":"To toot gently, repeatedly, or continuously, on a wind instrument, as a flute; also, to make a similar noise by any means.","pos":""}]}