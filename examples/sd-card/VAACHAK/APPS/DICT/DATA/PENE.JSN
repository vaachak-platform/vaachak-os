{"PENELOPE":[{"def":"A genus of curassows, including the guans.","pos":""}],"PENEPLAIN":[{"def":"A land surface reduced by erosion to the general condition of a plain, but not wholly devoid of hills; a base-level plain.","pos":""}],"PENETRABILITY":[{"def":"The quality of being penetrable; susceptibility of being penetrated, entered, or pierced.","pos":""}],"PENETRABLE":[{"def":"Capable of being penetrated, entered, or pierced.","pos":""}],"PENETRALIA":[{"def":"The quality or state of being penetrant; power of entering or piercing; penetrating power of quality; as, the penetrancy of subtile effluvia.","pos":""}],"PENETRANT":[{"def":"Having power to enter or pierce; penetrating; sharp; subtile; as, penetrant cold.","pos":""}],"PENETRATE":[{"def":"To enter into; to make way into the interior of; to effect an entrance into; to pierce; as, light penetrates darkness.","pos":""},{"def":"To affect profoundly through the senses or feelings; to touch with feeling; to make sensible; to move deeply; as, to penetrate one's heart with pity.","pos":""}],"PENETRATING":[{"def":"Having the power of entering, piercing, or pervading; sharp; subtile; penetrative; as, a penetrating odor.","pos":""},{"def":"Acute; discerning; sagacious; quick to discover; as, a penetrating mind.","pos":""}],"PENETRATINGLY":[{"def":"In a penetrating manner.","pos":""}],"PENETRATION":[{"def":"The act or process of penetrating, piercing, or entering; also, the act of mentally penetrating into, or comprehending, anything difficult.","pos":""},{"def":"Acuteness; insight; sharp discoverment; sagacity; as, a person of singular penetration.","pos":""}],"PENETRATIVE":[{"def":"Tending to penetrate; of a penetrating quality; piercing; as, the penetrative sun.","pos":""},{"def":"Having the power to affect or impress the mind or heart; impressive; as, penetrative shame.","pos":""}],"PENETRATIVENESS":[{"def":"The quality of being penetrative.","pos":""}]}