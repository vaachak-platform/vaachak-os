{"PLAN":[{"def":"A draught or form; properly, a representation drawn on a plane, as a map or a chart; especially, a top view, as of a machine, or the representation or delineation of a horizontal section of anything, as of a building; a graphic representation; a diagram.","pos":""},{"def":"A scheme devised; a method of action or procedure expressed or described in language; a project; as, the plan of a constitution; the plan of an expedition.","pos":""}],"PLANARIA":[{"def":"Any species of turbellarian worms belonging to Planaria, and many allied genera.","pos":""}],"PLANARIAN":[{"def":"One of the Planarida, or Dendrocoela; any turbellarian worm.","pos":""}],"PLANARIDA":[{"def":"A division of Turbellaria; the Dendrocoela.","pos":""}],"PLANARIOID":[{"def":"Like the planarians.","pos":""}],"PLANARY":[{"def":"Of or pertaining to a plane.","pos":""}],"PLANCH":[{"def":"To make or cover with planks or boards; to plank.","pos":""}],"PLANCHER":[{"def":"The under side of a cornice; a soffit.","pos":""}],"PLANCHET":[{"def":"A flat piece of metal; especially, a disk of metal ready to be stamped as a coin.","pos":""}],"PLANCHETTE":[{"def":"A circumferentor.","pos":""},{"def":"A small tablet of wood supported on casters and having a pencil attached.","pos":""}],"PLANCHING":[{"def":"The laying of floors in a building; also, a floor of boards or planks.","pos":""}],"PLANE":[{"def":"Any tree of the genus Platanus.","pos":""}],"PLANE TABLE":[{"def":"See under Plane, a.","pos":""}],"PLANE TREE":[{"def":"Same as 1st Plane.","pos":""},{"def":"Affected by the influence of planets; blasted.","pos":""}],"PLANE-PARALLEL":[{"def":"Having opposite surfaces exactly plane and parallel, as a piece of glass.","pos":""}],"PLANER":[{"def":"A wooden block used for forcing down the type in a form, and making the surface even.","pos":""}],"PLANER TREE":[{"def":"A small-leaved North American tree (Planera aquatica) related to the elm, but having a wingless, nutlike fruit.","pos":""}],"PLANET":[{"def":"A celestial body which revolves about the sun in an orbit of a moderate degree of eccentricity.","pos":""}],"PLANETARY":[{"def":"Under the dominion or influence of a planet.","pos":""}],"PLANETED":[{"def":"Belonging to planets.","pos":""},{"def":"Of or pertaining to planets.","pos":""}],"PLANETOID":[{"def":"A body resembling a planet; an asteroid.","pos":""}],"PLANETOIDAL":[{"def":"Pertaining to a planetoid.","pos":""}],"PLANETULE":[{"def":"A little planet.","pos":""}],"PLANGENCY":[{"def":"The quality or state of being plangent; a beating sound.","pos":""}],"PLANGENT":[{"def":"Beating; dashing, as a wave.","pos":""},{"def":"Combining forms signifying flat, level, plane; as planifolious, planimetry, plano-concave.","pos":""}],"PLANIFORM":[{"def":"Having a plane surface; as, a planiform, gliding, or arthrodial articulation.","pos":""}],"PLANIMETER":[{"def":"An instrument for measuring the area of any plane figure, however irregular, by passing a tracer around the bounding line; a platometer.","pos":""},{"def":"Of or pertaining to planimetry.","pos":""}],"PLANIMETRY":[{"def":"The mensuration of plane surfaces; -- distinguished from stereometry, or the mensuration of volumes.","pos":""}],"PLANIPENNATE":[{"def":"Of or pertaining to Planipennia.","pos":""}],"PLANIPENNIA":[{"def":"A suborder of Neuroptera, including those that have broad, flat wings, as the ant-lion, lacewing, etc.","pos":""}],"PLANIPETALOUS":[{"def":"Having flat petals.","pos":""}],"PLANISH":[{"def":"To make smooth or plane, as a metallic surface; to condense, toughen, and polish by light blows with a hammer.","pos":""}],"PLANISHER":[{"def":"One who, or that which, planishes.","pos":""}],"PLANISHING":[{"def":"Plan\"ish*ing, Defn: a.","pos":""}],"PLANISPHERE":[{"def":"The representation of the circles of the sphere upon a plane; especially, a representation of the celestial sphere upon a plane with adjustable circles, or other appendages, for showing the position of the heavens, the time of rising and setting of stars, etc.","pos":""}],"PLANISPHERIC":[{"def":"Of or pertaining to a planisphere.","pos":""}],"PLANK":[{"def":"A broad piece of sawed timber, differing from a board only in being thicker.","pos":""}],"PLANK-SHEER":[{"def":"The course of plank laid horizontally over the timberheads of a vessel's frame.","pos":""}],"PLANKING":[{"def":"The act of laying planks; also, planks, collectively; a series of planks in place, as the wooden covering of the frame of a vessel.","pos":""},{"def":"The act of splicing slivers.","pos":""}],"PLANKTON":[{"def":"All the animals and plants, taken collectively, which live at or near the surface of salt or fresh waters.","pos":""}],"PLANNER":[{"def":"One who plans; a projector.","pos":""}],"PLANO-CONCAVE":[{"def":"Plane or flat on one side, and concave on the other; as, a plano-concave lens.","pos":""}],"PLANO-CONICAL":[{"def":"Plane or flat on one side, and conical on the other.","pos":""}],"PLANO-CONVEX":[{"def":"Plane or flat on one side, and convex on the other; as, a plano-convex lens.","pos":""}],"PLANO-HORIZONTAL":[{"def":"Having a level horizontal surface or position.","pos":""}],"PLANO-ORBICULAR":[{"def":"Plane or flat on one side, and spherical on the other.","pos":""}],"PLANO-SUBULATE":[{"def":"Smooth and awl-shaped.","pos":""}],"PLANOBLAST":[{"def":"Any free-swimming gonophore of a hydroid; a hydroid medusa.","pos":""}],"PLANOGAMETE":[{"def":"One of the motile ciliated gametes, or zoögametes, found in isogamous plants, as many green algæ (Chlorophyceæ).","pos":""}],"PLANOMETER":[{"def":"An instrument for gauging or testing a plane surface.","pos":""}],"PLANOMETRY":[{"def":"The art or process of producing or gauging a plane surface.","pos":""}],"PLANORBIS":[{"def":"Any fresh-water air-breathing mollusk belonging to Planorbis and other allied genera, having shells of a discoidal form.","pos":""}],"PLANT":[{"def":"A vegetable; an organized living being, generally without feeling and voluntary motion, and having, when complete, a root, stem, and leaves, though consisting sometimes only of a single leafy expansion, or a series of cellules, or even a single cellule.","pos":""},{"def":"A bush, or young tree; a sapling; hence, a stick or staff.","pos":""}],"PLANT-CANE":[{"def":"A stalk or shoot of sugar cane of the first growth from the cutting.","pos":""}],"PLANT-EATING":[{"def":"Eating, or subsisting on, plants; as, a plant-eating beetle.","pos":""}],"PLANTABLE":[{"def":"Capable of being planted; fit to be planted.","pos":""}],"PLANTAGE":[{"def":"A word used once by Shakespeare to designate plants in general, or anything that is planted.","pos":""}],"PLANTAIN":[{"def":"A treelike perennial herb (Musa paradisiaca) of tropical regions, bearing immense leaves and large clusters of the fruits called plantains.","pos":""}],"PLANTAL":[{"def":"Belonging to plants; as, plantal life.","pos":""}],"PLANTAR":[{"def":"Of or pertaining to the sole of the foot; as, the plantar arteries.","pos":""}],"PLANTATION":[{"def":"The act or practice of planting, or setting in the earth for growth.","pos":""},{"def":"The place planted; land brought under cultivation; a piece of ground planted with trees or useful plants; esp.","pos":""}],"PLANTED":[{"def":"Fixed in place, as a projecting member wrought on a separate piece of stuff; as, a planted molding.","pos":""}],"PLANTER":[{"def":"One who, or that which, plants or sows; as, a planterof corn; a machine planter.","pos":""},{"def":"One who owns or cultivates a plantation; as, a sugar planter; a coffee planter.","pos":""}],"PLANTERSHIP":[{"def":"The occupation or position of a planter, or the management of a plantation, as in the United States or the West Indies.","pos":""}],"PLANTICLE":[{"def":"A young plant, or plant in embryo.","pos":""}],"PLANTIGRADA":[{"def":"A subdivision of Carnivora having plantigrade feet.","pos":""}],"PLANTIGRADE":[{"def":"A plantigrade animal, or one that walks or steps on the sole of the foot, as man, and the bears.","pos":""}],"PLANTING":[{"def":"The laying of the first courses of stone in a foundation.","pos":""}],"PLANTLESS":[{"def":"Without plants; barren of vegetation.","pos":""}],"PLANTOCRACY":[{"def":"Government by planters; planters, collectively.","pos":""}],"PLANTULE":[{"def":"The embryo which has begun its development in the act of germination.","pos":""}],"PLANULA":[{"def":"In embryonic development, a vesicle filled with fluid, formed from the morula by the divergence of its cells in such a manner as to give rise to a central space, around which the cells arrange themselves as an envelope; an embryonic form intermediate between the morula and gastrula.","pos":""},{"def":"The very young, free-swimming larva of the coelenterates.","pos":""}],"PLANXTY":[{"def":"An Irish or Welsh melody for the harp, sometimes of a mournful character.","pos":""}]}