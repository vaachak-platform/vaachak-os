{"BALAAM":[{"def":"A paragraph describing something wonderful, used to fill out a newspaper column; -- an allusion to the miracle of Balaam's ass speaking.","pos":""}],"BALACHONG":[{"def":"A condiment formed of small fishes or shrimps, pounded up with salt and spices, and then dried.","pos":""}],"BALAENOIDEA":[{"def":"A division of the Cetacea, including the right whale and all other whales having the mouth fringed with baleen.","pos":""}],"BALANCE":[{"def":"A balance wheel, as of a watch, or clock.","pos":""}],"BALANCE WHEEL":[{"def":"A wheel which imparts regularity to the movements of any engine or machine; a fly wheel.","pos":""}],"BALANCEABLE":[{"def":"Such as can be balanced.","pos":""}],"BALANCEMENT":[{"def":"The act or result of balancing or adjusting; equipoise; even adjustment of forces.","pos":""}],"BALANCER":[{"def":"In Diptera, the rudimentary posterior wing.","pos":""}],"BALANCEREEF":[{"def":"The last reef in a fore-and-aft sail, taken to steady the ship.","pos":""}],"BALANIFEROUS":[{"def":"Bearing or producing acorns.","pos":""}],"BALANITE":[{"def":"A fossil balanoid shell.","pos":""}],"BALANOGLOSSUS":[{"def":"A peculiar marine worm.","pos":""}],"BALANOID":[{"def":"Resembling an acorn; -- applied to a group of barnacles having shells shaped like acorns.","pos":""}],"BALAS RUBY":[{"def":"A variety of spinel ruby, of a pale rose red, or inclining to orange.","pos":""}],"BALATA":[{"def":"A West Indian sapotaceous tree (Bumelia retusa).","pos":""}],"BALAUSTINE":[{"def":"The pomegranate tree (Punica granatum).","pos":""}],"BALAYEUSE":[{"def":"A protecting ruffle or frill, as of silk or lace, sewed close to the lower edge of a skirt on the inside.","pos":""}],"BALBUTIES":[{"def":"The defect of stammering; also, a kind of incomplete pronunciation.","pos":""}],"BALCONIED":[{"def":"Having balconies.","pos":""}],"BALCONY":[{"def":"A platform projecting from the wall of a building, usually resting on brackets or consoles, and inclosed by a parapet; as, a balcony in front of a window.","pos":""}],"BALD":[{"def":"Destitute of a beard or awn; as, bald wheat.","pos":""}],"BALD EAGLE":[{"def":"The white-headed eagle (Haliæetus leucocephalus) of America.","pos":""}],"BALD-FACED":[{"def":"Having a white face or a white mark on the face, as a stag.","pos":""}],"BALDACHIN":[{"def":"A structure in form of a canopy, sometimes supported by columns, and sometimes suspended from the roof or projecting from the wall; generally placed over an altar; as, the baldachin in St.","pos":""}],"BALDER":[{"def":"The most beautiful and beloved of the gods; the god of peace; the son of Odin and Freya.","pos":""}],"BALDERDASH":[{"def":"A worthless mixture, especially of liquors.","pos":""},{"def":"Senseless jargon; ribaldry; nonsense; trash.","pos":""}],"BALDHEAD":[{"def":"A white-headed variety of pigeon.","pos":""}],"BALDHEADED":[{"def":"Having a bald head.","pos":""}],"BALDLY":[{"def":"Nakedly; without reserve; inelegantly.","pos":""}],"BALDNESS":[{"def":"The state or condition of being bald; as, baldness of the head; baldness of style.","pos":""}],"BALDPATE":[{"def":"The American widgeon (Anas Americana).","pos":""},{"def":"Destitute of hair on the head; baldheaded.","pos":""}],"BALDRIB":[{"def":"A piece of pork cut lower down than the sparerib, and destitute of fat.","pos":""}],"BALDRIC":[{"def":"A broad belt, sometimes richly ornamented, worn over one shoulder, across the breast, and under the opposite arm; less properly, any belt.","pos":""}],"BALDWIN":[{"def":"A kind of reddish, moderately acid, winter apple.","pos":""}],"BALE":[{"def":"A bundle or package of goods in a cloth cover, and corded for storage or transportation; also, a bundle of straw Bale of dice, a pair of dice.","pos":""}],"BALEARIC":[{"def":"Of or pertaining to the isles of Majorca, Minorca, Ivica, etc.","pos":""}],"BALEEN":[{"def":"Plates or blades of \"whalebone,\" from two to twelve feet long, and sometimes a foot wide, which in certain whales (Balænoidea) are attached side by side along the upper jaw, and form a fringelike sieve by which the food is retained in the mouth.","pos":""}],"BALEFIRE":[{"def":"A signal fire; an alarm fire.","pos":""}],"BALEFUL":[{"def":"Full of deadly or pernicious influence; destructive.","pos":""},{"def":"Full of grief or sorrow; woeful; sad.","pos":""}],"BALEFULLY":[{"def":"In a baleful manner; perniciously.","pos":""}],"BALEFULNESS":[{"def":"The quality or state of being baleful.","pos":""}],"BALISAUR":[{"def":"A badgerlike animal of India (Arcionyx collaris).","pos":""}],"BALISTOID":[{"def":"Like a fish of the genus Balistes; of the family Balistidæ.","pos":""}],"BALISTRARIA":[{"def":"A narrow opening, often cruciform, through which arrows might be discharged.","pos":""}],"BALIZE":[{"def":"A pole or a frame raised as a sea beacon or a landmark.","pos":""}],"BALK":[{"def":"One of the beams connecting the successive supports of a trestle bridge or bateau bridge.","pos":""},{"def":"A deceptive gesture of the pitcher, as if to deliver the ball.","pos":""}],"BALKER":[{"def":"One who, or that which balks.","pos":""}],"BALKINGLY":[{"def":"In manner to balk or frustrate.","pos":""}],"BALKY":[{"def":"Apt to balk; as, a balky horse.","pos":""}],"BALL":[{"def":"A flaming, roundish body shot into the air; a case filled with combustibles intended to burst and give light or set fire, or to produce smoke or stench; as, a fire ball; a stink ball.","pos":""},{"def":"A leather-covered cushion, fastened to a handle called a ballstock; -- formerly used by printers for inking the form, but now superseded by the roller.","pos":""}],"BALL-FLOWER":[{"def":"An ornament resembling a ball placed in a circular flower, the petals of which form a cup round it, -- usually inserted in a hollow molding.","pos":""}],"BALLAD":[{"def":"A popular kind of narrative poem, adapted for recitation or singing; as, the ballad of Chevy Chase; esp.","pos":""}],"BALLAD MONGER":[{"def":"A seller or maker of ballads; a poetaster.","pos":""}],"BALLADE":[{"def":"A form of French versification, sometimes imitated in English, in which three or four rhymes recur through three stanzas of eight or ten lines each, the stanzas concluding with a refrain, and the whole poem with an envoy.","pos":""}],"BALLADER":[{"def":"A writer of ballads.","pos":""}],"BALLADRY":[{"def":"Ballad poems; the subject or style of ballads.","pos":""},{"def":"A fast-sailing schooner, used in the Bermudas and West Indies.","pos":""}],"BALLARAG":[{"def":"To bully; to threaten.","pos":""}],"BALLAST":[{"def":"Any heavy substance, as stone, iron, etc.","pos":""}],"BALLASTAGE":[{"def":"A toll paid for the privilege of taking up ballast in a port or harbor.","pos":""}],"BALLASTING":[{"def":"That which is used for steadying anything; ballast.","pos":""}],"BALLET":[{"def":"A light part song, or madrigal, with a fa la burden or chorus, -- most common with the Elizabethan madrigal composers.","pos":""},{"def":"A bearing in coats of arms, representing one or more balls, which are denominated bezants, plates, etc.","pos":""}],"BALLISTA":[{"def":"An ancient military engine, in the form of a crossbow, used for hurling large missiles.","pos":""}],"BALLISTIC":[{"def":"Of or pertaining to the ballista, or to the art of hurling stones or missile weapons by means of an engine.","pos":""},{"def":"Pertaining to projection, or to a projectile.","pos":""}],"BALLISTICS":[{"def":"The science or art of hurling missile weapons by the use of an engine.","pos":""}],"BALLISTITE":[{"def":"A smokeless powder containing equal parts of soluble nitrocellulose and nitroglycerin.","pos":""}],"BALLOON":[{"def":"A ball or globe on the top of a pillar, church, etc.","pos":""},{"def":"A round vessel, usually with a short neck, to hold or receive whatever is distilled; a glass vessel of a spherical form.","pos":""}],"BALLOON FISH":[{"def":"A fish of the genus Diodon or the genus Tetraodon, having the power of distending its body by taking air or water into its dilatable esophagus.","pos":""}],"BALLOONED":[{"def":"Swelled out like a balloon.","pos":""}],"BALLOONER":[{"def":"One who goes up in a balloon; an aëronaut.","pos":""}],"BALLOONING":[{"def":"The process of temporarily raising the value of a stock, as by fictitious sales.","pos":""}],"BALLOONING SPIDER":[{"def":"A spider which has the habit of rising into the air.","pos":""}],"BALLOONRY":[{"def":"The art or practice of ascending in a balloon; aëronautics.","pos":""}],"BALLOT":[{"def":"Originally, a ball used for secret voting.","pos":""},{"def":"The act of voting by balls or written or printed ballots or tickets; the system of voting secretly by balls or by tickets.","pos":""}],"BALLOTADE":[{"def":"A leap of a horse, as between two pillars, or upon a straight line, so that when his four feet are in the air, he shows only the shoes of his hind feet, without jerking out.","pos":""}],"BALLOTAGE":[{"def":"In France, a second ballot taken after an indecisive first ballot to decide between two or several candidates.","pos":""}],"BALLOTATION":[{"def":"Voting by ballot.","pos":""}],"BALLOTER":[{"def":"One who votes by ballot.","pos":""}],"BALLOTIN":[{"def":"An officer who has charge of a ballot box.","pos":""}],"BALLPROOF":[{"def":"Incapable of being penetrated by balls from firearms.","pos":""}],"BALLROOM":[{"def":"A room for balls or dancing.","pos":""}],"BALM":[{"def":"An aromatic plant of the genus Melissa.","pos":""}],"BALMIFY":[{"def":"To render balmy.","pos":""}],"BALMILY":[{"def":"In a balmy manner.","pos":""}],"BALMORAL":[{"def":"A long woolen petticoat, worn immediately under the dress.","pos":""},{"def":"A kind of stout walking shoe, laced in front.","pos":""}],"BALMY":[{"def":"Having the qualities of balm; odoriferous; aromatic; assuaging; soothing; refreshing; mild.","pos":""}],"BALNEAL":[{"def":"Of or pertaining to a bath.","pos":""}],"BALNEATION":[{"def":"The act of bathing.","pos":""}],"BALNEATORY":[{"def":"Belonging to a bath.","pos":""}],"BALNEOGRAPHY":[{"def":"A description of baths.","pos":""}],"BALNEOLOGY":[{"def":"A treatise on baths; the science of bathing.","pos":""}],"BALNEOTHERAPY":[{"def":"The treatment of disease by baths.","pos":""}],"BALOPTICON":[{"def":"See Projector, below.","pos":""}],"BALSA":[{"def":"A raft or float, used principally on the Pacific coast of South America.","pos":""}],"BALSAM":[{"def":"A resin containing more or less of an essential or volatile oil.","pos":""},{"def":"Anything that heals, soothes, or restores.","pos":""}],"BALSAMATION":[{"def":"Having the qualities of balsam; containing, or resembling, balsam; soft; mitigative; soothing; restorative.","pos":""}],"BALSAMIFEROUS":[{"def":"Producing balsam.","pos":""}],"BALSAMINE":[{"def":"The Impatiens balsamina, or garden balsam.","pos":""}],"BALSAMOUS":[{"def":"Having the quality of balsam; containing balsam.","pos":""}],"BALTER":[{"def":"To stick together.","pos":""}],"BALTIC":[{"def":"Of or pertaining to the sea which separates Norway and Sweden from Jutland, Denmark, and Germany; situated on the Baltic Sea.","pos":""},{"def":"A common American bird (Icterus galbula), named after Lord Baltimore, because its colors (black and orange red) are like those of his coat of arms; -- called also golden robin.","pos":""}],"BALUSTER":[{"def":"A row of balusters topped by a rail, serving as an open parapet, as along the edge of a balcony, terrace, bridge, staircase, or the eaves of a building.","pos":""}],"BALUSTERED":[{"def":"Having balusters.","pos":""}],"BALUSTRADE":[{"def":"A row of balusters topped by a rail, serving as an open parapet, as along the edge of a balcony, terrace, bridge, staircase, or the eaves of a building.","pos":""}]}