{"GALOOT":[{"def":"A noisy, swaggering, or worthless fellow; a rowdy.","pos":""}],"GALOP":[{"def":"A kind of lively dance, in 2-4 time; also, the music to the dance.","pos":""}],"GALORE":[{"def":"Plenty; abundance; in abundance.","pos":""}],"GALOSH":[{"def":"Same as Galoche, Galoshe.","pos":""},{"def":"A strip of material, as leather, running around a shoe at and above the sole, as for protection or ornament.","pos":""}],"GALOSHE":[{"def":"Same as Galoche.","pos":""}]}