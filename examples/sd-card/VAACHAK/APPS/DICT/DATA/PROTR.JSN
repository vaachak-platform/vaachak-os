{"PROTRACHEATA":[{"def":"Same as Malacopoda.","pos":""}],"PROTRACT":[{"def":"To draw to a scale; to lay down the lines and angles of, with scale and protractor; to plot.","pos":""},{"def":"To extend; to protrude; as, the cat can protract its claws; -- opposed to retract.","pos":""}],"PROTRACTED":[{"def":"Prolonged; continued.","pos":""}],"PROTRACTILE":[{"def":"Capable of being protracted, or protruded; protrusile.","pos":""}],"PROTRACTION":[{"def":"A drawing out, or continuing; the act of delaying the termination of a thing; prolongation; continuance; delay; as, the protraction of a debate.","pos":""}],"PROTRACTIVE":[{"def":"Drawing out or lengthening in time; prolonging; continuing; delaying.","pos":""}],"PROTRACTOR":[{"def":"An instrument formerly used in extracting foreign or offensive matter from a wound.","pos":""},{"def":"A muscle which extends an organ or part; -- opposed to retractor.","pos":""}],"PROTREPTICAL":[{"def":"Adapted to persuade; hortatory; persuasive.","pos":""}],"PROTRUDABLE":[{"def":"That may be protruded; protrusile.","pos":""}],"PROTRUDE":[{"def":"To thrust forward; to drive or force along.","pos":""},{"def":"To thrust out, as through a narrow orifice or from confinement; to cause to come forth.","pos":""}],"PROTRUSILE":[{"def":"Capable of being protruded or thrust out; protractile; protrusive.","pos":""}],"PROTRUSION":[{"def":"The act of protruding or thrusting forward, or beyond the usual limit.","pos":""},{"def":"The state of being protruded, or thrust forward.","pos":""}],"PROTRUSIVE":[{"def":"Thrusting or impelling forward; as, protrusive motion.","pos":""},{"def":"Capable of being protruded; protrusile.","pos":""}],"PROTRUSIVELY":[{"def":"In a protrusive manner.","pos":""}]}