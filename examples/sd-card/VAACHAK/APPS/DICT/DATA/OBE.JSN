{"OBEAH":[{"def":"Of or pertaining to obi; as, the obeah man.","pos":""}],"OBEDIENCE":[{"def":"The act of obeying, or the state of being obedient; compliance with that which is required by authority; subjection to rightful restraint or control.","pos":""},{"def":"Words or actions denoting submission to authority; dutifulness.","pos":""}],"OBEDIENCIARY":[{"def":"One yielding obedience.","pos":""}],"OBEDIENT":[{"def":"Subject in will or act to authority; willing to obey; submissive to restraint, control, or command.","pos":""}],"OBEDIENTIAL":[{"def":"According to the rule of obedience.","pos":""}],"OBEDIENTLY":[{"def":"In an obedient manner; with obedience.","pos":""}],"OBEISANCE":[{"def":"A manifestation of obedience; an expression of difference or respect; homage; a bow; a courtesy.","pos":""}],"OBEISANT":[{"def":"Ready to obey; reverent; differential; also, servilely submissive.","pos":""}],"OBELION":[{"def":"The region of the skull between the two parietal foramina where the closure of the sagittal suture usually begins.","pos":""}],"OBELISCAL":[{"def":"Formed like an obelisk.","pos":""}],"OBELISK":[{"def":"A mark of reference; -- called also dagger [&dag;].","pos":""}],"OBELIZE":[{"def":"To designate with an obelus; to mark as doubtful or spirituous.","pos":""}],"OBELUS":[{"def":"A mark [thus ---, or ÷]; -- so called as resembling a needle.","pos":""}],"OBERON":[{"def":"The king of the fairies, and husband of Titania or Queen Mab.","pos":""}],"OBERRATION":[{"def":"A wandering about.","pos":""}],"OBESE":[{"def":"Excessively corpulent; fat; fleshy.","pos":""}],"OBESENESS":[{"def":"Quality of being obese; obesity.","pos":""}],"OBESITY":[{"def":"The state or quality of being obese; incumbrance of flesh.","pos":"noun"}],"OBEY":[{"def":"To give ear to; to execute the commands of; to yield submission to; to comply with the orders of.","pos":""},{"def":"To submit to the authority of; to be ruled by.","pos":""}],"OBEYER":[{"def":"One who yields obedience.","pos":""}],"OBEYINGLY":[{"def":"Obediently; submissively.","pos":""},{"def":"To make firm; to harden in resolution.","pos":""}]}