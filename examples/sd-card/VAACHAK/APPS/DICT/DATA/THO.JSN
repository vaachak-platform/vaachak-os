{"THO":[{"def":"This knowen tho that be to wives bound.","pos":""}],"THOLE":[{"def":"A wooden or metal pin, set in the gunwale of a boat, to serve as a fulcrum for the oar in rowing.","pos":""},{"def":"The pin, or handle, of a scythe snath.","pos":""}],"THOMAS PROCESS":[{"def":"Same as Basic process, above.","pos":""},{"def":"The doctrine of Thomas Aquinas, esp.","pos":""}],"THOMIST":[{"def":"A follower of Thomas Aquinas.","pos":""}],"THOMSEN'S DISEASE":[{"def":"An affection apparently congenital, consisting in tonic contraction and stiffness of the voluntary muscles occurring after a period of muscular inaction.","pos":""}],"THOMSENOLITE":[{"def":"A fluoride of aluminium, calcium, and sodium occurring with the cryolite of Greenland.","pos":""}],"THOMSON PROCESS":[{"def":"A process of electric welding in which heat is developed by a large current passing through the metal.","pos":""}],"THOMSONIAN":[{"def":"Of or pertaining to Thomsonianism.","pos":""},{"def":"A believer in Thomsonianism; one who practices Thomsonianism.","pos":""}],"THOMSONIANISM":[{"def":"An empirical system which assumes that the human body is composed of four elements, earth, air, fire, and water, and that vegetable medicines alone should be used; -- from the founder, Dr.","pos":""}],"THOMSONITE":[{"def":"A zeolitic mineral, occurring generally in masses of a radiated structure.","pos":""}],"THONG":[{"def":"A strap of leather; especially, one used for fastening anything.","pos":""}],"THOOID":[{"def":"Of or pertaining to a group of carnivores, including the wovels and the dogs.","pos":""}],"THOR":[{"def":"The god of thunder, and son of Odin.","pos":""}],"THORACENTESIS":[{"def":"The operation of puncturing the chest wall so as to let out liquids contained in the cavity of the chest.","pos":""}],"THORACIC":[{"def":"Of or pertaining to the thorax, or chest.","pos":""}],"THORACICA":[{"def":"A division of cirripeds including those which have six thoracic segments, usually bearing six pairs of cirri.","pos":""}],"THORACOMETER":[{"def":"Same as Stethometer.","pos":""}],"THORACOPLASTY":[{"def":"A remodeling or reshaping of the thorax; especially, the operation of removing the ribs, so as to obliterate the pleural cavity in cases of empyema.","pos":""}],"THORACOTOMY":[{"def":"The operation of opening the pleural cavity by incision.","pos":""}],"THORAL":[{"def":"Of or pertaining to a bed.","pos":""}],"THORAX":[{"def":"The part of the trunk between the neck and the abdomen, containing that part of the body cavity the walls of which are supported by the dorsal vertebræ, the ribs, and the sternum, and which the heart and lungs are situated; the chest.","pos":""},{"def":"A breastplate, cuirass, or corselet; especially, the breastplate worn by the ancient Greeks.","pos":""}],"THORIA":[{"def":"A rare white earthy substance, consisting of the oxide of thorium; -- formerly called also thorina.","pos":""}],"THORIC":[{"def":"Of or pertaining to thorium; designating the compounds of thorium.","pos":""}],"THORITE":[{"def":"A mineral of a brown to black color, or, as in the variety orangite, orange-yellow.","pos":""}],"THORIUM":[{"def":"A metallic element found in certain rare minerals, as thorite, pyrochlore, monazite, etc.","pos":""}],"THORN":[{"def":"Any shrub or small tree which bears thorns; especially, any species of the genus Cratægus, as the hawthorn, whitethorn, cockspur thorn.","pos":""}],"THORN-HEADED":[{"def":"Having a head armed with thorns or spines.","pos":""}],"THORNBACK":[{"def":"A European skate (Raia clavata) having thornlike spines on its back.","pos":""},{"def":"The large European spider crab or king crab (Maia squinado).","pos":""}],"THORNBILL":[{"def":"Any one of several species of small, brilliantly colored American birds of the genus Rhamphomicron.","pos":""}],"THORNBIRD":[{"def":"A small South American bird (Anumbius anumbii) allied to the ovenbirds of the genus Furnarius).","pos":""}],"THORNLESS":[{"def":"Destitute of, or free from, thorns.","pos":""}],"THORNSET":[{"def":"Set with thorns.","pos":""}],"THORNTAIL":[{"def":"A beautiful South American humming bird (Gouldia Popelairii), having the six outer tail feathers long, slender, and pointed.","pos":""}],"THORNY":[{"def":"Full of thorns or spines; rough with thorns; spiny; as, a thorny wood; a thorny tree; a thorny crown.","pos":""},{"def":"Like a thorn or thorns; hence, figuratively, troublesome; vexatious; harassing; perplexing.","pos":""}],"THOROUGH":[{"def":"Passing through; as, thorough lights in a house.","pos":""},{"def":"Passing through or to the end; hence, complete; perfect; as, a thorough reformation; thorough work; a thorough translator; a thorough poet.","pos":""}],"THOROUGH BASS":[{"def":"The representation of chords by figures placed under the base; figured bass; basso continuo; -- sometimes used as synonymous with harmony.","pos":""}],"THOROUGH-BRACE":[{"def":"A leather strap supporting the body of a carriage, and attached to springs, or serving as a spring.","pos":""}],"THOROUGH-LIGHTED":[{"def":"Provided with thorough lights or windows at opposite sides, as a room or building.","pos":""}],"THOROUGHBRED":[{"def":"Bred from the best blood through a long line; pure-blooded; -- said of stock, as horses.","pos":""},{"def":"A thoroughbred animal, especially a horse.","pos":""}],"THOROUGHFARE":[{"def":"A passage through; a passage from one street or opening to another; an unobstructed way open to the public; a public road; hence, a frequented street.","pos":""},{"def":"A passing or going through; passage.","pos":""}],"THOROUGHGOING":[{"def":"Going through, or to the end or bottom; very thorough; complete.","pos":""},{"def":"Going all lengths; extreme; thoroughplaced; -- less common in this sense.","pos":""}],"THOROUGHLY":[{"def":"In a thorough manner; fully; entirely; completely.","pos":""}],"THOROUGHNESS":[{"def":"The quality or state of being thorough; completeness.","pos":""}],"THOROUGHPACED":[{"def":"Perfect in what is undertaken; complete; going all lengths; as, a thoroughplaced Tory or Whig.","pos":""}],"THOROUGHSPED":[{"def":"Fully accomplished; thoroughplaced.","pos":""}],"THOROUGHSTITCH":[{"def":"So as to go the whole length of any business; fully; completely.","pos":""}],"THOROUGHWORT":[{"def":"Same as Boneset.","pos":""}],"THOROW":[{"def":"A group of houses in the country; a small village; a hamlet; a dorp; -- now chiefly occurring in names of places and persons; as, Althorp, Mablethorpe.","pos":""}],"THOSE":[{"def":"The plural of that.","pos":""}],"THOTH":[{"def":"The god of eloquence and letters among the ancient Egyptians, and supposed to be the inventor of writing and philosophy.","pos":""},{"def":"The Egyptian sacred baboon.","pos":""}],"THOU":[{"def":"The second personal pronoun, in the singular number, denoting the person addressed; thyself; the pronoun which is used in addressing persons in the solemn or poetical style.","pos":""}],"THOUGH":[{"def":"Granting, admitting, or supposing that; notwithstanding that; if.","pos":""}],"THOUGHT":[{"def":"Thought, Defn: imp.","pos":""}],"THOUGHTFUL":[{"def":"Full of thought; employed in meditation; contemplative; as, a man of thoughtful mind.","pos":""},{"def":"Attentive; careful; exercising the judgment; having the mind directed to an object; as, thoughtful of gain; thoughtful in seeking truth.","pos":""}],"THOUGHTLESS":[{"def":"Lacking thought; careless; inconsiderate; rash; as, a thoughtless person, or act.","pos":""},{"def":"Giddy; gay; dissipated.","pos":""}],"THOUSAND":[{"def":"The number of ten hundred; a collection or sum consisting of ten times one hundred units or objects.","pos":""},{"def":"Hence, indefinitely, a great number.","pos":""}],"THOUSAND LEGS":[{"def":"A millepid, or galleyworm; -- called also thousand-legged worm.","pos":""}],"THOUSANDFOLD":[{"def":"Multiplied by a thousand.","pos":""}],"THOUSANDTH":[{"def":"Next in order after nine hundred and ninty-nine; coming last of a thousand successive individuals or units; -- the ordinal of thousand; as, the thousandth part of a thing.","pos":""},{"def":"Constituting, or being one of, a thousand equal parts into which anything is divided; the tenth of a hundredth.","pos":""}]}