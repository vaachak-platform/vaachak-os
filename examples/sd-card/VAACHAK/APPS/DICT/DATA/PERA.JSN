{"PERACT":[{"def":"To go through with; to perform.","pos":""}],"PERACUTE":[{"def":"Very sharp; very violent; as, a peracute fever.","pos":""}],"PERADVENTURE":[{"def":"By chance; perhaps; it may be; if; supposing.","pos":""}],"PERAEOPOD":[{"def":"One of the thoracic legs of a crustacean.","pos":""}],"PERAGRATE":[{"def":"To travel over or through.","pos":""}],"PERAGRATION":[{"def":"The act or state of passing through any space; as, the peragration of the moon in her monthly revolution.","pos":""}],"PERAMBULATE":[{"def":"To walk through or over; especially, to travel over for the purpose of surveying or examining; to inspect by traversing; specifically, to inspect officially the boundaries of, as of a town or parish, by walking over the whole line.","pos":""}],"PERAMBULATION":[{"def":"The act of perambulating; traversing.","pos":""},{"def":"An annual survey of boundaries, as of town, a parish, a forest, etc.","pos":""}],"PERAMBULATOR":[{"def":"One who perambulates.","pos":""},{"def":"A surveyor's instrument for measuring distances.","pos":""}],"PERAMELES":[{"def":"Any marsupial of the genus Perameles, which includes numerous species found in Australia.","pos":""}]}