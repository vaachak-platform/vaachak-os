{"RIM":[{"def":"The border, edge, or margin of a thing, usually of something circular or curving; as, the rim of a kettle or basin.","pos":""},{"def":"The lower part of the abdomen.","pos":""}],"RIM-FIRE":[{"def":"Having the percussion fulminate in a rim surrounding the base, distinguished from center-fire; -- said of cartridges; also, using rim-fire cartridges; as, a rim-fire gun.","pos":""}],"RIMA":[{"def":"A narrow and elongated aperture; a cleft; a fissure.","pos":""}],"RIMAU DAHAN":[{"def":"The clouded tiger cat (Felis marmorata) of Southern Asia and the East Indies.","pos":""}],"RIMBASE":[{"def":"A short cylinder connecting a trunnion with the body of a cannon.","pos":""}],"RIME":[{"def":"A rent or long aperture; a chink; a fissure; a crack.","pos":""}],"RIMER":[{"def":"A rhymer; a versifier.","pos":""}],"RIMEY":[{"def":"To compose in rhyme; to versify.","pos":""}],"RIMMER":[{"def":"An implement for cutting, trimming, or ornamenting the rim of anything, as the edges of pies, etc.","pos":""}],"RIMOSE":[{"def":"Having long and nearly parallel clefts or chinks, like those in the bark of trees.","pos":""}],"RIMOSELY":[{"def":"In a rimose manner.","pos":""}],"RIMOSITY":[{"def":"State of being rimose.","pos":""}],"RIMPLE":[{"def":"A fold or wrinkle.","pos":""}],"RIMY":[{"def":"Abounding with rime; frosty.","pos":""}]}