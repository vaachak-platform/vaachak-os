{"RAFF":[{"def":"To sweep, snatch, draw, or huddle together; to take by a promiscuous sweep.","pos":""}],"RAFFIA":[{"def":"A fibrous material used for tying plants, said to come from the leaves of a palm tree of the genus Raphia.","pos":""}],"RAFFINOSE":[{"def":"A colorless crystalline slightly sweet substance obtained from the molasses of the sugar beet.","pos":""}],"RAFFISH":[{"def":"Resembling, or having the character of, raff, or a raff; worthless; low.","pos":""}],"RAFFLE":[{"def":"A kind of lottery, in which several persons pay, in shares, the value of something put up as a stake, and then determine by chance (as by casting dice) which one of them shall become the sole possessor.","pos":""},{"def":"A game of dice in which he who threw three alike won all the stakes.","pos":""}],"RAFFLER":[{"def":"One who raffles.","pos":""}],"RAFFLESIA":[{"def":"A genus of stemless, leafless plants, living parasitically upon the roots and stems of grapevines in Malaysia.","pos":""}],"RAFT":[{"def":"A large collection of people or things taken indiscriminately.","pos":""}],"RAFTER":[{"def":"Originally, any rough and somewhat heavy piece of timber.","pos":""}],"RAFTING":[{"def":"The business of making or managing rafts.","pos":""}],"RAFTSMAN":[{"def":"A man engaged in rafting.","pos":""}]}