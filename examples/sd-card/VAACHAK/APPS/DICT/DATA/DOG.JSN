{"DOG":[{"def":"A quadruped of the genus Canis, esp.","pos":""},{"def":"One of the two constellations, Canis Major and Canis Minor, or the Greater Dog and the Lesser Dog.","pos":""}],"DOG BEE":[{"def":"A male or drone bee.","pos":""}],"DOG DAYS":[{"def":"A period of from four to six weeks, in the summer, variously placed by almanac makers between the early part of July and the early part of September; canicular days; -- so called in reference to the rising in ancient times of the Dog Star (Sirius) with the sun.","pos":""}],"DOG FANCIER":[{"def":"One who has an unusual fancy for, or interest in, dogs; also, one who deals in dogs.","pos":""}],"DOG STAR":[{"def":"Sirius, a star of the constellation Canis Major, or the Greater Dog, and the brightest star in the heavens; -- called also Canicula, and, in astronomical charts, a Canis Majoris.","pos":""}],"DOG'S-EAR":[{"def":"The corner of a leaf, in a book, turned down like the ear of a dog.","pos":""}],"DOG'S-TAIL GRASS":[{"def":"A hardy species of British grass (Cynosurus cristatus) which abounds in grass lands, and is well suited for making straw plait; -- called also goldseed.","pos":""}],"DOG-EARED":[{"def":"Having the corners of the leaves turned down and soiled by careless or long-continued usage; -- said of a book.","pos":""}],"DOG-FACED":[{"def":"Having a face resembling that of a dog.","pos":""}],"DOG-HEADED":[{"def":"Having a head shaped like that of a dog; -- said of certain baboons.","pos":""}],"DOG-LEGGED":[{"def":"Noting a flight of stairs, consisting of two or more straight portions connected by a platform (landing) or platforms, and running in opposite directions without an intervening wellhole.","pos":""}],"DOG-ROSE":[{"def":"A common European wild rose, with single pink or white flowers.","pos":""}],"DOG-WEARY":[{"def":"Extremely weary.","pos":""}],"DOGAL":[{"def":"Of or pertaining to a doge.","pos":""}],"DOGATE":[{"def":"The office or dignity of a doge.","pos":""}],"DOGBANE":[{"def":"A small genus of perennial herbaceous plants, with poisonous milky juice, bearing slender pods pods in pairs.","pos":""}],"DOGBERRY":[{"def":"The berry of the dogwood; -- called also dogcherry.","pos":""}],"DOGBOLT":[{"def":"The bolt of the cap-square over the trunnion of a cannon.","pos":""}],"DOGCART":[{"def":"A light one-horse carriage, commonly two-wheeled, patterned after a cart.","pos":""},{"def":"One of the dog days.","pos":""}],"DOGDRAW":[{"def":"The act of drawing after, or pursuing, deer with a dog.","pos":""}],"DOGE":[{"def":"The chief magistrate in the republics of Venice and Genoa.","pos":""}],"DOGFISH":[{"def":"A small shark, of many species, of the genera Mustelus, Scyllium, Spinax, etc.","pos":""},{"def":"The bowfin (Amia calva).","pos":""}],"DOGGED":[{"def":"Sullenly obstinate; obstinately determined or persistent; as, dogged resolution; dogged work.","pos":""}],"DOGGEDLY":[{"def":"In a dogged manner; sullenly; with obstinate resolution.","pos":""}],"DOGGEDNESS":[{"def":"Sullenness; moroseness.","pos":""},{"def":"Sullen or obstinate determination; grim resolution or persistence.","pos":""}],"DOGGER":[{"def":"A two-masted fishing vessel, used by the Dutch.","pos":""}],"DOGGEREL":[{"def":"Low in style, and irregular in measure; as, doggerel rhymes.","pos":""}],"DOGGERMAN":[{"def":"A sailor belonging to a dogger.","pos":""}],"DOGGISH":[{"def":"Like a dog; having the bad qualities of a dog; churlish; growling; brutal.","pos":""}],"DOGGREL":[{"def":"Same as Doggerel.","pos":""}],"DOGHOLE":[{"def":"A place fit only for dogs; a vile, mean habitation or apartment.","pos":""}],"DOGMA":[{"def":"That which is held as an opinion; a tenet; a doctrine.","pos":""},{"def":"A formally stated and authoritatively settled doctrine; a definite, established, and authoritative tenet.","pos":""}],"DOGMATIC":[{"def":"One of an ancient sect of physicians who went by general principles; -- opposed to the Empiric.","pos":""}],"DOGMATICALLY":[{"def":"In a dogmatic manner; positively; magisterially.","pos":""}],"DOGMATICALNESS":[{"def":"The quality of being dogmatical; positiveness.","pos":""}],"DOGMATICS":[{"def":"The science which treats of Christian doctrinal theology.","pos":""}],"DOGMATISM":[{"def":"The manner or character of a dogmatist; arrogance or positiveness in stating opinion.","pos":""}],"DOGMATIST":[{"def":"One who dogmatizes; one who speaks dogmatically; a bold and arrogant advancer of principles.","pos":""}],"DOGMATIZE":[{"def":"To assert positively; to teach magisterially or with bold and undue confidence; to advance with arrogance.","pos":""}],"DOGMATIZER":[{"def":"One who dogmatizes; a bold asserter; a magisterial teacher.","pos":""}],"DOGSHIP":[{"def":"The character, or individuality, of a dog.","pos":""}],"DOGSHORE":[{"def":"One of several shores used to hold a ship firmly and prevent her moving while the blocks are knocked away before launching.","pos":""}],"DOGSICK":[{"def":"Sick as a dog sometimes is very sick.","pos":""}],"DOGSKIN":[{"def":"The skin of a dog, or leather made of the skin.","pos":""}],"DOGSLEEP":[{"def":"The fitful naps taken when all hands are kept up by stress.","pos":""}],"DOGTOOTH":[{"def":"An ornament common in Gothic architecture, consisting of pointed projections resembling teeth; -- also called tooth ornament.","pos":""}],"DOGTRICK":[{"def":"A gentle trot, like that of a dog.","pos":""}],"DOGVANE":[{"def":"A small vane of bunting, feathers, or any other light material, carried at the masthead to indicate the direction of the wind.","pos":""}],"DOGWATCH":[{"def":"A half watch; a watch of two hours, of which there are two, the first dogwatch from 4 to 6 o'clock, p.","pos":""}],"DOGWOOD":[{"def":"The Cornus, a genus of large shrubs or small trees, the wood of which is exceedingly hard, and serviceable for many purposes.","pos":""}]}