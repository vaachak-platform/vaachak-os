{"MORN":[{"def":"The first part of the day; the morning; -- used chiefly in poetry.","pos":""}],"MORNE":[{"def":"Of or pertaining to the morn; morning.","pos":""}],"MORNING":[{"def":"Pertaining to the first part or early part of the day; being in the early part of the day; as, morning dew; morning light; morning service.","pos":""}],"MORNING-GLORY":[{"def":"A climbing plant (Ipomoea purpurea) having handsome, funnel- shaped flowers, usually red, pink, purple, white, or variegated, sometimes pale blue.","pos":""}],"MORNWARD":[{"def":"Towards the morn.","pos":""}]}