{"IVAN IVANOVITCH":[{"def":"I*van\" I*van\"o*vitch Defn: .","pos":""}],"IVIED":[{"def":"Overgrown with ivy.","pos":""}],"IVORIDE":[{"def":"A composition resembling ivory in appearance and used as a substitute for it.","pos":""}],"IVORY":[{"def":"Teeth; as, to show one's ivories.","pos":""}],"IVORY-BILL":[{"def":"A large, handsome, North American woodpecker (Campephilus principalis), having a large, sharp, ivory-colored beak.","pos":""}],"IVORYTYPE":[{"def":"A picture produced by superposing a very light print, rendered translucent by varnish, and tinted upon the back, upon a stronger print, so as to give the effect of a photograph in natural colors; -- called also hellenotype.","pos":""}],"IVY":[{"def":"A plant of the genus Hedera (H.","pos":""}],"IVY-MANTLED":[{"def":"Covered with ivy.","pos":""}]}