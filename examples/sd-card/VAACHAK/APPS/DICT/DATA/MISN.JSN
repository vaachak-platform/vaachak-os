{"MISNAME":[{"def":"To call by the wrong name; to give a wrong or inappropriate name to.","pos":""}],"MISNOMER":[{"def":"The misnaming of a person in a legal instrument, as in a complaint or indictment; any misnaming of a person or thing; a wrong or inapplicable name or title.","pos":""}],"MISNUMBER":[{"def":"To number wrongly.","pos":""}],"MISNURTURE":[{"def":"To nurture or train wrongly; as, to misnurture children.","pos":""}]}