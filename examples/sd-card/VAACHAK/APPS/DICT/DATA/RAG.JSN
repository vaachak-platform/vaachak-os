{"RAG":[{"def":"To scold or rail at; to rate; to tease; to torment; to banter.","pos":""}],"RAGAMUFFIN":[{"def":"The long-tailed titmouse.","pos":""}],"RAGE":[{"def":"Violent excitement; eager passion; extreme vehemence of desire, emotion, or suffering, mastering the will.","pos":""},{"def":"Especially, anger accompanied with raving; overmastering wrath; violent anger; fury.","pos":""}],"RAGEFUL":[{"def":"Full of rage; expressing rage.","pos":""}],"RAGGED":[{"def":"Rent or worn into tatters, or till the texture is broken; as, a ragged coat; a ragged sail.","pos":""},{"def":"Broken with rough edges; having jags; uneven; rough; jagged; as, ragged rocks.","pos":""}],"RAGHUVANSA":[{"def":"A celebrated Sanskrit poem having for its subject the Raghu dynasty.","pos":""}],"RAGIOUS":[{"def":"Raging; furious; rageful.","pos":""}],"RAGLAN":[{"def":"A loose overcoat with large sleeves; -- named from Lord Raglan, an English general.","pos":""}],"RAGMAN":[{"def":"A man who collects, or deals in, rags.","pos":""}],"RAGMAN'S ROLL":[{"def":"The rolls of deeds on parchment in which the Scottish nobility and gentry subscribed allegiance to Edward I.","pos":""},{"def":"The so-called \"Twilight of the Gods\" (called in German Götterdämmerung), the final destruction of the world in the great conflict between the Æsir (gods) on the one hand, and on the other, the gaints and the powers of Hel under the leadership of Loki (who is escaped from bondage).","pos":""}],"RAGOUT":[{"def":"A dish made of pieces of meat, stewed, and highly seasoned; as, a ragout of mutton.","pos":""}],"RAGPICKER":[{"def":"One who gets a living by picking up rags and refuse things in the streets.","pos":""}],"RAGTIME":[{"def":"Time characterized by syncopation, as in many negro melodies.","pos":""},{"def":"Notched in regular diagonal breaks; -- said of a line, or a bearing having such an edge.","pos":""}],"RAGWEED":[{"def":"A common American composite weed (Ambrosia artemisiæfolia) with finely divided leaves; hogweed.","pos":""}],"RAGWORK":[{"def":"A kind of rubblework.","pos":""}],"RAGWORT":[{"def":"A name given to several species of the composite genus Senecio.","pos":""}]}