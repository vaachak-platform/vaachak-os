{"OBCOMPRESSED":[{"def":"Compressed or flattened antero-posteriorly, or in a way opposite to the usual one.","pos":""},{"def":"Conical, but having the apex downward; inversely conical.","pos":""}],"OBCORDATE":[{"def":"Heart-shaped, with the attachment at the pointed end; inversely cordate: as, an obcordate petal or leaf.","pos":""}]}