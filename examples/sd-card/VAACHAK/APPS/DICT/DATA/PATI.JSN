{"PATIBLE":[{"def":"Sufferable; tolerable; endurable.","pos":""}],"PATIBULARY":[{"def":"Of or pertaining to the gallows, or to execution.","pos":""}],"PATIBULATED":[{"def":"Hanged on a gallows.","pos":""}],"PATIENCE":[{"def":"A kind of dock (Rumex Patientia), less common in America than in Europe; monk's rhubarb.","pos":""}],"PATIENT":[{"def":"Having the quality of enduring; physically able to suffer or bear.","pos":""},{"def":"Undergoing pains, trails, or the like, without murmuring or fretfulness; bearing up with equanimity against trouble; long- suffering.","pos":""}],"PATIENTLY":[{"def":"In a patient manner.","pos":""}],"PATINA":[{"def":"The color or incrustation which age gives to works of art; especially, the green rust which covers ancient bronzes, coins, and medals.","pos":""}],"PATIO":[{"def":"A paved yard or floor where ores are cleaned and sorted, or where ore, salt, mercury, etc.","pos":""}]}