{"SOLVABILITY":[{"def":"The quality or state of being solvable; as, the solvability of a difficulty; the solvability of a problem.","pos":""},{"def":"The condition of being solvent; ability to pay all just debts; solvency; as, the solvability of a merchant.","pos":""}],"SOLVABLE":[{"def":"Susceptible of being solved, resolved, or explained; admitting of solution.","pos":""},{"def":"Capable of being paid and discharged; as, solvable obligations.","pos":""}],"SOLVABLENESS":[{"def":"Quality of being solvable.","pos":""}],"SOLVE":[{"def":"To explain; to resolve; to unfold; to clear up out to a result or conclusion; as, to solve a doubt; to solve difficulties; to solve a problem.","pos":""}],"SOLVENCY":[{"def":"The quality or state of being solvent.","pos":""}],"SOLVEND":[{"def":"A substance to be dissolved.","pos":""}],"SOLVENT":[{"def":"Having the power of dissolving; dissolving; as, a solvent fluid.","pos":""},{"def":"Able or sufficient to pay all just debts; as, a solvent merchant; the estate is solvent.","pos":""}],"SOLVER":[{"def":"One who, or that which, solves.","pos":""}]}