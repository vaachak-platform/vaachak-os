{"QUIESCE":[{"def":"To be silent, as a letter; to have no sound.","pos":""},{"def":"The state or quality of being quiescent.","pos":""}],"QUIESCENT":[{"def":"Not sounded; silent; as, y is quiescent in \"day\" and \"say.","pos":""}],"QUIESCENTLY":[{"def":"In a quiescent manner.","pos":""}],"QUIET":[{"def":"In a state of rest or calm; without stir, motion, or agitation; still; as, a quiet sea; quiet air.","pos":""},{"def":"Free from noise or disturbance; hushed; still.","pos":""}],"QUIETER":[{"def":"One who, or that which, quiets.","pos":""}],"QUIETISM":[{"def":"The system of the Quietists, who maintained that religion consists in the withdrawal of the mind from worldly interests and anxieties and its constant employment in the passive contemplation of God and his attributes.","pos":""}],"QUIETIST":[{"def":"One of a sect of mystics originated in the seventeenth century by Molinos, a Spanish priest living in Rome.","pos":""}],"QUIETISTIC":[{"def":"Of or pertaining to the Quietists, or to Quietism.","pos":""}],"QUIETLY":[{"def":"In a quiet state or manner; without motion; in a state of rest; as, to lie or sit quietly.","pos":""},{"def":"Without tumult, alarm, dispute, or disturbance; peaceably; as, to live quietly; to sleep quietly.","pos":""}],"QUIETNESS":[{"def":"The quality or state of being quiet; freedom from noise, agitation, disturbance, or excitement; stillness; tranquillity; calmness.","pos":""}],"QUIETUDE":[{"def":"Rest; repose; quiet; tranquillity.","pos":""}],"QUIETUS":[{"def":"Final discharge or acquittance, as from debt or obligation; that which silences claims; (Fig.","pos":""}]}