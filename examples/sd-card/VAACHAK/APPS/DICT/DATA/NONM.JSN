{"NONMALIGNANT":[{"def":"Not malignant, as a disease.","pos":""}],"NONMANUFACTURING":[{"def":"Not carrying on manufactures.","pos":""}],"NONMEDULLATED":[{"def":"Not medullated; (Anat.","pos":""}],"NONMEMBER":[{"def":"One who is not a member.","pos":""}],"NONMEMBERSHIP":[{"def":"State of not being a member.","pos":""}],"NONMETAL":[{"def":"Any one of the set of elements which, as contrasted with the metals, possess, produce, or receive, acid rather than basic properties; a metalloid; as, oxygen, sulphur, and chlorine are nonmetals.","pos":""}],"NONMETALLIC":[{"def":"Resembling, or possessing the properties of, a nonmetal or metalloid; as, sulphur is a nonmetallic element.","pos":""}],"NONMORAL":[{"def":"Not moral nor immoral; having no connection with morals; not in the sphere of morals or ethics; not ethical.","pos":""}]}