{"WEB":[{"def":"A band of webbing used to regulate the extension of the hood.","pos":""},{"def":"A plate or thin portion, continuous or perforated, connecting stiffening ribs or flanges, or other parts of an object.","pos":""}],"WEB-FINGERED":[{"def":"Having the fingers united by a web for a considerable part of their length.","pos":""}],"WEB-FOOTED":[{"def":"Having webbed feet; palmiped; as, a goose or a duck is a web- footed fowl.","pos":""}],"WEB-TOED":[{"def":"Having the toes united by a web for a considerable part of their length.","pos":""}],"WEBBED":[{"def":"Having the toes united by a membrane, or web; as, the webbed feet of aquatic fowls.","pos":""}],"WEBBER":[{"def":"One who forms webs; a weaver; a webster.","pos":""}],"WEBBING":[{"def":"A woven band of cotton or flax, used for reins, girths, bed bottoms, etc.","pos":""}],"WEBBY":[{"def":"Of or pertaining to a web or webs; like a web; filled or covered with webs.","pos":""}],"WEBER":[{"def":"The standard unit of electrical quantity, and also of current.","pos":""}],"WEBFOOT":[{"def":"Any web-footed bird.","pos":""}],"WEBSTER":[{"def":"A weaver; originally, a female weaver.","pos":""}],"WEBSTERITE":[{"def":"A hydrous sulphate of alumina occurring in white reniform masses.","pos":""}],"WEBWORM":[{"def":"Any one of various species of moths whose gregarious larvæ eat the leaves of trees, and construct a large web to which they retreat when not feeding.","pos":""}]}