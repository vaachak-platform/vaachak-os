{"STEM":[{"def":"A curved piece of timber to which the two sides of a ship are united at the fore end.","pos":""},{"def":"That part of a plant which bears leaves, or rudiments of leaves, whether rising above ground or wholly subterranean.","pos":""}],"STEM-CLASPING":[{"def":"Embracing the stem with its base; amplexicaul; as a leaf or petiole.","pos":""}],"STEM-WINDER":[{"def":"A stem-winding watch.","pos":""}],"STEM-WINDING":[{"def":"Wound by mechanism connected with the stem; as, a stem-winding watch.","pos":""}],"STEMLESS":[{"def":"Having no stem; (Bot.","pos":""}],"STEMLET":[{"def":"A small or young stem.","pos":""}],"STEMMER":[{"def":"One who, or that which, stems (in any of the senses of the verbs).","pos":""}],"STEMMERY":[{"def":"A large building in which tobacco is stemmed.","pos":""}],"STEMMY":[{"def":"Abounding in stems, or mixed with stems; -- said of tea, dried currants, etc.","pos":""}],"STEMPLE":[{"def":"A crossbar of wood in a shaft, serving as a step.","pos":""}],"STEMSON":[{"def":"A piece of curved timber bolted to the stem, keelson, and apron in a ship's frame near the bow.","pos":""}]}