{"URIC":[{"def":"Of or pertaining to urine; obtained from urine; as, uric acid.","pos":""}],"URIM":[{"def":"A part or decoration of the breastplate of the high priest among the ancient Jews, by which Jehovah revealed his will on certain occasions.","pos":""}],"URINAL":[{"def":"A vessel for holding urine; especially, a bottle or tube for holding urine for inspection.","pos":""},{"def":"A place or convenience for urinating purposes.","pos":""}],"URINARIUM":[{"def":"A reservoir for urine, etc.","pos":""}],"URINARY":[{"def":"Of or pertaining to the urine; as, the urinary bladder; urinary excretions.","pos":""},{"def":"Resembling, or being of the nature of, urine.","pos":""}],"URINATE":[{"def":"To discharge urine; to make water.","pos":""}],"URINATION":[{"def":"The act or process of voiding urine; micturition.","pos":""}],"URINATIVE":[{"def":"Provoking the flow of urine; uretic; diuretic.","pos":""}],"URINATOR":[{"def":"One who dives under water in search of something, as for pearls; a diver.","pos":""}],"URINE":[{"def":"In mammals, a fluid excretion from the kidneys; in birds and reptiles, a solid or semisolid excretion.","pos":""}],"URINIFEROUS":[{"def":"Bearing or conveying urine; as, uriniferous tubules.","pos":""}],"URINIPAROUS":[{"def":"Producing or preparing urine; as, the uriniparous tubes in the cortical portion of the kidney.","pos":""}],"URINOGENITAL":[{"def":"Pertaining to the urinary and genital organs; genitourinary; urogenital; as, the urinogenital canal.","pos":""}],"URINOMETER":[{"def":"A small hydrometer for determining the specific gravity of urine.","pos":""}],"URINOMETRY":[{"def":"The estimation of the specific gravity of urine by the urinometer.","pos":""},{"def":"Of or pertaining to urine, or partaking of its qualities; having the character or odor of urine; similar to urine.","pos":""}],"URITE":[{"def":"One of the segments of the abdomen or post-abdomen of arthropods.","pos":""}],"URITH":[{"def":"The bindings of a hedge.","pos":""}]}