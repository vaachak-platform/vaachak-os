{"NAP":[{"def":"To have a short sleep; to be drowsy; to doze.","pos":""},{"def":"To be in a careless, secure state.","pos":""}],"NAP-TAKING":[{"def":"A taking by surprise; an unexpected onset or attack.","pos":""}],"NAPE":[{"def":"The back part of the neck.","pos":""}],"NAPE-CREST":[{"def":"An African bird of the genus Schizorhis, related to the plantain eaters.","pos":""}],"NAPERY":[{"def":"Table linen; also, linen clothing, or linen in general.","pos":""}],"NAPHA WATER":[{"def":"A perfume distilled from orange flowers.","pos":""}],"NAPHTHA":[{"def":"The complex mixture of volatile, liquid, inflammable hydrocarbons, occurring naturally, and usually called crude petroleum, mineral oil, or rock oil.","pos":""},{"def":"One of several volatile inflammable liquids obtained by the distillation of certain carbonaceous materials and resembling the naphtha from petroleum; as, Boghead naphtha, from Boghead coal (obtained at Boghead, Scotland); crude naphtha, or light oil, from coal tar; wood naphtha, from wood, etc.","pos":""}],"NAPHTHALATE":[{"def":"A salt of naphthalic acid; a phthalate.","pos":""}],"NAPHTHALENE":[{"def":"A white crystalline aromatic hydrocarbon, C10H8, analogous to benzene, and obtained by the distillation of certain bituminous materials, such as the heavy oil of coal tar.","pos":""}],"NAPHTHALENIC":[{"def":"Pertaining to , or derived from, naphthalene; -- used specifically to designate a yellow crystalline substance, called naphthalenic acid and also hydroxy quinone, and obtained from certain derivatives of naphthol.","pos":""}],"NAPHTHALIDINE":[{"def":"Same as Naphthylamine.","pos":""},{"def":"See Naphthalene.","pos":""}],"NAPHTHALIZE":[{"def":"To mingle, saturate, or impregnate, with naphtha.","pos":""}],"NAPHTHAZARIN":[{"def":"A dyestuff, resembling alizarin, obtained from naphthoquinone as a red crystalline substance with a bright green, metallic luster; -- called also naphthalizarin.","pos":""}],"NAPHTHENE":[{"def":"A peculiar hydrocarbon occuring as an ingredient of Caucasian petroleum.","pos":""}],"NAPHTHIDE":[{"def":"A compound of naphthalene or its radical with a metallic element; as, mercuric naphthide.","pos":""}],"NAPHTHOIC":[{"def":"Pertaining to, derived from, or related to, naphthalene; -- used specifically to designate any one of a series of carboxyl derivatives, called naphthoic acids.","pos":""}],"NAPHTHOL":[{"def":"Any one of a series of hydroxyl derivatives of naphthalene, analogous to phenol.","pos":""}],"NAPHTHOQUINONE":[{"def":"A yellow crystalline substance, C10H6O2, analogous to quinone, obtained by oxidizing naphthalene with chromic acid.","pos":""}],"NAPHTHYL":[{"def":"A hydrocarbon radical regarded as the essential residue of naphthalene.","pos":""}],"NAPHTHYLAMINE":[{"def":"One of two basic amido derivatives of naphthalene, C10H7.","pos":""},{"def":"Of, pertaining to, or discovered by, Napier, or Naper.","pos":""}],"NAPIFORM":[{"def":"Turnip-shaped; large and round in the upper part, and very slender below.","pos":""}],"NAPKIN":[{"def":"A little towel, or small cloth, esp.","pos":""}],"NAPLES YELLOW":[{"def":"See under Yellow.","pos":""}],"NAPLESS":[{"def":"Without nap; threadbare.","pos":""}],"NAPOLEON":[{"def":"A French gold coin of twenty francs, or about $3.","pos":""}],"NAPOLEONIC":[{"def":"Of or pertaining to Napoleon I.","pos":""}],"NAPOLEONIST":[{"def":"A supporter of the dynasty of the Napoleons.","pos":""}],"NAPPE":[{"def":"Sheet; surface; all that portion of a surface that is continuous in such a way that it is possible to pass from any one point of the portion to any other point of the portion without leaving the surface.","pos":""}],"NAPPINESS":[{"def":"The quality of having a nap; abundance of nap, as on cloth.","pos":""}],"NAPPING":[{"def":"A sheet of partially felted fur before it is united to the hat body.","pos":""}],"NAPPY":[{"def":"Inclined to sleep; sleepy; as, to feel nappy.","pos":""},{"def":"Tending to cause sleepiness; serving to make sleepy; strong; heady; as, nappy ale.","pos":""}],"NAPU":[{"def":"A very small chevrotain (Tragulus Javanicus), native of Java.","pos":""}],"NAPUS":[{"def":"A kind of turnip.","pos":""}]}