{"SALMAGUNDI":[{"def":"A mixture of chopped meat and pickled herring, with oil, vinegar, pepper, and onions.","pos":""},{"def":"Hence, a mixture of various ingredients; an olio or medley; a potpourri; a miscellany.","pos":""}],"SALMIS":[{"def":"A ragout or partky roasted game stewed with sauce, wine, bread, and condiments suited to provoke appetite.","pos":""}],"SALMON":[{"def":"Any one of several species of fishes of the genus Salmo and allied genera.","pos":""}],"SALMONET":[{"def":"A salmon of small size; a samlet.","pos":""}],"SALMONOID":[{"def":"Like, or pertaining to, the Salmonidæ, a family of fishes including the trout and salmon.","pos":""},{"def":"Any fish of the family Salmonidæ.","pos":""}]}