{"ESPADON":[{"def":"A long, heavy, two-handed and two-edged sword, formerly used by Spanish foot soldiers and by executioners.","pos":""}],"ESPALIER":[{"def":"A railing or trellis upon which fruit trees or shrubs are trained, as upon a wall; a tree or row of trees so trained.","pos":""}],"ESPARCET":[{"def":"The common sainfoin (Onobrychis sativa), an Old World leguminous forage plant.","pos":""}],"ESPARTO":[{"def":"A species of Spanish grass (Macrochloa tenacissima), of which cordage, shoes, baskets, etc.","pos":""}],"ESPAULIERE":[{"def":"A defense for the shoulder, composed of flexible overlapping plates of metal, used in the 15th century; -- the origin of the modern epaulette.","pos":""}],"ESPECIAL":[{"def":"Distinguished among others of the same class or kind; special; concerning a species or a single object; principal; particular; as, in an especial manner or degree.","pos":""}],"ESPECIALLY":[{"def":"In an especial manner; chiefly; particularly; peculiarly; in an uncommon degree.","pos":""}],"ESPECIALNESS":[{"def":"The state of being especial.","pos":""}],"ESPERANTO":[{"def":"An artificial language, intended to be universal, devised by Dr.","pos":""}],"ESPIAL":[{"def":"The act of espying; notice; discovery.","pos":""},{"def":"One who espies; a spy; a scout.","pos":""}],"ESPIONAGE":[{"def":"The practice or employment of spies; the practice of watching the words and conduct of others, to make discoveries, as spies or secret emissaries; secret watching.","pos":""}],"ESPLANADE":[{"def":"A grass plat; a lawn.","pos":""}],"ESPLEES":[{"def":"The full profits or products which ground or land yields, as the hay of the meadows, the feed of the pasture, the grain of arable fields, the rents, services, and the like.","pos":""}],"ESPOUSAL":[{"def":"The act of espousing or betrothing; especially, in the plural, betrothal; plighting of the troths; a contract of marriage; sometimes, the marriage ceremony.","pos":""},{"def":"The uniting or allying one's self with anything; maintenance; adoption; as, the espousal of a quarrel.","pos":""}],"ESPOUSE":[{"def":"To betroth; to promise in marriage; to give as spouse.","pos":""},{"def":"To take as spouse; to take to wife; to marry.","pos":""}],"ESPOUSEMENT":[{"def":"The act of espousing, or the state of being espoused.","pos":""}],"ESPOUSER":[{"def":"One who espouses; one who embraces the cause of another or makes it his own.","pos":""}],"ESPRESSIVO":[{"def":"With expression.","pos":""}],"ESPRINGAL":[{"def":"An engine of war used for throwing viretons, large stones, and other missiles; a springal.","pos":""}],"ESPY":[{"def":"To catch sight of; to perceive with the eyes; to discover, as a distant object partly concealed, or not obvious to notice; to see at a glance; to discern unexpectedly; to spy; as, to espy land; to espy a man in a crowd.","pos":""},{"def":"To inspect narrowly; to examine and keep watch upon; to watch; to observe.","pos":""}]}