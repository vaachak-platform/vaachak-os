{"CORRADE":[{"def":"To erode, as the bed of a stream.","pos":""}],"CORRADIAL":[{"def":"Radiating to or from the same point.","pos":""}],"CORRADIATE":[{"def":"To converge to one point or focus, as light or rays.","pos":""}],"CORRADIATION":[{"def":"A conjunction or concentration of rays in one point.","pos":""}],"CORRAL":[{"def":"A pen for animals; esp.","pos":""}],"CORRASION":[{"def":"The erosion of the bed of a stream by running water, principally by attrition of the detritus carried along by the stream, but also by the solvent action of the water.","pos":""}],"CORRASIVE":[{"def":"Corrasive sores which eat into the flesh.","pos":""}],"CORRECT":[{"def":"Set right, or made straight; hence, conformable to truth, rectitude, or propriety, or to a just standard; nnot faulty or imperfect; free from error; as, correct behavior; correct views.","pos":""}],"CORRECTIFY":[{"def":"Cor*rect\"i*fy (kr-rk\"t-f), v.","pos":""}],"CORRECTION":[{"def":"The act of correcting, or making that right which was wrong; change for the better; amendment; rectification, as of an erroneous statement.","pos":""},{"def":"The act of reproving or punishing, or that which is intended to rectify or to cure faults; punishment; discipline; chastisement.","pos":""}],"CORRECTIONAL":[{"def":"Tending to, or intended for, correction; used for correction; as, a correctional institution.","pos":""}],"CORRECTIONER":[{"def":"One who is, or who has been, in the house of correction.","pos":""}],"CORRECTIVE":[{"def":"Having the power to correct; tending to rectify; as, corrective penalties.","pos":""},{"def":"Qualifying; limiting.","pos":""}],"CORRECTLY":[{"def":"In a correct manner; exactly; acurately; without fault or error.","pos":""}],"CORRECTNESS":[{"def":"The state or quality of being correct; as, the correctness of opinions or of manners; correctness of taste; correctness in writing or speaking; the correctness of a text or copy.","pos":""}],"CORRECTOR":[{"def":"One who, or that which, corrects; as, a corrector of abuses; a corrector of the press; an alkali is a corrector of acids.","pos":""}],"CORRECTORY":[{"def":"Containing or making correction; corrective.","pos":""}],"CORRECTRESS":[{"def":"A woman who corrects.","pos":""}],"CORREGIDOR":[{"def":"The chief magistrate of a Spanish town.","pos":""}],"CORREI":[{"def":"A hollow in the side of a hill, where game usually lies.","pos":""}],"CORRELATABLE":[{"def":"Such as can be correlated; as, correlatable phenomena.","pos":""}],"CORRELATE":[{"def":"To have reciprocal or mutual relations; to be mutually related.","pos":""}],"CORRELATION":[{"def":"Reciprocal relation; corresponding similarity or parallelism of relation or law; capacity of being converted into, or of giving place to, one another, under certain conditions; as, the correlation of forces, or of zymotic diseases.","pos":""}],"CORRELATIVE":[{"def":"Having or indicating a reciprocal relation.","pos":""}],"CORRELATIVELY":[{"def":"In a correlative relation.","pos":""}],"CORRELATIVENESS":[{"def":"Quality of being correlative.","pos":""}],"CORRELIGIONIST":[{"def":"Cor`re*li\"gion*ist (kr`r-lj\"n-st), n.","pos":""}],"CORREPTION":[{"def":"Chiding; reproof; reproach.","pos":""}],"CORRESPOND":[{"def":"To be like something else in the dimensions and arrangement of its parts; -- followed by with or to; as, concurring figures correspond with each other throughout.","pos":""},{"def":"To be adapted; to be congruous; to suit; to agree; to fit; to answer; -- followed by to.","pos":""}],"CORRESPONDENCE":[{"def":"Friendly intercourse; reciprocal exchange of civilities; especially, intercourse between persons by means of letters.","pos":""},{"def":"The letters which pass between correspondents.","pos":""}],"CORRESPONDENCE SCHOOL":[{"def":"A school that teaches by correspondence, the instruction being based on printed instruction sheets and the recitation papers written by the student in answer to the questions or requirements of these sheets.","pos":""}],"CORRESPONDENCY":[{"def":"Same as Correspondence, 3.","pos":""}],"CORRESPONDENT":[{"def":"Suitable; adapted; fit; corresponding; congruous; conformable; in accord or agreement; obedient; willing.","pos":""}],"CORRESPONDENTLY":[{"def":"In a a corresponding manner; conformably; suitably.","pos":""}],"CORRESPONDING":[{"def":"Answering; conformable; agreeing; suiting; as, corresponding numbers.","pos":""},{"def":"Carrying on intercourse by letters.","pos":""}],"CORRESPONDINGLY":[{"def":"In a corresponding manner; conformably.","pos":""}],"CORRESPONSIVE":[{"def":"Corresponding; conformable; adapted.","pos":""}],"CORRIDOR":[{"def":"A gallery or passageway leading to several apartments of a house.","pos":""},{"def":"The covered way lying round the whole compass of the fortifications of a place.","pos":""}],"CORRIDOR TRAIN":[{"def":"A train whose coaches are connected so as to have through its entire length a continuous corridor, into which the compartments open.","pos":""}],"CORRIGENDUM":[{"def":"A fault or error to be corrected.","pos":""}],"CORRIGENT":[{"def":"A substance added to a medicine to mollify or modify its action.","pos":""}],"CORRIGIBILITY":[{"def":"Quality of being corrigible; capability of being corrected; corrigibleness.","pos":""}],"CORRIGIBLE":[{"def":"Capable of being set right, amended, or reformed; as, a corrigible fault.","pos":""},{"def":"Submissive to correction; docile.","pos":""}],"CORRIGIBLENESS":[{"def":"The state or quality of being corrigible; corrigibility.","pos":""}],"CORRIVAL":[{"def":"A fellow rival; a competitor; a rival; also, a companion.","pos":""}],"CORRIVALRY":[{"def":"Cor*ri\"val*ry (kr-r\"val-r), n.","pos":""}],"CORRIVALSHIP":[{"def":"By the corrivalship of Shager his false friend.","pos":""}],"CORRIVATE":[{"def":"To cause to flow together, as water drawn from several streams.","pos":""}],"CORRIVATION":[{"def":"The flowing of different streams into one.","pos":""}],"CORROBORANT":[{"def":"Strengthening; supporting; corroborating.","pos":""},{"def":"Anything which gives strength or support; a tonic.","pos":""}],"CORROBORATE":[{"def":"To make strong, or to give additional strength to; to strengthen.","pos":""},{"def":"To make more certain; to confirm; to establish.","pos":""}],"CORROBORATION":[{"def":"The act of corroborating, strengthening, or confirming; addition of strength; confirmation; as, the corroboration of an argument, or of information.","pos":""},{"def":"That which corroborates.","pos":""}],"CORROBORATIVE":[{"def":"Tending to strengthen of confirm.","pos":""}],"CORROBORATORY":[{"def":"Tending to strengthen; corroborative; as, corroboratory facts.","pos":""}],"CORROBOREE":[{"def":"A nocturnal festivity with which the Australian aborigines celebrate tribal events of importance.","pos":""},{"def":"A song or chant made for such a festivity.","pos":""}],"CORRODE":[{"def":"To eat away by degrees; to wear away or diminish by gradually separating or destroying small particles of, as by action of a strong acid or a caustic alkali.","pos":""},{"def":"To consume; to wear away; to prey upon; to impair.","pos":""}],"CORRODENT":[{"def":"Cor*rod\"ent (kr-r\"dent), a.","pos":""}],"CORRODIATE":[{"def":"To eat away by degrees; to corrode.","pos":""}],"CORRODIBILITY":[{"def":"The qualityof being corrodible.","pos":""}],"CORRODIBLE":[{"def":"Capable of being corroded; corrosible.","pos":""}],"CORROSIBILITY":[{"def":"Cor*ro`si*bil\"i*ty (kr-r`s-bl\"-t), n.","pos":""}],"CORROSIBLE":[{"def":"Cor*ro\"si*ble (kr-r\"s-b'l), a.","pos":""}],"CORROSIBLENESS":[{"def":"The quality or state of being corrosible.","pos":""}],"CORROSION":[{"def":"The action or effect of corrosive agents, or the process of corrosive change; as, the rusting of iron is a variety of corrosion.","pos":""}],"CORROSIVE":[{"def":"Eating away; having the power of gradually wearing, changing, or destroying the texture or substance of a body; as, the corrosive action of an acid.","pos":""},{"def":"Having the quality of fretting or vexing.","pos":""}],"CORROVAL":[{"def":"A dark brown substance of vegetable origin, allied to curare, and used by the natives of New Granada as an arrow poison.","pos":""}],"CORROVALINE":[{"def":"A poisonous alkaloid extracted from corroval, and characterized by its immediate action in paralyzing the heart.","pos":""}],"CORRUGANT":[{"def":"Having the power of contracting into wrinkles.","pos":""}],"CORRUGATE":[{"def":"Wrinkled; crumpled; furrowed; contracted into ridges and furrows.","pos":""}],"CORRUGATION":[{"def":"The act corrugating; contraction into wrinkles or alternate ridges and grooves.","pos":""}],"CORRUGATOR":[{"def":"A muscle which contracts the skin of the forehead into wrinkles.","pos":""}],"CORRUGENT":[{"def":"Drawing together; contracting; -- said of the corrugator.","pos":""}],"CORRUMP":[{"def":"Cor*rump\" (kr-rmp\"), v.","pos":""}],"CORRUMPABLE":[{"def":"Cor*rump\"a*ble (--b'l), a.","pos":""}],"CORRUPT":[{"def":"Changed from a sound to a putrid state; spoiled; tainted; vitiated; unsound.","pos":""},{"def":"Changed from a state of uprightness, correctness, truth, etc.","pos":""}],"CORRUPTER":[{"def":"One who corrupts; one who vitiates or taints; as, a corrupter of morals.","pos":""}],"CORRUPTFUL":[{"def":"Tending to corrupt; full of corruption.","pos":""}],"CORRUPTIBILITY":[{"def":"The quality of being corruptible; the possibility or liability of being corrupted; corruptibleness.","pos":""}],"CORRUPTIBLE":[{"def":"Capable of being made corrupt; subject to decay.","pos":""},{"def":"Capable of being corrupted, or morally vitiated; susceptible of depravation.","pos":""}],"CORRUPTINGLY":[{"def":"In a manner that corrupts.","pos":""}],"CORRUPTION":[{"def":"The act of corrupting or making putrid, or state of being corrupt or putrid; decomposition or disorganization, in the process of putrefaction; putrefaction; deterioration.","pos":""},{"def":"The product of corruption; putrid matter.","pos":""}],"CORRUPTIONIST":[{"def":"One who corrupts, or who upholds corruption.","pos":""}],"CORRUPTIVE":[{"def":"Having the quality of taining or vitiating; tending to produce corruption.","pos":""}],"CORRUPTLESS":[{"def":"Not susceptible of corruption or decay; incorruptible.","pos":""}],"CORRUPTLY":[{"def":"In a corrupt manner; by means of corruption or corrupting influences; wronfully.","pos":""}],"CORRUPTNESS":[{"def":"The quality of being corrupt.","pos":""}],"CORRUPTRESS":[{"def":"A woman who corrupts.","pos":""}]}