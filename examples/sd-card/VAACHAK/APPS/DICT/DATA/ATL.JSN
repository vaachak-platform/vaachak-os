{"ATLANTA":[{"def":"A genus of small glassy heteropod mollusks found swimming at the surface in mid ocean.","pos":""}],"ATLANTEAN":[{"def":"Of or pertaining to the isle Atlantis, which the ancients allege was sunk, and overwhelmed by the ocean.","pos":""},{"def":"Pertaining to, or resembling, Atlas; strong.","pos":""}],"ATLANTES":[{"def":"Figures or half figures of men, used as columns to support an entablature; -- called also telamones.","pos":""}],"ATLANTIC":[{"def":"Of or pertaining to Mt.","pos":""},{"def":"Of or pertaining to the isle of Atlantis.","pos":""}],"ATLANTIDES":[{"def":"The Pleiades or seven stars, fabled to have been the daughters of Atlas.","pos":""}],"ATLAS":[{"def":"The first vertebra of the neck, articulating immediately with the skull, thus sustaining the globe of the head, whence the name.","pos":""}],"ATLAS POWDER":[{"def":"A blasting powder or dynamite composed of nitroglycerin, wood fiber, sodium nitrate, and magnesium carbonate.","pos":""}]}