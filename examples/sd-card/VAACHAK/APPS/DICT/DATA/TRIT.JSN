{"TRITE":[{"def":"Worn out; common; used until so common as to have lost novelty and interest; hackneyed; stale; as, a trite remark; a trite subject.","pos":""}],"TRITERNATE":[{"def":"Three times ternate; -- applied to a leaf whose petiole separates into three branches, each of which divides into three parts which each bear three leafiets.","pos":""}],"TRITHEISM":[{"def":"The opinion or doctrine that the Father, Son, and Holy Spirit are three distinct Gods.","pos":""}],"TRITHEIST":[{"def":"One who believes in tritheism.","pos":""},{"def":"Of or pertaining to tritheism.","pos":""}],"TRITHING":[{"def":"One of three ancient divisions of a county in England; -- now called riding.","pos":""}],"TRITHIONATE":[{"def":"A salt of trithionic acid.","pos":""}],"TRITHIONIC":[{"def":"Of or pertaining to, or designating, a certain thionic acid, H2S3O6 which is obtained as a colorless, odorless liquid.","pos":""}],"TRITICIN":[{"def":"A carbohydrate isomeric with dextrin, obtained from quitch grass (Agropyrum, formerly Triticum, repens) as a white amorphous substance.","pos":""}],"TRITICUM":[{"def":"A genus of grasses including the various species of wheat.","pos":""}],"TRITON":[{"def":"A fabled sea demigod, the son of Neptune and Amphitrite, and the trumpeter of Neptune.","pos":""},{"def":"Any one of many species of marine gastropods belonging to Triton and allied genera, having a stout spiral shell, often handsomely colored and ornamented with prominent varices.","pos":""}],"TRITONE":[{"def":"A superfluous or augmented fourth.","pos":""}],"TRITORIUM":[{"def":"Same as Triturium.","pos":""}],"TRITOVUM":[{"def":"An embryonic insect which has twice cast its skin previous to hatching from the egg.","pos":""}],"TRITOZOOID":[{"def":"A zooid of the third generation in asexual reproduction.","pos":""}],"TRITUBERCULY":[{"def":"A theory of the development of mammalian molar teeth.","pos":""}],"TRITURABLE":[{"def":"Capable of being triturated.","pos":""}],"TRITURATE":[{"def":"To rub, grind, bruise, or thrash.","pos":""},{"def":"To rub or grind to a very fine or impalpable powder; to pulverize and comminute thoroughly.","pos":""}],"TRITURATION":[{"def":"The act of triturating, or reducing to a fine or impalpable powder by grinding, rubbing, bruising, etc.","pos":""}],"TRITURE":[{"def":"A rubbing or grinding; trituration.","pos":""}],"TRITURIUM":[{"def":"A vessel for separating liquids of different densities.","pos":""}]}