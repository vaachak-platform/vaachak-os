{"MOVABLE":[{"def":"Capable of being moved, lifted, carried, drawn, turned, or conveyed, or in any way made to change place or posture; susceptible of motion; not fixed or stationary; as, a movable steam engine.","pos":""},{"def":"Changing from one time to another; as, movable feasts, i.","pos":""}],"MOVABLENESS":[{"def":"The quality or state of being movable; mobility; susceptibility of motion.","pos":""}],"MOVABLY":[{"def":"In a movable manner or condition.","pos":""}],"MOVE":[{"def":"To transfer (a piece or man) from one space or position to another, according to the rules of the game; as, to move a king.","pos":""}],"MOVELESS":[{"def":"Motionless; fixed.","pos":""}],"MOVEMENT":[{"def":"A system of mechanism for transmitting motion of a definite character, or for transforming motion; as, the wheelwork of a watch.","pos":""}],"MOVENT":[{"def":"That which moves anything.","pos":""}],"MOVER":[{"def":"A person or thing that moves, stirs, or changes place.","pos":""},{"def":"A person or thing that imparts motion, or causes change of place; a motor.","pos":""}],"MOVIE":[{"def":"A moving picture or a moving picture show; -- commonly used in pl.","pos":""}],"MOVING":[{"def":"Changing place or posture; causing motion or action; as, a moving car, or power.","pos":""},{"def":"Exciting movement of the mind; adapted to move the sympathies, passions, or affections; touching; pathetic; as, a moving appeal.","pos":""}],"MOVINGLY":[{"def":"In a moving manner.","pos":""}],"MOVINGNESS":[{"def":"The power of moving.","pos":""}]}