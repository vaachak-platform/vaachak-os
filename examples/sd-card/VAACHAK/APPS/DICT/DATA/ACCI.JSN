{"ACCIACCATURA":[{"def":"A short grace note, one semitone below the note to which it is prefixed; -- used especially in organ music.","pos":""}],"ACCIDENCE":[{"def":"The accidents, of inflections of words; the rudiments of grammar.","pos":""},{"def":"The rudiments of any subject.","pos":""}],"ACCIDENT":[{"def":"A property attached to a word, but not essential to it, as gender, number, case.","pos":""},{"def":"A point or mark which may be retained or omitted in a coat of arms.","pos":""}],"ACCIDENTAL":[{"def":"Happening by chance, or unexpectedly; taking place not according to the usual course of things; casual; fortuitous; as, an accidental visit.","pos":""},{"def":"Nonessential; not necessary belonging; incidental; as, are accidental to a play.","pos":""}],"ACCIDENTALISM":[{"def":"Accidental character or effect.","pos":""}],"ACCIDENTALITY":[{"def":"The quality of being accidental; accidentalness.","pos":""}],"ACCIDENTALLY":[{"def":"In an accidental manner; unexpectedly; by chance; unintentionally; casually; fortuitously; not essentially.","pos":""}],"ACCIDENTALNESS":[{"def":"The quality of being accidental; casualness.","pos":""}],"ACCIPITER":[{"def":"A genus of rapacious birds; one of the Accipitres or Raptores.","pos":""},{"def":"A bandage applied over the nose, resembling the claw of a hawk.","pos":""}],"ACCIPITRAL":[{"def":"Pertaining to, or of the nature of, a falcon or hawk; hawklike.","pos":""}],"ACCIPITRES":[{"def":"The order that includes rapacious birds.","pos":""}],"ACCIPITRINE":[{"def":"Like or belonging to the Accipitres; raptorial; hawklike.","pos":""}],"ACCISMUS":[{"def":"Affected refusal; coyness.","pos":""}],"ACCITE":[{"def":"To cite; to summon.","pos":""}]}