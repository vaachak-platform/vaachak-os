{"SOFA":[{"def":"A long seat, usually with a cushioned bottom, back, and ends; - - much used as a comfortable piece of furniture.","pos":""}],"SOFFIT":[{"def":"The under side of the subordinate parts and members of buildings, such as staircases, entablatures, archways, cornices, or the like.","pos":""}],"SOFT":[{"def":"Easily yielding to pressure; easily impressed, molded, or cut; not firm in resisting; impressible; yielding; also, malleable; -- opposed to Ant: hard; as, a soft bed; a soft peach; soft earth; soft wood or metal.","pos":""},{"def":"Not rough, rugged, or harsh to the touch; smooth; delicate; fine; as, soft silk; a soft skin.","pos":""}],"SOFT STEEL":[{"def":"Steel low in carbon; mild steel; ingot iron.","pos":""}],"SOFT-FINNED":[{"def":"Having the fin rays cartilaginous or flexible; without spines; -- said of certain fishes.","pos":""}],"SOFT-HEADED":[{"def":"Weak in intellect.","pos":""}],"SOFT-HEARTED":[{"def":"Having softness or tenderness of heart; susceptible of pity or other kindly affection; gentle; meek.","pos":""}],"SOFT-SPOKEN":[{"def":"Speaking softly; having a mild or gentle voice; hence, mild; affable.","pos":""}],"SOFTA":[{"def":"Any one attached to a Mohammedan mosque, esp.","pos":""}],"SOFTEN":[{"def":"To make soft or more soft.","pos":""}],"SOFTENER":[{"def":"One who, or that which, softens.","pos":""}],"SOFTLING":[{"def":"A soft, effeminate person; a voluptuary.","pos":""}],"SOFTLY":[{"def":"In a soft manner.","pos":""}],"SOFTNESS":[{"def":"The quality or state of being soft; -- opposed to Ant: hardness, and used in the various specific senses of the adjective.","pos":""},{"def":"Having a soft or fragile shell.","pos":""}]}