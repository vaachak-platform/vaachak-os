{"EXPRESS":[{"def":"Exactly representing; exact.","pos":""},{"def":"Directly and distinctly stated; declared in terms; not implied or left to inference; made unambiguous by intention and care; clear; not dubious; as, express consent; an express statement.","pos":""}],"EXPRESS RIFLE":[{"def":"A sporting rifle for use at short ranges, employing a large charge of powder and a light (short) bullet, giving a high initial velocity and consequently a flat trajectory.","pos":""}],"EXPRESS TRAIN":[{"def":"Formerly, a railroad train run expressly for the occasion; a special train; now, a train run at express or special speed and making few stops.","pos":""}],"EXPRESSAGE":[{"def":"The charge for carrying a parcel by express.","pos":""}],"EXPRESSIBLE":[{"def":"Capable of being expressed, squeezed out, shown, represented, or uttered.","pos":""}],"EXPRESSION":[{"def":"The representation of any quantity by its appropriate characters or signs.","pos":""}],"EXPRESSIONAL":[{"def":"Of, or relating to, expression; phraseological; also, vividly representing or suggesting an idea sentiment.","pos":""}],"EXPRESSIONLESS":[{"def":"Destitute of expression.","pos":""}],"EXPRESSIVE":[{"def":"Serving to express, utter, or represent; indicative; communicative; -- followed by of; as, words expressive of his gratitude.","pos":""},{"def":"Full of expression; vividly representing the meaning or feeling meant to be conveyed; significant; emphatic; as, expressive looks or words.","pos":""}],"EXPRESSLY":[{"def":"In an express manner; in direct terms; with distinct purpose; particularly; as, a book written expressly for the young.","pos":""}],"EXPRESSMAN":[{"def":"A person employed in the express business; also, the driver of a job wagon.","pos":""}],"EXPRESSNESS":[{"def":"The state or quality of being express; definiteness.","pos":""}],"EXPRESSURE":[{"def":"The act of expressing; expression; utterance; representation.","pos":""}],"EXPROBRATE":[{"def":"To charge upon with reproach; to upbraid.","pos":""}],"EXPROBRATION":[{"def":"Reproachful accusation; upbraiding.","pos":""},{"def":"Expressing reproach; upbraiding; reproachful.","pos":""}],"EXPROPRIATE":[{"def":"To put out of one's possession; to surrender the ownership of; also, to deprive of possession or proprietary rights.","pos":""}],"EXPROPRIATION":[{"def":"The act of expropriating; the surrender of a claim to exclusive property; the act of depriving of ownership or proprietary rights.","pos":""}]}