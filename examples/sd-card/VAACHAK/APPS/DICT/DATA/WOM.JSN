{"WOMAN":[{"def":"An adult female person; a grown-up female person, as distinguished from a man or a child; sometimes, any female person.","pos":""},{"def":"The female part of the human race; womankind.","pos":""}],"WOMANHOOD":[{"def":"The state of being a woman; the distinguishing character or qualities of a woman, or of womankind.","pos":""},{"def":"Women, collectively; womankind.","pos":""}],"WOMANISH":[{"def":"Suitable to a woman, having the qualities of a woman; effeminate; not becoming a man; -- usually in a reproachful sense.","pos":""}],"WOMANIZE":[{"def":"To make like a woman; to make effeminate.","pos":""}],"WOMANKIND":[{"def":"The females of the human race; women, collectively.","pos":""}],"WOMANLESS":[{"def":"Without a woman or women.","pos":""}],"WOMANLIKE":[{"def":"Like a woman; womanly.","pos":""}],"WOMANLINESS":[{"def":"The quality or state of being womanly.","pos":""}],"WOMANLY":[{"def":"Becoming a woman; feminine; as, womanly behavior.","pos":""}],"WOMB":[{"def":"The belly; the abdomen.","pos":""},{"def":"The place where anything is generated or produced.","pos":""}],"WOMBAT":[{"def":"Any one of three species of Australian burrowing marsupials of the genus Phascolomys, especially the common species (P.","pos":""}]}