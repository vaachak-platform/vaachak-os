{"BRIM":[{"def":"The rim, border, or upper sdge of a cup, dish, or any hollow vessel used for holding anything.","pos":""},{"def":"The edge or margin, as of a fountain, or of the water contained in it; the brink; border.","pos":""}],"BRIMFUL":[{"def":"Full to the brim; completely full; ready to overflow.","pos":""}],"BRIMLESS":[{"def":"Having no brim; as, brimless caps.","pos":""}],"BRIMMED":[{"def":"Having a brim; -- usually in composition.","pos":""},{"def":"Full to, or level with, the brim.","pos":""}],"BRIMMER":[{"def":"A brimful bowl; a bumper.","pos":""}],"BRIMMING":[{"def":"Full to the brim; overflowing.","pos":""}],"BRIMSTONE":[{"def":"Sulphur; See Sulphur.","pos":""}],"BRIMSTONY":[{"def":"Containing or resembling brimstone; sulphurous.","pos":""}]}