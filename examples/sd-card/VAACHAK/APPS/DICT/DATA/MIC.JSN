{"MICA":[{"def":"The name of a group of minerals characterized by highly perfect cleavage, so that they readily separate into very thin leaves, more or less elastic.","pos":""}],"MICACEO-CALCAREOUS":[{"def":"Partaking of the nature of, or consisting of, mica and lime; -- applied to a mica schist containing carbonate of lime.","pos":""}],"MICACEOUS":[{"def":"Pertaining to, or containing, mica; splitting into laminæ or leaves like mica.","pos":""}],"MICELLA":[{"def":"A theoretical aggregation of molecules constituting a structural particle of protoplasm, capable of increase or diminution without change in chemical nature.","pos":""},{"def":"To lie hid; to skulk; to act, or carry one's self, sneakingly.","pos":""}],"MICHAELMAS":[{"def":"The feat of the archangel Michael, a church festival, celebrated on the 29th of September.","pos":""}],"MICHER":[{"def":"One who skulks, or keeps out of sight; hence, a truant; an idler; a thief, etc.","pos":""}],"MICHERY":[{"def":"Theft; cheating.","pos":""}],"MICHING":[{"def":"Hiding; skulking; cowardly.","pos":""}],"MICMACS":[{"def":"A tribe of Indians inhabiting Nova Scotia and New Brunswick.","pos":""}],"MICO":[{"def":"A small South American monkey (Mico melanurus), allied to the marmoset.","pos":""}],"MICRACOUSTIC":[{"def":"Same as Microustic.","pos":""}],"MICRASTER":[{"def":"A genus of sea urchins, similar to Spatangus, abounding in the chalk formation; -- from the starlike disposal of the ambulacral furrows.","pos":""}],"MICRENCEPHALOUS":[{"def":"Having a small brain.","pos":""},{"def":"A combining form signifying: (a) Small, little, trivial, slight; as, microcosm, microscope.","pos":""}],"MICRO-CHEMICAL":[{"def":"Of or pertaining to micro-chemistry; as, a micro-chemical test.","pos":""}],"MICRO-CHEMISTRY":[{"def":"The application of chemical tests to minute objects or portions of matter, magnified by the use of the microscopy; -- distinguished from macro-chemistry.","pos":""}],"MICRO-GEOLOGICAL":[{"def":"Of or pertaining to micro-geology.","pos":""}],"MICRO-GEOLOGY":[{"def":"The part of geology relating to structure and organisms which require to be studied with a microscope.","pos":""}],"MICROAMPERE":[{"def":"One of the smaller measures of electrical currents; the millionth part of one ampère.","pos":""}],"MICROANALYSIS":[{"def":"Analysis of the structure of materials from careful observation of photomicrographs.","pos":""}],"MICROBACTERIA":[{"def":"In the classification of Cohn, one of the four tribes of Bacteria.","pos":""}],"MICROBAROGRAPH":[{"def":"An instrument for recording minor fluctuations of atmospheric pressure, as opposed to general barometric surges.","pos":""},{"def":"A microscopic organism; -- particularly applied to bacteria and especially to pathogenic forms; as, the microbe of fowl cholera.","pos":""}],"MICROBIAN":[{"def":"Of, pertaining to, or caused by, microbes; as, the microbian theory; a microbian disease.","pos":""}],"MICROBIC":[{"def":"Of or pertaining to a microbe.","pos":""}],"MICROBICIDE":[{"def":"Any agent detrimental to, or destructive of, the life of microbes or bacterial organisms.","pos":""}],"MICROBIOLOGY":[{"def":"The study of minute organisms, or microbes, as the bacteria.","pos":""},{"def":"Having a small head; having the cranial cavity small; -- opposed to Ant: megacephalic.","pos":""}],"MICROCHRONOMETER":[{"def":"Mi`cro*chro*nom\"e*ter, n.","pos":""}],"MICROCLINE":[{"def":"A mineral of the feldspar group, like orthoclase or common feldspar in composition, but triclinic in form.","pos":""}],"MICROCOCCAL":[{"def":"Of or pertaining to micrococci; caused by micrococci.","pos":""}],"MICROCOCCUS":[{"def":"A genus of Spherobacteria, in the form of very small globular or oval cells, forming, by transverse division, filaments, or chains of cells, or in some cases single organisms shaped like dumb-bells (Diplococcus), all without the power of motion.","pos":""}],"MICROCOSM":[{"def":"A little world; a miniature universe.","pos":""},{"def":"Of or pertaining to the microcosm.","pos":""}],"MICROCOSMOGRAPHY":[{"def":"Description of man as a microcosm.","pos":""}],"MICROCOULOMB":[{"def":"A measure of electrical quantity; the millionth part of one coulomb.","pos":""}],"MICROCOUSTIC":[{"def":"Pertaining, or suited, to the audition of small sounds; fitted to assist hearing.","pos":""}],"MICROCRITH":[{"def":"The weight of the half hydrogen molecule, or of the hydrogen atom, taken as the standard in comparing the atomic weights of the elements; thus, an atom of oxygen weighs sixteen microcriths.","pos":""}],"MICROCRYSTALLINE":[{"def":"Crystalline on a fine, or microscopic, scale; consisting of fine crystals; as, the ground mass of certain porphyrics is microcrystalline.","pos":""}],"MICROCYTE":[{"def":"One of the elementary granules found in blood.","pos":""}],"MICRODONT":[{"def":"Having small teeth.","pos":""}],"MICROFARAD":[{"def":"The millionth part of a farad.","pos":""}],"MICROFORM":[{"def":"A microscopic form of life; an animal or vegetable organism microscopic size.","pos":""}],"MICROGRAPH":[{"def":"An instrument for executing minute writing or engraving.","pos":""}],"MICROGRAPHIC":[{"def":"Of or pertaining to micrography.","pos":""}],"MICROGRAPHY":[{"def":"The description of microscopic objects.","pos":""}],"MICROHM":[{"def":"The millionth part of an ohm.","pos":""}],"MICROLEPIDOPTERA":[{"def":"A tribe of Lepidoptera, including a vast number of minute species, as the plume moth, clothes moth, etc.","pos":""}],"MICROLESTES":[{"def":"An extinct genus of small Triassic mammals, the oldest yet found in European strata.","pos":""}],"MICROLITE":[{"def":"A minute inclosed crystal, often observed when minerals or rocks are examined in thin sections under the microscope.","pos":""}],"MICROLITH":[{"def":"Same as Microlite, 2.","pos":""}],"MICROLITHIC":[{"def":"Formed of small stones.","pos":""},{"def":"Of or pertaining to micrology; very minute; as, micrologic examination.","pos":""}],"MICROLOGY":[{"def":"That part of science which treats of microscopic objects, or depends on microscopic observation.","pos":""},{"def":"Attention to petty items or differences.","pos":""}],"MICROMERE":[{"def":"One of the smaller cells, or blastomeres, resulting from the complete segmentation of a telolecithal ovum.","pos":""}],"MICROMETER":[{"def":"An instrument, used with a telescope or microscope, for measuring minute distances, or the apparent diameters of objects which subtend minute angles.","pos":""},{"def":"Belonging to micrometry; made by the micrometer.","pos":""}],"MICROMETRY":[{"def":"The art of measuring with a micrometer.","pos":""}],"MICROMILLIMETER":[{"def":"The millionth part of a meter.","pos":""}],"MICRON":[{"def":"A measure of length; the thousandth part of one millimeter; the millionth part of a meter.","pos":""}],"MICRONESIAN":[{"def":"Of or pertaining to Micronesia, a collective designation of the islands in the western part of the Pacific Ocean, embracing the Marshall and Gilbert groups, the Ladrones, the Carolines, etc.","pos":""}],"MICRONESIANS":[{"def":"A dark race inhabiting the Micronesian Islands.","pos":""}],"MICRONOMETER":[{"def":"An instrument for noting minute portions of time.","pos":""},{"def":"Any microscopic form of life; -- particularly applied to bacteria and similar organisms, esp.","pos":""}],"MICROPANTOGRAPH":[{"def":"A kind of pantograph which produces copies microscopically minute.","pos":""}],"MICROPARASITE":[{"def":"A parasitic microörganism.","pos":""}],"MICROPEGMATITE":[{"def":"A rock showing under the microscope the structure of a graphic granite (pegmatite).","pos":""}],"MICROPHONE":[{"def":"An instrument for intensifying and making audible very feeble sounds.","pos":""}],"MICROPHONICS":[{"def":"The science which treats of the means of increasing the intensity of low or weak sounds, or of the microphone.","pos":""}],"MICROPHONOUS":[{"def":"Serving to augment the intensity of weak sounds; microcoustic.","pos":""}],"MICROPHOTOGRAPH":[{"def":"A microscopically small photograph of a picture, writing, printed page, etc.","pos":""},{"def":"An enlarged representation of a microscopic object, produced by throwing upon a sensitive plate the magnified image of an object formed by a microscope or other suitable combination of lenses.","pos":""}],"MICROPHOTOGRAPHY":[{"def":"The art of making microphotographs.","pos":""},{"def":"An unnatural smallness of the eyes, occurring as the result of disease or of imperfect development.","pos":""}],"MICROPHYTAL":[{"def":"Pertaining to, or of the nature of, microphytes.","pos":""}],"MICROPHYTE":[{"def":"A very minute plant, one of certain unicellular algæ, such as the germs of various infectious diseases are believed to be.","pos":""}],"MICROSCOPAL":[{"def":"Pertaining to microscopy, or to the use of the microscope.","pos":""}],"MICROSCOPE":[{"def":"An optical instrument, consisting of a lens, or combination of lenses, for making an enlarged image of an object which is too minute to be viewed by the naked eye.","pos":""}],"MICROSCOPIAL":[{"def":"Of or pertaining to the microscope or to microscopy; made with a microscope; as, microscopic observation.","pos":""},{"def":"Able to see extremely minute objects.","pos":""}],"MICROSCOPICALLY":[{"def":"By the microscope; with minute inspection; in a microscopic manner.","pos":""}],"MICROSCOPIST":[{"def":"One skilled in, or given to, microscopy.","pos":""}],"MICROSCOPY":[{"def":"The use of the microscope; investigation with the microscope.","pos":""}],"MICROSEISM":[{"def":"A feeble earth tremor not directly perceptible, but detected only by means of specially constructed apparatus.","pos":""}],"MICROSEISMOGRAPH":[{"def":"A microseismometer; specif.","pos":""}],"MICROSEISMOLOGY":[{"def":"Science or study of microseisms.","pos":""}],"MICROSEISMOMETER":[{"def":"A seismometer for measuring amplitudes or periods, or both, of microseisms.","pos":""}],"MICROSEME":[{"def":"Having the orbital index relatively small; having the orbits broad transversely; -- opposed to Ant: megaseme.","pos":""}],"MICROSPECTROSCOPE":[{"def":"A spectroscope arranged for attachment to a microscope, for observation of the spectrum of light from minute portions of any substance.","pos":""}],"MICROSPORANGIUM":[{"def":"A sporangium or conceptacle containing only very minute spores.","pos":""}],"MICROSPORE":[{"def":"One of the exceedingly minute spores found in certain flowerless plants, as Selaginella and Isoetes, which bear two kinds of spores, one very much smaller than the other.","pos":""}],"MICROSPORIC":[{"def":"Of or pertaining to microspores.","pos":""}],"MICROSTHENE":[{"def":"One of a group of mammals having a small size as a typical characteristic.","pos":""}],"MICROSTHENIC":[{"def":"Having a typically small size; of or pertaining to the microsthenes.","pos":""}],"MICROTASIMETER":[{"def":"A tasimeter, especially when arranged for measuring very small extensions.","pos":""}],"MICROTOME":[{"def":"An instrument for making very thin sections for microscopical examination.","pos":""}],"MICROTOMIST":[{"def":"One who is skilled in or practices microtomy.","pos":""}],"MICROTOMY":[{"def":"The art of using the microtome; investigation carried on with the microtome.","pos":""}],"MICROVOLT":[{"def":"A measure of electro-motive force; the millionth part of one volt.","pos":""}],"MICROWEBER":[{"def":"The millionth part of one weber.","pos":""}],"MICROZOA":[{"def":"A small motile spore furnished with two vibratile cilia, found in certain green algæ.","pos":""}],"MICROZYME":[{"def":"A microörganism which is supposed to act like a ferment in causing or propagating certain infectious or contagious diseases; a pathogenic bacterial organism.","pos":""}],"MICTURITION":[{"def":"The act of voiding urine; also, a morbidly frequent passing of the urine, in consequence of disease.","pos":""}]}