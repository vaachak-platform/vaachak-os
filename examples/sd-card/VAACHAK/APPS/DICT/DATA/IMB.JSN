{"IMBAN":[{"def":"To put under a ban.","pos":""}],"IMBAND":[{"def":"To form into a band or bands.","pos":""}],"IMBANK":[{"def":"To inclose or defend with a bank or banks.","pos":""}],"IMBANKMENT":[{"def":"The act of surrounding with a bank; a bank or mound raised for defense, a roadway, etc.","pos":""}],"IMBAR":[{"def":"To bar in; to secure.","pos":""}],"IMBARN":[{"def":"To store in a barn.","pos":""}],"IMBASE":[{"def":"To diminish in value.","pos":""}],"IMBASTARDIZE":[{"def":"To bastardize; to debase.","pos":""}],"IMBATHE":[{"def":"To bathe; to wash freely; to immerce.","pos":""}],"IMBECILE":[{"def":"Destitute of strength, whether of body or mind; feeble; impotent; esp.","pos":""}],"IMBECILITATE":[{"def":"To weaken, as to the body or the mind; to enfeeble.","pos":""}],"IMBECILITY":[{"def":"The quality of being imbecile; weakness; feebleness, esp.","pos":""}],"IMBED":[{"def":"To sink or lay, as in a bed; to deposit in a partly inclosing mass, as of clay or mortar; to cover, as with earth, sand, etc.","pos":""}],"IMBELLIC":[{"def":"Not warlike or martial.","pos":""}],"IMBENCHING":[{"def":"A raised work like a bench.","pos":""}],"IMBIBE":[{"def":"To drink in; to absorb; to suck or take in; to receive as by drinking; as, a person imbibes drink, or a sponge imbibes moisture.","pos":""},{"def":"To receive or absorb into the mind and retain; as, to imbibe principles; to imbibe errors.","pos":""}],"IMBIBER":[{"def":"One who, or that which, imbibes.","pos":""}],"IMBIBITION":[{"def":"The act or process of imbibing, or absorbing; as, the post- mortem imbibition of poisons.","pos":""}],"IMBITTER":[{"def":"To make bitter; hence, to make distressing or more distressing; to make sad, morose, sour, or malignant.","pos":""}],"IMBITTERER":[{"def":"One who, or that which, imbitters.","pos":""}],"IMBITTERMENT":[{"def":"The act of imbittering; bitter feeling; embitterment.","pos":""}],"IMBODY":[{"def":"To become corporeal; to assume the qualities of a material body.","pos":""}],"IMBONITY":[{"def":"Want of goodness.","pos":""}],"IMBORDER":[{"def":"To furnish or inclose with a border; to form a border of.","pos":""}],"IMBOSK":[{"def":"To conceal, as in bushes; to hide.","pos":""}],"IMBOSOM":[{"def":"To hold in the bosom; to cherish in the heart or affection; to embosom.","pos":""},{"def":"To inclose or place in the midst of; to surround or shelter; as, a house imbosomed in a grove.","pos":""}],"IMBOSTURE":[{"def":"Embossed or raised work.","pos":""}],"IMBOUND":[{"def":"To inclose in limits; to shut in.","pos":""}],"IMBOW":[{"def":"To make like a bow; to curve; to arch; to vault; to embow.","pos":""}],"IMBOWMENT":[{"def":"act of imbowing; an arch; a vault.","pos":""}],"IMBOX":[{"def":"To inclose in a box.","pos":""}],"IMBRANGLE":[{"def":"To entangle as in a cobweb; to mix confusedly.","pos":""}],"IMBREED":[{"def":"To generate within; to inbreed.","pos":""}],"IMBRICATE":[{"def":"To lay in order, one lapping over another, so as to form an imbricated surface.","pos":""}],"IMBRICATION":[{"def":"An overlapping of the edges, like that of tiles or shingles; hence, intricacy of structure; also, a pattern or decoration representing such a structure.","pos":""}],"IMBROCADO":[{"def":"Cloth of silver or of gold.","pos":""},{"def":"A hit or thrust.","pos":""}],"IMBROGLIO":[{"def":"An intricate, complicated plot, as of a drama or work of fiction.","pos":""},{"def":"A complicated and embarrassing state of things; a serious misunderstanding.","pos":""}],"IMBROWN":[{"def":"To make brown; to obscure; to darken; to tan; as, features imbrowned by exposure.","pos":""}],"IMBRUE":[{"def":"To wet or moisten; to soak; to drench, especially in blood.","pos":""}],"IMBRUEMENT":[{"def":"The act of imbruing or state of being imbrued.","pos":""}],"IMBRUTE":[{"def":"To degrade to the state of a brute; to make brutal.","pos":""}],"IMBRUTEMENT":[{"def":"The act of imbruting, or the state of being imbruted.","pos":""}],"IMBUE":[{"def":"To tinge deeply; to dye; to cause to absorb; as, clothes thoroughly imbued with black.","pos":""},{"def":"To tincture deply; to cause to become impressed or penetrated; as, to imbue the minds of youth with good principles.","pos":""}],"IMBUEMENT":[{"def":"The act of imbuing; the state of being imbued; hence, a deep tincture.","pos":""}],"IMBURSE":[{"def":"To supply or stock with money.","pos":""}],"IMBURSEMENT":[{"def":"The act of imbursing, or the state of being imbursed.","pos":""},{"def":"Money laid up in stock.","pos":""}]}