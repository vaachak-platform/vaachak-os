{"TOT":[{"def":"Anything small; -- frequently applied as a term of endearment to a little child.","pos":""},{"def":"A drinking cup of small size, holding about half a pint.","pos":""}],"TOTAL":[{"def":"Whole; not divided; entire; full; complete; absolute; as, a total departure from the evidence; a total loss.","pos":""}],"TOTALIS":[{"def":"I look on nothing but totalis.","pos":""}],"TOTALISATOR":[{"def":"Same as Totalizator.","pos":""}],"TOTALITY":[{"def":"The quality or state of being total; as, the totality of an eclipse.","pos":""},{"def":"The whole sum; the whole quantity or amount; the entirety; as, the totalityof human knowledge.","pos":""}],"TOTALIZATION":[{"def":"Act of totalizing, or state of being totalized.","pos":""}],"TOTALIZATOR":[{"def":"A machine for registering and indicating the number and nature of bets made on horse races, as in Australia and South Africa.","pos":""}],"TOTALIZE":[{"def":"To make total, or complete;to reduce to completeness.","pos":""}],"TOTALIZER":[{"def":"Same as Totalizator.","pos":""}],"TOTALLY":[{"def":"In a total manner; wholly; entirely.","pos":""}],"TOTALNESS":[{"def":"The quality or state of being total; entireness; totality.","pos":""}],"TOTARA":[{"def":"A coniferous tree (Podocarpus totara), next to the kauri the most valuable timber tree of New Zeland.","pos":""}],"TOTE":[{"def":"To carry or bear; as, to tote a child over a stream; -- a colloquial word of the Southern States, and used esp.","pos":""}],"TOTEAR":[{"def":"To tear or rend in pieces.","pos":""}],"TOTEM":[{"def":"A rude picture, as of a bird, beast, or the like, used by the Nord American Indians as a symbolic designation, as of a family or a clan.","pos":""}],"TOTEMIC":[{"def":"Of or pertaining to a totem, or totemism.","pos":""}],"TOTEMISM":[{"def":"The system of distinguishing families, clans, etc.","pos":""},{"def":"Superstitious regard for a totem; the worship of any real or imaginary object; nature worship.","pos":""}],"TOTEMIST":[{"def":"One belonging to a clan or tribe having a totem.","pos":""},{"def":"A pole or pillar, carved and painted with a series of totemic symbols, set up before the house of certain Indian tribes of the northwest coast of North America, esp.","pos":""}],"TOTER":[{"def":"The stone roller.","pos":""}],"TOTIPALMATE":[{"def":"Having all four toes united by a web;-said of certain sea birds, as the pelican and the gannet.","pos":""}],"TOTIPALMI":[{"def":"A division of swimming birds including those that have totipalmate feet.","pos":"noun"}],"TOTTER":[{"def":"To shake so as to threaten a fall; to vacillate; to be unsteady; to stagger; as,an old man totters with age.","pos":""},{"def":"To shake; to reel; to lean; to waver.","pos":""}],"TOTTERER":[{"def":"One who totters.","pos":""}],"TOTTERINGLY":[{"def":"In a tottering manner.","pos":""}],"TOTTERY":[{"def":"Trembling or vaccilating, as if about to fall; unsteady; shaking.","pos":""}],"TOTTLE":[{"def":"To walk in a wavering, unsteady manner; to toddle; to topple.","pos":""}],"TOTTLISH":[{"def":"Trembling or tottering, as if about to fall; un steady.","pos":""}],"TOTTY":[{"def":"Unsteady; dizzy; tottery.","pos":""}],"TOTY":[{"def":"My head is totty of my swink to-night.","pos":""}]}