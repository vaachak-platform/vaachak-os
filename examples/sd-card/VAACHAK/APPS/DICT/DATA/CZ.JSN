{"CZAR":[{"def":"A king; a chief; the title of the emperor of Russia.","pos":""}],"CZAREVNA":[{"def":"The title of the wife of the czarowitz.","pos":""}],"CZARINA":[{"def":"The title of the empress of Russia.","pos":""}],"CZARINIAN":[{"def":"Of or pertaining to the czar or the czarina; czarish.","pos":""}],"CZARISH":[{"def":"Of or pertaining to the czar.","pos":""}],"CZAROWITZ":[{"def":"The title of the eldest son of the czar of Russia.","pos":""}],"CZECH":[{"def":"One of the Czechs.","pos":""},{"def":"The language of the Czechs (often called Bohemian), the harshest and richest of the Slavic languages.","pos":""}],"CZECHIC":[{"def":"Of or pertaining to the Czechs.","pos":""}],"CZECHS":[{"def":"The most westerly branch of the great Slavic family of nations, numbering now more than 6,000,000, and found principally in Bohemia and Moravia.","pos":""},{"def":"The nominal of the second tone in the model major scale (that in C), or of the fourth tone in the relative minor scale of C (that in A minor), or of the key tone in the relative minor of F.","pos":""}]}