{"PERIVASCULAR":[{"def":"Around the blood vessels; as, perivascular lymphatics.","pos":""}],"PERIVERTEBRAL":[{"def":"Surrounding the vertebræ.","pos":""}],"PERIVISCERAL":[{"def":"Around the viscera; as, the perivisceral cavity.","pos":""}],"PERIVITELLINE":[{"def":"Situated around the vitellus, or between the vitellus and zona pellucida of an ovum.","pos":""}]}