{"FLASH":[{"def":"To burst or break forth with a sudden and transient flood of flame and light; as, the lighting flashes vividly; the powder flashed.","pos":""},{"def":"To break forth, as a sudden flood of light; to burst instantly and brightly on the sight; to show a momentary brilliancy; to come or pass like a flash.","pos":""}],"FLASH BOILER":[{"def":"A variety of water-tube boiler, used chiefly in steam automobiles, consisting of a nest of strong tubes with very little water space, kept nearly red hot so that the water as it trickles drop by drop into the tubes is immediately flashed into steam and superheated.","pos":""}],"FLASH BURNER":[{"def":"A gas burner with a device for lighting by an electric spark.","pos":""}],"FLASHBOARD":[{"def":"A board placed temporarily upon a milldam, to raise the water in the pond above its usual level; a flushboard.","pos":""}],"FLASHER":[{"def":"One who, or that which, flashes.","pos":""},{"def":"A man of more appearance of wit than reality.","pos":""}],"FLASHILY":[{"def":"In a flashy manner; with empty show.","pos":""}],"FLASHINESS":[{"def":"The quality of being flashy.","pos":""}],"FLASHING":[{"def":"The creation of an artifical flood by the sudden letting in of a body of water; -- called also flushing.","pos":""},{"def":"Pieces of metal, built into the joints of a wall, so as to lap over the edge of the gutters or to cover the edge of the roofing; also, similar pieces used to cover the valleys of roofs of slate, shingles, or the like.","pos":""}],"FLASHY":[{"def":"Dazzling for a moment; making a momentary show of brilliancy; transitorily bright.","pos":""},{"def":"Fiery; vehement; impetuous.","pos":""}],"FLASK":[{"def":"The wooden or iron frame which holds the sand, etc.","pos":""}],"FLASKET":[{"def":"A long, shallow basket, with two handles.","pos":""}]}