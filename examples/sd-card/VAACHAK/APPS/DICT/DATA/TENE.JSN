{"TENE":[{"def":"See 1st and 2d Teen.","pos":""}],"TENEBRAE":[{"def":"The matins and lauds for the last three days of Holy Week, commemorating the sufferings and death of Christ, -- usually sung on the afternoon or evening of Wednesday, Thursday, and Friday, instead of on the following days.","pos":""}],"TENEBRICOSE":[{"def":"Tenebrous; dark; gloomy.","pos":""}],"TENEBRIFIC":[{"def":"Rendering dark or gloomy; tenebrous; gloomy.","pos":""}],"TENEBRIFICOUS":[{"def":"Authors who are tenebrificous stars.","pos":""}],"TENEBROSE":[{"def":"Characterized by darkness or gloom; tenebrous.","pos":""}],"TENEBROSITY":[{"def":"The quality or state of being tenebrous; tenebrousness.","pos":""}],"TENEBROUS":[{"def":"Dark; gloomy; dusky; tenebrious.","pos":""}],"TENEMENT":[{"def":"That which is held of another by service; property which one holds of a lord or proprietor in consideration of some military or pecuniary service; fief; fee.","pos":""},{"def":"Any species of permanent property that may be held, so as to create a tenancy, as lands, houses, rents, commons, an office, an advowson, a franchise, a right of common, a peerage, and the like; -- called also free or frank tenements.","pos":""}],"TENEMENTAL":[{"def":"Of or pertaining to a tenement; capable of being held by tenants.","pos":""}],"TENEMENTARY":[{"def":"Capable of being leased; held by tenants.","pos":""}],"TENERAL":[{"def":"Of, pertaining to, or designating, a condition assumed by the imago of certain Neuroptera, after exclusion from the pupa.","pos":""}],"TENERIFFE":[{"def":"A white wine resembling Madeira in taste, but more tart, produced in Teneriffe, one of the Canary Islands; -- called also Vidonia.","pos":""}],"TENESMIC":[{"def":"Of or pertaining to tenesmus; characterized by tenesmus.","pos":""}],"TENESMUS":[{"def":"An urgent and distressing sensation, as if a discharge from the intestines must take place, although none can be effected; -- always referred to the lower extremity of the rectum.","pos":""}],"TENET":[{"def":"Any opinion, principle, dogma, belief, or doctrine, which a person holds or maintains as true; as, the tenets of Plato or of Cicero.","pos":""}]}