{"ATTACCA":[{"def":"Attack at once; -- a direction at the end of a movement to show that the next is to follow immediately, without any pause.","pos":""}],"ATTACH":[{"def":"To bind, fasten, tie, or connect; to make fast or join; as, to attach one thing to another by a string, by glue, or the like.","pos":""},{"def":"To connect; to place so as to belong; to assign by authority; to appoint; as, an officer is attached to a certain regiment, company, or ship.","pos":""}],"ATTACHABLE":[{"def":"Capable of being attached; esp.","pos":""}],"ATTACHE":[{"def":"One attached to another person or thing, as a part of a suite or staff.","pos":""}],"ATTACHMENT":[{"def":"The act attaching, or state of being attached; close adherence or affection; fidelity; regard; anas, an attachment to a friend, or to a party.","pos":""},{"def":"That by which one thing is attached to another; connection; as, to cut the attachments of a muscle.","pos":""}],"ATTACK":[{"def":"To fall upon with force; to assail, as with force and arms; to assault.","pos":""},{"def":"To assail with unfriendly speech or writing; to begin a controversy with; to attempt to overthrow or bring into disrepute, by criticism or satire; to censure; as, to attack a man, or his opinions, in a pamphlet.","pos":""}],"ATTACKABLE":[{"def":"Capable of being attacked.","pos":""}],"ATTACKER":[{"def":"One who attacks.","pos":""},{"def":"A species of sand grouse (Syrrghaptes Pallasii) found in Asia and rarely in southern Europe.","pos":""}],"ATTAIN":[{"def":"To achieve or accomplish, that is, to reach by efforts; to gain; to compass; as, to attain rest.","pos":""},{"def":"To gain or obtain possession of; to acquire.","pos":""}],"ATTAINABILITY":[{"def":"The quality of being attainable; attainbleness.","pos":""}],"ATTAINABLE":[{"def":"Capable of being attained or reached by efforts of the mind or body; capable of being compassed or accomplished by efforts directed to the object.","pos":""}],"ATTAINABLENESS":[{"def":"The quality of being attainable; attainability.","pos":""}],"ATTAINDER":[{"def":"The act of attainting, or the state of being attainted; the extinction of the civil rights and capacities of a person, consequent upon sentence of death or outlawry; as, an act of attainder.","pos":""},{"def":"A stain or staining; state of being in dishonor or condemnation.","pos":""}],"ATTAINMENT":[{"def":"The act of attaining; the act of arriving at or reaching; hence, the act of obtaining by efforts.","pos":""},{"def":"That which is attained to, or obtained by exertion; acquirement; acquisition; (pl.","pos":""}],"ATTAINT":[{"def":"To find guilty; to convict; -- said esp.","pos":""},{"def":"To subject (a person) to the legal condition formerly resulting from a sentence of death or outlawry, pronounced in respect of treason or felony; to affect by attainder.","pos":""}],"ATTAINTMENT":[{"def":"Attainder; attainture; conviction.","pos":""}],"ATTAINTURE":[{"def":"Attainder; disgrace.","pos":""}],"ATTAME":[{"def":"To pierce; to attack.","pos":""},{"def":"To broach; to begin.","pos":""}],"ATTAMINATE":[{"def":"To corrupt; to defile; to contaminate.","pos":""}],"ATTAR":[{"def":"A fragrant essential oil; esp.","pos":""}],"ATTASK":[{"def":"To take to task; to blame.","pos":""}],"ATTASTE":[{"def":"To taste or cause to taste.","pos":""}],"ATTEMPER":[{"def":"To reduce, modify, or moderate, by mixture; to temper; to regulate, as temperature.","pos":""},{"def":"To soften, mollify, or moderate; to soothe; to temper; as, to attemper rigid justice with clemency.","pos":""}],"ATTEMPERAMENT":[{"def":"A tempering, or mixing in due proportion.","pos":""}],"ATTEMPERANCE":[{"def":"Temperance; attemperament.","pos":""}],"ATTEMPERATE":[{"def":"Tempered; proportioned; properly adapted.","pos":""}],"ATTEMPERATION":[{"def":"The act of attempering or regulating.","pos":""}],"ATTEMPT":[{"def":"To make trial or experiment of; to try; to endeavor to do or perform (some action); to assay; as, to attempt to sing; to attempt a bold flight.","pos":""},{"def":"To try to move, by entreaty, by afflictions, or by temptations; to tempt.","pos":""}],"ATTEMPTABLE":[{"def":"Capable of being attempted, tried, or attacked.","pos":""}],"ATTEMPTER":[{"def":"One who attempts; one who essays anything.","pos":""},{"def":"An assailant; also, a temper.","pos":""}],"ATTEMPTIVE":[{"def":"Disposed to attempt; adventurous.","pos":""}],"ATTEND":[{"def":"To direct the attention to; to fix the mind upon; to give heed to; to regard.","pos":""},{"def":"To care for; to look after; to take charge of; to watch over.","pos":""}],"ATTENDANCE":[{"def":"Attention; regard; careful application.","pos":""},{"def":"The act of attending; state of being in waiting; service; ministry; the fact of being present; presence.","pos":""}],"ATTENDANCY":[{"def":"The quality of attending or accompanying; attendance; an attendant.","pos":""}],"ATTENDANT":[{"def":"Depending on, or owing duty or service to; as, the widow attendant to the heir.","pos":""}],"ATTENDER":[{"def":"One who, or that which, attends.","pos":""}],"ATTENDMENT":[{"def":"An attendant circumstance.","pos":""}],"ATTENT":[{"def":"Attentive; heedful.","pos":""}],"ATTENTION":[{"def":"The act or state of attending or heeding; the application of the mind to any object of sense, representation, or thought; notice; exclusive or special consideration; earnest consideration, thought, or regard; obedient or affectionate heed; the supposed power or faculty of attending.","pos":""},{"def":"An act of civility or courtesy; care for the comfort and pleasure of others; as, attentions paid to a stranger.","pos":""}],"ATTENTIVE":[{"def":"Heedful; intent; observant; regarding with care or attention.","pos":""},{"def":"Heedful of the comfort of others; courteous.","pos":""}],"ATTENUANT":[{"def":"Making thin, as fluids; diluting; rendering less dense and viscid; diluent.","pos":""},{"def":"A medicine that thins or dilutes the fluids; a diluent.","pos":""}],"ATTENUATE":[{"def":"To make thin or slender, as by mechanical or chemical action upon inanimate objects, or by the effects of starvation, disease, etc.","pos":""},{"def":"To make thin or less consistent; to render less viscid or dense; to rarefy.","pos":""}],"ATTENUATION":[{"def":"The act or process of making slender, or the state of being slender; emaciation.","pos":""},{"def":"The act of attenuating; the act of making thin or less dense, or of rarefying, as fluids or gases.","pos":""}],"ATTER":[{"def":"Poison; venom; corrupt matter from a sore.","pos":""}],"ATTERCOP":[{"def":"A peevish, ill-natured person.","pos":""}],"ATTERRATE":[{"def":"To fill up with alluvial earth.","pos":""}],"ATTERRATION":[{"def":"The act of filling up with earth, or of forming land with alluvial earth.","pos":""}],"ATTEST":[{"def":"To bear witness to; to certify; to affirm to be true or genuine; as, to attest the truth of a writing, a copy of record.","pos":""},{"def":"To give proof of; to manifest; as, the ruins of Palmyra attest its ancient magnificence.","pos":""}],"ATTESTATION":[{"def":"The act of attesting; testimony; witness; a solemn or official declaration, verbal or written, in support of a fact; evidence.","pos":""}],"ATTESTATIVE":[{"def":"Of the nature of attestation.","pos":""},{"def":"One who attests.","pos":""}],"ATTESTIVE":[{"def":"Attesting; furnishing evidence.","pos":""}],"ATTIC":[{"def":"Of or pertaining to Attica, in Greece, or to Athens, its principal city; marked by such qualities as were characteristic of the Athenians; classical; refined.","pos":""}],"ATTICISM":[{"def":"A favoring of, or attachment to, the Athenians.","pos":""},{"def":"The style and idiom of the Greek language, used by the Athenians; a concise and elegant expression.","pos":""}],"ATTICIZE":[{"def":"To conform or make conformable to the language, customs, etc.","pos":""}],"ATTIGUOUS":[{"def":"Touching; bordering; contiguous.","pos":""}],"ATTINGE":[{"def":"To touch lightly.","pos":""}],"ATTIRE":[{"def":"To dress; to array; to adorn; esp.","pos":""}],"ATTIRED":[{"def":"Provided with antlers, as a stag.","pos":""}],"ATTIREMENT":[{"def":"Attire; adornment.","pos":""}],"ATTIRER":[{"def":"One who attires.","pos":""}],"ATTITUDE":[{"def":"The posture, action, or disposition of a figure or a statue.","pos":""}],"ATTITUDINAL":[{"def":"Relating to attitude.","pos":""}],"ATTITUDINARIAN":[{"def":"One who attitudinizes; a posture maker.","pos":""}],"ATTITUDINARIANISM":[{"def":"A practicing of attitudes; posture making.","pos":""}],"ATTITUDINIZE":[{"def":"To assume affected attitudes; to strike an attitude; to pose.","pos":""}],"ATTITUDINIZER":[{"def":"One who practices attitudes.","pos":""}],"ATTLE":[{"def":"Rubbish or refuse consisting of broken rock containing little or no ore.","pos":""}],"ATTOLLENT":[{"def":"Lifting up; raising; as, an attollent muscle.","pos":""}],"ATTONCE":[{"def":"At once; together.","pos":""}],"ATTORN":[{"def":"To turn, or transfer homage and service, from one lord to another.","pos":""},{"def":"To agree to become tenant to one to whom reversion has been granted.","pos":""}],"ATTORNEY":[{"def":"A substitute; a proxy; an agent.","pos":""}],"ATTORNEY-GENERAL":[{"def":"The chief law officer of the state, empowered to act in all litigation in which the law-executing power is a party, and to advise this supreme executive whenever required.","pos":""}],"ATTORNEYISM":[{"def":"The practice or peculiar cleverness of attorneys.","pos":""}],"ATTORNEYSHIP":[{"def":"The office or profession of an attorney; agency for another.","pos":""}],"ATTORNMENT":[{"def":"The act of a feudatory, vassal, or tenant, by which he consents, upon the alienation of an estate, to receive a new lord or superior, and transfers to him his homage and service; the agreement of a tenant to acknowledge the purchaser of the estate as his landlord.","pos":""}],"ATTRACT":[{"def":"To draw to, or cause to tend to; esp.","pos":""},{"def":"To draw by influence of a moral or emotional kind; to engage or fix, as the mind, attention, etc.","pos":""}],"ATTRACTABILITY":[{"def":"The quality or fact of being attractable.","pos":""}],"ATTRACTABLE":[{"def":"Capable of being attracted; subject to attraction.","pos":""}],"ATTRACTER":[{"def":"One who, or that which, attracts.","pos":""}],"ATTRACTILE":[{"def":"Having power to attract.","pos":""}],"ATTRACTION":[{"def":"An invisible power in a body by which it draws anything to itself; the power in nature acting mutually between bodies or ultimate particles, tending to draw them together, or to produce their cohesion or combination, and conversely resisting separation.","pos":""}],"ATTRACTIVE":[{"def":"Having the power or quality of attracting or drawing; as, the attractive force of bodies.","pos":""},{"def":"Attracting or drawing by moral influence or pleasurable emotion; alluring; inviting; pleasing.","pos":""}],"ATTRACTIVITY":[{"def":"The quality or degree of attractive power.","pos":""}],"ATTRACTOR":[{"def":"One who, or that which, attracts.","pos":""}],"ATTRAHENT":[{"def":"Attracting; drawing; attractive.","pos":""}],"ATTRAP":[{"def":"To entrap; to insnare.","pos":""}],"ATTRECTATION":[{"def":"Frequent handling or touching.","pos":""}],"ATTRIBUTABLE":[{"def":"Capable of being attributed; ascribable; imputable.","pos":""}],"ATTRIBUTE":[{"def":"To ascribe; to consider (something) as due or appropriate (to); to refer, as an effect to a cause; to impute; to assign; to consider as belonging (to).","pos":""}],"ATTRIBUTION":[{"def":"The act of attributing or ascribing, as a quality, character, or function, to a thing or person, an effect to a cause.","pos":""},{"def":"That which is ascribed or attributed.","pos":""}],"ATTRIBUTIVE":[{"def":"Attributing; pertaining to, expressing, or assigning an attribute; of the nature of an attribute.","pos":""}],"ATTRIBUTIVELY":[{"def":"In an attributive manner.","pos":""}],"ATTRITE":[{"def":"Repentant from fear of punishment; having attrition of grief for sin; -- opposed to contrite.","pos":""}],"ATTRITION":[{"def":"Grief for sin arising only from fear of punishment or feelings of shame.","pos":""}],"ATTRITUS":[{"def":"Matter pulverized by attrition.","pos":""}],"ATTRY":[{"def":"Poisonous; malignant; malicious.","pos":""}],"ATTUNE":[{"def":"To tune or put in tune; to make melodious; to adjust, as one sound or musical instrument to another; as, to attune the voice to a harp.","pos":""},{"def":"To arrange fitly; to make accordant.","pos":""}]}