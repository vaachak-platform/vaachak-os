{"ACICULA":[{"def":"One of the needlelike or bristlelike spines or prickles of some animals and plants; also, a needlelike crystal.","pos":""}],"ACICULAR":[{"def":"Needle-shaped; slender like a needle or bristle, as some leaves or crystals; also, having sharp points like needless.","pos":""}],"ACICULIFORM":[{"def":"Needle-shaped; acicular.","pos":""}],"ACID":[{"def":"Sour, sharp, or biting to the taste; tart; having the taste of vinegar: as, acid fruits or liquors.","pos":""},{"def":"Of or pertaining to an acid; as, acid reaction.","pos":""}],"ACID PROCESS":[{"def":"That variety of either the Bessemer or the open-hearth process in which the converter or hearth is lined with acid, that is, highly siliceous, material.","pos":""}],"ACIDIC":[{"def":"Containing a high percentage of silica; -- opposed to basic.","pos":""}],"ACIDIFEROUS":[{"def":"Containing or yielding an acid.","pos":""}],"ACIDIFIABLE":[{"def":"Capable of being acidified, or converted into an acid.","pos":""}],"ACIDIFIC":[{"def":"Producing acidity; converting into an acid.","pos":""}],"ACIDIFICATION":[{"def":"The act or process of acidifying, or changing into an acid.","pos":""}],"ACIDIFIER":[{"def":"A simple or compound principle, whose presence is necessary to produce acidity, as oxygen, chlorine, bromine, iodine, etc.","pos":""}],"ACIDIFY":[{"def":"To make acid; to convert into an acid; as, to acidify sugar.","pos":""},{"def":"To sour; to imbitter.","pos":""}],"ACIDIMETER":[{"def":"An instrument for ascertaining the strength of acids.","pos":""}],"ACIDIMETRY":[{"def":"The measurement of the strength of acids, especially by a chemical process based on the law of chemical combinations, or the fact that, to produce a complete reaction, a certain definite weight of reagent is required.","pos":""}],"ACIDITY":[{"def":"The quality of being sour; sourness; tartness; sharpness to the taste; as, the acidity of lemon juice.","pos":""}],"ACIDNESS":[{"def":"Acidity; sourness.","pos":""}],"ACIDULATE":[{"def":"To make sour or acid in a moderate degree; to sour somewhat.","pos":""}],"ACIDULENT":[{"def":"Having an acid quality; sour; acidulous.","pos":""}],"ACIDULOUS":[{"def":"Slightly sour; sub-acid; sourish; as, an acidulous tincture.","pos":""}],"ACIERAGE":[{"def":"The process of coating the surface of a metal plate (as a stereotype plate) with steellike iron by means of voltaic electricity; steeling.","pos":""}],"ACIFORM":[{"def":"Shaped like a needle.","pos":""}],"ACINACEOUS":[{"def":"Containing seeds or stones of grapes, or grains like them.","pos":""}],"ACINACES":[{"def":"A short sword or saber.","pos":""}],"ACINACIFORM":[{"def":"Scimeter-shaped; as, an acinaciform leaf.","pos":""}],"ACINESIA":[{"def":"Same as Akinesia.","pos":""}],"ACINETAE":[{"def":"A group of suctorial Infusoria, which in the adult stage are stationary.","pos":""}],"ACINETIFORM":[{"def":"Resembling the Acinetæ.","pos":""}],"ACINIFORM":[{"def":"Consisting of acini, or minute granular concretions; as, acinose or acinous glands.","pos":""}],"ACINUS":[{"def":"One of the granular masses which constitute a racemose or compound gland, as the pancreas; also, one of the saccular recesses in the lobules of a racemose gland.","pos":""}],"ACIPENSER":[{"def":"A genus of ganoid fishes, including the sturgeons, having the body armed with bony scales, and the mouth on the under side of the head.","pos":""}],"ACIURGY":[{"def":"Operative surgery.","pos":""}]}