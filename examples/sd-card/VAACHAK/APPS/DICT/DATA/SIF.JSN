{"SIFAC":[{"def":"The white indris of Madagascar.","pos":""}],"SIFFLEMENT":[{"def":"The act of whistling or hissing; a whistling sound; sibilation.","pos":""}],"SIFILET":[{"def":"The six-shafted bird of paradise.","pos":""}],"SIFT":[{"def":"To separate with a sieve, as the fine part of a substance from the coarse; as, to sift meal or flour; to sift powder; to sift sand or lime.","pos":""},{"def":"To separate or part as if with a sieve.","pos":""}],"SIFTER":[{"def":"One who, or that which, sifts.","pos":""}]}