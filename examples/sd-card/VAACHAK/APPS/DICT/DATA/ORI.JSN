{"ORICALCHE":[{"def":"Costly oricalche from strange Phoenice.","pos":""}],"ORICHALCEOUS":[{"def":"Pertaining to, or resembling, orichalch; having a color or luster like that of brass.","pos":""}],"ORICHALCH":[{"def":"A metallic substance, resembling gold in color, but inferior in value; a mixed metal of the ancients, resembling brass; -- called also aurichalcum, orichalcum, etc.","pos":""}],"ORIEL":[{"def":"A gallery for minstrels.","pos":""},{"def":"A small apartment next a hall, where certain persons were accustomed to dine; a sort of recess.","pos":""}],"ORIENCY":[{"def":"Brightness or strength of color.","pos":""}],"ORIENT":[{"def":"Rising, as the sun.","pos":""},{"def":"Eastern; oriental.","pos":""}],"ORIENTAL":[{"def":"Of or pertaining to the orient or east; eastern; concerned with the East or Orientalism; -- opposed to occidental; as, Oriental countries.","pos":""}],"ORIENTALISM":[{"def":"Any system, doctrine, custom, expression, etc.","pos":""},{"def":"Knowledge or use of Oriental languages, history, literature, etc.","pos":""}],"ORIENTALIST":[{"def":"An inhabitant of the Eastern parts of the world; an Oriental.","pos":""},{"def":"One versed in Eastern languages, literature, etc.","pos":""}],"ORIENTALITY":[{"def":"The quality or state of being oriental or eastern.","pos":""}],"ORIENTALIZE":[{"def":"to render Oriental; to cause to conform to Oriental manners or conditions.","pos":""}],"ORIENTATE":[{"def":"To place or turn toward the east; to cause to assume an easterly direction, or to veer eastward.","pos":""},{"def":"To arrange in order; to dispose or place (a body) so as to show its relation to other bodies, or the relation of its parts among themselves.","pos":""}],"ORIENTATION":[{"def":"The act or process of orientating; determination of the points of the compass, or the east point, in taking bearings.","pos":""},{"def":"The tendency of a revolving body, when suspended in a certain way, to bring the axis of rotation into parallelism with the earth's axis.","pos":""}],"ORIENTNESS":[{"def":"The quality or state of being orient or bright; splendor.","pos":""}],"ORIFICE":[{"def":"A mouth or aperture, as of a tube, pipe, etc.","pos":""},{"def":"A genus of aromatic labiate plants, including the sweet marjoram (O.","pos":""}],"ORIGENISM":[{"def":"The opinions of Origen of Alexandria, who lived in the 3d century, one of the most learned of the Greek Fathers.","pos":""}],"ORIGENIST":[{"def":"A follower of Origen of Alexandria.","pos":""}],"ORIGIN":[{"def":"The point of attachment or end of a muscle which is fixed during contraction; -- in contradistinction to insertion.","pos":""}],"ORIGINABLE":[{"def":"Capable of being originated.","pos":""}],"ORIGINAL":[{"def":"Pertaining to the origin or beginning; preceding all others; first in order; primitive; primary; pristine; as, the original state of man; the original laws of a country; the original inventor of a process.","pos":""},{"def":"Not copied, imitated, or translated; new; fresh; genuine; as, an original thought; an original process; the original text of Scripture.","pos":""}],"ORIGINALIST":[{"def":"One who is original.","pos":""}],"ORIGINALITY":[{"def":"The quality or state of being original.","pos":""}],"ORIGINALLY":[{"def":"In the original time, or in an original manner; primarily; from the beginning or origin; not by derivation, or imitation.","pos":""},{"def":"At first; at the origin; at the time of formation or costruction; as, a book originally written by another hand.","pos":""}],"ORIGINALNESS":[{"def":"The quality of being original; originality.","pos":""}],"ORIGINANT":[{"def":"Originating; original.","pos":""}],"ORIGINARY":[{"def":"Causing existence; productive.","pos":""},{"def":"Primitive; primary; original.","pos":""}],"ORIGINATE":[{"def":"To give an origin or beginning to; to cause to be; to bring into existence; to produce as new.","pos":""}],"ORIGINATION":[{"def":"The act or process of bringing or coming into existence; first production.","pos":""},{"def":"Mode of production, or bringing into being.","pos":""}],"ORIGINATIVE":[{"def":"Having power, or tending, to originate, or bring into existence; originating.","pos":""}],"ORIGINATOR":[{"def":"One who originates.","pos":""}],"ORILLON":[{"def":"A semicircular projection made at the shoulder of a bastion for the purpose of covering the retired flank, -- found in old fortresses.","pos":""}],"ORION":[{"def":"A large and bright constellation on the equator, between the stars Aldebaran and Sirius.","pos":""}],"ORISKANY":[{"def":"Designating, or pertaining to, certain beds, chiefly limestone, characteristic of the latest period of the Silurian age.","pos":""}],"ORISMOLOGICAL":[{"def":"Of or pertaining to orismology.","pos":""}],"ORISMOLOGY":[{"def":"That departament of natural history which treats of technical terms.","pos":""}],"ORISON":[{"def":"A prayer; a supplication.","pos":""}]}