{"RUSE":[{"def":"An artifice; trick; stratagem; wile; fraund; deceit.","pos":""}],"RUSH":[{"def":"A name given to many aquatic or marsh-growing endogenous plants with soft, slender stems, as the species of Juncus and Scirpus.","pos":""}],"RUSH-BEARING":[{"def":"A kind of rural festival at the dedication of a church, when the parishioners brought rushes to strew the church.","pos":""}],"RUSHBUCKLER":[{"def":"A bullying and violent person; a braggart; a swashbuckler.","pos":""}],"RUSHED":[{"def":"Abounding or covered with rushes.","pos":""}],"RUSHER":[{"def":"One who strewed rushes on the floor at dances.","pos":""}],"RUSHINESS":[{"def":"The quality or state of abounding with rushes.","pos":""}],"RUSHINGLY":[{"def":"In a rushing manner.","pos":""}],"RUSHLIGHT":[{"def":"A rush candle, or its light; hence, a small, feeble light.","pos":""}],"RUSHLIKE":[{"def":"Resembling a rush; weak.","pos":""}],"RUSHY":[{"def":"Abounding with rushes.","pos":""}],"RUSINE":[{"def":"Of, like, or pertaining to, a deer of the genus Rusa, which includes the sambur deer (Rusa Aristotelis) of India.","pos":""}],"RUSK":[{"def":"A kind of light, soft bread made with yeast and eggs, often toasted or crisped in an oven; or a kind of sweetened biscuit.","pos":""},{"def":"A kind of light, hard cake or bread, as for stores Smart.","pos":""}],"RUSMA":[{"def":"A depilatory made of orpiment and quicklime, and used by the Turks.","pos":""}],"RUSS":[{"def":"A Russian, or the Russians.","pos":""},{"def":"The language of the Russians.","pos":""}],"RUSSET":[{"def":"Of a reddish brown color, or (by some called) a red gray; of the color composed of blue, red, and yellow in equal strength, but unequal proportions, namely, two parts of red to one each of blue and yellow; also, of a yellowish brown color.","pos":""},{"def":"Coarse; homespun; rustic.","pos":""}],"RUSSETY":[{"def":"Of a russet color; russet.","pos":""}],"RUSSIA":[{"def":"A country of Europe and Asia.","pos":""}],"RUSSIAN":[{"def":"Of or pertaining to Russia, its inhabitants, or language.","pos":""},{"def":"A native or inhabitant of Russia; the language of Russia.","pos":""}],"RUSSIAN CHURCH":[{"def":"The established church of the Russian empire.","pos":""}],"RUSSIANIZE":[{"def":"To make Russian, or more or less like the Russians; as, to Russianize the Poles.","pos":""}],"RUSSIFICATION":[{"def":"The act or process of being Russified.","pos":""}],"RUSSIFY":[{"def":"To Russianize; as, to Russify conquered tribes.","pos":""},{"def":"One who, not being a Russian, favors Russian policy and aggrandizement.","pos":""}],"RUSSOPHOBIA":[{"def":"Morbid dread of Russia or of Russian influence.","pos":""}],"RUST":[{"def":"The reddish yellow coating formed on iron when exposed to moist air, consisting of ferric oxide or hydroxide; hence, by extension, any metallic film of corrosion.","pos":""},{"def":"A minute mold or fungus forming reddish or rusty spots on the leaves and stems of cereal and other grasses (Trichobasis Rubigo- vera), now usually believed to be a form or condition of the corn mildew (Puccinia graminis).","pos":""}],"RUSTFUL":[{"def":"Full of rust; resembling rust; causing rust; rusty.","pos":""}],"RUSTIC":[{"def":"Of or pertaining to the country; rural; as, the rustic gods of antiquity.","pos":""},{"def":"Rude; awkward; rough; unpolished; as, rustic manners.","pos":""}],"RUSTICATE":[{"def":"To go into or reside in the country; to ruralize.","pos":""}],"RUSTICATED":[{"def":"resembling rustic work.","pos":""}],"RUSTICATION":[{"def":"The act of rusticating, or the state of being rusticated; specifically, the punishment of a student for some offence, by compelling him to leave the institution for a time.","pos":""}],"RUSTICITY":[{"def":"The quality or state of being rustic; rustic manners; rudeness; simplicity; artlessness.","pos":""}],"RUSTICLY":[{"def":"In a rustic manner; rustically.","pos":""}],"RUSTILY":[{"def":"In a rusty state.","pos":""}],"RUSTINESS":[{"def":"The quality or state of being rusty.","pos":""}],"RUSTLE":[{"def":"To make a quick succession of small sounds, like the rubbing or moving of silk cloth or dry leaves.","pos":""},{"def":"To stir about energetically; to strive to succeed; to bustle about.","pos":""}],"RUSTLER":[{"def":"One who, or that which, rustles.","pos":""},{"def":"A bovine animal that can care for itself in any circumstances; also, an alert, energetic, driving person.","pos":""}],"RUSTY":[{"def":"Resembling, or covered with a substance resembling, rust; affected with rust; rubiginous.","pos":""}]}