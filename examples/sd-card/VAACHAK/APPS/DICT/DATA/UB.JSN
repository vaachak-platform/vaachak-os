{"UBEROUS":[{"def":"Fruitful; copious; abundant; plentiful.","pos":""}],"UBERTY":[{"def":"Fruitfulness; copiousness; abundance; plenty.","pos":""},{"def":"The quality or state of being in a place; local relation; position or location; whereness.","pos":""}],"UBIQUARIAN":[{"def":"One of a school of Lutheran divines which held that the body of Christ is present everywhere, and especially in the eucharist, in virtue of his omnipresence.","pos":""}],"UBIQUITARINESS":[{"def":"Quality or state of being ubiquitary, or ubiquitous.","pos":""}],"UBIQUITARY":[{"def":"One who exists everywhere.","pos":""}],"UBIQUITIST":[{"def":"Same as Ubiquist.","pos":""}],"UBIQUITOUS":[{"def":"Existing or being everywhere, or in all places, at the same time; omnipresent.","pos":""}],"UBIQUITY":[{"def":"The doctrine, as formulated by Luther, that Christ's glorified body is omnipresent.","pos":""}]}