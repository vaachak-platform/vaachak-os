{"COMMUNAL":[{"def":"Pertaining to a commune.","pos":""}],"COMMUNALISM":[{"def":"A French theory of government which holds that commune should be a kind of independent state, and the national government a confederation of such states, having only limited powers.","pos":""}],"COMMUNALIST":[{"def":"An advocate of communalism.","pos":""}],"COMMUNALISTIC":[{"def":"Pertaining to communalism.","pos":""}],"COMMUNE":[{"def":"To converse together with sympathy and confidence; to interchange sentiments or feelings; to take counsel.","pos":""},{"def":"To receive the communion; to partake of the eucharist or Lord's supper.","pos":""}],"COMMUNICABILITY":[{"def":"The quality of being communicable; capability of being imparted.","pos":""}],"COMMUNICABLE":[{"def":"Capable of being communicated, or imparted; as, a communicable disease; communicable knowledge.","pos":""},{"def":"Communicative; free-speaking.","pos":""}],"COMMUNICANT":[{"def":"One who partakes of, or is entitled to partake of, the sacrament of the Lord's supper; a church member.","pos":""},{"def":"One who communicates.","pos":""}],"COMMUNICATE":[{"def":"To share in common; to participate in.","pos":""},{"def":"To impart; to convey; as, to communicate a disease or a sensation; to communicate motion by means of a crank.","pos":""}],"COMMUNICATION":[{"def":"A trope, by which a speaker assumes that his hearer is a partner in his sentiments, and says we, instead of I or you.","pos":""}],"COMMUNICATIVE":[{"def":"Inclined to communicate; ready to impart to others.","pos":""}],"COMMUNICATIVENESS":[{"def":"The quality of being communicative.","pos":""}],"COMMUNICATOR":[{"def":"One who communicates.","pos":""}],"COMMUNICATORY":[{"def":"Imparting knowledge or information.","pos":""}],"COMMUNION":[{"def":"The act of sharing; community; participation.","pos":""},{"def":"Intercourse between two or more persons; esp.","pos":""}],"COMMUNISM":[{"def":"A scheme of equalizing the social conditions of life; specifically, a scheme which contemplates the abolition of inequalities in the possession of property, as by distributing all wealth equally to all, or by holding all wealth in common for the equal use and advantage of all.","pos":""}],"COMMUNIST":[{"def":"An advocate for the theory or practice of communism.","pos":""},{"def":"A supporter of the commune of Paris.","pos":""}],"COMMUNISTIC":[{"def":"Living or having their nests in common, as certain birds.","pos":""}],"COMMUNITY":[{"def":"Common possession or enjoyment; participation; as, a community of goods.","pos":""},{"def":"A body of people having common rights, privileges, or interests, or living in the same place under the same laws and regulations; as, a community of monks.","pos":""}],"COMMUTABILITY":[{"def":"The quality of being commutable.","pos":""}],"COMMUTABLE":[{"def":"Capable of being commuted or interchanged.","pos":""}],"COMMUTABLENESS":[{"def":"The quality of being commutable; interchangeableness.","pos":""}],"COMMUTATION":[{"def":"The change of a penalty or punishment by the pardoning power of the State; as, the commutation of a sentence of death to banishment or imprisonment.","pos":""}],"COMMUTATION TICKET":[{"def":"A ticket for transportation at a reduced rate in consideration of some special circumstance, as increase of travel; specif.","pos":""}],"COMMUTATIVE":[{"def":"Relative to exchange; interchangeable; reciprocal.","pos":""}],"COMMUTATOR":[{"def":"A piece of apparatus used for reversing the direction of an electrical current; an attachment to certain electrical machines, by means of which alternating currents are made to be continuous or to have the same direction.","pos":""}],"COMMUTE":[{"def":"The utmost that could be obtained was that her sentence should be commuted from burning to beheading.","pos":""}],"COMMUTER":[{"def":"One who commutes; especially, one who commutes in traveling.","pos":""}],"COMMUTUAL":[{"def":"Mutual; reciprocal; united.","pos":""}]}