{"FIG":[{"def":"A small fruit tree (Ficus Carica) with large leaves, known from the remotest antiquity.","pos":""}],"FIG-SHELL":[{"def":"A marine univalve shell of the genus Pyrula, or Ficula, resembling a fig in form.","pos":""},{"def":"Made of potter's clay; molded; shaped.","pos":""}],"FIGARY":[{"def":"A frolic; a vagary; a whim.","pos":""}],"FIGENT":[{"def":"Fidgety; restless.","pos":""}],"FIGGUM":[{"def":"A juggler's trick; conjuring.","pos":""}],"FIGHT":[{"def":"To strive or contened for victory, with armies or in single combat; to attempt to defeat, subdue, or destroy an enemy, either by blows or weapons; to contend in arms; -- followed by with or against.","pos":""},{"def":"To act in opposition to anything; to struggle against; to contend; to strive; to make resistance.","pos":""}],"FIGHTER":[{"def":"One who fights; a combatant; a warrior.","pos":""}],"FIGHTING":[{"def":"Qualified for war; fit for battle.","pos":""},{"def":"Occupied in war; being the scene of a battle; as, a fighting field.","pos":""}],"FIGHTWITE":[{"def":"A mulct or fine imposed on a person for making a fight or quarrel to the disturbance of the peace.","pos":""}],"FIGMENT":[{"def":"An invention; a fiction; something feigned or imagined.","pos":""}],"FIGPECKER":[{"def":"The European garden warbler (Sylvia, or Currica, hortensis); -- called also beccafico and greater pettychaps.","pos":""}],"FIGULINE":[{"def":"A piece of pottery ornamented with representations of natural objects.","pos":""}],"FIGURABILITY":[{"def":"The quality of being figurable.","pos":""}],"FIGURABLE":[{"def":"Capable of being brought to a fixed form or shape.","pos":""}],"FIGURAL":[{"def":"Represented by figure or delineation; consisting of figures; as, figural ornaments.","pos":""}],"FIGURANT":[{"def":"One who dances at the opera, not singly, but in groups or figures; an accessory character on the stage, who figures in its scenes, but has nothing to say; hence, one who figures in any scene, without taking a prominent part.","pos":""}],"FIGURANTE":[{"def":"A female figurant; esp.","pos":""}],"FIGURATE":[{"def":"Florid; figurative; involving passing discords by the freer melodic movement of one or more parts or voices in the harmony; as, figurate counterpoint or descant.","pos":""}],"FIGURATED":[{"def":"Having a determinate form.","pos":""}],"FIGURATELY":[{"def":"In a figurate manner.","pos":""}],"FIGURATION":[{"def":"Mixture of concords and discords.","pos":""}],"FIGURATIVE":[{"def":"Representing by a figure, or by resemblance; typical; representative.","pos":""},{"def":"Used in a sense that is tropical, as a metaphor; not literal; -- applied to words and expressions.","pos":""}],"FIGURE":[{"def":"A diagram or drawing; made to represent a magnitude or the relation of two or more magnitudes; a surface or space inclosed on all sides; -- called superficial when inclosed by lines, and solid when inclosed by surface; any arrangement made up of points, lines, angles, surfaces, etc.","pos":""},{"def":"A mode of expressing abstract or immaterial ideas by words which suggest pictures or images from the physical world; pictorial language; a trope; hence, any deviation from the plainest form of statement.","pos":""}],"FIGURED":[{"def":"Adorned with figures; marked with figures; as, figured muslin.","pos":""},{"def":"Not literal; figurative.","pos":""}],"FIGUREHEAD":[{"def":"The figure, statue, or bust, on the prow of a ship.","pos":""}],"FIGURIAL":[{"def":"Represented by figure or delineation.","pos":""}],"FIGURINE":[{"def":"A very small figure, whether human or of an animal; especially, one in terra cotta or the like; -- distinguished from statuette, which is applied to small figures in bronze, marble, etc.","pos":""}],"FIGURIST":[{"def":"One who uses or interprets figurative expressions.","pos":""}],"FIGWORT":[{"def":"A genus of herbaceous plants (Scrophularia), mostly found in the north temperate zones.","pos":""}]}