{"GENT":[{"def":"Gentle; noble; of gentle birth.","pos":""},{"def":"Neat; pretty; fine; elegant.","pos":""}],"GENTEEL":[{"def":"Possessing or exhibiting the qualities popularly regarded as belonging to high birth and breeding; free from vulgarity, or lowness of taste or behavior; adapted to a refined or cultivated taste; polite; well-bred; as, genteel company, manners, address.","pos":""},{"def":"Graceful in mien or form; elegant in appearance, dress, or manner; as, the lady has a genteel person.","pos":""}],"GENTEELISH":[{"def":"Somewhat genteel.","pos":""}],"GENTEELLY":[{"def":"In a genteel manner.","pos":""}],"GENTEELNESS":[{"def":"The quality of being genteel.","pos":""},{"def":"Nobility of birth or of character; gentility.","pos":""}],"GENTIAN":[{"def":"Any one of a genus (Gentiana) of herbaceous plants with opposite leaves and a tubular four- or five-lobed corolla, usually blue, but sometimes white, yellow, or red.","pos":""}],"GENTIANACEOUS":[{"def":"Of or pertaining to a natural order of plants (Gentianaceæ) of which the gentian is the type.","pos":""}],"GENTIANELLA":[{"def":"A kind of blue color.","pos":""}],"GENTIANIC":[{"def":"Pertaining to or derived from the gentian; as, gentianic acid.","pos":""}],"GENTIANINE":[{"def":"A bitter, crystallizable substance obtained from gentian.","pos":""}],"GENTIANOSE":[{"def":"A crystallizable, sugarlike substance, with a slightly sweetish taste, obtained from the gentian.","pos":""}],"GENTILE":[{"def":"One of a non-Jewish nation; one neither a Jew nor a Christian; a worshiper of false gods; a heathen.","pos":""}],"GENTILE-FALCON":[{"def":"See Falcon-gentil.","pos":""}],"GENTILESSE":[{"def":"Gentleness; courtesy; kindness; nobility.","pos":""}],"GENTILISH":[{"def":"Heathenish; pagan.","pos":""}],"GENTILISM":[{"def":"Hethenism; paganism; the worship of false gods.","pos":""},{"def":"Tribal feeling; devotion to one's gens.","pos":""}],"GENTILITY":[{"def":"Good extraction; dignity of birth.","pos":""},{"def":"The quality or qualities appropriate to those who are well born, as self-respect, dignity, courage, courtesy, politeness of manner, a graceful and easy mien and behavior, etc.","pos":""}],"GENTILIZE":[{"def":"To live like a gentile or heathen.","pos":""},{"def":"To act the gentleman; -- with it (see It, 5).","pos":""}],"GENTILLY":[{"def":"In a gentle or hoble manner; frankly.","pos":""}],"GENTIOPIKRIN":[{"def":"A bitter, yellow, crystalline substance, regarded as a glucoside, and obtained from the gentian.","pos":""}],"GENTISIN":[{"def":"A tasteless, yellow, crystalline substance, obtained from the gentian; -- called also gentianin.","pos":""}],"GENTLE":[{"def":"Well-born; of a good family or respectable birth, though not noble.","pos":""},{"def":"Quiet and refined in manners; not rough, harsh, or stern; mild; meek; bland; amiable; tender; as, a gentle nature, temper, or disposition; a gentle manner; a gentle address; a gentle voice.","pos":""}],"GENTLE-HEARTED":[{"def":"Having a kind or gentle disposition.","pos":""}],"GENTLEMAN":[{"def":"One who bears arms, but has no title.","pos":""}],"GENTLEMANHOOD":[{"def":"The qualities or condition of a gentleman.","pos":""},{"def":"Of, pertaining to, resembling, or becoming, a gentleman; well- behaved; courteous; polite.","pos":""}],"GENTLEMANLINESS":[{"def":"The state of being gentlemanly; gentlemanly conduct or manners.","pos":""}],"GENTLEMANSHIP":[{"def":"The carriage or quality of a gentleman.","pos":""}],"GENTLEMEN'S AGREEMENT":[{"def":"An agreement binding only as a matter of honor; often, specif.","pos":""}],"GENTLENESS":[{"def":"The quality or state of being gentle, well-born, mild, benevolent, docile, etc.","pos":""}],"GENTLESHIP":[{"def":"The deportment or conduct of a gentleman.","pos":""}],"GENTLESSE":[{"def":"Gentilesse; gentleness.","pos":""}],"GENTLEWOMAN":[{"def":"A woman of good family or of good breeding; a woman above the vulgar.","pos":""},{"def":"A woman who attends a lady of high rank.","pos":""}],"GENTLY":[{"def":"In a gentle manner.","pos":""}],"GENTOO":[{"def":"A native of Hindostan; a Hindoo.","pos":""}],"GENTRY":[{"def":"Birth; condition; rank by birth.","pos":""},{"def":"People of education and good breeding; in England, in a restricted sense, those between the nobility and the yeomanry.","pos":""}]}