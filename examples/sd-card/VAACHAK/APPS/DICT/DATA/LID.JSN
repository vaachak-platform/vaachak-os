{"LID":[{"def":"That which covers the opening of a vessel or box, etc.","pos":""},{"def":"The cover of the eye; an eyelid.","pos":""}],"LIDDED":[{"def":"Covered with a lid.","pos":""}],"LIDLESS":[{"def":"Having no lid, or not covered with the lids, as the eyes; hence, sleepless; watchful.","pos":""}]}