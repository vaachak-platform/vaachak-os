{"STROAM":[{"def":"To wander about idly and vacantly.","pos":""},{"def":"To take long strides in walking.","pos":""}],"STROBILATION":[{"def":"The act or phenomenon of spontaneously dividing transversely, as do certain species of annelids and helminths; transverse fission.","pos":""}],"STROBILE":[{"def":"A scaly multiple fruit resulting from the ripening of an ament in certain plants, as the hop or pine; a cone.","pos":""},{"def":"An individual asexually producing sexual individuals differing from itself also in other respects, as the tapeworm, -- one of the forms that occur in metagenesis.","pos":""}],"STROBILIFORM":[{"def":"Shaped like a strobile.","pos":""}],"STROBILINE":[{"def":"Of or pertaining to a strobile; strobilaceous; strobiliform; as, strobiline fruits.","pos":""}],"STROBOSCOPE":[{"def":"An instrument for studying or observing the successive phases of a periodic or varying motion by means of light which is periodically interrupted.","pos":""},{"def":"An optical toy similar to the phenakistoscope.","pos":""}],"STROCKLE":[{"def":"A shovel with a turned-up edge, for frit, sand, etc.","pos":""}],"STROKE":[{"def":"The movement, in either direction, of the piston plunger, piston rod, crosshead, etc.","pos":""}],"STROKER":[{"def":"One who strokes; also, one who pretends to cure by stroking.","pos":""}],"STROKESMAN":[{"def":"The man who rows the aftermost oar, and whose stroke is to be followed by the rest.","pos":""}],"STROKING":[{"def":"The act of laying small gathers in cloth in regular order.","pos":""},{"def":"See Stripping, 2.","pos":""}],"STROLL":[{"def":"To wander on foot; to ramble idly or leisurely; to rove.","pos":""}],"STROLLER":[{"def":"One who strolls; a vagrant.","pos":""}],"STROMA":[{"def":"A layer or mass of cellular tissue, especially that part of the thallus of certain fungi which incloses the perithecia.","pos":""}],"STROMATIC":[{"def":"Miscellaneous; composed of different kinds.","pos":""}],"STROMATOLOGY":[{"def":"The history of the formation of stratified rocks.","pos":""}],"STROMB":[{"def":"Any marine univalve mollusk of the genus Strombus and allied genera.","pos":""}],"STROMBITE":[{"def":"A fossil shell of the genus Strombus.","pos":""}],"STROMBOID":[{"def":"Of, pertaining to, or like, Strombus.","pos":""}],"STROMBULIFORM":[{"def":"Formed or shaped like a top.","pos":""},{"def":"Coiled into the shape of a screw or a helix.","pos":""}],"STROMBUS":[{"def":"A genus of marine gastropods in which the shell has the outer lip dilated into a broad wing.","pos":""}],"STROMEYERITE":[{"def":"A steel-gray mineral of metallic luster.","pos":""}],"STRONG":[{"def":"Tending to higher prices; rising; as, a strong market.","pos":""}],"STRONG-MINDED":[{"def":"Having a vigorous mind; esp.","pos":""}],"STRONG-WATER":[{"def":"Distilled or ardent spirits; intoxicating liquor.","pos":""}],"STRONGHAND":[{"def":"Violence; force; power.","pos":""}],"STRONGHOLD":[{"def":"A fastness; a fort or fortress; fortfield place; a place of security.","pos":""}],"STRONGISH":[{"def":"Somewhat strong.","pos":""}],"STRONGLY":[{"def":"In a strong manner; so as to be strong in action or in resistance; with strength; with great force; forcibly; powerfully; firmly; vehemently; as, a town strongly fortified; he objected strongly.","pos":""}],"STRONGYLOID":[{"def":"Like, or pertaining to, Strongylus, a genus of parasitic nematode worms of which many species infest domestic animals.","pos":""},{"def":"A strongyloid worm.","pos":""}],"STRONTIA":[{"def":"An earth of a white color resembling lime in appearance, and baryta in many of its properties.","pos":""}],"STRONTIANITE":[{"def":"Strontium carbonate, a mineral of a white, greenish, or yellowish color, usually occurring in fibrous massive forms, but sometimes in prismatic crystals.","pos":""}],"STRONTIC":[{"def":"Of or pertaining to strontium; containing, or designating the compounds of, strontium.","pos":""}],"STRONTIUM":[{"def":"A metallic element of the calcium group, always naturally occurring combined, as in the minerals strontianite, celestite, etc.","pos":""}],"STROOT":[{"def":"To swell out; to strut.","pos":""}],"STROP":[{"def":"A strap; specifically, same as Strap, 3.","pos":""}],"STROPHANTHUS":[{"def":"A genus of tropical apocynaceous shrubs having singularly twisted flowers.","pos":""}],"STROPHE":[{"def":"In Greek choruses and dances, the movement of the chorus while turning from the right to the left of the orchestra; hence, the strain, or part of the choral ode, sung during this movement.","pos":""}],"STROPHIC":[{"def":"Pertaining to, containing, or consisting of, strophes.","pos":""},{"def":"Furnished with a strophiole, or caruncle, or that which resembles it.","pos":""}],"STROPHIOLE":[{"def":"A crestlike excrescence about the hilum of certain seeds; a caruncle.","pos":""}],"STROUD":[{"def":"A kind of coarse blanket or garment used by the North American Indians.","pos":""}],"STROUDING":[{"def":"Material for strouds; a kind of coarse cloth used in trade with the North American Indians.","pos":""}],"STROUT":[{"def":"To swell; to puff out; to project.","pos":""}],"STROW":[{"def":"Thick as autumnal leaves that strow the brooks In Vallombrosa.","pos":""}]}