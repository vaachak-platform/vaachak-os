{"STEED":[{"def":"A horse, especially a spirited horse for state of war; -- used chiefly in poetry or stately prose.","pos":""}],"STEEDLESS":[{"def":"Having no steed; without a horse.","pos":""},{"def":"To pierce with a sharp instrument; hence, to stitch; to sew; also, to fix; to fasten.","pos":""}],"STEEL":[{"def":"A variety of iron intermediate in composition and properties between wrought iron and cast iron (containing between one half of one per cent and one and a half per cent of carbon), and consisting of an alloy of iron with an iron carbide.","pos":""},{"def":"A chalybeate medicine.","pos":""}],"STEELBOW GOODS":[{"def":"Those goods on a farm, such as corn, cattle, implements husbandry, etc.","pos":""}],"STEELER":[{"def":"One who points, edges, or covers with steel.","pos":""}],"STEELHEAD":[{"def":"A North Pacific salmon (Salmo Gairdneri) found from Northern California to Siberia; -- called also hardhead, and preesil.","pos":""}],"STEELINESS":[{"def":"The quality of being steely.","pos":""}],"STEELING":[{"def":"The process of pointing, edging, or overlaying with steel; specifically, acierage.","pos":""}],"STEELY":[{"def":"Made of steel; consisting of steel.","pos":""},{"def":"Resembling steel; hard; firm; having the color of steel.","pos":""}],"STEELYARD":[{"def":"Steelyard, which was a yard in which steel was sold.","pos":""}],"STEEM":[{"def":"See 1st and 2nd Stem.","pos":""}],"STEEN":[{"def":"A vessel of clay or stone.","pos":""},{"def":"A wall of brick, stone, or cement, used as a lining, as of a well, cistern, etc.","pos":""}],"STEENBOK":[{"def":"Same as Steinbock.","pos":""}],"STEENING":[{"def":"A lining made of brick, stone, or other hard material, as for a well.","pos":""},{"def":"A kind of neckcloth worn in a loose and disorderly fashion.","pos":""}],"STEEP":[{"def":"Bright; glittering; fiery.","pos":""}],"STEEP-DOWN":[{"def":"Deep and precipitous, having steep descent.","pos":""}],"STEEP-UP":[{"def":"Lofty and precipitous.","pos":""}],"STEEPEN":[{"def":"To become steep or steeper.","pos":""}],"STEEPER":[{"def":"A vessel, vat, or cistern, in which things are steeped.","pos":""}],"STEEPLE":[{"def":"A spire; also, the tower and spire taken together; the whole of a structure if the roof is of spire form.","pos":""}],"STEEPLE-CROWNED":[{"def":"Bearing a steeple; as, a steeple-crowned building.","pos":""},{"def":"Having a crown shaped like a steeple; as, a steeple-crowned hat; also, wearing a hat with such a crown.","pos":""}],"STEEPLECHASING":[{"def":"The act of riding steeple chases.","pos":""}],"STEEPLED":[{"def":"Furnished with, or having the form of, a steeple; adorned with steeples.","pos":""}],"STEEPLY":[{"def":"In a steep manner; with steepness; with precipitous declivity.","pos":""}],"STEEPNESS":[{"def":"Quality or state of being steep; precipitous declivity; as, the steepnessof a hill or a roof.","pos":""},{"def":"Height; loftiness.","pos":""}],"STEEPY":[{"def":"Steep; precipitous.","pos":""}],"STEER":[{"def":"A young male of the ox kind; especially, a common ox; a castrated taurine male from two to four years old.","pos":""}],"STEERABLE":[{"def":"Capable of being steered; dirigible.","pos":""}],"STEERAGE":[{"def":"The act or practice of steering, or directing; as, the steerage of a ship.","pos":""},{"def":"Direction; regulation; management; guidance.","pos":""}],"STEERAGEWAY":[{"def":"A rate of motion through the water sufficient to render a vessel governable by the helm.","pos":""}],"STEERER":[{"def":"One who steers; as, a boat steerer.","pos":""}],"STEERLESS":[{"def":"Having no rudder.","pos":""}],"STEERLING":[{"def":"A young small steer.","pos":""}],"STEERSMAN":[{"def":"One who steers; the helmsman of a vessel.","pos":""}],"STEERSMATE":[{"def":"One who steers; steersman.","pos":""}],"STEEVE":[{"def":"To project upward, or make an angle with the horizon or with the line of a vessel's keel; -- said of the bowsprit, etc.","pos":""}],"STEEVING":[{"def":"The act or practice of one who steeves.","pos":""}]}