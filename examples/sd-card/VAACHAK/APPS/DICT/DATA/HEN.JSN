{"HEN":[{"def":"The female of the domestic fowl; also, the female of grouse, pheasants, or any kind of birds; as, the heath hen; the gray hen.","pos":""}],"HEN'S-FOOT":[{"def":"An umbelliferous plant (Caucalis daucoides).","pos":""}],"HEN-HEARTED":[{"def":"Cowardly; timid; chicken-hearted.","pos":""}],"HENBANE":[{"def":"A plant of the genus Hyoscyamus (H.","pos":""}],"HENBIT":[{"def":"A weed of the genus Lamium (L.","pos":""}],"HENCE":[{"def":"From this place; away.","pos":""},{"def":"From this time; in the future; as, a week hence.","pos":""}],"HENCEFORTH":[{"def":"From this time forward; henceforward.","pos":""}],"HENCEFORWARD":[{"def":"From this time forward; henceforth.","pos":""}],"HENCHBOY":[{"def":"A page; a servant.","pos":""}],"HENCHMAN":[{"def":"An attendant; a servant; a follower.","pos":""}],"HENCOOP":[{"def":"A coop or cage for hens.","pos":""}],"HENDE":[{"def":"Skillful; dexterous; clever.","pos":""},{"def":"Friendly; civil; gentle; kind.","pos":""}],"HENDECAGON":[{"def":"A plane figure of eleven sides and eleven angles.","pos":""}],"HENDECANE":[{"def":"A hydrocarbon, C11H24, of the paraffin series; -- so called because it has eleven atoms of carbon in each molecule.","pos":""}],"HENDECASYLLABIC":[{"def":"Pertaining to a line of eleven syllables.","pos":""}],"HENDECASYLLABLE":[{"def":"A metrical line of eleven syllables.","pos":""}],"HENDECATOIC":[{"def":"Undecylic; pertaining to, or derived from, hendecane; as, hendecatoic acid.","pos":""}],"HENDIADYS":[{"def":"A figure in which the idea is expressed by two nouns connected by and, instead of by a noun and limiting adjective; as, we drink from cups and gold, for golden cups.","pos":""}],"HENHOUSE":[{"def":"A house or shelter for fowls.","pos":""}],"HENHUSSY":[{"def":"A cotquean; a man who intermeddles with women's concerns.","pos":""}],"HENNA":[{"def":"A thorny tree or shrub of the genus Lawsonia (L.","pos":""},{"def":"The leaves of the henna plant, or a preparation or dyestuff made from them.","pos":""}],"HENNERY":[{"def":"An inclosed place for keeping hens.","pos":""}],"HENNOTANNIC":[{"def":"Pertaining to, or designating, a brown resinous substance resembling tannin, and extracted from the henna plant; as, hennotannic acid.","pos":""},{"def":"Same as Ontogeny.","pos":""}],"HENOTHEISM":[{"def":"Primitive religion in which each of several divinities is regarded as independent, and is worshiped without reference to the rest.","pos":""}],"HENOTIC":[{"def":"Harmonizing; irenic.","pos":""}],"HENPECK":[{"def":"To subject to petty authority; -- said of a wife who thus treats her husband.","pos":""}],"HENRIETTA CLOTH":[{"def":"A fine wide wooled fabric much used for women's dresses.","pos":""}],"HENROOST":[{"def":"A place where hens roost.","pos":""}],"HENRY":[{"def":"The unit of electric induction; the induction in a circuit when the electro-motive force induced in this circuit is one volt, while the inducing current varies at the rate of one ampère a second.","pos":""}],"HENT":[{"def":"To seize; to lay hold on; to catch; to get.","pos":""}],"HENWARE":[{"def":"A coarse, blackish seaweed.","pos":""}]}