{"AVADAVAT":[{"def":"Same as Amadavat.","pos":""}],"AVAIL":[{"def":"To turn to the advantage of; to be of service to; to profit; to benefit; to help; as, artifices will not avail the sinner in the day of judgment.","pos":""},{"def":"To promote; to assist.","pos":""}],"AVAILABILITY":[{"def":"The quality of being available; availableness.","pos":""},{"def":"That which is available.","pos":""}],"AVAILABLE":[{"def":"Having sufficient power, force, or efficacy, for the object; effectual; valid; as, an available plea.","pos":""},{"def":"Such as one may avail one's self of; capable of being used for the accomplishment of a purpose; usable; profitable; advantageous; convertible into a resource; as, an available measure; an available candidate.","pos":""}],"AVAILABLENESS":[{"def":"Competent power; validity; efficacy; as, the availableness of a title.","pos":""},{"def":"Quality of being available; capability of being used for the purpose intended.","pos":""}],"AVAILABLY":[{"def":"In an available manner; profitably; advantageously; efficaciously.","pos":""}],"AVAILMENT":[{"def":"Profit; advantage.","pos":""}],"AVALANCHE":[{"def":"A large mass or body of snow and ice sliding swiftly down a mountain side, or falling down a precipice.","pos":""},{"def":"A fall of earth, rocks, etc.","pos":""}],"AVALE":[{"def":"To descend; to fall; to dismount.","pos":""}],"AVANT":[{"def":"The front of an army.","pos":""}],"AVANT-COURIER":[{"def":"A person dispatched before another person or company, to give notice of his or their approach.","pos":""}],"AVANT-GUARD":[{"def":"The van or advanced body of an army.","pos":""}],"AVARICE":[{"def":"An excessive or inordinate desire of gain; greediness after wealth; covetousness; cupidity.","pos":""},{"def":"An inordinate desire for some supposed good.","pos":""}],"AVARICIOUS":[{"def":"Actuated by avarice; greedy of gain; immoderately desirous of accumulating property.","pos":""}],"AVAST":[{"def":"Cease; stop; stay.","pos":""}],"AVATAR":[{"def":"The descent of a deity to earth, and his incarnation as a man or an animal; -- chiefly associated with the incarnations of Vishnu.","pos":""}],"AVAUNCE":[{"def":"To advance; to profit.","pos":""}],"AVAUNT":[{"def":"Begone; depart; -- a word of contempt or abhorrence, equivalent to the phrase \"Get thee gone.","pos":""}],"AVE":[{"def":"A reverential salutation.","pos":""}],"AVEL":[{"def":"Yet are not these parts avelled.","pos":""}],"AVELLANE":[{"def":"In the form of four unhusked filberts; as, an avellane cross.","pos":""}],"AVENA":[{"def":"A genus of grasses, including the common oat (Avena sativa); the oat grasses.","pos":""}],"AVENACEOUS":[{"def":"Belonging to, or resembling, oats or the oat grasses.","pos":""}],"AVENAGE":[{"def":"A quantity of oats paid by a tenant to a landlord in lieu of rent.","pos":""}],"AVENALIN":[{"def":"A crystalline globulin, contained in oat kernels, very similar in composition to excelsin, but different in reactions and crystalline form.","pos":""}],"AVENER":[{"def":"An officer of the king's stables whose duty it was to provide oats for the horses.","pos":""}],"AVENGE":[{"def":"To take vengeance for; to exact satisfaction for by punishing the injuring party; to vindicate by inflicting pain or evil on a wrongdoer.","pos":""},{"def":"To treat revengefully; to wreak vengeance on.","pos":""}],"AVENGEMENT":[{"def":"The inflicting of retributive punishment; satisfaction taken.","pos":""}],"AVENGER":[{"def":"One who avenges or vindicates; as, an avenger of blood.","pos":""},{"def":"One who takes vengeance.","pos":""}],"AVENGERESS":[{"def":"A female avenger.","pos":""}],"AVENIOUS":[{"def":"Being without veins or nerves, as the leaves of certain plants.","pos":""}],"AVENS":[{"def":"A plant of the genus Geum, esp.","pos":""}],"AVENTAIL":[{"def":"The movable front to a helmet; the ventail.","pos":""}],"AVENTINE":[{"def":"Pertaining to Mons Aventinus, one of the seven hills on which Rome stood.","pos":""}],"AVENTRE":[{"def":"To thrust forward (at a venture), as a spear.","pos":""}],"AVENTURE":[{"def":"A mischance causing a person's death without felony, as by drowning, or falling into the fire.","pos":""}],"AVENTURINE":[{"def":"A variety of translucent quartz, spangled throughout with scales of yellow mica.","pos":""}],"AVENUE":[{"def":"A way or opening for entrance into a place; a passage by which a place may by reached; a way of approach or of exit.","pos":""},{"def":"The principal walk or approach to a house which is withdrawn from the road, especially, such approach bordered on each side by trees; any broad passageway thus bordered.","pos":""}],"AVER":[{"def":"A work horse, or working ox.","pos":""}],"AVERAGE":[{"def":"That service which a tenant owed his lord, to be done by the work beasts of the tenant, as the carriage of wheat, turf, etc.","pos":""},{"def":"In the English corn trade, the medial price of the several kinds of grain in the principal corn markets.","pos":""}],"AVERCORN":[{"def":"A reserved rent in corn, formerly paid to religious houses by their tenants or farmers.","pos":""}],"AVERMENT":[{"def":"A positive statement of facts; an allegation; an offer to justify or prove what is alleged.","pos":""},{"def":"Of or pertaining to Avernus, a lake of Campania, in Italy, famous for its poisonous vapors, which ancient writers fancied were so malignant as to kill birds flying over it.","pos":""}],"AVERPENNY":[{"def":"Money paid by a tenant in lieu of the service of average.","pos":""}],"AVERROISM":[{"def":"The tenets of the Averroists.","pos":""}],"AVERROIST":[{"def":"One of a sect of peripatetic philosophers, who appeared in Italy before the restoration of learning; so denominated from Averroes, or Averrhoes, a celebrated Arabian philosopher.","pos":""}],"AVERRUNCATE":[{"def":"To avert; to ward off.","pos":""}],"AVERRUNCATION":[{"def":"The act of averting.","pos":""}],"AVERRUNCATOR":[{"def":"An instrument for pruning trees, consisting of two blades, or a blade and a hook, fixed on the end of a long rod.","pos":""}],"AVERSATION":[{"def":"A turning from with dislike; aversion.","pos":""}],"AVERSE":[{"def":"Turned away or backward.","pos":""},{"def":"Having a repugnance or opposition of mind; disliking; disinclined; unwilling; reluctant.","pos":""}],"AVERSELY":[{"def":"Backward; in a backward direction; as, emitted aversely.","pos":""},{"def":"With repugnance or aversion; unwillingly.","pos":""}],"AVERSENESS":[{"def":"The quality of being averse; opposition of mind; unwillingness.","pos":""}],"AVERSION":[{"def":"Opposition or repugnance of mind; fixed dislike; antipathy; disinclination; reluctance.","pos":""}],"AVERT":[{"def":"To turn aside, or away; as, to avert the eyes from an object; to ward off, or prevent, the occurrence or effects of; as, how can the danger be averted \"To avert his ire.","pos":""}],"AVERTED":[{"def":"Turned away, esp.","pos":""}],"AVERTER":[{"def":"One who, or that which, averts.","pos":""}],"AVERTIBLE":[{"def":"Capable of being averted; preventable.","pos":""}],"AVES":[{"def":"The class of Vertebrata that includes the birds.","pos":""}],"AVESTA":[{"def":"The Zoroastrian scriptures.","pos":""}],"AVESTAN":[{"def":"Of or pertaining to the Avesta or the language of the Avesta.","pos":""},{"def":"The language of the Avesta; -- less properly called Zend.","pos":""}],"AVIADO":[{"def":"One who works a mine with means provided by another.","pos":""}],"AVIAN":[{"def":"Of or instrument to birds.","pos":""}],"AVIARY":[{"def":"A house, inclosure, large cage, or other place, for keeping birds confined; a bird house.","pos":""}],"AVIATE":[{"def":"To fly, or navigate the air, in an aëroplane or heavier-than- air flying machine.","pos":""}],"AVIATION":[{"def":"The art or science of flying.","pos":""}],"AVIATOR":[{"def":"A woman aviator.","pos":""}],"AVICULA":[{"def":"A genus of marine bivalves, having a pearly interior, allied to the pearl oyster; -- so called from a supposed resemblance of the typical species to a bird.","pos":""}],"AVICULAR":[{"def":"Of or pertaining to a bird or to birds.","pos":""}],"AVICULARIA":[{"def":"See prehensile processes on the cells of some Bryozoa, often having the shape of a bird's bill.","pos":""}],"AVICULTURE":[{"def":"Rearing and care of birds.","pos":""}],"AVID":[{"def":"Longing eagerly for; eager; greedy.","pos":""}],"AVIDIOUSLY":[{"def":"Eagerly; greedily.","pos":""}],"AVIDITY":[{"def":"Greediness; strong appetite; eagerness; intenseness of desire; as, to eat with avidity.","pos":""}],"AVIETTE":[{"def":"A heavier-than-air flying machine in which the motive power is furnished solely by the aviator.","pos":""}],"AVIFAUNA":[{"def":"The birds, or all the kinds of birds, inhabiting a region.","pos":""}],"AVIGNON BERRY":[{"def":"The fruit of the Rhamnus infectorius, eand of other species of the same genus; -- so called from the city of Avignon, in France.","pos":""}],"AVILE":[{"def":"To abase or debase; to vilify; to depreciate.","pos":""}],"AVIS":[{"def":"Advice; opinion; deliberation.","pos":""}],"AVISE":[{"def":"To look at; to view; to think of.","pos":""},{"def":"To advise; to counsel.","pos":""}],"AVISEFUL":[{"def":"Watchful; circumspect.","pos":""}],"AVISEMENT":[{"def":"Advisement; observation; deliberation.","pos":""}],"AVISO":[{"def":"Information; advice.","pos":""},{"def":"An advice boat, or dispatch boat.","pos":""}],"AVOCADO":[{"def":"The pulpy fruit of Persea gratissima, a tree of tropical America.","pos":""}],"AVOCATE":[{"def":"To call off or away; to withdraw; to transfer to another tribunal.","pos":""}],"AVOCATION":[{"def":"Pursuits; duties; affairs which occupy one's time; usual employment; vocation.","pos":""}],"AVOCATIVE":[{"def":"That which calls aside; a dissuasive.","pos":""},{"def":"A grallatorial bird, of the genus Recurvirostra; the scooper.","pos":""}],"AVOID":[{"def":"To defeat or evade; to invalidate.","pos":""}],"AVOIDABLE":[{"def":"Capable of being vacated; liable to be annulled or made invalid; voidable.","pos":""},{"def":"Capable of being avoided, shunned, or escaped.","pos":""}],"AVOIDANCE":[{"def":"The act of annulling; annulment.","pos":""},{"def":"The act of becoming vacant, or the state of being vacant; -- specifically used for the state of a benefice becoming void by the death, deprivation, or resignation of the incumbent.","pos":""}],"AVOIDER":[{"def":"The person who carries anything away, or the vessel in which things are carried away.","pos":""},{"def":"One who avoids, shuns, or escapes.","pos":""}],"AVOIDLESS":[{"def":"Unavoidable; inevitable.","pos":""}],"AVOIRDUPOIS":[{"def":"Goods sold by weight.","pos":""},{"def":"Avoirdupois weight.","pos":""}],"AVOKE":[{"def":"To call from or back again.","pos":""}],"AVOLATE":[{"def":"To fly away; to escape; to exhale.","pos":""}],"AVOLATION":[{"def":"The act of flying; flight; evaporation.","pos":""}],"AVOUCH":[{"def":"To appeal to; to cite or claim as authority.","pos":""},{"def":"To maintain a just or true; to vouch for.","pos":""}],"AVOUCHABLE":[{"def":"Capable of being avouched.","pos":""}],"AVOUCHER":[{"def":"One who avouches.","pos":""}],"AVOUCHMENT":[{"def":"The act of avouching; positive declaration.","pos":""}],"AVOW":[{"def":"To acknowledge and justify, as an act done.","pos":""}],"AVOWABLE":[{"def":"Capable of being avowed, or openly acknowledged, with confidence.","pos":""}],"AVOWAL":[{"def":"An open declaration; frank acknowledgment; as, an avowal of such principles.","pos":""}],"AVOWANCE":[{"def":"Act of avowing; avowal.","pos":""},{"def":"Upholding; defense; vindication.","pos":""}],"AVOWANT":[{"def":"The defendant in replevin, who avows the distress of the goods, and justifies the taking.","pos":""}],"AVOWED":[{"def":"Openly acknowledged or declared; admitted.","pos":""}],"AVOWEE":[{"def":"The person who has a right to present to a benefice; the patron; an advowee.","pos":""}],"AVOWER":[{"def":"One who avows or asserts.","pos":""}],"AVOWRY":[{"def":"An advocate; a patron; a patron saint.","pos":""},{"def":"The act of the distrainer of goods, who, in an action of replevin, avows and justifies the taking in his own right.","pos":""}],"AVOYER":[{"def":"A chief magistrate of a free imperial city or canton of Switzerland.","pos":""}],"AVULSE":[{"def":"To pluck or pull off.","pos":""}],"AVULSION":[{"def":"The sudden removal of lands or soil from the estate of one man to that of another by an inundation or a current, or by a sudden change in the course of a river by which a part of the estate of one man is cut off and joined to the estate of another.","pos":""}],"AVUNCULAR":[{"def":"Of or pertaining to an uncle.","pos":""}]}