{"CYCAD":[{"def":"Any plant of the natural order Cycadeceæ, as the sago palm, etc.","pos":""}],"CYCADACEOUS":[{"def":"Pertaining to, or resembling, an order of plants like the palms, but having exogenous wood.","pos":""}],"CYCAS":[{"def":"A genus of trees, intermediate in character between the palms and the pines.","pos":""}],"CYCLAMEN":[{"def":"A genus of plants of the Primrose family, having depressed rounded corms, and pretty nodding flowers with the petals so reflexed as to point upwards, whence it is called rabbit's ears.","pos":""}],"CYCLAMIN":[{"def":"A white amorphous substance, regarded as a glucoside, extracted from the corm of Cyclamen Europæum.","pos":""}],"CYCLAS":[{"def":"A long gown or surcoat (cut off in front), worn in the Middle Ages.","pos":""}],"CYCLE":[{"def":"One entire round in a circle or a spire; as, a cycle or set of leaves.","pos":""}],"CYCLIDE":[{"def":"A surface of the fourth degree, having certain special relations to spherical surfaces.","pos":""}],"CYCLING":[{"def":"The act, art, or practice, of riding a cycle, esp.","pos":""}],"CYCLO-":[{"def":"A combining form meaning circular, of a circle or wheel.","pos":""}],"CYCLOBRANCHIATE":[{"def":"Having the gills around the margin of the body, as certain limpets.","pos":""}],"CYCLOGANOID":[{"def":"Of or pertaining to the Cycloganoidei.","pos":""}],"CYCLOGANOIDEI":[{"def":"An order of ganoid fishes, having cycloid scales.","pos":""}],"CYCLOGRAPH":[{"def":"Cy\"clo*graph (s\"kl-grf), n.","pos":""}],"CYCLOID":[{"def":"A curve generated by a point in the plane of a circle when the circle is rolled along a straight line, keeping always in the same plane.","pos":""}],"CYCLOIDAL":[{"def":"Pertaining to, or resembling, a cycloid; as, the cycloidal space is the space contained between a cycloid and its base.","pos":""}],"CYCLOIDEI":[{"def":"An order of fishes, formerly proposed by Agassiz, for those with thin, smooth scales, destitute of marginal spines, as the herring and salmon.","pos":""}],"CYCLOIDIAN":[{"def":"Same as 2d and 3d Cycloid.","pos":""}],"CYCLOMETER":[{"def":"A contrivance for recording the revolutions of a wheel, as of a bicycle.","pos":""}],"CYCLOMETRY":[{"def":"The art of measuring circles.","pos":""}],"CYCLONE":[{"def":"A violent storm, often of vast extent, characterized by high winds rotating about a calm center of low atmospheric pressure.","pos":""},{"def":"A cellar or excavation used for refuge from a cyclone, or tornado.","pos":""}],"CYCLONIC":[{"def":"Pertaining to a cyclone.","pos":""}],"CYCLONOSCOPE":[{"def":"An apparatus to assist in locating the center of a cyclone.","pos":""}],"CYCLOP":[{"def":"See Note under Cyclops, 1.","pos":""}],"CYCLOPEAN":[{"def":"Pertaining to the Cyclops; characteristic of the Cyclops; huge; gigantic; vast and rough; massive; as, Cyclopean labors; Cyclopean architecture.","pos":""},{"def":"The circle or compass of the arts and sciences (originally, of the seven so-called liberal arts and sciences); circle of human knowledge.","pos":""}],"CYCLOPEDIC":[{"def":"Belonging to the circle of the sciences, or to a cyclopedia; of the nature of a cyclopedia; hence, of great range, extent, or amount; as, a man of cyclopedic knowledge.","pos":""}],"CYCLOPEDIST":[{"def":"A maker of, or writer for, a cyclopedia.","pos":""}],"CYCLOPIC":[{"def":"Pertaining to the Cyclops; Cyclopean.","pos":""}],"CYCLOPS":[{"def":"One of a race of giants, sons of Neptune and Amphitrite, having but one eye, and that in the middle of the forehead.","pos":""},{"def":"A genus of minute Entomostraca, found both in fresh and salt water.","pos":""}],"CYCLORAMA":[{"def":"A pictorial view which is extended circularly, so that the spectator is surrounded by the objects represented as by things in nature.","pos":""}],"CYCLOSCOPE":[{"def":"A machine for measuring at any moment velocity of rotation, as of a wheel of a steam engine.","pos":""}],"CYCLOSIS":[{"def":"The circulation or movement of protoplasmic granules within a living vegetable cell.","pos":""}],"CYCLOSTOME":[{"def":"A division of Bryozoa, in which the cells have circular apertures.","pos":""},{"def":"Pertaining to the Cyclostomi.","pos":""}],"CYCLOSTOMI":[{"def":"A glass of fishes having a suckerlike mouth, without jaws, as the lamprey; the Marsipobranchii.","pos":""}],"CYCLOSTYLAR":[{"def":"Relating to a structure composed of a circular range of columns, without a core or building within.","pos":""}],"CYCLOSTYLE":[{"def":"A contrivance for producing manifold copies of writing or drawing.","pos":""}]}