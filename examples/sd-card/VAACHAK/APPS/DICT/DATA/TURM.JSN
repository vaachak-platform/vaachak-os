{"TURM":[{"def":"A troop; a company.","pos":""}],"TURMERIC":[{"def":"An East Indian plant of the genus Curcuma, of the Ginger family.","pos":""}],"TURMEROL":[{"def":"Turmeric oil, a brownish yellow, oily substance extracted from turmeric by ligroin.","pos":""}],"TURMOIL":[{"def":"Harassing labor; trouble; molestation by tumult; disturbance; worrying confusion.","pos":""}]}