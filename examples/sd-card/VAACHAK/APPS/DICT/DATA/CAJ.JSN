{"CAJOLE":[{"def":"To deceive with flattery or fair words; to wheedle.","pos":""}],"CAJOLEMENT":[{"def":"The act of cajoling; the state of being cajoled; cajolery.","pos":""}],"CAJOLER":[{"def":"A flatterer; a wheedler.","pos":""}],"CAJOLERY":[{"def":"A wheedling to delude; words used in cajoling; flattery.","pos":""}],"CAJUN":[{"def":"In Louisiana, a person reputed to be Acadian French descent.","pos":""}],"CAJUPUT":[{"def":"A highly stimulating volatile infammable oil, distilled from the leaves of an East Indian tree (Melaleuca cajuputi, etc.","pos":""}],"CAJUPUTENE":[{"def":"A colorlees or greenish oil extracted from cajuput.","pos":""}]}