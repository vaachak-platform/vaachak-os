{"ADIABATIC":[{"def":"Not giving out or receiving heat.","pos":""}],"ADIACTINIC":[{"def":"Not transmitting the actinic rays.","pos":""}],"ADIANTUM":[{"def":"A genus of ferns, the leaves of which shed water; maidenhair.","pos":""}],"ADIAPHORISM":[{"def":"Religious indifference.","pos":""}],"ADIAPHORIST":[{"def":"One of the German Protestants who, with Melanchthon, held some opinions and ceremonies to be indifferent or nonessential, which Luther condemned as sinful or heretical.","pos":""}],"ADIAPHORISTIC":[{"def":"Pertaining to matters indifferent in faith and practice.","pos":""}],"ADIAPHORITE":[{"def":"Same as Adiaphorist.","pos":""}],"ADIAPHOROUS":[{"def":"Incapable of doing either harm or good, as some medicines.","pos":""}],"ADIATHERMIC":[{"def":"Not pervious to heat.","pos":""}],"ADIEU":[{"def":"Good-by; farewell; an expression of kind wishes at parting.","pos":""}],"ADIGHT":[{"def":"To set in order; to array; to attire; to deck, to dress.","pos":""}],"ADIOS":[{"def":"Adieu; farewell; good-by; -- chiefly used among Spanish- speaking people.","pos":""}],"ADIPIC":[{"def":"Pertaining to, or derived from, fatty or oily substances; -- applied to certain acids obtained from fats by the action of nitric acid.","pos":""}],"ADIPOCERATE":[{"def":"To convert adipocere.","pos":""}],"ADIPOCERATION":[{"def":"The act or process of changing into adipocere.","pos":""}],"ADIPOCERE":[{"def":"A soft, unctuous, or waxy substance, of a light brown color, into which the fat and muscle tissue of dead bodies sometimes are converted, by long immersion in water or by burial in moist places.","pos":""}],"ADIPOCERIFORM":[{"def":"Having the form or appearance of adipocere; as, an adipoceriform tumor.","pos":""}],"ADIPOLYSIS":[{"def":"The digestion of fats.","pos":""}],"ADIPOLYTIC":[{"def":"Hydrolyzing fats; converting neutral fats into glycerin and free fatty acids, esp.","pos":""}],"ADIPOMA":[{"def":"A mass of fat found internally; also, a fatty tumor.","pos":""}],"ADIPOSE":[{"def":"Of or pertaining to animal fat; fatty.","pos":""},{"def":"The state of being fat; fatness.","pos":""}],"ADIPSOUS":[{"def":"Quenching thirst, as certain fruits.","pos":""}],"ADIPSY":[{"def":"Absence of thirst.","pos":""}],"ADIT":[{"def":"An entrance or passage.","pos":""},{"def":"Admission; approach; access.","pos":""}]}