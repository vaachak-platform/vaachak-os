{"LAM":[{"def":"To beat soundly; to thrash.","pos":""}],"LAMA":[{"def":"In Thibet, Mongolia, etc.","pos":""}],"LAMAIC":[{"def":"Of or pertaining to Lamaism.","pos":""}],"LAMAISM":[{"def":"A modified form of Buddhism which prevails in Thibet, Mongolia, and some adjacent parts of Asia; -- so called from the name of its priests.","pos":""},{"def":"One who believes in Lamaism.","pos":""}],"LAMAISTIC":[{"def":"Of or pertaining to Lamaism.","pos":""}],"LAMARCKIAN":[{"def":"Pertaining to, or involved in, the doctrines of Lamarckianism.","pos":""}],"LAMARCKISM":[{"def":"The theory that structural variations, characteristic of species and genera, are produced in animals and plants by the direct influence of physical environments, and esp.","pos":""}],"LAMB":[{"def":"The young of the sheep.","pos":""}],"LAMB'S-QUARTERS":[{"def":"A name given to several plants of the Goosefoot family, sometimes used as pot herbs, as Chenopodium album and Atriplex patulsa.","pos":""}],"LAMBALE":[{"def":"A feast at the time of shearing lambs.","pos":""}],"LAMBASTE":[{"def":"To beat severely.","pos":""}],"LAMBATIVE":[{"def":"Taken by licking with the tongue.","pos":""}],"LAMBDA":[{"def":"The point of junction of the sagittal and lambdoid sutures of the skull.","pos":""}],"LAMBDACISM":[{"def":"A fault in speaking or in composition, which consists in too frequent use of the letter l, or in doubling it erroneously.","pos":""},{"def":"A defect in pronunciation of the letter l when doubled, which consists in giving it a sound as if followed by y, similar to that of the letters lli in billion.","pos":""}],"LAMBDOID":[{"def":"Shaped like the Greek letter lambda (as, the lambdoid suture between the occipital and parietal bones of the skull.","pos":""}],"LAMBDOIDAL":[{"def":"Same as Lambdoid.","pos":""}],"LAMBENT":[{"def":"Playing on the surface; touching lightly; gliding over.","pos":""},{"def":"Twinkling or gleaming; fickering.","pos":""}],"LAMBERT PINE":[{"def":"The gigantic sugar pine of California and Oregon (Pinus Lambertiana).","pos":""}],"LAMBKILL":[{"def":"A small American ericaceous shrub (Kalmia angustifolia); -- called also calfkill, sheepkill, sheep laurel, etc.","pos":""}],"LAMBLIKE":[{"def":"Like a lamb; gentle; meek; inoffensive.","pos":""}],"LAMBOYS":[{"def":"Same as Base, n.","pos":""}],"LAMBREQUIN":[{"def":"A kind of pendent scarf or covering attached to the helmet, to protect it from wet or heat.","pos":""},{"def":"A leather flap hanging from a cuirass.","pos":""}],"LAMBSKIN":[{"def":"The skin of a lamb; especially, a skin dressed with the wool on, and used as a mat.","pos":""},{"def":"A kind of woolen.","pos":""}],"LAME":[{"def":"Hence, hobbling; limping; inefficient; imperfect.","pos":""}],"LAMELLA":[{"def":"a thin plate or scale of anything, as a thin scale growing from the petals of certain flowers; or one of the thin plates or scales of which certain shells are composed.","pos":""},{"def":"Flat and thin; lamelliform; composed of lamellæ.","pos":""}],"LAMELLARY":[{"def":"Of or pertaining to lamella or to lamellæ; lamellar.","pos":""},{"def":"Composed of, or furnished with, thin plates or scales.","pos":""}],"LAMELLIBRANCH":[{"def":"One of the Lamellibranchia.","pos":""},{"def":"A class of Mollusca including all those that have bivalve shells, as the clams, oysters, mussels, etc.","pos":""}],"LAMELLIBRANCHIATE":[{"def":"Having lamellar gills; belonging to the Lamellibranchia.","pos":""},{"def":"One of the Lamellibranchia.","pos":""}],"LAMELLICORN":[{"def":"A lamellicorn insect.","pos":""}],"LAMELLICORNIA":[{"def":"A group of lamellicorn, plant-eating beetles; -- called also Lamellicornes.","pos":""}],"LAMELLIFEROUS":[{"def":"Bearing, or composed of, lamellæ, or thin layers, plates, or scales; foliated.","pos":""}],"LAMELLIFORM":[{"def":"Thin and flat; scalelike; lamellar.","pos":""}],"LAMELLIROSTRAL":[{"def":"Having a lamellate bill, as ducks and geese.","pos":""}],"LAMELLIROSTRES":[{"def":"A group of birds embracing the Anseres and flamingoes, in which the bill is lamellate.","pos":""}],"LAMELLOSE":[{"def":"Composed of, or having, lamellæ; lamelliform.","pos":""}],"LAMELY":[{"def":"An a lame, crippled, disabled, or imperfect manner; as, to walk lamely; a figure lamely drawn.","pos":""}],"LAMENESS":[{"def":"The condition or quality of being lame; as, the lameness of an excuse or an argument.","pos":""}],"LAMENT":[{"def":"To express or feel sorrow; to weep or wail; to mourn.","pos":""}],"LAMENTABLE":[{"def":"Mourning; sorrowful; expressing grief; as, a lamentable countenance.","pos":""},{"def":"Fitted to awaken lament; to be lamented; sorrowful; pitiable; as, a lamentable misfortune, or error.","pos":""}],"LAMENTATION":[{"def":"A book of the Old Testament attributed to the prophet Jeremiah, and taking its name from the nature of its contents.","pos":""}],"LAMENTED":[{"def":"Mourned for; bewailed.","pos":""}],"LAMENTER":[{"def":"One who laments.","pos":""}],"LAMENTING":[{"def":"Lamentings heard i' the air.","pos":""}],"LAMENTINGLY":[{"def":"In a lamenting manner.","pos":""}],"LAMES":[{"def":"Small steel plates combined together so as to slide one upon the form a piece of armor.","pos":""}],"LAMETTA":[{"def":"Foil or wire made of gold, silver, or brass.","pos":""}],"LAMIA":[{"def":"A monster capable of assuming a woman's form, who was said to devour human beings or suck their blood; a vampire; a sorceress; a with.","pos":""}],"LAMINA":[{"def":"The blade of a leaf; the broad, expanded portion of a petal or sepal of a flower.","pos":""},{"def":"A thin plate or scale; specif.","pos":""}],"LAMINABILITY":[{"def":"The quality or state of being laminable.","pos":""}],"LAMINABLE":[{"def":"Capable of being split into laminæ or thin plates, as mica; capable of being extended under pressure into a thin plate or strip.","pos":""},{"def":"In, or consisting of, thin plates or layers; having the form of a thin plate or lamina.","pos":""}],"LAMINARIA":[{"def":"A genus of great seaweeds with long and broad fronds; kelp, or devil's apron.","pos":""}],"LAMINARIAN":[{"def":"Pertaining to seaweeds of the genus Laminaria, or to that zone of the sea (from two to ten fathoms in depth) where the seaweeds of this genus grow.","pos":""}],"LAMINARITE":[{"def":"A broad-leafed fossil alga.","pos":""}],"LAMINATE":[{"def":"Consisting of, or covered with, laminæ, or thin plates, scales, or layers, one over another; laminated.","pos":""}],"LAMINATING":[{"def":"Forming, or separating into, scales or thin layers.","pos":""}],"LAMINATION":[{"def":"The process of laminating, or the state of being laminated.","pos":""}],"LAMINIFEROUS":[{"def":"Having a structure consisting of laminæ, or thin layers.","pos":""}],"LAMINIPLANTAR":[{"def":"Having the tarsus covered behind with a horny sheath continuous on both sides, as in most singing birds, except the larks.","pos":""}],"LAMINITIS":[{"def":"Inflammation of the laminæ or fleshy plates along the coffin bone of a horse; founder.","pos":""}],"LAMMAS":[{"def":"The first day of August; -- called also Lammas day, and Lammastide.","pos":""},{"def":"A very large vulture (Gypaëtus barbatus), which inhabits the mountains of Southern Europe, Asia, and Northern Africa.","pos":""}],"LAMNUNGUIA":[{"def":"Same as Hyracoidea.","pos":""}],"LAMP":[{"def":"A thin plate or lamina.","pos":"noun"}],"LAMP-POST":[{"def":"A post (generally a pillar of iron) supporting a lamp or lantern for lighting a street, park, etc.","pos":""}],"LAMPAD":[{"def":"A lamp or candlestick.","pos":""}],"LAMPADIST":[{"def":"One who gained the prize in the lampadrome.","pos":""}],"LAMPADROME":[{"def":"A race run by young men with lighted torches in their hands.","pos":""}],"LAMPAS":[{"def":"An inflammation and swelling of the soft parts of the roof of the mouth immediately behind the fore teeth in the horse; -- called also lampers.","pos":""}],"LAMPATE":[{"def":"A supposed salt of lampic acid.","pos":""}],"LAMPBLACK":[{"def":"The fine impalpable soot obtained from the smoke of carbonaceous substances which have been only partly burnt, as in the flame of a smoking lamp.","pos":""}],"LAMPERN":[{"def":"The river lamprey (Ammocoetes, or Lampetra, fluviatilis).","pos":""}],"LAMPIC":[{"def":"Pertaining to, or produced by, a lamp; -- formerly said of a supposed acid.","pos":""}],"LAMPING":[{"def":"Shining; brilliant.","pos":""}],"LAMPLESS":[{"def":"Being without a lamp, or without light; hence, being without appreciation; dull.","pos":""}],"LAMPLIGHT":[{"def":"Light from a lamp.","pos":""}],"LAMPLIGHTER":[{"def":"The calico bass.","pos":""}],"LAMPOON":[{"def":"A personal satire in writing; usually, malicious and abusive censure written only to reproach and distress.","pos":""}],"LAMPOONER":[{"def":"The writer of a lampoon.","pos":""}],"LAMPOONRY":[{"def":"The act of lampooning; a lampoon, or lampoons.","pos":""}],"LAMPREY":[{"def":"An eel-like marsipobranch of the genus Petromyzon, and allied genera.","pos":""}],"LAMPYRINE":[{"def":"An insect of the genus Lampyris, or family Lampyridæ.","pos":""}],"LAMPYRIS":[{"def":"A genus of coleopterous insects, including the glowworms.","pos":""}]}