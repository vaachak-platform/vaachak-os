{"GAB":[{"def":"The hook on the end of an eccentric rod opposite the strap.","pos":""}],"GABARAGE":[{"def":"A kind of coarse cloth for packing goods.","pos":""},{"def":"A coarse frock or loose upper garment formerly worn by Jews; a mean dress.","pos":""}],"GABBER":[{"def":"A liar; a deceiver.","pos":""},{"def":"One addicted to idle talk.","pos":""}],"GABBLE":[{"def":"To talk fast, or to talk without meaning; to prate; to jabber.","pos":""},{"def":"To utter inarticulate sounds with rapidity; as, gabbling fowls.","pos":""}],"GABBLER":[{"def":"One who gabbles; a prater.","pos":""}],"GABBRO":[{"def":"A name originally given by the Italians to a kind of serpentine, later to the rock called euphotide, and now generally used for a coarsely crystalline, igneous rock consisting of lamellar pyroxene (diallage) and labradorite, with sometimes chrysolite (olivine gabbro).","pos":""}],"GABEL":[{"def":"A rent, service, tribute, custom, tax, impost, or duty; an excise.","pos":""}],"GABELER":[{"def":"A collector of gabels or taxes.","pos":""}],"GABELLE":[{"def":"A tax, especially on salt.","pos":""}],"GABER-LUNZIE":[{"def":"A beggar with a wallet; a licensed beggar.","pos":""}],"GABERT":[{"def":"A lighter, or vessel for inland navigation.","pos":""}],"GABION":[{"def":"A hollow cylinder of wickerwork, like a basket without a bottom.","pos":"noun"},{"def":"An openwork frame, as of poles, filled with stones and sunk, to assist in forming a bar dyke, etc.","pos":"noun"}],"GABIONADE":[{"def":"A traverse made with gabions between guns or on their flanks, protecting them from enfilading fire.","pos":""}],"GABIONAGE":[{"def":"The part of a fortification built of gabions.","pos":""}],"GABIONED":[{"def":"Furnished with gabions.","pos":""}],"GABLET":[{"def":"A small gable, or gable-shaped canopy, formed over a tabernacle, niche, etc.","pos":""}],"GABLOCK":[{"def":"A false spur or gaff, fitted on the heel of a gamecock.","pos":""}],"GABY":[{"def":"A simpleton; a dunce; a lout.","pos":""}]}