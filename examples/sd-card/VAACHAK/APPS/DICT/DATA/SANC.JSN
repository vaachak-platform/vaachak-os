{"SANCHO":[{"def":"The nine of trumps in sancho pedro.","pos":""}],"SANCHO PEDRO":[{"def":"A variety of auction pitch in which the nine (sancho) and five (pedro) of trumps are added as counting cards at their pip value, and the ten of trumps counts game.","pos":""}],"SANCTIFICATION":[{"def":"The act of sanctifying or making holy; the being sanctified or made holy; esp.","pos":""},{"def":"The act of consecrating, or of setting apart, for a sacred purpose; consecration.","pos":""}],"SANCTIFIED":[{"def":"Made holy; also, made to have the air of sanctity; sanctimonious.","pos":""}],"SANCTIFIER":[{"def":"One who sanctifies, or makes holy; specifically, the Holy Spirit.","pos":""}],"SANCTIFY":[{"def":"To make sacred or holy; to set apart to a holy or religious use; to consecrate by appropriate rites; to hallow.","pos":""},{"def":"To make free from sin; to cleanse from moral corruption and pollution; to purify.","pos":""}],"SANCTIFYINGLY":[{"def":"In a manner or degree tending to sanctify or make holy.","pos":""}],"SANCTILOQUENT":[{"def":"Discoursing on heavenly or holy things, or in a holy manner.","pos":""}],"SANCTIMONIOUS":[{"def":"Possessing sanctimony; holy; sacred; saintly.","pos":""},{"def":"Making a show of sanctity; affecting saintliness; hypocritically devout or pious.","pos":""}],"SANCTIMONY":[{"def":"Holiness; devoutness; scrupulous austerity; sanctity; especially, outward or artificial saintliness; assumed or pretended holiness; hypocritical devoutness.","pos":""}],"SANCTION":[{"def":"Solemn or ceremonious ratification; an official act of a superior by which he ratifies and gives validity to the act of some other person or body; establishment or furtherance of anything by authority to it; confirmation; approbation.","pos":""},{"def":"Anything done or said to enforce the will, law, or authority of another; as, legal sanctions.","pos":""}],"SANCTIONARY":[{"def":"Of, pertaining to, or giving, sanction.","pos":""}],"SANCTITUDE":[{"def":"Holiness; sacredness; sanctity.","pos":""}],"SANCTITY":[{"def":"The state or quality of being sacred or holy; holiness; saintliness; moral purity; godliness.","pos":""},{"def":"Sacredness; solemnity; inviolability; religious binding force; as, the sanctity of an oath.","pos":""}],"SANCTUARIZE":[{"def":"To shelter by means of a sanctuary or sacred privileges.","pos":""}],"SANCTUARY":[{"def":"A sacred place; a consecrated spot; a holy and inviolable site.","pos":""}],"SANCTUM":[{"def":"A sacred place; hence, a place of retreat; a room reserved for personal use; as, an editor's sanctum.","pos":""}],"SANCTUS":[{"def":"A part of the Mass, or, in Protestant churches, a part of the communion service, of which the first words in Latin are Sanctus, sanctus, sanctus [Holy, holy, holy]; -- called also Tersanctus.","pos":""},{"def":"An anthem composed for these words.","pos":""}]}