{"WIELD":[{"def":"To govern; to rule; to keep, or have in charge; also, to possess.","pos":""},{"def":"To direct or regulate by influence or authority; to manage; to control; to sway.","pos":""}],"WIELDABLE":[{"def":"Capable of being wielded.","pos":""}],"WIELDANCE":[{"def":"The act or power of wielding.","pos":""}],"WIELDER":[{"def":"One who wields or employs; a manager; a controller.","pos":""}],"WIELDING":[{"def":"Power; authority; rule.","pos":""}],"WIELDLESS":[{"def":"Not to be wielded; unmanageable; unwieldy.","pos":""}],"WIELDSOME":[{"def":"Admitting of being easily wielded or managed.","pos":""}],"WIELDY":[{"def":"Capable of being wielded; manageable; wieldable; -- opposed to unwieldy.","pos":""}],"WIENER SCHNITZEL":[{"def":"A veal cutlet variously seasoned garnished, often with lemon, sardines, and capers.","pos":""}],"WIERANGLE":[{"def":"Same as Wariangle.","pos":""}],"WIERY":[{"def":"Wet; moist; marshy.","pos":""}]}