{"THRUM":[{"def":"A threadlike part of a flower; a stamen.","pos":""},{"def":"A shove out of place; a small displacement or fault along a seam.","pos":""}],"THRUM-EYED":[{"def":"Having the anthers raised above the stigma, and visible at the throat of the corolla, as in long-stamened primroses; -- the reverse of pin-eyed.","pos":""}],"THRUMMY":[{"def":"Like thrums; made of, furnished with, or characterized by, thrums.","pos":""}],"THRUMWORT":[{"def":"A kind of amaranth (Amarantus caudatus).","pos":""}],"THRUSH":[{"def":"Any one of numerous species of singing birds belonging to Turdus and allied genera.","pos":""},{"def":"Any one of numerous species of singing birds more or less resembling the true thrushes in appearance or habits; as the thunderbird and the American brown thrush (or thrasher).","pos":""}],"THRUSHEL":[{"def":"The song thrush.","pos":""}],"THRUSHER":[{"def":"The song thrush.","pos":""}],"THRUST":[{"def":"To push or drive with force; to drive, force, or impel; to shove; as, to thrust anything with the hand or foot, or with an instrument.","pos":""},{"def":"To stab; to pierce; -- usually with through.","pos":""}],"THRUSTER":[{"def":"One who thrusts or stabs.","pos":""}],"THRUSTING":[{"def":"The white whey, or that which is last pressed out of the curd by the hand, and of which butter is sometimes made.","pos":""}],"THRUSTLE":[{"def":"The throstle, or song thrust.","pos":""}]}