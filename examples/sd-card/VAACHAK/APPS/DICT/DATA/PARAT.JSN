{"PARATACTIC":[{"def":"Of pertaining to, or characterized by, parataxis.","pos":""}],"PARATAXIS":[{"def":"The mere ranging of propositions one after another, without indicating their connection or interdependence; -- opposed to syntax.","pos":""}],"PARATHESIS":[{"def":"The placing of two or more nouns in the same case; apposition.","pos":""},{"def":"A parenthetical notice, usually of matter to be afterward expanded.","pos":""}],"PARATHETIC":[{"def":"Of or pertaining to parathesis.","pos":""}],"PARATONNERRE":[{"def":"A conductor of lightning; a lightning rod.","pos":""}]}