{"WAVE":[{"def":"To play loosely; to move like a wave, one way and the other; to float; to flutter; to undulate.","pos":""},{"def":"To be moved to and fro as a signal.","pos":""}],"WAVE-WORN":[{"def":"Worn by the waves.","pos":""}],"WAVED":[{"def":"Having undulations like waves; -- said of one of the lines in heraldry which serve as outlines to the ordinaries, etc.","pos":""}],"WAVELESS":[{"def":"Free from waves; undisturbed; not agitated; as, the waveless sea.","pos":""}],"WAVELET":[{"def":"A little wave; a ripple.","pos":""}],"WAVELLITE":[{"def":"A hydrous phosphate of alumina, occurring usually in hemispherical radiated forms varying in color from white to yellow, green, or black.","pos":""}],"WAVER":[{"def":"To play or move to and fro; to move one way and the other; hence, to totter; to reel; to swing; to flutter.","pos":""},{"def":"To be unsettled in opinion; to vacillate; to be undetermined; to fluctuate; as, to water in judgment.","pos":""}],"WAVERER":[{"def":"One who wavers; one who is unsettled in doctrine, faith, opinion, or the like.","pos":""}],"WAVERINGLY":[{"def":"In a wavering manner.","pos":""}],"WAVERINGNESS":[{"def":"The quality or state of wavering.","pos":""}],"WAVESON":[{"def":"Goods which, after shipwreck, appear floating on the waves, or sea.","pos":""}],"WAVINESS":[{"def":"The quality or state of being wavy.","pos":""}],"WAVY":[{"def":"Undulating on the border or surface; waved.","pos":""}]}