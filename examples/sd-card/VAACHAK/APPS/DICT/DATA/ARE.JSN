{"ARE":[{"def":"The present indicative plural of the substantive verb to be; but etymologically a different word from be, or was.","pos":""}],"AREA":[{"def":"The superficial contents of any figure; the surface included within any given lines; superficial extent; as, the area of a square or a triangle.","pos":""},{"def":"A spot or small marked space; as, the germinative area.","pos":""}],"AREAL":[{"def":"Of or pertaining to an area; as, areal interstices (the areas or spaces inclosed by the reticulate vessels of leaves).","pos":""}],"AREAR":[{"def":"To raise; to set up; to stir up.","pos":""}],"ARECA":[{"def":"A genus of palms, one species of which produces the areca nut, or betel nut, which is chewed in India with the leaf of the Piper Betle and lime.","pos":""},{"def":"An oily liquid substance, C8H13O2N, the chief alkaloid of the betel nut, to which the latter owes its anthelmintic action.","pos":""}],"AREEK":[{"def":"In a reeking condition.","pos":""}],"AREFACTION":[{"def":"The act of drying, or the state of growing dry.","pos":""}],"AREFY":[{"def":"To dry, or make dry.","pos":""}],"ARENA":[{"def":"The area in the central part of an amphitheater, in which the gladiators fought and other shows were exhibited; -- so called because it was covered with sand.","pos":""},{"def":"\"Sand\" or \"gravel\" in the kidneys.","pos":""}],"ARENACEOUS":[{"def":"Sandy or consisting largely of sand; of the nature of sand; easily disintegrating into sand; friable; as, arenaceous limestone.","pos":""}],"ARENARIOUS":[{"def":"Sandy; as, arenarious soil.","pos":""}],"ARENATION":[{"def":"A sand bath; application of hot sand to the body.","pos":""}],"ARENDATOR":[{"def":"In some provinces of Russia, one who farms the rents or revenues.","pos":""},{"def":"A palm tree (Saguerus saccharifer) which furnishes sago, wine, and fibers for ropes; the gomuti palm.","pos":""}],"ARENICOLITE":[{"def":"An ancient wormhole in sand, preserved in the rocks.","pos":""}],"ARENILITIC":[{"def":"Of or pertaining to sandstone; as, arenilitic mountains.","pos":""}],"ARENOSE":[{"def":"Sandy; full of sand.","pos":""}],"ARENULOUS":[{"def":"Full of fine sand; like sand.","pos":""}],"AREOLA":[{"def":"The colored ring around the nipple, or around a vesicle or pustule.","pos":""}],"AREOLAR":[{"def":"Pertaining to, or like, an areola; filled with interstices or areolæ.","pos":""},{"def":"Divided into small spaces or areolations, as the wings of insects, the leaves of plants, or the receptacle of compound flowers.","pos":""}],"AREOLATION":[{"def":"Division into areolæ.","pos":""},{"def":"Any small space, bounded by some part different in color or structure, as the spaces bounded by the nervures of the wings of insects, or those by the veins of leaves; an areola.","pos":""}],"AREOLET":[{"def":"A small inclosed area; esp.","pos":""}],"AREOMETER":[{"def":"An instrument for measuring the specific gravity of fluids; a form hydrometer.","pos":""},{"def":"Pertaining to, or measured by, an areometer.","pos":""}],"AREOMETRY":[{"def":"The art or process of measuring the specific gravity of fluids.","pos":""}],"AREOPAGITE":[{"def":"A member of the Areopagus.","pos":""}],"AREOPAGITIC":[{"def":"Pertaining to the Areopagus.","pos":""}],"AREOPAGUS":[{"def":"The highest judicial court at Athens.","pos":""}],"AREOSTYLE":[{"def":"See Intercolumniation, and Aræostyle.","pos":""}],"AREOSYSTYLE":[{"def":"See Intercolumniation, and Aræosystyle.","pos":""}],"AREST":[{"def":"A support for the spear when couched for the attack.","pos":""}],"ARET":[{"def":"To reckon; to ascribe; to impute.","pos":""}],"ARETAICS":[{"def":"The ethical theory which excludes all relations between virtue and happiness; the science of virtue; -- contrasted with eudemonics.","pos":""}],"ARETE":[{"def":"An acute and rugged crest of a mountain range or a subsidiary ridge between two mountain gorges.","pos":""}],"ARETOLOGY":[{"def":"That part of moral philosophy which treats of virtue, its nature, and the means of attaining to it.","pos":""}]}