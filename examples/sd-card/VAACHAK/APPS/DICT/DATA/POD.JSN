{"POD":[{"def":"A capsule of plant, especially a legume; a dry dehiscent fruit.","pos":""},{"def":"A considerable number of animals closely clustered together; -- said of seals.","pos":""}],"PODAGRA":[{"def":"Gout in the joints of the foot; -- applied also to gout in other parts of body.","pos":""}],"PODAGROUS":[{"def":"Gouty; podagric.","pos":""}],"PODALGIA":[{"def":"pain in the foot, due to gout, rheumatism, etc.","pos":""}],"PODARTHRUM":[{"def":"The foot joint; in birds, the joint between the metatarsus and the toes.","pos":""}],"PODDER":[{"def":"One who collects pods or pulse.","pos":""}],"PODESTA":[{"def":"One of the chief magistrates of the Italian republics in the Middle Ages.","pos":""},{"def":"A mayor, alderman, or other magistrate, in some towns of Italy.","pos":""}],"PODETIUM":[{"def":"A stalk which bears the fructification in some lichens, as in the so-called reindeer moss.","pos":""}],"PODGE":[{"def":"A puddle; a plash.","pos":""}],"PODGY":[{"def":"Fat and short; pudgy.","pos":""}],"PODICAL":[{"def":"Anal; -- applied to certain organs of insects.","pos":""}],"PODIUM":[{"def":"A low wall, serving as a foundation, a substructure, or a terrace wall.","pos":""}],"PODLEY":[{"def":"A young coalfish.","pos":""}],"PODO-":[{"def":"A combining form or prefix from Gr.","pos":""}],"PODOBRANCH":[{"def":"One of branchiæ attached to the bases of the legs in Crustacea.","pos":""}],"PODOBRANCHIA":[{"def":"Same as Podobranch.","pos":""}],"PODOCARP":[{"def":"A stem, or footstalk, supporting the fruit.","pos":""}],"PODOCEPHALOUS":[{"def":"Having a head of flowers on a long peduncle, or footstalk.","pos":""}],"PODOPHTHALMIA":[{"def":"The stalk-eyed Crustacea, -- an order of Crustacea having the eyes supported on movable stalks.","pos":""}],"PODOPHTHALMITE":[{"def":"The eyestalk of a crustacean.","pos":""}],"PODOPHYLLIN":[{"def":"A brown bitter gum extracted from the rootstalk of the May apple (Podophyllum peltatum).","pos":""}],"PODOPHYLLOUS":[{"def":"Having thin, flat, leaflike locomotive organs.","pos":""},{"def":"Pertaining to, or composing, the layer of tissue, made up of laminæ, beneath a horse's hoof.","pos":""}],"PODOPHYLLUM":[{"def":"A genus of herbs of the Barberry family, having large palmately lobed peltate leaves and solitary flower.","pos":""},{"def":"The rhizome and rootlet of the May apple (Podophyllum peltatum), -- used as a cathartic drug.","pos":""}],"PODOSCAPH":[{"def":"A canoe-shaped float attached to the foot, for walking on water.","pos":""}],"PODOSPERM":[{"def":"The stalk of a seed or ovule.","pos":""}],"PODOSTOMATA":[{"def":"An order of Bryozoa of which Rhabdopleura is the type.","pos":""}],"PODOTHECA":[{"def":"The scaly covering of the foot of a bird or reptile.","pos":""}],"PODRIDA":[{"def":"A miscellaneous dish of meats.","pos":""}],"PODURA":[{"def":"Any small leaping thysanurous insect of the genus Podura and related genera; a springtail.","pos":""}],"PODURID":[{"def":"Any species of Podura or allied genera.","pos":""},{"def":"Pertaining to the poduras.","pos":""}]}