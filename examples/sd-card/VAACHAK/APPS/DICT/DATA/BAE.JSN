{"BAENOMERE":[{"def":"One of the somites (arthromeres) that make up the thorax of Arthropods.","pos":""}],"BAENOPOD":[{"def":"One of the thoracic legs of Arthropods.","pos":""}],"BAENOSOME":[{"def":"The thorax of Arthropods.","pos":""}],"BAETULUS":[{"def":"A meteorite, or similar rude stone artificially shaped, held sacred or worshiped as of divine origin.","pos":""}]}