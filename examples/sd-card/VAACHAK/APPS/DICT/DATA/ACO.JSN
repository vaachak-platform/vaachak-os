{"ACOCK":[{"def":"In a cocked or turned up fashion.","pos":""}],"ACOLOGIC":[{"def":"Pertaining to acology.","pos":""}],"ACOLOGY":[{"def":"Materia medica; the science of remedies.","pos":""}],"ACOLYCTINE":[{"def":"An organic base, in the form of a white powder, obtained from Aconitum lycoctonum.","pos":""}],"ACOLYTE":[{"def":"One who has received the highest of the four minor orders in the Catholic church, being ordained to carry the wine and water and the lights at the Mass.","pos":""}],"ACOLYTH":[{"def":"Same as Acolyte.","pos":""}],"ACOLYTHIST":[{"def":"Being without joints; jointless.","pos":""}],"ACONITAL":[{"def":"Of the nature of aconite.","pos":""}],"ACONITE":[{"def":"The herb wolfsbane, or monkshood; -- applied to any plant of the genus Aconitum (tribe Hellebore), all the species of which are poisonous.","pos":""}],"ACONITIA":[{"def":"Same as Aconitine.","pos":""}],"ACONITIC":[{"def":"Of or pertaining to aconite.","pos":""}],"ACONITINE":[{"def":"An intensely poisonous alkaloid, extracted from aconite.","pos":""}],"ACONITUM":[{"def":"The poisonous herb aconite; also, an extract from it.","pos":""}],"ACONTIA":[{"def":"Threadlike defensive organs, composed largely of nettling cells (cnidæ), thrown out of the mouth or special pores of certain Actiniæ when irritated.","pos":""}],"ACONTIAS":[{"def":"Anciently, a snake, called dart snake; now, one of a genus of reptiles closely allied to the lizards.","pos":""}],"ACOPIC":[{"def":"Relieving weariness; restorative.","pos":""}],"ACORN":[{"def":"A cone-shaped piece of wood on the point of the spindle above the vane, on the mast-head.","pos":""},{"def":"See Acorn-shell.","pos":""}],"ACORN CUP":[{"def":"The involucre or cup in which the acorn is fixed.","pos":""}],"ACORN-SHELL":[{"def":"One of the sessile cirripeds; a barnacle of the genus Balanus.","pos":""}],"ACORNED":[{"def":"Furnished or loaded with acorns.","pos":""},{"def":"Fed or filled with acorns.","pos":""}],"ACOSMISM":[{"def":"A denial of the existence of the universe as distinct from God.","pos":""}],"ACOSMIST":[{"def":"One who denies the existence of the universe, or of a universe as distinct from God.","pos":""}],"ACOTYLEDON":[{"def":"A plant which has no cotyledons, as the dodder and all flowerless plants.","pos":""}],"ACOTYLEDONOUS":[{"def":"Having no seed lobes, as the dodder; also applied to plants which have no true seeds, as ferns, mosses, etc.","pos":""}],"ACOUCHY":[{"def":"A small species of agouti (Dasyprocta acouchy).","pos":""}],"ACOUMETER":[{"def":"An instrument for measuring the acuteness of the sense of hearing.","pos":""}],"ACOUMETRY":[{"def":"The measuring of the power or extent of hearing.","pos":""}],"ACOUSTIC":[{"def":"Pertaining to the sense of hearing, the organs of hearing, or the science of sounds; auditory.","pos":""}],"ACOUSTICAL":[{"def":"Of or pertaining to acoustics.","pos":""}],"ACOUSTICALLY":[{"def":"In relation to sound or to hearing.","pos":""}],"ACOUSTICIAN":[{"def":"One versed in acoustics.","pos":""}],"ACOUSTICS":[{"def":"The science of sounds, teaching their nature, phenomena, and laws.","pos":""}]}