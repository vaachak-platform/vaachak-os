{"TURTLE":[{"def":"Any one of the numerous species of Testudinata, especially a sea turtle, or chelonian.","pos":""},{"def":"The curved plate in which the form is held in a type-revolving cylinder press.","pos":""}],"TURTLE PEG":[{"def":"A sharp steel spear attached to a cord, used in taking sea turtles.","pos":""}],"TURTLE-SHELL":[{"def":"The turtle cowrie.","pos":""}],"TURTLEDOVE":[{"def":"Any one of numerous species of pigeons belonging to Turtur and allied genera, native of various parts of the Old World; especially, the common European species (Turtur vulgaris), which is noted for its plaintive note, affectionate disposition, and devotion to its mate.","pos":""},{"def":"Any one of several species of pigeons more or less resembling the true turtledoves, as the American mourning dove (see under Dove), and the Australian turtledove (Stictopelia cuneata).","pos":""}],"TURTLEHEAD":[{"def":"An American perennial herb (Chelone glabra) having white flowers shaped like the head of a turtle.","pos":""}],"TURTLER":[{"def":"One who catches turtles or tortoises.","pos":""}],"TURTLING":[{"def":"The act, practice, or art of catching turtles.","pos":""}]}