{"SHOP":[{"def":"A building or an apartment in which goods, wares, drugs, etc.","pos":""},{"def":"A building in which mechanics or artisans work; as, a shoe shop; a car shop.","pos":""}],"SHOPBOARD":[{"def":"A bench or board on which work is performed; a workbench.","pos":""}],"SHOPBOOK":[{"def":"A book in which a tradesman keeps his accounts.","pos":""}],"SHOPBOY":[{"def":"A boy employed in a shop.","pos":""}],"SHOPGIRL":[{"def":"A girl employed in a shop.","pos":""}],"SHOPKEEPER":[{"def":"A trader who sells goods in a shop, or by retail; -- in distinction from one who sells by wholesale.","pos":""}],"SHOPLIFTER":[{"def":"One who steals anything in a shop, or takes goods privately from a shop; one who, under pretense of buying goods, takes occasion to steal.","pos":""}],"SHOPLIFTING":[{"def":"Larceny committed in a shop; the stealing of anything from a shop.","pos":""}],"SHOPLIKE":[{"def":"Suiting a shop; vulgar.","pos":""}],"SHOPMAN":[{"def":"A shopkeeper; a retailer.","pos":""},{"def":"One who serves in a shop; a salesman.","pos":""}],"SHOPPISH":[{"def":"Having the appearance or qualities of a shopkeeper, or shopman.","pos":""}],"SHOPPY":[{"def":"Abounding with shops.","pos":""},{"def":"Of or pertaining to shops, or one's own shop or business; as, shoppy talk.","pos":""}],"SHOPSHIFT":[{"def":"The trick of a shopkeeper; deception.","pos":""}],"SHOPWALKER":[{"def":"One who walks about in a shop as an overseer and director.","pos":""}],"SHOPWOMAN":[{"def":"A woman employed in a shop.","pos":""}],"SHOPWORN":[{"def":"Somewhat worn or damaged by having been kept for a time in a shop.","pos":""}]}