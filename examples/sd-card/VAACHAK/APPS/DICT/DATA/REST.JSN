{"REST":[{"def":"A projection from the right side of the cuirass, serving to support the lance.","pos":""},{"def":"A short pause in reading verse; a cæsura.","pos":""}],"REST CURE":[{"def":"Treatment of severe nervous disorder, as neurasthenia, by rest and isolation with systematic feeding and the use of massage and electricity.","pos":""}],"REST-HARROW":[{"def":"A European leguminous plant (Ononis arvensis) with long, tough roots.","pos":""}],"RESTAGNANT":[{"def":"Stagnant; motionless.","pos":""}],"RESTAGNATE":[{"def":"To stagnate; to cease to flow.","pos":""}],"RESTAGNATION":[{"def":"Re`stag*na\"tion (-n\"shn), n.","pos":""}],"RESTANT":[{"def":"Res\"tant (rs\"tant), a.","pos":""}],"RESTATE":[{"def":"Re*state\" (r*stt\"), v.","pos":""}],"RESTAURANT":[{"def":"An eating house.","pos":""}],"RESTAURATE":[{"def":"Res\"tau*rate (rs\"t*rt), v.","pos":""}],"RESTAURATEUR":[{"def":"The keeper of an eathing house or a restaurant.","pos":""}],"RESTAURATION":[{"def":"Res`tau*ra\"tion (rs`t*r\"shn), n.","pos":""}],"RESTEM":[{"def":"To force back against the current; as, to restem their backward course.","pos":""},{"def":"To stem, or as, to restem a current.","pos":""}],"RESTFUL":[{"def":"Being at rest; quiet.","pos":""},{"def":"Giving rest; freeing from toil, trouble, etc.","pos":""}],"RESTIFF":[{"def":"A restive or stubborn horse.","pos":""}],"RESTIFORM":[{"def":"Formed like a rope; -- applied especially to several ropelike bundles or masses of fibers on the dorsal side of the medulla oblongata.","pos":""}],"RESTILY":[{"def":"In a resty manner.","pos":""}],"RESTINCTION":[{"def":"Act of quenching or extingishing.","pos":"noun"}],"RESTINESS":[{"def":"The quality or state of being resty; sluggishness.","pos":""}],"RESTINGUISH":[{"def":"To quench or extinguish.","pos":""}],"RESTITUTE":[{"def":"To restore to a former state.","pos":""}],"RESTITUTION":[{"def":"The act of returning to, or recovering, a former state; as, the restitution of an elastic body.","pos":""},{"def":"The movement of rotetion which usually occurs in childbirth after the head has been delivered, and which causes the latter to point towards the side to which it was directed at the beginning of labor.","pos":""}],"RESTITUTOR":[{"def":"One who makes restitution.","pos":""}],"RESTIVE":[{"def":"Unwilling to go on; obstinate in refusing to move forward; stubborn; drawing back.","pos":""}],"RESTLESS":[{"def":"Never resting; unquiet; uneasy; continually moving; as, a restless child.","pos":""},{"def":"Not satisfied to be at rest or in peace; averse to repose or quiet; eager for change; discontented; as, restless schemers; restless ambition; restless subjects.","pos":""}],"RESTORABLE":[{"def":"Admitting of being restored; capable of being reclaimed; as, restorable land.","pos":""}],"RESTORATION":[{"def":"The act of restoring or bringing back to a former place, station, or condition; the fact of being restored; renewal; reëstablishment; as, the restoration of friendship between enemies; the restoration of peace after war.","pos":""},{"def":"The state of being restored; recovery of health, strength, etc.","pos":""}],"RESTORATIONER":[{"def":"A Restorationist.","pos":""}],"RESTORATIONISM":[{"def":"The belief or doctrines of the Restorationists.","pos":""}],"RESTORATIONIST":[{"def":"One who believes in a temporary future punishment and a final restoration of all to the favor and presence of God; a Universalist.","pos":""}],"RESTORATIVE":[{"def":"Of or pertaining to restoration; having power to restore.","pos":""}],"RESTORATIVELY":[{"def":"In a restorative manner.","pos":""}],"RESTORATOR":[{"def":"Res\"to*ra`tor (rs\"t*r`tr), n.","pos":""}],"RESTORATORY":[{"def":"Re*stor\"a*to*ry (r*str\"*t*r), a.","pos":""}],"RESTORE":[{"def":"To bring back to its former state; to bring back from a state of ruin, decay, disease, or the like; to repair; to renew; to recover.","pos":""}],"RESTORER":[{"def":"One who, or that which, restores.","pos":""}],"RESTRAIN":[{"def":"To draw back again; to hold back from acting, proceeding, or advancing, either by physical or moral force, or by any interposing obstacle; to repress or suppress; to keep down; to curb.","pos":""},{"def":"To draw back toghtly, as a rein.","pos":""}],"RESTRAINABLE":[{"def":"Capable of being restrained; controllable.","pos":""}],"RESTRAINER":[{"def":"One who, or that which, restrains.","pos":""}],"RESTRAINMENT":[{"def":"The act of restraining.","pos":""}],"RESTRAINT":[{"def":"The act or process of restraining, or of holding back or hindering from motion or action, in any manner; hindrance of the will, or of any action, physical or mental.","pos":""},{"def":"The state of being restrained.","pos":""}],"RESTRENGTHEN":[{"def":"To strengthen again; to fortify anew.","pos":""}],"RESTRICT":[{"def":"To restrain within bounds; to limit; to confine; as, to restrict worlds to a particular meaning; to restrict a patient to a certain diet.","pos":""}],"RESTRICTION":[{"def":"The act of restricting, or state of being restricted; confinement within limits or bounds.","pos":""},{"def":"That which restricts; limitation; restraint; as, restrictions on trade.","pos":""}],"RESTRICTIONARY":[{"def":"Re*stric\"tion*a*ry, a.","pos":""}],"RESTRICTIVE":[{"def":"Serving or tending to restrict; limiting; as, a restrictive particle; restrictive laws of trade.","pos":""},{"def":"Astringent or styptic in effect.","pos":""}],"RESTRINGE":[{"def":"To confine; to contract; to stringe.","pos":""}],"RESTRINGENCY":[{"def":"Quality or state of being restringent; astringency.","pos":""}],"RESTRINGENT":[{"def":"Restringing; astringent; styptic.","pos":""},{"def":"A restringent medicine.","pos":""}],"RESTY":[{"def":"Disposed to rest; indisposed toexercton; sluggish; also, restive.","pos":""}]}