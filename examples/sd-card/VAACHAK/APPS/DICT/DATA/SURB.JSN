{"SURBASE":[{"def":"A cornice, or series of moldings, on the top of the base of a pedestal, podium, etc.","pos":""}],"SURBASED":[{"def":"Having the vertical height from springing line to crown less than the half span; -- said of an arch; as, a segmental arch is surbased.","pos":""}],"SURBATE":[{"def":"To make sore or bruise, as the feet by travel.","pos":""},{"def":"To harass; to fatigue.","pos":""}],"SURBEAT":[{"def":"Same as Surbate.","pos":""}],"SURBED":[{"def":"To set edgewise, as a stone; that is, to set it in a position different from that which it had in the quarry.","pos":""}],"SURBET":[{"def":"Same as Surbate.","pos":""}]}