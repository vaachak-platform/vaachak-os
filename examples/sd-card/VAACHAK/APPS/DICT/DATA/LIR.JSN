{"LIRA":[{"def":"An Italian coin equivalent in value to the French franc.","pos":""}],"LIRELLA":[{"def":"A linear apothecium furrowed along the middle; the fruit of certain lichens.","pos":""}],"LIRIODENDRON":[{"def":"A genus of large and very beautiful trees of North America, having smooth, shining leaves, and handsome, tuliplike flowers; tulip tree; whitewood; -- called also canoewood.","pos":""}],"LIRIPOOP":[{"def":"A pendent part of the old clerical tippet; afterwards, a tippet; a scarf; -- worn also by doctors, learned men, etc.","pos":""},{"def":"Acuteness; smartness; also, a smart trick or stratagem.","pos":""}],"LIROCONITE":[{"def":"A hydrated arseniate of copper, occurring in obtuse pyramidal crystals of a sky-blue or verdigris-green color.","pos":""}]}