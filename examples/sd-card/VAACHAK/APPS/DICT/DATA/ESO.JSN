{"ESODIC":[{"def":"Conveying impressions from the surface of the body to the spinal cord; -- said of certain nerves.","pos":""}],"ESOPHAGEAL":[{"def":"Pertaining to the esophagus.","pos":""}],"ESOPHAGOTOMY":[{"def":"The operation of making an incision into the esophagus, for the purpose of removing any foreign substance that obstructs the passage.","pos":""}],"ESOPHAGUS":[{"def":"That part of the alimentary canal between the pharynx and the stomach; the gullet.","pos":""},{"def":"Same as Æsopian, Æsopic.","pos":""}],"ESOTERIC":[{"def":"Designed for, and understood by, the specially initiated alone; not communicated, or not intelligible, to the general body of followers; private; interior; acroamatic; -- said of the private and more recondite instructions and doctrines of philosophers.","pos":""}],"ESOTERICALLY":[{"def":"In an esoteric manner.","pos":""}],"ESOTERICISM":[{"def":"Esoteric doctrine or principles.","pos":""}],"ESOTERICS":[{"def":"Mysterious or hidden doctrines; secret science.","pos":""}],"ESOTERY":[{"def":"Mystery; esoterics; -- opposed to exotery.","pos":""}],"ESOX":[{"def":"A genus of fresh-water fishes, including pike and pickerel.","pos":""}]}