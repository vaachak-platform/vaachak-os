{"REMADE":[{"def":"Re*made\" (r-md\"), Defn: imp.","pos":""}],"REMAIN":[{"def":"To stay behind while others withdraw; to be left after others have been removed or destroyed; to be left after a number or quantity has been subtracted or cut off; to be left as not included or comprised.","pos":""},{"def":"To continue unchanged in place, form, or condition, or undiminished in quantity; to abide; to stay; to endure; to last.","pos":""}],"REMAINDER":[{"def":"The quantity or sum that is left after subtraction, or after any deduction.","pos":""}],"REMAINDER-MAN":[{"def":"One who has an estate after a particular estate is determined.","pos":""}],"REMAND":[{"def":"To recommit; to send back.","pos":""}],"REMANDMENT":[{"def":"The state of being remanent; continuance; permanence.","pos":""}],"REMANENT":[{"def":"That which remains; a remnant; a residue.","pos":""}],"REMANET":[{"def":"A case for trial which can not be tried during the term; a postponed case.","pos":""}],"REMARK":[{"def":"To mark in a notable manner; to distinquish clearly; to make noticeable or conspicuous; to piont out.","pos":""},{"def":"To take notice of, or to observe, mentally; as, to remark the manner of a speaker.","pos":""}],"REMARKABLE":[{"def":"Worthy of being remarked or noticed; noticeable; conspicuous; hence, uncommon; extraordinary.","pos":""}],"REMARKER":[{"def":"One who remarks.","pos":""}],"REMARRIAGE":[{"def":"A second or repeated marriage.","pos":""}],"REMARRY":[{"def":"Re*mar\"ry (r-mr\"rr), v.","pos":""}],"REMAST":[{"def":"To furnish with a new mast or set of masts.","pos":""}],"REMASTICATE":[{"def":"To chew or masticate again; to chew over and over, as the cud.","pos":""}],"REMASTICATION":[{"def":"The act of masticating or chewing again or repeatedly.","pos":""}],"REMBERGE":[{"def":"Rem\"berge (rm\"brj), n.","pos":""}],"REMBLAI":[{"def":"Earth or materials made into a bank after having been excavated.","pos":""}],"REMEAN":[{"def":"To give meaning to; to explain the meaning of; to interpret.","pos":""}],"REMEANT":[{"def":"Coming back; returning.","pos":""}],"REMEASURE":[{"def":"To measure again; to retrace.","pos":""}],"REMEDIABLE":[{"def":"Capable of being remedied or cured.","pos":""}],"REMEDIAL":[{"def":"Affording a remedy; intended for a remedy, or for the removal or abatement of an evil; as, remedial treatment.","pos":""}],"REMEDIALLY":[{"def":"In a remedial manner.","pos":""}],"REMEDILESS":[{"def":"Not admitting of a remedy; incapable of being restored or corrected; incurable; irreparable; as, a remediless mistake or loss.","pos":""},{"def":"Not answering as a remedy; ineffectual.","pos":""}],"REMEDY":[{"def":"The legal means to recover a right, or to obtain redress for a wrong.","pos":""}],"REMEMBER":[{"def":"To have ( a notion or idea) come into the mind again, as previously perceived, known, or felt; to have a renewed apprehension of; to bring to mind again; to think of again; to recollect; as, I remember the fact; he remembers the events of his childhood; I cannot remember dates.","pos":""},{"def":"To be capable of recalling when required; to keep in mind; to be continually aware or thoughtful of; to preserve fresh in the memory; to attend to; to think of with gratitude, affection, respect, or any other emotion.","pos":""}],"REMEMBERABLE":[{"def":"Capable or worthy of being remembered.","pos":""}],"REMEMBERER":[{"def":"One who remembers.","pos":""}],"REMEMBRANCE":[{"def":"The act of remembering; a holding in mind, or bringing to mind; recollection.","pos":""},{"def":"The state of being remembered, or held in mind; memory; recollection.","pos":""}],"REMEMBRANCER":[{"def":"One who, or that which, serves to bring to, or keep in, mind; a memento; a memorial; a reminder.","pos":""},{"def":"A term applied in England to several officers, having various functions, their duty originally being to bring certain matters to the attention of the proper persons at the proper time.","pos":""}],"REMEMORATE":[{"def":"To recall something by means of memory; to remember.","pos":""}],"REMEMORATION":[{"def":"A recalling by the faculty of memory; remembrance.","pos":""}],"REMEMORATIVE":[{"def":"Tending or serving to remind.","pos":""}],"REMENANT":[{"def":"Rem\"e*nant (rm\"-nant), n.","pos":""}],"REMERGE":[{"def":"Re*merge\" (r-mrj\"), v.","pos":""}],"REMIFORM":[{"def":"Shaped like an oar.","pos":""}],"REMIGES":[{"def":"The quill feathers of the wings of a bird.","pos":""}],"REMIGRATE":[{"def":"To migrate again; to go back; to return.","pos":""}],"REMIGRATION":[{"def":"Migration back to the place from which one came.","pos":""}],"REMIND":[{"def":"To put (one) in mind of something; to bring to the remembrance of; to bring to the notice or consideration of (a person).","pos":""}],"REMINDER":[{"def":"One who, or that which, reminds; that which serves to awaken remembrance.","pos":""}],"REMINDFUL":[{"def":"Tending or adapted to remind; careful to remind.","pos":""}],"REMINISCENCE":[{"def":"The act or power of recalling past experience; the state of being reminiscent; remembrance; memory.","pos":""},{"def":"That which is remembered, or recalled to mind; a statement or narration of remembered experience; a recollection; as, pleasing or painful reminiscences.","pos":""}],"REMINISCENCY":[{"def":"Rem`i*nis\"cen*cy (-sen-s), n.","pos":""}],"REMINISCENT":[{"def":"Recalling to mind, or capable of recalling to mind; having remembrance; reminding one of something.","pos":""}],"REMINISCENTIAL":[{"def":"Of or pertaining to reminiscence, or remembrance.","pos":""}],"REMIPED":[{"def":"Having feet or legs that are used as oars; -- said of certain crustaceans and insects.","pos":""}],"REMISE":[{"def":"To send, give, or grant back; torelease a claim to; to resign or surrender by deed; to return.","pos":""}],"REMISS":[{"def":"Not energetic or exact in duty or business; not careful or prompt in fulfilling engagements; negligent; careless; tardy; behindhand; lagging; slack; hence, lacking earnestness or activity; languid; slow.","pos":""}],"REMISSFUL":[{"def":"Inclined to remit punishment; lenient; clement.","pos":""}],"REMISSIBILITY":[{"def":"The state or quality of being remissible.","pos":""}],"REMISSIBLE":[{"def":"Capable of being remitted or forgiven.","pos":""}],"REMISSION":[{"def":"A temporary and incomplete subsidence of the force or violence of a disease or of pain, as destinguished from intermission, in which the disease completely leaves the patient for a time; abatement.","pos":""}],"REMISSIVE":[{"def":"Remitting; forgiving; abating.","pos":""}],"REMISSLY":[{"def":"In a remiss or negligent manner; carelessly.","pos":""}],"REMISSNESS":[{"def":"Quality or state of being remiss.","pos":""}],"REMISSORY":[{"def":"Serving or tending to remit, or to secure remission; remissive.","pos":""}],"REMIT":[{"def":"To transmit or send, esp.","pos":""}],"REMITMENT":[{"def":"The act of remitting, or the state of being remitted; remission.","pos":""}],"REMITTAL":[{"def":"A remitting; a giving up; surrender; as, the remittal of the first fruits.","pos":""}],"REMITTANCE":[{"def":"The act of transmitting money, bills, or the like, esp.","pos":""},{"def":"The sum or thing remitted.","pos":""}],"REMITTEE":[{"def":"One to whom a remittance is sent.","pos":""}],"REMITTENT":[{"def":"Remitting; characterized by remission; having remissions.","pos":""}],"REMITTER":[{"def":"The sending or placing back of a person to a title or right he had before; the restitution of one who obtains possession of property under a defective title, to his rights under some valid title by virtue of which he might legally have entered into possession only by suit.","pos":""}],"REMITTITUR":[{"def":"Re*mit\"ti*tur (-t-tr), n.","pos":""}],"REMITTOR":[{"def":"One who makes a remittance; a remitter.","pos":""}],"REMIX":[{"def":"To mix again or repeatedly.","pos":""}],"REMNANT":[{"def":"Remaining; yet left.","pos":""}],"REMODEL":[{"def":"To model or fashion anew; to change the form of.","pos":""}],"REMODIFICATION":[{"def":"The act of remodifying; the state of being remodified.","pos":""}],"REMODIFY":[{"def":"To modify again or anew; to reshape.","pos":""},{"def":"A kind of piquant sauce or salad dressing resembling mayonnaise.","pos":""}],"REMOLLIENT":[{"def":"Mollifying; softening.","pos":""}],"REMONETIZATION":[{"def":"The act of remonetizing.","pos":""}],"REMONETIZE":[{"def":"To restore to use as money; as, to remonetize silver.","pos":""}],"REMONSTRANCE":[{"def":"Same as Monstrance.","pos":""}],"REMONSTRANT":[{"def":"Inclined or tending to remonstrate; expostulatory; urging reasons in opposition to something.","pos":""}],"REMONSTRANTLY":[{"def":"In a remonstrant manner.","pos":""}],"REMONSTRATE":[{"def":"To point out; to show clearly; to make plain or manifest; hence, to prove; to demonstrate.","pos":""}],"REMONSTRATION":[{"def":"The act of remonstrating; remonstrance.","pos":""}],"REMONSTRATIVE":[{"def":"Having the character of a remonstrance; expressing remonstrance.","pos":""}],"REMONSTRATOR":[{"def":"One who remonstrates; a remonsrant.","pos":""}],"REMONTANT":[{"def":"Rising again; -- applied to a class of roses which bloom more than once in a season; the hybrid perpetual roses, of which the Jacqueminot is a well-known example.","pos":""}],"REMONTOIR":[{"def":"See under Escapement.","pos":""}],"REMORA":[{"def":"Any one of several species of fishes belonging to Echeneis, Remora, and allied genera.","pos":""},{"def":"An instrument formerly in use, intended to retain parts in their places.","pos":""}],"REMORATE":[{"def":"To hinder; to delay.","pos":""}],"REMORD":[{"def":"To excite to remorse; to rebuke.","pos":""}],"REMORDENCY":[{"def":"Remorse; compunction; compassion.","pos":""}],"REMORSE":[{"def":"The anguish, like gnawing pain, excited by a sense of guilt; compunction of conscience for a crime committed, or for the sins of one's past life.","pos":""},{"def":"Sympathetic sorrow; pity; compassion.","pos":""}],"REMORSED":[{"def":"Feeling remorse.","pos":""}],"REMORSEFUL":[{"def":"Full of remorse.","pos":""},{"def":"Compassionate; feeling tenderly.","pos":""}],"REMORSELESS":[{"def":"Being without remorse; having no pity; hence, destitute of sensibility; cruel; insensible to distress; merciless.","pos":""}],"REMOTE":[{"def":"Separated by intervals greater than usual.","pos":""}],"REMOTION":[{"def":"The act of removing; removal.","pos":""},{"def":"The state of being remote; remoteness.","pos":""}],"REMOULD":[{"def":"Re*mould\" (r-mld\"), v.","pos":""}],"REMOUNT":[{"def":"Re*mount\" (r-mount\"), v.","pos":""}],"REMOVABLE":[{"def":"Admitting of being removed.","pos":""}],"REMOVAL":[{"def":"The act of removing, or the state of being removed.","pos":""}],"REMOVE":[{"def":"To move away from the position occupied; to cause to change place; to displace; as, to remove a building.","pos":""},{"def":"To cause to leave a person or thing; to cause to cease to be; to take away; hence, to banish; to destroy; to put an end to; to kill; as, to remove a disease.","pos":""}],"REMOVED":[{"def":"Changed in place.","pos":""},{"def":"Dismissed from office.","pos":""}],"REMOVER":[{"def":"One who removes; as, a remover of landmarks.","pos":""}],"REMUABLE":[{"def":"That may be removed; removable.","pos":""}],"REMUGIENT":[{"def":"Re*mu\"gi*ent (r-m\"j-ent), a.","pos":""}],"REMUNERABLE":[{"def":"Admitting, or worthy, of remuneration.","pos":""}],"REMUNERATE":[{"def":"To pay an equivalent to for any service, loss, expense, or other sacrifice; to recompense; to requite; as, to remunerate men for labor.","pos":""}],"REMUNERATION":[{"def":"The act of remunerating.","pos":""},{"def":"That which is given to remunerate; an equivalent given, as for services, loss, or sufferings.","pos":""}],"REMUNERATIVE":[{"def":"Affording remuneration; as, a remunerative payment for services; a remunerative business.","pos":""}],"REMUNERATORY":[{"def":"Re*mu\"ner*a*to*ry (-t-r), a.","pos":""}],"REMURMUR":[{"def":"To murmur again; to utter back, or reply, in murmurs.","pos":""}]}