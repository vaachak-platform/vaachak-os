{"TAVERN":[{"def":"A public house where travelers and other transient guests are accomodated with rooms and meals; an inn; a hotel; especially, in modern times, a public house licensed to sell liquor in small quantities.","pos":""}],"TAVERNER":[{"def":"One who keeps a tavern.","pos":""}],"TAVERNING":[{"def":"A feasting at taverns.","pos":""}],"TAVERNMAN":[{"def":"The keeper of a tavern; also, a tippler.","pos":""}]}