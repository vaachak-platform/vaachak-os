{"FOREFATHER":[{"def":"One who precedes another in the line of genealogy in any degree, but usually in a remote degree; an ancestor.","pos":""}],"FOREFEEL":[{"def":"To feel beforehand; to have a presentiment of.","pos":""}],"FOREFENCE":[{"def":"Defense in front.","pos":""}],"FOREFEND":[{"def":"To hinder; to fend off; to avert; to prevent the approach of; to forbid or prohibit.","pos":""}],"FOREFINGER":[{"def":"The finger next to the thumb; the index.","pos":""}],"FOREFOOT":[{"def":"A piece of timber which terminates the keel at the fore end, connecting it with the lower end of the stem.","pos":""}],"FOREFRONT":[{"def":"Foremost part or place.","pos":""}]}