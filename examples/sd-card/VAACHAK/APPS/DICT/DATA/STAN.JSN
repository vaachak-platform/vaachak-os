{"STANCE":[{"def":"A station; a position; a site.","pos":""}],"STANCH":[{"def":"To stop the flowing of, as blood; to check; also, to stop the flowing of blood from; as, to stanch a wound.","pos":""},{"def":"To extinguish; to quench, as fire or thirst.","pos":""}],"STANCHER":[{"def":"One who, or that which, stanches, or stops, the flowing, as of blood.","pos":""}],"STANCHION":[{"def":"A prop or support; a piece of timber in the form of a stake or post, used for a support or stay.","pos":""},{"def":"Any upright post or beam used as a support, as for the deck, the quarter rails, awnings, etc.","pos":""}],"STANCHLESS":[{"def":"Incapable of being stanched, or stopped.","pos":""},{"def":"Unquenchable; insatiable.","pos":""}],"STANCHLY":[{"def":"In a stanch manner.","pos":""}],"STANCHNESS":[{"def":"The quality or state of being stanch.","pos":""}],"STAND":[{"def":"To hold a course at sea; as, to stand from the shore; to stand for the harbor.","pos":""}],"STAND-BY":[{"def":"One who, or that which, stands by one in need; something upon which one relies for constant use or in an emergency.","pos":""}],"STANDAGE":[{"def":"A reservior in which water accumulates at the bottom of a mine.","pos":""}],"STANDARD":[{"def":"The proportion of weights of fine metal and alloy established by authority.","pos":""},{"def":"A tree of natural size supported by its own stem, and not dwarfed by grafting on the stock of a smaller species nor trained upon a wall or trellis.","pos":""}],"STANDARD-BRED":[{"def":"Bred in conformity to a standard.","pos":""}],"STANDARD-WING":[{"def":"A curious paradise bird (Semioptera Wallacii) which has two long special feathers standing erect on each wing.","pos":""}],"STANDARDIZE":[{"def":"To reduce to a normal standard; to calculate or adjust the strength of, by means of, and for uses in, analysis.","pos":""}],"STANDEL":[{"def":"A young tree, especially one reserved when others are cut.","pos":""}],"STANDER":[{"def":"See Legislature, above.","pos":""}],"STANDER-BY":[{"def":"One who stands near; one who is present; a bystander.","pos":""}],"STANDERGRASS":[{"def":"A plant (Orchis mascula); -- called also standerwort, and long purple.","pos":""}],"STANDING":[{"def":"Remaining erect; not cut down; as, standing corn.","pos":""},{"def":"Not flowing; stagnant; as, standing water.","pos":""}],"STANDISH":[{"def":"A stand, or case, for pen and ink.","pos":""}],"STANDPIPE":[{"def":"A vertical pipe, open at the top, between a hydrant and a reservoir, to equalize the flow of water; also, a large vertical pipe, near a pumping engine, into which water is forced up, so as to give it sufficient head to rise to the required level at a distance.","pos":""},{"def":"A supply pipe of sufficient elevation to enable the water to flow into the boiler, notwithstanding the pressure of the steam.","pos":""}],"STANDPOINT":[{"def":"A fixed point or station; a basis or fundamental principle; a position from which objects or principles are viewed, and according to which they are compared and judged.","pos":""}],"STANDSTILL":[{"def":"A standing without moving forward or backward; a stop; a state or rest.","pos":""}],"STANG":[{"def":"A long bar; a pole; a shaft; a stake.","pos":""},{"def":"In land measure, a pole, rod, or perch.","pos":""}],"STANHOPE":[{"def":"A light two-wheeled, or sometimes four-wheeled, carriage, without a top; -- so called from Lord Stanhope, for whom it was contrived.","pos":""}],"STANIELRY":[{"def":"Hawking with staniels, -- a base kind of falconry.","pos":""}],"STANK":[{"def":"Water retained by an embankment; a pool water.","pos":""},{"def":"A dam or mound to stop water.","pos":""}],"STANNARY":[{"def":"Of or pertaining to tin mines, or tin works.","pos":""}],"STANNATE":[{"def":"A salt of stannic acid.","pos":""}],"STANNEL":[{"def":"The kestrel; -- called also standgale, standgall, stanchel, stand hawk, stannel hawk, steingale, stonegall.","pos":""}],"STANNIC":[{"def":"Of or pertaining to tin; derived from or containing tin; specifically, designating those compounds in which the element has a higher valence as contrasted with stannous compounds.","pos":""}],"STANNIFEROUS":[{"def":"Containing or affording tin.","pos":""}],"STANNO-":[{"def":"A combining form (also used adjectively) denoting relation to, or connection with, tin, or including tin as an ingredient.","pos":""}],"STANNOFLUORIDE":[{"def":"Any one of a series of double fluorides of tin (stannum) and some other element.","pos":""}],"STANNOSO-":[{"def":"A combining form (also used adjectively) denoting relation to, or connection with, certain stannnous compounds.","pos":""}],"STANNOTYPE":[{"def":"A photograph taken upon a tin plate; a tintype.","pos":""}],"STANNOUS":[{"def":"Pertaining to, or containing, tin; specifically, designating those compounds in which the element has a lower valence as contrasted with stannic compounds.","pos":""}],"STANNUM":[{"def":"The technical name of tin.","pos":""}],"STANZA":[{"def":"An apartment or division in a building; a room or chamber.","pos":""}],"STANZAIC":[{"def":"Pertaining to, or consisting of, stanzas; as, a couplet in stanzaic form.","pos":""}]}