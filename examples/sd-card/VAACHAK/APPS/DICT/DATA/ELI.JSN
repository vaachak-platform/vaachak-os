{"ELICIT":[{"def":"Elicited; drawn out; made real; open; evident.","pos":""}],"ELICITATION":[{"def":"The act of eliciting.","pos":""}],"ELIDE":[{"def":"To cut off, as a vowel or a syllable, usually the final one; to subject to elision.","pos":""}],"ELIGIBILITY":[{"def":"The quality of being eligible; eligibleness; as, the eligibility of a candidate; the eligibility of an offer of marriage.","pos":""}],"ELIGIBLE":[{"def":"That may be selected; proper or qualified to be chosen; legally qualified to be elected and to hold office.","pos":""},{"def":"Worthy to be chosen or selected; suitable; desirable; as, an eligible situation for a house.","pos":""}],"ELIGIBLENESS":[{"def":"The quality worthy or qualified to be chosen; suitableness; desirableness.","pos":""}],"ELIGIBLY":[{"def":"In an eligible manner.","pos":""}],"ELIMATE":[{"def":"To render smooth; to polish.","pos":""}],"ELIMINANT":[{"def":"The result of eliminating n variables between n homogeneous equations of any degree; -- called also resultant.","pos":""}],"ELIMINATE":[{"def":"To cause to disappear from an equation; as, to eliminate an unknown quantity.","pos":""},{"def":"To separate; to expel from the system; to excrete; as, the kidneys eliminate urea, the lungs carbonic acid; to eliminate poison from the system.","pos":""}],"ELIMINATION":[{"def":"the act of discharging or excreting waste products or foreign substances through the various emunctories.","pos":""},{"def":"Act of causing a quantity to disappear from an equation; especially, in the operation of deducing from several equations containing several unknown quantities a less number of equations containing a less number of unknown quantities.","pos":""}],"ELIMINATIVE":[{"def":"Relating to, or carrying on, elimination.","pos":""}],"ELINGUATE":[{"def":"To deprive of the tongue.","pos":""}],"ELINGUATION":[{"def":"Punishment by cutting out the tongue.","pos":""}],"ELINGUID":[{"def":"Tongue-tied; dumb.","pos":""}],"ELIQUAMENT":[{"def":"A liquid obtained from fat, or fat fish, by pressure.","pos":""}],"ELIQUATION":[{"def":"The process of separating a fusible substance from one less fusible, by means of a degree of heat sufficient to melt the one and not the other, as an alloy of copper and lead; liquation.","pos":""}],"ELISON":[{"def":"The cutting off or suppression of a vowel or syllable, for the sake of meter or euphony; esp.","pos":""}],"ELISOR":[{"def":"An elector or chooser; one of two persons appointed by a court to return a jury or serve a writ when the sheriff and the coroners are disqualified.","pos":""}],"ELITE":[{"def":"A choice or select body; the flower; as, the élite of society.","pos":""}],"ELIXATE":[{"def":"To boil; to seethe; hence, to extract by boiling or seething.","pos":""}],"ELIXATION":[{"def":"A seething; digestion.","pos":""}],"ELIXIR":[{"def":"A tincture with more than one base; a compound tincture or medicine, composed of various substances, held in solution by alcohol in some form.","pos":""},{"def":"An imaginary liquor capable of transmuting metals into gold; also, one for producing life indefinitely; as, elixir vitæ, or the elixir of life.","pos":""}],"ELIZABETHAN":[{"def":"Pertaining to Queen Elizabeth or her times, esp.","pos":""},{"def":"One who lived in England in the time of Queen Elizabeth.","pos":""}]}