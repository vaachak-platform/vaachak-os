{"ACQUAINT":[{"def":"To furnish or give experimental knowledge of; to make (one) to know; to make familiar; -- followed by with.","pos":""},{"def":"To communicate notice to; to inform; to make cognizant; -- followed by with (formerly, also, by of), or by that, introducing the intelligence; as, to acquaint a friend with the particulars of an act.","pos":""}],"ACQUAINTABLE":[{"def":"Easy to be acquainted with; affable.","pos":""}],"ACQUAINTANCE":[{"def":"A state of being acquainted, or of having intimate, or more than slight or superficial, knowledge; personal knowledge gained by intercourse short of that of friendship or intimacy; as, I know the man; but have no acquaintance with him.","pos":""},{"def":"A person or persons with whom one is acquainted.","pos":""}],"ACQUAINTANCESHIP":[{"def":"A state of being acquainted; acquaintance.","pos":""}],"ACQUAINTANT":[{"def":"An acquaintance.","pos":""}],"ACQUAINTED":[{"def":"Personally known; familiar.","pos":""}],"ACQUAINTEDNESS":[{"def":"State of being acquainted; degree of acquaintance.","pos":""}],"ACQUEST":[{"def":"Property acquired by purchase, gift, or otherwise than by inheritance.","pos":""}],"ACQUIESCE":[{"def":"To rest satisfied, or apparently satisfied, or to rest without opposition and discontent (usually implying previous opposition or discontent); to accept or consent by silence or by omitting to object; -- followed by in, formerly also by with and to.","pos":""},{"def":"To concur upon conviction; as, to acquiesce in an opinion; to assent to; usually, to concur, not heartily but so far as to forbear opposition.","pos":""}],"ACQUIESCENCE":[{"def":"A silent or passive assent or submission, or a submission with apparent content; -- distinguished from avowed consent on the one hand, and on the other, from opposition or open discontent; quiet satisfaction.","pos":""}],"ACQUIESCENCY":[{"def":"The quality of being acquiescent; acquiescence.","pos":""}],"ACQUIESCENT":[{"def":"Resting satisfied or submissive; disposed tacitly to submit; assentive; as, an acquiescent policy.","pos":""}],"ACQUIESCENTLY":[{"def":"In an acquiescent manner.","pos":""}],"ACQUIET":[{"def":"Acquiet his mind from stirring you against your own peace.","pos":""}],"ACQUIRABILITY":[{"def":"The quality of being acquirable; attainableness.","pos":""}],"ACQUIRABLE":[{"def":"Capable of being acquired.","pos":""}],"ACQUIRE":[{"def":"To gain, usually by one's own exertions; to get as one's own; as, to acquire a title, riches, knowledge, skill, good or bad habits.","pos":""}],"ACQUIREMENT":[{"def":"The act of acquiring, or that which is acquired; attainment.","pos":""}],"ACQUIRER":[{"def":"A person who acquires.","pos":""}],"ACQUISITION":[{"def":"The act or process of acquiring.","pos":""},{"def":"The thing acquired or gained; an acquirement; a gain; as, learning is an acquisition.","pos":""}],"ACQUISITIVE":[{"def":"Able or disposed to make acquisitions; acquiring; as, an acquisitive person or disposition.","pos":""}],"ACQUISITIVELY":[{"def":"In the way of acquisition.","pos":""}],"ACQUISITIVENESS":[{"def":"The faculty to which the phrenologists attribute the desire of acquiring and possessing.","pos":""}],"ACQUISITOR":[{"def":"One who acquires.","pos":""}],"ACQUIST":[{"def":"Acquisition; gain.","pos":""}],"ACQUIT":[{"def":"Acquitted; set free; rid of.","pos":""}],"ACQUITTAL":[{"def":"A setting free, or deliverance from the charge of an offense, by verdict of a jury or sentence of a court.","pos":""}],"ACQUITTANCE":[{"def":"The clearing off of debt or obligation; a release or discharge from debt or other liability.","pos":""},{"def":"A writing which is evidence of a discharge; a receipt in full, which bars a further demand.","pos":""}],"ACQUITTER":[{"def":"One who acquits or releases.","pos":""}]}