{"BLACK":[{"def":"Destitute of light, or incapable of reflecting it; of the color of soot or coal; of the darkest or a very dark color, the opposite of white; characterized by such a color; as, black cloth; black hair or eyes.","pos":""},{"def":"In a less literal sense: Enveloped or shrouded in darkness; very dark or gloomy; as, a black night; the heavens black with clouds.","pos":""}],"BLACK ART":[{"def":"The art practiced by conjurers and witches; necromancy; conjuration; magic.","pos":""}],"BLACK BASS":[{"def":"An edible, fresh-water fish of the United States, of the genus Micropterus.","pos":""}],"BLACK BOOK":[{"def":"One of several books of a political character, published at different times and for different purposes; -- so called either from the color of the binding, or from the character of the contents.","pos":""},{"def":"A book compiled in the twelfth century, containing a description of the court of exchequer of England, an official statement of the revenues of the crown, etc.","pos":""}],"BLACK DEATH":[{"def":"A pestilence which ravaged Europe and Asia in the fourteenth century.","pos":""}],"BLACK FLAGS":[{"def":"An organization composed originally of Chinese rebels that had been driven into Tonkin by the suppression of the Taiping rebellion, but later increased by bands of pirates and adventurers.","pos":""}],"BLACK FRIAR":[{"def":"A friar of the Dominican order; -- called also predicant and preaching friar; in France, Jacobin.","pos":""}],"BLACK FRIDAY":[{"def":"Any Friday on which a public disaster has occurred, as: In England, December 6, 1745, when the news of the landing of the Pretender reached London, or May 11, 1866, when a financial panic commenced.","pos":""}],"BLACK HAMBURG":[{"def":"A sweet and juicy variety of European grape, of a dark purplish black color, much grown under glass in northern latitudes.","pos":""}],"BLACK HAND":[{"def":"A Spanish anarchistic society, many of the members of which were imprisoned in 1883.","pos":""}],"BLACK HOLE":[{"def":"A discipline of unlimited autocracy, upheld by rods, and ferules, and the black hole.","pos":""}],"BLACK LEAD":[{"def":"Plumbago; graphite.","pos":""}],"BLACK LETTER":[{"def":"The old English or Gothic letter, in which the Early English manuscripts were written, and the first English books were printed.","pos":""}],"BLACK MONDAY":[{"def":"Easter Monday, so called from the severity of that day in 1360, which was so unusual that many of Edward III.","pos":""},{"def":"The first Monday after the holidays; -- so called by English schoolboys.","pos":""}],"BLACK MONK":[{"def":"A Benedictine monk.","pos":""}],"BLACK PUDDING":[{"def":"A kind of sausage made of blood, suet, etc.","pos":""}],"BLACK ROD":[{"def":"Committed to the custody of the Black Rod.","pos":""}],"BLACK SPANISH":[{"def":"One of an old and well-known Mediterranean breed of domestic fowls with glossy black plumage, blue legs and feet, bright red comb and wattles, and white face.","pos":""}],"BLACK VOMIT":[{"def":"A copious vomiting of dark-colored matter; or the substance so discharged; -- one of the most fatal symptoms in yellow fever.","pos":""},{"def":"A lotion made by mixing calomel and lime water.","pos":""}],"BLACK-A-VISED":[{"def":"Dark-visaged; swart.","pos":""}],"BLACK-BROWED":[{"def":"Having black eyebrows.","pos":""}],"BLACK-EYED":[{"def":"Having black eyes.","pos":""}],"BLACK-FACED":[{"def":"Having a black, dark, or gloomy face or aspect.","pos":""}],"BLACK-HEARTED":[{"def":"Having a wicked, malignant disposition; morally bad.","pos":""}],"BLACK-JACK":[{"def":"A name given by English miners to sphalerite, or zinc blende; - - called also false galena.","pos":""},{"def":"The Quercus nigra, or barren oak.","pos":""}],"BLACK-LETTER":[{"def":"Written or printed in black letter; as, a black-letter manuscript or book.","pos":""},{"def":"Given to the study of books in black letter; that is, of old books; out of date.","pos":""}],"BLACK-MOUTHED":[{"def":"Using foul or scurrilous language; slanderous.","pos":""}],"BLACKAMOOR":[{"def":"A negro or negress.","pos":""}],"BLACKBALL":[{"def":"A composition for blacking shoes, boots, etc.","pos":""},{"def":"A ball of black color, esp.","pos":""}],"BLACKBAND":[{"def":"An earthy carbonate of iron containing considerable carbonaceous matter; -- valuable as an iron ore.","pos":""}],"BLACKBERRY":[{"def":"The fruit of several species of bramble (Rubus); also, the plant itself.","pos":""}],"BLACKBIRD":[{"def":"In England, a species of thrush (Turdus merula), a singing bird with a fin note; the merle.","pos":""}],"BLACKBIRDER":[{"def":"A slave ship; a slaver.","pos":""}],"BLACKBIRDING":[{"def":"The kidnaping of negroes or Polynesians to be sold as slaves.","pos":""},{"def":"The act or practice of collecting natives of the islands near Queensland for service on the Queensland sugar plantations.","pos":""}],"BLACKBOARD":[{"def":"A broad board painted black, or any black surface on which writing, drawing, or the working of mathematical problems can be done with chalk or crayons.","pos":""}],"BLACKBURNIAN WARBLER":[{"def":"A beautiful warbler of the United States (Dendroica Blackburniæ).","pos":""}],"BLACKCAP":[{"def":"An apple roasted till black, to be served in a dish of boiled custard.","pos":""}],"BLACKCOAT":[{"def":"A clergyman; -- familiarly so called, as a soldier is sometimes called a redcoat or a bluecoat.","pos":""}],"BLACKCOCK":[{"def":"The male of the European black grouse (Tetrao tetrix, Linn.","pos":""}],"BLACKEN":[{"def":"To make or render black.","pos":""},{"def":"To make dark; to darken; to cloud.","pos":""}],"BLACKENER":[{"def":"One who blackens.","pos":""}],"BLACKFEET":[{"def":"A tribe of North American Indians formerly inhabiting the country from the upper Missouri River to the Saskatchewan, but now much reduced in numbers.","pos":""}],"BLACKFISH":[{"def":"A small kind of whale, of the genus Globicephalus, of several species.","pos":""},{"def":"The tautog of New England (Tautoga).","pos":""}],"BLACKFOOT":[{"def":"Of or pertaining to the Blackfeet; as, a Blackfoot Indian.","pos":""},{"def":"A Blackfoot Indian.","pos":""}],"BLACKGUARD":[{"def":"The scullions and lower menials of a court, or of a nobleman's household, who, in a removal from one residence to another, had charge of the kitchen utensils, and being smutted by them, were jocularly called the \"black guard\"; also, the servants and hangers-on of an army.","pos":""},{"def":"The criminals and vagrants or vagabonds of a town or community, collectively.","pos":""}],"BLACKGUARDISM":[{"def":"The conduct or language of a blackguard; rufflanism.","pos":""}],"BLACKGUARDLY":[{"def":"In the manner of or resembling a blackguard; abusive; scurrilous; ruffianly.","pos":""}],"BLACKHEART":[{"def":"A heart-shaped cherry with a very dark-colored skin.","pos":""}],"BLACKING":[{"def":"Any preparation for making things black; esp.","pos":""},{"def":"The act or process of making black.","pos":""}],"BLACKLEAD":[{"def":"To coat or to polish with black lead.","pos":""}],"BLACKLEG":[{"def":"A notorious gambler.","pos":""},{"def":"A disease among calves and sheep, characterized by a settling of gelatinous matter in the legs, and sometimes in the neck.","pos":""}],"BLACKLIST":[{"def":"To put in a black list as deserving of suspicion, censure, or punishment; esp.","pos":""}],"BLACKLY":[{"def":"In a black manner; darkly, in color; gloomily; threateningly; atrociously.","pos":""}],"BLACKMAIL":[{"def":"Black rent, or rent paid in corn, flesh, or the lowest coin, a opposed to \"white rent\", which paid in silver.","pos":""}],"BLACKMAILER":[{"def":"One who extorts, or endeavors to extort, money, by black mailing.","pos":""}],"BLACKMAILING":[{"def":"The act or practice of extorting money by exciting fears of injury other than bodily harm, as injury to reputation.","pos":""}],"BLACKNESS":[{"def":"The quality or state of being black; black color; atrociousness or enormity in wickedness.","pos":""}],"BLACKPOLL":[{"def":"A warbler of the United States (Dendroica striata).","pos":""}],"BLACKS":[{"def":"The name of a kind of in used in copperplate printing, prepared from the charred husks of the grape, and residue of the wine press.","pos":""},{"def":"Soot flying in the air.","pos":""}],"BLACKSALTER":[{"def":"One who,makes crude potash, or black salts.","pos":""}],"BLACKSMITH":[{"def":"A fish of the Pacific coast (Chromis, or Heliastes, punctipinnis), of a blackish color.","pos":""},{"def":"A snake of a black color, of which two species are common in the United States, the Bascanium constrictor, or racer, sometimes six feet long, and the Scotophis Alleghaniensis, seven or eight feet long.","pos":""}],"BLACKSTRAP":[{"def":"A mixture of spirituous liquor (usually rum) and molasses.","pos":""},{"def":"Bad port wine; any commo wine of the Mediterranean; -- so called by sailors.","pos":""}],"BLACKTAIL":[{"def":"A fish; the ruff or pope.","pos":""},{"def":"The black-tailed deer (Cervus or Cariacus Columbianus) of California and Oregon; also, the mule deer of the Rocky Mountains.","pos":""}],"BLACKWATER STATE":[{"def":"Nebraska; -- a nickname alluding to the dark color of the water of its rivers, due to the presence of a black vegetable mold in the soil.","pos":""}],"BLACKWOOD":[{"def":"A name given to several dark-colored timbers.","pos":""}],"BLACKWORK":[{"def":"Work wrought by blacksmiths; -- so called in distinction from that wrought by whitesmiths.","pos":""}]}