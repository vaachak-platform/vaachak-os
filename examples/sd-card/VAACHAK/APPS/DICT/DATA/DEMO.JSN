{"DEMOBILIZATION":[{"def":"The disorganization or disarming of troops which have previously been mobilized or called into active service; the change from a war footing to a peace footing.","pos":""}],"DEMOBILIZE":[{"def":"To disorganize, or disband and send home, as troops which have been mobilized.","pos":""}],"DEMOCRACY":[{"def":"Government by the people; a form of government in which the supreme power is retained and directly exercised by the people.","pos":""},{"def":"Government by popular representation; a form of government in which the supreme power is retained by the people, but is indirectly exercised through a system of representation and delegated authority periodically renewed; a constitutional representative government; a republic.","pos":""}],"DEMOCRAT":[{"def":"One who is an adherent or advocate of democracy, or government by the people.","pos":""},{"def":"A member of the Democratic party.","pos":""}],"DEMOCRATIC":[{"def":"Pertaining to democracy; favoring democracy, or constructed upon the principle of government by the people.","pos":""},{"def":"Relating to a political party so called.","pos":""}],"DEMOCRATICAL":[{"def":"The democratical was democratically received.","pos":""}],"DEMOCRATICALLY":[{"def":"In a democratic manner.","pos":""}],"DEMOCRATISM":[{"def":"The principles or spirit of a democracy.","pos":""}],"DEMOCRATIZE":[{"def":"To render democratic.","pos":""}],"DEMOGORGON":[{"def":", A mysterious, terrible, and evil divinity, regarded by some as the author of creation, by others as a great magician who was supposed to command the spirits of the lower world.","pos":""}],"DEMOGRAPHY":[{"def":"The study of races, as to births, marriages, mortality, health, etc.","pos":""}],"DEMOISELLE":[{"def":"The Numidian crane (Antropoides virgo); -- so called on account of the grace and symmetry of its form and movements.","pos":""},{"def":"A beautiful, small dragon fly of the genus Agrion.","pos":""}],"DEMOLISH":[{"def":"To throw or pull down; to raze; to destroy the fabric of; to pull to pieces; to ruin; as, to demolish an edifice, or a wall.","pos":""}],"DEMOLISHER":[{"def":"One who, or that which, demolishes; as, a demolisher of towns.","pos":""}],"DEMOLITION":[{"def":"The act of overthrowing, pulling down, or destroying a pile or structure; destruction by violence; utter overthrow; -- opposed to construction; as, the demolition of a house, of military works, of a town, or of hopes.","pos":""}],"DEMON":[{"def":"A spirit, or immaterial being, holding a middle place between men and deities in pagan mythology.","pos":""}],"DEMONETIZATION":[{"def":"The act of demonetizing, or the condition of being demonetized.","pos":""}],"DEMONETIZE":[{"def":"To deprive of current value; to withdraw from use, as money.","pos":""}],"DEMONIAC":[{"def":"One of a sect of Anabaptists who maintain that the demons or devils will finally be saved.","pos":""}],"DEMONIACALLY":[{"def":"In a demoniacal manner.","pos":""}],"DEMONIACISM":[{"def":"The state of being demoniac, or the practices of demoniacs.","pos":""}],"DEMONIAL":[{"def":"Of or pertaining to a demon.","pos":""}],"DEMONIAN":[{"def":"Relating to, or having the nature of, a demon.","pos":""}],"DEMONIANISM":[{"def":"The state of being possessed by a demon or by demons.","pos":""}],"DEMONIASM":[{"def":"See Demonianism.","pos":""}],"DEMONIC":[{"def":"Of or pertaining to a demon or to demons; demoniac.","pos":""}],"DEMONISM":[{"def":"The belief in demons or false gods.","pos":""}],"DEMONIST":[{"def":"A believer in, or worshiper of, demons.","pos":""}],"DEMONIZE":[{"def":"To convert into a demon; to infuse the principles or fury of a demon into.","pos":""},{"def":"To control or possess by a demon.","pos":""}],"DEMONOCRACY":[{"def":"The power or government of demons.","pos":""}],"DEMONOLATRY":[{"def":"The worship of demons.","pos":""}],"DEMONOLOGER":[{"def":"One versed in demonology.","pos":""},{"def":"Of or Pertaining to demonology.","pos":""}],"DEMONOLOGIST":[{"def":"One who writes on, or is versed in, demonology.","pos":""}],"DEMONOLOGY":[{"def":"A treatise on demons; a supposititious science which treats of demons and their manifestations.","pos":""}],"DEMONOMAGY":[{"def":"Magic in which the aid of demons is invoked; black or infernal magic.","pos":""}],"DEMONOMANIA":[{"def":"A form of madness in which the patient conceives himself possessed of devils.","pos":""}],"DEMONOMIST":[{"def":"One in subjection to a demon, or to demons.","pos":""}],"DEMONOMY":[{"def":"The dominion of demons.","pos":""}],"DEMONRY":[{"def":"Demoniacal influence or possession.","pos":""}],"DEMONSHIP":[{"def":"The state of a demon.","pos":""}],"DEMONSTRABILITY":[{"def":"The quality of being demonstrable; demonstrableness.","pos":""}],"DEMONSTRABLE":[{"def":"Capable of being demonstrated; that can be proved beyond doubt or question.","pos":""},{"def":"Proved; apparent.","pos":""}],"DEMONSTRABLENESS":[{"def":"The quality of being demonstrable; demonstrability.","pos":""}],"DEMONSTRABLY":[{"def":"In a demonstrable manner; incontrovertibly; clearly.","pos":""}],"DEMONSTRANCE":[{"def":"Demonstration; proof.","pos":""}],"DEMONSTRATE":[{"def":"To exhibit and explain (a dissection or other anatomical preparation).","pos":""}],"DEMONSTRATER":[{"def":"See Demonstrator.","pos":""}],"DEMONSTRATION":[{"def":"The exhibition and explanation of a dissection or other anatomical preparation.","pos":""},{"def":"The act of proving by the syllogistic process, or the proof itself.","pos":""}],"DEMONSTRATIVE":[{"def":"Having the nature of demonstration; tending to demonstrate; making evident; exhibiting clearly or conclusively.","pos":""},{"def":"Expressing, or apt to express, much; displaying feeling or sentiment; as, her nature was demonstrative.","pos":""}],"DEMONSTRATIVELY":[{"def":"In a manner fitted to demonstrate; clearly; convincingly; forcibly.","pos":""}],"DEMONSTRATIVENESS":[{"def":"The state or quality of being demonstrative.","pos":""}],"DEMONSTRATOR":[{"def":"A teacher of practical anatomy.","pos":""}],"DEMONSTRATORY":[{"def":"Tending to demonstrate; demonstrative.","pos":""}],"DEMORALIZATION":[{"def":"The act of corrupting or subverting morals.","pos":""}],"DEMORALIZE":[{"def":"To corrupt or undermine in morals; to destroy or lessen the effect of moral principles on; to render corrupt or untrustworthy in morals, in discipline, in courage, spirit, etc.","pos":""}],"DEMOSTHENIC":[{"def":"Pertaining to, or in the style of, Demosthenes, the Grecian orator.","pos":""}],"DEMOTE":[{"def":"To reduce to a lower grade, as in school.","pos":""}],"DEMOTIC":[{"def":"Of or pertaining to the people; popular; common.","pos":""}],"DEMOTICS":[{"def":"The department of knowledge relative to the care and culture of the people; sociology in its broadest sense; -- in library cataloguing.","pos":""}],"DEMOUNTABLE":[{"def":"Capable of being dismounted; -- said of a form of rim, for an automobile wheel, which can be removed with its tire from the wheel.","pos":""}]}