{"WAR":[{"def":"A condition of belligerency to be maintained by physical force.","pos":""}],"WARBLE":[{"def":"To sing in a trilling, quavering, or vibratory manner; to modulate with turns or variations; to trill; as, certain birds are remarkable for warbling their songs.","pos":""},{"def":"To utter musically; to modulate; to carol.","pos":""}],"WARBLER":[{"def":"Any one of numerous species of small Old World singing birds belonging to the family Sylviidæ, many of which are noted songsters.","pos":""},{"def":"Any one of numerous species of small, often bright colored, American singing birds of the family or subfamily Mniotiltidæ, or Sylvicolinæ.","pos":""}],"WARBLINGLY":[{"def":"In a warbling manner.","pos":""}],"WARBURG'S TINCTURE":[{"def":"A preparation containing quinine and many other ingredients, often used in the treatment of malarial affections.","pos":""},{"def":"Suffixes denoting course or direction to; motion or tendency toward; as in backward, or backwards; toward, or towards, etc.","pos":""}],"WARD":[{"def":"The act of guarding; watch; guard; guardianship; specifically, a guarding during the day.","pos":""},{"def":"One who, or that which, guards; garrison; defender; protector; means of guarding; defense; protection.","pos":""}],"WARD-CORN":[{"def":"The duty of keeping watch and ward (see the Note under Watch, n.","pos":""}],"WARDCORPS":[{"def":"Guardian; one set to watch over another.","pos":""}],"WARDEN":[{"def":"A large, hard pear, chiefly used for baking and roasting.","pos":""},{"def":"The office or jurisdiction of a warden.","pos":""}],"WARDER":[{"def":"One who wards or keeps; a keeper; a guard.","pos":""},{"def":"A truncheon or staff carried by a king or a commander in chief, and used in signaling his will.","pos":""}],"WARDIAN":[{"def":"Designating, or pertaining to, a kind of glass inclosure for keeping ferns, mosses, etc.","pos":""}],"WARDMOTE":[{"def":"Anciently, a meeting of the inhabitants of a ward; also, a court formerly held in each ward of London for trying defaults in matters relating to the watch, police, and the like.","pos":""}],"WARDROBE":[{"def":"A room or apartment where clothes are kept, or wearing apparel is stored; a portable closet for hanging up clothes.","pos":""},{"def":"Wearing apparel, in general; articles of dress or personal decoration.","pos":""}],"WARDROOM":[{"def":"A room occupied as a messroom by the commissioned officers of a war vessel.","pos":""}],"WARDSHIP":[{"def":"The office of a ward or keeper; care and protection of a ward; guardianship; right of guardianship.","pos":""},{"def":"The state of begin under a guardian; pupilage.","pos":""}],"WARDSMAN":[{"def":"A man who keeps ward; a guard.","pos":""}],"WARE":[{"def":"To wear, or veer.","pos":""}],"WAREFUL":[{"def":"Wary; watchful; cautious.","pos":""}],"WAREFULNESS":[{"def":"Wariness; cautiousness.","pos":""}],"WAREHOUSE":[{"def":"A storehouse for wares, or goods.","pos":""}],"WAREHOUSEMAN":[{"def":"One who keeps a warehouse; the owner or keeper of a dock warehouse or wharf store.","pos":""},{"def":"One who keeps a wholesale shop or store for Manchester or woolen goods.","pos":""}],"WAREHOUSING":[{"def":"The act of placing goods in a warehouse, or in a customhouse store.","pos":""}],"WARELESS":[{"def":"Unwary; incautious; unheeding; careless; unaware.","pos":""}],"WARELY":[{"def":"Cautiously; warily.","pos":""}],"WAREROOM":[{"def":"A room in which goods are stored or exhibited for sale.","pos":""}],"WARFARE":[{"def":"Military service; military life; contest carried on by enemies; hostilities; war.","pos":""},{"def":"Contest; struggle.","pos":""}],"WARFARER":[{"def":"One engaged in warfare; a military man; a soldier; a warrior.","pos":""}],"WARIANGLE":[{"def":"The red-backed shrike (Lanius collurio); -- called also würger, worrier, and throttler.","pos":""}],"WARILY":[{"def":"In a wary manner.","pos":""}],"WARINE":[{"def":"A South American monkey, one of the sapajous.","pos":""}],"WARINESS":[{"def":"The quality or state of being wary; care to foresee and guard against evil; cautiousness.","pos":""}],"WARISH":[{"def":"To protect from the effects of; hence, to cure; to heal.","pos":""}],"WARISON":[{"def":"Preparation; protection; provision; supply.","pos":""},{"def":"Reward; requital; guerdon.","pos":""}],"WARK":[{"def":"Work; a building.","pos":""}],"WARKLOOM":[{"def":"A tool; an implement.","pos":""}],"WARLIKE":[{"def":"Fit for war; disposed for war; as, a warlike state; a warlike disposition.","pos":""},{"def":"Belonging or relating to war; military; martial.","pos":""}],"WARLIKENESS":[{"def":"Quality of being warlike.","pos":""}],"WARLING":[{"def":"One often quarreled with; -- darling.","pos":""}],"WARLOCK":[{"def":"A male witch; a wizard; a sprite; an imp.","pos":""}],"WARLOCKRY":[{"def":"Impishness; magic.","pos":""}],"WARM":[{"def":"Having yellow or red for a basis, or in their composition; -- said of colors, and opposed to cold which is of blue and its compounds.","pos":""}],"WARM-BLOODED":[{"def":"Having warm blood; -- applied especially to those animals, as birds and mammals, which have warm blood, or, more properly, the power of maintaining a nearly uniform temperature whatever the temperature of the surrounding air.","pos":""}],"WARM-HEARTED":[{"def":"Having strong affection; cordial; sincere; hearty; sympathetic.","pos":""}],"WARMER":[{"def":"One who, or that which, warms.","pos":""}],"WARMFUL":[{"def":"Abounding in capacity to warm; giving warmth; as, a warmful garment.","pos":""}],"WARMLY":[{"def":"In a warm manner; ardently.","pos":""}],"WARMONGER":[{"def":"One who makes ar a trade or business; a mercenary.","pos":""}],"WARMOUTH":[{"def":"An American freshwater bream, or sunfish (Chænobryttus gulosus); -- called also red-eyed bream.","pos":""}],"WARMTH":[{"def":"The glowing effect which arises from the use of warm colors; hence, any similar appearance or effect in a painting, or work of color.","pos":""}],"WARMTHLESS":[{"def":"Being without warmth; not communicating warmth; cold.","pos":""}],"WARN":[{"def":"To make ware or aware; to give previous information to; to give notice to; to notify; to admonish; hence, to notify or summon by authority; as, to warn a town meeting; to warn a tenant to quit a house.","pos":""},{"def":"To give notice to, of approaching or probable danger or evil; to caution against anything that may prove injurious.","pos":""}],"WARNER":[{"def":"One who warns; an admonisher.","pos":""}],"WARNING":[{"def":"Giving previous notice; cautioning; admonishing; as, a warning voice.","pos":""}],"WARNINGLY":[{"def":"In a warning manner.","pos":""}],"WARP":[{"def":"To tow or move, as a vessel, with a line, or warp, attached to a buoy, anchor, or other fixed object.","pos":""},{"def":"To let the tide or other water in upon (lowlying land), for the purpose of fertilization, by a deposit of warp, or slimy substance.","pos":""}],"WARP KNITTING":[{"def":"A kind of knitting in which a number of threads are interchained each with one or more contiguous threads on either side.","pos":""}],"WARPAGE":[{"def":"The act of warping; also, a charge per ton made on shipping in some harbors.","pos":""}],"WARPATH":[{"def":"The route taken by a party of Indians going on a warlike expedition.","pos":""}],"WARPER":[{"def":"One who, or that which, warps or twists out of shape.","pos":""},{"def":"One who, or that which, forms yarn or thread into warps or webs for the loom.","pos":""}],"WARPING":[{"def":"The act or process of one who, or that which, warps.","pos":""},{"def":"The art or occupation of preparing warp or webs for the weaver.","pos":""}],"WARPROOF":[{"def":"Valor tried by war.","pos":""}],"WARRANDICE":[{"def":"The obligation by which a person, conveying a subject or a right, is bound to uphold that subject or right against every claim, challenge, or burden arising from circumstances prior to the conveyance; warranty.","pos":""}],"WARRANT":[{"def":"That which vouches or insures for anything; guaranty; security.","pos":""}],"WARRANTABLE":[{"def":"Authorized by commission, precept, or right; justifiable; defensible; as, the seizure of a thief is always warrantable by law and justice; falsehood is never warrantable.","pos":""}],"WARRANTEE":[{"def":"The person to whom a warrant or warranty is made.","pos":""}],"WARRANTER":[{"def":"One who assures, or covenants to assure; one who contracts to secure another in a right, or to make good any defect of title or quality; one who gives a warranty; a guarantor; as, the warranter of a horse.","pos":""}],"WARRANTISE":[{"def":"Authority; security; warranty.","pos":""}],"WARRANTOR":[{"def":"One who warrants.","pos":""}],"WARRANTY":[{"def":"A covenant real, whereby the grantor of an estate of freehold and his heirs were bound to warrant and defend the title, and, in case of eviction by title paramount, to yield other lands of equal value in recompense.","pos":""},{"def":"An engagement or undertaking, express or implied, that a certain fact regarding the subject of a contract is, or shall be, as it is expressly or impliedly declared or promised to be.","pos":""}],"WARRAY":[{"def":"To make war upon.","pos":""}],"WARRE":[{"def":"They say the world is much warre than it wont.","pos":""}],"WARREN":[{"def":"A piece of ground for the breeding of rabbits.","pos":""},{"def":"A place for keeping flash, in a river.","pos":""}],"WARRENER":[{"def":"The keeper of a warren.","pos":""}],"WARRIN":[{"def":"An Australian lorikeet (Trichoglossus multicolor) remarkable for the variety and brilliancy of its colors; -- called also blue- bellied lorikeet, and blue-bellied parrot.","pos":""}],"WARRIOR":[{"def":"A man engaged or experienced in war, or in the military life; a soldier; a champion.","pos":""}],"WARRIORESS":[{"def":"A female warrior.","pos":""}],"WART":[{"def":"A small, usually hard, tumor on the skin formed by enlargement of its vascular papillæ, and thickening of the epidermis which covers them.","pos":""}],"WART HOG":[{"def":"Either one of two species of large, savage African wild hogs of the genus Phacochoerus.","pos":""}],"WARTED":[{"def":"Having little knobs on the surface; verrucose; as, a warted capsule.","pos":""}],"WARTWEED":[{"def":"Same as Wartwort.","pos":""}],"WARTWORT":[{"def":"A name given to several plants because they were thought to be a cure for warts, as a kind of spurge (Euphorbia Helioscopia), and the nipplewort (Lampsana communis).","pos":""}],"WARTY":[{"def":"Having warts; full of warts; overgrow with warts; as, a warty leaf.","pos":""},{"def":"Of the nature of warts; as, a warty excrescence.","pos":""}],"WARTY-BACK":[{"def":"An American fresh-water mussel (Quadrula pustulosa).","pos":""}],"WARWICKITE":[{"def":"A dark brown or black mineral, occurring in prismatic crystals imbedded in limestone near Warwick, New York.","pos":""}],"WARWORN":[{"def":"Worn with military service; as, a warworn soldier; a warworn coat.","pos":""}],"WARY":[{"def":"Cautious of danger; carefully watching and guarding against deception, artifices, and dangers; timorously or suspiciously prudent; circumspect; scrupulous; careful.","pos":""},{"def":"Characterized by caution; guarded; careful.","pos":""}],"WARYE":[{"def":"To curse; to curse; to execrate; to condemn; also, to vex.","pos":""}]}