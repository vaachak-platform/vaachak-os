{"DISLEAL":[{"def":"Disloyal; perfidious.","pos":""}],"DISLEAVE":[{"def":"To deprive of leaves.","pos":""}],"DISLIKE":[{"def":"To regard with dislike or aversion; to disapprove; to disrelish.","pos":""},{"def":"To awaken dislike in; to displease.","pos":""}],"DISLIKEFUL":[{"def":"Full of dislike; disaffected; malign; disagreeable.","pos":""}],"DISLIKELIHOOD":[{"def":"The want of likelihood; improbability.","pos":""}],"DISLIKEN":[{"def":"To make unlike; to disguise.","pos":""}],"DISLIKER":[{"def":"One who dislikes or disrelishes.","pos":""}],"DISLIMB":[{"def":"To tear limb from limb; to dismember.","pos":""}],"DISLIMN":[{"def":"To efface, as a picture.","pos":""}],"DISLINK":[{"def":"To unlink; to disunite; to separate.","pos":""}],"DISLIVE":[{"def":"To deprive of life.","pos":""}],"DISLOCATE":[{"def":"To displace; to put out of its proper place.","pos":""}],"DISLOCATION":[{"def":"The displacement of parts of rocks or portions of strata from the situation which they originally occupied.","pos":""},{"def":"The act of dislocating, or putting out of joint; also, the condition of being thus displaced.","pos":""}],"DISLODGE":[{"def":"To drive from a lodge or place of rest; to remove from a place of quiet or repose; as, shells resting in the sea at a considerate depth are not dislodged by storms.","pos":""},{"def":"To drive out from a place of hiding or defense; as, to dislodge a deer, or an enemy.","pos":""}],"DISLODGMENT":[{"def":"The act or process of dislodging, or the state of being dislodged.","pos":""}],"DISLOIGN":[{"def":"To put at a distance; to remove.","pos":""}],"DISLOYAL":[{"def":"Not loyal; not true to a sovereign or lawful superior, or to the government under which one lives; false where allegiance is due; faithless; as, a subject disloyal to the king; a husband disloyal to his wife.","pos":""}],"DISLOYALLY":[{"def":"In a disloyal manner.","pos":""}],"DISLOYALTY":[{"def":"Want of loyalty; lack of fidelity; violation of allegiance.","pos":""}]}