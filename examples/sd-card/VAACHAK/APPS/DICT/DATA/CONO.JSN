{"CONODONT":[{"def":"A peculiar toothlike fossil of many forms, found especially in carboniferous rocks.","pos":""}],"CONOID":[{"def":"Anything that has a form resembling that of a cone.","pos":""}],"CONOIDAL":[{"def":"Nearly, but not exactly, conical.","pos":""},{"def":"Pertaining to a conoid; having the form of a conoid.","pos":""}],"CONOMINEE":[{"def":"One nominated in conjunction with another; a joint nominee.","pos":""}]}