{"RALE":[{"def":"An adventitious sound, usually of morbid origin, accompanying the normal respiratory sounds.","pos":""}],"RALLENTANDO":[{"def":"Slackening; -- a direction to perform a passage with a gradual decrease in time and force; ritardando.","pos":""}],"RALLIANCE":[{"def":"The act of rallying.","pos":""}],"RALLIER":[{"def":"One who rallies.","pos":""}],"RALLIES":[{"def":"A French political group, also known as the Constitutional Right from its position in the Chambers, mainly monarchists who rallied to the support of the Republic in obedience to the encyclical put forth by Pope Leo XIII.","pos":""}],"RALLINE":[{"def":"Pertaining to the rails.","pos":""}],"RALLY":[{"def":"To collect, and reduce to order, as troops dispersed or thrown into confusion; to gather again; to reunite.","pos":""}],"RALPH":[{"def":"A name sometimes given to the raven.","pos":""}],"RALSTONITE":[{"def":"A fluoride of alumina and soda occurring with the Greenland cryolite in octahedral crystals.","pos":""}]}