{"EXPIABLE":[{"def":"Capable of being expiated or atoned for; as, an expiable offense; expiable guilt.","pos":""}],"EXPIATE":[{"def":"To extinguish the guilt of by sufferance of penalty or some equivalent; to make complete satisfaction for; to atone for; to make amends for; to make expiation for; as, to expiate a crime, a guilt, or sin.","pos":""},{"def":"To purify with sacred rites.","pos":""}],"EXPIATION":[{"def":"The act of making satisfaction or atonement for any crime or fault; the extinguishing of guilt by suffering or penalty.","pos":""},{"def":"The means by which reparation or atonement for crimes or sins is made; an expiatory sacrifice or offering; an atonement.","pos":""}],"EXPIATOR":[{"def":"One who makes expiation or atonement.","pos":""}],"EXPIATORIOUS":[{"def":"Of an expiatory nature; expiatory.","pos":""}],"EXPIATORY":[{"def":"Having power, or intended, to make expiation; atoning; as, an expiatory sacrifice.","pos":""}],"EXPILATION":[{"def":"The act of expilating or stripping off; plunder; pillage.","pos":""}],"EXPILATOR":[{"def":"One who pillages; a plunderer; a pillager.","pos":""}],"EXPIRABLE":[{"def":"That may expire; capable of being brought to an end.","pos":""}],"EXPIRANT":[{"def":"One who expires or is expiring.","pos":""}],"EXPIRATION":[{"def":"The act or process of breathing out, or forcing air from the lungs through the nose or mouth; as, respiration consists of inspiration and expiration; -- opposed to Ant: inspiration.","pos":""}],"EXPIRATORY":[{"def":"Pertaining to, or employed in, the expiration or emission of air from the lungs; as, the expiratory muscles.","pos":""}],"EXPIRE":[{"def":"To breathe out; to emit from the lungs; to throw out from the mouth or nostrils in the process of respiration; -- opposed to inspire.","pos":""},{"def":"To give forth insensibly or gently, as a fluid or vapor; to emit in minute particles; to exhale; as, the earth expires a damp vapor; plants expire odors.","pos":""}],"EXPIRING":[{"def":"Breathing out air from the lungs; emitting fluid or volatile matter; exhaling; breathing the last breath; dying; ending; terminating.","pos":""},{"def":"Pertaining to, or uttered at, the time of dying; as, expiring words; expiring groans.","pos":""}],"EXPIRY":[{"def":"He had to leave at the expiry of the term.","pos":""}],"EXPISCATE":[{"def":"To fish out; to find out by skill or laborious investigation; to search out.","pos":""}],"EXPISCATION":[{"def":"The act of expiscating; a fishing.","pos":""}],"EXPISCATORY":[{"def":"Tending to fish out; searching out [R.","pos":""}]}