{"SPIKE":[{"def":"A kind of flower cluster in which sessile flowers are arranged on an unbranched elongated axis.","pos":""}],"SPIKED":[{"def":"Furnished or set with spikes, as corn; fastened with spikes; stopped with spikes.","pos":""}],"SPIKELET":[{"def":"A small or secondary spike; especially, one of the ultimate parts of the in florescence of grasses.","pos":""}],"SPIKENARD":[{"def":"An aromatic plant.","pos":"noun"}],"SPIKETAIL":[{"def":"The pintail duck.","pos":""}],"SPIKY":[{"def":"Like a spike; spikelike.","pos":""},{"def":"Having a sharp point, or sharp points; furnished or armed with spikes.","pos":""}]}