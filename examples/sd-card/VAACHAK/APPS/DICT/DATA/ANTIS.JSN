{"ANTISABBATARIAN":[{"def":"One of a sect which opposes the observance of the Christian Sabbath.","pos":""}],"ANTISACERDOTAL":[{"def":"Hostile to priests or the priesthood.","pos":""},{"def":"The inhabitants of the earth, living on different sides of the equator, whose shadows at noon are cast in opposite directions.","pos":""}],"ANTISCORBUTIC":[{"def":"Counteracting scurvy.","pos":""},{"def":"A remedy for scurvy.","pos":""}],"ANTISCORBUTICAL":[{"def":"An`ti*scor*bu\"tic*al, a.","pos":""}],"ANTISCRIPTURAL":[{"def":"Opposed to, or not in accordance with, the Holy Scriptures.","pos":""}],"ANTISEPALOUS":[{"def":"Standing before a sepal, or calyx leaf.","pos":""}],"ANTISEPSIS":[{"def":"Prevention of sepsis by excluding or destroying microorganisms.","pos":""},{"def":"Counteracting or preventing putrefaction, or a putrescent tendency in the system; antiputrefactive.","pos":""}],"ANTISEPTIC":[{"def":"A substance which prevents or retards putrefaction, or destroys, or protects from, putrefactive organisms; as, salt, carbolic acid, alcohol, cinchona.","pos":""}],"ANTISEPTICALLY":[{"def":"By means of antiseptics.","pos":""}],"ANTISIALAGOGUE":[{"def":"Checking the flow of saliva.","pos":""}],"ANTISLAVERY":[{"def":"Opposed to slavery.","pos":""},{"def":"Opposition to slavery.","pos":""}],"ANTISOCIAL":[{"def":"Tending to interrupt or destroy social intercourse; averse to society, or hostile to its existence; as, antisocial principles.","pos":""}],"ANTISOCIALIST":[{"def":"One opposed to the doctrines and practices of socialists or socialism.","pos":""}],"ANTISOLAR":[{"def":"Opposite to the sun; -- said of the point in the heavens 180º distant from the sun.","pos":""}],"ANTISPASMODIC":[{"def":"Good against spasms.","pos":""},{"def":"A medicine which prevents or allays spasms or convulsions.","pos":""}],"ANTISPAST":[{"def":"A foot of four syllables, the first and fourth short, and the second and third long.","pos":""}],"ANTISPASTIC":[{"def":"An antispastic agent.","pos":""}],"ANTISPLENETIC":[{"def":"Good as a remedy against disease of the spleen.","pos":""},{"def":"An antisplenetic medicine.","pos":""}],"ANTISTROPHE":[{"def":"In Greek choruses and dances, the returning of the chorus, exactly answering to a previous strophe or movement from right to left.","pos":""}],"ANTISTROPHIC":[{"def":"Of or pertaining to an antistrophe.","pos":""}],"ANTISTROPHON":[{"def":"An argument retorted on an opponent.","pos":""}],"ANTISTRUMATIC":[{"def":"A medicine for scrofula.","pos":""}],"ANTISTRUMOUS":[{"def":"Good against scrofulous disorders.","pos":""}],"ANTISYPHILITIC":[{"def":"Efficacious against syphilis.","pos":""},{"def":"A medicine for syphilis.","pos":""}]}