{"REVIBRATE":[{"def":"To vibrate back or in return.","pos":""}],"REVICTUAL":[{"def":"To victual again.","pos":""}],"REVIE":[{"def":"To meet a wager on, as on the taking of a trick, with a higher wager.","pos":""}],"REVIEW":[{"def":"To view or see again; to look back on [R.","pos":""},{"def":"To go over and examine critically or deliberately.","pos":""}],"REVIEWABLE":[{"def":"Capable of being reviewed.","pos":""}],"REVIEWER":[{"def":"One who reviews or reëxamines; an inspector; one who examines publications critically, and publishes his opinion upon their merits; a professional critic of books.","pos":""}],"REVIGORATE":[{"def":"Having new vigor or strength; invigorated anew.","pos":""}],"REVILE":[{"def":"To address or abuse with opprobrious and contemptuous language; to reproach.","pos":""}],"REVILEMENT":[{"def":"The act of reviling; also, contemptuous language; reproach; abuse.","pos":""}],"REVILER":[{"def":"One who reviles.","pos":""}],"REVILING":[{"def":"Reproach; abuse; vilification.","pos":""}],"REVINCE":[{"def":"To overcome; to refute, as error.","pos":""}],"REVINDICATE":[{"def":"To vindicate again; to reclaim; to demand and take back.","pos":""}],"REVIRESCENCE":[{"def":"A growing green or fresh again; renewal of youth or vigor.","pos":""}],"REVISABLE":[{"def":"That may be revised.","pos":""}],"REVISAL":[{"def":"The act of revising, or reviewing and reëxamining for correction and improvement; revision; as, the revisal of a manuscript; the revisal of a proof sheet; the revisal of a treaty.","pos":""}],"REVISE":[{"def":"To compare (a proof) with a previous proof of the same matter, and mark again such errors as have not been corrected in the type.","pos":""}],"REVISER":[{"def":"One who revises.","pos":""}],"REVISION":[{"def":"Of or pertaining to revision; revisory.","pos":""}],"REVISITATION":[{"def":"The act of revisiting.","pos":""}],"REVISORY":[{"def":"Having the power or purpose to revise; revising.","pos":""}],"REVITALIZE":[{"def":"To restore vitality to; to bring back to life.","pos":""}],"REVIVABLE":[{"def":"That may be revived.","pos":""}],"REVIVAL":[{"def":"The act of reviving, or the state of being revived.","pos":""}],"REVIVALISM":[{"def":"The spirit of religious revivals; the methods of revivalists.","pos":""}],"REVIVALIST":[{"def":"A clergyman or layman who promotes revivals of religion; an advocate for religious revivals; sometimes, specifically, a clergyman, without a particular charge, who goes about to promote revivals.","pos":""}],"REVIVALISTIC":[{"def":"Pertaining to revivals.","pos":""}],"REVIVE":[{"def":"To recover its natural or metallic state, as a metal.","pos":""}],"REVIVER":[{"def":"One who, or that which, revives.","pos":""}],"REVIVIFICATE":[{"def":"To revive; to recall or restore to life.","pos":""}],"REVIVIFICATION":[{"def":"The reduction of a metal from a state of combination to its metallic state.","pos":""}],"REVIVIFY":[{"def":"To cause to revive.","pos":""}],"REVIVING":[{"def":"Returning or restoring to life or vigor; reanimating.","pos":""},{"def":"The act of reviving, or the state of being revived; renewal of life.","pos":""}],"REVIVISCENT":[{"def":"Able or disposed to revive; reviving.","pos":""}],"REVIVOR":[{"def":"Revival of a suit which is abated by the death or marriage of any of the parties, -- done by a bill of revivor.","pos":""}]}