{"MAW":[{"def":"A stomach; the receptacle into which food is taken by swallowing; in birds, the craw; -- now used only of the lower animals, exept humorously or in contempt.","pos":""},{"def":"Appetite; inclination.","pos":""}],"MAWK":[{"def":"A slattern; a mawks.","pos":""}],"MAWKIN":[{"def":"See Malkin, and Maukin.","pos":""}],"MAWKISH":[{"def":"Apt to cause satiety or loathing; nauseous; disgusting.","pos":""},{"def":"Easily disgusted; squeamish; sentimentally fastidious.","pos":""}],"MAWKISHLY":[{"def":"In a mawkish way.","pos":""}],"MAWKISHNESS":[{"def":"The quality or state of being mawkish.","pos":""}],"MAWKS":[{"def":"A slattern; a mawk.","pos":""}],"MAWMET":[{"def":"A puppet; a doll; originally, an idol, because in the Middle Ages it was generally believed that the Mohammedans worshiped images representing Mohammed.","pos":""}],"MAWMETRY":[{"def":"The religion of Mohammed; also, idolatry.","pos":""}],"MAWSEED":[{"def":"The seed of the opium poppy.","pos":""}]}