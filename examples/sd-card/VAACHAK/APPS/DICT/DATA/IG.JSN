{"IGASURIC":[{"def":"Pertaining to, or obtained from, nux vomica or St.","pos":""}],"IGASURINE":[{"def":"An alkaloid found in nux vomica, and extracted as a white crystalline substance.","pos":""}],"IGLOO":[{"def":"A cavity, or excavation, made in the snow by a seal, over its breathing hole in the ice.","pos":""}],"IGNATIUS BEAN":[{"def":"See Saint Ignatius's bean, under Saint.","pos":""}],"IGNEOUS":[{"def":"Resulting from, or produced by, the action of fire; as, lavas and basalt are igneous rocks.","pos":""}],"IGNESCENT":[{"def":"Emitting sparks of fire when struck with steel; scintillating; as, ignescent stones.","pos":""}],"IGNICOLIST":[{"def":"A worshiper of fire.","pos":""}],"IGNIFLUOUS":[{"def":"Flowing with fire.","pos":""}],"IGNIFY":[{"def":"To form into fire.","pos":""}],"IGNIGENOUS":[{"def":"Produced by the action of fire, as lava.","pos":""}],"IGNIPOTENCE":[{"def":"Power over fire.","pos":""}],"IGNIPOTENT":[{"def":"Presiding over fire; also, fiery.","pos":""}],"IGNIS FATUUS":[{"def":"A phosphorescent light that appears, in the night, over marshy ground, supposed to be occasioned by the decomposition of animal or vegetable substances, or by some inflammable gas; -- popularly called also Will-with-the-wisp, or Will-o'-the-wisp, and Jack-with-a- lantern, or Jack-o'-lantern.","pos":""}],"IGNITE":[{"def":"To subject to the action of intense heat; to heat strongly; -- often said of incombustible or infusible substances; as, to ignite iron or platinum.","pos":""}],"IGNITIBLE":[{"def":"Capable of being ignited.","pos":""}],"IGNITION":[{"def":"The act of igniting, kindling, or setting on fire.","pos":""},{"def":"The state of being ignited or kindled.","pos":""}],"IGNITOR":[{"def":"One who, or that which, produces ignition; especially, a contrivance for igniting the powder in a torpedo or the like.","pos":""}],"IGNOBLE":[{"def":"Not a true or noble falcon; -- said of certain hawks, as the goshawk.","pos":""}],"IGNOBLENESS":[{"def":"State or quality of being ignoble.","pos":""}],"IGNOBLY":[{"def":"In an ignoble manner; basely.","pos":""}],"IGNOMINIOUS":[{"def":"Marked with ignominy; in curring public disgrace; dishonorable; shameful.","pos":""},{"def":"Deserving ignominy; despicable.","pos":""}],"IGNOMINIOUSLY":[{"def":"In an ignominious manner; disgracefully; shamefully; ingloriously.","pos":""}],"IGNOMINY":[{"def":"Public disgrace or dishonor; reproach; infamy.","pos":""},{"def":"An act deserving disgrace; an infamous act.","pos":""}],"IGNOMY":[{"def":"I blush to think upon this ignomy.","pos":""}],"IGNORAMUS":[{"def":"We are ignorant; we ignore; -- being the word formerly written on a bill of indictment by a grand jury when there was not sufficient evidence to warrant them in finding it a true bill.","pos":""},{"def":"A stupid, ignorant person; a vain pretender to knowledge; a dunce.","pos":""}],"IGNORANCE":[{"def":"A willful neglect or refusal to acquire knowledge which one may acquire and it is his duty to have.","pos":""}],"IGNORANT":[{"def":"Destitute of knowledge; uninstructed or uninformed; untaught; unenlightened.","pos":""},{"def":"Unacquainted with; unconscious or unaware; -- used with of.","pos":""}],"IGNORANTISM":[{"def":"The spirit of those who extol the advantage to ignorance; obscuriantism.","pos":""}],"IGNORANTIST":[{"def":"One opposed to the diffusion of knowledge; an obscuriantist.","pos":""}],"IGNORANTLY":[{"def":"In a ignorant manner; without knowledge; inadvertently.","pos":""}],"IGNORE":[{"def":"To throw out or reject as false or ungrounded; -- said of a bill rejected by a grand jury for want of evidence.","pos":""}],"IGNOTE":[{"def":"One who is unknown.","pos":""}],"IGUANA":[{"def":"Any species of the genus Iguana, a genus of large American lizards of the family Iguanidæ.","pos":""}],"IGUANIAN":[{"def":"Resembling, or pertaining to, the iguana.","pos":""}],"IGUANID":[{"def":"Same as Iguanoid.","pos":""}],"IGUANODON":[{"def":"A genus of gigantic herbivorous dinosaurs having a birdlike pelvis and large hind legs with three-toed feet capable of supporting the entire body.","pos":""}],"IGUANODONT":[{"def":"Like or pertaining to the genus Iguanodon.","pos":""}],"IGUANOID":[{"def":"Pertaining to the Iguanidæ.","pos":""}]}