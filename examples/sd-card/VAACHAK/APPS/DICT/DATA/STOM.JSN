{"STOMA":[{"def":"One of the minute apertures between the cells in many serous membranes.","pos":""}],"STOMACH":[{"def":"An enlargement, or series of enlargements, in the anterior part of the alimentary canal, in which food is digested; any cavity in which digestion takes place in an animal; a digestive cavity.","pos":""}],"STOMACHAL":[{"def":"Of or pertaining to the stomach; gastric.","pos":""},{"def":"Helping the stomach; stomachic; cordial.","pos":""}],"STOMACHER":[{"def":"An ornamental covering for the breast, worn originally both by men and women.","pos":""}],"STOMACHFUL":[{"def":"Willfully obstinate; stubborn; perverse.","pos":""}],"STOMACHIC":[{"def":"A medicine that strengthens the stomach and excites its action.","pos":""}],"STOMACHLESS":[{"def":"Being without a stomach.","pos":""},{"def":"Having no appetite.","pos":""}],"STOMACHOUS":[{"def":"Stout; sullen; obstinate.","pos":""}],"STOMACHY":[{"def":"Obstinate; sullen; haughty.","pos":""}],"STOMAPOD":[{"def":"One of the Stomapoda.","pos":""}],"STOMAPODA":[{"def":"An order of Crustacea including the squillas.","pos":""}],"STOMATIC":[{"def":"Of or pertaining to a stoma; of the nature of a stoma.","pos":""}],"STOMATIFEROUS":[{"def":"Having or producing stomata.","pos":""}],"STOMATITIS":[{"def":"Inflammation of the mouth.","pos":""}],"STOMATODA":[{"def":"A division of Protozoa in which a mouthlike opening exists.","pos":""}],"STOMATODAEUM":[{"def":"Same as Stomodæum.","pos":""}],"STOMATODE":[{"def":"Having a mouth; -- applied to certain Protozoa.","pos":""},{"def":"One of the Stomatoda.","pos":""}],"STOMATOGASTRIC":[{"def":"Of or pertaining to the mouth and the stomach; as, the stomatogastric ganglion of certain Mollusca.","pos":""}],"STOMATOLOGY":[{"def":"Scientific study or knowledge of the mouth.","pos":""}],"STOMATOPLASTIC":[{"def":"Of or pertaining to the operation of forming a mouth where the aperture has been contracted, or in any way deformed.","pos":""}],"STOMATOPLASTY":[{"def":"Plastic surgery of the mouth.","pos":""}],"STOMATOPOD":[{"def":"One of the Stomatopoda.","pos":""}],"STOMATOPODA":[{"def":"Same as Stomapoda.","pos":""}],"STOMATOPODOUS":[{"def":"Of or pertaining to the Stomatopoda.","pos":""}],"STOMATOSCOPE":[{"def":"An apparatus for examining the interior of the mouth.","pos":""}],"STOMODAEUM":[{"def":"A part of the alimentary canal.","pos":""},{"def":"The primitive mouth and esophagus of the embryo of annelids and arthropods.","pos":""}],"STOMP":[{"def":"To stamp with the foot.","pos":""}]}