{"ENTELECHY":[{"def":"An actuality; a conception completely actualized, in distinction from mere potential existence.","pos":""}],"ENTELLUS":[{"def":"An East Indian long-tailed bearded monkey (Semnopithecus entellus) regarded as sacred by the natives.","pos":""}],"ENTEND":[{"def":"To attend to; to apply one's self to.","pos":""}],"ENTENDER":[{"def":"To treat with tenderness.","pos":""}],"ENTENTIVE":[{"def":"Attentive; zealous.","pos":""}],"ENTER":[{"def":"To come or go into; to pass into the interior of; to pass within the outer cover or shell of; to penetrate; to pierce; as, to enter a house, a closet, a country, a door, etc.","pos":""},{"def":"To unite in; to join; to be admitted to; to become a member of; as, to enter an association, a college, an army.","pos":""}],"ENTER-":[{"def":"A prefix signifying between, among, part.","pos":""}],"ENTERADENOGRAPHY":[{"def":"A treatise upon, or description of, the intestinal glands.","pos":""}],"ENTERADENOLOGY":[{"def":"The science which treats of the glands of the alimentary canal.","pos":""}],"ENTERALGIA":[{"def":"Pain in the intestines; colic.","pos":""}],"ENTERDEAL":[{"def":"Mutual dealings; intercourse.","pos":""}],"ENTERER":[{"def":"One who makes an entrance or beginning.","pos":""}],"ENTERIC":[{"def":"Of or pertaining to the enteron, or alimentary canal; intestinal.","pos":""},{"def":"= Advancing edge.","pos":""}],"ENTERITIS":[{"def":"An inflammation of the intestines.","pos":""}],"ENTERMETE":[{"def":"To interfere; to intermeddle.","pos":""}],"ENTERMEWER":[{"def":"A hawk gradually changing the color of its feathers, commonly in the second year.","pos":""}],"ENTEROCELE":[{"def":"A hernial tumor whose contents are intestine.","pos":""}],"ENTEROCOELE":[{"def":"A perivisceral cavity which arises as an outgrowth or outgrowths from the digestive tract; distinguished from a schizocoele, which arises by a splitting of the mesoblast of the embryo.","pos":""}],"ENTEROGRAPHY":[{"def":"A treatise upon, or description of, the intestines; enterology.","pos":""}],"ENTEROLITH":[{"def":"An intestinal concretion.","pos":""}],"ENTEROLOGY":[{"def":"The science which treats of the viscera of the body.","pos":""}],"ENTERON":[{"def":"The whole alimentary, or enteric, canal.","pos":""}],"ENTEROPATHY":[{"def":"Disease of the intestines.","pos":""}],"ENTEROPNEUSTA":[{"def":"A group of wormlike invertebrates having, along the sides of the body, branchial openings for the branchial sacs, which are formed by diverticula of the alimentary canal.","pos":""}],"ENTERORRHAPHY":[{"def":"The operation of sewing up a rent in the intestinal canal.","pos":""}],"ENTEROTOME":[{"def":"A kind of scissors used for opening the intestinal canal, as in post-mortem examinations.","pos":""}],"ENTEROTOMY":[{"def":"Incision of the intestines, especially in reducing certain cases of hernia.","pos":""}],"ENTERPARLANCE":[{"def":"Mutual talk or conversation; conference.","pos":""}],"ENTERPLEAD":[{"def":"Same as Interplead.","pos":""}],"ENTERPRISE":[{"def":"That which is undertaken; something attempted to be performed; a work projected which involves activity, courage, energy, and the like; a bold, arduous, or hazardous attempt; an undertaking; as, a manly enterprise; a warlike enterprise.","pos":""},{"def":"Willingness or eagerness to engage in labor which requires boldness, promptness, energy, and like qualities; as, a man of great enterprise.","pos":""}],"ENTERPRISER":[{"def":"One who undertakes enterprises.","pos":""}],"ENTERPRISING":[{"def":"Having a disposition for enterprise; characterized by enterprise; resolute, active or prompt to attempt; as, an enterprising man or firm.","pos":""}],"ENTERTAIN":[{"def":"To be at the charges of; to take or keep in one's service; to maintain; to support; to harbor; to keep.","pos":""},{"def":"To give hospitable reception and maintenance to; to receive at one's board, or into one's house; to receive as a guest.","pos":""}],"ENTERTAINER":[{"def":"One who entertains.","pos":""}],"ENTERTAINING":[{"def":"Affording entertainment; pleasing; amusing; diverting.","pos":""}],"ENTERTAINMENT":[{"def":"The act of receiving as host, or of amusing, admitting, or cherishing; hospitable reception; also, reception or treatment, in general.","pos":""},{"def":"That which entertains, or with which one is entertained; as: (a) Hospitality; hospitable provision for the wants of a guest; especially, provision for the table; a hospitable repast; a feast; a formal or elegant meal.","pos":""}],"ENTERTISSUED":[{"def":"Same as Intertissued.","pos":""},{"def":"Divinely inspired; wrought up to enthusiasm.","pos":""}]}