{"INTHIRST":[{"def":"To make thirsty.","pos":""}],"INTHRALL":[{"def":"To reduce to bondage or servitude; to make a thrall, slave, vassal, or captive of; to enslave.","pos":""}],"INTHRALLMENT":[{"def":"Act of inthralling, or state of being inthralled; servitude; bondage; vassalage.","pos":""}],"INTHRONE":[{"def":"Same as Enthrone.","pos":""}],"INTHRONG":[{"def":"To throng or collect together.","pos":""}],"INTHRONIZATION":[{"def":"In*thron`i*za\"tion, n.","pos":""}]}