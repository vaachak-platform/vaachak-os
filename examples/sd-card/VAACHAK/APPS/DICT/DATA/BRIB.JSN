{"BRIBABLE":[{"def":"Capable of being bribed.","pos":""}],"BRIBE":[{"def":"A gift begged; a present.","pos":""},{"def":"A price, reward, gift, or favor bestowed or promised with a view to prevent the judgment or corrupt the conduct of a judge, witness, voter, or other person in a position of trust.","pos":""}],"BRIBELESS":[{"def":"Incapable of being bribed; free from bribes.","pos":""}],"BRIBER":[{"def":"One who bribes, or pays for corrupt practices.","pos":""}],"BRIBERY":[{"def":"Miscellaneous curiosities and works of decorative art, considered collectively.","pos":""}]}