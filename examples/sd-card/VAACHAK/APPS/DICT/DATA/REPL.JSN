{"REPLACE":[{"def":"To place again; to restore to a former place, position, condition, or the like.","pos":""},{"def":"To refund; to repay; to restore; as, to replace a sum of money borrowed.","pos":""}],"REPLACEABILITY":[{"def":"The quality, state, or degree of being replaceable.","pos":""}],"REPLACEABLE":[{"def":"Capable of being replaced (by), or of being exchanged (for); as, the hydrogen of acids is replaceable by metals or by basic radicals.","pos":""}],"REPLACEMENT":[{"def":"The removal of an edge or an angle by one or more planes.","pos":""}],"REPLAIT":[{"def":"To plait or fold again; to fold, as one part over another, again and again.","pos":""}],"REPLANT":[{"def":"Re*plant\" (rE-plnt\"), v.","pos":""}],"REPLANTABLE":[{"def":"That may be planted again.","pos":""}],"REPLANTATION":[{"def":"The act of planting again; a replanting.","pos":""}],"REPLEAD":[{"def":"Re*plead\" (r-pld\"), v.","pos":""}],"REPLEADER":[{"def":"A second pleading, or course of pleadings; also, the right of pleading again.","pos":""}],"REPLENISH":[{"def":"To fill again after having been diminished or emptied; to stock anew; hence, to fill completely; to cause to abound.","pos":""},{"def":"To finish; to complete; to perfect.","pos":""}],"REPLENISHER":[{"def":"One who replenishes.","pos":""}],"REPLENISHMENT":[{"def":"The act of replenishing, or the state of being replenished.","pos":""},{"def":"That which replenishes; supply.","pos":""}],"REPLETE":[{"def":"Filled again; completely filled; full; charged; abounding.","pos":""}],"REPLETENESS":[{"def":"The state of being replete.","pos":""}],"REPLETION":[{"def":"Fullness of blood; plethora.","pos":""}],"REPLETIVE":[{"def":"Tending to make replete; filling.","pos":""}],"REPLETORY":[{"def":"Re*ple\"to*ry (-t-r), a.","pos":""}],"REPLEVIABLE":[{"def":"Capable of being replevied.","pos":""}],"REPLEVIN":[{"def":"A personal action which lies to recover possession of goods and chattle wrongfully taken or detained.","pos":""}],"REPLEVISABLE":[{"def":"Re*plev\"i*sa*ble (--s-b'l), a.","pos":""}],"REPLEVY":[{"def":"To take or get back, by a writ for that purpose (goods and chattels wrongfuly taken or detained), upon giving security to try the right to them in a suit at law, and, if that should be determined against the plaintiff, to return the property replevied.","pos":""}],"REPLICA":[{"def":"A copy of a work of art, as of a picture or satue, made by the maker of the original.","pos":""}],"REPLICANT":[{"def":"One who replies.","pos":""}],"REPLICATE":[{"def":"Folded over or backward; folded back upon itself; as, a replicate leaf or petal; a replicate margin of a shell.","pos":""}],"REPLICATION":[{"def":"The reply of the plaintiff, in matters of fact, to the defendant's plea.","pos":""}],"REPLIER":[{"def":"One who replies.","pos":""}],"REPLUM":[{"def":"The framework of some pods, as the cress, which remains after the valves drop off.","pos":""}],"REPLY":[{"def":"To answer a defendant's plea.","pos":""}]}