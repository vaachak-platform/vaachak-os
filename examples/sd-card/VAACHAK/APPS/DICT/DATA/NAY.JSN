{"NAY":[{"def":"No; -- a negative answer to a question asked, or a request made, now superseded by no.","pos":""},{"def":"Not this merely, but also; not only so, but; -- used to mark the addition or substitution of a more explicit or more emphatic phrase.","pos":""}],"NAYAUR":[{"def":"A specied of wild sheep (Ovis Hodgsonii), native of Nepaul and Thibet.","pos":""}],"NAYT":[{"def":"To refuse; to deny.","pos":""}],"NAYWARD":[{"def":"The negative side.","pos":""}],"NAYWORD":[{"def":"A byword; a proverb; also, a watchword.","pos":""}]}