{"RETOLD":[{"def":"Re*told\", Defn: imp.","pos":""}],"RETORSION":[{"def":"Same as Retortion.","pos":""}],"RETORT":[{"def":"To bend or curve back; as, a retorted line.","pos":""},{"def":"To throw back; to reverberate; to reflect.","pos":""}],"RETORTER":[{"def":"One who retorts.","pos":""}],"RETORTION":[{"def":"Act of retorting or throwing back; reflection or turning back.","pos":""}],"RETORTIVE":[{"def":"Containing retort.","pos":""}],"RETOSS":[{"def":"To toss back or again.","pos":""}],"RETOUCH":[{"def":"To correct or change, as a negative, by handwork.","pos":""}],"RETOUCHER":[{"def":"One who retouches.","pos":""}]}