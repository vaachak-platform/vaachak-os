{"AD CAPTANDUM":[{"def":"A phrase used adjectively sometimes of meretricious attempts to catch or win popular favor.","pos":""}],"AD HOMINEM":[{"def":"` phrase applied to an appeal or argument addressed to the principles, interests, or passions of a man.","pos":""}],"AD INFINITUM":[{"def":"Without limit; endlessly.","pos":""}],"AD INTERIM":[{"def":"Meanwhile; temporary.","pos":""}],"AD LIBITUM":[{"def":"Ad lib\"i*tum Defn: .","pos":""}],"AD VALOREM":[{"def":"A term used to denote a duty or charge laid upon goods, at a certain rate per cent upon their value, as stated in their invoice, - - in opposition to a specific sum upon a given quantity or number; as, an ad valorem duty of twenty per cent.","pos":""}],"AD-":[{"def":"As a prefix ad- assumes the forms ac-, af-, ag-, al-, an-, ap-, ar-, as-, at-, assimilating the d with the first letter of the word to which ad- is prefixed.","pos":""}]}