{"TIM-WHISKEY":[{"def":"A kind of carriage.","pos":""}],"TIMAL":[{"def":"The blue titmouse.","pos":""}],"TIMALINE":[{"def":"Of or pertaining to the genus Timalus or family Timalidæ, which includes the babblers thrushes, and bulbuls.","pos":""}],"TIMBALE":[{"def":"A seasoned preparation, as of chicken, lobster, cheese, or fish, cooked in a drum-shaped mold; also, a pastry case, usually small, filled with a cooked mixture.","pos":""}],"TIMBER":[{"def":"A certain quantity of fur skins, as of martens, ermines, sables, etc.","pos":""}],"TIMBERED":[{"def":"Furnished with timber; -- often compounded; as, a well-timbered house; a low-timbered house.","pos":""},{"def":"Built; formed; contrived.","pos":""}],"TIMBERHEAD":[{"def":"The top end of a timber, rising above the gunwale, and serving for belaying ropes, etc.","pos":""}],"TIMBERING":[{"def":"The act of furnishing with timber; also, timbers, collectively; timberwork; timber.","pos":""}],"TIMBERMAN":[{"def":"A man employed in placing supports of timber in a mine.","pos":""}],"TIMBERWORK":[{"def":"Work made of timbers.","pos":""}],"TIMBRE":[{"def":"The crest on a coat of arms.","pos":""},{"def":"The quality or tone distinguishing voices or instruments; tone color; clang tint; as, the timbre of the voice; the timbre of a violin.","pos":""}],"TIMBREL":[{"def":"A kind of drum, tabor, or tabret, in use from the highest antiquity.","pos":""},{"def":"Sung to the sound of the timbrel.","pos":""}],"TIME":[{"def":"The measured duration of sounds; measure; tempo; rate of movement; rhythmical division; as, common or triple time; the musician keeps good time.","pos":""}],"TIME POLICY":[{"def":"A policy limited to become void at a specified time; -- often contrasted with voyage policy.","pos":""}],"TIME SIGNATURE":[{"def":"A sign at the beginning of a composition or movement, placed after the key signature, to indicate its time or meter.","pos":""}],"TIME-HONORED":[{"def":"Honored for a long time; venerable, and worthy of honor, by reason of antiquity, or long continuance.","pos":""}],"TIME-TABLE":[{"def":"A plane surface divided in one direction with lines representing hours and minutes, and in the other with lines representing miles, and having diagonals (usually movable strings) representing the speed and position of various trains.","pos":""},{"def":"A table showing the notation, length, or duration of the several notes.","pos":""}],"TIMEFUL":[{"def":"Seasonable; timely; sufficiently early.","pos":""}],"TIMEKEEPER":[{"def":"A clock, watch, or other chronometer; a timepiece.","pos":""},{"def":"A person who keeps, marks, regulates, or determines the time.","pos":""}],"TIMELESS":[{"def":"Done at an improper time; unseasonable; untimely.","pos":""},{"def":"Done or occurring before the proper time; premature; immature; as, a timeless grave.","pos":""}],"TIMELESSLY":[{"def":"In a timeless manner; unseasonably.","pos":""}],"TIMELINESS":[{"def":"The quality or state of being timely; seasonableness; opportuneness.","pos":""}],"TIMELY":[{"def":"Being or occurring in good time; sufficiently early; seasonable.","pos":""},{"def":"Keeping time or measure.","pos":""}],"TIMENOGUY":[{"def":"A rope carried taut between or over obstacles likely to engage or foul the running rigging in working a ship.","pos":""}],"TIMEOUS":[{"def":"Timely; seasonable.","pos":""}],"TIMEPIECE":[{"def":"A clock, watch, or other instrument, to measure or show the progress of time; a chronometer.","pos":""}],"TIMEPLEASER":[{"def":"One who complies with prevailing opinions, whatever they may be; a timeserver.","pos":""}],"TIMER":[{"def":"A timekeeper; especially, a watch by which small intervals of time can be measured; a kind of stop watch.","pos":""}],"TIMESAVING":[{"def":"Saving time; as, a timesaving expedient.","pos":""}],"TIMESERVER":[{"def":"One who adapts his opinions and manners to the times; one who obsequiously compiles with the ruling power; -- now used only in a bad sense.","pos":""}],"TIMESERVING":[{"def":"Obsequiously complying with the spirit of the times, or the humors of those in power.","pos":""}],"TIMID":[{"def":"Wanting courage to meet danger; easily frightened; timorous; not bold; fearful; shy.","pos":""}],"TIMIDITY":[{"def":"The quality or state of being timid; timorousness; timidness.","pos":""}],"TIMIST":[{"def":"A performer who keeps good time.","pos":""}],"TIMMER":[{"def":"Same as 1st Timber.","pos":""}],"TIMOCRATIC":[{"def":"Belonging to, or constituted by, timocracy.","pos":""}],"TIMOROUS":[{"def":"Fearful of danger; timid; deficient in courage.","pos":""},{"def":"Indicating, or caused by, fear; as, timorous doubts.","pos":""}],"TIMORSOME":[{"def":"Easily frightened; timorous.","pos":""},{"def":"A kind of grass (Phleum pratense) with long cylindrical spikes; -- called also herd's grass, in England, cat's-tail grass, and meadow cat's-tail grass.","pos":""}],"TIMOUS":[{"def":"Timely; seasonable.","pos":""}]}