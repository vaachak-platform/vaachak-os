{"DEPAINT":[{"def":"To paint; to picture; hence, to describe; to delineate in words; to depict.","pos":""},{"def":"To mark with, or as with, color; to color.","pos":""}],"DEPAINTER":[{"def":"One who depaints.","pos":""}],"DEPARDIEUX":[{"def":"In God's name; certainly.","pos":""}],"DEPART":[{"def":"To part; to divide; to separate.","pos":""},{"def":"To go forth or away; to quit, leave, or separate, as from a place or a person; to withdraw; -- opposed to arrive; -- often with from before the place, person, or thing left, and for or to before the destination.","pos":""}],"DEPARTER":[{"def":"One who refines metals by separation.","pos":""},{"def":"One who departs.","pos":""}],"DEPARTMENT":[{"def":"Act of departing; departure.","pos":""},{"def":"A part, portion, or subdivision.","pos":""}],"DEPARTMENT STORE":[{"def":"A store keeping a great variety of goods which are arranged in several departments, esp.","pos":""}],"DEPARTMENTAL":[{"def":"Pertaining to a department or division.","pos":""}],"DEPARTURE":[{"def":"The desertion by a party to any pleading of the ground taken by him in his last antecedent pleading, and the adoption of another.","pos":""},{"def":"The distance due east or west which a person or ship passes over in going along an oblique line.","pos":""}],"DEPASTURE":[{"def":"To pasture; to feed; to graze; also, to use for pasture.","pos":""}],"DEPATRIATE":[{"def":"To withdraw, or cause to withdraw, from one's country; to banish.","pos":""}],"DEPAUPERATE":[{"def":"To make poor; to impoverish.","pos":""}],"DEPAUPERIZE":[{"def":"To free from paupers; to rescue from poverty.","pos":""}]}