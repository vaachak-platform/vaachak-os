{"DAVENPORT":[{"def":"A kind of small writing table, generally somewhat ornamental, and forming a piece of furniture for the parlor or boudoir.","pos":""}],"DAVIDIC":[{"def":"Of or pertaining to David, the king and psalmist of Israel, or to his family.","pos":""}],"DAVIT":[{"def":"Curved arms of timber or iron, projecting over a ship's side of stern, having tackle to raise or lower a boat, swing it in on deck, rig it out for lowering, etc.","pos":""}],"DAVY JONES":[{"def":"The spirit of the sea; sea devil; -- a term used by sailors.","pos":""}],"DAVY LAMP":[{"def":"See Safety lamp, under Lamp.","pos":""}],"DAVYNE":[{"def":"A variety of nephelite from Vesuvius.","pos":""}],"DAVYUM":[{"def":"A rare metallic element found in platinum ore.","pos":""}]}