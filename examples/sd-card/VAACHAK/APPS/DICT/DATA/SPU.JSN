{"SPUD":[{"def":"A sharp, narrow spade, usually with a long handle, used by farmers for digging up large-rooted weeds; a similarly shaped implement used for various purposes.","pos":""}],"SPULLER":[{"def":"One employed to inspect yarn, to see that it is well spun, and fit for the loom.","pos":""}],"SPULZIE":[{"def":"Plunder, or booty.","pos":""}],"SPUME":[{"def":"Frothy matter raised on liquids by boiling, effervescence, or agitation; froth; foam; scum.","pos":""}],"SPUMESCENCE":[{"def":"The state of being foamy; frothiness.","pos":""}],"SPUMESCENT":[{"def":"Resembling froth or foam; foaming.","pos":""}],"SPUMID":[{"def":"Spumous; frothy.","pos":""}],"SPUMINESS":[{"def":"The quality or condition of being spumy; spumescence.","pos":""},{"def":"Consisting of, containing, or covered with, froth, scum, or foam; frothy; foamy.","pos":""}],"SPUNK":[{"def":"Wood that readily takes fire; touchwood; also, a kind of tinder made from a species of fungus; punk; amadou.","pos":""},{"def":"An inflammable temper; spirit; mettle; pluck; as, a man of spunk.","pos":""}],"SPUNKY":[{"def":"Full of spunk; quick; spirited.","pos":""}],"SPUR":[{"def":"Any stiff, sharp spine, as on the wings and legs of certain burds, on the legs of insects, etc.","pos":""},{"def":"A brace strengthening a post and some connected part, as a rafter or crossbeam; a strut.","pos":""}],"SPUR-ROYAL":[{"def":"A gold coin, first made in the reign of Edward IV.","pos":""}],"SPUR-SHELL":[{"def":"Any one of several species of handsome gastropod shells of the genus Trochus, or Imperator.","pos":""}],"SPUR-WINGED":[{"def":"Having one or more spurs on the bend of the wings.","pos":""}],"SPURGALL":[{"def":"A place galled or excoriated by much using of the spur.","pos":""}],"SPURGE":[{"def":"To emit foam; to froth; -- said of the emission of yeast from beer in course of fermentation.","pos":""}],"SPURGEWORT":[{"def":"Any euphorbiaceous plant.","pos":""}],"SPURIOUS":[{"def":"Not proceeding from the true source, or from the source pretended; not genuine; false; adulterate.","pos":""},{"def":"Not legitimate; bastard; as, spurious issue.","pos":""}],"SPURLESS":[{"def":"Having no spurs.","pos":""}],"SPURLING-LINE":[{"def":"The line which forms the communication between the steering wheel and the telltale.","pos":""}],"SPURN":[{"def":"To drive back or away, as with the foot; to kick.","pos":""},{"def":"To reject with disdain; to scorn to receive or accept; to treat with contempt.","pos":""}],"SPURN-WATER":[{"def":"A channel at the end of a deck to restrain the water.","pos":""}],"SPURRED":[{"def":"Wearing spurs; furnished with a spur or spurs; having shoots like spurs.","pos":""},{"def":"Affected with spur, or ergot; as, spurred rye.","pos":""}],"SPURRIER":[{"def":"One whose occupation is to make spurs.","pos":""}],"SPURRY":[{"def":"An annual herb (Spergula arvensis) with whorled filiform leaves, sometimes grown in Europe for fodder.","pos":""}],"SPURT":[{"def":"To gush or issue suddenly or violently out in a stream, as liquor from a cask; to rush from a confined place in a small stream or jet; to spirt.","pos":""}],"SPURTLE":[{"def":"To spurt or shoot in a scattering manner.","pos":""}],"SPUT":[{"def":"An annular reënforce, to strengthen a place where a hole is made.","pos":""}],"SPUTATION":[{"def":"The act of spitting; expectoration.","pos":""}],"SPUTATIVE":[{"def":"Inclined to spit; spitting much.","pos":""}],"SPUTE":[{"def":"To dispute; to discuss.","pos":""}],"SPUTTER":[{"def":"To spit, or to emit saliva from the mouth in small, scattered portions, as in rapid speaking.","pos":""},{"def":"To utter words hastily and indistinctly; to speak so rapidly as to emit saliva.","pos":""}],"SPUTTERER":[{"def":"One who sputters.","pos":""}],"SPUTUM":[{"def":"That which is expectorated; a salival discharge; spittle; saliva.","pos":""}]}