{"ACE":[{"def":"A unit; a single point or spot on a card or die; the card or die so marked; as, the ace of diamonds.","pos":""},{"def":"Hence: A very small quantity or degree; a particle; an atom; a jot.","pos":""}],"ACELDAMA":[{"def":"The potter's field, said to have lain south of Jerusalem, purchased with the bribe which Judas took for betraying his Master, and therefore called the field of blood.","pos":""}],"ACENTRIC":[{"def":"Not centered; without a center.","pos":""}],"ACEPHAL":[{"def":"One of the Acephala.","pos":""}],"ACEPHALA":[{"def":"That division of the Mollusca which includes the bivalve shells, like the clams and oysters; -- so called because they have no evident head.","pos":""}],"ACEPHALAN":[{"def":"Same as Acephal.","pos":""}],"ACEPHALI":[{"def":"A fabulous people reported by ancient writers to have heads.","pos":""},{"def":"A class of levelers in the time of K.","pos":""}],"ACEPHALIST":[{"def":"One who acknowledges no head or superior.","pos":""}],"ACEPHALOCYST":[{"def":"A larval entozoön in the form of a subglobular or oval vesicle, or hy datid, filled with fluid, sometimes found in the tissues of man and the lower animals; -- so called from the absence of a head or visible organs on the vesicle.","pos":""}],"ACEPHALOCYSTIC":[{"def":"Pertaining to, or resembling, the acephalocysts.","pos":""}],"ACEPHALOUS":[{"def":"Without a distinct head; -- a term applied to bivalve mollusks.","pos":""},{"def":"Having the style spring from the base, instead of from the apex, as is the case in certain ovaries.","pos":""}],"ACEQUIA":[{"def":"A canal or trench for irrigating land.","pos":""}],"ACERATE":[{"def":"A combination of aceric acid with a salifiable base.","pos":""}],"ACERB":[{"def":"Sour, bitter, and harsh to the taste, as unripe fruit; sharp and harsh.","pos":""}],"ACERBATE":[{"def":"To sour; to imbitter; to irritate.","pos":""}],"ACERBITUDE":[{"def":"Sourness and harshness.","pos":""}],"ACERBITY":[{"def":"Sourness of taste, with bitterness and astringency, like that of unripe fruit.","pos":""},{"def":"Harshness, bitterness, or severity; as, acerbity of temper, of language, of pain.","pos":""}],"ACERIC":[{"def":"Pertaining to, or obtained from, the maple; as, aceric acid.","pos":""}],"ACEROUS":[{"def":"Same as Acerose.","pos":""}],"ACERVAL":[{"def":"Pertaining to a heap.","pos":""}],"ACERVATE":[{"def":"Heaped, or growing in heaps, or closely compacted clusters.","pos":""}],"ACERVATION":[{"def":"A heaping up; accumulation.","pos":""}],"ACERVATIVE":[{"def":"Heaped up; tending to heap up.","pos":""}],"ACERVULINE":[{"def":"Resembling little heaps.","pos":""},{"def":"The quality of being acescent; the process of acetous fermentation; a moderate degree of sourness.","pos":""}],"ACESCENT":[{"def":"Turning sour; readily becoming tart or acid; slightly sour.","pos":""}],"ACETABLE":[{"def":"An acetabulum; or about one eighth of a pint.","pos":""}],"ACETABULAR":[{"def":"Cup-shaped; saucer-shaped; acetabuliform.","pos":""}],"ACETABULIFERA":[{"def":"The division of Cephalopoda in which the arms are furnished with cup-shaped suckers, as the cuttlefishes, squids, and octopus; the Dibranchiata.","pos":""}],"ACETABULIFEROUS":[{"def":"Furnished with fleshy cups for adhering to bodies, as cuttlefish, etc.","pos":""}],"ACETABULIFORM":[{"def":"Shaped like a shallow; saucer-shaped; as, an acetabuliform calyx.","pos":""}],"ACETABULUM":[{"def":"A vinegar cup; socket of the hip bone; a measure of about one eighth of a pint, etc.","pos":""}],"ACETAL":[{"def":"A limpid, colorless, inflammable liquid from the slow oxidation of alcohol under the influence of platinum black.","pos":""}],"ACETALDEHYDE":[{"def":"Acetic aldehyde.","pos":""}],"ACETAMIDE":[{"def":"A white crystalline solid, from ammonia by replacement of an equivalent of hydrogen by acetyl.","pos":""}],"ACETANILIDE":[{"def":"A compound of aniline with acetyl, used to allay fever or pain; -- called also antifebrine.","pos":""}],"ACETARIOUS":[{"def":"Used in salads; as, acetarious plants.","pos":""}],"ACETARY":[{"def":"An acid pulp in certain fruits, as the pear.","pos":""}],"ACETATE":[{"def":"A salt formed by the union of acetic acid with a base or positive radical; as, acetate of lead, acetate of potash.","pos":""}],"ACETATED":[{"def":"Combined with acetic acid.","pos":""}],"ACETIFICATION":[{"def":"The act of making acetous or sour; the process of converting, or of becoming converted, into vinegar.","pos":""}],"ACETIFIER":[{"def":"An apparatus for hastening acetification.","pos":""}],"ACETIFY":[{"def":"To convert into acid or vinegar.","pos":""}],"ACETIMETER":[{"def":"An instrument for estimating the amount of acetic acid in vinegar or in any liquid containing acetic acid.","pos":""}],"ACETIMETRY":[{"def":"The act or method of ascertaining the strength of vinegar, or the proportion of acetic acid contained in it.","pos":""}],"ACETIN":[{"def":"A combination of acetic acid with glycerin.","pos":""}],"ACETOL":[{"def":"Methyl ketol; also, any of various homologues of the same.","pos":""}],"ACETOMETER":[{"def":"Same as Acetimeter.","pos":""},{"def":"A morbid condition characterized by the presence of acetone in the blood, as in diabetes.","pos":""}],"ACETONE":[{"def":"A volatile liquid consisting of three parts of carbon, six of hydrogen, and one of oxygen; pyroacetic spirit, -- obtained by the distillation of certain acetates, or by the destructive distillation of citric acid, starch, sugar, or gum, with quicklime.","pos":""}],"ACETONIC":[{"def":"Of or pertaining to acetone; as, acetonic bodies.","pos":""}],"ACETONURIA":[{"def":"Excess of acetone in the urine, as in starvation or diabetes.","pos":""}],"ACETOPHENONE":[{"def":"A crystalline ketone, CH3COC6H5, which may be obtained by the dry distillation of a mixture of the calcium salts of acetic and benzoic acids.","pos":""}],"ACETOSE":[{"def":"Sour like vinegar; acetous.","pos":""}],"ACETOSITY":[{"def":"The quality of being acetous; sourness.","pos":""}],"ACETOUS":[{"def":"Having a sour taste; sour; acid.","pos":""},{"def":"Causing, or connected with, acetification; as, acetous fermentation.","pos":""}],"ACETYL":[{"def":"A complex, hypothetical radical, composed of two parts of carbon to three of hydrogen and one of oxygen.","pos":""}],"ACETYLENE":[{"def":"A gaseous compound of carbon and hydrogen, in the proportion of two atoms of the former to two of the latter.","pos":""},{"def":"A name given to several species of plants; as, smallage, wild celery, parsley.","pos":""}]}