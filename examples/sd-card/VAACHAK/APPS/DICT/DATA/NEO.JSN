{"NEO-CHRISTIANITY":[{"def":"Ne`o-Chris*tian\"i*ty ( or ), n.","pos":""}],"NEO-DARWINISM":[{"def":"The theory which holds natural selection, as explained by Darwin, to be the chief factor in the evolution of plants and animals, and denies the inheritance of acquired characters; -- esp.","pos":""}],"NEO-GREEK":[{"def":"A member of a body of French painters (F.","pos":""}],"NEO-HEBRAIC":[{"def":"The modern Hebrew language.","pos":""}],"NEO-HEGELIAN":[{"def":"An adherent of Neo-Hegelianism.","pos":""}],"NEO-HEGELIANISM":[{"def":"The philosophy of a school of British and American idealists who follow Hegel in dialectical or logical method and in the general outcome of their doctrine.","pos":""}],"NEO-HELLENISM":[{"def":"Hellenism as surviving or revival in modern times; the practice or pursuit of ancient Greek ideals in modern life, art, or literature, as in the Renaissance.","pos":""},{"def":"A theory or practice which is a further development, on more rigorously scientific lines, of the theory and practice of Impressionism, originated by George Seurat (1859-91), and carried on by Paul Signac (1863- -) and others.","pos":""}],"NEO-KANTIAN":[{"def":"An adherent of Neo-Kantianism.","pos":""}],"NEO-KANTIANISM":[{"def":"The philosophy of modern thinkers who follow Kant in his general theory of knowledge, esp.","pos":""}],"NEO-LAMARCKISM":[{"def":"Lamarckism as revived, modified, and expounded by recent biologists, esp.","pos":""}],"NEO-LATIN":[{"def":"Applied to the Romance languages, as being mostly of Latin origin.","pos":""}],"NEO-MALTHUSIAN":[{"def":"Designating, or pertaining to, a group of modern economists who hold to the Malthusianism doctrine that permanent betterment of the general standard of living is impossible without decrease of competition by limitation of the number of births.","pos":""}],"NEO-SCHOLASTICISM":[{"def":"The modern revival of the Scholastic philosophy, esp.","pos":""}],"NEOCARIDA":[{"def":"The modern, or true, Crustacea, as distinguished from the Merostomata.","pos":""}],"NEOCENE":[{"def":"More recent than the Eocene, that is, including both the Miocene and Pliocene divisions of the Tertiary.","pos":""}],"NEOCLASSIC":[{"def":"Belonging to, or designating, the modern revival of classical, esp.","pos":""}],"NEOCLASSIC ARCHITECTURE":[{"def":"All that architecture which, since the beginning of the Italian Renaissance, about 1420, has been designed with deliberate imitation of Greco-Roman buildings.","pos":""}],"NEOCOMIAN":[{"def":"A term applied to the lowest deposits of the Cretaceous or chalk formation of Europe, being the lower greensand.","pos":""}],"NEOCOSMIC":[{"def":"of or pertaining to the universe in its present state; specifically, pertaining to the races of men known to history.","pos":""}],"NEOCRACY":[{"def":"Government by new or inexperienced hands; upstart rule; raw or untried officials.","pos":""}],"NEOCRITICISM":[{"def":"The form of Neo-Kantianism developed by French idealists, following C.","pos":""}],"NEODAMODE":[{"def":"In ancient Sparta, one of those Helots who were freed by the state in reward for military service.","pos":""}],"NEODYMIUM":[{"def":"An elementary substance which forms one of the constituents of didymium.","pos":""}],"NEOGAEAN":[{"def":"Of or pertaining to the New World, or Western Hemisphere.","pos":""}],"NEOGAMIST":[{"def":"A person recently married.","pos":""}],"NEOGEN":[{"def":"An alloy resembling silver, and consisting chiefly of copper, zinc, and nickel, with small proportions of tin, aluminium, and bismuth.","pos":""}],"NEOGRAMMARIAN":[{"def":"One of a group of philologists who apply phonetic laws more widely and strictly than was formerly done, and who maintain that these laws admit of no real exceptions.","pos":""}],"NEOGRAPHY":[{"def":"A new method or system of writing.","pos":""}],"NEOLITHIC":[{"def":"Of or pertaining to, or designating, an era characterized by late remains in stone.","pos":""}],"NEOLOGIAN":[{"def":"Neologic; neological.","pos":""}],"NEOLOGIANISM":[{"def":"Of or pertaining to neology; employing new words; of the nature of, or containing, new words or new doctrines.","pos":""}],"NEOLOGICALLY":[{"def":"Ne`o*log\"ic*al*ly Defn: , adv.","pos":""}],"NEOLOGISM":[{"def":"The introduction of new words, or the use of old words in a new sense.","pos":""},{"def":"A new word, phrase, or expression.","pos":""}],"NEOLOGIST":[{"def":"of or pertaining to neology; neological.","pos":""}],"NEOLOGIZATION":[{"def":"The act or process of neologizing.","pos":""}],"NEOLOGIZE":[{"def":"To introduce or use new words or terms or new uses of old words.","pos":""},{"def":"To introduce innovations in doctrine, esp.","pos":""}],"NEOLOGY":[{"def":"The introduction of a new word, or of words or significations, into a language; as, the present nomenclature of chemistry is a remarkable instance of neology.","pos":""},{"def":"A new doctrine; esp.","pos":""}],"NEOMENIA":[{"def":"The time of the new moon; the beginning of the month in the lunar calendar.","pos":""}],"NEOMENOIDEA":[{"def":"A division of vermiform gastropod mollusks, without a shell, belonging to the Isopleura.","pos":""}],"NEOMORPH":[{"def":"A structure, part, or organ developed independently, that is, not derived from a similar structure, part, or organ, in a pre existing form.","pos":""}],"NEONOMIAN":[{"def":"One who advocates adheres to new laws; esp.","pos":""}],"NEONOMIANISM":[{"def":"The doctrines or belief of the neonomians.","pos":""}],"NEOPAGANISM":[{"def":"Revived or new paganism.","pos":""}],"NEOPHYTE":[{"def":"A new convert or proselyte; -- a name given by the early Christians, and still given by the Roman Catholics, to such as have recently embraced the Christian faith, and been admitted to baptism, esp.","pos":""},{"def":"A novice; a tyro; a beginner in anything.","pos":""}],"NEOPLASIA":[{"def":"Growth or development of new material; neoplasty.","pos":""}],"NEOPLASM":[{"def":"A new formation or tissue, the product of morbid action.","pos":""}],"NEOPLASTIC":[{"def":"of or pertaining to neoplasty, or neoplasia.","pos":""}],"NEOPLASTY":[{"def":"Restoration of a part by granulation, adhesive inflammation, or autoplasty.","pos":""}],"NEOPLATONIC":[{"def":"Of, pertaining to, or resembling, Neoplatonism or the Neoplatonists.","pos":""}],"NEOPLATONICIAN":[{"def":"Ne`o*pla`to*ni\"cian, n.","pos":""}],"NEOPLATONISM":[{"def":"A pantheistic eclectic school of philosophy, of which Plotinus was the chief (A.","pos":""}],"NEOPLATONIST":[{"def":"One who held to Neoplatonism; a member of the Neoplatonic school.","pos":""}],"NEORAMA":[{"def":"A panorama of the interior of a building, seen from within.","pos":""}],"NEOSSINE":[{"def":"The substance constituting the edible bird's nest.","pos":""}],"NEOSSOLOGY":[{"def":"The study of young birds.","pos":""},{"def":"Recent in origin; modern; new.","pos":""}],"NEOTERIC":[{"def":"One of modern times; a modern.","pos":""}],"NEOTERICALLY":[{"def":"Recently; newly.","pos":""}],"NEOTERISM":[{"def":"An innovation or novelty; a neoteric word or phrase.","pos":""}],"NEOTERIST":[{"def":"One ho introduces new word Fitzed Hall.","pos":""}],"NEOTERIZE":[{"def":"To innovate; to coin or introduce new words.","pos":""}],"NEOTROPICAL":[{"def":"Belonging to, or designating, a region of the earth's surface which comprises most of South America, the Antilles, and tropical North America.","pos":""}],"NEOZOIC":[{"def":"More recent than the Paleozoic, -- that is, including the Mesozoic and Cenozoic.","pos":""}]}