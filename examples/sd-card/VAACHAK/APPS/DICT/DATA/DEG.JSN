{"DEGAGE":[{"def":"Unconstrained; easy; free.","pos":""}],"DEGARNISH":[{"def":"To strip or deprive of entirely, as of furniture, ornaments, etc.","pos":""},{"def":"To deprive of a garrison, or of troops necessary for defense; as, to degarnish a city or fort.","pos":""}],"DEGARNISHMENT":[{"def":"The act of depriving, as of furniture, apparatus, or a garrison.","pos":""}],"DEGENERACY":[{"def":"The act of becoming degenerate; a growing worse.","pos":""},{"def":"The state of having become degenerate; decline in good qualities; deterioration; meanness.","pos":""}],"DEGENERATE":[{"def":"Having become worse than one's kind, or one's former state; having declined in worth; having lost in goodness; deteriorated; degraded; unworthy; base; low.","pos":""}],"DEGENERATELY":[{"def":"In a degenerate manner; unworthily.","pos":""}],"DEGENERATENESS":[{"def":"De*gen\"er*ate*ness, n.","pos":""}],"DEGENERATION":[{"def":"That condition of a tissue or an organ in which its vitality has become either diminished or perverted; a substitution of a lower for a higher form of structure; as, fatty degeneration of the liver.","pos":""},{"def":"A gradual deterioration, from natural causes, of any class of animals or plants or any particular or organs; hereditary degradation of type.","pos":""}],"DEGENERATIONIST":[{"def":"A believer in the theory of degeneration, or hereditary degradation of type; as, the degenerationists hold that savagery is the result of degeneration from a superior state.","pos":""}],"DEGENERATIVE":[{"def":"Undergoing or producing degeneration; tending to degenerate.","pos":""}],"DEGENEROUS":[{"def":"Degenerate; base.","pos":""}],"DEGENEROUSLY":[{"def":"De*gen\"er*ous*ly, adv.","pos":""}],"DEGERM":[{"def":"To extract the germs from, as from wheat grains.","pos":""}],"DEGERMINATOR":[{"def":"A machine for breaking open the kernels of wheat or other grain and removing the germs.","pos":""}],"DEGLAZE":[{"def":"To remove the glaze from, as pottery or porcelain, so as to give a dull finish.","pos":""}],"DEGLAZING":[{"def":"The process of giving a dull or ground surface to glass by acid or by mechanical means.","pos":""}],"DEGLORIED":[{"def":"Deprived of glory; dishonored.","pos":""}],"DEGLUTINATE":[{"def":"To loosen or separate by dissolving the glue which unties; to unglue.","pos":""}],"DEGLUTINATION":[{"def":"The act of ungluing.","pos":""}],"DEGLUTITION":[{"def":"The act or process of swallowing food; the power of swallowing.","pos":""}],"DEGLUTITIOUS":[{"def":"Pertaining to deglutition.","pos":""}],"DEGLUTITORY":[{"def":"Serving for, or aiding in, deglutition.","pos":""}],"DEGRADATION":[{"def":"A gradual wearing down or wasting, as of rocks and banks, by the action of water, fro 5.","pos":""},{"def":"The state or condition of a species or group which exhibits degraded forms; degeneration.","pos":""}],"DEGRADE":[{"def":"To reduce in altitude or magnitude, as hills and mountains; to wear down.","pos":""}],"DEGRADED":[{"def":"Having the typical characters or organs in a partially developed condition, or lacking certain parts.","pos":""},{"def":"Having steps; -- said of a cross each of whose extremities finishes in steps growing larger as they leave the center; -- termed also on degrees.","pos":""}],"DEGRADEMENT":[{"def":"Deprivation of rank or office; degradation.","pos":""}],"DEGRADINGLY":[{"def":"In a degrading manner.","pos":""},{"def":"A semisolid emulsion produced by the treatment of certain skins with oxidized fish oil, which extracts their soluble albuminoids.","pos":""}],"DEGRAVATION":[{"def":"The act of making heavy.","pos":""}],"DEGREASE":[{"def":"To remove grease or fatty matter from, as wool or silk.","pos":""}],"DEGREE":[{"def":"A certain distance or remove in the line of descent, determining the proximity of blood; one remove in the chain of relationship; as, a relation in the third or fourth degree.","pos":""},{"def":"Three figures taken together in numeration; thus, 140 is one degree, 222,140 two degrees.","pos":""}],"DEGU":[{"def":"A small South American rodent (Octodon Cumingii), of the family Octodontidæ.","pos":""}],"DEGUM":[{"def":"To deprive of, or free from, gum; as, to degum ramie.","pos":""}],"DEGUSTATION":[{"def":"Tasting; the appreciation of sapid qualities by the taste organs.","pos":""}]}