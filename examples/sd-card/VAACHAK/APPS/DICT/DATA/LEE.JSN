{"LEE":[{"def":", i, To lie; to speak falsely.","pos":""}],"LEEBOARD":[{"def":"A board, or frame of planks, lowered over the side of a vessel to lessen her leeway when closehauled, by giving her greater draught.","pos":""}],"LEECH":[{"def":"The border or edge at the side of a sail.","pos":""}],"LEECHCRAFT":[{"def":"The art of healing; skill of a physician.","pos":""},{"def":"A caldron; a copper kettle.","pos":""}],"LEEK":[{"def":"A plant of the genus Allium (A.","pos":""}],"LEER":[{"def":"Empty; destitute; wanting; as: (a) Empty of contents.","pos":""}],"LEERE":[{"def":"Tape or braid; an ornament.","pos":""}],"LEERINGLY":[{"def":"In a leering manner.","pos":""}],"LEESE":[{"def":"They would rather leese their friend than their jest.","pos":""}],"LEET":[{"def":"of Let, to allow.","pos":""}],"LEETMAN":[{"def":"One subject to the jurisdiction of a court-leet.","pos":""}],"LEEWARD":[{"def":"Pertaining to, or in the direction of, the part or side toward which the wind blows; -- opposed to windward; as, a leeward berth; a leeward ship.","pos":""},{"def":"The lee side; the lee.","pos":""}],"LEEWAY":[{"def":"The lateral movement of a ship to the leeward of her course; drift.","pos":""}]}