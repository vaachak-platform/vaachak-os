{"ENJAIL":[{"def":"To put into jail; to imprison.","pos":""}],"ENJOIN":[{"def":"To prohibit or restrain by a judicial order or decree; to put an injunction on.","pos":""}],"ENJOINER":[{"def":"One who enjoins.","pos":""}],"ENJOINMENT":[{"def":"Direction; command; authoritative admonition.","pos":""}],"ENJOY":[{"def":"To take pleasure or satisfaction in the possession or experience of; to feel or perceive with pleasure; to be delighted with; as, to enjoy the dainties of a feast; to enjoy conversation.","pos":""},{"def":"To have, possess, and use with satisfaction; to occupy or have the benefit of, as a good or profitable thing, or as something desirable; as, to enjoy a free constitution and religious liberty.","pos":""}],"ENJOYABLE":[{"def":"Capable of being enjoyed or of giving joy; yielding enjoyment.","pos":""}],"ENJOYMENT":[{"def":"The condition of enjoying anything; pleasure or satisfaction, as in the possession or occupancy of anything; possession and use; as, the enjoyment of an estate.","pos":""},{"def":"That which gives pleasure or keen satisfaction.","pos":""}]}