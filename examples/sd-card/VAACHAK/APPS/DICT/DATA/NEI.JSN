{"NEIGH":[{"def":"To utter the cry of the horse; to whinny.","pos":""},{"def":"To scoff or sneer; to jeer.","pos":""}],"NEIGHBOR":[{"def":"A person who lives near another; one whose abode is not far off.","pos":""},{"def":"One who is near in sympathy or confidence.","pos":""}],"NEIGHBORHOOD":[{"def":"The quality or condition of being a neighbor; the state of being or dwelling near; proximity.","pos":""},{"def":"A place near; vicinity; adjoining district; a region the inhabitants of which may be counted as neighbors; as, he lives in my neighborhood.","pos":""}],"NEIGHBORING":[{"def":"Living or being near; adjacent; as, the neighboring nations or countries.","pos":""}],"NEIGHBORLINESS":[{"def":"The quality or state of being neighborly.","pos":""}],"NEIGHBORLY":[{"def":"Apropriate to the relation of neighbors; having frequent or familiar intercourse; kind; civil; social; friendly.","pos":""},{"def":"In a neigborly manner.","pos":""}],"NEIGHBORSHIP":[{"def":"The state of being neighbors.","pos":""}],"NEISHOUT":[{"def":"The mahogany-like wood of the South African tree Pteroxylon utile, the sawdust of which causes violent sneezing (whence the name).","pos":""}],"NEITHER":[{"def":"Not either; not the one or the other.","pos":""}]}