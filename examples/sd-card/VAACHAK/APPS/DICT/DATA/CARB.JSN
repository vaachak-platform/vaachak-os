{"CARBAMIC":[{"def":"Pertaining to an acid so called.","pos":""}],"CARBAMIDE":[{"def":"The technical name for urea.","pos":""}],"CARBAMINE":[{"def":"An isocyanide of a hydrocarbon radical.","pos":""}],"CARBANIL":[{"def":"A mobile liquid, CO.","pos":"noun"}],"CARBAZOL":[{"def":"A white crystallized substance, C12H8NH, derived from aniline and other amines.","pos":""}],"CARBAZOTATE":[{"def":"A salt of carbazotic or picric acid; a picrate.","pos":""}],"CARBAZOTIC":[{"def":"Containing, or derived from, carbon and nitrogen.","pos":""}],"CARBIDE":[{"def":"A binary compound of carbon with some other element or radical, in which the carbon plays the part of a negative; -- formerly termed carburet.","pos":""}],"CARBIMIDE":[{"def":"The technical name for isocyanic acid.","pos":""}],"CARBINE":[{"def":"A short, light musket or rifle, esp.","pos":""}],"CARBINEER":[{"def":"A soldier armed with a carbine.","pos":""}],"CARBINOL":[{"def":"Methyl alcohol, CH3OH; -- also, by extension, any one in the homologous series of paraffine alcohols of which methyl alcohol is the type.","pos":""}],"CARBOHYDRATE":[{"def":"One of a group of compounds including the sugars, starches, and gums, which contain six (or some multiple of six) carbon atoms, united with a variable number of hydrogen and oxygen atoms, but with the two latter always in proportion as to form water; as dextrose, C6H12O6.","pos":""}],"CARBOLIC":[{"def":"Pertaining to, or designating, an acid derived from coal tar and other sources; as, carbolic acid (called also phenic acid, and phenol).","pos":""}],"CARBOLIZE":[{"def":"To apply carbonic acid to; to wash or treat with carbolic acid.","pos":""}],"CARBON":[{"def":"An elementary substance, not metallic in its nature, which is present in all organic compounds.","pos":""}],"CARBON PROCESS":[{"def":"A printing process depending on the effect of light on bichromatized gelatin.","pos":""}],"CARBON STEEL":[{"def":"Steel deriving its qualities from carbon chiefly, without the presence of other alloying elements; --opposed to alloy steel.","pos":""}],"CARBON TRANSMITTER":[{"def":"A telephone transmitter in which a carbon contact is used.","pos":""}],"CARBONACEOUS":[{"def":"Pertaining to, containing, or composed of, carbon.","pos":""},{"def":"Flesh, fowl, etc.","pos":""}],"CARBONADO":[{"def":"A black variety of diamond, found in Brazil, and used for diamond drills.","pos":""}],"CARBONARISM":[{"def":"The principles, practices, or organization of the Carbonari.","pos":""}],"CARBONARO":[{"def":"A member of a secret political association in Italy, organized in the early part of the nineteenth centry for the purpose of changing the government into a republic.","pos":""}],"CARBONATATION":[{"def":"The saturation of defecated beet juice with carbonic acid gas.","pos":""}],"CARBONATE":[{"def":"A salt or carbonic acid, as in limestone, some forms of lead ore, etc.","pos":""}],"CARBONATED":[{"def":"Combined or impregnated with carbonic acid.","pos":""}],"CARBONIC":[{"def":"Of, pertaining to, or obtained from, carbon; as, carbonic oxide.","pos":""}],"CARBONIFEROUS":[{"def":"Producing or containing carbon or coal.","pos":""}],"CARBONITE":[{"def":"An explosive consisting essentially of nitroglycerin, wood meal, and some nitrate, as that of sodium.","pos":""}],"CARBONIZATION":[{"def":"The act or process of carbonizing.","pos":""}],"CARBONIZE":[{"def":"To cover (an animal or vegatable substance) into a residue of carbon by the action of fire or some corrosive agent; to char.","pos":""},{"def":"To impregnate or combine with carbon, as in making steel by cementation.","pos":""}],"CARBONOMETER":[{"def":"An instrument for detecting and measuring the amount of carbon which is present, or more esp.","pos":""}],"CARBONYL":[{"def":"The radical (CO)'\\'b7, occuring, always combined, in many compounds, as the aldehydes, the ketones, urea, carbonyl chloride, etc.","pos":""}],"CARBORUNDUM":[{"def":"A beautiful crystalline compound, SiC, consisting of carbon and silicon in combination; carbon silicide.","pos":""},{"def":"Cloth or paper covered with powdered carborundum.","pos":""}],"CARBOSTYRIL":[{"def":"A white crystalline substance, C9H6N.","pos":""}],"CARBOXIDE":[{"def":"A compound of carbon and oxygen, as carbonyl, with some element or radical; as, potassium carboxide.","pos":""}],"CARBOXYL":[{"def":"The complex radical, CO.","pos":""}],"CARBOY":[{"def":"A large, globular glass bottle, esp.","pos":""}],"CARBUNCLE":[{"def":"A beautiful gem of a deep red color (with a mixture of scarlet) called by the Greeks anthrax; found in the East Indies.","pos":""},{"def":"A very painful acute local inflammation of the subcutaneous tissue, esp.","pos":""}],"CARBUNCLED":[{"def":"Set with carbuncles.","pos":""},{"def":"Affected with a carbuncle or carbuncles; marked with red sores; pimpled and blotched.","pos":""}],"CARBUNCULAR":[{"def":"Belonging to a carbuncle; resembling a carbuncle; red; inflamed.","pos":""}],"CARBUNCULATION":[{"def":"The blasting of the young buds of trees or plants, by excessive heat or caold.","pos":""}],"CARBURET":[{"def":"To combine or to impregnate with carbon, as by passing through or over a liquid hydrocarbon; to carbonize or carburize.","pos":""}],"CARBURETANT":[{"def":"Any volatile liquid used in charging illuminating gases.","pos":""}],"CARBURETED":[{"def":"Combined with carbon in the manner of a carburet or carbide.","pos":""}],"CARBURETOR":[{"def":"An apparatus in which coal gas, hydrogen, or air is passed through or over a volatile hydrocarbon, in order to confer or increase illuminating power.","pos":""},{"def":"One that carburets; specif.","pos":""}],"CARBURIZATION":[{"def":"The act, process, or result of carburizing.","pos":""}],"CARBURIZE":[{"def":"To combine wtih carbon or a carbon compound; -- said esp.","pos":""}]}