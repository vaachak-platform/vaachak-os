{"COKE":[{"def":"Mineral coal charred, or depriver of its bitumen, sulphur, or other volatile matter by roasting in a kiln or oven, or by distillation, as in gas works.","pos":""}],"COKERNUT":[{"def":"Note: A mode of spelling introduced by the London customhouse to distinguish more widely between this and other articles spelt much in the same manner.","pos":""}],"COKES":[{"def":"A simpleton; a gull; a dupe.","pos":""}],"COKEWOLD":[{"def":"- (with, together.","pos":""}]}