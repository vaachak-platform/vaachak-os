{"RECHABITE":[{"def":"One of the descendants of Jonadab, the son of Rechab, all of whom by his injunction abstained from the use of intoxicating drinks and even from planting the vine.","pos":""}],"RECHANGE":[{"def":"To change again, or change back.","pos":""}],"RECHARGE":[{"def":"To charge or accuse in return.","pos":""},{"def":"To attack again; to attack anew.","pos":""}],"RECHARTER":[{"def":"A second charter; a renewal of a charter.","pos":""}],"RECHASE":[{"def":"To chase again; to chase or drive back.","pos":""}],"RECHAUFFE":[{"def":"A dish of food that has been warmed again, hence, fig.","pos":""}],"RECHEAT":[{"def":"A strain given on the horn to call back the hounds when they have lost track of the game.","pos":""}],"RECHERCHE":[{"def":"Sought out with care; choice.","pos":""}],"RECHOOSE":[{"def":"To choose again.","pos":""}]}