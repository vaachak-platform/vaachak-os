{"ELBOW":[{"def":"A sharp angle in any surface of wainscoting or other woodwork; the upright sides which flank any paneled work, as the sides of windows, where the jamb makes an elbow with the window back.","pos":""}],"ELBOWBOARD":[{"def":"The base of a window casing, on which the elbows may rest.","pos":""}],"ELBOWCHAIR":[{"def":"A chair with arms to support the elbows; an armchair.","pos":""}],"ELBOWROOM":[{"def":"Room to extend the elbows on each side; ample room for motion or action; free scope.","pos":""}]}