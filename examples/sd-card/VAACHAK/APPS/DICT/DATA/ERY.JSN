{"ERYNGIUM":[{"def":"A genus of umbelliferous plants somewhat like thistles in appearance.","pos":""}],"ERYNGO":[{"def":"A plant of the genus Eryngium.","pos":""}],"ERYSIPELATOID":[{"def":"Resembling erysipelas.","pos":""}],"ERYSIPELATOUS":[{"def":"Resembling erysipelas, or partaking of its nature.","pos":""}],"ERYTHEMA":[{"def":"A disease of the skin, in which a diffused inflammation forms rose-colored patches of variable size.","pos":""}],"ERYTHEMATIC":[{"def":"Characterized by, or causing, a morbid redness of the skin; relating to erythema.","pos":""}],"ERYTHEMATOUS":[{"def":"Relating to, or causing, erythema.","pos":""}],"ERYTHRIC":[{"def":"Pertaining to, derived from, or resembling, erythrin.","pos":""},{"def":"A colorless crystalline substance, C20H22O10, extracted from certain lichens, as the various species of Rocella.","pos":""}],"ERYTHRINA":[{"def":"A genus of leguminous plants growing in the tropics; coral tree; -- so called from its red flowers.","pos":""}],"ERYTHRISM":[{"def":"A condition of excessive redness.","pos":""}],"ERYTHRITE":[{"def":"A colorless crystalline substance, C4H6.","pos":""},{"def":"A rose-red mineral, crystallized and earthy, a hydrous arseniate of cobalt, known also as cobalt bloom; -- called also erythrin or erythrine.","pos":""}],"ERYTHROCHROIC":[{"def":"Having, or subject to, erythrochroism.","pos":""}],"ERYTHROCHROISM":[{"def":"An unusual redness, esp.","pos":""}],"ERYTHRODEXTRIN":[{"def":"A dextrin which gives a red color with iodine.","pos":""}],"ERYTHROGRANULOSE":[{"def":"A term applied by Brücke to a substance present in small amount in starch granules, colored red by iodine.","pos":""}],"ERYTHROID":[{"def":"Of a red color; reddish; as, the erythroid tunic (the cremaster muscle).","pos":""}],"ERYTHROLEIC":[{"def":"Having a red color and oily appearance; -- applied to a purple semifluid substance said to be obtained from archil.","pos":""}],"ERYTHROLEIN":[{"def":"A red substance obtained from litmus.","pos":""}],"ERYTHRONIUM":[{"def":"A name originally given (from its red acid) to the metal vanadium.","pos":""}],"ERYTHROPHLEINE":[{"def":"A white crystalline alkaloid, extracted from sassy bark (Erythrophleum Guineense).","pos":""},{"def":"The red coloring matter of leaves, fruits, flowers, etc.","pos":""}],"ERYTHROXYLON":[{"def":"A genus of shrubs or small trees of the Flax family, growing in tropical countries.","pos":""}],"ERYTHROZYME":[{"def":"A ferment extracted from madder root, possessing the power of inducing alcoholic fermentation in solutions of sugar.","pos":""}]}