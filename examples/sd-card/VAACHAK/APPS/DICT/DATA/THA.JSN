{"THALAMENCEPHALON":[{"def":"The segment of the brain next in front of the midbrain, including the thalami, pineal gland, and pituitary body; the diencephalon; the interbrain.","pos":""}],"THALAMIC":[{"def":"Of or pertaining to a thalamus or to thalami.","pos":""},{"def":"Bearing the stamens directly on the receptacle; -- said of a subclass of polypetalous dicotyledonous plants in the system of De Candolle.","pos":""}],"THALAMOCOELE":[{"def":"The cavity or ventricle of the thalamencephalon; the third ventricle.","pos":""}],"THALAMOPHORA":[{"def":"Same as Foraminifera.","pos":""}],"THALAMUS":[{"def":"A mass of nervous matter on either side of the third ventricle of the brain; -- called also optic thalamus.","pos":""}],"THALASSIAN":[{"def":"Any sea tortoise.","pos":""}],"THALASSIC":[{"def":"Of or pertaining to the sea; -- sometimes applied to rocks formed from sediments deposited upon the sea bottom.","pos":""}],"THALASSINIAN":[{"def":"Any species of Thalaassinidæ, a family of burrowing macrurous Crustacea, having a long and soft abdomen.","pos":""}],"THALASSOGRAPHY":[{"def":"The study or science of the life of marine organisms.","pos":""}],"THALER":[{"def":"A German silver coin worth about three shillings sterling, or about 73 cents.","pos":""}],"THALIACEA":[{"def":"A division of Tunicata comprising the free-swimming species, such as Salpa and Doliolum.","pos":""}],"THALIAN":[{"def":"Of or pertaining to Thalia; hence, of or pertaining to comedy; comic.","pos":""}],"THALLATE":[{"def":"A salt of a hypothetical thallic acid.","pos":""}],"THALLENE":[{"def":"A hydrocarbon obtained from coal-tar residues, and remarkable for its intense yellowish green fluorescence.","pos":""}],"THALLIC":[{"def":"Of or pertaining to thallium; derived from, or containing, thallium; specifically, designating those compounds in which the element has a higher valence as contrasted with the thallous compounds; as, thallic oxide.","pos":""}],"THALLINE":[{"def":"Consisting of a thallus.","pos":""}],"THALLIUM":[{"def":"A rare metallic element of the aluminium group found in some minerals, as certain pyrites, and also in the lead-chamber deposit in the manufacture of sulphuric acid.","pos":""}],"THALLOID":[{"def":"Resembling, or consisting of, thallus.","pos":""}],"THALLOPHYTA":[{"def":"A phylum of plants of very diverse habit and structure, including the algæ, fungi, and lichens.","pos":""}],"THALLOPHYTE":[{"def":"Same as Thallogen.","pos":""}],"THALLOUS":[{"def":"Of or pertaining to thallium; derived from, or containing, thallium; specifically, designating those compounds in which the element has a lower valence as contrasted with the thallic compounds.","pos":""}],"THALLUS":[{"def":"A solid mass of cellular tissue, consisting of one or more layers, usually in the form of a flat stratum or expansion, but sometimes erect or pendulous, and elongated and branching, and forming the substance of the thallogens.","pos":""}],"THALWEG":[{"def":"A deity among the ancient Syrians, in honor of whom the Hebrew idolatresses held an annual lamentation.","pos":""},{"def":"The fourth month of the Jewish ecclesiastical year, -- supposed to correspond nearly with our month of July.","pos":""}],"THAMYN":[{"def":"An Asiatic deer (Rucervus Eldi) resembling the swamp deer; -- called also Eld's deer.","pos":""}],"THAN":[{"def":"A particle expressing comparison, used after certain adjectives and adverbs which express comparison or diversity, as more, better, other, otherwise, and the like.","pos":""}],"THANA":[{"def":"A police station.","pos":""}],"THANAGE":[{"def":"The district in which a thane anciently had jurisdiction; thanedom.","pos":""}],"THANATOID":[{"def":"Deathlike; resembling death.","pos":""}],"THANATOLOGY":[{"def":"A description, or the doctrine, of death.","pos":""}],"THANATOPSIS":[{"def":"A view of death; a meditation on the subject of death.","pos":""}],"THANE":[{"def":"A dignitary under the Anglo-Saxons and Danes in England.","pos":""}],"THANEDOM":[{"def":"The property or jurisdiction of a thane; thanage.","pos":""}],"THANEHOOD":[{"def":"The character or dignity of a thane; also, thanes, collectively.","pos":""}],"THANESHIP":[{"def":"The state or dignity of a thane; thanehood; also, the seignioralty of a thane.","pos":""}],"THANK":[{"def":"A expression of gratitude; an acknowledgment expressive of a sense of favor or kindness received; obligation, claim, or desert, or gratitude; -- now generally used in the plural.","pos":""}],"THANKFUL":[{"def":"Obtaining or deserving thanks; thankworthy.","pos":""},{"def":"Impressed with a sense of kindness received, and ready to acknowledge it; grateful.","pos":""}],"THANKLESS":[{"def":"Not acknowledging favors; not expressing thankfulness; unthankful; ungrateful.","pos":""},{"def":"Not obtaining or deserving thanks; unacceptable; as, a thankless task.","pos":""}],"THANKSGIVE":[{"def":"To give or dedicate in token of thanks.","pos":""}],"THANKSGIVER":[{"def":"One who gives thanks, or acknowledges a kindness.","pos":""}],"THANKSGIVING":[{"def":"The act of rending thanks, or expressing gratitude for favors or mercies.","pos":""},{"def":"A public acknowledgment or celebration of divine goodness; also, a day set apart for religious services, specially to acknowledge the goodness of God, either in any remarkable deliverance from calamities or danger, or in the ordinary dispensation of his bounties.","pos":""}],"THANKWORTHINESS":[{"def":"The quality or state of being thankworthy.","pos":""}],"THANKWORTHY":[{"def":"Deserving thanks; worthy of gratitude; mreitorious.","pos":""}],"THAR":[{"def":"A goatlike animal (Capra Jemlaica) native of the Himalayas.","pos":""}],"THAROS":[{"def":"A small American butterfly (Phycoides tharos) having the upper surface of the wings variegated with orange and black, the outer margins black with small white crescents; -- called also pearl crescent.","pos":""}],"THAT":[{"def":"As a demonstrative pronoun (pl.","pos":""},{"def":"As an adjective, that has the same demonstrative force as the pronoun, but is followed by a noun.","pos":""}],"THATCH":[{"def":"A name in the West Indies for several kinds of palm, the leaves of which are used for thatching.","pos":""}],"THATCHER":[{"def":"One who thatches.","pos":""}],"THATCHING":[{"def":"The act or art of covering buildings with thatch; so as to keep out rain, snow, etc.","pos":""},{"def":"The materials used for this purpose; thatch.","pos":""}],"THAUMATOLATRY":[{"def":"Worship or undue admiration of wonderful or miraculous things.","pos":""}],"THAUMATROPE":[{"def":"An optical instrument or toy for showing the presistence of an impression upon the eyes after the luminous object is withdrawn.","pos":""}],"THAUMATURGE":[{"def":"A magician; a wonder worker.","pos":""},{"def":"Of or pertaining to thaumaturgy; magical; wonderful.","pos":""}],"THAUMATURGICS":[{"def":"Feats of legerdemain, or magical performances.","pos":""}],"THAUMATURGIST":[{"def":"One who deals in wonders, or believes in them; a wonder worker.","pos":""}],"THAUMATURGUS":[{"def":"A miracle worker; -- a title given by the Roman Catholics to some saints.","pos":""}],"THAUMATURGY":[{"def":"The act or art of performing something wonderful; magic; legerdemain.","pos":""}],"THAW":[{"def":"To melt, dissolve, or become fluid; to soften; -- said of that which is frozen; as, the ice thaws.","pos":""},{"def":"To become so warm as to melt ice and snow; -- said in reference to the weather, and used impersonally.","pos":""}],"THAWY":[{"def":"Liquefying by heat after having been frozen; thawing; melting.","pos":""}]}