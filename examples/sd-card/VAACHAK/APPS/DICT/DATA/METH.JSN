{"METHAEMOGLOBIN":[{"def":"A stable crystalline compound obtained by the decomposition of hemoglobin.","pos":""}],"METHAL":[{"def":"A white waxy substance, found in small quantities in spermaceti as an ethereal salt of several fatty acids, and regarded as an alcohol of the methane series.","pos":""}],"METHANE":[{"def":"A light, colorless, gaseous, inflammable hydrocarbon, CH4; marsh gas.","pos":""}],"METHANOMETER":[{"def":"An instrument, resembling a eudiometer, to detect the presence and amount of methane, as in coal mines.","pos":""}],"METHEGLIN":[{"def":"A fermented beverage made of honey and water; mead.","pos":""}],"METHENYL":[{"def":"The hypothetical hydrocarbon radical CH, regarded as an essential residue of certain organic compounds.","pos":""}],"METHIDE":[{"def":"A binary compound of methyl with some element; as, aluminium methide, Al2(CH3)6.","pos":""}],"METHINKS":[{"def":"It seems to me; I think.","pos":""}],"METHIONATE":[{"def":"A salt of methionic acid.","pos":""}],"METHIONIC":[{"def":"Of, pertaining to, or designating, a sulphonic (thionic) acid derivative of methane, obtained as a stable white crystalline substance, CH2.","pos":""}],"METHOD":[{"def":"Classification; a mode or system of classifying natural objects according to certain common characteristics; as, the method of Theophrastus; the method of Ray; the Linnæan method.","pos":""}],"METHODIOS":[{"def":"The art and principles of method.","pos":""}],"METHODISM":[{"def":"The system of doctrines, polity, and worship, of the sect called Methodists.","pos":""}],"METHODIST":[{"def":"One of a sect of Christians, the outgrowth of a small association called the \"Holy Club,\" formed at Oxford University, A.","pos":""}],"METHODIZATION":[{"def":"The act or process of methodizing, or the state of being methodized.","pos":""}],"METHODIZE":[{"def":"To reduce to method; to dispose in due order; to arrange in a convenient manner; as, to methodize one's work or thoughts.","pos":""}],"METHODIZER":[{"def":"One who methodizes.","pos":""}],"METHODOLOGICAL":[{"def":"Of or pertaining to methodology.","pos":""}],"METHODOLOGY":[{"def":"The science of method or arrangement; a treatise on method.","pos":""}],"METHOL":[{"def":"The technical name of methyl alcohol or wood spirit; also, by extension, the class name of any of the series of alcohols of the methane series of which methol proper is the type.","pos":""}],"METHOXYL":[{"def":"A hypothetical radical, CH3O, analogous to hydroxyl.","pos":""}],"METHYL":[{"def":"A hydrocarbon radical, CH3, not existing alone but regarded as an essential residue of methane, and appearing as a component part of many derivatives; as, methyl alcohol, methyl ether, methyl amine, etc.","pos":""}],"METHYLAL":[{"def":"A light, volatile liquid, H2C(OCH3)2, regarded as a complex ether, and having a pleasant ethereal odor.","pos":""}],"METHYLAMINE":[{"def":"See Methyl amine, under Methyl.","pos":""}],"METHYLATE":[{"def":"An alcoholate of methyl alcohol in which the hydroxyl hydrogen is replaced by a metal, after the analogy of a hydrate; as, sodium methylate, CH3ONa.","pos":""}],"METHYLATED":[{"def":"Impregnated with, or containing, methyl alcohol or wood spirit; as, methylated spirits.","pos":""}],"METHYLENE":[{"def":"A hydrocarbon radical, CH2, not known in the free state, but regarded as an essential residue and component of certain derivatives of methane; as, methylene bromide, CH2Br2; -- formerly called also methene.","pos":""}],"METHYLIC":[{"def":"Pertaining to, derived from, or containing, methyl; specifically, designating methyl alcohol.","pos":""}],"METHYSTICIN":[{"def":"A white, silky, crystalline substance extracted from the thick rootstock of a species of pepper (Piper methysticum) of the South Sea Islands; -- called also kanakin.","pos":""}]}