{"SEMILAPIDIFIED":[{"def":"Imperfectly changed into stone.","pos":""}],"SEMILENS":[{"def":"The half of a lens divided along a plane passing through its axis.","pos":""}],"SEMILENTICULAR":[{"def":"Half lenticular or convex; imperfectly resembling a lens.","pos":""}],"SEMILIGNEOUS":[{"def":"Half or partially ligneous, as a stem partly woody and partly herbaceous.","pos":""}],"SEMILIQUID":[{"def":"Half liquid; semifluid.","pos":""}],"SEMILIQUIDITY":[{"def":"The quality or state of being semiliquid; partial liquidity.","pos":""}],"SEMILOGICAL":[{"def":"Half logical; partly logical; said of fallacies.","pos":""}],"SEMILOR":[{"def":"A yellowish alloy of copper and zinc.","pos":""}],"SEMILUNAR":[{"def":"Shaped like a half moon.","pos":""}],"SEMILUNE":[{"def":"The half of a lune.","pos":""}]}