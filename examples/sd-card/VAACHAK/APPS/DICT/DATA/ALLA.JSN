{"ALLAH":[{"def":"The name of the Supreme Being, in use among the Arabs and the Mohammedans generally.","pos":""}],"ALLANITE":[{"def":"A silicate containing a large amount of cerium.","pos":""}],"ALLANTOIC":[{"def":"Pertaining to, or contained in, the allantois.","pos":""},{"def":"Of or pertaining to the allantois.","pos":""}],"ALLANTOIDEA":[{"def":"The division of Vertebrata in which the embryo develops an allantois.","pos":""}],"ALLANTOIN":[{"def":"A crystalline, transparent, colorless substance found in the allantoic liquid of the fetal calf; -- formerly called allantoic acid and amniotic acid.","pos":""},{"def":"A membranous appendage of the embryos of mammals, birds, and reptiles, -- in mammals serving to connect the fetus with the parent; the urinary vesicle.","pos":""}],"ALLATRATE":[{"def":"To bark as a dog.","pos":""}],"ALLAY":[{"def":"To make quiet or put at rest; to pacify or appease; to quell; to calm; as, to allay popular excitement; to allay the tumult of the passions.","pos":""},{"def":"To alleviate; to abate; to mitigate; as, to allay the severity of affliction or the bitterness of adversity.","pos":""}],"ALLAYER":[{"def":"One who, or that which, allays.","pos":""}],"ALLAYMENT":[{"def":"An allaying; that which allays; mitigation.","pos":""}]}