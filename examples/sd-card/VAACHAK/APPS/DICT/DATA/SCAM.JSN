{"SCAMBLE":[{"def":"To move awkwardly; to be shuffling, irregular, or unsteady; to sprawl; to shamble.","pos":""},{"def":"To move about pushing and jostling; to be rude and turbulent; to scramble.","pos":""}],"SCAMBLER":[{"def":"A bold intruder upon the hospitality of others; a mealtime visitor.","pos":""}],"SCAMBLINGLY":[{"def":"In a scambling manner; with turbulence and noise; with bold intrusiveness.","pos":""},{"def":"The female bar-tailed godwit.","pos":""}],"SCAMILLUS":[{"def":"A sort of second plinth or block, below the bases of Ionic and Corinthian columns, generally without moldings, and of smaller size horizontally than the pedestal.","pos":""}],"SCAMMONIATE":[{"def":"Made from scammony; as, a scammoniate aperient.","pos":""}],"SCAMMONY":[{"def":"A species of bindweed or Convolvulus (C.","pos":""}],"SCAMP":[{"def":"A rascal; a swindler; a rogue.","pos":""}],"SCAMPAVIA":[{"def":"A long, low war galley used by the Neapolitans and Sicilians in the early part of the nineteenth century.","pos":""}],"SCAMPER":[{"def":"To run with speed; to run or move in a quick, hurried manner; to hasten away.","pos":""}],"SCAMPERER":[{"def":"One who scampers.","pos":""}],"SCAMPISH":[{"def":"Of or like a scamp; knavish; as, scampish conduct.","pos":""}]}