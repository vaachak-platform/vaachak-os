{"INSOBRIETY":[{"def":"Want of sobriety, moderation, or calmness; intemperance; drunkenness.","pos":""}],"INSOCIABILITY":[{"def":"The quality of being insociable; want of sociability; unsociability.","pos":""}],"INSOCIABLE":[{"def":"Incapable of being associated, joined, or connected.","pos":""},{"def":"Not sociable or companionable; disinclined to social intercourse or conversation; unsociable; taciturn.","pos":""}],"INSOCIATE":[{"def":"Not associate; without a companion; single; solitary; recluse.","pos":""}],"INSOLATE":[{"def":"To dry in, or to expose to, the sun's rays; to ripen or prepare by such exposure.","pos":""}],"INSOLATION":[{"def":"The act or process to exposing to the rays of the sun fro the purpose of drying or maturing, as fruits, drugs, etc.","pos":""}],"INSOLE":[{"def":"The inside sole of a boot or shoe; also, a loose, thin strip of leather, felt, etc.","pos":""}],"INSOLENCE":[{"def":"The quality of being unusual or novel.","pos":""},{"def":"The quality of being insolent; pride or haughtiness manifested in contemptuous and overbearing treatment of others; arrogant contempt; brutal imprudence.","pos":""}],"INSOLENT":[{"def":"Deviating from that which is customary; novel; strange; unusual.","pos":""},{"def":"Haughty and contemptuous or brutal in behavior or language; overbearing; domineering; grossly rude or disrespectful; saucy; as, an insolent master; an insolent servant.","pos":""}],"INSOLENTLY":[{"def":"In an insolent manner.","pos":""}],"INSOLIDITY":[{"def":"Want of solidity; weakness; as, the insolidity of an argument.","pos":""}],"INSOLUBILITY":[{"def":"The quality or state of being insoluble or not dissolvable, as in a fluid.","pos":""},{"def":"The quality of being inexplicable or insolvable.","pos":""}],"INSOLUBLE":[{"def":"Not soluble; in capable or difficult of being dissolved, as by a liquid; as, chalk is insoluble in water.","pos":""},{"def":"Not to be solved or explained; insolvable; as, an insoluble doubt, question, or difficulty.","pos":""}],"INSOLUBLENESS":[{"def":"The quality or state of being insoluble; insolubility.","pos":""}],"INSOLVABLE":[{"def":"Not solvable; insoluble; admitting no solution or explanation; as, an insolvable problem or difficulty.","pos":""},{"def":"Incapable of being paid or discharged, as debts.","pos":""}],"INSOLVENT":[{"def":"One who is insolvent; as insolvent debtor; -- in England, before 1861, especially applied to persons not traders.","pos":""}],"INSOMNIA":[{"def":"Want of sleep; inability to sleep; wakefulness; sleeplessness.","pos":""}],"INSOMNIOUS":[{"def":"Restless; sleepless.","pos":""}],"INSOMUCH":[{"def":"So; to such a degree; in such wise; -- followed by that or as, and formerly sometimes by both.","pos":""}],"INSONOROUS":[{"def":"Not clear or melodious.","pos":""}],"INSOOTH":[{"def":"In sooth; truly.","pos":""}],"INSOUCIANCE":[{"def":"Carelessness; heedlessness; thoughtlessness; unconcern.","pos":""}],"INSOUCIANT":[{"def":"Careless; heedless; indifferent; unconcerned.","pos":""}],"INSOUL":[{"def":"To set a soul in; reflexively, to fix one's strongest affections on.","pos":""}]}