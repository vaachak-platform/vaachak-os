{"APPLAUD":[{"def":"To show approval of by clapping the hands, acclamation, or other significant sign.","pos":""},{"def":"To praise by words; to express approbation of; to commend; to approve.","pos":""}],"APPLAUDER":[{"def":"One who applauds.","pos":""}],"APPLAUSABLE":[{"def":"Worthy pf applause; praiseworthy.","pos":""}],"APPLAUSE":[{"def":"The act of applauding; approbation and praise publicly expressed by clapping the hands, stamping or tapping with the feet, acclamation, huzzas, or other means; marked commendation.","pos":""}],"APPLAUSIVE":[{"def":"Expressing applause; approbative.","pos":""}],"APPLE":[{"def":"Any tree genus Pyrus which has the stalk sunken into the base of the fruit; an apple tree.","pos":""}],"APPLE PIE":[{"def":"A pie made of apples (usually sliced or stewed) with spice and sugar.","pos":""}],"APPLE-FACED":[{"def":"Having a round, broad face, like an apple.","pos":""}],"APPLE-JOHN":[{"def":"A kind of apple which by keeping becomes much withered; -- called also Johnapple.","pos":""}],"APPLE-SQUIRE":[{"def":"A pimp; a kept gallant.","pos":""}],"APPLIABLE":[{"def":"Applicable; also, compliant.","pos":""}],"APPLIANCE":[{"def":"The act of applying; application; [Obs.","pos":""},{"def":"The thing applied or used as a means to an end; an apparatus or device; as, to use various appliances; a mechanical appliance; a machine with its appliances.","pos":""}],"APPLICABILITY":[{"def":"The quality of being applicable or fit to be applied.","pos":""}],"APPLICABLE":[{"def":"Capable of being applied; fit or suitable to be applied; having relevance; as, this observation is applicable to the case under consideration.","pos":""}],"APPLICANCY":[{"def":"The quality or state of being applicable.","pos":""}],"APPLICANT":[{"def":"One who apples for something; one who makes request; a petitioner.","pos":""}],"APPLICATE":[{"def":"Applied or put to some use.","pos":""}],"APPLICATION":[{"def":"The act of applying or laying on, in a literal sense; as, the application of emollients to a diseased limb.","pos":""},{"def":"The thing applied.","pos":""}],"APPLICATIVE":[{"def":"Having of being applied or used; applying; applicatory; practical.","pos":""}],"APPLICATORILY":[{"def":"By way of application.","pos":""}],"APPLICATORY":[{"def":"Having the property of applying; applicative; practical.","pos":""},{"def":"That which applies.","pos":""}],"APPLIER":[{"def":"He who, or that which, applies.","pos":""}],"APPLIQUE":[{"def":"Ornamented with a pattern (which has been cut out of another color or stuff) applied or transferred to a foundation; as, appliqué lace; appliqué work.","pos":""}],"APPLOT":[{"def":"To divide into plots or parts; to apportion.","pos":""}],"APPLY":[{"def":"To lay or place; to put or adjust (one thing to another); -- with to; as, to apply the hand to the breast; to apply medicaments to a diseased part of the body.","pos":""},{"def":"To put to use; to use or employ for a particular purpose, or in a particular case; to appropriate; to devote; as, to apply money to the payment of a debt.","pos":""}]}