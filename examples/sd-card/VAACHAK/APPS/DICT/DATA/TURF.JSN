{"TURF":[{"def":"That upper stratum of earth and vegetable mold which is filled with the roots of grass and other small plants, so as to adhere and form a kind of mat; sward; sod.","pos":""},{"def":"Peat, especially when prepared for fuel.","pos":""}],"TURFEN":[{"def":"Made of turf; covered with turf.","pos":""}],"TURFINESS":[{"def":"Quality or state of being turfy.","pos":""}],"TURFING":[{"def":"The act or process of providing or covering with turf.","pos":""}],"TURFITE":[{"def":"A votary of the turf, or race course; hence, sometimes, a blackleg.","pos":""}],"TURFLESS":[{"def":"Destitute of turf.","pos":""}],"TURFMAN":[{"def":"A turfite; a votary of the turf, or race course.","pos":""}],"TURFY":[{"def":"Abounding with turf; made of, or covered with, turf.","pos":""},{"def":"Having the nature or appearance of turf.","pos":""}]}