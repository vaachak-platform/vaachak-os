{"STELA":[{"def":"A small column or pillar, used as a monument, milestone, etc.","pos":""}],"STELE":[{"def":"One of these steles, containing the Greek version of the ordinance, has recently been discovered.","pos":""}],"STELENE":[{"def":"Resembling, or used as, a stela; columnar.","pos":""}],"STELL":[{"def":"To place or fix firmly or permanently.","pos":""}],"STELLATION":[{"def":"Radiation of light.","pos":""}],"STELLED":[{"def":"Firmly placed or fixed.","pos":""}],"STELLER":[{"def":"The rytina; -- called also stellerine.","pos":""}],"STELLERIDA":[{"def":"An extensive group of echinoderms, comprising the starfishes and ophiurans.","pos":""},{"def":"A starfish, or brittle star.","pos":""}],"STELLIFEROUS":[{"def":"Having, or abounding with, stars.","pos":""}],"STELLIFORM":[{"def":"Like a star; star-shaped; radiated.","pos":""}],"STELLIFY":[{"def":"To turn into a star; to cause to appear like a star; to place among the stars, or in heaven.","pos":""}],"STELLION":[{"def":"A lizard (Stellio vulgaris), common about the Eastern Mediterranean among ruins.","pos":""}],"STELLIONATE":[{"def":"Any fraud not distinguished by a more special name; -- chiefly applied to sales of the same property to two different persons, or selling that for one's own which belongs to another, etc.","pos":""}],"STELLULAR":[{"def":"Having the shape or appearance of little stars; radiated.","pos":""},{"def":"Marked with starlike spots of color.","pos":""}],"STELLULATE":[{"def":"Minutely stellate.","pos":""}],"STELMATOPODA":[{"def":"Same as Gymnolæmata.","pos":""}],"STELOGRAPHY":[{"def":"The art of writing or inscribing characters on pillars.","pos":""}]}