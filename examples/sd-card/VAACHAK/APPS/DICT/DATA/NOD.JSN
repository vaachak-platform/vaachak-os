{"NOD":[{"def":"To bend or incline the upper part, with a quick motion; as, nodding plumes.","pos":""},{"def":"To incline the head with a quick motion; to make a slight bow; to make a motion of assent, of salutation, or of drowsiness, with the head; as, to nod at one.","pos":""}],"NODAL":[{"def":"Of the nature of, or relating to, a node; as, a nodal point.","pos":""}],"NODATION":[{"def":"Act of making a knot, or state of being knotted.","pos":""}],"NODDER":[{"def":"One who nods; a drowsy person.","pos":""}],"NODDING":[{"def":"Curved so that the apex hangs down; having the top bent downward.","pos":""}],"NODDLE":[{"def":"The head; -- used jocosely or contemptuously.","pos":""},{"def":"The back part of the head or neck.","pos":""}],"NODDY":[{"def":"A simpleton; a fool.","pos":""},{"def":"An old game at cards.","pos":""}],"NODE":[{"def":"A knot, a knob; a protuberance; a swelling.","pos":""},{"def":"Specifically: (a) (Astron.","pos":""}],"NODICAL":[{"def":"Of or pertaining to the nodes; from a node to the same node again; as, the nodical revolutions of the moon.","pos":""}],"NODOSARINE":[{"def":"Resembling in form or structure a foraminiferous shell of the genus Nodosaria.","pos":""},{"def":"A foraminifer of the genus Nodosaria or of an allied genus.","pos":""}],"NODOSE":[{"def":"Having nodes or prominences; having the alternate joints enlarged, as the antennæ of certain insects.","pos":""}],"NODOSITY":[{"def":"Nodose; knotty; knotted.","pos":""}],"NODULAR":[{"def":"Of, pertaining to, or in the form of, a nodule or knot.","pos":""}],"NODULE":[{"def":"A rounded mass or irregular shape; a little knot or lump.","pos":""}],"NODULED":[{"def":"Having little knots or lumps.","pos":""},{"def":"Having small nodes or knots; diminutively nodose.","pos":""}]}