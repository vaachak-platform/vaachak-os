{"BRYOLOGICAL":[{"def":"Relating to bryology; as, bryological studies.","pos":""}],"BRYOLOGIST":[{"def":"One versed in bryology.","pos":""}],"BRYOLOGY":[{"def":"That part of botany which relates to mosses.","pos":""}],"BRYONIN":[{"def":"A bitter principle obtained from the root of the bryony (Bryonia alba and B.","pos":""}],"BRYONY":[{"def":"The common name of several cucurbitaceous plants of the genus Bryonia.","pos":""}],"BRYOPHYTA":[{"def":"See Cryptogamia.","pos":""}],"BRYOZOA":[{"def":"A class of Molluscoidea, including minute animals which by budding form compound colonies; -- called also Polyzoa.","pos":""}],"BRYOZOAN":[{"def":"Of or pertaining to the Bryozoa.","pos":""},{"def":"One of the Bryozoa.","pos":""}],"BRYOZOUM":[{"def":"An individual zooid of a bryozoan coralline, of which there may be two or more kinds in a single colony.","pos":""}]}