{"FLAM":[{"def":"A freak or whim; also, a falsehood; a lie; an illusory pretext; deception; delusion.","pos":""}],"FLAMBE":[{"def":"Decorated by glaze splashed or irregularly spread upon the surface, or apparently applied at the top and allowed to run down the sides; -- said of pieces of Chinese porcelain.","pos":""}],"FLAMBEAU":[{"def":"A flaming torch, esp.","pos":""}],"FLAMBOYANT":[{"def":"Characterized by waving or flamelike curves, as in the tracery of windows, etc.","pos":""}],"FLAMBOYER":[{"def":"A name given in the East and West Indies to certain trees with brilliant blossoms, probably species of Cæsalpinia.","pos":""}],"FLAME":[{"def":"A stream of burning vapor or gas, emitting light and heat; darting or streaming fire; a blaze; a fire.","pos":""},{"def":"Burning zeal or passion; elevated and noble enthusiasm; glowing imagination; passionate excitement or anger.","pos":""}],"FLAME-COLORED":[{"def":"Of the color of flame; of a bright orange yellow color.","pos":""}],"FLAMELESS":[{"def":"Destitute of flame.","pos":""}],"FLAMELET":[{"def":"The flamelets gleamed and flickered.","pos":""}],"FLAMEN":[{"def":"A priest devoted to the service of a particular god, from whom he received a distinguishing epithet.","pos":""}],"FLAMINEOUS":[{"def":"Pertaining to a flamen; flaminical.","pos":""}],"FLAMING":[{"def":"Emitting flames; afire; blazing; consuming; illuminating.","pos":""},{"def":"Of the color of flame; high-colored; brilliant; dazzling.","pos":""}],"FLAMINGLY":[{"def":"In a flaming manner.","pos":""}],"FLAMINGO":[{"def":"Any bird of the genus Phoenicopterus.","pos":""}],"FLAMINICAL":[{"def":"Pertaining to a flamen.","pos":""}],"FLAMMABILITY":[{"def":"The quality of being flammable; inflammability.","pos":""}],"FLAMMATION":[{"def":"The act of setting in a flame or blaze.","pos":""}],"FLAMMEOUS":[{"def":"Pertaining to, consisting of, or resembling, flame.","pos":""}],"FLAMMIFEROUS":[{"def":"Producing flame.","pos":""}],"FLAMMIVOMOUS":[{"def":"Vomiting flames, as a volcano.","pos":""}],"FLAMMULATED":[{"def":"Of a reddish color.","pos":""}],"FLAMY":[{"def":"Flaming; blazing; flamelike; flame-colored; composed of flame.","pos":""}]}