{"CHILBLAIN":[{"def":"A blain, sore, or inflammatory swelling, produced by exposure of the feet or hands to cold, and attended by itching, pain, and sometimes ulceration.","pos":""}],"CHILD":[{"def":"A son or a daughter; a male or female descendant, in the first degree; the immediate progeny of human parents; -- in law, legitimate offspring.","pos":""},{"def":"A descendant, however remote; -- used esp.","pos":""}],"CHILD STUDY":[{"def":"A scientific study of children, undertaken for the purpose of discovering the laws of development of the body and the mind from birth to manhood.","pos":""}],"CHILDBEARING":[{"def":"The act of producing or bringing forth children; parturition.","pos":""}],"CHILDBED":[{"def":"The state of a woman bringing forth a child, or being in labor; parturition.","pos":""}],"CHILDBIRTH":[{"def":"The act of bringing forth a child; travail; labor.","pos":""}],"CHILDCROWING":[{"def":"The crowing noise made by children affected with spasm of the laryngeal muscles; false croup.","pos":""}],"CHILDE":[{"def":"A cognomen formerly prefixed to his name by the oldest son, until he succeeded to his ancestral titles, or was knighted; as, Childe Roland.","pos":""}],"CHILDED":[{"def":"Furnished with a child.","pos":""}],"CHILDERMAS DAY":[{"def":"A day (December 28) observed by mass or festival in commemoration of the children slain by Herod at Bethlehem; -- called also Holy Innocent's Day.","pos":""}],"CHILDHOOD":[{"def":"The state of being a child; the time in which persons are children; the condition or time from infancy to puberty.","pos":""},{"def":"Children, taken collectively.","pos":""}],"CHILDING":[{"def":"Bearing Children; (Fig.","pos":""}],"CHILDISH":[{"def":"Of, pertaining to, befitting, or resembling, a child.","pos":""},{"def":"Peurile; trifling; weak.","pos":""}],"CHILDISHLY":[{"def":"In the manner of a child; in a trifling way; in a weak or foolish manner.","pos":""}],"CHILDISHNESS":[{"def":"The state or quality of being childish; simplicity; harmlessness; weakness of intellect.","pos":""}],"CHILDLESSNESS":[{"def":"The state of being childless.","pos":""}],"CHILDLIKE":[{"def":"Resembling a child, or that which belongs to children; becoming a child; meek; submissive; dutiful.","pos":""}],"CHILDLY":[{"def":"Having tthe character of a child; belonging, or appropriate, to a child.","pos":""}],"CHILDNESS":[{"def":"The manner characteristic of a child.","pos":""}],"CHILDSHIP":[{"def":"The state or relation of being a child.","pos":""}],"CHILEAN":[{"def":"Of or pertaining to Chile.","pos":""}],"CHILEAN PINE":[{"def":"Same as Monkey-puzzle.","pos":""}],"CHILI":[{"def":"A kind of red pepper.","pos":""}],"CHILIAD":[{"def":"A thousand; the aggregate of a thousand things; especially, a period of a thousand years.","pos":""}],"CHILIAGON":[{"def":"A plane figure of a thousand angles and sides.","pos":""}],"CHILIAHEDRON":[{"def":"A figure bounded by a thousand plane surfaces [Spelt also chiliaëdron.","pos":""}],"CHILIAN":[{"def":"Of or pertaining to Chili.","pos":""},{"def":"A native or citizen of Chili.","pos":""}],"CHILIARCHY":[{"def":"A body consisting of a thousand men.","pos":""}],"CHILIASM":[{"def":"The doctrine of the personal reign of Christ on earth during the millennium.","pos":""}],"CHILIAST":[{"def":"One who believes in the second coming of Christ to reign on earth a thousand years; a milllenarian.","pos":""}],"CHILL":[{"def":"A sensation of cold with convulsive shaking of the body, pinched face, pale skin, and blue lips, caused by undue cooling of the body or by nervous excitement, or forming the precursor of some constitutional disturbance, as of a fever.","pos":""}],"CHILLED":[{"def":"Having that cloudiness or dimness of surface that is called \"blooming.","pos":""}],"CHILLINESS":[{"def":"A state or sensation of being chilly; a disagreeable sensation of coldness.","pos":""},{"def":"A moderate degree of coldness; disagreeable coldness or rawness; as, the chilliness of the air.","pos":""}],"CHILLING":[{"def":"Making chilly or cold; depressing; discouraging; cold; distant; as, a chilling breeze; a chilling manner.","pos":""}],"CHILLNESS":[{"def":"Coolness; coldness; a chill.","pos":""}],"CHILLY":[{"def":"Moderately cold; cold and raw or damp so as to cause shivering; causing or feeling a disagreeable sensation of cold, or a shivering.","pos":""}],"CHILOGNATH":[{"def":"A myriapod of the order Chilognatha.","pos":""}],"CHILOGNATHA":[{"def":"One of the two principal orders of myriapods.","pos":""}],"CHILOMA":[{"def":"The tumid upper lip of certain mammals, as of a camel.","pos":""}],"CHILOPOD":[{"def":"A myriapod of the order Chilopoda.","pos":""}],"CHILOPODA":[{"def":"One of the orders of myriapods, including the centipeds.","pos":""},{"def":"An extensive suborder of marine Bryozoa, mostly with calcareous shells.","pos":""}],"CHILOSTOMATOUS":[{"def":"Of or pertaining to the Chilostoma.","pos":""}],"CHILTERN HUNDREDS":[{"def":"A tract of crown land in Buckinghamshire and Oxfordshire, England, to which is attached the nominal office of steward.","pos":""}]}