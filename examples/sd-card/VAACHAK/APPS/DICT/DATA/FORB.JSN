{"FORBADE":[{"def":"For*bade\", Defn: imp.","pos":""}],"FORBEAR":[{"def":"An ancestor; a forefather; -- usually in the plural.","pos":""}],"FORBEARANCE":[{"def":"The act of forbearing or waiting; the exercise of patience.","pos":""}],"FORBEARER":[{"def":"One who forbears.","pos":""}],"FORBEARING":[{"def":"Disposed or accustomed to forbear; patient; long-suffering.","pos":""}],"FORBID":[{"def":"To command against, or contrary to; to prohibit; to interdict.","pos":""},{"def":"To deny, exclude from, or warn off, by express command; to command not to enter.","pos":""}],"FORBIDDANCE":[{"def":"The act of forbidding; prohibition; command or edict against a thing.","pos":""}],"FORBIDDEN":[{"def":"Prohibited; interdicted.","pos":""}],"FORBIDDENLY":[{"def":"In a forbidden or unlawful manner.","pos":""}],"FORBIDDER":[{"def":"One who forbids.","pos":""}],"FORBIDDING":[{"def":"Repelling approach; repulsive; raising abhorrence, aversion, or dislike; disagreeable; prohibiting or interdicting; as, a forbidding aspect; a forbidding formality; a forbidding air.","pos":""}],"FORBLACK":[{"def":"As any raven's feathers it shone forblack.","pos":""}],"FORBORE":[{"def":"For*bore\", Defn: imp.","pos":""}],"FORBORNE":[{"def":"For*borne\", Defn: p.","pos":""}],"FORBRUISE":[{"def":"To bruise sorely or exceedingly.","pos":""}],"FORBY":[{"def":"Near; hard by; along; past.","pos":""}]}