{"PENIBLE":[{"def":"Painstaking; assidous.","pos":""}],"PENICIL":[{"def":"A tent or pledget for wounds or ulcers.","pos":""}],"PENICILLATE":[{"def":"Having the form of a pencil; furnished with a pencil of fine hairs; ending in a tuft of hairs like a camel's-hair brush, as the stigmas of some grasses.","pos":""}],"PENINSULA":[{"def":"A portion of land nearly surrounded by water, and connected with a larger body by a neck, or isthmus.","pos":""}],"PENINSULA STATE":[{"def":"Florida; -- a nickname.","pos":""}],"PENINSULAR":[{"def":"Of or pertaining to a peninsula; as, a peninsular form; peninsular people; the peninsular war.","pos":""}],"PENINSULATE":[{"def":"To form into a peninsula.","pos":""}],"PENIS":[{"def":"The male member, or organ of generation.","pos":""}],"PENITENCE":[{"def":"The quality or condition of being penitent; the disposition of a penitent; sorrow for sins or faults; repentance; contrition.","pos":""}],"PENITENCER":[{"def":"A priest who heard confession and enjoined penance in extraordinary cases.","pos":""}],"PENITENT":[{"def":"Feeling pain or sorrow on account of sins or offenses; repentant; contrite; sincerely affected by a sense of guilt, and resolved on amendment of life.","pos":""}],"PENITENTIAL":[{"def":"Of or pertaining to penitence, or to penance; expressing penitence; of the nature of penance; as, the penitential book; penitential tears.","pos":""}],"PENITENTIALLY":[{"def":"In a penitential manner.","pos":""}],"PENITENTIARY":[{"def":"Relating to penance, or to the rules and measures of penance.","pos":""},{"def":"Expressive of penitence; as, a penitentiary letter.","pos":""}],"PENITENTIARYSHIP":[{"def":"The office or condition of a penitentiary of the papal court.","pos":""}],"PENITENTLY":[{"def":"In a penitent manner.","pos":""}]}