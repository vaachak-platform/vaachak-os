{"SCROBICULA":[{"def":"One of the smooth areas surrounding the tubercles of a sea urchin.","pos":""}],"SCROBICULAR":[{"def":"Pertaining to, or surrounding, scrobiculæ; as, scrobicular tubercles.","pos":""},{"def":"Having numerous small, shallow depressions or hollows; pitted.","pos":""}],"SCRODDLED WARE":[{"def":"Mottled pottery made from scraps of differently colored clays.","pos":""}],"SCROFULIDE":[{"def":"Any affection of the skin dependent on scrofula.","pos":""}],"SCROFULOUS":[{"def":"Pertaining to scrofula, or partaking of its nature; as, scrofulous tumors; a scrofulous habit of body.","pos":""},{"def":"Diseased or affected with scrofula.","pos":""}],"SCROG":[{"def":"A stunted shrub, bush, or branch.","pos":""}],"SCROGGY":[{"def":"Abounding in scrog; also, twisted; stunted.","pos":""}],"SCROLL":[{"def":"An ornament formed of undulations giving off spirals or sprays, usually suggestive of plant form.","pos":""},{"def":"Same as Skew surface.","pos":""}],"SCROLLED":[{"def":"Formed like a scroll; contained in a scroll; adorned with scrolls; as, scrolled work.","pos":""}],"SCROPHULARIA":[{"def":"A genus of coarse herbs having small flowers in panicled cymes; figwort.","pos":""}],"SCROPHULARIACEOUS":[{"def":"Of or pertaining to a very large natural order of gamopetalous plants (Scrophulariaceæ, or Scrophularineæ), usually having irregular didynamous flowers and a two-celled pod.","pos":""}],"SCROTAL":[{"def":"Of or pertaining to the scrotum; as, scrotal hernia.","pos":""}],"SCROTIFORM":[{"def":"Purse-shaped; pouch-shaped.","pos":""}],"SCROTOCELE":[{"def":"A rupture or hernia in the scrotum; scrotal hernia.","pos":""}],"SCROTUM":[{"def":"The bag or pouch which contains the testicles; the cod.","pos":""}],"SCROUGE":[{"def":"To crowd; to squeeze.","pos":""}],"SCROW":[{"def":"A clipping from skins; a currier's cuttings.","pos":""}],"SCROYLE":[{"def":"A mean fellow; a wretch.","pos":""}]}