{"PROW":[{"def":"The fore part of a vessel; the bow; the stem; hence, the vessel itself.","pos":""}],"PROWESS":[{"def":"Distinguished bravery; valor; especially, military bravery and skill; gallantry; intrepidity; fearlessness.","pos":""}],"PROWL":[{"def":"To rove over, through, or about in a stealthy manner; esp.","pos":""},{"def":"To collect by plunder; as, to prowl money.","pos":""}],"PROWLER":[{"def":"One that prowls.","pos":""}],"PROWLING":[{"def":"Accustomed to prowl, or engaged in roving stealthily, as for prey.","pos":""}]}