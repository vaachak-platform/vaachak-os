{"UNGAIN":[{"def":"Ungainly; clumsy; awkward; also, troublesome; inconvenient.","pos":""}],"UNGAINLINESS":[{"def":"The state or quality of being ungainly; awkwardness.","pos":""}],"UNGAINLY":[{"def":"Not gainly; not expert or dexterous; clumsy; awkward; uncouth; as, an ungainly strut in walking.","pos":""},{"def":"Unsuitable; unprofitable.","pos":""}],"UNGEAR":[{"def":"To strip of gear; to unharness; to throw out of gear.","pos":""}],"UNGELD":[{"def":"A person so far out of the protection of the law, that if he were murdered, no geld, or fine, should be paid, or composition made by him that killed him.","pos":""}],"UNGENEROUS":[{"def":"Not generous; illiberal; ignoble; unkind; dishonorable.","pos":""}],"UNGENEROUSLY":[{"def":"In an ungenerous manner.","pos":""}],"UNGENITURED":[{"def":"Destitute of genitals; impotent.","pos":""}],"UNGENTLE":[{"def":"Not gentle; lacking good breeding or delicacy; harsh.","pos":""}],"UNGET":[{"def":"To cause to be unbegotten or unborn, or as if unbegotten or unborn.","pos":""}],"UNGIFTED":[{"def":"Being without gifts, especially native gifts or endowments.","pos":""}],"UNGIRD":[{"def":"To loose the girdle or band of; to unbind; to unload.","pos":""}],"UNGIVE":[{"def":"To yield; to relax; to give way.","pos":""}],"UNGKA":[{"def":"The siamang; -- called also ungka ape.","pos":""}],"UNGKA-PUTI":[{"def":"The agile gibbon; -- called also ungka-pati, and ungka-etam.","pos":""}],"UNGLAZE":[{"def":"To strip of glass; to remove the glazing, or glass, from, as a window.","pos":""}],"UNGLORIFY":[{"def":"To deprive of glory.","pos":""}],"UNGLOVE":[{"def":"To take off the glove or gloves of; as, to unglove the hand.","pos":""}],"UNGLUE":[{"def":"To separate, part, or open, as anything fastened with glue.","pos":""}],"UNGOD":[{"def":"To deprive of divinity; to undeify.","pos":""},{"def":"To cause to recognize no god; to deprive of a god; to make atheistical.","pos":""}],"UNGODLY":[{"def":"Not godly; not having regard for God; disobedient to God; wicked; impious; sinful.","pos":""},{"def":"Polluted by sin or wickedness.","pos":""}],"UNGORED":[{"def":"Not stained with gore; not bloodied.","pos":""}],"UNGOVERNABLE":[{"def":"Not governable; not capable of being governed, ruled, or restrained; licentious; wild; unbridled; as, ungovernable passions.","pos":""}],"UNGOWN":[{"def":"To strip of a gown; to unfrock.","pos":""}],"UNGOWNED":[{"def":"Stripped of a gown; unfrocked.","pos":""},{"def":"Not having, or not wearing, a gown.","pos":""}],"UNGRACEFUL":[{"def":"Not graceful; not marked with ease and dignity; deficient in beauty and elegance; inelegant; awkward; as, ungraceful manners; ungraceful speech.","pos":""}],"UNGRACIOUS":[{"def":"Not gracious; showing no grace or kindness; being without good will; unfeeling.","pos":""},{"def":"Having no grace; graceless; wicked.","pos":""}],"UNGRATE":[{"def":"Displeasing; ungrateful; ingrate.","pos":""}],"UNGRATEFUL":[{"def":"Not grateful; not thankful for favors; making no returns, or making ill return for kindness, attention, etc.","pos":""},{"def":"Unpleasing; unacceptable; disagreeable; as, harsh sounds are ungrateful to the ear.","pos":""}],"UNGRAVE":[{"def":"To raise or remove from the grave; to disinter; to untomb; to exhume.","pos":""}],"UNGUAL":[{"def":"Of or pertaining to a nail, claw, talon, or hoof, or resembling one.","pos":""},{"def":"Having a nail, claw, or hoof attached; -- said of certain bones of the feet.","pos":""}],"UNGUARD":[{"def":"To deprive of a guard; to leave unprotected.","pos":""}],"UNGUENT":[{"def":"A lubricant or salve for sores, burns, or the like; an ointment.","pos":""}],"UNGUENTARY":[{"def":"Like an unguent, or partaking of its qualities.","pos":""}],"UNGUESTLIKE":[{"def":"In a manner not becoming to a guest.","pos":""}],"UNGUICULAR":[{"def":"Of or pertaining to a claw or a nail; ungual.","pos":""}],"UNGUICULATA":[{"def":"An extensive division of Mammalia including those having claws or nails, as distinguished from the hoofed animals (Ungulata).","pos":""}],"UNGUICULATE":[{"def":"One of the Unguiculata.","pos":""},{"def":"Furnished with a claw, or a narrow stalklike base, as the petals of a carnation.","pos":""}],"UNGUIFEROUS":[{"def":"Producing, having, or supporting nails or claws.","pos":""}],"UNGUIFORM":[{"def":"Having the form of a claw or claws.","pos":""}],"UNGUINOUS":[{"def":"Consisting of, or resembling, fat or oil; oily; unctuous; oleaginous.","pos":""}],"UNGUIS":[{"def":"One of the terminal hooks on the foot of an insect.","pos":""},{"def":"The slender base of a petal in some flowers; a claw; called also ungula.","pos":""}],"UNGULA":[{"def":"A section or part of a cylinder, cone, or other solid of revolution, cut off by a plane oblique to the base; -- so called from its resemblance to the hoof of a horse.","pos":""},{"def":"Same as Unguis, 3.","pos":""}],"UNGULAR":[{"def":"Of or pertaining to a hoof, claw, or talon; ungual.","pos":""}],"UNGULATA":[{"def":"An extensive group of mammals including all those that have hoofs.","pos":""}],"UNGULATE":[{"def":"Furnished with hoofs.","pos":""}],"UNGULED":[{"def":"Hoofed, or bearing hoofs; -- used only when these are of a tincture different from the body.","pos":""}],"UNGULIGRADE":[{"def":"Having, or walking on, hoofs.","pos":""}],"UNGULOUS":[{"def":"Same as Ungulate.","pos":""}]}