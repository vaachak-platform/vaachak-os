{"PAVAN":[{"def":"A stately and formal Spanish dance for which full state costume is worn; -- so called from the resemblance of its movements to those of the peacock.","pos":""}],"PAVE":[{"def":"To lay or cover with stone, brick, or other material, so as to make a firm, level, or convenient surface for horses, carriages, or persons on foot, to travel on; to floor with brick, stone, or other solid material; as, to pave a street; to pave a court.","pos":""}],"PAVEMENT":[{"def":"That with which anythingis paved; a floor or covering of solid material, laid so as to make a hard and convenient surface for travel; a paved road or sidewalk; a decorative interior floor of tiles or colored bricks.","pos":""}],"PAVER":[{"def":"One who paves; one who lays a pavement.","pos":""}],"PAVESADE":[{"def":"A canvas screen, formerly sometimes extended along the side of a vessel in a naval engagement, to conceal from the enemy the operations on board.","pos":""}],"PAVIAGE":[{"def":"A contribution or a tax for paving streets or highways.","pos":""}],"PAVIAN":[{"def":"Pav\"i*an Defn: , n.","pos":""}],"PAVIIN":[{"def":"A glucoside found in species of the genus Pavia of the Horse- chestnut family.","pos":""}],"PAVILION":[{"def":"A single body or mass of building, contained within simple walls and a single roof, whether insulated, as in the park or garden of a larger edifice, or united with other parts, and forming an angle or central feature of a large pile.","pos":""},{"def":"A flag, colors, ensign, or banner.","pos":""}],"PAVING":[{"def":"The act or process of laying a pavement, or covering some place with a pavement.","pos":""}],"PAVIOR":[{"def":"One who paves; a paver.","pos":""},{"def":"A rammer for driving paving stones.","pos":""}],"PAVISE":[{"def":"A large shield covering the whole body, carried by a pavisor, who sometimes screened also an archer with it.","pos":""}],"PAVISOR":[{"def":"A soldier who carried a pavise.","pos":""}],"PAVO":[{"def":"A genus of birds, including the peacocks.","pos":""},{"def":"The Peacock, a constellation of the southern hemisphere.","pos":""}],"PAVON":[{"def":"A small triangular flag, esp.","pos":""}],"PAVONIAN":[{"def":"Of or pertaining to a peacock.","pos":""}],"PAVONINE":[{"def":"Like, or pertaining to, the genus Pavo.","pos":""}]}