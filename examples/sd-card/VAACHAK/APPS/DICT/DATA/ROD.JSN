{"ROD":[{"def":"A straight and slender stick; a wand; hence, any slender bar, as of wood or metal (applied to various purposes).","pos":""},{"def":"A measure of length containing sixteen and a half feet; -- called also perch, and pole.","pos":""}],"RODDY":[{"def":"Full of rods or twigs.","pos":""}],"RODE":[{"def":"Redness; complexion.","pos":""}],"RODENT":[{"def":"Gnawing; biting; corroding; (Med.","pos":""}],"RODENTIA":[{"def":"An order of mammals having two (rarely four) large incisor teeth in each jaw, distant from the molar teeth.","pos":""}],"RODOMEL":[{"def":"Juice of roses mixed with honey.","pos":""}],"RODOMONT":[{"def":"A vain or blustering boaster; a braggart; a braggadocio.","pos":""}],"RODOMONTADE":[{"def":"Vain boasting; empty bluster or vaunting; rant.","pos":""}],"RODOMONTADOR":[{"def":"A rodomontadist.","pos":""}],"RODSMAN":[{"def":"One who carries and holds a leveling staff, or rod, in a surveying party.","pos":""}]}