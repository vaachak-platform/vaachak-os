{"CIVET":[{"def":"The animal that produces civet (Viverra civetta); -- called also civet cat.","pos":""}],"CIVIC":[{"def":"Relating to, or derived from, a city or citizen; relating to man as a member of society, or to civil affairs.","pos":""}],"CIVICISM":[{"def":"The principle of civil government.","pos":""}],"CIVICS":[{"def":"The science of civil government.","pos":""}],"CIVIL":[{"def":"Pertaining to a city or state, or to a citizen in his relations to his fellow citizens or to the state; within the city or state.","pos":""},{"def":"Subject to government; reduced to order; civilized; not barbarous; -- said of the community.","pos":""}],"CIVIL SERVICE COMMISSION":[{"def":"In the United States, a commission appointed by the President, consisting of three members, not more than two of whom may be adherents of the same party, which has the control, through examinations, of appointments and promotions in the classified civil service.","pos":""}],"CIVIL SERVICE REFORM":[{"def":"The substitution of business principles and methods for political methods in the conduct of the civil service.","pos":""}],"CIVILIAN":[{"def":"One skilled in the civil law.","pos":""},{"def":"A student of the civil law at a university or college.","pos":""}],"CIVILITY":[{"def":"The state of society in which the relations and duties of a citizen are recognized and obeyed; a state of civilization.","pos":""},{"def":"A civil office, or a civil process [Obs.","pos":""}],"CIVILIZABLE":[{"def":"Capable of being civilized.","pos":""}],"CIVILIZATION":[{"def":"Rendering a criminal process civil.","pos":""}],"CIVILIZE":[{"def":"To reclaim from a savage state; to instruct in the rules and customs of civilization; to educate; to refine.","pos":""},{"def":"To admit as suitable to a civilized state.","pos":""}],"CIVILIZED":[{"def":"Reclaimed from savage life and manners; instructed in arts, learning, and civil manners; refined; cultivated.","pos":""}],"CIVILIZER":[{"def":"One who, or that which, civilizes or tends to civilize.","pos":""}],"CIVILY":[{"def":"In a civil manner; as regards civil rights and privileges; politely; courteously; in a well bred manner.","pos":""}],"CIVISM":[{"def":"State of citizenship.","pos":""}]}