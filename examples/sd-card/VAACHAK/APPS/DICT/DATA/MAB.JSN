{"MAB":[{"def":"The name of a female fairy, esp.","pos":""}],"MABBY":[{"def":"A spirituous liquor or drink distilled from potatoes; -- used in the Barbadoes.","pos":""}],"MABOLO":[{"def":"A kind of persimmon tree (Diospyros discolor) from the Philippine Islands, now introduced into the East and West Indies.","pos":""}]}