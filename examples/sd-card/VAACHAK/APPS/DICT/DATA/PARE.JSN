{"PARE":[{"def":"To cut off, or shave off, the superficial substance or extremities of; as, to pare an apple; to pare a horse's hoof.","pos":""},{"def":"To remove; to separate; to cut or shave, as the skin, ring, or outside part, from anything; -- followed by off or away; as; to pare off the ring of fruit; to pare away redundancies.","pos":""}],"PAREGORIC":[{"def":"Mitigating; assuaging or soothing pain; as, paregoric elixir.","pos":""}],"PARELCON":[{"def":"The addition of a syllable or particle to the end of a pronoun, verb, or adverb.","pos":""}],"PARELECTRONOMIC":[{"def":"Of or relating to parelectronomy; as, the parelectronomic part of a muscle.","pos":""}],"PARELECTRONOMY":[{"def":"A condition of the muscles induced by exposure to severe cold, in which the electrical action of the muscle is reversed.","pos":""}],"PAREMBOLE":[{"def":"A kind of parenthesis.","pos":""}],"PAREMPTOSIS":[{"def":"Same as Parembole.","pos":""}],"PARENCHYMA":[{"def":"The soft celluar substance of the tissues of plants and animals, like the pulp of leaves, to soft tissue of glands, and the like.","pos":""}],"PARENCHYMAL":[{"def":"Of, pertaining to, or consisting of, parenchyma.","pos":""},{"def":"Of, pertaining to, or connected with, the parenchyma of a tissue or an organ; as, parenchymatous degeneration.","pos":""}],"PARENESIS":[{"def":"Hortatory; encouraging; persuasive.","pos":""}],"PARENT":[{"def":"One who begets, or brings forth, offspring; a father or a mother.","pos":""},{"def":"That which produces; cause; source; author; begetter; as, idleness is the parent of vice.","pos":""}],"PARENTAGE":[{"def":"Descent from parents or ancestors; parents or ancestors considered with respect to their rank or character; extraction; birth; as, a man of noble parentage.","pos":""}],"PARENTAL":[{"def":"Of or pertaining to a parent or to parents; as, parental authority; parental obligations.","pos":""},{"def":"Becoming to, or characteristic of, parents; tender; affectionate; devoted; as, parental care.","pos":""}],"PARENTALLY":[{"def":"In a parental manner.","pos":""}],"PARENTATION":[{"def":"Something done or said in honor of the dead; obsequies.","pos":""}],"PARENTELE":[{"def":"Kinship; parentage.","pos":""}],"PARENTHESIS":[{"def":"One of the curved lines () which inclose a parenthetic word or phrase.","pos":""}],"PARENTHESIZE":[{"def":"To make a parenthesis of; to include within parenthetical marks.","pos":""}],"PARENTHETICALLY":[{"def":"In a parenthetical manner; by way of parenthesis; by parentheses.","pos":""}],"PARENTHOOD":[{"def":"The state of a parent; the office or character of a parent.","pos":""}],"PARENTICIDE":[{"def":"The act of one who kills one's own parent.","pos":""},{"def":"One who kills one's own parent; a parricide.","pos":""}],"PARENTLESS":[{"def":"Deprived of parents.","pos":""}],"PAREPIDIDYMIS":[{"def":"A small body containing convoluted tubules, situated near the epididymis in man and some other animals, and supposed to be a remnant of the anterior part of the Wolffian body.","pos":""}],"PARER":[{"def":"One who, or that which, pares; an instrument for paring.","pos":""}],"PARERGY":[{"def":"Something unimportant, incidental, or superfluous.","pos":""}],"PARESIS":[{"def":"Incomplete paralysis, affecting motion but not sensation.","pos":""}],"PARETHMOID":[{"def":"Near or beside the ethmoid bone or cartilage; -- applied especially to a pair of bones in the nasal region of some fishes, and to the ethmoturbinals in some higher animals.","pos":""},{"def":"A parethmoid bone.","pos":""}],"PARETIC":[{"def":"Of or pertaining to paresis; affected with paresis.","pos":""}]}