{"DUFF":[{"def":"A stiff flour pudding, boiled in a bag; -- a term used especially by seamen; as, plum duff.","pos":""}],"DUFFEL":[{"def":"A kind of coarse woolen cloth, having a thick nap or frieze.","pos":""}],"DUFFEL BAG":[{"def":"A sack to hold miscellaneous articles, as tools, supplies, or the like.","pos":""}],"DUFFER":[{"def":"A peddler or hawker, especially of cheap, flashy articles, as sham jewelry; hence, a sham or cheat.","pos":""},{"def":"A stupid, awkward, inefficient person.","pos":""}],"DUFRENITE":[{"def":"A mineral of a blackish green color, commonly massive or in nodules.","pos":""}]}