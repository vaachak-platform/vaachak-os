{"LIM NAEA":[{"def":"A genus of fresh-water air-breathing mollusks, abundant in ponds and streams; -- called also pond snail.","pos":""}],"LIMA":[{"def":"The capital city of Peru, in South America.","pos":""}],"LIMACEOUS":[{"def":"Pertaining to, or like, Limax, or the slugs.","pos":""}],"LIMACINA":[{"def":"A genus of small spiral pteropods, common in the Arctic and Antarctic seas.","pos":""}],"LIMACON":[{"def":"A curve of the fourth degree, invented by Pascal.","pos":""}],"LIMAILLE":[{"def":"Filings of metal.","pos":""}],"LIMAN":[{"def":"The deposit of slime at the mouth of a river; slime.","pos":""}],"LIMATION":[{"def":"The act of filing or polishing.","pos":""}],"LIMATURE":[{"def":"The act of filing.","pos":""},{"def":"That which is filed off; filings.","pos":""}],"LIMAX":[{"def":"A genus of airbreathing mollusks, including the common garden slugs.","pos":""}],"LIMB":[{"def":"A part of a tree which extends from the trunk and separates into branches and twigs; a large branch.","pos":""},{"def":"An arm or a leg of a human being; a leg, arm, or wing of an animal.","pos":""}],"LIMBAT":[{"def":"A cooling periodical wind in the Isle of Cyprus, blowing from the northwest from eight o'clock, A.","pos":""}],"LIMBATE":[{"def":"Bordered, as when one color is surrounded by an edging of another.","pos":""}],"LIMBEC":[{"def":"An alembic; a still.","pos":""}],"LIMBED":[{"def":"Having limbs; -- much used in composition; as, large-limbed; short-limbed.","pos":""}],"LIMBER":[{"def":"The shafts or thills of a wagon or carriage.","pos":""},{"def":"The detachable fore part of a gun carriage, consisting of two wheels, an axle, and a shaft to which the horses are attached.","pos":""}],"LIMBERNESS":[{"def":"The quality or state of being limber; flexibleness.","pos":""}],"LIMBLESS":[{"def":"Destitute of limbs.","pos":""}],"LIMBMEAL":[{"def":"An extramundane region where certain classes of souls were supposed to await the judgment.","pos":""}],"LIMBOUS":[{"def":"With slightly overlapping borders; -- said of a suture.","pos":""},{"def":"A soft cheese made in the Belgian province of Limburg (Limbourg), and usually not eaten until the curing has developed a peculiar and, to most people, unpleasant odor.","pos":""}],"LIME":[{"def":"A thong by which a dog is led; a leash.","pos":""}],"LIME-TWIGGED":[{"def":"Beset with snares; insnared, as with birdlime.","pos":""}],"LIMEHOUND":[{"def":"A dog used in hunting the wild boar; a leamer.","pos":""}],"LIMEKILN":[{"def":"A kiln or furnace in which limestone or shells are burned and reduced to lime.","pos":""}],"LIMELIGHT":[{"def":"That part of the stage upon which the limelight as cast, usually where the most important action is progressing or where the leading player or players are placed and upon which the attention of the spectators is therefore concentrated.","pos":""}],"LIMENEAN":[{"def":"Of or pertaining to Lima, or to the inhabitants of Lima, in Peru.","pos":""},{"def":"A native or inhabitant of Lima.","pos":""}],"LIMER":[{"def":"A limehound; a limmer.","pos":""}],"LIMERICK":[{"def":"A nonsense poem of five anapestic lines, of which lines 1, 2, and 5 are of there feet, and rime, and lines 3 and 4 are of two feet, and rime; as -- There was a young lady, Amanda, Whose Ballades Lyriques were quite fin de Siècle, I deem But her Journal Intime Was what sent her papa to Uganda.","pos":""}],"LIMESTONE":[{"def":"A rock consisting chiefly of calcium carbonate or carbonate of lime.","pos":""}],"LIMEWATER":[{"def":"Water impregnated with lime; esp.","pos":""}],"LIMICOLAE":[{"def":"A group of shore birds, embracing the plovers, sandpipers, snipe, curlew, etc.","pos":""}],"LIMICOLINE":[{"def":"Shore-inhabiting; of or pertaining to the Limicolæ.","pos":""}],"LIMINESS":[{"def":"The state or quality of being limy.","pos":""}],"LIMIT":[{"def":"A determining feature; a distinguishing characteristic a differentia.","pos":""},{"def":"A determinate quantity, to which a variable one continually approaches, and may differ from it by less than any given difference, but to which, under the law of variation, the variable can never become exactly equivalent.","pos":""}],"LIMITABLE":[{"def":"Capable of being limited.","pos":""}],"LIMITANEOUS":[{"def":"Of or pertaining to a limit.","pos":""}],"LIMITARIAN":[{"def":"Tending to limit.","pos":""}],"LIMITARY":[{"def":"Placed at the limit, as a guard.","pos":""},{"def":"Confined within limits; limited in extent, authority, power, etc.","pos":""}],"LIMITATE":[{"def":"Bounded by a distinct line.","pos":""}],"LIMITATION":[{"def":"The act of limiting; the state or condition of being limited; as, the limitation of his authority was approved by the council.","pos":""},{"def":"That which limits; a restriction; a qualification; a restraining condition, defining circumstance, or qualifying conception; as, limitations of thought.","pos":""}],"LIMITED":[{"def":"Confined within limits; narrow; circumscribed; restricted; as, our views of nature are very limited.","pos":""}],"LIMITEDLY":[{"def":"With limitation.","pos":""}],"LIMITEDNESS":[{"def":"The quality of being limited.","pos":""}],"LIMITER":[{"def":"One who, or that which, limits.","pos":""},{"def":"A friar licensed to beg within certain bounds, or whose duty was limited to a certain district.","pos":""}],"LIMITIVE":[{"def":"Involving a limit; as, a limitive law, one designed to limit existing powers.","pos":""}],"LIMITLESS":[{"def":"Having no limits; unbounded; boundless.","pos":""}],"LIMMER":[{"def":"A mongrel, as a cross between the mastiff and hound.","pos":""},{"def":"A man rope at the side of a ladder.","pos":""}],"LIMN":[{"def":"To draw or paint; especially, to represent in an artistic way with pencil or brush.","pos":""},{"def":"To illumine, as books or parchments, with ornamental figures, letters, or borders.","pos":""}],"LIMNER":[{"def":"A painter; an artist; esp.","pos":""}],"LIMNING":[{"def":"The act, process, or art of one who limns; the picture or decoration so produced.","pos":""}],"LIMOGES":[{"def":"A city of Southern France.","pos":""}],"LIMONIAD":[{"def":"A nymph of the meadows; -- called also Limniad.","pos":""}],"LIMONIN":[{"def":"A bitter, white, crystalline substance found in orange and lemon seeds.","pos":""}],"LIMONITE":[{"def":"Hydrous sesquixoide of iron, an important ore of iron, occurring in stalactitic, mammillary, or earthy forms, of a dark brown color, yellowish brown powder.","pos":""}],"LIMOSIS":[{"def":"A ravenous appetite caused by disease; excessive and morbid hunger.","pos":""}],"LIMOUS":[{"def":"Muddy; slimy; thick.","pos":""}],"LIMOUSINE":[{"def":"An automobile body with seats and permanent top like a coupé, and with the top projecting over the driver and a projecting front; also, an automobile with such a body.","pos":""}],"LIMP":[{"def":"To halt; to walk lamely.","pos":""}],"LIMPET":[{"def":"In a general sense, any hatshaped, or conical, gastropod shell.","pos":""},{"def":"Any one of many species of marine shellfish of the order Docoglossa, mostly found adhering to rocks, between tides.","pos":""}],"LIMPID":[{"def":"Characterized by clearness or transparency; clear; as, a limpid stream.","pos":""}],"LIMPIDITY":[{"def":"The quality or state of being limpid.","pos":""}],"LIMPIDNESS":[{"def":"Quality of being limpid; limpidity.","pos":""}],"LIMPINGLY":[{"def":"In a limping manner.","pos":""}],"LIMPKIN":[{"def":"Either one of two species of wading birds of the genus Aramus, intermediate between the cranes and rails.","pos":""}],"LIMPNESS":[{"def":"The quality or state of being limp.","pos":""},{"def":"Limp; flexible; flimsy.","pos":""}],"LIMU":[{"def":"The Hawaiian name for seaweeds.","pos":""}],"LIMULOIDEA":[{"def":"An order of Merostomata, including among living animals the genus Limulus, with various allied fossil genera, mostly of the Carboniferous period.","pos":""}],"LIMULUS":[{"def":"The only existing genus of Merostomata.","pos":""}],"LIMY":[{"def":"Smeared with, or consisting of, lime; viscous.","pos":""},{"def":"Containing lime; as, a limy soil.","pos":""}]}