{"QUAIL":[{"def":"To die; to perish; hence, to wither; to fade.","pos":""},{"def":"To become quelled; to become cast down; to sink under trial or apprehension of danger; to lose the spirit and power of resistance; to lose heart; to give way; to shrink; to cower.","pos":""}],"QUAILY":[{"def":"The upland plover.","pos":""}],"QUAINT":[{"def":"Prudent; wise; hence, crafty; artful; wily.","pos":""},{"def":"Characterized by ingenuity or art; finely fashioned; skillfully wrought; elegant; graceful; nice; neat.","pos":""}],"QUAINTISE":[{"def":"Craft; subtlety; cunning.","pos":""},{"def":"Elegance; beauty.","pos":""}],"QUAINTLY":[{"def":"In a quaint manner.","pos":""}],"QUAINTNESS":[{"def":"The quality of being quaint.","pos":""}],"QUAIR":[{"def":"A quire; a book.","pos":""}]}