{"KABOOK":[{"def":"A clay ironstone found in Ceylon.","pos":""}],"KABYLE":[{"def":"A Berber, as in Algiers or Tunis.","pos":""}],"KADDER":[{"def":"A Turkish judge.","pos":""}],"KAFAL":[{"def":"The Arabian name of two trees of the genus Balsamodendron, which yield a gum resin and a red aromatic wood.","pos":""}],"KAGE":[{"def":"A chantry chapel inclosed with lattice or screen work.","pos":""}],"KAGU":[{"def":"A singular, crested, grallatorial bird (Rhinochetos jubatus), native of New Caledonia.","pos":""}],"KAHANI":[{"def":"A kind of notary public, or attorney, in the Levant.","pos":""}],"KAHAU":[{"def":"A long-nosed monkey (Semnopithecus nasalis), native of Borneo.","pos":""}],"KAIL":[{"def":"A kind of headless cabbage.","pos":""}],"KAIMACAM":[{"def":"Same as Caimacam.","pos":""}],"KAINIT":[{"def":"Salts of potassium used in the manufacture of fertilizers.","pos":""}],"KAINITE":[{"def":"A compound salt consisting chiefly of potassium chloride and magnesium sulphate, occurring at the Stassfurt salt mines in Prussian Saxony.","pos":""}],"KAIRINE":[{"def":"A pale buff or white crystalline alkaloid derived from quinoline, and used as an antipyretic in medicine.","pos":""}],"KAIROLINE":[{"def":"An organic base obtained from quinoline.","pos":""}],"KAISER":[{"def":"The ancient title of emperors of Germany assumed by King William of Prussia when crowned sovereign of the new German empire in 1871.","pos":""}],"KAKA":[{"def":"A New Zealand parrot of the genus Nestor, especially the brown parrot (Nestor meridionalis).","pos":""}],"KAKAPO":[{"def":"A singular nocturnal parrot (Strigops habroptilus), native of New Zealand.","pos":""}],"KAKARALLI":[{"def":"A kind of wood common in Demerara, durable in salt water, because not subject to the depredations of the sea worm and barnacle.","pos":""}],"KAKISTOCRACY":[{"def":"Government by the worst men.","pos":""}],"KALASIE":[{"def":"A long-tailed monkey of Borneo (Semnopithecus rubicundus).","pos":""}],"KALE":[{"def":"A variety of cabbage in which the leaves do not form a head, being nearly the original or wild form of the species.","pos":""}],"KALEEGE":[{"def":"One of several species of large, crested, Asiatic pheasants, belonging to the genus Euplocamus, and allied to the firebacks.","pos":""},{"def":"An instrument invented by Professor Wheatstone, consisting of a reflecting knob at the end of a vibrating rod or thin plate, for making visible, in the motion of a point of light reflected from the knob, the paths or curves corresponding with the musical notes produced by the vibrations.","pos":""}],"KALEIDOSCOPE":[{"def":"An instrument invented by Sir David Brewster, which contains loose fragments of colored glass, etc.","pos":""},{"def":"Of, pertaining to, or formed by, a kaleidoscope; variegated.","pos":""}],"KALENDARIAL":[{"def":"See Calendarial.","pos":""}],"KALENDER":[{"def":"See 3d Calender.","pos":""}],"KALENDS":[{"def":"Same as Calends.","pos":""}],"KALI":[{"def":"The last and worst of the four ages of the world; -- considered to have begun B.","pos":""}],"KALIFORM":[{"def":"Formed like kali, or glasswort.","pos":""}],"KALIGENOUS":[{"def":"Forming alkalies with oxygen, as some metals.","pos":""}],"KALIUM":[{"def":"Potassium; -- so called by the German chemists.","pos":""}],"KALKI":[{"def":"The name of Vishnu in his tenth and last avatar.","pos":""}],"KALMIA":[{"def":"A genus of North American shrubs with poisonous evergreen foliage and corymbs of showy flowers.","pos":""}],"KALMUCK":[{"def":"A kind of shaggy cloth, resembling bearskin.","pos":""},{"def":"A coarse, dyed, cotton cloth, made in Prussia.","pos":""}],"KALONG":[{"def":"A fruit bat, esp.","pos":""}],"KALPA":[{"def":"One of the Brahmanic eons, a period of 4,320,000,000 years.","pos":""}],"KALSOMINE":[{"def":"Same as Calcimine.","pos":""}],"KAMA":[{"def":"The Hindoo Cupid.","pos":""}],"KAMALA":[{"def":"The red dusty hairs of the capsules of an East Indian tree (Mallotus Philippinensis) used for dyeing silk.","pos":""}],"KAMI":[{"def":"A title given to the celestial gods of the first mythical dynasty of Japan and extended to the demigods of the second dynasty, and then to the long line of spiritual princes still represented by the mikado.","pos":""}],"KAMICHI":[{"def":"A curious South American bird (Anhima, or Palamedea, cornuta), often domesticated by the natives and kept with poultry, which it defends against birds of prey.","pos":""}],"KAMPTULICON":[{"def":"A kind of elastic floor cloth, made of India rubber, gutta- percha, linseed oil, and powdered cork.","pos":""}],"KAMPYLITE":[{"def":"A variety of mimetite or arseniate of lead in hexagonal prisms of a fine orange yellow.","pos":""},{"def":"A hot southwesterly wind in Egypt, coming from the Sahara.","pos":""}],"KAMTSCHADALES":[{"def":"An aboriginal tribe inhabiting the southern part of Kamtschatka.","pos":""}],"KAN":[{"def":"To know; to ken.","pos":""}],"KANCHIL":[{"def":"A small chevrotain of the genus Tragulus, esp.","pos":""}],"KAND":[{"def":"Fluor spar; -- so called by Cornish miners.","pos":""}],"KANGAROO":[{"def":"Any one of numerous species of jumping marsupials of the family Macropodidæ.","pos":""}],"KANSAS":[{"def":"A tribe of Indians allied to the Winnebagoes and Osages.","pos":""}],"KANTIAN":[{"def":"Of or pertaining to Immanuel Kant, the German philosopher; conformed or relating to any or all of the philosophical doctrines of Immanuel Kant.","pos":""}],"KANTIST":[{"def":"A disciple or follower of Kant.","pos":""}],"KANTTRY":[{"def":"Same as Cantred.","pos":""},{"def":"A very pure white clay, ordinarily in the form of an impalpable powder, and used to form the paste of porcelain; China clay; porcelain clay.","pos":""}],"KAOLINIZATION":[{"def":"The process by which feldspar is changed into kaolin.","pos":""}],"KAOLINIZE":[{"def":"To convert into kaolin.","pos":""}],"KAPELLE":[{"def":"A chapel; hence, the choir or orchestra of a prince's chapel; now, a musical establishment, usually orchestral.","pos":""}],"KAPELLMEISTER":[{"def":"See Capellmeister.","pos":""}],"KAPIA":[{"def":"The fossil resin of the kauri tree of New Zealand.","pos":""}],"KAPOK":[{"def":"A silky wool derived from the seeds of Ceiba pentandra (syn.","pos":""}],"KARAGANE":[{"def":"A species of gray fox found in Russia.","pos":""}],"KARAISM":[{"def":"Doctrines of the Karaites.","pos":""}],"KARAITE":[{"def":"A sect of Jews who adhere closely to the letter of the Scriptures, rejecting the oral law, and allowing the Talmud no binding authority; -- opposed to the Rabbinists.","pos":""}],"KARATAS":[{"def":"A West Indian plant of the Pineapple family (Nidularium Karatas).","pos":""}],"KARMA":[{"def":"One's acts considered as fixing one's lot in the future existence.","pos":""}],"KARMATHIAN":[{"def":"One of a Mohammedan sect founded in the ninth century by Karmat.","pos":""}],"KARN":[{"def":"A pile of rocks; sometimes, the solid rock.","pos":""}],"KAROB":[{"def":"The twenty-fourth part of a grain; -- a weight used by goldsmiths.","pos":""}],"KAROSS":[{"def":"A native garment or rug of skin sewed together in the form of a square.","pos":""}],"KARPHOLITE":[{"def":"A fibrous mineral occurring in tufts of a straw-yellow color.","pos":""}],"KARROO":[{"def":"One of the dry table-lands of South Africa, which often rise terracelike to considerable elevations.","pos":""}],"KARSTENITE":[{"def":"Same as Anhydrite.","pos":""}],"KARVEL":[{"def":"See Carvel, and Caravel.","pos":""}],"KARYOKINESIS":[{"def":"The indirect division of cells in which, prior to division of the cell protoplasm, complicated changes take place in the nucleus, attended with movement of the nuclear fibrils; -- opposed to karyostenosis.","pos":""}],"KARYOKINETIC":[{"def":"Of or pertaining to karyokinesis; as, karyokinetic changes of cell division.","pos":""}],"KARYOMITON":[{"def":"The reticular network of fine fibers, of which the nucleus of a cell is in part composed; -- in opposition to kytomiton, or the network in the body of the cell.","pos":""}],"KARYOPLASMA":[{"def":"The protoplasmic substance of the nucleus of a cell: nucleoplasm; -- in opposition to kytoplasma, the protoplasm of the cell.","pos":""}],"KARYOSTENOSIS":[{"def":"Direct cell division (in which there is first a simple division of the nucleus, without any changes in its structure, followed by division of the protoplasm of the karyostenotic mode of nuclear division.","pos":""}],"KARYOSTENOTIC":[{"def":"Pertaining to, or connected with, karyostenosis; as, the karyostenotic mode of nuclear division.","pos":""}],"KASACK":[{"def":"Same as Cossack.","pos":""}],"KAT":[{"def":"An Arabian shrub Catha edulis) the leaves of which are used as tea by the Arabs.","pos":""}],"KATABOLIC":[{"def":"Of or pertaining to katabolism; as, katabolic processes, which give rise to substances (katastates) of decreasing complexity and increasing stability.","pos":""}],"KATABOLISM":[{"def":"Destructive or downward metabolism; regressive metamorphism; -- opposed to anabolism.","pos":""}],"KATE":[{"def":"The brambling finch.","pos":""}],"KATHETAL":[{"def":"Making a right angle; perpendicular, as two lines or two sides of a triangle, which include a right angle.","pos":""}],"KATHETOMETER":[{"def":"Same as Cathetometer.","pos":""}],"KATTIMUNDOO":[{"def":"A caoutchouc like substance obtained from the milky juice of the East Indian Euphorbia Kattimundoo.","pos":""}],"KATYDID":[{"def":"A large, green, arboreal, orthopterous insect (Cyrtophyllus concavus) of the family Locustidæ, common in the United States.","pos":""}],"KAURI":[{"def":"A lofty coniferous tree of New Zealand Agathis, or Dammara, australis), furnishing valuable timber and yielding one kind of dammar resin.","pos":""},{"def":"A resinous product of the kauri, found in the form of yellow or brown lumps in the ground where the trees have grown.","pos":""}],"KAVA":[{"def":"A species of Macropiper (M.","pos":""}],"KAVASS":[{"def":"An armed constable; also, a government servant or courier.","pos":""}],"KAWAKA":[{"def":"a New Zealand tree, the Cypress cedar (Libocedrus Doniana), having a valuable, fine-grained, reddish wood.","pos":""}],"KAYAK":[{"def":"A light canoe, made of skins stretched over a frame, and usually capable of carrying but one person, who sits amidships and uses a double-bladed paddle.","pos":""}],"KAYAKER":[{"def":"One who uses a kayak.","pos":""}],"KAYLES":[{"def":"A game; ninepins.","pos":""}],"KAYNARD":[{"def":"A lazy or cowardly person; a rascal.","pos":""}],"KAZOO":[{"def":"A kind of toy or rude musical instrument, as a tube inside of which is a stretched string made to vibrate by singing or humming into the tube.","pos":""}]}