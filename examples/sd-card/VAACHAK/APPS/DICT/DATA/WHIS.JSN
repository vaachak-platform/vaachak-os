{"WHISK":[{"def":"A game at cards; whist.","pos":""}],"WHISKER":[{"def":"That part of the beard which grows upon the sides of the face, or upon the chin, or upon both; as, side whiskers; chin whiskers.","pos":""},{"def":"Iron rods extending on either side of the bowsprit, to spread, or guy out, the stays, etc.","pos":""}],"WHISKERED":[{"def":"Having elongated hairs, feathers, or bristles on the cheeks.","pos":""}],"WHISKERLESS":[{"def":"Being without whiskers.","pos":""}],"WHISKET":[{"def":"A small lathe for turning wooden pins.","pos":""}],"WHISKEY":[{"def":"Same as Whisky, a liquor.","pos":""},{"def":"A light carriage built for rapid motion; -- called also tim- whiskey.","pos":""}],"WHISKIN":[{"def":"A shallow drinking bowl.","pos":""}],"WHISKING":[{"def":"An intoxicating liquor distilled from grain, potatoes, etc.","pos":""},{"def":"Drunk with whisky; intoxicated.","pos":""}],"WHISP":[{"def":"A flock of snipe.","pos":""}],"WHISPER":[{"def":"To speak softly, or under the breath, so as to be heard only by one near at hand; to utter words without sonant breath; to talk without that vibration in the larynx which gives sonorous, or vocal, sound.","pos":""},{"def":"To make a low, sibilant sound or noise.","pos":""}],"WHISPERER":[{"def":"One who whispers.","pos":""},{"def":"A tattler; one who tells secrets; a conveyer of intelligence secretly; hence; a backbiter; one who slanders secretly.","pos":""}],"WHISPERING":[{"def":"Whis\"per*ing, Defn: a.","pos":""}],"WHISPERINGLY":[{"def":"In a whisper, or low voice; in a whispering manner; with whispers.","pos":""}],"WHIST":[{"def":"Be silent; be still; hush; silence.","pos":""}],"WHISTLE":[{"def":"To make a kind of musical sound, or series of sounds, by forcing the breath through a small orifice formed by contracting the lips; also, to emit a similar sound, or series of notes, from the mouth or beak, as birds.","pos":""},{"def":"To make a shrill sound with a wind or steam instrument, somewhat like that made with the lips; to blow a sharp, shrill tone.","pos":""}],"WHISTLEFISH":[{"def":"A gossat, or rockling; -- called also whistler, three-bearded rockling, sea loach, and sorghe.","pos":""}],"WHISTLER":[{"def":"The hoary, or northern, marmot (Arctomys pruinosus).","pos":""},{"def":"The whistlefish.","pos":""}],"WHISTLEWING":[{"def":"The American golden-eye.","pos":""}],"WHISTLEWOOD":[{"def":"The moosewood, or striped maple.","pos":""}],"WHISTLING":[{"def":"Whis\"tling, Defn: a.","pos":""}],"WHISTLINGLY":[{"def":"In a whistling manner; shrilly.","pos":""}],"WHISTLY":[{"def":"In a whist manner; silently.","pos":""}]}