{"STOLA":[{"def":"A long garment, descending to the ankles, worn by Roman women.","pos":""}],"STOLE":[{"def":"A narrow band of silk or stuff, sometimes enriched with embroidery and jewels, worn on the left shoulder of deacons, and across both shoulders of bishops and priests, pendent on each side nearly to the ground.","pos":""}],"STOLED":[{"def":"Having or wearing a stole.","pos":""}],"STOLID":[{"def":"Hopelessly insensible or stupid; not easily aroused or excited; dull; impassive; foolish.","pos":""}],"STOLIDITY":[{"def":"The state or quality of being stolid; dullness of intellect; obtuseness; stupidity.","pos":""}],"STOLIDNESS":[{"def":"Same as Stolidity.","pos":""}],"STOLON":[{"def":"A trailing branch which is disposed to take root at the end or at the joints; a stole.","pos":""},{"def":"An extension of the integument of the body, or of the body wall, from which buds are developed, giving rise to new zooids, and thus forming a compound animal in which the zooids usually remain united by the stolons.","pos":""}],"STOLONIFEROUS":[{"def":"Producing stolons; putting forth suckers.","pos":""}]}