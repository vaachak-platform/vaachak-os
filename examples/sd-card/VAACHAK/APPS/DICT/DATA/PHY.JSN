{"PHYCITE":[{"def":"See Erythrite, 1.","pos":""}],"PHYCOCHROME":[{"def":"A bluish green coloring matter of certain algæ.","pos":""},{"def":"A blue coloring matter found in certain algæ.","pos":""}],"PHYCOGRAPHY":[{"def":"A description of seaweeds.","pos":""}],"PHYCOLOGY":[{"def":"The science of algæ, or seaweeds; algology.","pos":""}],"PHYCOMATER":[{"def":"A gelatin in which the algæ spores have been supposed to vegetate.","pos":""}],"PHYCOMYCETES":[{"def":"A large, important class of parasitic or saprophytic fungi, the algal or algalike fungi.","pos":""}],"PHYCOPHAEINE":[{"def":"A brown coloring matter found in certain algæ.","pos":""},{"def":"A yellowish coloring matter found in certain algæ.","pos":""}],"PHYLACTERED":[{"def":"Wearing a phylactery.","pos":""},{"def":"Of or pertaining to phylacteries.","pos":""}],"PHYLACTERY":[{"def":"Any charm or amulet worn as a preservative from danger or disease.","pos":""},{"def":"A small square box, made either of parchment or of black calfskin, containing slips of parchment or vellum on which are written the scriptural passages Exodus xiii.","pos":""}],"PHYLACTOCARP":[{"def":"A branch of a plumularian hydroid specially modified in structure for the protection of the gonothecæ.","pos":""},{"def":"An order of fresh-water Bryozoa in which the tentacles are arranged on a horseshoe-shaped lophophore, and the mouth is covered by an epistome.","pos":""}],"PHYLACTOLAEMATOUS":[{"def":"Of or pertaining to the Phylactolæma.","pos":""},{"def":"Same as Phylactolæma.","pos":""}],"PHYLARCH":[{"def":"The chief of a phyle, or tribe.","pos":""}],"PHYLARCHY":[{"def":"The office of a phylarch; government of a class or tribe.","pos":""}],"PHYLE":[{"def":"A local division of the people in ancient Athens; a clan; a tribe.","pos":""}],"PHYLLO-":[{"def":"A combining form from Gr.","pos":""}],"PHYLLOBRANCHIA":[{"def":"A crustacean gill composed of lamellæ.","pos":""}],"PHYLLOCLADIUM":[{"def":"A flattened stem or branch which more or less resembles a leaf, and performs the function of a leaf as regards respiration and assimilation.","pos":""}],"PHYLLOCYANIN":[{"def":"A blue coloring matter extracted from chlorophyll.","pos":""}],"PHYLLOCYST":[{"def":"The cavity of a hydrophyllium.","pos":""}],"PHYLLODE":[{"def":"Same as Phyllodium.","pos":""}],"PHYLLODINEOUS":[{"def":"Having phyllodia; relating to phyllodia.","pos":""}],"PHYLLODIUM":[{"def":"A petiole dilated into the form of a blade, and usually with vertical edges, as in the Australian acacias.","pos":""}],"PHYLLODY":[{"def":"A retrograde metamorphosis of the floral organs to the condition of leaves.","pos":""}],"PHYLLOID":[{"def":"Resembling a leaf.","pos":""}],"PHYLLOMANIA":[{"def":"An abnormal or excessive production of leaves.","pos":""}],"PHYLLOME":[{"def":"A foliar part of a plant; any organ homologous with a leaf, or produced by metamorphosis of a leaf.","pos":""}],"PHYLLOMORPHOSIS":[{"def":"The succession and variation of leaves during different seasons.","pos":""}],"PHYLLOPHAGOUS":[{"def":"Substituting on leaves; leaf-eating.","pos":""}],"PHYLLOPHOROUS":[{"def":"Leaf-bearing; producing leaves.","pos":""}],"PHYLLOPOD":[{"def":"One of the Phyllopoda.","pos":""}],"PHYLLOPODA":[{"def":"An order of Entomostraca including a large number of species, most of which live in fresh water.","pos":""}],"PHYLLOPODOUS":[{"def":"Of or pertaining to the Phyllopoda.","pos":""}],"PHYLLORHINE":[{"def":"Of or pertaining to Phyllorhina and other related genera of bats that have a leaflike membrane around the nostrils.","pos":""}],"PHYLLOSOMA":[{"def":"The larva of the spiny lobsters (Palinurus and allied genera).","pos":""}],"PHYLLOSTOME":[{"def":"Any bat of the genus Phyllostoma, or allied genera, having large membranes around the mouth and nose; a nose-leaf bat.","pos":""}],"PHYLLOTACTIC":[{"def":"Of or pertaining to phyllotaxy.","pos":""},{"def":"The order or arrangement of leaves on the stem; the science of the relative position of leaves.","pos":""}],"PHYLLOUS":[{"def":"Homologous with a leaf; as, the sepals, petals, stamens, and pistils are phyllous organs.","pos":""}],"PHYLLOXANTHIN":[{"def":"A yellow coloring matter extracted from chlorophyll.","pos":""}],"PHYLLOXERA":[{"def":"A small hemipterous insect (Phylloxera vastatrix) allied to the aphids.","pos":""},{"def":"The history of genealogical development; the race history of an animal or vegetable type; the historic exolution of the phylon or tribe, in distinction from ontogeny, or the development of the individual organism, and from biogenesis, or life development generally.","pos":""}],"PHYLOGENETIC":[{"def":"Relating to phylogenesis, or the race history of a type of organism.","pos":""}],"PHYLUM":[{"def":"One of the larger divisions of the animal kingdom; a branch; a grand division.","pos":""}],"PHYMA":[{"def":"A tubercle on any external part of the body.","pos":""}],"PHYSA":[{"def":"A genus of fresh-water Pulmonifera, having reversed spiral shells.","pos":""}],"PHYSALIA":[{"def":"A genus of large oceanic Siphonophora which includes the Portuguese man-of-war.","pos":""}],"PHYSALIAE":[{"def":"An order of Siphonophora which includes Physalia.","pos":""}],"PHYSEMARIA":[{"def":"A group of simple marine organisms, usually classed as the lowest of the sponges.","pos":""}],"PHYSETER":[{"def":"The genus that includes the sperm whale.","pos":""}],"PHYSIANTHROPY":[{"def":"The philosophy of human life, or the doctrine of the constitution and diseases of man, and their remedies.","pos":""}],"PHYSIC":[{"def":"The art of healing diseases; the science of medicine; the theory or practice of medicine.","pos":""},{"def":"A specific internal application for the cure or relief of sickness; a remedy for disease; a medicine.","pos":""}],"PHYSICAL":[{"def":"Of or pertaining to physics, or natural philosophy; treating of, or relating to, the causes and connections of natural phenomena; as, physical science; physical laws.","pos":""}],"PHYSICALLY":[{"def":"In a physical manner; according to the laws of nature or physics; by physical force; not morally.","pos":""}],"PHYSICIAN":[{"def":"A person skilled in physic, or the art of healing; one duty authorized to prescribe remedies for, and treat, diseases; a doctor of medicine.","pos":""},{"def":"Hence, figuratively, one who ministers to moral diseases; as, a physician of the soul.","pos":""}],"PHYSICIANED":[{"def":"Licensed as a physician.","pos":""}],"PHYSICISM":[{"def":"The tendency of the mind toward, or its preoccupation with, physical phenomena; materialism in philosophy and religion.","pos":""}],"PHYSICIST":[{"def":"One versed in physics.","pos":""},{"def":"A believer in the theory that the fundamental phenomena of life are to be explained upon purely chemical and physical principles; -- opposed to vitalist.","pos":""}],"PHYSICKING":[{"def":"Phys\"ick*ing, Defn: p.","pos":""}],"PHYSICO-":[{"def":"A combining form, denoting relation to, or dependence upon, natural causes, or the science of physics.","pos":""}],"PHYSICO-MATHEMATICS":[{"def":"Mixed mathematics.","pos":""}],"PHYSICO-PHILOSOPHY":[{"def":"The philosophy of nature.","pos":""}],"PHYSICO-THEOLOGY":[{"def":"Theology or divinity illustrated or enforced by physics or natural philosophy.","pos":""}],"PHYSICOCHEMICAL":[{"def":"Involving the principles of both physics and chemistry; dependent on, or produced by, the joint action of physical and chemical agencies.","pos":""}],"PHYSICOLOGIC":[{"def":"Logic illustrated by physics.","pos":""}],"PHYSICOLOGICAL":[{"def":"Of or pertaining to physicologic.","pos":""}],"PHYSICS":[{"def":"The science of nature, or of natural objects; that branch of science which treats of the laws and properties of matter, and the forces acting upon it; especially, that department of natural science which treats of the causes (as gravitation, heat, light, magnetism, electricity, etc.","pos":""}],"PHYSIOCRAT":[{"def":"One of the followers of Quesnay of France, who, in the 18th century, founded a system of political economy based upon the supremacy of natural order.","pos":""}],"PHYSIOGENY":[{"def":"The germ history of the functions, or the history of the development of vital activities, in the individual, being one of the branches of ontogeny.","pos":""}],"PHYSIOGNOMER":[{"def":"Of or pertaining to physiognomy; according with the principles of physiognomy.","pos":""}],"PHYSIOGNOMIST":[{"def":"Same as Physiognomy, 1.","pos":""}],"PHYSIOGNOMIZE":[{"def":"To observe and study the physiognomy of.","pos":""}],"PHYSIOGNOMMONIC":[{"def":"Phys`i*og`no*mmon\"ic, a.","pos":""}],"PHYSIOGNOMY":[{"def":"The art and science of discovering the predominant temper, and other characteristic qualities of the mind, by the outward appearance, especially by the features of the face.","pos":""},{"def":"The face or countenance, with respect to the temper of the mind; particular configuration, cast, or expression of countenance, as denoting character.","pos":""}],"PHYSIOGONY":[{"def":"The birth of nature.","pos":""},{"def":"Of or pertaining to physiography.","pos":""}],"PHYSIOGRAPHY":[{"def":"The science which treats of the earth's exterior physical features, climate, life, etc.","pos":""}],"PHYSIOLATRY":[{"def":"The worship of the powers or agencies of nature; materialism in religion; nature worship.","pos":""}],"PHYSIOLOGICAL":[{"def":"Of or pertaining to physiology; relating to the science of the functions of living organism; as, physiological botany or chemistry.","pos":""}],"PHYSIOLOGICALLY":[{"def":"In a physiological manner.","pos":""}],"PHYSIOLOGIST":[{"def":"One who is versed in the science of physiology; a student of the properties and functions of animal and vegetable organs and tissues.","pos":""}],"PHYSIOLOGIZE":[{"def":"To speculate in physiology; to make physiological investigations.","pos":""}],"PHYSIOLOGY":[{"def":"The science which treats of the phenomena of living organisms; the study of the processes incidental to, and characteristic of, life.","pos":""},{"def":"A treatise on physiology.","pos":""}],"PHYSIOPHYLY":[{"def":"The tribal history of the functions, or the history of the paleontological development of vital activities, -- being a branch of phylogeny.","pos":""}],"PHYSIQUE":[{"def":"The natural constitution, or physical structure, of a person.","pos":""}],"PHYSOCLIST":[{"def":"One of the Physoclisti.","pos":""}],"PHYSOCLISTI":[{"def":"An order of teleost in which the air bladder has no opening.","pos":""}],"PHYSOGRADE":[{"def":"Any siphonophore which has an air sac for a float, as the Physalia.","pos":""}],"PHYSOPHORAE":[{"def":"An order of Siphonophora, furnished with an air sac, or float, and a series of nectocalyces.","pos":""}],"PHYSOPOD":[{"def":"One of the Physopoda; a thrips.","pos":""}],"PHYSOPODA":[{"def":"Same as Thysanoptera.","pos":""}],"PHYSOSTIGMINE":[{"def":"An alkaloid found in the Calabar bean (the seed of Physostigma venenosum), and extracted as a white, tasteless, substance, amorphous or crystalline; -- formerly called eserine, with which it was regarded as identical.","pos":""}],"PHYSOSTOMI":[{"def":"An order of fishes in which the air bladder is provided with a duct, and the ventral fins, when present, are abdominal.","pos":""}],"PHYTELEPHAS":[{"def":"A genus of South American palm trees, the seeds of which furnish the substance called vegetable ivory.","pos":""}],"PHYTIVOROUS":[{"def":"Feeding on plants or herbage; phytophagous; as, phytivorous animals.","pos":""}],"PHYTO-":[{"def":"A combining form from Gr.","pos":""}],"PHYTOCHEMICAL":[{"def":"Relating to phytochemistry.","pos":""}],"PHYTOCHEMISTRY":[{"def":"Chemistry in its relation to vegetable bodies; vegetable chemistry.","pos":""}],"PHYTOCHIMY":[{"def":"The doctrine of the generation of plants.","pos":""}],"PHYTOGEOGRAPHICAL":[{"def":"Of or pertaining to phytogeography.","pos":""}],"PHYTOGEOGRAPHY":[{"def":"The geographical distribution of plants.","pos":""}],"PHYTOGLYPHIC":[{"def":"Relating to phytoglyphy.","pos":""}],"PHYTOGLYPHY":[{"def":"See Nature printing, under Nature.","pos":""}],"PHYTOGRAPHICAL":[{"def":"Of or pertaining to phytography.","pos":""}],"PHYTOGRAPHY":[{"def":"The science of describing plants in a systematic manner; also, a description of plants.","pos":""}],"PHYTOID":[{"def":"Resembling a plant; plantlike.","pos":""}],"PHYTOLACCA":[{"def":"A genus of herbaceous plants, some of them having berries which abound in intensely red juice; poke, or pokeweed.","pos":""}],"PHYTOLITE":[{"def":"An old name for a fossil plant.","pos":""}],"PHYTOLITHOLOGIST":[{"def":"One versed in phytolithology; a paleobotanist.","pos":""}],"PHYTOLITHOLOGY":[{"def":"The branch of science which treats of fossil plants; -- usually called paleobotany, sometimes paleophytology.","pos":""}],"PHYTOLOGICAL":[{"def":"Of or pertaining to phytology; botanical.","pos":""}],"PHYTOLOGIST":[{"def":"One skilled in phytology; a writer on plants; a botanist.","pos":""}],"PHYTOLOGY":[{"def":"The science of plants; a description of the kinds and properties of plants; botany.","pos":""},{"def":"An organic element of a flowering plant; a phyton.","pos":""}],"PHYTON":[{"def":"One of the parts which by their repetition make up a flowering plant, each being a single joint of a stem with its leaf or leaves; a phytomer.","pos":""}],"PHYTONOMY":[{"def":"The science of the origin and growth of plants.","pos":""}],"PHYTOPATHOLOGIST":[{"def":"One skilled in diseases of plants.","pos":""}],"PHYTOPATHOLOGY":[{"def":"The science of diseases to which plants are liable.","pos":""}],"PHYTOPHAGA":[{"def":"A division of Hymenoptera; the sawflies.","pos":""}],"PHYTOPHAGOUS":[{"def":"Feeding on plants; herbivorous; as, a phytophagous animal.","pos":""}],"PHYTOPHAGY":[{"def":"The eating of plants.","pos":""}],"PHYTOPHYSIOLOGY":[{"def":"Vegetable physiology.","pos":""}],"PHYTOTOMIST":[{"def":"One versed in phytotomy.","pos":""}],"PHYTOTOMY":[{"def":"The dissection of plants; vegetable anatomy.","pos":""}],"PHYTOZOARIA":[{"def":"Same as Infusoria.","pos":""},{"def":"A plantlike animal.","pos":""}]}