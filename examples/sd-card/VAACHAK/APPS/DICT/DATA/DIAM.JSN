{"DIAMAGNET":[{"def":"A body having diamagnetic polarity.","pos":""}],"DIAMAGNETIC":[{"def":"Pertaining to, or exhibiting the phenomena of, diamagnetism; taking, or being of a nature to take, a position at right angles to the lines of magnetic force.","pos":""}],"DIAMAGNETICALLY":[{"def":"In the manner of, or according to, diamagnetism.","pos":""}],"DIAMAGNETISM":[{"def":"The science which treats of diamagnetic phenomena, and of the properties of diamagnetic bodies.","pos":""},{"def":"That form or condition of magnetic action which characterizes diamagnetics.","pos":""}],"DIAMANTIFEROUS":[{"def":"Yielding diamonds.","pos":""}],"DIAMETER":[{"def":"The distance through the lower part of the shaft of a column, used as a standard measure for all parts of the order.","pos":""}],"DIAMETRAL":[{"def":"Pertaining to a diameter; diametrical.","pos":""}],"DIAMETRALLY":[{"def":"Of or pertaining to a diameter.","pos":""},{"def":"As remote as possible, as if at the opposite end of a diameter; directly adverse.","pos":""}],"DIAMETRICALLY":[{"def":"In a diametrical manner; directly; as, diametrically opposite.","pos":""}],"DIAMIDE":[{"def":"Any compound containing two amido groups united with one or more acid or negative radicals, -- as distinguished from a diamine.","pos":""}],"DIAMIDO-":[{"def":"A prefix or combining form of Diamine.","pos":""}],"DIAMINE":[{"def":"A compound containing two amido groups united with one or more basic or positive radicals, -- as contrasted with a diamide.","pos":""}],"DIAMOND":[{"def":"A pointed projection, like a four-sided pyramid, used for ornament in lines or groups.","pos":""},{"def":"The infield; the square space, 90 feet on a side, having the bases at its angles.","pos":""}],"DIAMOND STATE":[{"def":"Delaware; -- a nickname alluding to its small size.","pos":""}],"DIAMOND-BACK":[{"def":"The salt-marsh terrapin of the Atlantic coast (Malacoclemmys palustris).","pos":""}],"DIAMOND-SHAPED":[{"def":"Shaped like a diamond or rhombus.","pos":""}],"DIAMONDED":[{"def":"Having figures like a diamond or lozenge.","pos":""},{"def":"Adorned with diamonds; diamondized.","pos":""}],"DIAMONDIZE":[{"def":"To set with diamonds; to adorn; to enrich.","pos":""}],"DIAMYLENE":[{"def":"A liquid hydrocarbon, C10H20, of the ethylene series, regarded as a polymeric form of amylene.","pos":""}]}