{"POOD":[{"def":"A Russian weight, equal to forty Russian pounds or about thirty-six English pounds avoirdupois.","pos":""}],"POODLE":[{"def":"A breed of dogs having curly hair, and often showing remarkable intelligence in the performance of tricks.","pos":""}],"POOH":[{"def":"Pshaw! pish! nonsense! -- an expression of scorn, dislike, or contempt.","pos":""}],"POOH-POOH":[{"def":"To make light of; to treat with derision or contempt, as if by saying pooh! pooh! [Colloq.","pos":""}],"POOKOO":[{"def":"A red African antelope (Kobus Vardoni) allied to the water buck.","pos":""}],"POOL":[{"def":"A small and rather deep collection of (usually) fresh water, as one supplied by a spring, or occurring in the course of a stream; a reservoir for water; as, the pools of Solomon.","pos":""},{"def":"A small body of standing or stagnant water; a puddle.","pos":""}],"POOLER":[{"def":"A stick for stirring a tan vat.","pos":""}],"POOLING":[{"def":"The act of uniting, or an agreement to unite, an aggregation of properties belonging to different persons, with a view to common liabilities or profits.","pos":""}],"POON":[{"def":"A name for several East Indian, or their wood, used for the masts and spars of vessels, as Calophyllum angustifolium, C.","pos":""}],"POONAC":[{"def":"A kind of oil cake prepared from the cocoanut.","pos":""}],"POONAH PAINTING":[{"def":"A style of painting, popular in England in the 19th century, in which a thick opaque color is applied without background and with scarcely any shading, to thin paper, producing flowers, birds, etc.","pos":""}],"POONGA OIL":[{"def":"A kind of oil used in India for lamps, and for boiling with dammar for pitching vessels.","pos":""}],"POOP":[{"def":"To make a noise; to pop; also, to break wind.","pos":""}],"POOPING":[{"def":"The act or shock of striking a vessel's stern by a following wave or vessel.","pos":""}],"POOR":[{"def":"So completely destitute of property as to be entitled to maintenance from the public.","pos":""},{"def":"Destitute of such qualities as are desirable, or might naturally be expected; as: (a) Wanting in fat, plumpness, or fleshiness; lean; emaciated; meager; as, a poor horse, ox, dog, etc.","pos":""}],"POOR-JOHN":[{"def":"A small European fish, similar to the cod, but of inferior quality.","pos":""}],"POOR-SPIRITED":[{"def":"Of a mean spirit; cowardly; base.","pos":""}],"POOR-WILL":[{"def":"A bird of the Western United States (Phalænoptilus Nutalli) allied to the whip-poor-will.","pos":""}],"POOR-WILLIE":[{"def":"The bar-tailed godwit.","pos":""}],"POORBOX":[{"def":"A receptacle in which money given for the poor is placed.","pos":""}],"POORHOUSE":[{"def":"A dwelling for a number of paupers maintained at public expense; an almshouse; a workhouse.","pos":""}],"POORLINESS":[{"def":"The quality or state of being poorly; ill health.","pos":""}],"POORLY":[{"def":"In a poor manner or condition; without plenty, or sufficiency, or suitable provision for comfort; as, to live poorly.","pos":""},{"def":"With little or no success; indifferently; with little profit or advantage; as, to do poorly in business.","pos":""}],"POORNESS":[{"def":"The quality or state of being poor (in any of the senses of the adjective).","pos":""}]}