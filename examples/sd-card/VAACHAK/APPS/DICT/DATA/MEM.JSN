{"MEM-SAHIB":[{"def":"Lady; mistress; -- used by Hindustani-speaking natives in India in addressing European women.","pos":""}],"MEMBER":[{"def":"To remember; to cause to remember; to mention.","pos":""}],"MEMBERED":[{"def":"Having legs of a different tincture from that of the body; -- said of a bird in heraldic representations.","pos":""}],"MEMBERSHIP":[{"def":"The state of being a member.","pos":""},{"def":"The collective body of members, as of a society.","pos":""}],"MEMBRAL":[{"def":"Relating to a member.","pos":""}],"MEMBRANACEOUS":[{"def":"Thin and rather soft or pliable, as the leaves of the rose, peach tree, and aspen poplar.","pos":""}],"MEMBRANE":[{"def":"A thin layer or fold of tissue, usually supported by a fibrous network, serving to cover or line some part or organ, and often secreting or absorbing certain fluids.","pos":""}],"MEMBRANIFEROUS":[{"def":"Having or producing membranes.","pos":""}],"MEMBRANIFORM":[{"def":"Having the form of a membrane or of parchment.","pos":""}],"MEMBRANOLOGY":[{"def":"The science which treats of membranes.","pos":""}],"MEMBRANOUS":[{"def":"Pertaining to, consisting of, or resembling, membrane; as, a membranous covering or lining.","pos":""}],"MEMENTO":[{"def":"A hint, suggestion, token, or memorial, to awaken memory; that which reminds or recalls to memory; a souvenir.","pos":""}],"MEMINNA":[{"def":"A small deerlet, or chevrotain, of India.","pos":""}],"MEMNON":[{"def":"A celebrated Egyptian statue near Thebes, said to have the property of emitting a harplike sound at sunrise.","pos":""}],"MEMOIRIST":[{"def":"A writer of memoirs.","pos":""}],"MEMORABILIA":[{"def":"Things remarkable and worthy of remembrance or record; also, the record of them.","pos":""}],"MEMORABILITY":[{"def":"The quality or state of being memorable.","pos":""}],"MEMORABLE":[{"def":"Worthy to be remembered; very important or remarkable.","pos":""}],"MEMORANDUM":[{"def":"A brief or informal note in writing of some transaction, or an outline of an intended instrument; an instrument drawn up in a brief and compendious form.","pos":""}],"MEMORIAL":[{"def":"Serving to preserve remembrance; commemorative; as, a memorial building.","pos":""},{"def":"Contained in memory; as, a memorial possession.","pos":""}],"MEMORIAL DAY":[{"def":"A day, May 30, appointed for commemorating, by decorating their graves with flowers, by patriotic exercises, etc.","pos":""}],"MEMORIAL ROSE":[{"def":"A Japanese evergreen rose (Rosa wichuraiana) with creeping branches, shining leaves, and single white flowers.","pos":""}],"MEMORIALIST":[{"def":"One who writes or signs a memorial.","pos":""}],"MEMORIALIZE":[{"def":"To address or petition by a memorial; to present a memorial to; as, to memorialize the legislature.","pos":""}],"MEMORIALIZER":[{"def":"One who petitions by a memorial.","pos":""}],"MEMORIST":[{"def":"One who, or that which, causes to be remembered.","pos":""}],"MEMORITER":[{"def":"By, or from, memory.","pos":""}],"MEMORIZE":[{"def":"To cause to be remembered ; hence, to record.","pos":""},{"def":"To commit to memory; to learn by heart.","pos":""}],"MEMORY":[{"def":"The faculty of the mind by which it retains the knowledge of previous thoughts, impressions, or events.","pos":""},{"def":"The reach and positiveness with which a person can remember; the strength and trustworthiness of one's power to reach and represent or to recall the past; as, his memory was never wrong.","pos":""}],"MEMPHIAN":[{"def":"Of or pertaining to the ancient city of Memphis in Egypt; hence, Egyptian; as, Memphian darkness.","pos":""}]}