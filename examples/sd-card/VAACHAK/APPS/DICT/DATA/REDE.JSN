{"REDE":[{"def":"To advise or counsel.","pos":""},{"def":"To interpret; to explain.","pos":""}],"REDEEM":[{"def":"Hence, to rescue and deliver from the bondage of sin and the penalties of God's violated law.","pos":""}],"REDEEMABILITY":[{"def":"Re*deem`a*bil\"i*ty (-*bl\"*t), n.","pos":""}],"REDEEMABLE":[{"def":"Capable of being redeemed; subject to repurchase; held under conditions permitting redemption; as, a pledge securing the payment of money is redeemable.","pos":""},{"def":"Subject to an obligation of redemtion; conditioned upon a promise of redemtion; payable; due; as, bonds, promissory notes, etc.","pos":""}],"REDEEMABLENESS":[{"def":"The quality or state of being redeemable; redeemability.","pos":""}],"REDEEMER":[{"def":"One who redeems.","pos":""},{"def":"Specifically, the Savior of the world, Jesus Christ.","pos":""}],"REDELESS":[{"def":"Without rede or counsel.","pos":""}],"REDELIBERATE":[{"def":"To deliberate again; to reconsider.","pos":""}],"REDELIVER":[{"def":"To deliver or give back; to return.","pos":""},{"def":"To deliver or liberate a second time or again.","pos":""}],"REDELIVERANCE":[{"def":"A second deliverance.","pos":""}],"REDELIVERY":[{"def":"Act of delivering back.","pos":""},{"def":"A second or new delivery or liberation.","pos":""}],"REDEMAND":[{"def":"To demand back; to demand again.","pos":""}],"REDEMISE":[{"def":"To demise back; to convey or transfer back, as an estate.","pos":""}],"REDEMONSTRATE":[{"def":"To demonstrate again, or anew.","pos":""}],"REDEMPTIBLE":[{"def":"Re*demp\"ti*ble (r*dmp\"t*b'l), a.","pos":""}],"REDEMPTIONARY":[{"def":"One who is, or may be, redeemed.","pos":""}],"REDEMPTIONER":[{"def":"One who redeems himself, as from debt or servitude.","pos":""},{"def":"Formerly, one who, wishing to emigrate from Europe to America, sold his services for a stipulated time to pay the expenses of his passage.","pos":""}],"REDEMPTIONIST":[{"def":"A monk of an order founded in 1197; -- so called because the order was especially devoted to the redemption of Christians held in captivity by the Mohammedans.","pos":""}],"REDEMPTIVE":[{"def":"Serving or tending to redeem; redeeming; as, the redemptive work of Christ.","pos":""}],"REDEMPTORIST":[{"def":"One of the Congregation of the Most Holy Redeemer, founded in Naples in 1732 by St.","pos":""}],"REDEMPTORY":[{"def":"Paid for ransom; serving to redeem.","pos":""}],"REDEMPTURE":[{"def":"Re*demp\"ture (-tr; 135), n.","pos":""}],"REDENTED":[{"def":"Formed like the teeth of a saw; indented.","pos":""}],"REDEPOSIT":[{"def":"To deposit again.","pos":""}],"REDESCEND":[{"def":"To descend again.","pos":""}],"REDEVELOP":[{"def":"To develop again; specif.","pos":""},{"def":"to intensify (a developed image), as by bleaching with mercuric chloride and subsequently subjecting anew to a developing agent.","pos":""}]}