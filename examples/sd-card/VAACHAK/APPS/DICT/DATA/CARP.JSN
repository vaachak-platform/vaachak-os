{"CARP":[{"def":"To talk; to speak; to prattle.","pos":""},{"def":"To find fault; to cavil; to censure words or actions without reason or ill-naturedly; -- usually followed by at.","pos":""}],"CARPAL":[{"def":"Of or pertaining to the carpus, or wrist.","pos":""},{"def":"One of the bones or cartilages of the carpus; a carpale.","pos":""}],"CARPALE":[{"def":"One of the bones or cartilages of the carpus; esp.","pos":""}],"CARPATHIAN":[{"def":"Of or pertaining to a range of mountains in Austro-Hungary, called the Carpathians, which partially inclose Hungary on the north, east, and south.","pos":""},{"def":"A simple pistil or single-celled ovary or seed vessel, or one of the parts of a compound pistil, ovary, or seed vessel.","pos":""}],"CARPELLARY":[{"def":"Belonging to, forming, or containing carpels.","pos":""}],"CARPENTER":[{"def":"An artificer who works in timber; a framer and builder of houses, ships, etc.","pos":""}],"CARPENTERING":[{"def":"The occupation or work of a carpenter; the act of workingin timber; carpentry.","pos":""}],"CARPENTRY":[{"def":"The art of cutting, framing, and joining timber, as in the construction of buildings.","pos":""},{"def":"An assemblage of pieces of timber connected by being framed together, as the pieces of a roof, floor, etc.","pos":""}],"CARPER":[{"def":"One who carps; a caviler.","pos":""}],"CARPET":[{"def":"A heavy woven or felted fabric, usually of wool, but also of cotton, hemp, straw, etc.","pos":""},{"def":"A smooth soft covering resembling or suggesting a carpet.","pos":""}],"CARPETBAG":[{"def":"A portable bag for travelers; -- so called because originally made of carpet.","pos":""}],"CARPETBAGGER":[{"def":"An adventurer; -- a term of contempt for a Northern man seeking private gain or political advancement in the southern part of the United States after the Civil War (1865).","pos":""}],"CARPETING":[{"def":"Cloth or materials for carpets; carpets, in general.","pos":""}],"CARPETLESS":[{"def":"Without a carpet.","pos":""}],"CARPETMONGER":[{"def":"One who deals in carpets; a buyer and seller of carpets.","pos":""},{"def":"One fond of pleasure; a gallant.","pos":""}],"CARPETWAY":[{"def":"A border of greensward left round the margin of a plowed field.","pos":""}],"CARPHOLOGY":[{"def":"See Flaccillation.","pos":""}],"CARPING":[{"def":"Fault-finding; censorious caviling.","pos":""}],"CARPINTERO":[{"def":"A california woodpecker (Melanerpes formicivorus), noted for its habit of inserting acorns in holes which it drills in trees.","pos":""}],"CARPOGENIC":[{"def":"Productive of fruit, or causing fruit to be developed.","pos":""}],"CARPOLITE":[{"def":"A general term for a fossil fruit, nut, or seed.","pos":""}],"CARPOLOGICAL":[{"def":"Of or pertaining to carpology.","pos":""}],"CARPOLOGIST":[{"def":"One who describes fruits; one versed in carpology.","pos":""}],"CARPOLOGY":[{"def":"That branch of botany which relates to the structure of seeds and fruit.","pos":""}],"CARPOPHAGOUS":[{"def":"Living on fruits; fruit-consuming.","pos":""}],"CARPOPHORE":[{"def":"A slender prolongation of the receptacle as an axis between the carpels, as in Geranium and many umbelliferous plants.","pos":""}],"CARPOPHYLL":[{"def":"A leaf converted into a fruit or a constituent portion of a fruit; a carpel.","pos":""}],"CARPOPHYTE":[{"def":"A flowerless plant which forms a true fruit as the result of fertilization, as the red seaweeds, the Ascomycetes, etc.","pos":""}],"CARPOSPORE":[{"def":"A kind of spore formed in the conceptacles of red algæ.","pos":""}],"CARPUS":[{"def":"The wrist; the bones or cartilages between the forearm, or antibrachium, and the hand or forefoot; in man, consisting of eight short bones disposed in two rows.","pos":""}]}