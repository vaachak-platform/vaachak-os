{"LUDDITE":[{"def":"One of a number of riotous persons in England, who for six years (1811-17) tried to prevent the use of labor-saving machinery by breaking it, burning factories, etc.","pos":""}],"LUDIBRIOUS":[{"def":"Sportive; ridiculous; wanton.","pos":""}],"LUDICROUS":[{"def":"Adapted to excite laughter, without scorn or contempt; sportive.","pos":""}],"LUDIFICATION":[{"def":"The act of deriding.","pos":""}],"LUDIFICATORY":[{"def":"Making sport; tending to excite derision.","pos":""}],"LUDLAMITE":[{"def":"A mineral occurring in small, green, transparent, monoclinic crystals.","pos":""}],"LUDLOW GROUP":[{"def":"A subdivision of the British Upper Silurian lying below the Old Red Sandstone; -- so named from the Ludlow, in Western England.","pos":""}],"LUDWIGITE":[{"def":"A borate of iron and magnesia, occurring in fibrous masses of a blackish green color.","pos":""}]}