{"NEPA":[{"def":"A genus of aquatic hemipterus insects.","pos":""}],"NEPAULESE":[{"def":"Of or pertaining to Nepaul, a kingdom in Northern Hindostan.","pos":""},{"def":"A native or natives of Nepaul.","pos":""}],"NEPENTHE":[{"def":"A drug used by the ancients to give relief from pain and sorrow; -- by some supposed to have been opium or hasheesh.","pos":""}],"NEPENTHES":[{"def":"A genus of climbing plants found in India, Malaya, etc.","pos":""}],"NEPETA":[{"def":"A genus of labiate plants, including the catnip and ground ivy.","pos":""}],"NEPHALISM":[{"def":"Total abstinence from spirituous liquor.","pos":""}],"NEPHALIST":[{"def":"One who advocates or practices nephalism.","pos":""},{"def":"A mineral occuring at Vesuvius, in glassy agonal crystals; also elsewhere, in grayish or greenish masses having a greasy luster, as the variety elæolite.","pos":""}],"NEPHELODOMETER":[{"def":"An instrument for reckoning the distances or velocities of clouds.","pos":""}],"NEPHELOMETER":[{"def":"An instrument for measuring or registering the amount of cloudiness.","pos":""}],"NEPHEW":[{"def":"A grandson or grandchild, or remoter lineal descendant.","pos":""}],"NEPHOSCOPE":[{"def":"An instrument for observing the clouds and their velocity.","pos":""},{"def":"Neuralgia of the kidneys; a disease characterized by pain in the region of the kidneys without any structural lesion of the latter.","pos":""}],"NEPHRIDIAL":[{"def":"of or pertaining to a nephridium.","pos":""}],"NEPHRIDIUM":[{"def":"A segmental tubule; one of the tubules of the primitive urinogenital organs; a segmental organ.","pos":""}],"NEPHRITE":[{"def":"A hard compact mineral, of a dark green color, formerly worn as a remedy for diseases of the kidneys, whence its name; kidney stone; a kind of jade.","pos":""}],"NEPHRITIC":[{"def":"A medicine adapted to relieve or cure disease of the kidneys.","pos":""}],"NEPHRITIS":[{"def":"An inflammation of the kidneys.","pos":""}],"NEPHROLITHIC":[{"def":"of or pertaining to gravel, or renal calculi.","pos":""}],"NEPHROLOGY":[{"def":"A treatise on, or the science which treats of, the kidneys, and their structure and functions.","pos":""}],"NEPHROSTOME":[{"def":"The funnelshaped opening of a nephridium into the body cavity.","pos":""}],"NEPHROTOMY":[{"def":"Extraction of stone from the kidney by cutting.","pos":""}],"NEPOTAL":[{"def":"Of or relating to a nephew.","pos":""}],"NEPOTIC":[{"def":"Of or pertaining to npotism.","pos":""}],"NEPOTISM":[{"def":"Undue attachment to relations; favoritism shown to members of one's family; bestowal of patronage in consideration of relationship, rather than of merit or of legal claim.","pos":""}],"NEPOTIST":[{"def":"One who practices nepotism.","pos":""}],"NEPTUNE":[{"def":"The son of Saturn and Ops, the god of the waters, especially of the sea.","pos":""},{"def":"The remotest known planet of our system, discovered -- as a result of the computations of Leverrier, of Paris -- by Galle, of Berlin, September 23, 1846.","pos":""}],"NEPTUNIAN":[{"def":"Formed by water or aqueous solution; as, Neptunian rocks.","pos":""},{"def":"One who adopts the neptunian theory.","pos":""}],"NEPTUNICENTRIC":[{"def":"As seen from Neptune, or having Neptune as a center; as, Neptunicentric longitude or force.","pos":""}],"NEPTUNIUM":[{"def":"A new metallic element, of doubtful genuineness and uncertain indentification, said to exist in certain minerals, as columbite.","pos":""}]}