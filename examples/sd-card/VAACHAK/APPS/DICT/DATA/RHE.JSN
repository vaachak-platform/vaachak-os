{"RHEA":[{"def":"The ramie or grass-cloth plant.","pos":""}],"RHEAE":[{"def":"A suborder of struthious birds including the rheas.","pos":"noun"}],"RHEIC":[{"def":"Pertaining to, or designating, an acid (commonly called chrysophanic acid) found in rhubarb (Rheum).","pos":""}],"RHEIN":[{"def":"Chrysophanic acid.","pos":""}],"RHEINBERRY":[{"def":"One of the berries or drupes of the European buckthorn; also, the buckthorn itself.","pos":""}],"RHEMATIC":[{"def":"Having a verb for its base; derived from a verb; as, rhematic adjectives.","pos":""}],"RHEMISH":[{"def":"Of or pertaining to Rheimis, or Reima, in France.","pos":""}],"RHENISH":[{"def":"Of or pertaining to the river Rhine; as, Rhenish wine.","pos":""}],"RHEOCHORD":[{"def":"A metallic wire used for regulating the resistance of a circuit, or varying the strength of an electric current, by inserting a greater or less length of it in the circuit.","pos":""}],"RHEOCRAT":[{"def":"A kind of motor speed controller permitting of very gradual variation in speed and of reverse.","pos":""}],"RHEOMETER":[{"def":"An instrument for measuring currents, especially the force or intensity of electrical currents; a galvanometer.","pos":""},{"def":"An instrument for measuring the velocity of the blood current in the arteries.","pos":""}],"RHEOMETRIC":[{"def":"Of or pertaining to a rheometer or rheometry.","pos":""}],"RHEOMETRY":[{"def":"The calculus; fluxions.","pos":""}],"RHEOMOTOR":[{"def":"Any apparatus by which an electrical current is originated.","pos":""}],"RHEOSCOPE":[{"def":"An instrument for detecting the presence or movement of currents, as of electricity.","pos":""}],"RHEOSTAT":[{"def":"A contrivance for adjusting or regulating the strength of electrical currents, operating usually by the intercalation of resistance which can be varied at will.","pos":""}],"RHEOTOME":[{"def":"An instrument which periodically or otherwise interrupts an electric current.","pos":""}],"RHEOTROPE":[{"def":"An instrument for reversing the direction of an electric current.","pos":""}],"RHESUS":[{"def":"A monkey; the bhunder.","pos":""}],"RHETIAN":[{"def":"Pertaining to the ancient Rhæti, or Rhætians, or to Rhætia, their country; as, the Rhetian Alps, now the country of Tyrol and the Grisons.","pos":""}],"RHETIZITE":[{"def":"Same as Rhætizite.","pos":""}],"RHETORIC":[{"def":"The art of composition; especially, elegant composition in prose.","pos":""},{"def":"Oratory; the art of speaking with propriety, elegance, and force.","pos":""}],"RHETORICAL":[{"def":"Of or pertaining to rhetoric; according to, or exhibiting, rhetoric; oratorical; as, the rhetorical art; a rhetorical treatise; a rhetorical flourish.","pos":""}],"RHETORICATE":[{"def":"To play the orator.","pos":""}],"RHETORICATION":[{"def":"Rhetorical amplification.","pos":""}],"RHETORICIAN":[{"def":"One well versed in the rules and principles of rhetoric.","pos":""},{"def":"A teacher of rhetoric.","pos":""}],"RHETORIZE":[{"def":"To play the orator.","pos":""}],"RHEUM":[{"def":"A genus of plants.","pos":""}],"RHEUMATIC":[{"def":"Of or pertaining to rheumatism; as, rheumatic pains or affections; affected with rheumatism; as, a rheumatic old man; causing rheumatism; as, a rheumatic day.","pos":""}],"RHEUMATISM":[{"def":"A general disease characterized by painful, often multiple, local inflammations, usually affecting the joints and muscles, but also extending sometimes to the deeper organs, as the heart.","pos":""}],"RHEUMATISMAL":[{"def":"Of or pertaining to rheumatism.","pos":""}],"RHEUMATISMOID":[{"def":"Of or resembling rheum or rheumatism.","pos":""}],"RHEUMIC":[{"def":"Pertaining to, or characterized by, rheum.","pos":""}],"RHEUMIDES":[{"def":"The class of skin disease developed by the dartrous diathesis.","pos":"noun"}],"RHEUMY":[{"def":"Of or pertaining to rheum; abounding in, or causing, rheum; affected with rheum.","pos":""}]}