{"LIP":[{"def":"One of the edges of the aperture of a univalve shell.","pos":""}],"LIPAEMIA":[{"def":"A condition in which fat occurs in the blood.","pos":""}],"LIPANS":[{"def":"A tribe of North American Inedians, inhabiting the northern part of Mexico.","pos":""}],"LIPARIAN":[{"def":"Any species of a family (Liparidæ) of destructive bombycid moths, as the tussock moths.","pos":""}],"LIPARITE":[{"def":"A quartzose trachyte; rhyolite.","pos":""}],"LIPIC":[{"def":"Pertaining to, or derived from, fat.","pos":""}],"LIPLESS":[{"def":", Having no lips.","pos":""}],"LIPOCEPHALA":[{"def":"Same as Lamellibranchia.","pos":""}],"LIPOCHRIN":[{"def":"A yellow coloring matter, soluble in ether, contained in the small round fat drops in the retinal epithelium cells.","pos":""}],"LIPOGRAM":[{"def":"A writing composed of words not having a certain letters; -- as in the Odyssey of Tryphiodorus there was no A in the first book, no B in the second, and so on.","pos":""}],"LIPOGRAMMATIC":[{"def":"Omitting a letter; composed of words not having a certain letter or letters; as, lipogrammatic writings.","pos":""}],"LIPOGRAMMATIST":[{"def":"One who makes a lipogram.","pos":""}],"LIPOMA":[{"def":"A tumor consisting of fat or adipose tissue.","pos":""}],"LIPOTHYMIC":[{"def":"Tending to swoon; fainting.","pos":""}],"LIPOTHYMOUS":[{"def":"Pertaining, or given, to swooning; fainting.","pos":""}],"LIPOTHYMY":[{"def":"A fainting; a swoon.","pos":""}],"LIPPED":[{"def":"Having a lip or lips; having a raised or rounded edge resembling the lip; -- often used in composition; as, thick-lipped, thin-lipped, etc.","pos":""}],"LIPPITUDE":[{"def":"Soreness of eyes; the state of being blear-eyes; blearedness.","pos":""}],"LIPYL":[{"def":"A hypothetical radical of glycerin.","pos":""}]}