{"METOL":[{"def":"A whitish soluble powder used as a developer in photography.","pos":""}],"METONIC":[{"def":"Pertaining to, or discovered by, Meton, the Athenian.","pos":""},{"def":"Used by way of metonymy.","pos":""}],"METONYMY":[{"def":"A trope in which one word is put for another that suggests it; as, we say, a man keeps a good table instead of good provisions; we read Virgil, that is, his poems; a man has a warm heart, that is, warm affections.","pos":""}],"METOPE":[{"def":"The space between two triglyphs of the Doric frieze, which, among the ancients, was often adorned with carved work.","pos":""},{"def":"The face of a crab.","pos":""}],"METOPIC":[{"def":"Of or pertaining to the forehead or frontal bones; frontal; as, the metopic suture.","pos":""}],"METOPOMANCY":[{"def":"Fortune telling by physiognomy.","pos":""},{"def":"Of or relating to metoposcopy.","pos":""}],"METOPOSCOPIST":[{"def":"One versed in metoposcopy.","pos":""}],"METOPOSCOPY":[{"def":"The study of physiognomy; the art of discovering the character of persons by their features, or the lines of the face.","pos":""}],"METOSTEON":[{"def":"The postero-lateral ossification in the sternum of birds; also, the part resulting from such ossification.","pos":""}]}