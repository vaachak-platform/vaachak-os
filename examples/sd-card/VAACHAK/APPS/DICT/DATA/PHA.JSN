{"PHACELLUS":[{"def":"One of the filaments on the inner surface of the gastric cavity of certain jellyfishes.","pos":""}],"PHACOID":[{"def":"Resembling a lentil; lenticular.","pos":""}],"PHACOLITE":[{"def":"A colorless variety of chabazite; the original was from Leipa, in Bohemia.","pos":""}],"PHACOPS":[{"def":"A genus of trilobites found in the Silurian and Devonian formations.","pos":""}],"PHAEACIAN":[{"def":"Of or pertaining to the Phæacians, a fabulous seafaring people fond of the feast, the lyre, and the dance, mentioned by Homer.","pos":""}],"PHAENOGAM":[{"def":"Any plant of the class Phænogamia.","pos":""}],"PHAENOGAMIA":[{"def":"The class of flowering plants including all which have true flowers with distinct floral organs; phanerogamia.","pos":""},{"def":"Same as Phænogamous.","pos":""}],"PHAENOGAMOUS":[{"def":"Having true flowers with with distinct floral organs; flowering.","pos":""}],"PHAEOSPORE":[{"def":"A brownish zoöspore, characteristic of an order (Phæosporeæ) of dark green or olive-colored algæ.","pos":""}],"PHAETHON":[{"def":"The son of Helios (Phoebus), that is, the son of light, or of the sun.","pos":""},{"def":"A genus of oceanic birds including the tropic birds.","pos":""}],"PHAETON":[{"def":"A handsome American butterfly (Euphydryas, or Melitæa, Phaëton).","pos":""}],"PHAGEDENA":[{"def":"Of, like, or pertaining to, phagedena; used in the treatment of phagedena; as, a phagedenic ulcer or medicine.","pos":""},{"def":"A phagedenic medicine.","pos":""}],"PHAGOCYTE":[{"def":"A leucocyte which plays a part in retrogressive processes by taking up (eating), in the form of fine granules, the parts to be removed.","pos":""}],"PHAINOPEPLA":[{"def":"A small crested passerine bird (Phaïnopepla nitens), native of Mexico and the Southern United States.","pos":""}],"PHAKOSCOPE":[{"def":"An instrument for studying the mechanism of accommodation.","pos":""}],"PHALAENA":[{"def":"A linnæan genus which included the moths in general.","pos":""}],"PHALAENID":[{"def":"Any moth of the family Phalænidæ, of which the cankerworms are examples; a geometrid.","pos":""},{"def":"Of or pertaining to the phalanges.","pos":""}],"PHALANGER":[{"def":"Any marsupial belonging to Phalangista, Cuscus, Petaurus, and other genera of the family Phalangistidæ.","pos":""}],"PHALANGES":[{"def":"PHALANGIAL; PHALANGIAN Pha*lan\"gi*al, Pha*lan\"gi*an, a.","pos":""}],"PHALANGID":[{"def":"One of the Phalangoidea.","pos":""}],"PHALANGIOUS":[{"def":"Of or pertaining to Phalangoidea.","pos":""}],"PHALANGIST":[{"def":"Any arboreal marsupial of the genus Phalangista.","pos":""},{"def":"Same as Phalangist.","pos":""}],"PHALANGITE":[{"def":"A soldier belonging to a phalanx.","pos":""}],"PHALANGOIDEA":[{"def":"A division of Arachnoidea, including the daddy longlegs or harvestman (Phalangium) and many similar kinds.","pos":""}],"PHALANSTERIAN":[{"def":"Of or pertaining to phalansterianism.","pos":""}],"PHALANSTERY":[{"def":"An association or community organized on the plan of Fourier.","pos":""},{"def":"The dwelling house of a Fourierite community.","pos":""}],"PHALANX":[{"def":"A body of heavy-armed infantry formed in ranks and files close and deep.","pos":""},{"def":"One of the digital bones of the hand or foot, beyond the metacarpus or metatarsus; an internode.","pos":""}],"PHALAROPE":[{"def":"Any species of Phalaropus and allied genera of small wading birds (Grallæ), having lobate toes.","pos":""}],"PHALLIC":[{"def":"Of or pertaining to the phallus, or to phallism.","pos":""}],"PHALLISM":[{"def":"The worship of the generative principle in nature, symbolized by the phallus.","pos":""}],"PHALLUS":[{"def":"The penis or clitoris, or the embryonic or primitive organ from which either may be derived.","pos":""},{"def":"A genus of fungi which have a fetid and disgusting odor; the stinkhorn.","pos":""}],"PHANAR":[{"def":"A quarter of Constantinople which, after the Turkish conquest of the city, became the chief Greek quarter; hence, the Greek officials of Turkey, or phanariots, as a class.","pos":""},{"def":"One of the Greeks of Constantinople who after the Turkish conquest became powerful in clerical and other offices under Turkish patronage.","pos":""}],"PHANERITE":[{"def":"Evident; visible.","pos":""}],"PHANEROCARPAE":[{"def":"Same as Acraspeda.","pos":""}],"PHANEROCODONIC":[{"def":"Having an umbrella-shaped or bell-shaped body, with a wide, open cavity beneath; -- said of certain jellyfishes.","pos":""}],"PHANEROCRYSTALLINE":[{"def":"Distinctly crystalline; -- used of rocks.","pos":""}],"PHANERODACTYLA":[{"def":"Same as Saururæ.","pos":""}],"PHANEROGAMIA":[{"def":"That one of the two primary divisions of the vegetable kingdom which contains the phanerogamic, or flowering, plants.","pos":""}],"PHANEROGAMIAN":[{"def":"Having visible flowers containing distinct stamens and pistils; -- said of plants.","pos":""}],"PHANEROGLOSSAL":[{"def":"Having a conspicious tongue; -- said of certain reptiles and insects.","pos":""}],"PHANTASCOPE":[{"def":"An optical instrument or toy, resembling the phenakistoscope, and illustrating the same principle; -- called also phantasmascope.","pos":""}],"PHANTASM":[{"def":"An image formed by the mind, and supposed to be real or material; a shadowy or airy appearance; sometimes, an optical illusion; a phantom; a dream.","pos":""},{"def":"A mental image or representation of a real object; a fancy; a notion.","pos":""}],"PHANTASMAGORIA":[{"def":"An optical effect produced by a magic lantern.","pos":""},{"def":"The apparatus by which such an effect is produced.","pos":""}],"PHANTASMAGORIAL":[{"def":"Of, relating to, or resembling phantasmagoria; phantasmagoric.","pos":""}],"PHANTASMAGORIC":[{"def":"Of or pertaining to phantasmagoria; phantasmagorial.","pos":""}],"PHANTASMAGORY":[{"def":"See Phantasmagoria.","pos":""}],"PHANTASMAL":[{"def":"Pertaining to, of the nature of, or resembling, a phantasm; spectral; illusive.","pos":""}],"PHANTASMASCOPE":[{"def":"See Phantascope.","pos":""}],"PHANTASMATICAL":[{"def":"Phan`tas*mat\"ic*al, a.","pos":""}],"PHANTASMATOGRAPHY":[{"def":"A description of celestial phenomena, as rainbows, etc.","pos":""}],"PHANTASY":[{"def":"See Fantasy, and Fancy.","pos":""}],"PHANTOM":[{"def":"That which has only an apparent existence; an apparition; a specter; a phantasm; a sprite; an airy spirit; an ideal image.","pos":""}],"PHANTOM CIRCUIT":[{"def":"The equivalent of an additional circuit or wire, in reality not existing, obtained by certain arrangements of real circuits, as in some multiplex telegraph systems.","pos":""}],"PHARAOH":[{"def":"A title by which the sovereigns of ancient Egypt were designated.","pos":""}],"PHARAONIC":[{"def":"Of or pertaining to the Pharaohs, or kings of ancient Egypt.","pos":""}],"PHARE":[{"def":"A beacon tower; a lighthouse.","pos":""},{"def":"Hence, a harbor.","pos":""}],"PHARISAISM":[{"def":"The notions, doctrines, and conduct of the Pharisees, as a sect.","pos":""},{"def":"Rigid observance of external forms of religion, without genuine piety; hypocrisy in religion; a censorious, self-righteous spirit in matters of morals or manners.","pos":""}],"PHARISEAN":[{"def":"Following the practice of Pharisees; Pharisaic.","pos":""}],"PHARISEE":[{"def":"One of a sect or party among the Jews, noted for a strict and formal observance of rites and ceremonies and of the traditions of the elders, and whose pretensions to superior sanctity led them to separate themselves from the other Jews.","pos":""}],"PHARISEEISM":[{"def":"Of or pertaining to the knowledge or art of pharmacy, or to the art of preparing medicines according to the rules or formulas of pharmacy; as, pharmaceutical preparations.","pos":""}],"PHARMACEUTICS":[{"def":"The science of preparing medicines.","pos":""}],"PHARMACEUTIST":[{"def":"One skilled in pharmacy; a druggist.","pos":""}],"PHARMACIST":[{"def":"One skilled in pharmacy; a pharmaceutist; a druggist.","pos":""}],"PHARMACODYMANICS":[{"def":"That branch of pharmacology which treats of the action and the effects of medicines.","pos":""}],"PHARMACODYNAMICS":[{"def":"That branch of pharmacology which considers the mode of action, and the effects, of medicines.","pos":""}],"PHARMACOGNOSIS":[{"def":"That branch of pharmacology which treats of unprepared medicines or simples; -- called also pharmacography, and pharmacomathy.","pos":""}],"PHARMACOGRAPHY":[{"def":"See Pharmacognosis.","pos":""}],"PHARMACOLITE":[{"def":"A hydrous arsenate of lime, usually occurring in silky fibers of a white or grayish color.","pos":""}],"PHARMACOLOGIST":[{"def":"One skilled in pharmacology.","pos":""}],"PHARMACOLOGY":[{"def":"Knowledge of drugs or medicines; the art of preparing medicines.","pos":""},{"def":"A treatise on the art of preparing medicines.","pos":""}],"PHARMACOMATHY":[{"def":"See Pharmacognosis.","pos":""}],"PHARMACON":[{"def":"A medicine or drug; also, a poison.","pos":""}],"PHARMACOPOEIA":[{"def":"A book or treatise describing the drugs, preparations, etc.","pos":""},{"def":"A chemical laboratory.","pos":""}],"PHARMACOPOLIST":[{"def":"One who sells medicines; an apothecary.","pos":""}],"PHARMACOSIDERITE":[{"def":"A hydrous arsenate of iron occurring in green or yellowish green cubic crystals; cube ore.","pos":""}],"PHARMACY":[{"def":"The art or practice of preparing and preserving drugs, and of compounding and dispensing medicines according to prescriptions of physicians; the occupation of an apothecary or a pharmaceutical chemist.","pos":""},{"def":"A place where medicines are compounded; a drug store; an apothecary's shop.","pos":""}],"PHARO":[{"def":"A pharos; a lighthouse.","pos":""}],"PHAROLOGY":[{"def":"The art or science which treats of lighthouses and signal lights.","pos":""}],"PHAROS":[{"def":"A lighthouse or beacon for the guidance of seamen.","pos":""}],"PHARYNGEAL":[{"def":"Of or pertaining to the pharynx; in the region of the pharynx.","pos":""}],"PHARYNGITIS":[{"def":"Inflammation of the pharynx.","pos":""}],"PHARYNGOBRANCHIAL":[{"def":"Of or pertaining to the pharynx and the branchiæ; -- applied especially to the dorsal elements in the branchial arches of fishes.","pos":""},{"def":"A pharyngobranchial, or upper pharyngeal, bone or cartilage.","pos":""}],"PHARYNGOBRANCHII":[{"def":"Same as Leptocardia.","pos":""}],"PHARYNGOGNATHI":[{"def":"A division of fishes in which the lower pharyngeal bones are united.","pos":""}],"PHARYNGOLARYNGEAL":[{"def":"Of or pertaining both to pharynx and the larynx.","pos":""}],"PHARYNGOPNEUSTA":[{"def":"A group of invertebrates including the Tunicata and Enteropneusta.","pos":""}],"PHARYNGOTOME":[{"def":"An instrument for incising or scarifying the tonsils, etc.","pos":""}],"PHARYNX":[{"def":"The part of the alimentary canal between the cavity of the mouth and the esophagus.","pos":""}],"PHASCOLOME":[{"def":"A marsupial of the genus Phascolomys; a wombat.","pos":""}],"PHASE":[{"def":"A particular appearance or state in a regularly recurring cycle of changes with respect to quantity of illumination or form of enlightened disk; as, the phases of the moon or planets.","pos":""}],"PHASE ANGLE":[{"def":"The angle expressing phase relation.","pos":""}],"PHASE CONVERTER":[{"def":"A machine for converting an alternating current into an alternating current of a different number of phases and the same frequency.","pos":""}],"PHASE DISPLACEMENT":[{"def":"A charge of phase whereby an alternating current attains its maximum later or earlier.","pos":""}],"PHASE RULE":[{"def":"A generalization with regard to systems of chemical equilibrium, discovered by Prof.","pos":""}],"PHASE SPLITTER":[{"def":"A device by which a single-phase current is split into two or more currents differing in phase.","pos":""}],"PHASE SPLITTING":[{"def":"The dephasing of the two parts of a single alternating current in two dissimilar branches of a given circuit.","pos":""}],"PHASEL":[{"def":"The French bean, or kidney bean.","pos":""}],"PHASELESS":[{"def":"Without a phase, or visible form.","pos":""},{"def":"A device for measuring the difference in phase of two alternating currents of electromotive forces.","pos":""}],"PHASEOLUS":[{"def":"A genus of leguminous plants, including the Lima bean, the kidney bean, the scarlet runner, etc.","pos":""}],"PHASEOMANNITE":[{"def":"Same as Inosite.","pos":""}],"PHASING":[{"def":"Pertaining to phase or differences of phase.","pos":""}],"PHASING CURRENT":[{"def":"The momentary current between two alternating-current generators when juxtaposed in parallel and not agreeing exactly in phase or period.","pos":""}],"PHASING TRANSFORMER":[{"def":"Any of several transformers (there must be at least two) for changing phase.","pos":""}],"PHASIS":[{"def":"An apparition; a phantom; an appearance.","pos":""}],"PHASMID":[{"def":"Any orthopterous insect of the family Phasmidæ, as a leaf insect or a stick insect.","pos":""}],"PHASSACHATE":[{"def":"The lead-colored agate; -- so called in reference to its color.","pos":""}],"PHATAGIN":[{"def":"The long-tailed pangolin (Manis tetradactyla); -- called also ipi.","pos":""}]}