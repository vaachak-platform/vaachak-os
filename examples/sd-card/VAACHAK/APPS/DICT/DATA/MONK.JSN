{"MONK":[{"def":"A blotch or spot of ink on a printed page, caused by the ink not being properly distributed.","pos":""}],"MONK'S SEAM":[{"def":"An extra middle seam made at the junction of two breadths of canvas, ordinarily joined by only two rows of stitches.","pos":""},{"def":"A prefix signifying one, single, alone; as, monocarp, monopoly; (Chem.","pos":""}],"MONKERY":[{"def":"The life of monks; monastic life; monastic usage or customs; -- now usually applied by way of reproach.","pos":""},{"def":"A collective body of monks.","pos":""}],"MONKEY":[{"def":"A term of disapproval, ridicule, or contempt, as for mischievous child.","pos":""},{"def":"The weight or hammer of a pile driver, that is, a very heavy mass of iron, which, being raised on high, falls on the head of the pile, and drives it into the earth; the falling weight of a drop hammer used in forging.","pos":""}],"MONKEY'S PUZZLE":[{"def":"A lofty coniferous Chilian tree (Araucaria imbricata), the branches of which are so crowded and intertwisted \"as to puzzle a monkey to climb.","pos":""}],"MONKEY-BREAD":[{"def":"The fruit of the Adansonia digitata; also, the tree.","pos":""}],"MONKEY-POT":[{"def":"The fruit of two South American trees (Lecythis Ollaria, and L.","pos":""}],"MONKEYTAIL":[{"def":"A short, round iron bar or lever used in naval gunnery.","pos":""}],"MONKFLOWER":[{"def":"A name of certain curious orchids which bear three kinds of flowers formerly referred to three genera, but now ascertained to be sexually different forms of the same genus (Catasetum tridentatum, etc.","pos":""}],"MONKHOOD":[{"def":"The character or condition of a monk.","pos":""},{"def":"Monks, regarded collectively.","pos":""}],"MONKISH":[{"def":"Like a monk, or pertaining to monks; monastic; as, monkish manners; monkish dress; monkish solitude.","pos":""}],"MONKLY":[{"def":"Like, or suitable to, a monk.","pos":""}],"MONKSHOOD":[{"def":"A plant of the genus Aconitum; aconite.","pos":""}]}