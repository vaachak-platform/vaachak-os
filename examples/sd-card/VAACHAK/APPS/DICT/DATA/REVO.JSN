{"REVOCABILITY":[{"def":"The quality of being revocable; as, the revocability of a law.","pos":""}],"REVOCABLE":[{"def":"Capable of being revoked; as, a revocable edict or grant; a revocable covenant.","pos":""}],"REVOCATE":[{"def":"To recall; to call back.","pos":""}],"REVOCATION":[{"def":"The act of calling back, or the state of being recalled; recall.","pos":""},{"def":"The act by which one, having the right, annuls an act done, a power or authority given, or a license, gift, or benefit conferred; repeal; reversal; as, the revocation of an edict, a power, a will, or a license.","pos":""}],"REVOCATORY":[{"def":"Of or pertaining to revocation; tending to, or involving, a revocation; revoking; recalling.","pos":""}],"REVOICE":[{"def":"To refurnish with a voice; to refit, as an organ pipe, so as to restore its tone.","pos":""}],"REVOKE":[{"def":"To call or bring back; to recall.","pos":""},{"def":"Hence, to annul, by recalling or taking back; to repeal; to rescind; to cancel; to reverse, as anything granted by a special act; as, , to revoke a will, a license, a grant, a permission, a law, or the like.","pos":""}],"REVOKER":[{"def":"One who revokes.","pos":""}],"REVOKINGLY":[{"def":"By way of revocation.","pos":""}],"REVOLT":[{"def":"To turn away; to abandon or reject something; specifically, to turn away, or shrink, with abhorrence.","pos":""},{"def":"Hence, to be faithless; to desert one party or leader for another; especially, to renounce allegiance or subjection; to rise against a government; to rebel.","pos":""}],"REVOLTER":[{"def":"One who revolts.","pos":""}],"REVOLTING":[{"def":"Causing abhorrence mixed with disgust; exciting extreme repugnance; loathsome; as, revolting cruelty.","pos":""}],"REVOLUBLE":[{"def":"Capable of revolving; rotatory; revolving.","pos":""}],"REVOLUTE":[{"def":"Rolled backward or downward.","pos":""}],"REVOLUTION":[{"def":"The act of revolving, or turning round on an axis or a center; the motion of a body round a fixed point or line; rotation; as, the revolution of a wheel, of a top, of the earth on its axis, etc.","pos":""},{"def":"Return to a point before occupied, or to a point relatively the same; a rolling back; return; as, revolution in an ellipse or spiral.","pos":""}],"REVOLUTIONARY":[{"def":"Of or pertaining to a revolution in government; tending to, or promoting, revolution; as, revolutionary war; revolutionary measures; revolutionary agitators.","pos":""}],"REVOLUTIONER":[{"def":"One who is engaged in effecting a revolution; a revolutionist.","pos":""}],"REVOLUTIONISM":[{"def":"The state of being in revolution; revolutionary doctrines or principles.","pos":""}],"REVOLUTIONIST":[{"def":"One engaged in effecting a change of government; a favorer of revolution.","pos":""}],"REVOLUTIONIZE":[{"def":"To change completely, as by a revolution; as, to revolutionize a government.","pos":""}],"REVOLUTIVE":[{"def":"Inclined to revolve things in the mind; meditative.","pos":""}],"REVOLVABLE":[{"def":"That may be revolved.","pos":""}],"REVOLVE":[{"def":"To turn or roll round on, or as on, an axis, like a wheel; to rotate, -- which is the more specific word in this sense.","pos":""},{"def":"To move in a curved path round a center; as, the planets revolve round the sun.","pos":""}],"REVOLVEMENT":[{"def":"Act of revolving.","pos":""}],"REVOLVENCY":[{"def":"The act or state of revolving; revolution.","pos":""}],"REVOLVER":[{"def":"One who, or that which, revolves; specifically, a firearm ( commonly a pistol) with several chambers or barrels so arranged as to revolve on an axis, and be discharged in succession by the same lock; a repeater.","pos":""}],"REVOLVING":[{"def":"Making a revolution or revolutions; rotating; -- used also figuratively of time, seasons, etc.","pos":""}]}