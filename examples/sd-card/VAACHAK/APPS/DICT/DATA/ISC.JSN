{"ISCHIAL":[{"def":"Of or pertaining to the ischium or hip; ischiac; ischiadic; ischiatic.","pos":""}],"ISCHIOCAPSULAR":[{"def":"Of or pertaining to the ischium and the capsule of the hip joint; as, the ischiocapsular ligament.","pos":""}],"ISCHIOCERITE":[{"def":"The third joint or the antennæ of the Crustacea.","pos":""},{"def":"The ventral and posterior of the three principal bones composing either half of the pelvis; seat bone; the huckle bone.","pos":""}],"ISCHIOPODITE":[{"def":"The third joint of the typical appendages of Crustacea.","pos":""}],"ISCHIORECTAL":[{"def":"Of or pertaining to the region between the rectum and ishial tuberosity.","pos":""}],"ISCHURETIC":[{"def":"Having the quality of relieving ischury.","pos":""},{"def":"An ischuretic medicine.","pos":""}],"ISCHURY":[{"def":"A retention or suppression of urine.","pos":""}]}