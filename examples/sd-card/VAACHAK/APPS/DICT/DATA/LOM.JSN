{"LOMA":[{"def":"A lobe; a membranous fringe or flap.","pos":""}],"LOMATINOUS":[{"def":"Furnished with lobes or flaps.","pos":""}],"LOMBARD":[{"def":"Of or pertaining to Lombardy, or the inhabitants of Lombardy.","pos":""}],"LOMBARDEER":[{"def":"A bank or a pawnbroker's shop.","pos":""},{"def":"A public institution for lending money to the poor at a moderate interest, upon articles deposited and pledged; -- called also mont de piété.","pos":""}],"LOMBARDIC":[{"def":"Of or pertaining to Lombardy of the Lombards.","pos":""}],"LOMENT":[{"def":"An elongated pod, consisting, like the legume, of two valves, but divided transversely into small cells, each containing a single seed.","pos":""}],"LOMENTACEOUS":[{"def":"Of the nature of a loment; having fruits like loments.","pos":""}],"LOMONITE":[{"def":"Same as Laumontite.","pos":""}]}