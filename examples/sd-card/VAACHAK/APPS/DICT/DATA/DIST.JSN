{"DISTAD":[{"def":"Toward a distal part; on the distal side of; distally.","pos":""}],"DISTAFF":[{"def":"The staff for holding a bunch of flax, tow, or wool, from which the thread is drawn in spinning by hand.","pos":""},{"def":"Used as a symbol of the holder of a distaff; hence, a woman; women, collectively.","pos":""}],"DISTAIN":[{"def":"To tinge with a different color from the natural or proper one; to stain; to discolor; to sully; to tarnish; to defile; -- used chiefly in poetry.","pos":""}],"DISTALLY":[{"def":"Toward a distal part.","pos":""}],"DISTANCE":[{"def":"A space marked out in the last part of a race course.","pos":""},{"def":"Relative space, between troops in ranks, measured from front to rear; -- contrasted with interval, which is measured from right to left.","pos":""}],"DISTANT":[{"def":"Separated; having an intervening space; at a distance; away.","pos":""},{"def":"Far separated; far off; not near; remote; -- in place, time, consanguinity, or connection; as, distant times; distant relatives.","pos":""}],"DISTANTIAL":[{"def":"More distantial from the eye.","pos":""}],"DISTANTLY":[{"def":"At a distance; remotely; with reserve.","pos":""}],"DISTASTE":[{"def":"Aversion of the taste; dislike, as of food or drink; disrelish.","pos":""},{"def":"Discomfort; uneasiness.","pos":""}],"DISTASTEFUL":[{"def":"Unpleasant or disgusting to the taste; nauseous; loathsome.","pos":""},{"def":"Offensive; displeasing to the feelings; disagreeable; as, a distasteful truth.","pos":""}],"DISTASTEIVE":[{"def":"Tending to excite distaste.","pos":""},{"def":"That which excites distaste or aversion.","pos":""}],"DISTASTURE":[{"def":"Something which excites distaste or disgust.","pos":""}],"DISTEMPER":[{"def":"To mix (colors) in the way of distemper; as, to distemper colors with size.","pos":""}],"DISTEMPERATE":[{"def":"Diseased; disordered.","pos":""}],"DISTEMPERATELY":[{"def":"Dis*tem\"per*ate*ly, adv.","pos":""}],"DISTEMPERATURE":[{"def":"Bad temperature; intemperateness; excess of heat or cold, or of other qualities; as, the distemperature of the air.","pos":""},{"def":"Disorder; confusion.","pos":""}],"DISTEMPERMENT":[{"def":"Distempered state; distemperature.","pos":""}],"DISTEND":[{"def":"To extend in some one direction; to lengthen out; to stretch.","pos":""},{"def":"To stretch out or extend in all directions; to dilate; to enlarge, as by elasticity of parts; to inflate so as to produce tension; to cause to swell; as, to distend a bladder, the stomach, etc.","pos":""}],"DISTENSIBILITY":[{"def":"The quality or capacity of being distensible.","pos":""}],"DISTENSIBLE":[{"def":"Capable of being distended or dilated.","pos":""}],"DISTENSION":[{"def":"Same as Distention.","pos":""}],"DISTENSIVE":[{"def":"Distending, or capable of being distended.","pos":""}],"DISTENTION":[{"def":"The act of distending; the act of stretching in breadth or in all directions; the state of being Distended; as, the distention of the lungs.","pos":""},{"def":"Breadth; extent or space occupied by the thing distended.","pos":""}],"DISTER":[{"def":"To banish or drive from a country.","pos":""}],"DISTERMINATE":[{"def":"Separated by bounds.","pos":""}],"DISTERMINATION":[{"def":"Separation by bounds.","pos":""}],"DISTHENE":[{"def":"Cyanite or kyanite; -- so called in allusion to its unequal hardness in two different directions.","pos":""}],"DISTICH":[{"def":"A couple of verses or poetic lines making complete sense; an epigram of two verses.","pos":""},{"def":"Disposed in two vertical rows; two-ranked.","pos":""}],"DISTICHOUSLY":[{"def":"In a distichous manner.","pos":""}],"DISTILL":[{"def":"To drop; to fall in drops; to trickle.","pos":""},{"def":"To flow gently, or in a small stream.","pos":""}],"DISTILLABLE":[{"def":"Capable of being distilled; especially, capable of being distilled without chemical change or decomposition; as, alcohol is distillable; olive oil is not distillable.","pos":""}],"DISTILLATE":[{"def":"The product of distillation; as, the distillate from molasses.","pos":""}],"DISTILLATION":[{"def":"The act of falling in drops, or the act of pouring out in drops.","pos":""},{"def":"That which falls in drops.","pos":""}],"DISTILLATORY":[{"def":"Belonging to, or used in, distilling; as, distillatory vessels.","pos":""},{"def":"A distillatory apparatus; a still.","pos":""}],"DISTILLER":[{"def":"One who distills; esp.","pos":""},{"def":"The condenser of a distilling apparatus.","pos":""}],"DISTILLERY":[{"def":"The building and works where distilling, esp.","pos":""},{"def":"The act of distilling spirits.","pos":""}],"DISTILLMENT":[{"def":"Distillation; the substance obtained by distillation.","pos":""}],"DISTINCT":[{"def":"Distinguished; having the difference marked; separated by a visible sign; marked out; specified.","pos":""},{"def":"Marked; variegated.","pos":""}],"DISTINCTION":[{"def":"A marking off by visible signs; separation into parts; division.","pos":""},{"def":"The act of distinguishing or denoting the differences between objects, or the qualities by which one is known from others; exercise of discernment; discrimination.","pos":""}],"DISTINCTIVE":[{"def":"Marking or expressing distinction or difference; distinguishing; characteristic; peculiar.","pos":""},{"def":"Having the power to distinguish and discern; discriminating.","pos":""}],"DISTINCTIVELY":[{"def":"With distinction; plainly.","pos":""}],"DISTINCTIVENESS":[{"def":"State of being distinctive.","pos":""}],"DISTINCTLY":[{"def":"With distinctness; not confusedly; without the blending of one part or thing another; clearly; plainly; as, to see distinctly.","pos":""},{"def":"With meaning; significantly.","pos":""}],"DISTINCTNESS":[{"def":"The quality or state of being distinct; a separation or difference that prevents confusion of parts or things.","pos":""},{"def":"Nice discrimination; hence, clearness; precision; as, he stated his arguments with great distinctness.","pos":""}],"DISTINGUISH":[{"def":"Not set apart from others by visible marks; to make distinctive or discernible by exhibiting differences; to mark off by some characteristic.","pos":""},{"def":"To separate by definition of terms or logical division of a subject with regard to difference; as, to distinguish sounds into high and low.","pos":""}],"DISTINGUISHABLE":[{"def":"Capable of being distinguished; separable; divisible; discernible; capable of recognition; as, a tree at a distance is distinguishable from a shrub.","pos":""},{"def":"Worthy of note or special regard.","pos":""}],"DISTINGUISHABLENESS":[{"def":"The quality of being distinguishable.","pos":""}],"DISTINGUISHABLY":[{"def":"So as to be distinguished.","pos":""}],"DISTINGUISHED":[{"def":"Marked; special.","pos":""},{"def":"Separated from others by distinct difference; having, or indicating, superiority; eminent or known; illustrious; -- applied to persons and deeds.","pos":""}],"DISTINGUISHEDLY":[{"def":"In a distinguished manner.","pos":""}],"DISTINGUISHER":[{"def":"One who, or that which, distinguishes or separates one thing from another by marks of diversity.","pos":""},{"def":"One who discerns accurately the difference of things; a nice or judicious observer.","pos":""}],"DISTINGUISHING":[{"def":"Constituting difference, or distinction from everything else; distinctive; peculiar; characteristic.","pos":""}],"DISTINGUISHINGLY":[{"def":"With distinction; with some mark of preference.","pos":""}],"DISTINGUISHMENT":[{"def":"Observation of difference; distinction.","pos":""}],"DISTITLE":[{"def":"To deprive of title or right.","pos":""}],"DISTOMA":[{"def":"A genus of parasitic, trematode worms, having two suckers for attaching themselves to the part they infest.","pos":""}],"DISTORT":[{"def":"Distorted; misshapen.","pos":""}],"DISTORTER":[{"def":"One who, or that which, distorts.","pos":""}],"DISTORTION":[{"def":"An unnatural deviation of shape or position of any part of the body producing visible deformity.","pos":""}],"DISTORTIVE":[{"def":"Causing distortion.","pos":""}],"DISTRACT":[{"def":"Separated; drawn asunder.","pos":""}],"DISTRACTED":[{"def":"Mentally disordered; unsettled; mad.","pos":""}],"DISTRACTEDLY":[{"def":"Disjointedly; madly.","pos":""}],"DISTRACTEDNESS":[{"def":"A state of being distracted; distraction.","pos":""}],"DISTRACTER":[{"def":"One who, or that which, distracts away.","pos":""}],"DISTRACTIBLE":[{"def":"Capable of being drawn aside or distracted.","pos":""}],"DISTRACTILE":[{"def":"Tending or serving to draw apart.","pos":""}],"DISTRACTING":[{"def":"Tending or serving to distract.","pos":""}],"DISTRACTION":[{"def":"The act of distracting; a drawing apart; separation.","pos":""},{"def":"That which diverts attention; a diversion.","pos":""}],"DISTRACTIVE":[{"def":"Causing perplexity; distracting.","pos":""}],"DISTRAIN":[{"def":"To press heavily upon; to bear down upon with violence; hence, to constrain or compel; to bind; to distress, torment, or afflict.","pos":""},{"def":"To rend; to tear.","pos":""}],"DISTRAINABLE":[{"def":"Capable of being, or liable to be, distrained.","pos":""}],"DISTRAINER":[{"def":"Same as Distrainor.","pos":""}],"DISTRAINOR":[{"def":"One who distrains; the party distraining goods or chattels.","pos":""}],"DISTRAINT":[{"def":"The act or proceeding of seizing personal property by distress.","pos":""}],"DISTRAIT":[{"def":"Absent-minded; lost in thought; abstracted.","pos":""}],"DISTRAUGHT":[{"def":"Torn asunder; separated.","pos":""},{"def":"Distracted; perplexed.","pos":""}],"DISTREAM":[{"def":"Yet o'er that virtuous blush distreams a tear.","pos":""}],"DISTRESS":[{"def":"Extreme pain or suffering; anguish of body or mind; as, to suffer distress from the gout, or from the loss of friends.","pos":""},{"def":"That which occasions suffering; painful situation; misfortune; affliction; misery.","pos":""}],"DISTRESSEDNESS":[{"def":"A state of being distressed or greatly pained.","pos":""}],"DISTRESSFUL":[{"def":"Full of distress; causing, indicating, or attended with, distress; as, a distressful situation.","pos":""}],"DISTRESSING":[{"def":"Causing distress; painful; unpleasant.","pos":""}],"DISTRIBUTABLE":[{"def":"Capable of being distributed.","pos":""}],"DISTRIBUTARY":[{"def":"Tending to distribute or be distributed; that distributes; distributive.","pos":""}],"DISTRIBUTE":[{"def":"To employ (a term) in its whole extent; to take as universal in one premise.","pos":""}],"DISTRIBUTER":[{"def":"One who, or that which, distributes or deals out anything; a dispenser.","pos":""}],"DISTRIBUTING":[{"def":"That distributes; dealing out.","pos":""}],"DISTRIBUTION":[{"def":"A resolving a whole into its parts.","pos":""},{"def":"The sorting of types and placing them in their proper boxes in the cases.","pos":""}],"DISTRIBUTIONAL":[{"def":"Of or pertaining to distribution.","pos":""}],"DISTRIBUTIONIST":[{"def":"Dis`tri*bu\"tion*ist, n.","pos":""}],"DISTRIBUTIVE":[{"def":"Assigning the species of a general term.","pos":""},{"def":"Expressing separation; denoting a taking singly, not collectively; as, a distributive adjective or pronoun, such as each, either, every; a distributive numeral, as (Latin) bini (two by two).","pos":""}],"DISTRIBUTIVELY":[{"def":"By distribution; singly; not collectively; in a distributive manner.","pos":""}],"DISTRIBUTIVENESS":[{"def":"Quality of being distributive.","pos":""}],"DISTRICT":[{"def":"Rigorous; stringent; harsh.","pos":""}],"DISTRICTION":[{"def":"Sudden display; flash; glitter.","pos":""}],"DISTRINGAS":[{"def":"A writ commanding the sheriff to distrain a person by his goods or chattels, to compel a compliance with something required of him.","pos":""}],"DISTRUST":[{"def":"To feel absence of trust in; not to confide in or rely upon; to deem of questionable sufficiency or reality; to doubt; to be suspicious of; to mistrust.","pos":""}],"DISTRUSTER":[{"def":"One who distrusts.","pos":""}],"DISTRUSTFUL":[{"def":"Not confident; diffident; wanting confidence or thrust; modest; as, distrustful of ourselves, of one's powers.","pos":""},{"def":"Apt to distrust; suspicious; mistrustful.","pos":""}],"DISTRUSTING":[{"def":"That distrusts; suspicious; lacking confidence in.","pos":""}],"DISTRUSTLESS":[{"def":"Free from distrust.","pos":""}],"DISTUNE":[{"def":"To put out of tune.","pos":""}],"DISTURB":[{"def":"To throw into disorder or confusion; to derange; to interrupt the settled state of; to excite from a state of rest.","pos":""},{"def":"To agitate the mind of; to deprive of tranquillity; to disquiet; to render uneasy; as, a person is disturbed by receiving an insult, or his mind is disturbed by envy.","pos":""}],"DISTURBANCE":[{"def":"The hindering or disquieting of a person in the lawful and peaceable enjoyment of his right; the interruption of a right; as, the disturbance of a franchise, of common, of ways, and the like.","pos":""}],"DISTURBATION":[{"def":"Act of disturbing; disturbance.","pos":""}],"DISTURBER":[{"def":"One who interrupts or incommodes another in the peaceable enjoyment of his right.","pos":""}],"DISTYLE":[{"def":"Having two columns in front; -- said of a temple, portico, or the like.","pos":""}]}