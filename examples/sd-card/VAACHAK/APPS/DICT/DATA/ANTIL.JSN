{"ANTILEGOMENA":[{"def":"Certain books of the New Testament which were for a time not universally received, but which are now considered canonical.","pos":""}],"ANTILIBRATION":[{"def":"A balancing; equipoise.","pos":""}],"ANTILITHIC":[{"def":"Tending to prevent the formation of urinary calculi, or to destroy them when formed.","pos":""},{"def":"An antilithic medicine.","pos":""}],"ANTILOGARITHM":[{"def":"The number corresponding to a logarithm.","pos":""}],"ANTILOGOUS":[{"def":"Of the contrary name or character; -- opposed to analogous.","pos":""}],"ANTILOGY":[{"def":"A contradiction between any words or passages in an author.","pos":""}],"ANTILOIMIC":[{"def":"A remedy against the plague.","pos":""}],"ANTILOPINE":[{"def":"Of or relating to the antelope.","pos":""}],"ANTILYSSIC":[{"def":"Antihydrophobic.","pos":""}]}