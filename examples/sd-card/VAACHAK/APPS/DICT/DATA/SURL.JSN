{"SURLILY":[{"def":"In a surly manner.","pos":""}],"SURLINESS":[{"def":"The quality or state of being surly.","pos":""}],"SURLING":[{"def":"A sour, morose fellow.","pos":""}],"SURLOIN":[{"def":"A loin of beef, or the upper part of the loin.","pos":""}],"SURLY":[{"def":"Arrogant; haughty.","pos":""},{"def":"Gloomily morose; ill-natured, abrupt, and rude; severe; sour; crabbed; rough; sullen; gloomy; as, a surly groom; a surly dog; surly language; a surly look.","pos":""}]}