{"SARABAITE":[{"def":"One of certain vagrant or heretical Oriental monks in the early church.","pos":""}],"SARABAND":[{"def":"A slow Spanish dance of Saracenic origin, to an air in triple time; also, the air itself.","pos":""}],"SARACEN":[{"def":"Anciently, an Arab; later, a Mussulman; in the Middle Ages, the common term among Christians in Europe for a Mohammedan hostile to the crusaders.","pos":""},{"def":"Of or pertaining to the Saracens; as, Saracenic architecture.","pos":""}],"SARASWATI":[{"def":"The sakti or wife of Brahma; the Hindoo goddess of learning, music, and poetry.","pos":""}],"SARCASM":[{"def":"A keen, reproachful expression; a satirical remark uttered with some degree of scorn or contempt; a taunt; a gibe; a cutting jest.","pos":""}],"SARCASMOUS":[{"def":"Expressing, or expressed by, sarcasm; characterized by, or of the nature of, sarcasm; given to the use of sarcasm; bitterly satirical; scornfully severe; taunting.","pos":""}],"SARCASTICALLY":[{"def":"In a sarcastic manner.","pos":""}],"SARCEL":[{"def":"One of the outer pinions or feathers of the wing of a bird, esp.","pos":""}],"SARCELED":[{"def":"Cut through the middle.","pos":""}],"SARCELLE":[{"def":"The old squaw, or long-tailed duck.","pos":""}],"SARCENET":[{"def":"A species of fine thin silk fabric, used for linings, etc.","pos":""}],"SARCIN":[{"def":"Same as Hypoxanthin.","pos":""}],"SARCINA":[{"def":"A genus of bacteria found in various organic fluids, especially in those those of the stomach, associated with certain diseases.","pos":""}],"SARCLE":[{"def":"To weed, or clear of weeds, with a hoe.","pos":""},{"def":"A combining form from Gr.","pos":""}],"SARCOBASIS":[{"def":"A fruit consisting of many dry indehiscent cells, which contain but few seeds and cohere about a common style, as in the mallows.","pos":""}],"SARCOBLAST":[{"def":"A minute yellowish body present in the interior of certain rhizopods.","pos":""}],"SARCOCARP":[{"def":"the fleshy part of a stone fruit, situated between the skin, or epicarp, and the stone, or endocarp, as in a peach.","pos":""}],"SARCOCELE":[{"def":"Any solid tumor of the testicle.","pos":""},{"def":"A gum resin obtained from certain shrubs of Africa (Penæa), -- formerly thought to cause healing of wounds and ulcers.","pos":""}],"SARCODE":[{"def":"A name applied by Dujardin in 1835 to the gelatinous material forming the bodies of the lowest animals; protoplasm.","pos":""}],"SARCODIC":[{"def":"Of or pertaining to sarcode.","pos":""}],"SARCOID":[{"def":"Resembling flesh, or muscle; composed of sarcode.","pos":""}],"SARCOLACTIC":[{"def":"relating to muscle and milk; as, sarcolactic acid.","pos":""}],"SARCOLEMMA":[{"def":"The very thin transparent and apparently homogenous sheath which incloses a striated muscular fiber; the myolemma.","pos":""}],"SARCOLINE":[{"def":"Of or pertaining to sarcology.","pos":""}],"SARCOLOGY":[{"def":"That part of anatomy which treats of the soft parts.","pos":""}],"SARCOMA":[{"def":"A tumor of fleshy consistence; -- formerly applied to many varieties of tumor, now restricted to a variety of malignant growth made up of cells resembling those of fetal development without any proper intercellular substance.","pos":""}],"SARCOMATOUS":[{"def":"Of or pertaining to sarcoma; resembling sarcoma.","pos":""}],"SARCOPHAGA":[{"def":"A suborder of carnivorous and insectivorous marsupials including the dasyures and the opossums.","pos":""}],"SARCOPHAGAN":[{"def":"Any animal which eats flesh, especially any carnivorous marsupial.","pos":""},{"def":"Any fly of the genus Sarcophaga.","pos":""}],"SARCOPHAGOUS":[{"def":"Feeding on flesh; flesh-eating; carnivorous.","pos":""}],"SARCOPHAGUS":[{"def":"A species of limestone used among the Greeks for making coffins, which was so called because it consumed within a few weeks the flesh of bodies deposited in it.","pos":""},{"def":"A coffin or chest-shaped tomb of the kind of stone described above; hence, any stone coffin.","pos":""}],"SARCOPHAGY":[{"def":"The practice of eating flesh.","pos":""}],"SARCOPHILE":[{"def":"A flesh-eating animal, especially any one of the carnivorous marsupials.","pos":""}],"SARCOPTES":[{"def":"A genus of parasitic mites including the itch mites.","pos":""}],"SARCOPTID":[{"def":"Any species of the genus Sarcoptes and related genera of mites, comprising the itch mites and mange mites.","pos":""},{"def":"Of or pertaining to the itch mites.","pos":""}],"SARCORHAMPHI":[{"def":"A division of raptorial birds composing the vultures.","pos":""}],"SARCOSEPTUM":[{"def":"One of the mesenteries of an anthozoan.","pos":""}],"SARCOSIN":[{"def":"A crystalline nitrogenous substance, formed in the decomposition of creatin (one of the constituents of muscle tissue).","pos":""}],"SARCOTIC":[{"def":"Producing or promoting the growth of flesh.","pos":""},{"def":"A sarcotic medicine.","pos":""}],"SARCOUS":[{"def":"Fleshy; -- applied to the minute stryctural elements, called sarcous elements, or sarcous disks, of which striated muscular fiber is composed.","pos":""}],"SARCULATION":[{"def":"A weeding, as with a hoe or a rake.","pos":""}],"SARD":[{"def":"A variety of carnelian, of a rich reddish yellow or brownish red color.","pos":""}],"SARDACHATE":[{"def":"A variety of agate containing sard.","pos":""}],"SARDEL":[{"def":"A precious stone.","pos":""}],"SARDINE":[{"def":"Any one of several small species of herring which are commonly preserved in olive oil for food, especially the pilchard, or European sardine (Clupea pichardus).","pos":""}],"SARDINIAN":[{"def":"Of or pertaining to the island, kingdom, or people of Sardinia.","pos":""},{"def":"A native or inhabitant of Sardinia.","pos":""}],"SARDIUS":[{"def":"A precious stone, probably a carnelian, one of which was set in Aaron's breastplate.","pos":""}],"SARDOIN":[{"def":"Sard; carnelian.","pos":""}],"SARDONIC":[{"def":"Forced; unnatural; insincere; hence, derisive, mocking, malignant, or bitterly sarcastic; -- applied only to a laugh, smile, or some facial semblance of gayety.","pos":""}],"SARDONYX":[{"def":"A variety of onyx consisting of sard and white chalcedony in alternate layers.","pos":""}],"SAREE":[{"def":"The principal garment of a Hindoo woman.","pos":""}],"SARGASSUM":[{"def":"A genus of algæ including the gulf weed.","pos":""}],"SARGO":[{"def":"Any one of several species of sparoid fishes belonging to Sargus, Pomodasys, and related genera; -- called also sar, and saragu.","pos":""}],"SARIGUE":[{"def":"A small South American opossum (Didelphys opossum), having four white spots on the face.","pos":""}],"SARK":[{"def":"To cover with sarking, or thin boards.","pos":""}],"SARKIN":[{"def":"Same as Hypoxanthin.","pos":""}],"SARKING":[{"def":"Thin boards for shealting, as above the rafters, and under the shingles or slates, and for similar purposes.","pos":""}],"SARMENT":[{"def":"A prostrate filiform stem or runner, as of the strawbwrry.","pos":""}],"SARMENTACEOUS":[{"def":"Bearing sarments, or runners, as the strawberry.","pos":""}],"SARMENTOSE":[{"def":"Sar`men*tose\" ( or ), a.","pos":""}],"SARN":[{"def":"A pavement or stepping-stone.","pos":""}],"SARONG":[{"def":"A sort of petticoat worn by both sexes in Java and the Malay Archipelago.","pos":""}],"SAROS":[{"def":"A Chaldean astronomical period or cycle, the length of which has been variously estimated from 3,600 years to 3,600 days, or a little short of 10 years.","pos":""}],"SARPLAR":[{"def":"A large bale or package of wool, containing eighty tods, or 2,240 pounds, in weight.","pos":""}],"SARPLIER":[{"def":"A coarse cloth made of hemp, and used for packing goods, etc.","pos":""}],"SARPO":[{"def":"A large toadfish the Southern United States and the Gulf of Mexico (Batrachus tau, var.","pos":""}],"SARRACENIA":[{"def":"A genus of American perrenial herbs growing in bogs; the American pitcher plant.","pos":""},{"def":"A portcullis, or herse.","pos":""}],"SARSAPARILLA":[{"def":"Note: The name is also applied to many other plants and their roots, especially to the Aralia nudicaulis, the wild sarsaparilla of the United States.","pos":""}],"SARSE":[{"def":"A fine sieve; a searce.","pos":""}],"SARSEN":[{"def":"One of the large sandstone blocks scattered over the English chalk downs; -- called also sarsen stone, and Druid stone.","pos":""}],"SART":[{"def":"An assart, or clearing.","pos":""}],"SARTORIAL":[{"def":"Of or pertaining to thesartorius muscle.","pos":""}],"SARTORIUS":[{"def":"A muscle of the thigh, called the tailor's muscle, which arises from the hip bone and is inserted just below the knee.","pos":""}],"SARUM USE":[{"def":"A liturgy, or use, put forth about 1087 by St.","pos":""}]}