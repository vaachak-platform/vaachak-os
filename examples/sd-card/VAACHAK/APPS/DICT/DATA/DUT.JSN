{"DUTCH":[{"def":"Pertaining to Holland, or to its inhabitants.","pos":""}],"DUTCHMAN":[{"def":"A native, or one of the people, of Holland.","pos":""}],"DUTEOUS":[{"def":"Fulfilling duty; dutiful; having the sentiments due to a superior, or to one to whom respect or service is owed; obedient; as, a duteous son or daughter.","pos":""},{"def":"Subservient; obsequious.","pos":""}],"DUTIABLE":[{"def":"Subject to the payment of a duty; as dutiable goods.","pos":""}],"DUTIED":[{"def":"Subjected to a duty.","pos":""}],"DUTIFUL":[{"def":"Performing, or ready to perform, the duties required by one who has the right to claim submission, obedience, or deference; submissive to natural or legal superiors; obedient, as to parents or superiors; as, a dutiful son or daughter; a dutiful ward or servant; a dutiful subject.","pos":""},{"def":"Controlled by, proceeding from, a sense of duty; respectful; deferential; as, dutiful affection.","pos":""}],"DUTY":[{"def":"The efficiency of an engine, especially a steam pumping engine, as measured by work done by a certain quantity of fuel; usually, the number of pounds of water lifted one foot by one bushel of coal (94 lbs.","pos":""},{"def":"Tax, toll, impost, or customs; excise; any sum of money required by government to be paid on the importation, exportation, or consumption of goods.","pos":""}]}