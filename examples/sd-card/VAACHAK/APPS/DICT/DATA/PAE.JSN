{"PAEAN":[{"def":"An ancient Greek hymn in honor of Apollo as a healing deity, and, later, a song addressed to other deities.","pos":""},{"def":"Any loud and joyous song; a song of triumph.","pos":""}],"PAEDOGENESIS":[{"def":"Reproduction by young or larval animals.","pos":""}],"PAEDOGENETIC":[{"def":"Producing young while in the immature or larval state; -- said of certain insects, etc.","pos":""}],"PAEON":[{"def":"A foot of four syllables, one long and three short, admitting of four combinations, according to the place of the long syllable.","pos":""}],"PAEONINE":[{"def":"An artifical red nitrogenous dyestuff, called also red coralline.","pos":""}]}