{"DEPOLARIZATION":[{"def":"The act of depriving of polarity, or the result of such action; reduction to an unpolarized condition.","pos":""}],"DEPOLARIZE":[{"def":"To deprive of polarity; to reduce to an unpolarized condition.","pos":""},{"def":"To free from polarization, as the negative plate of the voltaic battery.","pos":""}],"DEPOLARIZER":[{"def":"A substance used to prevent polarization, as upon the negative plate of a voltaic battery.","pos":""}],"DEPOLISH":[{"def":"To remove the polish or glaze from.","pos":""}],"DEPOLISHING":[{"def":"The process of removing the vitreous glaze from porcelain, leaving the dull luster of the surface of ivory porcelian.","pos":""}],"DEPONE":[{"def":"To lay, as a stake; to wager.","pos":""}],"DEPONENT":[{"def":"One who deposes or testifies under oath; one who gives evidence; usually, one who testifies in writing.","pos":""},{"def":"A deponent verb.","pos":""}],"DEPOPULACY":[{"def":"Depopulation; destruction of population.","pos":""}],"DEPOPULATE":[{"def":"To deprive of inhabitants, whether by death or by expulsion; to reduce greatly the populousness of; to dispeople; to unpeople.","pos":""}],"DEPOPULATION":[{"def":"The act of depopulating, or condition of being depopulated; destruction or explusion of inhabitants.","pos":""}],"DEPOPULATOR":[{"def":"One who depopulates; a dispeopler.","pos":""}],"DEPORT":[{"def":"To transport; to carry away; to exile; to send into banishment.","pos":""},{"def":"To carry or demean; to conduct; to behave; -- followed by the reflexive pronoun.","pos":""}],"DEPORTATION":[{"def":"The act of deporting or exiling, or the state of being deported; banishment; transportation.","pos":""}],"DEPORTMENT":[{"def":"Manner of deporting or demeaning one's self; manner of acting; conduct; carrige; especially, manner of acting with respect to the courtesies and duties of life; behavior; demeanor; bearing.","pos":""}],"DEPORTURE":[{"def":"Stately port and majestical deporture.","pos":""}],"DEPOSABLE":[{"def":"Capable of being deposed or deprived of office.","pos":""}],"DEPOSAL":[{"def":"The act of deposing from office; a removal from the throne.","pos":""}],"DEPOSE":[{"def":"To lay down; to divest one's self of; to lay aside.","pos":""},{"def":"To let fall; to deposit.","pos":""}],"DEPOSER":[{"def":"One who deposes or degrades from office.","pos":""},{"def":"One who testifies or deposes; a deponent.","pos":""}],"DEPOSIT":[{"def":"To lay down; to place; to put; to let fall or throw down (as sediment); as, a crocodile deposits her eggs in the sand; the waters deposited a rich alluvium.","pos":""},{"def":"To lay up or away for safekeeping; to put up; to store; as, to deposit goods in a warehouse.","pos":""}],"DEPOSITARY":[{"def":"One to whom goods are bailed, to be kept for the bailor without a recompense.","pos":""}],"DEPOSITION":[{"def":"The act of laying down one's testimony in writing; also, testimony laid or taken down in writting, under oath or affirmation, befor some competent officer, and in reply to interrogatories and cross-interrogatories.","pos":""}],"DEPOSITOR":[{"def":"One who makes a deposit, especially of money in bank; -- the correlative of depository.","pos":""}],"DEPOSITORY":[{"def":"A place where anything is deposited for sale or keeping; as, warehouse is a depository for goods; a clerk's office is a depository for records.","pos":""},{"def":"One with whom something is deposited; a depositary.","pos":""}],"DEPOSITURE":[{"def":"The act of depositing; deposition.","pos":""}],"DEPOT":[{"def":"A place of deposit storing of goods; a warehouse; a storehouse.","pos":""},{"def":"A railway station; a building for the accommodation and protection of railway passenges or freight.","pos":""}]}