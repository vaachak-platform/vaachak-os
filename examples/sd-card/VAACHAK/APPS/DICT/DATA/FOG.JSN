{"FOG":[{"def":"Note: Sometimes called, in New England, old tore.","pos":""}],"FOG BELT":[{"def":"A region of the ocean where fogs are of marked frequency, as near the coast of Newfoundland.","pos":""}],"FOGBOW":[{"def":"A nebulous arch, or bow, of white or yellowish light sometimes seen in fog, etc.","pos":""}],"FOGE":[{"def":"The Cornish name for a forge used for smelting tin.","pos":""}],"FOGGER":[{"def":"One who fogs; a pettifogger.","pos":""}],"FOGGILY":[{"def":"In a foggy manner; obscurely.","pos":""}],"FOGGINESS":[{"def":"The state of being foggy.","pos":""}],"FOGGY":[{"def":"Filled or abounding with fog, or watery exhalations; misty; as, a foggy atmosphere; a foggy morning.","pos":""},{"def":"Beclouded; dull; obscure; as, foggy ideas.","pos":""}],"FOGLESS":[{"def":"Without fog; clear.","pos":""}],"FOGY":[{"def":"A dull old fellow; a person behind the times, over- conservative, or slow; -- usually preceded by old.","pos":""}],"FOGYISM":[{"def":"The principles and conduct of a fogy.","pos":""}]}