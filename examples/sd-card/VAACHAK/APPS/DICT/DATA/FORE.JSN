{"FORE":[{"def":"Journey; way; method of proceeding.","pos":""}],"FORE TOOTH":[{"def":"One of the teeth in the forepart of the mouth; an incisor.","pos":""}],"FORE-NIGHT":[{"def":"The evening between twilight and bedtime.","pos":""}],"FORE-TOPGALLANT":[{"def":"Designating the mast, sail, yard, etc.","pos":""}],"FORE-TOPMAST":[{"def":"The mast erected at the head of the foremast, and at the head of which stands the fore-topgallant mast.","pos":""}],"FORE-TOPSAIL":[{"def":"Fore`-top\"sail ( or ), n.","pos":""}]}