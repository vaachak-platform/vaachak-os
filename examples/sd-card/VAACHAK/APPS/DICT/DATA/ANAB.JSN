{"ANABAPTISM":[{"def":"The doctrine of the Anabaptists.","pos":""}],"ANABAPTIST":[{"def":"A name sometimes applied to a member of any sect holding that rebaptism is necessary for those baptized in infancy.","pos":""},{"def":"Relating or attributed to the Anabaptists, or their doctrines.","pos":""}],"ANABAPTISTRY":[{"def":"The doctrine, system, or practice, of Anabaptists.","pos":""}],"ANABAPTIZE":[{"def":"To rebaptize; to rechristen; also, to rename.","pos":""}],"ANABAS":[{"def":"A genus of fishes, remarkable for their power of living long out of water, and of making their way on land for considerable distances, and for climbing trees; the climbing fishes.","pos":""}],"ANABASIS":[{"def":"The first period, or increase, of a disease; augmentation.","pos":""}],"ANABATIC":[{"def":"Pertaining to anabasis; as, an anabatic fever.","pos":""}],"ANABOLIC":[{"def":"Pertaining to anabolism; an anabolic changes, or processes, more or less constructive in their nature.","pos":""}],"ANABOLISM":[{"def":"The constructive metabolism of the body, as distinguished from katabolism.","pos":""}],"ANABRANCH":[{"def":"A branch of a river that reënters, or anastomoses with, the main stream; also, less properly, a branch which loses itself in sandy soil.","pos":""}]}