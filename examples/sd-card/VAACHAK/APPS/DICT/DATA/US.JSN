{"US":[{"def":"The persons speaking, regarded as an object; ourselves; -- the objective case of we.","pos":""}],"USABLE":[{"def":"Capable of being used.","pos":""}],"USAGE":[{"def":"The act of using; mode of using or treating; treatment; conduct with respect to a person or a thing; as, good usage; ill usage; hard usage.","pos":""},{"def":"Manners; conduct; behavior.","pos":""}],"USAGER":[{"def":"One who has the use of anything in trust for another.","pos":""}],"USANCE":[{"def":"The time, fixed variously by the usage between different countries, when a bill of exchange is payable; as, a bill drawn on London at one usance, or at double usance.","pos":""}],"USANT":[{"def":"Using; accustomed.","pos":""},{"def":"A Turkish tribe which about the close of the 15th century conquered, and settled in, that part of Asia now called Turkestan.","pos":""}],"USE":[{"def":"The special form of ritual adopted for use in any diocese; as, the Sarum, or Canterbury, use; the Hereford use; the York use; the Roman use; etc.","pos":""},{"def":"The benefit or profit of lands and tenements.","pos":""}],"USEFUL":[{"def":"Full of use, advantage, or profit; producing, or having power to produce, good; serviceable for any end or object; helpful toward advancing any purpose; beneficial; profitable; advantageous; as, vessels and instruments useful in a family; books useful for improvement; useful knowledge; useful arts.","pos":""}],"USEFULLY":[{"def":"In a useful manner.","pos":""}],"USEFULNESS":[{"def":"The quality or state of being useful; utility; serviceableness; advantage.","pos":""}],"USELESS":[{"def":"Having, or being of, no use; unserviceable; producing no good end; answering no valuable purpose; not advancing the end proposed; unprofitable; ineffectual; as, a useless garment; useless pity.","pos":""}],"USER":[{"def":"Enjoyment of property; use.","pos":""}],"USHER":[{"def":"An officer or servant who has the care of the door of a court, hall, chamber, or the like; hence, an officer whose business it is to introduce strangers, or to walk before a person of rank.","pos":""},{"def":"An under teacher, or assistant master, in a school.","pos":""}],"USHERANCE":[{"def":"The act of ushering, or the state of being ushered in.","pos":""}],"USHERDOM":[{"def":"The office or position of an usher; ushership; also, ushers, collectively.","pos":""}],"USHERLESS":[{"def":"Destitute of an usher.","pos":""}],"USHERSHIP":[{"def":"The office of an usher; usherdom.","pos":""}],"USITATIVE":[{"def":"Denoting usual or customary action.","pos":""}],"USNEA":[{"def":"A genus of lichens, most of the species of which have long, gray, pendulous, and finely branched fronds.","pos":""}],"USNIC":[{"def":"Pertaining to, or designating, a complex acid obtained, as a yellow crystalline substance, from certain genera of lichens (Usnea, Parmelia, etc.","pos":""}],"USQUEBAUGH":[{"def":"A compound distilled spirit made in Ireland and Scotland; whisky.","pos":""},{"def":"A liquor compounded of brandy, or other strong spirit, raisins, cinnamon and other spices.","pos":""}],"USTION":[{"def":"The act of burning, or the state of being burned.","pos":""}],"USTORIOUS":[{"def":"Having the quality of burning.","pos":""}],"USTULATE":[{"def":"Blackened as if burned.","pos":""}],"USTULATION":[{"def":"The operation of expelling one substance from another by heat, as sulphur or arsenic from ores, in a muffle.","pos":""}],"USUAL":[{"def":"Such as is in common use; such as occurs in ordinary practice, or in the ordinary course of events; customary; ordinary; habitual; common.","pos":""}],"USUCAPTION":[{"def":"The acquisition of the title or right to property by the uninterrupted possession of it for a certain term prescribed by law; -- the same as prescription in common law.","pos":""}],"USUFRUCT":[{"def":"The right of using and enjoying the profits of an estate or other thing belonging to another, without impairing the substance.","pos":""}],"USUFRUCTUARY":[{"def":"A person who has the use of property and reaps the profits of it.","pos":""}],"USURE":[{"def":"To practice usury; to charge unlawful interest.","pos":""}],"USURER":[{"def":"One who lends money and takes interest for it; a money lender.","pos":""},{"def":"One who lends money at a rate of interest beyond that established by law; one who exacts an exorbitant rate of interest for the use of money.","pos":""}],"USURIOUS":[{"def":"Practicing usury; taking illegal or exorbitant interest for the use of money; as, a usurious person.","pos":""},{"def":"Partaking of usury; containing or involving usury; as, a usurious contract.","pos":""}],"USURP":[{"def":"To seize, and hold in possession, by force, or without right; as, to usurp a throne; to usurp the prerogatives of the crown; to usurp power; to usurp the right of a patron is to oust or dispossess him.","pos":""}],"USURPANT":[{"def":"Usurping; encroaching.","pos":""}],"USURPATION":[{"def":"Use; usage; custom.","pos":""}],"USURPATORY":[{"def":"Marked by usurpation; usurping.","pos":""}],"USURPER":[{"def":"One who usurps; especially, one who seizes illegally on sovereign power; as, the usurper of a throne, of power, or of the rights of a patron.","pos":""}],"USURPINGLY":[{"def":"In a usurping manner.","pos":""}],"USURY":[{"def":"Interest in excess of a legal rate charged to a borrower for the use of money.","pos":""}]}