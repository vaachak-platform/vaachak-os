{"TIG":[{"def":"A game among children.","pos":""},{"def":"A capacious, flat-bottomed drinking cup, generally with four handles, formerly used for passing around the table at convivial entertainment.","pos":""}],"TIGELLA":[{"def":"That part of an embryo which represents the young stem; the caulicle or radicle.","pos":""}],"TIGELLE":[{"def":"Same as Tigella.","pos":""}],"TIGER":[{"def":"A very large and powerful carnivore (Felis tigris) native of Southern Asia and the East Indies.","pos":"verb"}],"TIGER'S-FOOT":[{"def":"A name given to some species of morning-glory (Ipomoea) having the leaves lobed in pedate fashion.","pos":""}],"TIGER-EYE":[{"def":"A siliceous stone of a yellow color and chatoyant luster, obtained in South Africa and much used for ornament.","pos":""}],"TIGER-FOOT":[{"def":"Same as Tiger's-foot.","pos":""}],"TIGER-FOOTED":[{"def":"Hastening to devour; furious.","pos":""}],"TIGERINE":[{"def":"Tigerish; tigrine.","pos":""}],"TIGERISH":[{"def":"Like a tiger; tigrish.","pos":""}],"TIGH":[{"def":"A close, or inclosure; a croft.","pos":""}],"TIGHT":[{"def":"Pressing; stringent; not easy; firmly held; dear; -- said of money or the money market.","pos":""}],"TIGHTEN":[{"def":"To draw tighter; to straiten; to make more close in any manner.","pos":""}],"TIGHTENER":[{"def":"That which tightens; specifically (Mach.","pos":""}],"TIGHTER":[{"def":"A ribbon or string used to draw clothes closer.","pos":""}],"TIGHTLY":[{"def":"In a tight manner; closely; nearly.","pos":""}],"TIGHTNESS":[{"def":"The quality or condition of being tight.","pos":""}],"TIGHTS":[{"def":"Close-fitting garments, especially for the lower part of the body and the legs.","pos":""}],"TIGLIC":[{"def":"Of, pertaining to, or designating, an acid, C4H7CO2H (called also methyl crotonic acid), homologous with crotonic acid, and obtained from croton oil (from Croton Tiglium) as a white crystalline substance.","pos":""}],"TIGRESS":[{"def":"The female of the tiger.","pos":""}],"TIGRINE":[{"def":"Resembling the tiger in color; as, the tigrine cat (Felis tigrina) of South America.","pos":""}],"TIGRISH":[{"def":"Resembling a tiger; tigerish.","pos":""}]}