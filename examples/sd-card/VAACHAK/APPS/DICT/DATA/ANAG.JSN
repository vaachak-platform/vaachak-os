{"ANAGLYPH":[{"def":"Any sculptured, chased, or embossed ornament worked in low relief, as a cameo.","pos":""}],"ANAGLYPHIC":[{"def":"Work chased or embossed relief.","pos":""},{"def":"Pertaining to the art of chasing or embossing in relief; anaglyptic; -- opposed to diaglyptic or sunk work.","pos":""}],"ANAGLYPTIC":[{"def":"Relating to the art of carving, enchasing, or embossing in low relief.","pos":""}],"ANAGLYPTICS":[{"def":"The art of carving in low relief, embossing, etc.","pos":""}],"ANAGLYPTOGRAPH":[{"def":"An instrument by which a correct engraving of any embossed object, such as a medal or cameo, can be executed.","pos":""}],"ANAGLYPTOGRAPHIC":[{"def":"Of or pertaining to anaglyptography; as, analyptographic engraving.","pos":""}],"ANAGLYPTOGRAPHY":[{"def":"The art of copying works in relief, or of engraving as to give the subject an embossed or raised appearance; -- used in representing coins, bas-reliefs, etc.","pos":""}],"ANAGNORISIS":[{"def":"The unfolding or dénouement.","pos":""}],"ANAGOGE":[{"def":"Mystical; having a secondary spiritual meaning; as, the rest of the Sabbath, in an anagogical sense, signifies the repose of the saints in heaven; an anagogical explication.","pos":""}],"ANAGOGICS":[{"def":"Mystical interpretations or studies, esp.","pos":""}],"ANAGOGY":[{"def":"Same as Anagoge.","pos":""}],"ANAGRAM":[{"def":"Literally, the letters of a word read backwards, but in its usual wider sense, the change or one word or phrase into another by the transposition of its letters.","pos":""}],"ANAGRAMMATISM":[{"def":"The act or practice of making anagrams.","pos":""}],"ANAGRAMMATIST":[{"def":"A maker anagrams.","pos":""}],"ANAGRAMMATIZE":[{"def":"To transpose, as the letters of a word, so as to form an anagram.","pos":""}],"ANAGRAPH":[{"def":"An inventory; a record.","pos":""},{"def":"A race of giants living in Palestine.","pos":""}]}