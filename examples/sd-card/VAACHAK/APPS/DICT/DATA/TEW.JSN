{"TEW":[{"def":"To prepare by beating or working, as leather or hemp; to taw.","pos":""},{"def":"Hence, to beat; to scourge; also, to pull about; to maul; to tease; to vex.","pos":""}],"TEWAN":[{"def":"A tribe of American Indians including many of the Pueblos of New Mexico and adjacent regions.","pos":""}],"TEWED":[{"def":"Fatigued; worn with labor or hardship.","pos":""}],"TEWEL":[{"def":"A pipe, funnel, or chimney, as for smoke.","pos":""},{"def":"The tuyère of a furnace.","pos":""}],"TEWHIT":[{"def":"The lapwing; -- called also teewheep.","pos":""}],"TEWTAW":[{"def":"To beat; to break, as flax or hemp.","pos":""}]}