{"SEAWAND":[{"def":"See Sea girdles.","pos":""}],"SEAWARD":[{"def":"Directed or situated toward the sea.","pos":""}],"SEAWEED":[{"def":"Any marine plant of the class Algæ, as kelp, dulse, Fucus, Ulva, etc.","pos":""}],"SEAWIFE":[{"def":"A European wrasse (Labrus vetula).","pos":""}],"SEAWORTHINESS":[{"def":"The state or quality of being seaworthy, or able to resist the ordinary violence of wind and weather.","pos":""}],"SEAWORTHY":[{"def":"Fit for a voyage; worthy of being trusted to transport a cargo with safety; as, a seaworthy ship.","pos":""}]}