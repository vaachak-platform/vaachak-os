{"ELEMENT":[{"def":"One of the simplest essential parts, more commonly called cells, of which animal and vegetable organisms, or their tissues and organs, are composed.","pos":""},{"def":"The simplest or fundamental principles of any system in philosophy, science, or art; rudiments; as, the elements of geometry, or of music.","pos":""}],"ELEMENTAL":[{"def":"Pertaining to the elements, first principles, and primary ingredients, or to the four supposed elements of the material world; as, elemental air.","pos":""},{"def":"Pertaining to rudiments or first principles; rudimentary; elementary.","pos":""}],"ELEMENTALISM":[{"def":"The theory that the heathen divinities originated in the personification of elemental powers.","pos":""}],"ELEMENTALITY":[{"def":"The condition of being composed of elements, or a thing so composed.","pos":""}],"ELEMENTALLY":[{"def":"According to elements; literally; as, the words, \"Take, eat; this is my body,\" elementally understood.","pos":""}],"ELEMENTARINESS":[{"def":"The state of being elementary; original simplicity; uncompounded state.","pos":""}],"ELEMENTARY":[{"def":"Having only one principle or constituent part; consisting of a single element; simple; uncompounded; as, an elementary substance.","pos":""},{"def":"Pertaining to, or treating of, the elements, rudiments, or first principles of anything; initial; rudimental; introductory; as, an elementary treatise.","pos":""}],"ELEMENTATION":[{"def":"Instruction in the elements or first principles.","pos":""}],"ELEMENTOID":[{"def":"Resembling an element.","pos":""}],"ELEMI":[{"def":"A fragrant gum resin obtained chiefly tropical trees of the genera Amyris and Canarium.","pos":""}],"ELEMIN":[{"def":"A transparent, colorless oil obtained from elemi resin by distillation with water; also, a crystallizable extract from the resin.","pos":""}]}