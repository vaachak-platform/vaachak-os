{"ZOANTHACEA":[{"def":"A suborder of Actinaria, including Zoanthus and allied genera, which are permanently attached by their bases.","pos":""}],"ZOANTHARIA":[{"def":"Same as Anthozoa.","pos":""}],"ZOANTHARIAN":[{"def":"Of or pertaining to the Zoantharia.","pos":""},{"def":"One of the Anthozoa.","pos":""}],"ZOANTHODEME":[{"def":"The zooids of a compound anthozoan, collectively.","pos":""}],"ZOANTHOID":[{"def":"Of or pertaining to the Zoanthacea.","pos":""}],"ZOANTHROPY":[{"def":"A kind of monomania in which the patient believes himself transformed into one of the lower animals.","pos":""}],"ZOANTHUS":[{"def":"A genus of Actinaria, including numerous species, found mostly in tropical seas.","pos":""}],"ZOBO":[{"def":"A kind of domestic cattle reared in Asia for its flesh and milk.","pos":""}],"ZODIAC":[{"def":"A girdle; a belt.","pos":""}],"ZODIACAL":[{"def":"Of or pertaining to the zodiac; situated within the zodiac; as, the zodiacal planets.","pos":""}],"ZOEA":[{"def":"A peculiar larval stage of certain decapod Crustacea, especially of crabs and certain Anomura.","pos":""}],"ZOETROPE":[{"def":"An optical toy, in which figures made to revolve on the inside of a cylinder, and viewed through slits in its circumference, appear like a single figure passing through a series of natural motions as if animated or mechanically moved.","pos":""}],"ZOHAR":[{"def":"A Jewish cabalistic book attributed by tradition to Rabbi Simon ben Yochi, who lived about the end of the 1st century, a.","pos":""}],"ZOIC":[{"def":"Of or pertaining to animals, or animal life.","pos":""}],"ZOILEAN":[{"def":"Having the characteristic of Zoilus, a bitter, envious, unjust critic, who lived about 270 years before Christ.","pos":""}],"ZOILISM":[{"def":"Resemblance to Zoilus in style or manner; carping criticism; detraction.","pos":""}],"ZOISITE":[{"def":"A grayish or whitish mineral occurring in orthorhombic, prismatic crystals, also in columnar masses.","pos":""}],"ZOISM":[{"def":"Reverence for animal life or belief in animal powers and influences, as among savages.","pos":""}],"ZOKOR":[{"def":"An Asiatic burrowing rodent (Siphneus aspalax) resembling the mole rat.","pos":""}],"ZOLAESQUE":[{"def":"In the style of Zola (see Zolaism).","pos":""}],"ZOLAISM":[{"def":"The literary theories and practices of the French novelist Emile Zola (1840-1902); naturalism, esp.","pos":""}],"ZOLLNER'S LINES":[{"def":"Parallel lines that are made to appear convergent or divergent by means of oblique intersections.","pos":""}],"ZOLLVEREIN":[{"def":"Literally, a customs union; specifically, applied to the several customs unions successively formed under the leadership of Prussia among certain German states for establishing liberty of commerce among themselves and common tariff on imports, exports, and transit.","pos":""}],"ZONA":[{"def":"A zone or band; a layer.","pos":""}],"ZONAL":[{"def":"Of or pertaining to a zone; having the form of a zone or zones.","pos":""}],"ZONAR":[{"def":"A belt or girdle which the Christians and Jews of the Levant were obliged to wear to distinguish them from Mohammedans.","pos":""}],"ZONARIA":[{"def":"A division of Mammalia in which the placenta is zonelike.","pos":""}],"ZONATE":[{"def":"Divided by parallel planes; as, zonate tetraspores, found in certain red algæ.","pos":""}],"ZONE":[{"def":"One of the five great divisions of the earth, with respect to latitude and temperature.","pos":""},{"def":"The portion of the surface of a sphere included between two parallel planes; the portion of a surface of revolution included between two planes perpendicular to the axis.","pos":""}],"ZONED":[{"def":"Wearing a zone, or girdle.","pos":""},{"def":"Having zones, or concentric bands; striped.","pos":""}],"ZONELESS":[{"def":"Not having a zone; ungirded.","pos":""}],"ZONULAR":[{"def":"Of or pertaining to a zone; zone-shaped.","pos":""}],"ZONULE":[{"def":"A little zone, or girdle.","pos":""}],"ZONURE":[{"def":"Any one of several of South African lizards of the genus Zonura, common in rocky situations.","pos":""},{"def":"A combining form from Gr.","pos":""}],"ZOOECIUM":[{"def":"One of the cells or tubes which inclose the feeling zooids of Bryozoa.","pos":""},{"def":"A peculiar organic red coloring matter found in the feathers of various birds.","pos":""}],"ZOOID":[{"def":"Pertaining to, or resembling, an animal.","pos":""}],"ZOOIDAL":[{"def":"Of or pertaining to a zooid; as, a zooidal form.","pos":""},{"def":"The worship of animals.","pos":""}],"ZOOLOGIZE":[{"def":"To study zoölogy; esp.","pos":""},{"def":"A pigment giving the black color to the feathers of many birds.","pos":""}],"ZOOZOO":[{"def":"The wood pigeon.","pos":""}],"ZOPE":[{"def":"A European fresh-water bream (Abramis ballerus).","pos":""}],"ZOPILOTE":[{"def":"The urubu, or American black vulture.","pos":""}],"ZORIL":[{"def":"Same as Zorilla.","pos":""}],"ZORILLA":[{"def":"Either one of two species of small African carnivores of the genus Ictonyx allied to the weasels and skunks.","pos":""}],"ZOROASTRIAN":[{"def":"Of or pertaining to Zoroaster, or his religious system.","pos":""}],"ZOROASTRIANISM":[{"def":"The religious system of Zoroaster, the legislator and prophet of the ancient Persians, which was the national faith of Persia; mazdeism.","pos":""}],"ZOROASTRISM":[{"def":"Same as Zoroastrianism.","pos":""}],"ZOSTERA":[{"def":"A genus of plants of the Naiadaceæ, or Pondweed family.","pos":""}],"ZOSTEROPS":[{"def":"A genus of birds that comprises the white-eyes.","pos":""}],"ZOUNDS":[{"def":"An exclamation formerly used as an oath, and an expression of anger or wonder.","pos":""}],"ZOUTCH":[{"def":"To stew, as flounders, eels, etc.","pos":""}]}