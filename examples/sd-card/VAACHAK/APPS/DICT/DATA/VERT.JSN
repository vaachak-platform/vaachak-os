{"VERT":[{"def":"The color green, represented in a drawing or engraving by parallel lines sloping downward toward the right.","pos":""}],"VERTEBRA":[{"def":"One of the serial segments of the spinal column.","pos":""},{"def":"One of the central ossicles in each joint of the arms of an ophiuran.","pos":""}],"VERTEBRAL":[{"def":"Of or pertaining to a vertebræ, or the vertebral column; spinal; rachidian.","pos":""}],"VERTEBRALLY":[{"def":"At or within a vertebra or vertebræ; -- distinguished from interverterbrally.","pos":""}],"VERTEBRARTERIAL":[{"def":"Of or pertaining to a vertebræ and an artery; -- said of the foramina in the transverse processes of cervical vertebræ and of the canal which they form for the vertebral artery and vein.","pos":""}],"VERTEBRATA":[{"def":"One of the grand divisions of the animal kingdom, comprising all animals that have a backbone composed of bony or cartilaginous vertebræ, together with Amphioxus in which the backbone is represented by a simple undivided notochord.","pos":""}],"VERTEBRATE":[{"def":"One of the Vertebrata.","pos":""},{"def":"Having a backbone, or vertebral column, containing the spinal marrow, as man, quadrupeds, birds, amphibia, and fishes.","pos":""}],"VERTEBRO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, a vertebra, vertebræ, or vertebral column; as in vertebrocostal.","pos":""}],"VERTEBRO-ILIAC":[{"def":"Ver\"te*bro-il\"i*ac, a.","pos":""}],"VERTEX":[{"def":"A turning point; the principal or highest point; top; summit; crown; apex.","pos":""},{"def":"The top, or crown, of the head.","pos":""}],"VERTICAL":[{"def":"Of or pertaining to the vertex; situated at the vertex, or highest point; directly overhead, or in the zenith; perpendicularly above one.","pos":""},{"def":"Perpendicular to the plane of the horizon; upright; plumb; as, a vertical line.","pos":""}],"VERTICALITY":[{"def":"The quality or state of being vertical; verticalness.","pos":""}],"VERTICALLY":[{"def":"In a vertical manner, position, or direction; perpendicularly; as, to look down vertically; to raise a thing vertically.","pos":""}],"VERTICALNESS":[{"def":"Quality or state of being vertical.","pos":""}],"VERTICIL":[{"def":"A circle either of leaves or flowers about a stem at the same node; a whorl.","pos":""}],"VERTICILLASTER":[{"def":"A whorl of flowers apparently of one cluster, but composed of two opposite axillary cymes, as in mint.","pos":""},{"def":"Arranged in a transverse whorl or whorls like the rays of a wheel; as, verticillate leaves of a plant; a verticillate shell.","pos":""}],"VERTICILLUS":[{"def":"A whorl; a verticil.","pos":""}],"VERTICITY":[{"def":"The quality or power of turning; revolution; rotation.","pos":""}],"VERTICLE":[{"def":"An axis; hinge; a turning point.","pos":""}],"VERTIGINATE":[{"def":"Turned round; giddy.","pos":""}],"VERTIGINOUS":[{"def":"Turning round; whirling; rotary; revolving; as, vertiginous motion.","pos":""},{"def":"Affected with vertigo; giddy; dizzy.","pos":""}],"VERTIGO":[{"def":"Dizziness or swimming of the head; an affection of the head in which objects, though stationary, appear to move in various directions, and the person affected finds it difficult to maintain an erect posture; giddiness.","pos":""},{"def":"Any one of numerous species of small land snails belonging to the genus Vertigo, having an elongated or conical spiral shell and usually teeth in the aperture.","pos":""}],"VERTILINEAR":[{"def":"Straight; rectilinear.","pos":""}],"VERTUOUS":[{"def":"Virtuous; powerful.","pos":""}]}