{"OBI":[{"def":"A species of sorcery, probably of African origin, practiced among the negroes of the West Indies.","pos":""},{"def":"A charm or fetich.","pos":""}],"OBIISM":[{"def":"Belief in, or the practice of, the obi superstitions and rites.","pos":""}],"OBIMBRICATE":[{"def":"Imbricated, with the overlapping ends directed downward.","pos":""}],"OBIT":[{"def":"Death; decease; the date of one's death.","pos":""},{"def":"A funeral solemnity or office; obsequies.","pos":""}],"OBITER":[{"def":"In passing; incidentally; by the way.","pos":""}],"OBITUAL":[{"def":"Of or pertaining to obits, or days when obits are celebrated; as, obitual days.","pos":""}],"OBITUARILY":[{"def":"In the manner of an obituary.","pos":""}],"OBITUARY":[{"def":"Of or pertaining to the death of a person or persons; as, an obituary notice; obituary poetry.","pos":""}]}