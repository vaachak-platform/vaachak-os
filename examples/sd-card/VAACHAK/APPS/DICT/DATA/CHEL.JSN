{"CHELA":[{"def":"The pincherlike claw of Crustacea and Arachnida.","pos":""}],"CHELATE":[{"def":"Same as Cheliferous.","pos":""}],"CHELERYTHRINE":[{"def":"Am alkaloidal principle obtained from the celandine, and named from the red color of its salts, It is a coloriess crystalline substance, and acts as an acrid narcotic poison.","pos":""}],"CHELICERA":[{"def":"One of the anterior pair of mouth organs, terminated by a pincherlike claw, in scorpions and allied Arachnida.","pos":""}],"CHELIDON":[{"def":"The hollow at the flexure of the arm.","pos":""}],"CHELIDONIC":[{"def":"Of, pertaining to, or derived from, the celandine.","pos":""}],"CHELIDONIUS":[{"def":"A small stone taken from the gizzard of a young swallow.","pos":""}],"CHELIFER":[{"def":"See Book scorpion, under Book.","pos":""}],"CHELIFEROUS":[{"def":"Having cheliform claws, like a crab.","pos":""}],"CHELIFORM":[{"def":"Having a movable joint or finger closing againts a preceding joint or a projecting part of it, so that the whole may be ised for grasping, as the claw of a crab; pincherlike.","pos":""}],"CHELONE":[{"def":"A genus of hardy perennial flowering plants, of the order Scrophulariaceaæ.","pos":""}],"CHELONIA":[{"def":"An order of reptiles, including the tortoises and turtles, perculiar in having a part of the vertebræ, ribs, and sternum united with the dermal plates so as to form a firm shell.","pos":""}],"CHELONIAN":[{"def":"Of or pertaining to animals of the tortoise kind.","pos":""},{"def":"One of the Chelonia.","pos":""}],"CHELURA":[{"def":"A genus of marine amphipod crustacea, which bore into and sometimes destroy timber.","pos":""}]}