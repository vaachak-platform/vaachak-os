{"FID":[{"def":"A square bar of wood or iron, used to support the topmast, being passed through a hole or mortise at its heel, and resting on the trestle trees.","pos":""},{"def":"A block of wood used in mounting and dismounting heavy guns.","pos":""}],"FIDALGO":[{"def":"The lowest title of nobility in Portugal, corresponding to that of Hidalgo in Spain.","pos":""}],"FIDDLE":[{"def":"A stringed instrument of music played with a bow; a violin; a kit.","pos":""},{"def":"A kind of dock (Rumex pulcher) with fiddle-shaped leaves; -- called also fiddle dock.","pos":""}],"FIDDLE-FADDLE":[{"def":"A trifle; trifling talk; nonsense.","pos":""}],"FIDDLE-SHAPED":[{"def":"Inversely ovate, with a deep hollow on each side.","pos":""}],"FIDDLEDEEDEE":[{"def":"An exclamatory word or phrase, equivalent to nonsense! [Colloq.","pos":""}],"FIDDLER":[{"def":"A burrowing crab of the genus Gelasimus, of many species.","pos":""},{"def":"The common European sandpiper (Tringoides hypoleucus); -- so called because it continually oscillates its body.","pos":""}],"FIDDLESTICK":[{"def":"The bow, strung with horsehair, used in playing the fiddle; a fiddle bow.","pos":""}],"FIDDLESTRING":[{"def":"One of the catgut strings of a fiddle.","pos":""}],"FIDDLEWOOD":[{"def":"The wood of several West Indian trees, mostly of the genus Citharexylum.","pos":""}],"FIDEJUSSION":[{"def":"The act or state of being bound as surety for another; suretyship.","pos":""}],"FIDEJUSSOR":[{"def":"A surety; one bound for another, conjointly with him; a guarantor.","pos":""}],"FIDELITY":[{"def":"Faithfulness; adherence to right; careful and exact observance of duty, or discharge of obligations.","pos":""}],"FIDES":[{"def":"Faith personified as a goddess; the goddess of faith.","pos":""}],"FIDGET":[{"def":"To move uneasily one way and the other; to move irregularly, or by fits and starts.","pos":""}],"FIDGETINESS":[{"def":"Quality of being fidgety.","pos":""}],"FIDGETY":[{"def":"Restless; uneasy.","pos":""}],"FIDIA":[{"def":"A genus of small beetles, of which one species (the grapevine Fidia, F.","pos":""}],"FIDICINAL":[{"def":"Of or pertaining to a stringed instrument.","pos":""}],"FIDUCIAL":[{"def":"Having faith or trust; confident; undoubting; firm.","pos":""},{"def":"Having the nature of a trust; fiduciary; as, fiducial power.","pos":""}],"FIDUCIALLY":[{"def":"With confidence.","pos":""}],"FIDUCIARY":[{"def":"Involving confidence or trust; confident; undoubting; faithful; firm; as, in a fiduciary capacity.","pos":""},{"def":"Holding, held, or founded, in trust.","pos":""}]}