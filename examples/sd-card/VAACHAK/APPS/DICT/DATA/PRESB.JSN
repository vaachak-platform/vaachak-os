{"PRESBYOPE":[{"def":"One who has presbyopia; a farsighted person.","pos":""}],"PRESBYOPIA":[{"def":"A defect of vision consequent upon advancing age.","pos":""}],"PRESBYOPIC":[{"def":"Affected by presbyopia; also, remedying presbyopia; farsighted.","pos":""}],"PRESBYTE":[{"def":"Same as Presbyope.","pos":""}],"PRESBYTER":[{"def":"One ordained to the second order in the ministry; -- called also priest.","pos":""},{"def":"A member of a presbytery whether lay or clerical.","pos":""}],"PRESBYTERAL":[{"def":"Of or pertaining to a presbyter or presbytery; presbyterial.","pos":""}],"PRESBYTERATE":[{"def":"A presbytery; also, presbytership.","pos":""}],"PRESBYTERESS":[{"def":"A female presbyter.","pos":""}],"PRESBYTERIAN":[{"def":"Of or pertaining to a presbyter, or to ecclesiastical government by presbyters; relating to those who uphold church government by presbyters; also, to the doctrine, discipline, and worship of a communion so governed.","pos":""}],"PRESBYTERIANISM":[{"def":"That form of church government which invests presbyters with all spiritual power, and admits no prelates over them; also, the faith and polity of the Presbyterian churches, taken collectively.","pos":""}],"PRESBYTERIUM":[{"def":"Same as Presbytery, 4.","pos":""}],"PRESBYTERSHIP":[{"def":"The office or station of a presbyter; presbyterate.","pos":""}],"PRESBYTERY":[{"def":"A judicatory consisting of all the ministers within a certain district, and one layman, who is a ruling elder, from each parish or church, commissioned to represent the church in conjunction with the pastor.","pos":""}],"PRESBYTIC":[{"def":"Same as Presbyopic.","pos":""}]}