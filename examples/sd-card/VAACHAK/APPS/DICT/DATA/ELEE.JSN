{"ELEEMOSYNARILY":[{"def":"In an eleemosynary manner; by charity; charitably.","pos":""}],"ELEEMOSYNARY":[{"def":"Relating to charity, alms, or almsgiving; intended for the distribution of charity; as, an eleemosynary corporation.","pos":""},{"def":"Given in charity or alms; having the nature of alms; as, eleemosynary assistance.","pos":""}]}