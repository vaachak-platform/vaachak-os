{"WEAK":[{"def":"Tending towards lower prices; as, a weak market.","pos":""}],"WEAK-HEARTED":[{"def":"Having little courage; of feeble spirit; dispirited; faint- hearted.","pos":""}],"WEAK-KNEED":[{"def":"Having weak knees; hence, easily yielding; wanting resolution.","pos":""}],"WEAK-MINDED":[{"def":"Having a weak mind, either naturally or by reason of disease; feebleminded; foolish; idiotic.","pos":""}],"WEAKEN":[{"def":"To make weak; to lessen the strength of; to deprive of strength; to debilitate; to enfeeble; to enervate; as, to weaken the body or the mind; to weaken the hands of a magistrate; to weaken the force of an objection or an argument.","pos":""},{"def":"To reduce in quality, strength, or spirit; as, to weaken tea; to weaken any solution or decoction.","pos":""}],"WEAKENER":[{"def":"One who, or that which, weakens.","pos":""}],"WEAKFISH":[{"def":"Any fish of the genus Cynoscion; a squeteague; -- so called from its tender mouth.","pos":""}],"WEAKISH":[{"def":"Somewhat weak; rather weak.","pos":""}],"WEAKISHNESS":[{"def":"Quality or state of being weakish.","pos":""}],"WEAKLING":[{"def":"A weak or feeble creature.","pos":""}],"WEAKLY":[{"def":"In a weak manner; with little strength or vigor; feebly.","pos":""}],"WEAKNESS":[{"def":"The quality or state of being weak; want of strength or firmness; lack of vigor; want of resolution or of moral strength; feebleness.","pos":""},{"def":"That which is a mark of lack of strength or resolution; a fault; a defect.","pos":""}],"WEAL":[{"def":"The mark of a stripe.","pos":""}],"WEAL-BALANCED":[{"def":"Balanced or considered with reference to public weal.","pos":""}],"WEALD":[{"def":"A wood or forest; a wooded land or region; also, an open country; -- often used in place names.","pos":""}],"WEALDEN":[{"def":"Of or pertaining to the lowest division of the Cretaceous formation in England and on the Continent, which overlies the Oölitic series.","pos":""}],"WEALDISH":[{"def":"Of or pertaining to a weald, esp.","pos":""}],"WEALSMAN":[{"def":"A statesman; a politician.","pos":""}],"WEALTH":[{"def":"Weal; welfare; prosperity; good.","pos":""},{"def":"Large possessions; a comparative abundance of things which are objects of human desire; esp.","pos":""}],"WEALTHFUL":[{"def":"Full of wealth; wealthy; prosperous.","pos":""}],"WEALTHILY":[{"def":"In a wealthy manner; richly.","pos":""}],"WEALTHINESS":[{"def":"The quality or state of being wealthy, or rich; richness; opulence.","pos":""}],"WEALTHY":[{"def":"Having wealth; having large possessions, or larger than most men, as lands, goods, money, or securities; opulent; affluent; rich.","pos":""},{"def":"Hence, ample; full; satisfactory; abundant.","pos":""}],"WEAN":[{"def":"To accustom and reconcile, as a child or other young animal, to a want or deprivation of mother's milk; to take from the breast or udder; to cause to cease to depend on the mother nourishment.","pos":""},{"def":"Hence, to detach or alienate the affections of, from any object of desire; to reconcile to the want or loss of anything.","pos":""}],"WEANEDNESS":[{"def":"Quality or state of being weaned.","pos":""}],"WEANLING":[{"def":"Wean\"ling, Defn: a.","pos":""}],"WEAPON":[{"def":"A thorn, prickle, or sting with which many plants are furnished.","pos":""}],"WEAPONED":[{"def":"Furnished with weapons, or arms; armed; equipped.","pos":""}],"WEAPONLESS":[{"def":"Having no weapon.","pos":""}],"WEAPONRY":[{"def":"Weapons, collectively; as, an array of weaponry.","pos":""}],"WEAR":[{"def":"To cause to go about, as a vessel, by putting the helm up, instead of alee as in tacking, so that the vessel's bow is turned away from, and her stern is presented to, the wind, and, as she turns still farther, her sails fill on the other side; to veer.","pos":""}],"WEARABLE":[{"def":"Capable of being worn; suitable to be worn.","pos":""}],"WEARER":[{"def":"One who wears or carries as appendant to the body; as, the wearer of a cloak, a sword, a crown, a shackle, etc.","pos":""},{"def":"That which wastes or diminishes.","pos":""}],"WEARIABLE":[{"def":"That may be wearied.","pos":""}],"WEARIFUL":[{"def":"Abounding in qualities which cause weariness; wearisome.","pos":""}],"WEARILESS":[{"def":"Incapable of being wearied.","pos":""}],"WEARILY":[{"def":"In a weary manner.","pos":""}],"WEARINESS":[{"def":"The quality or state of being weary or tried; lassitude; exhaustion of strength; fatigue.","pos":""}],"WEARING":[{"def":"The act of one who wears; the manner in which a thing wears; use; conduct; consumption.","pos":""},{"def":"That which is worn; clothes; garments.","pos":""}],"WEARISH":[{"def":"Weak; withered; shrunk.","pos":""},{"def":"Insipid; tasteless; unsavory.","pos":""}],"WEARISOME":[{"def":"Causing weariness; tiresome; tedious; weariful; as, a wearisome march; a wearisome day's work; a wearisome book.","pos":""}],"WEARY":[{"def":"Having the strength exhausted by toil or exertion; worn out in respect to strength, endurance, etc.","pos":""},{"def":"Causing weariness; tiresome.","pos":""}],"WEASAND":[{"def":"The windpipe; -- called also, formerly, wesil.","pos":""}],"WEASEL":[{"def":"Any one of various species of small carnivores belonging to the genus Putorius, as the ermine and ferret.","pos":""}],"WEASEL-FACED":[{"def":"Having a thin, sharp face, like a weasel.","pos":""}],"WEASER":[{"def":"The American merganser; -- called also weaser sheldrake.","pos":""}],"WEASINESS":[{"def":"Quality or state of being weasy; full feeding; sensual indulgence.","pos":""}],"WEASY":[{"def":"Given to sensual indulgence; gluttonous.","pos":""}],"WEATHER":[{"def":"The state of the air or atmosphere with respect to heat or cold, wetness or dryness, calm or storm, clearness or cloudiness, or any other meteorological phenomena; meteorological condition of the atmosphere; as, warm weather; cold weather; wet weather; dry weather, etc.","pos":""},{"def":"Vicissitude of season; meteorological change; alternation of the state of the air.","pos":""}],"WEATHER MAP":[{"def":"A map or chart showing the principal meteorological elements at a given hour and over an extended region.","pos":""}],"WEATHER SIGNAL":[{"def":"Any signal giving information about the weather.","pos":""}],"WEATHER STATION":[{"def":"A station for taking meteorological observations, making weather forecasts, or disseminating such information.","pos":""}],"WEATHER-BEATEN":[{"def":"Beaten or harassed by the weather; worn by exposure to the weather, especially to severe weather.","pos":""}],"WEATHER-BIT":[{"def":"A turn of the cable about the end of the windlass, without the bits.","pos":""}],"WEATHER-BITTEN":[{"def":"Eaten into, defaced, or worn, by exposure to the weather.","pos":""}],"WEATHER-BOARD":[{"def":"To nail boards upon so as to lap one over another, in order to exclude rain, snow, etc.","pos":""}],"WEATHER-BOUND":[{"def":"Kept in port or at anchor by storms; delayed by bad weather; as, a weather-bound vessel.","pos":""}],"WEATHER-DRIVEN":[{"def":"Driven by winds or storms; forced by stress of weather.","pos":""}],"WEATHER-FEND":[{"def":"To defend from the weather; to shelter.","pos":""}],"WEATHERBIT":[{"def":"To take another turn with, as a cable around a windlass.","pos":""}],"WEATHERBOARDING":[{"def":"Weath\"er*board`ing, n.","pos":""}],"WEATHERCOCK":[{"def":"A vane, or weather vane; -- so called because originally often in the figure of a cock, turning on the top of a spire with the wind, and showing its direction.","pos":""},{"def":"Hence, any thing or person that turns easily and frequently; one who veers with every change of current opinion; a fickle, inconstant person.","pos":""}],"WEATHERED":[{"def":"Made sloping, so as to throw off water; as, a weathered cornice or window sill.","pos":""},{"def":"Having the surface altered in color, texture, or composition, or the edges rounded off by exposure to the elements.","pos":""}],"WEATHERGLASS":[{"def":"An instrument to indicate the state of the atmosphere, especially changes of atmospheric pressure, and hence changes of weather, as a barometer or baroscope.","pos":""}],"WEATHERING":[{"def":"The action of the elements on a rock in altering its color, texture, or composition, or in rounding off its edges.","pos":""}],"WEATHERLINESS":[{"def":"The quality of being weatherly.","pos":""}],"WEATHERLY":[{"def":"Working, or able to sail, close to the wind; as, a weatherly ship.","pos":""}],"WEATHERMOST":[{"def":"Being farthest to the windward.","pos":""}],"WEATHERPROOF":[{"def":"Proof against rough weather.","pos":""}],"WEATHERWISE":[{"def":"Skillful in forecasting the changes of the weather.","pos":""}],"WEATHERWISER":[{"def":"Something that foreshows the weather.","pos":""}],"WEATHERWORN":[{"def":"Worn by the action of, or by exposure to, the weather.","pos":""}],"WEAVE":[{"def":"To unite, as threads of any kind, in such a manner as to form a texture; to entwine or interlace into a fabric; as, to weave wool, silk, etc.","pos":""},{"def":"To form, as cloth, by interlacing threads; to compose, as a texture of any kind, by putting together textile materials; as, to weave broadcloth; to weave a carpet; hence, to form into a fabric; to compose; to fabricate; as, to weave the plot of a story.","pos":""}],"WEAVER":[{"def":"An aquatic beetle of the genus Gyrinus.","pos":""}],"WEAVING":[{"def":"An incessant motion of a horse's head, neck, and body, from side to side, fancied to resemble the motion of a hand weaver in throwing the shuttle.","pos":""}],"WEAZEN":[{"def":"Thin; sharp; withered; wizened; as, a weazen face.","pos":""}],"WEAZENY":[{"def":"Somewhat weazen; shriveled.","pos":""}]}