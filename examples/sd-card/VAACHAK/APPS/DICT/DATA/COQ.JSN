{"COQUE":[{"def":"A small loop or bow of ribbon used in making hats, boas, etc.","pos":""}],"COQUELICOT":[{"def":"The wild poppy, or red corn rose.","pos":""}],"COQUET":[{"def":"To attempt to attract the notice, admiration, or love of; to treat with a show of tenderness or regard, with a view to deceive and disappoint.","pos":""}],"COQUETRY":[{"def":"Attempts to attract admoration, notice, or love, for the mere gratification of vanity; trifling in love.","pos":""}],"COQUETTE":[{"def":"A tropical humming bird of the genus Lophornis, with very elegant neck plumes.","pos":""}],"COQUETTISH":[{"def":"Practicing or exhibiting coquetry; alluring; enticing.","pos":""}],"COQUETTISHLY":[{"def":"In a coquettish manner.","pos":""}],"COQUILLA NUT":[{"def":"The fruit of a Brazilian tree (Attalea funifera of Martius.","pos":""}],"COQUILLE":[{"def":"Co*quille\" (ko*kel\"; F.","pos":""}],"COQUIMBITE":[{"def":"A mineral consisting principally of sulphate of iron; white copperas; -- so called because found in the province of Coquimbo, Chili.","pos":""}],"COQUINA":[{"def":"A soft, whitish, coral-like stone, formed of broken shells and corals, found in the southern United States, and used for roadbeds and for building material, as in the fort at St.","pos":""}]}