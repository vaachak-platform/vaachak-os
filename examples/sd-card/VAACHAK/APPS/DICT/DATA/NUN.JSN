{"NUN":[{"def":"A woman devoted to a religious life, who lives in a convent, under the three vows of poverty, chastity, and obedience.","pos":""}],"NUNATAK":[{"def":"In Greenland, an insular hill or mountain surrounded by an ice sheet.","pos":""}],"NUNC DIMITTIS":[{"def":"The song of Simeon (Luke ii.","pos":""}],"NUNCHION":[{"def":"A portion of food taken at or after noon, usually between full meals; a luncheon.","pos":""}],"NUNCIATE":[{"def":"One who announces; a messenger; a nuncio.","pos":""}],"NUNCIATURE":[{"def":"The office of a nuncio.","pos":""}],"NUNCIO":[{"def":"The permanent official representative of the pope at a foreign court or seat of government.","pos":""}],"NUNCUPATE":[{"def":"To declare publicly or solemnly; to proclaim formally.","pos":""},{"def":"To dedicate by declaration; to inscribe; as, to nuncupate a book.","pos":""}],"NUNCUPATION":[{"def":"The act of nuncupating.","pos":""}],"NUNCUPATIVE":[{"def":"Publicly or solemnly declaratory.","pos":""},{"def":"Nominal; existing only in name.","pos":""}],"NUNCUPATORY":[{"def":"Nuncupative; oral.","pos":""}],"NUNDINAL":[{"def":"A nundinal letter.","pos":""},{"def":"Of or pertaining to a fair, or to a market day.","pos":""}],"NUNDINATE":[{"def":"To buy and sell at fairs or markets.","pos":""}],"NUNDINATION":[{"def":"Traffic at fairs; marketing; buying and selling.","pos":""}],"NUNNATION":[{"def":"The pronunciation of n at the end of words.","pos":""}],"NUNNERY":[{"def":"A house in which nuns reside; a cloister or convent in which women reside for life, under religious vows.","pos":""}],"NUNNISH":[{"def":"Of, pertaining to, or resembling a nun; characteristic of a nun.","pos":""}]}