{"BARD":[{"def":"Defensive armor formerly worn by a man at arms.","pos":""},{"def":"A thin slice of fat bacon used to cover any meat or game.","pos":""}],"BARDED":[{"def":"Wearing rich caparisons.","pos":""}],"BARDIC":[{"def":"Of or pertaining to bards, or their poetry.","pos":""}],"BARDIGLIO":[{"def":"An Italian marble of which the principal varieties occur in the neighborhood of Carrara and in Corsica.","pos":""}],"BARDISH":[{"def":"Pertaining to, or written by, a bard or bards.","pos":""}],"BARDISM":[{"def":"The system of bards; the learning and maxims of bards.","pos":""}],"BARDLING":[{"def":"An inferior bard.","pos":""}],"BARDSHIP":[{"def":"The state of being a bard.","pos":""}]}