{"PAM":[{"def":"The knave of clubs.","pos":""}],"PAMPANO":[{"def":"Same as Pompano.","pos":""}],"PAMPAS":[{"def":"Vast plains in the central and southern part of the Argentine Republic in South America.","pos":""}],"PAMPER":[{"def":"To feed to the full; to feed luxuriously; to glut; as, to pamper the body or the appetite.","pos":""},{"def":"To gratify inordinately; to indulge to excess; as, to pamper pride; to pamper the imagination.","pos":""}],"PAMPERED":[{"def":"Fed luxuriously; indulged to the full; hence, luxuriant.","pos":""}],"PAMPERER":[{"def":"One who, or that which, pampers.","pos":""}],"PAMPERO":[{"def":"A violent wind from the west or southwest, which sweeps over the pampas of South America and the adjacent seas, often doing great damage.","pos":"noun"}],"PAMPEROS":[{"def":"A tribe of Indians inhabiting the pampas of South America.","pos":""}],"PAMPHLET":[{"def":"A writing; a book.","pos":""},{"def":"A small book consisting of a few sheets of printed paper, stitched together, often with a paper cover, but not bound; a short essay or written discussion, usually on a subject of current interest.","pos":""}],"PAMPHLETEER":[{"def":"A writer of pamphlets; a scribbler.","pos":""}],"PAMPINIFORM":[{"def":"In the form of tendrils; -- applied especially to the spermatic and ovarian veins.","pos":""}],"PAMPRE":[{"def":"An ornament, composed of vine leaves and bunches of grapes, used for decorating spiral columns.","pos":""}],"PAMPRODACTYLOUS":[{"def":"Having all the toes turned forward, as the colies.","pos":""},{"def":"Combining forms signifying all, every; as, panorama, pantheism, pantagraph, pantograph.","pos":""}]}