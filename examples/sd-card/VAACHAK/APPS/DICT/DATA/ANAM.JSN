{"ANAMESE":[{"def":"Of or pertaining to Anam, to southeastern Asia.","pos":""},{"def":"A native of Anam.","pos":""}],"ANAMNESIS":[{"def":"A recalling to mind; recollection.","pos":""}],"ANAMNESTIC":[{"def":"Aiding the memory; as, anamnestic remedies.","pos":""}],"ANAMNIOTIC":[{"def":"Without, or not developing, an amnion.","pos":""}],"ANAMORPHISM":[{"def":"A gradual progression from one type to another, generally ascending.","pos":""}],"ANAMORPHOSCOPE":[{"def":"An instrument for restoring a picture or image distorted by anamorphosis to its normal proportions.","pos":""}],"ANAMORPHOSIS":[{"def":"A distorted or monstrous projection or representation of an image on a plane or curved surface, which, when viewed from a certain point, or as reflected from a curved mirror or through a polyhedron, appears regular and in proportion; a deformation of an image.","pos":""},{"def":"Same as Anamorphism, 2.","pos":""}],"ANAMORPHOSY":[{"def":"Same as Anamorphosis.","pos":""}]}