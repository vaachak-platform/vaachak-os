{"CONACRE":[{"def":"To underlet a proportion of, for a single crop; -- said of a farm.","pos":""}],"CONARIUM":[{"def":"The pineal gland.","pos":""}],"CONATION":[{"def":"The power or act which directs or impels to effort of any kind, whether muscular or psychical.","pos":""}],"CONATIVE":[{"def":"Of or pertaining to conation.","pos":""}],"CONATUS":[{"def":"A natural tendency inherent in a body to develop itself; an attempt; an effort.","pos":""}]}