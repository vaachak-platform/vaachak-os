{"RASANTE":[{"def":"Sweeping; grazing; -- applied to a style of fortification in which the command of the works over each other, and over the country, is kept very low, in order that the shot may more effectually sweep or graze the ground before them.","pos":""}],"RASCAL":[{"def":"One of the rabble; a low, common sort of person or creature; collectively, the rabble; the common herd; also, a lean, ill- conditioned beast, esp.","pos":""},{"def":"A mean, trickish fellow; a base, dishonest person; a rogue; a scoundrel; a trickster.","pos":""}],"RASCALDOM":[{"def":"State of being a rascal; rascality; domain of rascals; rascals, collectively.","pos":""}],"RASCALESS":[{"def":"A female rascal.","pos":""}],"RASCALITY":[{"def":"The quality or state of being rascally, or a rascal; mean trickishness or dishonesty; base fraud.","pos":""},{"def":"The poorer and lower classes of people.","pos":""}],"RASCALLION":[{"def":"A low, mean wretch [Written also rascalion.","pos":""}],"RASCALLY":[{"def":"Like a rascal; trickish or dishonest; base; worthless; -- often in humorous disparagement, without implication of dishonesty.","pos":""}],"RASE":[{"def":"To rub along the surface of; to graze.","pos":""},{"def":"To rub or scratch out; to erase.","pos":""}],"RASH":[{"def":"To pull off or pluck violently.","pos":""},{"def":"To slash; to hack; to slice.","pos":""}],"RASHER":[{"def":"A California rockfish (Sebastichthys miniatus).","pos":""}],"RASHFUL":[{"def":"Rash; hasty; precipitate.","pos":""}],"RASHLY":[{"def":"In a rush manner; with precipitation.","pos":""}],"RASHNESS":[{"def":"The quality of state of being rash.","pos":""}],"RASKOLNIK":[{"def":"One of the separatists or dissenters from the established or Greek church in Russia.","pos":""}],"RASORES":[{"def":"An order of birds; the Gallinæ.","pos":""}],"RASORIAL":[{"def":"Of or pertaining to the Rasores, or gallinaceous birds, as the peacock, domestic fowl, patridge, and the like.","pos":""}],"RASP":[{"def":"To rub or file with a rasp; to rub or grate with a rough file; as, to rasp wood to make it smooth; to rasp bones to powder.","pos":""},{"def":"Hence, figuratively: To grate harshly upon; to offend by coarse or rough treatment or language; as, some sounds rasp the ear; his insults rasped my temper.","pos":""}],"RASPATORY":[{"def":"A surgeon's rasp.","pos":""}],"RASPBERRY":[{"def":"Rasp\"ber*ry, n, Etym: [From E.","pos":""}],"RASPER":[{"def":"One who, or which, rasps; a scraper.","pos":""}],"RASPY":[{"def":"Like a rasp, or the sound made by a rasp; grating.","pos":""}],"RASSE":[{"def":"A carnivore (Viverricula Mallaccensis) allied to the civet but smaller, native of China and the East Indies.","pos":""}],"RASURE":[{"def":"The act of rasing, scraping, or erasing; erasure; obliteration.","pos":""},{"def":"A mark by which a letter, word, or any part of a writing or print, is erased, effaced, or obliterated; an erasure.","pos":""}]}