{"BILABIATE":[{"def":"Having two lips, as the corols of certain flowers.","pos":""}],"BILALO":[{"def":"A two-masted passenger boat or small vessel, used in the bay of Manila.","pos":""},{"def":"Formed of two plates, as the stigma of the Mimulus; also, having two elevated ridges, as in the lip of certain flowers.","pos":""}],"BILANDER":[{"def":"A small two-masted merchant vessel, fitted only for coasting, or for use in canals, as in Holland.","pos":""}],"BILATERAL":[{"def":"Of or pertaining to the two sides of a central area or organ, or of a central axis; as, bilateral symmetry in animals, where there is a similarity of parts on the right and left sides of the body.","pos":""}],"BILATERALITY":[{"def":"State of being bilateral.","pos":""}],"BILBERRY":[{"def":"The European whortleberry (Vaccinium myrtillus); also, its edible bluish black fruit.","pos":""}],"BILBO":[{"def":"A long bar or bolt of iron with sliding shackles, and a lock at the end, to confine the feet of prisoners or offenders, esp.","pos":""}],"BILBOQUET":[{"def":"The toy called cup and ball.","pos":""}],"BILCOCK":[{"def":"The European water rail.","pos":""}],"BILDSTEIN":[{"def":"Same as Agalmatolite.","pos":""}],"BILE":[{"def":"A yellow, or greenish, viscid fluid, usually alkaline in reaction, secreted by the liver.","pos":""}],"BILECTION":[{"def":"That portion of a group of moldings which projects beyond the general surface of a panel; a bolection.","pos":""}],"BILESTONE":[{"def":"A gallstone, or biliary calculus.","pos":""}],"BILGE":[{"def":"That part of a ship's hull or bottom which is broadest and most nearly flat, and on which she would rest if aground.","pos":""}],"BILGY":[{"def":"Having the smell of bilge water.","pos":""}],"BILIARY":[{"def":"Relating or belonging to bile; conveying bile; as, biliary acids; biliary ducts.","pos":""}],"BILIATION":[{"def":"The production and excretion of bile.","pos":""}],"BILIFEROUS":[{"def":"Generating bile.","pos":""}],"BILIFUSCIN":[{"def":"A brownish green pigment found in human gallstones and in old bile.","pos":""},{"def":"The berries of two East Indian species of Averrhoa, of the Oxalideæ or Sorrel family.","pos":""}],"BILIMENT":[{"def":"A woman's ornament; habiliment.","pos":""}],"BILIN":[{"def":"A name applied to the amorphous or crystalline mass obtained from bile by the action of alcohol and ether.","pos":""}],"BILINEAR":[{"def":"Of, pertaining to, or included by, two lines; as, bilinear coördinates.","pos":""}],"BILINGUAL":[{"def":"Containing, or consisting of, two languages; expressed in two languages; as, a bilingual inscription; a bilingual dictionary.","pos":""}],"BILINGUALISM":[{"def":"Quality of being bilingual.","pos":""}],"BILINGUIST":[{"def":"One versed in two languages.","pos":""}],"BILINGUOUS":[{"def":"Having two tongues, or speaking two languages.","pos":""}],"BILIOUS":[{"def":"Of or pertaining to the bile.","pos":""},{"def":"Disordered in respect to the bile; troubled with and excess of bile; as, a bilious patient; dependent on, or characterized by, an excess of bile; as, bilious symptoms.","pos":""}],"BILIOUSNESS":[{"def":"The state of being bilious.","pos":""}],"BILIPRASIN":[{"def":"A dark green pigment found in small quantity in human gallstones.","pos":""}],"BILIRUBIN":[{"def":"A reddish yellow pigment present in human bile, and in that from carnivorous and herbivorous animals; the normal biliary pigment.","pos":""}],"BILITERAL":[{"def":"Consisting of two letters; as, a biliteral root of a Sanskrit verb.","pos":""},{"def":"A word, syllable, or root, consisting of two letters.","pos":""}],"BILITERALISM":[{"def":"The property or state of being biliteral.","pos":""}],"BILIVERDIN":[{"def":"A green pigment present in the bile, formed from bilirubin by oxidation.","pos":""}],"BILK":[{"def":"To frustrate or disappoint; to deceive or defraud, by nonfulfillment of engagement; to leave in the lurch; to give the slip to; as, to bilk a creditor.","pos":""}],"BILL":[{"def":"A beak, as of a bird, or sometimes of a turtle or other animal.","pos":""}],"BILL BOOK":[{"def":"A book in which a person keeps an account of his notes, bills, bills of exchange, etc.","pos":""}],"BILL BROKER":[{"def":"One who negotiates the discount of bills.","pos":""}],"BILL HOLDER":[{"def":"A person who holds a bill or acceptance.","pos":""},{"def":"A device by means of which bills, etc.","pos":""}],"BILLABONG":[{"def":"In Australia, a blind channel leading out from a river; -- sometimes called an anabranch.","pos":""}],"BILLARD":[{"def":"An English fish, allied to the cod; the coalfish.","pos":""},{"def":"A weevil or curculio of various species, as the corn weevil.","pos":""}],"BILLBOARD":[{"def":"A piece of thick plank, armed with iron plates, and fixed on the bow or fore channels of a vessel, for the bill or fluke of the anchor to rest on.","pos":""}],"BILLED":[{"def":"Furnished with, or having, a bill, as a bird; -- used in composition; as, broad-billed.","pos":""}],"BILLET":[{"def":"A small paper; a note; a short letter.","pos":""},{"def":"A ticket from a public officer directing soldiers at what house to lodge; as, a billet of residence.","pos":""}],"BILLET-DOUX":[{"def":"A love letter or note.","pos":""}],"BILLETHEAD":[{"def":"A round piece of timber at the bow or stern of a whaleboat, around which the harpoon lone is run out when the whale darts off.","pos":""}],"BILLFISH":[{"def":"A name applied to several distinct fishes: (a) The garfish (Tylosurus, or Belone, longirostris) and allied species.","pos":""}],"BILLHEAD":[{"def":"A printed form, used by merchants in making out bills or rendering accounts.","pos":""}],"BILLHOOK":[{"def":"A thick, heavy knife with a hooked point, used in pruning hedges, etc.","pos":""}],"BILLIARD":[{"def":"Of or pertaining to the game of billiards.","pos":""}],"BILLIARDS":[{"def":"A game played with ivory balls o a cloth-covered, rectangular table, bounded by elastic cushions.","pos":""}],"BILLING":[{"def":"Caressing; kissing.","pos":""}],"BILLINGSGATE":[{"def":"A market near the Billings gate in London, celebrated for fish and foul language.","pos":""},{"def":"Coarsely abusive, foul, or profane language; vituperation; ribaldry.","pos":""}],"BILLION":[{"def":"According to the French and American method of numeration, a thousand millions, or 1,000,000,000; according to the English method, a million millions, or 1,000,000,000,000.","pos":""}],"BILLMAN":[{"def":"One who uses, or is armed with, a bill or hooked ax.","pos":""}],"BILLON":[{"def":"An alloy of gold and silver with a large proportion of copper or other base metal, used in coinage.","pos":""}],"BILLOT":[{"def":"Bullion in the bar or mass.","pos":""}],"BILLOW":[{"def":"A great wave or surge of the sea or other water, caused usually by violent wind.","pos":""},{"def":"A great wave or flood of anything.","pos":""}],"BILLOWY":[{"def":"Of or pertaining to billows; swelling or swollen into large waves; full of billows or surges; resembling billows.","pos":""},{"def":"One whose occupation is to post handbills or posters in public places.","pos":""}],"BILLY":[{"def":"A slubbing or roving machine.","pos":""}],"BILLYBOY":[{"def":"A flat-bottomed river barge or coasting vessel.","pos":""},{"def":"A round, low-crowned felt hat; a wideawake.","pos":""}],"BILOBATE":[{"def":"Divided into two lobes or segments.","pos":""}],"BILOCATION":[{"def":"Double location; the state or power of being in two places at the same instant; -- a miraculous power attributed to some of the saints.","pos":""}],"BILOCULAR":[{"def":"Divided into two cells or compartments; as, a bilocular pericarp.","pos":""}],"BILTONG":[{"def":"Lean meat cut into strips and sun-dried.","pos":""}]}