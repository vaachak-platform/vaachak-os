{"BAM":[{"def":"An imposition; a cheat; a hoax.","pos":""}],"BAMBINO":[{"def":"A child or baby; esp.","pos":""}],"BAMBOCCIADE":[{"def":"A representation of a grotesque scene from common or rustic life.","pos":""}],"BAMBOO":[{"def":"A plant of the family of grasses, and genus Bambusa, growing in tropical countries.","pos":""}],"BAMBOOZLE":[{"def":"To deceive by trickery; to cajole by confusing the senses; to hoax; to mystify; to humbug.","pos":""}],"BAMBOOZLER":[{"def":"A swindler; one who deceives by trickery.","pos":""}]}