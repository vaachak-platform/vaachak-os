{"DAHLIA":[{"def":"A genus of plants native to Mexico and Central America, of the order Compositæ; also, any plant or flower of the genus.","pos":""}],"DAHLIN":[{"def":"A variety of starch extracted from the dahlia; -- called also inulin.","pos":""}],"DAHOON":[{"def":"An evergreen shrub or small tree (Ilex cassine) of the southern United States, bearing red drupes and having soft, white, close- grained wood; -- called also dahoon holly.","pos":""}]}