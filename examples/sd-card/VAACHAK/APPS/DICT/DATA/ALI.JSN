{"ALIBI":[{"def":"The plea or mode of defense under which a person on trial for a crime proves or attempts to prove that he was in another place when the alleged act was committed; as, to set up an alibi; to prove an alibi.","pos":""}],"ALIBILITY":[{"def":"Quality of being alible.","pos":""}],"ALIBLE":[{"def":"Nutritive; nourishing.","pos":""}],"ALICANT":[{"def":"A kind of wine, formerly much esteemed; -- said to have been made near Alicant, in Spain.","pos":""}],"ALIDADE":[{"def":"The portion of a graduated instrument, as a quadrant or astrolabe, carrying the sights or telescope, and showing the degrees cut off on the arc of the instrument Whewell.","pos":""}],"ALIEN":[{"def":"Not belonging to the same country, land, or government, or to the citizens or subjects thereof; foreign; as, alien subjects, enemies, property, shores.","pos":""},{"def":"Wholly different in nature; foreign; adverse; inconsistent (with); incongruous; -- followed by from or sometimes by to; as, principles alien from our religion.","pos":""}],"ALIENABILITY":[{"def":"Capability of being alienated.","pos":""}],"ALIENABLE":[{"def":"Capable of being alienated, sold, or transferred to another; as, land is alienable according to the laws of the state.","pos":""}],"ALIENAGE":[{"def":"The state or legal condition of being an alien.","pos":""},{"def":"The state of being alienated or transferred to another.","pos":""}],"ALIENATE":[{"def":"Estranged; withdrawn in affection; foreign; -- with from.","pos":""}],"ALIENATION":[{"def":"A transfer of title, or a legal conveyance of property to another.","pos":""}],"ALIENATOR":[{"def":"One who alienates.","pos":""}],"ALIENE":[{"def":"To alien or alienate; to transfer, as title or property; as, to aliene an estate.","pos":""}],"ALIENEE":[{"def":"One to whom the title of property is transferred; -- opposed to alienor.","pos":""}],"ALIENISM":[{"def":"The status or legal condition of an alien; alienage.","pos":""},{"def":"The study or treatment of diseases of the mind.","pos":""}],"ALIENIST":[{"def":"One who treats diseases of the mind.","pos":""}],"ALIENOR":[{"def":"One who alienates or transfers property to another.","pos":""}],"ALIFE":[{"def":"On my life; dearly.","pos":""}],"ALIFEROUS":[{"def":"Having wings, winged; aligerous.","pos":""}],"ALIFORM":[{"def":"Wing-shaped; winglike.","pos":""}],"ALIGEROUS":[{"def":"Having wings; winged.","pos":""}],"ALIGHT":[{"def":"To spring down, get down, or descend, as from on horseback or from a carriage; to dismount.","pos":""},{"def":"To descend and settle, lodge, rest, or stop; as, a flying bird alights on a tree; snow alights on a roof.","pos":""}],"ALIGN":[{"def":"To adjust or form to a line; to range or form in line; to bring into line; to aline.","pos":""}],"ALIGNMENT":[{"def":"The ground-plan of a railway or other road, in distinction from the grades or profile.","pos":""}],"ALIKE":[{"def":"Having resemblance or similitude; similar; without difference.","pos":""}],"ALIMENT":[{"def":"That which nourishes; food; nutriment; anything which feeds or adds to a substance in natural growth.","pos":""},{"def":"An allowance for maintenance.","pos":""}],"ALIMENTAL":[{"def":"Supplying food; having the quality of nourishing; furnishing the materials for natural growth; as, alimental sap.","pos":""}],"ALIMENTALLY":[{"def":"So as to serve for nourishment or food; nourishing quality.","pos":""}],"ALIMENTARINESS":[{"def":"The quality of being alimentary; nourishing quality.","pos":""}],"ALIMENTARY":[{"def":"Pertaining to aliment or food, or to the function of nutrition; nutritious; alimental; as, alimentary substances.","pos":""}],"ALIMENTATION":[{"def":"The act or process of affording nutriment; the function of the alimentary canal.","pos":""},{"def":"State or mode of being nourished.","pos":""}],"ALIMENTIVENESS":[{"def":"The instinct or faculty of appetite for food.","pos":""}],"ALIMONIOUS":[{"def":"Affording food; nourishing.","pos":""}],"ALIMONY":[{"def":"An allowance made to a wife out of her husband's estate or income for her support, upon her divorce or legal separation from him, or during a suit for the same.","pos":""}],"ALINASAL":[{"def":"Pertaining to expansions of the nasal bone or cartilage.","pos":""}],"ALINE":[{"def":"To range or place in a line; to bring into line; to align.","pos":""}],"ALINEATION":[{"def":"See Allineation.","pos":""}],"ALINEMENT":[{"def":"Same as Alignment.","pos":""}],"ALINER":[{"def":"One who adjusts things to a line or lines or brings them into line.","pos":""}],"ALIOTH":[{"def":"A star in the tail of the Great Bear, the one next the bowl in the Dipper.","pos":""}],"ALIPED":[{"def":"Wing-footed, as the bat.","pos":""},{"def":"An animal whose toes are connected by a membrane, serving for a wing, as the bat.","pos":""}],"ALIPHATIC":[{"def":"Of, pertaining to, or derived from, fat; fatty; -- applied to compounds having an openc-hain structure.","pos":""}],"ALIQUANT":[{"def":"An aliquant part of a number or quantity is one which does not divide it without leaving a remainder; thus, 5 is an aliquant part of 16.","pos":""}],"ALIQUOT":[{"def":"An aliquot part of a number or quantity is one which will divide it without a remainder; thus, 5 is an aliquot part of 15.","pos":""}],"ALISEPTAL":[{"def":"Relating to expansions of the nasal septum.","pos":""}],"ALISH":[{"def":"Like ale; as, an alish taste.","pos":""}],"ALISPHENOID":[{"def":"The alisphenoid bone.","pos":""},{"def":"Pertaining to or forming the wing of the sphenoid; relating to a bone in the base of the skull, which in the adult is often consolidated with the sphenoid; as, alisphenoid bone; alisphenoid canal.","pos":""}],"ALITRUNK":[{"def":"The segment of the body of an insect to which the wings are attached; the thorax.","pos":""}],"ALITURGICAL":[{"def":"Applied to those days when the holy sacrifice is not offered.","pos":""}],"ALIUNDE":[{"def":"From another source; from elsewhere; as, a case proved aliunde; evidence aliunde.","pos":""}],"ALIVE":[{"def":"Having life, in opposition to dead; living; being in a state in which the organs perform their functions; as, an animal or a plant which is alive.","pos":""},{"def":"In a state of action; in force or operation; unextinguished; unexpired; existent; as, to keep the fire alive; to keep the affections alive.","pos":""}],"ALIZARI":[{"def":"The madder of the Levant.","pos":""}],"ALIZARIN":[{"def":"A coloring principle, C14H6O2(OH)2, found in madder, and now produced artificially from anthracene.","pos":""}]}