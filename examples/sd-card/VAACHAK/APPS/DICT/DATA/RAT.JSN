{"RAT":[{"def":"One of the several species of small rodents of the genus Mus and allied genera, larger than mice, that infest houses, stores, and ships, especially the Norway, or brown, rat (M.","pos":""}],"RAT-TAIL":[{"def":"Like a rat's tale in form; as, a rat-tail file, which is round, slender, and tapering.","pos":""}],"RAT-TAILED":[{"def":"Having a long, tapering tail like that of a rat.","pos":""}],"RATA":[{"def":"A New Zealand forest tree (Metrosideros robusta), also, its hard dark red wood, used by the Maoris for paddles and war clubs.","pos":""}],"RATABILITY":[{"def":"The quality or state of being ratable.","pos":""}],"RATABLE":[{"def":"Capable of being rated, or set at a certain value.","pos":""},{"def":"Liable to, or subjected by law to, taxation; as, ratable estate.","pos":""}],"RATAFIA":[{"def":"A spirituous liquor flavored with the kernels of cherries, apricots, peaches, or other fruit, spiced, and sweetened with sugar; -- a term applied to the liqueurs called noyau, curaçao, etc.","pos":""}],"RATANY":[{"def":"Same as Rhatany.","pos":""}],"RATAPLAN":[{"def":"The iterative sound of beating a drum, or of a galloping horse.","pos":""}],"RATCH":[{"def":"A ratchet wheel, or notched bar, with which a pawl or chick works.","pos":""}],"RATCHET":[{"def":"A pawl, click, or detent, for holding or propelling a ratchet wheel, or ratch, etc.","pos":""},{"def":"A mechanism composed of a ratchet wheel, or ratch, and pawl.","pos":""}],"RATE":[{"def":"To chide with vehemence; to scold; to censure violently.","pos":""}],"RATEL":[{"def":"Any carnivore of the genus Mellivora, allied to the weasels and the skunks; -- called also honey badger.","pos":""}],"RATEPAYER":[{"def":"One who pays rates or taxes.","pos":""}],"RATER":[{"def":"One who rates or estimates.","pos":""}],"RATFISH":[{"def":"Same as Rat-tail.","pos":""}],"RATH":[{"def":"Coming before others, or before the usual time; early.","pos":""},{"def":"Early; soon; betimes.","pos":""}],"RATHER":[{"def":"Prior; earlier; former.","pos":""}],"RATHRIPE":[{"def":"Rareripe, or early ripe.","pos":""}],"RATHSKELLER":[{"def":"Raths\"kel`ler (räts\"kel*ler), n.","pos":""}],"RATIFICATION":[{"def":"The act of ratifying; the state of being ratified; confirmation; sanction; as, the ratification of a treaty.","pos":""}],"RATIFIER":[{"def":"One who, or that which, ratifies; a confirmer.","pos":""}],"RATIFY":[{"def":"To approve and sanction; to make valid; to establish; to settle; especially, to give sanction to, as something done by an agent or servant; as, to ratify an agreement, treaty, or contract; to ratify a nomination.","pos":""}],"RATIHABITION":[{"def":"Confirmation or approbation, as of an act or contract.","pos":""}],"RATIO":[{"def":"The relation which one quantity or magnitude has to another of the same kind.","pos":""}],"RATIOCINATION":[{"def":"The process of reasoning, or deducing conclusions from premises; deductive reasoning.","pos":""}],"RATIOCINATIVE":[{"def":"Characterized by, or addicted to, ratiocination; consisting in the comparison of proportions or facts, and the deduction of inferences from the comparison; argumentative; as, a ratiocinative process.","pos":""}],"RATIOCINATORY":[{"def":"Ra`ti*oc\"i*na*to*ry, a.","pos":""}],"RATION":[{"def":"A fixed daily allowance of provisions assigned to a soldier in the army, or a sailor in the navy, for his subsistence.","pos":""},{"def":"Hence, a certain portion or fixed amount dealt out; an allowance; an allotment.","pos":""}],"RATIONAL":[{"def":"Expressing the type, structure, relations, and reactions of a compound; graphic; -- said of formulæ.","pos":""}],"RATIONALE":[{"def":"An explanation or exposition of the principles of some opinion, action, hypothesis, phenomenon, or like; also, the principles themselves.","pos":""}],"RATIONALISM":[{"def":"The doctrine or system of those who deduce their religious opinions from reason or the understanding, as distinct from, or opposed to, revelation.","pos":""},{"def":"The system that makes rational power the ultimate test of truth; -- opposed to sensualism, or sensationalism, and empiricism.","pos":""}],"RATIONALIST":[{"def":"One who accepts rationalism as a theory or system; also, disparagingly, a false reasoner.","pos":""},{"def":"Belonging to, or in accordance with, the principles of rationalism.","pos":""}],"RATIONALITY":[{"def":"The quality or state of being rational; agreement with reason; possession of reason; due exercise of reason; reasonableness.","pos":""}],"RATIONALIZATION":[{"def":"The act or process of rationalizing.","pos":""}],"RATIONALIZE":[{"def":"To render rational; to free from radical signs or quantities.","pos":""}],"RATIONALLY":[{"def":"In a rational manner.","pos":""}],"RATIONALNESS":[{"def":"The quality or state of being rational; rationality.","pos":""}],"RATITAE":[{"def":"An order of birds in which the wings are small, rudimentary, or absent, and the breastbone is destitute of a keel.","pos":""}],"RATITATE":[{"def":"Of or pertaining to the Ratitæ.","pos":""}],"RATITE":[{"def":"Of or pertaining to the Ratitæ.","pos":""},{"def":"One of the Ratitæ.","pos":""}],"RATOON":[{"def":"Same as Rattoon, n.","pos":""}],"RATSBANE":[{"def":"Rat poison; white arsenic.","pos":""}],"RATSBANED":[{"def":"Poisoned by ratsbane.","pos":""}],"RATTAN":[{"def":"One of the long slender flexible stems of several species of palms of the genus Calamus, mostly East Indian, though some are African and Australian.","pos":""}],"RATTEEN":[{"def":"A thick woolen stuff quilled or twilled.","pos":""}],"RATTEN":[{"def":"To deprive feloniously of the tools used in one's employment (as by breaking or stealing them), for the purpose of annoying; as, to ratten a mechanic who works during a strike.","pos":""}],"RATTER":[{"def":"One who, or that which, rats, as one who deserts his party.","pos":""},{"def":"Anything which catches rats; esp.","pos":""}],"RATTINET":[{"def":"A woolen stuff thinner than ratteen.","pos":""}],"RATTING":[{"def":"The conduct or practices of one who rats.","pos":""},{"def":"The low sport of setting a dog upon rats confined in a pit to see how many he will kill in a given time.","pos":""}],"RATTLE":[{"def":"To make a quick succession of sharp, inharmonious noises, as by the collision of hard and not very sonorous bodies shaken together; to clatter.","pos":""},{"def":"To drive or ride briskly, so as to make a clattering; as, we rattled along for a couple of miles.","pos":""}],"RATTLE-BRAINED":[{"def":"Giddy; rattle-headed.","pos":""}],"RATTLE-HEADED":[{"def":"Noisy; giddy; unsteady.","pos":""}],"RATTLEBOX":[{"def":"A toy that makes a rattle sound; a rattle.","pos":""}],"RATTLEHEAD":[{"def":"An empty, noisy talker.","pos":""}],"RATTLER":[{"def":"One who, or that which, rattles.","pos":""}],"RATTLESNAKE":[{"def":"Any one of several species of venomous American snakes belonging to the genera Crotalus and Caudisona, or Sistrurus.","pos":""}],"RATTLETRAP":[{"def":"Any machine or vehicle that does not run smoothly.","pos":""}],"RATTLEWEED":[{"def":"Any plant of the genus Astragalus.","pos":""}],"RATTLEWORT":[{"def":"Same as Rattlebox.","pos":""}],"RATTOON":[{"def":"One of the stems or shoots of sugar cane of the second year's growth from the root, or later.","pos":""}]}