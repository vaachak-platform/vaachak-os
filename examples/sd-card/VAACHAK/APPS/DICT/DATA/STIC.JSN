{"STICCADO":[{"def":"An instrument consisting of small bars of wood, flat at the bottom and rounded at the top, and resting on the edges of a kind of open box.","pos":""}],"STICH":[{"def":"A verse, of whatever measure or number of feet.","pos":"verb"},{"def":"A line in the Scriptures; specifically (Hebrew Scriptures), one of the rhythmic lines in the poetical books and passages of the Old Treatment, as written in the oldest Hebrew manuscripts and in the Revised Version of the English Bible.","pos":"verb"}],"STICHIC":[{"def":"Of or pertaining to stichs, or lines; consisting of stichs, or lines.","pos":""}],"STICHIDIUM":[{"def":"A special podlike or fusiform branch containing tetraspores.","pos":""}],"STICHOMANCY":[{"def":"Divination by lines, or passages of books, taken at hazard.","pos":""}],"STICHOMETRICAL":[{"def":"Of or pertaining to stichometry; characterized by stichs, or lines.","pos":""}],"STICHOMETRY":[{"def":"Measurement of books by the number of lines which they contain.","pos":""},{"def":"Division of the text of a book into lines; especially, the division of the text of books into lines accommodated to the sense, - - a method of writing manuscripts used before punctuation was adopted.","pos":""}],"STICHWORT":[{"def":"A kind of chickweed (Stellaria Holostea).","pos":""}],"STICK":[{"def":"A composing stick.","pos":""}],"STICK-LAC":[{"def":"See the Note under Lac.","pos":""}],"STICK-SEED":[{"def":"A plant (Echinospermum Lappula) of the Borage family, with small blue flowers and prickly nutlets.","pos":""}],"STICKED":[{"def":"And in the sand her ship sticked so fast.","pos":""}],"STICKER":[{"def":"In the organ, a small wooden rod which connects (in part) a key and a pallet, so as to communicate motion by pushing.","pos":""}],"STICKFUL":[{"def":"As much set type as fills a composing stick.","pos":""}],"STICKINESS":[{"def":"The quality of being sticky; as, the stickiness of glue or paste.","pos":""}],"STICKING":[{"def":"Stick\"ing, Defn: a.","pos":""}],"STICKIT":[{"def":"Stuck; spoiled in making.","pos":""}],"STICKLE":[{"def":"To separate combatants by intervening.","pos":""},{"def":"To contend, contest, or altercate, esp.","pos":""}],"STICKLEBACK":[{"def":"Any one of numerous species of small fishes of the genus Gasterosteus and allied genera.","pos":""}],"STICKLER":[{"def":"One who stickles.","pos":""}],"STICKY":[{"def":"Having the quality of sticking to a surface; adhesive; gluey; viscous; viscid; glutinous; tenacious.","pos":""}]}