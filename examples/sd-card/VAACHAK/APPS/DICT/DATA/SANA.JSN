{"SANABILITY":[{"def":"The quality or state of being sanable; sanableness; curableness.","pos":""}],"SANABLE":[{"def":"Capable of being healed or cured; susceptible of remedy.","pos":""}],"SANABLENESS":[{"def":"The quality of being sanable.","pos":""}],"SANATION":[{"def":"The act of healing or curing.","pos":""}],"SANATIVE":[{"def":"Having the power to cure or heal; healing; tending to heal; sanatory.","pos":""}],"SANATORIUM":[{"def":"An establishment for the treatment of the sick; a resort for invalids.","pos":""}],"SANATORY":[{"def":"Conducive to health; tending to cure; healing; curative; sanative.","pos":""}]}