{"IT":[{"def":"The neuter pronoun of the third person, corresponding to the masculine pronoun he and the feminine she, and having the same plural (they, their of theirs, them).","pos":""}],"ITA PALM":[{"def":"A magnificent species of palm (Mauritia flexuosa), growing near the Orinoco.","pos":""}],"ITACISM":[{"def":"Pronunciation of e in the English word be.","pos":""}],"ITACIST":[{"def":"One who is in favor of itacism.","pos":""}],"ITACOLUMITE":[{"def":"A laminated, granular, siliceous rocks, often occurring in regions where the diamond is found.","pos":""}],"ITACONIC":[{"def":"Pertaining to, or designating, an acid, C5H6O4, which is obtained as a white crystalline substance by decomposing aconitic and other organic acids.","pos":""}],"ITALA":[{"def":"An early Latin version of the Scriptures (the Old Testament was translated from the Septuagint, and was also called the Italic version).","pos":""}],"ITALIAN":[{"def":"Of or pertaining to Italy, or to its people or language.","pos":""}],"ITALIANATE":[{"def":"To render Italian, or conformable to Italian customs; to Italianize.","pos":""}],"ITALIANISM":[{"def":"A word, phrase, or idiom, peculiar to the Italians; an Italicism.","pos":""},{"def":"Attachment to, or sympathy for, Italy.","pos":""}],"ITALIANIZE":[{"def":"To play the Italian; to speak Italian.","pos":""},{"def":"To render Italian in any respect; to Italianate.","pos":""}],"ITALIC":[{"def":"Relating to Italy or to its people.","pos":""},{"def":"Applied especially to a kind of type in which the letters do not stand upright, but slope toward the right; -- so called because dedicated to the States of Italy by the inventor, Aldus Manutius, about the year 1500.","pos":""}],"ITALICISM":[{"def":"A phrase or idiom peculiar to the Italian language; to Italianism.","pos":""},{"def":"The use of Italics.","pos":""}],"ITALICIZE":[{"def":"To print in Italic characters; to underline written letters or words with a single line; as, to Italicize a word; Italicizes too much.","pos":""}],"ITCH":[{"def":"To have an uneasy sensation in the skin, which inclines the person to scratch the part affected.","pos":""},{"def":"To have a constant desire or teasing uneasiness; to long for; as, itching ears.","pos":""}],"ITCHINESS":[{"def":"The state of being itchy.","pos":""}],"ITCHLESS":[{"def":"Free from itching.","pos":""}],"ITCHY":[{"def":"Infected with the itch, or with an itching sensation.","pos":""},{"def":"A suffix used to denote the salts formed from those acids whose names end in -ous; as, sulphite, from sulphurous; nitrite, from nitrous acid, etc.","pos":""}],"ITEM":[{"def":"Also; as an additional article.","pos":""}],"ITEMIZE":[{"def":"To state in items, or by particulars; as, to itemize the cost of a railroad.","pos":""}],"ITERABLE":[{"def":"Capable of being iterated or repeated.","pos":""}],"ITERANT":[{"def":"Repeating; iterating; as, an iterant echo.","pos":""}],"ITERATE":[{"def":"Uttered or done again; repeated.","pos":""}],"ITERATION":[{"def":"Recital or performance a second time; repetition.","pos":""}],"ITHYPHALLIC":[{"def":"Lustful; lewd; salacious; indecent; obscene.","pos":""}],"ITINERACY":[{"def":"The act or practice of itinerating; itinerancy.","pos":""}],"ITINERANCY":[{"def":"A passing from place to place.","pos":""},{"def":"A discharge of official duty involving frequent change of residence; the custom or practice of discharging official duty in this way; also, a body of persons who thus discharge official duty.","pos":""}],"ITINERANT":[{"def":"Passing or traveling about a country; going or preaching on a circuit; wandering; not settled; as, an itinerant preacher; an itinerant peddler.","pos":""}],"ITINERANTLY":[{"def":"In an itinerant manner.","pos":""}],"ITINERARY":[{"def":"Itinerant; traveling; passing from place to place; done on a journey.","pos":""}],"ITINERATE":[{"def":"To wander without a settled habitation; to travel from place or on a circuit, particularly for the purpose of preaching, lecturing, etc.","pos":""},{"def":"A suffix used in medical terms to denote an inflammatory disease of; as, arthritis; bronchitis, phrenitis.","pos":""}],"ITS":[{"def":"Possessive form of the pronoun it.","pos":""}],"ITSELF":[{"def":"The neuter reciprocal pronoun of It; as, the thing is good in itself; it stands by itself.","pos":""}],"ITZIBU":[{"def":"A silver coin of Japan, worth about thirty-four cents.","pos":""}]}