{"KHAKI":[{"def":"Of a dull brownish yellow, or drab color; -- applied to cloth, originally to a stout brownish cotton cloth, used in making uniforms in the Anglo-Indian army.","pos":""}],"KHAN":[{"def":"A king; a prince; a chief; a governor; -- so called among the Tartars, Turks, and Persians, and in countries now or formerly governed by them.","pos":""}],"KHANATE":[{"def":"Dominion or jurisdiction of a khan.","pos":""}],"KHAYA":[{"def":"A lofty West African tree (Khaya Senegalensis), related to the mahogany, which it resembles in the quality of the wood.","pos":""}],"KHEDIVE":[{"def":"A governor or viceroy; -- a title granted in 1867 by the sultan of Turkey to the ruler of Egypt.","pos":""}],"KHOLAH":[{"def":"The Indian jackal.","pos":""}],"KHOND":[{"def":"A Dravidian of a group of tribes of Orissa, India, a section of whom were formerly noted for their cruel human sacrifices to the earth goddess, murder of female infants, and marriage by capture.","pos":""}],"KHUTBAH":[{"def":"An address or public prayer read from the steps of the pulpit in Mohammedan mosques, offering glory to God, praising Mohammed and his descendants, and the ruling princes.","pos":""}]}