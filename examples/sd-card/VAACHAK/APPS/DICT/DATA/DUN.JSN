{"DUN":[{"def":"A mound or small hill.","pos":""}],"DUNCE":[{"def":"One backward in book learning; a child or other person dull or weak in intellect; a dullard; a dolt.","pos":""}],"DUNCEDOM":[{"def":"The realm or domain of dunces.","pos":""}],"DUNCERY":[{"def":"Dullness; stupidity.","pos":""}],"DUNCICAL":[{"def":"Like a dunce; duncish.","pos":""}],"DUNCIFY":[{"def":"To make stupid in intellect.","pos":""}],"DUNCISH":[{"def":"Somewhat like a dunce.","pos":""}],"DUNDER":[{"def":"The lees or dregs of cane juice, used in the distillation of rum.","pos":""}],"DUNDER-HEADED":[{"def":"Thick-headed; stupid.","pos":""}],"DUNDERHEAD":[{"def":"A dunce; a numskull; a blockhead.","pos":""}],"DUNE":[{"def":"A low hill of drifting sand usually formed on the coats, but often carried far inland by the prevailing winds.","pos":""}],"DUNFISH":[{"def":"Codfish cured in a particular manner, so as to be of a superior quality.","pos":""}],"DUNG":[{"def":"The excrement of an animal.","pos":""}],"DUNGAREE":[{"def":"A coarse kind of unbleached cotton stuff.","pos":""}],"DUNGEON":[{"def":"A close, dark prison, commondonjon or keep of a castle, these being used as prisons.","pos":""}],"DUNGFORK":[{"def":"A fork for tossing dung.","pos":""}],"DUNGHILL":[{"def":"Any mean situation or condition; a vile abode.","pos":""}],"DUNGMEER":[{"def":"A pit where dung and weeds rot for manure.","pos":""}],"DUNGY":[{"def":"Full of dung; filthy; vile; low.","pos":""}],"DUNGYARD":[{"def":"A yard where dung is collected.","pos":""}],"DUNKER":[{"def":"One of a religious denomination whose tenets and practices are mainly those of the Baptists, but partly those of the Quakers; -- called also Tunkers, Dunkards, Dippers, and, by themselves, Brethren, and German Baptists.","pos":""}],"DUNLIN":[{"def":"A species of sandpiper (Tringa alpina); -- called also churr, dorbie, grass bird, and red-backed sandpiper.","pos":""}],"DUNNAGE":[{"def":"Fagots, boughs, or loose materials of any kind, laid on the bottom of the hold for the cargo to rest upon to prevent injury by water, or stowed among casks and other cargo to prevent their motion.","pos":""}],"DUNNER":[{"def":"One employed in soliciting the payment of debts.","pos":""}],"DUNNISH":[{"def":"Inclined to a dun color.","pos":""}],"DUNNOCK":[{"def":"The hedge sparrow or hedge accentor.","pos":""}],"DUNNY":[{"def":"My old dame Joan is something dunny, and will scarce know how to manage.","pos":""}],"DUNTED":[{"def":"Beaten; hence, blunted.","pos":""}]}