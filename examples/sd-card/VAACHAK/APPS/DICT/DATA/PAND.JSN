{"PANDA":[{"def":"A small Asiatic mammal (Ailurus fulgens) having fine soft fur.","pos":""}],"PANDANUS":[{"def":"A genus of endogenous plants.","pos":""}],"PANDARISM":[{"def":"Same as Panderism.","pos":""}],"PANDEAN":[{"def":"Of or relating to the god Pan.","pos":""}],"PANDECT":[{"def":"The digest, or abridgment, in fifty books, of the decisions, writings, and opinions of the old Roman jurists, made in the sixth century by direction of the emperor Justinian, and forming the leading compilation of the Roman civil law.","pos":""}],"PANDEMIC":[{"def":"Affecting a whole people or a number of countries; everywhere epidemic.","pos":""},{"def":"A pandemic disease.","pos":""}],"PANDEMONIUM":[{"def":"The great hall or council chamber of demons or evil spirits.","pos":""},{"def":"An utterly lawless, riotous place or assemblage.","pos":""}],"PANDER":[{"def":"A male bawd; a pimp; a procurer.","pos":""},{"def":"Hence, one who ministers to the evil designs and passions of another.","pos":""}],"PANDERAGE":[{"def":"The act of pandering.","pos":""}],"PANDERISM":[{"def":"The employment, arts, or practices of a pander.","pos":""}],"PANDERLY":[{"def":"Having the quality of a pander.","pos":""}],"PANDERMITE":[{"def":"A hydrous borate of lime, near priceite.","pos":""}],"PANDEROUS":[{"def":", Of or relating to a pander; characterizing a pander.","pos":""}],"PANDICULATED":[{"def":"Extended; spread out; stretched.","pos":""}],"PANDICULATION":[{"def":"A stretching and stiffening of the trunk and extremities, as when fatigued and drowsy.","pos":""}],"PANDOOR":[{"def":"Same as Pandour.","pos":""}],"PANDORA":[{"def":"A beautiful woman (all-gifted), whom Jupiter caused Vulcan to make out of clay in order to punish the human race, because Prometheus had stolen the fire from heaven.","pos":""},{"def":"A genus of marine bivalves, in which one valve is flat, the other convex.","pos":""}],"PANDORE":[{"def":"An ancient musical instrument, of the lute kind; a bandore.","pos":""}],"PANDOUR":[{"def":"One of a class of Hungarian mountaineers serving in the Austrian army; -- so called from Pandur, a principal town in the region from which they originally came.","pos":""}],"PANDOWDY":[{"def":"A deep pie or pudding made of baked apples, or of sliced bread and apples baked together, with no bottom crust.","pos":""},{"def":"Obovate, with a concavity in each side, like the body of a violin; fiddle-shaped; as, a panduriform leaf; panduriform color markings of an animal.","pos":""}]}