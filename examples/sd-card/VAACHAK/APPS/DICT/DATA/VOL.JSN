{"VOL-AU-VENT":[{"def":"A light puff paste, with a raised border, filled, after baking, usually with a ragout of fowl, game, or fish.","pos":""}],"VOLACIOUS":[{"def":"Apt or fit to fly.","pos":""}],"VOLAGE":[{"def":"They wroughten all their lust volage.","pos":""}],"VOLANT":[{"def":"Represented as flying, or having the wings spread; as, an eagle volant.","pos":""}],"VOLANTE":[{"def":"A cumbrous two-wheeled pleasure carriage used in Cuba.","pos":""},{"def":"Literally, world's speech; the name of an artificial language invented by Johan Martin Schleyer, of Constance, Switzerland, about 1879.","pos":""}],"VOLAR":[{"def":"Of or pertaining to the palm of the hand or the sole of the foot.","pos":""}],"VOLATILE":[{"def":"Passing through the air on wings, or by the buoyant force of the atmosphere; flying; having the power to fly.","pos":""},{"def":"Capable of wasting away, or of easily passing into the aëriform state; subject to evaporation.","pos":""}],"VOLATILIZABLE":[{"def":"Capable of being volatilized.","pos":""}],"VOLATILIZATION":[{"def":"The act or process of volatilizing, or rendering volatile; the state of being volatilized.","pos":""}],"VOLATILIZE":[{"def":"To render volatile; to cause to exhale or evaporate; to cause to pass off in vapor.","pos":""}],"VOLATOR":[{"def":"Same as Volador, 1.","pos":""}],"VOLBORTHITE":[{"def":"A mineral occurring in small six-sided tabular crystals of a green or yellow color.","pos":""}],"VOLCANIC":[{"def":"Of or pertaining to a volcano or volcanoes; as, volcanic heat.","pos":""},{"def":"Produced by a volcano, or, more generally, by igneous agencies; as, volcanic tufa.","pos":""}],"VOLCANIC NECK":[{"def":"A column of igneous rock formed by congelation of lava in the conduit of a volcano and later exposed by the removal of surrounding rocks.","pos":""}],"VOLCANIC WIND":[{"def":"A wind associated with a volcanic outburst and due to the eruption or to convection currents over hot lava.","pos":""}],"VOLCANICALLY":[{"def":"Vol*can\"ic*al*ly, adv.","pos":""}],"VOLCANICITY":[{"def":"Quality or state of being volcanic; volcanic power.","pos":""}],"VOLCANISM":[{"def":"Volcanic power or action; volcanicity.","pos":""}],"VOLCANIST":[{"def":"One versed in the history and phenomena of volcanoes.","pos":""},{"def":"One who believes in the igneous, as opposed to the aqueous, origin of the rocks of the earth's crust; a vulcanist.","pos":""}],"VOLCANITY":[{"def":"The quality or state of being volcanic, or volcanic origin; volcanicity.","pos":""}],"VOLCANIZATION":[{"def":"The act of volcanizing, or the state of being volcanized; the process of undergoing volcanic heat, and being affected by it.","pos":""}],"VOLCANIZE":[{"def":"To subject to, or cause to undergo, volcanic heat, and to be affected by its action.","pos":""}],"VOLCANO":[{"def":"A mountain or hill, usually more or less conical in form, from which lava, cinders, steam, sulphur gases, and the like, are ejected; -- often popularly called a burning mountain.","pos":""}],"VOLE":[{"def":"A deal at cards that draws all the tricks.","pos":""}],"VOLERY":[{"def":"A flight of birds.","pos":""},{"def":"A large bird cage; an aviary.","pos":""}],"VOLGE":[{"def":"The common sort of people; the crowd; the mob.","pos":""}],"VOLITATION":[{"def":"The act of flying; flight.","pos":""}],"VOLITIENT":[{"def":"Exercising the will; acting from choice; willing, or having power to will.","pos":""}],"VOLITION":[{"def":"The act of willing or choosing; the act of forming a purpose; the exercise of the will.","pos":""},{"def":"The result of an act or exercise of choosing or willing; a state of choice.","pos":""}],"VOLITIONAL":[{"def":"Belonging or relating to volition.","pos":""}],"VOLITIVE":[{"def":"Used in expressing a wish or permission as, volitive proposition.","pos":""}],"VOLKSLIED":[{"def":"A popular song, or national air.","pos":""}],"VOLKSRAAD":[{"def":"A legislative assembly or parliament of any one of several countries colonized by the Dutch, esp.","pos":""}],"VOLLEY":[{"def":"A flight of missiles, as arrows, bullets, or the like; the simultaneous discharge of a number of small arms.","pos":""},{"def":"A burst or emission of many things at once; as, a volley of words.","pos":""}],"VOLLEY BALL":[{"def":"A game played by volleying a large inflated ball with the hands over a net 7 ft.","pos":""}],"VOLLEYED":[{"def":"Discharged with a sudden burst, or as if in a volley; as, volleyed thunder.","pos":""}],"VOLOST":[{"def":"In the greater part of Russia, a division for local government consisting of a group of mirs, or village communities; a canton.","pos":""}],"VOLOW":[{"def":"To baptize; -- used in contempt by the Reformers.","pos":""}],"VOLPLANE":[{"def":"To glide in a flying machine.","pos":""}],"VOLT":[{"def":"A circular tread; a gait by which a horse going sideways round a center makes two concentric tracks.","pos":""},{"def":"A sudden movement to avoid a thrust.","pos":""}],"VOLT AMPERE":[{"def":"A unit of electric measurement equal to the product of a volt and an ampere.","pos":""}],"VOLTA":[{"def":"A turning; a time; -- chiefly used in phrases signifying that the part is to be repeated one, two, or more times; as, una volta, once.","pos":""}],"VOLTA-ELECTRIC":[{"def":"Of or pertaining to voltaic electricity, or voltaism.","pos":""}],"VOLTA-ELECTROMETER":[{"def":"An instrument for the exact measurement of electric currents.","pos":""}],"VOLTAGE":[{"def":"Electric potential or potential difference, expressed in volts.","pos":""}],"VOLTAGRAPHY":[{"def":"In electrotypy, the act or art of copying, in metals deposited by electrolytic action, a form or pattern which is made the negative electrode.","pos":""}],"VOLTAIC":[{"def":"Of or pertaining to Alessandro Volta, who first devised apparatus for developing electric currents by chemical action, and established this branch of electric science; discovered by Volta; as, voltaic electricity.","pos":""},{"def":"Of or pertaining to voltaism, or voltaic electricity; as, voltaic induction; the voltaic arc.","pos":""}],"VOLTAIREAN":[{"def":"Of or relating to Voltaire, the French author.","pos":""}],"VOLTAIRISM":[{"def":"The theories or practice of Voltaire.","pos":""}],"VOLTAMETER":[{"def":"An instrument for measuring the voltaic electricity passing through it, by its effect in decomposing water or some other chemical compound acting as an electrolyte.","pos":""}],"VOLTAPLAST":[{"def":"A form of voltaic, or galvanic, battery suitable for use electrotyping.","pos":""}],"VOLTI":[{"def":"Turn, that is, turn over the leaf.","pos":""}],"VOLTIGEUR":[{"def":"One of a picked company of irregular riflemen in each regiment of the French infantry.","pos":""}],"VOLTMETER":[{"def":"An instrument for measuring in volts the differences of potential between different points of an electrical circuit.","pos":""}],"VOLTZITE":[{"def":"An oxysulphide of lead occurring in implanted spherical globules of a yellowish or brownish color; -- called also voltzine.","pos":""},{"def":"Turning, or whirling; winding; twining; voluble.","pos":""}],"VOLUBILITY":[{"def":"The quality or state of being voluble (in any of the senses of the adjective).","pos":""}],"VOLUBLE":[{"def":"Having the power or habit of turning or twining; as, the voluble stem of hop plants.","pos":""}],"VOLUME":[{"def":"Amount, fullness, quantity, or caliber of voice or tone.","pos":""}],"VOLUMED":[{"def":"Having the form of a volume, or roil; as, volumed mist.","pos":""},{"def":"Having volume, or bulk; massive; great.","pos":""}],"VOLUMENOMETER":[{"def":"An instrument for measuring the volume of a body, especially a solid, by means of the difference in tension caused by its presence and absence in a confined portion of air.","pos":""}],"VOLUMENOMETRY":[{"def":"The method or process of measuring volumes by means of the volumenometer.","pos":""}],"VOLUMESCOPE":[{"def":"An instrument consisting essentially of a glass tube provided with a graduated scale, for exhibiting to the eye the changes of volume of a gas or gaseous mixture resulting from chemical action, and the like.","pos":""}],"VOLUMETER":[{"def":"An instrument for measuring the volumes of gases or liquids by introducing them into a vessel of known capacity.","pos":""}],"VOLUMETRIC":[{"def":"Of or pertaining to the measurement of volume.","pos":""}],"VOLUMINOUS":[{"def":"Of or pertaining to volume or volumes.","pos":""}],"VOLUMIST":[{"def":"One who writes a volume; an author.","pos":""}],"VOLUNTARILY":[{"def":"In a voluntary manner; of one's own will; spontaneously.","pos":""}],"VOLUNTARINESS":[{"def":"The quality or state of being voluntary; spontaneousness; specifically, the quality or state of being free in the exercise of one's will.","pos":""}],"VOLUNTARISM":[{"def":"Any theory which conceives will to be the dominant factor in experience or in the constitution of the world; -- contrasted with intellectualism.","pos":""}],"VOLUNTARY":[{"def":"Of or pertaining to the will; subject to, or regulated by, the will; as, the voluntary motions of an animal, such as the movements of the leg or arm (in distinction from involuntary motions, such as the movements of the heart); the voluntary muscle fibers, which are the agents in voluntary motion.","pos":""},{"def":"Free; without compulsion; according to the will, consent, or agreement, of a party; without consideration; gratuitous; without valuable consideration.","pos":""}],"VOLUNTARYISM":[{"def":"The principle of supporting a religious system and its institutions by voluntary association and effort, rather than by the aid or patronage of the state.","pos":""}],"VOLUNTEER":[{"def":"One who enters into service voluntarily, but who, when in service, is subject to discipline and regulations like other soldiers; -- opposed to conscript; specifically, a voluntary member of the organized militia of a country as distinguished from the standing army.","pos":""},{"def":"A grantee in a voluntary conveyance; one to whom a conveyance is made without valuable consideration; a party, other than a wife or child of the grantor, to whom, or for whose benefit, a voluntary conveyance is made.","pos":""}],"VOLUNTEER NAVY":[{"def":"A navy of vessels fitted out and manned by volunteers who sail under the flag of the regular navy and subject to naval discipline.","pos":""}],"VOLUNTEER STATE":[{"def":"Tennessee; -- a nickname.","pos":""}],"VOLUNTEERS OF AMERICA":[{"def":"A religious and philanthropic organization, similar to the Salvation Army, founded (1896) by Commander and Mrs.","pos":""}],"VOLUPTUARY":[{"def":"A voluptuous person; one who makes his physical enjoyment his chief care; one addicted to luxury, and the gratification of sensual appetites.","pos":""}],"VOLUPTUOUS":[{"def":"Full of delight or pleasure, especially that of the senses; ministering to sensuous or sensual gratification; exciting sensual desires; luxurious; sensual.","pos":""},{"def":"Given to the enjoyments of luxury and pleasure; indulging to excess in sensual gratifications.","pos":""}],"VOLUTA":[{"def":"Any one of numerous species of large, handsome marine gastropods belonging to Voluta and allied genera.","pos":""}],"VOLUTATION":[{"def":"A rolling of a body; a wallowing.","pos":""}],"VOLUTE":[{"def":"A spiral scroll which forms the chief feature of the Ionic capital, and which, on a much smaller scale, is a feature in the Corinthian and Composite capitals.","pos":""},{"def":"A spiral turn, as in certain shells.","pos":""}],"VOLUTED":[{"def":"Having a volute, or spiral scroll.","pos":""}],"VOLUTION":[{"def":"A whorl of a spiral shell.","pos":""}],"VOLVA":[{"def":"A saclike envelope of certain fungi, which bursts open as the plant develops.","pos":""}],"VOLVOX":[{"def":"A genus of minute, pale-green, globular, organisms, about one fiftieth of an inch in diameter, found rolling through water, the motion being produced by minute colorless cilia.","pos":""}]}