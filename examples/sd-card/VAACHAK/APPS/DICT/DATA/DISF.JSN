{"DISFAVOR":[{"def":"Want of favor of favorable regard; disesteem; disregard.","pos":""},{"def":"The state of not being in favor; a being under the displeasure of some one; state of unacceptableness; as, to be in disfavor at court.","pos":""}],"DISFAVORABLY":[{"def":"Dis*fa\"vor*a*bly, adv.","pos":""}],"DISFAVORER":[{"def":"One who disfavors.","pos":""}],"DISFEATURE":[{"def":"To deprive of features; to mar the features of.","pos":""}],"DISFELLOWSHIP":[{"def":"To exclude from fellowship; to refuse intercourse with, as an associate.","pos":""}],"DISFIGURATION":[{"def":"The act of disfiguring, or the state of being disfigured; defacement; deformity; disfigurement.","pos":""}],"DISFIGURE":[{"def":"To mar the figure of; to render less complete, perfect, or beautiful in appearance; to deface; to deform.","pos":""}],"DISFIGUREMENT":[{"def":"Act of disfiguring, or state of being disfigured; deformity.","pos":""},{"def":"That which disfigures; a defacement; a blot.","pos":""}],"DISFIGURER":[{"def":"One who disfigures.","pos":""}],"DISFLESH":[{"def":"To reduce the flesh or obesity of.","pos":""}],"DISFOREST":[{"def":"To clear or deprive of forests or trees.","pos":""}],"DISFORESTATION":[{"def":"The act of clearing land of forests.","pos":""}],"DISFORMITY":[{"def":"Discordance or diversity of form; unlikeness in form.","pos":""}],"DISFRANCHISE":[{"def":"To deprive of a franchise or chartered right; to dispossess of the rights of a citizen, or of a particular privilege, as of voting, holding office, etc.","pos":""}],"DISFRANCHISEMENT":[{"def":"The act of disfranchising, or the state disfranchised; deprivation of privileges of citizenship or of chartered immunities.","pos":""}],"DISFRIAR":[{"def":"To depose or withdraw from the condition of a friar.","pos":""}],"DISFURNISH":[{"def":"To deprive of that with which anything is furnished (furniture, equipments, etc.","pos":""}],"DISFURNISHMENT":[{"def":"The act of disfurnishing, or the state of being disfurnished.","pos":""}],"DISFURNITURE":[{"def":"The act of disfurnishing, or the state of being disfurnished.","pos":""}]}