{"EVE":[{"def":"The evening before a holiday, -- from the Jewish mode of reckoning the day as beginning at sunset.","pos":""}],"EVECTICS":[{"def":"The branch of medical science which teaches the method of acquiring a good habit of body.","pos":""}],"EVECTION":[{"def":"The act of carrying up or away; exaltation.","pos":""}],"EVEN":[{"def":"Level, smooth, or equal in surface; not rough; free from irregularities; hence uniform in rate of motion of action; as, even ground; an even speed; an even course of conduct.","pos":""},{"def":"Equable; not easily ruffed or disturbed; calm; uniformly self- possessed; as, an even temper.","pos":""}],"EVENER":[{"def":"One who, or that which makes even.","pos":""},{"def":"In vehicles, a swinging crossbar, to the ends of which other crossbars, or whiffletrees, are hung, to equalize the draught when two or three horses are used abreast.","pos":""}],"EVENFALL":[{"def":"Beginning of evening.","pos":""}],"EVENHANDED":[{"def":"Fair or impartial; unbiased.","pos":""}],"EVENING":[{"def":"The latter part and close of the day, and the beginning of darkness or night; properly, the decline of the day, or of the sum.","pos":""},{"def":"The latter portion, as of life; the declining period, as of strength or glory.","pos":""}],"EVENLY":[{"def":"With an even, level, or smooth surface; without roughness, elevations, or depression; uniformly; equally; comfortably; impartially; serenely.","pos":""}],"EVENMINDED":[{"def":"Having equanimity.","pos":""}],"EVENNESS":[{"def":"The state of being ven, level, or disturbed; smoothness; horizontal position; uniformity; impartiality; calmness; equanimity; appropriate place or level; as, evenness of surface, of a fluid at rest, of motion, of dealings, of temper, of condition.","pos":""}],"EVENSONG":[{"def":"A song for the evening; the evening service or form of worship (in the Church of England including vespers and compline); also, the time of evensong.","pos":""}],"EVENT":[{"def":"That which comes, arrives, or happens; that which falls out; any incident, good or bad.","pos":""},{"def":"An affair in hand; business; enterprise.","pos":""}],"EVENTERATE":[{"def":"To rip open; todisembowel.","pos":""}],"EVENTFUL":[{"def":"Full of, or rich in, events or incidents; as, an eventful journey; an eventful period of history; an eventful period of life.","pos":""}],"EVENTIDE":[{"def":"The time of evening; evening.","pos":""}],"EVENTILATE":[{"def":"To winnow out; to fan.","pos":""},{"def":"To discuss; to ventilate.","pos":""}],"EVENTILATION":[{"def":"The act of eventilating; discussion.","pos":""}],"EVENTLESS":[{"def":"Without events; tame; monotomous; marked by nothing unusual; uneventful.","pos":""}],"EVENTOGNATHI":[{"def":"An order of fishes including a vast number of freshwater species such as the carp, loach, chub, etc.","pos":""}],"EVENTUAL":[{"def":"Dependent on events; contingent.","pos":""}],"EVENTUALITY":[{"def":"Disposition to take cognizance of events.","pos":""}],"EVENTUALLY":[{"def":"In an eventual manner; finally; ultimately.","pos":""}],"EVENTUATE":[{"def":"To come out finally or in conclusion; to result; to come to pass.","pos":""}],"EVENTUATION":[{"def":"The act of eventuating or happening as a result; the outcome.","pos":""}],"EVER":[{"def":"At any time; at any period or point of time.","pos":""},{"def":"At all times; through all time; always; forever.","pos":""}],"EVERGLADE":[{"def":"A swamp or low tract of land inundated with water and interspersed with hummocks, or small islands, and patches of high grass; as, the everglades of Florida.","pos":""}],"EVERGREEN":[{"def":"Remaining unwithered through the winter, or retaining unwithered leaves until the leaves of the next year are expanded, as pines cedars, hemlocks, and the like.","pos":""}],"EVERGREEN STATE":[{"def":"Washington; -- a nickname alluding to the abundance of evergreen trees.","pos":""},{"def":"each one; every one; each of two.","pos":""}],"EVERLASTING":[{"def":"Lasting or enduring forever; exsisting or continuing without end; immoral; eternal.","pos":""},{"def":"Continuing indefinitely, or during a long period; perpetual; sometimes used, colloquially, as a strong intensive; as, this everlasting nonsence.","pos":""}],"EVERLASTINGLY":[{"def":"In an everlasting manner.","pos":""}],"EVERLASTINGNESS":[{"def":"The state of being everlasting; endless duration; indefinite duration.","pos":""}],"EVERLIVING":[{"def":"Living always; immoral; eternal; as, the everliving God.","pos":""},{"def":"Continual; incessant; unintermitted.","pos":""}],"EVERMORE":[{"def":"During eternity; always; forever; for an indefinite period; at all times; -- often used substantively with for.","pos":""}],"EVERNIC":[{"def":"Pertaining to Evernia, a genus of lichens; as, evernic acid.","pos":""}],"EVERSE":[{"def":"To overthrow or subvert.","pos":""}],"EVERSION":[{"def":"The act of eversing; destruction.","pos":""},{"def":"The state of being turned back or outward; as, eversion of eyelids; ectropium.","pos":""}],"EVERSIVE":[{"def":"Tending to evert or overthrow; subversive; with of.","pos":""}],"EVERT":[{"def":"To overthrow; to subvert.","pos":""},{"def":"To turn outwards, or inside out, as an intestine.","pos":""}],"EVERY":[{"def":"All the parts which compose a whole collection or aggregate number, considered in their individuality, all taken separately one by one, out of an indefinite bumber.","pos":""}],"EVERYDAY":[{"def":"Used or fit for every day; common; usual; as, an everyday suit or clothes.","pos":""}],"EVERYONE":[{"def":"Everybody; -- commonly separated, every one.","pos":""}],"EVERYTHING":[{"def":"Whatever pertains to the subject under consideration; all things.","pos":""}],"EVERYWHEN":[{"def":"At any or all times; every instant.","pos":""}],"EVERYWHERE":[{"def":"In every place; in all places; hence, in every part; throughly; altogether.","pos":""}],"EVERYWHERENESS":[{"def":"Ubiquity; omnipresence.","pos":""}],"EVESDROPPER":[{"def":"See Eavesdropper.","pos":""}],"EVET":[{"def":"The common newt or eft.","pos":""}]}