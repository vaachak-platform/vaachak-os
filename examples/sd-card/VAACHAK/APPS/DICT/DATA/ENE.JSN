{"ENECATE":[{"def":"To kill off; to destroy.","pos":""}],"ENEMA":[{"def":"An injection, or clyster, thrown into the rectum as a medicine, or to impart nourishment.","pos":""}],"ENEMY":[{"def":"One hostile to another; one who hates, and desires or attempts the injury of, another; a foe; an adversary; as, an enemy of or to a person; an enemy to truth, or to falsehood.","pos":""}],"ENEPIDERMIC":[{"def":"Applied to the skin without friction; -- said of medicines.","pos":""}],"ENERGETICS":[{"def":"That branch of science which treats of the laws governing the physical or mechanical, in distinction from the vital, forces, and which comprehends the consideration and general investigation of the whole range of the forces concerned in physical phenomena.","pos":""}],"ENERGIZE":[{"def":"To use strength in action; to act or operate with force or vigor; to act in producing an effect.","pos":""}],"ENERGIZER":[{"def":"One who, or that which, gives energy, or acts in producing an effect.","pos":""}],"ENERGIZING":[{"def":"Capable of imparting or exercising energy.","pos":""}],"ENERGUMEN":[{"def":"One possessed by an evil spirit; a demoniac.","pos":""}],"ENERGY":[{"def":"Capacity for performing work.","pos":""}],"ENERVATE":[{"def":"To deprive of nerve, force, strength, or courage; to render feeble or impotent; to make effeminate; to impair the moral powers of.","pos":""}],"ENERVATION":[{"def":"The act of weakening, or reducing strength.","pos":""},{"def":"The state of being weakened; effeminacy.","pos":""}],"ENERVATIVE":[{"def":"Having power, or a tendency, to enervate; weakening.","pos":""}],"ENERVE":[{"def":"To weaken; to enervate.","pos":""}],"ENERVOUS":[{"def":"Lacking nerve or force; enervated.","pos":""}]}