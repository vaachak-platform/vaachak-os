{"DISCAL":[{"def":"Pertaining to, or resembling, a disk; as, discal cells.","pos":""}],"DISCALCEATE":[{"def":"To pull off shoes or sandals from.","pos":""}],"DISCALCEATED":[{"def":"Deprived off shoes or sandals; unshod; discalced.","pos":""}],"DISCALCEATION":[{"def":"The act of pulling off the shoes or sandals.","pos":""}],"DISCALCED":[{"def":"Unshod; barefooted; -- in distinction from calced.","pos":""}],"DISCAMP":[{"def":"To drive from a camp.","pos":""}],"DISCANDY":[{"def":"To melt; to dissolve; to thaw.","pos":""}],"DISCAPACITATE":[{"def":"To deprive of capacity; to incapacitate.","pos":""}],"DISCARD":[{"def":"To throw out of one's hand, as superfluous cards; to lay aside (a card or cards).","pos":""}],"DISCARDURE":[{"def":"Rejection; dismissal.","pos":""}],"DISCARNATE":[{"def":"Stripped of flesh.","pos":""}],"DISCASE":[{"def":"To strip; to undress.","pos":""}]}