{"HAUBERK":[{"def":"A coat of mail; especially, the long coat of mail of the European Middle Ages, as contrasted with the habergeon, which is shorter and sometimes sleeveless.","pos":""}],"HAUERITE":[{"def":"Native sulphide of manganese a reddish brown or brownish black mineral.","pos":""}],"HAUGH":[{"def":"A low-lying meadow by the side of a river.","pos":""}],"HAUGHT":[{"def":"High; elevated; hence, haughty; proud.","pos":""}],"HAUGHTILY":[{"def":"In a haughty manner; arrogantly.","pos":""}],"HAUGHTINESS":[{"def":"The quality of being haughty; disdain; arrogance.","pos":""}],"HAUGHTY":[{"def":"High; lofty; bold.","pos":""},{"def":"Disdainfully or contemptuously proud; arrogant; overbearing.","pos":""}],"HAUL":[{"def":"To pull or draw with force; to drag.","pos":""},{"def":"To transport by drawing, as with horses or oxen; as, to haul logs to a sawmill.","pos":""}],"HAULABOUT":[{"def":"A bargelike vessel with steel hull, large hatchways, and coal transporters, for coaling war vessels from its own hold or from other colliers.","pos":""}],"HAULAGE":[{"def":"Act of hauling; as, the haulage of cars by an engine; charge for hauling.","pos":""}],"HAULM":[{"def":"The denuded stems or stalks of such crops as buckwheat and the cereal grains, beans, etc.","pos":""}],"HAULT":[{"def":"Through support of countenance proud and hault.","pos":""}],"HAUM":[{"def":"See Haulm, stalk.","pos":""}],"HAUNCH":[{"def":"The hip; the projecting region of the lateral parts of the pelvis and the hip joint; the hind part.","pos":""},{"def":"Of meats: The leg and loin taken together; as, a haunch of venison.","pos":""}],"HAUNCHED":[{"def":"Having haunches.","pos":""}],"HAUNT":[{"def":"To frequent; to resort to frequently; to visit pertinaciously or intrusively; to intrude upon.","pos":""},{"def":"To inhabit or frequent as a specter; to visit as a ghost or apparition.","pos":""}],"HAUNTED":[{"def":"Inhabited by, or subject to the visits of, apparitions; frequented by a ghost.","pos":""}],"HAUNTER":[{"def":"One who, or that which, haunts.","pos":""}],"HAURIENT":[{"def":"In pale, with the head in chief; -- said of the figure of a fish, as if rising for air.","pos":""}],"HAUSEN":[{"def":"A large sturgeon (Acipenser huso) from the region of the Black Sea.","pos":""}],"HAUSSE":[{"def":"A kind of graduated breech sight for a small arm, or a cannon.","pos":""}],"HAUSTELLATA":[{"def":"An artificial division of insects, including all those with a sucking proboscis.","pos":""}],"HAUSTELLATE":[{"def":"Provided with a haustellum, or sucking proboscis.","pos":""},{"def":"One of the Haustellata.","pos":""}],"HAUSTELLUM":[{"def":"The sucking proboscis of various insects.","pos":""}],"HAUSTORIUM":[{"def":"One of the suckerlike rootlets of such plants as the dodder and ivy.","pos":""}],"HAUTBOY":[{"def":"A wind instrument, sounded through a reed, and similar in shape to the clarinet, but with a thinner tone.","pos":""},{"def":"A sort of strawberry (Fragaria elatior).","pos":""}],"HAUTBOYIST":[{"def":"A player on the hautboy.","pos":""}],"HAUTEIN":[{"def":"High; -- said of the voice or flight of birds.","pos":""}],"HAUTEUR":[{"def":"Haughty manner or spirit; haughtiness; pride; arrogance.","pos":""}],"HAUTGOUT":[{"def":"High relish or flavor; high seasoning.","pos":""}],"HAUTPAS":[{"def":"A raised part of the floor of a large room; a platform for a raised table or throne.","pos":""}]}