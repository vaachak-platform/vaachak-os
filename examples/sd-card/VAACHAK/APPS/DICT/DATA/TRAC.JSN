{"TRACE":[{"def":"One of two straps, chains, or ropes of a harness, extending from the collar or breastplate to a whiffletree attached to a vehicle or thing to be drawn; a tug.","pos":""}],"TRACEABLE":[{"def":"Capable of being traced.","pos":""}],"TRACER":[{"def":"One who, or that which, traces.","pos":""}],"TRACERY":[{"def":"Ornamental work with rambled lines.","pos":""}],"TRACHEA":[{"def":"One of the respiratory tubes of insects and arachnids.","pos":""}],"TRACHEAL":[{"def":"Of or pertaining to the trachea; like a trachea.","pos":""}],"TRACHEARIA":[{"def":"A division of Arachnida including those that breathe only by means of tracheæ.","pos":"noun"}],"TRACHEARY":[{"def":"Tracheal; breathing by means of tracheæ.","pos":""},{"def":"One of the Trachearia.","pos":""}],"TRACHEATA":[{"def":"An extensive division of arthropods comprising all those which breathe by tracheæ, as distinguished from Crustacea, which breathe by means of branchiæ.","pos":"noun"}],"TRACHEATE":[{"def":"Breathing by means of tracheæ; of or pertaining to the Tracheata.","pos":""}],"TRACHEID":[{"def":"A wood cell with spiral or other markings and closed throughout, as in pine wood.","pos":""}],"TRACHEITIS":[{"def":"Inflammation of the trachea, or windpipe.","pos":""}],"TRACHELIDAN":[{"def":"Any one of a tribe of beetles (Trachelides) which have the head supported on a pedicel.","pos":""}],"TRACHELIPOD":[{"def":"One of the Trachelipoda.","pos":""}],"TRACHELIPODA":[{"def":"An extensive artificial group of gastropods comprising all those which have a spiral shell and the foot attached to the base of the neck.","pos":"noun"}],"TRACHELIPODOUS":[{"def":"Having the foot united with the neck; of or pertainingto the Trachelipoda.","pos":""}],"TRACHELOBRANCHIATE":[{"def":"Having the gills situated upon the neck; -- said of certain mollusks.","pos":""}],"TRACHELORRHAPHY":[{"def":"The operation of sewing up a laceration of the neck of the uterus.","pos":""}],"TRACHENCHYMA":[{"def":"A vegetable tissue consisting of tracheæ.","pos":""}],"TRACHEOBRANCHIA":[{"def":"One of the gill-like breathing organs of certain aquatic insect larvæ.","pos":""}],"TRACHEOBRONCHIAL":[{"def":"Pertaining both to the tracheal and bronchial tubes, or to their junction; -- said of the syrinx of certain birds.","pos":""}],"TRACHEOPHONAE":[{"def":"A group of passerine birds having the syrinx at the lower end of the trachea.","pos":""}],"TRACHEOSCOPY":[{"def":"Examination of the interior of the trachea by means of a mirror.","pos":""}],"TRACHEOTOMY":[{"def":"The operation of making an opening into the windpipe.","pos":""}],"TRACHINOID":[{"def":"Of, pertaining to, or like, Trachinus, a genus of fishes which includes the weevers.","pos":""}],"TRACHOMA":[{"def":"Granular conjunctivitis due to a specific micrococcus.","pos":""}],"TRACHYMEDUSAE":[{"def":"A division of acalephs in which the development is direct from the eggs, without a hydroid stage.","pos":""}],"TRACHYSTOMATA":[{"def":"An order of tailed aquatic amphibians, including Siren and Pseudobranchus.","pos":""}],"TRACHYTE":[{"def":"An igneous rock,usually light gray in color and breaking with a rough surface.","pos":""}],"TRACHYTIC":[{"def":"Of, pertaining to, or resembling, trachyte.","pos":""}],"TRACHYTOID":[{"def":"Resembling trachyte; -- used to define the structure of certain rocks.","pos":""}],"TRACING":[{"def":"The act of one who traces; especially, the act of copying by marking on thin paper, or other transparent substance, the lines of a pattern placed beneath; also, the copy thus producted.","pos":""},{"def":"A regular path or track; a course.","pos":""}],"TRACK":[{"def":"The entire lower surface of the foot;-said of birds, ect.","pos":""},{"def":"The permanent way; the rails.","pos":""}],"TRACKAGE":[{"def":"The act of tracking, or towing, as a boat; towage.","pos":""}],"TRACKER":[{"def":"In the organ, a light strip of wood connecting (in path) a key and a pallet, to communicate motion by pulling.","pos":""}],"TRACKLAYER":[{"def":"Any workman engaged in work involved in putting the track in place.","pos":""}],"TRACKLESS":[{"def":"Having no track; marked by no footsteps; untrodden; as, a trackless desert.","pos":""}],"TRACKMAN":[{"def":"One employed on work on the track; specif.","pos":""},{"def":"One who has charge of the track; --called also roadmaster.","pos":""}],"TRACKSCOUT":[{"def":"See Trackschuyt.","pos":""}],"TRACKWALKER":[{"def":"A person employed to walk over and inspect a section of tracks.","pos":""}],"TRACKWAY":[{"def":"Any of two or more narrow paths, of steel, smooth stone, or the like, laid in a public roadway otherwise formed of an inferior pavement, as cobblestones, to provide an easy way for wheels.","pos":""}],"TRACT":[{"def":"A written discourse or dissertation, generally of short extent; a short treatise, especially on practical religion.","pos":""}],"TRACTABILITY":[{"def":"The quality or state of being tractable or docile; docility; tractableness.","pos":""}],"TRACTABLE":[{"def":"Capable of being easily led, taught, or managed; docile; manageable; governable; as, tractable children; a tractable learner.","pos":""},{"def":"Capable of being handled; palpable; practicable; feasible; as, tractable measures.","pos":""}],"TRACTARIAN":[{"def":"One of the writers of the Oxford tracts, called \"Tracts for the Times,\" issued during the period 1833-1841, in which series of papers the sacramental system and authority of the Church, and the value of tradition, were brought into prominence.","pos":""}],"TRACTARIANISM":[{"def":"The principles of the Tractarians, or of those persons accepting the teachings of the \"Tracts for the Times.","pos":""}],"TRACTATE":[{"def":"A treatise; a tract; an essay.","pos":""}],"TRACTATION":[{"def":"Treatment or handling of a subject; discussion.","pos":""}],"TRACTATOR":[{"def":"One who writes tracts; specif.","pos":""}],"TRACTILE":[{"def":"Capable of being drawn out in length; ductile.","pos":""}],"TRACTILITY":[{"def":"The quality of being tractile; ductility.","pos":""}],"TRACTION":[{"def":"The act of drawing, or the state of being drawn; as, the traction of a muscle.","pos":""},{"def":"Specifically, the act of drawing a body along a plane by motive power, as the drawing of a carriage by men or horses, the towing of a boat by a tug.","pos":""}],"TRACTIONAL":[{"def":"Of or relating to traction.","pos":""}],"TRACTITIOUS":[{"def":"Treating of; handling.","pos":""}],"TRACTIVE":[{"def":"Serving to draw; pulling; attracting; as, tractive power.","pos":""}],"TRACTOR":[{"def":"Two small, pointed rods of metal, formerly used in the treatment called Perkinism.","pos":""}],"TRACTORATION":[{"def":"A propeller screw placed in front of the supporting planes of an aëroplane instead of behind them, so that it exerts a pull instead of a push.","pos":""}],"TRACTRIX":[{"def":"A curve such that the part of the tangent between the point of tangency and a given straight line is constant; -- so called because it was conceived as described by the motion of one end of a tangent line as the other end was drawn along the given line.","pos":""}]}