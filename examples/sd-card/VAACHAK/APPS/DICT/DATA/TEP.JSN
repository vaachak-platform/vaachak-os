{"TEPAL":[{"def":"A division of a perianth.","pos":""}],"TEPEE":[{"def":"An Indian wigwam or tent.","pos":""}],"TEPEFACTION":[{"def":"Act of tepefying.","pos":""}],"TEPEFY":[{"def":"To make or become tepid, or moderately warm.","pos":""}],"TEPHRAMANCY":[{"def":"Divination by the ashes of the altar on which a victim had been consumed in sacrifice.","pos":""}],"TEPHRITE":[{"def":"An igneous rock consisting essentially of plagioclase and either leucite or nephelite, or both.","pos":""}],"TEPHROITE":[{"def":"A silicate of manganese of an ash-gray color.","pos":""}],"TEPHROSIA":[{"def":"A genus of leguminous shrubby plants and herbs, mostly found in tropical countries, a few herbaceous species being North American.","pos":""}],"TEPID":[{"def":"Moderately warm; lukewarm; as, a tepid bath; tepid rays; tepid vapors.","pos":""}],"TEPIDITY":[{"def":"The quality or state of being tepid; moderate warmth; lukewarmness; tepidness.","pos":""}],"TEPOR":[{"def":"Gentle heat; moderate warmth; tepidness.","pos":""}]}