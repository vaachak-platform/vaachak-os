{"AFOAM":[{"def":"In a foaming state; as, the sea is all afoam.","pos":""},{"def":"American Federation of Labor.","pos":""}],"AFOOT":[{"def":"We 'll walk afoot a while.","pos":""}],"AFORE":[{"def":"In the fore part of a vessel.","pos":""}],"AFORECITED":[{"def":"Named or quoted before.","pos":""}],"AFOREGOING":[{"def":"Going before; foregoing.","pos":""}],"AFOREHAND":[{"def":"Beforehand; in anticipation.","pos":""}],"AFOREMENTIONED":[{"def":"Previously mentioned; before-mentioned.","pos":""}],"AFORESAID":[{"def":"Said before, or in a preceding part; already described or identified.","pos":""}],"AFORETHOUGHT":[{"def":"Premeditated; prepense; previously in mind; designed; as, malice aforethought, which is required to constitute murder.","pos":""}],"AFORETIME":[{"def":"In time past; formerly.","pos":""}],"AFOUL":[{"def":"In collision; entangled.","pos":""}]}