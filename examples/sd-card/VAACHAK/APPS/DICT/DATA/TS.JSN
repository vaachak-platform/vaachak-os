{"TSAR":[{"def":"The title of the emperor of Russia.","pos":""},{"def":"The title of the empress of Russia.","pos":""}],"TSCHEGO":[{"def":"A West African anthropoid ape allied to the gorilla and chimpanzee, and by some considered only a variety of the chimpanzee.","pos":""}],"TSETSE":[{"def":"A venomous two-winged African fly (Glossina morsitans) whose bite is very poisonous, and even fatal, to horses and cattle, but harmless to men.","pos":""}],"TSUNG TU":[{"def":"A viceroy or governor-general, the highest provincial official in China, with civil and military authority over one or more provinces.","pos":""}],"TSUNG-LI YAMEN":[{"def":"The board or department of foreign affairs in the Chinese government.","pos":""}]}