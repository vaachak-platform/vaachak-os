{"INTERNATIONALLY":[{"def":"In an international manner; from an international point of view.","pos":""}],"INTERNE":[{"def":"That which is within; the interior.","pos":""}],"INTERNECINE":[{"def":"Involving, or accompanied by, mutual slaughter; mutually destructive.","pos":""}],"INTERNECION":[{"def":"Mutual slaughter or destruction; massacre.","pos":""}],"INTERNECTION":[{"def":"Intimate connection.","pos":""}],"INTERNEURAL":[{"def":"Between the neural arches or neural spines.","pos":""},{"def":"An interneural spine or cartilage.","pos":""}],"INTERNITY":[{"def":"State of being within; interiority.","pos":""}],"INTERNMENT":[{"def":"Confinement within narrow limits, -- as of foreign troops, to the interior of a country.","pos":""}],"INTERNODAL":[{"def":"Of or pertaining to internodes; intervening between nodes or joints.","pos":""}],"INTERNODE":[{"def":"The space between two nodes or points of the stem from which the leaves properly arise.","pos":""},{"def":"A part between two joints; a segment; specifically, one of the phalanges.","pos":""}],"INTERNUNCIAL":[{"def":"Communicating or transmitting impressions between different parts of the body; -- said of the nervous system.","pos":""}],"INTERNUNCIESS":[{"def":"A female messenger.","pos":""}],"INTERNUNCIO":[{"def":"A messenger between two parties.","pos":""},{"def":"A representative, or chargé d'affaires, of the pope at a foreign court or seat of government, ranking next below a nuncio.","pos":""}],"INTERNUNCIOSHIP":[{"def":"The office or function of an internuncio.","pos":""}],"INTEROCEANIC":[{"def":"Between oceans; connecting oceans; as, interoceanic communication; an interoceanic canal.","pos":""}],"INTEROCULAR":[{"def":"Between, or within, the eyes; as, the interocular distance; situated between the eyes, as the antennæ of some insects.","pos":""}],"INTEROPERCULAR":[{"def":"Of or pertaining to the interoperculum.","pos":""},{"def":"The interopercular bone.","pos":""}],"INTEROPERCULUM":[{"def":"The postero-inferior opercular bone, in fishes.","pos":""}],"INTERORBITAL":[{"def":"Between the orbits; as, the interorbital septum.","pos":""}],"INTEROSCULANT":[{"def":"Uniting two groups; -- said of certain genera which connect family groups, or of species that connect genera.","pos":""}],"INTEROSCULATE":[{"def":"To have the character of, or to lie between, two distinct groups.","pos":""},{"def":"Situated between bones; as, an interosseous ligament.","pos":""}],"INTERPALE":[{"def":"To place pales between or among; to separate by pales.","pos":""},{"def":"To interweave or interlace.","pos":""}],"INTERPARIETAL":[{"def":"Between the parietal bones or cartilages; as, the interparietal suture.","pos":""}],"INTERPAUSE":[{"def":"An intermission.","pos":""}],"INTERPEDENCULAR":[{"def":"Between peduncles; esp.","pos":""}],"INTERPEL":[{"def":"To interrupt, break in upon, or intercede with.","pos":""}],"INTERPELLANT":[{"def":"Interpelling; interrupting.","pos":""},{"def":"One who, or that which, interpels.","pos":""}],"INTERPELLATE":[{"def":"To question imperatively, as a minister, or other executive officer, in explanation of his conduct; -- generally on the part of a legislative body.","pos":""}],"INTERPELLATION":[{"def":"The act of interpelling or interrupting; interruption.","pos":""},{"def":"The act of interposing or interceding; intercession.","pos":""}],"INTERPENETRATE":[{"def":"To penetrate between or within; to penetrate mutually.","pos":""}],"INTERPENETRATION":[{"def":"The act of penetrating between or within other substances; mutual penetration.","pos":""}],"INTERPENETRATIVE":[{"def":"Penetrating among or between other substances; penetrating each the other; mutually penetrative.","pos":""}],"INTERPETALARY":[{"def":"Between the petals of a flower.","pos":""}],"INTERPETIOLAR":[{"def":"Being between petioles.","pos":""}],"INTERPHALANGEAL":[{"def":"Between phalanges; as, interphalangeal articulations.","pos":""}],"INTERPILASTER":[{"def":"The interval or space between two pilasters.","pos":""}],"INTERPLACE":[{"def":"To place between or among; as, to interplace a name.","pos":""}],"INTERPLANETARY":[{"def":"Between planets; as, interplanetary spaces.","pos":""}],"INTERPLAY":[{"def":"Mutual action or influence; interaction; as, the interplay of affection.","pos":""}],"INTERPLEAD":[{"def":"To plead against each other, or go to trial between themselves, as the claimants in an in an interpleader.","pos":""}],"INTERPLEADER":[{"def":"A proceeding devised to enable a person, of whom the same debt, duty, or thing is claimed adversely by two or more parties, to compel them to litigate the right or title between themselves, and thereby to relieve himself from the suits which they might otherwise bring against him.","pos":""}],"INTERPLEDGE":[{"def":"To pledge mutually.","pos":""}],"INTERPOINT":[{"def":"To point; to mark with stops or pauses; to punctuate.","pos":""}],"INTERPOLABLE":[{"def":"That may be interpolated; suitable to be interpolated.","pos":""}],"INTERPOLATE":[{"def":"To fill up intermediate terms of, as of a series, according to the law of the series; to introduce, as a number or quantity, in a partial series, according to the law of that part of the series.","pos":""}],"INTERPOLATED":[{"def":"Inserted in, or added to, the original; introduced; foisted in; changed by the insertion of new or spurious matter.","pos":""}],"INTERPOLATION":[{"def":"The method or operation of finding from a few given terms of a series, as of numbers or observations, other intermediate terms in conformity with the law of the series.","pos":""}],"INTERPOLATOR":[{"def":"One who interpolates; esp.","pos":""}],"INTERPONE":[{"def":"To interpose; to insert or place between.","pos":""}],"INTERPONENT":[{"def":"One who, or that which, interposes; an interloper, an opponent.","pos":""}],"INTERPOSAL":[{"def":"The act of interposing; interposition; intervention.","pos":""}],"INTERPOSE":[{"def":"To place between; as, to interpose a screen between the eye and the light.","pos":""},{"def":"To thrust; to intrude; to between, either for aid or for troubling.","pos":""}],"INTERPOSER":[{"def":"One who, or that which, interposes or intervenes; an obstacle or interruption; a mediator or agent between parties.","pos":""}],"INTERPOSIT":[{"def":"An intermediate depot or station between one commercial city or country and another.","pos":""}],"INTERPOSITION":[{"def":"The act of interposing, or the state of being interposed; a being, placing, or coming between; mediation.","pos":""},{"def":"The thing interposed.","pos":""}],"INTERPRET":[{"def":"To explain or tell the meaning of; to expound; to translate orally into intelligible or familiar language or terms; to decipher; to define; -- applied esp.","pos":""},{"def":"To apprehend and represent by means of art; to show by illustrative representation; as, an actor interprets the character of Hamlet; a musician interprets a sonata; an artist interprets a landscape.","pos":""}],"INTERPRETABLE":[{"def":"Admitting of interpretation; capable of being interpreted or explained.","pos":""}],"INTERPRETAMENT":[{"def":"In*ter\"pre*ta*ment, n.","pos":""}],"INTERPRETATION":[{"def":"An artist's way of expressing his thought or embodying his conception of nature.","pos":""},{"def":"The act or process of applying general principles or formulæ to the explanation of the results obtained in special cases.","pos":""}],"INTERPRETATIVE":[{"def":"Designed or fitted to interpret; explanatory.","pos":""},{"def":"According to interpretation; constructive.","pos":""}],"INTERPRETATIVELY":[{"def":"By interpretation.","pos":""}],"INTERPRETER":[{"def":"One who or that which interprets, explains, or expounds; a translator; especially, a person who translates orally between two parties.","pos":""}],"INTERPUBIC":[{"def":"Between the pubic bones or cartilages; as, the interpubic disk.","pos":""}],"INTERPUNCTION":[{"def":"The insertion of points between word or sentences; punctuation.","pos":""}],"INTERRADIAL":[{"def":"Between the radii, or rays; -- in zoölogy, said of certain parts of radiate animals; as, the interradial plates of a starfish.","pos":""}],"INTERRAMAL":[{"def":"Between rami or branches; esp.","pos":""}],"INTERRECEIVE":[{"def":"To receive between or within.","pos":""}],"INTERREGENT":[{"def":"A person who discharges the royal functions during an interregnum.","pos":""}],"INTERREGNUM":[{"def":"The time during which a throne is vacant between the death or abdication of a sovereign and the accession of his successor.","pos":""},{"def":"Any period during which, for any cause, the executive branch of a government is suspended or interrupted.","pos":""}],"INTERRELATED":[{"def":"Having a mutual or reciprocal relation or parallelism; correlative.","pos":""}],"INTERRELATION":[{"def":"Mutual or reciprocal relation; correlation.","pos":""}],"INTERRENAL":[{"def":"Between the kidneys; as, the interrenal body, an organ found in many fishes.","pos":""},{"def":"The interrenal body.","pos":""}],"INTERREPELLENT":[{"def":"Mutually repellent.","pos":""}],"INTERREX":[{"def":"An interregent, or a regent.","pos":""}],"INTERROGATE":[{"def":"To question formally; to question; to examine by asking questions; as, to interrogate a witness.","pos":""}],"INTERROGATEE":[{"def":"One who is interrogated.","pos":""}],"INTERROGATION":[{"def":"The act of interrogating or questioning; examination by questions; inquiry.","pos":""},{"def":"A question put; an inquiry.","pos":""}],"INTERROGATIVE":[{"def":"Denoting a question; expressed in the form of a question; as, an interrogative sentence; an interrogative pronoun.","pos":""}],"INTERROGATIVELY":[{"def":"In the form of, or by means of, a question; in an interrogative manner.","pos":""}],"INTERROGATOR":[{"def":"One who asks questions; a questioner.","pos":""}],"INTERROGATORY":[{"def":"A formal question or inquiry; esp.","pos":""}],"INTERRUPT":[{"def":"To break into, or between; to stop, or hinder by breaking in upon the course or progress of; to interfere with the current or motion of; to cause a temporary cessation of; as, to interrupt the remarks speaking.","pos":""},{"def":"To divide; to separate; to break the monotony of; as, the evenness of the road was not interrupted by a single hill.","pos":""}],"INTERRUPTED":[{"def":"Irregular; -- said of any arrangement whose symmetry is destroyed by local causes, as when leaflets are interposed among the leaves in a pinnate leaf.","pos":""}],"INTERRUPTEDLY":[{"def":"With breaks or interruptions; discontinuously.","pos":""}],"INTERRUPTER":[{"def":"A device for opening and closing an electrical circuit; a vibrating spring or tuning fork, arranged to make and break a circuit at rapidly recurring intervals, by the action of the current itself.","pos":""}],"INTERRUPTION":[{"def":"The act of interrupting, or breaking in upon.","pos":""},{"def":"The state of being interrupted; a breach or break, caused by the abrupt intervention of something foreign; intervention; interposition.","pos":""}],"INTERRUPTIVE":[{"def":"Tending to interrupt; interrupting.","pos":""}],"INTERSCAPULAR":[{"def":"Between the scapulæ or shoulder blades.","pos":""},{"def":"Pertaining to the upper back, or the part between the shoulders; as, the interscapular feathers.","pos":""}],"INTERSCAPULARS":[{"def":"The interscapular feathers of a bird.","pos":""}],"INTERSCENDENT":[{"def":"Having exponents which are radical quantities; -- said of certain powers; as, xsq.","pos":""}],"INTERSCRIBE":[{"def":"To write between.","pos":""}],"INTERSECANT":[{"def":"Dividing into parts; crossing; intersecting.","pos":""}],"INTERSECT":[{"def":"To cut into or between; to cut or cross mutually; to divide into parts; as, any two diameters of a circle intersect each other at the center.","pos":""}],"INTERSECTION":[{"def":"The point or line in which one line or surface cuts another.","pos":""}],"INTERSECTIONAL":[{"def":"Pertaining to, or formed by, intersections.","pos":""}],"INTERSEMINATE":[{"def":"To sow between or among.","pos":""}],"INTERSEPTAL":[{"def":"Between septa; as, the interseptal spaces or zones, between the transparent, or septal, zones in striated muscle; the interseptal chambers of a shell, or of a seed vessel.","pos":""}],"INTERSERT":[{"def":"To put in between other things; to insert.","pos":""}],"INTERSERTTION":[{"def":"The act of interserting, or that which is interserted.","pos":""}],"INTERSESAMOID":[{"def":"Between sesamoid bones; as, intersesamoid ligaments.","pos":""}],"INTERSET":[{"def":"To set between or among.","pos":""}],"INTERSHOCK":[{"def":"To shock mutually.","pos":""}],"INTERSIDEREAL":[{"def":"Between or among constellations or stars; interstellar.","pos":""}],"INTERSOCIAL":[{"def":"Pertaining to the mutual intercourse or relations of persons in society; social.","pos":""}],"INTERSOMNIOUS":[{"def":"Between the times of sleeping; in an interval of wakefulness.","pos":""}],"INTERSPACE":[{"def":"Intervening space.","pos":""}],"INTERSPEECH":[{"def":"A speech interposed between others.","pos":""}],"INTERSPERSE":[{"def":"To scatter or set here and there among other things; to insert at intervals; as, to intersperse pictures in a book.","pos":""},{"def":"To diversify or adorn with things set or scattered at intervals; to place something at intervals in or among; as, to intersperse a book with pictures.","pos":""}],"INTERSPERSION":[{"def":"The act of interspersing, or the state of being interspersed.","pos":""},{"def":"Between spines; esp.","pos":""}],"INTERSPIRATION":[{"def":"Spiritual inspiration at separate times, or at intervals.","pos":""}],"INTERSTAPEDIAL":[{"def":"Pertaining to a part of the columella of the ear, between the stapes and the mediostapedial.","pos":""},{"def":"The interstapedial part of the columella.","pos":""}],"INTERSTATE":[{"def":"Pertaining to the mutual relations of States; existing between, or including, different States; as, interstate commerce.","pos":""}],"INTERSTELLAR":[{"def":"Between or among the stars; as, interstellar space.","pos":""}],"INTERSTERNAL":[{"def":"Between the sternal; -- said of certain membranes or parts of insects and crustaceans.","pos":""}]}