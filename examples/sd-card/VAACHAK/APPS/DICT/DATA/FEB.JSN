{"FEBRICITATE":[{"def":"To have a fever.","pos":""}],"FEBRICULOSE":[{"def":"Somewhat feverish.","pos":""}],"FEBRIFACIENT":[{"def":"That which causes fever.","pos":""}],"FEBRIFEROUS":[{"def":"Causing fever; as, a febriferous locality.","pos":""}],"FEBRIFIC":[{"def":"Producing fever.","pos":""}],"FEBRIFUGAL":[{"def":"Having the quality of mitigating or curing fever.","pos":""}],"FEBRIFUGE":[{"def":"A medicine serving to mitigate or remove fever.","pos":""}],"FEBRILE":[{"def":"Pertaining to fever; indicating fever, or derived from it; as, febrile symptoms; febrile action.","pos":""}],"FEBRUARY":[{"def":"The second month in the year, said to have been introduced into the Roman calendar by Numa.","pos":""}],"FEBRUATION":[{"def":"Purification; a sacrifice.","pos":""}]}