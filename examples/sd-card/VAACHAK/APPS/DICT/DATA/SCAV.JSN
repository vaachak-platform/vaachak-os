{"SCAVAGE":[{"def":"A toll duty formerly exacted of merchant strangers by mayors, sheriffs, etc.","pos":""}],"SCAVENGE":[{"def":"To cleanse, as streets, from filth.","pos":""}],"SCAVENGER":[{"def":"A person whose employment is to clean the streets of a city, by scraping or sweeping, and carrying off the fifth.","pos":""}],"SCAVENGING":[{"def":"Act or process of expelling the exhaust gases from the cylinder by some special means, as, in many four-cycle engines, by utilizing the momentum of the exhaust gases in a long exhaust pipe.","pos":""}]}