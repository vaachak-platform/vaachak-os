{"CONSECRATE":[{"def":"Consecrated; devoted; dedicated; sacred.","pos":""}],"CONSECRATION":[{"def":"The act or ceremony of consecrating; the state of being consecrated; dedication.","pos":""}],"CONSECRATOR":[{"def":"One who consecrates; one who performs the rites by which a person or thing is devoted or dedicated to sacred purposes.","pos":""}],"CONSECRATORY":[{"def":"Of or pertaining to the act of consecration; dedicatory.","pos":""}],"CONSECTANEOUS":[{"def":"Following as a matter of course.","pos":""}],"CONSECTARY":[{"def":"Following by consequence; consequent; deducible.","pos":""}],"CONSECUTE":[{"def":"To follow closely; to endeavor to overtake; to pursue.","pos":""}],"CONSECUTION":[{"def":"A following, or sequel; actual or logical dependence.","pos":""},{"def":"A succession or series of any kind.","pos":""}],"CONSECUTIVE":[{"def":"Having similarity of sequence; -- said of certain parallel progressions of two parts in a piece of harmony; as, consecutive fifths, or consecutive octaves, which are forbidden.","pos":""}],"CONSECUTIVELY":[{"def":"In a consecutive manner; by way of sequence; successively.","pos":""}],"CONSECUTIVENESS":[{"def":"The state or quality of being consecutive.","pos":""}],"CONSENSION":[{"def":"Agreement; accord.","pos":""}],"CONSENSUAL":[{"def":"Existing, or made, by the mutual consent of two or more parties.","pos":""},{"def":"Excited or caused by sensation, sympathy, or reflex action, and not by conscious volition; as, consensual motions.","pos":""}],"CONSENSUS":[{"def":"Agreement; accord; consent.","pos":""}],"CONSENT":[{"def":"To agree in opinion or sentiment; to be of the same mind; to accord; to concur.","pos":""},{"def":"To indicate or express a willingness; to yield to guidance, persuasion, or necessity; to give assent or approval; to comply.","pos":""}],"CONSENTANEITY":[{"def":"Mutual agreement.","pos":""}],"CONSENTANEOUS":[{"def":"Consistent; agreeable; suitable; accordant to; harmonious; concurrent.","pos":""}],"CONSENTER":[{"def":"One who consents.","pos":""}],"CONSENTIENT":[{"def":"Agreeing in mind; accordant.","pos":""}],"CONSENTINGLY":[{"def":"With consent; in a compliant manner.","pos":""}],"CONSEQUENCE":[{"def":"A proposition collected from the agreement of other previous propositions; any conclusion which results from reason or argument; inference.","pos":""}],"CONSEQUENCING":[{"def":"Drawing inference.","pos":""}],"CONSEQUENT":[{"def":"Following by necessary inference or rational deduction; as, a proposition consequent to other propositions.","pos":""}],"CONSEQUENTIAL":[{"def":"Following as a consequence, result, or logical inference; consequenment.","pos":""},{"def":"Assuming or exhibiting an air of consequence; pretending to importance; pompous; self-important; as, a consequential man.","pos":""}],"CONSEQUENTIALLY":[{"def":"With just deduction of consequence; with right connection of ideas; logically.","pos":""},{"def":"By remote consequence; not immediately; eventually; as, to do a thing consequentially.","pos":""}],"CONSEQUENTIALNESS":[{"def":"The quality of being consequential.","pos":""}],"CONSEQUENTLY":[{"def":"By consequence; by natural or logical sequence or connection.","pos":""}],"CONSERTION":[{"def":"Junction; adaptation [R.","pos":""}],"CONSERVABLE":[{"def":"Capable of being preserved from decay or injury.","pos":""}],"CONSERVANCY":[{"def":"Conservation, as from injury, defilement, or irregular use.","pos":""}],"CONSERVANT":[{"def":"Having the power or quality of conservation.","pos":""}],"CONSERVATION":[{"def":"The act of preserving, guarding, or protecting; the keeping (of a thing) in a safe or entire state; preservation.","pos":""}],"CONSERVATIONAL":[{"def":"Tending to conserve; preservative.","pos":""}],"CONSERVATISM":[{"def":"The disposition and tendency to preserve what is established; opposition to change; the habit of mind; or conduct, of a conservative.","pos":""}],"CONSERVATIVE":[{"def":"Having power to preserve in a safe of entire state, or from loss, waste, or injury; preservative.","pos":""},{"def":"Tending or disposed to maintain existing institutions; opposed to change or innovation.","pos":""}],"CONSERVATIVENESS":[{"def":"The quality of being conservative.","pos":""}],"CONSERVATOIRE":[{"def":"A public place of instruction in any special branch, esp.","pos":""}],"CONSERVATOR":[{"def":"One who preserves from injury or violation; a protector; a preserver.","pos":""}],"CONSERVATORY":[{"def":"Having the quality of preserving from loss, decay, or injury.","pos":""}],"CONSERVATRIX":[{"def":"A woman who preserves from loss, injury, etc.","pos":""}],"CONSERVE":[{"def":"To keep in a safe or sound state; to save; to preserve; to protect.","pos":""},{"def":"To prepare with sugar, etc.","pos":""}],"CONSERVER":[{"def":"One who conserves.","pos":""}]}