{"DISPLACE":[{"def":"To change the place of; to remove from the usual or proper place; to put out of place; to place in another situation; as, the books in the library are all displaced.","pos":""},{"def":"To crowd out; to take the place of.","pos":""}],"DISPLACEABLE":[{"def":"Capable of being displaced.","pos":""}],"DISPLACEMENT":[{"def":"The process of extracting soluble substances from organic material and the like, whereby a quantity of saturated solvent is displaced, or removed, for another quantity of the solvent.","pos":""}],"DISPLACENCY":[{"def":"Want of complacency or gratification; envious displeasure; dislike.","pos":""}],"DISPLACER":[{"def":"The funnel part of the apparatus for solution by displacement.","pos":""}],"DISPLANT":[{"def":"To remove (what is planted or fixed); to unsettle and take away; to displace; to root out; as, to displant inhabitants.","pos":""},{"def":"To strip of what is planted or settled; as, to displant a country of inhabitants.","pos":""}],"DISPLANTATION":[{"def":"The act of displanting; removal; displacement.","pos":""}],"DISPLAT":[{"def":"To untwist; to uncurl; to unplat.","pos":""}],"DISPLAY":[{"def":"To extend the front of (a column), bringing it into line.","pos":""},{"def":"To make conspicuous by large or prominent type.","pos":""}],"DISPLAYED":[{"def":"With wings expanded; -- said of a bird of pray, esp.","pos":""},{"def":"Set with lines of prominent type interspersed, to catch the eye.","pos":""}],"DISPLAYER":[{"def":"One who, or that which, displays.","pos":""}],"DISPLE":[{"def":"To discipline; to correct.","pos":""}],"DISPLEASANCE":[{"def":"Displeasure; discontent; annoyance.","pos":""}],"DISPLEASANT":[{"def":"Unpleasing; offensive; unpleasant.","pos":""}],"DISPLEASE":[{"def":"To make not pleased; to excite a feeling of disapprobation or dislike in; to be disagreeable to; to offend; to vex; -- often followed by with or at.","pos":""},{"def":"To fail to satisfy; to miss of.","pos":""}],"DISPLEASEDLY":[{"def":"With displeasure.","pos":""}],"DISPLEASER":[{"def":"One who displeases.","pos":""}],"DISPLEASING":[{"def":"Causing displeasure or dissatisfaction; offensive; disagreeable.","pos":""}],"DISPLEASURE":[{"def":"The feeling of one who is displeased; irritation or uneasiness of the mind, occasioned by anything that counteracts desire or command, or which opposes justice or a sense of propriety; disapprobation; dislike; dissatisfaction; disfavor; indignation.","pos":""},{"def":"That which displeases; cause of irritation or annoyance; offense; injury.","pos":""}],"DISPLENISH":[{"def":"To deprive or strip, as a house of furniture, or a barn of stock.","pos":""},{"def":"Dislike; dissatisfaction; discontent.","pos":""}],"DISPLODE":[{"def":"To discharge; to explode.","pos":""}],"DISPLOSION":[{"def":"The vast displosion dissipates the clouds.","pos":""}],"DISPLUME":[{"def":"To strip of, or as of, a plume, or plumes; to deprive of decoration; to dishonor; to degrade.","pos":""}]}