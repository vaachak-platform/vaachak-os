{"NONREGARDANCE":[{"def":"Want of due regard; disregard; slight.","pos":""}],"NONREGENT":[{"def":"A master of arts whose regency has ceased.","pos":""}],"NONRENDITION":[{"def":"Neglect of rendition; the not rendering what is due.","pos":""}],"NONRESEMBLANCE":[{"def":"Want of resemblance; unlikeness; dissimilarity.","pos":""}],"NONRESIDENCE":[{"def":"The state or condition of being nonresident, Swift.","pos":""}],"NONRESIDENT":[{"def":"Not residing in a particular place, on one's own estate, or in one's proper place; as, a nonresident clergyman or proprietor of lands.","pos":""}],"NONRESISTANCE":[{"def":"The principles or practice of a nonresistant; passive obedience; submission to authority, power, oppression, or violence without opposition.","pos":""}],"NONRESISTANT":[{"def":"Making no resistance.","pos":""}],"NONRESISTING":[{"def":"Not making resistance.","pos":""}],"NONRUMINANT":[{"def":"Not ruminating; as, a nonruminant animal.","pos":""}]}