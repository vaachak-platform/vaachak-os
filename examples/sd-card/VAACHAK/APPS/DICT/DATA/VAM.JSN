{"VAMBRACE":[{"def":"The piece designed to protect the arm from the elbow to the wrist.","pos":""}],"VAMOSE":[{"def":"To depart quickly; to depart from.","pos":""}],"VAMP":[{"def":"To advance; to travel.","pos":""}],"VAMPER":[{"def":"One who vamps; one who pieces an old thing with something new; a cobbler.","pos":""}],"VAMPIRE":[{"def":"Either one of two or more species of South American blood- sucking bats belonging to the genera Desmodus and Diphylla.","pos":""},{"def":"Any one of several species of harmless tropical American bats of the genus Vampyrus, especially V.","pos":""}],"VAMPIRISM":[{"def":"Belief in the existence of vampires.","pos":""},{"def":"The actions of a vampire; the practice of bloodsucking.","pos":""}],"VAMPLATE":[{"def":"A round of iron on the shaft of a tilting spear, to protect the hand.","pos":""}]}