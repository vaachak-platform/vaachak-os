{"APPAIR":[{"def":"To impair; to grow worse.","pos":""}],"APPALACHIAN":[{"def":"Of or pertaining to a chain of mountains in the United States, commonly called the Allegheny mountains.","pos":""}],"APPALL":[{"def":"To make pale; to blanch.","pos":""},{"def":"To weaken; to enfeeble; to reduce; as, an old appalled wight.","pos":""}],"APPALLING":[{"def":"Such as to appall; as, an appalling accident.","pos":""}],"APPALLMENT":[{"def":"Depression occasioned by terror; dismay.","pos":""}],"APPANAGE":[{"def":"The portion of land assigned by a sovereign prince for the subsistence of his younger sons.","pos":""},{"def":"A dependency; a dependent territory.","pos":""}],"APPANAGIST":[{"def":"A prince to whom an appanage has been granted.","pos":""}],"APPARATUS":[{"def":"A collection of organs all of which unite in a common function; as, the respiratory apparatus.","pos":""}],"APPAREL":[{"def":"The furniture of a ship, as masts, sails, rigging, anchors, guns, etc.","pos":""}],"APPARENCY":[{"def":"Apparentness; state of being apparent.","pos":""}],"APPARENT":[{"def":"Capable of being seen, or easily seen; open to view; visible to the eye; within sight or view.","pos":""},{"def":"Clear or manifest to the understanding; plain; evident; obvious; known; palpable; indubitable.","pos":""}],"APPARENTLY":[{"def":"Plainly; clearly; manifestly; evidently.","pos":""}],"APPARENTNESS":[{"def":"Plainness to the eye or the mind; visibleness; obviousness.","pos":""}],"APPARITION":[{"def":"The first appearance of a star or other luminary after having been invisible or obscured; -- opposed to occultation.","pos":""}],"APPARITIONAL":[{"def":"Pertaining to an apparition or to apparitions; spectral.","pos":""}],"APPARITOR":[{"def":"A messenger or officer who serves the process of an ecclesiastical court.","pos":""}],"APPAUME":[{"def":"A hand open and extended so as to show the palm.","pos":""}],"APPAY":[{"def":"To pay; to satisfy or appease.","pos":""}]}