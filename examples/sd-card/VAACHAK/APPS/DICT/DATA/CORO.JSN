{"COROCORE":[{"def":"A kind of boat of various forms, used in the Indian Archipelago.","pos":""}],"CORODY":[{"def":"An allowance of meat, drink, or clothing due from an abbey or other religious house for the sustenance of such of the king's servants as he may designate to receive it.","pos":""}],"COROLLA":[{"def":"The inner envelope of a flower; the part which surrounds the organs of fructification, consisting of one or more leaves, called petals.","pos":""}],"COROLLACEOUS":[{"def":"Pertaining to, or resembling, a corolla; having the form or texture of a corolla.","pos":""}],"COROLLARY":[{"def":"Having a corolla or corollas; like a corolla.","pos":""}],"COROLLET":[{"def":"A floret in an aggregate flower.","pos":""},{"def":"Having the stamens borne on the petals, and the latter free from the calyx.","pos":""}],"COROLLINE":[{"def":"Of or pertaining to a corolla.","pos":""}],"COROMANDEL":[{"def":"The west coast, or a portion of the west coast, of the Bay of Bengal.","pos":""}],"CORONA":[{"def":"The projecting part of a Classic cornice, the under side of which is cut with a recess or channel so as to form a drip.","pos":""},{"def":"The upper surface of some part, as of a tooth or the skull; a crown.","pos":""}],"CORONACH":[{"def":"Cor\"o*nach (kr\"-nk), n.","pos":""}],"CORONAL":[{"def":"Of or pertaining to the shell of a sea urchin.","pos":""}],"CORONAMEN":[{"def":"The upper margin of a hoof; a coronet.","pos":""}],"CORONARY":[{"def":"Resembling, or situated like, a crown or circlet; as, the coronary arteries and veins of the heart.","pos":""}],"CORONARY BONE":[{"def":"The small pastern bone of the horse and allied animals.","pos":""}],"CORONARY CUSHION":[{"def":"A cushionlike band of vascular tissue at the upper border of the wall of the hoof of the horse and allied animals.","pos":""},{"def":"Having a crest or a crownlike appendage.","pos":""}],"CORONATION":[{"def":"The act or solemnity of crowning a sovereign; the act of investing a prince with the insignia of royalty, on his succeeding to the sovereignty.","pos":""},{"def":"The pomp or assembly at a coronation.","pos":""}],"CORONEL":[{"def":"The iron head of a tilting spear, divided into two, three, or four blunt points.","pos":""}],"CORONER":[{"def":"An officer of the peace whose principal duty is to inquire, with the help of a jury, into the cause of any violent, sudden or mysterious death, or death in prison, usually on sight of the body and at the place where the death occurred.","pos":""}],"CORONET":[{"def":"The upper part of a horse's hoof, where the horn terminates in skin.","pos":""},{"def":"The iron head of a tilting spear; a coronel.","pos":""}],"CORONETED":[{"def":"Wearing, or entitled to wear, a coronet; of noble birth or rank.","pos":""}],"CORONIFORM":[{"def":"Having the form of a crown or coronet; resembling a crown.","pos":""}],"CORONILLA":[{"def":"A genus of plants related to the clover, having their flowers arranged in little heads or tufts resembling coronets.","pos":""}],"CORONIS":[{"def":"In Greek grammar, a sign ['] sometimes placed over a contracted syllable.","pos":""},{"def":"The curved line or flourish at the end of a book or chapter; hence, the end.","pos":""}],"CORONIUM":[{"def":"The principal gaseous substance forming the solar corona, characterized by a green line in the coronal spectrum.","pos":""}],"CORONOID":[{"def":"Resembling the beak of a crow; as, the coronoid process of the jaw, or of the ulna.","pos":""}],"CORONULE":[{"def":"A coronet or little crown of a seed; the downy tuft on seeds.","pos":""}],"COROUN":[{"def":"The name in Central America for the seed of a true palm; also, a commercial name for the true ivory nut.","pos":""}]}