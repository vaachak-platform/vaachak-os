{"SPICA":[{"def":"A kind of bandage passing, by successive turns and crosses, from an extremity to the trunk; -- so called from its resemblance to a spike of a barley.","pos":""},{"def":"A star of the first magnitude situated in the constellation Virgo.","pos":""}],"SPICCATO":[{"def":"Detached; separated; -- a term indicating that every note is to be performed in a distinct and pointed manner.","pos":""}],"SPICE":[{"def":"A vegetable production of many kinds, fragrant or aromatic and pungent to the taste, as pepper, cinnamon, nutmeg, mace, allspice, ginger, cloves, etc.","pos":""}],"SPICENUT":[{"def":"A small crisp cake, highly spiced.","pos":""}],"SPICER":[{"def":"One who seasons with spice.","pos":""},{"def":"One who deals in spice.","pos":""}],"SPICERY":[{"def":"Spices, in general.","pos":""},{"def":"A repository of spices.","pos":""}],"SPICEWOOD":[{"def":"An American shrub (Lindera Benzoin), the bark of which has a spicy taste and odor; -- called also Benjamin, wild allspice, and fever bush.","pos":""}],"SPICIFEROUS":[{"def":"Bearing ears, or spikes; spicate.","pos":""}],"SPICILY":[{"def":"In a spicy manner.","pos":""}],"SPICINESS":[{"def":"The quality or state of being spicy.","pos":""}],"SPICK":[{"def":"A spike or nail.","pos":""}],"SPICKNEL":[{"def":"An umbelliferous herb (Meum Athamanticum) having finely divided leaves, common in Europe; -- called also baldmoney, mew, and bearwort.","pos":""}],"SPICOSE":[{"def":"Having spikes, or ears, like corn spikes.","pos":""}],"SPICOSITY":[{"def":"The state of having, or being full of, ears like corn.","pos":""}],"SPICULAR":[{"def":"Resembling a dart; having sharp points.","pos":""}],"SPICULATE":[{"def":"Covered with minute spiculæ, or pointed fleshy appendages; divided into small spikelets.","pos":""}],"SPICULE":[{"def":"Same as Spicula.","pos":""},{"def":"Any small calcareous or siliceous body found in the tissues of various invertebrate animals, especially in sponges and in most Alcyonaria.","pos":""}],"SPICULIFORM":[{"def":"Having the shape of a spicule.","pos":""}],"SPICULIGENOUS":[{"def":"Producing or containing spicules.","pos":""}],"SPICULISPONGIAE":[{"def":"A division of sponges including those which have independent siliceous spicules.","pos":""}],"SPICULUM":[{"def":"Same as Spicule.","pos":""}],"SPICY":[{"def":"Flavored with, or containing, spice or spices; fragrant; aromatic; as, spicy breezes.","pos":""},{"def":"Producing, or abounding with, spices.","pos":""}]}