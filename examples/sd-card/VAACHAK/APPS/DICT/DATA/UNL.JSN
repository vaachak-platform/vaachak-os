{"UNLABORED":[{"def":"Not produced by labor or toil.","pos":""},{"def":"Not cultivated; untitled; as, an unlabored field.","pos":""}],"UNLACE":[{"def":"To loose, and take off, as a bonnet from a sail, or to cast off, as any lacing in any part of the rigging of a vessel.","pos":""}],"UNLADE":[{"def":"To take the load from; to take out the cargo of; as, to unlade a ship or a wagon.","pos":""},{"def":"To unload; to remove, or to have removed, as a load or a burden; to discharge.","pos":""}],"UNLAID":[{"def":"Not laid or placed; not fixed.","pos":""},{"def":"Not allayed; not pacified; not laid finally to rest.","pos":""}],"UNLAND":[{"def":"To deprive of lands.","pos":""}],"UNLASH":[{"def":"To loose, as that which is lashed or tied down.","pos":""}],"UNLATCH":[{"def":"To open or loose by lifting the latch; as, to unlatch a door.","pos":""}],"UNLAUGH":[{"def":"To recall, as former laughter.","pos":""}],"UNLAW":[{"def":"To impose a fine upon; to fine.","pos":""}],"UNLAWED":[{"def":"Not having the claws and balls of the forefeet cut off; -- said of dogs.","pos":""}],"UNLAWFUL":[{"def":"Not lawful; contrary to law.","pos":""}],"UNLAWLIKE":[{"def":"Not according to law; being or done in violation of law; unlawful.","pos":""}],"UNLAY":[{"def":"To untwist; as, to unlay a rope.","pos":""}],"UNLEARN":[{"def":"To forget, as what has been learned; to lose from memory; also, to learn the contrary of.","pos":""},{"def":"To fail to learn.","pos":""}],"UNLEARNED":[{"def":"Not learned; untaught; uneducated; ignorant; illiterate.","pos":""},{"def":"Not gained by study; not known.","pos":""}],"UNLEASH":[{"def":"To free from a leash, or as from a leash; to let go; to release; as, to unleash dogs.","pos":""}],"UNLEAVENED":[{"def":"Not leavened; containing no leaven; as, unleavened bread.","pos":""}],"UNLESS":[{"def":"Upon any less condition than (the fact or thing stated in the sentence or clause which follows); if not; supposing that not; if it be not; were it not that; except; as, we shall fail unless we are industrious.","pos":""}],"UNLICKED":[{"def":"Not licked; hence, not properly formed; ungainly.","pos":""}],"UNLIKE":[{"def":"Not like; dissimilar; diverse; having no resemblance; as, the cases are unlike.","pos":""},{"def":"Not likely; improbable; unlikely.","pos":""}],"UNLIKELIHOOD":[{"def":"Absence of likelihood.","pos":""}],"UNLIKELINESS":[{"def":"The quality or state of being unlikely.","pos":""}],"UNLIKELY":[{"def":"Not likely; improbable; not to be reasonably expected; as, an unlikely event; the thing you mention is very unlikely.","pos":""},{"def":"Not holding out a prospect of success; likely to fail; unpromising; as, unlikely means.","pos":""}],"UNLIKEN":[{"def":"To make unlike; to dissimilate.","pos":""}],"UNLIKENESS":[{"def":"The quality or state of being unlike; want of resemblance; dissimilarity.","pos":""}],"UNLIMBER":[{"def":"To detach the limber from; as, to unlimber a gun.","pos":""}],"UNLIMITED":[{"def":"Not limited; having no bounds; boundless; as, an unlimited expanse of ocean.","pos":""},{"def":"Undefined; indefinite; not bounded by proper exceptions; as, unlimited terms.","pos":""}],"UNLINE":[{"def":"To take the lining out of; hence, to empty; as, to unline one's purse.","pos":""}],"UNLINK":[{"def":"To separate or undo, as links; to uncoil; to unfasten.","pos":""}],"UNLIQUIDATED":[{"def":"Not liquidated; not exactly ascertained; not adjusted or settled.","pos":""}],"UNLIQUORED":[{"def":"Not moistened or wet with liquor; dry.","pos":""},{"def":"Not in liquor; not intoxicated; sober.","pos":""}],"UNLISTED":[{"def":"Not listed; specif.","pos":""},{"def":"admitted to quotation in the unlisted department, that is, admitted to be dealt in on the floor, but not to the \"regular list.","pos":""}],"UNLIVED":[{"def":"Bereft or deprived of life.","pos":""}],"UNLOAD":[{"def":"To take the load from; to discharge of a load or cargo; to disburden; as, to unload a ship; to unload a beast.","pos":""},{"def":"Hence, to relieve from anything onerous.","pos":""}],"UNLOADER":[{"def":"One who, or that which, unloads; a device for unloading, as hay from a wagon.","pos":""}],"UNLOCATED":[{"def":"Not located or placed; not fixed in a place.","pos":""},{"def":"Not surveyed, or designated by marks, limits, or boundaries, as appropriated to some individual, company, or corporation; as, unlocated lands.","pos":""}],"UNLOCK":[{"def":"To unfasten, as what is locked; as, to unlock a door or a chest.","pos":""},{"def":"To open, in general; to lay open; to undo.","pos":""}],"UNLODGE":[{"def":"To dislodge; to deprive of lodgment.","pos":""}],"UNLOOK":[{"def":"To recall or retract, as a look.","pos":""}],"UNLOOKED":[{"def":"Not observed or foreseen; unexpected; -- generally with for.","pos":""}],"UNLOOKED-FOR":[{"def":"Not looked for; unexpected; as, an unlooked-for event.","pos":""}],"UNLOOSE":[{"def":"To make loose; to loosen; to set free.","pos":""}],"UNLOOSEN":[{"def":"To loosen; to unloose.","pos":""}],"UNLORD":[{"def":"To deprive of the rank or position of a lord.","pos":""}],"UNLORDED":[{"def":"Deprived of the rank of a lord.","pos":""},{"def":"Not raised to the rank of a lord.","pos":""}],"UNLOVE":[{"def":"To cease to love; to hate.","pos":""}],"UNLOVELY":[{"def":"Not lovely; not amiable; possessing qualities that excite dislike; disagreeable; displeasing; unpleasant.","pos":""}],"UNLUCKILY":[{"def":"In an unlucky manner.","pos":""}],"UNLUCKINESS":[{"def":"Quality or state of being unlucky.","pos":""}],"UNLUCKY":[{"def":"Not lucky; not successful; unfortunate; ill-fated; unhappy; as, an unlucky man; an unlucky adventure; an unlucky throw of dice; an unlucky game.","pos":""},{"def":"Bringing bad luck; ill-omened; inauspicious.","pos":""}],"UNLUST":[{"def":"Listlessness; disinclination.","pos":""}],"UNLUTE":[{"def":"To separate, as things cemented or luted; to take the lute or the clay from.","pos":""}]}