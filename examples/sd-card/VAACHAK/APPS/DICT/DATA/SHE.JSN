{"SHE":[{"def":"This or that female; the woman understood or referred to; the animal of the female sex, or object personified as feminine, which was spoken of.","pos":""},{"def":"A woman; a female; -- used substantively.","pos":""}],"SHEA TREE":[{"def":"An African sapotaceous tree (Bassia, or Butyrospermum, Parkii), from the seeds of which a substance resembling butter is obtained; the African butter tree.","pos":""}],"SHEADING":[{"def":"A tithing, or division, in the Isle of Man, in which there is a coroner, or chief constable.","pos":""}],"SHEAF":[{"def":"A quantity of the stalks and ears of wheat, rye, or other grain, bound together; a bundle of grain or straw.","pos":""},{"def":"Any collection of things bound together; a bundle; specifically, a bundle of arrows sufficient to fill a quiver, or the allowance of each archer, -- usually twenty-four.","pos":""}],"SHEAFY":[{"def":"Pertaining to, or consisting of, a sheaf or sheaves; resembling a sheaf.","pos":""}],"SHEAL":[{"def":"Same as Sheeling.","pos":""}],"SHEALING":[{"def":"The outer husk, pod, or shell, as of oats, pease, etc.","pos":""}],"SHEAR":[{"def":"To produce a change of shape in by a shear.","pos":""}],"SHEAR STEEL":[{"def":"See under Shear.","pos":""}],"SHEARBILL":[{"def":"The black skimmer.","pos":""}],"SHEARER":[{"def":"Like a lamb dumb before his shearer.","pos":""}],"SHEARING":[{"def":"The process of making a vertical side cutting in working into a face of coal.","pos":""}],"SHEARLING":[{"def":"A sheep but once sheared.","pos":""}],"SHEARMAN":[{"def":"One whose occupation is to shear cloth.","pos":""}],"SHEARN":[{"def":"Dung; excrement.","pos":""}],"SHEARS":[{"def":"The bedpiece of a machine tool, upon which a table or slide rest is secured; as, the shears of a lathe or planer.","pos":""}],"SHEARTAIL":[{"def":"Thaumastura having a long forked tail.","pos":""}],"SHEARWATER":[{"def":"Any one of numerous species of long-winged oceanic birds of the genus Puffinus and related genera.","pos":""}],"SHEATFISH":[{"def":"A European siluroid fish (Silurus glanis) allied to the cat- fishes.","pos":""}],"SHEATH":[{"def":"A case for the reception of a sword, hunting knife, or other long and slender instrument; a scabbard.","pos":"verb"},{"def":"Any sheathlike covering, organ, or part.","pos":"verb"}],"SHEATH-WINGED":[{"def":"Having elytra, or wing cases, as a beetle.","pos":""}],"SHEATHBILL":[{"def":"Either one of two species of birds composing the genus Chionis, and family Chionidæ, native of the islands of the Antarctic.","pos":""}],"SHEATHE":[{"def":"To put into a sheath, case, or scabbard; to inclose or cover with, or as with, a sheath or case.","pos":""},{"def":"To fit or furnish, as with a sheath.","pos":""}],"SHEATHED":[{"def":"Invested by a sheath, or cylindrical membranaceous tube, which is the base of the leaf, as the stalk or culm in grasses; vaginate.","pos":""}],"SHEATHER":[{"def":"One who sheathes.","pos":""}],"SHEATHFISH":[{"def":"Same as Sheatfish.","pos":""}],"SHEATHING":[{"def":"That which sheathes.","pos":""}],"SHEATHLESS":[{"def":"Without a sheath or case for covering; unsheathed.","pos":""}],"SHEATHY":[{"def":"Forming or resembling a sheath or case.","pos":""}],"SHEAVE":[{"def":"A wheel having a groove in the rim for a rope to work in, and set in a block, mast, or the like; the wheel of a pulley.","pos":""}],"SHEBANDER":[{"def":"A harbor master, or ruler of a port, in the East Indies.","pos":""}],"SHEBANG":[{"def":"A jocosely depreciative name for a dwelling or shop.","pos":""}],"SHEBEEN":[{"def":"A low public house; especially, a place where spirits and other excisable liquors are illegally and privately sold.","pos":""}],"SHECKLATON":[{"def":"A kind of gilt leather.","pos":""}],"SHED":[{"def":"A slight or temporary structure built to shade or shelter something; a structure usually open in front; an outbuilding; a hut; as, a wagon shed; a wood shed.","pos":""}],"SHEDDER":[{"def":"A crab in the act of casting its shell, or immediately afterwards while still soft; -- applied especially to the edible crabs, which are most prized while in this state.","pos":""}],"SHEDDING":[{"def":"The chaffinch; -- so named from its call note.","pos":""}],"SHEELING":[{"def":"A hut or small cottage in an expessed or a retired place (as on a mountain or at the seaside) such as is used by shepherds, fishermen, sportsmen, etc.","pos":""}],"SHEELY":[{"def":"Same as Sheelfa.","pos":""}],"SHEEN":[{"def":"Bright; glittering; radiant; fair; showy; sheeny.","pos":""}],"SHEENY":[{"def":"Bright; shining; radiant; sheen.","pos":""}],"SHEEP":[{"def":"Any one of several species of ruminants of the genus Ovis, native of the higher mountains of both hemispheres, but most numerous in Asia.","pos":""}],"SHEEP'S-EYE":[{"def":"A modest, diffident look; a loving glance; -- commonly in the plural.","pos":""}],"SHEEP'S-FOOT":[{"def":"A printer's tool consisting of a metal bar formed into a hammer head at one end and a claw at the other, -- used as a lever and hammer.","pos":""}],"SHEEP-FACED":[{"def":"Over-bashful; sheepish.","pos":""}],"SHEEP-HEADED":[{"def":"Silly; simple-minded; stupid.","pos":""}],"SHEEP-SHEARER":[{"def":"One who shears, or cuts off the wool from, sheep.","pos":""}],"SHEEP-SHEARING":[{"def":"Act of shearing sheep.","pos":""},{"def":"A feast at the time of sheep-shearing.","pos":""}],"SHEEPBACK":[{"def":"A rounded knoll of rock resembling the back of a sheep.","pos":""}],"SHEEPBERRY":[{"def":"The edible fruit of a small North American tree of the genus Viburnum (V.","pos":""}],"SHEEPBITE":[{"def":"To bite or nibble like a sheep; hence, to practice petty thefts.","pos":""}],"SHEEPBITER":[{"def":"One who practices petty thefts.","pos":""},{"def":"A small inclosure for sheep; a pen; a fold.","pos":""}],"SHEEPFOLD":[{"def":"A fold or pen for sheep; a place where sheep are collected or confined.","pos":""}],"SHEEPHOOK":[{"def":"A hook fastened to pole, by which shepherds lay hold on the legs or necks of their sheep; a shepherd's crook.","pos":""}],"SHEEPISH":[{"def":"Of or pertaining to sheep.","pos":""},{"def":"Like a sheep; bashful; over-modest; meanly or foolishly diffident; timorous to excess.","pos":""}],"SHEEPMASTER":[{"def":"A keeper or feeder of sheep; also, an owner of sheep.","pos":""}],"SHEEPSHANK":[{"def":"A hitch by which a rope may be temporarily shortened.","pos":""}],"SHEEPSHEAD":[{"def":"A large and valuable sparoid food fish (Archosargus, or Diplodus, probatocephalus) found on the Atlantic coast of the United States.","pos":""}],"SHEEPSKIN":[{"def":"The skin of a sheep; or, leather prepared from it.","pos":""},{"def":"A diploma; -- so called because usually written or printed on parchment prepared from the skin of the sheep.","pos":""}],"SHEEPSPLIT":[{"def":"A split of a sheepskin; one of the thin sections made by splitting a sheepskin with a cutting knife or machine.","pos":""}],"SHEEPY":[{"def":"Resembling sheep; sheepish.","pos":""}],"SHEER":[{"def":"Bright; clear; pure; unmixed.","pos":""},{"def":"Very thin or transparent; -- applied to fabrics; as, sheer muslin.","pos":""}],"SHEERLY":[{"def":"At once; absolutely.","pos":""}],"SHEET":[{"def":"In general, a large, broad piece of anything thin, as paper, cloth, etc.","pos":""},{"def":"The space in the forward or the after part of a boat where there are no rowers; as, fore sheets; stern sheets.","pos":""}],"SHEET ANCHOR":[{"def":"A large anchor stowed on shores outside the waist of a vessel; -- called also waist anchor.","pos":""}],"SHEET CABLE":[{"def":"The cable belonging to the sheet anchor.","pos":""}],"SHEET CHAIN":[{"def":"A chain sheet cable.","pos":""}],"SHEETFUL":[{"def":"Enough to fill a sheet; as much as a sheet can hold.","pos":""}],"SHEETING":[{"def":"A lining of planks or boards (rarely of metal) for protecting an embankment.","pos":""}],"SHEIK":[{"def":"The head of an Arab family, or of a clan or a tribe; also, the chief magistrate of an Arab village.","pos":""}],"SHEKEL":[{"def":"A jocose term for money.","pos":""}],"SHEKINAH":[{"def":"The visible majesty of the Divine Presence, especially when resting or dwelling between the cherubim on the mercy seat, in the Tabernacle, or in the Temple of Solomon; -- a term used in the Targums and by the later Jews, and adopted by Christians.","pos":""}],"SHELD":[{"def":"Variegated; spotted; speckled; piebald.","pos":""}],"SHELDFOWL":[{"def":"The common sheldrake.","pos":""}],"SHELDRAKE":[{"def":"Any one of several species of large Old World ducks of the genus Tadorna and allied genera, especially the European and Asiatic species.","pos":""}],"SHELF":[{"def":"A flat tablet or ledge of any material set horizontally at a distance from the floor, to hold objects of use or ornament.","pos":""},{"def":"A stratum lying in a very even manner; a flat, projecting layer of rock.","pos":""}],"SHELFY":[{"def":"Abounding in shelves; full of dangerous shallows.","pos":""},{"def":"Full of strata of rock.","pos":""}],"SHELL":[{"def":"The hard calcareous or chitinous external covering of mollusks, crustaceans, and some other invertebrates.","pos":""},{"def":"A hollow projectile, of various shapes, adapted for a mortar or a cannon, and containing an explosive substance, ignited with a fuse or by percussion, by means of which the projectile is burst and its fragments scattered.","pos":""}],"SHELL-LESS":[{"def":"Shell\"-less Defn: , a.","pos":""}],"SHELLBARK":[{"def":"A species of hickory (Carya alba) whose outer bark is loose and peeling; a shagbark; also, its nut.","pos":""}],"SHELLER":[{"def":"One who, or that which, shells; as, an oyster sheller; a corn sheller.","pos":""}],"SHELLFISH":[{"def":"Any aquatic animal whose external covering consists of a shell, either testaceous, as in oysters, clams, and other mollusks, or crustaceous, as in lobsters and crabs.","pos":""}],"SHELLING":[{"def":"Groats; hulled oats.","pos":""}],"SHELLPROOF":[{"def":"Capable of resisting bombs or other shells; bombproof.","pos":""}],"SHELLWORK":[{"def":"Work composed of shells, or adorned with them.","pos":""}],"SHELLY":[{"def":"Abounding with shells; consisting of shells, or of a shell.","pos":""}],"SHELTER":[{"def":"That which covers or defends from injury or annoyance; a protection; a screen.","pos":""},{"def":"One who protects; a guardian; a defender.","pos":""}],"SHELTERLESS":[{"def":"Destitute of shelter or protection.","pos":""}],"SHELTERY":[{"def":"Affording shelter.","pos":""},{"def":"A Shetland pony.","pos":""}],"SHELVE":[{"def":"To furnish with shelves; as, to shelve a closet or a library.","pos":""},{"def":"To place on a shelf.","pos":""}],"SHELVING":[{"def":"Sloping gradually; inclining; as, a shelving shore.","pos":""}],"SHELVY":[{"def":"Sloping gradually; shelving.","pos":""}],"SHEMITE":[{"def":"A descendant of Shem.","pos":""},{"def":"Of or pertaining to Shem, the son of Noah, or his descendants.","pos":""}],"SHEND":[{"def":"To injure, mar, spoil, or harm.","pos":""},{"def":"To blame, reproach, or revile; to degrade, disgrace, or put to shame.","pos":""}],"SHENDFUL":[{"def":"Destructive; ruinous; disgraceful.","pos":""}],"SHENDSHIP":[{"def":"Harm; ruin; also, reproach; disgrace.","pos":""}],"SHEOL":[{"def":"The place of departed spirits; Hades; also, the grave.","pos":""}],"SHEPEN":[{"def":"A stable; a shippen.","pos":""}],"SHEPHERD":[{"def":"A man employed in tending, feeding, and guarding sheep, esp.","pos":""},{"def":"The pastor of a church; one with the religious guidance of others.","pos":""}],"SHEPHERDESS":[{"def":"A woman who tends sheep; hence, a rural lass.","pos":""}],"SHEPHERDIA":[{"def":"A genus of shrubs having silvery scurfy leaves, and belonging to the same family as Elæagnus; also, any plant of this genus.","pos":""}],"SHEPHERDISH":[{"def":"Resembling a shepherd; suiting a shepherd; pastoral.","pos":""}],"SHEPHERDISM":[{"def":"Pastoral life or occupation.","pos":""}],"SHEPHERDLING":[{"def":"A little shepherd.","pos":""}],"SHEPHERDLY":[{"def":"Resembling, or becoming to, a shepherd; pastoral; rustic.","pos":""}],"SHERARDIZE":[{"def":"To subject to the process of vapor galvanizing (which see, below).","pos":""}],"SHERBET":[{"def":"A refreshing drink, common in the East, made of the juice of some fruit, diluted, sweetened, and flavored in various ways; as, orange sherbet; lemon sherbet; raspberry sherbet, etc.","pos":""},{"def":"A flavored water ice.","pos":""}],"SHERD":[{"def":"A fragment; -- now used only in composition, as in potsherd.","pos":""},{"def":"A member of an Arab princely family descended from Mohammed through his son-in-law Ali and daughter Fatima.","pos":""}],"SHERIAT":[{"def":"The sacred law of the Turkish empire.","pos":""}],"SHERIFF":[{"def":"The chief officer of a shire or county, to whom is intrusted the execution of the laws, the serving of judicial writs and processes, and the preservation of the peace.","pos":""},{"def":"The office or jurisdiction of sheriff.","pos":""}],"SHERRY":[{"def":"A Spanish light-colored dry wine, made in Andalusia.","pos":""}],"SHERRYVALLIES":[{"def":"Trousers or overalls of thick cloth or leather, buttoned on the outside of each leg, and generally worn to protect other trousers when riding on horseback.","pos":""}],"SHETH":[{"def":"The part of a plow which projects downward beneath the beam, for holding the share and other working parts; -- also called standard, or post.","pos":""}],"SHETLAND PONY":[{"def":"One of a small, hardy breed of horses, with long mane and tail, which originated in the Shetland Islands; a sheltie.","pos":""}]}