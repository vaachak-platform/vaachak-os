{"SIAGA":[{"def":"The ahu, or jairou.","pos":""}],"SIALOGOGUE":[{"def":"An agent which promotes the flow of saliva.","pos":""}],"SIAMANG":[{"def":"A gibbon (Hylobates syndactylus), native of Sumatra.","pos":""}],"SIAMESE":[{"def":"Of or pertaining to Siam, its native people, or their language.","pos":""}]}