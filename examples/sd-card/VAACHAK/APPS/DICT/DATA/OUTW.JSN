{"OUTWALK":[{"def":"To excel in walking; to leave behind in walking.","pos":""}],"OUTWALL":[{"def":"The exterior wall; the outside surface, or appearance.","pos":""},{"def":"From the interior part; in a direction from the interior toward the exterior; out; to the outside; beyond; off; away; as, a ship bound outward.","pos":""}],"OUTWARD":[{"def":"Formmg the superficial part; external; exterior; -- opposed to inward; as, an outward garment or layer.","pos":""},{"def":"Of or pertaining to the outer surface or to what is external; manifest; public.","pos":""}],"OUTWARDS":[{"def":"See Outward, adv.","pos":""}],"OUTWATCH":[{"def":"To exceed in watching.","pos":""}],"OUTWAY":[{"def":"A way out; exit.","pos":""}],"OUTWEAR":[{"def":"To wear out; to consume or destroy by wearing.","pos":""},{"def":"To last longer than; to outlast; as, this cloth will outwear the other.","pos":""}],"OUTWEEP":[{"def":"To exceed in weeping.","pos":""}],"OUTWEIGH":[{"def":"To exceed in weight or value.","pos":""}],"OUTWENT":[{"def":"Out*went\", Defn: imp.","pos":""}],"OUTWHORE":[{"def":"To exceed in lewdness.","pos":""}],"OUTWIN":[{"def":"To win a way out of.","pos":""}],"OUTWIND":[{"def":"To extricate by winding; to unloose.","pos":""}],"OUTWING":[{"def":"To surpass, exceed, or outstrip in flying.","pos":""}],"OUTWIT":[{"def":"To surpass in wisdom, esp.","pos":""}],"OUTWOE":[{"def":"To exceed in woe.","pos":""}],"OUTWORK":[{"def":"To exceed in working; to work more or faster than.","pos":""}],"OUTWORTH":[{"def":"To exceed in worth.","pos":""}],"OUTWREST":[{"def":"To extort; to draw from or forth by violence.","pos":""}],"OUTWRITE":[{"def":"To exceed or excel in writing.","pos":""}]}