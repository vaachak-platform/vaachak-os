{"CONCOCT":[{"def":"To digest; to convert into nourishment by the organs of nutrition.","pos":""},{"def":"To purify or refine chemically.","pos":""}],"CONCOCTER":[{"def":"One who concocts.","pos":""}],"CONCOCTION":[{"def":"Abatement of a morbid process, as a fever and return to a normal condition.","pos":""}],"CONCOCTIVE":[{"def":"Having the power of digesting or ripening; digestive.","pos":""}],"CONCOLOR":[{"def":"Of the same color; of uniform color.","pos":""}],"CONCOLOROUS":[{"def":"Of the same color throughout.","pos":""},{"def":"The doctrine of the existence of the entire body of Christ in the eucharist, under each element, so that the body and blood are both received by comunication in one kind only.","pos":""}],"CONCOMITANT":[{"def":"Accompanying; conjoined; attending.","pos":""}],"CONCOMITANTLY":[{"def":"In company with others; unitedly; concurrently.","pos":""}],"CONCORD":[{"def":"Agreement of words with one another, in gender, number, person, or case.","pos":""},{"def":"An agreement between the parties to a fine of land in reference to the manner in which it should pass, being an acknowledgment that the land in question belonged to the complainant.","pos":""}],"CONCORD BUGGY":[{"def":"A kind of buggy having a body with low sides, and side springs.","pos":""}],"CONCORDABLE":[{"def":"Capable of according; agreeing; harmonious.","pos":""}],"CONCORDANCE":[{"def":"Concord; agreement.","pos":""}],"CONCORDANT":[{"def":"Agreeing; correspondent; harmonious; consonant.","pos":""}],"CONCORDANTLY":[{"def":"In a concordant manner.","pos":""}],"CONCORDAT":[{"def":"A compact, covenant, or agreement concerning anything.","pos":""},{"def":"An agreement made between the pope and a sovereign or government for the regulation of ecclesiastical matters with which both are concerned; as, the concordat between Pope Pius VIL and Bonaparte in 1801.","pos":""}],"CONCORDIST":[{"def":"The compiler of a concordance.","pos":""}],"CONCORPORATE":[{"def":"To unite in one mass or body; to incorporate.","pos":""}],"CONCORPORATION":[{"def":"Union of things in one mass or body.","pos":""}],"CONCOURSE":[{"def":"A moving, flowing, or running together; confluence.","pos":""},{"def":"An assembly; a gathering formed by a voluntary or spontaneous moving and meeting in one place.","pos":""}]}