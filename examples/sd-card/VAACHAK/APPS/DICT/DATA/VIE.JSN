{"VIE":[{"def":"To stake a sum upon a hand of cards, as in the old game of gleek.","pos":""},{"def":"To strive for superiority; to contend; to use emulous effort, as in a race, contest, or competition.","pos":""}],"VIELLE":[{"def":"An old stringed instrument played upon with a wheel; a hurdy- gurdy.","pos":""}],"VIENNA PASTE":[{"def":"A caustic application made up of equal parts of caustic potash and quicklime; -- called also Vienna caustic.","pos":""}],"VIENNESE":[{"def":"Of or pertaining to Vienna, or people of Vienna.","pos":""},{"def":"An inhabitant, or the inhabitants, of Vienna.","pos":""}],"VIERKLEUR":[{"def":"The four-colored flag of the South African Republic, or Transvaal, -- red, white, blue, and green.","pos":""}],"VIEW":[{"def":"The act of seeing or beholding; sight; look; survey; examination by the eye; inspection.","pos":""},{"def":"Mental survey; intellectual perception or examination; as, a just view of the arguments or facts in a case.","pos":""}],"VIEWER":[{"def":"A person appointed to inspect highways, fences, or the like, and to report upon the same.","pos":""}],"VIEWINESS":[{"def":"The quality or state of being viewy, or of having unpractical views.","pos":""}],"VIEWLESS":[{"def":"Not perceivable by the eye; invisible; unseen.","pos":""},{"def":"Pleasing to the sight; sightly.","pos":""}],"VIEWY":[{"def":"Having peculiar views; fanciful; visionary; unpractical; as, a viewy person.","pos":""},{"def":"Spectacular; pleasing to the eye or the imagination.","pos":""}]}