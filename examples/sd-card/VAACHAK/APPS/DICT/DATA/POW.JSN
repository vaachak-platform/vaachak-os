{"POWDER":[{"def":"The fine particles to which any dry substance is reduced by pounding, grinding, or triturating, or into which it falls by decay; dust.","pos":""},{"def":"An explosive mixture used in gunnery, blasting, etc.","pos":""}],"POWDER-POSTED":[{"def":"Affected with dry rot; reduced to dust by rot.","pos":""}],"POWDERED":[{"def":"Reduced to a powder; sprinkled with, or as with, powder.","pos":""},{"def":"Sprinkled with salt; salted; corned.","pos":""}],"POWDERFLASK":[{"def":"A flask in which gunpowder is carried, having a charging tube at the end.","pos":""}],"POWDERHORN":[{"def":"A horn in which gunpowder is carried.","pos":""}],"POWDERING":[{"def":"Pow\"der*ing, Defn: a.","pos":""}],"POWDERMILL":[{"def":"A mill in which gunpowder is made.","pos":""}],"POWDERY":[{"def":"Easily crumbling to pieces; friable; loose; as, a powdery spar.","pos":""},{"def":"Sprinkled or covered with powder; dusty; as, the powdery bloom on plums.","pos":""}],"POWDIKE":[{"def":"A dike a marsh or fen.","pos":""}],"POWER":[{"def":"Same as Poor, the fish.","pos":""}],"POWERABLE":[{"def":"Capable of being effected or accomplished by the application of power; possible.","pos":""},{"def":"Capable of exerting power; powerful.","pos":""}],"POWERFUL":[{"def":"Large; capacious; -- said of veins of ore.","pos":""}],"POWERLESS":[{"def":"Destitute of power, force, or energy; weak; impotent; not able to produce any effect.","pos":""}],"POWLDRON":[{"def":"Same as Pauldron.","pos":""}],"POWWOW":[{"def":"A priest, or conjurer, among the North American Indians.","pos":""},{"def":"Conjuration attended with great noise and confusion, and often with feasting, dancing, etc.","pos":""}]}