{"CUSCUS":[{"def":"A soft grass (Pennisetum typhoideum) found in all tropical regions, used as food for men and cattle in Central Africa.","pos":""}],"CUSCUS OIL":[{"def":"Same as Vetiver oil.","pos":""}],"CUSHAT":[{"def":"The ringdove or wood pigeon.","pos":""}],"CUSHEWBIRD":[{"def":"The galeated curassow.","pos":""}],"CUSHION":[{"def":"A case or bag stuffed with some soft and elastic material, and used to sit or recline upon; a soft pillow or pad.","pos":""},{"def":"Anything resembling a cushion in properties or use; as: (a) a pad on which gilders cut gold leaf; (b) a mass of steam in the end of the cylinder of a steam engine to receive the impact of the piston; (c) the elastic edge of a billiard table.","pos":""}],"CUSHION TIRE":[{"def":"A thick solid-rubber tire, as for a bicycle, with a hollow groove running lengthwise on the inside.","pos":""}],"CUSHIONET":[{"def":"A little cushion.","pos":""}],"CUSHIONLESS":[{"def":"Hot furnished with a cushion.","pos":""}],"CUSHIONY":[{"def":"Like a cushion; soft; pliable.","pos":""}],"CUSHITE":[{"def":"A descendant of Cush, the son of Ham and grandson of Noah.","pos":""}],"CUSK":[{"def":"A large, edible, marine fish (Brosmius brosme), allied to the cod, common on the northern coasts of Europe and America; -- called also tusk and torsk.","pos":""}],"CUSKIN":[{"def":"A kind of drinking cup.","pos":""}],"CUSP":[{"def":"A triangular protection from the intrados of an arch, or from an inner curve of tracery.","pos":""},{"def":"The beginning or first entrance of any house in the calculations of nativities, etc.","pos":""}],"CUSPATED":[{"def":"Ending in a point.","pos":""}],"CUSPID":[{"def":"One of the canine teeth; -- so called from having but one point or cusp on the crown.","pos":""}],"CUSPIDAL":[{"def":"Ending in a point.","pos":""}],"CUSPIDATE":[{"def":"To make pointed or sharp.","pos":""},{"def":"Having a sharp end, like the point of a spear; terminating in a hard point; as, a cuspidate leaf.","pos":""}],"CUSPIDOR":[{"def":"Any ornamental vessel used as a spittoon; hence, to avoid the common term, a spittoon of any sort.","pos":""}],"CUSPIS":[{"def":"A point; a sharp end.","pos":""}],"CUSSEDNESS":[{"def":"Disposition to willful wrongdoing; malignity; perversity; cantankerousness; obstinacy.","pos":""}],"CUSTARD":[{"def":"A mixture of milk and eggs, sweetened, and baked or boiled.","pos":""}],"CUSTODIAL":[{"def":"Relating to custody or guardianship.","pos":""}],"CUSTODIAN":[{"def":"One who has care or custody, as of some public building; a keeper or superintendent.","pos":""}],"CUSTODIANSHIP":[{"def":"Office or duty of a custodian.","pos":""}],"CUSTODY":[{"def":"A keeping or guarding; care, watch, inspection, for keeping, preservation, or security.","pos":""},{"def":"Judicial or penal safe-keeping.","pos":""}],"CUSTOM":[{"def":"Long-established practice, considered as unwritten law, and resting for authority on long consent; usage.","pos":""}],"CUSTOMABLE":[{"def":"Subject to the payment of customs; dutiable.","pos":""}],"CUSTOMABLENESS":[{"def":"Quality of being customable; conformity to custom.","pos":""}],"CUSTOMARILY":[{"def":"In a customary manner; habitually.","pos":""}],"CUSTOMARINESS":[{"def":"Quality of being customary.","pos":""}],"CUSTOMARY":[{"def":"Holding or held by custom; as, customary tenants; customary service or estate.","pos":""}],"CUSTOMER":[{"def":"One who collect customs; a toll gatherer.","pos":""},{"def":"One who regularly or repeatedly makes purchases of a trader; a purchaser; a buyer.","pos":""}],"CUSTOMHOUSE":[{"def":"The building where customs and duties are paid, and where vessels are entered or cleared.","pos":""}],"CUSTOS":[{"def":"A keeper; a custodian; a superintendent.","pos":""}],"CUSTREL":[{"def":"An armor-bearer to a knight.","pos":""}],"CUSTUMARY":[{"def":"Cus\"tu*ma*ry (-t-m-r), a.","pos":""}]}