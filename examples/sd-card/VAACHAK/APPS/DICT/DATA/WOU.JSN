{"WOU-WOU":[{"def":"The agile, or silvery, gibbon; -- called also camper.","pos":""}],"WOULD":[{"def":"Commonly used as an auxiliary verb, either in the past tense or in the conditional or optative present.","pos":""}],"WOULD-BE":[{"def":"' (as, a would-be poet.","pos":""}],"WOULDING":[{"def":"Emotion of desire; inclination; velleity.","pos":""}],"WOULDINGNESS":[{"def":"Willingness; desire.","pos":""}],"WOULFE BOTTLE":[{"def":"A kind of wash bottle with two or three necks; -- so called after the inventor, Peter Woulfe, an English chemist.","pos":""}],"WOUND":[{"def":"An injury to the person by which the skin is divided, or its continuity broken; a lesion of the body, involving some solution of continuity.","pos":""}],"WOUNDABLE":[{"def":"Capable of being wounded; vulnerable.","pos":""}],"WOUNDER":[{"def":"One who, or that which, wounds.","pos":""}],"WOUNDILY":[{"def":"In a woundy manner; excessively; woundy.","pos":""}],"WOUNDLESS":[{"def":"Free from wound or hurt; exempt from being wounded; invulnerable.","pos":""}],"WOUNDWORT":[{"def":"Any one of certain plants whose soft, downy leaves have been used for dressing wounds, as the kidney vetch, and several species of the labiate genus Stachys.","pos":""}],"WOUNDY":[{"def":"Such a world of holidays, that 't a woundy hindrance to a poor man that lives by his labor.","pos":""}]}