{"SHASH":[{"def":"The scarf of a turban.","pos":""}],"SHASTA":[{"def":"A mountain peak, etc.","pos":""}],"SHASTA DAISY":[{"def":"A large-flowered garden variety of the oxeye daisy.","pos":""}],"SHASTA FIR":[{"def":"A Californian fir (Abies shastensis).","pos":""}],"SHASTA SAM":[{"def":"A game like California Jack, except that the pack drawn from is turned face down.","pos":""},{"def":"A treatise for authoritative instruction among the Hindoos; a book of institutes; especially, a treatise explaining the Vedas.","pos":""}]}