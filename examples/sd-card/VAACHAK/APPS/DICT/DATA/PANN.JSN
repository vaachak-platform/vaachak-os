{"PANNADE":[{"def":"The curvet of a horse.","pos":""}],"PANNE":[{"def":"A fabric resembling velvet, but having the nap flat and less close.","pos":""}],"PANNEL":[{"def":"The stomach of a hawk.","pos":""},{"def":"A carriage for conveying a mortar and its bed, on a march.","pos":""}],"PANNIER":[{"def":"A shield of basket work formerly used by archers as a shelter from the enemy's missiles.","pos":""}],"PANNIERED":[{"def":"Bearing panniers.","pos":""}],"PANNIKEL":[{"def":"The brainpan, or skull; hence, the crest.","pos":""}],"PANNIKIN":[{"def":"A small pan or cup.","pos":""}],"PANNOSE":[{"def":"Similar in texture or appearance to felt or woolen cloth.","pos":""}],"PANNUS":[{"def":"A very vascular superficial opacity of the cornea, usually caused by granulation of the eyelids.","pos":""}]}