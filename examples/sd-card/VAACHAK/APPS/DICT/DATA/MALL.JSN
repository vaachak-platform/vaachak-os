{"MALL":[{"def":"A large heavy wooden beetle; a mallet for driving anything with force; a maul.","pos":""}],"MALLARD":[{"def":"A drake; the male of Anas boschas.","pos":""},{"def":"A large wild duck (Anas boschas) inhabiting both America and Europe.","pos":""}],"MALLEABILITY":[{"def":"The quality or state of being malleable; -- opposed to friability and brittleness.","pos":""}],"MALLEABLE":[{"def":"Capable of being extended or shaped by beating with a hammer, or by the pressure of rollers; -- applied to metals.","pos":""}],"MALLEABLEIZE":[{"def":"To make malleable.","pos":""}],"MALLEABLENESS":[{"def":"Quality of being malleable.","pos":""}],"MALLEAL":[{"def":"Pertaining to the malleus.","pos":""}],"MALLEATE":[{"def":"To hammer; to beat into a plate or leaf.","pos":""}],"MALLEATION":[{"def":"The act or process of beating into a plate, sheet, or leaf, as a metal; extension by beating.","pos":""}],"MALLECHO":[{"def":"Same as Malicho.","pos":""}],"MALLEE BIRD":[{"def":"MALLEMOCK; MALLEMOKE Mal\"le*mock, Mal\"le*moke, n.","pos":""}],"MALLENDERS":[{"def":"Same as Malanders.","pos":""}],"MALLEOLAR":[{"def":"Of or pertaining to the malleolus; in the region of the malleoli of the ankle joint.","pos":""}],"MALLEOLUS":[{"def":"A projection at the distal end of each bone of the leg at the ankle joint.","pos":""}],"MALLET":[{"def":"A small maul with a short handle, -- used esp.","pos":""}],"MALLEUS":[{"def":"The outermost of the three small auditory bones, ossicles; the hammer.","pos":""},{"def":"One of the hard lateral pieces of the mastax of Rotifera.","pos":""}],"MALLOPHAGA":[{"def":"An extensive group of insects which are parasitic on birds and mammals, and feed on the feathers and hair; -- called also bird lice.","pos":""}],"MALLOTUS":[{"def":"A genus of small Arctic fishes.","pos":""},{"def":"A genus of plants (Malva) having mucilaginous qualities.","pos":""}],"MALLOWWORT":[{"def":"Any plant of the order Malvaceæ.","pos":""},{"def":"A kind of brick of a light brown or yellowish color, made of sand, clay, and chalk.","pos":""}]}