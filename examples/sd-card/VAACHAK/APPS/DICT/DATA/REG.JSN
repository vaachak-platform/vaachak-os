{"REGAIN":[{"def":"To gain anew; to get again; to recover, as what has escaped or been lost; to reach again.","pos":""}],"REGAL":[{"def":"Of or pertaining to a king; kingly; royal; as, regal authority, pomp, or sway.","pos":""}],"REGALE":[{"def":"A prerogative of royalty.","pos":""}],"REGALEMENT":[{"def":"The act of regaling; anything which regales; refreshment; entertainment.","pos":""}],"REGALER":[{"def":"One who regales.","pos":""}],"REGALIA":[{"def":"That which belongs to royalty.","pos":""},{"def":"Hence, decorations or insignia of an office or order, as of Freemasons, Odd Fellows,etc.","pos":""}],"REGALIAN":[{"def":"Pertaining to regalia; pertaining to the royal insignia or prerogatives.","pos":""}],"REGALISM":[{"def":"The doctrine of royal prerogative or supremacy.","pos":""}],"REGALITY":[{"def":"Royalty; ssovereignty; sovereign jurisdiction.","pos":""},{"def":"An ensign or badge of royalty.","pos":""}],"REGALLY":[{"def":"In a regal or royal manner.","pos":""}],"REGARD":[{"def":"To keep in view; to behold; to look at; to view; to gaze upon.","pos":""},{"def":"Hence, to look or front toward; to face.","pos":""}],"REGARDABLE":[{"def":"Worthy of regard or notice; to be regarded; observable.","pos":""}],"REGARDANT":[{"def":"Looking behind or backward; as, a lion regardant.","pos":""},{"def":"Annexed to the land or manor; as, a villain regardant.","pos":""}],"REGARDER":[{"def":"An officer appointed to supervise the forest.","pos":""}],"REGARDFUL":[{"def":"Heedful; attentive; observant.","pos":""}],"REGARDING":[{"def":"Concerning; respecting.","pos":""}],"REGARDLESS":[{"def":"Having no regard; heedless; careless; as, regardless of life, consequences, dignity.","pos":""},{"def":"Not regarded; slighted.","pos":""}],"REGATHER":[{"def":"To gather again.","pos":""}],"REGATTA":[{"def":"Originally, a gondola race in Venice; now, a rowing or sailing race, or a series of such races.","pos":""}],"REGELATE":[{"def":"To freeze together again; to undergo regelation, as ice.","pos":""}],"REGELATION":[{"def":"The act or process of freezing anew, or together,as two pieces of ice.","pos":""}],"REGENCY":[{"def":"The office of ruler; rule; authority; government.","pos":""},{"def":"Especially, the office, jurisdiction, or dominion of a regent or vicarious ruler, or of a body of regents; deputed or vicarious government.","pos":""}],"REGENERACY":[{"def":"The state of being regenerated.","pos":""}],"REGENERATE":[{"def":"Born anew; become Christian; renovated in heart; changed from a natural to a spiritual state.","pos":""}],"REGENERATENESS":[{"def":"The quality or state of being rgenerate.","pos":""}],"REGENERATION":[{"def":"The entering into a new spiritual life; the act of becoming, or of being made, Christian; that change by which holy affectations and purposes are substituted for the opposite motives in the heart.","pos":""},{"def":"The reproduction of a part which has been removed or destroyed; re-formation; -- a process especially characteristic of a many of the lower animals; as, the regeneration of lost feelers, limbs, and claws by spiders and crabs.","pos":""}],"REGENERATIVE":[{"def":"Of or pertaining to regeneration; tending to regenerate; as, regenerative influences.","pos":""}],"REGENERATIVELY":[{"def":"So as to regenerate.","pos":""}],"REGENERATOR":[{"def":"A device used in connection with hot-air engines, gas-burning furnaces, etc.","pos":""}],"REGENERATORY":[{"def":"Having power to renew; tending to reproduce; regenerating.","pos":""}],"REGENESIS":[{"def":"New birth; renewal.","pos":""}],"REGENT":[{"def":"Ruling; governing; regnant.","pos":""},{"def":"Exercising vicarious authority.","pos":""}],"REGENT DIAMOND":[{"def":"A famous diamond of fine quality, which weighs about 137 carats and is among the state jewels of France.","pos":""}],"REGENTESS":[{"def":"A female regent.","pos":""}],"REGENTSHIP":[{"def":"The office of a regent; regency.","pos":""}],"REGERMINATE":[{"def":"To germinate again.","pos":""}],"REGERMINATION":[{"def":"A germinating again or anew.","pos":""}],"REGIAN":[{"def":"An upholder of kingly authority; a royalist.","pos":""}],"REGIBLE":[{"def":"Governable; tractable.","pos":""}],"REGICIDAL":[{"def":"Pertaining to regicide, or to one committing it; having the nature of, or resembling, regicide.","pos":""}],"REGICIDE":[{"def":"One who kills or who murders a king; specifically (Eng.","pos":""},{"def":"The killing or the murder of a king.","pos":""}],"REGIDOR":[{"def":"One of a body of officers charged with the government of Spanish municipalities, corresponding to the English alderman.","pos":""}],"REGIE":[{"def":"Direct management of public finance or public works by agents of the government for government account; -- opposed to the contract system.","pos":""}],"REGIME":[{"def":"The condition of a river with respect to the rate of its flow, as measured by the volume of water passing different cross sections in a given time, uniform régime being the condition when the flow is equal and uniform at all the cross sections.","pos":""}],"REGIMEN":[{"def":"a systematic course of diet, etc.","pos":""}],"REGIMENT":[{"def":"A body of men, either horse, foot, or artillery, commanded by a colonel, and consisting of a number of companies, usually ten.","pos":""}],"REGIMENTAL":[{"def":"Belonging to, or concerning, a regiment; as, regimental officers, clothing.","pos":""}],"REGIMENTALLY":[{"def":"In or by a regiment or regiments; as, troops classified regimentally.","pos":""}],"REGIMENTALS":[{"def":"The uniform worn by the officers and soldiers of a regiment; military dress; -- formerly used in the singular in the same sense.","pos":""}],"REGIMINAL":[{"def":"Of or relating to regimen; as, regiminal rules.","pos":""}],"REGION":[{"def":"One of the grand districts or quarters into which any space or surface, as of the earth or the heavens, is conceived of as divided; hence, in general, a portion of space or territory of indefinite extent; country; province; district; tract.","pos":""},{"def":"Tract, part, or space, lying about and including anything; neighborhood; vicinity; sphere.","pos":""}],"REGIONAL":[{"def":"Of or pertaining to a particular region; sectional.","pos":""}],"REGISTER":[{"def":"One who registers or records; a registrar; a recorder; especially, a public officer charged with the duty of recording certain transactions or events; as, a register of deeds.","pos":""}],"REGISTERING":[{"def":"Recording; -- applied to instruments; having an apparatus which registers; as, a registering thermometer.","pos":""}],"REGISTERSHIP":[{"def":"The office of a register.","pos":""}],"REGISTRANT":[{"def":"One who registers; esp.","pos":""}],"REGISTRAR":[{"def":"One who registers; a recorder; a keeper of records; as, a registrar of births, deaths, and marriages.","pos":""}],"REGISTRARSHIP":[{"def":"The office of a registrar.","pos":""}],"REGISTRARY":[{"def":"Reg\"is*tra*ry (- tr*r), n.","pos":""}],"REGISTRATE":[{"def":"Reg\"is*trate (-trt), v.","pos":""}],"REGISTRATION":[{"def":"The art of selecting and combining the stops or registers of an organ.","pos":""}],"REGISTRY":[{"def":"The act of recording or writing in a register; enrollment; registration.","pos":""},{"def":"The place where a register is kept.","pos":""}],"REGIUS":[{"def":"Of or pertaining to a king; royal.","pos":""}],"REGIVE":[{"def":"To give again; to give back.","pos":""}],"REGLE":[{"def":"To rule; to govern.","pos":""}],"REGLEMENT":[{"def":"Re\"gle*ment (rg\"'l*ment), n.","pos":""}],"REGLEMENTARY":[{"def":"Reg`le*men\"ta*ry (-l*mn\"t*r), a.","pos":""}],"REGLET":[{"def":"A flat, narrow molding, used chiefly to separate the parts or members of compartments or panels from one another, or doubled, turned, and interlaced so as to form knots, frets, or other ornaments.","pos":""},{"def":"A strip of wood or metal of the height of a quadrat, used for regulating the space between pages in a chase, and also for spacing out title-pages and other open matter.","pos":""}],"REGMA":[{"def":"A kind of dry fruit, consisting of three or more cells, each which at length breaks open at the inner angle.","pos":""}],"REGMACARP":[{"def":"Any dry dehiscent fruit.","pos":""}],"REGNAL":[{"def":"Of or pertaining to the reign of a monarch; as, regnal years.","pos":""}],"REGNANCY":[{"def":"The condition or quality of being regnant; sovereignty; rule.","pos":""}],"REGNANT":[{"def":"Exercising regal authority; reigning; as, a queen regnant.","pos":""},{"def":"Having the chief power; ruling; predominant; prevalent.","pos":""}],"REGNATIVE":[{"def":"Ruling; governing.","pos":""}],"REGORGE":[{"def":"To vomit up; to eject from the stomach; to throw back.","pos":""},{"def":"To swallow again; to swallow back.","pos":""}],"REGRADE":[{"def":"To retire; to go back.","pos":""}],"REGRAFT":[{"def":"Re*graft\" (r*grft\"), v.","pos":""}],"REGRANT":[{"def":"To grant back; to grant again or anew.","pos":""}],"REGRATE":[{"def":"To remove the outer surface of, as of an old hewn stone, so as to give it a fresh appearance.","pos":""}],"REGRATER":[{"def":"One who regrates.","pos":""}],"REGRATERY":[{"def":"The act or practice of regrating.","pos":""}],"REGRATIATORY":[{"def":"A returning or giving of thanks.","pos":""}],"REGRATOR":[{"def":"One guilty of regrating.","pos":""}],"REGREDE":[{"def":"To go back; to retrograde, as the apsis of a planet's orbit.","pos":""}],"REGREDIENCE":[{"def":"A going back; a retrogression; a return.","pos":""}],"REGREET":[{"def":"To greet again; to resalute; to return a salutation to; to greet.","pos":""}],"REGRESS":[{"def":"The act of passing back; passage back; return; retrogression.","pos":""},{"def":"The power or liberty of passing back.","pos":""}],"REGRESSION":[{"def":"The act of passing back or returning; retrogression; retrogradation.","pos":""}],"REGRESSIVE":[{"def":"Passing back; returning.","pos":""},{"def":"Characterized by retrogression; retrogressive.","pos":""}],"REGRESSIVELY":[{"def":"In a regressive manner.","pos":""}],"REGRET":[{"def":"Pain of mind on account of something done or experienced in the past, with a wish that it had been different; a looking back with dissatisfaction or with longing; grief; sorrow; especially, a mourning on account of the loss of some joy, advantage, or satisfaction.","pos":""},{"def":"Dislike; aversion.","pos":""}],"REGRETFUL":[{"def":"Full of regret; indulging in regrets; repining.","pos":""}],"REGROW":[{"def":"The snail had power to regrow them all [horns, tongue, etc.","pos":""}],"REGROWTH":[{"def":"The act of regrowing; a second or new growth.","pos":""}],"REGUARDANT":[{"def":"Same as Regardant.","pos":""}],"REGUERDON":[{"def":"Re*guer\"don (r*gr\"dn), v.","pos":""}],"REGULABLE":[{"def":"Capable of being regulated.","pos":""}],"REGULAR":[{"def":"Having all the parts of the same kind alike in size and shape; as, a regular flower; a regular sea urchin.","pos":""},{"def":"Same as Isometric.","pos":""}],"REGULARIA":[{"def":"A division of Echini which includes the circular, or regular, sea urchins.","pos":"noun"}],"REGULARITY":[{"def":"The condition or quality of being regular; as, regularity of outline; the regularity of motion.","pos":""}],"REGULARIZE":[{"def":"To cause to become regular; to regulate.","pos":""}],"REGULARLY":[{"def":"In a regular manner; in uniform order; methodically; in due order or time.","pos":""}],"REGULATE":[{"def":"To adjust by rule, method, or established mode; to direct by rule or restriction; to subject to governing principles or laws.","pos":""},{"def":"To put in good order; as, to regulate the disordered state of a nation or its finances.","pos":""}],"REGULATION":[{"def":"The act of regulating, or the state of being regulated.","pos":""},{"def":"A rule or order prescribed for management or government; prescription; a regulating principle; a governing direction; precept; law; as, the regulations of a society or a school.","pos":""}],"REGULATIVE":[{"def":"Necessarily assumed by the mind as fundamental to all other knowledge; furnishing fundamental principles; as, the regulative principles, or principles a priori; the regulative faculty.","pos":""}],"REGULATOR":[{"def":"A contrivance for regulating and controlling motion, as: (a) The lever or index in a watch, which controls the effective length of the hairspring, and thus regulates the vibrations of the balance.","pos":""}],"REGULINE":[{"def":"Of or pertaining to regulus.","pos":""}],"REGULIZE":[{"def":"To reduce to regulus; to separate, as a metal from extraneous matter; as, to regulize antimony.","pos":""}],"REGULUS":[{"def":"The button, globule, or mass of metal, in a more or less impure state, which forms in the bottom of the crucible in smelting and reduction of ores.","pos":""},{"def":"A star of the first magnitude in the constellation Leo; -- called also the Lion's Heart.","pos":""}],"REGURGITATE":[{"def":"To throw or pour back, as from a deep or hollow place; to pour or throw back in great quantity.","pos":""}],"REGURGITATION":[{"def":"the reversal of the natural direction in which the current or contents flow through a tube or cavity of the body.","pos":""}]}