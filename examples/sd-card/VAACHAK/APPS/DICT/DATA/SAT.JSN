{"SATAN":[{"def":"The grand adversary of man; The Devil, or Prince of darkness; the chief of the fallen angels; the archfiend.","pos":""},{"def":"Of or pertaining to Satan; having the qualities of Satan; resembling Satan; extremely malicious or wicked; devilish; infernal.","pos":""}],"SATANISM":[{"def":"The evil and malicious disposition of Satan; a diabolical sprit.","pos":""}],"SATANIST":[{"def":"A very wicked-person.","pos":""}],"SATANOPHANY":[{"def":"An incarnation of Satan; a being possessed by a demon.","pos":""}],"SATCHEL":[{"def":"A little sack or bag for carrying papers, books, or small articles of wearing apparel; a hand bag.","pos":""}],"SATE":[{"def":"To satisfy the desire or appetite of; to satiate; to glut; to surfeit.","pos":""}],"SATEEN":[{"def":"A kind of dress goods made of cotton or woolen, with a glossy surface resembling satin.","pos":""}],"SATELLITE":[{"def":"A secondary planet which revolves about another planet; as, the moon is a satellite of the earth.","pos":""}],"SATELLITIOUS":[{"def":"Pertaining to, or consisting of, satellites.","pos":""}],"SATIATE":[{"def":"Filled to satiety; glutted; sated; -- followed by with or of.","pos":""}],"SATIETY":[{"def":"The state of being satiated or glutted; fullness of gratification, either of the appetite or of any sensual desire; fullness beyond desire; an excess of gratification which excites wearisomeness or loathing; repletion; satiation.","pos":""}],"SATIN":[{"def":"A silk cloth, of a thick, close texture, and overshot woof, which has a glossy surface.","pos":""}],"SATIN WEAVE":[{"def":"A style of weaving producing smooth-faced fabric in which the warp interlaces with the filling at points distributed over the surface.","pos":""}],"SATINET":[{"def":"A thin kind of satin.","pos":""},{"def":"A kind of cloth made of cotton warp and woolen filling, used chiefly for trousers.","pos":""}],"SATINETTE":[{"def":"One of a breed of fancy frilled pigeons allied to the owls and turbits, having the body white, the shoulders tricolored, and the tail bluish black with a large white spot on each feather.","pos":""}],"SATINWOOD":[{"def":"The hard, lemon-colored, fragrant wood of an East Indian tree (Chloroxylon Swietnia).","pos":""}],"SATINY":[{"def":"Like or composed of satin; glossy; as, to have a satiny appearance; a satiny texture.","pos":""}],"SATION":[{"def":"A sowing or planting.","pos":""}],"SATIRE":[{"def":"A composition, generally poetical, holding up vice or folly to reprobation; a keen or severe exposure of what in public or private morals deserves rebuke; an invective poem; as, the Satires of Juvenal.","pos":""},{"def":"Keeness and severity of remark; caustic exposure to reprobation; trenchant wit; sarcasm.","pos":""}],"SATIRIST":[{"def":"One who satirizes; especially, one who writes satire.","pos":""}],"SATIRIZE":[{"def":"To make the object of satire; to attack with satire; to censure with keenness or severe sarcasm.","pos":""}],"SATISFACTION":[{"def":"The act of satisfying, or the state of being satisfied; gratification of desire; contentment in possession and enjoyment; repose of mind resulting from compliance with its desires or demands.","pos":""},{"def":"Settlement of a claim, due, or demand; payment; indemnification; adequate compensation.","pos":""}],"SATISFACTIVE":[{"def":"Satisfactive discernment of fish.","pos":""}],"SATISFACTORY":[{"def":"Giving or producing satisfaction; yielding content; especially, relieving the mind from doubt or uncertainty, and enabling it to rest with confidence; sufficient; as, a satisfactory account or explanation.","pos":""},{"def":"Making amends, indemnification, or recompense; causing to cease from claims and to rest content; compensating; atoning; as, to make satisfactory compensation, or a satisfactory apology.","pos":""}],"SATISFIABLE":[{"def":"That may be satisfied.","pos":""}],"SATISFIER":[{"def":"One who satisfies.","pos":""}],"SATISFY":[{"def":"In general, to fill up the measure of a want of (a person or a thing); hence, to grafity fully the desire of; to make content; to supply to the full, or so far as to give contentment with what is wished for.","pos":""},{"def":"To pay to the extent of chaims or deserts; to give what is due to; as, to satisfy a creditor.","pos":""}],"SATISFYINGLY":[{"def":"So as to satisfy; satisfactorily.","pos":""}],"SATIVE":[{"def":"Sown; propagated by seed.","pos":""}],"SATRAP":[{"def":"The governor of a province in ancient Persia; hence, a petty autocrat despot.","pos":""}],"SATRAPAL":[{"def":"Of or pertaining to a satrap, or a satrapy.","pos":""}],"SATRAPESS":[{"def":"A female satrap.","pos":""}],"SATRAPY":[{"def":"The government or jurisdiction of a satrap; a principality.","pos":""}],"SATSUMA WARE":[{"def":"A kind of ornamental hard-glazed pottery made at Satsuma in Kiushu, one of the Japanese islands.","pos":""}],"SATURABLE":[{"def":"Capable of being saturated; admitting of saturation.","pos":""}],"SATURANT":[{"def":"Impregnating to the full; saturating.","pos":""}],"SATURATE":[{"def":"To satisfy the affinity of; to cause to become inert by chemical combination with all that it can hold; as, to saturate phosphorus with chlorine.","pos":""}],"SATURATED":[{"def":"Having its affinity satisfied; combined with all it can hold; - - said of certain atoms, radicals, or compounds; thus, methane is a saturated compound.","pos":""}],"SATURATION":[{"def":"The act, process, or result of saturating a substance, or of combining it to its fullest extent.","pos":""},{"def":"Freedom from mixture or dilution with white; purity; -- said of colors.","pos":""}],"SATURATOR":[{"def":"One who, or that which, saturates.","pos":""}],"SATURDAY":[{"def":"The seventh or last day of the week; the day following Friday and preceding Sunday.","pos":""}],"SATURITY":[{"def":"The state of being saturated; fullness of supply.","pos":""}],"SATURN":[{"def":"One of the elder and principal deities, the son of Coelus and Terra (Heaven and Earth), anf the father of Jupiter.","pos":""},{"def":"One of the planets of the solar system, next in magnitude to Jupiter, but more remote from the sun.","pos":""}],"SATURNALIA":[{"def":"the festival of Saturn, celebrated in December, originally during one day, but afterward during seven days, as a period of unrestrained license and merriment for all classes, extending even to the slaves.","pos":""}],"SATURNALIAN":[{"def":"Of or pertaining to the Saturnalia.","pos":""},{"def":"Of unrestrained and intemperate jollity; riotously merry; dissolute.","pos":""}],"SATURNIAN":[{"def":"Of or pertaining to Saturn, whose age or reign, from the mildness and wisdom of his government, is called the golden age.","pos":""},{"def":"Of or pertaining to the planet Saturn; as, the Saturnian year.","pos":""}],"SATURNICENTRIC":[{"def":"Appearing as if seen from the center of the planet Saturn; relating or referred to Saturn as a center.","pos":""}],"SATURNINE":[{"def":"Of or pertaining to lead; characterized by, or resembling, lead, which was formerly called Saturn.","pos":""}],"SATURNIST":[{"def":"A person of a dull, grave, gloomy temperament.","pos":""}],"SATYR":[{"def":"A sylvan deity or demigod, represented as part man and part goat, and characterized by riotous merriment and lasciviousness.","pos":""},{"def":"Any one of many species of butterflies belonging to the family Nymphalidæ.","pos":""}],"SATYRIASIS":[{"def":"Immoderate venereal appetite in the male.","pos":""},{"def":"Of or pertaining to satyrs; burlesque; as, satyric tragedy.","pos":""}],"SATYRION":[{"def":"Any one of several kinds of orchids.","pos":""}]}