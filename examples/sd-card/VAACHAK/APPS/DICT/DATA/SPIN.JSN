{"SPIN":[{"def":"To shape, as malleable sheet metal, into a hollow form, by bending or buckling it by pressing against it with a smooth hand tool or roller while the metal revolves, as in a lathe.","pos":""}],"SPINA BIFIDA":[{"def":"A congenital malformation in which the spinal column is cleft at its lower portion, and the membranes of the spinal cord project as an elastic swelling from the gap thus formed.","pos":""}],"SPINACEOUS":[{"def":"Of, pertaining to, or resembling, the plant spinach, or the family of plants to which it belongs.","pos":""},{"def":"A common pot herb (Spinacia oleracea) belonging to the Goosefoot family.","pos":""}],"SPINAL":[{"def":"Of, pertaining to, or in the region of, the backbone, or vertebral column; rachidian; vertebral.","pos":""}],"SPINATE":[{"def":"Bearing a spine; spiniform.","pos":""}],"SPINDLE":[{"def":"The shaft, mandrel, or arbor, in a machine tool, as a lathe or drilling machine, etc.","pos":""},{"def":"A solid generated by the revolution of a curved line about its base or double ordinate or chord.","pos":""}],"SPINDLE-LEGGED":[{"def":"Having long, slender legs.","pos":""}],"SPINDLE-SHANKED":[{"def":"Having long, slender legs.","pos":""}],"SPINDLE-SHAPED":[{"def":"Thickest in the middle, and tapering to both ends; fusiform; -- applied chiefly to roots.","pos":""}],"SPINDLESHANKS":[{"def":"A person with slender shanks, or legs; -- used humorously or in contempt.","pos":""}],"SPINDLETAIL":[{"def":"The pintail duck.","pos":""}],"SPINDLEWORM":[{"def":"The larva of a noctuid mmoth (Achatodes zeæ) which feeds inside the stalks of corn (maize), sometimes causing much damage.","pos":""}],"SPINDLING":[{"def":"Long and slender, or disproportionately tall and slender; as, a spindling tree; a spindling boy.","pos":""}],"SPINDRIFT":[{"def":"Same as Spoondrift.","pos":""}],"SPINE":[{"def":"A sharp appendage to any of a plant; a thorn.","pos":""},{"def":"The backbone, or spinal column, of an animal; -- so called from the projecting processes upon the vertebræ.","pos":""}],"SPINE-FINNED":[{"def":"Having fine supported by spinous fin rays; -- said of certain fishes.","pos":""},{"def":"A mineral occuring in octahedrons of great hardness and various colors, as red, green, blue, brown, and black, the red variety being the gem spinel ruby.","pos":""}],"SPINE-TAILED":[{"def":"Having the tail quills ending in sharp, naked tips.","pos":""}],"SPINEBACK":[{"def":"A fish having spines in, or in front of, the dorsal fins.","pos":""}],"SPINEBILL":[{"def":"Any species of Australian birds of the genus Acanthorhynchus.","pos":""}],"SPINED":[{"def":"Furnished with spines; spiny.","pos":""}],"SPINEL":[{"def":"Bleached yarn in making the linen tape called inkle; unwrought inkle.","pos":""}],"SPINELESS":[{"def":"Having no spine.","pos":""}],"SPINESCENCE":[{"def":"The state or quality of being spinescent or spiny; also, a spiny growth or covering, as of certain animals.","pos":""}],"SPINESCENT":[{"def":"Becoming hard and thorny; tapering gradually to a rigid, leafless point; armed with spines.","pos":""}],"SPINET":[{"def":"A keyed instrument of music resembling a harpsichord, but smaller, with one string of brass or steel wire to each note, sounded by means of leather or quill plectrums or jacks.","pos":""}],"SPINETAIL":[{"def":"Chætura, and allied genera, in which the shafts of the tail feathers terminate in rigid spines.","pos":""}],"SPINI-SPIRULATE":[{"def":"Having spines arranged spirally.","pos":""}],"SPINIFEROUS":[{"def":"Producing spines; bearing thorns or spines; thorny; spiny.","pos":""}],"SPINIFEX":[{"def":"Any of several Australian grasses of the genus Tricuspis, which often form dense, almost impassable growth, their leaves being stiff and sharp-pointed.","pos":""}],"SPINIFORM":[{"def":"Shaped like a spine.","pos":""}],"SPINIGEROUS":[{"def":"Bearing a spine or spines; thorn-bearing.","pos":""}],"SPININESS":[{"def":"Quality of being spiny.","pos":""}],"SPINNAKER":[{"def":"A large triangular sail set upon a boom, -- used when running before the wind.","pos":""}],"SPINNER":[{"def":"A goatsucker; -- so called from the peculiar noise it makes when darting through the air.","pos":""}],"SPINNERET":[{"def":"One of the special jointed organs situated on the under side, and near the end, of the abdomen of spiders, by means of which they spin their webs.","pos":""}],"SPINNERULE":[{"def":"One of the numerous small spinning tubes on the spinnerets of spiders.","pos":""}],"SPINNY":[{"def":"A small thicket or grove with undergrowth; a clump of trees.","pos":""}],"SPINOSE":[{"def":"Full of spines; armed with thorns; thorny.","pos":""}],"SPINOSITY":[{"def":"The quality or state of being spiny or thorny; spininess.","pos":""}],"SPINOUS":[{"def":"Spinose; thorny.","pos":""},{"def":"Having the form of a spine or thorn; spinelike.","pos":""}],"SPINOZISM":[{"def":"The form of Pantheism taught by Benedict Spinoza, that there is but one substance, or infinite essence, in the universe, of which the so-called material and spiritual beings and phenomena are only modes, and that one this one substance is God.","pos":""}],"SPINOZIST":[{"def":"A believer in Spinozism.","pos":""}],"SPINSTER":[{"def":"An unmarried or single woman; -- used in legal proceedings as a title, or addition to the surname.","pos":""}],"SPINSTRESS":[{"def":"A woman who spins.","pos":""}],"SPINSTRY":[{"def":"The business of one who spins; spinning.","pos":""}],"SPINTHARISCOPE":[{"def":"A small instrument containing a minute particle of a radium compound mounted in front of a fluorescent screen and viewed with magnifying lenses.","pos":""}],"SPINULESCENT":[{"def":"Having small spines; somewhat thorny.","pos":""},{"def":"Covered with small spines.","pos":""}],"SPINY":[{"def":"Full of spines; thorny; as, a spiny tree.","pos":""},{"def":"Like a spine in shape; slender.","pos":""}]}