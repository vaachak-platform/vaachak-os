{"SOU":[{"def":"An old French copper coin, equivalent in value to, and now displaced by, the five-centime piece (sou.","pos":""}],"SOUARI NUT":[{"def":"The large edible nutlike seed of a tall tropical American tree (Caryocar nuciferum) of the same natural order with the tea plant; -- also called butternut.","pos":""}],"SOUBISE":[{"def":"A kind of cravat worn by men in the late 18th century.","pos":""}],"SOUBRETTE":[{"def":"A female servant or attendant; specifically, as a term of the theater, a lady's maid, in comedies, who acts the part of an intrigante; a meddlesome, mischievous female servant or young woman.","pos":""}],"SOUCHONG":[{"def":"A kind of black tea of a fine quality.","pos":""}],"SOUDAN":[{"def":"United; consolidated; made firm; strengthened.","pos":"noun"}],"SOUFFLE":[{"def":"A murmuring or blowing sound; as, the uterine souffle heard over the pregnant uterus.","pos":""}],"SOUFFLEE":[{"def":"Filled with air by beating, and baked; as, an omelette soufflé.","pos":""}],"SOUGH":[{"def":"A small drain; an adit.","pos":""}],"SOUL":[{"def":"To afford suitable sustenance.","pos":""}],"SOULED":[{"def":"Furnished with a soul; possessing soul and feeling; -- used chiefly in composition; as, great-souled Hector.","pos":""}],"SOULILI":[{"def":"A long-tailed, crested Javan monkey (Semnopithecus mitratus).","pos":""}],"SOULLESS":[{"def":"Being without a soul, or without greatness or nobleness of mind; mean; spiritless.","pos":""}],"SOULLESSLY":[{"def":"In a soulless manner.","pos":""}],"SOUND":[{"def":"The air bladder of a fish; as, cod sounds are an esteemed article of food.","pos":""}],"SOUND-BOARD":[{"def":"A sounding-board.","pos":""}],"SOUNDABLE":[{"def":"Capable of being sounded.","pos":""}],"SOUNDAGE":[{"def":"Dues for soundings.","pos":""}],"SOUNDER":[{"def":"One who, or that which; sounds; specifically, an instrument used in telegraphy in place of a register, the communications being read by sound.","pos":""}],"SOUNDING":[{"def":"Making or emitting sound; hence, sonorous; as, sounding words.","pos":""}],"SOUNDING BALLOON":[{"def":"An unmanned balloon sent aloft for meteorological or aëronautic purposes.","pos":""}],"SOUNDING-BOARD":[{"def":"A thin board which propagates the sound in a piano, in a violin, and in some other musical instruments.","pos":""},{"def":"See Sound boarding, under Sound, a noise.","pos":""}],"SOUNDLESS":[{"def":"Not capable of being sounded or fathomed; unfathomable.","pos":""}],"SOUNDLY":[{"def":"In a sound manner.","pos":""}],"SOUNDNESS":[{"def":"The quality or state of being sound; as, the soundness of timber, of fruit, of the teeth, etc.","pos":""}],"SOUP":[{"def":"A liquid food of many kinds, usually made by boiling meat and vegetables, or either of them, in water, -- commonly seasoned or flavored; strong broth.","pos":""}],"SOUPCON":[{"def":"A suspicion; a suggestion; hence, a very small portion; a taste; as, coffee with a soupçon of brandy; a soupçon of coquetry.","pos":""}],"SOUPE-MAIGRE":[{"def":"Soup made chiefly from vegetables or fish with a little butter and a few condiments.","pos":""}],"SOUPLE":[{"def":"That part of a flail which strikes the grain.","pos":""}],"SOUPY":[{"def":"Resembling soup; souplike.","pos":""}],"SOUR":[{"def":"Having an acid or sharp, biting taste, like vinegar, and the juices of most unripe fruits; acid; tart.","pos":""},{"def":"Changed, as by keeping, so as to be acid, rancid, or musty, turned.","pos":""}],"SOURCE":[{"def":"The act of rising; a rise; an ascent.","pos":""},{"def":"The rising from the ground, or beginning, of a stream of water or the like; a spring; a fountain.","pos":""}],"SOURDE":[{"def":"To have origin or source; to rise; to spring.","pos":""}],"SOURISH":[{"def":"Somewhat sour; moderately acid; as, sourish fruit; a sourish taste.","pos":""}],"SOURKROUT":[{"def":"Same as Sauerkraut.","pos":""}],"SOURLY":[{"def":"In a sour manner; with sourness.","pos":""}],"SOURNESS":[{"def":"The quality or state of being sour.","pos":""}],"SOURSOP":[{"def":"The large succulent and slightly acid fruit of a small tree (Anona muricata) of the West Indies; also, the tree itself.","pos":""}],"SOURWOOD":[{"def":"The sorrel tree.","pos":""},{"def":"A corrupt form of Sou.","pos":""}],"SOUSE":[{"def":"Pickle made with salt.","pos":""},{"def":"Something kept or steeped in pickle; esp.","pos":""}],"SOUTACHE":[{"def":"A kind of narrow braid, usually of silk; -- also known as Russian braid.","pos":""}],"SOUTAGE":[{"def":"That in which anything is packed; bagging, as for hops.","pos":""}],"SOUTANE":[{"def":"A close garnment with straight sleeves, and skirts reaching to the ankles, and buttoned in front from top to bottom; especially, the black garment of this shape worn by the clergy in France and Italy as their daily dress; a cassock.","pos":""}],"SOUTER":[{"def":"A shoemaker; a cobbler.","pos":""}],"SOUTERLY":[{"def":"Of or pertaining to a cobbler or cobblers; like a cobbler; hence, vulgar; low.","pos":""}],"SOUTERRAIN":[{"def":"A grotto or cavern under ground.","pos":""}],"SOUTH":[{"def":"That one of the four cardinal points directly opposite to the north; the region or direction to the right or direction to the right of a person who faces the east.","pos":""},{"def":"A country, region, or place situated farther to the south than another; the southern section of a country.","pos":""}],"SOUTHCOTTIAN":[{"def":"A follower of Joanna Southcott (1750-1814), an Englishwoman who, professing to have received a miraculous calling, preached and prophesied, and committed many impious absurdities.","pos":""}],"SOUTHDOWN":[{"def":"Of or pertaining to the South Downs, a range of pasture hills south of the Thames, in England.","pos":""}],"SOUTHEAST":[{"def":"The point of the compass equally distant from the south and the east; the southeast part or region.","pos":""}],"SOUTHEASTER":[{"def":"A storm, strong wind, or gale coming from the southeast.","pos":""}],"SOUTHEASTERN":[{"def":"Of or pertaining to the southeast; southeasterly.","pos":""},{"def":"Toward the southeast.","pos":""}],"SOUTHER":[{"def":"A strong wind, gale, or storm from the south.","pos":""}],"SOUTHERLINESS":[{"def":"The quality or state of being southerly; direction toward the south.","pos":""}],"SOUTHERN":[{"def":"Of or pertaining to the south; situated in, or proceeding from, the south; situated or proceeding toward the south.","pos":""}],"SOUTHERNER":[{"def":"An inhabitant or native of the south, esp.","pos":""}],"SOUTHERNLY":[{"def":"Somewhat southern.","pos":""},{"def":"In a southerly manner or course; southward.","pos":""}],"SOUTHERNWOOD":[{"def":"A shrubby species of wormwood (Artemisia Abrotanum) having aromatic foliage.","pos":""}],"SOUTHING":[{"def":"Distance of any heavenly body south of the equator; south declination; south latitude.","pos":""},{"def":"Distance southward from any point departure or of reckoning, measured on a meridian; -- opposed to northing.","pos":""}],"SOUTHMOST":[{"def":"Farthest toward the south; southernmost.","pos":""}],"SOUTHNESS":[{"def":"A tendency in the end of a magnetic needle to point toward the south pole.","pos":""}],"SOUTHPAW":[{"def":"Using the left hand in pitching; said of a pitcher.","pos":""}],"SOUTHRON":[{"def":"An inhabitant of the more southern part of a country; formerly, a name given in Scotland to any Englishman.","pos":""}],"SOUTHSAYER":[{"def":"the old squaw; -- so called in imitation of its cry.","pos":""}],"SOUTHWARD":[{"def":"Toward the south.","pos":""}],"SOUTHWARDLY":[{"def":"In a southern direction.","pos":""}],"SOUTHWEST":[{"def":"The point of the compass equally from the south and the west; the southwest part or region.","pos":""}],"SOUTHWESTER":[{"def":"A storm, gale, or strong wind from the southwest.","pos":""},{"def":"A hat made of painted canvas, oiled cloth, or the like, with a flap at the back, -- worn in stormy weather.","pos":""}],"SOUTHWESTERLY":[{"def":"To ward or from the southwest; as, a southwesterly course; a southwesterly wind.","pos":""}],"SOUTHWESTERN":[{"def":"Of or pertaining to the southwest; southwesterly; as, to sail a southwestern course.","pos":""},{"def":"Toward the southwest.","pos":""}],"SOUVENIR":[{"def":"That which serves as a reminder; a remembrancer; a memento; a keepsake.","pos":""}]}