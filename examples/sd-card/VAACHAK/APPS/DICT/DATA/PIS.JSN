{"PISASPHALTUM":[{"def":"See Pissasphalt.","pos":""}],"PISCARY":[{"def":"The right or privilege of fishing in another man's waters.","pos":""}],"PISCATION":[{"def":"Fishing; fishery.","pos":""}],"PISCATOR":[{"def":"A fisherman; an angler.","pos":""},{"def":"Of or pertaining to fishes or fishing.","pos":""}],"PISCES":[{"def":"The class of Vertebrata that includes the fishes.","pos":""}],"PISCICAPTURE":[{"def":"Capture of fishes, as by angling.","pos":""}],"PISCICULTURAL":[{"def":"Relating to pisciculture.","pos":""}],"PISCICULTURIST":[{"def":"One who breeds fish.","pos":""}],"PISCIFORM":[{"def":"Having the form of a fish; resembling a fish.","pos":""}],"PISCINA":[{"def":"A niche near the altar in a church, containing a small basin for rinsing altar vessels.","pos":""}],"PISCINAL":[{"def":"Belonging to a fishpond or a piscina.","pos":""}],"PISCINE":[{"def":"Of or pertaining to a fish or fishes; as, piscine remains.","pos":""}],"PISCIVOROUS":[{"def":"Feeding or subsisting on fish.","pos":""}],"PISE":[{"def":"A species of wall made of stiff earth or clay rammed in between molds which are carried up as the wall rises; -- called also pisé work.","pos":""}],"PISH":[{"def":"An exclamation of contempt.","pos":""}],"PISHU":[{"def":"The Canada lynx.","pos":""}],"PISIFORM":[{"def":"Resembling a pea or peas in size and shape; as, a pisiform iron ore.","pos":""}],"PISMIRE":[{"def":"An ant, or emmet.","pos":""}],"PISOLITE":[{"def":"A variety of calcite, or calcium carbonate, consisting of aggregated globular concretions about the size of a pea; -- called also peastone, peagrit.","pos":""}],"PISOLITIC":[{"def":"Composed of, containing, or resembling, pisolite.","pos":""}],"PISS":[{"def":"To discharge urine, to urinate.","pos":""}],"PISSABED":[{"def":"A name locally applied to various wild plants, as dandelion, bluet, oxeye daisy, etc.","pos":""}],"PISSASPHALT":[{"def":"Earth pitch; a soft, black bitumen of the consistence of tar, and of a strong smell.","pos":""}],"PISTACHE":[{"def":"The anacardiaceous tree Pistacia vera, which yields the pistachio nut; also, the nut itself and the flavoring extract prepared from it.","pos":""}],"PISTACHIO":[{"def":"The nut of the Pistacia vera, a tree of the order Anacardiaceæ, containing a kernel of a pale greenish color, which has a pleasant taste, resembling that of the almond, and yields an oil of agreeable taste and odor; -- called also pistachio nut.","pos":""}],"PISTACHIO GREEN":[{"def":"A light yellowish green color resembling that of the pistachio nut.","pos":""}],"PISTACIA":[{"def":"The name of a genus of trees, including the tree which bears the pistachio, the Mediterranean mastic tree (Pistacia Lentiscus), and the species (P.","pos":""}],"PISTAREEN":[{"def":"An old Spanish silver coin of the value of about twenty cents.","pos":""}],"PISTAZITE":[{"def":"Same as Pistacite.","pos":""}],"PISTE":[{"def":"The track or tread a horseman makes upon the ground he goes over.","pos":""}],"PISTIL":[{"def":"The seed-bearing organ of a flower.","pos":""}],"PISTILLACEOUS":[{"def":"Growing on, or having nature of, the pistil; of or pertaining to a pistil.","pos":""}],"PISTILLATE":[{"def":"Having a pistil or pistils; -- usually said of flowers having pistils but no stamens.","pos":""}],"PISTILLATION":[{"def":"The act of pounding or breaking in a mortar; pestillation.","pos":""}],"PISTILLIDIUM":[{"def":"Same as Archegonium.","pos":""}],"PISTILLIFEROUS":[{"def":"Pis`til*lif\"er*ous, a.","pos":""}],"PISTILLODY":[{"def":"The metamorphosis of other organs into pistils.","pos":""}],"PISTOL":[{"def":"The smallest firearm used, intended to be fired from one hand, -- now of many patterns, and bearing a great variety of names.","pos":""}],"PISTOLE":[{"def":"The name of certain gold coins of various values formerly coined in some countries of Europe.","pos":""}],"PISTOLEER":[{"def":"One who uses a pistol.","pos":""}],"PISTON":[{"def":"A sliding piece which either is moved by, or moves against, fluid pressure.","pos":""}],"PISTON RING":[{"def":"A spring packing ring, or any of several such rings, for a piston.","pos":""}]}