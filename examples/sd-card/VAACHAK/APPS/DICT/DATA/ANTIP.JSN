{"ANTIPAPAL":[{"def":"Opposed to the pope or to popery.","pos":""}],"ANTIPARALLEL":[{"def":"Running in a contrary direction.","pos":""}],"ANTIPARALLELS":[{"def":"Straight lines or planes which make angles in some respect opposite in character to those made by parallel lines or planes.","pos":""}],"ANTIPARALYTIC":[{"def":"Good against paralysis.","pos":""},{"def":"A medicine for paralysis.","pos":""}],"ANTIPARALYTICAL":[{"def":"An`ti*par`a*lyt\"ic*al, a.","pos":""}],"ANTIPASCH":[{"def":"The Sunday after Easter; Low Sunday.","pos":""},{"def":"Having a natural contrariety, or constitutional aversion, to a thing; characterized by antipathy; -- often followed by to.","pos":""}],"ANTIPATHIC":[{"def":"Belonging to antipathy; opposite; contrary; allopathic.","pos":""}],"ANTIPATHIST":[{"def":"One who has an antipathy.","pos":""}],"ANTIPATHIZE":[{"def":"To feel or show antipathy.","pos":""}],"ANTIPATHOUS":[{"def":"Having a natural contrariety; adverse; antipathetic.","pos":""}],"ANTIPATHY":[{"def":"Contrariety or opposition in feeling; settled aversion or dislike; repugnance; distaste.","pos":""},{"def":"Natural contrariety; incompatibility; repugnancy of qualities; as, oil and water have antipathy.","pos":""}],"ANTIPEPTONE":[{"def":"A product of gastric and pancreatic digestion, differing from hemipeptone in not being decomposed by the continued action of pancreatic juice.","pos":""}],"ANTIPERIODIC":[{"def":"A remedy possessing the property of preventing the return of periodic paroxysms, or exacerbations, of disease, as in intermittent fevers.","pos":""}],"ANTIPERISTALTIC":[{"def":"Opposed to, or checking motion; acting upward; -- applied to an inverted action of the intestinal tube.","pos":""}],"ANTIPERISTASIS":[{"def":"Opposition by which the quality opposed asquires strength; resistance or reaction roused by opposition or by the action of an opposite principle or quality.","pos":""}],"ANTIPERISTATIC":[{"def":"Pertaining to antiperistasis.","pos":""}],"ANTIPETALOUS":[{"def":"Standing before a petal, as a stamen.","pos":""}],"ANTIPHARMIC":[{"def":"Antidotal; alexipharmic.","pos":""}],"ANTIPHLOGISTIAN":[{"def":"An opposer of the theory of phlogiston.","pos":""}],"ANTIPHLOGISTIC":[{"def":"Opposed to the doctrine of phlogiston.","pos":""},{"def":"Counteracting inflammation.","pos":""}],"ANTIPHON":[{"def":"A musical response; alternate singing or chanting.","pos":""},{"def":"A verse said before and after the psalms.","pos":""}],"ANTIPHONAL":[{"def":"Of or pertaining to antiphony, or alternate singing; sung alternately by a divided choir or opposite choirs.","pos":""}],"ANTIPHONARY":[{"def":"A book containing a collection of antiphons; the book in which the antiphons of the breviary, with their musical notes, are contained.","pos":""}],"ANTIPHONE":[{"def":"The response which one side of the choir makes to the other in a chant; alternate chanting or signing.","pos":""}],"ANTIPHONER":[{"def":"A book of antiphons.","pos":""}],"ANTIPHONY":[{"def":"A musical response; also, antiphonal chanting or signing.","pos":""},{"def":"An anthem or psalm sung alternately by a choir or congregation divided into two parts.","pos":""}],"ANTIPHRASIS":[{"def":"The use of words in a sense opposite to their proper meaning; as when a court of justice is called a court of vengeance.","pos":""},{"def":"Pertaining to antiphrasis.","pos":""}],"ANTIPHTHISIC":[{"def":"Relieving or curing phthisis, or consumption.","pos":""},{"def":"A medicine for phthisis.","pos":""}],"ANTIPHYSICAL":[{"def":"Contrary to nature; unnatural.","pos":""}],"ANTIPLASTIC":[{"def":"Preventing or checking the process of healing, or granulation.","pos":""}],"ANTIPODAGRIC":[{"def":"Good against gout.","pos":""},{"def":"A medicine for gout.","pos":""}],"ANTIPODAL":[{"def":"Pertaining to the antipodes; situated on the opposite side of the globe.","pos":""},{"def":"Diametrically opposite.","pos":""}],"ANTIPODE":[{"def":"One of the antipodes; anything exactly opposite.","pos":""}],"ANTIPODEAN":[{"def":"Pertaining to the antipodes, or the opposite side of the world; antipodal.","pos":""}],"ANTIPODES":[{"def":"Those who live on the side of the globe diametrically opposite.","pos":""},{"def":"The country of those who live on the opposite side of the globe.","pos":""}],"ANTIPOLE":[{"def":"The opposite pole; anything diametrically opposed.","pos":""}],"ANTIPOPE":[{"def":"One who is elected, or claims to be, pope in opposition to the pope canonically chosen; esp.","pos":""}],"ANTIPSORIC":[{"def":"Of use in curing the itch.","pos":""},{"def":"An antipsoric remedy.","pos":""}],"ANTIPTOSIS":[{"def":"The putting of one case for another.","pos":""},{"def":"Counteracting, or preserving from, putrefaction; antiseptic.","pos":""}],"ANTIPYIC":[{"def":"Checking or preventing suppuration.","pos":""},{"def":"An antipyic medicine.","pos":""}],"ANTIPYRESIS":[{"def":"The condition or state of being free from fever.","pos":""}],"ANTIPYRETIC":[{"def":"Efficacious in preventing or allaying fever.","pos":""}],"ANTIPYRINE":[{"def":"An artificial alkaloid, believed to be efficient in abating fever.","pos":""}],"ANTIPYROTIC":[{"def":"Good against burns or pyrosis.","pos":""},{"def":"Anything of use in preventing or healing burns or pyrosis.","pos":""}]}