{"SERR":[{"def":"To crowd, press, or drive together.","pos":""}],"SERRANOID":[{"def":"Any fish of the family Serranidæ, which includes the striped bass, the black sea bass, and many other food fishes.","pos":""},{"def":"Of or pertaining to the Serranidæ.","pos":""}],"SERRATION":[{"def":"Condition of being serrate; formation in the shape of a saw.","pos":""},{"def":"One of the teeth in a serrate or serrulate margin.","pos":""}],"SERRATIROSTRAL":[{"def":"Having a toothed bill, like that of a toucan.","pos":""}],"SERRATOR":[{"def":"The ivory gull (Larus eburneus).","pos":""}],"SERRATURE":[{"def":"A notching, like that between the teeth of a saw, in the edge of anything.","pos":""},{"def":"One of the teeth in a serrated edge; a serration.","pos":""}],"SERRICATED":[{"def":"Covered with fine silky down.","pos":""}],"SERRICORN":[{"def":"Any one of a numerous tribe of beetles (Serricornia).","pos":""}],"SERRIED":[{"def":"Crowded; compact; dense; pressed together.","pos":""}],"SERRIFERA":[{"def":"A division of Hymenoptera comprising the sawflies.","pos":""}],"SERRIROSTRES":[{"def":"Same as Lamellirostres.","pos":""}],"SERROUS":[{"def":"Like the teeth off a saw; jagged.","pos":""}],"SERRULA":[{"def":"The red-breasted merganser.","pos":""},{"def":"Finely serrate; having very minute teeth.","pos":""}],"SERRULATION":[{"def":"The state of being notched minutely, like a fine saw.","pos":""},{"def":"One of the teeth in a serrulate margin.","pos":""}],"SERRY":[{"def":"To crowd; to press together.","pos":""}]}