{"CUB":[{"def":"A young animal, esp.","pos":""},{"def":"Jocosely or in contempt, a boy or girl, esp.","pos":""}],"CUBAN":[{"def":"Of or pertaining to Cuba or its inhabitants.","pos":""},{"def":"A native or an inhabitant of Cuba.","pos":""}],"CUBATION":[{"def":"The act of lying down; a reclining.","pos":""}],"CUBATORY":[{"def":"Lying down; recumbent.","pos":""}],"CUBATURE":[{"def":"The process of determining the solid or cubic contents of a body.","pos":""}],"CUBBRIDGE-HEAD":[{"def":"A bulkhead on the forecastle and half deck of a ship.","pos":""},{"def":"A snug or confined place.","pos":""}],"CUBDRAWN":[{"def":"Cub\"*drawn` (kb\"drn`), a.","pos":""}],"CUBE":[{"def":"A regular solid body, with six equal square sides.","pos":""},{"def":"The product obtained by taking a number or quantity three times as a factor; as, 4x4=16, and 16x4=64, the cube of 4.","pos":""}],"CUBEB":[{"def":"The small, spicy berry of a species of pepper (Piper Cubeba; in med.","pos":""}],"CUBEBIC":[{"def":"Pertaining to, or derived from, cubebs; as, cubebic acid (a soft olive-green resin extracted from cubebs).","pos":""}],"CUBHOOD":[{"def":"The state of being a cub.","pos":""},{"def":"Isometric or monometric; as, cubic cleavage.","pos":""}],"CUBIC":[{"def":"A curve of the third degree.","pos":""}],"CUBICALLY":[{"def":"In a cubical method.","pos":""}],"CUBICALNESS":[{"def":"The quality of being cubical.","pos":""}],"CUBICLE":[{"def":"A loding room; esp.","pos":""}],"CUBICULAR":[{"def":"Belonging to a chamber or bedroom.","pos":""}],"CUBIFORM":[{"def":"Of the form of a cube.","pos":""}],"CUBILE":[{"def":"The lowest course of stones in a building.","pos":""}],"CUBILOSE":[{"def":"A mucilagenous secretion of certain birds found as the characteristic ingredient of edible bird's-nests.","pos":""}],"CUBISM":[{"def":"A movement or phase in post-impressionism (which see, below).","pos":""}],"CUBIT":[{"def":"The forearm; the ulna, a bone of the arm extending from elbow to wrist.","pos":""}],"CUBITAL":[{"def":"Of or pertaining to the cubit or ulna; as, the cubital nerve; the cubital artery; the cubital muscle.","pos":""},{"def":"Of the length of a cubit.","pos":""}],"CUBITED":[{"def":"Having the measure of a cubit.","pos":""}],"CUBO-OCTAHEDRAL":[{"def":"Presenting a combination of a cube and an octahedron.","pos":""}],"CUBO-OCTAHEDRON":[{"def":"A combination of a cube and octahedron, esp.","pos":""}],"CUBOID":[{"def":"Cube-shaped, or nearly so; as, the cuboid bone of the foot.","pos":""},{"def":"The bone of the tarsus, which, in man and most mammals, supports the metatarsals of the fourth and fifth toes.","pos":""}],"CUBOIDAL":[{"def":"Cu*boid\"al (k-boid\"al), a.","pos":""}]}