{"THIALDINE":[{"def":"A weak nitrogenous sulphur base, C6H13NS2.","pos":""}],"THIALOL":[{"def":"A colorless oily liquid, (C2H5)2S2, having a strong garlic odor; -- called also ethyl disulphide.","pos":""}],"THIBETAN":[{"def":"Of or pertaining to Thibet.","pos":""},{"def":"A native or inhabitant of Thibet.","pos":""}],"THIBETIAN":[{"def":"Same as Thibetan.","pos":""}],"THIBLE":[{"def":"A slice; a skimmer; a spatula; a pudding stick.","pos":""}],"THICK":[{"def":"Measuring in the third dimension other than length and breadth, or in general dimension other than length; -- said of a solid body; as, a timber seven inches thick.","pos":""},{"def":"Having more depth or extent from one surface to its opposite than usual; not thin or slender; as, a thick plank; thick cloth; thick paper; thick neck.","pos":""}],"THICK WIND":[{"def":"A defect of respiration in a horse, that is unassociated with noise in breathing or with the signs of emphysema.","pos":""}],"THICK-HEADED":[{"def":"Having a thick skull; stupid.","pos":""}],"THICK-SKINNED":[{"def":"Having a thick skin; hence, not sensitive; dull; obtuse.","pos":""}],"THICK-SKULLED":[{"def":"Having a thick skull; hence, dull; heavy; stupid; slow to learn.","pos":""}],"THICK-WINDED":[{"def":"Affected with thick wind.","pos":""}],"THICKEN":[{"def":"To make thick (in any sense of the word).","pos":""}],"THICKENING":[{"def":"Something put into a liquid or mass to make it thicker.","pos":""}],"THICKET":[{"def":"A wood or a collection of trees, shrubs, etc.","pos":""}],"THICKHEAD":[{"def":"Any one of several species of Australian singing birds of the genus Pachycephala.","pos":""}],"THICKLY":[{"def":"In a thick manner; deeply; closely.","pos":""}],"THICKNESS":[{"def":"The quality or state of being thick (in any of the senses of the adjective).","pos":""}],"THICKSET":[{"def":"Close planted; as, a thickset wood; a thickset hedge.","pos":""},{"def":"Having a short, thick body; stout.","pos":""}],"THICKSKIN":[{"def":"A coarse, gross person; a person void of sensibility or sinsitiveness; a dullard.","pos":""}],"THICKSKULL":[{"def":"A dullard, or dull person; a blockhead; a numskull.","pos":""}],"THIEF":[{"def":"One who steals; one who commits theft or larceny.","pos":""},{"def":"A waster in the snuff of a candle.","pos":""}],"THIEFLY":[{"def":"Like a thief; thievish; thievishly.","pos":""}],"THIENONE":[{"def":"A ketone derivative of thiophene obtained as a white crystalline substance, (C4H3S)2.","pos":""}],"THIENYL":[{"def":"The hypothetical radical C4H3S, regarded as the essential residue of thiophene and certain of its derivatives.","pos":""}],"THIEVE":[{"def":"To practice theft; to steal.","pos":""}],"THIEVERY":[{"def":"The practice of stealing; theft; thievishness.","pos":""},{"def":"That which is stolen.","pos":""}],"THIEVISH":[{"def":"Given to stealing; addicted to theft; as, a thievish boy, a thievish magpie.","pos":""},{"def":"Like a thief; acting by stealth; sly; secret.","pos":""}],"THIGH":[{"def":"The proximal segment of the hind limb between the knee and the trunk.","pos":""},{"def":"The coxa, or femur, of an insect.","pos":""}],"THIGMOTACTIC":[{"def":"Of or pertaining to thigmotaxis.","pos":""}],"THIGMOTAXIS":[{"def":"The property possessed by living protoplasm of contracting, and thus moving, when touched by a solid or fluid substance.","pos":""}],"THILK":[{"def":"That same; this; that.","pos":""}],"THILL":[{"def":"The floor of a coal mine.","pos":""}],"THILLER":[{"def":"The horse which goes between the thills, or shafts, and supports them; also, the last horse in a team; -- called also thill horse.","pos":""}],"THIMBLE":[{"def":"Any thimble-shaped appendage or fixure.","pos":""},{"def":"A ring of thin metal formed with a grooved circumference so as to fit within an eye-spice, or the like, and protect it from chafing.","pos":""}],"THIMBLEBERRY":[{"def":"A kind of black raspberry (Rubus occidentalis), common in America.","pos":""}],"THIMBLEEYE":[{"def":"The chub mackerel.","pos":""}],"THIMBLEFUL":[{"def":"As much as a thimble will hold; a very small quantity.","pos":""}],"THIMBLERIG":[{"def":"A sleight-of-hand trick played with three small cups, shaped like thimbles, and a small ball or little pea.","pos":""}],"THIMBLERIGGER":[{"def":"One who cheats by thimblerigging, or tricks of legerdemain.","pos":""}],"THIMBLEWEED":[{"def":"Any plant of the composite genus Rudbeckia, coarse herbs somewhat resembling the sunflower; -- so called from their conical receptacles.","pos":""}],"THIN":[{"def":"Having little thickness or extent from one surface to its opposite; as, a thin plate of metal; thin paper; a thin board; a thin covering.","pos":""},{"def":"Rare; not dense or thick; -- applied to fluids or soft mixtures; as, thin blood; thin broth; thin air.","pos":""}],"THIN-SKINNED":[{"def":"Having a thin skin; hence, sensitive; irritable.","pos":""}],"THINE":[{"def":"A form of the possessive case of the pronoun thou, now superseded in common discourse by your, the possessive of you, but maintaining a place in solemn discourse, in poetry, and in the usual language of the Friends, or Quakers.","pos":""}],"THING":[{"def":"Clothes; furniture; appurtenances; luggage; as, to pack or store one's things.","pos":""},{"def":"Whatever may be possessed or owned; a property; -- distinguished from person.","pos":""}],"THINK":[{"def":"To seem or appear; -- used chiefly in the expressions methinketh or methinks, and methought.","pos":""},{"def":"To employ any of the intellectual powers except that of simple perception through the senses; to exercise the higher intellectual faculties.","pos":""}],"THINKABLE":[{"def":"Capable of being thought or conceived; cogitable.","pos":""}],"THINKER":[{"def":"One who thinks; especially and chiefly, one who thinks in a particular manner; as, a close thinker; a deep thinker; a coherent thinker.","pos":""}],"THINKING":[{"def":"Having the faculty of thought; cogitative; capable of a regular train of ideas; as, man is a thinking being.","pos":""}],"THINLY":[{"def":"In a thin manner; in a loose, scattered manner; scantily; not thickly; as, ground thinly planted with trees; a country thinly inhabited.","pos":""}],"THINNER":[{"def":"One who thins, or makes thinner.","pos":""}],"THINNESS":[{"def":"The quality or state of being thin (in any of the senses of the word).","pos":""}],"THINOLITE":[{"def":"A calcareous tufa, in part crystalline, occurring on a large scale as a shore deposit about the Quaternary lake basins of Nevada.","pos":""}],"THIO-":[{"def":"A combining form (also used adjectively) denoting the presence of sulphur.","pos":""}],"THIOCARBONATE":[{"def":"A sulphocarbonate.","pos":""}],"THIOCARBONIC":[{"def":"Same as Sulphocarbonic.","pos":""}],"THIOCYANATE":[{"def":"Same as Sulphocyanate.","pos":""}],"THIOCYANIC":[{"def":"Same as Sulphocyanic.","pos":""}],"THIONAPHTHENE":[{"def":"A double benzene and thiophene nucleus, C8H6S, analogous to naphthalene, and like it the base of a large series of derivatives.","pos":""}],"THIONIC":[{"def":"Of or pertaining to sulphur; containing or resembling sulphur; specifically, designating certain of the thio compounds; as, the thionic acids.","pos":""}],"THIONINE":[{"def":"An artificial red or violet dyestuff consisting of a complex sulphur derivative of certain aromatic diamines, and obtained as a dark crystalline powder; -- called also phenylene violet.","pos":""}],"THIONOL":[{"def":"A red or violet dyestuff having a greenish metallic luster.","pos":""}],"THIONOLINE":[{"def":"A beautiful fluorescent crystalline substance, intermediate in composition between thionol and thionine.","pos":""}],"THIONYL":[{"def":"The hypothetical radical SO, regarded as an essential constituent of certain sulphurous compounds; as, thionyl chloride.","pos":""}],"THIOPHENE":[{"def":"A sulphur hydrocarbon, C4H4S, analogous to furfuran and benzene, and acting as the base of a large number of substances which closely resemble the corresponding aromatic derivatives.","pos":""}],"THIOPHENIC":[{"def":"Of, pertaining to, or derived from, thiophene; specifically, designating a certain acid analogous to benzoic acid.","pos":""}],"THIOPHENOL":[{"def":"A colorless mobile liquid, C6H5.","pos":""}],"THIOPHTHENE":[{"def":"A double thiophene nucleus, C6H4S2, analogous to thionaphthene, and the base of a large series of compounds.","pos":""}],"THIOSULPHATE":[{"def":"A salt of thiosulphuric acid; -- formerly called hyposulphite.","pos":""}],"THIOSULPHURIC":[{"def":"Of, pertaining to, or designating, an unstable acid, H2S2O3, analogous to sulphuric acid, and formerly called hyposulphurous acid.","pos":""}],"THIOTOLENE":[{"def":"A colorless oily liquid, C4H3S.","pos":""}],"THIOXENE":[{"def":"Any one of three possible metameric substances, which are dimethyl derivatives of thiophene, like the xylenes from benzene.","pos":""}],"THIRD":[{"def":"Next after the second; coming after two others; -- the ordinal of three; as, the thirdhour in the day.","pos":""},{"def":"Constituting or being one of three equal parts into which anything is divided; as, the third part of a day.","pos":""}],"THIRD-BOROUGH":[{"def":"An under constable.","pos":""}],"THIRD-PENNY":[{"def":"A third part of the profits of fines and penalties imposed at the country court, which was among the perquisites enjoyed by the earl.","pos":""}],"THIRD-RAIL SYSTEM":[{"def":"A system in which a third rail is used for carrying the current for operating the motors, the rail being insulated from the ground and the current being taken off by means of contact brushes or other devices.","pos":""}],"THIRDINGS":[{"def":"The third part of the corn or grain growing on the ground at the tenant's death, due to the lord for a heriot, as within the manor of Turfat in Herefordshire.","pos":""}],"THIRDLY":[{"def":"In the third place.","pos":""}],"THIRL":[{"def":"To bore; to drill or thrill.","pos":""}],"THIRLAGE":[{"def":"The right which the owner of a mill possesses, by contract or law, to compel the tenants of a certain district, or of his sucken, to bring all their grain to his mill for grinding.","pos":""}],"THIRST":[{"def":"A sensation of dryness in the throat associated with a craving for liquids, produced by deprivation of drink, or by some other cause (as fear, excitement, etc.","pos":""}],"THIRSTER":[{"def":"One who thirsts.","pos":""}],"THIRSTILY":[{"def":"In a thirsty manner.","pos":""}],"THIRSTINESS":[{"def":"The state of being thirsty; thirst.","pos":""}],"THIRSTY":[{"def":"Feeling thirst; having a painful or distressing sensation from want of drink; hence, having an eager desire.","pos":""},{"def":"Deficient in moisture; dry; parched.","pos":""}],"THIRTEEN":[{"def":"One more than twelve; ten and three; as, thirteen ounces or pounds.","pos":""}],"THIRTEENTH":[{"def":"Next in order after the twelfth; the third after the tenth; -- the ordinal of thirteen; as, the thirteenth day of the month.","pos":""},{"def":"Constituting or being one of thirteen equal parts into which anything is divided.","pos":""}],"THIRTIETH":[{"def":"Next in order after the twenty-ninth; the tenth after the twentieth; -- the ordinal of thirty; as, the thirtieth day of the month.","pos":""},{"def":"Constituting or being one of thirty equal parts into which anything is divided.","pos":""}],"THIRTY":[{"def":"Being three times ten; consisting of one more than twenty-nine; twenty and ten; as, the month of June consists of thirty days.","pos":""}],"THIRTY-SECOND":[{"def":"Being one of thirty-two equal parts into which anything is divided.","pos":""}],"THIS":[{"def":"As a demonstrative pronoun, this denotes something that is present or near in place or time, or something just mentioned, or that is just about to be mentioned.","pos":""},{"def":"As an adjective, this has the same demonstrative force as the pronoun, but is followed by a noun; as, this book; this way to town.","pos":""}],"THISTLE":[{"def":"Any one of several prickly composite plants, especially those of the genera Cnicus, Craduus, and Onopordon.","pos":""}],"THISTLY":[{"def":"Overgrown with thistles; as, thistly ground.","pos":""}],"THITHER":[{"def":"To that place; -- opposed to Ant: hither.","pos":""},{"def":"To that point, end, or result; as, the argument tended thither.","pos":""}],"THITHERTO":[{"def":"To that point; so far.","pos":""}],"THITHERWARD":[{"def":"To ward that place; in that direction.","pos":""}],"THITSEE":[{"def":"The varnish tree of Burmah (Melanorrhoea usitatissima).","pos":""}]}