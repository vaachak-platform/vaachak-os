{"CHAIN":[{"def":"An instrument which consists of links and is used in measuring land.","pos":""},{"def":"Iron links bolted to the side of a vessel to bold the dead-eyes connected with the shrouds; also, the channels.","pos":""}],"CHAIN PUMP":[{"def":"A pump consisting of an endless chain, running over a drum or wheel by which it is moved, and dipping below the water to be raised.","pos":""}],"CHAIN STITCH":[{"def":"A stitch in which the looping of the thread or threads forms a chain on the under side of the work; the loop stitch, as distinguished from the lock stitch.","pos":""}],"CHAIN TIE":[{"def":"A tie consisting of a series of connected iron bars or rods.","pos":""}],"CHAIN WHEEL":[{"def":"A chain pulley, or sprocket wheel.","pos":""},{"def":"An inversion of the chain pump, by which it becomes a motor driven by water.","pos":""}],"CHAINLESS":[{"def":"Having no chain; not restrained or fettered.","pos":""}],"CHAINWORK":[{"def":"Work looped or linked after the manner of a chain; chain stitch work.","pos":""}],"CHAIR":[{"def":"A movable single seat with a back.","pos":""},{"def":"An official seat, as of a chief magistrate or a judge, but esp.","pos":""}],"CHAIRMAN":[{"def":"The presiding officer of a committee, or of a public or private meeting, or of any organized body.","pos":""},{"def":"One whose business it is to cary a chair or sedan.","pos":""}],"CHAIRMANSHIP":[{"def":"The office of a chairman of a meeting or organized body.","pos":""}],"CHAISE":[{"def":"a carriage in general.","pos":""}]}