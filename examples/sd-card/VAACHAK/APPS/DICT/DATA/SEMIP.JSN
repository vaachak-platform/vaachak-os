{"SEMIPAGAN":[{"def":"Having the anterior toes joined only part way down with a web; half-webbed; as, a semipalmate bird or foot.","pos":""}],"SEMIPARABOLA":[{"def":"One branch of a parabola, being terminated at the principal vertex of the curve.","pos":""}],"SEMIPED":[{"def":"A half foot in poetry.","pos":""}],"SEMIPEDAL":[{"def":"Containing a half foot.","pos":""}],"SEMIPELLUCID":[{"def":"Half clear, or imperfectly transparent; as, a semipellucid gem.","pos":""}],"SEMIPELLUCIDITY":[{"def":"The qualiti or state of being imperfectly transparent.","pos":""}],"SEMIPENNIFORM":[{"def":"Half or partially penniform; as, a semipenniform muscle.","pos":""}],"SEMIPERMANENT":[{"def":"Half or partly permanent.","pos":""}],"SEMIPERSPICUOUS":[{"def":"Half transparent; imperfectly clear; semipellucid.","pos":""}],"SEMIPHLOGISTICATED":[{"def":"Partially impregnated with phlogiston.","pos":""}],"SEMIPLUME":[{"def":"A feather which has a plumelike web, with the shaft of an ordinary feather.","pos":""}],"SEMIPRECIOUS":[{"def":"Somewhat precious; as, semiprecious stones or metals.","pos":""}],"SEMIPROOF":[{"def":"Half proof; evidence from the testimony of a single witness.","pos":""}]}