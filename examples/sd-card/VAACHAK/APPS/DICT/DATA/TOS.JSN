{"TOSCATTER":[{"def":"To scatter in pieces; to divide.","pos":""}],"TOSE":[{"def":"To tease, or comb, as wool.","pos":""}],"TOSHRED":[{"def":"To cut into shreads or pieces.","pos":""}],"TOSS":[{"def":"To throw with the hand; especially, to throw with the palm of the hand upward, or to throw upward; as, to toss a ball.","pos":""},{"def":"To lift or throw up with a sudden or violent motion; as, to toss the head.","pos":""}],"TOSSILY":[{"def":"In a tossy manner.","pos":""}],"TOSSING":[{"def":"The act of throwing upward; a rising and falling suddenly; a rolling and tumbling.","pos":""}],"TOSSPOT":[{"def":"A toper; one habitually given to strong drink; a drunkard.","pos":""}],"TOSSY":[{"def":"Tossing the head, as in scorn or pride; hence, proud; contemptuous; scornful; affectedly indifferent; as, a tossy commonplace.","pos":""}],"TOSWINK":[{"def":"To labor excessively.","pos":""}]}