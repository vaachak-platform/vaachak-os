{"CHEMIC":[{"def":"A solution of chloride of line.","pos":""}],"CHEMICAL":[{"def":"Pertaining to chemistry; characterized or produced by the forces and operations of chemistry; employed in the processes of chemistry; as, chemical changes; chemical comnbinations.","pos":""}],"CHEMICALLY":[{"def":"According to chemical principles; by chemical process or operation.","pos":""}],"CHEMIGLYPHIC":[{"def":"Engraved by a voltaic battary.","pos":""}],"CHEMIGRAPHY":[{"def":"Any mechanical engraving process depending upon chemical action; specif.","pos":""}],"CHEMILOON":[{"def":"A garment for women, consisting of chemise and drawers united in one.","pos":""}],"CHEMISE":[{"def":"A shift, or undergarment, worn by women.","pos":""},{"def":"A wall that lines the face of a bank or earthwork.","pos":""}],"CHEMISETTE":[{"def":"An under-garment, worn by women, usually covering the neck, shoulders, and breast.","pos":"noun"}],"CHEMISM":[{"def":"The force exerted between the atoms of elementary substance whereby they unite to form chemical compounds; chemical attaction; affinity; -- sometimes used as a general expression for chemical activity or relationship.","pos":""}],"CHEMIST":[{"def":"A person versed in chemistry or given to chemical investigation; an analyst; a maker or seller of chemicals or drugs.","pos":""}],"CHEMISTRY":[{"def":"That branch of science which treats of the composition of substances, and of the changes which they undergo in consequence of alterations in the constitution of the molecules, which depend upon variations of the number, kind, or mode of arrangement, of the constituent atoms.","pos":""},{"def":"An application of chemical theory and method to the consideration of some particular subject; as, the chemistry of iron; the chemistry of indigo.","pos":""}],"CHEMITYPE":[{"def":"One of a number of processes by which an impression from an engraved plate is obtained in relief, to be used for printing on an ordinary printing press.","pos":""}],"CHEMOLYSIS":[{"def":"A term sometimes applied to the decomposition of organic substance into more simple bodies, by the use of chemical agents alone.","pos":""}],"CHEMOSIS":[{"def":"Inflammatory swelling of the conjunctival tissue surrounding the cornea.","pos":""}],"CHEMOSMOSIS":[{"def":"Chemical action taking place through an intervening membrane.","pos":""}],"CHEMOSMOTIC":[{"def":"Pertaining to, or produced by, chemosmosis.","pos":""}],"CHEMOSYNTHESIS":[{"def":"Synthesis of organic compounds by energy derived from chemical changes or reactions.","pos":""},{"def":"The sensitiveness exhibited by small free-swimming organisms, as bacteria, zoöspores of algæ, etc.","pos":""}],"CHEMUNG PERIOD":[{"def":"A subdivision in the upper part of the Devonian system in America, so named from the Chemung River, along which the rocks are well developed.","pos":""}]}