{"TAB":[{"def":"The flap or latchet of a shoe fastened with a string or a buckle.","pos":""}],"TABANUS":[{"def":"A genus of blood sucking flies, including the horseflies.","pos":""}],"TABARD":[{"def":"A sort of tunic or mantle formerly worn for protection from the weather.","pos":""}],"TABARDER":[{"def":"One who wears a tabard.","pos":""},{"def":"A scholar on the foundation of Queen's College, Oxford, England, whose original dress was a tabard.","pos":""}],"TABARET":[{"def":"A stout silk having satin stripes, -- used for furniture.","pos":""}],"TABASCO SAUCE":[{"def":"A kind of very pungent sauce made from red peppers.","pos":""}],"TABASHEER":[{"def":"A concretion in the joints of the bamboo, which consists largely or chiefly of pure silica.","pos":""}],"TABBINET":[{"def":"A fabric like poplin, with a watered surface.","pos":""}],"TABEFACTION":[{"def":"A wasting away; a gradual losing of flesh by disease.","pos":""}],"TABEFY":[{"def":"To cause to waste gradually, to emaciate.","pos":""}],"TABELLION":[{"def":"A secretary or notary under the Roman empire; also, a similar officer in France during the old monarchy.","pos":""}],"TABERNACLE":[{"def":"A slightly built or temporary habitation; especially, a tent.","pos":""},{"def":"Hence, the Jewish temple; sometimes, any other place for worship.","pos":""}],"TABERNACULAR":[{"def":"Of or pertaining to a tabernacle, especially the Jewish tabernacle.","pos":""},{"def":"Formed in latticework; latticed.","pos":""}],"TABES":[{"def":"Progressive emaciation of the body, accompanied with hectic fever, with no well-marked local symptoms.","pos":""}],"TABESCENT":[{"def":"Withering, or wasting away.","pos":""}],"TABETIC":[{"def":"Of or pertaining to tabes; of the nature of tabes; affected with tabes; tabid.","pos":""},{"def":"One affected with tabes.","pos":""}],"TABID":[{"def":"Affected by tabes; tabetic.","pos":""},{"def":"Producing tabes; wasting; tabefying.","pos":""}],"TABLATURE":[{"def":"The chimes of bells are so rarely managed that I went up to that of Sir Nicholas, where I found who played all sorts of compositions from the tablature before him as if he had fingered an organ.","pos":""}],"TABLE":[{"def":"To insert, as one piece of timber into another, by alternate scores or projections from the middle, to prevent slipping; to scarf.","pos":""},{"def":"To make board hems in the skirts and bottoms of (sails) in order to strengthen them in the part attached to the boltrope.","pos":""}],"TABLE D'HOTE":[{"def":"A common table for guests at a hotel; an ordinary.","pos":""}],"TABLE WORK":[{"def":"Typesetting of tabular nmatter, or the type matter set in tabular form.","pos":""}],"TABLE-LAND":[{"def":"A broad, level, elevated area of land; a plateau.","pos":""}],"TABLEAU":[{"def":"A striking and vivid representation; a picture.","pos":""},{"def":"A representation of some scene by means of persons grouped in the proper manner, placed in appropriate postures, and remaining silent and motionless.","pos":""}],"TABLEAU VIVANT":[{"def":"Same as Tableau, n.","pos":""}],"TABLEBOOK":[{"def":"A tablet; a notebook.","pos":""}],"TABLECLOTH":[{"def":"A cloth for covering a table, especially one with which a table is covered before the dishes, etc.","pos":""}],"TABLEMAN":[{"def":"A man at draughts; a piece used in playing games at tables.","pos":""}],"TABLEMENT":[{"def":"Tablements and chapters of pillars.","pos":""}],"TABLER":[{"def":"One who boards others for hire.","pos":""}],"TABLESPOON":[{"def":"A spoon of the largest size commonly used at the table; -- distinguished from teaspoon, dessert spoon, etc.","pos":""}],"TABLESPOONFUL":[{"def":"As much as a tablespoon will hold; enough to fill a tablespoon.","pos":""}],"TABLET":[{"def":"A kind of pocket memorandum book.","pos":""},{"def":"A solid kind of electuary or confection, commonly made of dry ingredients with sugar, and usually formed into little flat squares; -- called also lozenge, and troche, especially when of a round or rounded form.","pos":""}],"TABLEWARE":[{"def":"Ware, or articles collectively, for table use.","pos":""}],"TABLING":[{"def":"The letting of one timber into another by alternate scores or projections, as in shipbuilding.","pos":""},{"def":"A broad hem on the edge of a sail.","pos":""}],"TABLOID":[{"def":"A compressed portion of one or more drugs or chemicals, or of food, etc.","pos":""}],"TABOO":[{"def":"A total prohibition of intercourse with, use of, or approach to, a given person or thing under pain of death, -- an interdict of religious origin and authority, formerly common in the islands of Polynesia; interdiction.","pos":""}],"TABOR":[{"def":"A small drum used as an accompaniment to a pipe or fife, both being played by the same person.","pos":""}],"TABORER":[{"def":"One who plays on the tabor.","pos":""}],"TABORINE":[{"def":"A small, shallow drum; a tabor.","pos":""}],"TABORITE":[{"def":"One of certain Bohemian reformers who suffered persecution in the fifteenth century; -- so called from Tabor, a hill or fortress where they encamped during a part of their struggles.","pos":""}],"TABOURET":[{"def":"Same as Taboret.","pos":""},{"def":"A seat without arms or back, cushioned and stuffed: a high stool; -- so called from its resemblance to a drum.","pos":""}],"TABULA":[{"def":"One of the transverse plants found in the calicles of certain corals and hydroids.","pos":""}],"TABULAR":[{"def":"Having the form of, or pertaining to, a table (in any of the uses of the word).","pos":""}],"TABULARIZATION":[{"def":"The act of tabularizing, or the state of being tabularized; formation into tables; tabulation.","pos":""}],"TABULATA":[{"def":"An artificial group of stony corals including those which have transverse septa in the calicles.","pos":""}],"TABULATE":[{"def":"To form into a table or tables; to reduce to tables or synopses.","pos":""},{"def":"To shape with a flat surface.","pos":""}],"TABULATION":[{"def":"The act of forming into a table or tables; as, the tabulation of statistics.","pos":""}]}