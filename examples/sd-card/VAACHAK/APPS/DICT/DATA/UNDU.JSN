{"UNDUBITABLE":[{"def":"Indubitable; as, an undubitable principle.","pos":""}],"UNDUE":[{"def":"Not due; not yet owing; as, an undue debt, note, or bond.","pos":""},{"def":"Not right; not lawful or legal; improper; as, an undue proceeding.","pos":""}],"UNDUENESS":[{"def":"The quality of being undue.","pos":""}],"UNDUKE":[{"def":"To deprive of dukedom.","pos":""}],"UNDULARY":[{"def":"Moving like waves; undulatory.","pos":""}],"UNDULATE":[{"def":"Same as Undulated.","pos":""}],"UNDULATED":[{"def":"Waved obtusely up and down, near the margin, as a leaf or corolla; wavy.","pos":""},{"def":"Formed with elevations and depressions resembling waves; having wavelike color markings; as, an undulated shell.","pos":""}],"UNDULATING":[{"def":"Rising and falling like waves; resembling wave form or motion; undulatory; rolling; wavy; as, an undulating medium; undulating ground.","pos":""}],"UNDULATION":[{"def":"A motion to and fro, up and down, or from side to side, in any fluid or elastic medium, propagated continuously among its particles, but with no translation of the particles themselves in the direction of the propagation of the wave; a wave motion; a vibration.","pos":""}],"UNDULATIONIST":[{"def":"One who advocates the undulatory theory of light.","pos":""}],"UNDULATIVE":[{"def":"Consisting in, or accompanied by, undulations; undulatory.","pos":""}],"UNDULATORY":[{"def":"Moving in the manner of undulations, or waves; resembling the motion of waves, which successively rise or swell rise or swell and fall; pertaining to a propagated alternating motion, similar to that of waves.","pos":""}],"UNDULL":[{"def":"To remove the dullness of; to clear.","pos":""}],"UNDULOUS":[{"def":"Undulating; undulatory.","pos":""}],"UNDULY":[{"def":"In an undue manner.","pos":""}],"UNDUMPISH":[{"def":"To relieve from the dumps.","pos":""}],"UNDUST":[{"def":"To free from dust.","pos":""}]}