{"DOBBER":[{"def":"A float to a fishing line.","pos":""}],"DOBBIN":[{"def":"An old jaded horse.","pos":""},{"def":"Sea gravel mixed with sand.","pos":""}],"DOBBY":[{"def":"An apparatus resembling a Jacquard for weaving small figures (usually about 12 - 16 threads, seldom more than 36 - 40 threads).","pos":""}],"DOBELL'S SOLUTION":[{"def":"An aqueous solution of carbolic acid, borax, sodium bicarbonate, and glycerin, used as a spray in diseases of the nose and throat.","pos":""}],"DOBSON":[{"def":"The aquatic larva of a large neuropterous insect (Corydalus cornutus), used as bait in angling.","pos":""}],"DOBULE":[{"def":"The European dace.","pos":""}]}