{"ROQUE":[{"def":"A form of croquet modified for greater accuracy of play.","pos":""},{"def":"A highly flavored blue-molded cheese, made at Roquefort, department of Aveyron, France.","pos":""}],"ROQUELAURE":[{"def":"A cloak reaching about to, or just below, the knees, worn in the 18th century.","pos":""}],"ROQUET":[{"def":"To hit, as another's ball, with one's own ball.","pos":""}]}