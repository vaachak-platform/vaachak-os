{"CREDENCE":[{"def":"The small table by the side of the altar or communion table, on which the bread and wine are placed before being consecrated.","pos":""}],"CREDENDUM":[{"def":"A thing to be believed; an article of faith; -- distinguished from agendum, a practical duty.","pos":""}],"CREDENT":[{"def":"Believing; giving credence; credulous.","pos":""},{"def":"Having credit or authority; credible.","pos":""}],"CREDENTIAL":[{"def":"Giving a title or claim to credit or confidence; accrediting.","pos":""}],"CREDIBILITY":[{"def":"The quality of being credible; credibleness; as, the credibility of facts; the credibility of witnesses.","pos":""}],"CREDIBLE":[{"def":"Capable of being credited or believed; worthy of belief; entiled to confidence; trustworthy.","pos":""}],"CREDIBLENESS":[{"def":"The quality or state of being credible; worthness of belief; credibility.","pos":""}],"CREDIBLY":[{"def":"In a manner inducing belief; as, I have been credibly informed of the event.","pos":""}],"CREDIT":[{"def":"Trust given or received; expectation of future playment for property transferred, or of fulfillment or promises given; mercantile reputation entitling one to be trusted; -- applied to individuals, corporations, communities, or nations; as, to buy goods on credit.","pos":""}],"CREDIT FONCIER":[{"def":"A company licensed for the purpose of carrying out improvements, by means of loans and advances upon real securities.","pos":""}],"CREDIT MOBILIER":[{"def":"A joint stock company, formed for general banking business, or for the construction of public works, by means of loans on personal estate, after the manner of the crédit foncier on real estate.","pos":""}],"CREDITABLE":[{"def":"Worthy of belief.","pos":""},{"def":"Deserving or possessing reputation or esteem; reputable; estimable.","pos":""}],"CREDITABLENESS":[{"def":"The quality of being creditable.","pos":""}],"CREDITABLY":[{"def":"In a creditable manner; reputably; with credit.","pos":""}],"CREDITOR":[{"def":"A female creditor.","pos":""}],"CREDO":[{"def":"The creed, as sung or read in the Roman Catholic church.","pos":""}],"CREDULITY":[{"def":"Readiness of belief; a disposition to believe on slight evidence.","pos":""}],"CREDULOUS":[{"def":"Apt to believe on slight evidence; easly imposed upon; unsuspecting.","pos":""},{"def":"Believed too readily.","pos":""}],"CREDULOUSNESS":[{"def":"Readiness to believe on slight evidence; credulity.","pos":""}]}