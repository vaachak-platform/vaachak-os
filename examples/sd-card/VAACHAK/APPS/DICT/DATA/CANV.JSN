{"CANVAS":[{"def":"A strong cloth made of hemp, flax, or cotton; -- used for tents, sails, etc.","pos":""},{"def":"Something for which canvas is used: (a) A sail, or a collection of sails.","pos":""}],"CANVASBACK":[{"def":"A Species of duck (Aythya vallisneria), esteemed for the delicacy of its flesh.","pos":""}],"CANVASS":[{"def":"To sift; to strain; to examine thoroughly; to scrutinize; as, to canvass the votes cast at an election; to canvass a district with reference to its probable vote.","pos":""},{"def":"To examine by discussion; to debate.","pos":""}],"CANVASSER":[{"def":"One who canvasses.","pos":""}]}