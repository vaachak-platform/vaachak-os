{"JAIL":[{"def":"A kind of prison; a building for the confinement of persons held in lawful custody, especially for minor offenses or with reference to some future judicial proceeding.","pos":""}],"JAILER":[{"def":"The keeper of a jail or prison.","pos":""},{"def":"One of a numerous sect in British India, holding the tenets of Jainism.","pos":""}],"JAINISM":[{"def":"The heterodox Hindoo religion, of which the most striking features are the exaltation of saints or holy mortals, called jins, above the ordinary Hindoo gods, and the denial of the divine origin and infallibility of the Vedas.","pos":""}],"JAIROU":[{"def":"The ahu or Asiatic gazelle.","pos":""}]}