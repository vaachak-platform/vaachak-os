{"BAIGNE":[{"def":"To soak or drench.","pos":""}],"BAIGNOIRE":[{"def":"A box of the lowest tier in a theater.","pos":""}],"BAIL":[{"def":"A bucket or scoop used in bailing water out of a boat.","pos":""}],"BAILABLE":[{"def":"Having the right or privilege of being admitted to bail, upon bond with sureties; -- used of persons.","pos":""},{"def":"Admitting of bail; as, a bailable offense.","pos":""}],"BAILEE":[{"def":"The person to whom goods are committed in trust, and who has a temporary possession and a qualified property in them, for the purposes of the trust.","pos":""}],"BAILER":[{"def":"One who bails or lades.","pos":""},{"def":"A utensil, as a bucket or cup, used in bailing; a machine for bailing water out of a pit.","pos":""}],"BAILEY":[{"def":"The outer wall of a feudal castle.","pos":""},{"def":"The space immediately within the outer wall of a castle or fortress.","pos":""}],"BAILIE":[{"def":"An officer in Scotland, whose office formerly corresponded to that of sheriff, but now corresponds to that of an English alderman.","pos":""}],"BAILIFF":[{"def":"A sheriff's deputy, appointed to make arrests, collect fines, summon juries, etc.","pos":""}],"BAILIWICK":[{"def":"The precincts within which a bailiff has jurisdiction; the limits of a bailiff's authority.","pos":""}],"BAILMENT":[{"def":"The action of bailing a person accused.","pos":""},{"def":"A delivery of goods or money by one person to another in trust, for some special purpose, upon a contract, expressed or implied, that the trust shall be faithfully executed.","pos":""}],"BAILOR":[{"def":"One who delivers goods or money to another in trust.","pos":""}],"BAILPIECE":[{"def":"A piece of parchment, or paper, containing a recognizance or bail bond.","pos":""}],"BAILY'S BEADS":[{"def":"A row of bright spots observed in connection with total eclipses of the sun.","pos":""}],"BAIN":[{"def":"A bath; a bagnio.","pos":""}],"BAIN-MARIE":[{"def":"A vessel for holding hot water in which another vessel may be heated without scorching its contents; -- used for warming or preparing food or pharmaceutical preparations.","pos":""}],"BAIRAM":[{"def":"The name of two Mohammedan festivals, of which one is held at the close of the fast called Ramadan, and the other seventy days after the fast.","pos":""}],"BAIRN":[{"def":"Has he not well provided for the bairn ! Beau.","pos":""}],"BAISEMAINS":[{"def":"Respects; compliments.","pos":""}],"BAIT":[{"def":"Any substance, esp.","pos":""},{"def":"Anything which allures; a lure; enticement; temptation.","pos":""}],"BAITER":[{"def":"One who baits; a tormentor.","pos":""}],"BAIZE":[{"def":"A coarse woolen stuff with a long nap; -- usually dyed in plain colors.","pos":""}]}