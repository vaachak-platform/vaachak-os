{"GEOCENTRICALLY":[{"def":"In a geocentric manner.","pos":""}],"GEOCHEMISTRY":[{"def":"The study of the chemical composition of, and of actual or possible chemical changes in, the crust of the earth.","pos":""}],"GEOCRONITE":[{"def":"A lead-gray or grayish blue mineral with a metallic luster, consisting of sulphur, antimony, and lead, with a small proportion of arsenic.","pos":""}],"GEOCYCLIC":[{"def":"Of, pertaining to, or illustrating, the revolutions of the earth; as, a geocyclic machine.","pos":""},{"def":"Circling the earth periodically.","pos":""}],"GEODEPHAGOUS":[{"def":"Living in the earth; -- applied to the ground beetles.","pos":""},{"def":"Of or pertaining to geodetic.","pos":""}],"GEODESIC":[{"def":"A geodetic line or curve.","pos":""}],"GEODESIST":[{"def":"One versed in geodesy.","pos":""}],"GEODESY":[{"def":"Of or pertaining to gebdesy; obtained or determined by the operations of geodesy; engaged in geodesy; geodesic; as, geodetic surveying; geodetic observers.","pos":""}],"GEODETICALLY":[{"def":"In a geodetic manner; according to geodesy.","pos":""}],"GEODETICS":[{"def":"Same as Geodesy.","pos":""}],"GEODIFEROUS":[{"def":"Producing geodes; containing geodes.","pos":""}],"GEODUCK":[{"def":"A gigantic clam (Glycimeris generosa) of the Pacific coast of North America, highly valued as an article of food.","pos":""}],"GEOGNOSIS":[{"def":"Knowledge of the earth.","pos":""}],"GEOGNOST":[{"def":"One versed in geognosy; a geologist.","pos":""},{"def":"Of or pertaining to geognosy, or to a knowledge of the structure of the earth; geological.","pos":""}],"GEOGNOSY":[{"def":"That part of geology which treats of the materials of the earth's structure, and its general exterior and interior constitution.","pos":""},{"def":"Of or pertaining to geogony, or to the formation of the earth.","pos":""}],"GEOGONY":[{"def":"The branch of science which treats of the formation of the earth.","pos":""}],"GEOGRAPHER":[{"def":"One versed in geography.","pos":""},{"def":"Of or pertaining to geography.","pos":""}],"GEOGRAPHICALLY":[{"def":"In a geographical manner or method; according to geography.","pos":""}],"GEOGRAPHY":[{"def":"The science which treats of the world and its inhabitants; a description of the earth, or a portion of the earth, including its structure, fetures, products, political divisions, and the people by whom it is inhabited.","pos":""},{"def":"A treatise on this science.","pos":""}],"GEOLATRY":[{"def":"The worship of the earth.","pos":""}],"GEOLOGICALLY":[{"def":"In a geological manner.","pos":""}],"GEOLOGIST":[{"def":"One versed in the science of geology.","pos":""}],"GEOLOGIZE":[{"def":"To study geology or make geological investigations in the field; to discourse as a geologist.","pos":""}],"GEOLOGY":[{"def":"The science which treats: (a) Of the structure and mineral constitution of the globe; structural geology.","pos":""},{"def":"A treatise on the science.","pos":""}],"GEOMALISM":[{"def":"The tendency of an organism to respond, during its growth, to the force of gravitation.","pos":""}],"GEOMANCER":[{"def":"One who practices, or is versed in, geomancy.","pos":""}],"GEOMANCY":[{"def":"A kind of divination by means of figures or lines, formed by little dots or points, originally on the earth, and latterly on paper.","pos":""},{"def":"Pertaining or belonging to geomancy.","pos":""}],"GEOMETER":[{"def":"Any species of geometrid moth; a geometrid.","pos":""}],"GEOMETRAL":[{"def":"Pertaining to geometry.","pos":""},{"def":"Pertaining to, or according to the rules or principles of, geometry; determined by geometry; as, a geometrical solution of a problem.","pos":""}],"GEOMETRICALLY":[{"def":"According to the rules or laws of geometry.","pos":""}],"GEOMETRICIAN":[{"def":"One skilled in geometry; a geometer; a mathematician.","pos":""}],"GEOMETRID":[{"def":"Pertaining or belonging to the Geometridæ.","pos":""}],"GEOMETRIZE":[{"def":"To investigate or apprehend geometrical quantities or laws; to make geometrical constructions; to proceed in accordance with the principles of geometry.","pos":""}],"GEOMETRY":[{"def":"That branch of mathematics which investigates the relations, properties, and measurement of solids, surfaces, lines, and angles; the science which treats of the properties and relations of magnitudes; the science of the relations of space.","pos":""},{"def":"A treatise on this science.","pos":""}],"GEOPHAGISM":[{"def":"The act or habit of eating earth.","pos":""}],"GEOPHAGIST":[{"def":"One who eats earth, as dirt, clay, chalk, etc.","pos":""}],"GEOPHILA":[{"def":"The division of Mollusca which includes the land snails and slugs.","pos":""},{"def":"Pertaining to tillage of the earth, or agriculture.","pos":""}],"GEOPONICS":[{"def":"The art or science of cultivating the earth; agriculture.","pos":""}],"GEORAMA":[{"def":"A hollow globe on the inner surface of which a map of the world is depicted, to be examined by one standing inside.","pos":""}],"GEORDIE":[{"def":"A name given by miners to George Stephenson's safety lamp.","pos":""}],"GEORGE":[{"def":"A kind of brown loaf.","pos":""}],"GEORGE NOBLE":[{"def":"A gold noble of the time of Henry VIII.","pos":""}],"GEORGIAN":[{"def":"Of or pertaining to Georgia, in Asia, or to Georgia, one of the United States.","pos":""},{"def":"Of or relating to the reigns of the four Georges, kings of Great Britan; as, the Georgian era.","pos":""}],"GEORGIAN ARCHITECTURE":[{"def":"British or British colonial architecture of the period of the four Georges, especially that of the period before 1800.","pos":""}],"GEORGIC":[{"def":"A rural poem; a poetical composition on husbandry, containing rules for cultivating lands, etc.","pos":""},{"def":"Relating to agriculture and rural affairs.","pos":""}],"GEORGIUM SIDUS":[{"def":"The planet Uranus, so named by its discoverer, Sir W.","pos":""}],"GEOSCOPY":[{"def":"Knowledge of the earth, ground, or soil, obtained by inspection.","pos":""}],"GEOSELENIC":[{"def":"Pertaining to the earth and moon; belonging to the joint action or mutual relations of the earth and moon; as, geoselenic phenomena.","pos":""}],"GEOSTATIC":[{"def":"Relating to the pressure exerted by earth or similar substance.","pos":""}],"GEOSYNCLINAL":[{"def":"the downward bend or subsidence of the earth's crust, which allows of the gradual accumulation of sediment, and hence forms the first step in the making of a mountain range; -- opposed to geanticlinal.","pos":""}],"GEOTHERMOMETER":[{"def":"A thermometer specially constructed for measuring temperetures at a depth below the surface of the ground.","pos":""}],"GEOTIC":[{"def":"Belonging to earth; terrestrial.","pos":""}],"GEOTROPIC":[{"def":"Relating to, or showing, geotropism.","pos":""}],"GEOTROPISM":[{"def":"A disposition to turn or incline towards the earth; the influence of gravity in determining the direction of growth of an organ.","pos":""}]}