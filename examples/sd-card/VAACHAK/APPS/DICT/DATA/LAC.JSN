{"LAC":[{"def":"A resinous substance produced mainly on the banyan tree, but to some extent on other trees, by the Coccus lacca, a scale-shaped insect, the female of which fixes herself on the bark, and exudes from the margin of her body this resinous substance.","pos":""}],"LACCIC":[{"def":"Pertaining to lac, or produced from it; as, laccic acid.","pos":""}],"LACCIN":[{"def":"A yellow amorphous substance obtained from lac.","pos":""},{"def":"A mass of igneous rock intruded between sedimentary beds and resulting in a mammiform bulging of the overlying strata.","pos":""}],"LACE":[{"def":"That which binds or holds, especially by being interwoven; a string, cord, or band, usually one passing through eyelet or other holes, and used in drawing and holding together parts of a garment, of a shoe, of a machine belt, etc.","pos":""},{"def":"A snare or gin, especially one made of interwoven cords; a net.","pos":""}],"LACE-BARK":[{"def":"A shrub in the West Indies (Lagetta Iintearia); -- so called from the lacelike layers of its inner bark.","pos":""}],"LACE-WINGED":[{"def":"Having thin, transparent, reticulated wings; as, the lace- winged flies.","pos":""},{"def":"Neglect; negligence; remissness; neglect to do a thing at the proper time; delay to assert a claim.","pos":""}],"LACED":[{"def":"Fastened with a lace or laces; decorated with narrow strips or braid.","pos":""},{"def":"Decorated with the fabric lace.","pos":""}],"LACEDAEMONIAN":[{"def":"Of or pertaining to Lacedæmon or Sparta, the chief city of Laconia in the Peloponnesus.","pos":""}],"LACEMAN":[{"def":"A man who deals in lace.","pos":""}],"LACERABLE":[{"def":"That can be lacerated or torn.","pos":""}],"LACERATE":[{"def":"To tear; to rend; to separate by tearing; to mangle; as, to lacerate the flesh.","pos":""},{"def":"Jagged, or slashed irregularly, at the end, or along the edge.","pos":""}],"LACERATION":[{"def":"The act of lacerating.","pos":""},{"def":"A breach or wound made by lacerating.","pos":""}],"LACERATIVE":[{"def":"Lacerating, or having the power to lacerate; as, lacerative humors.","pos":""}],"LACERT":[{"def":"A muscle of the human body.","pos":""}],"LACERTA":[{"def":"A genus of lizards.","pos":""},{"def":"The Lizard, a northern constellation.","pos":""}],"LACERTIAN":[{"def":"Like a lizard; of or pertaining to the Lacertilia.","pos":""},{"def":"One of the Lacertilia.","pos":""}],"LACERTILIA":[{"def":"An order of Reptilia, which includes the lizards.","pos":""}],"LACERTILIAN":[{"def":"Same as Lacertian.","pos":""}],"LACERTILOID":[{"def":"Like or belonging to the Lacertilia.","pos":""}],"LACERTUS":[{"def":"A bundle or fascicle of muscular fibers.","pos":""}],"LACEWING":[{"def":"Any one of several species of neuropterous insects of the genus Chrysopa and allied genera.","pos":""}],"LACHRYMAE CHRISTI":[{"def":"A rich, sweet, red Neapolitan wine.","pos":""}],"LACHRYMAL":[{"def":"Of or pertaining to tears; as, lachrymal effusions.","pos":""}],"LACHRYMALS":[{"def":"Tears; also, lachrymal feelings or organs.","pos":""}],"LACHRYMARY":[{"def":"Containing, or intended to contain, tears; lachrymal.","pos":""}],"LACHRYMATE":[{"def":"Lach\"ry*mate (-mat), v.","pos":""}],"LACHRYMATION":[{"def":"The act of shedding tears; weeping.","pos":""}],"LACHRYMATORY":[{"def":"A \"tear-bottle;\" a narrow-necked vessel found in sepulchers of the ancient Romans; -- so called from a former notion that the tears of the deceased person's friends were collected in it.","pos":""}],"LACHRYMIFORM":[{"def":"Having the form of a tear; tear-shaped.","pos":""}],"LACHRYMOSE":[{"def":"Generating or shedding tears; given to shedding tears; suffused with tears; tearful.","pos":""}],"LACING":[{"def":"A system of bracing bars, not crossing each other in the middle, connecting the channel bars of a compound strut.","pos":""}],"LACINIA":[{"def":"The posterior, inner process of the stipes on the maxillæ of insects.","pos":""},{"def":"Cut into deep, narrow, irregular lobes; slashed.","pos":""}],"LACINIOLATE":[{"def":"Consisting of, or abounding in, very minute laciniæ.","pos":""}],"LACINULA":[{"def":"A diminutive lacinia.","pos":""}],"LACK":[{"def":"Blame; cause of blame; fault; crime; offense.","pos":""},{"def":"Deficiency; want; need; destitution; failure; as, a lack of sufficient food.","pos":""}],"LACKADAISICAL":[{"def":"Affectedly pensive; languidly sentimental.","pos":""}],"LACKADAISY":[{"def":"An expression of languor.","pos":""}],"LACKADAY":[{"def":"Alack the day; alas; -- an expression of sorrow, regret, dissatisfaction, or surprise.","pos":""}],"LACKBRAIN":[{"def":"One who is deficient in understanding; a witless person.","pos":""}],"LACKER":[{"def":"One who lacks or is in want.","pos":""}],"LACKEY":[{"def":"An attending male servant; a footman; a servile follower.","pos":""}],"LACONIAN":[{"def":"Of or pertaining to Laconia, a division of ancient Greece; Spartan.","pos":""},{"def":"An inhabitant of Laconia; esp.","pos":""}],"LACONICALLY":[{"def":"In a laconic manner.","pos":""}],"LACONICISM":[{"def":"Same as Laconism.","pos":""}],"LACONISM":[{"def":"A vigorous, brief manner of expression; laconic style.","pos":""},{"def":"An instance of laconic style or expression.","pos":""}],"LACONIZE":[{"def":"To imitate the manner of the Laconians, especially in brief, pithy speech, or in frugality and austerity.","pos":""}],"LACQUER":[{"def":"A varnish, consisting of a solution of shell-lac in alcohol, often colored with gamboge, saffron, or the like; -- used for varnishing metals, papier-maché, and wood.","pos":""}],"LACQUERER":[{"def":"One who lacquers, especially one who makes a business of lacquering.","pos":""}],"LACQUERING":[{"def":"The act or business of putting on lacquer; also, the coat of lacquer put on.","pos":""}],"LACRIMOSO":[{"def":"Plaintive; -- a term applied to a mournful or pathetic movement or style.","pos":""}],"LACROSSE":[{"def":"A game of ball, originating among the North American Indians, now the popular field sport of Canada, and played also in England and the United States.","pos":""}],"LACRYMAL":[{"def":"See Lachrymatory, n.","pos":""},{"def":"See Lachrymary, Lachrymatory, Lachrymose.","pos":""}],"LACTAGE":[{"def":"The produce of animals yielding milk; milk and that which is made from it.","pos":""}],"LACTAM":[{"def":"One of a series of anhydrides of an amido type, analogous to the lactones, as oxindol.","pos":""}],"LACTAMIC":[{"def":"Pertaining to, or designating, an amido acid related to lactic acid, and called also amido-propionic acid.","pos":""}],"LACTAMIDE":[{"def":"An acid amide derived from lactic acid, and obtained as a white crystalline substance having a neutral reaction.","pos":""}],"LACTANT":[{"def":"Suckling; giving suck.","pos":""}],"LACTARENE":[{"def":"A preparation of casein from milk, used in printing calico.","pos":""}],"LACTARY":[{"def":"Milky; full of white juice like milk.","pos":""}],"LACTATE":[{"def":"A salt of lactic acid.","pos":""}],"LACTATION":[{"def":"A giving suck; the secretion and yielding of milk by the mammary gland.","pos":""}],"LACTEAL":[{"def":"Pertaining to, or containing, chyle; as, the lacteal vessels.","pos":""}],"LACTEALLY":[{"def":"Milkily; in the manner of milk.","pos":""}],"LACTEAN":[{"def":"Lacteal; conveying chyle.","pos":""}],"LACTEOUS":[{"def":"Milky; resembling milk.","pos":""},{"def":"Lacteal; conveying chyle; as, lacteous vessels.","pos":""}],"LACTEOUSLY":[{"def":"In a lacteous manner; after the manner of milk.","pos":""}],"LACTESCENCE":[{"def":"The latex of certain plants.","pos":""}],"LACTESCENT":[{"def":"Producing milk or a milklike juice or fluid, as the milkweed.","pos":""}],"LACTIC":[{"def":"Of or pertaining to milk; procured from sour milk or whey; as, lactic acid; lactic fermentation, etc.","pos":""}],"LACTIDE":[{"def":"A white, crystalline substance, obtained from also, by extension, any similar substance.","pos":""}],"LACTIFEROUS":[{"def":"Bearing or containing milk or a milky fluid; as, the lactiferous vessels, cells, or tissue of various vascular plants.","pos":""},{"def":"Producing or yielding milk.","pos":""}],"LACTIFUGE":[{"def":"A medicine to check the secretion of milk, or to dispel a supposed accumulation of milk in any part of the body.","pos":""}],"LACTIM":[{"def":"One of a series of anhydrides resembling the lactams, but of an imido type; as, isatine is a lactim.","pos":""}],"LACTIMIDE":[{"def":"A white, crystalline substance obtained as an anhydride of alanine, and regarded as an imido derivative of lactic acid.","pos":""}],"LACTOABUMIN":[{"def":"The albumin present on milk, apparently identical with ordinary serum albumin.","pos":""}],"LACTOBUTYROMETER":[{"def":"An instrument for determining the amount of butter fat contained in a given sample of milk.","pos":""}],"LACTODENSIMETER":[{"def":"A form of hydrometer, specially graduated, for finding the density of milk, and thus discovering whether it has been mixed with water or some of the cream has been removed.","pos":""}],"LACTOMETER":[{"def":"An instrument for estimating the purity or richness of milk, as a measuring glass, a specific gravity bulb, or other apparatus.","pos":""}],"LACTONE":[{"def":"One of a series of organic compounds, regarded as anhydrides of certain hydroxy acids.","pos":""}],"LACTONIC":[{"def":"Of, pertaining to, or derived from, lactone.","pos":""}],"LACTOPROTEIN":[{"def":"A peculiar albuminous body considered a normal constituent of milk.","pos":""}],"LACTOSCOPE":[{"def":"An instrument for estimating the amount of cream contained in milk by ascertaining its relative opacity.","pos":""}],"LACTOSE":[{"def":"Sugar of milk or milk sugar; a crystalline sugar present in milk, and separable from the whey by evaporation and crystallization.","pos":""}],"LACTUCA":[{"def":"A genus of composite herbs, several of which are cultivated foe salad; lettuce.","pos":""}],"LACTUCARIUM":[{"def":"The inspissated juice of the common lettuce, sometimes used as a substitute for opium.","pos":""}],"LACTUCIC":[{"def":"Pertaining to, or derived from, the juice of the Lactuca virosa; -- said of certain acids.","pos":""}],"LACTUCIN":[{"def":"A white, crystalline substance, having a bitter taste and a neutral reaction, and forming one of the essential ingredients of lactucarium.","pos":""}],"LACTUCONE":[{"def":"A white, crystalline, tasteless substance, found in the milky sap of species of Lactuca, and constituting an essential ingredient of lactucarium.","pos":""}],"LACTURAMIC":[{"def":"Pertaining to, or designating, an organic amido acid, which is regarded as a derivative of lactic acid and urea.","pos":""}],"LACTYL":[{"def":"An organic residue or radical derived from lactic acid.","pos":""}],"LACUNA":[{"def":"Pertaining to, or having, lacunæ; as, a lacunar circulation.","pos":""}],"LACUNE":[{"def":"Furrowed or pitted; having shallow cavities or lacunæ; as, a lacunose leaf.","pos":""}],"LACWORK":[{"def":"Ornamentation by means of lacquer painted or carved, or simply colored, sprinkled with gold or the like; -- said especially of Oriental work of this kind.","pos":""}]}