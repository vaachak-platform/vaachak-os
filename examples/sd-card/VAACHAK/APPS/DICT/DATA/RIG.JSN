{"RIG":[{"def":"To furnish with apparatus or gear; to fit with tackling.","pos":""},{"def":"To dress; to equip; to clothe, especially in an odd or fanciful manner; -- commonly followed by out.","pos":""}],"RIGA FIR":[{"def":"A species of pine (Pinus sylvestris), and its wood, which affords a valuable timber; -- called also Scotch pine, and red or yellow deal.","pos":""}],"RIGADOON":[{"def":"A gay, lively dance for one couple, -- said to have been borrowed from Provence in France.","pos":""}],"RIGEL":[{"def":"A fixed star of the first magnitude in the left foot of the constellation Orion.","pos":""}],"RIGESCENT":[{"def":"Growing stiff or numb.","pos":""}],"RIGGER":[{"def":"One who rigs or dresses; one whose occupation is to fit the rigging of a ship.","pos":""},{"def":"A cylindrical pulley or drum in machinery.","pos":""}],"RIGGING":[{"def":"DRess; tackle; especially (Naut.","pos":""}],"RIGGISH":[{"def":"Like a rig or wanton.","pos":""}],"RIGGLE":[{"def":"The European lance fish.","pos":""}],"RIGHT":[{"def":"Straight; direct; not crooked; as, a right line.","pos":""},{"def":"Upright; erect from a base; having an upright axis; not oblique; as, right ascension; a right pyramid or cone.","pos":""}],"RIGHT WHALE":[{"def":"Atlantic, or Biscay, right whale (Balæna cisarctica), and the Pacific right whale (B.","pos":""}],"RIGHT-ABOUT":[{"def":"A turning directly about by the right, so as to face in the opposite direction; also, the quarter directly opposite; as, to turn to the right-about.","pos":""}],"RIGHT-ANGLED":[{"def":"Containing a right angle or right angles; as, a right-angled triangle.","pos":""}],"RIGHT-HAND":[{"def":"Situated or being on the right; nearer the right hand than the left; as, the right-hand side, room, or road.","pos":""},{"def":"Chiefly relied on; almost indispensable.","pos":""}],"RIGHT-HANDED":[{"def":"Having the whorls rising from left to right; dextral; -- said of spiral shells.","pos":""}],"RIGHT-HANDEDNESS":[{"def":"The state or quality of being right-handed; hence, skill; dexterity.","pos":""}],"RIGHT-HEARTED":[{"def":"Having a right heart or disposition.","pos":""}],"RIGHT-LINED":[{"def":"Formed by right lines; rectilineal; as, a right-lined angle.","pos":""}],"RIGHT-MINDED":[{"def":"Having a right or honest mind.","pos":""}],"RIGHT-RUNNING":[{"def":"Straight; direct.","pos":""}],"RIGHTEN":[{"def":"To do justice to.","pos":""}],"RIGHTEOUS":[{"def":"Doing, or according with, that which is right; yielding to all their due; just; equitable; especially, free from wrong, guilt, or sin; holy; as, a righteous man or act; a righteous retribution.","pos":""}],"RIGHTEOUSLY":[{"def":"In a righteous manner; as, to judge righteously.","pos":""}],"RIGHTEOUSNESS":[{"def":"The state of being right with God; justification; the work of Christ, which is the ground justification.","pos":""}],"RIGHTER":[{"def":"One who sets right; one who does justice or redresses wrong.","pos":""}],"RIGHTFUL":[{"def":"Righteous; upright; just; good; -- said of persons.","pos":""},{"def":"Consonant to justice; just; as, a rightful cause.","pos":""}],"RIGHTFULLY":[{"def":"According to right or justice.","pos":""}],"RIGHTFULNESS":[{"def":"The quality or state of being rightful; accordance with right and justice.","pos":""},{"def":"Moral rectitude; righteousness.","pos":""}],"RIGHTLESS":[{"def":"Destitute of right.","pos":""}],"RIGHTLY":[{"def":"Straightly; directly; in front.","pos":""},{"def":"According to justice; according to the divine will or moral rectitude; uprightly; as, duty rightly performed.","pos":""}],"RIGHTNESS":[{"def":"Straightness; as, the rightness of a line.","pos":""}],"RIGHTWARD":[{"def":"Toward the right.","pos":""}],"RIGHTWISE":[{"def":"To make righteous.","pos":""}],"RIGHTWISENESS":[{"def":"In doom and eke in rightwisnesse.","pos":""}],"RIGID":[{"def":"Firm; stiff; unyielding; not pliant; not flexible.","pos":""},{"def":"Hence, not lax or indulgent; severe; inflexible; strict; as, a rigid father or master; rigid discipline; rigid criticism; a rigid sentence.","pos":""}],"RIGIDITY":[{"def":"The quality or state of being rigid; want of pliability; the quality of resisting change of from; the amount of resistance with which a body opposes change of form; -- opposed to flexibility, ductility, malleability, and softness.","pos":""},{"def":"Stiffness of appearance or manner; want of ease or elegance.","pos":""}],"RIGIDLY":[{"def":"In a rigid manner; stiffly.","pos":""}],"RIGIDNESS":[{"def":"The quality or state of being rigid.","pos":""}],"RIGIDULOUS":[{"def":"Somewhat rigid or stiff; as, a rigidulous bristle.","pos":""}],"RIGMAROLE":[{"def":"A succession of confused or nonsencial statements; foolish talk; nonsense.","pos":""}],"RIGOL":[{"def":"A circle; hence, a diadem.","pos":""}],"RIGOLETTE":[{"def":"A woman's light scarflike head covering, usually knit or crocheted of wool.","pos":""}],"RIGOLL":[{"def":"A musical instrument formerly in use, consisting of several sticks bound together, but separated by beads, and played with a stick with a ball at its end.","pos":""}],"RIGOR":[{"def":"A sense of chilliness, with contraction of the skin; a convulsive shuddering or tremor, as in the chill preceeding a fever.","pos":""}],"RIGORISM":[{"def":"Rigidity in principle or practice; strictness; -- opposed to laxity.","pos":""},{"def":"Severity, as of style, or the like.","pos":""}],"RIGORIST":[{"def":"One who is rigorous; -- sometimes applied to an extreme Jansenist.","pos":""}],"RIGOROUS":[{"def":"Manifesting, exercising, or favoring rigor; allowing no abatement or mitigation; scrupulously accurate; exact; strict; severe; relentless; as, a rigorous officer of justice; a rigorous execution of law; a rigorous definition or demonstration.","pos":""},{"def":"Severe; intense; inclement; as, a rigorous winter.","pos":""}],"RIGSDAG":[{"def":"See Legislature, Denmark.","pos":""}],"RIGSDALER":[{"def":"A Danish coin worth about fifty-four cents.","pos":""}]}