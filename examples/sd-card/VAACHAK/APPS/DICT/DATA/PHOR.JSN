{"PHORMINX":[{"def":"A kind of lyre used by the Greeks.","pos":""}],"PHORMIUM":[{"def":"A genus of liliaceous plants, consisting of one species (Phormium tenax).","pos":""}],"PHORONE":[{"def":"A yellow crystalline substance, having a geraniumlike odor, regarded as a complex derivative of acetone, and obtained from certain camphor compounds.","pos":""}],"PHORONIS":[{"def":"A remarkable genus of marine worms having tentacles around the mouth.","pos":""}],"PHORONOMIA":[{"def":"See Phoronomics.","pos":""}],"PHORONOMICS":[{"def":"The science of motion; kinematics.","pos":""}]}