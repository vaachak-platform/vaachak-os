{"BAC":[{"def":"A broad, flatbottomed ferryboat, usually worked by a rope.","pos":""},{"def":"A vat or cistern.","pos":""}],"BACCALAUREATE":[{"def":"The degree of bachelor of arts.","pos":""},{"def":"A baccalaureate sermon.","pos":""}],"BACCATE":[{"def":"Pulpy throughout, like a berry; -- said of fruits.","pos":""}],"BACCATED":[{"def":"Having many berries.","pos":""},{"def":"Set or adorned with pearls.","pos":""}],"BACCHANAL":[{"def":"Relating to Bacchus or his festival.","pos":""},{"def":"Engaged in drunken revels; drunken and riotous or noisy.","pos":""}],"BACCHANALIA":[{"def":"A feast or an orgy in honor of Bacchus.","pos":""}],"BACCHANALIAN":[{"def":"Of or pertaining to the festival of Bacchus; relating to or given to reveling and drunkenness.","pos":""}],"BACCHANALIANISM":[{"def":"The practice of bacchanalians; bacchanals; drunken revelry.","pos":""}],"BACCHANT":[{"def":"A priest of Bacchus.","pos":""},{"def":"A bacchanal; a reveler.","pos":""}],"BACCHANTE":[{"def":"A priestess of Bacchus.","pos":""},{"def":"A female bacchanal.","pos":""}],"BACCHANTIC":[{"def":"Of or relating to Bacchus; hence, jovial, or riotous,with intoxication.","pos":""}],"BACCHIUS":[{"def":"A metrical foot composed of a short syllable and two long ones; according to some, two long and a short.","pos":""}],"BACCHUS":[{"def":"The god of wine, son of Jupiter and Semele.","pos":""}],"BACCIFEROUS":[{"def":"Producing berries.","pos":""}],"BACCIFORM":[{"def":"Having the form of a berry.","pos":""}],"BACCIVOROUS":[{"def":"Eating, or subsisting on, berries; as, baccivorous birds.","pos":""}],"BACE":[{"def":"A kind of wine made at Bacharach on the Rhine.","pos":""}],"BACHELOR":[{"def":"A kind of bass, an edible fresh-water fish (Pomoxys annularis) of the southern United States.","pos":""}],"BACHELOR'S BUTTON":[{"def":"Bach\"e*lor's but\"ton Defn: , (Bot.","pos":""}],"BACHELORDOM":[{"def":"The state of bachelorhood; the whole body of bachelors.","pos":""}],"BACHELORHOOD":[{"def":"The state or condition of being a bachelor; bachelorship.","pos":""}],"BACHELORISM":[{"def":"Bachelorhood; also, a manner or peculiarity belonging to bachelors.","pos":""}],"BACHELORSHIP":[{"def":"The state of being a bachelor.","pos":""}],"BACHELRY":[{"def":"The body of young aspirants for knighthood.","pos":""}],"BACILLAR":[{"def":"Shaped like a rod or staff.","pos":""}],"BACILLARY":[{"def":"Of or pertaining to little rods; rod-shaped.","pos":""}],"BACILLUS":[{"def":"A variety of bacterium; a microscopic, rod-shaped vegetable organism.","pos":""}],"BACK":[{"def":"A large shallow vat; a cistern, tub, or trough, used by brewers, distillers, dyers, picklers, gluemakers, and others, for mixing or cooling wort, holding water, hot glue, etc.","pos":""}],"BACK DOOR":[{"def":"A door in the back part of a building; hence, an indirect way.","pos":""}],"BACK STAIRS":[{"def":"Stairs in the back part of a house, as distinguished from the front stairs; hence, a private or indirect way.","pos":""},{"def":"Private; indirect; secret; intriguing; as if finding access by the back stairs.","pos":""}],"BACK-FIRE":[{"def":"To have or experience a back fire or back fires; -- said of an internal-combustion engine.","pos":""}],"BACKARE":[{"def":"Same as Baccare.","pos":""}],"BACKBAND":[{"def":"The band which passes over the back of a horse and holds up the shafts of a carriage.","pos":""}],"BACKBITE":[{"def":"To wound by clandestine detraction; to censure meanly or spitefully (as absent person); to slander or speak evil of (one absent).","pos":""}],"BACKBITER":[{"def":"One who backbites; a secret calumniator or detractor.","pos":""}],"BACKBITING":[{"def":"Secret slander; detraction.","pos":""}],"BACKBOARD":[{"def":"A board which supports the back wen one is sitting; Note: specifically, the board athwart the after part of a boat.","pos":""},{"def":"A board serving as the back part of anything, as of a wagon.","pos":""}],"BACKBOND":[{"def":"An instrument which, in conjunction with another making an absolute disposition, constitutes a trust.","pos":""}],"BACKBONE":[{"def":"The column of bones in the back which sustains and gives firmness to the frame; the spine; the vertebral or spinal column.","pos":""},{"def":"Anything like , or serving the purpose of, a backbone.","pos":""}],"BACKCAST":[{"def":"Anything which brings misfortune upon one, or causes failure in an effort or enterprise; a reverse.","pos":""}],"BACKDOOR":[{"def":"Acting from behind and in concealment; as backdoor intrigues.","pos":""}],"BACKDOWN":[{"def":"A receding or giving up; a complete surrender.","pos":""}],"BACKED":[{"def":"Having a back; fitted with a back; as, a backed electrotype or stereotype plate.","pos":""}],"BACKER":[{"def":"One who, or that which, backs; especially one who backs a person or thing in a contest.","pos":""}],"BACKFALL":[{"def":"A fall or throw on the back in wrestling.","pos":""}],"BACKGAMMON":[{"def":"A game of chance and skill, played by two persons on a \"board\" marked off into twenty-four spaces called \"points\".","pos":""}],"BACKGROUND":[{"def":"The space which is behind and subordinate to a portrait or group of figures.","pos":""}],"BACKHAND":[{"def":"A kind of handwriting in which the downward slope of the letters is from left to right.","pos":""}],"BACKHANDED":[{"def":"With the hand turned backward; as, a backhanded blow.","pos":""},{"def":"Indirect; awkward; insincere; sarcastic; as, a backhanded compliment.","pos":""}],"BACKHANDEDNESS":[{"def":"State of being backhanded; the using of backhanded or indirect methods.","pos":""}],"BACKHANDER":[{"def":"A backhanded blow.","pos":""}],"BACKHEEL":[{"def":"A method of tripping by getting the leg back of the opponent's heel on the outside and pulling forward while pushing his body back; a throw made in this way.","pos":""},{"def":"To trip (a person) in this way.","pos":""}],"BACKHOUSE":[{"def":"A building behind the main building.","pos":""}],"BACKING":[{"def":"The preparation of the back of a book with glue, etc.","pos":""}],"BACKJOINT":[{"def":"A rebate or chase in masonry left to receive a permanent slab or other filling.","pos":""}],"BACKLOG":[{"def":"A large stick of wood, forming the of a fire on the hearth.","pos":""},{"def":"A piece, or plate which forms the back of anything, or which covers the back; armor for the back.","pos":""}],"BACKS":[{"def":"Among leather dealers, the thickest and stoutest tanned hides.","pos":""}],"BACKSAW":[{"def":"A saw (as a tenon saw) whose blade is stiffened by an added metallic back.","pos":""}],"BACKSET":[{"def":"A check; a relapse; a discouragement; a setback.","pos":""},{"def":"Whatever is thrown back in its course, as water.","pos":""}],"BACKSETTLER":[{"def":"One living in the back or outlying districts of a community.","pos":""},{"def":"In Egypt and the Turkish empire, a gratuity; a \"tip\".","pos":""}],"BACKSIDE":[{"def":"The hinder part, posteriors, or rump of a person or animal.","pos":""}],"BACKSIGHT":[{"def":"The reading of the leveling staff in its unchanged position when the leveling instrument has been taken to a new position; a sight directed backwards to a station previously occupied.","pos":""}],"BACKSLIDE":[{"def":"To slide back; to fall away; esp.","pos":""}],"BACKSLIDER":[{"def":"One who backslides.","pos":""}],"BACKSLIDING":[{"def":"Slipping back; falling back into sin or error; sinning.","pos":""}],"BACKSTAFF":[{"def":"An instrument formerly used for taking the altitude of the heavenly bodies, but now superseded by the quadrant and sextant; -- so called because the observer turned his back to the body observed.","pos":""}],"BACKSTAY":[{"def":"A rope or stay extending from the masthead to the side of a ship, slanting a little aft, to assist the shrouds in supporting the mast.","pos":""}],"BACKSTITCH":[{"def":"A stitch made by setting the needle back of the end of the last stitch, and bringing it out in front of the end.","pos":""}],"BACKSTOP":[{"def":"In baseball, a fence, prop.","pos":""},{"def":"In rounders, the player who stands immediately behind the striking base.","pos":""}],"BACKSWORD":[{"def":"A sword with one sharp edge.","pos":""},{"def":"In England, a stick with a basket handle, used in rustic amusements; also, the game in which the stick is used.","pos":""}],"BACKWARD":[{"def":"Directed to the back or rear; as, backward glances.","pos":""},{"def":"Unwilling; averse; reluctant; hesitating; loath.","pos":""}],"BACKWARDATION":[{"def":"The seller's postponement of delivery of stock or shares, with the consent of the buyer, upon payment of a premium to the latter; -- also, the premium so paid.","pos":"verb"}],"BACKWARDLY":[{"def":"Reluctantly; slowly; aversely.","pos":""},{"def":"Perversely; ill.","pos":""}],"BACKWARDNESS":[{"def":"The state of being backward.","pos":""}],"BACKWASH":[{"def":"To clean the oil from (wood) after combing.","pos":""}],"BACKWATER":[{"def":"Water turned back in its course by an obstruction, an opposing current , or the flow of the tide, as in a sewer or river channel, or across a river bar.","pos":""},{"def":"An accumulation of water overflowing the low lands, caused by an obstruction.","pos":""}],"BACKWOODS":[{"def":"The forests or partly cleared grounds on the frontiers.","pos":""}],"BACKWOODSMAN":[{"def":"A men living in the forest in or beyond the new settlements, especially on the western frontiers of the older portions of the United States.","pos":""}],"BACKWORM":[{"def":"A disease of hawks.","pos":""}],"BACON":[{"def":"The back and sides of a pig salted and smoked; formerly, the flesh of a pig salted or fresh.","pos":""}],"BACONIAN":[{"def":"Of or pertaining to Lord Bacon, or to his system of philosophy.","pos":""}],"BACTERIAL":[{"def":"Of or pertaining to bacteria.","pos":""}],"BACTERICIDAL":[{"def":"Destructive of bacteria.","pos":""}],"BACTERICIDE":[{"def":"Same as Germicide.","pos":""}],"BACTERIN":[{"def":"A bacterial vaccine.","pos":""}],"BACTERIOLOGICAL":[{"def":"Of or pertaining to bacteriology; as, bacteriological studies.","pos":""}],"BACTERIOLOGIST":[{"def":"One skilled in bacteriology.","pos":""}],"BACTERIOLOGY":[{"def":"The science relating to bacteria.","pos":""}],"BACTERIOLYSIS":[{"def":"Chemical decomposition brought about by bacteria without the addition of oxygen.","pos":""},{"def":"The destruction or dissolution of bacterial cells.","pos":""}],"BACTERIOSCOPIC":[{"def":"Relating to bacterioscopy; as, a bacterioscopic examination.","pos":""}],"BACTERIOSCOPIST":[{"def":"One skilled in bacterioscopic examinations.","pos":""}],"BACTERIOSCOPY":[{"def":"The application of a knowledge of bacteria for their detection and identification, as in the examination of polluted water.","pos":""}],"BACTERIUM":[{"def":"A microscopic vegetable organism, belonging to the class Algæ, usually in the form of a jointed rodlike filament, and found in putrefying organic infusions.","pos":""},{"def":"Resembling bacteria; as, bacteroid particles.","pos":""}],"BACTRIAN":[{"def":"Of or pertaining to Bactria in Asia.","pos":""},{"def":"A native of Bactria.","pos":""}],"BACULINE":[{"def":"Of or pertaining to the rod or punishment with the rod.","pos":""}],"BACULITE":[{"def":"A cephalopod of the extinct genus Baculites, found fossil in the Cretaceous rocks.","pos":""}],"BACULOMETRY":[{"def":"Measurement of distance or altitude by a staff or staffs.","pos":""}]}