{"OVERCANOPY":[{"def":"To cover as with a canopy.","pos":""}],"OVERCAPABLE":[{"def":"Overcapable of such pleasing errors.","pos":""}],"OVERCARKING":[{"def":"Too anxious; too full of care.","pos":""}],"OVERCARRY":[{"def":"To carry too far; to carry beyond the proper point.","pos":""}],"OVERCAST":[{"def":"To take long, loose stitches over (the raw edges of a seam) to prevent raveling.","pos":""}],"OVERCAUTIOUS":[{"def":"Too cautious; cautious or prudent to excess.","pos":""}],"OVERCHANGE":[{"def":"Too much or too frequent change; fickleness.","pos":""}],"OVERCHARGE":[{"def":"To charge or load too heavily; to burden; to oppress; to cloy.","pos":""},{"def":"To fill too full; to crowd.","pos":""}],"OVERCLOUD":[{"def":"To cover or overspread with clouds; to becloud; to overcast.","pos":""}],"OVERCLOY":[{"def":"To fill beyond satiety.","pos":""}],"OVERCOAT":[{"def":"A coat worn over the other clothing; a greatcoat; a topcoat.","pos":""}],"OVERCOLOR":[{"def":"To color too highly.","pos":""}],"OVERCOME":[{"def":"To get the better of; to surmount; to conquer; to subdue; as, to overcome enemies in battle.","pos":""},{"def":"To overflow; to surcharge.","pos":""}],"OVERCOMER":[{"def":"One who overcomes.","pos":""}],"OVERCOMING":[{"def":"Conquering; subduing.","pos":""}],"OVERCONFIDENCE":[{"def":"Excessive confidence; too great reliance or trust.","pos":""}],"OVERCONFIDENT":[{"def":"Confident to excess.","pos":""}],"OVERCOUNT":[{"def":"To rate too high; to outnumber.","pos":""}],"OVERCROW":[{"def":"To crow, exult, or boast, over; to overpower.","pos":""}],"OVERCROWD":[{"def":"To crowd too much.","pos":""}],"OVERCUNNING":[{"def":"Exceedingly or excessively cunning.","pos":""}]}