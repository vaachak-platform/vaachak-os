{"PROVABLE":[{"def":"Capable of being proved; demonstrable.","pos":""},{"def":"Provender or food.","pos":""}],"PROVANT":[{"def":"To supply with provender or provisions; to provide for.","pos":""}],"PROVE":[{"def":"To test, evince, ascertain, or verify, as the correctness of any operation or result; thus, in subtraction, if the difference between two numbers, added to the lesser number, makes a sum equal to the greater, the correctness of the subtraction is proved.","pos":""},{"def":"To take a trial impression of; to take a proof of; as, to prove a page.","pos":""}],"PROVECT":[{"def":"Carried forward; advanced.","pos":""}],"PROVECTION":[{"def":"A carrying forward, as of a final letter, to a following word; as, for example, a nickname for an ekename.","pos":""}],"PROVEDITOR":[{"def":"One employed to procure supplies, as for an army, a steamer, etc.","pos":""}],"PROVEDORE":[{"def":"A proveditor; a purveyor.","pos":""}],"PROVEN":[{"def":"Of this which was the principal charge, and was generally believed to beproven, he was acquitted.","pos":""}],"PROVENANCE":[{"def":"Origin; source; provenience.","pos":""}],"PROVENCAL":[{"def":"Of or pertaining to Provence or its inhabitants.","pos":""}],"PROVENCIAL":[{"def":"Of or pertaining to Provence in France.","pos":""}],"PROVENDER":[{"def":"Dry food for domestic animals, as hay, straw, corn, oats, or a mixture of ground grain; feed.","pos":""},{"def":"Food or provisions.","pos":""}],"PROVENIENCE":[{"def":"Origin; source; place where found or produced; provenance; -- used esp.","pos":""}],"PROVENIENT":[{"def":"Forthcoming; issuing.","pos":""}],"PROVENTRIULUS":[{"def":"The glandular stomach of birds, situated just above the crop.","pos":""}],"PROVER":[{"def":"One who, or that which, proves.","pos":""}],"PROVERB":[{"def":"An old and common saying; a phrase which is often repeated; especially, a sentence which briefly and forcibly expresses some practical truth, or the result of experience and observation; a maxim; a saw; an adage.","pos":""},{"def":"A striking or paradoxical assertion; an obscure saying; an enigma; a parable.","pos":""}],"PROVERBIAL":[{"def":"Mentioned or comprised in a proverb; used as a proverb; hence, commonly known; as, a proverbial expression; his meanness was proverbial.","pos":""},{"def":"Of or pertaining to proverbs; resembling a proverb.","pos":""}],"PROVERBIALISM":[{"def":"A proverbial phrase.","pos":""}],"PROVERBIALIST":[{"def":"One who makes much use of proverbs in speech or writing; one who composes, collects, or studies proverbs.","pos":""}],"PROVERBIALIZE":[{"def":"To turn into a proverb; to speak in proverbs.","pos":""}],"PROVERBIALLY":[{"def":"In a proverbial manner; by way of proverb; hence, commonly; universally; as, it is proverbially said; the bee is proverbially busy.","pos":""}],"PROVEXITY":[{"def":"Great advance in age.","pos":""}],"PROVIDE":[{"def":"To look out for in advance; to procure beforehand; to get, collect, or make ready for future use; to prepare.","pos":""},{"def":"To supply; to afford; to contribute.","pos":""}],"PROVIDED":[{"def":"On condition; by stipulation; with the understanding; if; -- usually followed by that; as, provided that nothing in this act shall prejudice the rights of any person whatever.","pos":""}],"PROVIDENCE":[{"def":"A manifestation of the care and superintendence which God exercises over his creatures; an event ordained by divine direction.","pos":""}],"PROVIDENT":[{"def":"Foreseeing wants and making provision to supply them; prudent in preparing for future exigencies; cautious; economical; -- sometimes followed by of; as, aprovident man; an animal provident of the future.","pos":""}],"PROVIDENTIAL":[{"def":"Effected by, or referable to, divine direction or superintendence; as, the providential contrivance of thing; a providential escape.","pos":""}],"PROVIDENTLY":[{"def":"In a provident manner.","pos":""}],"PROVIDENTNESS":[{"def":"The quality or state of being provident; carefulness; prudence; economy.","pos":""}],"PROVIDER":[{"def":"One who provides, furnishes, or supplies; one who procures what is wanted.","pos":""}],"PROVIDORE":[{"def":"One who makes provision; a purveyor.","pos":""}],"PROVINCE":[{"def":"A country or region, more or less remote from the city of Rome, brought under the Roman government; a conquered country beyond the limits of Italy.","pos":""}],"PROVINCIAL":[{"def":"Of or pertaining to province; constituting a province; as, a provincial government; a provincial dialect.","pos":""},{"def":"Exhibiting the ways or manners of a province; characteristic of the inhabitants of a province; not cosmopolitan; countrified; not polished; rude; hence, narrow; illiberal.","pos":""}],"PROVINCIALISM":[{"def":"A word, or a manner of speaking, peculiar to a province or a district remote from the mother country or from the metropolis; a provincial characteristic; hence, narrowness; illiberality.","pos":""}],"PROVINCIALIST":[{"def":"One who lives in a province; a provincial.","pos":""}],"PROVINCIALITY":[{"def":"The quality or state of being provincial; peculiarity of language characteristic of a province.","pos":""}],"PROVINCIALIZE":[{"def":"To render provincial.","pos":""}],"PROVINCIALLY":[{"def":"In a provincial manner.","pos":""}],"PROVINCIATE":[{"def":"To convert into a province or provinces.","pos":""}],"PROVINE":[{"def":"To lay a stock or branch of a vine in the ground for propagation.","pos":""}],"PROVISION":[{"def":"A canonical term for regular induction into a benefice, comprehending nomination, collation, and installation.","pos":""},{"def":"A nomination by the pope to a benefice before it became vacant, depriving the patron of his right of presentation.","pos":""}],"PROVISIONAL":[{"def":"Of the nature of a provision; serving as a provision for the time being; -- used of partial or temporary arrangements; as, a provisional government; a provisional treaty.","pos":""}],"PROVISIONALLY":[{"def":"By way of provision for the time being; temporarily.","pos":""}],"PROVISO":[{"def":"An article or clause in any statute, agreement, contract, grant, or other writing, by which a condition is introduced, usually beginning with the word provided; a conditional stipulation that affects an agreement, contract, law, grant, or the like; as, the contract was impaired by its proviso.","pos":""}],"PROVISOR":[{"def":"One who procures or receives a papal provision.","pos":""}],"PROVISORILY":[{"def":"In a provisory manner; conditionally; subject to a proviso; as, to admit a doctrine provisorily.","pos":""}],"PROVISORSHIP":[{"def":"The office or position of a provisor.","pos":""}],"PROVISORY":[{"def":"Of the nature of a proviso; containing a proviso or condition; conditional; as, a provisory clause.","pos":""},{"def":"Making temporary provision; provisional.","pos":""}],"PROVOCATION":[{"def":"Such prior insult or injury as may be supposed, under the circumstances, to create hot blood, and to excuse an assault made in retort or redress.","pos":""}],"PROVOCATIVE":[{"def":"Serving or tending to provoke, excite, or stimulate; exciting.","pos":""}],"PROVOCATIVENESS":[{"def":"Quality of being provocative.","pos":""}],"PROVOKABLE":[{"def":"That may be provoked.","pos":""}],"PROVOKE":[{"def":"To call forth; to call into being or action; esp.","pos":""}],"PROVOKEMENT":[{"def":"The act that which, provokes; one who excites anger or other passion, or incites to action; as, a provoker of sedition.","pos":""}],"PROVOKING":[{"def":"Having the power or quality of exciting resentment; tending to awaken passion or vexation; as, provoking words or treatment.","pos":""}],"PROVOST":[{"def":"The keeper of a prison.","pos":""}],"PROVOSTSHIP":[{"def":"The office of a provost.","pos":""}]}