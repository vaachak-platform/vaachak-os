{"CARRACK":[{"def":"A small, purplish, branching, cartilaginous seaweed (Chondrus crispus), which, when bleached, is the Irish moss of commerce.","pos":""}],"CARRANCHA":[{"def":"The Brazilian kite (Polyborus Brasiliensis); -- so called in imitation of its notes.","pos":""}],"CARREL":[{"def":"See Quarrel, an arrow.","pos":""}],"CARRIABLE":[{"def":"Capable of being carried.","pos":""}],"CARRIAGE":[{"def":"That which is carried; burden; baggage.","pos":""},{"def":"The act of carrying, transporting, or conveying.","pos":""}],"CARRIAGEABLE":[{"def":"Passable by carriages; that can be conveyed in carriages.","pos":""}],"CARRIER":[{"def":"That which drives or carries; as: (a) A piece which communicates to an object in a lathe the motion of the face plate; a lathe dog.","pos":""}],"CARRION":[{"def":"The dead and putrefying body or flesh of an animal; flesh so corrupted as to be unfit for food.","pos":""},{"def":"A contemptible or worthless person; -- a term of reproach.","pos":""}],"CARROMATA":[{"def":"In the Philippines, a light, two-wheeled, boxlike vehicle usually drawn by a single native pony and used to convey passengers within city limits or for traveling.","pos":""}],"CARRON OIL":[{"def":"A lotion of linseed oil and lime water, used as an application to burns and scalds; -- first used at the Carron iron works in Scotland.","pos":""}],"CARRONADE":[{"def":"A kind of short cannon, formerly in use, designed to throw a large projectile with small velocity, used for the purpose of breaking or smashing in, rather than piercing, the object aimed at, as the side of a ship.","pos":""}],"CARROT":[{"def":"An umbelliferous biennial plant (Daucus Carota), of many varieties.","pos":""}],"CARROTY":[{"def":"Like a carrot in color or in taste; -- an epithet given to reddish yellow hair, etc.","pos":""}],"CARROW":[{"def":"A strolling gamester.","pos":""}],"CARRY":[{"def":"To convey or transport in any manner from one place to another; to bear; -- often with away or off.","pos":""},{"def":"To have or hold as a burden, while moving from place to place; to have upon or about one's person; to bear; as, to carry a wound; to carry an unborn child.","pos":""}],"CARRYALL":[{"def":"A light covered carriage, having four wheels and seats for four or more persons, usually drawn by one horse.","pos":""}],"CARRYING":[{"def":"The act or business of transporting from one place to another.","pos":""}]}