{"FORLAY":[{"def":"To lie in wait for; to ambush.","pos":""}],"FORLEAVE":[{"def":"To leave off wholly.","pos":""}],"FORLEND":[{"def":"To give up wholly.","pos":""}],"FORLESE":[{"def":"To lose utterly.","pos":""}],"FORLET":[{"def":"To give up; to leave; to abandon.","pos":""}],"FORLORE":[{"def":"The beasts their caves, the birds their neforlore.","pos":""}],"FORLORN":[{"def":"Deserted abandoned; lost.","pos":""},{"def":"Destitute; helpless; in pitiful plight; wretched; miserable; almost hopeless; desperate.","pos":""}],"FORLORNLY":[{"def":"In a forlorn manner.","pos":""}],"FORLORNNESS":[{"def":"State of being forlorn.","pos":""}]}