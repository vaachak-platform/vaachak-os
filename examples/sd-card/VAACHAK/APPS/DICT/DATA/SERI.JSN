{"SERIAL":[{"def":"Of or pertaining to rows.","pos":""}],"SERIALITY":[{"def":"The quality or state of succession in a series; sequence.","pos":""}],"SERIALLY":[{"def":"In a series, or regular order; in a serial manner; as, arranged serially; published serially.","pos":""}],"SERIATE":[{"def":"Arranged in a series or succession; pertaining to a series.","pos":""}],"SERIATIM":[{"def":"In regular order; one after the other; severally.","pos":""}],"SERIATION":[{"def":"Arrangement or position in a series.","pos":""}],"SERICEOUS":[{"def":"Covered with very soft hairs pressed close to the surface; as, a sericeous leaf.","pos":""},{"def":"Having a silklike luster, usually due to fine, close hairs.","pos":""}],"SERICIN":[{"def":"A gelatinous nitrogenous material extracted from crude silk and other similar fiber by boiling water; -- called also silk gelatin.","pos":""}],"SERICITE":[{"def":"A kind of muscovite occuring in silky scales having a fibrous structure.","pos":""}],"SERICTERIUM":[{"def":"A silk gland, as in the silkworms.","pos":""}],"SERICULTURE":[{"def":"The raising of silkworms.","pos":""}],"SERIEMA":[{"def":"A large South American bird (Dicholophus, or Cariama cristata) related to the cranes.","pos":""}],"SERIES":[{"def":"Any comprehensive group of animals or plants including several subordinate related groups.","pos":""},{"def":"An indefinite number of terms succeeding one another, each of which is derived from one or more of the preceding by a fixed law, called the law of the series; as, an arithmetical series; a geometrical series.","pos":""}],"SERIES TURNS":[{"def":"The turns in a series circuit.","pos":""}],"SERIES WINDING":[{"def":"A winding in which the armature coil and the field-magnet coil are in series with the external circuits; -- opposed to shunt winding.","pos":""}],"SERIGRAPH":[{"def":"An autographic device to test the strength of raw silk.","pos":""}],"SERIN":[{"def":"A European finch (Serinus hortulanus) closely related to the canary.","pos":""}],"SERINE":[{"def":"A white crystalline nitrogenous substance obtained by the action of dilute sulphuric acid on silk gelatin.","pos":""},{"def":"Having a mixture of seriousness and sport; serious and comical.","pos":""}],"SERIOUS":[{"def":"Grave in manner or disposition; earnest; thoughtful; solemn; not light, gay, or volatile.","pos":""},{"def":"Really intending what is said; being in earnest; not jesting or deceiving.","pos":""}],"SERIPH":[{"def":"See Sergeant, Sergeantcy, etc.","pos":""}]}