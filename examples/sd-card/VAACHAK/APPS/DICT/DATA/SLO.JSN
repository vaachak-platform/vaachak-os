{"SLOAKAN":[{"def":"A species of seaweed.","pos":""}],"SLOAM":[{"def":"A layer of earth between coal seams.","pos":""}],"SLOAT":[{"def":"A narrow piece of timber which holds together large pieces; a slat; as, the sloats of a cart.","pos":""}],"SLOBBERER":[{"def":"One who slobbers.","pos":""},{"def":"A slovenly farmer; a jobbing tailor.","pos":""}],"SLOBBERY":[{"def":"Wet; sloppy, as land.","pos":""},{"def":"To quench; to allay; to slake.","pos":""}],"SLOE":[{"def":"A small, bitter, wild European plum, the fruit of the blackthorn (Prunus spinosa); also, the tree itself.","pos":""}],"SLOG":[{"def":"To hit hard, esp.","pos":""}],"SLOGAN":[{"def":"The war cry, or gathering word, of a Highland clan in Scotland; hence, any rallying cry.","pos":""}],"SLOGGER":[{"def":"A hard hitter; a slugger.","pos":""}],"SLOGGY":[{"def":"Somnolence that is sloggy slumbering Chaucer.","pos":""}],"SLOKE":[{"def":"A slough; a run or wet place.","pos":""}],"SLOOP":[{"def":"A vessel having one mast and fore-and-aft rig, consisting of a boom-and-gaff mainsail, jibs, staysail, and gaff topsail.","pos":"noun"}],"SLOP":[{"def":"Dirty water; water in which anything has been washed or rinsed; water from wash-bowls, etc.","pos":"verb"}],"SLOPE":[{"def":"An oblique direction; a line or direction including from a horizontal line or direction; also, sometimes, an inclination, as of one line or surface to another.","pos":""},{"def":"Any ground whose surface forms an angle with the plane of the horizon.","pos":""}],"SLOPENESS":[{"def":"State of being slope.","pos":""}],"SLOPING":[{"def":"Inclining or inclined from the plane of the horizon, or from a horizontal or other right line; oblique; declivous; slanting.","pos":""}],"SLOPPINESS":[{"def":"The quality or state of being sloppy; muddiness.","pos":""}],"SLOPPY":[{"def":"Wet, so as to spatter easily; wet, as with something slopped over; muddy; plashy; as, a sloppy place, walk, road.","pos":""}],"SLOPSELLER":[{"def":"One who sells slops, or ready-made clothes.","pos":""}],"SLOPSHOP":[{"def":"A shop where slops.","pos":""}],"SLOPWORK":[{"def":"The manufacture of slops, or cheap ready-made clothing; also, such clothing; hence, hasty, slovenly work of any kind.","pos":""}],"SLOPY":[{"def":"Sloping; inclined.","pos":""},{"def":"See Slush, Slushy.","pos":""}],"SLOT":[{"def":"A broad, flat, wooden bar; a slat or sloat.","pos":""},{"def":"A bolt or bar for fastening a door.","pos":""}],"SLOT MACHINE":[{"def":"A machine the operation of which is started by dropping a coin into a slot, for delivering small articles of merchandise, showing one's weight, exhibiting pictures, throwing dice, etc.","pos":""}],"SLOTH":[{"def":"Any one of several species of arboreal edentates constituting the family Bradypodidæ, and the suborder Tardigrada.","pos":""}],"SLOTHFUL":[{"def":"Addicted to sloth; inactive; sluggish; lazy; indolent; idle.","pos":""}],"SLOTHHOUND":[{"def":"See Sleuthhound.","pos":""}],"SLOTTING":[{"def":"The act or process of making slots, or mortises.","pos":""}],"SLOUCH":[{"def":"A hanging down of the head; a drooping attitude; a limp appearance; an ungainly, clownish gait; a sidewise depression or hanging down, as of a hat brim.","pos":""},{"def":"An awkward, heavy, clownish fellow.","pos":""}],"SLOUCHING":[{"def":"Hanging down at the side; limp; drooping; without firmness or shapeliness; moving in an ungainly manner.","pos":""}],"SLOUGH":[{"def":"A wet place; a swale; a side channel or inlet from a river.","pos":""}],"SLOUGHING":[{"def":"The act of casting off the skin or shell, as do insects and crustaceans; ecdysis.","pos":""}],"SLOUGHY":[{"def":"Full of sloughs, miry.","pos":""}],"SLOVEN":[{"def":"A man or boy habitually negligent of neathess and order; -- the correlative term to slattern, or slut.","pos":""}],"SLOVENLINESS":[{"def":"The quality or state of being slovenly.","pos":""}],"SLOVENLY":[{"def":"Having the habits of a sloven; negligent of neatness and order, especially in dress.","pos":""},{"def":"Characteristic of a solven; lacking neatness and order; evincing negligence; as, slovenly dress.","pos":""}],"SLOW":[{"def":"Moving a short space in a relatively long time; not swift; not quick in motion; not rapid; moderate; deliberate; as, a slow stream; a slow motion.","pos":""},{"def":"Not happening in a short time; gradual; late.","pos":""}],"SLOW-WITTED":[{"def":"Dull of apprehension; not possessing quick intelligence.","pos":""}],"SLOWBACK":[{"def":"A lubber; an idle fellow; a loiterer.","pos":""}],"SLOWLY":[{"def":"In a slow manner; moderately; not rapidly; not early; not rashly; not readly; tardly.","pos":""}],"SLOWNESS":[{"def":"The quality or state of being slow.","pos":""}],"SLOWWORM":[{"def":"A lecertilian reptile; the blindworm.","pos":""}]}