{"GALICIAN":[{"def":"Of or pertaining to Galicia, in Spain, or to Galicia, the kingdom of Austrian Poland.","pos":""},{"def":"A native of Galicia in Spain; -- called also Gallegan.","pos":""}],"GALILEAN":[{"def":"Of or pertaining to Galileo; as, the Galilean telescope.","pos":""}],"GALILEE":[{"def":"A porch or waiting room, usually at the west end of an abbey church, where the monks collected on returning from processions, where bodies were laid previous to interment, and where women were allowed to see the monks to whom they were related, or to hear divine service.","pos":""}],"GALIMATIAS":[{"def":"Nonsense; gibberish; confused and unmeaning talk; confused mixture.","pos":""}],"GALINGALE":[{"def":"A plant of the Sedge family (Cyperus longus) having aromatic roots; also, any plant of the same genus.","pos":""}],"GALIPOT":[{"def":"An impure resin of turpentine, hardened on the outside of pine trees by the spontaneous evaporation of its essential oil.","pos":""}]}