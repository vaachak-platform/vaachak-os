{"MARMALADE":[{"def":"A preserve or confection made of the pulp of fruit, as the quince, pear, apple, orange, etc.","pos":""}],"MARMATITE":[{"def":"A ferruginous variety of shalerite or zinc blende, nearly black in color.","pos":""}],"MARMOLITE":[{"def":"A thin, laminated variety of serpentine, usually of a pale green color.","pos":""}],"MARMORACEOUS":[{"def":"Pertaining to, or like, marble.","pos":""},{"def":"Variegated like marble; covered or overlaid with marble.","pos":""}],"MARMORATION":[{"def":"A covering or incrusting with marble; a casing of marble; a variegating so as to resemble marble.","pos":""}],"MARMORATUM OPUS":[{"def":"A kind of hard finish for plasterwork, made of plaster of Paris and marble dust, and capable of taking a high polish.","pos":""},{"def":"Pertaining to, or resembling, marble; made of marble.","pos":""}],"MARMOROSIS":[{"def":"The metamorphism of limestone, that is, its conversion into marble.","pos":""}],"MARMOSE":[{"def":"A species of small opossum (Didelphus murina) ranging from Mexico to Brazil.","pos":""}],"MARMOSET":[{"def":"Any one of numerous species of small South American monkeys of the genera Hapale and Midas, family Hapalidæ.","pos":""}],"MARMOT":[{"def":"Any rodent of the genus Arctomys.","pos":""}],"MARMOTTES OIL":[{"def":"Mar\"mottes oil` Defn: .","pos":""}]}