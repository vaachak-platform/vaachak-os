{"TRIG":[{"def":"To fill; to stuff; to cram.","pos":""}],"TRIGAMIST":[{"def":"One who has been married three times; also, one who has three husbands or three wives at the same time.","pos":""}],"TRIGAMOUS":[{"def":"Having three sorts of flowers in the same head, -- male, female, and hermaphrodite, or perfect, flowers.","pos":""}],"TRIGAMY":[{"def":"The act of marrying, or the state of being married, three times; also, the offense of having three husbands or three wives at the same time.","pos":""}],"TRIGASTRIC":[{"def":"Having three bellies; -- said of a muscle.","pos":""}],"TRIGEMINAL":[{"def":"Of, pertaining to, or designating, the fifth pair of cranial nerves, which divide on each side of the head into three main branches distributed to the orbits, jaws, and parts of the mouth; trifacial.","pos":""}],"TRIGEMINOUS":[{"def":"Born three together; being one of three born at the same birth; also, threefold.","pos":""}],"TRIGENIC":[{"def":"Of, pertaining to, or designating, an acid, C4H7N3O2, obtained, by the action of the vapor of cyanic acid on cold aldehyde, as a white crystalline substance having a slightly acid taste and faint smell; -- called also ethidene- or ethylidene-biuret.","pos":""}],"TRIGER PROCESS":[{"def":"A method of sinking through water-bearing ground, in which the shaft is lined with tubbing and provided with an air lock, work being proceeded with under air pressure.","pos":""}],"TRIGESIMO-SECUNDO":[{"def":"Having thirty-two leaves to a sheet; as, a trigesimo-secundo form, book, leaf, size, etc.","pos":""}],"TRIGGER":[{"def":"A piece, as a lever, which is connected with a catch or detent as a means of releasing it; especially (Firearms), the part of a lock which is moved by the finger to release the cock and discharge the piece.","pos":""}],"TRIGLYCERIDE":[{"def":"A glyceride formed by the replacement of three hydrogen atoms in glycerin by acid radicals.","pos":""}],"TRIGLYPH":[{"def":"An ornament in the frieze of the Doric order, repeated at equal intervals.","pos":""}],"TRIGNESS":[{"def":"The quality or state of being trig; smartness; neatness.","pos":""}],"TRIGON":[{"def":"The cutting region of the crown of an upper molar, usually the anterior part.","pos":""}],"TRIGONAL":[{"def":"Having three angles, or corners; triangular; as, a trigonal stem, one having tree prominent longitudinal angles.","pos":""}],"TRIGONE":[{"def":"A smooth triangular area on the inner surface of the bladder, limited by the apertures of the ureters and urethra.","pos":""}],"TRIGONIA":[{"def":"A genus of pearly bivalve shells, numerous extinct species of which are characteristic of the Mesozoic rocks.","pos":""}],"TRIGONOCEROUS":[{"def":"Having horns with three angles, like those of some species of goats.","pos":""}],"TRIGONODONT":[{"def":"See Trituberculy.","pos":""},{"def":"Of or pertaining to trigonometry; performed by the rules of trigonometry.","pos":""}],"TRIGONOMETRY":[{"def":"That branch of mathematics which treats of the relations of the sides and angles of triangles, which the methods of deducing from certain given parts other required parts, and also of the general relations which exist between the trigonometrical functions of arcs or angles.","pos":""},{"def":"A treatise in this science.","pos":""}],"TRIGONOUS":[{"def":"Same as Trigonal.","pos":""}],"TRIGRAM":[{"def":"Same as Trigraph.","pos":""}],"TRIGRAMMATIC":[{"def":"Containing three letters or characters, or three sets of letters or characters.","pos":""}],"TRIGRAMMIC":[{"def":"Same as Trigrammatic.","pos":""}],"TRIGRAPH":[{"def":"Three letters united in pronunciation so as to have but one sound, or to form but one syllable, as -ieu in adieu; a triphthong.","pos":""}],"TRIGYN":[{"def":"Any one of the Trigynia.","pos":""}],"TRIGYNIA":[{"def":"A Linnæan order of plants having three pistils or styles.","pos":""},{"def":"Having three pistils or styles; of or pertaining to the Trigynia.","pos":""}]}