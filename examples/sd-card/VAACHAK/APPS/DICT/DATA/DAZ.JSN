{"DAZE":[{"def":"To stupefy with excess of light; with a blow, with cold, or with fear; to confuse; to benumb.","pos":""}],"DAZZLE":[{"def":"To overpower with light; to confuse the sight of by brilliance of light.","pos":""},{"def":"To bewilder or surprise with brilliancy or display of any kind.","pos":""}],"DAZZLEMENT":[{"def":"Dazzling flash, glare, or burst of light.","pos":""}],"DAZZLINGLY":[{"def":"In a dazzling manner.","pos":""}]}