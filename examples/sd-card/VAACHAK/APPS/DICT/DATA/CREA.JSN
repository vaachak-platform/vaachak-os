{"CREABLE":[{"def":"Capable of being created.","pos":""}],"CREAGHT":[{"def":"A drove or herd.","pos":""}],"CREAK":[{"def":"To make a prolonged sharp grating or ssqueaking sound, as by the friction of hard substances; as, shoes creak.","pos":""}],"CREAKING":[{"def":"A harsh grating or squeaking sound, or the act of making such a sound.","pos":""}],"CREAM":[{"def":"The rich, oily, and yellowish part of milk, which, when the milk stands unagitated, rises, and collects on the surface.","pos":""},{"def":"The part of any liquor that rises, and collects on the surface.","pos":""}],"CREAM LAID":[{"def":"Cream\" laid` (krm\" ld`).","pos":""}],"CREAM-COLORED":[{"def":"Of the color of cream; light yellow.","pos":""}],"CREAM-FACED":[{"def":"White or pale, as the effect of fear, or as the natural complexion.","pos":""}],"CREAM-FRUIT":[{"def":"A plant of Sierra Leone which yields a wholesome, creamy juice.","pos":""}],"CREAM-SLICE":[{"def":"A wooden knife with a long thin blade, used in handling cream or ice cream.","pos":""}],"CREAM-WHITE":[{"def":"As white as cream.","pos":""}],"CREAMCAKE":[{"def":"A kind of cake filled with custard made of cream, eggs, etc.","pos":""}],"CREAMERY":[{"def":"A place where butter and cheese are made, or where milk and cream are put up in cans for market.","pos":""},{"def":"A place or apparatus in which milk is set for raising cream.","pos":""}],"CREAMINESS":[{"def":"The quality of being creamy.","pos":""}],"CREAMY":[{"def":"Full of, or containing, cream; resembling cream, in nature, appearance, or taste; creamlike; unctuous.","pos":""}],"CREANCE":[{"def":"A fine, small line, fastened to a hawk's leash, when it is first lured.","pos":""}],"CREANT":[{"def":"Creative; formative.","pos":""}],"CREASE":[{"def":"One of the lines serving to define the limits of the bowler and the striker.","pos":""}],"CREASER":[{"def":"A tool for making the band impression distinct on the back.","pos":""}],"CREASING":[{"def":"A layer of tiles forming a corona for a wall.","pos":""}],"CREASOTE":[{"def":"Cre\"a*sote (kr\"-st), n.","pos":""}],"CREASY":[{"def":"Full of creases.","pos":""}],"CREAT":[{"def":"An usher to a riding master.","pos":""}],"CREATABLE":[{"def":"That may be created.","pos":""}],"CREATE":[{"def":"Created; composed; begotte.","pos":""}],"CREATIC":[{"def":"Relating to, or produced by, flesh or animal food; as, creatic nausea.","pos":""}],"CREATIN":[{"def":"A white, crystalline, nitrogenous substance found abundantly in muscle tissue.","pos":""}],"CREATININ":[{"def":"A white, crystalline, nitrogenous body closely related to creatin but more basic in its properties, formed from the latter by the action of acids, and occurring naturally in muscle tissue and in urine.","pos":""}],"CREATION":[{"def":"The act of creating or causing to exist.","pos":""},{"def":"That which is created; that which is produced or caused to exist, as the world or some original work of art or of the imagination; nature.","pos":""}],"CREATIONAL":[{"def":"Of or pertaining to creation.","pos":""}],"CREATIONISM":[{"def":"The doctrine that a soul is specially created for each human being as soon as it is formed in the womb; -- opposed to traducianism.","pos":""}],"CREATIVE":[{"def":"Having the power to create; exerting the act of creation.","pos":""}],"CREATIVENESS":[{"def":"The qualiyu of being creative.","pos":""}],"CREATOR":[{"def":"One who creates, produces, or constitutes.","pos":""}],"CREATORSHIP":[{"def":"State or condition of a creator.","pos":""}],"CREATRESS":[{"def":"She who creates.","pos":""}],"CREATRIX":[{"def":"Cre*a\"trix (-trks), n.","pos":""}],"CREATURAL":[{"def":"Belonging to a creature; having the qualities of a creature.","pos":""}],"CREATURE":[{"def":"Anything created; anything not self-existent; especially, any being created with life; an animal; a man.","pos":""},{"def":"A human being, in pity, contempt, or endearment; as, a poor creature; a pretty creature.","pos":""}],"CREATURELESS":[{"def":"Without created beings; alone.","pos":""}],"CREATURELY":[{"def":"Creatural; characteristic of a creature.","pos":""}],"CREATURESHIP":[{"def":"The condition of being a creature.","pos":""}],"CREATURIZE":[{"def":"To make like a creature; to degrade [Obs.","pos":""}],"CREAZE":[{"def":"The tin ore which collects in the central part of the washing pit or buddle.","pos":""}]}