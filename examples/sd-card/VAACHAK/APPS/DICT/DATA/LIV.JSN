{"LIVABLE":[{"def":"Such as can be lived.","pos":""},{"def":"Such as in pleasant to live in; fit or suitable to live in.","pos":""}],"LIVE":[{"def":"To be alive; to have life; to have, as an animal or a plant, the capacity of assimilating matter as food, and to be dependent on such assimilation for a continuance of existence; as, animals and plants that live to a great age are long in reaching maturity.","pos":""},{"def":"To pass one's time; to pass life or time in a certain manner, as to habits, conduct, or circumstances; as, to live in ease or affluence; to live happily or usefully.","pos":""}],"LIVE-FOREVER":[{"def":"A plant (Sedum Telephium) with fleshy leaves, which has extreme powers of resisting drought; garden ox-pine.","pos":""}],"LIVED":[{"def":"Having life; -- used only in composition; as, long-lived; short-lived.","pos":""}],"LIVELIHOOD":[{"def":"Subsistence or living, as dependent on some means of support; support of life; maintenance.","pos":""}],"LIVELILY":[{"def":"In a lively manner.","pos":""}],"LIVELINESS":[{"def":"The quality or state of being lively or animated; sprightliness; vivacity; animation; spirit; as, the liveliness of youth, contrasted with the gravity of age.","pos":""},{"def":"An appearance of life, animation, or spirit; as, the liveliness of the eye or the countenance in a portrait.","pos":""}],"LIVELODE":[{"def":"Course of life; means of support; livelihood.","pos":""}],"LIVELONG":[{"def":"Whole; entire; long in passing; -- used of time, as day or night, in adverbial phrases, and usually with a sense of tediousness.","pos":""},{"def":"Lasting; durable.","pos":""}],"LIVELY":[{"def":"Endowed with or manifesting life; living.","pos":""},{"def":"Brisk; vivacious; active; as, a lively youth.","pos":""}],"LIVER":[{"def":"One who, or that which, lives.","pos":""},{"def":"A resident; a dweller; as, a liver in Brooklyn.","pos":""}],"LIVER-COLORED":[{"def":"Having a color like liver; dark reddish brown.","pos":""}],"LIVER-GROWN":[{"def":"Having an enlarged liver.","pos":""}],"LIVERED":[{"def":"Having (such) a liver; used in composition; as, white-livered.","pos":""}],"LIVERIED":[{"def":"Wearing a livery.","pos":""}],"LIVERING":[{"def":"A kind of pudding or sausage made of liver or pork.","pos":""}],"LIVERLEAF":[{"def":"Same as Liverwort.","pos":""}],"LIVERWORT":[{"def":"A ranunculaceous plant (Anemone Hepatica) with pretty white or bluish flowers and a three-lobed leaf; -- called also squirrel cups.","pos":""},{"def":"A flowerless plant (Marchantia polymorpha), having an irregularly lobed, spreading, and forking frond.","pos":""}],"LIVERY":[{"def":"Release from wardship; deliverance.","pos":""},{"def":"That which is delivered out statedly or formally, as clothing, food, etc.","pos":""}],"LIVERY STABLE":[{"def":"Liv\"er*y sta`ble Defn: .","pos":""}],"LIVERYMAN":[{"def":"One who wears a livery, as a servant.","pos":""},{"def":"A freeman of the city, in London, who, having paid certain fees, is entitled to wear the distinguishing dress or livery of the company to which he belongs, and also to enjoy certain other privileges, as the right of voting in an election for the lord mayor, sheriffs, chamberlain, etc.","pos":""}],"LIVES":[{"def":"Alive; living; with life.","pos":""}],"LIVID":[{"def":"Black and blue; grayish blue; of a lead color; discolored, as flesh by contusion.","pos":""}],"LIVIDITY":[{"def":"The state or quality of being livid.","pos":""}],"LIVING":[{"def":"Being alive; having life; as, a living creature.","pos":""},{"def":"Active; lively; vigorous; -- said esp.","pos":""}],"LIVING PICTURE":[{"def":"A tableau in which persons take part; also, specif.","pos":""}],"LIVINGLY":[{"def":"In a living state.","pos":""}],"LIVINGNESS":[{"def":"The state or quality of being alive; possession of energy or vigor; animation; quickening.","pos":""}],"LIVONIAN":[{"def":"Of or pertaining to Livonia, a district of Russia near the Baltic Sea.","pos":""}],"LIVRAISON":[{"def":"A part of a book or literary composition printed and delivered by itself; a number; a part.","pos":""}],"LIVRE":[{"def":"A French money of account, afterward a silver coin equal to 20 sous.","pos":""}]}