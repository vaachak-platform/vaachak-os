{"DOT":[{"def":"A marriage portion; dowry.","pos":""}],"DOTAGE":[{"def":"Feebleness or imbecility of understanding or mind, particularly in old age; the childishness of old age; senility; as, a venerable man, now in his dotage.","pos":""},{"def":"Foolish utterance; drivel.","pos":""}],"DOTAL":[{"def":"Pertaining to dower, or a woman's marriage portion; constituting dower, or comprised in it.","pos":""}],"DOTARD":[{"def":"One whose mind is impaired by age; one in second childhood.","pos":""}],"DOTARY":[{"def":"A dotard's weakness; dotage.","pos":""}],"DOTATION":[{"def":"The act of endowing, or bestowing a marriage portion on a woman.","pos":""},{"def":"Endowment; establishment of funds for support, as of a hospital or eleemosynary corporation.","pos":""}],"DOTE":[{"def":"Natural endowments.","pos":""}],"DOTED":[{"def":"Stupid; foolish.","pos":""},{"def":"Half-rotten; as, doted wood.","pos":""}],"DOTER":[{"def":"One who dotes; a man whose understanding is enfeebled by age; a dotard.","pos":""},{"def":"One excessively fond, or weak in love.","pos":""}],"DOTERY":[{"def":"The acts or speech of a dotard; drivel.","pos":""}],"DOTING":[{"def":"That dotes; silly; excessively fond.","pos":""}],"DOTISH":[{"def":"Foolish; weak; imbecile.","pos":""}],"DOTTARD":[{"def":"An old, decayed tree.","pos":""}],"DOTTED":[{"def":"Marked with, or made of, dots or small spots; diversified with small, detached objects.","pos":""}],"DOTTEREL":[{"def":"A European bird of the Plover family (Eudromias, or Charadrius, morinellus).","pos":""}],"DOTTY":[{"def":"Composed of, or characterized by, dots.","pos":""}],"DOTY":[{"def":"Half-rotten; as, doty timber.","pos":""}]}