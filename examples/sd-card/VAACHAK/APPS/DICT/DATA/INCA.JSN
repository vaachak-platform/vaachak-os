{"INCA":[{"def":"The people governed by the Incas, now represented by the Quichua tribe.","pos":""}],"INCAGE":[{"def":"To confine in, or as in, a cage; to coop up.","pos":""}],"INCAGEMENT":[{"def":"Confinement in, or as in, cage.","pos":""}],"INCALCULABILITY":[{"def":"The quality or state of being incalculable.","pos":""}],"INCALCULABLE":[{"def":"Not capable of being calculated; beyond calculation; very great.","pos":""}],"INCALESCENCE":[{"def":"The state of being incalescent, or of growing warm.","pos":""}],"INCALESCENT":[{"def":"Growing warm; increasing in heat.","pos":""}],"INCAMERATION":[{"def":"The act or process of uniting lands, rights, or revenues, to the ecclesiastical chamber, i.","pos":""}],"INCAN":[{"def":"Of or pertaining to the Incas.","pos":""}],"INCANDESCENCE":[{"def":"A white heat, or the glowing or luminous whiteness of a body caused by intense heat.","pos":""}],"INCANDESCENT":[{"def":"White, glowing, or luminous, with intense heat; as, incandescent carbon or platinum; hence, clear; shining; brilliant.","pos":""}],"INCANESCENT":[{"def":"Becoming hoary or gray; canescent.","pos":""}],"INCANOUS":[{"def":"Hoary with white pubescence.","pos":""}],"INCANTATION":[{"def":"The act or process of using formulas sung or spoken, with occult ceremonies, for the purpose of raising spirits, producing enchantment, or affecting other magical results; enchantment.","pos":""},{"def":"A formula of words used as above.","pos":""}],"INCANTATORY":[{"def":"Dealing by enchantment; magical.","pos":""}],"INCANTON":[{"def":"To unite to, or form into, a canton or separate community.","pos":""}],"INCAPABILITY":[{"def":"Want of legal qualifications, or of legal power; as, incapability of holding an office.","pos":""}],"INCAPABLE":[{"def":"Unqualified or disqualified, in a legal sense; as, a man under thirty-five years of age is incapable of holding the office of president of the United States; a person convicted on impeachment is thereby made incapable of holding an office of profit or honor under the government.","pos":""},{"def":"As a term of disgrace, sometimes annexed to a sentence when an officer has been cashiered and rendered incapable of serving his country.","pos":""}],"INCAPABLENESS":[{"def":"The quality or state of being incapable; incapability.","pos":""}],"INCAPABLY":[{"def":"In an incapable manner.","pos":""}],"INCAPACIOUS":[{"def":"Not capacious; narrow; small; weak or foolish; as, an incapacious soul.","pos":""}],"INCAPACITATE":[{"def":"To deprive of legal or constitutional requisites, or of ability or competency for the performance of certain civil acts; to disqualify.","pos":""}],"INCAPACITATION":[{"def":"The act of incapacitating or state of being incapacitated; incapacity; disqualification.","pos":""}],"INCAPACITY":[{"def":"Want of legal ability or competency to do, give, transmit, or receive something; inability; disqualification; as, the inacapacity of minors to make binding contracts, etc.","pos":""}],"INCAPSULATE":[{"def":"To inclose completely, as in a membrane.","pos":""}],"INCAPSULATION":[{"def":"The process of becoming, or the state or condition of being, incapsulated; as, incapsulation of the ovum in the uterus.","pos":""}],"INCARCERATE":[{"def":"To imprison; to confine in a jail or priso 2.","pos":""}],"INCARCERATION":[{"def":"The act of confining, or the state of being confined; imprisonment.","pos":""}],"INCARCERATOR":[{"def":"One who incarcerates.","pos":""}],"INCARN":[{"def":"To cover or invest with flesh.","pos":""}],"INCARNADINE":[{"def":"Flesh-colored; of a carnation or pale red color.","pos":""}],"INCARNATE":[{"def":"Not in the flesh; spiritual.","pos":""}],"INCARNATION":[{"def":"The union of the second person of the Godhead with manhood in Christ.","pos":""},{"def":"The process of healing wounds and filling the part with new flesh; granulation.","pos":""}],"INCARNATIVE":[{"def":"Causing new flesh to grow; healing; regenerative.","pos":""},{"def":"An incarnative medicine.","pos":""}],"INCARNIFICATION":[{"def":"The act of assuming, or state of being clothed with, flesh; incarnation.","pos":""}],"INCASE":[{"def":"To inclose in a case; to inclose; to cover or surround with something solid.","pos":""}],"INCASEMENT":[{"def":"The act or process of inclosing with a case, or the state of being incased.","pos":""},{"def":"That which forms a case, covering, or inclosure.","pos":""}],"INCASK":[{"def":"To cover with a casque or as with a casque.","pos":""}],"INCASTELLATED":[{"def":"Confined or inclosed in a castle.","pos":""}],"INCATENATION":[{"def":"The act of linking together; enchaining.","pos":""}],"INCAUTION":[{"def":"Want of caution.","pos":""}],"INCAUTIOUS":[{"def":"Not cautious; not circumspect; not attending to the circumstances on which safety and interest depend; heedless; careless; as, an incautious step; an incautious remark.","pos":""}],"INCAVATED":[{"def":"Made hollow; bent round or in.","pos":""}],"INCAVATION":[{"def":"Act of making hollow; also, a hollow; an exvation; a depression.","pos":""}],"INCAVED":[{"def":"Inclosed in a cave.","pos":""}],"INCAVERNED":[{"def":"Inclosed or shut up as in a cavern.","pos":""}]}