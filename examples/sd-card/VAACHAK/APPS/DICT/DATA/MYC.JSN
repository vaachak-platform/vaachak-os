{"MYCELIUM":[{"def":"The white threads or filamentous growth from which a mushroom or fungus is developed; the so-called mushroom spawn.","pos":""}],"MYCELOID":[{"def":"Resembling mycelium.","pos":""}],"MYCETES":[{"def":"A genus of South American monkeys, including the howlers.","pos":""}],"MYCETOID":[{"def":"Resembling a fungus.","pos":""}],"MYCETOZOA":[{"def":"The Myxomycetes; -- so called by those who regard them as a class of animals.","pos":""}],"MYCODERMA":[{"def":"One of the forms in which bacteria group themselves; a more or less thick layer of motionless but living bacteria, formed by the bacteria uniting on the surface of the fluid in which they are developed.","pos":""},{"def":"Of or relating to mycology, or the fungi.","pos":""}],"MYCOLOGIST":[{"def":"One who is versed in, or who studies, mycology.","pos":""}],"MYCOLOGY":[{"def":"That branch of botanical science which relates to the musgrooms and other fungi.","pos":""}],"MYCOMELIC":[{"def":"Pertaining to, or designating, a complex nitrogenous acid of the alloxan group, obtained as a honey-yellow powder.","pos":""}],"MYCOPROTEIN":[{"def":"The protoplasmic matter of which bacteria are composed.","pos":""}],"MYCOSE":[{"def":"A variety of sugar, isomeric with sucrose and obtained from certain lichens and fungi.","pos":""}],"MYCOTHRIX":[{"def":"The chain of micrococci formed by the division of the micrococci in multiplication.","pos":""}]}