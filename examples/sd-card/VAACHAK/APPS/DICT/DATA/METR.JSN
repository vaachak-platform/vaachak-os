{"METRIC":[{"def":"Relating to measurement; involving, or proceeding by, measurement.","pos":""},{"def":"Of or pertaining to the meter as a standard of measurement; of or pertaining to the decimal system of measurement of which a meter is the unit; as, the metric system; a metric measurement.","pos":""}],"METRIC TON":[{"def":"A weight of 1,000 kilograms, or 2,204.","pos":""}],"METRICAL":[{"def":"Of or pertaining to the meter; arranged in meter; consisting of verses; as, metrical compositions.","pos":""},{"def":"Of or pertaining to measurement; as, the inch, foot, yard, etc.","pos":""}],"METRICALLY":[{"def":"In a metrical manner.","pos":""}],"METRICIAN":[{"def":"A composer of verses.","pos":""}],"METRIFICATION":[{"def":"Composition in metrical form; versification.","pos":""}],"METRIST":[{"def":"A maker of verses.","pos":""}],"METRITIS":[{"def":"Inflammation of the womb.","pos":""}],"METROCHROME":[{"def":"An instrument for measuring colors.","pos":""}],"METROGRAPH":[{"def":"An instrument attached to a locomotive for recording its speed and the number and duration of its stops.","pos":""}],"METROLOGICAL":[{"def":"Of or pertaining to metrology.","pos":""}],"METROLOGY":[{"def":"The science of, or a system of, weights and measures; also, a treatise on the subject.","pos":""}],"METROMANIA":[{"def":"A mania for writing verses.","pos":""}],"METROMANIAC":[{"def":"One who has metromania.","pos":""}],"METROMETER":[{"def":"An instrument for measuring the size of the womb.","pos":""}],"METRONOME":[{"def":"An instrument consisting of a short pendulum with a sliding weight.","pos":""}],"METRONOMY":[{"def":"Measurement of time by an instrument.","pos":""}],"METRONYMIC":[{"def":"Derived from the name of one's mother, or other female ancestor; as, a metronymic name or appellation.","pos":""}],"METROPOLIS":[{"def":"The seat, or see, of the metropolitan, or highest church dignitary.","pos":""}],"METROPOLITAN":[{"def":"Of, pertaining to, or designating, a metropolitan or the presiding bishop of a country or province, his office, or his dignity; as, metropolitan authority.","pos":""}],"METROPOLITANATE":[{"def":"The see of a metropolitan bishop.","pos":""}],"METROPOLITICAL":[{"def":"Of or pertaining to a metropolis; being a metropolis; metropolitan; as, the metropolitical chair.","pos":""}],"METRORRHAGIA":[{"def":"Profuse bleeding from the womb, esp.","pos":""}],"METROSCOPE":[{"def":"A modification of the stethoscope, for directly auscultating the uterus from the vagina.","pos":""}],"METROSIDEROS":[{"def":"A myrtaceous genus of trees or shrubs, found in Australia and the South Sea Islands, and having very hard wood.","pos":""}],"METROTOME":[{"def":"An instrument for cutting or scarifying the uterus or the neck of the uterus.","pos":""}],"METROTOMY":[{"def":"The operation of cutting into the uterus; hysterotomy; the Cæsarean section.","pos":""},{"def":"A suffix denoting the art, process, or science, of measuring; as, acidmetry, chlorometry, chronometry.","pos":""}]}