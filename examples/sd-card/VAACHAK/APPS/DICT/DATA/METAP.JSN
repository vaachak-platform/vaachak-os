{"METAPECTIC":[{"def":"Pertaining to, or designating, a supposed acid obtained from pectin.","pos":""}],"METAPECTIN":[{"def":"A substance obtained from, and resembling, pectin, and occurring in overripe fruits.","pos":""}],"METAPEPTONE":[{"def":"An intermediate product formed in the gastric digestion of albuminous matter.","pos":""}],"METAPHOR":[{"def":"The transference of the relation between one set of objects to another set for the purpose of brief explanation; a compressed simile; e.","pos":""},{"def":"Of or pertaining to metaphor; comprising a metaphor; not literal; figurative; tropical; as, a metaphorical expression; a metaphorical sense.","pos":""}],"METAPHORIST":[{"def":"One who makes metaphors.","pos":""}],"METAPHOSPHATE":[{"def":"A salt of metaphosphoric acid.","pos":""}],"METAPHOSPHORIC":[{"def":"Pertaining to, or designating, a monobasic acid, HPO3, analogous to nitric acid, and, by heating phosphoric acid, obtained as a crystalline substance, commonly called glacial phosphoric acid.","pos":""}],"METAPHRASE":[{"def":"A verbal translation; a version or translation from one language into another, word for word; -- opposed to paraphrase.","pos":""},{"def":"An answering phrase; repartee.","pos":""}],"METAPHRASED":[{"def":"Translated literally.","pos":""}],"METAPHRAST":[{"def":"A literal translator.","pos":""},{"def":"Close, or literal.","pos":""}],"METAPHYSIC":[{"def":"See Metaphysics.","pos":""}],"METAPHYSICAL":[{"def":"Of or pertaining to metaphysics.","pos":""},{"def":"According to rules or principles of metaphysics; as, metaphysical reasoning.","pos":""}],"METAPHYSICALLY":[{"def":"In the manner of metaphysical science, or of a metaphysician.","pos":""}],"METAPHYSICIAN":[{"def":"One who is versed in metaphysics.","pos":""}],"METAPHYSICS":[{"def":"Hence: The scientific knowledge of mental phenomena; mental philosophy; psychology.","pos":""}],"METAPHYSIS":[{"def":"Change of form; transformation.","pos":""}],"METAPLASM":[{"def":"A change in the letters or syllables of a word.","pos":""}],"METAPLAST":[{"def":"A word having more than one form of the root.","pos":""}],"METAPODE":[{"def":"The posterior division of the foot in the Gastropoda and Pteropoda.","pos":""}],"METAPODIAL":[{"def":"Of or pertaining to the metapodialia, or to the parts of the limbs to which they belong.","pos":""}],"METAPODIALE":[{"def":"One of the bones of either the metacarpus or metatarsus.","pos":""}],"METAPODIUM":[{"def":"Same as Metapode.","pos":""}],"METAPOPHYSIS":[{"def":"A tubercle projecting from the anterior articular processes of some vertebræ; a mammillary process.","pos":""}],"METAPTERYGIUM":[{"def":"The posterior of the three principal basal cartilages in the fins of fishes.","pos":""}]}