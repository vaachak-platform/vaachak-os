{"CAD":[{"def":"A person who stands at the door of an omnibus to open and shut it, and to receive fares; an idle hanger-on about innyards.","pos":""},{"def":"A lowbred, presuming person; a mean, vulgar fellow.","pos":""}],"CADASTRAL":[{"def":"Of or pertaining to landed property.","pos":""},{"def":"An official statement of the quantity and value of real estate for the purpose of apportioning the taxes payable on such property.","pos":""}],"CADAVER":[{"def":"A dead human body; a corpse.","pos":""}],"CADAVERIC":[{"def":"Of, pertaining to, or resembling, a corpse, or the changes produced by death; cadaverous; as, cadaveric rigidity.","pos":""},{"def":"A sirupy, nontoxic ptomaine, C5H14N2 (chemically pentamethylene diamine), formed in putrefaction of flesh, etc.","pos":""}],"CADAVEROUS":[{"def":"Having the appearance or color of a dead human body; pale; ghastly; as, a cadaverous look.","pos":""},{"def":"Of or pertaining to, or having the qualities of, a dead body.","pos":""}],"CADBAIT":[{"def":"The larva of a caddice fly.","pos":""}],"CADDIS":[{"def":"A kind of worsted lace or ribbon.","pos":""}],"CADDISH":[{"def":"Like a cad; lowbred and presuming.","pos":""}],"CADDY":[{"def":"A small box, can, or chest to keep tea in.","pos":""}],"CADE":[{"def":"Bred by hand; domesticated; petted.","pos":""}],"CADENCE":[{"def":"Harmony and proportion in motions, as of a well-managed horse.","pos":""}],"CADENCY":[{"def":"Descent of related families; distinction between the members of a family according to their ages.","pos":""}],"CADENE":[{"def":"A species of inferior carpet imported from the Levant.","pos":""}],"CADENZA":[{"def":"A parenthetic flourish or flight of ornament in the course of a piece, commonly just before the final cadence.","pos":""}],"CADET":[{"def":"The younger of two brothers; a younger brother or son; the youngest son.","pos":""}],"CADETSHIP":[{"def":"The position, rank, or commission of a cadet; as, to get a cadetship.","pos":""}],"CADGE":[{"def":"To carry, as a burden.","pos":""},{"def":"To hawk or peddle, as fish, poultry, etc.","pos":""}],"CADGER":[{"def":"A packman or itinerant huckster.","pos":""},{"def":"One who gets his living by trickery or begging.","pos":""}],"CADGY":[{"def":"Cheerful or mirthful, as after good eating or drinking; also, wanton.","pos":""}],"CADI":[{"def":"An inferior magistrate or judge among the Mohammedans, usually the judge of a town or village.","pos":""},{"def":"A Scotch errand boy, porter, or messenger.","pos":""}],"CADILESKER":[{"def":"A chief judge in the Turkish empire, so named originally because his jurisdiction extended to the cases of soldiers, who are now tried only by their own officers.","pos":""}],"CADILLAC":[{"def":"A large pear, shaped like a flattened top, used chiefly for cooking.","pos":""}],"CADIS":[{"def":"A kind of coarse serge.","pos":""}],"CADMEAN":[{"def":"Of or pertaining to Cadmus, a fabulous prince of Thebes, who was said to have introduced into Greece the sixteen simple letters of the alphabet -- Cadmean letters.","pos":""}],"CADMIA":[{"def":"An oxide of zinc which collects on the sides of furnaces where zinc is sublimed.","pos":""}],"CADMIC":[{"def":"Pertaining to, derived from, or containing, cadmium; as, cadmic sulphide.","pos":""}],"CADMIUM":[{"def":"A comparatively rare element related to zinc, and occurring in some zinc ores.","pos":""}],"CADRANS":[{"def":"An instrument with a graduated disk by means of which the angles of gems are measured in the process of cutting and polishing.","pos":""}],"CADRE":[{"def":"The framework or skeleton upon which a regiment is to be formed; the officers of a regiment forming the staff.","pos":""}],"CADUCARY":[{"def":"Relating to escheat, forfeiture, or confiscation.","pos":""}],"CADUCEAN":[{"def":"Of or belonging to Mercury's caduceus, or wand.","pos":""}],"CADUCEUS":[{"def":"The official staff or wand of Hermes or Mercury, the messenger of the gods.","pos":""}],"CADUCIBRANCHIATE":[{"def":"With temporary gills: -- applied to those Amphibia in which the gills do not remain in adult life.","pos":""}],"CADUCITY":[{"def":"Tendency to fall; the feebleness of old age; senility.","pos":""}],"CADUCOUS":[{"def":"Dropping off or disappearing early, as the calyx of a poppy, or the gills of a tadpole.","pos":""}],"CADUKE":[{"def":"Perishable; frail; transitory.","pos":""}]}