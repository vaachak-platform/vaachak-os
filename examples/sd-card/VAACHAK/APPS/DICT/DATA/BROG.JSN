{"BROG":[{"def":"A pointed instrument, as a joiner's awl, a brad awl, a needle, or a small ship stick.","pos":""}],"BROGAN":[{"def":"A stout, coarse shoe; a brogue.","pos":""}],"BROGGLE":[{"def":"To sniggle, or fish with a brog.","pos":""}],"BROGUE":[{"def":"A stout, coarse shoe; a brogan.","pos":""},{"def":"A dialectic pronunciation; esp.","pos":""}]}