{"TAP":[{"def":"To strike with a slight or gentle blow; to touch gently; to rap lightly; to pat; as, to tap one with the hand or a cane.","pos":""},{"def":"To put a new sole or heel on; as, to tap shoes.","pos":""}],"TAPA":[{"def":"A kind of cloth prepared by the Polynesians from the inner bark of the paper mulberry; -- sometimes called also kapa.","pos":""},{"def":"One of the leather hoods which cover the stirrups of a Mexican saddle.","pos":""}],"TAPAYAXIN":[{"def":"A Mexican spinous lizard (Phrynosoma orbiculare) having a head somewhat like that of a toad; -- called also horned toad.","pos":""}],"TAPE":[{"def":"A narrow fillet or band of cotton or linen; a narrow woven fabric used for strings and the like; as, curtains tied with tape.","pos":""},{"def":"A tapeline; also, a metallic ribbon so marked as to serve as a tapeline; as, a steel tape.","pos":""}],"TAPELINE":[{"def":"A painted tape, marked with linear dimensions, as inches, feet, etc.","pos":""}],"TAPER":[{"def":"A small wax candle; a small lighted wax candle; hence, a small light.","pos":""},{"def":"A tapering form; gradual diminution of thickness in an elongated object; as, the taper of a spire.","pos":""}],"TAPERED":[{"def":"Lighted with a taper or tapers; as, a tapered choir.","pos":""}],"TAPERING":[{"def":"Becoming gradually smaller toward one end.","pos":""}],"TAPERNESS":[{"def":"The quality or state of being taper; tapering form; taper.","pos":""}],"TAPESTRY":[{"def":"A fabric, usually of worsted, worked upon a warp of linen or other thread by hand, the designs being usually more or less pictorial and the stuff employed for wall hangings and the like.","pos":""}],"TAPESTRY BEETLE":[{"def":"A small black dermestoid beetle (Attagenus piceus) whose larva feeds on tapestry, carpets, silk, fur, flour, and various other goods.","pos":""}],"TAPET":[{"def":"Worked or figured stuff; tapestry.","pos":""}],"TAPETI":[{"def":"A small South American hare (Lepus Braziliensis).","pos":""}],"TAPETUM":[{"def":"An area in the pigmented layer of the choroid coat of the eye in many animals, which has an iridescent or metallic luster and helps to make the eye visible in the dark.","pos":""}],"TAPEWORM":[{"def":"Any one of numerous species of cestode worms belonging to Tænia and many allied genera.","pos":""}],"TAPHOUSE":[{"def":"A house where liquors are retailed.","pos":""}],"TAPHRENCHYMA":[{"def":"Same as Bothrenchyma.","pos":""}],"TAPINAGE":[{"def":"A lurking or skulking.","pos":""}],"TAPIOCA":[{"def":"A coarsely granular substance obtained by heating, and thus partly changing, the moistened starch obtained from the roots of the cassava.","pos":""}],"TAPIR":[{"def":"Any one of several species of large odd-toed ungulates belonging to Tapirus, Elasmognathus, and allied genera.","pos":""}],"TAPIROID":[{"def":"Allied to the tapir, or the Tapir family.","pos":""}],"TAPIS":[{"def":"Tapestry; formerly, the cover of a council table.","pos":""}],"TAPISER":[{"def":"A maker of tapestry; an upholsterer.","pos":""}],"TAPISH":[{"def":"To lie close to the ground, so as to be concealed; to squat; to crouch; hence, to hide one's self.","pos":""}],"TAPLASH":[{"def":"Bad small beer; also, the refuse or dregs of liquor.","pos":""}],"TAPLINGS":[{"def":"The strong double leathers by which the two parts of a flail are united.","pos":""}],"TAPOA TAFA":[{"def":"A small carnivorous marsupial (Phascogale penicillata) having long, soft fur, and a very long tail with a tuft of long hairs at the end; -- called also brush-tailed phascogale.","pos":""}],"TAPPEN":[{"def":"An obstruction, or indigestible mass, found in the intestine of bears and other animals during hibernation.","pos":""}],"TAPPER":[{"def":"The lesser spotted woodpecker (Dendrocopus minor); -- called also tapperer, tabberer, little wood pie, barred woodpecker, wood tapper, hickwall, and pump borer.","pos":""}],"TAPPESTER":[{"def":"A female tapster.","pos":""}],"TAPPET":[{"def":"A lever or projection moved by some other piece, as a cam, or intended to tap or touch something else, with a view to produce change or regulate motion.","pos":""}],"TAPPET ROD":[{"def":"A rod carrying a tappet or tappets, as one for closing the valves in a Cornish pumping engine.","pos":""}],"TAPPIT HEN":[{"def":"A hen having a tuft of feathers on her head.","pos":""},{"def":"A measuring pot holding one quart (according to some, three quarts); -- so called from a knob on the lid, though to resemble a crested hen.","pos":""}],"TAPPOON":[{"def":"A piece of wood or sheet metal fitted into a ditch to dam up the water so as to overflow a field.","pos":""}],"TAPROOM":[{"def":"A room where liquors are kept on tap; a barroom.","pos":""}],"TAPROOT":[{"def":"The root of a plant which penetrates the earth directly downward to a considerable depth without dividing.","pos":""}],"TAPSTER":[{"def":"One whose business is to tap or draw ale or other liquor.","pos":""}]}