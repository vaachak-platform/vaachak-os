{"INEBRIANT":[{"def":"Anything that intoxicates, as opium, alcohol, etc.","pos":""}],"INEBRIATE":[{"def":"To make drunk; to intoxicate.","pos":""}],"INEBRIATION":[{"def":"The condition of being inebriated; intoxication; figuratively, deprivation of sense and judgment by anything that exhilarates, as success.","pos":""}],"INEBRIETY":[{"def":"Drunkenness; inebriation.","pos":""}],"INEBRIOUS":[{"def":"Intoxicated, or partially so; intoxicating.","pos":""}]}