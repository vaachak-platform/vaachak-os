{"MYSELF":[{"def":"I or me in person; -- used for emphasis, my own self or person; as I myself will do it; I have done it myself; -- used also instead of me, as the object of the first person of a reflexive verb, without emphasis; as, I will defend myself.","pos":""}],"MYSIS":[{"def":"A genus of small schizopod shrimps found both in fresh and salt water; the opossum shrimps.","pos":""}],"MYSTACAL":[{"def":"Of or pertaining to the upper lip, or mustache.","pos":""},{"def":"Of or pertaining to interpretation of mysteries or to mystagogue; of the nature of mystagogy.","pos":""}],"MYSTAGOGUE":[{"def":"One who keeps and shows church relics.","pos":""}],"MYSTAGOGY":[{"def":"The doctrines, principles, or practice of a mystagogue; interpretation of mysteries.","pos":""}],"MYSTERIARCH":[{"def":"One presiding over mysteries.","pos":""}],"MYSTERIOUS":[{"def":"Of or pertaining to mystery; containing a mystery; difficult or impossible to understand; obscure not revealed or explained; enigmatical; incomprehensible.","pos":""}],"MYSTERIOUSLY":[{"def":"In a mysterious manner.","pos":""}],"MYSTERIOUSNESS":[{"def":"The state or quality of being mysterious.","pos":""},{"def":"Something mysterious; a mystery.","pos":""}],"MYSTERIZE":[{"def":"To make mysterious; to make a mystery of.","pos":""}],"MYSTERY":[{"def":"The consecrated elements in the eucharist.","pos":""}],"MYSTIC":[{"def":"One given to mysticism; one who holds mystical views, interpretations, etc.","pos":""}],"MYSTICETE":[{"def":"Any right whale, or whalebone whale.","pos":""}],"MYSTICISM":[{"def":"The doctrine that the ultimate elements or principles of knowledge or belief are gained by an act or process akin to feeling or faith.","pos":""}],"MYSTIFICATION":[{"def":"The act of mystifying, or the state of being mystied; also, something designed to, or that does, mystify.","pos":""}],"MYSTIFICATOR":[{"def":"One who mystifies.","pos":""}],"MYSTIFY":[{"def":"To involve in mystery; to make obscure or difficult to understand; as, to mystify a passage of Scripture.","pos":""},{"def":"To perplex the mind of; to puzzle; to impose upon the credulity of ; as, to mystify an opponent.","pos":""}]}