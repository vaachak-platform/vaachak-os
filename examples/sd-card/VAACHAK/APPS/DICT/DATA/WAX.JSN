{"WAX":[{"def":"To increase in size; to grow bigger; to become larger or fuller; - - opposed to wane.","pos":""},{"def":"To pass from one state to another; to become; to grow; as, to wax strong; to wax warmer or colder; to wax feeble; to wax old; to wax worse and worse.","pos":""}],"WAXBERRY":[{"def":"The wax-covered fruit of the wax myrtle, or bayberry.","pos":""}],"WAXBILL":[{"def":"Any one of numerous species of finchlike birds belonging to Estrelda and allied genera, native of Asia, Africa, and Australia.","pos":""}],"WAXEN":[{"def":"Covered with wax; waxed; as, a waxen tablet.","pos":""}],"WAXINESS":[{"def":"Quality or state of being waxy.","pos":""}],"WAXWING":[{"def":"Any one of several species of small birds of the genus Ampelis, in which some of the secondary quills are usually tipped with small horny ornaments resembling red sealing wax.","pos":""}],"WAXWORK":[{"def":"An American climbing shrub (Celastrus scandens).","pos":""}],"WAXWORKER":[{"def":"One who works in wax; one who makes waxwork.","pos":""},{"def":"A bee that makes or produces wax.","pos":""}],"WAXWORKS":[{"def":"An exhibition of wax figures, or the place of exhibition.","pos":""}],"WAXY":[{"def":"Resembling wax in appearance or consistency; viscid; adhesive; soft; hence, yielding; pliable; impressible.","pos":""}]}