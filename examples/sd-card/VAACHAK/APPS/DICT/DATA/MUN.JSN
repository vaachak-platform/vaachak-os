{"MUN":[{"def":"One a penny, two a penny, hot cross buns, Butter them and sugar them and put them in your muns.","pos":""}],"MUNCH":[{"def":"To chew with a grinding, crunching sound, as a beast chews provender; to chew deliberately or in large mouthfuls.","pos":""}],"MUNCHAUSENISM":[{"def":"An extravagant fiction embodying an account of some marvelous exploit or adventure.","pos":""}],"MUNCHER":[{"def":"One who munches.","pos":""}],"MUNDANE":[{"def":"Of or pertaining to the world; worldly; earthly; terrestrial; as, the mundane sphere.","pos":""}],"MUNDATION":[{"def":"The act of cleansing.","pos":""}],"MUNDATORY":[{"def":"Cleansing; having power to cleanse.","pos":""}],"MUNDIC":[{"def":"Iron pyrites, or arsenical pyrites; -- so called by the Cornish miners.","pos":""}],"MUNDIFICANT":[{"def":"Serving to cleanse and heal.","pos":""},{"def":"A mundificant ointment or plaster.","pos":""}],"MUNDIFICATION":[{"def":"The act or operation of cleansing.","pos":""}],"MUNDIFICATIVE":[{"def":"A detergent medicine or preparation.","pos":""}],"MUNDIL":[{"def":"A turban ornamented with an imitation of gold or silver embroidery.","pos":""}],"MUNDIVAGANT":[{"def":"Wandering over the world.","pos":""}],"MUNDUNGUS":[{"def":"A stinking tobacco.","pos":""}],"MUNERARY":[{"def":"Having the nature of a gift.","pos":""}],"MUNG":[{"def":"Green gram, a kind of pulse (Phaseolus Mungo), grown for food in British India.","pos":""}],"MUNGA":[{"def":"See Bonnet monkey, under Bonnet.","pos":""}],"MUNGCORN":[{"def":"Same as Mangcorn.","pos":""}],"MUNGO":[{"def":"A fibrous material obtained by deviling rags or the remnants of woolen goods.","pos":""}],"MUNICIPAL":[{"def":"Of or pertaining to a city or a corporation having the right of administering local government; as, municipal rights; municipal officers.","pos":""},{"def":"Of or pertaining to a state, kingdom, or nation.","pos":""}],"MUNICIPALISM":[{"def":"Municipal condition.","pos":""}],"MUNICIPALITY":[{"def":"A municipal district; a borough, city, or incorporated town or village.","pos":""}],"MUNICIPALIZE":[{"def":"To bring under municipal oversight or control; as, a municipalized industry.","pos":""}],"MUNICIPALLY":[{"def":"In a municipal relation or condition.","pos":""}],"MUNIFIC":[{"def":"Munificent; liberal.","pos":""}],"MUNIFICENCE":[{"def":"Means of defense; fortification.","pos":""}],"MUNIFICENT":[{"def":"Very liberal in giving or bestowing; lavish; as, a munificent benefactor.","pos":""}],"MUNIFY":[{"def":"To prepare for defense; to fortify.","pos":""}],"MUNIMENT":[{"def":"A record; the evidences or writings whereby a man is enabled to defend the title to his estate; title deeds and papers.","pos":""}],"MUNITE":[{"def":"To fortify; to strengthen.","pos":""}],"MUNITION":[{"def":"Fortification; stronghold.","pos":""},{"def":"Whatever materials are used in war for drfense or for annoying an enemy; ammunition; also, stores and provisions; military stores of all kinds.","pos":""}],"MUNITY":[{"def":"Freedom; security; immunity.","pos":""}],"MUNJEET":[{"def":"See Indian madder, under Madder.","pos":""}],"MUNJISTIN":[{"def":"An orangered coloring substance resembling alizarin, found in the root of an East Indian species of madder (Rubia munjista).","pos":""}],"MUNNION":[{"def":"Same as Mullion; -- especially used in joiner's work.","pos":""}],"MUNTJAC":[{"def":"Any one of several species of small Asiatic deer of the genus Cervulus, esp.","pos":""}],"MUNTZ METAL":[{"def":"See under Metal.","pos":""}]}