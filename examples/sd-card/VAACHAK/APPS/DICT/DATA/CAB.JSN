{"CAB":[{"def":"A kind of close carriage with two or four wheels, usually a public vehicle.","pos":""},{"def":"The covered part of a locomotive, in which the engineer has his station.","pos":""}],"CABAL":[{"def":"Tradition; occult doctrine.","pos":""}],"CABALA":[{"def":"A kind of occult theosophy or traditional interpretation of the Scriptures among Jewish rabbis and certain mediæval Christians, which treats of the nature of god and the mystery of human existence.","pos":""},{"def":"Secret science in general; mystic art; mystery.","pos":""}],"CABALISM":[{"def":"The secret science of the cabalists.","pos":""},{"def":"A superstitious devotion to the mysteries of the religion which one professes.","pos":""}],"CABALIST":[{"def":"One versed in the cabala, or the mysteries of Jewish traditions.","pos":""},{"def":"Of or pertaining to the cabala; containing or conveying an occult meaning; mystic.","pos":""}],"CABALISTICALLY":[{"def":"In a cabalistic manner.","pos":""}],"CABALIZE":[{"def":"To use cabalistic language.","pos":""}],"CABALLER":[{"def":"A close caballer and tongue-valiant lord.","pos":""}],"CABALLERIA":[{"def":"An ancient Spanish land tenure similar to the English knight's fee; hence, in Spain and countries settled by the Spanish, a land measure of varying size.","pos":""}],"CABALLERO":[{"def":"A knight or cavalier; hence, a gentleman.","pos":""}],"CABALLINE":[{"def":"Of or pertaining to a horse.","pos":""},{"def":"Caballine aloes.","pos":""}],"CABALLO":[{"def":"Ca*bal\"lo (ka*väl\"yo; 220), n.","pos":""}],"CABARET":[{"def":"A tavern; a house where liquors are retailed.","pos":""}],"CABAS":[{"def":"A flat basket or frail for figs, etc.","pos":""}],"CABASSOU":[{"def":"A speciec of armadillo of the genus Xenurus (X.","pos":""}],"CABBAGE":[{"def":"An esculent vegetable of many varieties, derived from the wild Brassica oleracea of Europe.","pos":""},{"def":"The terminal bud of certain palm trees, used, like, cabbage, for food.","pos":""}],"CABBLER":[{"def":"One who works at cabbling.","pos":""}],"CABBLING":[{"def":"The process of breaking up the flat masses into which wrought iron is first hammered, in order that the pieces may be reheated and wrought into bar iron.","pos":""},{"def":"The finest kind of silk received from India.","pos":""}],"CABER":[{"def":"A pole or beam used in Scottish games for tossing as a trial of strength.","pos":""}],"CABEZON":[{"def":"A California fish (Hemilepidotus spinosus), allied to the sculpin.","pos":""}],"CABIN":[{"def":"A cottage or small house; a hut.","pos":""},{"def":"A small room; an inclosed place.","pos":""}],"CABINET":[{"def":"A hut; a cottage; a small house.","pos":""},{"def":"A small room, or retired apartment; a closet.","pos":""}],"CABINETMAKER":[{"def":"One whose occupation is to make cabinets or other choice articles of household furniture, as tables, bedsteads, bureaus, etc.","pos":""}],"CABINETMAKING":[{"def":"The art or occupation of making the finer articles of household furniture.","pos":""}],"CABINETWORK":[{"def":"The art or occupation of working upon wooden furniture requiring nice workmanship; also, such furniture.","pos":""}],"CABIREAN":[{"def":"Cab`i*re\"an Defn: ,n.","pos":"noun"}],"CABIRI":[{"def":"Certain deities originally worshiped with mystical rites by the Pelasgians in Lemnos and Samothrace and afterwards throughout Greece; -- also called sons of Hephæstus (or Vulcan), as being masters of the art of working metals.","pos":""}],"CABIRIAN":[{"def":"Same as Cabiric.","pos":""}],"CABIRIC":[{"def":"Of or pertaining to the Cabiri, or to their mystical worship.","pos":""}],"CABLE":[{"def":"A molding, shaft of a column, or any other member of convex, rounded section, made to resemble the spiral twist of a rope; -- called also cable molding.","pos":""}],"CABLED":[{"def":"Adorned with cabling.","pos":""}],"CABLEGRAM":[{"def":"A message sent by a submarine telegraphic cable.","pos":""}],"CABLELAID":[{"def":"Composed of three three-stranded ropes, or hawsers, twisted together to form a cable.","pos":""}],"CABLET":[{"def":"A little cable less than ten inches in circumference.","pos":""}],"CABLING":[{"def":"The decoration of a fluted shaft of a column or of a pilaster with reeds, or rounded moldings, which seem to be laid in the hollows of the fluting.","pos":""}],"CABMAN":[{"def":"The driver of a cab.","pos":""}],"CABOB":[{"def":"A small piece of mutton or other meat roasted on a skewer; -- so called in Turkey and Persia.","pos":""},{"def":"A leg of mutton roasted, stuffed with white herrings and sweet herbs.","pos":""}],"CABOCHED":[{"def":"Showing the full face, but nothing of the neck; -- said of the head of a beast in armorial bearing.","pos":""}],"CABOCHON":[{"def":"A stone of convex form, highly polished, but not faceted; also, the style of cutting itself.","pos":""}],"CABOODLE":[{"def":"The whole collection; the entire quantity or number; -- usually in the phrase the whole caboodle.","pos":""}],"CABOOSE":[{"def":"A house on deck, where the cooking is done; -- commonly called the galley.","pos":""},{"def":"A car used on freight or construction trains for brakemen, workmen, etc.","pos":""}],"CABOTAGE":[{"def":"Navigation along the coast; the details of coast pilotage.","pos":""}],"CABREE":[{"def":"The pronghorn antelope.","pos":""}],"CABRERITE":[{"def":"An apple-green mineral, a hydrous arseniate of nickel, cobalt, and magnesia; -- so named from the Sierra Cabrera, Spain.","pos":""}],"CABRILLA":[{"def":"A name applied to various species of edible fishes of the genus Serranus, and related genera, inhabiting the Meditarranean, the coast of California, etc.","pos":""}],"CABRIOLE":[{"def":"A curvet; a leap.","pos":""}],"CABRIOLET":[{"def":"A one-horse carriage with two seats and a calash top.","pos":"noun"}],"CABURN":[{"def":"A small line made of spun yarn, to bind or worm cables, seize tackles, etc.","pos":""},{"def":"A degenerated or poisoned condition of the blood.","pos":""}]}