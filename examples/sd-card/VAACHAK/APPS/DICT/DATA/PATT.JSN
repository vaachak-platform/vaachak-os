{"PATTEN":[{"def":"A clog or sole of wood, usually supported by an iron ring, worn to raise the feet from the wet or the mud.","pos":""}],"PATTENED":[{"def":"Wearing pattens.","pos":""}],"PATTER":[{"def":"To strike with a quick succession of slight, sharp sounds; as, pattering rain or hail; pattering feet.","pos":""},{"def":"To mutter; to mumble; as, to patter with the lips.","pos":""}],"PATTERER":[{"def":"One who patters, or talks glibly; specifically, a street peddler.","pos":""}],"PATTERN":[{"def":"A full-sized model around which a mold of sand is made, to receive the melted metal.","pos":""}],"PATTINSON'S PROCESS":[{"def":"A process of desilverizing argentiferous lead by repeated meltings and skimmings, which concentrate the silver in the molten bath, the final skimmings being nearly pure lad.","pos":""}],"PATTYPAN":[{"def":"A pan for baking patties.","pos":""}]}