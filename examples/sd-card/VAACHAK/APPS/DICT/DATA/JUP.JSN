{"JUPATI PALM":[{"def":"A great Brazilian palm tree (Raphia tædigera), used by the natives for many purposes.","pos":""}],"JUPITER":[{"def":"The supreme deity, king of gods and men, and reputed to be the son of Saturn and Rhea; Jove.","pos":""},{"def":"One of the planets, being the brightest except Venus, and the largest of them all, its mean diameter being about 85,000 miles.","pos":""}]}