{"MISPAINT":[{"def":"To paint ill, or wrongly.","pos":""}],"MISPASSION":[{"def":"Wrong passion or feeling.","pos":""}],"MISPAY":[{"def":"See Misspell, Misspend, etc.","pos":""}],"MISPERCEPTION":[{"def":"Erroneous perception.","pos":""}],"MISPERSUADE":[{"def":"To persuade amiss.","pos":""}],"MISPERSUASION":[{"def":"A false persuasion; wrong notion or opinion.","pos":""}],"MISPICKEL":[{"def":"Arsenical iron pyrites; arsenopyrite.","pos":""}],"MISPLACE":[{"def":"To put in a wrong place; to set or place on an improper or unworthy object; as, he misplaced his confidence.","pos":""}],"MISPLACEMENT":[{"def":"The act of misplacing, or the state of being misplaced.","pos":""}],"MISPLEAD":[{"def":"To err in pleading.","pos":""}],"MISPLEADING":[{"def":"An error in pleading.","pos":""}],"MISPOINT":[{"def":"To point improperly; to punctuate wrongly.","pos":""}],"MISPOLICY":[{"def":"Wrong policy; impolicy.","pos":""}],"MISPRAISE":[{"def":"To praise amiss.","pos":""}],"MISPRINT":[{"def":"A mistake in printing; a deviation from the copy; as, a book full of misprints.","pos":""}],"MISPRISION":[{"def":"A neglect, negligence, or contempt.","pos":""}],"MISPRIZE":[{"def":"To slight or undervalue.","pos":""}],"MISPROCEEDING":[{"def":"Wrong or irregular proceding.","pos":""}],"MISPROFESS":[{"def":"To make a false profession; to make pretensions to skill which is not possessed.","pos":""}],"MISPRONOUNCE":[{"def":"To pronounce incorrectly.","pos":""}],"MISPRONUNCIATION":[{"def":"Wrong or improper pronunciation.","pos":""}],"MISPROPORTION":[{"def":"To give wrong proportions to; to join without due proportion.","pos":""}],"MISPROUD":[{"def":"Viciously proud.","pos":""}],"MISPUNCTUATE":[{"def":"To punctuate wrongly or incorrectly.","pos":""}]}