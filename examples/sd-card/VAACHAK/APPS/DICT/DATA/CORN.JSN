{"CORN":[{"def":"A thickening of the epidermis at some point, esp.","pos":""}],"CORNAGE":[{"def":"Anancient tenure of land, which obliged the tenant to give notice of an invasion by blowing a horn.","pos":""}],"CORNAMUTE":[{"def":"Cor\"na*mute (kr\"n-mt), n.","pos":""}],"CORNBIND":[{"def":"A weed that binds stalks of corn, as Convolvulus arvensis, Polygonum Convolvulus.","pos":""}],"CORNCOB":[{"def":"The cob or axis on which the kernels of Indian corn grow.","pos":""}],"CORNCRAKE":[{"def":"A bird (Crex crex or C.","pos":""}],"CORNCRIB":[{"def":"A crib for storing corn.","pos":""}],"CORNCUTTER":[{"def":"A machine for cutting up stalks of corn for food of cattle.","pos":""},{"def":"An implement consisting of a long blade, attached to a handle at nearly a right angle, used for cutting down the stalks of Indian corn.","pos":""}],"CORNDODGER":[{"def":"A cake made of the meal of Indian corn, wrapped in a covering of husks or paper, and baked under the embers.","pos":""}],"CORNEA":[{"def":"The transparent part of the coat of the eyeball which covers the iris and pupil and admits light to the interior.","pos":""}],"CORNEAL":[{"def":"Pertaining to the cornea.","pos":""}],"CORNEL":[{"def":"The cornelian cherry (Cornus Mas), a European shrub with clusters of small, greenish flowers, followed by very acid but edible drupes resembling cherries.","pos":""}],"CORNELIAN":[{"def":"Same as Carnelian.","pos":""}],"CORNEMUSE":[{"def":"A wind instrument nearly identical with the bagpipe.","pos":""}],"CORNEOCALCAREOUS":[{"def":"Formed of a mixture of horny and calcareous materials, as some shells and corals.","pos":""}],"CORNEOUS":[{"def":"Of a texture resembling horn; horny; hard.","pos":""}],"CORNER":[{"def":"The point where two converging lines meet; an angle, either external or internal.","pos":""},{"def":"The space in the angle between converging lines or walls which meet in a point; as, the chimney corner.","pos":""}],"CORNERCAP":[{"def":"The chief ornament.","pos":""}],"CORNERED":[{"def":"1 Having corners or angles.","pos":""}],"CORNERWISE":[{"def":"With the corner in front; diagonally; not square.","pos":""}],"CORNET":[{"def":"A cap of paper twisted at the end, used by retailers to inclose small wares.","pos":""},{"def":"A headdress: (a) A square cap anciently worn as a mark of certain professions.","pos":""}],"CORNET-A-PISTON":[{"def":"A brass wind instrument, like the trumpet, furnished with valves moved by small pistons or sliding rods; a cornopean; a cornet.","pos":""}],"CORNETCY":[{"def":"The commission or rank of a cornet.","pos":""}],"CORNETER":[{"def":"One who blows a cornet.","pos":""}],"CORNEULE":[{"def":"One of the corneas of a compound eye in the invertebrates.","pos":""}],"CORNFIELD":[{"def":"A field where corn is or has been growing; -- in England, a field of wheat, rye, barley, or oats; in America, a field of Indian corn.","pos":""}],"CORNFLOOR":[{"def":"A thrashing floor.","pos":""}],"CORNFLOWER":[{"def":"A conspicuous wild flower (Centaurea Cyanus), growing in grainfields.","pos":""}],"CORNIC":[{"def":"Pertaining to, derived from, or resembling, the dogwood (Cornus florida).","pos":""}],"CORNICE":[{"def":"Any horizontal, molded or otherwise decorated projection which crowns or finishes the part to which it is affixed; as, the cornice of an order, pedestal, door, window, or house.","pos":""}],"CORNICED":[{"def":"Having a cornice.","pos":""}],"CORNICLE":[{"def":"Cor\"ni*cle (kr\"n-k'l), n.","pos":""}],"CORNICULAR":[{"def":"A secretary or clerk.","pos":""}],"CORNICULATE":[{"def":"Having processes resembling small horns.","pos":""}],"CORNICULUM":[{"def":"A small hornlike part or process.","pos":""}],"CORNIFEROUS":[{"def":"Of or pertaining to the lowest period of the Devonian age.","pos":""}],"CORNIFIC":[{"def":"Producing horns; forming horn.","pos":""}],"CORNIFICATION":[{"def":"Conversion into, or formation of, horn; a becoming like horn.","pos":""}],"CORNIFIED":[{"def":"Converted into horn; horny.","pos":""}],"CORNIFORM":[{"def":"Having the shape of a horn; horn-shaped.","pos":""}],"CORNIGEROUS":[{"def":"Horned; having horns; as, cornigerous animals.","pos":""}],"CORNIPLUME":[{"def":"A hornlike tuft of feathers on the head of some birds.","pos":""}],"CORNISH":[{"def":"Of or pertaining to Cornwall, in England.","pos":""}],"CORNIST":[{"def":"A performer on the cornet or horn.","pos":""}],"CORNLOFT":[{"def":"A loft for corn; a granary.","pos":""}],"CORNO DI BASSETTO":[{"def":"A tenor clarinet; -- called also basset horn, and sometimes confounded with the English horn, which is a tenor oboe.","pos":""}],"CORNO INGLESE":[{"def":"A reed instrument, related to the oboe, but deeper in pitch; the English horn.","pos":""}],"CORNOPEAN":[{"def":"An obsolete name for the cornet-à-piston.","pos":""}],"CORNSHELLER":[{"def":"A machine that separates the kernels of corn from the cob.","pos":""}],"CORNSHUCK":[{"def":"The husk covering an ear of Indian corn.","pos":""}],"CORNSTALK":[{"def":"A stalk of Indian corn.","pos":""}],"CORNSTARCH":[{"def":"Starch made from Indian corn, esp.","pos":""}],"CORNU":[{"def":"A horn, or anything shaped like or resembling a horn.","pos":""}],"CORNU AMMONIS":[{"def":"A fossil shell, curved like a ram's horn; an obsolete name for an ammonite.","pos":""}],"CORNUCOPIA":[{"def":"A genus of grasses bearing spikes of flowers resembling the cornucopia in form.","pos":""}],"CORNUTE":[{"def":"To bestow horns upon; to make a cuckold of; to cuckold.","pos":""}],"CORNUTO":[{"def":"A man that wears the horns; a cuckold.","pos":""}],"CORNUTOR":[{"def":"A cuckold maker.","pos":""}],"CORNY":[{"def":"Strong, stiff, or hard, like a horn; resembling horn.","pos":""}]}