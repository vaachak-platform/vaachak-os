{"GAY":[{"def":"Excited with merriment; manifesting sportiveness or delight; inspiring delight; livery; merry.","pos":""},{"def":"Brilliant in colors; splendid; fine; richly dressed.","pos":""}],"GAYAL":[{"def":"A Southern Asiatic species of wild cattle (Bibos frontalis).","pos":""}],"GAYDIANG":[{"def":"A vessel of Anam, with two or three masts, lofty triangular sails, and in construction somewhat resembling a Chinese junk.","pos":""}],"GAYETY":[{"def":"The state of being gay; merriment; mirth; acts or entertainments prompted by, or inspiring, merry delight; -- used often in the plural; as, the gayeties of the season.","pos":""},{"def":"Finery; show; as, the gayety of dress.","pos":""}],"GAYLEY PROCESS":[{"def":"The process of removing moisture from the blast of an iron blast furnace by reducing its temperature so far that it will not remain suspended as vapor in the blast current, but will be deposited as snow in the cooling apparatus.","pos":""}],"GAYLUSSITE":[{"def":"A yellowish white, translucent mineral, consisting of the carbonates of lime and soda, with water.","pos":""}],"GAYLY":[{"def":"With mirth and frolic; merrily; blithely; gleefully.","pos":""},{"def":"Finely; splendidly; showily; as, ladies gayly dressed; a flower gayly blooming.","pos":""}],"GAYTRE":[{"def":"The dogwood tree.","pos":""}]}