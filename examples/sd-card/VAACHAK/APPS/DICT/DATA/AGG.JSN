{"AGGENERATION":[{"def":"The act of producing in addition.","pos":""}],"AGGER":[{"def":"An earthwork; a mound; a raised work.","pos":""}],"AGGERATION":[{"def":"A heaping up; accumulation; as, aggerations of sand.","pos":""}],"AGGEROSE":[{"def":"In heaps; full of heaps.","pos":""}],"AGGEST":[{"def":"The violence of the waters aggested the earth.","pos":""}],"AGGLOMERATE":[{"def":"To wind or collect into a ball; hence, to gather into a mass or anything like a mass.","pos":""}],"AGGLOMERATION":[{"def":"The act or process of collecting in a mass; a heaping together.","pos":""},{"def":"State of being collected in a mass; a mass; cluster.","pos":""}],"AGGLOMERATIVE":[{"def":"Having a tendency to gather together, or to make collections.","pos":""}],"AGGLUTINANT":[{"def":"Uniting, as glue; causing, or tending to cause, adhesion.","pos":""},{"def":"Any viscous substance which causes bodies or parts to adhere.","pos":""}],"AGGLUTINATE":[{"def":"To unite, or cause to adhere, as with glue or other viscous substance; to unite by causing an adhesion of substances.","pos":""}],"AGGLUTINATION":[{"def":"Combination in which root words are united with little or no change of form or loss of meaning.","pos":""}],"AGGLUTINATIVE":[{"def":"Formed or characterized by agglutination, as a language or a compound.","pos":""}],"AGGRACE":[{"def":"To favor; to grace.","pos":""}],"AGGRADE":[{"def":"To bring, or tend to bring, to a uniform grade, or slope, by addition of material; as, streams aggrade their beds by depositing sediment.","pos":""}],"AGGRANDIZABLE":[{"def":"Capable of being aggrandized.","pos":""}],"AGGRANDIZATION":[{"def":"Ag*gran`di*za\"tion, n.","pos":""}],"AGGRANDIZE":[{"def":"To make great; to enlarge; to increase; as, to aggrandize our conceptions, authority, distress.","pos":""},{"def":"To make great or greater in power, rank, honor, or wealth; -- applied to persons, countries, etc.","pos":""}],"AGGRANDIZEMENT":[{"def":"The act of aggrandizing, or the state of being aggrandized or exalted in power, rank, honor, or wealth; exaltation; enlargement; as, the emperor seeks only the aggrandizement of his own family.","pos":""}],"AGGRANDIZER":[{"def":"One who aggrandizes, or makes great.","pos":""}],"AGGRATE":[{"def":"Each one sought his lady to aggrate.","pos":""}],"AGGRAVATE":[{"def":"To make heavy or heavier; to add to; to increase.","pos":""},{"def":"To make worse, or more severe; to render less tolerable or less excusable; to make more offensive; to enhance; to intensify.","pos":""}],"AGGRAVATING":[{"def":"Making worse or more heinous; as, aggravating circumstances.","pos":""},{"def":"Exasperating; provoking; irritating.","pos":""}],"AGGRAVATINGLY":[{"def":"In an aggravating manner.","pos":""}],"AGGRAVATION":[{"def":"The act of aggravating, or making worse; -- used of evils, natural or moral; the act of increasing in severity or heinousness; something additional to a crime or wrong and enhancing its guilt or injurious consequences.","pos":""},{"def":"Exaggerated representation.","pos":""}],"AGGRAVATIVE":[{"def":"Tending to aggravate.","pos":""}],"AGGREGATE":[{"def":"Formed by a collection of particulars into a whole mass or sum; collective.","pos":""}],"AGGREGATELY":[{"def":"Collectively; in mass.","pos":""}],"AGGREGATION":[{"def":"The act of aggregating, or the state of being aggregated; collection into a mass or sum; a collection of particulars; an aggregate.","pos":""}],"AGGREGATIVE":[{"def":"Taken together; collective.","pos":""},{"def":"Gregarious; social.","pos":""}],"AGGREGATOR":[{"def":"One who aggregates.","pos":""}],"AGGREGE":[{"def":"To make heavy; to aggravate.","pos":""}],"AGGRESS":[{"def":"To commit the first act of hostility or offense; to begin a quarrel or controversy; to make an attack; -- with on.","pos":""}],"AGGRESSION":[{"def":"The first attack, or act of hostility; the first act of injury, or first act leading to a war or a controversy; unprovoked attack; assault; as, a war of aggression.","pos":""}],"AGGRESSIVE":[{"def":"Tending or disposed to aggress; characterized by aggression; making assaults; unjustly attacking; as, an aggressive policy, war, person, nation.","pos":""}],"AGGRESSOR":[{"def":"The person who first attacks or makes an aggression; he who begins hostility or a quarrel; an assailant.","pos":""}],"AGGRIEVANCE":[{"def":"Oppression; hardship; injury; grievance.","pos":""}],"AGGRIEVE":[{"def":"To give pain or sorrow to; to afflict; hence, to oppress or injure in one's rights; to bear heavily upon; -- now commonly used in the passive TO be aggrieved.","pos":""}],"AGGROUP":[{"def":"To bring together in a group; to group.","pos":""}],"AGGROUPMENT":[{"def":"Arrangement in a group or in groups; grouping.","pos":""},{"def":"Applied to a kind of variegated glass beads of ancient manufacture; as, aggry beads are found in Ashantee and Fantee in Africa.","pos":""}]}