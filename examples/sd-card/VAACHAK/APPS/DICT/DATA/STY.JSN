{"STY":[{"def":"A pen or inclosure for swine.","pos":""},{"def":"A place of bestial debauchery.","pos":""}],"STYAN":[{"def":"See Sty, a boil.","pos":""}],"STYCA":[{"def":"An anglo-Saxon copper coin of the lowest value, being worth half a farthing.","pos":""}],"STYCERIN":[{"def":"A triacid alcohol, related to glycerin, and obtained from certain styryl derivatives as a yellow, gummy, amorphous substance; - - called also phenyl glycerin.","pos":""}],"STYE":[{"def":"See Sty, a boil.","pos":""}],"STYGIAN":[{"def":"Of or pertaining to the river Styx; hence, hellish; infernal.","pos":""}],"STYLAGALMAIC":[{"def":"Performing the office of columns; as, Atlantes and Caryatides are stylagalmaic figures or images.","pos":""}],"STYLASTER":[{"def":"Any one of numerous species of delicate, usually pink, calcareous hydroid corals of the genus Stylaster.","pos":""}],"STYLE":[{"def":"The pin, or gnomon, of a dial, the shadow of which indicates the hour.","pos":""},{"def":"The elongated part of a pistil between the ovary and the stigma.","pos":""}],"STYLET":[{"def":"A small poniard; a stiletto.","pos":""},{"def":"Any small, more or less rigid, bristlelike organ; as, the caudal stylets of certain insects; the ventral stylets of certain Infusoria.","pos":""}],"STYLIFEROUS":[{"def":"Bearing one or more styles.","pos":""}],"STYLIFORM":[{"def":"Having the form of, or resembling, a style, pin, or pen; styloid.","pos":""}],"STYLISH":[{"def":"Having style or artistic quality; given to, or fond of, the display of style; highly fashionable; modish; as, a stylish dress, house, manner.","pos":""}],"STYLIST":[{"def":"One who is a master or a model of style, especially in writing or speaking; a critic of style.","pos":""}],"STYLISTIC":[{"def":"Of or pertaining to style in language.","pos":""}],"STYLITE":[{"def":"One of a sect of anchorites in the early church, who lived on the tops of pillars for the exercise of their patience; -- called also pillarist and pillar saint.","pos":""}],"STYLO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the styloid process of the temporal bone; as, stylohyal, stylomastoid, stylomaxillary.","pos":""}],"STYLOBATE":[{"def":"The uninterrupted and continuous flat band, coping, or pavement upon which the bases of a row of columns are supported.","pos":""}],"STYLOGLOSSAL":[{"def":"Of or pertaining to styloid process and the tongue.","pos":""}],"STYLOGRAPH":[{"def":"A stylographic pen.","pos":""}],"STYLOGRAPHIC":[{"def":"Of or pertaining to stylography; used in stylography; as, stylographic tablets.","pos":""},{"def":"Pertaining to, or used in, stylographic pen; as, stylographic ink.","pos":""}],"STYLOGRAPHICAL":[{"def":"Same as Stylographic, 1.","pos":""}],"STYLOGRAPHY":[{"def":"A mode of writing or tracing lines by means of a style on cards or tablets.","pos":""}],"STYLOHYAL":[{"def":"A segment in the hyoidean arch between the epihyal and tympanohyal.","pos":""}],"STYLOHYOID":[{"def":"Of or pertaining to the styloid process and the hyoid bone.","pos":""}],"STYLOID":[{"def":"Of or pertaining to the styloid process.","pos":""}],"STYLOMASTOID":[{"def":"Of or pertaining to the styloid and mastoid processes of the temporal bone.","pos":""}],"STYLOMAXILLARY":[{"def":"Of or pertaining to the styloid process and the maxilla.","pos":""}],"STYLOMETER":[{"def":"An instrument for measuring columns.","pos":""}],"STYLOMMATA":[{"def":"Same as Stylommatophora.","pos":""}],"STYLOMMATOPHORA":[{"def":"A division of Pulmonata in which the eyes are situated at the tips of the tentacles.","pos":""}],"STYLOMMATOPHOROUS":[{"def":"Of or pertaining to Stylommatophora.","pos":""}],"STYLOPODIUM":[{"def":"An expansion at the base of the style, as in umbelliferous plants.","pos":""}],"STYLOPS":[{"def":"A genus of minute insects parasitic, in their larval state, on bees and wasps.","pos":""}],"STYLUS":[{"def":"An instrument for writing.","pos":""},{"def":"A pen-shaped pointing device used to specify the cursor position on a graphics tablet.","pos":""}],"STYPHNATE":[{"def":"A salt of styphnic acid.","pos":""}],"STYPHNIC":[{"def":"Pertaining to, or designating, a yellow crystalline astringent acid, (NO2)3.","pos":""}],"STYPTIC":[{"def":"Producing contraction; stopping bleeding; having the quality of restraining hemorrhage when applied to the bleeding part; astringent.","pos":""}],"STYPTICAL":[{"def":"Styptic; astringent.","pos":""}],"STYPTICITY":[{"def":"The quality or state of being styptic; astringency.","pos":""}],"STYRACIN":[{"def":"A white crystalline tasteless substance extracted from gum storax, and consisting of a salt of cinnamic acid with cinnamic alcohol.","pos":""}],"STYRAX":[{"def":"A genus of shrubs and trees, mostly American or Asiatic, abounding in resinous and aromatic substances.","pos":""}],"STYROLENE":[{"def":"An unsaturated hydrocarbon, C8H8, obtained by the distillation of storax, by the decomposition of cinnamic acid, and by the condensation of acetylene, as a fragrant, aromatic, mobile liquid; -- called also phenyl ethylene, vinyl benzene, styrol, styrene, and cinnamene.","pos":""}],"STYRONE":[{"def":"A white crystalline substance having a sweet taste and a hyacinthlike odor, obtained by the decomposition of styracin; -- properly called cinnamic, or styryl, alcohol.","pos":""}],"STYRYL":[{"def":"A hypothetical radical found in certain derivatives of styrolene and cinnamic acid; -- called also cinnyl, or cinnamyl.","pos":""}],"STYX":[{"def":"The principal river of the lower world, which had to be crossed in passing to the regions of the dead.","pos":""}]}