{"INCOHERENT":[{"def":"Not coherent; wanting cohesion; loose; unconnected; physically disconnected; not fixed to each; -- said of material substances.","pos":""},{"def":"Wanting coherence or agreement; incongruous; inconsistent; having no dependence of one part on another; logically disconnected.","pos":""}],"INCOHERENTIFIC":[{"def":"Causing incoherence.","pos":""}],"INCOHERENTLY":[{"def":"In an incoherent manner; without due connection of parts.","pos":""}],"INCOHERENTNESS":[{"def":"In`co*her\"ent*ness, n.","pos":""}]}