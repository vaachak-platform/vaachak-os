{"BRIE CHEESE":[{"def":"A kind of soft French cream cheese; -- so called from the district in France where it is made; --called also fromage de Brie.","pos":""}],"BRIEF":[{"def":"Short in duration.","pos":""},{"def":"Concise; terse; succinct.","pos":""}],"BRIEFLESS":[{"def":"Having no brief; without clients; as, a briefless barrister.","pos":""}],"BRIEFLY":[{"def":"Concisely; in few words.","pos":""}],"BRIEFMAN":[{"def":"One who makes a brief.","pos":""},{"def":"A copier of a manuscript.","pos":""}],"BRIEFNESS":[{"def":"The quality of being brief; brevity; conciseness in discourse or writing.","pos":""}],"BRIERED":[{"def":"Set with briers.","pos":""}],"BRIERY":[{"def":"Full of briers; thorny.","pos":""}]}