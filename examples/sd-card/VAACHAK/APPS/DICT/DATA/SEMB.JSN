{"SEMBLABLE":[{"def":"Like; similar; resembling.","pos":""}],"SEMBLANCE":[{"def":"Seeming; appearance; show; figure; form.","pos":""},{"def":"Likeness; resemblance, actual or apparent; similitude; as, the semblance of worth; semblance of virtue.","pos":""}],"SEMBLANT":[{"def":"Like; resembling.","pos":""},{"def":"Seeming, rather than real; apparent.","pos":""}],"SEMBLATIVE":[{"def":"And all is semblative a woman's part.","pos":""}],"SEMBLE":[{"def":"It seems; -- chiefly used impersonally in reports and judgments to express an opinion in reference to the law on some point not necessary to be decided, and not intended to be definitely settled in the cause.","pos":""}],"SEMBLING":[{"def":"The practice of attracting the males of Lepidoptera or other insects by exposing the female confined in a cage.","pos":""}]}