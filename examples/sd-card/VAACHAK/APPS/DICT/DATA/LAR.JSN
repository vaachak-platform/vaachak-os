{"LAR":[{"def":"A tutelary deity; a deceased ancestor regarded as a protector of the family.","pos":""}],"LARAMIE GROUP":[{"def":"An extensive series of strata, principally developed in the Rocky Mountain region, as in the Laramie Mountains, and formerly supposed to be of the Tertiary age, but now generally regarded as Cretaceous, or of intermediate and transitional character.","pos":""}],"LARBOARD":[{"def":"The left-hand side of a ship to one on board facing toward the bow; port; -- opposed to Ant: starboard.","pos":""}],"LARCENOUS":[{"def":"Having the character of larceny; as, a larcenous act; committing larceny.","pos":""}],"LARCENY":[{"def":"The unlawful taking and carrying away of things personal with intent to deprive the right owner of the same; theft.","pos":""}],"LARCH":[{"def":"A genus of coniferous trees, having deciduous leaves, in fascicles (see Illust.","pos":""}],"LARCHEN":[{"def":"Of or pertaining to the larch.","pos":""}],"LARD":[{"def":"Bacon; the flesh of swine.","pos":""},{"def":"The fat of swine, esp.","pos":""}],"LARDACEIN":[{"def":"A peculiar amyloid substance, colored blue by iodine and sulphuric acid, occurring mainly as an abnormal infiltration into the spleen, liver, etc.","pos":""}],"LARDACEOUS":[{"def":"Consisting of, or resembling, lard.","pos":""}],"LARDER":[{"def":"A room or place where meat and other articles of food are kept before they are cooked.","pos":""}],"LARDERER":[{"def":"One in charge of the larder.","pos":""}],"LARDERY":[{"def":"A bit of fat pork or bacon used in larding.","pos":""}],"LARDY":[{"def":"Containing, or resembling, lard; of the character or consistency of lard.","pos":""}],"LARE":[{"def":"To feed; to fatten.","pos":""}],"LARGE":[{"def":"Crossing the line of a ship's course in a favorable direction; -- said of the wind when it is abeam, or between the beam and the quarter.","pos":""}],"LARGE-ACRED":[{"def":"Possessing much land.","pos":""}],"LARGE-HANDED":[{"def":"Having large hands, Fig.","pos":""}],"LARGE-HEARTED":[{"def":"Having a large or generous heart or disposition; noble; liberal.","pos":""}],"LARGELY":[{"def":"In a large manner.","pos":""}],"LARGENESS":[{"def":"The quality or state of being large.","pos":""}],"LARGET":[{"def":"A sport piece of bar iron for rolling into a sheet; a small billet.","pos":""}],"LARGHETTO":[{"def":"Somewhat slow or slowly, but not so slowly as largo, and rather more so than andante.","pos":""}],"LARGIFICAL":[{"def":"Generous; ample; liberal.","pos":""}],"LARGIFLUOUS":[{"def":"Flowing copiously.","pos":""}],"LARGITION":[{"def":"The bestowment of a largess or gift.","pos":""}],"LARGO":[{"def":"Slow or slowly; -- more so than adagio; next in slowness to grave, which is also weighty and solemn.","pos":""},{"def":"A movement or piece in largo time.","pos":""}],"LARIAT":[{"def":"A long, slender rope made of hemp or strips of hide, esp.","pos":""}],"LARINE":[{"def":"Of or pertaining to the Gull family (Laridæ).","pos":""}],"LARIXINIC":[{"def":"Of, or derived from, the larch (Larix); as, larixinic acid.","pos":""}],"LARK":[{"def":"A frolic; a jolly time.","pos":""}],"LARK-COLORED":[{"def":"Having the sandy brown color of the European larks.","pos":""}],"LARKER":[{"def":"A catcher of larks.","pos":""},{"def":"One who indulges in a lark or frolic.","pos":""}],"LARKSPUR":[{"def":"A genus of ranunculaceous plants (Delphinium), having showy flowers, and a spurred calyx.","pos":""}],"LAROID":[{"def":"Like or belonging to the Gull family (Laridæ).","pos":""}],"LARRIKIN":[{"def":"A rowdy street loafer; a rowdyish or noisy ill-bred fellow; -- variously applied, as to a street blackguard, a street Arab, a youth given to horse-play, etc.","pos":""},{"def":"Rowdy; rough; disorderly.","pos":""}],"LARRUP":[{"def":"To beat or flog soundly.","pos":""}],"LARRY":[{"def":"Same as Lorry, or Lorrie.","pos":""}],"LARUM":[{"def":", See Alarum, and Alarm.","pos":""}],"LARVA":[{"def":"Any young insect from the time that it hatches from the egg until it becomes a pupa, or chrysalis.","pos":""},{"def":"The early, immature form of any animal when more or less of a metamorphosis takes place, before the assumption of the mature shape.","pos":""}],"LARVAL":[{"def":"Of or pertaining to a larva.","pos":""}],"LARVALIA":[{"def":"An order of Tunicata, including Appendicularia, and allied genera; -- so called because certain larval features are retained by them through life.","pos":""}],"LARVATE":[{"def":"Masked; hence, concealed; obscure; -- applied in medicine to doubtful cases of some diseases; as, larvate pneumonis; larvate epilepsy.","pos":""}],"LARVATED":[{"def":"Masked; clothed as with a mask.","pos":""}],"LARVIFORM":[{"def":"Having the form or structure of a larva.","pos":""}],"LARVIPAROUS":[{"def":"Depositing living larvæ, instead of eggs; -- said of certain insects.","pos":""}],"LARY":[{"def":"A guillemot; -- called also lavy.","pos":""}],"LARYNGEAL":[{"def":"Of or pertaining to the larynx; adapted to operations on the larynx; as, laryngeal forceps.","pos":""}],"LARYNGECTOMY":[{"def":"Excision of the larynx.","pos":""}],"LARYNGISMUS":[{"def":"A spasmodic state of the glottis, giving rise to contraction or closure of the opening.","pos":""}],"LARYNGITIS":[{"def":"Inflammation of the larynx.","pos":""}],"LARYNGOGRAPH":[{"def":"An instrument for recording the larynx movements in speech.","pos":""}],"LARYNGOLOGICAL":[{"def":"Of or pertaining to laryngology.","pos":""}],"LARYNGOLOGIST":[{"def":"One who applies himself to laryngology.","pos":""}],"LARYNGOLOGY":[{"def":"Systematized knowledge of the action and functions of the larynx; in pathology, the department which treats of the diseases of the larynx.","pos":""}],"LARYNGOPHONY":[{"def":"The sound of the voice as heard through a stethoscope when the latter is placed upon the larynx.","pos":""}],"LARYNGOSCOPE":[{"def":"An instrument, consisting of an arrangement of two mirrors, for reflecting light upon the larynx, and for examining its image.","pos":""}],"LARYNGOSCOPIC":[{"def":"Of or pertaining to the inspection of the larynx.","pos":""}],"LARYNGOSCOPIST":[{"def":"One skilled in laryngoscopy.","pos":""}],"LARYNGOSCOPY":[{"def":"The art of using the laryngoscope; investigations made with the laryngoscope.","pos":""}],"LARYNGOTOME":[{"def":"An instrument for performing laryngotomy.","pos":""}],"LARYNGOTOMY":[{"def":"The operation of cutting into the larynx, from the outside of the neck, for assisting respiration when obstructed, or for removing foreign bodies.","pos":""}],"LARYNGOTRACHEAL":[{"def":"Pertaining to both larynx and trachea; as, the laryngotracheal cartilage in the frog.","pos":""}],"LARYNGOTRACHEOTOMY":[{"def":"The operation of cutting into the larynx and the upper part of the trachea, -- a frequent operation for obstruction to breathing.","pos":""}],"LARYNX":[{"def":"The expanded upper end of the windpipe or trachea, connected with the hyoid bone or cartilage.","pos":""}]}