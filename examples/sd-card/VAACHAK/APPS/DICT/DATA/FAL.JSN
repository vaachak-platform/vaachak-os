{"FALANAKA":[{"def":"A viverrine mammal of Madagascar (Eupleres Goudotii), allied to the civet; -- called also Falanouc.","pos":""}],"FALCADE":[{"def":"The action of a horse, when he throws himself on his haunches two or three times, bending himself, as it were, in very quick curvets.","pos":""},{"def":"Hooked or bent like a sickle; as, a falcate leaf; a falcate claw; -- said also of the moon, or a planet, when horned or crescent- formed.","pos":""}],"FALCATION":[{"def":"The state of being falcate; a bend in the form of a sickle.","pos":""}],"FALCER":[{"def":"One of the mandibles of a spider.","pos":""}],"FALCHION":[{"def":"A broad-bladed sword, slightly curved, shorter and lighter than the ordinary sword; -- used in the Middle Ages.","pos":""},{"def":"A name given generally and poetically to a sword, especially to the swords of Oriental and fabled warriors.","pos":""}],"FALCIDIAN":[{"def":"Of or pertaining to Publius Falcidius, a Roman tribune.","pos":""}],"FALCIFORM":[{"def":"Having the shape of a scithe or sickle; resembling a reaping hook; as, the falciform ligatment of the liver.","pos":""}],"FALCON":[{"def":"An ancient form of cannon.","pos":""}],"FALCONER":[{"def":"A person who breeds or trains hawks for taking birds or game; one who follows the sport of fowling with hawks.","pos":""}],"FALCONET":[{"def":"One of the smaller cannon used in the 15th century and later.","pos":""}],"FALCONGENTIL":[{"def":"The female or young of the goshawk (Astur palumbarius).","pos":""}],"FALCONRY":[{"def":"The art of training falcons or hawks to pursue and attack wild fowl or game.","pos":""},{"def":"The sport of taking wild fowl or game by means of falcons or hawks.","pos":""}],"FALCULA":[{"def":"A curved and sharp-pointed claw.","pos":""}],"FALCULATE":[{"def":"Curved and sharppointed, like a falcula, or claw of a falcon.","pos":""}],"FALDAGE":[{"def":"A privilege of setting up, and moving about, folds for sheep, in any fields within manors, in order to manure them; -- often reserved to himself by the lord of the manor.","pos":""}],"FALDFEE":[{"def":"A fee or rent paid by a tenant for the privilege of faldage on his own ground.","pos":""}],"FALDING":[{"def":"A frieze or rough-napped cloth.","pos":""}],"FALDISTORY":[{"def":"The throne or seat of a bishop within the chancel.","pos":""}],"FALDSTOOL":[{"def":"A folding stool, or portable seat, made to fold up in the manner of a camo stool.","pos":""}],"FALERNIAN":[{"def":"Of or pertaining to Mount Falernus, in Italy; as, Falernianwine.","pos":""}],"FALL":[{"def":"To Descend, either suddenly or gradually; particularly, to descend by the force of gravity; to drop; to sink; as, the apple falls; the tide falls; the mercury falls in the barometer.","pos":""},{"def":"To cease to be erect; to take suddenly a recumbent posture; to become prostrate; to drop; as, a child totters and falls; a tree falls; a worshiper falls on his knees.","pos":""}],"FALLACIOUS":[{"def":"Embodying or pertaining to a fallacy; illogical; fitted to deceive; misleading; delusive; as, fallacious arguments or reasoning.","pos":""}],"FALLACY":[{"def":"An argument, or apparent argument, which professes to be decisive of the matter at issue, while in reality it is not; a sophism.","pos":""},{"def":"Gay ornaments; frippery; gewgaws.","pos":""}],"FALLAX":[{"def":"Cavillation; a caviling.","pos":""}],"FALLEN":[{"def":"Dropped; prostrate; degraded; ruined; decreased; dead.","pos":""}],"FALLER":[{"def":"A part which acts by falling, as a stamp in a fulling mill, or the device in a spinning machine to arrest motion when a thread breaks.","pos":""}],"FALLFISH":[{"def":"A fresh-water fish of the United States (Semotilus bullaris); - - called also silver chub, and Shiner.","pos":""}],"FALLIBILITY":[{"def":"The state of being fallible; liability to deceive or to be deceived; as, the fallibity of an argument or of an adviser.","pos":""}],"FALLIBLE":[{"def":"Liable to fail, mistake, or err; liable to deceive or to be deceived; as, all men are fallible; our opinions and hopes are fallible.","pos":""}],"FALLIBLY":[{"def":"In a fallible manner.","pos":""}],"FALLOPIAN":[{"def":"Pertaining to, or discovered by, Fallopius; as, the Fallopian tubes or oviducts, the ducts or canals which conduct the ova from the ovaries to the uterus.","pos":""}],"FALLOW":[{"def":"Left untilled or unsowed after plowing; uncultivated; as, fallow ground.","pos":""}],"FALLOW DEER":[{"def":"A European species of deer (Cervus dama), much smaller than the red deer.","pos":""}],"FALLOWIST":[{"def":"One who favors the practice of fallowing land.","pos":""}],"FALLOWNESS":[{"def":"A well or opening, through the successive floors of a warehouse or manufactory, through which goods are raised or lowered.","pos":""}],"FALSARY":[{"def":"A falsifier of evidence.","pos":""}],"FALSE":[{"def":"Uttering falsehood; unveracious; given to deceit; dishnest; as, a false witness.","pos":""},{"def":"Not faithful or loyal, as to obligations, allegiance, vows, etc.","pos":""}],"FALSE-HEARTED":[{"def":"Hollow or unsound at the core; treacherous; deceitful; perfidious.","pos":""}],"FALSEHOOD":[{"def":"Want of truth or accuracy; an untrue assertion or representation; error; misrepresentation; falsity.","pos":""},{"def":"A deliberate intentional assertion of what is known to be untrue; a departure from moral integrity; a lie.","pos":""}],"FALSELY":[{"def":"In a false manner; erroneously; not truly; perfidiously or treacherously.","pos":""}],"FALSENESS":[{"def":"The state of being false; contrariety to the fact; inaccuracy; want of integrity or uprightness; double dealing; unfaithfulness; treachery; perfidy; as, the falseness of a report, a drawing, or a singer's notes; the falseness of a man, or of his word.","pos":""}],"FALSETTO":[{"def":"A false or artificial voice; that voice in a man which lies above his natural voice; the male counter tenor or alto voice.","pos":""}],"FALSICRIMEN":[{"def":"The crime of falsifying.","pos":""}],"FALSIFIABLE":[{"def":"Capable of being falsified, counterfeited, or corrupted.","pos":""}],"FALSIFICATION":[{"def":"The showing an item of charge in an account to be wrong.","pos":""}],"FALSIFIER":[{"def":"One who falsifies, or gives to a thing a deceptive appearance; a liar.","pos":""}],"FALSIFY":[{"def":"To avoid or defeat; to prove false, as a judgment.","pos":""},{"def":"To show, in accounting, (an inem of charge inserted in an account) to be wrong.","pos":""}],"FALSISM":[{"def":"That which is evidently false; an assertion or statement the falsity of which is plainly apparent; -- opposed to truism.","pos":""}],"FALSITY":[{"def":"The quality of being false; coutrariety or want of conformity to truth.","pos":""},{"def":"That which is false; falsehood; a lie; a false assertion.","pos":""}],"FALTER":[{"def":"To thrash in the chaff; also, to cleanse or sift, as barley.","pos":""}],"FALTERING":[{"def":"Hesitating; trembling.","pos":""},{"def":"Falter; halting; hesitation.","pos":""}],"FALUNS":[{"def":"A series of strata, of the Middle Tertiary period, of France, abounding in shells, and used by Lyell as the type of his Miocene subdivision.","pos":""}],"FALX":[{"def":"A curved fold or process of the dura mater or the peritoneum; esp.","pos":""}]}