{"SUBVAGINAL":[{"def":"Situated under or inside a sheath or vaginal membrane; as, the subvaginal, or subdural, spaces about the optic nerve.","pos":""}],"SUBVARIETY":[{"def":"A subordinate variety, or a division of a variety.","pos":""}],"SUBVENE":[{"def":"To come under, as a support or stay; to happen.","pos":""}],"SUBVENTANEOUS":[{"def":"Produced by the wind.","pos":""}],"SUBVENTION":[{"def":"The act of coming under.","pos":""},{"def":"The act of relieving, as of a burden; support; aid; assistance; help.","pos":""}],"SUBVENTIONIZE":[{"def":"To come to the aid of; to subsidize; to support.","pos":""}],"SUBVENTITIOUS":[{"def":"Helping; aiding; supporting.","pos":""}],"SUBVERSION":[{"def":"The act of overturning, or the state of being overturned; entire overthrow; an overthrow from the foundation; utter ruin; destruction; as, the subversion of a government; the subversion of despotic power; the subversion of the constitution.","pos":""}],"SUBVERSIONARY":[{"def":"Promoting destruction.","pos":""}],"SUBVERSIVE":[{"def":"Tending to subvert; having a tendency to overthrow and ruin.","pos":""}],"SUBVERT":[{"def":"To overturn from the foundation; to overthrow; to ruin utterly.","pos":""},{"def":"To pervert, as the mind, and turn it from the truth; to corrupt; to confound.","pos":""}],"SUBVERTEBRAL":[{"def":"Situated beneath, or on the ventral side of, the vertebral column; situated beneath, or inside of, the endoskeleton; hypaxial; hyposkeletal.","pos":""}],"SUBVERTER":[{"def":"One who, or that which, subverts; an overthrower.","pos":""}],"SUBVERTIBLE":[{"def":"That may be subverted.","pos":""}],"SUBVITALIZED":[{"def":"Imperfectly vitalized; having naturally but little vital power or energy.","pos":""}],"SUBVOCAL":[{"def":"Same as Subtonic.","pos":""}]}