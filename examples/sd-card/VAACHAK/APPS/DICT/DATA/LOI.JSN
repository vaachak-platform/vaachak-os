{"LOIMIC":[{"def":"Of or pertaining to the plague or contagious disorders.","pos":""}],"LOIN":[{"def":"That part of a human being or quadruped, which extends on either side of the spinal column between the hip bone and the false ribs.","pos":""}],"LOIR":[{"def":"A large European dormouse (Myoxus glis).","pos":""}],"LOITER":[{"def":"To be slow in moving; to delay; to linger; to be dilatory; to spend time idly; to saunter; to lag behind.","pos":""},{"def":"To wander as an idle vagrant.","pos":""}],"LOITERER":[{"def":"One who loiters; an idler.","pos":""},{"def":"An idle vagrant; a tramp.","pos":""}],"LOITERINGLY":[{"def":"In a loitering manner.","pos":""},{"def":"The evil deity, the author of all calamities and mischief, answering to the African of the Persians.","pos":""}]}