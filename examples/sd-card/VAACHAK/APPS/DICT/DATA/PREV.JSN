{"PREVAIL":[{"def":"To overcome; to gain the victory or superiority; to gain the advantage; to have the upper hand, or the mastery; to succeed; -- sometimes with over or against.","pos":""},{"def":"To be in force; to have effect, power, or influence; to be predominant; to have currency or prevalence; to obtain; as, the practice prevails this day.","pos":""}],"PREVAILING":[{"def":"Having superior force or influence; efficacious; persuasive.","pos":""},{"def":"Predominant; prevalent; most general; as, the prevailing disease of a climate; a prevailing opinion.","pos":""}],"PREVAILINGLY":[{"def":"So as to prevail.","pos":""}],"PREVAILMENT":[{"def":"Prevalence; superior influence; efficacy.","pos":""}],"PREVALENCE":[{"def":"The quality or condition of being prevalent; superior strength, force, or influence; general existence, reception, or practice; wide extension; as, the prevalence of virtue, of a fashion, or of a disease; the prevalence of a rumor.","pos":""}],"PREVALENT":[{"def":"Gaining advantage or superiority; having superior force, influence, or efficacy; prevailing; predominant; successful; victorious.","pos":""},{"def":"Most generally received or current; most widely adopted or practiced; also, generally or extensively existing; widespread; prevailing; as, a prevalent observance; prevalent disease.","pos":""}],"PREVALENTLY":[{"def":"In a prevalent manner.","pos":""}],"PREVARICATE":[{"def":"To collude, as where an informer colludes with the defendant, and makes a sham prosecution.","pos":""},{"def":"To undertake a thing falsely and deceitfully, with the purpose of defeating or destroying it.","pos":""}],"PREVARICATION":[{"def":"The act of prevaricating, shuffling, or quibbling, to evade the truth or the disclosure of truth; a deviation from the truth and fair dealing.","pos":""},{"def":"A secret abuse in the exercise of a public office.","pos":""}],"PREVARICATOR":[{"def":"A sham dealer; one who colludes with a defendant in a sham prosecution.","pos":""}],"PREVENANCE":[{"def":"A going before; anticipation in sequence or order.","pos":""}],"PREVENANCY":[{"def":"The act of anticipating another's wishes, desires, etc.","pos":""}],"PREVENE":[{"def":"To come before; to anticipate; hence, to hinder; to prevent.","pos":""}],"PREVENIENCE":[{"def":"The act of going before; anticipation.","pos":""}],"PREVENIENT":[{"def":"Going before; preceding; hence, preventive.","pos":""}],"PREVENT":[{"def":"To go before; to precede; hence, to go before as a guide; to direct.","pos":""},{"def":"To be beforehand with; to anticipate.","pos":""}],"PREVENTABILITY":[{"def":"The quality or state of being preventable.","pos":""}],"PREVENTABLE":[{"def":"Capable of being prevented or hindered; as, preventable diseases.","pos":""}],"PREVENTATIVE":[{"def":"That which prevents; -- incorrectly used instead of preventive.","pos":""}],"PREVENTER":[{"def":"An auxiliary rope to strengthen a mast.","pos":""}],"PREVENTINGLY":[{"def":"So as to prevent or hinder.","pos":""}],"PREVENTION":[{"def":"The act of going, or state of being, before.","pos":""},{"def":"Anticipation; esp.","pos":""}],"PREVENTIONAL":[{"def":"Tending to prevent.","pos":""}],"PREVENTIVE":[{"def":"Going before; preceding.","pos":""},{"def":"Tending to defeat or hinder; obviating; preventing the access of; as, a medicine preventive of disease.","pos":""}],"PREVENTIVELY":[{"def":"In a preventive manner.","pos":""}],"PREVERTEBRAL":[{"def":"Situated immediately in front, or on the ventral side, of the vertebral column; prespinal.","pos":""}],"PREVIOUS":[{"def":"Going before in time; being or happening before something else; antecedent; prior; as, previous arrangements; a previous illness.","pos":""}],"PREVIOUSLY":[{"def":"Beforehand; antecedently; as, a plan previously formed.","pos":""}],"PREVIOUSNESS":[{"def":"The quality or state of being previous; priority or antecedence in time.","pos":""}],"PREVISE":[{"def":"To inform beforehand; to warn.","pos":""}],"PREVISION":[{"def":"Foresight; foreknowledge; prescience.","pos":""}],"PREVOYANT":[{"def":"Foreseeing; prescient.","pos":""}]}