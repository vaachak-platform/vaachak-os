{"MOME":[{"def":"A dull, silent person; a blockhead.","pos":""}],"MOMENT":[{"def":"An infinitesimal change in a varying quantity; an increment or decrement.","pos":""},{"def":"Tendency, or measure of tendency, to produce motion, esp.","pos":""}],"MOMENTAL":[{"def":"Of or pertaining to moment or momentum.","pos":""}],"MOMENTALLY":[{"def":"MOMENTANEOUS; MOMENTANY Mo`men*ta\"ne*ous, Mo\"men*ta*ny, a.","pos":""}],"MOMENTARILY":[{"def":"Every moment; from moment to moment.","pos":""}],"MOMENTARINESS":[{"def":"The state or quality of being momentary; shortness of duration.","pos":""}],"MOMENTARY":[{"def":"Done in a moment; continuing only a moment; lasting a very short time; as, a momentary pang.","pos":""}],"MOMENTLY":[{"def":"In a moment; every moment; momentarily.","pos":""}],"MOMENTOUS":[{"def":"Of moment or consequence; very important; weighty; as, a momentous decision; momentous affairs.","pos":""}],"MOMENTUM":[{"def":"The quantity of motion in a moving body, being always proportioned to the quantity of matter multiplied into the velocity; impetus.","pos":""}],"MOMIER":[{"def":"A name given in contempt to strict Calvinists in Switzerland, France, and some parts of Germany, in the early part of the 19th century.","pos":""}],"MOMUS":[{"def":"The god of mockery and censure.","pos":""}]}