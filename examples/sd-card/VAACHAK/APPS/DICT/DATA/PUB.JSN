{"PUBBLE":[{"def":"Puffed out, pursy; pudgy; fat.","pos":""}],"PUBERAL":[{"def":"Of or pertaining to puberty.","pos":""}],"PUBERTY":[{"def":"The period when a plant first bears flowers.","pos":""}],"PUBERULENT":[{"def":"Very minutely downy.","pos":""}],"PUBES":[{"def":"The down of plants; a downy or villous substance which grows on plants; pubescence.","pos":""}],"PUBESCENCE":[{"def":"The quality or state of being pubescent, or of having arrived at puberty.","pos":""},{"def":"A covering of soft short hairs, or down, as one some plants and insects; also, the state of being so covered.","pos":""}],"PUBESCENT":[{"def":"Arrived at puberty.","pos":""},{"def":"Covered with pubescence, or fine short hairs, as certain insects, and the leaves of some plants.","pos":""}],"PUBIC":[{"def":"Of or pertaining to the pubes; in the region of the pubes; as, the pubic bone; the pubic region, or the lower part of the hypogastric region.","pos":""}],"PUBIS":[{"def":"The ventral and anterior of the three principal bones composing either half of the pelvis; sharebone; pubic bone.","pos":""}],"PUBLIC":[{"def":"Of or pertaining to the people; belonging to the people; relating to, or affecting, a nation, state, or community; -- opposed to private; as, the public treasury.","pos":""},{"def":"Open to the knowledge or view of all; general; common; notorious; as, public report; public scandal.","pos":""}],"PUBLIC SCHOOL":[{"def":"A corporation, such as a railroad company, lighting company, water company, etc.","pos":""}],"PUBLIC-HEARTED":[{"def":"Public-spirited.","pos":""}],"PUBLIC-MINDED":[{"def":"Public-spirited.","pos":""}],"PUBLIC-SPIRITED":[{"def":"Having, or exercising, a disposition to advance the interest of the community or public; as, public-spirited men.","pos":""},{"def":"Dictated by a regard to public good; as, a public-spirited project or measure.","pos":""}],"PUBLICAN":[{"def":"A farmer of the taxes and public revenues; hence, a collector of toll or tribute.","pos":""}],"PUBLICATION":[{"def":"The act of publishing or making known; notification to the people at large, either by words, writing, or printing; proclamation; divulgation; promulgation; as, the publication of the law at Mount Sinai; the publication of the gospel; the publication of statutes or edicts.","pos":""},{"def":"The act of offering a book, pamphlet, engraving, etc.","pos":""}],"PUBLICIST":[{"def":"A writer on the laws of nature and nations; one who is versed in the science of public right, the principles of government, etc.","pos":""}],"PUBLICITY":[{"def":"The quality or state of being public, or open to the knowledge of a community; notoriety; publicness.","pos":""}],"PUBLICITY PAMPHLET":[{"def":"A pamphlet which, in some States of the United States having the initiative or referendum, is mailed to the voters to inform them as to the nature of a measure submitted by the initiative or referendum.","pos":""}],"PUBLICLY":[{"def":"With exposure to popular view or notice; without concealment; openly; as, property publicly offered for sale; an opinion publicly avowed; a declaration publicly made.","pos":""},{"def":"In the name of the community.","pos":""}],"PUBLICNESS":[{"def":"The quality or state of being public, or open to the view or notice of people at large; publicity; notoriety; as, the publicness of a sale.","pos":""},{"def":"The quality or state of belonging to the community; as, the publicness of property.","pos":""}],"PUBLISH":[{"def":"To make public; to make known to mankind, or to people in general; to divulge, as a private transaction; to promulgate or proclaim, as a law or an edict.","pos":""},{"def":"To make known by posting, or by reading in a church; as, to publish banns of marriage.","pos":""}],"PUBLISHABLE":[{"def":"Capable of being published; suitable for publication.","pos":""}],"PUBLISHER":[{"def":"One who publishes; as, a publisher of a book or magazine.","pos":""}],"PUBLISHMENT":[{"def":"The act or process of making publicly known; publication.","pos":""},{"def":"A public notice of intended marriage, required by the laws of some States.","pos":""}]}