{"ALKAHEST":[{"def":"The fabled \"universal solvent\" of the alchemists; a menstruum capable of dissolving all bodies.","pos":""}],"ALKALAMIDE":[{"def":"One of a series of compounds that may be regarded as ammonia in which a part of the hydrogen has been replaced by basic, and another part by acid, atoms or radicals.","pos":""},{"def":"A tendency to become alkaline; or the state of a substance in which alkaline properties begin to be developed, or to predominant.","pos":""}],"ALKALESCENT":[{"def":"Tending to the properties of an alkali; slightly alkaline.","pos":""}],"ALKALI":[{"def":"Soda ash; caustic soda, caustic potash, etc.","pos":""}],"ALKALI FLAT":[{"def":"A sterile plain, containing an excess of alkali, at the bottom of an undrained basin in an arid region; a playa.","pos":""}],"ALKALI SOIL":[{"def":"Any one of various soils found in arid and semiarid regions, containing an unusual amount of soluble mineral salts which effloresce in the form of a powder or crust (usually white) in dry weather following rains or irrigation.","pos":""}],"ALKALI WASTE":[{"def":"Waste material from the manufacture of alkali; specif.","pos":""}],"ALKALIFIABLE":[{"def":"Capable of being alkalified, or converted into an alkali.","pos":""}],"ALKALIFY":[{"def":"To convert into an alkali; to give alkaline properties to.","pos":""}],"ALKALIMETER":[{"def":"An instrument to ascertain the strength of alkalies, or the quantity of alkali in a mixture.","pos":""},{"def":"Of or pertaining to alkalimetry.","pos":""}],"ALKALIMETRY":[{"def":"The art or process of ascertaining the strength of alkalies, or the quantity present in alkaline mixtures.","pos":""}],"ALKALINE":[{"def":"Of or pertaining to an alkali or to alkalies; having the properties of an alkali.","pos":""}],"ALKALINITY":[{"def":"The quality which constitutes an alkali; alkaline property.","pos":""}],"ALKALIZATION":[{"def":"The act rendering alkaline by impregnating with an alkali; a conferring of alkaline qualities.","pos":""}],"ALKALIZE":[{"def":"To render alkaline; to communicate the properties of an alkali to.","pos":""}],"ALKALOID":[{"def":"An organic base, especially one of a class of substances occurring ready formed in the tissues of plants and the bodies of animals.","pos":""},{"def":"Pertaining to, resembling, or containing, alkali.","pos":""}],"ALKANET":[{"def":"A dyeing matter extracted from the roots of Alkanna tinctoria, which gives a fine deep red color.","pos":""}],"ALKARGEN":[{"def":"Same as Cacodylic acid.","pos":""}],"ALKARSIN":[{"def":"A spontaneously inflammable liquid, having a repulsive odor, and consisting of cacodyl and its oxidation products; -- called also Cadel's fuming liquid.","pos":""}],"ALKEKENGI":[{"def":"An herbaceous plant of the nightshade family (Physalis alkekengi) and its fruit, which is a well flavored berry, the size of a cherry, loosely inclosed in a enlarged leafy calyx; -- also called winter cherry, ground cherry, and strawberry tomato.","pos":""}],"ALKERMES":[{"def":"A compound cordial, in the form of a confection, deriving its name from the kermes insect, its principal ingredient.","pos":""}],"ALKORAN":[{"def":"The Mohammedan Scriptures.","pos":""}],"ALKORANIC":[{"def":"Same as Alcoranic.","pos":""}],"ALKORANIST":[{"def":"Same as Alcoranist.","pos":""}]}