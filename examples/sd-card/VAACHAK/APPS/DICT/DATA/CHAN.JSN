{"CHANCE":[{"def":"A supposed material or psychical agent or mode of activity other than a force, law, or purpose; fortune; fate; -- in this sense often personifed.","pos":""},{"def":"The operation or activity of such agent.","pos":""}],"CHANCE-MEDLEY":[{"def":"The kiling of another in self-defense upon a sudden and unpremeditated encounter.","pos":""}],"CHANCEABLE":[{"def":"Fortuitous; casual.","pos":""}],"CHANCELLOR":[{"def":"A judicial court of chancery, which in England and in the United States is distinctively a court with equity jurisdiction.","pos":""}],"CHANCELLORSHIP":[{"def":"The office of a chancellor; the time during which one is chancellor.","pos":""}],"CHANCERY":[{"def":"In England, formerly, the highest court of judicature next to the Parliament, exercising jurisdiction at law, but chiefly in equity; but under the jurisdiction act of 1873 it became the chancery division of the High Court of Justice, and now exercises jurisdiction only in equity.","pos":""},{"def":"In the Unites States, a court of equity; equity; proceeding in equity.","pos":""}],"CHANCRE":[{"def":"A venereal sore or ulcer; specifically, the initial lesion of true syphilis, whether forming a distinct ulcer or not; -- called also hard chancre, indurated chancre, and Hunterian chancre.","pos":""}],"CHANCROID":[{"def":"A venereal sore, resembling a chancre in its seat and some external characters, but differing from it in being the starting point of a purely local process and never of a systemic disease; -- called also soft chancre.","pos":""}],"CHANCROUS":[{"def":"Of the nature of a chancre; having chancre.","pos":""}],"CHANDELIER":[{"def":"A movable parapet, serving to support fascines to cover pioneers.","pos":""}],"CHANDLER":[{"def":"A maker or seller of candles.","pos":""},{"def":"A dealer in other commodities, which are indicated by a word prefixed; as, ship chandler, corn chandler.","pos":""}],"CHANDLERLY":[{"def":"Like a chandler; in a petty way.","pos":""}],"CHANDLERY":[{"def":"Commodities sold by a chandler.","pos":""}],"CHANDOO":[{"def":"An extract or preparation of opium, used in China and India for smoking.","pos":""}],"CHANFRIN":[{"def":"The fore part of a horse's head.","pos":""}],"CHANGE":[{"def":"To alter; to make different; to cause to pass from one state to another; as, to change the position, character, or appearance of a thing; to change the countenance.","pos":""},{"def":"To alter by substituting something else for, or by giving up for something else; as, to change the clothes; to change one's occupation; to change one's intention.","pos":""}],"CHANGE GEAR":[{"def":"A gear by means of which the speed of machinery or of a vehicle may be changed while that of the propelling engine or motor remains constant; -- called also change-speed gear.","pos":""}],"CHANGE KEY":[{"def":"A key adapted to open only one of a set of locks; -- distinguished from a master key.","pos":""}],"CHANGEABLE":[{"def":"Capable of change; subject to alteration; mutable; variable; fickle; inconstant; as, a changeable humor.","pos":""},{"def":"Appearing different, as in color, in different lights, or under different circumstances; as, changeable silk.","pos":""}],"CHANGEABLENESS":[{"def":"The quality of being changeable; fickleness; inconstancy; mutability.","pos":""}],"CHANGEABLY":[{"def":"In a changeable manner.","pos":""}],"CHANGEFUL":[{"def":"Full of change; mutable; inconstant; fickle; uncertain.","pos":""}],"CHANGELESS":[{"def":"That can not be changed; constant; as, a changeless purpose.","pos":""}],"CHANGELING":[{"def":"One who, or that which, is left or taken in the place of another, as a child exchanged by fairies.","pos":""},{"def":"A simpleton; an idiot.","pos":""}],"CHANGER":[{"def":"One who changes or alters the form of anything.","pos":""},{"def":"One who deals in or changes money.","pos":""}],"CHANK":[{"def":"The East Indian name for the large spiral shell of several species of sea conch much used in making bangles, esp.","pos":""}],"CHANNEL":[{"def":"A strait, or narrow sea, between two portions of lands; as, the British Channel.","pos":""},{"def":"Flat ledges of heavy plank bolted edgewise to the outside of a vessel, to increase the spread of the shrouds and carry them clear of the bulwarks.","pos":""}],"CHANNELING":[{"def":"The act or process of forming a channel or channels.","pos":""},{"def":"A channel or a system of channels; a groove.","pos":""}],"CHANSON DE GESTE":[{"def":"Any Old French epic poem having for its subject events or exploits of early French history, real or legendary, and written originally in assonant verse of ten or twelve syllables.","pos":""}],"CHANSONNETTE":[{"def":"These pretty little chansonnettes that he sung.","pos":""}],"CHANT":[{"def":"To sing or recite after the manner of a chant, or to a tune called a chant.","pos":""}],"CHANTANT":[{"def":"Composed in a melodious and singing style.","pos":""}],"CHANTER":[{"def":"The hedge sparrow.","pos":""}],"CHANTERELLE":[{"def":"A name for several species of mushroom, of which one (Cantharellus cibrius) is edible, the others reputed poisonous.","pos":""}],"CHANTEY":[{"def":"A sailor's song.","pos":""}],"CHANTICLEER":[{"def":"A cock, so called from the clearness or loundness of his voice in crowing.","pos":""}],"CHANTING":[{"def":"African falcon (Melierax canorus or musicus).","pos":""}],"CHANTRESS":[{"def":"A female chanter or singer.","pos":""}],"CHANTRY":[{"def":"An endowment or foundation for the chanting of masses and offering of prayers, commonly for the founder.","pos":""},{"def":"A chapel or altar so endowed.","pos":""}]}