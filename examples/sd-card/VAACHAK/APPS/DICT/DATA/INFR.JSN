{"INFRA":[{"def":"Below; beneath; under; after; -- often used as a prefix.","pos":""}],"INFRA-AXILLARY":[{"def":"Situated below the axil, as a bud.","pos":""}],"INFRA-RED":[{"def":"Lying outside the visible spectrum at its red end; -- said of rays less refrangible than the extreme red rays.","pos":""}],"INFRABRANCHIAL":[{"def":"Below the gills; -- applied to the ventral portion of the pallial chamber in the lamellibranchs.","pos":""}],"INFRACLAVICULAR":[{"def":"Below the clavicle; as, the infraclavicular fossa.","pos":""}],"INFRACT":[{"def":"Not broken or fractured; unharmed; whole.","pos":""}],"INFRACTIBLE":[{"def":"Capable of being broken.","pos":""}],"INFRACTION":[{"def":"The act of infracting or breaking; breach; violation; nonobservance; infringement; as, an infraction of a treaty, compact, rule, or law.","pos":""}],"INFRACTOR":[{"def":"One who infracts or infringes; a violator; a breaker.","pos":""}],"INFRAHYOID":[{"def":"Same as Hyosternal (a).","pos":""}],"INFRALABIAL":[{"def":"Below the lower lip; -- said of certain scales of reptiles and fishes.","pos":""}],"INFRALAPSARIAN":[{"def":"One of that class of Calvinists who consider the decree of election as contemplating the apostasy as past and the elect as being at the time of election in a fallen and guilty state; -- opposed to Supralapsarian.","pos":""}],"INFRALAPSARIANISM":[{"def":"The doctrine, belief, or principles of the Inralapsarians.","pos":""}],"INFRAMARGINAL":[{"def":"Below the margin; submarginal; as, an inframarginal convolution of the brain.","pos":""}],"INFRAMAXILLARY":[{"def":"In`fra*max\"il*la*ry, a.","pos":""}],"INFRAMEDIAN":[{"def":"Of or pertaining to the interval or zone along the sea bottom, at the depth of between fifty and one hundred fathoms.","pos":""}],"INFRAMUNDANE":[{"def":"Lying or situated beneath the world.","pos":""}],"INFRANCHISE":[{"def":"See Enfranchise.","pos":""}],"INFRANGIBILITY":[{"def":"The quality or state of being infrangible; infrangibleness.","pos":""}],"INFRANGIBLE":[{"def":"Not capable of being broken or separated into parts; as, infrangible atoms.","pos":""},{"def":"Not to be infringed or violated.","pos":""}],"INFRANGIBLENESS":[{"def":"The state or quality of being infrangible; infrangibility.","pos":""}],"INFRAOCULAR":[{"def":"Situated below the eyes, as the antenna of certain insects.","pos":""}],"INFRAORBITAL":[{"def":"Below the orbit; as, the infraorbital foramen; the infraorbital nerve.","pos":""}],"INFRAPOSE":[{"def":"To place under or beneath.","pos":""}],"INFRAPOSITION":[{"def":"A situation or position beneath.","pos":""}],"INFRASCAPULAR":[{"def":"Beneath the scapula, or shoulder blade; subscapular.","pos":""}],"INFRASPINAL":[{"def":"Below the spine; infraspinal; esp.","pos":""}],"INFRASTAPEDIAL":[{"def":"Of or pertaining to a part of the columella of the ear, which in many animals projects below the connection with the stapes.","pos":""},{"def":"The infrastapedial part of the columella.","pos":""}],"INFRASTERNAL":[{"def":"Below the sternum; as, the infrasternal depression, or pit of the stomach.","pos":""}],"INFRATEMPORAL":[{"def":"Below the temple; below the temporal bone.","pos":""}],"INFRATERRITORIAL":[{"def":"Within the territory of a state.","pos":""}],"INFRATROCHLEAR":[{"def":"Below a trochlea, or pulley; -- applied esp.","pos":""}],"INFREQUENT":[{"def":"Seldom happening or occurring; rare; uncommon; unusual.","pos":""}],"INFREQUENTLY":[{"def":"Not frequently; rarely.","pos":""}],"INFRIGIDATE":[{"def":"To chill; to make cold; to cool.","pos":""}],"INFRIGIDATION":[{"def":"The act of chilling or causing to become cold; a chilling; coldness; congelation.","pos":""}],"INFRINGE":[{"def":"To break; to violate; to transgress; to neglect to fulfill or obey; as, to infringe a law or contract.","pos":""},{"def":"To hinder; to destroy; as, to infringe efficacy; to infringe delight or power.","pos":""}],"INFRINGEMENT":[{"def":"The act of infringing; breach; violation; nonfulfillment; as, the infringement of a treaty, compact, law, or constitution.","pos":""},{"def":"An encroachment on a patent, copyright, or other special privilege; a trespass.","pos":""}],"INFRINGER":[{"def":"One who infringes or violates; a violator.","pos":""}],"INFRUCTUOSE":[{"def":"Not producing fruit; unfruitful; unprofitable.","pos":""}],"INFRUGAL":[{"def":"Not frugal; wasteful; as, an infrugal expense of time.","pos":""}],"INFRUGIFEROUS":[{"def":"Not bearing fruit; not fructiferous.","pos":""}]}