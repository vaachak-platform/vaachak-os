{"MORDACIOUS":[{"def":"Biting; given to biting; hence, figuratively, sarcastic; severe; scathing.","pos":""}],"MORDACITY":[{"def":"The quality of being mordacious; biting severity, or sarcastic quality.","pos":""}],"MORDANT":[{"def":"Serving to fix colors.","pos":""}],"MORDANTLY":[{"def":"In the manner of a mordant.","pos":""}],"MORDENTE":[{"def":"An embellishment resembling a trill.","pos":""}],"MORDICANCY":[{"def":"A biting quality; corrosiveness.","pos":""}],"MORDICANT":[{"def":"Biting; acrid; as, the mordicant quality of a body.","pos":""}],"MORDICATION":[{"def":"The act of biting or corroding; corrosion.","pos":""}],"MORDICATIVE":[{"def":"Biting; corrosive.","pos":""}]}