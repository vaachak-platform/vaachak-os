{"SPILE":[{"def":"A small plug or wooden pin, used to stop a vent, as in a cask.","pos":""},{"def":"A small tube or spout inserted in a tree for conducting sap, as from a sugar maple.","pos":""}],"SPILIKIN":[{"def":"One of a number of small pieces or pegs of wood, ivory, bone, or other material, for playing a game, or for counting the score in a game, as in cribbage.","pos":""}],"SPILL":[{"def":"A bit of wood split off; a splinter.","pos":""},{"def":"A slender piece of anything.","pos":""}],"SPILLER":[{"def":"A system or method of fishing by means of a number of hooks set on snoods all on one line; -- in North America, called trawl fishing, bultow, or bultow fishing, and long-line fishing.","pos":""}],"SPILLWAY":[{"def":"A sluiceway or passage for superfluous water in a reservoir, to prevent too great pressure on the dam.","pos":""}],"SPILTER":[{"def":"Any one of the small branches on a stag's head.","pos":""}],"SPILTH":[{"def":"Anything spilt, or freely poured out; slop; effusion.","pos":""}]}