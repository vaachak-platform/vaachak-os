{"OCEAN":[{"def":"The whole body of salt water which covers more than three fifths of the surface of the globe; -- called also the sea, or great sea.","pos":""},{"def":"One of the large bodies of water into which the great ocean is regarded as divided, as the Atlantic, Pacific, Indian, Arctic and Antarctic oceans.","pos":""}],"OCEANIC":[{"def":"Of or pertaining to the ocean; found or formed in or about, or produced by, the ocean; frequenting the ocean, especially mid-ocean.","pos":""},{"def":"Of or pertaining to Oceania or its inhabitants.","pos":""}],"OCEANOGRAPHY":[{"def":"A description of the ocean.","pos":""}],"OCEANOLOGY":[{"def":"That branch of science which relates to the ocean.","pos":""}],"OCEANUS":[{"def":"The god of the great outer sea, or the river which was believed to flow around the whole earth.","pos":""}],"OCELLARY":[{"def":"Of or pertaining to ocelli.","pos":""}],"OCELLATE":[{"def":"Same as Ocellated.","pos":""}],"OCELLATED":[{"def":"Resembling an eye.","pos":""},{"def":"Marked with eyelike spots of color; as, the ocellated blenny.","pos":""}],"OCELOID":[{"def":"Resembling the ocelot.","pos":""}],"OCELOT":[{"def":"An American feline carnivore (Felis pardalis).","pos":""},{"def":"Of or pertaining to ocher; containing or resembling ocher; as, ocherous matter; ocherous soil.","pos":""}]}