{"KNOB":[{"def":"A hard protuberance; a hard swelling or rising; a bunch; a lump; as, a knob in the flesh, or on a bone.","pos":""},{"def":"A knoblike ornament or handle; as, the knob of a lock, door, or drawer.","pos":""}],"KNOBBED":[{"def":"Containing knobs; full of knobs; ending in a nob.","pos":""}],"KNOBBING":[{"def":"Rough dressing by knocking off knobs or projections.","pos":""}],"KNOBBLER":[{"def":"The hart in its second year; a young deer.","pos":""}],"KNOBBLING FIRE":[{"def":"Knob\"bling fire Defn: .","pos":""}],"KNOBBY":[{"def":"Full of, or covered with, knobs or hard protuberances.","pos":""},{"def":"Irregular; stubborn in particulars.","pos":""}],"KNOBKERRIE":[{"def":"A short club with a knobbed end used as a missile weapon by Kafir and other native tribes of South Africa.","pos":""}],"KNOBSTICK":[{"def":"One who refuses to join, or withdraws from, a trades union.","pos":""}],"KNOCK":[{"def":"To drive or be driven against something; to strike against something; to clash; as, one heavy body knocks against another.","pos":""},{"def":"To strike or beat with something hard or heavy; to rap; as, to knock with a club; to knock on the door.","pos":""}],"KNOCK-KNEE":[{"def":"A condition in which the knees are bent in so as to touch each other in walking; inknee.","pos":""}],"KNOCK-KNEED":[{"def":"Having the legs bent inward so that the knees touch in walking.","pos":""}],"KNOCK-OFF":[{"def":"That knocks off; of or pertaining to knocking off.","pos":""}],"KNOCK-OUT":[{"def":"Act of knocking out, or state of being knocked out.","pos":""}],"KNOCK-OUT DROPS":[{"def":"Drops of some drug put in one's drink to stupefy him for purpose of robbery, etc.","pos":""}],"KNOCKABOUT":[{"def":"Marked by knocking about or roughness.","pos":""},{"def":"Of noisy and violent character.","pos":""}],"KNOCKDOWN":[{"def":"A felling by a knock, as of a combatant, or of an animal.","pos":""}],"KNOCKER":[{"def":"One who, or that which, knocks; specifically, an instrument, or kind of hammer, fastened to a door, to be used in seeking for admittance.","pos":""}],"KNOCKING":[{"def":"A beating; a rap; a series of raps.","pos":""}],"KNOCKINGS":[{"def":"Large lumps picked out of the sieve, in dressing ore.","pos":""}],"KNOCKSTONE":[{"def":"A block upon which ore is broken up.","pos":""}],"KNOLL":[{"def":"A little round hill; a mound; a small elevation of earth; the top or crown of a hill.","pos":""}],"KNOLLER":[{"def":"One who tolls a bell.","pos":""}],"KNOP":[{"def":"Any boldly projecting sculptured ornament; esp.","pos":""}],"KNOPPED":[{"def":"Having knops or knobs; fastened as with buttons.","pos":""}],"KNOPPERN":[{"def":"A kind of gall produced by a gallfly on the cup of an acorn, -- used in tanning and dyeing.","pos":""}],"KNOPWEED":[{"def":"Same as Knapweed.","pos":""}],"KNOT":[{"def":"A sandpiper (Tringa canutus), found in the northern parts of all the continents, in summer.","pos":""}],"KNOTBERRY":[{"def":"The cloudberry (Rudus Chamæmorus); -- so called from its knotted stems.","pos":""}],"KNOTGRASS":[{"def":"Note: An infusion of Polygonum aviculare was once supposed to have the effect of stopping the growth of an animal, and hence it was called, as by Shakespeare, \"hindering knotgrass.","pos":""}],"KNOTLESS":[{"def":"Free from knots; without knots.","pos":""}],"KNOTTED":[{"def":"Characterized by small, detached points, chiefly composed of mica, less decomposable than the mass of the rock, and forming knots in relief on the weathered surface; as, knotted rocks.","pos":""}],"KNOTTINESS":[{"def":"The quality or state of being knotty or full of knots.","pos":""},{"def":"Difficulty of solution; intricacy; complication.","pos":""}],"KNOTTY":[{"def":"Full of knots; knotted; having many knots; as, knotty timber; a knotty rope.","pos":""},{"def":"Hard; rugged; as, a knotty head.","pos":""}],"KNOTWORT":[{"def":"A small, herbaceous, trailing plant, of the genus Illecebrum (I.","pos":""}],"KNOUT":[{"def":"A kind of whip for flogging criminals, formerly much used in Russia.","pos":""}],"KNOW":[{"def":"To perceive or apprehend clearly and certainly; to understand; to have full information of; as, to know one's duty.","pos":""},{"def":"To be convinced of the truth of; to be fully assured of; as, to know things from information.","pos":""}],"KNOW-ALL":[{"def":"One who knows everything; hence, one who makes pretension to great knowledge; a wiseacre; -- usually ironical.","pos":""}],"KNOW-NOTHING":[{"def":"A member of a secret political organization in the United States, the chief objects of which were the proscription of foreigners by the repeal of the naturalization laws, and the exclusive choice of native Americans for office.","pos":""}],"KNOW-NOTHINGISM":[{"def":"The doctrines, principles, or practices, of the Know-nothings.","pos":""}],"KNOWABLE":[{"def":"That may be known; capable of being discovered, understood, or ascertained.","pos":""}],"KNOWABLENESS":[{"def":"The state or quality of being knowable.","pos":""}],"KNOWING":[{"def":"Skilful; well informed; intelligent; as, a knowing man; a knowing dog.","pos":""},{"def":"Artful; cunning; as, a knowing rascal.","pos":""}],"KNOWINGLY":[{"def":"With knowledge; in a knowing manner; intelligently; consciously; deliberately; as, he would not knowingly offend.","pos":""}],"KNOWINGNESS":[{"def":"The state or quality of being knowing or intelligent; shrewdness; skillfulness.","pos":""}],"KNOWLECHE":[{"def":"See Knowl, edge.","pos":""}],"KNOWLEDGE":[{"def":"The act or state of knowing; clear perception of fact, truth, or duty; certain apprehension; familiar cognizance; cognition.","pos":""},{"def":"That which is or may be known; the object of an act of knowing; a cognition; -- chiefly used in the plural.","pos":""}]}