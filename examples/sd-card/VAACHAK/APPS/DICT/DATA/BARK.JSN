{"BARK":[{"def":"To strip the bark from; to peel.","pos":""},{"def":"To abrade or rub off any outer covering from; as to bark one's heel.","pos":""}],"BARK BEETLE":[{"def":"A small beetle of many species (family Scolytidæ), which in the larval state bores under or in the bark of trees, often doing great damage.","pos":""}],"BARK LOUSE":[{"def":"An insect of the family Coccidæ, which infests the bark of trees and vines.","pos":""}],"BARKANTINE":[{"def":"Same as Barkentine.","pos":""}],"BARKBOUND":[{"def":"Prevented from growing, by having the bark too firm or close.","pos":""}],"BARKEEPER":[{"def":"One who keeps or tends a bar for the sale of liquors.","pos":""}],"BARKENTINE":[{"def":"A threemasted vessel, having the foremast square-rigged, and the others schooner-rigged.","pos":""}],"BARKER":[{"def":"The spotted redshank.","pos":""}],"BARKER'S MILL":[{"def":"A machine, invented in the 17th century, worked by a form of reaction wheel.","pos":""}],"BARKING IRONS":[{"def":"Instruments used in taking off the bark of trees.","pos":""},{"def":"A pair of pistols.","pos":""}],"BARKLESS":[{"def":"Destitute of bark.","pos":""}],"BARKY":[{"def":"Covered with, or containing, bark.","pos":""}]}