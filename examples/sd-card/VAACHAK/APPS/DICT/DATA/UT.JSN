{"UT":[{"def":"The first note in Guido's musical scale, now usually superseded by do.","pos":""}],"UTAS":[{"def":"The eighth day after any term or feast; the octave; as, the utas of St.","pos":""}],"UTENSIL":[{"def":"That which is used; an instrument; an implement; especially, an instrument or vessel used in a kitchen, or in domestic and farming business.","pos":""}],"UTERINE":[{"def":"Of or instrument to the uterus, or womb.","pos":""},{"def":"Born of the same mother, but by a different father.","pos":""}],"UTEROGESTATION":[{"def":"Gestation in the womb from conception to birth; pregnancy.","pos":""}],"UTEROVAGINAL":[{"def":"Pertaining to both the uterus and the vagina.","pos":""}],"UTERUS":[{"def":"The organ of a female mammal in which the young are developed previous to birth; the womb.","pos":""},{"def":"A receptacle, or pouch, connected with the oviducts of many invertebrates in which the eggs are retained until they hatch or until the embryos develop more or less.","pos":""}],"UTES":[{"def":"An extensive tribe of North American Indians of the Shoshone stock, inhabiting Colorado, Utah, New Mexico, Arizona, and adjacent regions.","pos":""}],"UTI POSSIDETIS":[{"def":"The basis or principle of a treaty which leaves belligerents mutually in possession of what they have acquired by their arms during the war.","pos":""},{"def":"A species of interdict granted to one who was in possession of an immovable thing, in order that he might be declared the legal possessor.","pos":""}],"UTIA":[{"def":"Any species of large West Indian rodents of the genus Capromys, or Utia.","pos":""}],"UTICA":[{"def":"Of, pertaining to, or designating, a subdivision of the Trenton Period of the Lower Silurian, characterized in the State of New York by beds of shale.","pos":""}],"UTILE":[{"def":"Profitable; useful.","pos":""}],"UTILITARIAN":[{"def":"Of or pertaining to utility; consisting in utility; as, utilitarian narrowness; a utilitarian indifference to art.","pos":""},{"def":"Of or pertaining to utilitarianism; supporting utilitarianism; as, the utilitarian view of morality; the Utilitarian Society.","pos":""}],"UTILITARIANISM":[{"def":"The doctrine that the greatest happiness of the greatest number should be the end and aim of all social and political institutions.","pos":""},{"def":"The doctrine that virtue is founded in utility, or that virtue is defined and enforced by its tendency to promote the highest happiness of the universe.","pos":""}],"UTILITY":[{"def":"Adaptation to satisfy the desires or wants; intrinsic value.","pos":""}],"UTILIZABLE":[{"def":"Capable of being utilized; as, the utilizable products of the gas works.","pos":""}],"UTILIZATION":[{"def":"The act of utilizing, or the state of being utilized.","pos":""}],"UTILIZE":[{"def":"To make useful; to turn to profitable account or use; to make use of; as, to utilize the whole power of a machine; to utilize one's opportunities.","pos":""}],"UTMOST":[{"def":"Situated at the farthest point or extremity; farthest out; most distant; extreme; as, the utmost limits of the land; the utmost extent of human knowledge.","pos":""},{"def":"Being in the greatest or highest degree, quantity, number, or the like; greatest; as, the utmost assiduity; the utmost harmony; the utmost misery or happiness.","pos":""}],"UTOPIA":[{"def":"An imaginary island, represented by Sir Thomas More, in a work called Utopia, as enjoying the greatest perfection in politics, laws, and the like.","pos":""},{"def":"Hence, any place or state of ideal perfection.","pos":""}],"UTOPIAN":[{"def":"Of or pertaining to Utopia; resembling Utopia; hence, ideal; chimerical; fanciful; founded upon, or involving, imaginary perfections; as, Utopian projects; Utopian happiness.","pos":""}],"UTOPIANISM":[{"def":"The ideas, views, aims, etc.","pos":""}],"UTOPIANIST":[{"def":"An Utopian; an optimist.","pos":""}],"UTRAQUIST":[{"def":"One who receives the eucharist in both kinds; esp.","pos":""}],"UTRICLE":[{"def":"A microscopic cell in the structure of an egg, animal, or plant.","pos":""},{"def":"A small, thin-walled, one-seeded fruit, as of goosefoot.","pos":""}],"UTRICULAR":[{"def":"Of or pertaining to a utricle, or utriculus; containing, or furnished with, a utricle or utricles; utriculate; as, a utricular plant.","pos":""},{"def":"Resembling a utricle or bag, whether large or minute; -- said especially with reference to the condition of certain substances, as sulphur, selenium, etc.","pos":""}],"UTRICULARIA":[{"def":"A genus of aquatic flowering plants, in which the submersed leaves bear many little utricles, or ascidia.","pos":""}],"UTRICULATE":[{"def":"Resembling a bladder; swollen like a bladder; inflated; utricular.","pos":""}],"UTRICULOID":[{"def":"Resembling a bladder; utricular; utriculate.","pos":""}],"UTRICULUS":[{"def":"A little sac, or bag; a utricle; especially, a part of the membranous labyrinth of the ear.","pos":""},{"def":"- (connection with, or relation to, the uterus; as in utro- ovarian.","pos":""}],"UTTER":[{"def":"Situated on the outside, or extreme limit; remote from the center; outer.","pos":""}],"UTTERABLE":[{"def":"Capable of being uttered.","pos":""}],"UTTERANCE":[{"def":"The act of uttering.","pos":""},{"def":"Power or style of speaking; as, a good utterance.","pos":""}],"UTTEREST":[{"def":"To the utterest proof of her courage.","pos":""}],"UTTERLESS":[{"def":"Incapable of being uttered.","pos":""}],"UTTERLY":[{"def":"In an utter manner; to the full extent; fully; totally; as, utterly ruined; it is utterly vain.","pos":""}],"UTTERMORE":[{"def":"Further; outer; utter.","pos":""}],"UTTERMOST":[{"def":"Extreme; utmost; being; in the farthest, greatest, or highest degree; as, the uttermost extent or end.","pos":""}],"UTTERNESS":[{"def":"The quality or state of being utter, or extreme; extremity; utmost; uttermost.","pos":""}]}