{"EXSANGUINEOUS":[{"def":"Destitute of blood; anæmic; exsanguious.","pos":""}],"EXSANGUINITY":[{"def":"Privation or destitution of blood; -- opposed to plethora.","pos":""}],"EXSANGUINOUS":[{"def":"See Exsanguious.","pos":""}],"EXSANGUIOUS":[{"def":"Destitute of true, or red, blood, as insects.","pos":""}],"EXSCIND":[{"def":"To cut off; to separate or expel from union; to extirpate.","pos":""}],"EXSCRIBE":[{"def":"To copy; to transcribe.","pos":""}],"EXSCRIPT":[{"def":"A copy; a transcript.","pos":""}],"EXSCRIPTURAL":[{"def":"Not in accordance with the doctrines of Scripture; unscriptural.","pos":""}],"EXSCUTELLATE":[{"def":"Without, or apparently without, a scutellum; -- said of certain insects.","pos":""}],"EXSECT":[{"def":"The removal by operation of a portion of a limb; particularly, the removal of a portion of a bone in the vicinity of a joint; the act or process of cutting out.","pos":""},{"def":"Standing out; projecting beyond some other part; as, exsert stamens.","pos":""}],"EXSERTILE":[{"def":"Capable of being thrust out or protruded.","pos":""}],"EXSICCANT":[{"def":"Having the quality of drying up; causing a drying up.","pos":""},{"def":"An exsiccant medicine.","pos":""}],"EXSICCATE":[{"def":"To exhaust or evaporate moisture from; to dry up.","pos":""}],"EXSICCATION":[{"def":"The act of operation of drying; evaporation or expulsion of moisture; state of being dried up; dryness.","pos":""}],"EXSICCATIVE":[{"def":"Tending to make dry; having the power of drying.","pos":""}],"EXSICCATOR":[{"def":"An apparatus for drying substances or preserving them from moisture; a desiccator; also, less frequently, an agent employed to absorb moisture, as calcium chloride, or concentrated sulphuric acid.","pos":""}],"EXSPUITION":[{"def":"A discharge of saliva by spitting.","pos":""}],"EXSPUTORY":[{"def":"Spit out, or as if spit out.","pos":""}],"EXSTIPULATE":[{"def":"Having no stipules.","pos":""}],"EXSTROPHY":[{"def":"The eversion or turning out of any organ, or of its inner surface; as, exstrophy of the eyelid or of the bladder.","pos":""}],"EXSUCCOUS":[{"def":"Destitute of juice; dry; sapless.","pos":""}],"EXSUCTION":[{"def":"The act of sucking out.","pos":""}],"EXSUFFLATE":[{"def":"To exorcise or renounce by blowing.","pos":""}],"EXSUFFLATION":[{"def":"A kind of exorcism by blowing with the breath.","pos":""},{"def":"A strongly forced expiration of air from the lungs.","pos":""}],"EXSUFFLICATE":[{"def":"Empty; frivolous.","pos":""}],"EXSUSCITATE":[{"def":"To rouse; to excite.","pos":""}],"EXSUSCITATION":[{"def":"A stirring up; a rousing.","pos":""}]}