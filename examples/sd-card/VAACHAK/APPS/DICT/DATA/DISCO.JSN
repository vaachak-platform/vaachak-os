{"DISCOAST":[{"def":"To depart; to quit the coast (that is, the side or border) of anything; to be separated.","pos":""}],"DISCOBLASTIC":[{"def":"Applied to a form of egg cleavage seen in osseous fishes, which occurs only in a small disk that separates from the rest of the egg.","pos":""}],"DISCOBOLUS":[{"def":"Note: The Discobolus of Myron was a famous statue of antiquity, and several copies or imitations of it have been preserved.","pos":""}],"DISCODACTYL":[{"def":"One of the tree frogs.","pos":""}],"DISCODACTYLIA":[{"def":"A division of amphibians having suctorial disks on the toes, as the tree frogs.","pos":""}],"DISCODACTYLOUS":[{"def":"Having sucking disks on the toes, as the tree frogs.","pos":""}],"DISCOID":[{"def":"Having the form of a disk, as those univalve shells which have the whorls in one plane, so as to form a disk, as the pearly nautilus.","pos":""}],"DISCOIDAL":[{"def":"Disk-shaped; discoid.","pos":""}],"DISCOLITH":[{"def":"One of a species of coccoliths, having an oval discoidal body, with a thick strongly refracting rim, and a thinner central portion.","pos":""}],"DISCOLOR":[{"def":"To alter the natural hue or color of; to change to a different color; to stain; to tinge; as, a drop of wine will discolor water; silver is discolored by sea water.","pos":""},{"def":"To alter the true complexion or appearance of; to put a false hue upon.","pos":""}],"DISCOLORATION":[{"def":"The act of discoloring, or the state of being discolored; alteration of hue or appearance.","pos":""},{"def":"A discolored spot; a stain.","pos":""}],"DISCOLORED":[{"def":"Altered in color; 2.","pos":""}],"DISCOMFIT":[{"def":"To scatter in fight; to put to rout; to defeat.","pos":""},{"def":"To break up and frustrate the plans of; to balk Well, go with me and be not so discomfited.","pos":""}],"DISCOMFITURE":[{"def":"The act of discomfiting, or the state of being discomfited; rout; overthrow; defeat; frustration; confusion and dejection.","pos":""}],"DISCOMFORT":[{"def":"To discourage; to deject.","pos":""},{"def":"To destroy or disturb the comfort of; to deprive oas, a smoky chimney discomforts a family.","pos":""}],"DISCOMFORTABLE":[{"def":"Causing discomfort; occasioning uneasiness; making sad.","pos":""},{"def":"Destitute of comfort; uncomfortable.","pos":""}],"DISCOMMEND":[{"def":"To mention with disapprobation; to blame; to disapprove.","pos":""},{"def":"To expose to censure or ill favor; to put out of the good graces of any one.","pos":""}],"DISCOMMENDABLE":[{"def":"Deserving, disapprobation or blame.","pos":""}],"DISCOMMENDATION":[{"def":"Blame; censure; reproach.","pos":""}],"DISCOMMENDER":[{"def":"One who discommends; a dispraiser.","pos":""}],"DISCOMMISSION":[{"def":"To deprive of a commission or trust.","pos":""}],"DISCOMMODE":[{"def":"To put inconvenience; to incommode; to trouble.","pos":""}],"DISCOMMODIOUS":[{"def":"Inconvenient; troublesome; incommodious.","pos":""}],"DISCOMMODITY":[{"def":"Disadvantage; inconvenience.","pos":""}],"DISCOMMON":[{"def":"To deprive of commonable quality, as lands, by inclosing or appropriating.","pos":""}],"DISCOMMUNITY":[{"def":"A lack of common possessions, properties, or relationship.","pos":""}],"DISCOMPANY":[{"def":"To free from company; to dissociate.","pos":""}],"DISCOMPLEXION":[{"def":"To change the complexion or hue of.","pos":""}],"DISCOMPLIANCE":[{"def":"Failure or refusal to comply; noncompliance.","pos":""}],"DISCOMPOSE":[{"def":"To disarrange; to interfere with; to disturb; to disorder; to unsettle; to break up.","pos":""},{"def":"To throw into disorder; to ruffle; to destroy the composure or equanimity; to agitate.","pos":""}],"DISCOMPOSED":[{"def":"Disordered; disturbed; disquieted.","pos":""}],"DISCOMPOSITION":[{"def":"Inconsistency; discordance.","pos":""}],"DISCOMPOSURE":[{"def":"The state of being discomposed; disturbance; disorder; agitation; perturbation.","pos":""},{"def":"Discordance; disagreement of parts.","pos":""}],"DISCONCERT":[{"def":"To break up the harmonious progress of; to throw into disorder or confusion; as, the emperor disconcerted the plans of his enemy.","pos":""},{"def":"To confuse the faculties of; to disturb the composure of; to discompose; to abash.","pos":""}],"DISCONCERTION":[{"def":"The act of disconcerting, or state of being disconcerted; discomposure; perturbation.","pos":""}],"DISCONDUCIVE":[{"def":"Not conductive; impeding; disadvantageous.","pos":""}],"DISCONFORMABLE":[{"def":"Not conformable.","pos":""}],"DISCONFORMITY":[{"def":"Want of conformity or correspondence; inconsistency; disagreement.","pos":""}],"DISCONGRUITY":[{"def":"Incongruity; disagreement; unsuitableness.","pos":""}],"DISCONNECT":[{"def":"To dissolve the union or connection of; to disunite; to sever; to separate; to disperse.","pos":""}],"DISCONNECTION":[{"def":"The act of disconnecting, or state of being disconnected; separation; want of union.","pos":""}],"DISCONSECRATE":[{"def":"To deprive of consecration or sacredness.","pos":""}],"DISCONSENT":[{"def":"To differ; to disagree; to dissent.","pos":""}],"DISCONSOLACY":[{"def":"The state of being disconsolate.","pos":""}],"DISCONSOLATE":[{"def":"Disconsolateness.","pos":""}],"DISCONSOLATED":[{"def":"A poor, disconsolated, drooping creature.","pos":""}],"DISCONSOLATION":[{"def":"Dejection; grief.","pos":""}],"DISCONTENT":[{"def":"Not content; discontented; dissatisfied.","pos":""}],"DISCONTENTATION":[{"def":"Dis*con`ten*ta\"tion, n.","pos":""}],"DISCONTENTED":[{"def":"Dissatisfied; uneasy in mind; malcontent.","pos":""}],"DISCONTENTFUL":[{"def":"Full of discontent.","pos":""}],"DISCONTENTING":[{"def":"Causing discontent; dissatisfying.","pos":""}],"DISCONTENTIVE":[{"def":"Relating or tending to discontent.","pos":""}],"DISCONTENTMENT":[{"def":"The state of being discontented; uneasiness; inquietude.","pos":""}],"DISCONTINUABLE":[{"def":"Admitting of being discontinued.","pos":""}],"DISCONTINUANCE":[{"def":"The act of discontinuing, or the state of being discontinued; want of continued connection or continuity; breaking off; cessation; interruption; as, a discontinuance of conversation or intercourse; discontinuance of a highway or of travel.","pos":""}],"DISCONTINUATION":[{"def":"Breach or interruption of continuity; separation of parts in a connected series; discontinuance.","pos":""}],"DISCONTINUE":[{"def":"To interrupt the continuance of; to intermit, as a practice or habit; to put an end to; to cause to cease; to cease using, to stop; to leave off.","pos":""}],"DISCONTINUEE":[{"def":"One whose possession of an estate is broken off, or discontinued; one whose estate is subject to discontinuance.","pos":""}],"DISCONTINUER":[{"def":"One who discontinues, or breaks off or away from; an absentee.","pos":""}],"DISCONTINUITY":[{"def":"Want of continuity or cohesion; disunion of parts.","pos":""}],"DISCONTINUOR":[{"def":"One who deprives another of the possession of an estate by discontinuance.","pos":""}],"DISCONTINUOUS":[{"def":"Not continuous; interrupted; broken off.","pos":""},{"def":"Exhibiting a dissolution of continuity; gaping.","pos":""}],"DISCONVENIENCE":[{"def":"Unsuitableness; incongruity.","pos":""}],"DISCONVENIENT":[{"def":"Not convenient or congruous; unsuitable; ill-adapted.","pos":""}],"DISCOPHORA":[{"def":"A division of acalephs or jellyfishes, including most of the large disklike species.","pos":""}],"DISCORD":[{"def":"Union of musical sounds which strikes the ear harshly or disagreeably, owing to the incommensurability of the vibrations which they produce; want of musical concord or harmony; a chord demanding resolution into a concord.","pos":""}],"DISCORDABLE":[{"def":"That may produce discord; disagreeing; discordant.","pos":""},{"def":"State or quality of being discordant; disagreement; inconsistency.","pos":""}],"DISCORDANT":[{"def":"Dissonant; not in harmony or musical concord; harsh; jarring; as, discordant notes or sounds.","pos":""},{"def":"Said of strata which lack conformity in direction of bedding, either as in unconformability, or as caused by a fault.","pos":""}],"DISCORDFUL":[{"def":"Full of discord; contentious.","pos":""}],"DISCORDOUS":[{"def":"Full of discord.","pos":""}],"DISCORPORATE":[{"def":"Deprived of the privileges or form of a body corporate.","pos":""}],"DISCORRESPONDENT":[{"def":"Dis*cor`re*spond\"ent, a.","pos":""}],"DISCOST":[{"def":"Same as Discoast.","pos":""}],"DISCOUNT":[{"def":"To deduct from an account, debt, charge, and the like; to make an abatement of; as, merchants sometimes discount five or six per cent for prompt payment of bills.","pos":""},{"def":"To lend money upon, deducting the discount or allowance for interest; as, the banks discount notes and bills of exchange.","pos":""}],"DISCOUNTABLE":[{"def":"Capable of being, or suitable to be, discounted; as, certain forms are necessary to render notes discountable at a bank.","pos":""}],"DISCOUNTENANCE":[{"def":"To ruffle or discompose the countenance of; to put of countenance; to put to shame; to abash.","pos":""},{"def":"To refuse to countenance, or give the support of one's approval to; to give one's influence against; to restrain by cold treatment; to discourage.","pos":""}],"DISCOUNTENANCER":[{"def":"One who discountenances; one who disfavors.","pos":""}],"DISCOUNTER":[{"def":"One who discounts; a discount broker.","pos":""}],"DISCOURAGE":[{"def":"To extinguish the courage of; to dishearten; to depress the spirits of; to deprive of confidence; to deject; -- the opposite of encourage; as, he was discouraged in his undertaking; he need not be discouraged from a like attempt.","pos":""},{"def":"To dishearten one with respect to; to discountenance; to seek to check by disfavoring; to deter one from; as, they discouraged his efforts.","pos":""}],"DISCOURAGEABLE":[{"def":"Capable of being discouraged; easily disheartened.","pos":""}],"DISCOURAGEMENT":[{"def":"The act of discouraging, or the state of being discouraged; depression or weakening of confidence; dejection.","pos":""},{"def":"That which discourages; that which deters, or tends to deter, from an undertaking, or from the prosecution of anything; a determent; as, the revolution was commenced under every possible discouragement.","pos":""}],"DISCOURAGER":[{"def":"One who discourages.","pos":""}],"DISCOURAGING":[{"def":"Causing or indicating discouragement.","pos":""}],"DISCOURE":[{"def":"That none might her discoure.","pos":""}],"DISCOURSE":[{"def":"The power of the mind to reason or infer by running, as it were, from one fact or reason to another, and deriving a conclusion; an exercise or act of this power; reasoning; range of reasoning faculty.","pos":""},{"def":"Conversation; talk.","pos":""}],"DISCOURSER":[{"def":"One who discourse; a narrator; a speaker; an haranguer.","pos":""},{"def":"The writer of a treatise or dissertation.","pos":""}],"DISCOURSIVE":[{"def":"Reasoning; characterized by reasoning; passing from premises to consequences; discursive.","pos":""},{"def":"Containing dialogue or conversation; interlocutory.","pos":""}],"DISCOURTEOUS":[{"def":"Uncivil; rude; wanting in courtesy or good manners; uncourteous.","pos":""}],"DISCOURTESY":[{"def":"Rudeness of behavior or language; ill manners; manifestation of disrespect; incivility.","pos":""}],"DISCOURTSHIP":[{"def":"Want of courtesy.","pos":""}],"DISCOUS":[{"def":"Disklike; discoid.","pos":""}],"DISCOVENANT":[{"def":"To dissolve covenant with.","pos":""}],"DISCOVER":[{"def":"To disclose; to lay open to view; to make visible; to reveal; to make known; to show (what has been secret, unseen, or unknown).","pos":""}],"DISCOVERABILITY":[{"def":"The quality of being discoverable.","pos":""}],"DISCOVERABLE":[{"def":"Capable of being discovered, found out, or perceived; as, many minute animals are discoverable only by the help of the microscope; truths discoverable by human industry.","pos":""}],"DISCOVERER":[{"def":"One who discovers; one who first comes to the knowledge of something; one who discovers an unknown country, or a new principle, truth, or fact.","pos":""},{"def":"A scout; an explorer.","pos":""}],"DISCOVERT":[{"def":"Not covert; not within the bonds of matrimony; unmarried; -- applied either to a woman who has never married or to a widow.","pos":""}],"DISCOVERTURE":[{"def":"A state of being released from coverture; freedom of a woman from the coverture of a husband.","pos":""}],"DISCOVERY":[{"def":"The action of discovering; exposure to view; laying open; showing; as, the discovery of a plot.","pos":""},{"def":"A making known; revelation; disclosure; as, a bankrupt is bound to make a full discovery of his assets.","pos":""}],"DISCOVERY DAY":[{"def":"= Columbus Day, above.","pos":""}]}