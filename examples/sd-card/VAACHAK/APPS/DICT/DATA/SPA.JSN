{"SPA":[{"def":"A spring or mineral water; -- so called from a place of this name in Belgium.","pos":""}],"SPAAD":[{"def":"A kind of spar; earth flax, or amianthus.","pos":""}],"SPACE":[{"def":"One of the intervals, or open places, between the lines of the staff.","pos":""}],"SPACEFUL":[{"def":"Wide; extensive.","pos":""}],"SPACIOUS":[{"def":"Extending far and wide; vast in extent.","pos":""},{"def":"Inclosing an extended space; having large or ample room; not contracted or narrow; capacious; roomy; as, spacious bounds; a spacious church; a spacious hall.","pos":""}],"SPAD":[{"def":"A nail one or two inches long, of iron, brass, tin, or tinner iron, with a hole through the flattened head, used to mark stations in underground surveying.","pos":""}],"SPADASSIN":[{"def":"A bravo; a bully; a duelist.","pos":""}],"SPADE":[{"def":"A hart or stag three years old.","pos":""},{"def":"A castrated man or beast.","pos":""}],"SPADEFISH":[{"def":"An American market fish (Chætodipterus faber) common on the southern coasts; -- called also angel fish, moonfish, and porgy.","pos":""}],"SPADEFOOT":[{"def":"Any species of burrowing toads of the genus Scaphiopus, esp.","pos":""}],"SPADEFUL":[{"def":"As much as a spade will hold or lift.","pos":""}],"SPADER":[{"def":"One who, or that which, spades; specifically, a digging machine.","pos":""}],"SPADICEOUS":[{"def":"Bearing flowers on a spadix; of the nature of a spadix.","pos":""}],"SPADILLE":[{"def":"The ace of spades in omber and quadrille.","pos":""}],"SPADIX":[{"def":"A fleshy spike of flowers, usually inclosed in a leaf called a spathe.","pos":""},{"def":"A special organ of the nautilus, due to a modification of the posterior tentacles.","pos":""}],"SPADO":[{"def":"An impotent person.","pos":""}],"SPADROON":[{"def":"A sword, especially a broadsword, formerly used both to cut and thrust.","pos":""}],"SPAE":[{"def":"To foretell; to divine.","pos":""}],"SPAEMAN":[{"def":"A prophet; a diviner.","pos":""}],"SPAEWIFE":[{"def":"A female fortune teller.","pos":""}],"SPAGHETTI":[{"def":"A variety or macaroni made in tubes of small diameter.","pos":""},{"def":"Chemical; alchemical.","pos":""}],"SPAGYRIST":[{"def":"One of a sect which arose in the days of alchemy, who sought to discover remedies for disease by chemical means.","pos":""}],"SPAKE":[{"def":"Spake, archaic Defn: imp.","pos":""}],"SPAKENET":[{"def":"A net for catching crabs.","pos":""}],"SPALDING KNIFE":[{"def":"A spalting knife.","pos":""}],"SPALE":[{"def":"A strengthening cross timber.","pos":""}],"SPALL":[{"def":"A chip or fragment, especially a chip of stone as struck off the block by the hammer, having at least one feather-edge.","pos":""}],"SPALPEEN":[{"def":"A scamp; an Irish term for a good-for-nothing fellow; -- often used in good-humored contempt or ridicule.","pos":""}],"SPALT":[{"def":"Liable to break or split; brittle; as, spalt timber.","pos":""},{"def":"Heedless; clumsy; pert; saucy.","pos":""}],"SPALTING KNIFE":[{"def":"A knife used in splitting codfish.","pos":""}],"SPAN":[{"def":"Span, archaic Defn: imp.","pos":""}],"SPAN-NEW":[{"def":"Quite new; brand-new; fire-new.","pos":""}],"SPANAEMIA":[{"def":"A condition of impoverishment of the blood; a morbid state in which the red corpuscles, or other important elements of the blood, are deficient.","pos":""}],"SPANAEMIC":[{"def":"Of or pertaining to spanæmia; having impoverished blood.","pos":""}],"SPANCEL":[{"def":"A rope used for tying or hobbling the legs of a horse or cow.","pos":""}],"SPANDOGS":[{"def":"A pair of grappling dogs for hoisting logs and timber.","pos":""}],"SPANDREL":[{"def":"The irregular triangular space between the curve of an arch and the inclosing right angle; or the space between the outer moldings of two contiguous arches and a horizontal line above them, or another arch above and inclosing them.","pos":""}],"SPANG":[{"def":"To spring; to bound; to leap.","pos":""}],"SPANGLE":[{"def":"A small plate or boss of shining metal; something brilliant used as an ornament, especially when stitched on the dress.","pos":""},{"def":"Figuratively, any little thing that sparkless.","pos":""}],"SPANGLER":[{"def":"One who, or that which, spangles.","pos":""}],"SPANGLY":[{"def":"Resembling, or consisting of, spangles; glittering; as, spangly light.","pos":""}],"SPANIARD":[{"def":"A native or inhabitant of Spain.","pos":""}],"SPANIEL":[{"def":"One of a breed of small dogs having long and thick hair and large drooping ears.","pos":""}],"SPANISH":[{"def":"Of or pertaining to Spain or the Spaniards.","pos":""}],"SPANK":[{"def":"To strike, as the breech, with the open hand; to slap.","pos":""}],"SPANKER":[{"def":"The after sail of a ship or bark, being a fore-and-aft sail attached to a boom and gaff; -- sometimes called driver.","pos":""}],"SPANKING":[{"def":"Moving with a quick, lively pace, or capable of so doing; dashing.","pos":""},{"def":"Large; considerable.","pos":""}],"SPANKING BREEZE":[{"def":"a strong breeze.","pos":""}],"SPANLESS":[{"def":"Incapable of being spanned.","pos":""}],"SPANNER":[{"def":"A contrivance in some of the ealier steam engines for moving the valves for the alternate admission and shutting off of the steam.","pos":""}],"SPANNISHING":[{"def":"The full blooming of a flower.","pos":""}],"SPANPIECE":[{"def":"The collar of a roof; sparpiece.","pos":""}],"SPANWORM":[{"def":"The larva of any geometrid moth, as the cankeworm; a geometer; a measuring worm.","pos":""}],"SPAR":[{"def":"An old name for a nonmetallic mineral, usually cleavable and somewhat lustrous; as, calc spar, or calcite, fluor spar, etc.","pos":""}],"SPAR-HUNG":[{"def":"Hung with spar, as a cave.","pos":""}],"SPARABLE":[{"def":"A kind of small nail used by shoemakers.","pos":""}],"SPARADA":[{"def":"A small California surf fish (Micrometrus aggregatus); -- called also shiner.","pos":""}],"SPARADRAP":[{"def":"Any adhesive plaster.","pos":""}],"SPARBLE":[{"def":"To scatter; to disperse; to rout.","pos":""}],"SPARE":[{"def":"To use frugally or stintingly, as that which is scarce or valuable; to retain or keep unused; to save.","pos":"noun"},{"def":"To keep to one's self; to forbear to impart or give.","pos":"noun"}],"SPARELY":[{"def":"In a spare manner; sparingly.","pos":""}],"SPARENESS":[{"def":"The quality or state of being lean or thin; leanness.","pos":""}],"SPARERIB":[{"def":"A piece of pork, consisting or ribs with little flesh on them.","pos":""}],"SPARGE":[{"def":"To sprinkle; to moisten by sprinkling; as, to sparge paper.","pos":""}],"SPARGEFACTION":[{"def":"The act of sprinkling.","pos":""}],"SPARGER":[{"def":"A vessel with a perforated cover, for sprinkling with a liquid; a sprinkler.","pos":""}],"SPARHAWK":[{"def":"The sparrow hawk.","pos":""}],"SPARING":[{"def":"Spare; saving; frugal; merciful.","pos":""}],"SPARK":[{"def":"A small particle of fire or ignited substance which is emitted by a body in combustion.","pos":""},{"def":"A small, shining body, or transient light; a sparkle.","pos":""}],"SPARK GAP":[{"def":"The space filled with air or other dielectric between high potential terminals (as of an electrostatic machine, induction coil, or condenser), through which the discharge passes; the air gap of a jump spark.","pos":""}],"SPARK PLUG":[{"def":"In internal-combustion engines with electric ignition, a plug, screwed into the cylinder head, having through it an insulated wire which is connected with the induction coil or magneto circuit on the outside, and forms, with another terminal on the base of the plug, a spark gap inside the cylinder.","pos":""}],"SPARKER":[{"def":"A spark arrester.","pos":""}],"SPARKFUL":[{"def":"Lively; brisk; gay.","pos":""}],"SPARKISH":[{"def":"Like a spark; airy; gay.","pos":""},{"def":"Showy; well-dresed; fine.","pos":""}],"SPARKLE":[{"def":"A little spark; a scintillation.","pos":""},{"def":"Brilliancy; luster; as, the sparkle of a diamond.","pos":""}],"SPARKLER":[{"def":"One who scatters; esp.","pos":""}],"SPARKLING":[{"def":"Emitting sparks; glittering; flashing; brilliant; lively; as, sparkling wine; sparkling eyes.","pos":""}],"SPARLYRE":[{"def":"The calf of the leg.","pos":""}],"SPAROID":[{"def":"of or pertaining to the Sparidæ, a family of spinous-finned fishes which includes the scup, sheepshead, and sea bream.","pos":""},{"def":"One of the Sparidæ.","pos":""}],"SPARPIECE":[{"def":"The collar beam of a roof; the spanpiece.","pos":""}],"SPARPOIL":[{"def":"To scatter; to spread; to disperse.","pos":""}],"SPARROW":[{"def":"One of many species of small singing birds of the family Fringilligæ, having conical bills, and feeding chiefly on seeds.","pos":""},{"def":"Any one of several small singing birds somewhat resembling the true sparrows in form or habits, as the European hedge sparrow.","pos":""}],"SPARROWWORT":[{"def":"An evergreen shrub of the genus Erica (E.","pos":""}],"SPARRY":[{"def":"Resembling spar, or consisting of spar; abounding with spar; having a confused crystalline structure; spathose.","pos":""}],"SPARSE":[{"def":"Placed irregularly and distantly; scattered; -- applied to branches, leaves, peduncles, and the like.","pos":""}],"SPARSELY":[{"def":"In a scattered or sparse manner.","pos":""}],"SPARSENESS":[{"def":"The quality or state of being sparse; as, sparseness of population.","pos":""}],"SPARSIM":[{"def":"Sparsely; scatteredly; here and there.","pos":""}],"SPARTAN":[{"def":"of or pertaining to Sparta, especially to ancient Sparta; hence, hardy; undaunted; as, Spartan souls; Spartan bravey.","pos":""},{"def":"A native or inhabitant of Sparta; figuratively, a person of great courage and fortitude.","pos":""}],"SPARTEINE":[{"def":"A narcotic alkaloid extracted from the tops of the common broom (Cytisus scoparius, formerly Spartium scoparium), as a colorless oily liquid of aniline-like odor and very bitter taste.","pos":""}],"SPARTERIE":[{"def":"Articles made of the blades or fiber of the Lygeum Spartum and Stipa (or Macrochloa) tenacissima, kinds of grass used in Spain and other countries for making ropes, mats, baskets, nets, and mattresses.","pos":""}],"SPARTH":[{"def":"An Anglo-Saxon battle-ax, or halberd.","pos":""}],"SPARVE":[{"def":"The hedge sparrow.","pos":""}],"SPARY":[{"def":"Sparing; parsimonious.","pos":""}],"SPASM":[{"def":"An involuntary and unnatural contraction of one or more muscles or muscular fibers.","pos":""}],"SPASMODIC":[{"def":"Of or pertaining to spasm; consisting in spasm; occuring in, or characterized by, spasms; as, a spasmodic asthma.","pos":""}],"SPASMODICAL":[{"def":"Same as Spasmodic, a.","pos":""}],"SPASTIC":[{"def":"Of or pertaining to spasm; spasmodic; especially, pertaining to tonic spasm; tetanic.","pos":""}],"SPASTICITY":[{"def":"A state of spasm.","pos":""},{"def":"The tendency to, or capability of suffering, spasm.","pos":""}],"SPAT":[{"def":"A young oyster or other bivalve mollusk, both before and after it first becomes adherent, or such young, collectively.","pos":""}],"SPATANGOID":[{"def":"Of or pertaining to the Spatangoidea.","pos":""},{"def":"One of the Spatangoidea.","pos":""}],"SPATANGOIDEA":[{"def":"An order of irregular sea urchins, usually having a more or less heart-shaped shell with four or five petal-like ambulacra above.","pos":""}],"SPATANGUS":[{"def":"A genus of heart-shaped sea urchins belonging to the Spatangoidea.","pos":""}],"SPATE":[{"def":"A river flood; an overflow or inundation.","pos":""}],"SPATHACEOUS":[{"def":"Having a spathe; resembling a spathe; spathal.","pos":""}],"SPATHAL":[{"def":"Furnished with a spathe; as, spathal flowers.","pos":""}],"SPATHE":[{"def":"A special involucre formed of one leaf and inclosing a spadix, as in aroid plants and palms.","pos":""}],"SPATHED":[{"def":"Having a spathe or calyx like a sheath.","pos":""}],"SPATHIC":[{"def":"Like spar; foliated or lamellar; spathose.","pos":""}],"SPATHIFORM":[{"def":"Resembling spar in form.","pos":""}],"SPATHOSE":[{"def":"Having a spathe; resembling a spathe; spatheceous; spathal.","pos":""}],"SPATIAL":[{"def":"Of or pertaining to space.","pos":""}],"SPATIALLY":[{"def":"As regards space.","pos":""}],"SPATIATE":[{"def":"To rove; to ramble.","pos":""}],"SPATTER":[{"def":"To sprinkle with a liquid or with any wet substance, as water, mud, or the like; to make wet of foul spots upon by sprinkling; as, to spatter a coat; to spatter the floor; to spatter boots with mud.","pos":""},{"def":"To distribute by sprinkling; to sprinkle around; as, to spatter blood.","pos":""}],"SPATTER-DOCK":[{"def":"The common yellow water lily (Nuphar advena).","pos":""}],"SPATTERDASHED":[{"def":"Wearing spatterdashes.","pos":""}],"SPATTERDASHES":[{"def":"Coverings for the legs, to protect them from water and mud; long gaiters.","pos":""}],"SPATTLE":[{"def":"A tool or implement for mottling a molded article with coloring matter Knoght.","pos":""}],"SPATTLING-POPPY":[{"def":"A kind of catchfly (Silene inflata) which is sometimes frothy from the action of captured insects.","pos":""}],"SPATULA":[{"def":"An implement shaped like a knife, flat, thin, and somewhat flexible, used for spreading paints, fine plasters, drugs in compounding prescriptions, etc.","pos":""}],"SPATULATE":[{"def":"Shaped like spatula, or like a battledoor, being roundish, with a long, narrow, linear base.","pos":""}],"SPAVIN":[{"def":"A disease of horses characterized by a bony swelling developed on the hock as the result of inflammation of the bones; also, the swelling itself.","pos":""}],"SPAVINED":[{"def":"Affected with spavin.","pos":""}],"SPAWL":[{"def":"A splinter or fragment, as of wood or stone.","pos":""}],"SPAWLING":[{"def":"That which is spawled, or spit out.","pos":""}],"SPAWN":[{"def":"To produce or deposit (eggs), as fishes or frogs do.","pos":""},{"def":"To bring forth; to generate; -- used in contempt.","pos":""}],"SPAWNER":[{"def":"A mature female fish.","pos":""}],"SPAY":[{"def":"To remove or extirpate the ovaries of, as a sow or a bitch; to castrate (a female animal).","pos":""}]}