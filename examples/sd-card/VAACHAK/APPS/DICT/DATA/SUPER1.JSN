{"SUPER":[{"def":"A contraction of Supernumerary, in sense 2.","pos":""}],"SUPER-":[{"def":"A prefix formerly much used to denote that the ingredient to the name of which it was prefixed was present in a large, or unusually large, proportion as compared with the other ingredients; as in calcium superphosphate.","pos":""}],"SUPERABLE":[{"def":"Capable of being overcome or conquered; surmountable.","pos":""}],"SUPERABOUND":[{"def":"To be very abundant or exuberant; to be more than sufficient; as, the country superabounds with corn.","pos":""}],"SUPERABUNDANCE":[{"def":"The quality or state of being superabundant; a superabundant quantity; redundancy; excess.","pos":""}],"SUPERABUNDANT":[{"def":"Abounding to excess; being more than is sufficient; redundant; as, superabundant zeal.","pos":""}],"SUPERACIDULATED":[{"def":"Acidulated to excess.","pos":""}],"SUPERADD":[{"def":"To add over and above; to add to what has been added; to annex, as something extrinsic.","pos":""}],"SUPERADDITION":[{"def":"The act of adding something in excess or something extraneous; also, something which is added in excess or extraneously.","pos":""}],"SUPERADVENIENT":[{"def":"Coming upon; coming in addition to, or in assistance of, something.","pos":""}],"SUPERALIMENTATION":[{"def":"The act of overfeeding, or making one take food in excess of the natural appetite for it.","pos":""}],"SUPERALTAR":[{"def":"A raised shelf or stand on the back of an altar, on which different objects can be placed; a predella or gradino.","pos":""}],"SUPERANGELIC":[{"def":"Superior to the angels in nature or rank.","pos":""}],"SUPERANNUATE":[{"def":"To impair or disquality on account of age or infirmity.","pos":""},{"def":"To give a pension to, on account of old age or other infirmity; to cause to retire from service on a pension.","pos":""}],"SUPERANNUATION":[{"def":"The state of being superannuated, or too old for office or business; the state of being disqualified by old age; decrepitude.","pos":""}],"SUPERB":[{"def":"Grand; magnificent; august; stately; as, a superb edifice; a superb colonnade.","pos":""},{"def":"Rich; elegant; as, superb furniture or decorations.","pos":""}],"SUPERBIATE":[{"def":"To make (a person) haughty.","pos":""}],"SUPERCARBONATE":[{"def":"Su`per*car\"bon*ate, n.","pos":""}],"SUPERCARBURETED":[{"def":"Su`per*car\"bu*ret`ed, a.","pos":""}],"SUPERCARGO":[{"def":"An officer or person in a merchant ship, whose duty is to manage the sales, and superintend the commercial concerns, of the voyage.","pos":""}],"SUPERCARPAL":[{"def":"Situated above, or in the upper part of, the carpus.","pos":""}],"SUPERCELESTIAL":[{"def":"Situated above the firmament, or great vault of heaven.","pos":""},{"def":"Higher than celestial; superangelic.","pos":""}],"SUPERCHARGE":[{"def":"To charge (a bearing) upon another bearing; as, to supercharge a rose upon a fess.","pos":""}],"SUPERCHEMICAL":[{"def":"Above or beyond chemistry; inexplicable by chemical laws.","pos":""}],"SUPERCHERY":[{"def":"Deceit; fraud; imposition.","pos":""}],"SUPERCILIARY":[{"def":"Having a distinct streak of color above the eyes; as, the superciliary woodpecker.","pos":""}],"SUPERCILIOUS":[{"def":"Lofty with pride; haughty; dictatorial; overbearing; arrogant; as, a supercilious officer; asupercilious air; supercilious behavior.","pos":""}],"SUPERCILIUM":[{"def":"The eyebrow, or the region of the eyebrows.","pos":""}],"SUPERCOLUMNIATION":[{"def":"The putting of one order above another; also, an architectural work produced by this method; as, the putting of the Doric order in the ground story, Ionic above it, and Corinthian or Composite above this.","pos":""}],"SUPERCONCEPTION":[{"def":"Su`per*con*cep\"tion, n.","pos":""}],"SUPERCONSEQUENCE":[{"def":"Remote consequence.","pos":""}],"SUPERCRESCENCE":[{"def":"That which grows upon another growing thing; a parasite.","pos":""}],"SUPERCRESCENT":[{"def":"Growing on some other growing thing.","pos":""}],"SUPERCRETACEOUS":[{"def":"Same as Supracretaceous.","pos":""}],"SUPERCURIOUS":[{"def":"Excessively curious or inquisitive.","pos":""}],"SUPERDOMINANT":[{"def":"The sixth tone of the scale; that next above the dominant; -- called also submediant.","pos":""}],"SUPERDREADNOUGHT":[{"def":"See Dreadnought, above.","pos":""},{"def":"The quality or state of being supereminent; distinguished eminence; as, the supereminence of Cicero as an orator, or Lord Chatham as a statesman.","pos":""}],"SUPEREMINENT":[{"def":"Eminent in a superior degree; surpassing others in excellence; as, a supereminent divine; the supereminent glory of Christ.","pos":""}],"SUPEREROGATE":[{"def":"To do more than duty requires; to perform works of supererogation; to atone (for a dificiency in another) by means of a surplus action or quality.","pos":""}],"SUPEREROGATION":[{"def":"The act of supererogating; performance of more than duty or necessity requires.","pos":""}],"SUPEREROGATIVE":[{"def":"Su`per*e*rog\"a*tive, a.","pos":""}],"SUPEREROGATORY":[{"def":"Performed to an extent not enjoined, or not required, by duty or necessity; as, supererogatory services.","pos":""}],"SUPERESSENTIAL":[{"def":"Essential above others, or above the constitution of a thing.","pos":""}],"SUPERETHICAL":[{"def":"More than ethical; above ethics.","pos":""}],"SUPEREXALT":[{"def":"To exalt to a superior degree; to exalt above others.","pos":""}],"SUPEREXALTATION":[{"def":"Elevation above the common degree.","pos":""}],"SUPEREXCELLENCE":[{"def":"Superior excellence; extraordinary excellence.","pos":""}],"SUPEREXCELLENT":[{"def":"Excellent in an uncommon degree; very excellent.","pos":""}],"SUPEREXCINATION":[{"def":"Excessive, or more than normal, excitation.","pos":""}],"SUPEREXCRESCENCE":[{"def":"Something growing superfluously.","pos":""}],"SUPERFAMILY":[{"def":"A group intermediate between a family and a suborder.","pos":""}],"SUPERFECUNDATION":[{"def":"Fertilization of two ova, at the same menstruation, by two different acts of coition.","pos":""}],"SUPERFECUNDITY":[{"def":"Superabundant fecundity or multiplication of the species.","pos":""}],"SUPERFETATE":[{"def":"To conceive after a prior conception, but before the birth of the offspring.","pos":""}],"SUPERFETATION":[{"def":"The formation of a fetus at the result of an impregnation occurring after another impregnation but before the birth of the offspring produced by it.","pos":""}],"SUPERFETE":[{"def":"To conceive (another fetus) after a former conception.","pos":""}],"SUPERFICIAL":[{"def":"Of or pertaining to the superficies, or surface; lying on the surface; shallow; not deep; as, a superficial color; a superficial covering; superficial measure or contents; superficial tillage.","pos":""},{"def":"Reaching or comprehending only what is obvious or apparent; not deep or profound; shallow; -- said especially in respect to study, learning, and the like; as, a superficial scholar; superficial knowledge.","pos":""}],"SUPERFICIALIST":[{"def":"One who attends to anything superficially; a superficial or shallow person; a sciolist; a smatterer.","pos":""}],"SUPERFICIALITY":[{"def":"The quality or state of being superficial; also, that which is superficial.","pos":""}],"SUPERFICIALIZE":[{"def":"To attend to, or to treat, superficially, or in a shallow or slighting way.","pos":""}],"SUPERFICIARY":[{"def":"One to whom a right of surface occupation is granted; one who pays quitrent for a house built upon another man's ground.","pos":""}],"SUPERFICIES":[{"def":"The surface; the exterior part, superficial area, or face of a thing.","pos":""}],"SUPERFINE":[{"def":"Very fine, or most fine; being of surpassing fineness; of extra nice or fine quality; as, superfine cloth.","pos":""},{"def":"Excessively fine; too nice; over particular; as, superfine distinctions; superfine tastes.","pos":""}],"SUPERFINENESS":[{"def":"The state of being superfine.","pos":""}],"SUPERFINICAL":[{"def":"Extremely finical.","pos":""}],"SUPERFLUITANT":[{"def":"Floating above or on the surface.","pos":""}],"SUPERFLUITY":[{"def":"A greater quantity than is wanted; superabundance; as, a superfluity of water; a superfluity of wealth.","pos":""},{"def":"The state or quality of being superfluous; excess.","pos":""}],"SUPERFLUOUS":[{"def":"More than is wanted or is sufficient; rendered unnecessary by superabundance; unnecessary; useless; excessive; as, a superfluous price.","pos":""}],"SUPERFLUX":[{"def":"Superabundance; superfluity; an overflowing.","pos":""}],"SUPERFOETATION":[{"def":"Su`per*foe*ta\"tion, n.","pos":""}],"SUPERFOLIATION":[{"def":"Excess of foliation.","pos":""}],"SUPERFRONTAL":[{"def":"A cloth which is placed over the top of an altar, and often hangs down a few inches over the frontal.","pos":""}],"SUPERFUSE":[{"def":"To pour (something) over or on something else.","pos":""}],"SUPERHEAT":[{"def":"To heat, as steam, apart from contact with water, until it resembles a perfect gas.","pos":""}],"SUPERHEATER":[{"def":"An apparatus for superheating steam.","pos":""}],"SUPERHIVE":[{"def":"A removable upper part of a hive.","pos":""}],"SUPERHUMAN":[{"def":"Above or beyond what is human; sometimes, divine; as, superhuman strength; superhuman wisdom.","pos":""}],"SUPERIMPOSE":[{"def":"To lay or impose on something else; as, a stratum of earth superimposed on another stratum.","pos":""}],"SUPERIMPREGNATION":[{"def":"The act of impregnating, or the state of being impregnated, in addition to a prior impregnation; superfetation.","pos":""},{"def":"The quality or state of being superincumbent.","pos":""}],"SUPERINCUMBENT":[{"def":"Lying or resting on something else.","pos":""}],"SUPERINDUCE":[{"def":"To bring in, or upon, as an addition to something.","pos":""}],"SUPERINDUCEMENT":[{"def":"Su`per*in*duce\"ment, n.","pos":""}],"SUPERINDUCTION":[{"def":"The act of superinducing, or the state of being superinduced.","pos":""}],"SUPERINJECTION":[{"def":"An injection succeeding another.","pos":""}],"SUPERINSPECT":[{"def":"To over see; to superintend by inspection.","pos":""}],"SUPERINSTITUTION":[{"def":"One institution upon another, as when A is instituted and admitted to a benefice upon a title, and B instituted and admitted upon the presentation of another.","pos":""}],"SUPERINTELLECTUAL":[{"def":"Being above intellect.","pos":""}],"SUPERINTEND":[{"def":"To have or exercise the charge and oversight of; to oversee with the power of direction; to take care of with authority; to supervise; as, an officer superintends the building of a ship or the construction of a fort.","pos":""}],"SUPERINTENDENCE":[{"def":"The act of superintending; care and oversight for the purpose of direction; supervision.","pos":""}],"SUPERINTENDENCY":[{"def":"The act of superintending; superintendence.","pos":""}],"SUPERINTENDENT":[{"def":"Overseeing; superintending.","pos":""}],"SUPERINTENDER":[{"def":"A superintendent.","pos":""}],"SUPERINVESTITURE":[{"def":"An outer vestment or garment.","pos":""}],"SUPERIOR":[{"def":"More elevated in place or position; higher; upper; as, the superior limb of the sun; the superior part of an image.","pos":""},{"def":"Higher in rank or office; more exalted in dignity; as, a superior officer; a superior degree of nobility.","pos":""}],"SUPERIORESS":[{"def":"A woman who acts as chief in a convent, abbey, or nunnery; a lady superior.","pos":""}],"SUPERIORITY":[{"def":"The quality, state, or condition of being superior; as, superiority of rank; superiority in merit.","pos":""}],"SUPERIORLY":[{"def":"In a superior position or manner.","pos":""}],"SUPERJACENT":[{"def":"Situated immediately above; as, superjacent rocks.","pos":""}],"SUPERLATION":[{"def":"Exaltation of anything beyond truth or propriety.","pos":""}],"SUPERLATIVE":[{"def":"Expressing the highest or lowest degree of the quality, manner, etc.","pos":""}],"SUPERLUCRATION":[{"def":"Excessive or extraordinary gain.","pos":""},{"def":"Being above the moon; not belonging to this world; -- opposed to sublunary.","pos":""}],"SUPERMAN":[{"def":"= Overman, above.","pos":""}],"SUPERMATERIAL":[{"def":"Being above, or superior to, matter.","pos":""}],"SUPERMAXILLA":[{"def":"The supermaxilla.","pos":""}],"SUPERMAXILLARY":[{"def":"Su`per*max\"il*la*ry, a.","pos":""}],"SUPERMEDIAL":[{"def":"Above the middle.","pos":""}],"SUPERMUNDANE":[{"def":"Being above the world; -- opposed to inframundane.","pos":""}],"SUPERNACULAR":[{"def":"Like supernaculum; first-rate; as, a supernacular wine.","pos":""}],"SUPERNACULUM":[{"def":"A kind of mock Latin term intended to mean, upon the nail; -- used formerly by topers.","pos":""},{"def":"Good liquor, of which not enough is left to wet one's nail.","pos":""}],"SUPERNAL":[{"def":"Being in a higher place or region; locally higher; as, the supernal orbs; supernal regions.","pos":""},{"def":"Relating or belonging to things above; celestial; heavenly; as, supernal grace.","pos":""}],"SUPERNATANT":[{"def":"Swimming above; floating on the surface; as, oil supernatant on water.","pos":""},{"def":"The liquid remaining after solids suspended in a liquid have been sedimented by gravity or by centrifugation.","pos":""}],"SUPERNATATION":[{"def":"The act of floating on the surface of a fluid.","pos":""}],"SUPERNATURAL":[{"def":"Being beyond, or exceeding, the power or laws of nature; miraculous.","pos":""}],"SUPERNATURALISM":[{"def":"The doctrine of a divine and supernatural agency in the production of the miracles and revelations recorded in the Bible, and in the grace which renews and sanctifies men, -- in opposition to the doctrine which denies the agency of any other than physical or natural causes in the case.","pos":""}],"SUPERNATURALIST":[{"def":"One who holds to the principles of supernaturalism.","pos":""}],"SUPERNATURALISTIC":[{"def":"Of or pertaining to supernaturalism.","pos":""}],"SUPERNATURALITY":[{"def":"The quality or state of being supernatural.","pos":""}],"SUPERNATURALIZE":[{"def":"To treat or regard as supernatural.","pos":""}],"SUPERNATURALLY":[{"def":"In a supernatural manner.","pos":""}],"SUPERNATURALNESS":[{"def":"The quality or state of being supernatural.","pos":""}],"SUPERNUMERARY":[{"def":"Exceeding the number stated or prescribed; as, a supernumerary officer in a regiment.","pos":""},{"def":"Exceeding a necessary, usual, or required number or quality; superfluous; as, supernumerary addresses; supernumerary expense.","pos":""}]}