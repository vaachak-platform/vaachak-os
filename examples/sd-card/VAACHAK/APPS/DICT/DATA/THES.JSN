{"THESAURUS":[{"def":"A treasury or storehouse; hence, a repository, especially of knowledge; -- often applied to a comprehensive work, like a dictionary or cyclopedia.","pos":""}],"THESE":[{"def":"The plural of this.","pos":""}],"THESICLE":[{"def":"A little or subordinate thesis; a proposition.","pos":""}],"THESIS":[{"def":"An affirmation, or distinction from a supposition or hypothesis.","pos":""},{"def":"The accented part of the measure, expressed by the downward beat; -- the opposite of arsis.","pos":""}],"THESMOTHETE":[{"def":"A lawgiver; a legislator; one of the six junior archons at Athens.","pos":""}],"THESPIAN":[{"def":"Of or pertaining to Thespis; hence, relating to the drama; dramatic; as, the Thespian art.","pos":""}],"THESSALIAN":[{"def":"Of or pertaining to Thessaly in Greece.","pos":""},{"def":"A native or inhabitant of Thessaly.","pos":""}],"THESSALONIAN":[{"def":"Of or pertaining to Thessalonica, a city of Macedonia.","pos":""},{"def":"A native or inhabitant of Thessalonica.","pos":""}]}