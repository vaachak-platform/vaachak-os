{"ZEA":[{"def":"A genus of large grasses of which the Indian corn (Zea Mays) is the only species known.","pos":""}],"ZEAL":[{"def":"Passionate ardor in the pursuit of anything; eagerness in favor of a person or cause; ardent and active interest; engagedness; enthusiasm; fervor.","pos":""}],"ZEALANT":[{"def":"One who is zealous; a zealot; an enthusiast.","pos":""}],"ZEALED":[{"def":"Full of zeal; characterized by zeal.","pos":""}],"ZEALOT":[{"def":"One who is zealous; one who engages warmly in any cause, and pursues his object with earnestness and ardor; especially, one who is overzealous, or carried away by his zeal; one absorbed in devotion to anything; an enthusiast; a fanatical partisan.","pos":""}],"ZEALOTICAL":[{"def":"Like, or suitable to, a zealot; ardently zealous.","pos":""}],"ZEALOTISM":[{"def":"The character or conduct of a zealot; zealotry.","pos":""}],"ZEALOTRY":[{"def":"The character and behavior of a zealot; excess of zeal; fanatical devotion to a cause.","pos":""}],"ZEALOUS":[{"def":"Filled with, or characterized by, zeal; warmly engaged, or ardent, in behalf of an object.","pos":""},{"def":"Filled with religious zeal.","pos":""}],"ZEBRA":[{"def":"Either one of two species of South African wild horses remarkable for having the body white or yellowish white, and conspicuously marked with dark brown or brackish bands.","pos":""}],"ZEBRINE":[{"def":"Pertaining to, or resembling, the zebra.","pos":""}],"ZEBRINNY":[{"def":"A cross between a male horse and a female zebra.","pos":""},{"def":"A cross between a male zebra and a female horse.","pos":""}],"ZEBU":[{"def":"A bovine mammal (Ros Indicus) extensively domesticated in India, China, the East Indies, and East Africa.","pos":""}],"ZEBUB":[{"def":"A large noxious fly of Abyssinia, which like the tsetse fly, is destructive to cattle.","pos":""}],"ZECHSTEIN":[{"def":"The upper division of the Permian (Dyas) of Europe.","pos":""}],"ZED":[{"def":"The letter Z; -- called also zee, and formerly izzard.","pos":""}],"ZEDOARY":[{"def":"A medicinal substance obtained in the East Indian, having a fragrant smell, and a warm, bitter, aromatic taste.","pos":""}],"ZEEMAN EFFECT":[{"def":"The widening and duplication, triplication, etc.","pos":""}],"ZEHNER":[{"def":"An Austrian silver coin equal to ten kreutzers, or about five cents.","pos":""}],"ZEIN":[{"def":"A nitrogenous substance of the nature of gluten, obtained from the seeds of Indian corn (Zea) as a soft, yellowish, amorphous substance.","pos":""}],"ZEITGEIST":[{"def":"The spirit of the time; the general intellectual and moral state or temper characteristic of any period of time.","pos":""}],"ZEMINDAR":[{"def":"Same as Zamindar.","pos":""},{"def":"Same as Zamindary.","pos":""}],"ZEMNI":[{"def":"The blind mole rat (Spalax typhlus), native of Eastern Europe and Asia.","pos":""}],"ZEMSTVO":[{"def":"In Russia, an elective local district and provincial administrative assembly.","pos":""}],"ZENANA":[{"def":"The part of a dwelling appropriated to women.","pos":""}],"ZEND":[{"def":"Properly, the translation and exposition in the Huzvâresh, or literary Pehlevi, language, of the Avesta, the Zoroastrian sacred writings; as commonly used, the language (an ancient Persian dialect) in which the Avesta is written.","pos":""}],"ZEND-AVESTA":[{"def":"The sacred writings of the ancient Persian religion, attributed to Zoroaster, but chiefly of a later date.","pos":""}],"ZENDIK":[{"def":"An atheist or unbeliever; -- name given in the East to those charged with disbelief of any revealed religion, or accused of magical heresies.","pos":""}],"ZENICK":[{"def":"A South African burrowing mammal (Suricata tetradactyla), allied to the civets.","pos":""}],"ZENITH":[{"def":"That point in the visible celestial hemisphere which is vertical to the spectator; the point of the heavens directly overhead; -- opposed to nadir.","pos":""}],"ZENITHAL":[{"def":"Of or pertaining to the zenith.","pos":""}],"ZEOLITE":[{"def":"A term now used to designate any one of a family of minerals, hydrous silicates of alumina, with lime, soda, potash, or rarely baryta.","pos":""}],"ZEOLITIC":[{"def":"Of or pertaining to a zeolite; consisting of, or resembling, a zeolite.","pos":""}],"ZEOLITIFORM":[{"def":"Having the form of a zeolite.","pos":""}],"ZEPHYR":[{"def":"The west wind; poetically, any soft, gentle breeze.","pos":""}],"ZEPHYRUS":[{"def":"The west wind, or zephyr; -- usually personified, and made the most mild and gentle of all the sylvan deities.","pos":""}],"ZEPPELIN":[{"def":"A dirigible balloon of the rigid type, consisting of a cylindrical trussed and covered frame supported by internal gas cells, and provided with means of propulsion and control.","pos":""}],"ZERO":[{"def":"A cipher; nothing; naught.","pos":""}],"ZEST":[{"def":"A piece of orange or lemon peel, or the aromatic oil which may be squeezed from such peel, used to give flavor to liquor, etc.","pos":""},{"def":"Hence, something that gives or enhances a pleasant taste, or the taste itself; an appetizer; also, keen enjoyment; relish; gusto.","pos":""}],"ZETA":[{"def":"A Greek letter [z] corresponding to our z.","pos":""}],"ZETETIC":[{"def":"Seeking; proceeding by inquiry.","pos":""}],"ZETETICS":[{"def":"A branch of algebra which relates to the direct search for unknown quantities.","pos":""}],"ZEUGLODON":[{"def":"A genus of extinct Eocene whales, remains of which have been found in the Gulf States.","pos":""}],"ZEUGLODONT":[{"def":"Any species of Zeuglodonta.","pos":""}],"ZEUGLODONTA":[{"def":"Same as Phocodontia.","pos":""}],"ZEUGMA":[{"def":"A figure by which an adjective or verb, which agrees with a nearer word, is, by way of supplement, referred also to another more remote; as, \"hic illius arma, hic currus fuit;\" where fuit, which agrees directly with currus, is referred also to arma.","pos":""}],"ZEUGMATIC":[{"def":"Of or pertaining to zeugma; characterized by zeugma.","pos":""}],"ZEUGOBRANCHIATA":[{"def":"Same as Zygobranchia.","pos":""}],"ZEUS":[{"def":"The chief deity of the Greeks, and ruler of the upper world (cf.","pos":""}],"ZEUZERIAN":[{"def":"Any one of a group of bombycid moths of which the genus Zeuzera is the type.","pos":""}],"ZEYLANITE":[{"def":"A carnivorous mammal (Viverra zibetha) closely allied to the civet, from which it differs in having the spots on the body less distinct, the throat whiter, and the black rings on the tail more numerous.","pos":""}]}