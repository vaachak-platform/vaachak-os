{"CALABAR":[{"def":"A district on the west coast of Africa.","pos":""}],"CALABARINE":[{"def":"An alkaloid resembing physostigmine and occurring with it in the calabar bean.","pos":""}],"CALABASH":[{"def":"The common gourd (plant or fruit).","pos":""},{"def":"The fruit of the calabash tree.","pos":""}],"CALABOOSE":[{"def":"A prison; a jail.","pos":""}],"CALADE":[{"def":"A slope or declivity in a manege ground down which a horse is made to gallop, to give suppleness to his haunches.","pos":""}],"CALADIUM":[{"def":"A genus of aroideous plants, of which some species are cultivated for their immense leaves (which are often curiously blotched with white and red), and others (in Polynesia) for food.","pos":""}],"CALAMANCO":[{"def":"A glossy woolen stuff, plain, striped, or checked.","pos":""}],"CALAMANDER WOOD":[{"def":"A valuable furniture wood from India and Ceylon, of a hazel- brown color, with black stripes, very hard in texture.","pos":""},{"def":"A cephalopod, belonging to the genus Loligo and related genera.","pos":""}],"CALAMBAC":[{"def":"A fragrant wood; agalloch.","pos":""}],"CALAMBOUR":[{"def":"A species of agalloch, or aloes wood, of a dusky or mottled color, of a light, friable texture, and less fragrant than calambac; -- used by cabinetmakers.","pos":""}],"CALAMIFEROUS":[{"def":"Producing reeds; reedy.","pos":""}],"CALAMINE":[{"def":"A mineral, the hydrous silicate of zinc.","pos":""}],"CALAMINT":[{"def":"A genus of perennial plants (Calamintha) of the Mint family, esp.","pos":""}],"CALAMIST":[{"def":"One who plays upon a reed or pipe.","pos":""}],"CALAMISTRATE":[{"def":"To curl or friz, as the hair.","pos":""}],"CALAMISTRATION":[{"def":"The act or process of curling the hair.","pos":""}],"CALAMISTRUM":[{"def":"A comblike structure on the metatarsus of the hind legs of certain spiders (Ciniflonidæ), used to curl certain fibers in the construction of their webs.","pos":""}],"CALAMITE":[{"def":"A fossil plant of the coal formation, having the general form of plants of the modern Equiseta (the Horsetail or Scouring Rush family) but sometimes attaining the height of trees, and having the stem more or less woody within.","pos":""}],"CALAMITOUS":[{"def":"Suffering calamity; wretched; miserable.","pos":""},{"def":"Producing, or attended with distress and misery; making wretched; wretched; unhappy.","pos":""}],"CALAMITY":[{"def":"Any great misfortune or cause of misery; -- generally applied to events or disasters which produce extensive evil, either to communities or individuals.","pos":""},{"def":"A state or time of distress or misfortune; misery.","pos":""}],"CALAMUS":[{"def":"The indian cane, a plant of the Palm family.","pos":""},{"def":"A species of Acorus (A.","pos":""}],"CALASH":[{"def":"A light carriage with low wheels, having a top or hood that can be raised or lowered, seats for inside, a separate seat for the driver, and often a movable front, so that it can be used as either an open or a close carriage.","pos":""},{"def":"In Canada, a two-wheeled, one-seated vehicle, with a calash top, and the driver's seat elevated in front.","pos":""}],"CALAVERAS SKULL":[{"def":"A human skull reported, by Prof.","pos":""}],"CALAVERITE":[{"def":"A bronze-yellow massive mineral with metallic luster; a telluride of gold; -- first found in Calaveras County California.","pos":""}]}