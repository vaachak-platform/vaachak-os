{"SESAME":[{"def":"Either of two annual herbaceous plants of the genus Sesamum (S.","pos":""}],"SESAMOID":[{"def":"Of or pertaining to the sesamoid bones or cartilages; sesamoidal.","pos":""}],"SESBAN":[{"def":"A leguminous shrub (Sesbania aculeata) which furnishes a fiber used for making ropes.","pos":""}],"SESQUI-":[{"def":"A combining form (also used adjectively) denoting that three atoms or equivalents of the substance to the name of which it is prefixed are combined with two of some other element or radical; as, sesquibromide, sesquicarbonate, sesquichloride, sesquioxide.","pos":""}],"SESQUIALTER":[{"def":"A stop on the organ, containing several ranks of pipes which reënforce some of the high harmonics of the ground tone, and make the sound more brilliant.","pos":""}],"SESQUIALTEROUS":[{"def":"Ses`qui*al\"ter*ous, a.","pos":""}],"SESQUIBASIC":[{"def":"Containing, or acting as, a base in the proportions of a sesqui compound.","pos":""}],"SESQUIDUPLICATE":[{"def":"Twice and a half as great (as another thing); having the ratio of two and a half to one.","pos":""}],"SESQUIOXIDE":[{"def":"An oxide containing three atoms of oxygen with two atoms (or radicals) of some other substance; thus, alumina, Al2O3 is a sesquioxide.","pos":""},{"def":"Measuring or containing a foot and a half; as, a sesquipedalian pygmy; -- sometimes humorously applied to long words.","pos":""}],"SESQUIPEDALITY":[{"def":"The quality or condition of being sesquipedal.","pos":""},{"def":"The use of sesquipedalian words; style characterized by the use of long words; sesquipedalism.","pos":""}],"SESQUIPLICATE":[{"def":"Subduplicate of the triplicate; -- a term applied to ratios; thus, a and a' are in the sesquiplicate ratio of b and b', when a is to a' as the square root of the cube of b is to the square root of the cube of b', or a:a'::sq.","pos":""}],"SESQUISALT":[{"def":"A salt derived from a sesquioxide base, or made up on the proportions of a sesqui compound.","pos":""}],"SESQUISULPHIDE":[{"def":"A sulphide, analogous to a sesquioxide, containing three atoms of sulphur to two of the other ingredient; -- formerly called also sesquisulphuret; as, orpiment, As2S3 is arsenic sesquisulphide.","pos":""}],"SESQUITERTIAL":[{"def":"Having the ratio of one and one third to one (as 4 : 3).","pos":""}],"SESQUITONE":[{"def":"A minor third, or interval of three semitones.","pos":""}],"SESS":[{"def":"To lay a tax upon; to assess.","pos":""}],"SESSILE":[{"def":"Resting directly upon the main stem or branch, without a petiole or footstalk; as, a sessile leaf or blossom.","pos":""},{"def":"Permanently attached; -- said of the gonophores of certain hydroids which never became detached.","pos":""}],"SESSILE-EYED":[{"def":"Having eyes which are not elevated on a stalk; -- opposed to stalk-eyed.","pos":""}],"SESSION":[{"def":"The act of sitting, or the state of being seated.","pos":""},{"def":"The actual sitting of a court, council, legislature, etc.","pos":""}],"SESSIONAL":[{"def":"Of or pertaining to a session or sessions.","pos":""}],"SESSPOOL":[{"def":"Same as Cesspool.","pos":""}],"SESTERCE":[{"def":"A Roman coin or denomination of money, in value the fourth part of a denarius, and originally containing two asses and a half, afterward four asses, -- equal to about two pence sterling, or four cents.","pos":""}],"SESTET":[{"def":"A piece of music composed for six voices or six instruments; a sextet; -- called also sestuor.","pos":""},{"def":"The last six lines of a sonnet.","pos":""}]}