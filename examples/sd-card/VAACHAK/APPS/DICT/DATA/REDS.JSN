{"REDSEAR":[{"def":"To be brittle when red-hot; to be red-short.","pos":""}],"REDSHANK":[{"def":"A bare-legged person; -- a contemptuous appellation formerly given to the Scotch Highlanders, in allusion to their bare legs.","pos":""}],"REDSKIN":[{"def":"A common appellation for a North American Indian; -- so called from the color of the skin.","pos":""}],"REDSTART":[{"def":"Red\"start` (-strt`), n.","pos":""}],"REDSTREAK":[{"def":"A kind of apple having the skin streaked with red and yellow, -- a favorite English cider apple.","pos":""},{"def":"Cider pressed from redstreak apples.","pos":""}]}