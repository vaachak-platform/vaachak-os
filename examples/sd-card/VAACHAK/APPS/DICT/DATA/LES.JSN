{"LESBIAN":[{"def":"Of or pertaining to the island anciently called Lesbos, now Mitylene, in the Grecian Archipelago.","pos":""}],"LESBIANISM":[{"def":"Unnatural sexual relations between women.","pos":""}],"LESE-MAJESTY":[{"def":"See Leze majesty.","pos":""}],"LESION":[{"def":"A hurt; an injury.","pos":""},{"def":"A privative adjective suffix, denoting without, destitute of, not having; as witless, childless, fatherless.","pos":""}],"LESS":[{"def":"Smaller; not so large or great; not so much; shorter; inferior; as, a less quantity or number; a horse of less size or value; in less time than before.","pos":""}],"LESSEE":[{"def":"The person to whom a lease is given, or who takes an estate by lease.","pos":""}],"LESSEN":[{"def":"To make less; to reduce; to make smaller, or fewer; to diminish; to lower; to degrade; as, to lessen a kingdom, or a population; to lessen speed, rank, fortune.","pos":""}],"LESSENER":[{"def":"One who, or that which, lessens.","pos":""}],"LESSER":[{"def":"Less; smaller; inferior.","pos":""}],"LESSES":[{"def":"The leavings or dung of beasts.","pos":""}],"LESSON":[{"def":"Anything read or recited to a teacher by a pupil or learner; something, as a portion of a book, assigned to a pupil to be studied or learned at one time.","pos":""},{"def":"That which is learned or taught by an express effort; instruction derived from precept, experience, observation, or deduction; a precept; a doctrine; as, to take or give a lesson in drawing.","pos":""}],"LESSOR":[{"def":"One who leases; the person who lets to farm, or gives a lease.","pos":""}],"LEST":[{"def":"Lust; desire; pleasure.","pos":""}],"LESTER":[{"def":"A dry sirocco in the Madeira Islands.","pos":""},{"def":"A noun suffix having a diminutive force; as in streamlet, armlet.","pos":""}]}