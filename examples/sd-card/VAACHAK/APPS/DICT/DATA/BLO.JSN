{"BLOAT":[{"def":"To make turgid, as with water or air; to cause a swelling of the surface of, from effusion of serum in the cellular tissue, producing a morbid enlargement, often accompanied with softness.","pos":""},{"def":"To inflate; to puff up; to make vain.","pos":""}],"BLOATED":[{"def":"Distended beyond the natural or usual size, as by the presence of water, serum, etc.","pos":""}],"BLOATEDNESS":[{"def":"The state of being bloated.","pos":""}],"BLOATER":[{"def":"The common herring, esp.","pos":""}],"BLOB":[{"def":"A small fresh-water fish (Uranidea Richardsoni); the miller's thumb.","pos":""}],"BLOBBER":[{"def":"A bubble; blubber.","pos":""}],"BLOBBER-LIPPED":[{"def":"Having thick lips.","pos":""}],"BLOCAGE":[{"def":"The roughest and cheapest sort of rubblework, in masonry.","pos":""}],"BLOCK":[{"def":"The perch on which a bird of prey is kept.","pos":""},{"def":"A piece of hard wood (as mahogany or cherry) on which a stereotype or electrotype plate is mounted to make it type high.","pos":""}],"BLOCK BOOK":[{"def":"A book printed from engraved wooden blocks instead of movable types.","pos":""}],"BLOCK CHAIN":[{"def":"A chain in which the alternate links are broad blocks connected by thin side links pivoted to the ends of the blocks, used with sprocket wheels to transmit power, as in a bicycle.","pos":""}],"BLOCK SIGNAL":[{"def":"One of the danger signals or safety signals which guide the movement of trains in a block system.","pos":""}],"BLOCKADE":[{"def":"The shutting up of a place by troops or ships, with the purpose of preventing ingress or egress, or the reception of supplies; as, the blockade of the ports of an enemy.","pos":""},{"def":"An obstruction to passage.","pos":""}],"BLOCKADER":[{"def":"A vessel employed in blockading.","pos":""}],"BLOCKAGE":[{"def":"The act of blocking up; the state of being blocked up.","pos":""}],"BLOCKHEAD":[{"def":"A stupid fellow; a dolt; a person deficient in understanding.","pos":""}],"BLOCKHEADISM":[{"def":"That which characterizes a blockhead; stupidity.","pos":""}],"BLOCKHOUSE":[{"def":"A house of squared logs.","pos":""}],"BLOCKING":[{"def":"The act of obstructing, supporting, shaping, or stamping with a block or blocks.","pos":""},{"def":"Blocks used to support (a building, etc.","pos":""}],"BLOCKING COURSE":[{"def":"The finishing course of a wall showing above a cornice.","pos":""}],"BLOCKISH":[{"def":"Like a block; deficient in understanding; stupid; dull.","pos":""}],"BLOCKLIKE":[{"def":"Like a block; stupid.","pos":""}],"BLOEDITE":[{"def":"A hydrous sulphate of magnesium and sodium.","pos":""}],"BLOMARY":[{"def":"Gray; bluish gray.","pos":""}],"BLOND METAL":[{"def":"A variety of clay ironstone, in Staffordshire, England, used for making tools.","pos":""}],"BLONDE":[{"def":"A kind of silk lace originally of the color of raw silk, now sometimes dyed; -- called also blond lace.","pos":""}],"BLONDNESS":[{"def":"The state of being blond.","pos":""}],"BLOOD":[{"def":"Descent from parents of recognized breed; excellence or purity of breed.","pos":""}],"BLOOD MONEY":[{"def":"Money paid to the next of kin of a person who has been killed by another.","pos":""},{"def":"Money obtained as the price, or at the cost, of another's life; -- said of a reward for supporting a capital charge, of money obtained for betraying a fugitive or for committing murder, or of money obtained from the sale of that which will destroy the purchaser.","pos":""}],"BLOOD VESSEL":[{"def":"Any vessel or canal in which blood circulates in an animal, as an artery or vein.","pos":""},{"def":"A fine or amercement paid as a composition for the shedding of blood; also, a riot wherein blood was spilled.","pos":""}],"BLOOD-BOLTERED":[{"def":"Having the hair matted with clotted blood.","pos":""}],"BLOODBIRD":[{"def":"An Australian honeysucker (Myzomela sanguineolata); -- so called from the bright red color of the male bird.","pos":""}],"BLOODED":[{"def":"Having pure blood, or a large admixture or pure blood; of approved breed; of the best stock.","pos":""}],"BLOODFLOWER":[{"def":"A genus of bulbous plants, natives of Southern Africa, named Hæmanthus, of the Amaryllis family.","pos":""}],"BLOODGUILTY":[{"def":"Guilty of murder or bloodshed.","pos":""}],"BLOODHOUND":[{"def":"A breed of large and powerful dogs, with long, smooth, and pendulous ears, and remarkable for acuteness of smell.","pos":""}],"BLOODILY":[{"def":"In a bloody manner; cruelly; with a disposition to shed blood.","pos":""}],"BLOODINESS":[{"def":"The state of being bloody.","pos":""},{"def":"Disposition to shed blood; bloodthirstiness.","pos":""}],"BLOODLESS":[{"def":"Destitute of blood, or apparently so; as, bloodless cheeks; lifeless; dead.","pos":""},{"def":"Not attended with shedding of blood, or slaughter; as, a bloodless victory.","pos":""}],"BLOODLET":[{"def":"bleed; to let blood.","pos":""}],"BLOODLETTER":[{"def":"One who, or that which, lets blood; a phlebotomist.","pos":""}],"BLOODLETTING":[{"def":"The act or process of letting blood or bleeding, as by opening a vein or artery, or by cupping or leeches; -- esp.","pos":""}],"BLOODROOT":[{"def":"A plant (Sanguinaria Canadensis), with a red root and red sap, and bearing a pretty, white flower in early spring; -- called also puccoon, redroot, bloodwort, tetterwort, turmeric, and Indian paint.","pos":""}],"BLOODSHED":[{"def":"The shedding or spilling of blood; slaughter; the act of shedding human blood, or taking life, as in war, riot, or murder.","pos":""}],"BLOODSHEDDER":[{"def":"One who sheds blood; a manslayer; a murderer.","pos":""}],"BLOODSHOT":[{"def":"Red and inflamed; suffused with blood, or having the vessels turgid with blood, as when the conjunctiva is inflamed or irritated.","pos":""}],"BLOODSTICK":[{"def":"A piece of hard wood loaded at one end with lead, and used to strike the fleam into the vein.","pos":""}],"BLOODSTROKE":[{"def":"Loss of sensation and motion from hemorrhage or congestion in the brain.","pos":""}],"BLOODSUCKER":[{"def":"Any animal that sucks blood; esp.","pos":""}],"BLOODTHIRSTY":[{"def":"Eager to shed blood; cruel; sanguinary; murderous.","pos":""}],"BLOODULF":[{"def":"The European bullfinch.","pos":""}],"BLOODWOOD":[{"def":"A tree having the wood or the sap of the color of blood.","pos":""}],"BLOODWORT":[{"def":"A plant, Rumex sanguineus, or bloody-veined dock.","pos":""}],"BLOODY":[{"def":"Containing or resembling blood; of the nature of blood; as, bloody excretions; bloody sweat.","pos":""},{"def":"Smeared or stained with blood; as, bloody hands; a bloody handkerchief.","pos":""}],"BLOODY FLUX":[{"def":"The dysentery, a disease in which the flux or discharge from the bowels has a mixture of blood.","pos":""}],"BLOODY HAND":[{"def":"A red hand, as in the arms of Ulster, which is now the distinguishing mark of a baronet of the United Kingdom.","pos":""}],"BLOODY SWEAT":[{"def":"A sweat accompanied by a discharge of blood; a disease, called sweating sickness, formerly prevalent in England and other countries.","pos":""}],"BLOODY-MINDED":[{"def":"Having a cruel, ferocious disposition; bloodthirsty.","pos":""}],"BLOODYBONES":[{"def":"A terrible bugbear.","pos":""}],"BLOOM":[{"def":"A popular term for a bright-hued variety of some minerals; as, the rose-red cobalt bloom.","pos":""}],"BLOOMER":[{"def":"A costume for women, consisting of a short dress, with loose trousers gathered round ankles, and (commonly) a broad-brimmed hat.","pos":""},{"def":"A woman who wears a Bloomer costume.","pos":""}],"BLOOMERY":[{"def":"A furnace and forge in which wrought iron in the form of blooms is made directly from the ore, or (more rarely) from cast iron.","pos":""}],"BLOOMING":[{"def":"The process of making blooms from the ore or from cast iron.","pos":""}],"BLOOMINGLY":[{"def":"In a blooming manner.","pos":""}],"BLOOMINGNESS":[{"def":"A blooming condition.","pos":""}],"BLOOMLESS":[{"def":"Without bloom or flowers.","pos":""}],"BLOOMY":[{"def":"Full of bloom; flowery; flourishing with the vigor of youth; as, a bloomy spray.","pos":""},{"def":"Covered with bloom, as fruit.","pos":""}],"BLOOTH":[{"def":"Bloom; a blossoming.","pos":""}],"BLORE":[{"def":"The act of blowing; a roaring wind; a blast.","pos":""}],"BLOSSOM":[{"def":"The flower of a plant, or the essential organs of reproduction, with their appendages; florescence; bloom; the flowers of a plant, collectively; as, the blossoms and fruit of a tree; an apple tree in blossom.","pos":""},{"def":"A blooming period or stage of development; something lovely that gives rich promise.","pos":""}],"BLOSSOMLESS":[{"def":"Without blossoms.","pos":""}],"BLOSSOMY":[{"def":"Full of blossoms; flowery.","pos":""}],"BLOT":[{"def":"To spot, stain, or bespatter, as with ink.","pos":""},{"def":"To impair; to damage; to mar; to soil.","pos":""}],"BLOTCH":[{"def":"A large pustule, or a coarse eruption.","pos":""}],"BLOTCHED":[{"def":"Marked or covered with blotches.","pos":""}],"BLOTCHY":[{"def":"Having blotches.","pos":""}],"BLOTE":[{"def":"To cure, as herrings, by salting and smoking them; to bloat.","pos":""}],"BLOTTER":[{"def":"A wastebook, in which entries of transactions are made as they take place.","pos":""}],"BLOTTESQUE":[{"def":"Characterized by blots or heavy touches; coarsely depicted; wanting in delineation.","pos":""}],"BLOTTING PAPER":[{"def":"A kind of thick, bibulous, unsized paper, used to absorb superfluous ink from freshly written manuscript, and thus prevent blots.","pos":""}],"BLOUSE":[{"def":"A light, loose over-garment, like a smock frock, worn especially by workingmen in France; also, a loose coat of any material, as the undress uniform coat of the United States army.","pos":""}],"BLOW":[{"def":"To flower; to blossom; to bloom.","pos":""}],"BLOW VALVE":[{"def":"See Snifting valve.","pos":""}],"BLOW-OFF":[{"def":"as, a blow-off cock or pipe.","pos":""}],"BLOW-OUT":[{"def":"The cleaning of the flues of a boiler from scale, etc.","pos":""}],"BLOWBALL":[{"def":"The downy seed head of a dandelion, which children delight to blow away.","pos":""},{"def":"A prostitute; a courtesan; a strumpet.","pos":""}],"BLOWER":[{"def":"A device for producing a current of air; as: (a) A metal plate temporarily placed before the upper part of a grate or open fire.","pos":""},{"def":"A small fish of the Atlantic coast (Tetrodon turgidus); the puffer.","pos":""}],"BLOWFLY":[{"def":"Any species of fly of the genus Musca that deposits its eggs or young larvæ (called flyblows and maggots) upon meat or other animal products.","pos":""}],"BLOWGUN":[{"def":"A tube, as of cane or reed, sometimes twelve feet long, through which an arrow or other projectile may be impelled by the force of the breath.","pos":""}],"BLOWHOLE":[{"def":"An air hole in a casting.","pos":""}],"BLOWN":[{"def":"Swollen; inflated; distended; puffed up, as cattle when gorged with green food which develops gas.","pos":""},{"def":"Stale; worthless.","pos":""}],"BLOWPIPE":[{"def":"A tube for directing a jet of air into a fire or into the flame of a lamp or candle, so as to concentrate the heat on some object.","pos":""},{"def":"A blowgun; a blowtube.","pos":""}],"BLOWTH":[{"def":"A blossoming; a bloom.","pos":""}],"BLOWTUBE":[{"def":"A long wrought iron tube, on the end of which the workman gathers a quantity of \"metal\" (melted glass), and through which he blows to expand or shape it; -- called also blowing tube, and blowpipe.","pos":""}],"BLOWY":[{"def":"Windy; as, blowy weather; a blowy upland.","pos":""}],"BLOWZE":[{"def":"A ruddy, fat-faced woman; a wench.","pos":""}],"BLOWZED":[{"def":"Having high color from exposure to the weather; ruddy-faced; blowzy; disordered.","pos":""}],"BLOWZY":[{"def":"Coarse and ruddy-faced; fat and ruddy; high colored; frowzy.","pos":""}]}