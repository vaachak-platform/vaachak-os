{"MARL":[{"def":"To cover, as part of a rope, with marline, marking a pecular hitch at each turn to prevent unwinding.","pos":""}],"MARLACEOUS":[{"def":"Resembling marl; partaking of the qualities of marl.","pos":""}],"MARLIN":[{"def":"The American great marbled godwit (Limosa fedoa).","pos":""}],"MARLINE":[{"def":"A small line composed of two strands a little twisted, used for winding around ropes and cables, to prevent their being weakened by fretting.","pos":""}],"MARLITE":[{"def":"A variety of marl.","pos":""}],"MARLITIC":[{"def":"Partaking of the qualites of marlite.","pos":""}],"MARLPIT":[{"def":"Apit where marl is dug.","pos":""}],"MARLSTONE":[{"def":"A sandy calcareous straum, containing, or impregnated with, iron, and lying between the upper and lower Lias of England.","pos":""}],"MARLY":[{"def":"Consisting or partaking of marl; resembling marl; abounding with marl.","pos":""}]}