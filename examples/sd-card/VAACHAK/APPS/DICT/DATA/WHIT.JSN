{"WHIT":[{"def":"The smallest part or particle imaginable; a bit; a jot; an iota; -- generally used in an adverbial phrase in a negative sentence.","pos":""}],"WHITE":[{"def":"Reflecting to the eye all the rays of the spectrum combined; not tinted with any of the proper colors or their mixtures; having the color of pure snow; snowy; -- the opposite of Ant: black or dark; as, white paper; a white skin.","pos":""},{"def":"Destitute of color, as in the cheeks, or of the tinge of blood color; pale; pallid; as, white with fear.","pos":""}],"WHITE ELEPHANT":[{"def":"Something requiring much care and expense and yielding little profit; any burdensome possession.","pos":""}],"WHITE FLY":[{"def":"Any one of numerous small injurious hemipterous insects of the genus Aleyrodes, allied to scale insects.","pos":""}],"WHITE FRIAR":[{"def":"A mendicant monk of the Carmelite order, so called from the white cloaks worn by the order.","pos":""}],"WHITE HORSE":[{"def":"A large mass of tough sinewy substance in the head of sperm whales, just above the upper jaw and extending in streaks into the junk above it.","pos":""}],"WHITE MUSTARD":[{"def":"A kind of mustard (Sinapis alba) with rough-hairy foliage, a long-beaked hispid pod, and pale seeds, which yield mustard and mustard oil.","pos":""}],"WHITE PERSON":[{"def":"A person of the Caucasian race (6 Fed.","pos":""}],"WHITE PLAGUE":[{"def":"Tuberculosis, esp.","pos":""}],"WHITE SLAVE":[{"def":"A woman held in involuntary confinement for purposes of prostitution; loosely, any woman forced into unwilling prostitution.","pos":""}],"WHITE SLAVER":[{"def":"A person engaged in procuring or holding a woman or women for unwilling prostitution.","pos":""}],"WHITE SLAVING":[{"def":"The action of one who procures or holds a woman or women for unwilling prostitution.","pos":""}],"WHITE-EYE":[{"def":"Any one of several species of small Old World singing of the genus Zosterops, as Zosterops palpebrosus of India, and Z.","pos":""}],"WHITE-FACE":[{"def":"A white mark in the forehead of a horse, descending almost to the nose; -- called also white-blaze.","pos":""}],"WHITE-FOOT":[{"def":"A white mark on the foot of a horse, between the fetlock and the coffin.","pos":""}],"WHITE-FRONTED":[{"def":"Having a white front; as, the white-fronted lemur.","pos":""}],"WHITE-HEART":[{"def":"A somewhat heart-shaped cherry with a whitish skin.","pos":""}],"WHITE-HOT":[{"def":"White with heat; heated to whiteness, or incandescence.","pos":""}],"WHITE-LIMED":[{"def":"Whitewashed or plastered with lime.","pos":""}],"WHITE-LIVERED":[{"def":"Having a pale look; feeble; hence, cowardly; pusillanimous; dastardly.","pos":""}],"WHITE-POT":[{"def":"A kind of food made of milk or cream, eggs, sugar, bread, etc.","pos":""}],"WHITE-WATER":[{"def":"A dangerous disease of sheep.","pos":""}],"WHITEBEAM":[{"def":"The common beam tree of England (Pyrus Aria); -- so called from the white, woolly under surface of the leaves.","pos":""}],"WHITEBEARD":[{"def":"An old man; a graybeard.","pos":""}],"WHITEBILL":[{"def":"The American coot.","pos":""}],"WHITEBLOW":[{"def":"Same as Whitlow grass, under Whitlow.","pos":""}],"WHITEBOY":[{"def":"One of an association of poor Roman catholics which arose in Ireland about 1760, ostensibly to resist the collection of tithes, the members of which were so called from the white shirts they wore in their nocturnal raids.","pos":""}],"WHITEBOYISM":[{"def":"The conduct or principle of the Whiteboys.","pos":""}],"WHITECAP":[{"def":"A wave whose crest breaks into white foam, as when the wind is freshening.","pos":""}],"WHITECOAT":[{"def":"The skin of a newborn seal; also, the seal itself.","pos":""}],"WHITEFISH":[{"def":"Lakes, and in other lakes farther north.","pos":""}],"WHITEHEAD":[{"def":"A form of self-propelling torpedo.","pos":""}],"WHITELY":[{"def":"Like, or coming near to, white.","pos":""}],"WHITEN":[{"def":"To grow white; to turn or become white or whiter; as, the hair whitens with age; the sea whitens with foam; the trees in spring whiten with blossoms.","pos":""}],"WHITENER":[{"def":"One who, or that which, whitens; a bleacher; a blancher; a whitewasher.","pos":""}],"WHITENESS":[{"def":"A flock of swans.","pos":""}],"WHITENING":[{"def":"The act or process of making or becoming white.","pos":""},{"def":"That which is used to render white; whiting.","pos":""}],"WHITERUMP":[{"def":"The American black-tailed godwit.","pos":""}],"WHITES":[{"def":"The finest flour made from white wheat.","pos":""},{"def":"Cloth or garments of a plain white color.","pos":""}],"WHITESMITH":[{"def":"One who works in tinned or galvanized iron, or white iron; a tinsmith.","pos":""},{"def":"A worker in iron who finishes or polishes the work, in distinction from one who forges it.","pos":""}],"WHITESTER":[{"def":"A bleacher of lines; a whitener; a whitster.","pos":""}],"WHITETAIL":[{"def":"The Virginia deer.","pos":""}],"WHITETHROAT":[{"def":"Any one of several species of Old World warblers, esp.","pos":""}],"WHITEWALL":[{"def":"The spotted flycatcher; -- so called from the white color of the under parts.","pos":""}],"WHITEWASH":[{"def":"Any wash or liquid composition for whitening something, as a wash for making the skin fair.","pos":""},{"def":"A composition of line and water, or of whiting size, and water, or the like, used for whitening walls, ceilings, etc.","pos":""}],"WHITEWASHER":[{"def":"One who whitewashes.","pos":""}],"WHITEWEED":[{"def":"A perennial composite herb (Chrysanthemum Leucanthemum) with conspicuous white rays and a yellow disk, a common weed in grass lands and pastures; -- called also oxeye daisy.","pos":""}],"WHITEWOOD":[{"def":"The soft and easily-worked wood of the tulip tree (Liriodendron).","pos":""}],"WHITHER":[{"def":"To what place; -- used interrogatively; as, whither goest thou \"Whider may I flee\" Chaucer.","pos":""},{"def":"To what or which place; -- used relatively.","pos":""}],"WHITHERSOEVER":[{"def":"To whatever place; to what place soever; wheresoever; as, I will go whithersoever you lead.","pos":""}],"WHITHERWARD":[{"def":"In what direction; toward what or which place.","pos":""}],"WHITING":[{"def":"Chalk prepared in an impalpable powder by pulverizing and repeated washing, used as a pigment, as an ingredient in putty, for cleaning silver, etc.","pos":""}],"WHITING-MOP":[{"def":"A young whiting.","pos":""}],"WHITISH":[{"def":"Covered with an opaque white powder.","pos":""}],"WHITISHNESS":[{"def":"The quality or state of being whitish or somewhat white.","pos":""}],"WHITLEATHER":[{"def":"Leather dressed or tawed with alum, salt, etc.","pos":""}],"WHITLING":[{"def":"A young full trout during its second season.","pos":""}],"WHITLOW":[{"def":"An inflammation of the fingers or toes, generally of the last phalanx, terminating usually in suppuration.","pos":""},{"def":"An inflammatory disease of the feet.","pos":""}],"WHITLOW-WORT":[{"def":"Same as Whitlow grass, under Whitlow.","pos":""}],"WHITMONDAY":[{"def":"The day following Whitsunday; -- called also Whitsun Monday.","pos":""}],"WHITNEYITE":[{"def":"an arsenide of copper from Lake Superior.","pos":""}],"WHITSOUR":[{"def":"A sort of apple.","pos":""}],"WHITSTER":[{"def":"A whitener; a bleacher; a whitester.","pos":""}],"WHITSUN":[{"def":"Of, pertaining to, or observed at, Whitsuntide; as, Whitsun week; Whitsun Tuesday; Whitsun pastorals.","pos":""}],"WHITSUNDAY":[{"def":"See the Note under Term, n.","pos":""}],"WHITSUNTIDE":[{"def":"The week commencing with Whitsunday, esp.","pos":""}],"WHITTEN TREE":[{"def":"Either of two shrubs (Viburnum Lantana, and V.","pos":""}],"WHITTLE":[{"def":"Thwaite a piece of ground.","pos":""}],"WHITTLINGS":[{"def":"Chips made by one who whittles; shavings cut from a stick with a knife.","pos":""}],"WHITTUESDAY":[{"def":"The day following Whitmonday; -- called also Whitsun Tuesday.","pos":""}],"WHITWALL":[{"def":"Same as Whetile.","pos":""}],"WHITWORTH BALL":[{"def":"A prejectile used in the Whitworth gun.","pos":""}],"WHITWORTH GUN":[{"def":"A form of rifled cannon and small arms invented by Sir Joseph Whitworth, of Manchester, England.","pos":""}],"WHITY-BROWN":[{"def":"Of a color between white and brown.","pos":""}]}