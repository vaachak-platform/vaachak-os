{"BOY":[{"def":"A male child, from birth to the age of puberty; a lad; hence, a son.","pos":""}],"BOYAU":[{"def":"A winding or zigzag trench forming a path or communication from one siegework to another, to a magazine, etc.","pos":""}],"BOYCOTT":[{"def":"To combine against (a landlord, tradesman, employer, or other person), to withhold social or business relations from him, and to deter others from holding such relations; to subject to a boycott.","pos":""}],"BOYCOTTER":[{"def":"A participant in boycotting.","pos":""}],"BOYCOTTISM":[{"def":"Methods of boycotters.","pos":""}],"BOYDEKIN":[{"def":"A dagger; a bodkin.","pos":""}],"BOYER":[{"def":"A Flemish sloop with a castle at each end.","pos":""}],"BOYHOOD":[{"def":"The state of being a boy; the time during which one is a boy.","pos":""}],"BOYISH":[{"def":"Resembling a boy in a manners or opinions; belonging to a boy; childish; trifling; puerile.","pos":""}],"BOYISHLY":[{"def":"In a boyish manner; like a boy.","pos":""}],"BOYISHNESS":[{"def":"The manners or behavior of a boy.","pos":""}],"BOYISM":[{"def":"The nature of a boy; childishness.","pos":""}]}