{"PROX":[{"def":"\"The ticket or list of candidates at elections, presented to the people for their votes.","pos":""}],"PROXENE":[{"def":"An officer who had the charge of showing hospitality to those who came from a friendly city or state.","pos":""}],"PROXENET":[{"def":"A negotiator; a factor.","pos":""}],"PROXENETISM":[{"def":"The action of a go-between or broker in negotiating immoral bargains between the sexes; procuring.","pos":""}],"PROXIMAD":[{"def":"Toward a proximal part; on the proximal side of; proximally.","pos":""}],"PROXIMAL":[{"def":"Toward or nearest, as to a body, or center of motion of dependence; proximate.","pos":""}],"PROXIMALLY":[{"def":"On or toward a proximal part; proximad.","pos":""}],"PROXIMATE":[{"def":"Nearest; next immediately preceding or following.","pos":""}],"PROXIMATELY":[{"def":"In a proximate manner, position, or degree; immediately.","pos":""}],"PROXIME":[{"def":"Next; immediately preceding or following.","pos":""}],"PROXIMITY":[{"def":"The quality or state of being next in time, place, causation, influence, etc.","pos":""}],"PROXIMO":[{"def":"In the next month after the present; -- often contracted to prox.","pos":""}],"PROXY":[{"def":"The written appointment of a proctor in suits in the ecclesiastical courts.","pos":""},{"def":"See Procuration.","pos":""}],"PROXYSHIP":[{"def":"The office or agency of a proxy.","pos":""}]}