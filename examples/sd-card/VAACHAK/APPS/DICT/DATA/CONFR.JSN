{"CONFRACT":[{"def":"Broken in pieces; severed.","pos":""}],"CONFRATERNITY":[{"def":"A society or body of men united for some purpose, or in some profession; a brotherhood.","pos":""}],"CONFRERE":[{"def":"Fellow member of a fraternity; intimate associate.","pos":""}],"CONFRICATION":[{"def":"A rubbing together; friction.","pos":""}],"CONFRONT":[{"def":"To stand facing or in front of; to face; esp.","pos":""},{"def":"To put face to face; to cause to face or to meet; as, to confront one with the proofs of his wrong doing.","pos":""}],"CONFRONTATION":[{"def":"Act of confronting.","pos":""}],"CONFRONTE":[{"def":"Same as Affronté.","pos":""}],"CONFRONTER":[{"def":"One who confronts.","pos":""}],"CONFRONTING":[{"def":"dealing with (a person or problem) directly; taking the bull by the horns.","pos":""}],"CONFRONTMENT":[{"def":"The act of confronting; the state of being face to face.","pos":""}]}