{"EUSEBIAN":[{"def":"A follower of Eusebius, bishop of Cæsarea, who was a friend and protector of Arius.","pos":""}],"EUSTACHIAN":[{"def":"Eustachian catheter, a tubular instrument to be introduced into the Eustachian tube so as to allow of inflation of the middle ear through the nose or mouth.","pos":""}],"EUSTYLE":[{"def":"See Intercolumnlation.","pos":""}]}