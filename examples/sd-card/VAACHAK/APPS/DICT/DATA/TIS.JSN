{"TISAR":[{"def":"The fireplace at the side of an annealing oven.","pos":""},{"def":"Consumptive, phthisical.","pos":""}],"TISIC":[{"def":"Consumption; phthisis.","pos":""}],"TISICKY":[{"def":"Consumptive, phthisical.","pos":""}],"TISRI":[{"def":"The seventh month of the Jewish ecclesiastical year, answering to a part of September with a part of October.","pos":""}],"TISSUE":[{"def":"One of the elementary materials or fibres, having a uniform structure and a specialized function, of which ordinary animals and plants are composed; a texture; as, epithelial tissue; connective tissue.","pos":""}],"TISSUED":[{"def":"Clothed in, or adorned with, tissue; also, variegated; as, tissued flowers.","pos":""}]}