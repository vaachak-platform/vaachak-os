{"EXICCATION":[{"def":"See Exsiccation.","pos":""}],"EXIGENCY":[{"def":"The state of being exigent; urgent or exacting want; pressing necessity or distress; need; a case demanding immediate action, supply, or remedy; as, an unforeseen exigency.","pos":""}],"EXIGENT":[{"def":"Exacting or requiring immediate aid or action; pressing; critical.","pos":""}],"EXIGENTER":[{"def":"An officer in the Court of King's Bench and Common Pleas whose duty it was make out exigents.","pos":""}],"EXIGIBLE":[{"def":"That may be exacted; repairable.","pos":""}],"EXIGUITY":[{"def":"Scantiness; smallness; thinness.","pos":""}],"EXIGUOUS":[{"def":"Scanty; small; slender; diminutive.","pos":""}],"EXILE":[{"def":"Forced separation from one's native country; expulsion from one's home by the civil authority; banishment; sometimes, voluntary separation from one's native country.","pos":""},{"def":"The person expelled from his country by authority; also, one who separates himself from his home.","pos":""}],"EXILIC":[{"def":"Pertaining to exile or banishment, esp.","pos":""}],"EXILITION":[{"def":"A sudden springing or leaping out.","pos":""}],"EXILITY":[{"def":"Smallness; meagerness; slenderness; fineness, thinness.","pos":""}],"EXIMIOUS":[{"def":"Select; choice; hence, extraordinary, excellent.","pos":""}],"EXINANITE":[{"def":"To make empty; to render of no effect; to humble.","pos":""}],"EXINANITION":[{"def":"Ex*in`a*ni\"tion Defn: n.","pos":""}],"EXIST":[{"def":"To be as a fact and not as a mode; to have an actual or real being, whether material or spiritual.","pos":""},{"def":"To be manifest in any manner; to continue to be; as, great evils existed in his reign.","pos":""}],"EXISTENCE":[{"def":"The state of existing or being; actual possession of being; continuance in being; as, the existence of body and of soul in union; the separate existence of the soul; immortal existence.","pos":""},{"def":"Continued or repeated manifestation; occurrence, as of events of any kind; as, the existence of a calamity or of a state of war.","pos":""}],"EXISTENT":[{"def":"Having being or existence; existing; being; occurring now; taking place.","pos":""}],"EXISTENTIAL":[{"def":"Having existence.","pos":""}],"EXISTIBLE":[{"def":"Capable of existence.","pos":""}],"EXISTIMATION":[{"def":"Esteem; opinion; reputation.","pos":""}],"EXIT":[{"def":"He (or she ) goes out, or retires from view; as, exit Macbeth.","pos":""}]}