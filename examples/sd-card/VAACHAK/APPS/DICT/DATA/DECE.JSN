{"DECEASE":[{"def":"Departure, especially departure from this life; death.","pos":""}],"DECEASED":[{"def":"Passed away; dead; gone.","pos":""}],"DECEDENT":[{"def":"Removing; departing.","pos":""}],"DECEIT":[{"def":"Any trick, collusion, contrivance, false representation, or underhand practice, used to defraud another.","pos":""}],"DECEITFUL":[{"def":"Full of, or characterized by, deceit; serving to mislead or insnare; trickish; fraudulent; cheating; insincere.","pos":""}],"DECEITFULLY":[{"def":"With intent to deceive.","pos":""}],"DECEITFULNESS":[{"def":"The disposition to deceive; as, a man's deceitfulness may be habitual.","pos":""},{"def":"The quality of being deceitful; as, the deceitfulness of a man's practices.","pos":""}],"DECEITLESS":[{"def":"Free from deceit.","pos":""}],"DECEIVABLE":[{"def":"Fitted to deceive; deceitful.","pos":""},{"def":"Subject to deceit; capable of being misled.","pos":""}],"DECEIVABLENESS":[{"def":"Capability of deceiving.","pos":""},{"def":"Liability to be deceived or misled; as, the deceivableness of a child.","pos":""}],"DECEIVABLY":[{"def":"In a deceivable manner.","pos":""}],"DECEIVE":[{"def":"To lead into error; to cause to believe what is false, or disbelieve what is true; to impose upon; to mislead; to cheat; to disappoint; to delude; to insnare.","pos":""},{"def":"To beguile; to amuse, so as to divert the attention; to while away; to take away as if by deception.","pos":""}],"DECEIVER":[{"def":"One who deceives; one who leads into error; a cheat; an impostor.","pos":""}],"DECEMBER":[{"def":"The twelfth and last month of the year, containing thirty-one days.","pos":""}],"DECEMBRIST":[{"def":"One of those who conspired for constitutional government against the Emperor Nicholas on his accession to the throne at the death of Alexander I.","pos":""}],"DECEMDENTATE":[{"def":"Having ten points or teeth.","pos":""}],"DECEMFID":[{"def":"Cleft into ten parts.","pos":""}],"DECEMLOCULAR":[{"def":"Having ten cells for seeds.","pos":""}],"DECEMPEDAL":[{"def":"Having ten feet; decapodal.","pos":""}],"DECEMVIR":[{"def":"One of a body of ten magistrates in ancient Rome.","pos":""},{"def":"A member of any body of ten men in authority.","pos":""}],"DECEMVIRAL":[{"def":"Pertaining to the decemvirs in Rome.","pos":""}],"DECEMVIRATE":[{"def":"The office or term of office of the decemvirs in Rome.","pos":""},{"def":"A body of ten men in authority.","pos":""}],"DECEMVIRSHIP":[{"def":"The office of a decemvir.","pos":""}],"DECENCY":[{"def":"The quality or state of being decent, suitable, or becoming, in words or behavior; propriety of form in social intercourse, in actions, or in discourse; proper formality; becoming ceremony; seemliness; hence, freedom from obscenity or indecorum; modesty.","pos":""},{"def":"That which is proper or becoming.","pos":""}],"DECENE":[{"def":"One of the higher hydrocarbons, C10H20, of the ethylene series.","pos":""}],"DECENNARY":[{"def":"A tithing consisting of ten neighboring families.","pos":""}],"DECENNIAL":[{"def":"Consisting of ten years; happening every ten years; as, a decennial period; decennial games.","pos":""}],"DECENNIUM":[{"def":"A period of ten years.","pos":""},{"def":"Pertaining to the number nineteen; of nineteen years.","pos":""}],"DECENT":[{"def":"Suitable in words, behavior, dress, or ceremony; becoming; fit; decorous; proper; seemly; as, decent conduct; decent language.","pos":""},{"def":"Free from immodesty or obscenity; modest.","pos":""}],"DECENTRALIZATION":[{"def":"The action of decentralizing, or the state of being decentralized.","pos":""}],"DECENTRALIZE":[{"def":"To prevent from centralizing; to cause to withdraw from the center or place of concentration; to divide and distribute (what has been united or concentrated); -- esp.","pos":""}],"DECEPTIBLE":[{"def":"Capable of being deceived; deceivable.","pos":""}],"DECEPTION":[{"def":"The act of deceiving or misleading.","pos":""},{"def":"The state of being deceived or misled.","pos":""}],"DECEPTIOUS":[{"def":"Tending deceive; delusive.","pos":""}],"DECEPTIVE":[{"def":"Tending to deceive; having power to mislead, or impress with false opinions; as, a deceptive countenance or appearance.","pos":""}],"DECEPTIVELY":[{"def":"In a manner to deceive.","pos":""}],"DECEPTIVENESS":[{"def":"The power or habit of deceiving; tendency or aptness to deceive.","pos":""}],"DECEPTIVITY":[{"def":"Deceptiveness; a deception; a sham.","pos":""}],"DECERN":[{"def":"To decree; to adjudge.","pos":""}],"DECERNITURE":[{"def":"A decree or sentence of a court.","pos":""}],"DECERP":[{"def":"To pluck off; to crop; to gather.","pos":""}],"DECERPT":[{"def":"Plucked off or away.","pos":""}],"DECERPTIBLE":[{"def":"That may be plucked off, cropped, or torn away.","pos":""}],"DECERPTION":[{"def":"The act of plucking off; a cropping.","pos":""},{"def":"That which is plucked off or rent away; a fragment; a piece.","pos":""}],"DECERTATION":[{"def":"Contest for mastery; contention; strife.","pos":""}],"DECESSION":[{"def":"Departure; decrease; -- opposed to accesion.","pos":""}]}