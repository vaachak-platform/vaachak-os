{"ANXIETUDE":[{"def":"The state of being anxious; anxiety.","pos":""}],"ANXIETY":[{"def":"A state of restlessness and agitation, often with general indisposition and a distressing sense of oppression at the epigastrium.","pos":""}],"ANXIOUS":[{"def":"Full of anxiety or disquietude; greatly concerned or solicitous, esp.","pos":""},{"def":"Accompanied with, or causing, anxiety; worrying; -- applied to things; as, anxious labor.","pos":""}],"ANXIOUSLY":[{"def":"In an anxious manner; with painful uncertainty; solicitously.","pos":""}],"ANXIOUSNESS":[{"def":"The quality of being anxious; great solicitude; anxiety.","pos":""}]}