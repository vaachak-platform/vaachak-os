{"MASCLE":[{"def":"A lozenge voided.","pos":""}],"MASCLED":[{"def":"Composed of, or covered with, lozenge-shaped scales; having lozenge-shaped divisions.","pos":""},{"def":"A person who is supposed to bring good luck to the household to which he or she belongs; anything that brings good luck.","pos":""}],"MASCULINE":[{"def":"Having the inflections of, or construed with, words pertaining especially to male beings, as distinguished from feminine and neuter.","pos":""}],"MASCULINITY":[{"def":"The state or quality of being masculine; masculineness.","pos":""}],"MASH":[{"def":"A mass of mixed ingredients reduced to a soft pulpy state by beating or pressure; a mass of anything in a soft pulpy state.","pos":""},{"def":"A mixture of meal or bran and water fed to animals.","pos":""}],"MASHER":[{"def":"A golf club like the iron, but with a shorter head, slightly more lofted, used chiefly for short approaches.","pos":""}],"MASHY":[{"def":"Produced by crushing or bruising; resembling, or consisting of, a mash.","pos":""}],"MASK":[{"def":"A grotesque head or face, used to adorn keystones and other prominent parts, to spout water in fountains, and the like; -- called also mascaron.","pos":""},{"def":"The lower lip of the larva of a dragon fly, modified so as to form a prehensile organ.","pos":""}],"MASK SHELL":[{"def":"Any spiral marine shell of the genus Persona, having a curiously twisted aperture.","pos":""}],"MASKED":[{"def":"Same as Personate.","pos":""},{"def":"Having the anterior part of the head differing decidedly in color from the rest of the plumage; -- said of birds.","pos":""}],"MASKER":[{"def":"One who wears a mask; one who appears in disguise at a masquerade.","pos":""}],"MASKERY":[{"def":"The dress or disguise of a maske [Obs.","pos":""}],"MASKINONGE":[{"def":"The muskellunge.","pos":""}],"MASLACH":[{"def":"An excitant containing opium, much used by the Turks.","pos":""}],"MASLIN":[{"def":"A mixture composed of different materials; especially: (a) A mixture of metals resembling brass.","pos":""},{"def":"A vessel made of maslin, 1 (a).","pos":""}],"MASON":[{"def":"One whose occupation is to build with stone or brick; also, one who prepares stone for building purposes.","pos":""},{"def":"A member of the fraternity of Freemasons.","pos":""}],"MASONIC":[{"def":"Of or pertaining to Freemasons or to their craft or mysteries.","pos":""}],"MASONRY":[{"def":"The art or occupation of a mason.","pos":""},{"def":"The work or performance of a mason; as, good or bad masonry; skillful masonry.","pos":""}],"MASOOLA BOAT":[{"def":"Ma*soo\"la boat` Defn: .","pos":""}],"MASORA":[{"def":"A Jewish critical work on the text of the Hebrew Scriptures, composed by several learned rabbis of the school of Tiberias, in the eighth and ninth centuries.","pos":""}],"MASORET":[{"def":"Of or relating to the Masora, or to its authors.","pos":""}],"MASORITE":[{"def":"One of the writers of the Masora.","pos":""}],"MASQUE":[{"def":"A mask; a masquerade.","pos":""}],"MASQUERADE":[{"def":"An assembly of persons wearing masks, and amusing themselves with dancing, conversation, or other diversions.","pos":""},{"def":"A dramatic performance by actors in masks; a mask.","pos":""}],"MASQUERADER":[{"def":"One who masquerades; a person wearing a mask; one disguised.","pos":""}],"MASS":[{"def":"The sacrifice in the sacrament of the Eucharist, or the consecration and oblation of the host.","pos":""},{"def":"The portions of the Mass usually set to music, considered as a musical composition; -- namely, the Kyrie, the Gloria, the Credo, the Sanctus, and the Agnus Dei, besides sometimes an Offertory and the Benedictus.","pos":""}],"MASSACRE":[{"def":"The killing of a considerable number of human beings under circumstances of atrocity or cruelty, or contrary to the usages of civilized people; as, the massacre on St.","pos":""}],"MASSACRER":[{"def":"One who massacres.","pos":""}],"MASSAGE":[{"def":"A rubbing or kneading of the body, especially when performed as a hygienic or remedial measure.","pos":""}],"MASSAGIST":[{"def":"One who practices massage; a masseur or masseuse.","pos":""}],"MASSASAUGA":[{"def":"The black rattlesnake (Crotalus, or Caudisona, tergemina), found in the Mississippi Valley.","pos":""},{"def":"A stroke made with the cue held vertically.","pos":""}],"MASSER":[{"def":"A priest who celebrates Mass.","pos":""}],"MASSETER":[{"def":"The large muscle which raises the under jaw, and assists in mastication.","pos":""}],"MASSETERIC":[{"def":"Of or pertaining to the masseter.","pos":""}],"MASSETERINE":[{"def":"One who performs massage.","pos":""}],"MASSICOT":[{"def":"Lead protoxide, PbO, obtained as a yellow amorphous powder, the fused and crystalline form of which is called litharge; lead ocher.","pos":""}],"MASSINESS":[{"def":"The state or quality of being massy; ponderousness.","pos":""}],"MASSIVE":[{"def":"In mass; not necessarily without a crystalline structure, but having no regular form; as, a mineral occurs massive.","pos":""}],"MASSIVELY":[{"def":"In a heavy mass.","pos":""}],"MASSIVENESS":[{"def":"The state or quality of being massive; massiness.","pos":""}],"MASSOOLA BOAT":[{"def":"See Masoola boat.","pos":""}],"MASSORET":[{"def":"Same as Masorite.","pos":""}],"MASSY":[{"def":"Compacted into, or consisting of, a mass; having bulk and weight ot substance; ponderous; bulky and heavy; weight; heavy; as, a massy shield; a massy rock.","pos":""}],"MAST":[{"def":"The fruit of the oak and beech, or other forest trees; nuts; acorns.","pos":""}],"MASTAX":[{"def":"The two central ones form the incus, against which the mallei, or lateral ones, work so as to crush the food.","pos":""}],"MASTED":[{"def":"Furnished with a mast or masts; -- chiefly in composition; as, a three-masted schooner.","pos":""}],"MASTER":[{"def":"A vessel having (so many) masts; -- used only in compounds; as, a two-master.","pos":""}],"MASTER VIBRATOR":[{"def":"In an internal-combustion engine with two or more cylinders, an induction coil and vibrator placed in the circuit between the battery or magneto and the coils for the different cylinders, which are used without vibrators of their own.","pos":""}],"MASTERDOM":[{"def":"Dominion; rule; command.","pos":""}],"MASTERFUL":[{"def":"Inclined to play the master; domineering; imperious; arbitrary.","pos":""},{"def":"Having the skill or power of a master; indicating or expressing power or mastery.","pos":""}],"MASTERFULLY":[{"def":"In a masterful manner; imperiously.","pos":""}],"MASTERHOOD":[{"def":"The state of being a master; hence, disposition to command or hector.","pos":""}],"MASTERLESS":[{"def":"Destitute of a master or owner; ungoverned or ungovernable.","pos":""}],"MASTERLINESS":[{"def":"The quality or state of being masterly; ability to control wisely or skillfully.","pos":""}],"MASTERLY":[{"def":"Suitable to, or characteristic of, a master; indicating thorough knowledge or superior skill and power; showing a master's hand; as, a masterly design; a masterly performance; a masterly policy.","pos":""},{"def":"Imperious; domineering; arbitrary.","pos":""}],"MASTERPIECE":[{"def":"Anything done or made with extraordinary skill; a capital performance; a chef-d'oeuvre; a supreme achievement.","pos":""}],"MASTERSHIP":[{"def":"The state or office of a master.","pos":""},{"def":"Mastery; dominion; superior skill; superiority.","pos":""}],"MASTERSINGER":[{"def":"One of a class of poets which flourished in Nuremberg and some other cities of Germany in the 15th and 16th centuries.","pos":""}],"MASTERWORT":[{"def":"Ostruthium, formerly Imperatoria).","pos":""}],"MASTERY":[{"def":"The position or authority of a master; dominion; command; supremacy; superiority.","pos":""},{"def":"Superiority in war or competition; victory; triumph; preëminence.","pos":""}],"MASTFUL":[{"def":"Abounding in mast; producing mast in abundance; as, the mastful forest; a mastful chestnut.","pos":""}],"MASTHEAD":[{"def":"The top or head of a mast; the part of a mast above the hounds.","pos":""}],"MASTHOUSE":[{"def":"A building in which vessels' masts are shaped, fitted, etc.","pos":""}],"MASTIC":[{"def":"A low shrubby tree of the genus Pistacia (P.","pos":""}],"MASTICABLE":[{"def":"Capable of being masticated.","pos":""}],"MASTICADOR":[{"def":"A part of a bridle, the slavering bit.","pos":""}],"MASTICATE":[{"def":"To grind or crush with, or as with, the teeth and prepare for swallowing and digestion; to chew; as, to masticate food.","pos":""}],"MASTICATER":[{"def":"One who masticates.","pos":""}],"MASTICATION":[{"def":"The act or operation of masticating; chewing, as of food.","pos":""}],"MASTICATOR":[{"def":"One who masticates.","pos":""},{"def":"A machine for cutting meat into fine pieces for toothless people; also, a machine for cutting leather, India rubber, or similar tough substances, into fine pieces, in some processes of manufacture.","pos":""}],"MASTICATORY":[{"def":"A substance to be chewed to increase the saliva.","pos":""}],"MASTICIN":[{"def":"A white, amorphous, tenacious substance resembling caoutchouc, and obtained as an insoluble residue of mastic.","pos":""}],"MASTIFF":[{"def":"A breed of large dogs noted for strength and courage.","pos":""}],"MASTIGOPOD":[{"def":"One of the Mastigopoda.","pos":""}],"MASTIGURE":[{"def":"Any one of several large spiny-tailed lizards of the genus Uromastix.","pos":""}],"MASTING":[{"def":"The act or process of putting a mast or masts into a vessel; also, the scientific principles which determine the position of masts, and the mechanical methods of placing them.","pos":""}],"MASTITIS":[{"def":"Inflammation of the breast.","pos":""}],"MASTLESS":[{"def":"Bearing no mast; as, a mastless oak or beech.","pos":""}],"MASTODON":[{"def":"An extinct genus of mammals closely allied to the elephant, but having less complex molar teeth, and often a pair of lower, as well as upper, tusks, which are incisor teeth.","pos":""}],"MASTODONSAURUS":[{"def":"A large extinct genus of labyrinthodonts, found in the European Triassic rocks.","pos":""}],"MASTODONTIC":[{"def":"Pertaining to, or resembling, a mastodon; as, mastodontic dimensions.","pos":""},{"def":"Pain occuring in the mamma or female breast, -- a form of neuralgia.","pos":""}],"MASTOIDAL":[{"def":"Same as Mastoid.","pos":""}],"MASTOIDITIS":[{"def":"Inflammation in the mastoid process of the temporal bone.","pos":""}],"MASTOLOGY":[{"def":"The natural history of Mammalia.","pos":""}],"MASTURBATION":[{"def":"Onanism; self-pollution.","pos":""}],"MASTY":[{"def":"Full of mast; abounding in acorns, etc.","pos":""}],"MASULA BOAT":[{"def":"Same as Masoola boat.","pos":""}]}