{"UMBECAST":[{"def":"To cast about; to consider; to ponder.","pos":""}],"UMBEL":[{"def":"A kind of flower cluster in which the flower stalks radiate from a common point, as in the carrot and milkweed.","pos":""}],"UMBELLAR":[{"def":"Of or pertaining to an umbel; having the form of an umbel.","pos":""},{"def":"Bearing umbels; pertaining to an umbel; umbel-like; as, umbellate plants or flowers.","pos":""}],"UMBELLET":[{"def":"A small or partial umbel; an umbellule.","pos":""}],"UMBELLIC":[{"def":"Pertaining to, or obtained from, certain umbelliferous plants; as, umbellic acid.","pos":""}],"UMBELLIFER":[{"def":"A plant producing an umbel or umbels.","pos":""}],"UMBELLIFERONE":[{"def":"A tasteless white crystalline substance, C9H6O3, found in the bark of a certain plant (Daphne Mezereum), and also obtained by the distillation of certain gums from the Umbelliferæ, as galbanum, asafetida, etc.","pos":""}],"UMBELLULARIA":[{"def":"A genus of deep-sea alcyonaria consisting of a cluster of large flowerlike polyps situated at the summit of a long, slender stem which stands upright in the mud, supported by a bulbous base.","pos":""}],"UMBER":[{"def":"A brown or reddish pigment used in both oil and water colors, obtained from certain natural clays variously colored by the oxides of iron and manganese.","pos":""},{"def":"See Grayling, 1.","pos":""}],"UMBERY":[{"def":"Of or pertaining to umber; like umber; as, umbery gold.","pos":""}],"UMBILIC":[{"def":"The navel; the center.","pos":""}],"UMBILICAL":[{"def":"Of or pertaining to an umbilicus, or umbilical cord; umbilic.","pos":""}],"UMBILICATION":[{"def":"A slight, navel-like depression, or dimpling, of the center of a rounded body; as, the umbilication of a smallpox vesicle; also, the condition of being umbilicated.","pos":""}],"UMBILICUS":[{"def":"The depression, or mark, in the median line of the abdomen, which indicates the point where the umbilical cord separated from the fetus; the navel.","pos":""},{"def":"An ornamented or painted ball or boss fastened at each end of the stick on which manuscripts were rolled.","pos":""}],"UMBLE PIE":[{"def":"A pie made of umbles.","pos":""}],"UMBLES":[{"def":"The entrails and coarser parts of a deer; hence, sometimes, entrails, in general.","pos":""}],"UMBO":[{"def":"One of the lateral prominence just above the hinge of a bivalve shell.","pos":""},{"def":"Having a conical or rounded projection or protuberance, like a boss.","pos":""}],"UMBRA":[{"def":"Any one of several species of sciænoid food fishes of the genus Umbrina, especially the Mediterranean species (U.","pos":""}],"UMBRACULIFEROUS":[{"def":"Bearing something like an open umbrella.","pos":""}],"UMBRACULIFORM":[{"def":"Having the form of anything that serves to shade, as a tree top, an umbrella, and the like; specifically (Bot.","pos":""}],"UMBRAGE":[{"def":"Shade; shadow; obscurity; hence, that which affords a shade, as a screen of trees or foliage.","pos":""},{"def":"Shadowy resemblance; shadow.","pos":""}],"UMBRAGEOUS":[{"def":"Forming or affording a shade; shady; shaded; as, umbrageous trees or foliage.","pos":""},{"def":"Not easily perceived, as if from being darkened or shaded; obscure.","pos":""}],"UMBRATE":[{"def":"To shade; to shadow; to foreshadow.","pos":""},{"def":"Of or pertaining to the shade or darkness; shadowy; unreal; secluded; retired.","pos":""}],"UMBRATIOUS":[{"def":"Suspicious; captious; disposed to take umbrage.","pos":""}],"UMBREL":[{"def":"Each of them besides bore their umbrels.","pos":""}],"UMBRELLA":[{"def":"The umbrellalike disk, or swimming bell, of a jellyfish.","pos":""},{"def":"Any marine tectibranchiate gastropod of the genus Umbrella, having an umbrella-shaped shell; -- called also umbrella shell.","pos":""}],"UMBRIFEROUS":[{"def":"Casting or making a shade; umbrageous.","pos":""}],"UMBROSE":[{"def":"Shady; umbrageous.","pos":""}],"UMBROSITY":[{"def":"The quality or state of being umbrose; shadiness.","pos":""}],"UMHOFO":[{"def":"An African two-horned rhinoceros (Atelodus, or Rhinoceros, simus); -- called also chukuru, and white rhinoceros.","pos":""}],"UMLAUT":[{"def":"The euphonic modification of a root vowel sound by the influence of a, u, or especially i, in the syllable which formerly followed.","pos":""}],"UMLAUTED":[{"def":"Having the umlaut; as, umlauted vowels.","pos":""}],"UMPIRAGE":[{"def":"The office of an umpire; the power, right, or authority of an umpire to decide.","pos":""},{"def":"The act of umpiring; arbitrament.","pos":""}],"UMPIRE":[{"def":"A third person, who is to decide a controversy or question submitted to arbitrators in case of their disagreement.","pos":""}],"UMPIRESHIP":[{"def":"Umpirage; arbitrament.","pos":""}],"UMPTEEN":[{"def":"An indefinite number, usu.","pos":""}],"UMQUHILE":[{"def":"Some time ago; formerly.","pos":""}]}