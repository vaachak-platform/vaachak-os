{"PERDICINE":[{"def":"Of or pertaining to the family Perdicidæ, or partridges.","pos":""}],"PERDIFOIL":[{"def":"A deciduous plant; -- opposed to Ant: evergreen.","pos":""}],"PERDITION":[{"def":"Entire loss; utter destruction; ruin; esp.","pos":""},{"def":"Loss of diminution.","pos":""}],"PERDITIONABLE":[{"def":"Capable of being ruined; worthy of perdition.","pos":""}],"PERDIX":[{"def":"A genus of birds including the common European partridge.","pos":""}],"PERDU":[{"def":"One placed on watch, or in ambush.","pos":""},{"def":"A soldier sent on a forlorn hope.","pos":""}],"PERDULOUS":[{"def":"Lost; thrown away.","pos":""}],"PERDURABILITY":[{"def":"Durability; lastingness.","pos":""}],"PERDURABLE":[{"def":"Very durable; lasting; continuing long.","pos":""},{"def":"Long continuance.","pos":""}],"PERDURE":[{"def":"To last or endure for a long time; to be perdurable or lasting.","pos":""}],"PERDY":[{"def":"Ah, dame! perdy ye have not done me right.","pos":""}]}