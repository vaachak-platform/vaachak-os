{"FOIBLE":[{"def":"A moral weakness; a failing; a weak point; a frailty.","pos":""},{"def":"The half of a sword blade or foil blade nearest the point; -- opposed to forte.","pos":""}],"FOIL":[{"def":"To tread under foot; to trample.","pos":""},{"def":"To render (an effort or attempt) vain or nugatory; to baffle; to outwit; to balk; to frustrate; to defeat.","pos":""}],"FOILABLE":[{"def":"Capable of being foiled.","pos":""}],"FOILER":[{"def":"One who foils or frustrates.","pos":""}],"FOILING":[{"def":"The track of game (as deer) in the grass.","pos":""}],"FOIN":[{"def":"The beech marten (Mustela foina).","pos":""}],"FOINERY":[{"def":"Thrusting with the foil; fencing with the point, as distinguished from broadsword play.","pos":""}],"FOININGLY":[{"def":"With a push or thrust.","pos":""}],"FOISON":[{"def":"Rich harvest; plenty; abundance.","pos":""}],"FOIST":[{"def":"A light and fast-sailing ship.","pos":""}],"FOISTER":[{"def":"One who foists something surreptitiously; a falsitier.","pos":""}],"FOISTINESS":[{"def":"Fustiness; mustiness.","pos":""}]}