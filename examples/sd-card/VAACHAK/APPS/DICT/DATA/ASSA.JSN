{"ASSAFOETIDA":[{"def":"Same as Asafetida.","pos":""},{"def":"A spear used by tribes in South Africa as a missile and for stabbing, a kind of light javelin.","pos":""}],"ASSAI":[{"def":"A direction equivalent to very; as, adagio assai, very slow.","pos":""}],"ASSAIL":[{"def":"To attack with violence, or in a vehement and hostile manner; to assault; to molest; as, to assail a man with blows; to assail a city with artillery.","pos":""},{"def":"To encounter or meet purposely with the view of mastering, as an obstacle, difficulty, or the like.","pos":""}],"ASSAILABLE":[{"def":"Capable of being assailed.","pos":""}],"ASSAILANT":[{"def":"Assailing; attacking.","pos":""}],"ASSAILER":[{"def":"One who assails.","pos":""}],"ASSAILMENT":[{"def":"The act or power of assailing; attack; assault.","pos":""}],"ASSAMAR":[{"def":"The peculiar bitter substance, soft or liquid, and of a yellow color, produced when meat, bread, gum, sugar, starch, and the like, are roasted till they turn brown.","pos":""}],"ASSAMESE":[{"def":"Of or pertaining to Assam, a province of British India, or to its inhabitants.","pos":""},{"def":"A native or natives of Assam.","pos":""}],"ASSART":[{"def":"The act or offense of grubbing up trees and bushes, and thus destroying the tickets or coverts of a forest.","pos":""}],"ASSASSIN":[{"def":"One who kills, or attempts to kill, by surprise or secret assault; one who treacherously murders any one unprepared for defense.","pos":""}],"ASSASSINATE":[{"def":"To kill by surprise or secret assault; to murder by treacherous violence.","pos":""},{"def":"To assail with murderous intent; hence, by extended meaning, to maltreat exceedingly.","pos":""}],"ASSASSINATION":[{"def":"The act of assassinating; a killing by treacherous violence.","pos":""}],"ASSAULT":[{"def":"A violent onset or attack with physical means, as blows, weapons, etc.","pos":""},{"def":"A violent onset or attack with moral weapons, as words, arguments, appeals, and the like; as, to make an assault on the prerogatives of a prince, or on the constitution of a government.","pos":""}],"ASSAULTABLE":[{"def":"Capable of being assaulted.","pos":""}],"ASSAULTER":[{"def":"One who assaults, or violently attacks; an assailant.","pos":""}],"ASSAY":[{"def":"The act or process of ascertaining the proportion of a particular metal in an ore or alloy; especially, the determination of the proportion of gold or silver in bullion or coin.","pos":""}],"ASSAY POUND":[{"def":"A small standard weight used in assaying bullion, etc.","pos":""}],"ASSAYABLE":[{"def":"That may be assayed.","pos":""}],"ASSAYING":[{"def":"The act or process of testing, esp.","pos":""}]}