{"QUANDARY":[{"def":"A state of difficulty or perplexity; doubt; uncertainty.","pos":""}],"QUANDONG":[{"def":"The edible drupaceous fruit of an Australian tree (Fusanus acuminatus) of the Sandalwood family; -- called also quandang.","pos":""}],"QUANNET":[{"def":"A flat file having the handle at one side, so as to be used like a plane.","pos":""}],"QUANT":[{"def":"A punting pole with a broad flange near the end to prevent it from sinking into the mud; a setting pole.","pos":""}],"QUANTIC":[{"def":"A homogeneous algebraic function of two or more variables, in general containing only positive integral powers of the variables, and called quadric, cubic, quartic, etc.","pos":""}],"QUANTIFICATION":[{"def":"Modification by a reference to quantity; the introduction of the element of quantity.","pos":""}],"QUANTIFY":[{"def":"To modify or qualify with respect to quantity; to fix or express the quantity of; to rate.","pos":""}],"QUANTITATIVE":[{"def":"Relating to quantity.","pos":""}],"QUANTITIVE":[{"def":"Estimable according to quantity; quantitative.","pos":""}],"QUANTITIVELY":[{"def":"So as to be measurable by quantity; quantitatively.","pos":""}],"QUANTITY":[{"def":"That which can be increased, diminished, or measured; especially (Math.","pos":""}],"QUANTIVALENT":[{"def":"Of or pertaining to quantivalence.","pos":""}],"QUANTUM":[{"def":"A definite portion of a manifoldness, limited by a mark or by a boundary.","pos":""}]}