{"DISCUBITORY":[{"def":"Leaning; fitted for a reclining posture.","pos":""}],"DISCULPATE":[{"def":"To free from blame or the imputation of a fault; to exculpate.","pos":""}],"DISCULPATORY":[{"def":"Tending to exculpate; exculpatory.","pos":""}],"DISCUMBENCY":[{"def":"The act of reclining at table according to the manner of the ancients at their meals.","pos":""}],"DISCUMBER":[{"def":"To free from that which cumbers or impedes; to disencumber.","pos":""}],"DISCURE":[{"def":"To discover; to reveal; to discoure.","pos":""}],"DISCURRENT":[{"def":"Not current or free to circulate; not in use.","pos":""}],"DISCURSION":[{"def":"The act of discoursing or reasoning; range, as from thought to thought.","pos":""}],"DISCURSIVE":[{"def":"Passing from one thing to another; ranging over a wide field; roving; digressive; desultory.","pos":""},{"def":"Reasoning; proceeding from one ground to another, as in reasoning; argumentative.","pos":""}],"DISCURSORY":[{"def":"Argumentative; discursive; reasoning.","pos":""}],"DISCURSUS":[{"def":"Argumentation; ratiocination; discursive reasoning.","pos":""}],"DISCUS":[{"def":"Note: This among the Greeks was one of the chief gymnastic exercises and was included in the Pentathlon (the contest of the five exercises).","pos":""}],"DISCUSS":[{"def":"To examine or search thoroughly; to exhaust a remedy against, as against a principal debtor before proceeding against the surety.","pos":""}],"DISCUSSER":[{"def":"One who discusses; one who sifts or examines.","pos":""}],"DISCUSSION":[{"def":"The act or process of discussing by breaking up, or dispersing, as a tumor, or the like.","pos":""},{"def":"The act of discussing or exchanging reasons; examination by argument; debate; disputation; agitation.","pos":""}],"DISCUSSIONAL":[{"def":"Pertaining to discussion.","pos":""}],"DISCUSSIVE":[{"def":"Able or tending to discuss or disperse tumors or coagulated matter.","pos":""}],"DISCUTIENT":[{"def":"Serving to disperse morbid matter; discussive; as, a discutient application.","pos":""},{"def":"An agent (as a medicinal application) which serves to disperse morbid matter.","pos":""}]}