{"BARIC":[{"def":"Of or pertaining to barium; as, baric oxide.","pos":""}],"BARILLA":[{"def":"A name given to several species of Salsola from which soda is made, by burning the barilla in heaps and lixiviating the ashes.","pos":""}],"BARILLET":[{"def":"A little cask, or something resembling one.","pos":""}],"BARITE":[{"def":"Native sulphate of barium, a mineral occurring in transparent, colorless, white to yellow crystals (generally tabular), also in granular form, and in compact massive forms resembling marble.","pos":""}],"BARIUM":[{"def":"One of the elements, belonging to the alkaline earth group; a metal having a silver-white color, and melting at a very high temperature.","pos":""}]}