{"GAM":[{"def":"To have a gam with; to pay a visit to, esp.","pos":""}],"GAMA GRASS":[{"def":"A species of grass (Tripsacum dactyloides) tall, stout, and exceedingly productive; cultivated in the West Indies, Mexico, and the Southern States of North America as a forage grass; -- called also sesame grass.","pos":""}],"GAMASHES":[{"def":"High boots or buskins; in Scotland, short spatterdashes or riding trousers, worn over the other clothing.","pos":""}],"GAMBA":[{"def":"A viola da gamba.","pos":""}],"GAMBADOES":[{"def":"Same as Gamashes.","pos":""}],"GAMBEER":[{"def":"To gaff, as mackerel.","pos":""}],"GAMBESON":[{"def":"Same as Gambison.","pos":""}],"GAMBET":[{"def":"Any bird of the genuis Totanus.","pos":""}],"GAMBIER":[{"def":"Japonica, is used for chewing with the Areca nut, and is exported for tanning and dyeing.","pos":""}],"GAMBISON":[{"def":"A defensive garment formerly in use for the body, made of cloth stuffed and quilted.","pos":""}],"GAMBIST":[{"def":"A performer upon the viola di gamba.","pos":""}],"GAMBIT":[{"def":"A mode of opening the game, in which a pawn is sacrificed to gain an attacking position.","pos":""}],"GAMBLE":[{"def":"To play or game for money or other stake.","pos":""}],"GAMBLER":[{"def":"One who gambles.","pos":""}],"GAMBOGE":[{"def":"A concrete juice, or gum resin, produced by several species of trees in Siam, Ceylon, and Malabar.","pos":""},{"def":"Pertaining to, resembling, or containing, gamboge.","pos":""}],"GAMBOL":[{"def":"A skipping or leaping about in frolic; a hop; a sportive prank.","pos":""}],"GAMBREL":[{"def":"The hind leg of a horse.","pos":""},{"def":"A stick crooked like a horse's hind leg; -- used by butchers in suspending slaughtered animals.","pos":""}],"GAMBROON":[{"def":"A kind of twilled linen cloth for lining.","pos":""}],"GAME":[{"def":"Crooked; lame; as, a game leg.","pos":""}],"GAME FOWL":[{"def":"A handsome breed of the common fowl, remarkable for the great courage and pugnacity of the males.","pos":""}],"GAMECOCK":[{"def":"The male game fowl.","pos":""}],"GAMEFUL":[{"def":"Full of game or games.","pos":""}],"GAMEKEEPER":[{"def":"One who has the care of game, especially in a park or preserve.","pos":""}],"GAMELESS":[{"def":"Destitute of game.","pos":""}],"GAMELY":[{"def":"In a plucky manner; spiritedly.","pos":""}],"GAMENESS":[{"def":"Endurance; pluck.","pos":""}],"GAMESOME":[{"def":"Gay; sportive; playful; frolicsome; merry.","pos":""}],"GAMESTER":[{"def":"A merry, frolicsome person.","pos":""},{"def":"A person who plays at games; esp.","pos":""}],"GAMETE":[{"def":"A sexual cell or germ cell; a conjugating cell which unites with another of like or unlike character to form a new individual.","pos":""}],"GAMETOPHYTE":[{"def":"In the alternation of generations in plants, that generation or phase which bears sex organs.","pos":""}],"GAMIC":[{"def":"Pertaining to, or resulting from, sexual connection; formed by the union of the male and female elements.","pos":""}],"GAMIN":[{"def":"A neglected and untrained city boy; a young street Arab.","pos":""}],"GAMING":[{"def":"The act or practice of playing games for stakes or wagers; gambling.","pos":""}],"GAMMA":[{"def":"The third letter (G) of the Greek alphabet.","pos":""}],"GAMMA RAYS":[{"def":"Very penetrating rays not appreciably deflected by a magnetic or electric field, emitted by radioactive substances.","pos":""}],"GAMMADION":[{"def":"A cross formed of four capital gammas, formerly used as a mysterious ornament on ecclesiastical vestments, etc.","pos":""}],"GAMMER":[{"def":"An old wife; an old woman; -- correlative of gaffer, an old man.","pos":""}],"GAMMON":[{"def":"The buttock or tight of a hog, salted and smoked or dried; the lower end of a flitch.","pos":""}],"GAMMONING":[{"def":"The lashing or iron band by which the bowsprit of a vessel is secured to the stem to opposite the lifting action of the forestays.","pos":""}],"GAMOGENESIS":[{"def":"The production of offspring by the union of parents of different sexes; sexual reproduction; -- the opposite of agamogenesis.","pos":""}],"GAMOGENETIC":[{"def":"Relating to gamogenesis.","pos":""}],"GAMOMORPHISM":[{"def":"That stage of growth or development in an organism, in which the reproductive elements are generated and matured in preparation for propagating the species.","pos":""}],"GAMOPETALOUS":[{"def":"Having the petals united or joined so as to form a tube or cup; monopetalous.","pos":""}],"GAMOPHYLLOUS":[{"def":"Composed of leaves united by their edges (coalescent).","pos":""}],"GAMOSEPALOUS":[{"def":"Formed of united sepals; monosepalous.","pos":""}],"GAMP":[{"def":"A large umbrella; --said to allude to Mrs.","pos":""}],"GAMY":[{"def":"Having the flavor of game, esp.","pos":""},{"def":"Showing an unyielding spirit to the last; plucky; furnishing sport; as, a gamy trout.","pos":""}]}