{"DESUDATION":[{"def":"A sweating; a profuse or morbid sweating, often succeeded by an eruption of small pimples.","pos":""}],"DESUETE":[{"def":"Disused; out of use.","pos":""}],"DESUETUDE":[{"def":"The cessation of use; disuse; discontinuance of practice, custom, or fashion.","pos":""}],"DESULPHURATE":[{"def":"To deprive of sulphur.","pos":""}],"DESULPHURATION":[{"def":"The act or process of depriving of sulphur.","pos":""}],"DESULPHURIZE":[{"def":"To desulphurate; to deprive of sulphur.","pos":""}],"DESULTORILY":[{"def":"In a desultory manner; without method; loosely; immethodically.","pos":""}],"DESULTORINESS":[{"def":"The quality of being desultory or without order or method; unconnectedness.","pos":""}],"DESULTORY":[{"def":"Leaping or skipping about.","pos":""},{"def":"Jumping, or passing, from one thing or subject to another, without order or rational connection; without logical sequence; disconnected; immethodical; aimless; as, desultory minds.","pos":""}],"DESUME":[{"def":"To select; to borrow.","pos":""}]}