{"WHILE":[{"def":"Space of time, or continued duration, esp.","pos":""},{"def":"That which requires time; labor; pains.","pos":""}],"WHILERE":[{"def":"A little while ago; recently; just now; erewhile.","pos":""}],"WHILES":[{"def":"Meanwhile; meantime.","pos":""}],"WHILK":[{"def":"A kind of mollusk, a whelk.","pos":""}],"WHILOM":[{"def":"Formerly; once; of old; erewhile; at times.","pos":""}],"WHILST":[{"def":"Whilst the emperor lay at Antioch.","pos":""}]}