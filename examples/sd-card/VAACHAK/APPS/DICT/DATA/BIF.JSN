{"BIFACIAL":[{"def":"Having the opposite surfaces alike.","pos":""}],"BIFARIOUS":[{"def":"Pointing two ways, as leaves that grow only on opposite sides of a branch; in two vertical rows.","pos":""}],"BIFARIOUSLY":[{"def":"In a bifarious manner.","pos":""}],"BIFEROUS":[{"def":"Bearing fruit twice a year.","pos":""}],"BIFFIN":[{"def":"A sort of apple peculiar to Norfolk, Eng.","pos":""},{"def":"A baked apple pressed down into a flat, round cake; a dried apple.","pos":""}],"BIFID":[{"def":"Cleft to the middle or slightly beyond the middle; opening with a cleft; divided by a linear sinus, with straight margins.","pos":""}],"BIFILAR":[{"def":"Two-threaded; involving the use of two threads; as, bifilar suspension; a bifilar balance.","pos":""}],"BIFLABELLATE":[{"def":"Flabellate on both sides.","pos":""}],"BIFLAGELLATE":[{"def":"Having two long, narrow, whiplike appendages.","pos":""},{"def":"Bearing two flowers; two-flowered.","pos":""}],"BIFOCAL":[{"def":"Having two foci, as some spectacle lenses.","pos":""}],"BIFOLD":[{"def":"Twofold; double; of two kinds, degrees, etc.","pos":""}],"BIFOLIATE":[{"def":"Having two leaves; two-leaved.","pos":""}],"BIFOLIOLATE":[{"def":"Having two leaflets, as some compound leaves.","pos":""}],"BIFORATE":[{"def":"Having two perforations.","pos":""}],"BIFORINE":[{"def":"An oval sac or cell, found in the leaves of certain plants of the order Araceæ.","pos":""}],"BIFORM":[{"def":"Having two forms, bodies, or shapes.","pos":""}],"BIFORMED":[{"def":"Having two forms.","pos":""}],"BIFRONTED":[{"def":"Having two fronts.","pos":""},{"def":"Two-pronged; forked.","pos":""}],"BIFURCATE":[{"def":"To divide into two branches.","pos":""}],"BIFURCATION":[{"def":"A forking, or division into two branches.","pos":""}],"BIFURCOUS":[{"def":"See Bifurcate, a.","pos":""}]}