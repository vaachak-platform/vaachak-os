{"PRENASAL":[{"def":"Situated in front of the nose, or in front of the nasal chambers.","pos":""}],"PRENATAL":[{"def":"Being or happening before birth.","pos":""}],"PRENDER":[{"def":"The power or right of taking a thing before it is offered.","pos":""}],"PRENOMINAL":[{"def":"Serving as a prefix in a compound name.","pos":""}],"PRENOMINATE":[{"def":"Forenamed; named beforehand.","pos":""}],"PRENOMINATION":[{"def":"The act of prenominating; privilege of being named first.","pos":""}],"PRENOSTIC":[{"def":"A prognostic; an omen.","pos":""}],"PRENOTE":[{"def":"To note or designate beforehand.","pos":""}],"PRENOTION":[{"def":"A notice or notion which precedes something else in time; previous notion or thought; foreknowledge.","pos":""}],"PRENSATION":[{"def":"The act of seizing with violence.","pos":""}],"PRENTICEHOOD":[{"def":"This jolly prentice with his master bode Till he was out nigh of his prenticehood.","pos":""}],"PRENTICESHIP":[{"def":"He served a prenticeship who sets up shop.","pos":""}],"PRENUNCIATION":[{"def":"The act of announcing or proclaiming beforehand.","pos":""}],"PRENUNCIOUS":[{"def":"Announcing beforehand; presaging.","pos":""}]}