{"PYX":[{"def":"The box, case, vase, or tabernacle, in which the host is reserved.","pos":""},{"def":"The box in which the compass is suspended; the binnacle.","pos":""}],"PYXIDATE":[{"def":"Having a pyxidium.","pos":""}],"PYXIS":[{"def":"Anglo-Saxon, cw being used instead of qu; as in cwic, quick; cwen, queen.","pos":""}]}