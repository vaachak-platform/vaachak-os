{"PYRO":[{"def":"Abbreviation of pyrogallic acid.","pos":""}],"PYROACETIC":[{"def":"Pertaining to, and designating, a substance (acetone) obtained by the distillation of the acetates.","pos":""}],"PYROACID":[{"def":"An acid obtained by sybjecting another acid to the action of heat.","pos":""}],"PYROANTIMONATE":[{"def":"A salt of pyroantimonic acid.","pos":""}],"PYROANTIMONIC":[{"def":"Pertaining to, or designating, an acid of antimony analogous to pyrophosphoric acid.","pos":""}],"PYROARSENATE":[{"def":"A salt of pyroarsenic acid.","pos":""}],"PYROARSENIC":[{"def":"Pertaining to or designating, an acid of arsenic analogous to pyrophosphoric acid.","pos":""}],"PYROBORATE":[{"def":"A salt of pyroboric acid.","pos":""}],"PYROBORIC":[{"def":"Pertaining to derived from, or designating, an acid, H2B4O7 (called also tetraboric acid), which is the acid ingredient of ordinary borax, and is obtained by heating boric acid.","pos":""}],"PYROCATECHIN":[{"def":"A white crystalline substance, C6H4(OH)2, of the phenol series, found in various plants; -- so called because first obtained by distillation of gum catechu.","pos":""}],"PYROCHLORE":[{"def":"A niobate of calcium, cerium, and other bases, occurring usually in octahedrons of a yellowish or brownish color and resinous luster; -- so called from its becoming grass-green on being subjected to heat under the blowpipe.","pos":""}],"PYROCITRIC":[{"def":"Pertaining to, or designating, any one of three acids obtained by the distillation of citric acid, and called respectively citraconic, itaconic, and mesaconic acid.","pos":""}],"PYROCOLL":[{"def":"A yellow crystalline substance allied to pyrrol, obtained by the distillation of gelatin.","pos":""}],"PYROELECTRIC":[{"def":"Pertaining to, or dependent on, pyroelectricity; receiving electric polarity when heated.","pos":""}],"PYROELECTRICITY":[{"def":"Electricity developed by means of heat; the science which treats of electricity thus developed.","pos":""}],"PYROGALLATE":[{"def":"A salt of pyrogallic acid; an ether of pyrogallol.","pos":""}],"PYROGALLIC":[{"def":"Pertaining to, derived from, or designating, an acid called pyrogallol.","pos":""}],"PYROGALLOL":[{"def":"A phenol metameric with phloroglucin, obtained by the distillation of gallic acid as a poisonous white crystalline substance having acid properties, and hence called also pyrogallic acid.","pos":""}],"PYROGEN":[{"def":"A poison separable from decomposed meat infusions, and supposed to be formed from albuminous matter through the agency of bacteria.","pos":""}],"PYROGENIC":[{"def":"Producing heat; -- said of substances, as septic poisons, which elevate the temperature of the body and cause fever.","pos":""}],"PYROGENOUS":[{"def":"Produced by fire; igneous.","pos":""}],"PYROGNOSTIC":[{"def":"Of or pertaining to characters developed by the use of heat; pertaining to the characters of minerals when examined before the blowpipe; as, the pyrognostic characters of galena.","pos":""}],"PYROGNOSTICS":[{"def":"The characters of a mineral observed by the use of the blowpipe, as the degree of fusibility, flame coloration, etc.","pos":""}],"PYROGRAPH":[{"def":"A production of pyrography.","pos":""}],"PYROGRAPHY":[{"def":"A process of printing, ornamenting, or carving, by burning with heated instruments.","pos":""}],"PYROGRAVURE":[{"def":"Pyrography; also, a design or picture made by pyrography.","pos":""}],"PYROLATOR":[{"def":"A fire worshiper.","pos":""}],"PYROLATRY":[{"def":"The worship of fire.","pos":""},{"def":"Pertaining to, or designating, the acid liquid obtained in the distillation of wood, consisting essentially of impure acetic acid.","pos":""}],"PYROLIGNITE":[{"def":"A crude acetate produced by treating pyroligneous acid with a metal or basic compound; as, pyrolignite of iron (iron liquor).","pos":""}],"PYROLIGNOUS":[{"def":"Same as Pyroligneous.","pos":""}],"PYROLITHIC":[{"def":"Same as Pyrouric, or Cyanuric.","pos":""}],"PYROLOGIST":[{"def":"One who is versed in, or makes a study of, pyrology.","pos":""}],"PYROLOGY":[{"def":"That branch of physical science which treats of the properties, phenomena, or effects of heat; also, a treatise on heat.","pos":""}],"PYROLUSITE":[{"def":"Manganese dioxide, a mineral of an iron-black or dark steel- gray color and metallic luster, usually soft.","pos":""}],"PYROMAGNETIC":[{"def":"Acting by the agency of heat and magnetism; as, a pyromagnetic machine for producing electric currents.","pos":""}],"PYROMALATE":[{"def":"A salt of pyromalic acid.","pos":""}],"PYROMALIC":[{"def":"Pertaining to, or designating, an acid now called maleic acid.","pos":""}],"PYROMANCY":[{"def":"Divination by means of fire.","pos":""}],"PYROMANIA":[{"def":"An insane disposition to incendiarism.","pos":""}],"PYROMANTIC":[{"def":"Of or pertaining to pyromancy.","pos":""}],"PYROMETER":[{"def":"An instrument used for measuring the expansion of solid bodies by heat.","pos":""},{"def":"An instrument for measuring degrees of heat above those indicated by the mercurial thermometer.","pos":""}],"PYROMETRY":[{"def":"The art of measuring degrees of heat, or the expansion of bodies by heat.","pos":""}],"PYROMORPHITE":[{"def":"Native lead phosphate with lead chloride, occurring in bright green and brown hexagonal crystals and also massive; -- so called because a fused globule crystallizes in cooling.","pos":""}],"PYROMORPHOUS":[{"def":"Having the property of crystallizing by the agency of fire.","pos":""}],"PYROMUCATE":[{"def":"A salt of pyromucic acid.","pos":""}],"PYROMUCIC":[{"def":"Pertaining to, derived from, or designating, an acid obtained as a white crystalline substance by the distillation of mucic acid, or by the oxidation of furfurol.","pos":""}],"PYRONE":[{"def":"An unsaturated cyclic compound, C5H4O2, of which two varieties are known, a and g.","pos":""}],"PYRONOMICS":[{"def":"The science of heat.","pos":""}],"PYROPE":[{"def":"A variety of garnet, of a poppy or blood-red color, frequently with a tinge of orange.","pos":""}],"PYROPHANE":[{"def":"A mineral which is opaque in its natural state, but is said to change its color and become transparent by heat.","pos":""}],"PYROPHANOUS":[{"def":"Rendered transparent by heat.","pos":""}],"PYROPHONE":[{"def":"A musical instrument in which the tones are produced by flames of hydrogen, or illuminating gas, burning in tubes of different sizes and lengths.","pos":""},{"def":"Light-producing; of or pertaining to pyrophorus.","pos":""}],"PYROPHORUS":[{"def":"Any one of several substances or mixtures which phosphoresce or ignite spontaneously on exposure to air, as a heated mixture of alum, potash, and charcoal, or a mixture of charcoal and finely divided lead.","pos":""}],"PYROPHOSPHATE":[{"def":"A salt of pyrophosphoric acid.","pos":""}],"PYROPHOSPHORIC":[{"def":"Pertaining to, or designating, an acid, H4P2O7, which is obtained as a white crystalline substance.","pos":""}],"PYROPHYLLITE":[{"def":"A mineral, usually of a white or greenish color and pearly luster, consisting chiefly of the hydrous silicate of alumina.","pos":""}],"PYROSCOPE":[{"def":"An instrument for measuring the intensity of heat radiating from a fire, or the cooling influence of bodies.","pos":""}],"PYROSIS":[{"def":"See Water brash, under Brash.","pos":""}],"PYROSMALITE":[{"def":"A mineral, usually of a pale brown or of a gray or grayish green color, consisting chiefly of the hydrous silicate of iron and manganese; -- so called from the odor given off before the blowpipe.","pos":""}],"PYROSOME":[{"def":"Any compound ascidian of the genus Pyrosoma.","pos":""}],"PYROSULPHATE":[{"def":"A salt of pyrosulphuric acid.","pos":""}],"PYROSULPHURIC":[{"def":"Pertaining to, or designating, an acid called also disulphuric acid) obtained by distillation of certain sulphates, as a colorless, thick, oily liquid, H2S2O7 resembling sulphuric acid.","pos":""}],"PYROTARTARIC":[{"def":"Pertaining to, or designating, an acid obtained as a white crystalline substance by the distillation of tartaric acid.","pos":""}],"PYROTARTRATE":[{"def":"A salt of pyrotartaric acid.","pos":""}],"PYROTECHNIAN":[{"def":"Of or pertaining to fireworks, or the art of forming them.","pos":""}],"PYROTECHNICIAN":[{"def":"Pyr`o*tech*ni\"cian, n.","pos":""}],"PYROTECHNICS":[{"def":"The art of making fireworks; the manufacture and use of fireworks; pyrotechny.","pos":""}],"PYROTECHNIST":[{"def":"One skilled in pyrotechny; one who manufactures fireworks.","pos":""}],"PYROTECHNY":[{"def":"The use and application of fire in science and the arts.","pos":""},{"def":"Same as Pyrotechnics.","pos":""}],"PYROTHONIDE":[{"def":"A kind of empyreumatic oil produced by the combustion of textures of hemp, linen, or cotton in a copper vessel, -- formerly used as a remedial agent.","pos":""}],"PYROTIC":[{"def":"A caustic medicine.","pos":""}],"PYROTRITARTARIC":[{"def":"Designating an acid which is more commonly called uric acid.","pos":""}],"PYROTUNGSTIC":[{"def":"Pertaining to, or designating, an acid now called cyanuric acid.","pos":""}],"PYROVANADIC":[{"def":"Pertaining to, or designating, an acid of vanadium, analogous to pyrophosphoric acid.","pos":""}],"PYROXANTHIN":[{"def":"A yellow crystalline hydrocardon extracted from crude wood spirit; -- called also eblanin.","pos":""}],"PYROXENE":[{"def":"A common mineral occurring in monoclinic crystals, with a prismatic angle of nearly 90º, and also in massive forms which are often laminated.","pos":""}],"PYROXENIC":[{"def":"Containing pyroxene; composed chiefly of pyroxene.","pos":""}],"PYROXENITE":[{"def":"A rock consisting essentially of pyroxene.","pos":""}],"PYROXYLE":[{"def":"See Pyroxylic, -yl.","pos":""}],"PYROXYLIC":[{"def":"Derived from wood by distillation; -- formerly used in designating crude wood spirit.","pos":""}],"PYROXYLIN":[{"def":"A substance resembling gun cotton in composition and properties, but distinct in that it is more highly nitrified and is soluble in alcohol, ether, etc.","pos":""}]}