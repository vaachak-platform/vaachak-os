{"TRIUMPH":[{"def":"A magnificent and imposing ceremonial performed in honor of a general who had gained a decisive victory over a foreign enemy.","pos":""}],"TRIUMPHAL":[{"def":"Of or pertaining to triumph; used in a triumph; indicating, or in honor of, a triumph or victory; as, a triumphal crown; a triumphal arch.","pos":""}],"TRIUMPHANT":[{"def":"Rejoicing for victory; triumphing; exultant.","pos":""},{"def":"Celebrating victory; expressive of joy for success; as, a triumphant song or ode.","pos":""}],"TRIUMPHANTLY":[{"def":"In a triumphant manner.","pos":""}],"TRIUMPHER":[{"def":"One who was honored with a triumph; a victor.","pos":""}],"TRIUMPHING":[{"def":"Having or celebrating a triumph; victorious; triumphant.","pos":""}],"TRIUMVIR":[{"def":"One of tree men united in public office or authority.","pos":""}],"TRIUMVIRATE":[{"def":"Government by three in coalition or association; the term of such a government.","pos":""},{"def":"A coalition or association of three in office or authority; especially, the union of three men who obtained the government of the Roman empire.","pos":""}],"TRIUNE":[{"def":"Being three in one; -- an epithet used to express the unity of a trinity of persons in the Godhead.","pos":""}],"TRIUNGULUS":[{"def":"The active young larva of any oil beetle.","pos":""}],"TRIUNITY":[{"def":"The quality or state of being triune; trinity.","pos":""}]}