{"CTENOCYST":[{"def":"An organ of the Ctenophora, supposed to be sensory.","pos":""}],"CTENOID":[{"def":"Cte\"noid (t\"noid or tn\"oid), a.","pos":""}],"CTENOIDEAN":[{"def":"Relating to the Ctenoidei.","pos":""},{"def":"One of the Ctenoidei.","pos":""}],"CTENOIDEI":[{"def":"A group of fishes, established by Agassiz, characterized by having scales with a pectinated margin, as in the perch.","pos":""}],"CTENOPHORA":[{"def":"A class of Coelenterata, commonly ellipsoidal in shape, swimming by means of eight longitudinal rows of paddles.","pos":""}],"CTENOPHORE":[{"def":"Of or pertaining to the Ctenophora.","pos":""}],"CTENOSTOMATA":[{"def":"A suborder of Bryozoa, usually having a circle of bristles below the tentacles.","pos":""}]}