{"SYRACUSE":[{"def":"A red wine of Italy.","pos":""}],"SYRIAC":[{"def":"Of or pertaining to Syria, or its language; as, the Syriac version of the Pentateuch.","pos":""},{"def":"The language of Syria; especially, the ancient language of that country.","pos":""}],"SYRIACISM":[{"def":"A Syrian idiom; a Syrianism.","pos":""}],"SYRIAN":[{"def":"Of or pertaining to Syria; Syriac.","pos":""},{"def":"A native of Syria.","pos":""}],"SYRIANISM":[{"def":"A Syrian idiom, or a peculiarity of the Syrian language; a Syriacism.","pos":""}],"SYRIASM":[{"def":"A Syrian idiom; a Syrianism; a Syriacism.","pos":""}],"SYRINGE":[{"def":"A kind of small hand-pump for throwing a stream of liquid, or for purposes of aspiration.","pos":""}],"SYRINGEAL":[{"def":"Of or pertaining to the syrinx; as, the syringeal muscle.","pos":""}],"SYRINGIN":[{"def":"A glucoside found in the bark of the lilac (Syringa) and extracted as a white crystalline substance; -- formerly called also lilacin.","pos":""}],"SYRINGOCOELE":[{"def":"The central canal of the spinal cord.","pos":""}],"SYRINGOTOME":[{"def":"A small blunt-pointed bistoury, -- used in syringotomy.","pos":""}],"SYRINGOTOMY":[{"def":"The operation of cutting for anal fistula.","pos":""}],"SYRINX":[{"def":"A wind instrument made of reeds tied together; -- called also pandean pipes.","pos":""},{"def":"The lower larynx in birds.","pos":""}],"SYRMA":[{"def":"A long dress, trailing on the floor, worn by tragic actors in Greek and Roman theaters.","pos":""}],"SYRPHIAN":[{"def":"Of or pertaining to the syrphus flies.","pos":""}],"SYRPHUS FLY":[{"def":"Any one of numerous species of dipterous flies of the genus Syrphus and allied genera.","pos":""}],"SYRT":[{"def":"A quicksand; a bog.","pos":""}],"SYRTIC":[{"def":"Of or pertaining to a syrt; resembling syrt, or quicksand.","pos":""}],"SYRTIS":[{"def":"Same as Sirup, Sirupy.","pos":""}]}