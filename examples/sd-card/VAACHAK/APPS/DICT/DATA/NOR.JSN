{"NOR":[{"def":"A negative connective or particle, introducing the second member or clause of a negative proposition, following neither, or not, in the first member or clause (as or in affirmative propositions follows either).","pos":""}],"NORBERTINE":[{"def":"See Premonstrant.","pos":""}],"NORFOLK":[{"def":"Short for Norfolk Jacket.","pos":""}],"NORFOLK JACKET":[{"def":"A kind of loose-fitting plaited jacket, having a loose belt.","pos":""}],"NORFOLK PLOVER":[{"def":"The stone curlew.","pos":""}],"NORFOLK SPANIEL":[{"def":"One of a breed of field spaniels similar to the clumbers, but shorter in body and of a liver-and-white or black-and-white color.","pos":""}],"NORIA":[{"def":"A large water wheel, turned by the action of a stream against its floats, and carrying at its circumference buckets, by which water is raised and discharged into a trough; used in Arabia, China, and elsewhere for irrigating land; a Persian wheel.","pos":""}],"NORIAN":[{"def":"Pertaining to the upper portion of the Laurentian rocks.","pos":""}],"NORIMON":[{"def":"A Japanese covered litter, carried by men.","pos":""}],"NORITE":[{"def":"A granular crystalline rock consisting essentially of a triclinic feldspar (as labradorite) and hypersthene.","pos":""}],"NORIUM":[{"def":"A supposed metal alleged to have been discovered in zircon.","pos":""}],"NORLAND":[{"def":"The land in the north; north country.","pos":""}],"NORLANDER":[{"def":"A northener; a person from the north country.","pos":""}],"NORM":[{"def":"A typical, structural unit; a type.","pos":""}],"NORMA":[{"def":"A norm; a principle or rule; a model; a standard.","pos":""},{"def":"A mason's or a carpenter's square or rule.","pos":""}],"NORMAL":[{"def":"According to a square or rule; perpendicular; forming a right angle.","pos":""},{"def":"Standard; original; exact; typical.","pos":""}],"NORMALCY":[{"def":"The quality, state, or fact of being normal; as, the point of normalcy.","pos":""}],"NORMALIZATION":[{"def":"Reduction to a standard or normal state.","pos":""}],"NORMALLY":[{"def":"In a normal manner.","pos":""}],"NORMAN":[{"def":"A wooden bar, or iron pin.","pos":""}],"NORMANISM":[{"def":"A Norman idiom; a custom or expression peculiar to the Normans.","pos":""},{"def":"One of the three Fates, Past, Present, and Future.","pos":""}],"NOROPIANIC":[{"def":"Of, pertaining to, or designating, an acid of the aromatic series obtained from opianic acid.","pos":""}],"NORROY":[{"def":"The most northern of the English Kings-at-arms.","pos":""}],"NORSE":[{"def":"Of or pertaining to ancient Scandinavia, or to the language spoken by its inhabitants.","pos":""}],"NORSEMAN":[{"def":"One of the ancient Scandinavians; a Northman.","pos":""}],"NORTELRY":[{"def":"Nurture; education; culture; bringing up.","pos":""}],"NORTH":[{"def":"That one of the four cardinal points of the compass, at any place, which lies in the direction of the true meridian, and to the left hand of a person facing the east; the direction opposite to the south.","pos":""},{"def":"Any country or region situated farther to the north than another; the northern section of a country.","pos":""}],"NORTH STAR STATE":[{"def":"Minnesota; -- a nickname.","pos":""}],"NORTHEAST":[{"def":"The point between the north and east, at an equal distance from each; the northeast part or region.","pos":""}],"NORTHEASTER":[{"def":"A storm, strong wind, or gale, coming from the northeast.","pos":""}],"NORTHEASTERLY":[{"def":"Pertaining to the northeast; toward the northeast, or coming from the northeast.","pos":""}],"NORTHEASTERN":[{"def":"Of or pertaining to the northeast; northeasterly.","pos":""},{"def":"Toward the northeast.","pos":""}],"NORTHER":[{"def":"A wind from the north; esp.","pos":""}],"NORTHERLINESS":[{"def":"The quality or state of being northerly; direction toward the north.","pos":""}],"NORTHERLY":[{"def":"Of or pertaining to the north; toward the north, or from the north; northern.","pos":""}],"NORTHERN":[{"def":"Of or pertaining to the north; being in the north, or nearer to that point than to the east or west.","pos":""},{"def":"In a direction toward the north; as, to steer a northern course; coming from the north; as, a northern wind.","pos":""}],"NORTHERNER":[{"def":"One born or living in the north.","pos":""},{"def":"A native or inhabitant of the Northern States; -- contradistinguished from Ant: Southerner.","pos":""}],"NORTHING":[{"def":"Distance northward from any point of departure or of reckoning, measured on a meridian; -- opposed to Ant: southing.","pos":""},{"def":"The distance of any heavenly body from the equator northward; north declination.","pos":""}],"NORTHMAN":[{"def":"One of the inhabitants of the north of Europe; esp.","pos":""}],"NORTHMOST":[{"def":"Lying farthest north; northernmost.","pos":""}],"NORTHNESS":[{"def":"A tendency in the end of a magnetic needle to point to the north.","pos":""}],"NORTHUMBRIAN":[{"def":"Of or pertaining to Northumberland in England.","pos":""},{"def":"A native or inhabitant of Northumberland.","pos":""}],"NORTHWARD":[{"def":"Toward the north; nearer to the north than to the east or west point.","pos":""},{"def":"Toward the north, or toward a point nearer to the north than to the east or west point.","pos":""}],"NORTHWARDLY":[{"def":"Having a northern direction.","pos":""}],"NORTHWEST":[{"def":"The point in the horizon between the north and west, and equally distant from each; the northwest part or region.","pos":""}],"NORTHWESTER":[{"def":"A storm or gale from the northwest; a strong northwest wind.","pos":""}],"NORTHWESTERLY":[{"def":"Toward the northwest, or from the northwest.","pos":""}],"NORTHWESTERN":[{"def":"Of, pertaining to, or being in, the northwest; in a direction toward the northwest; coming from the northwest; northwesterly; as, a northwestern course.","pos":""},{"def":"Toward the northwest.","pos":""}],"NORWEGIAN":[{"def":"Of or pertaining to Norway, its inhabitants, or its language.","pos":""}],"NORWEGIUM":[{"def":"A rare metallic element, of doubtful identification, said to occur in the copper-nickel of Norway.","pos":""}]}