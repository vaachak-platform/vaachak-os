{"MARC":[{"def":"The refuse matter which remains after the pressure of fruit, particularly of grapes.","pos":""}],"MARCASITE":[{"def":"A sulphide of iron resembling pyrite or common iron pyrites in composition, but differing in form; white iron pyrites.","pos":""},{"def":"Containing, or having the nature of, marcasite.","pos":""}],"MARCASSIN":[{"def":"A young wild boar.","pos":""}],"MARCATO":[{"def":"In a marked emphatic manner; -- used adverbially as a direction.","pos":""}],"MARCELINE":[{"def":"A thin silk fabric used for linings, etc.","pos":""}],"MARCH":[{"def":"The third month of the year, containing thirty-one days.","pos":""}],"MARCH-MAD":[{"def":"Extremely rash; foolhardy.","pos":""}],"MARCH-WARD":[{"def":"A warden of the marches; a marcher.","pos":""}],"MARCHER":[{"def":"One who marches.","pos":""}],"MARCHING":[{"def":"In England, a regiment liable to be ordered into other quarters, at home or abroad; a regiment of the line.","pos":""}],"MARCHIONESS":[{"def":"The wife or the widow of a marquis; a woman who has the rank and dignity of a marquis.","pos":""}],"MARCHMAN":[{"def":"A person living in the marches between England and Scotland or Wales.","pos":""}],"MARCHPANE":[{"def":"A kind of sweet bread or biscuit; a cake of pounded almonds and sugar.","pos":""}],"MARCIAN":[{"def":"Under the influence of Mars; courageous; bold.","pos":""}],"MARCID":[{"def":"Pining; lean; withered.","pos":""},{"def":"Characterized by emaciation, as a fever.","pos":""}],"MARCIDITY":[{"def":"The state or quality of being withered or lean.","pos":""}],"MARCIONITE":[{"def":"A follower of Marcion, a Gnostic of the second century, who adopted the Oriental notion of the two conflicting principles, and imagined that between them there existed a third power, neither wholly good nor evil, the Creator of the world and of man, and the God of the Jewish dispensation.","pos":""}],"MARCOBRUNNER":[{"def":"A celebrated Rhine wine.","pos":""}],"MARCONI":[{"def":"Designating, or pert.","pos":""}],"MARCONI SYSTEM":[{"def":"A system or wireless telegraphy developed by G.","pos":""}],"MARCONI'S LAW":[{"def":"The law that the maximum good signaling distance varies directly as the square of the height of the transmitting antenna.","pos":""}],"MARCONIGRAM":[{"def":"A Marconi wireless message.","pos":""}],"MARCONIGRAPH":[{"def":"The apparatus used in Marconi wireless telegraphy.","pos":""}],"MARCONISM":[{"def":"The theory or practice of Marconi's wireless telegraph system.","pos":""}],"MARCOR":[{"def":"A wasting away of flesh; decay.","pos":""}],"MARCOSIAN":[{"def":"One of a Gnostic sect of the second century, so called from Marcus, an Egyptian, who was reputed to be a margician.","pos":""}]}