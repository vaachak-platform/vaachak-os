{"COFFEE":[{"def":"The \"beans\" or \"berries\" (pyrenes) obtained from the drupes of a small evergreen tree of the genus Coffea, growing in Abyssinia, Arabia, Persia, and other warm regions of Asia and Africa, and also in tropical America.","pos":""},{"def":"The coffee tree.","pos":""}],"COFFEEHOUSE":[{"def":"A house of entertainment, where guests are supplied with coffee and other refreshments, and where men meet for conversation.","pos":""}],"COFFEEMAN":[{"def":"One who keeps a coffeehouse.","pos":""}],"COFFEEROOM":[{"def":"A public room where coffee and other refreshments may be obtained.","pos":""}],"COFFER":[{"def":"A panel deeply recessed in the ceiling of a vault, dome, or portico; a caisson.","pos":""},{"def":"A trench dug in the botton of a dry moat, and extending across it, to enable the besieged to defend it by a raking fire.","pos":""}],"COFFERDAM":[{"def":"A water-tight inclosure, as of piles packed with clay, from which the water is pumped to expose the bottom (of a river, etc.","pos":""}],"COFFERER":[{"def":"One who keeps treasures in a coffer.","pos":""}],"COFFERWORK":[{"def":"Rubblework faced with stone.","pos":""}],"COFFIN":[{"def":"The hollow crust or hoof of a horse's foot, below the coronet, in which is the coffin bone.","pos":""}],"COFFINLESS":[{"def":"Having no coffin.","pos":""}],"COFFLE":[{"def":"A gang of negro slaves being driven to market.","pos":""}]}