{"URBAN":[{"def":"Of or belonging to a city or town; as, an urban population.","pos":""},{"def":"Belonging to, or suiting, those living in a city; cultivated; polite; urbane; as, urban manners.","pos":""}],"URBANE":[{"def":"Courteous in manners; polite; refined; elegant.","pos":""}],"URBANISTE":[{"def":"A large and delicious pear or Flemish origin.","pos":""}],"URBANITY":[{"def":"The quality or state of being urbane; civility or courtesy of manners; politeness; refinement.","pos":""},{"def":"Polite wit; facetiousness.","pos":""}],"URBANIZE":[{"def":"To render urban, or urbane; to refine; to polish.","pos":""}],"URBICOLAE":[{"def":"An extensive family of butterflies, including those known as skippers (Hesperiadæ).","pos":""}],"URBICOLOUS":[{"def":"Of or pertaining to a city; urban.","pos":""}]}