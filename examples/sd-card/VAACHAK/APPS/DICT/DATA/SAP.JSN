{"SAP":[{"def":"The juice of plants of any kind, especially the ascending and descending juices or circulating fluid essential to nutrition.","pos":""},{"def":"The sapwood, or alburnum, of a tree.","pos":""}],"SAPAJOU":[{"def":"Any one of several species of South American monkeys of the genus Cebus, having long and prehensile tails.","pos":""}],"SAPAN WOOD":[{"def":"A dyewood yielded by Cæsalpinia Sappan, a thorny leguminous tree of Southern Asia and the neighboring islands.","pos":""}],"SAPFUL":[{"def":"Abounding in sap; sappy.","pos":""}],"SAPHEAD":[{"def":"A weak-minded, stupid fellow; a milksop.","pos":""}],"SAPID":[{"def":"Having the power of affecting the organs of taste; possessing savor, or flavor.","pos":""}],"SAPIDITY":[{"def":"The quality or state of being sapid; taste; savor; savoriness.","pos":""}],"SAPIDNESS":[{"def":"Quality of being sapid; sapidity.","pos":""}],"SAPIENCE":[{"def":"The quality of being sapient; wisdom; sageness; knowledge.","pos":""}],"SAPIENT":[{"def":"Wise; sage; discerning; -- often in irony or contempt.","pos":""}],"SAPIENTIAL":[{"def":"Having or affording wisdom.","pos":""}],"SAPIENTIZE":[{"def":"To make sapient.","pos":""}],"SAPIENTLY":[{"def":"In a sapient manner.","pos":""}],"SAPINDACEOUS":[{"def":"Of or pertaining to an order of trees and shrubs (Sapindaceæ), including the (Typical) genus Sapindus, the maples, the margosa, and about seventy other genera.","pos":""}],"SAPINDUS":[{"def":"A genus of tropical and subtropical trees with pinnate leaves and panicled flowers.","pos":""}],"SAPLESS":[{"def":"Destitute of sap; not juicy.","pos":""}],"SAPODILLA":[{"def":"A tall, evergeen, tropical American tree (Achras Sapota); also, its edible fruit, the sapodilla plum.","pos":""}],"SAPOGENIN":[{"def":"A white crystalline substance obtained by the decomposition of saponin.","pos":""}],"SAPONACEOUS":[{"def":"Resembling soap; having the qualities of soap; soapy.","pos":""}],"SAPONACITY":[{"def":"The quality or state of being saponaceous.","pos":""}],"SAPONIFIABLE":[{"def":"Capable of conversion into soap; as, a saponifiable substance.","pos":""}],"SAPONIFICATION":[{"def":"The act, process, or result, of soap making; conversion into soap; specifically (Chem.","pos":""}],"SAPONIFIER":[{"def":"That which saponifies; any reagent used to cause saponification.","pos":""}],"SAPONIFY":[{"def":"To convert into soap, as tallow or any fat; hence (Chem.","pos":""}],"SAPONIN":[{"def":"A poisonous glucoside found in many plants, as in the root of soapwort (Saponaria), in the bark of soap bark (Quillaia), etc.","pos":""}],"SAPONITE":[{"def":"A hydrous silicate of magnesia and aluminia.","pos":""}],"SAPONUL":[{"def":"A soapy mixture obtained by treating an essential oil with an alkali; hence, any similar compound of an essential oil.","pos":""}],"SAPOR":[{"def":"Power of affecting the organs of taste; savor; flavor; taste.","pos":""}],"SAPORIFIC":[{"def":"Having the power to produce the sensation of taste; producing taste, flavor, or relish.","pos":""}],"SAPOROSITY":[{"def":"The quality of a body by which it excites the sensation of taste.","pos":""}],"SAPOROUS":[{"def":"Having flavor or taste; yielding a taste.","pos":""}],"SAPOTACEOUS":[{"def":"Of or pertaining to a natural order (Sapotaceæ) of (mostly tropical) trees and shrubs, including the star apple, the Lucuma, or natural marmalade tree, the gutta-percha tree (Isonandra), and the India mahwa, as well as the sapodilla, or sapota, after which the order is named.","pos":""}],"SAPPER":[{"def":"One who saps; specifically (Mil.","pos":""}],"SAPPHIC":[{"def":"Belonging to, or in the manner of, Sappho; -- said of a certain kind of verse reputed to have been invented by Sappho, consisting of five feet, of which the first, fourth, and fifth are trochees, the second is a spondee, and the third a dactyl.","pos":""}],"SAPPHIRE":[{"def":"Native alumina or aluminium sesquioxide, Al2O3; corundum; esp.","pos":""},{"def":"Any humming bird of the genus Hylocharis, native of South America.","pos":""}],"SAPPHIRINE":[{"def":"Resembling sapphire; made of sapphire; having the color, or any quality of sapphire.","pos":""}],"SAPPHO":[{"def":"Any one of several species of brilliant South American humming birds of the genus Sappho, having very bright-colored and deeply forked tails; -- called also firetail.","pos":""}],"SAPPINESS":[{"def":"The quality of being sappy; juiciness.","pos":""}],"SAPPY":[{"def":"Abounding in sap; resembling, or consisting lagerly of, sapwood.","pos":""}],"SAPROPHAGAN":[{"def":"One of a tribe of beetles which feed upon dacaying animal and vegetable substances; a carrion beetle.","pos":""}],"SAPROPHAGOUS":[{"def":"Feeding on carrion.","pos":""}],"SAPROPHYTE":[{"def":"Any plant growing on dacayed animal or vegetable matter, as most fungi and some flowering plants with no green color, as the Indian pipe.","pos":""}],"SAPROPHYTIC":[{"def":"Feeding or growing upon decaying anomal or vegetable matter; pertaining to a saprophyte or the saprophytes.","pos":""}],"SAPROPHYTISM":[{"def":"State or fact of being saprophytic.","pos":""}],"SAPSAGO":[{"def":"A kind of Swiss cheese, of a greenish color, flavored with melilot.","pos":""}],"SAPUCAIA":[{"def":"A Brazilian tree.","pos":""}],"SAPWOOD":[{"def":"The alburnum, or part of the wood on any exogenous tree next to the bark, being that portion of the tree through which the sap flows most freely; -- distinguished from Heartwood.","pos":""}]}