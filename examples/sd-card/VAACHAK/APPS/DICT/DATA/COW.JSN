{"COW":[{"def":"The mature female of bovine animals.","pos":""},{"def":"The female of certain large mammals, as whales, seals, etc.","pos":""}],"COW PARSLEY":[{"def":"An umbelliferous plant of the genus Chærophyllum (C.","pos":""}],"COW PARSNIP":[{"def":"A coarse umbelliferous weed of the genus Heracleum (H.","pos":""}],"COW TREE":[{"def":"A tree (Galactodendron utile or Brosimum Galactodendron) of South America, which yields, on incision, a nourishing fluid, resembling milk.","pos":""}],"COW'S LUNGWORT":[{"def":"Cow's\" lung\"wort` (kouz\" lng\"wrt`).","pos":""}],"COW-PILOT":[{"def":"A handsomely banded, coral-reef fish, of Florida and the West Indies (Pomacentrus saxatilis); -- called also mojarra.","pos":""}],"COWALKER":[{"def":"A phantasmic or \"astral\" body deemed to be separable from the physical body and capable of acting independently; a doppelgänger.","pos":""}],"COWAN":[{"def":"One who works as a mason without having served a regular apprenticeship.","pos":""}],"COWARD":[{"def":"Borne in the escutcheon with his tail doubled between his legs; -- said of a lion.","pos":""}],"COWARDICE":[{"def":"Want of courage to face danger; extreme timidity; pusillanimity; base fear of danger or hurt; lack of spirit.","pos":""}],"COWARDIE":[{"def":"Cow\"ard*ie (kou\"rd-), n.","pos":""}],"COWARDIZE":[{"def":"To render cowardly.","pos":""}],"COWARDLINESS":[{"def":"Cow\"ard*li*ness (-l-ns), n.","pos":""}],"COWARDLY":[{"def":"Wanting courage; basely or weakly timid or fearful; pusillanimous; spiritless.","pos":""},{"def":"Proceeding from fear of danger or other consequences; befitting a coward; dastardly; base; as, cowardly malignity.","pos":""}],"COWBANE":[{"def":"A poisonous umbelliferous plant; in England, the Cicuta virosa; in the United States, the Cicuta maculata and the Archemora rigida.","pos":""}],"COWBERRY":[{"def":"A species of Vaccinium (V.","pos":""}],"COWBIRD":[{"def":"The cow blackbird (Molothrus ater), an American starling.","pos":""}],"COWBLAKES":[{"def":"Dried cow dung used as fuel.","pos":""}],"COWBOY":[{"def":"A cattle herder; a drover; specifically, one of an adventurous class of herders and drovers on the plains of the Western and Southwestern United States.","pos":""},{"def":"One of the marauders who, in the Revolutionary War infested the neutral ground between the American and British lines, and committed depredations on the Americans.","pos":""}],"COWCATCHER":[{"def":"A strong inclined frame, usually of wrought-iron bars, in front of a locomotive engine, for catching or throwing off obstructions on a railway, as cattle; the pilot.","pos":""}],"COWER":[{"def":"To stoop by bending the knees; to crouch; to squat; hence, to quail; to sink through fear.","pos":""}],"COWHAGE":[{"def":"A leguminous climbing plant of the genus Mucuna, having crooked pods covered with sharp hairs, which stick to the fingers, causing intolerable itching.","pos":""}],"COWHEARTED":[{"def":"Cow\"heart`ed (-hrt`d), a.","pos":""}],"COWHERD":[{"def":"One whose occupation is to tend cows.","pos":""}],"COWHIDE":[{"def":"The hide of a cow.","pos":""},{"def":"Leather made of the hide of a cow.","pos":""}],"COWISH":[{"def":"Timorous; fearful; cowardly.","pos":""}],"COWITCH":[{"def":"Cow\"itch (kou\"ch; 224), n.","pos":""}],"COWL":[{"def":"A monk's hood; -- usually attached to the gown.","pos":""},{"def":"A cowl-shaped cap, commonly turning with the wind, used to improve the draft of a chimney, ventilatingshaft, etc.","pos":""}],"COWLED":[{"def":"Wearing a cowl; hooded; as, a cowled monk.","pos":""}],"COWLEECH":[{"def":"One who heals disease of cows; a cow doctor.","pos":""}],"COWLEECHING":[{"def":"Healing the distemper of cows.","pos":""}],"COWLICK":[{"def":"A tuft of hair turned up or awry (usually over the forehead), as if licked by a cow.","pos":""}],"COWLIKE":[{"def":"Resembling a cow.","pos":""}],"COWLSTAFF":[{"def":"A staff or pole on which a vessel is supported between two persons.","pos":""}],"COWORKER":[{"def":"Co`work\"er (k`wrk\"r), n.","pos":""}],"COWPEA":[{"def":"The seed of one or more leguminous plants of the genus Dolichos; also, the plant itself.","pos":""}],"COWPER'S GLANDS":[{"def":"Two small glands discharging into the male urethra.","pos":""}],"COWPOX":[{"def":"A pustular eruptive disease of the cow, which, when communicated to the human system, as by vaccination, protects from the smallpox; vaccinia; -- called also kinepox, cowpock, and kinepock.","pos":""}],"COWQUAKE":[{"def":"A genus of plants (Briza); quaking grass.","pos":""}],"COWRIE":[{"def":"A marine shell of the genus Cypræa.","pos":""}],"COWSLIP":[{"def":"A common flower in England (Primula veris) having yellow blossoms and appearing in early spring.","pos":""},{"def":"In the United States, the marsh marigold (Caltha palustris), appearing in wet places in early spring and often used as a pot herb.","pos":""}],"COWSLIPPED":[{"def":"Adorned with cowslips.","pos":""}],"COWWEED":[{"def":"Same as Cow parsley.","pos":""}],"COWWHEAT":[{"def":"A weed of the genus Melampyrum, with black seeds, found on European wheatfields.","pos":""}]}