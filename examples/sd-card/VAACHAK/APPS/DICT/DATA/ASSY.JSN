{"ASSYRIAN":[{"def":"Of or pertaining to Assyria, or to its inhabitants.","pos":""}],"ASSYRIOLOGICAL":[{"def":"Of or pertaining to Assyriology; as, Assyriological studies.","pos":""}],"ASSYRIOLOGIST":[{"def":"One versed in Assyriology; a student of Assyrian archæology.","pos":""}],"ASSYRIOLOGY":[{"def":"The science or study of the antiquities, language, etc.","pos":""}],"ASSYTHMENT":[{"def":"Indemnification for injury; satisfaction.","pos":""}]}