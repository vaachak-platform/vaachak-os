{"DOW":[{"def":"A kind of vessel.","pos":""}],"DOWABLE":[{"def":"Capable of being endowed; entitled to dower.","pos":""}],"DOWAGER":[{"def":"A widow endowed, or having a jointure; a widow who either enjoys a dower from her deceased husband, or has property of her own brought by her to her husband on marriage, and settled on her after his decease.","pos":""}],"DOWAGERISM":[{"def":"The rank or condition of a dowager; formality, as that of a dowager.","pos":""}],"DOWCET":[{"def":"One of the testicles of a hart or stag.","pos":""}],"DOWDY":[{"def":"Showing a vulgar taste in dress; awkward and slovenly in dress; vulgar-looking.","pos":""}],"DOWEL":[{"def":"A pin, or block, of wood or metal, fitting into holes in the abutting portions of two pieces, and being partly in one piece and partly in the other, to keep them in their proper relative position.","pos":""},{"def":"A piece of wood driven into a wall, so that other pieces may be nailed to it.","pos":""}],"DOWER":[{"def":"That portion of the real estate of a man which his widow enjoys during her life, or to which a woman is entitled after the death of her husband.","pos":""}],"DOWERED":[{"def":"Furnished with, or as with, dower or a marriage portion.","pos":""}],"DOWERLESS":[{"def":"Destitute of dower; having no marriage portion.","pos":""}],"DOWITCHER":[{"def":"The red-breasted or gray snipe (Macrorhamphus griseus); -- called also brownback, and grayback.","pos":""}],"DOWLAS":[{"def":"A coarse linen cloth made in the north of England and in Scotland, now nearly replaced by calico.","pos":""}],"DOWLE":[{"def":"Feathery or wool-like down; filament of a feather.","pos":""}],"DOWN":[{"def":"Fine, soft, hairy outgrowth from the skin or surface of animals or plants, not matted and fleecy like wool; esp.","pos":""},{"def":"That which is made of down, as a bed or pillow; that which affords ease and repose, like a bed of down When in the down I sink my head, Sleep, Death's twin brother, times my breath.","pos":""}],"DOWN-SHARE":[{"def":"A breastplow used in paring off turf on downs.","pos":""}],"DOWNBEAR":[{"def":"To bear down; to depress.","pos":""}],"DOWNCAST":[{"def":"Cast downward; directed to the ground, from bashfulness, modesty, dejection, or guilt.","pos":""}],"DOWNCOME":[{"def":"A pipe for leading combustible gases downward from the top of the blast furnace to the hot-blast stoves, boilers, etc.","pos":""}],"DOWNFALL":[{"def":"A sudden fall; a body of things falling.","pos":""},{"def":"A sudden descent from rank or state, reputation or happiness; destruction; ruin.","pos":""}],"DOWNGYVED":[{"def":"Hanging down like gyves or fetters.","pos":""}],"DOWNHAUL":[{"def":"A rope to haul down, or to assist in hauling down, a sail; as, a staysail downhaul; a trysail downhaul.","pos":""}],"DOWNHEARTED":[{"def":"Dejected; low-spirited.","pos":""}],"DOWNHILL":[{"def":"Towards the bottom of a hill; as, water runs downhill.","pos":""}],"DOWNINESS":[{"def":"The quality or state of being downy.","pos":""}],"DOWNLOOKED":[{"def":"Having a downcast countenance; dejected; gloomy; sullen.","pos":""}],"DOWNLYING":[{"def":"The time of retiring to rest; time of repose.","pos":""}],"DOWNPOUR":[{"def":"A pouring or streaming downwards; esp.","pos":""}],"DOWNRIGHT":[{"def":"Straight down; perpendicularly.","pos":""},{"def":"In plain terms; without ceremony.","pos":""}],"DOWNSITTING":[{"def":"The act of sitting down; repose; a resting.","pos":""}],"DOWNSTAIRS":[{"def":"Down the stairs; to a lower floor.","pos":""},{"def":"Below stairs; as, a downstairs room.","pos":""}],"DOWNSTREAM":[{"def":"Down the stream; as, floating downstream.","pos":""}],"DOWNSTROKE":[{"def":"A stroke made with a downward motion of the pen or pencil.","pos":""}],"DOWNTHROW":[{"def":"The sudden drop or depression of the strata of rocks on one side of a fault.","pos":""},{"def":"Trodden down; trampled down; abused by superior power.","pos":""}],"DOWNWARD":[{"def":"Moving or extending from a higher to a lower place; tending toward the earth or its center, or toward a lower level; declivous.","pos":""},{"def":"Descending from a head, origin, or source; as, a downward line of descent.","pos":""}],"DOWNWEED":[{"def":"Cudweed, a species of Gnaphalium.","pos":""}],"DOWNWEIGH":[{"def":"To weigh or press down.","pos":""}],"DOWNY":[{"def":"Covered with down, or with pubescence or soft hairs.","pos":""},{"def":"Made of, or resembling, down.","pos":""}],"DOWRAL":[{"def":"Of or relating to a dower.","pos":""}],"DOWRESS":[{"def":"A woman entitled to dower.","pos":""}],"DOWRY":[{"def":"A gift; endowment.","pos":""},{"def":"The money, goods, or estate, which a woman brings to her husband in marriage; a bride's portion on her marriage.","pos":""}],"DOWSE":[{"def":"To beat or thrash.","pos":""}],"DOWSER":[{"def":"A divining rod used in searching for water, ore, etc.","pos":""},{"def":"One who uses the dowser or divining rod.","pos":""}]}