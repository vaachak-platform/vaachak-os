{"NAUFRAGE":[{"def":"Shipwreck; ruin.","pos":""}],"NAUFRAGOUS":[{"def":"causing shipwreck.","pos":""}],"NAUGHT":[{"def":"The arithmetical character 0; a cipher.","pos":""}],"NAUGHTILY":[{"def":"In a naughty manner; wickedly; perversely.","pos":""}],"NAUGHTINESS":[{"def":"The quality or state of being naughty; perverseness; badness; wickedness.","pos":""}],"NAUGHTLY":[{"def":"Naughtily; wrongly.","pos":""}],"NAUGHTY":[{"def":"Having little or nothing.","pos":""},{"def":"Worthless; bad; good for nothing.","pos":""}],"NAUMACHY":[{"def":"A show or spectacle representing a sea fight; also, a place for such exhibitions.","pos":""}],"NAUPLIUS":[{"def":"A crustacean larva having three pairs of locomotive organs (corresponding to the antennules, antennæ, and mandibles), a median eye, and little or no segmentation of the body.","pos":""}],"NAUROPOMETER":[{"def":"An instrument for measuring the amount which a ship heels at sea.","pos":""}],"NAUSCOPY":[{"def":"The power or act of discovering ships or land at considerable distances.","pos":""}],"NAUSEA":[{"def":"Seasickness; hence, any similar sickness of the stomach accompanied with a propensity to vomit; qualm; squeamishness of the stomach; loathing.","pos":""}],"NAUSEANT":[{"def":"A substance which produces nausea.","pos":""}],"NAUSEATE":[{"def":"To become squeamish; to feel nausea; to turn away with disgust.","pos":""}],"NAUSEATION":[{"def":"The act of nauseating, or the state of being nauseated.","pos":""}],"NAUSEATIVE":[{"def":"Causing nausea; nauseous.","pos":""}],"NAUSEOUS":[{"def":"Causing, or fitted to cause, nausea; sickening; loathsome; disgusting; exciting abhorrence; as, a nauseous drug or medicine.","pos":""}],"NAUTCH":[{"def":"An entertainment consisting chiefly of dancing by professional dancing (or Nautch) girls.","pos":""}],"NAUTICAL":[{"def":"Of or pertaining to seamen, to the art of navigation, or to ships; as, nautical skill.","pos":""}],"NAUTICALLY":[{"def":"In a nautical manner; with reference to nautical affais.","pos":""}],"NAUTIFORM":[{"def":"Shaped like the hull of a ship.","pos":""}],"NAUTILITE":[{"def":"A fossil nautilus.","pos":""}],"NAUTILOID":[{"def":"Like or pertaining to the nautilus; shaped like a nautilus shell.","pos":""},{"def":"A mollusk, or shell, of the genus Nautilus or family Nautilidæ.","pos":""}],"NAUTILUS":[{"def":"The only existing genus of tetrabranchiate cephalopods.","pos":""}]}