{"CARMAGNOLE":[{"def":"A popular or Red Rebublican song and dance, of the time of the first French Revolution.","pos":""},{"def":"A bombastic report from the French armies.","pos":""}],"CARMAN":[{"def":"A man whose employment is to drive, or to convey goods in, a car or car.","pos":""},{"def":"Of or pertaining to the order of Carmelites.","pos":""}],"CARMELITE":[{"def":"A friar of a mendicant order (the Order of Our Lady of Mount Carmel) established on Mount Carmel, in Syria, in the twelfth century; a White Friar.","pos":""}],"CARMINATED":[{"def":"Of, relating to, or mixed with, carmine; as, carminated lake.","pos":""}],"CARMINATIVE":[{"def":"Expelling wind from the body; warning; antispasmodic.","pos":""}],"CARMINE":[{"def":"The essential coloring principle of cochineal, extracted as a purple-red amorphous mass.","pos":""}],"CARMINIC":[{"def":"Of or pertaining to, or derived from, carmine.","pos":""}],"CARMOT":[{"def":"The matter of which the philosopher's stone was believed to be composed.","pos":""}]}