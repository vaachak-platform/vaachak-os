{"IMMACULATE":[{"def":"Without stain or blemish; spotless; undefiled; clear; pure.","pos":""}],"IMMAILED":[{"def":"Wearing mail or armor; clad of armor.","pos":""}],"IMMANACLE":[{"def":"To manacle; to fetter; hence; to confine; to restrain from free action.","pos":""}],"IMMANATION":[{"def":"A flowing or entering in; -- opposed to emanation.","pos":""}],"IMMANE":[{"def":"Very great; huge; vast; also, monstrous in character; inhuman; atrocious; fierce.","pos":""},{"def":"The condition or quality of being immanent; inherence; an indwelling.","pos":""}],"IMMANENT":[{"def":"Remaining within; inherent; indwelling; abiding; intrinsic; internal or subjective; hence, limited in activity, agency, or effect, to the subject or associated acts; -- opposed to emanant, transitory, transitive, or objective.","pos":""}],"IMMANITY":[{"def":"The state or quality of being immane; barbarity.","pos":""}],"IMMANUEL":[{"def":"God with us; -- an appellation of the Christ.","pos":""}],"IMMARCESCIBLE":[{"def":"Unfading; lasting.","pos":""}],"IMMARCESCIBLY":[{"def":"Im`mar*ces\"ci*bly, adv.","pos":""}],"IMMARGINATE":[{"def":"Not having a distinctive margin or border.","pos":""}],"IMMARTIAL":[{"def":"Not martial; unwarlike.","pos":""}],"IMMASK":[{"def":"To cover, as with a mask; to disguise or conceal.","pos":""}],"IMMATCHABLE":[{"def":"Matchless; peerless.","pos":""}],"IMMATERIAL":[{"def":"Not consisting of matter; incorporeal; spiritual; disembodied.","pos":""},{"def":"Of no substantial consequence; without weight or significance; unimportant; as, it is wholly immaterial whether he does so or not.","pos":""}],"IMMATERIALISM":[{"def":"The doctrine that external bodies may be reduced to mind and ideas in a mind; any doctrine opposed to materialism or phenomenalism, esp.","pos":""}],"IMMATERIALIST":[{"def":"One who believes in or professes, immaterialism.","pos":""}],"IMMATERIALITY":[{"def":"The state or quality of being immaterial or incorporeal; as, the immateriality of the soul.","pos":""}],"IMMATERIALIZE":[{"def":"To render immaterial or incorporeal.","pos":""}],"IMMATERIALLY":[{"def":"In an immaterial manner; without matter or corporeal substance.","pos":""},{"def":"In an unimportant manner or degree.","pos":""}],"IMMATERIALNESS":[{"def":"The state or quality of being immaterial; immateriality.","pos":""}],"IMMATURE":[{"def":"Not mature; unripe; not arrived at perfection of full development; crude; unfinished; as, immature fruit; immature character; immature plans.","pos":""},{"def":"Premature; untimely; too early; as, an immature death.","pos":""}],"IMMATURELY":[{"def":"In an immature manner.","pos":""}],"IMMATURENESS":[{"def":"The state or quality of being immature; immaturity.","pos":""}],"IMMATURITY":[{"def":"The state or quality of being immature or not fully developed; unripeness; incompleteness.","pos":""}],"IMMEABILITY":[{"def":"Want of power to pass, or to permit passage; impassableness.","pos":""}],"IMMEASURABILITY":[{"def":"The quality of being immeasurable; immensurability.","pos":""}],"IMMEASURABLE":[{"def":"Incapble of being measured; indefinitely extensive; illimitable; immensurable; vast.","pos":""}],"IMMEASURABLENESS":[{"def":"The state or quality of being immeasurable.","pos":""}],"IMMEASURABLY":[{"def":"In an immeasurable manner or degree.","pos":""}],"IMMEDIACY":[{"def":"The relation of freedom from the interventionof a medium; immediateness.","pos":""}],"IMMEDIATE":[{"def":"Not separated in respect to place by anything intervening; proximate; close; as, immediate contact.","pos":""},{"def":"Not deferred by an interval of time; present; instant.","pos":""}],"IMMEDIATELY":[{"def":"In an immediate manner; without intervention of any other person or thing; proximately; directly; -- opposed to mediately; as, immediately contiguous.","pos":""},{"def":"Without interval of time; without delay; promptly; instantly; at once.","pos":""}],"IMMEDIATENESS":[{"def":"The quality or relations of being immediate in manner, place, or time; exemption from second or interventing causes.","pos":""}],"IMMEDICABLE":[{"def":"Not to be healed; incurable.","pos":""}],"IMMEMORABLE":[{"def":"Not memorable; not worth remembering.","pos":""}],"IMMEMORIAL":[{"def":"Extending beyond the reach of memory, record, or tradition; indefinitely ancient; as, existing from time immemorial.","pos":""}],"IMMEMORIALLY":[{"def":"Im`me*mo\"ri*al*ly, adv.","pos":""}],"IMMENSE":[{"def":"Immeasurable; unlimited.","pos":""}],"IMMENSELY":[{"def":"In immense manner or degree.","pos":""}],"IMMENSENESS":[{"def":"The state of being immense.","pos":""}],"IMMENSITY":[{"def":"The state or quality of being immense; inlimited or immeasurable extension; infinity; vastness in extent or bulk; greatness.","pos":""}],"IMMENSURABILITY":[{"def":"The quality of being immensurable.","pos":""}],"IMMENSURABLE":[{"def":"What an immensurable space is the firmament.","pos":""}],"IMMENSURATE":[{"def":"Unmeasured; unlimited.","pos":""}],"IMMERGE":[{"def":"To plungel into, under, or within anything especially a fuid; to dip; to immerse.","pos":""}],"IMMERIT":[{"def":"Want of worth; demerit.","pos":""}],"IMMERSE":[{"def":"Immersed; buried; hid; sunk.","pos":""}],"IMMERSED":[{"def":"Growing wholly under water.","pos":""}],"IMMERSIBLE":[{"def":"Capable of being immersed.","pos":""}],"IMMERSION":[{"def":"The dissapearance of a celestail body, by passing either behind another, as in the occultation of a star, or into its shadow, as in the eclipse of a satellite; -- opposed to emersion.","pos":""}],"IMMERSIONIST":[{"def":"One who holds the doctrine that immersion is essential to Christian baptism.","pos":""}],"IMMESH":[{"def":"To catch or entangle in, or as in, the meshes of a net.","pos":""}],"IMMETHODICAL":[{"def":"Not methodical; without method or systematic arrangement; without order or regularity; confused.","pos":""}],"IMMETHODICALLY":[{"def":"Without method; confusedly; unsystematically.","pos":""}],"IMMETHODICALNESS":[{"def":"Im`me*thod\"ic*al*ness, n.","pos":""}],"IMMETHODIZE":[{"def":"To render immethodical; to destroy the method of; to confuse.","pos":""}],"IMMETRICAL":[{"def":"Not metrical or rhythmical.","pos":""}],"IMMIGRANT":[{"def":"One who immigrates; one who comes to a country for the purpose of permanent residence; -- correlative of emigrant.","pos":""}],"IMMIGRATE":[{"def":"To come into a country of which one is not a native, for the purpose of permanent residence.","pos":""}],"IMMIGRATION":[{"def":"The act of immigrating; the passing or coming into a country for the purpose of permanent residence.","pos":""}],"IMMINENCE":[{"def":"The condition or quality of being imminent; a threatening, as of something about to happen.","pos":""},{"def":"That which is imminent; impending evil or danger.","pos":""}],"IMMINENT":[{"def":"Threatening to occur immediately; near at hand; impending; -- said especially of misfortune or peril.","pos":""},{"def":"Full of danger; threatening; menacing; perilous.","pos":""}],"IMMINENTLY":[{"def":"In an imminent manner.","pos":""}],"IMMINGLE":[{"def":"To mingle; to mix; to unite; to blend.","pos":""}],"IMMINUTION":[{"def":"A lessening; diminution; decrease.","pos":""}],"IMMISCIBILITY":[{"def":"Incapability of being mixed, or mingled.","pos":""}],"IMMISCIBLE":[{"def":"Not capable of being mixed or mingled.","pos":""}],"IMMISSION":[{"def":"The act of immitting, or of sending or thrusting in; injection; -- the correlative of emission.","pos":""}],"IMMIT":[{"def":"To send in; to inject; to infuse; -- the correlative of emit.","pos":""}],"IMMITIGABLE":[{"def":"Not capable of being mitigated, softened, or appeased.","pos":""}],"IMMITIGABLY":[{"def":"In an immitigable manner.","pos":""}],"IMMIX":[{"def":"To mix; to mingle.","pos":""}],"IMMIXED":[{"def":"How pure and immixed the design is.","pos":""}],"IMMIXTURE":[{"def":"Freedom from mixture; purity.","pos":""}],"IMMOBILE":[{"def":"Incapable of being moved; immovable; fixed; stable.","pos":""}],"IMMOBILITY":[{"def":"The condition or quality of being immobile; fixedness in place or state.","pos":""}],"IMMOBILIZE":[{"def":"To make immovable; in surgery, to make immovable (a naturally mobile part, as a joint) by the use of splints, or stiffened bandages.","pos":""}],"IMMODERANCY":[{"def":"Immoderateness; excess.","pos":""}],"IMMODERATE":[{"def":"Not moderate; exceeding just or usual and suitable bounds; excessive; extravagant; unreasonable; as, immoderate demands; immoderate grief; immoderate laughter.","pos":""}],"IMMODERATELY":[{"def":"In an immoderate manner; excessively.","pos":""}],"IMMODERATENESS":[{"def":"The quality of being immoderate; excess; extravagance.","pos":""}],"IMMODERATION":[{"def":"Want of moderation.","pos":""}],"IMMODEST":[{"def":"Not limited to due bounds; immoderate.","pos":""},{"def":"Not modest; wanting in the reserve or restraint which decorum and decency require; indecent; indelicate; obscene; lewd; as, immodest persons, behavior, words, pictures, etc.","pos":""}],"IMMODESTLY":[{"def":"In an immodest manner.","pos":""}],"IMMODESTY":[{"def":"Want of modesty, delicacy, or decent reserve; indecency.","pos":""}],"IMMOLATE":[{"def":"To sacrifice; to offer in sacrifice; to kill, as a sacrificial victim.","pos":""}],"IMMOLATION":[{"def":"The act of immolating, or the state of being immolated, or sacrificed.","pos":""},{"def":"That which is immolated; a sacrifice.","pos":""}],"IMMOLATOR":[{"def":"One who offers in sacrifice; specifically, one of a sect of Russian fanatics who practice self-mutilatio and sacrifice.","pos":""},{"def":"To mold into shape, or form.","pos":""}],"IMMOMENTOUS":[{"def":"Not momentous; unimportant; insignificant.","pos":""}],"IMMORAL":[{"def":"Not moral; inconsistent with rectitude, purity, or good morals; contrary to conscience or the divine law; wicked; unjust; dishonest; vicious; licentious; as, an immoral man; an immoral deed.","pos":""}],"IMMORALITY":[{"def":"The state or quality of being immoral; vice.","pos":""},{"def":"An immoral act or practice.","pos":""}],"IMMORALLY":[{"def":"In an immoral manner; wickedly.","pos":""}],"IMMORIGEROUS":[{"def":"Rude; uncivil; disobedient.","pos":""}],"IMMORTAL":[{"def":"Not mortal; exempt from liability to die; undying; imperishable; lasting forever; having unlimited, or eternal, existance.","pos":""},{"def":"Connected with, or pertaining to immortability.","pos":""}],"IMMORTALIST":[{"def":"One who holds the doctrine of the immortality of the soul.","pos":""}],"IMMORTALITY":[{"def":"The quality or state of being immortal; exemption from death and annihilation; unending existance; as, the immortality of the soul.","pos":""},{"def":"Exemption from oblivion; perpetuity; as, the immortality of fame.","pos":""}],"IMMORTALIZATION":[{"def":"The act of immortalizing, or state of being immortalized.","pos":""}],"IMMORTALIZE":[{"def":"To render immortal; to cause to live or exist forever.","pos":""},{"def":"To exempt from oblivion; to perpetuate in fame.","pos":""}],"IMMORTALLY":[{"def":"In an immortal manner.","pos":""}],"IMMORTELLE":[{"def":"A plant with a conspicuous, dry, unwithering involucre, as the species of Antennaria, Helichrysum, Gomphrena, etc.","pos":""}],"IMMORTIFICATION":[{"def":"Failure to mortify the passions.","pos":""}],"IMMOVABILITY":[{"def":"The quality or state of being immovable; fixedness; steadfastness; as, immovability of a heavy body; immovability of purpose.","pos":""}],"IMMOVABLE":[{"def":"Not liable to be removed; permanent in place or tenure; fixed; as, an immovable estate.","pos":""}],"IMMOVABLENESS":[{"def":"Quality of being immovable.","pos":""}],"IMMOVABLY":[{"def":"In an immovable manner.","pos":""}],"IMMUNDICITY":[{"def":"Uncleanness; filthness.","pos":""}],"IMMUNE":[{"def":"Exempt; protected by inoculation.","pos":""}],"IMMUNITY":[{"def":"Freedom or exemption from any charge, duty, obligation, office, tax, imposition, penalty, or service; a particular privilege; as, the immunities of the free cities of Germany; the immunities of the clergy.","pos":""},{"def":"Freedom; exemption; as, immunity from error.","pos":""}],"IMMURE":[{"def":"To wall around; to surround with walls.","pos":""},{"def":"To inclose whithin walls, or as within walls; hence, to shut up; to imprison; to incarcerate.","pos":""}],"IMMUREMENT":[{"def":"The act iif immuring, or the state of being immured; imprsonment.","pos":""}],"IMMUSICAL":[{"def":"Inharmonious; unmusical; discordant.","pos":""}],"IMMUTABILITY":[{"def":"The state or quality of being immutable; immutableness.","pos":""}],"IMMUTABLE":[{"def":"Not mutable; not capable or susceptible of change; unchangeable; unalterable.","pos":""}],"IMMUTATION":[{"def":"Change; alteration; mutation.","pos":""}],"IMMUTE":[{"def":"To change or alter.","pos":""}]}