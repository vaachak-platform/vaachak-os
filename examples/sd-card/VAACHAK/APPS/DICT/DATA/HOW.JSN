{"HOW":[{"def":"In what manner or way; by what means or process.","pos":""},{"def":"To what degree or extent, number or amount; in what proportion; by what measure or quality.","pos":""}],"HOWADJI":[{"def":"A merchant; -- so called in the East because merchants were formerly the chief travelers.","pos":""}],"HOWBEIT":[{"def":"Be it as it may; nevertheless; notwithstanding; although; albeit; yet; but; however.","pos":""}],"HOWDAH":[{"def":"A seat or pavilion, generally covered, fastened on the back of an elephant, for the rider or riders.","pos":""}],"HOWEL":[{"def":"A tool used by coopers for smoothing and chamfering rheir work, especially the inside of casks.","pos":""}],"HOWELL":[{"def":"The upper stage of a porcelian furnace.","pos":""}],"HOWEVER":[{"def":"In whetever manner, way, or degree.","pos":""},{"def":"At all events; at least; in any case.","pos":""}],"HOWL":[{"def":"To utter a loud, protraced, mournful sound or cry, as dogs and wolves often do.","pos":""},{"def":"To utter a sound expressive of distress; to cry aloud and mournfully; to lament; to wail.","pos":""}],"HOWLER":[{"def":"Any South American monkey of the genus Mycetes.","pos":""}],"HOWLET":[{"def":"An owl; an owlet.","pos":""}],"HOWP":[{"def":"To cry out; to whoop.","pos":""}],"HOWSOEVER":[{"def":"In what manner soever; to whatever degree or extent; however.","pos":""},{"def":"Although; though; however.","pos":""}]}