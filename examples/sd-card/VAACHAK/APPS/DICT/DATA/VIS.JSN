{"VIS MAJOR":[{"def":"A superior force which under certain circumstances is held to exempt from contract obligations; inevitable accident; -- a civil-law term used as nearly equivalent to, but broader than, the common-law term act of God (which see).","pos":""}],"VIS-A-VIS":[{"def":"One who, or that which, is face to face with another; esp.","pos":""},{"def":"A carriage in which two persons sit face to face.","pos":""}],"VISA":[{"def":"To indorse, after examination, with the word visé, as a passport; to visé.","pos":""}],"VISAGE":[{"def":"The face, countenance, or look of a person or an animal; -- chiefly applied to the human face.","pos":""}],"VISAGED":[{"def":"Having a visage.","pos":""}],"VISAYAN":[{"def":"A member of the most numerous of the native races of the Philippines, occupying the Visayan Islands and the northern coast Mindanao; also, their language.","pos":""},{"def":"A large burrowing South American rodent (Lagostomus trichodactylus) allied to the chinchillas, but much larger.","pos":""}],"VISCERAL":[{"def":"Of or pertaining to the viscera; splanchnic.","pos":""}],"VISCERATE":[{"def":"To deprive of the viscera, or entrails; to eviscerate; to disembowel.","pos":""}],"VISCEROSKELETAL":[{"def":"Of or pertaining to the framework, or skeleton, or skeleton, of the viscera; as, the visceroskeletal system of muscles.","pos":""}],"VISCID":[{"def":"Sticking or adhering, and having a ropy or glutinous consistency; viscous; glutinous; sticky; tenacious; clammy; as, turpentine, tar, gums, etc.","pos":""}],"VISCIDITY":[{"def":"The quality or state of being viscid; also, that which is viscid; glutinous concretion; stickiness.","pos":""}],"VISCIN":[{"def":"A clear, viscous, tasteless substance extracted from the mucilaginous sap of the mistletoe (Viscum album), holly, etc.","pos":""}],"VISCOIDAL":[{"def":"Somewhat viscous.","pos":""}],"VISCOSIMETER":[{"def":"An instrument for measuring the degree of viscosity of liquids, as solutions of gum.","pos":""}],"VISCOSITY":[{"def":"A quality analogous to that of a viscous fluid, supposed to be caused by internal friction, especially in the case of gases.","pos":""}],"VISCOUNT":[{"def":"An officer who formerly supplied the place of the count, or earl; the sheriff of the county.","pos":""}],"VISCOUNTCY":[{"def":"The dignity or jurisdiction of a viscount.","pos":""}],"VISCOUNTESS":[{"def":"The wife of a viscount.","pos":""},{"def":"The quality, rank, or office of a viscount.","pos":""}],"VISCOUS":[{"def":"Adhesive or sticky, and having a ropy or glutinous consistency; viscid; glutinous; clammy; tenacious; as, a viscous juice.","pos":""}],"VISCUM":[{"def":"A genus of parasitic shrubs, including the mistletoe of Europe.","pos":""}],"VISCUS":[{"def":"One of the organs, as the brain, heart, or stomach, in the great cavities of the body of an animal; -- especially used in the plural, and applied to the organs contained in the abdomen.","pos":""}],"VISE":[{"def":"An instrument consisting of two jaws, closing by a screw, lever, cam, or the like, for holding work, as in filing.","pos":""}],"VISHNU":[{"def":"A divinity of the modern Hindoo trimurti, or trinity.","pos":""}],"VISIBILITY":[{"def":"The quality or state of being visible.","pos":""}],"VISIBLE":[{"def":"Perceivable by the eye; capable of being seen; perceptible; in view; as, a visible star; the least spot is visible on white paper.","pos":""},{"def":"Noticeable; apparent; open; conspicuous.","pos":""}],"VISIBLE SPEECH":[{"def":"A system of characters invented by Prof.","pos":""}],"VISIGOTH":[{"def":"One of the West Goths.","pos":""}],"VISION":[{"def":"The faculty of seeing; sight; one of the five senses, by which colors and the physical qualities of external objects are appreciated as a result of the stimulating action of light on the sensitive retina, an expansion of the optic nerve.","pos":""}],"VISIONAL":[{"def":"Of or pertaining to a vision.","pos":""}],"VISIONARINESS":[{"def":"The quality or state of being visionary.","pos":""}],"VISIONARY":[{"def":"Of or pertaining to a visions or visions; characterized by, appropriate to, or favorable for, visions.","pos":""},{"def":"Affected by phantoms; disposed to receive impressions on the imagination; given to reverie; apt to receive, and act upon, fancies as if they were realities.","pos":""}],"VISIONED":[{"def":"Having the power of seeing visions; inspired; also, seen in visions.","pos":""}],"VISIONLESS":[{"def":"Destitute of vision; sightless.","pos":""}],"VISIT":[{"def":"To come to for the purpose of chastising, rewarding, comforting; to come upon with reward or retribution; to appear before or judge; as, to visit in mercy; to visit one in wrath.","pos":""}],"VISITABLE":[{"def":"Liable or subject to be visited or inspected.","pos":""}],"VISITANT":[{"def":"One who visits; a guest; a visitor.","pos":""}],"VISITATION":[{"def":"The act of a naval commander who visits, or enters on board, a vessel belonging to another nation, for the purpose of ascertaining her character and object, but without claiming or exercising a right of searching the vessel.","pos":""},{"def":"A festival in honor of the visit of the Virgin Mary to Elisabeth, mother of John the Baptist, celebrated on the second of July.","pos":""}],"VISITATORIAL":[{"def":"Of or pertaining to visitation, or a judicial visitor or superintendent; visitorial.","pos":""}],"VISITE":[{"def":"A light cape or short cloak of silk or lace worn by women in summer.","pos":""}],"VISITING":[{"def":"Vis\"it*ing, Defn: a.","pos":""}],"VISITOR":[{"def":"One who visits; one who comes or goes to see another, as in civility or friendship.","pos":""},{"def":"A superior, or a person lawfully appointed for the purpose, who makes formal visits of inspection to a corporation or an institution.","pos":""}],"VISITORIAL":[{"def":"Same as Visitatorial.","pos":""}],"VISIVE":[{"def":"Of or pertaining to the sight; visual.","pos":""}],"VISNE":[{"def":"Neighborhood; vicinity; venue.","pos":""}],"VISNOMY":[{"def":"Face; countenance.","pos":""}],"VISOR":[{"def":"A part of a helmet, arranged so as to lift or open, and so show the face.","pos":""},{"def":"A mask used to disfigure or disguise.","pos":""}],"VISORED":[{"def":"Wearing a visor; masked.","pos":""}],"VISTA":[{"def":"A view; especially, a view through or between intervening objects, as trees; a view or prospect through an avenue, or the like; hence, the trees or other objects that form the avenue.","pos":""}],"VISTO":[{"def":"A vista; a prospect.","pos":""}],"VISUAL":[{"def":"Of or pertaining to sight; used in sight; serving as the instrument of seeing; as, the visual nerve.","pos":""},{"def":"That can be seen; visible.","pos":""}],"VISUALIZE":[{"def":"To make visual, or visible; to see in fancy.","pos":""}],"VISUALIZER":[{"def":"One who visualizes or is proficient in visualization; esp.","pos":""},{"def":"one whose mental imagery is prevailingly visualization.","pos":""}]}