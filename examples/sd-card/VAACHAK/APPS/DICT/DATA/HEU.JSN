{"HEUGH":[{"def":"A crag; a cliff; a glen with overhanging sides.","pos":""},{"def":"A shaft in a coal pit; a hollow in a quarry.","pos":""}],"HEUK":[{"def":"Variant of Huke.","pos":""}],"HEULANDITE":[{"def":"A mineral of the Zeolite family, often occurring in amygdaloid, in foliated masses, and also in monoclinic crystals with pearly luster on the cleavage face.","pos":""}],"HEURISTIC":[{"def":"Serving to discover or find out.","pos":""}]}