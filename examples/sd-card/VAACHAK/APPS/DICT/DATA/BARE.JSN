{"BARE":[{"def":"Without clothes or covering; stripped of the usual covering; naked; as, his body is bare; the trees are bare.","pos":""},{"def":"With head uncovered; bareheaded.","pos":""}],"BAREBACK":[{"def":"On the bare back of a horse, without using a saddle; as, to ride bareback.","pos":""}],"BAREBACKED":[{"def":"Having the back uncovered; as, a barebacked horse.","pos":""}],"BAREBONE":[{"def":"A very lean person; one whose bones show through the skin.","pos":""}],"BAREFACED":[{"def":"With the face uncovered; not masked.","pos":""},{"def":"Without concealment; undisguised.","pos":""}],"BAREFACEDLY":[{"def":"Openly; shamelessly.","pos":""}],"BAREFACEDNESS":[{"def":"The quality of being barefaced; shamelessness; assurance; audaciousness.","pos":""}],"BAREFOOT":[{"def":"With the feet bare; without shoes or stockings.","pos":""}],"BAREFOOTED":[{"def":"Having the feet bare.","pos":""}],"BAREGE":[{"def":"A gauzelike fabric for ladies' dresses, veils, etc.","pos":""}],"BAREHANDED":[{"def":"Having bare hands.","pos":""},{"def":"Having the head uncovered; as, a bareheaded girl.","pos":""}],"BARELEGGED":[{"def":"Having the legs bare.","pos":""}],"BARELY":[{"def":"Without covering; nakedly.","pos":""},{"def":"Without concealment or disguise.","pos":""}],"BARENECKED":[{"def":"Having the neck bare.","pos":""}],"BARENESS":[{"def":"The state of being bare.","pos":""}],"BARESARK":[{"def":"A Berserker, or Norse warrior who fought without armor, or shirt of mail.","pos":""}]}