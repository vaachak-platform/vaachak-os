{"YACARE":[{"def":"A South American crocodilian (Jacare sclerops) resembling the alligator in size and habits.","pos":""}],"YACCA":[{"def":"A West Indian name for two large timber trees (Podocarpus coriaceus, and P.","pos":""}],"YACHT":[{"def":"A light and elegantly furnished vessel, used either for private parties of pleasure, or as a vessel of state to convey distinguished persons from one place to another; a seagoing vessel used only for pleasure trips, racing, etc.","pos":""}],"YACHTER":[{"def":"One engaged in sailing a jacht.","pos":""}],"YACHTING":[{"def":"Sailing for pleasure in a yacht.","pos":""}],"YACHTSMAN":[{"def":"One who owns or sails a yacht; a yachter.","pos":""}],"YAFFLE":[{"def":"The European green woodpecker (Picus, or Genius, viridis).","pos":""}],"YAGER":[{"def":"In the German army, one belonging to a body of light infantry armed with rifles, resembling the chasseur of the French army.","pos":""}],"YAGUARUNDI":[{"def":"Same as Jaguarondi.","pos":""}],"YAHOO":[{"def":"A modern transliteration of the Hebrew word translated Jehovah in the Bible; -- used by some critics to discriminate the tribal god of the ancient Hebrews from the Christian Jehovah.","pos":""},{"def":"The author of the passages of the Old Testament, esp.","pos":""}],"YAK":[{"def":"A bovine mammal (Poëphagus grunnies) native of the high plains of Central Asia.","pos":""}],"YAKAMILK":[{"def":"See Trumpeter, 3 (a).","pos":""}],"YAKIN":[{"def":"A large Asiatic antelope (Budorcas taxicolor) native of the higher parts of the Himalayas and other lofty mountains.","pos":""}],"YAKSHA":[{"def":"A kind of demigod attendant on Kuvera, the god of wealth.","pos":""}],"YAKUT":[{"def":"The Turkish language of the Yakuts, a Mongolian people of northeastern Siberia, which is lingua franca over much of eastern Siberia.","pos":""}],"YALAH":[{"def":"The oil of the mahwa tree.","pos":""}],"YAM":[{"def":"A large, esculent, farinaceous tuber of various climbing plants of the genus Dioscorea; also, the plants themselves.","pos":""}],"YAMA":[{"def":"The king of the infernal regions, corresponding to the Greek Pluto, and also the judge of departed souls.","pos":""}],"YAMEN":[{"def":"In China, the official headquarters or residence of a mandarin, including court rooms, offices, gardens, prisons, etc.","pos":""}],"YAMP":[{"def":"An umbelliferous plant (Carum Gairdneri); also, its small fleshy roots, which are eaten by the Indians from Idaho to California.","pos":""}],"YANG":[{"def":"The cry of the wild goose; a honk.","pos":""}],"YANK":[{"def":"A jerk or twitch.","pos":""}],"YANKEE":[{"def":"A nickname for a native of citizen of New England, especially one descended from old New England stock; by extension, an inhabitant of the Northern States as distinguished from a Southerner; also, applied sometimes by foreigners to any inhabitant of the United States.","pos":""}],"YANKEE-DOODLE":[{"def":"The name of a tune adopted popularly as one of the national airs of the United States.","pos":""},{"def":"Humorously, a Yankee.","pos":""}],"YANKEEISM":[{"def":"A Yankee idiom, word, custom, or the like.","pos":""}],"YAOURT":[{"def":"A fermented drink, or milk beer, made by the Turks.","pos":""}],"YAP":[{"def":"To bark; to yelp.","pos":""}],"YAPOCK":[{"def":"A South American aquatic opossum (Chironectes variegatus) found in Guiana and Brazil.","pos":""}],"YARAGE":[{"def":"The power of moving, or being managed, at sea; -- said with reference to a ship.","pos":""}],"YARD":[{"def":"A long piece of timber, nearly cylindrical, tapering toward the ends, and designed to support and extend a square sail.","pos":""}],"YARDARM":[{"def":"Either half of a square-rigged vessel's yard, from the center or mast to the end.","pos":""}],"YARDFUL":[{"def":"As much as a yard will contain; enough to fill a yard.","pos":""}],"YARDLAND":[{"def":"A measure of land of uncertain quantity, varying from fifteen to forty acres; a virgate.","pos":""}],"YARDSTICK":[{"def":"A stick three feet, or a yard, in length, used as a measure of cloth, etc.","pos":""}],"YARE":[{"def":"Ready; dexterous; eager; lively; quick to move.","pos":""}],"YARELY":[{"def":"In a yare manner.","pos":""}],"YARN":[{"def":"One of the threads of which the strands of a rope are composed.","pos":""}],"YARNEN":[{"def":"Made of yarn; consisting of yarn.","pos":""}],"YARR":[{"def":"To growl or snarl as a dog.","pos":""}],"YARRISH":[{"def":"Having a rough, dry taste.","pos":""}],"YARROW":[{"def":"An American and European composite plant (Achillea Millefolium) with very finely dissected leaves and small white corymbed flowers.","pos":""}],"YARWHIP":[{"def":"The European bar-tailed godwit; -- called also yardkeep, and yarwhelp.","pos":""}],"YATAGHAN":[{"def":"A long knife, or short saber, common among Mohammedan nations, usually having a double curve, sometimes nearly straight.","pos":""}],"YAUP":[{"def":"To cry out like a child; to yelp.","pos":""}],"YAUPER":[{"def":"One who, or that which, yaups.","pos":""}],"YAUPON":[{"def":"A shrub (Ilex Cassine) of the Holly family, native from Virginia to Florida.","pos":""}],"YAUTIA":[{"def":"In Porto Rico, any of several araceous plants or their starchy edible roots, which are cooked and eaten like yams or potatoes, as the taro.","pos":""}],"YAW":[{"def":"To rise in blisters, breaking in white froth, as cane juice in the clarifiers in sugar works.","pos":""}],"YAW-WEED":[{"def":"A low, shrubby, rubiaceous plant (Morinda Royoc) growing along the seacoast of the West Indies.","pos":""}],"YAWD":[{"def":"A jade; an old horse or mare.","pos":""}],"YAWI":[{"def":"A fore-and-aft-rigged vessel with a mainmast stepped a little farther forward than in a sloop and carrying a mainsail and jibs, with a jigger mast far aft, usually placed abaft the rudder post.","pos":""}],"YAWL":[{"def":"A small ship's boat, usually rowed by four or six oars.","pos":""}],"YAWL-RIGGED":[{"def":"Having two masts with fore-and-aft sails, but differing from a schooner in that the after mast is very small, and stepped as far aft as possible.","pos":""}],"YAWN":[{"def":"To open the mouth involuntarily through drowsiness, dullness, or fatigue; to gape; to oscitate.","pos":""},{"def":"To open wide; to gape, as if to allow the entrance or exit of anything.","pos":""}],"YAWNINGLY":[{"def":"In a yawning manner.","pos":""}],"YAWS":[{"def":"A disease, occurring in the Antilles and in Africa, characterized by yellowish or reddish tumors, of a contagious character, which, in shape and appearance, often resemble currants, strawberries, or raspberries.","pos":""}],"YAZOO FRAUD":[{"def":"The grant by the State of Georgia, by Act of Jan.","pos":""}]}