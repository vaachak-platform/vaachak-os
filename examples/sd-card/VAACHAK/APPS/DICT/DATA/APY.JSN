{"APYRETIC":[{"def":"Without fever; -- applied to days when there is an intermission of fever.","pos":""},{"def":"The absence or intermission of fever.","pos":""}],"APYREXIAL":[{"def":"Relating to apyrexy.","pos":""}],"APYROUS":[{"def":"Incombustible; capable of sustaining a strong heat without alteration of form or properties.","pos":""}]}