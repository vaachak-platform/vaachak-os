{"CASH":[{"def":"A place where money is kept, or where it is deposited and paid out; a money box.","pos":""}],"CASH RAILWAY":[{"def":"A form of cash carrier in which a small carrier or car travels upon a kind of track.","pos":""}],"CASH REGISTER":[{"def":"A device for recording the amount of cash received, usually having an automatic adding machine and a money drawer and exhibiting the amount of the sale.","pos":""}],"CASHBOOK":[{"def":"A book in which is kept a register of money received or paid out.","pos":""}],"CASHEW":[{"def":"A tree (Anacardium occidentale) of the same family which the sumac.","pos":""}],"CASHIER":[{"def":"One who has charge of money; a cash keeper; the officer who has charge of the payments and receipts (moneys, checks, notes), of a bank or a mercantile company.","pos":""}],"CASHIER'S CHECK":[{"def":"A check drawn by a bank upon its own funds, signed by the cashier.","pos":""}],"CASHIERER":[{"def":"One who rejects, discards, or dismisses; as, a cashierer of monarchs.","pos":""}],"CASHMERE":[{"def":"A rich stuff for shawls, acaris, etc.","pos":""},{"def":"A dress fabric made of fine wool, or of fine wool and cotton, in imitation of the original cashmere.","pos":""}],"CASHMERETTE":[{"def":"A kind of dress goods, made with a soft and glossy surface like cashmere.","pos":""}]}