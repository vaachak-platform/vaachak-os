{"CAPTAIN":[{"def":"A head, or chief officer; as: (a) The military officer who commands a company, troop, or battery, or who has the rank entitling him to do so though he may be employed on other service.","pos":""},{"def":"A military leader; a warrior.","pos":""}],"CAPTAINCY":[{"def":"The rank, post, or commission of a captain.","pos":""}],"CAPTAINRY":[{"def":"Power, or command, over a certain district; chieftainship.","pos":""}],"CAPTAINSHIP":[{"def":"The condition, rank, post, or authority of a captain or chief commander.","pos":""},{"def":"Military skill; as, to show good captainship.","pos":""}],"CAPTATION":[{"def":"A courting of favor or applause, by flattery or address; a captivating quality; an attraction.","pos":""}],"CAPTION":[{"def":"That part of a legal instrument, as a commission, indictment, etc.","pos":""}],"CAPTIOUS":[{"def":"Art to catch at faults; disposed to find fault or to cavil; eager to object; difficult to please.","pos":""},{"def":"Fitted to harass, perplex, or insnare; insidious; troublesome.","pos":""}],"CAPTIOUSLY":[{"def":"In a captious manner.","pos":""}],"CAPTIOUSNESS":[{"def":"Captious disposition or manner.","pos":""}],"CAPTIVATE":[{"def":"To take prisoner; to capture; to subdue.","pos":""},{"def":"To acquire ascendancy over by reason of some art or attraction; to fascinate; to charm; as, Cleopatra captivated Antony; the orator captivated all hearts.","pos":""}],"CAPTIVATING":[{"def":"Having power to captivate or cham; fascinating; as, captivating smiles.","pos":""}],"CAPTIVATION":[{"def":"The act of captivating.","pos":""}],"CAPTIVE":[{"def":"A prisoner taken by force or stratagem, esp.","pos":""},{"def":"One charmed or subdued by beaty, excellence, or affection; one who is captivated.","pos":""}],"CAPTIVITY":[{"def":"The state of being a captive or a prisoner.","pos":""},{"def":"A state of being under control; subjection of the will or affections; bondage.","pos":""}],"CAPTOR":[{"def":"One who captures any person or thing, as a prisoner or a prize.","pos":""}],"CAPTURE":[{"def":"The act of seizing by force, or getting possession of by superior power or by stratagem; as, the capture of an enemy, a vessel, or a criminal.","pos":""},{"def":"The securing of an object of strife or desire, as by the power of some attraction.","pos":""}]}