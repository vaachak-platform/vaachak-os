{"SOMA":[{"def":"The whole axial portion of an animal, including the head, neck, trunk, and tail.","pos":""},{"def":"A society; a congregation; a worshiping assembly, or church, esp.","pos":""}],"SOMATIC":[{"def":"Of or pertaining to the body as a whole; corporeal; as, somatic death; somatic changes.","pos":""},{"def":"Of or pertaining to the wall of the body; somatopleuric; parietal; as, the somatic stalk of the yolk sac of an embryo.","pos":""}],"SOMATICS":[{"def":"The science which treats of the general properties of matter; somatology.","pos":""}],"SOMATIST":[{"def":"One who admits the existence of material beings only; a materialist.","pos":""}],"SOMATOCYST":[{"def":"A cavity in the primary nectocalyx of certain Siphonophora.","pos":""}],"SOMATOLOGY":[{"def":"The dictrine or the science of the general properties of material substances; somatics.","pos":""},{"def":"A treatise on the human body; anatomy.","pos":""}],"SOMATOPLEURE":[{"def":"The outer, or parietal, one of the two lamellæ into which the vertebrate blastoderm divides on either side of the notochord, and from which the walls of the body and the amnion are developed.","pos":""}],"SOMATOPLEURIC":[{"def":"of or pertaining to the somatopleure.","pos":""}],"SOMATOTROPISM":[{"def":"A directive influence exercised by a mass of matter upon growing organs.","pos":""},{"def":"To make somber, or dark; to make shady.","pos":""}],"SOMBRERO":[{"def":"A kind of broad-brimmed hat, worn in Spain and in Spanish America.","pos":""}],"SOMBROUS":[{"def":"A combining form or suffix from Gr.","pos":""}],"SOME":[{"def":"Consisting of a greater or less portion or sum; composed of a quantity or number which is not stated; -- used to express an indefinite quantity or number; as, some wine; some water; some persons.","pos":""},{"def":"A certain; one; -- indicating a person, thing, event, etc.","pos":""}],"SOMEBODY":[{"def":"A person unknown or uncertain; a person indeterminate; some person.","pos":""},{"def":"A person of consideration or importance.","pos":""}],"SOMEDEAL":[{"def":"In some degree; somewhat.","pos":""}],"SOMEHOW":[{"def":"In one way or another; in some way not yet known or designated; by some means; as, the thing must be done somehow; he lives somehow.","pos":""},{"def":"A leap in which a person turns his heels over his head and lights upon his feet; a turning end over end.","pos":""}],"SOMETHING":[{"def":"Anything unknown, undetermined, or not specifically designated; a certain indefinite thing; an indeterminate or unknown event; an unspecified task, work, or thing.","pos":""},{"def":"A part; a portion, more or less; an indefinite quantity or degree; a little.","pos":""}],"SOMETIME":[{"def":"At a past time indefinitely referred to; once; formerly.","pos":""},{"def":"At a time undefined; once in a while; now and then; sometimes.","pos":""}],"SOMETIMES":[{"def":"Formerly; sometime.","pos":""},{"def":"At times; at intervals; now and then;occasionally.","pos":""}],"SOMEWHAT":[{"def":"More or less; a certain quantity or degree; a part, more or less; something.","pos":""},{"def":"A person or thing of importance; a somebody.","pos":""}],"SOMEWHEN":[{"def":"At some indefinite time.","pos":""}],"SOMEWHERE":[{"def":"In some place unknown or not specified; in one place or another.","pos":""}],"SOMEWHILE":[{"def":"Once; for a time.","pos":""}],"SOMEWHITHER":[{"def":"To some indeterminate place; to some place or other.","pos":""}],"SOMITE":[{"def":"One of the actual or ideal serial segments of which an animal, esp.","pos":""}],"SOMNAMBULAR":[{"def":"Of or pertaining to somnambulism; somnambulistic.","pos":""}],"SOMNAMBULATION":[{"def":"The act of walking in sleep.","pos":""}],"SOMNAMBULISM":[{"def":"A condition of the nervous system in which an individual during sleep performs actions approppriate to the waking state; a state of sleep in which some of the senses and voluntary powers are partially awake; noctambulism.","pos":""}],"SOMNAMBULIST":[{"def":"A person who is subject to somnambulism; one who walks in his sleep; a sleepwalker; a noctambulist.","pos":""}],"SOMNAMBULISTIC":[{"def":"Of or pertaining to a somnambulist or somnambulism; affected by somnambulism; appropriate to the state of a somnambulist.","pos":""}],"SOMNER":[{"def":"A summoner; esp.","pos":""}],"SOMNIAL":[{"def":"Of or pertaining to sleep or dreams.","pos":""}],"SOMNIATIVE":[{"def":"Somnial; somniatory.","pos":""}],"SOMNIATORY":[{"def":"Pertaining to sleep or dreams; somnial.","pos":""}],"SOMNICULOUS":[{"def":"Inclined to sleep; drowsy; sleepy.","pos":""}],"SOMNIFEROUS":[{"def":"Causing or inducing sleep; soporific; dormitive; as, a somniferous potion.","pos":""}],"SOMNIFIC":[{"def":"Causing sleep; somniferous.","pos":""}],"SOMNIFUGOUS":[{"def":"Driving away sleep.","pos":""}],"SOMNILOQUENCE":[{"def":"The act of talking in one's sleep; somniloquism.","pos":""}],"SOMNILOQUISM":[{"def":"The act or habit of talking in one's sleep; somniloquy.","pos":""}],"SOMNILOQUIST":[{"def":"One who talks in his sleep.","pos":""}],"SOMNILOQUOUS":[{"def":"Apt to talk in sleep.","pos":""}],"SOMNILOQUY":[{"def":"A talking in sleep; the talking of one in a state of somnipathy.","pos":""}],"SOMNIPATHIST":[{"def":"A person in a state of somniapathy.","pos":""}],"SOMNIPATHY":[{"def":"Sleep from sympathy, or produced by mesmerism or the like.","pos":""},{"def":"Sleepiness; drowsiness; inclination to sleep.","pos":""}],"SOMNOLENT":[{"def":"Sleepy; drowsy; inclined to sleep.","pos":""}],"SOMNOLISM":[{"def":"The somnolent state induced by animal magnetism.","pos":""}],"SOMNOUR":[{"def":"A summoner; an apparitor; a sompnour.","pos":""},{"def":"A summons; a citation.","pos":""}],"SOMPNE":[{"def":"To summon; to cite.","pos":""}]}