{"WIRBLE":[{"def":"To whirl; to eddy.","pos":""}],"WIRE":[{"def":"A thread or slender rod of metal; a metallic substance formed to an even thread by being passed between grooved rollers, or drawn through holes in a plate of steel.","pos":""},{"def":"A telegraph wire or cable; hence, an electric telegraph; as, to send a message by wire.","pos":""}],"WIRE GUN":[{"def":"= Wire-wound gun.","pos":""}],"WIRE TAPPER":[{"def":"One that taps, or cuts in on, telegraph wires and intercepts messages; hence (Slang), Defn: a swindler who pretends to tap wires or otherwise intercept advance telegraphic news for betting.","pos":""}],"WIRE-DRAWER":[{"def":"One who draws metal into wire.","pos":""}],"WIRE-HEEL":[{"def":"A disease in the feet of a horse or other beast.","pos":""}],"WIRE-PULLER":[{"def":"One who pulls the wires, as of a puppet; hence, one who operates by secret means; an intriguer.","pos":""}],"WIRE-PULLING":[{"def":"The act of pulling the wires, as of a puppet; hence, secret influence or management, especially in politics; intrigue.","pos":""}],"WIRE-TAILED":[{"def":"Having some or all of the tail quills terminated in a long, slender, pointed shaft, without a web or barbules.","pos":""}],"WIRE-WORKER":[{"def":"One who manufactures articles from wire.","pos":""}],"WIRE-WOUND GUN":[{"def":"A gun in the construction of which an inner tube (either entire or in segments) is wound with wire under tension to insure greater soundness and uniformity of resistance.","pos":""}],"WIREDRAW":[{"def":"To pass, or to draw off, (as steam) through narrow ports, or the like, thus reducing its pressure or force by friction.","pos":""}],"WIRELESS":[{"def":"Having no wire; specif.","pos":""},{"def":"designating, or pertaining to, a method of telegraphy, telephony, etc.","pos":""}],"WIREWORK":[{"def":"Work, especially openwork, formed of wires.","pos":""}],"WIRINESS":[{"def":"The quality of being wiry.","pos":""}],"WIRING":[{"def":"The act of one that wires anything.","pos":""},{"def":"The wires or conductors employed in a system of electric distribution.","pos":""}],"WIRY":[{"def":"Made of wire; like wire; drawn out like wire.","pos":""},{"def":"Capable of endurance; tough; sinewy; as, a wiry frame or constitution.","pos":""}]}