{"OUTGAZE":[{"def":"To gaze beyond; to exceed in sharpness or persistence of seeing or of looking; hence, to stare out of countenance.","pos":""}],"OUTGENERAL":[{"def":"To exceed in generalship; to gain advantage over by superior military skill or executive ability; to outmaneuver.","pos":""}],"OUTGIVE":[{"def":"To surpass in giving.","pos":""}],"OUTGO":[{"def":"To go beyond; to exceed in swiftness; to surpass; to outdo.","pos":""},{"def":"To circumvent; to overreach.","pos":""}],"OUTGOER":[{"def":"One who goes out or departs.","pos":""}],"OUTGOING":[{"def":"The act or the state of going out.","pos":""},{"def":"That which goes out; outgo; outlay.","pos":""}],"OUTGROUND":[{"def":"Ground situated at a distance from the house; outlying land.","pos":""}],"OUTGROW":[{"def":"To surpass in growing; to grow more than.","pos":""},{"def":"To grow out of or away from; to grow too large, or too aged, for; as, to outgrow clothing; to outgrow usefulness; to outgrow an infirmity.","pos":""}],"OUTGROWTH":[{"def":"That which grows out of, or proceeds from, anything; an excrescence; an offshoot; hence, a result or consequence.","pos":""}],"OUTGUARD":[{"def":"A guard or small body of troops at a distance from the main body of an army, to watch for the approach of an enemy; hence, anything for defense placed at a distance from the thing to be defended.","pos":""}],"OUTGUSH":[{"def":"A pouring out; an outburst.","pos":""}]}