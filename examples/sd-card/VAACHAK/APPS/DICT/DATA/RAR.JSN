{"RARE":[{"def":"Rude mechanicals that rare and late Work in the market place.","pos":""}],"RAREBIT":[{"def":"A dainty morsel; a Welsh rabbit.","pos":""}],"RAREE-SHOW":[{"def":"A show carried about in a box; a peep show.","pos":""}],"RAREFACTION":[{"def":"The act or process of rarefying; the state of being rarefied; - - opposed to condensation; as, the rarefaction of air.","pos":""}],"RAREFIABLE":[{"def":"Capable of being rarefied.","pos":""}],"RAREFY":[{"def":"To make rare, thin, porous, or less dense; to expand or enlarge without adding any new portion of matter to; -- opposed to condense.","pos":""}],"RARELY":[{"def":"In a rare manner or degree; seldom; not often; as, things rarely seen.","pos":""},{"def":"Finely; excellently; with rare skill.","pos":""}],"RARENESS":[{"def":"The state or quality of being rare.","pos":""}],"RARERIPE":[{"def":"Early ripe; ripe before others, or before the usual season.","pos":""}],"RARIFICATION":[{"def":"See Rarefaction.","pos":""}],"RARITY":[{"def":"The quality or state of being rare; rareness; thinness; as, the rarity (contrasted with the density) of gases.","pos":""},{"def":"That which is rare; an uncommon thing; a thing valued for its scarcity.","pos":""}]}