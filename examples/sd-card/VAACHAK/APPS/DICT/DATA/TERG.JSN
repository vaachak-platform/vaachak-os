{"TERGAL":[{"def":"Of or pertaining to back, or tergum.","pos":""}],"TERGANT":[{"def":"Showing the back; as, the eagle tergant.","pos":""},{"def":"Thrice twin; having three pairs of leaflets.","pos":""}],"TERGEMINOUS":[{"def":"Threefold; thrice-paired.","pos":""}],"TERGIFEROUS":[{"def":"Carrying or bearing upon the back.","pos":""}],"TERGITE":[{"def":"The dorsal portion of an arthromere or somite of an articulate animal.","pos":""}],"TERGIVERSATE":[{"def":"To shift; to practice evasion; to use subterfuges; to shuffle.","pos":""}],"TERGIVERSATION":[{"def":"The act of tergiversating; a shifting; shift; subterfuge; evasion.","pos":""},{"def":"Fickleness of conduct; inconstancy; change.","pos":""}],"TERGIVERSATOR":[{"def":"One who tergiversates; one who suffles, or practices evasion.","pos":""}]}