{"SALAAM":[{"def":"Finally, Josiah might have made his salaam to the exciseman just as he was folding up that letter.","pos":""}],"SALABILITY":[{"def":"The quality or condition of being salable; salableness.","pos":""}],"SALABLE":[{"def":"Capable of being sold; fit to be sold; finding a ready market.","pos":""}],"SALACIOUS":[{"def":"Having a propensity to venery; lustful; lecherous.","pos":""}],"SALACITY":[{"def":"Strong propensity to venery; lust; lecherousness.","pos":""}],"SALAD":[{"def":"A preparation of vegetables, as lettuce, celery, water cress, onions, etc.","pos":""},{"def":"A dish composed of chopped meat or fish, esp.","pos":""}],"SALADING":[{"def":"Vegetable for salad.","pos":""}],"SALAGANE":[{"def":"The esculent swallow.","pos":""}],"SALAL-BERRY":[{"def":"The edible fruit of the Gaultheria Shallon, an ericaceous shrub found from California northwards.","pos":""}],"SALAM":[{"def":"A salutation or compliment of ceremony in the east by word or act; an obeisance, performed by bowing very low and placing the right palm on the forehead.","pos":""}],"SALAMANDER":[{"def":"Any one of numerous species of Urodela, belonging to Salamandra, Amblystoma, Plethodon, and various allied genera, especially those that are more or less terrestrial in their habits.","pos":""},{"def":"The pouched gopher (Geomys tuza) of the Southern United States.","pos":""}],"SALAMANDRINA":[{"def":"A suborder of Urodela, comprising salamanders.","pos":""}],"SALAMANDRINE":[{"def":"Of, pertaining to, or resembling, a salamander; enduring fire.","pos":""}],"SALAMANDROID":[{"def":"Like or pertaining to the salamanders.","pos":""}],"SALAMANDROIDEA":[{"def":"A division of Amphibia including the Salamanders and allied groups; the Urodela.","pos":""}],"SALAMSTONE":[{"def":"A kind of blue sapphire brought from Ceylon.","pos":""}],"SALARIED":[{"def":"Receiving a salary; paid by a salary; having a salary attached; as, a salaried officer; a salaried office.","pos":""}],"SALARY":[{"def":"The recompense or consideration paid, or stipulated to be paid, to a person at regular intervals for services; fixed wages, as by the year, quarter, or month; stipend; hire.","pos":""}]}