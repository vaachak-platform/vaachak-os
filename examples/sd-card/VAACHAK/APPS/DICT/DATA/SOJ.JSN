{"SOJA":[{"def":"An Asiatic leguminous herb (Glycine Soja) the seeds of which are used in preparing the sauce called soy.","pos":""}],"SOJOURN":[{"def":"To dwell for a time; to dwell or live in a place as a temporary resident or as a stranger, not considering the place as a permanent habitation; to delay; to tarry.","pos":""}],"SOJOURNER":[{"def":"One who sojourns.","pos":""}],"SOJOURNING":[{"def":"The act or state of one who sojourns.","pos":""}],"SOJOURNMENT":[{"def":"Temporary residence, as that of a stranger or a traveler.","pos":""}]}