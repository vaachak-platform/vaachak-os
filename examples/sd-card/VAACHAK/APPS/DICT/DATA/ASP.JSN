{"ASP":[{"def":"A small, hooded, poisonous serpent of Egypt and adjacent countries, whose bite is often fatal.","pos":""}],"ASPARAGINE":[{"def":"A white, nitrogenous, crystallizable substance, C4H8N2O3+H2O, found in many plants, and first obtained from asparagus.","pos":""}],"ASPARAGINOUS":[{"def":"Pertaining or allied to, or resembling, asparagus; having shoots which are eaten like asparagus; as, asparaginous vegetables.","pos":""}],"ASPARAGUS":[{"def":"A genus of perennial plants belonging to the natural order Liliaceæ, and having erect much branched stems, and very slender branchlets which are sometimes mistaken for leaves.","pos":""}],"ASPARTIC":[{"def":"Pertaining to, or derived, asparagine; as, aspartic acid.","pos":""}],"ASPECT":[{"def":"The situation of planets or stars with respect to one another, or the angle formed by the rays of light proceeding from them and meeting at the eye; the joint look of planets or stars upon each other or upon the earth.","pos":""},{"def":"The influence of the stars for good or evil; as, an ill aspect.","pos":""}],"ASPECT RATIO":[{"def":"The ratio of the long to the short side of an aëroplane, aërocurve, or wing.","pos":""},{"def":"One of several species of poplar bearing this name, especially the Populus tremula, so called from the trembling of its leaves, which move with the slightest impulse of the air.","pos":""}],"ASPECTABLE":[{"def":"Capable of being; visible.","pos":""}],"ASPECTANT":[{"def":"Facing each other.","pos":""}],"ASPECTED":[{"def":"Having an aspect.","pos":""}],"ASPECTION":[{"def":"The act of viewing; a look.","pos":""}],"ASPEN":[{"def":"Of or pertaining to the aspen, or resembling it; made of aspen wood.","pos":""}],"ASPER":[{"def":"Rough; rugged; harsh; bitter; stern; fierce.","pos":""}],"ASPERATE":[{"def":"To make rough or uneven.","pos":""}],"ASPERATION":[{"def":"The act of asperating; a making or becoming rough.","pos":""}],"ASPERGES":[{"def":"See Wateringpot shell.","pos":""}],"ASPERGILLIFORM":[{"def":"Resembling the aspergillum in form; as, an aspergilliform stigma.","pos":""},{"def":"Having rough leaves.","pos":""}],"ASPERITY":[{"def":"Roughness of surface; unevenness; -- opposed to smoothness.","pos":""},{"def":"Roughness or harshness of sound; that quality which grates upon the ear; raucity.","pos":""}],"ASPERMOUS":[{"def":"Destitute of seeds; aspermatous.","pos":""}],"ASPERNE":[{"def":"To spurn; to despise.","pos":""}],"ASPERSE":[{"def":"To sprinkle, as water or dust, upon anybody or anything, or to besprinkle any one with a liquid or with dust.","pos":""},{"def":"To bespatter with foul reports or false and injurious charges; to tarnish in point of reputation or good name; to slander or calumniate; as, to asperse a poet or his writings; to asperse a man's character.","pos":""}],"ASPERSED":[{"def":"Having an indefinite number of small charges scattered or strewed over the surface.","pos":""}],"ASPERSER":[{"def":"One who asperses; especially, one who vilifies another.","pos":""}],"ASPERSION":[{"def":"A sprinkling, as with water or dust, in a literal sense.","pos":""},{"def":"The spreading of calumniations reports or charges which tarnish reputation, like the bespattering of a body with foul water; calumny.","pos":""}],"ASPERSIVE":[{"def":"Tending to asperse; defamatory; slanderous.","pos":""}],"ASPERSORIUM":[{"def":"The stoup, basin, or other vessel for holy water in Roman Catholic churches.","pos":""},{"def":"A brush for sprinkling holy water; an aspergill.","pos":""}],"ASPHALT":[{"def":"To cover with asphalt; as, to asphalt a roof; asphalted streets.","pos":""}],"ASPHALTE":[{"def":"Asphaltic mastic or cement.","pos":""}],"ASPHALTIC":[{"def":"Pertaining to, of the nature of, or containing, asphalt; bituminous.","pos":""}],"ASPHODEL":[{"def":"A general name for a plant of the genus Asphodelus.","pos":""}],"ASPHYCTIC":[{"def":"Pertaining to asphyxia.","pos":""},{"def":"Apparent death, or suspended animation; the condition which results from interruption of respiration, as in suffocation or drowning, or the inhalation of irrespirable gases.","pos":""}],"ASPHYXIAL":[{"def":"Of or relating to asphyxia; as, asphyxial phenomena.","pos":""}],"ASPHYXIATE":[{"def":"To bring to a state of asphyxia; to suffocate.","pos":""},{"def":"In a state of asphyxia; suffocated.","pos":""}],"ASPHYXIATION":[{"def":"The act of causing asphyxia; a state of asphyxia.","pos":""}],"ASPIC":[{"def":"The venomous asp.","pos":""},{"def":"A piece of ordnance carrying a 12 pound shot.","pos":""}],"ASPIDOBRANCHIA":[{"def":"A group of Gastropoda, with limpetlike shells, including the abalone shells and keyhole limpets.","pos":""}],"ASPIRANT":[{"def":"One who aspires; one who eagerly seeks some high position or object of attainment.","pos":""}],"ASPIRATE":[{"def":"To pronounce with a breathing, an aspirate, or an h sound; as, we aspirate the words horse and house; to aspirate a vowel or a liquid consonant.","pos":""}],"ASPIRATION":[{"def":"The act of aspirating; the pronunciation of a letter with a full or strong emission of breath; an aspirated sound.","pos":""},{"def":"The act of breathing; a breath; an inspiration.","pos":""}],"ASPIRATOR":[{"def":"An apparatus for passing air or gases through or over certain liquids or solids, or for exhausting a closed vessel, by means of suction.","pos":""},{"def":"An instrument for the evacuation of the fluid contents of tumors or collections of blood.","pos":""}],"ASPIRE":[{"def":"To desire with eagerness; to seek to attain something high or great; to pant; to long; -- followed by to or after, and rarely by at; as, to aspire to a crown; to aspire after immorality.","pos":""},{"def":"To rise; to ascend; to tower; to soar.","pos":""}],"ASPIRER":[{"def":"One who aspires.","pos":""}],"ASPIRIN":[{"def":"A white crystalline compound of acetyl and salicylic acid used as a drug for the salicylic acid liberated from it in the intestines.","pos":""}],"ASPIRING":[{"def":"That aspires; as, an Aspiring mind.","pos":""}],"ASPISH":[{"def":"Pertaining to, or like, an asp.","pos":""}],"ASPORTATION":[{"def":"The felonious removal of goods from the place where they were deposited.","pos":""}]}