{"EGAD":[{"def":"An exclamation expressing exultation or surprise, etc.","pos":""}],"EGAL":[{"def":"Equal; impartial.","pos":""}],"EGENCE":[{"def":"The state of needing, or of suffering a natural want.","pos":""},{"def":"Sharp; bitter; acid; sour.","pos":""}],"EGER":[{"def":"An impetuous flood; a bore.","pos":""}],"EGEST":[{"def":"To cast or throw out; to void, as excrement; to excrete, as the indigestible matter of the food; in an extended sense, to excrete by the lungs, skin, or kidneys.","pos":""}],"EGESTA":[{"def":"That which is egested or thrown off from the body by the various excretory channels; excrements; -- opposed to ingesta.","pos":""}],"EGESTION":[{"def":"Act or process of egesting; a voiding.","pos":""}],"EGG":[{"def":"The oval or roundish body laid by domestic poultry and other birds, tortoises, etc.","pos":""},{"def":"A simple cell, from the development of which the young of animals are formed; ovum; germ cell.","pos":""}],"EGG SQUASH":[{"def":"A variety of squash with small egg-shaped fruit.","pos":""}],"EGG-BIRD":[{"def":"A species of tern, esp.","pos":""}],"EGG-CUP":[{"def":"A cup used for holding an egg, at table.","pos":""}],"EGG-GLASS":[{"def":"A small sandglass, running about three minutes, for marking time in boiling eggs; also, a small glass for holding an egg, at table.","pos":""}],"EGG-SHAPED":[{"def":"Resembling an egg in form; ovoid.","pos":""}],"EGGAR":[{"def":"Any bombycid moth of the genera Eriogaster and Lasiocampa; as, the oak eggar (L.","pos":""}],"EGGEMENT":[{"def":"Instigation; incitement.","pos":""}],"EGGER":[{"def":"One who gathers eggs; an eggler.","pos":""}],"EGGERY":[{"def":"A place where eggs are deposited (as by sea birds) or kept; a nest of eggs.","pos":""}],"EGGHOT":[{"def":"A kind of posset made of eggs, brandy, sugar, and ale.","pos":""}],"EGGLER":[{"def":"One who gathers, or deals in, eggs.","pos":""}],"EGGNOG":[{"def":"A drink consisting of eggs beaten up with sugar, milk, and (usually) wine or spirits.","pos":""}],"EGGPLANT":[{"def":"A plant (Solanum Melongena), of East Indian origin, allied to the tomato, and bearing a large, smooth, edible fruit, shaped somewhat like an egg; mad-apple.","pos":""}],"EGGSHELL":[{"def":"A smooth, white, marine, gastropod shell of the genus Ovulum, resembling an egg in form.","pos":""}],"EGILOPICAL":[{"def":"Pertaining to, of the nature of, or affected with, an ægilops, or tumor in the corner of the eye.","pos":""}],"EGILOPS":[{"def":"Destitute of glands.","pos":""}],"EGLANTINE":[{"def":"Note: Milton, in the following lines, has applied the name to some twinning plant, perhaps the honeysuckle.","pos":""}],"EGLING":[{"def":"The European perch when two years old.","pos":""}],"EGLOMERATE":[{"def":"To unwind, as a thread from a ball.","pos":""}],"EGO":[{"def":"The conscious and permanent subject of all psychical experiences, whether held to be directly known or the product of reflective thought; -- opposed to non-ego.","pos":""}],"EGOICAL":[{"def":"Pertaining to egoism.","pos":""}],"EGOISM":[{"def":"The doctrine of certain extreme adherents or disciples of Descartes and Johann Gottlieb Fichte, which finds all the elements of knowledge in the ego and the relations which it implies or provides for.","pos":""}],"EGOIST":[{"def":"A believer in egoism.","pos":""},{"def":"Pertaining to egoism; imbued with egoism or excessive thoughts of self; self-loving.","pos":""}],"EGOISTICALLY":[{"def":"In an egoistic manner.","pos":""}],"EGOPHONIC":[{"def":"Belonging to, or resembling, egophony.","pos":""}],"EGOPHONY":[{"def":"The sound of a patient's voice so modified as to resemble the bleating of a goat, heard on applying the ear to the chest in certain diseases within its cavity, as in pleurisy with effusion.","pos":""}],"EGOTHEISM":[{"def":"The deification of self.","pos":""}],"EGOTISM":[{"def":"The practice of too frequently using the word I; hence, a speaking or writing overmuch of one's self; self-exaltation; self- praise; the act or practice of magnifying one's self or parading one's own doings.","pos":""}],"EGOTIST":[{"def":"One addicted to egotism; one who speaks much of himself or magnifies his own achievements or affairs.","pos":""},{"def":"Addicted to, or manifesting, egotism.","pos":""}],"EGOTISTICALLY":[{"def":"E`go*tis\"tic*al*ly, adv.","pos":""}],"EGOTIZE":[{"def":"To talk or write as an egotist.","pos":""}],"EGRANULOSE":[{"def":"Having no granules, as chlorophyll in certain conditions.","pos":""}],"EGRE":[{"def":"See Eager, and Eagre.","pos":""}],"EGREGIOUS":[{"def":"Surpassing; extraordinary; distinguished (in a bad sense); -- formerly used with words importing a good quality, but now joined with words having a bad sense; as, an egregious rascal; an egregious ass; an egregious mistake.","pos":""}],"EGREGIOUSLY":[{"def":"Greatly; enormously; shamefully; as, egregiously cheated.","pos":""}],"EGREGIOUSNESS":[{"def":"The state of being egregious.","pos":""}],"EGREMOIN":[{"def":"Agrimony (Agrimonia Eupatoria).","pos":""}],"EGRESS":[{"def":"The passing off from the sun's disk of an inferior planet, in a transit.","pos":""}],"EGRESSION":[{"def":"The act of going; egress.","pos":""}],"EGRESSOR":[{"def":"One who goes out.","pos":""}],"EGRET":[{"def":"The name of several species of herons which bear plumes on the back.","pos":""},{"def":"The flying feathery or hairy crown of seeds or achenes, as the down of the thistle.","pos":""}],"EGRETTE":[{"def":"Same as Egret, n.","pos":""}],"EGRIMONY":[{"def":"The herb agrimony.","pos":""}],"EGRIOT":[{"def":"A kind of sour cherry.","pos":""}],"EGRITUDE":[{"def":"Sickness; ailment; sorrow.","pos":""}],"EGYPTIAN":[{"def":"Pertaining to Egypt, in Africa.","pos":""}],"EGYPTIZE":[{"def":"To give an Egyptian character or appearance to.","pos":""},{"def":"One skilled in the antiquities of Egypt; a student of Egyptology.","pos":""}],"EGYPTOLOGICAL":[{"def":"Of, pertaining to, or devoted to, Egyptology.","pos":""}],"EGYPTOLOGY":[{"def":"The science or study of Egyptian antiquities, esp.","pos":""}]}