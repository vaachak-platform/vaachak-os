{"HARM":[{"def":"Injury; hurt; damage; detriment; misfortune.","pos":""},{"def":"That which causes injury, damage, or loss.","pos":""}],"HARMALINE":[{"def":"An alkaloid found in the plant Peganum harmala.","pos":""}],"HARMATTAN":[{"def":"A dry, hot wind, prevailing on the Atlantic coast of Africa, in December, January, and February, blowing from the interior or Sahara.","pos":""}],"HARMEL":[{"def":"A kind of rue (Ruta sylvestris) growing in India.","pos":""}],"HARMFUL":[{"def":"Full of harm; injurious; hurtful; mischievous.","pos":""}],"HARMINE":[{"def":"An alkaloid accompanying harmaline (in the Peganum harmala), and obtained from it by oxidation.","pos":"noun"}],"HARMLESS":[{"def":"Relating to harmony, -- as melodic relates to melody; harmonious; esp.","pos":""},{"def":"Having relations or properties bearing some resemblance to those of musical consonances; -- said of certain numbers, ratios, proportions, points, lines.","pos":""}],"HARMONIC":[{"def":"A musical note produced by a number of vibrations which is a multiple of the number producing some other; an overtone.","pos":""}],"HARMONICA":[{"def":"A musical instrument, consisting of a series of hemispherical glasses which, by touching the edges with the dampened finger, give forth the tones.","pos":""},{"def":"A toy instrument of strips of glass or metal hung on two tapes, and struck with hammers.","pos":""}],"HARMONICALLY":[{"def":"In harmonical progression.","pos":""}],"HARMONICON":[{"def":"A small, flat, wind instrument of music, in which the notes are produced by the vibration of free metallic reeds.","pos":""}],"HARMONICS":[{"def":"Secondary and less distinct tones which accompany any principal, and apparently simple, tone, as the octave, the twelfth, the fifteenth, and the seventeenth.","pos":""}],"HARMONIOUS":[{"def":"Adapted to each other; having parts proportioned to each other; symmetrical.","pos":""},{"def":"Acting together to a common end; agreeing in action or feeling; living in peace and friendship; as, an harmonious family.","pos":""}],"HARMONIPHON":[{"def":"An obsolete wind instrument with a keyboard, in which the sound, which resembled the oboe, was produced by the vibration of thin metallic plates, acted upon by blowing through a tube.","pos":""}],"HARMONIST":[{"def":"One who understands the principles of harmony or is skillful in applying them in composition; a musical composer.","pos":""},{"def":"One of a religious sect, founded in Würtemburg in the last century, composed of followers of George Rapp, a weaver.","pos":""}],"HARMONIUM":[{"def":"A musical instrument, resembling a small organ and especially designed for church music, in which the tones are produced by forcing air by means of a bellows so as to cause the vibration of free metallic reeds.","pos":""}],"HARMONIZATION":[{"def":"The act of harmonizing.","pos":""}],"HARMONIZE":[{"def":"To agree in action, adaptation, or effect on the mind; to agree in sense or purport; as, the parts of a mechanism harmonize.","pos":""},{"def":"To be in peace and friendship, as individuals, families, or public organizations.","pos":""}],"HARMONIZER":[{"def":"One who harmonizes.","pos":""}],"HARMONOMETER":[{"def":"An instrument for measuring the harmonic relations of sounds.","pos":""}],"HARMONY":[{"def":"See Harmonic suture, under Harmonic.","pos":""}],"HARMOST":[{"def":"A governor or prefect appointed by the Spartans in the cities subjugated by them.","pos":""}],"HARMOTOME":[{"def":"A hydrous silicate of alumina and baryta, occurring usually in white cruciform crystals; cross-stone.","pos":""}]}