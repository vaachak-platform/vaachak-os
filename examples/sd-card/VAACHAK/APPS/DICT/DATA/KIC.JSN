{"KICK":[{"def":"To strike, thrust, or hit violently with the foot; as, a horse kicks a groom; a man kicks a dog.","pos":""}],"KICKABLE":[{"def":"Capable or deserving of being kicked.","pos":""}],"KICKAPOOS":[{"def":"A tribe of Indians which formerly occupied the region of Northern Illinois, allied in language to the Sacs and Foxes.","pos":""}],"KICKER":[{"def":"One who, or that which, kicks.","pos":""}],"KICKSHAW":[{"def":"See Kickshaws, the correct singular.","pos":""}],"KICKSHAWS":[{"def":"Something fantastical; any trifling, trumpery thing; a toy.","pos":""},{"def":"A fancy dish; a titbit; a delicacy.","pos":""}],"KICKSHOE":[{"def":"That which is restless and uneasy.","pos":""}],"KICKSY-WICKSY":[{"def":"Fantastic; restless; as, kicksy-wicksy flames.","pos":""}],"KICKUP":[{"def":"The water thrush or accentor.","pos":""}]}