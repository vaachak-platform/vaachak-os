{"CASCABEL":[{"def":"The projection in rear of the breech of a cannon, usually a knob or breeching loop connected with the gun by a neck.","pos":""}],"CASCADE":[{"def":"A fall of water over a precipice, as in a river or brook; a waterfall less than a cataract.","pos":""}],"CASCADE METHOD":[{"def":"A method of attaining successively lower temperatures by utilizing the cooling effect of the expansion of one gas in condensing another less easily liquefiable, and so on.","pos":""}],"CASCALHO":[{"def":"A deposit of pebbles, gravel, and ferruginous sand, in which the Brazilian diamond is usually found.","pos":""}],"CASCARA BUCKTHORN":[{"def":"The buckthorn (Rhamnus Purshiana) of the Pacific coast of the United States, which yields cascara sagrada.","pos":""}],"CASCARA SAGRADA":[{"def":"Holy bark; the bark of the California buckthorn (Rhamnus Purshianus), used as a mild cathartic or laxative.","pos":""}],"CASCARILLA":[{"def":"A euphorbiaceous West Indian shrub (Croton Eleutheria); also, its aromatic bark.","pos":"noun"}],"CASCARILLIN":[{"def":"A white, crystallizable, bitter substance extracted from oil of cascarilla.","pos":""}]}