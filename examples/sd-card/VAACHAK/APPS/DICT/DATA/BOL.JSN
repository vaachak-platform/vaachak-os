{"BOLAR":[{"def":"Of or pertaining to bole or clay; partaking of the nature and qualities of bole; clayey.","pos":""}],"BOLAS":[{"def":"A kind of missile weapon consisting of one, two, or more balls of stone, iron, or other material, attached to the ends of a leather cord; -- used by the Gauchos of South America, and others, for hurling at and entangling an animal.","pos":""}],"BOLD":[{"def":"Forward to meet danger; venturesome; daring; not timorous or shrinking from risk; brave; courageous.","pos":""},{"def":"Exhibiting or requiring spirit and contempt of danger; planned with courage; daring; vigorous.","pos":""}],"BOLD EAGLE":[{"def":"an Australian eagle (Aquila audax), which destroys lambs and even the kangaroo.","pos":""}],"BOLD-FACED":[{"def":"Having a conspicuous or heavy face.","pos":""}],"BOLDEN":[{"def":"To make bold; to encourage; to embolden.","pos":""}],"BOLDLY":[{"def":"In a bold manner.","pos":""}],"BOLDNESS":[{"def":"The state or quality of being bold.","pos":""},{"def":"A fragrant evergreen shrub of Chili (Peumus Boldus).","pos":""}],"BOLE":[{"def":"The trunk or stem of a tree, or that which is like it.","pos":""}],"BOLECTION":[{"def":"A projecting molding round a panel.","pos":""}],"BOLERO":[{"def":"A Spanish dance, or the lively music which accompanies it.","pos":""}],"BOLETE":[{"def":"any fungus of the family Boletaceae.","pos":""}],"BOLETIC":[{"def":"Pertaining to, or obtained from, the Boletus.","pos":""}],"BOLETUS":[{"def":"A genus of fungi having the under side of the pileus or cap composed of a multitude of fine separate tubes.","pos":""}],"BOLIDE":[{"def":"A kind of meteor; a bolis.","pos":""}],"BOLIS":[{"def":"A meteor or brilliant shooting star, followed by a train of light or sparks; esp.","pos":""}],"BOLIVIAN":[{"def":"Of or pertaining to Bolivia.","pos":""},{"def":"A native of Bolivia.","pos":""}],"BOLL":[{"def":"The pod or capsule of a plant, as of flax or cotton; a pericarp of a globular form.","pos":""},{"def":"A Scotch measure, formerly in use: for wheat and beans it contained four Winchester bushels; for oats, barley, and potatoes, six bushels.","pos":""}],"BOLLANDISTS":[{"def":"The Jesuit editors of the \"Acta Sanctorum\", or Lives of the Saints; -- named from John Bolland, who began the work.","pos":""}],"BOLLARD":[{"def":"An upright wooden or iron post in a boat or on a dock, used in veering or fastening ropes.","pos":""}],"BOLLING":[{"def":"A tree from which the branches have been cut; a pollard.","pos":""}],"BOLLWORM":[{"def":"The larva of a moth (Heliothis armigera) which devours the bolls or unripe pods of the cotton plant, often doing great damage to the crops.","pos":""}],"BOLN":[{"def":"To swell; to puff.","pos":""},{"def":"Swollen; puffed out.","pos":""}],"BOLO":[{"def":"A kind of large knife resembling a machete.","pos":""}],"BOLOGNA":[{"def":"A city of Italy which has given its name to various objects.","pos":""},{"def":"A Bologna sausage.","pos":""}],"BOLOGNESE":[{"def":"Of or pertaining to Bologna.","pos":""},{"def":"A native of Bologna.","pos":""}],"BOLOMETER":[{"def":"An instrument for measuring minute quantities of radiant heat, especially in different parts of the spectrum; -- called also actinic balance, thermic balance.","pos":""}],"BOLSA":[{"def":"An exchange for the transaction of business.","pos":""}],"BOLSTER":[{"def":"A cushioned or a piece part of a saddle.","pos":""},{"def":"the perforated plate in a punching machine on which anything rests when being punched.","pos":""}],"BOLSTERED":[{"def":"Supported; upheld.","pos":""}],"BOLT":[{"def":"A shaft or missile intended to be shot from a crossbow or catapult, esp.","pos":""},{"def":"Lightning; a thunderbolt.","pos":""}],"BOLTER":[{"def":"One who bolts; esp.","pos":""}],"BOLTHEAD":[{"def":"A long, straightnecked, glass vessel for chemical distillations; -- called also a matrass or receiver.","pos":""}],"BOLTING":[{"def":"A darting away; a starting off or aside.","pos":""}],"BOLTONITE":[{"def":"A granular mineral of a grayish or yellowish color, found in Bolton, Massachusetts.","pos":""}],"BOLTROPE":[{"def":"A rope stitched to the edges of a sail to strengthen the sail.","pos":""}],"BOLTY":[{"def":"An edible fish of the Nile (genus Chromis).","pos":""}],"BOLUS":[{"def":"A rounded mass of anything, esp.","pos":""}]}