{"DUCAL":[{"def":"Of or pertaining to a duke.","pos":""}],"DUCALLY":[{"def":"In the manner of a duke, or in a manner becoming the rank of a duke.","pos":""}],"DUCAT":[{"def":"A coin, either of gold or silver, of several countries in Europe; originally, one struck in the dominions of a duke.","pos":""}],"DUCATOON":[{"def":"A silver coin of several countries of Europe, and of different values.","pos":""}],"DUCES TECUM":[{"def":"A judicial process commanding a person to appear in court and bring with him some piece of evidence or other thing to be produced to the court.","pos":""}],"DUCHESS":[{"def":"The wife or widow of a duke; also, a lady who has the sovereignty of a duchy in her own right.","pos":""}],"DUCHESSE D'ANGOULEME":[{"def":"A variety of pear of large size and excellent flavor.","pos":""}],"DUCHESSE LACE":[{"def":"A beautiful variety of Brussels pillow lace made originally in Belgium and resembling Honiton guipure.","pos":""}],"DUCHY":[{"def":"The territory or dominions of a duke; a dukedom.","pos":""}],"DUCK":[{"def":"A pet; a darling.","pos":""}],"DUCK'S-BILL":[{"def":"Having the form of a duck's bill.","pos":""}],"DUCK'S-FOOT":[{"def":"The May apple (Podophyllum peltatum).","pos":""}],"DUCK-BILLED":[{"def":"Having a bill like that of a duck.","pos":""}],"DUCK-LEGGED":[{"def":"Having short legs, like a waddling duck; short-legged.","pos":""}],"DUCKBILL":[{"def":"See Duck mole, under Duck, n.","pos":""}],"DUCKER":[{"def":"One who, or that which, ducks; a plunger; a diver.","pos":""},{"def":"A cringing, servile person; a fawner.","pos":""}],"DUCKLING":[{"def":"A young or little duck.","pos":""}],"DUCKWEED":[{"def":"A genus (Lemna) of small plants, seen floating in great quantity on the surface of stagnant pools fresh water, and supposed to furnish food for ducks; -- called also duckmeat.","pos":""}],"DUCT":[{"def":"One of the vessels of an animal body by which the products of glandular secretion are conveyed to their destination.","pos":""},{"def":"A large, elongated cell, either round or prismatic, usually found associated with woody fiber.","pos":""}],"DUCTIBLE":[{"def":"Capable of being drawn out [R.","pos":""}],"DUCTILE":[{"def":"Easily led; tractable; complying; yielding to motives, persuasion, or instruction; as, a ductile people.","pos":""},{"def":"Capable of being elongated or drawn out, as into wire or threads.","pos":""}],"DUCTILIMETER":[{"def":"An instrument for accurately determining the ductility of metals.","pos":""}],"DUCTILITY":[{"def":"The property of a metal which allows it to be drawn into wires or filaments.","pos":""},{"def":"Tractableness; pliableness.","pos":""}],"DUCTLESS":[{"def":"Having to duct or outlet; as, a ductless gland.","pos":""}],"DUCTOR":[{"def":"A contrivance for removing superfluous ink or coloring matter from a roller.","pos":""}]}