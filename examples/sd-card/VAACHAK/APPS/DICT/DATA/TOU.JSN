{"TOUCAN":[{"def":"Any one of numerous species of fruit-eating birds of tropical America belonging to Ramphastos, Pteroglossus, and allied genera of the family Ramphastidæ.","pos":""},{"def":"A modern constellation of the southern hemisphere.","pos":""}],"TOUCH":[{"def":"To be tangent to.","pos":""}],"TOUCH-BOX":[{"def":"A box containing lighted tinder, formerly carried by soldiers who used matchlocks, to kindle the match.","pos":""}],"TOUCH-NEEDLE":[{"def":"A small bar of gold and silver, either pure, or alloyed in some known proportion with copper, for trying the purity of articles of gold or silver by comparison of the streaks made by the article and the bar on a touchstone.","pos":""}],"TOUCH-PAPER":[{"def":"Paper steeped in saltpeter, which burns slowly, and is used as a match for firing gunpowder, and the like.","pos":""}],"TOUCHABLE":[{"def":"Capable of being touched; tangible.","pos":""}],"TOUCHBACK":[{"def":"The act of touching the football down by a player behind his own goal line when it received its last impulse from an opponent; -- distinguished from safety touchdown.","pos":""}],"TOUCHDOWN":[{"def":"The act of touching the football down behind the opponents' goal .","pos":""}],"TOUCHHOLE":[{"def":"The vent of a cannot or other firearm, by which fire is communicateed to the powder of the charge.","pos":""}],"TOUCHILY":[{"def":"In a touchy manner.","pos":""}],"TOUCHINESS":[{"def":"The quality or state of being touchy peevishness; irritability; irascibility.","pos":""}],"TOUCHING":[{"def":"Affecting; moving; pathetic; as, a touching tale.","pos":""}],"TOUCHSTONE":[{"def":"Lydian stone; basanite; -- so called because used to test the purity of gold and silver by the streak which is left upon the stone when it is rubbed by the metal.","pos":""},{"def":"Any test or criterion by which the qualities of a thing are tried.","pos":""}],"TOUCHWOOD":[{"def":"Wood so decayed as to serve for tinder; spunk, or punk.","pos":""},{"def":"Dried fungi used as tinder; especially, the Polyporus igniarius.","pos":""}],"TOUCHY":[{"def":"Peevish; irritable; irascible; techy; apt to take fire.","pos":""}],"TOUGH":[{"def":"Having the quality of flexibility without brittleness; yielding to force without breaking; capable of resisting great strain; as, the ligaments of animals are remarkably tough.","pos":""},{"def":"Not easily broken; able to endure hardship; firm; strong; as, tough sinews.","pos":""}],"TOUGH-CAKE":[{"def":"See Tough-pitch (b).","pos":""}],"TOUGHEN":[{"def":"To grow or make tough, or tougher.","pos":""}],"TOUGHISH":[{"def":"Tough in a slight degree.","pos":""}],"TOUGHLY":[{"def":"In a tough manner.","pos":""}],"TOUGHNESS":[{"def":"The quality or state of being tough.","pos":""}],"TOUITE":[{"def":"The wood warbler.","pos":""}],"TOUPETTIT":[{"def":"The crested titmouse.","pos":""}],"TOUR":[{"def":"anything done successively, or by regular order; a turn; as, a tour of duty.","pos":""}],"TOURACO":[{"def":"Same as Turacou.","pos":""}],"TOURBILLION":[{"def":"An ornamental firework which turns round, when in the air, so as to form a scroll of fire.","pos":""}],"TOURING CAR":[{"def":"An automobile designed for touring; specif.","pos":""}],"TOURIST":[{"def":"One who makes a tour, or performs a journey in a circuit.","pos":""}],"TOURMALINE":[{"def":"A mineral occurring usually in three-sided or six-sided prisms terminated by rhombohedral or scalenohedral planes.","pos":""}],"TOURN":[{"def":"The sheriff's turn, or court.","pos":""}],"TOURNAMENT":[{"def":"A mock fight, or warlike game, formerly in great favor, in which a number of combatants were engaged, as an exhibition of their address and bravery; hence, figuratively, a real battle.","pos":""},{"def":"Any contest of skill in which there are many contestents for championship; as, a chess tournament.","pos":""}],"TOURNERY":[{"def":"Work turned on a lathe; turnery.","pos":""}],"TOURNEY":[{"def":"At tilt or tourney or like warlike game.","pos":""}],"TOURNIQUET":[{"def":"An instrument for arresting hemorrhage.","pos":""}],"TOURNOIS":[{"def":"A former French money of account worth 20 sous, or a franc.","pos":""}],"TOURNURE":[{"def":"To pull; to haul; to tear; to worry.","pos":""}],"TOUS-LES-MOIS":[{"def":"A kind of starch with very large, oval, flattened grains, often sold as arrowroot, and extensively used for adulterating cocoa.","pos":""}],"TOUSE":[{"def":"A pulling; a disturbance.","pos":""}],"TOUSLE":[{"def":"To put into disorder; to tumble; to touse.","pos":""}],"TOUSY":[{"def":"Tousled; tangled; rough; shaggy.","pos":""}],"TOUT":[{"def":"To act as a tout.","pos":""},{"def":"To ply or seek for customers.","pos":""}],"TOUT-ENSEMBLE":[{"def":"All together; hence, in costume, the fine arts, etc.","pos":""}],"TOUTER":[{"def":"One who seeks customers, as for an inn, a public conveyance, shops, and the like: hence, an obtrusive candidate for office.","pos":""}]}