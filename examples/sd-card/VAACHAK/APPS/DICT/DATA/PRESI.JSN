{"PRESIDE":[{"def":"To be set, or to sit, in the place of authority; to occupy the place of president, chairman, moderator, director, etc.","pos":""},{"def":"To exercise superintendence; to watch over.","pos":""}],"PRESIDENCY":[{"def":"The function or condition of one who presides; superintendence; control and care.","pos":""},{"def":"The office of president; as, Washington was elected to the presidency.","pos":""}],"PRESIDENT":[{"def":"Occupying the first rank or chief place; having the highest authority; presiding.","pos":""}],"PRESIDENTIAL":[{"def":"Presiding or watching over.","pos":""},{"def":"Of or pertaining to a president; as, the presidential chair; a presidential election.","pos":""}],"PRESIDENTSHIP":[{"def":"The office and dignity of president; presidency.","pos":""}],"PRESIDER":[{"def":"One who presides.","pos":""},{"def":"Of or pertaining to a garrison; having a garrison.","pos":""}],"PRESIDING":[{"def":"Pre*sid\"ing, Defn: a.","pos":""}],"PRESIDIO":[{"def":"A place of defense; a fortress; a garrison; a fortress; a garrison or guardhouse.","pos":""}],"PRESIGNIFICATION":[{"def":"The act of signifying or showing beforehand.","pos":""}],"PRESIGNIFY":[{"def":"To intimate or signify beforehand; to presage.","pos":""}]}