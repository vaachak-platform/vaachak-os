{"CONVULSE":[{"def":"To contract violently and irregulary, as the muscular parts of an animal body; to shake with irregular spasms, as in excessive laughter, or in agony from grief or pain.","pos":""},{"def":"To agitate greatly; to shake violently.","pos":""}],"CONVULSION":[{"def":"An unnatural, violent, and unvoluntary contraction of the muscular parts of an animal body.","pos":""}],"CONVULSIONAL":[{"def":"Pertaining to, or having, convulsions; convulsionary.","pos":""}],"CONVULSIONARY":[{"def":"Pertaining to convulsion; convulsive.","pos":""}],"CONVULSIONIST":[{"def":"One who has convulsions; esp.","pos":""}],"CONVULSIVE":[{"def":"Producing, or attended with, convulsions or spasms; characterized by convulsions; convulsionary.","pos":""}],"CONVULSIVELY":[{"def":"in a convulsive manner.","pos":""}]}