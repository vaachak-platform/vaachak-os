{"PEA":[{"def":"The sliding weight on a steelyard.","pos":""}],"PEA-JACKET":[{"def":"A thick loose woolen jacket, or coat, much worn by sailors in cold weather.","pos":""}],"PEABIRD":[{"def":"The wryneck; -- so called from its note.","pos":""}],"PEABODY BIRD":[{"def":"An American sparrow (Zonotrichia albicollis) having a conspicuous white throat.","pos":""}],"PEACE":[{"def":"A state of quiet or tranquillity; freedom from disturbance or agitation; calm; repose; specifically: (a) Exemption from, or cessation of, war with public enemies.","pos":""}],"PEACEABLE":[{"def":"Begin in or at peace; tranquil; quiet; free from, or not disposed to, war, disorder, or excitement; not quarrelsome.","pos":""}],"PEACEBREAKER":[{"def":"One who disturbs the public peace.","pos":""}],"PEACEFUL":[{"def":"Possessing or enjoying peace; not disturbed by war, tumult, agitation, anxiety, or commotion; quiet; tranquil; as, a peaceful time; a peaceful country; a peaceful end.","pos":""},{"def":"Not disposed or tending to war, tumult or agitation; pacific; mild; calm; peaceable; as, peaceful words.","pos":""}],"PEACELESS":[{"def":"Without peace; disturbed.","pos":""}],"PEACEMAKER":[{"def":"One who makes peace by reconciling parties that are at variance.","pos":""}],"PEACH":[{"def":"To accuse of crime; to inform against.","pos":""}],"PEACH-COLORED":[{"def":"Of the color of a peach blossom.","pos":""}],"PEACHBLOW":[{"def":"Of the delicate purplish pink color likened to that of peach blooms; -- applied esp.","pos":""}],"PEACHER":[{"def":"One who peaches.","pos":""}],"PEACHICK":[{"def":"The chicken of the peacock.","pos":""}],"PEACHY":[{"def":"Resembling a peach or peaches.","pos":""}],"PEACOCK":[{"def":"The male of any pheasant of the genus Pavo, of which at least two species are known, native of Southern Asia and the East Indies.","pos":""}],"PEACOCK THRONE":[{"def":"A famous throne formerly of the kings of Delhi, India, but since 1739, when it was carried off by Nadir Shah, held by the shahs of Persia (later Iran); -- so called from its bearing a fully expanded peacock's tail done in gems.","pos":""}],"PEAFOWL":[{"def":"The peacock or peahen; any species of Pavo.","pos":""}],"PEAG":[{"def":"A kind of aboriginal shell money, or wampum, of the Atlantic coast of the United States; -- originally applied only to polished white cylindrical beads.","pos":""}],"PEAGRIT":[{"def":"A coarse pisolitic limestone.","pos":""}],"PEAHEN":[{"def":"The hen or female peafowl.","pos":""}],"PEAK":[{"def":"A point; the sharp end or top of anything that terminates in a point; as, the peak, or front, of a cap.","pos":""},{"def":"The top, or one of the tops, of a hill, mountain, or range, ending in a point; often, the whole hill or mountain, esp.","pos":""}],"PEAKED":[{"def":"Sickly; not robust.","pos":""}],"PEAKING":[{"def":"Pining; sickly; peakish.","pos":""}],"PEAKISH":[{"def":"Of or relating to a peak; or to peaks; belonging to a mountainous region.","pos":""},{"def":"Having peaks; peaked.","pos":""}],"PEAKY":[{"def":"Having a peak or peaks.","pos":""}],"PEAL":[{"def":"A small salmon; a grilse; a sewin.","pos":""}],"PEAN":[{"def":"One of the furs, the ground being sable, and the spots or tufts or.","pos":""}],"PEANISM":[{"def":"The song or shout of praise, of battle, or of triumph.","pos":""}],"PEANUT":[{"def":"The fruit of a trailing leguminous plant (Arachis hypogæa); also, the plant itself, which is widely cultivated for its fruit.","pos":""}],"PEANUT BUTTER":[{"def":"A paste made by mixing ground fresh roasted peanuts with a small quantity of water or oil, and used chiefly as a relish on sandwiches, etc.","pos":""}],"PEAR":[{"def":"The fleshy pome, or fruit, of a rosaceous tree (Pyrus communis), cultivated in many varieties in temperate climates; also, the tree which bears this fruit.","pos":""}],"PEAR-SHAPED":[{"def":"Of the form of a pear.","pos":""}],"PEARL":[{"def":"A fringe or border.","pos":""},{"def":"To fringe; to border.","pos":""}],"PEARL-EYED":[{"def":"Having a pearly speck in the eye; afflicted with the cataract.","pos":""}],"PEARLACEOUS":[{"def":"Resembling pearl or mother-of-pearl; pearly in quality or appearance.","pos":""}],"PEARLASH":[{"def":"A white amorphous or granular substance which consists principally of potassium carbonate, and has a strong alkaline reaction.","pos":""}],"PEARLFISH":[{"def":"Any fish whose scales yield a pearl-like pigment used in manufacturing artificial pearls, as the bleak, and whitebait.","pos":""},{"def":"A kind of lace of silk or thread.","pos":""}],"PEARLWORT":[{"def":"A name given to several species of Sagina, low and inconspicuous herbs of the Chickweed family.","pos":""}],"PEARLY":[{"def":"Containing pearls; abounding with, or yielding, pearls; as, pearly shells.","pos":""},{"def":"Resembling pearl or pearls; clear; pure; transparent; iridescent; as, the pearly dew or flood.","pos":""}],"PEARMAIN":[{"def":"The name of several kinds of apples; as, the blue pearmain, winter pearmain, and red pearmain.","pos":""}],"PEART":[{"def":"Active; lively; brisk; smart; -- often applied to convalescents; as, she is quite peart to-day.","pos":""}],"PEASANT":[{"def":"A countryman; a rustic; especially, one of the lowest class of tillers of the soil in European countries.","pos":""}],"PEASANTLIKE":[{"def":"Rude; clownish; illiterate.","pos":""}],"PEASANTRY":[{"def":"Peasants, collectively; the body of rustics.","pos":""},{"def":"Rusticity; coarseness.","pos":""}],"PEASCOD":[{"def":"The legume or pericarp, or the pod, of the pea.","pos":""}],"PEASE":[{"def":"A plural form of Pea.","pos":""}],"PEAT":[{"def":"A small person; a pet; -- sometimes used contemptuously.","pos":""}],"PEATY":[{"def":"Composed of peat; abounding in peat; resembling peat.","pos":""},{"def":"A cant hook having the end of its lever armed with a spike.","pos":""}]}