{"CLATCH":[{"def":"A soft or sloppy lump or mass; as, to throw a clatch of mud.","pos":""},{"def":"Anything put together or made in a careless or slipshod way; hence, a sluttish or slipshod woman.","pos":""}],"CLATHRATE":[{"def":"Shaped like a lattice; cancellate.","pos":""},{"def":"Having the surface marked with raised lines resembling a lattice, as many shells.","pos":""}],"CLATTER":[{"def":"To make a rattling sound by striking hard bodies together; to make a succession of abrupt, rattling sounds.","pos":""},{"def":"To talk fast and noisily; to rattle with the tongue.","pos":""}],"CLATTERER":[{"def":"One who clatters.","pos":""}],"CLATTERINGLY":[{"def":"With clattering.","pos":""}]}