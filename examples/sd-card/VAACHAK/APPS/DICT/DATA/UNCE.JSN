{"UNCE":[{"def":"An ounce; a small portion.","pos":""}],"UNCEASABLE":[{"def":"Not capable of being ended; unceasing.","pos":""},{"def":"To throw from its center.","pos":""}],"UNCENTURY":[{"def":"To remove from its actual century.","pos":""}],"UNCERTAIN":[{"def":"Not certain; not having certain knowledge; not assured in mind; distrustful.","pos":""},{"def":"Irresolute; inconsonant; variable; untrustworthy; as, an uncertain person; an uncertain breeze.","pos":""}],"UNCERTAINLY":[{"def":"In an uncertain manner.","pos":""}],"UNCERTAINTY":[{"def":"The quality or state of being uncertain.","pos":""},{"def":"That which is uncertain; something unknown.","pos":""}]}