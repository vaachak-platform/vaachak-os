{"SEAR":[{"def":"To wither; to dry up.","pos":""},{"def":"To burn (the surface of) to dryness and hardness; to cauterize; to expose to a degree of heat such as changes the color or the hardness and texture of the surface; to scorch; to make callous; as, to sear the skin or flesh.","pos":""}],"SEARCE":[{"def":"To sift; to bolt.","pos":""}],"SEARCER":[{"def":"One who sifts or bolts.","pos":""},{"def":"A searce, or sieve.","pos":""}],"SEARCH":[{"def":"To look over or through, for the purpose of finding something; to examine; to explore; as, to search the city.","pos":""},{"def":"To inquire after; to look for; to seek.","pos":""}],"SEARCHABLE":[{"def":"Capable of being searched.","pos":""}],"SEARCHABLENESS":[{"def":"Quality of being searchable.","pos":""}],"SEARCHER":[{"def":"One who, or that which, searhes or examines; a seeker; an inquirer; an examiner; a trier.","pos":""}],"SEARCHING":[{"def":"Exploring thoroughly; scrutinizing; penetrating; trying; as, a searching discourse; a searching eye.","pos":""}],"SEARCHLESS":[{"def":"Impossible to be searched; inscrutable; impenetrable.","pos":""}],"SEARCLOTH":[{"def":"To cover, as a sore, with cerecloth.","pos":""}],"SEARED":[{"def":"Scorched; cauterized; hence, figuratively, insensible; not susceptible to moral influences.","pos":""}],"SEAREDNESS":[{"def":"The state of being seared or callous; insensibility.","pos":""}]}