{"SCUD":[{"def":"To be driven swiftly, or to run, before a gale, with little or no sail spread.","pos":""}],"SCUDDLE":[{"def":"To run hastily; to hurry; to scuttle.","pos":""}],"SCUFF":[{"def":"The back part of the neck; the scruff.","pos":""}],"SCUFFLE":[{"def":"To strive or struggle with a close grapple; to wrestle in a rough fashion.","pos":"verb"},{"def":"Hence, to strive or contend tumultuously; to struggle confusedly or at haphazard.","pos":"verb"}],"SCUFFLER":[{"def":"One who scuffles.","pos":""},{"def":"An agricultural implement resembling a scarifier, but usually lighter.","pos":""}],"SCUG":[{"def":"A place of shelter; the declivity of a hill.","pos":""},{"def":"See Skulk, Skulker.","pos":""}],"SCULL":[{"def":"A shoal of fish.","pos":""}],"SCULLER":[{"def":"A boat rowed by one man with two sculls, or short oars.","pos":""}],"SCULLERY":[{"def":"A place where dishes, kettles, and culinary utensils, are cleaned and kept; also, a room attached to the kitchen, where the coarse work is done; a back kitchen.","pos":""},{"def":"Hence, refuse; fifth; offal.","pos":""}],"SCULLION":[{"def":"A servant who cleans pots and kettles, and does other menial services in the kitchen.","pos":""}],"SCULLIONLY":[{"def":"Like a scullion; base.","pos":""}],"SCULP":[{"def":"To sculpture; to carve; to engrave.","pos":""}],"SCULPIN":[{"def":"Cottus, or Acanthocottus, having a large head armed with sharp spines, and a broad mouth.","pos":""}],"SCULPTILE":[{"def":"Formed by carving; graven; as, sculptile images.","pos":""}],"SCULPTOR":[{"def":"One who sculptures; one whose occupation is to carve statues, or works of sculpture.","pos":""},{"def":"Hence, an artist who designs works of sculpture, his first studies and his finished model being usually in a plastic material, from which model the marble is cut, or the bronze is cast.","pos":""}],"SCULPTRESS":[{"def":"A female sculptor.","pos":""}],"SCULPTURAL":[{"def":"Of or pertaining to sculpture.","pos":""}],"SCULPTURE":[{"def":"The art of carving, cutting, or hewing wood, stone, metal, etc.","pos":""},{"def":"Carved work modeled of, or cut upon, wood, stone, metal, etc.","pos":""}],"SCULPTURESQUE":[{"def":"After the manner of sculpture; resembling, or relating to, sculpture.","pos":""}],"SCUM":[{"def":"The extraneous matter or impurities which rise to the surface of liquids in boiling or fermentation, or which form on the surface by other means; also, the scoria of metals in a molten state; dross.","pos":""}],"SCUMBER":[{"def":"To void excrement.","pos":""}],"SCUMBLE":[{"def":"To cover lighty, as a painting, or a drawing, with a thin wash of opaque color, or with color-crayon dust rubbed on with the stump, or to make any similar additions to the work, so as to produce a softened effect.","pos":""}],"SCUMBLING":[{"def":"The color so laid on.","pos":""}],"SCUMMER":[{"def":"Excrement; scumber.","pos":""}],"SCUMMY":[{"def":"Covered with scum; of the nature of scum.","pos":""}],"SCUNNER":[{"def":"To cause to loathe, or feel disgust at.","pos":""}],"SCUP":[{"def":"A marine sparoid food fish (Stenotomus chrysops, or S.","pos":""}],"SCUPPER":[{"def":"An opening cut through the waterway and bulwarks of a ship, so that water falling on deck may flow overboard; -- called also scupper hole.","pos":""}],"SCUPPERNONG":[{"def":"An American grape, a form of Vitis vulpina, found in the Southern Atlantic States, and often cultivated.","pos":""}],"SCUR":[{"def":"To move hastily; to scour.","pos":""}],"SCURF":[{"def":"Minute membranous scales on the surface of some leaves, as in the goosefoot.","pos":""}],"SCURFINESS":[{"def":"Quality or state of being scurfy.","pos":""}],"SCURFY":[{"def":"Having or producing scurf; covered with scurf; resembling scurf.","pos":""}],"SCURRIER":[{"def":"One who scurries.","pos":""}],"SCURRILE":[{"def":"Such as befits a buffoon or vulgar jester; grossly opprobrious or loudly jocose in language; scurrilous; as, scurrile taunts.","pos":""}],"SCURRILITY":[{"def":"The quality or state of being scurrile or scurrilous; mean, vile, or obscene jocularity.","pos":""},{"def":"That which is scurrile or scurrilous; gross or obscene language; low buffoonery; vulgar abuse.","pos":""}],"SCURRILOUS":[{"def":"Using the low and indecent language of the meaner sort of people, or such as only the license of buffoons can warrant; as, a scurrilous fellow.","pos":""},{"def":"Containing low indecency or abuse; mean; foul; vile; obscenely jocular; as, scurrilous language.","pos":""}],"SCURRIT":[{"def":"the lesser tern (Sterna minuta).","pos":""}],"SCURRY":[{"def":"To hasten away or along; to move rapidly; to hurry; as, the rabbit scurried away.","pos":""}],"SCURVILY":[{"def":"In a scurvy manner.","pos":""}],"SCURVINESS":[{"def":"The quality or state of being scurvy; vileness; meanness.","pos":""}],"SCURVY":[{"def":"Covered or affected with scurf or scabs; scabby; scurfy; specifically, diseased with the scurvy.","pos":""},{"def":"Vile; mean; low; vulgar; contemptible.","pos":""}],"SCUT":[{"def":"The tail of a hare, or of a deer, or other animal whose tail is short, sp.","pos":""}],"SCUTAGE":[{"def":"Shield money; commutation of service for a sum of money.","pos":""}],"SCUTAL":[{"def":"Of or pertaining to a shield.","pos":""}],"SCUTATE":[{"def":"Protected or covered by bony or horny plates, or large scales.","pos":""}],"SCUTCH":[{"def":"To beat or whip; to drub.","pos":""},{"def":"To separate the woody fiber from (flax, hemp, etc.","pos":""}],"SCUTCH GRASS":[{"def":"A kind of pasture grass (Cynodon Dactylon).","pos":""}],"SCUTCHEON":[{"def":"An escutcheon; an emblazoned shield.","pos":""},{"def":"A small plate of metal, as the shield around a keyhole.","pos":""}],"SCUTCHEONED":[{"def":"Emblazoned on or as a shield.","pos":""}],"SCUTCHER":[{"def":"One who scutches.","pos":""},{"def":"An implement or machine for scutching hemp, flax, or cotton; etc.","pos":""}],"SCUTE":[{"def":"A bony scale of a reptile or fish; a large horny scale on the leg of a bird, or on the belly of a snake.","pos":""}],"SCUTELLA":[{"def":"See Scutellum, n.","pos":""},{"def":"Formed like a plate or salver; composed of platelike surfaces; as, the scutellated bone of a sturgeon.","pos":""}],"SCUTELLATION":[{"def":"the entire covering, or mode of arrangement, of scales, as on the legs and feet of a bird.","pos":""}],"SCUTELLIFORM":[{"def":"Having the form of a scutellum.","pos":""}],"SCUTELLIPLANTAR":[{"def":"Having broad scutella on the front, and small scales on the posterior side, of the tarsus; -- said of certain birds.","pos":""}],"SCUTELLUM":[{"def":"A rounded apothecium having an elevated rim formed of the proper thallus, the fructification of certain lichens.","pos":""}],"SCUTIBRANCH":[{"def":"Scutibranchiate.","pos":""},{"def":"One of the Scutibranchiata.","pos":""}],"SCUTIBRANCHIA":[{"def":"Same as Scutibranchiata.","pos":""}],"SCUTIBRANCHIAN":[{"def":"One of the Scutibranchiata.","pos":""}],"SCUTIBRANCHIATA":[{"def":"An order of gastropod Mollusca having a heart with two auricles and one ventricle.","pos":""}],"SCUTIBRANCHIATE":[{"def":"Having the gills protected by a shieldlike shell; of or pertaining to the Scutibranchiata.","pos":""},{"def":"One of the Scutibranchiata.","pos":""}],"SCUTIFEROUS":[{"def":"Carrying a shield or buckler.","pos":""}],"SCUTIFORM":[{"def":"Shield-shaped; scutate.","pos":""}],"SCUTIGER":[{"def":"Any species of chilopod myriapods of the genus Scutigera.","pos":""}],"SCUTIPED":[{"def":"Having the anterior surface of the tarsus covered with scutella, or transverse scales, in the form of incomplete bands terminating at a groove on each side; -- said of certain birds.","pos":""}],"SCUTTER":[{"def":"To run quickly; to scurry; to scuttle.","pos":""}],"SCUTTLE":[{"def":"A broad, shallow basket.","pos":""},{"def":"A wide-mouthed vessel for holding coal: a coal hod.","pos":""}],"SCUTUM":[{"def":"An oblong shield made of boards or wickerwork covered with leather, with sometimes an iron rim; -- carried chiefly by the heavy- armed infantry.","pos":""},{"def":"A penthouse or awning.","pos":""}]}