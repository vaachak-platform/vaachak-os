{"PIP":[{"def":"A contagious disease of fowls, characterized by hoarseness, discharge from the nostrils and eyes, and an accumulation of mucus in the mouth, forming a \"scale\" on the tongue.","pos":""}],"PIPA":[{"def":"The Surinam toad (Pipa Americana), noted for its peculiar breeding habits.","pos":""}],"PIPAGE":[{"def":"Transportation, as of petroleum oil, by means of a pipe conduit; also, the charge for such transportation.","pos":""}],"PIPAL TREE":[{"def":"Same as Peepul tree.","pos":""}],"PIPE":[{"def":"The bagpipe; as, the pipes of Lucknow.","pos":""},{"def":"An elongated body or vein of ore.","pos":""}],"PIPE CLAY":[{"def":"A plastic, unctuous clay of a grayish white color, -- used in making tobacco pipes and various kinds of earthenware, in scouring cloth, and in cleansing soldiers' equipments.","pos":""}],"PIPE LINE":[{"def":"A line of pipe with pumping machinery and apparatus for conveying liquids, esp.","pos":""}],"PIPE-LINE":[{"def":"To convey by a pipe line; to furnish with a pipe line or pipe lines.","pos":""}],"PIPECLAY":[{"def":"To whiten or clean with pipe clay, as a soldier's accouterments.","pos":""},{"def":"To clear off; as, to pipeclay accounts.","pos":""}],"PIPED":[{"def":"Formed with a pipe; having pipe or pipes; tubular.","pos":""}],"PIPEFISH":[{"def":"Any lophobranch fish of the genus Siphostoma, or Syngnathus, and allied genera, having a long and very slender angular body, covered with bony plates.","pos":""},{"def":"A politician who works in secret; -- in this sense, usually written as one word.","pos":""}],"PIPEMOUTH":[{"def":"Any fish of the genus Fistularia; -- called also tobacco pipefish.","pos":""}],"PIPER":[{"def":"One who plays on a pipe, or the like, esp.","pos":""}],"PIPERACEOUS":[{"def":"Of or pertaining to the order of plants (Piperaceæ) of which the pepper (Piper nigrum) is the type.","pos":""},{"def":"A crystalline substance, (C2H4NH)2, formed by action of ammonia on ethylene bromide, by reduction of pyrazine, etc.","pos":""}],"PIPERIC":[{"def":"Pertaining to, or derived from, or designating, a complex organic acid found in the products of different members of the Pepper family, and extracted as a yellowish crystalline substance.","pos":""}],"PIPERIDGE":[{"def":"Same as Pepperidge.","pos":""}],"PIPERIDINE":[{"def":"An oily liquid alkaloid, C5H11N, having a hot, peppery, ammoniacal odor.","pos":""}],"PIPERINE":[{"def":"A white crystalline compound of piperidine and piperic acid.","pos":""}],"PIPERONAL":[{"def":"A white crystalline substance obtained by oxidation of piperic acid, and regarded as a complex aldehyde.","pos":""}],"PIPERYLENE":[{"def":"A hydrocarbon obtained by decomposition of certain piperidine derivatives.","pos":""}],"PIPESTEM":[{"def":"The hollow stem or tube of a pipe used for smoking tobacco, etc.","pos":""}],"PIPESTONE":[{"def":"A kind of clay slate, carved by the Indians into tobacco pipes.","pos":""}],"PIPETTE":[{"def":"A small glass tube, often with an enlargement or bulb in the middle, and usually graduated, -- used for transferring or delivering measured quantities.","pos":""}],"PIPEVINE":[{"def":"The Dutchman's pipe.","pos":""}],"PIPEWOOD":[{"def":"An ericaceous shrub (Leucothoë acuminata) of the southern United States, from the wood of which pipe bowls are made.","pos":""}],"PIPEWORT":[{"def":"Any plant of a genus (Eriocaulon) of aquatic or marsh herbs with soft grass-like leaves.","pos":""}],"PIPING":[{"def":"Playing on a musical pipe.","pos":""},{"def":"Peaceful; favorable to, or characterized by, the music of the pipe rather than of the drum and fife.","pos":""}],"PIPIT":[{"def":"Any one of numerous species of small singing birds belonging to Anthus and allied genera, of the family Motacillidæ.","pos":""}],"PIPKIN":[{"def":"A small earthen boiler.","pos":"noun"}],"PIPPIN":[{"def":"We will eat a last year's pippin.","pos":""}],"PIPPUL TREE":[{"def":"Same as Peepul tree.","pos":""}],"PIPRA":[{"def":"Any one of numerous species of small clamatorial birds belonging to Pipra and allied genera, of the family Pipridæ.","pos":""}],"PIPRINE":[{"def":"Of or pertaining to the pipras, or the family Pipridæ.","pos":""}],"PIPSISSEWA":[{"def":"A low evergreen plant (Chimaphila umbellata), with narrow, wedge-lanceolate leaves, and an umbel of pretty nodding fragrant blossoms.","pos":""}],"PIPY":[{"def":"Like a pipe; hollow-stemmed.","pos":""}]}