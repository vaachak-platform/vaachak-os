{"SUPRA":[{"def":"Over; above; before; also, beyond; besides; -- much used as a prefix.","pos":""}],"SUPRA-ACROMIAL":[{"def":"Situated above the acromial process of the scapula.","pos":""}],"SUPRA-AURICULAR":[{"def":"Situated above the ear coverts, or auriculars; -- said of certain feathers of birds.","pos":""},{"def":"A supra-auricular feather.","pos":""}],"SUPRA-AXILLARY":[{"def":"Growing above the axil; inserted above the axil, as a peduncle.","pos":""}],"SUPRA-ETHMOID":[{"def":"Above, or on the dorsal side of, the ethmoid bone or cartilage.","pos":""}],"SUPRA-ILIUM":[{"def":"The cartilaginous cap at the sacral end of the ilium of some animals.","pos":""}],"SUPRA-OESOPHAGAL":[{"def":"See Supra-esophagal.","pos":""},{"def":"Situated above the orbit of the eye.","pos":""}],"SUPRABRANCHIAL":[{"def":"Situated above the branchiæ; -- applied especially to the upper division of the gill cavity of bivalve mollusks.","pos":""},{"def":"Situated above the choroid; -- applied to the layer of the choroid coat of the eyeball next to the sclerotic.","pos":""}],"SUPRACLAVICLE":[{"def":"A bone which usually connects the clavicle with the post- temporal in the pectorial arch of fishes.","pos":""}],"SUPRACLAVICULAR":[{"def":"Situated above a condyle or condyles.","pos":""}],"SUPRACOSTAL":[{"def":"Situated above, or on the outside of, the ribs.","pos":""}],"SUPRACRANIAL":[{"def":"Situated above, or in the roof of, the cranium.","pos":""}],"SUPRACRETACEOUS":[{"def":"Lying above the chalk; Supercretaceous.","pos":""}],"SUPRADECOMPOUND":[{"def":"More than decompound; divided many times.","pos":""},{"def":"Situated above, or on the dorsal side of, the esophagus; as, the supra-esophageal ganglion of Crustacea.","pos":""}],"SUPRAFOLIACEOUS":[{"def":"Inserted into the stem above the leaf, petiole, or axil, as a peduncle or flower.","pos":""}],"SUPRAGLOTIC":[{"def":"Situated above the glottis; -- applied to that part of the cavity of the larynx above the true vocal cords.","pos":""}],"SUPRAHEPATIC":[{"def":"Situated over, or on the dorsal side of, the liver; -- applied to the branches of the hepatic veins.","pos":""}],"SUPRALAPSARIAN":[{"def":"Su`pra*lap*sa\"ri*an, n.","pos":""}],"SUPRALAPSARIANISM":[{"def":"The doctrine, belief, or principles of the Supralapsarians.","pos":""}],"SUPRALAPSARY":[{"def":"A Supralapsarian.","pos":""}],"SUPRALORAL":[{"def":"Situated above the lores; as, the supraloral feathers of a bird.","pos":""},{"def":"A supraloral feather.","pos":""}],"SUPRAMAXILLA":[{"def":"The upper jaw or maxilla.","pos":""}],"SUPRAMAXILLARY":[{"def":"Su`pra*max\"il*la*ry, a.","pos":""}],"SUPRAMUNDANE":[{"def":"Being or situated above the world or above our system; celestial.","pos":""}],"SUPRANATURALISM":[{"def":"The state of being supernatural; belief in supernatural agency or revelation; supernaturalism.","pos":""}],"SUPRANATURALIST":[{"def":"A supernaturalist.","pos":""},{"def":"Of or pertaining to supernaturalism; supernaturalistic.","pos":""}],"SUPRAOCCIPITAL":[{"def":"Situated over, or in the upper part of, the occiput; of or pertaining to the supraoccipital bone.","pos":""},{"def":"The supraoccipital bone.","pos":""}],"SUPRAOCULAR":[{"def":"Above the eyes; -- said of certain scales of fishes and reptiles.","pos":""}],"SUPRAPEDAL":[{"def":"Situated above the foot of a mollusk; as, the suprapedal gland.","pos":""}],"SUPRAPROTEST":[{"def":"An acceptance of a bill by a third person after protest for nonacceptance by the drawee.","pos":""},{"def":"Situated above, or anterior to, the pubic bone.","pos":""}],"SUPRARENAL":[{"def":"Situated above, or anterior to, the kidneys.","pos":""},{"def":"A suprarenal capsule.","pos":""}],"SUPRASPHENOIDAL":[{"def":"Situated above the sphenoidal bone; as, the suprasphenoidal appendage, or pituitary body.","pos":""}],"SUPRASPINAL":[{"def":"Situated above a spine or spines; especially, situated above, or on the dorsal side of, the neural spines of the vertebral column, or above, or in front of, the spine of the scapula.","pos":""}],"SUPRASTAPEDIAL":[{"def":"Of, pertaining to, or designating, that part of the columella of the ear which projects above the connection with the stapes, as in many animals.","pos":""},{"def":"The suprastapedial part of the columella.","pos":""}],"SUPRASTERNAL":[{"def":"Situated above, or anterior to, the sternum.","pos":""}],"SUPRATEMPORAL":[{"def":"Situated above the temporal bone or temporal fossa.","pos":""},{"def":"A supratemporal bone.","pos":""}],"SUPRATROCHLEAR":[{"def":"Situated over or above a trochlea or trochlear surface; -- applied esp.","pos":""}],"SUPRAVAGINAL":[{"def":"Situated above or outside a sheath or vaginal membrane.","pos":""}],"SUPRAVULGAR":[{"def":"Being above the vulgar or common people.","pos":""}],"SUPREMACY":[{"def":"The state of being supreme, or in the highest station of power; highest or supreme authority or power; as, the supremacy of a king or a parliament.","pos":""}],"SUPREME":[{"def":"Situated at the highest part or point.","pos":""}],"SUPREMELY":[{"def":"In a supreme manner.","pos":""}]}