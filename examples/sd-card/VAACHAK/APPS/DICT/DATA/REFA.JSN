{"REFACTION":[{"def":"Recompense; atonemet; retribution.","pos":""}],"REFAIT":[{"def":"A drawn game; specif.","pos":""},{"def":"a state of the game in which the aggregate pip value of cards dealt to red equals that of those dealt to black.","pos":""}],"REFAR":[{"def":"To go over again; to repeat.","pos":""}],"REFASHION":[{"def":"To fashion anew; to form or mold into shape a second time.","pos":""}],"REFASHIONMENT":[{"def":"The act of refashioning, or the state of being refashioned.","pos":""}],"REFASTEN":[{"def":"To fasten again.","pos":""}]}