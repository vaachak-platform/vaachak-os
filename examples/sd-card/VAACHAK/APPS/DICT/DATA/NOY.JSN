{"NOY":[{"def":"To annoy; to vex.","pos":""}],"NOYADE":[{"def":"A drowning of many persons at once, -- a method of execution practiced at Nantes in France during the Reign of Terror, by Jean Baptiste Carrier.","pos":""}],"NOYANCE":[{"def":"Noy\"ance Defn: , Annoyance.","pos":""}],"NOYAU":[{"def":"A cordial of brandy, etc.","pos":""}],"NOYFUL":[{"def":"Full of annoyance.","pos":""}],"NOYOUS":[{"def":"Annoying; disagreeable.","pos":""}]}