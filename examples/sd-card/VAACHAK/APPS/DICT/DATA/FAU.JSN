{"FAUBOURG":[{"def":"A suburb of French city; also, a district now within a city, but formerly without its walls.","pos":""}],"FAUCAL":[{"def":"Pertaining to the fauces, or opening of the throat; faucial; esp.","pos":""}],"FAUCES":[{"def":"The narrow passage from the mouth to the pharynx, situated between the soft palate and the base of the tongue; -- called also the isthmus of the fauces.","pos":"noun"},{"def":"The throat of a calyx, corolla, etc.","pos":"noun"}],"FAUCET":[{"def":"A fixture for drawing a liquid, as water, molasses, oil, etc.","pos":""},{"def":"The enlarged end of a section of pipe which receives the spigot end of the next section.","pos":""}],"FAUCIAL":[{"def":"Pertaining to the fauces; pharyngeal.","pos":""}],"FAUGH":[{"def":"An exclamation of contempt, disgust, or abhorrence.","pos":""}],"FAULD":[{"def":"The arch over the dam of a blast furnace; the tymp arch.","pos":""}],"FAULE":[{"def":"A fall or falling band.","pos":""}],"FAULT":[{"def":"A lost scent; act of losing the scent.","pos":""},{"def":"Failure to serve the ball into the proper court.","pos":""}],"FAULT-FINDER":[{"def":"One who makes a practice off discovering others' faults and censuring them; a scold.","pos":""}],"FAULT-FINDING":[{"def":"The act of finding fault or blaming; -- used derogatively.","pos":""}],"FAULTER":[{"def":"One who commits a fault.","pos":""}],"FAULTFUL":[{"def":"Full of faults or sins.","pos":""}],"FAULTILY":[{"def":"In a faulty manner.","pos":""}],"FAULTINESS":[{"def":"Quality or state of being faulty.","pos":""}],"FAULTING":[{"def":"The state or condition of being faulted; the process by which a fault is produced.","pos":""}],"FAULTLESS":[{"def":"Without fault; not defective or imperfect; free from blemish; free from incorrectness, vice, or offense; perfect; as, a faultless poem.","pos":""}],"FAULTY":[{"def":"Containing faults, blemishes, or defects; imperfect; not fit for the use intended.","pos":""},{"def":"Guilty of a fault, or of faults; hence, blamable; worthy of censure.","pos":""}],"FAUN":[{"def":"A god of fields and shipherds, diddering little from the satyr.","pos":""}],"FAUNA":[{"def":"The animals of any given area or epoch; as, the fauna of America; fossil fauna; recent fauna.","pos":""}],"FAUNAL":[{"def":"Relating to fauna.","pos":""}],"FAUNIST":[{"def":"One who describes the fauna of country; a naturalist.","pos":""}],"FAUSSE-BRAYE":[{"def":"A second raampart, exterior to, and parallel to, the main rampart, and considerably below its level.","pos":""}],"FAUTEUIL":[{"def":"An armchair; hence (because the members sit in fauteuils or armchairs), membership in the French Academy.","pos":""},{"def":"Chair of a presiding officer.","pos":""}],"FAUTOR":[{"def":"A favorer; a patron; one who gives countenance or support; an abettor.","pos":""}],"FAUVETTE":[{"def":"A small singing bird, as the nightingale and warblers.","pos":""}],"FAUX PAS":[{"def":"A false step; a mistake or wrong measure.","pos":""}]}