{"SCAR":[{"def":"A mark left upon a stem or branch by the fall of a leaf, leaflet, or frond, or upon a seed by the separation of its support.","pos":""}],"SCARABOID":[{"def":"Of or pertaining to the family Scarabæidæ, an extensive group which includes the Egyptian scarab, the tumbleding, and many similar lamellicorn beetles.","pos":""}],"SCARAMOUCH":[{"def":"A personage in the old Italian comedy (derived from Spain) characterized by great boastfulness and poltroonery; hence, a person of like characteristics; a buffoon.","pos":""}],"SCARCE":[{"def":"Not plentiful or abundant; in small quantity in proportion to the demand; not easily to be procured; rare; uncommon.","pos":""},{"def":"Scantily supplied (with); deficient (in); -- with of.","pos":""}],"SCARCEMENT":[{"def":"An offset where a wall or bank of earth, etc.","pos":""},{"def":"The quality or condition of being scarce; smallness of quantity in proportion to the wants or demands; deficiency; lack of plenty; short supply; penury; as, a scarcity of grain; a great scarcity of beauties.","pos":""}],"SCARD":[{"def":"A shard or fragment.","pos":""}],"SCARE":[{"def":"To frighten; to strike with sudden fear; to alarm.","pos":""}],"SCARECROW":[{"def":"Anything set up to frighten crows or other birds from cornfields; hence, anything terifying without danger.","pos":""},{"def":"A person clad in rags and tatters.","pos":""}],"SCAREFIRE":[{"def":"An alarm of fire.","pos":""},{"def":"A fire causing alarm.","pos":""}],"SCARF":[{"def":"An article of dress of a light and decorative character, worn loosely over the shoulders or about the neck or the waist; a light shawl or handkerchief for the neck; also, a cravat; a neckcloth.","pos":""}],"SCARIFICATION":[{"def":"The act of scarifying.","pos":""}],"SCARIFICATOR":[{"def":"An instrument, principally used in cupping, containing several lancets moved simultaneously by a spring, for making slight incisions.","pos":""}],"SCARIFIER":[{"def":"The instrument used for scarifying.","pos":""},{"def":"An implement for stripping and loosening the soil, without bringing up a fresh surface.","pos":""}],"SCARIFY":[{"def":"To stir the surface soil of, as a field.","pos":""},{"def":"Thin, dry, membranous, and not green.","pos":""}],"SCARLET":[{"def":"A deep bright red tinged with orange or yellow, -- of many tints and shades; a vivid or bright red color.","pos":""}],"SCAROID":[{"def":"Of or pertaining to the Scaridæ, a family of marine fishes including the parrot fishes.","pos":""}],"SCARP":[{"def":"A band in the same position as the bend sinister, but only half as broad as the latter.","pos":""}],"SCARRING":[{"def":"We find upon the limestone rocks the scarrings of the ancient glacier which brought the bowlder here.","pos":""}],"SCARRY":[{"def":"Bearing scars or marks of wounds.","pos":""}],"SCARUS":[{"def":"A Mediterranean food fish (Sparisoma scarus) od excellent quality and highly valued by the Romans; -- called also parrot fish.","pos":""}],"SCARY":[{"def":"Barren land having only a thin coat of grass.","pos":""}]}