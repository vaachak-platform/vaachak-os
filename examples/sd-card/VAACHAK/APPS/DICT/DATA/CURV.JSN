{"CURVATION":[{"def":"The act of bending or crooking.","pos":""}],"CURVATIVE":[{"def":"Having the margins only a little curved; -- said of leaves.","pos":""}],"CURVATURE":[{"def":"The amount of degree of bending of a mathematical curve, or the tendency at any point to depart from a tangent drawn to the curve at that point.","pos":""}],"CURVE":[{"def":"Bent without angles; crooked; curved; as, a curve line; a curve surface.","pos":""}],"CURVEDNESS":[{"def":"The state of being curved.","pos":""}],"CURVET":[{"def":"A particular leap of a horse, when he raises both his fore legs at once, equally advanced, and, as his fore legs are falling, raises his hind legs, so that all his legs are in the air at once.","pos":""}],"CURVICAUDATE":[{"def":"Having a curved or crooked tail.","pos":""}],"CURVICOSTATE":[{"def":"Having bent ribs.","pos":""}],"CURVIDENTATE":[{"def":"Having curved teeth.","pos":""}],"CURVIFORM":[{"def":"Having a curved form.","pos":""}],"CURVILINEAD":[{"def":"An instrument for drawing curved lines.","pos":""},{"def":"Consisting of, or bounded by, curved lines; as, a curvilinear figure.","pos":""}],"CURVILINEARITY":[{"def":"The state of being curvilinear or of being bounded by curved lines.","pos":""}],"CURVILINEARLY":[{"def":"In a curvilinear manner.","pos":""}],"CURVINERVED":[{"def":"Having the ribs or the veins of the leaves curved; -- called also curvinervate and curve-veined.","pos":""}],"CURVIROSTRAL":[{"def":"Having a crooked beak, as the crossbill.","pos":""}],"CURVIROSTRES":[{"def":"A group of passerine birds, including the creepers and nuthatches.","pos":""}],"CURVISERIAL":[{"def":"Distributed in a curved line, as leaves along a stem.","pos":""}],"CURVITY":[{"def":"The state of being curved; a bending in a regular form; crookedness.","pos":""}],"CURVOGRAPH":[{"def":"Cur\"vo*graph (kr\"v-grf), n.","pos":""}]}