{"GAUCHE":[{"def":"Winding; twisted; warped; -- applied to curves and surfaces.","pos":""}],"GAUCHERIE":[{"def":"An awkward action; clumsiness; boorishness.","pos":""}],"GAUCHO":[{"def":"On of the native inhabitants of the pampas, of Spanish-American descent.","pos":""}],"GAUD":[{"def":"Trick; jest; sport.","pos":""},{"def":"Deceit; fraud; artifice; device.","pos":""}],"GAUD-DAY":[{"def":"See Gaudy, a feast.","pos":""}],"GAUDERY":[{"def":"Finery; ornaments; ostentatious display.","pos":""}],"GAUDILY":[{"def":"In a gaudy manner.","pos":""}],"GAUDINESS":[{"def":"The quality of being gaudy.","pos":""}],"GAUDLESS":[{"def":"Destitute of ornament.","pos":""}],"GAUDY":[{"def":"Ostentatiously fine; showy; gay, but tawdry or meretricious.","pos":""},{"def":"Gay; merry; festal.","pos":""}],"GAUFFER":[{"def":"To plait, crimp, or flute; to goffer, as lace.","pos":""}],"GAUFFERING":[{"def":"A mode of plaiting or fluting.","pos":""}],"GAUGE":[{"def":"To measure the dimensions of, or to test the accuracy of the form of, as of a part of a gunlock.","pos":""}],"GAUGEABLE":[{"def":"Capable of being gauged.","pos":""}],"GAUGED":[{"def":"Tested or measured by, or conformed to, a gauge.","pos":""}],"GAUGER":[{"def":"One who gauges; an officer whose business it is to ascertain the contents of casks.","pos":""}],"GAUGER-SHIP":[{"def":"The office of a gauger.","pos":""}],"GAUGING ROD":[{"def":"See Gauge rod, under Gauge, n.","pos":""}],"GAUL":[{"def":"The Anglicized form of Gallia, which in the time of the Romans included France and Upper Italy (Transalpine and Cisalpine Gaul).","pos":""},{"def":"A native or inhabitant of Gaul.","pos":""}],"GAULISH":[{"def":"Pertaining to ancient France, or Gaul; Gallic.","pos":""}],"GAULT":[{"def":"A series of beds of clay and marl in the South of England, between the upper and lower greensand of the Cretaceous period.","pos":""}],"GAULTHERIA":[{"def":"A genus of ericaceous shrubs with evergreen foliage, and, often, edible berries.","pos":""}],"GAUNT":[{"def":"Attenuated, as with fasting or suffering; lean; meager; pinched and grim.","pos":""}],"GAUNTLET":[{"def":"A rope on which hammocks or clothes are hung for drying.","pos":""}],"GAUNTLETTED":[{"def":"Wearing a gauntlet.","pos":""}],"GAUNTLY":[{"def":"In a gaunt manner; meagerly.","pos":""},{"def":"A scaffolding or frame carrying a crane or other structure.","pos":""}],"GAUR":[{"def":"An East Indian species of wild cattle (Bibos gauris), of large size and an untamable disposition.","pos":""}],"GAURE":[{"def":"To gaze; to stare.","pos":""}],"GAUSSAGE":[{"def":"The intensity of a magnetic field expressed in C.","pos":""}],"GAUZE":[{"def":"A very thin, slight, transparent stuff, generally of silk; also, any fabric resembling silk gauze; as, wire gauze; cotton gauze.","pos":""}],"GAUZINESS":[{"def":"The quality of being gauzy; flimsiness.","pos":""}],"GAUZY":[{"def":"Pertaining to, or resembling, gauze; thin and slight as gauze.","pos":""}]}