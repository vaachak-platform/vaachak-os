{"TUCAN":[{"def":"The Mexican pocket gopher (Geomys Mexicanus).","pos":""}],"TUCET":[{"def":"See Tucket, a steak.","pos":""}],"TUCH":[{"def":"A dark-colored kind of marble; touchstone.","pos":""}],"TUCK":[{"def":"A long, narrow sword; a rapier.","pos":""}],"TUCK POINTING":[{"def":"The finishing of joints along the center lines with a narrow ridge of putty or fine lime mortar.","pos":""}],"TUCKAHOE":[{"def":"A curious vegetable production of the Southern Atlantic United States, growing under ground like a truffle and often attaining immense size.","pos":""}],"TUCKER":[{"def":"One who, or that which, tucks; specifically, an instrument with which tuck are made.","pos":""},{"def":"A narrow piece of linen or the like, folded across the breast, or attached to the gown at the neck, forming a part of a woman's dress in the 17th century and later.","pos":""}],"TUCKET":[{"def":"A slight flourish on a trumpet; a fanfare.","pos":""}],"TUCUM":[{"def":"A fine, strong fiber obtained from the young leaves of a Brazilian palm (Astrocaryum vulgare), used for cordage, bowstrings, etc.","pos":""}],"TUCUMA":[{"def":"A Brazilian palm (Astrocaryum Tucuma) which furnishes an edible fruit.","pos":""}]}