{"GRAY":[{"def":"White mixed with black, as the color of pepper and salt, or of ashes, or of hair whitened by age; sometimes, a dark mixed color; as, the soft gray eye of a dove.","pos":""},{"def":"Gray-haired; gray-headed; of a gray color; hoary.","pos":""}],"GRAYFLY":[{"def":"The trumpet fly.","pos":""}],"GRAYHOUND":[{"def":"Gray\"hound` (-hound`), n.","pos":""}],"GRAYLAG":[{"def":"The common wild gray goose (Anser anser) of Europe, believed to be the wild form of the domestic goose.","pos":""}],"GRAYLING":[{"def":"A European fish (Thymallus vulgaris), allied to the trout, but having a very broad dorsal fin; -- called also umber.","pos":""},{"def":"An American fish of the genus Thymallus, having similar habits to the above; one species (T.","pos":""}],"GRAYNESS":[{"def":"The quality of being gray.","pos":""}],"GRAYSTONE":[{"def":"A grayish or greenish compact rock, composed of feldspar and augite, and allied to basalt.","pos":""}],"GRAYWACKE":[{"def":"A conglomerate or grit rock, consisting of rounded pebbles sand firmly united together.","pos":""}]}