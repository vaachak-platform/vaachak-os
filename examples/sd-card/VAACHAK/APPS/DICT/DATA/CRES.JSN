{"CRESCENCE":[{"def":"Increase; enlargement.","pos":""}],"CRESCENDO":[{"def":"With a constantly increasing volume of voice; with gradually increasing strength and fullness of tone; -- a direction for the performance of music, indicated by the mark, or by writing the word on the score.","pos":""}],"CRESCENT":[{"def":"The emblem of the increasing moon with horns directed upward, when used in a coat of arms; -- often used as a mark of cadency to distinguish a second son and his descendants.","pos":""}],"CRESCENTIC":[{"def":"Crescent-shaped.","pos":""}],"CRESCENTWISE":[{"def":"In the form of a crescent; like a crescent.","pos":""}],"CRESCIVE":[{"def":"Increasing; growing.","pos":""}],"CRESOL":[{"def":"Any one of three metameric substances, CH3.","pos":""}],"CRESORCIN":[{"def":"Same as Isorcin.","pos":""}],"CRESS":[{"def":"A plant of various species, chiefly cruciferous.","pos":""}],"CRESSELLE":[{"def":"A wooden rattle sometimes used as a substitute for a bell, in the Roman Catholic church, during the latter part of Holy Week, or the last week of Lent.","pos":""}],"CRESSET":[{"def":"A small furnace or iron cage to hold fire for charring the inside of a cask, and making the staves flexible.","pos":""}],"CRESSY":[{"def":"Abounding in cresses.","pos":""}],"CREST":[{"def":"A bearing worn, not upon the shield, but usually above it, or separately as an ornament for plate, liveries, and the like.","pos":""},{"def":"The ornamental finishing which surmounts the ridge of a roof, canopy, etc.","pos":""}],"CRESTED":[{"def":"Having a crest of feathers or hair upon the head.","pos":""},{"def":"Bearing any elevated appendage like a crest, as an elevated line or ridge, or a tuft.","pos":""}],"CRESTFALLEN":[{"def":"With hanging head; hence, dispirited; dejected; cowed.","pos":""},{"def":"Having the crest, or upper part of the neck, hanging to one side; -- said of a horse.","pos":""}],"CRESTING":[{"def":"An ornamental finish on the top of a wall or ridge of a roof.","pos":""}],"CRESTLESS":[{"def":"Without a crest or escutcheon; of low birth.","pos":""}],"CRESYLIC":[{"def":"Pertaining to, or derived from, cresol, creosote, etc.","pos":""}]}