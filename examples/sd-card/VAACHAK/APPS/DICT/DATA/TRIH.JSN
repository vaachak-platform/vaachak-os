{"TRIHEDRAL":[{"def":"Having three sides or faces; thus, a trihedral angle is a solid angle bounded by three plane angles.","pos":""}],"TRIHEDRON":[{"def":"A figure having three sides.","pos":""}],"TRIHORAL":[{"def":"Occurring once in every three hours.","pos":""}],"TRIHYBRID":[{"def":"A hybrid whose parents differ by three pairs of contrasting Mendelian characters.","pos":""}]}