{"HUT":[{"def":"A small house, hivel, or cabin; a mean lodge or dwelling; a slightly built or temporary structure.","pos":""}],"HUTCH":[{"def":"To place in huts; to live in huts; as, to hut troops in winter quarters.","pos":""}],"HUTCHUNSONIAN":[{"def":"A follower of John Hutchinson of Yorkshire, England, who believed that the Hebrew Scriptures contained a complete system of natural science and of theology.","pos":""}],"HUTTONIAN":[{"def":"Relating to what is now called the Plutonic theory of the earth, first advanced by Dr.","pos":""}],"HUTTONING":[{"def":"Forcible manipulation of a dislocated, stiff, or painful joint.","pos":""}]}