{"ERODE":[{"def":"To eat into or away; to corrode; as, canker erodes the flesh.","pos":""}],"ERODED":[{"def":"Having the edge worn away so as to be jagged or irregularly toothed.","pos":""}],"ERODENT":[{"def":"A medicine which eats away extraneous growths; a caustic.","pos":""}],"EROGATE":[{"def":"To lay out, as money; to deal out; to expend.","pos":""}],"EROGATION":[{"def":"The act of giving out or bestowing.","pos":""}],"EROS":[{"def":"Love; the god of love; -- by earlier writers represented as one of the first and creative gods, by later writers as the son of Aphrodite, equivalent to the Latin god Cupid.","pos":""}],"EROSE":[{"def":"Jagged or irregularly toothed, as if nibbled out or gnawed.","pos":""}],"EROSION":[{"def":"The act or operation of eroding or eating away.","pos":""},{"def":"The state of being eaten away; corrosion; canker.","pos":""}],"EROSIVE":[{"def":"That erodes or gradually eats away; tending to erode; corrosive.","pos":""}],"EROTEME":[{"def":"A mark indicating a question; a note of interrogation.","pos":""}],"EROTESIS":[{"def":"A figure o Must I give way and room to your rash choler Shall I be frighted when a madman stares Shak.","pos":""},{"def":"Of or pertaining to the passion of love; treating of love; amatory.","pos":""}],"EROTIC":[{"def":"An amorous composition or poem.","pos":""}]}