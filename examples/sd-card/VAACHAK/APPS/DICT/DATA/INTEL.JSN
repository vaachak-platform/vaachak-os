{"INTELLECTED":[{"def":"Endowed with intellect; having intellectual powers or capacities.","pos":""}],"INTELLECTION":[{"def":"A mental act or process; especially: (a) The act of understanding; simple apprehension of ideas; intuition.","pos":""}],"INTELLECTIVE":[{"def":"Pertaining to, or produced by, the intellect or understanding; intellectual.","pos":""},{"def":"Having power to understand, know, or comprehend; intelligent; rational.","pos":""}],"INTELLECTIVELY":[{"def":"In an intellective manner.","pos":""}],"INTELLECTUAL":[{"def":"Belonging to, or performed by, the intellect; mental; as, intellectual powers, activities, etc.","pos":""},{"def":"Endowed with intellect; having the power of understanding; having capacity for the higher forms of knowledge or thought; characterized by intelligence or mental capacity; as, an intellectual person.","pos":""}],"INTELLECTUALISM":[{"def":"Intellectual power; intellectuality.","pos":""},{"def":"The doctrine that knowledge is derived from pure reason.","pos":""}],"INTELLECTUALIST":[{"def":"One who overrates the importance of the understanding.","pos":""},{"def":"One who accepts the doctrine of intellectualism.","pos":""}],"INTELLECTUALITY":[{"def":"Intellectual powers; possession of intellect; quality of being intellectual.","pos":""}],"INTELLECTUALIZE":[{"def":"To treat in an intellectual manner; to discuss intellectually; to reduce to intellectual form; to express intellectually; to idealize.","pos":""},{"def":"To endow with intellect; to bestow intellectual qualities upon; to cause to become intellectual.","pos":""}],"INTELLECTUALLY":[{"def":"In an intellectual manner.","pos":""}],"INTELLIGENCE":[{"def":"The act or state of knowing; the exercise of the understanding.","pos":""},{"def":"The capacity to know or understand; readiness of comprehension; the intellect, as a gift or an endowment.","pos":""}],"INTELLIGENCER":[{"def":"One who, or that which, sends or conveys intelligence or news; a messenger.","pos":""}],"INTELLIGENCING":[{"def":"Informing; giving information; talebearing.","pos":""}],"INTELLIGENT":[{"def":"Endowed with the faculty of understanding or reason; as, man is an intelligent being.","pos":""},{"def":"Possessed of intelligence, education, or judgment; knowing; sensible; skilled; marked by intelligence; as, an intelligent young man; an intelligent architect; an intelligent answer.","pos":""}],"INTELLIGENTIAL":[{"def":"Of or pertaining to the intelligence; exercising or implying understanding; intellectual.","pos":""},{"def":"Consisting of unembodied mind; incorporeal.","pos":""}],"INTELLIGENTIARY":[{"def":"One who gives information; an intelligencer.","pos":""}],"INTELLIGENTLY":[{"def":"In an intelligent manner; with intelligence.","pos":""}],"INTELLIGIBILITY":[{"def":"The quality or state of being intelligible; clearness; perspicuity; definiteness.","pos":""}],"INTELLIGIBLE":[{"def":"Capable of being understood or comprehended; as, an intelligible account or description; intelligible pronunciation, writing, etc.","pos":""}],"INTELLIGIBLENESS":[{"def":"The quality or state of being intelligible; intelligibility.","pos":""}],"INTELLIGIBLY":[{"def":"In an intelligible manner; so as to be understood; clearly; plainly; as, to write or speak intelligibly.","pos":""},{"def":"Pure; undefiled.","pos":""}]}