{"MAY":[{"def":"An auxiliary verb qualifyng the meaning of another verb, by expressing: (a) Ability, competency, or possibility; -- now oftener expressed by can.","pos":""}],"MAY LAWS":[{"def":"See Kulturkampf, above.","pos":""},{"def":"In Russia, severe oppressive laws against Jews, which have given occasion for great persecution; -- so called because they received the assent of the czar in May, 1882, and because likened to the Prussian May laws (see Kulturkampf).","pos":""}],"MAYA":[{"def":"The name for the doctrine of the unreality of matter, called, in English, idealism; hence, nothingness; vanity; illusion.","pos":""}],"MAYAN":[{"def":"A form of corbel arch employing regular small corbels.","pos":""}],"MAYBE":[{"def":"Perhaps; possibly; peradventure.","pos":""}],"MAYDUKE":[{"def":"A large dark-red cherry of excellent quality.","pos":""}],"MAYFISH":[{"def":"A common American minnow (Fundulus majalis).","pos":""}],"MAYFLOWER":[{"def":"In England, the hawthorn; in New England, the trailing arbutus (see Arbutus); also, the blossom of these plants.","pos":""}],"MAYHAP":[{"def":"Perhaps; peradventure.","pos":""}],"MAYHEM":[{"def":"The maiming of a person by depriving him of the use of any of his members which are necessary for defense or protection.","pos":""}],"MAYING":[{"def":"The celebrating of May Day.","pos":""}],"MAYONNAISE":[{"def":"A sauce compounded of raw yolks of eggs beaten up with olive oil to the consistency of a sirup, and seasoned with vinegar, pepper, salt, etc.","pos":""}],"MAYOR":[{"def":"The chief magistrate of a city or borough; the chief officer of a municipal corporation.","pos":""}],"MAYORAL":[{"def":"The conductir of a mule team; also, a head shepherd.","pos":""}],"MAYORALTY":[{"def":"The office, or the term of office, of a mayor.","pos":""}],"MAYORESS":[{"def":"The wife of a mayor.","pos":""}],"MAYORSHIP":[{"def":"The office of a mayor.","pos":""}],"MAYPOLE":[{"def":"A tall pole erected in an open place and wreathed with flowers, about which the rustic May-day sports were had.","pos":""}],"MAYPOP":[{"def":"The edible fruit of a passion flower, especially that of the North American Passiflora incarnata, an oval yellowish berry as large as a small apple.","pos":""}],"MAYWEED":[{"def":"A goatlike antelope (Haplocerus montanus) which inhabits the Rocky Mountains, frequenting the highest parts; -- called also mountain goat.","pos":""}]}