{"HOB":[{"def":"A threaded and fluted hardened steel cutter, resembling a tap, used in a lathe for forming the teeth of screw chasers, worm wheels, etc.","pos":""}],"HOBBIST":[{"def":"One who accepts the doctrines of Thomas Hobbes.","pos":""}],"HOBBLE":[{"def":"To walk lame, bearing chiefly on one leg; to walk with a hitch or hop, or with crutches.","pos":""},{"def":"To move roughly or irregularly; -- said of style in writing.","pos":""}],"HOBBLE SKIRT":[{"def":"A woman's skirt so scant at the bottom as to restrain freedom of movement after the fashion of a hobble.","pos":""}],"HOBBLEBUSH":[{"def":"A low bush (Viburnum lantanoides) having long, straggling branches and handsome flowers.","pos":""},{"def":"A youth between boy and man; an awkward, gawky young fellow .","pos":""}],"HOBBLER":[{"def":"One who hobbles.","pos":""}],"HOBBLINGLY":[{"def":"With a limping step.","pos":""}],"HOBBLY":[{"def":"Rough; uneven; causing one to hobble; as a hobbly road.","pos":""}],"HOBBY":[{"def":"A small, strong-winged European falcon (Falco subbuteo), formerly trained for hawking.","pos":""}],"HOBBYHORSICAL":[{"def":"Pertaining to, or having, a hobby or whim; eccentric; whimsical.","pos":""}],"HOBGOBLIN":[{"def":"A frightful goblin; an imp; a bugaboo; also, a name formerly given to the household spirit, Robin Goodfellow.","pos":""}],"HOBILER":[{"def":"A light horseman.","pos":"noun"}],"HOBIT":[{"def":"A small mortar on a gun carriage, in use before the howitzer.","pos":""}],"HOBNAIL":[{"def":"A short, sharp-pointed, large-headed nail, -- used in shoeing houses and for studding the soles of heavy shoes.","pos":""},{"def":"A clownish person; a rustic.","pos":""}],"HOBNAILED":[{"def":"See with hobnails, as a shoe.","pos":""}],"HOBNOB":[{"def":"Have or have not; -- a familiar invitation to reciprocal drinking.","pos":""},{"def":"At random; hit or miss.","pos":""}],"HOBO":[{"def":"A professional tramp; one who spends his life traveling from place to place, esp.","pos":""}],"HOBOY":[{"def":"A hautboy or oboe.","pos":""}],"HOBSON'S CHOICE":[{"def":"A choice without an alternative; the thing offered or nothing.","pos":""}]}