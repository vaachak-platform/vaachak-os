{"WEE":[{"def":"A little; a bit, as of space, time, or distance.","pos":""}],"WEED":[{"def":"A garment; clothing; especially, an upper or outer garment.","pos":""},{"def":"An article of dress worn in token of grief; a mourning garment or badge; as, he wore a weed on his hat; especially, in the plural, mourning garb, as of a woman; as, a widow's weeds.","pos":""}],"WEEDER":[{"def":"One who, or that which, weeds, or frees from anything noxious.","pos":""}],"WEEDERY":[{"def":"Weeds, collectively; also, a place full of weeds or for growing weeds.","pos":""}],"WEEDING-RHIM":[{"def":"A kind of implement used for tearing up weeds esp.","pos":""}],"WEEDLESS":[{"def":"Free from weeds or noxious matter.","pos":""}],"WEEDY":[{"def":"Of or pertaining to weeds; consisting of weeds.","pos":""},{"def":"Abounding with weeds; as, weedy grounds; a weedy garden; weedy corn.","pos":""}],"WEEK":[{"def":"A period of seven days, usually that reckoned from one Sabbath or Sunday to the next.","pos":""}],"WEEK-END":[{"def":"The end of the week; specif.","pos":""}],"WEEKLY":[{"def":"Of or pertaining to a week, or week days; as, weekly labor.","pos":""},{"def":"Coming, happening, or done once a week; hebdomadary; as, a weekly payment; a weekly gazette.","pos":""}],"WEEL":[{"def":"A kind of trap or snare for fish, made of twigs.","pos":""}],"WEEN":[{"def":"To think; to imagine; to fancy.","pos":""}],"WEEP":[{"def":"The lapwing; the wipe; -- so called from its cry.","pos":""}],"WEEPER":[{"def":"One who weeps; esp.","pos":""},{"def":"A white band or border worn on the sleeve as a badge of mourning.","pos":""}],"WEEPFUL":[{"def":"Full of weeping or lamentation; grieving.","pos":""}],"WEEPING":[{"def":"The act of one who weeps; lamentation with tears; shedding of tears.","pos":""}],"WEEPING-RIPE":[{"def":"Ripe for weeping; ready to weep.","pos":""}],"WEEPINGLY":[{"def":"In a weeping manner.","pos":""}],"WEET":[{"def":"To know; to wit.","pos":""}],"WEET-BIRD":[{"def":"The wryneck; -- so called from its cry.","pos":""}],"WEETLESS":[{"def":"Unknowing; also, unknown; unmeaning.","pos":""}],"WEETWEET":[{"def":"A throwing toy, or implement, of the Australian aborigines, consisting of a cigar-shaped stick fastened at one end to a flexible twig.","pos":""}],"WEEVER":[{"def":"Any one of several species of edible marine fishes belonging to the genus Trachinus, of the family Trachinidæ.","pos":""}],"WEEVIL":[{"def":"Any one of numerous species of snout beetles, or Rhynchophora, in which the head is elongated and usually curved downward.","pos":""}],"WEEVILED":[{"def":"Infested by weevils; as, weeviled grain.","pos":""}],"WEEVILY":[{"def":"Having weevils; weeviled.","pos":""}]}