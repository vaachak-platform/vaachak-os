{"UNSACRAMENT":[{"def":"To deprive of sacramental character or efficacy; as, to unsacrament the rite of baptism.","pos":""}],"UNSAD":[{"def":"Unsteady; fickle.","pos":""}],"UNSADDEN":[{"def":"To relieve from sadness; to cheer.","pos":""}],"UNSADDLE":[{"def":"To strip of a saddle; to take the saddle from, as a horse.","pos":""},{"def":"To throw from the saddle; to unhorse.","pos":""}],"UNSADNESS":[{"def":"Infirmity; weakness.","pos":""}],"UNSAFETY":[{"def":"The quality or state of being in peril; absence of safety; insecurity.","pos":""}],"UNSAINT":[{"def":"To deprive of saintship; to deny sanctity to.","pos":""}],"UNSAINTLY":[{"def":"Unbecoming to a saint.","pos":""}],"UNSALABLE":[{"def":"Not salable; unmerchantable.","pos":""},{"def":"That which can not be sold.","pos":""}],"UNSANCTIFICATION":[{"def":"Absence or lack of sanctification.","pos":""}],"UNSATIABILITY":[{"def":"Quality of being unsatiable; insatiability.","pos":""}],"UNSATISFACTION":[{"def":"Dissatisfaction.","pos":""}],"UNSATURATED":[{"def":"Capable of taking up, or of uniting with, certain other elements or compounds, without the elimination of any side product; thus, aldehyde, ethylene, and ammonia are unsaturated.","pos":""}],"UNSATURATION":[{"def":"The quality or state of being unsaturated.","pos":""}],"UNSAY":[{"def":"To recant or recall, as what has been said; to refract; to take back again; to make as if not said.","pos":""}]}