{"APO":[{"def":"A prefix from a Greek preposition.","pos":""}],"APOCALYPSE":[{"def":"Of or pertaining to a revelation, or, specifically, to the Revelation of St.","pos":""},{"def":"The writer of the Apocalypse.","pos":""}],"APOCALYPTICALLY":[{"def":"By revelation; in an apocalyptic manner.","pos":""}],"APOCARPOUS":[{"def":"Either entirely of partially separate, as the carpels of a compound pistil; -- opposed to syncarpous.","pos":""}],"APOCHROMATIC":[{"def":"Free from chromatic and spherical aberration; -- said esp.","pos":""}],"APOCODEINE":[{"def":"An alkaloid, , prepared from codeine.","pos":""}],"APOCOPATE":[{"def":"To cut off or drop; as, to apocopate a word, or the last letter, syllable, or part of a word.","pos":""},{"def":"Shortened by apocope; as, an apocopate form.","pos":""}],"APOCOPATION":[{"def":"Shortening by apocope; the state of being apocopated.","pos":""}],"APOCOPE":[{"def":"A cutting off; abscission.","pos":""},{"def":"A delegate or deputy; especially, the pope's nuncio or legate at Constantinople.","pos":""}],"APOCRUSTIC":[{"def":"Astringent and repellent.","pos":""},{"def":"An apocrustic medicine.","pos":""}],"APOCRYPHA":[{"def":"Something, as a writing, that is of doubtful authorship or authority; -- formerly used also adjectively.","pos":""}],"APOCRYPHAL":[{"def":"Pertaining to the Apocrypha.","pos":""}],"APOCRYPHALIST":[{"def":"One who believes in, or defends, the Apocrypha.","pos":""}],"APOCRYPHALLY":[{"def":"In an apocryphal manner; mythically; not indisputably.","pos":""}],"APOCRYPHALNESS":[{"def":"The quality or state of being apocryphal; doubtfulness of credit or genuineness.","pos":""},{"def":"Belonging to, or resembling, a family of plants, of which the dogbane (Apocynum) is the type.","pos":""}],"APOCYNIN":[{"def":"A bitter principle obtained from the dogbane (Apocynum cannabinum).","pos":""},{"def":"Destitute of the ventral fin, as the eels.","pos":""}],"APODAN":[{"def":"Self-evident; intuitively true; evident beyond contradiction.","pos":""}],"APODEME":[{"def":"One of the processes of the shell which project inwards and unite with one another, in the thorax of many Crustacea.","pos":""}],"APODICTIC":[{"def":"Same as Apodeictic.","pos":""}],"APODIXIS":[{"def":"Full demonstration.","pos":""}],"APODOSIS":[{"def":"The consequent clause or conclusion in a conditional sentence, expressing the result, and thus distinguished from the protasis or clause which expresses a condition.","pos":""}],"APODYTERIUM":[{"def":"The apartment at the entrance of the baths, or in the palestra, where one stripped; a dressing room.","pos":""}],"APOGAMIC":[{"def":"Relating to apogamy.","pos":""}],"APOGAMY":[{"def":"The formation of a bud in place of a fertilized ovule or oöspore.","pos":""}],"APOGEAN":[{"def":"Connected with the apogee; as, apogean (neap) tides, which occur when the moon has passed her apogee.","pos":""}],"APOGEE":[{"def":"That point in the orbit of the moon which is at the greatest distance from the earth.","pos":""}],"APOGEOTROPIC":[{"def":"Bending away from the ground; -- said of leaves, etc.","pos":""}],"APOGEOTROPISM":[{"def":"The apogeotropic tendency of some leaves, and other parts.","pos":""}],"APOGRAPH":[{"def":"A copy or transcript.","pos":""}],"APOHYAL":[{"def":"Of or pertaining to a portion of the horn of the hyoid bone.","pos":""}],"APOLAR":[{"def":"Having no radiating processes; -- applied particularly to certain nerve cells.","pos":""}],"APOLAUSTIC":[{"def":"Devoted to enjoyment.","pos":""}],"APOLLINARIAN":[{"def":"In honor of Apollo; as, the Apollinarian games.","pos":""}],"APOLLINARIS WATER":[{"def":"An effervescing alkaline mineral water used as a table beverage.","pos":""}],"APOLLO":[{"def":"A deity among the Greeks and Romans.","pos":""},{"def":"Of, pertaining to, or resembling, Apollo.","pos":""}],"APOLLYON":[{"def":"The Destroyer; -- a name used (Rev.","pos":""}],"APOLOGER":[{"def":"A teller of apologues.","pos":""},{"def":"Defending by words or arguments; said or written in defense, or by way of apology; regretfully excusing; as, an apologetic essay.","pos":""}],"APOLOGETICALLY":[{"def":"By way of apology.","pos":""}],"APOLOGETICS":[{"def":"That branch of theology which defends the Holy Scriptures, and sets forth the evidence of their divine authority.","pos":""}],"APOLOGIST":[{"def":"One who makes an apology; one who speaks or writes in defense of a faith, a cause, or an institution; especially, one who argues in defense of Christianity.","pos":""}],"APOLOGIZE":[{"def":"To make an apology or defense.","pos":""},{"def":"To make an apology or excuse; to make acknowledgment of some fault or offense, with expression of regret for it, by way of amends; -- with for; as, my correspondent apologized for not answering my letter.","pos":""}],"APOLOGIZER":[{"def":"One who makes an apology; an apologist.","pos":""}],"APOLOGUE":[{"def":"A story or relation of fictitious events, intended to convey some moral truth; a moral fable.","pos":""}],"APOLOGY":[{"def":"Something said or written in defense or justification of what appears to others wrong, or of what may be liable to disapprobation; justification; as, Tertullian's Apology for Christianity.","pos":""},{"def":"An acknowledgment intended as an atonement for some improper or injurious remark or act; an admission to another of a wrong or discourtesy done him, accompanied by an expression of regret.","pos":""}],"APOMECOMETER":[{"def":"An instrument for measuring the height of objects.","pos":""}],"APOMECOMETRY":[{"def":"The art of measuring the distance of objects afar off.","pos":""},{"def":"A crystalline alkaloid obtained from morphia.","pos":""}],"APONEUROSIS":[{"def":"Any one of the thicker and denser of the deep fasciæ which cover, invest, and the terminations and attachments of, many muscles.","pos":""}],"APONEUROTIC":[{"def":"Of or pertaining to an aponeurosis.","pos":""}],"APONEUROTOMY":[{"def":"Dissection of aponeuroses.","pos":""}],"APOPEMPTIC":[{"def":"Sung or addressed to one departing; valedictory; as, apoplectic songs or hymns.","pos":""}],"APOPHASIS":[{"def":"A figure by which a speaker formally declines to take notice of a favorable point, but in such a manner as to produce the effect desired.","pos":""}],"APOPHLEGMATIC":[{"def":"Designed to facilitate discharges of phlegm or mucus from mouth or nostrils.","pos":""},{"def":"An apohlegmatic medicine.","pos":""}],"APOPHLEGMATISM":[{"def":"The action of apophlegmatics.","pos":""}],"APOPHLEGMATIZANT":[{"def":"An apophlegmatic.","pos":""}],"APOPHTHEGM":[{"def":"Same as Apothegmatic.","pos":""}],"APOPHYGE":[{"def":"The small hollow curvature given to the top or bottom of the shaft of a column where it expands to meet the edge of the fillet; -- called also the scape.","pos":""}],"APOPHYLLITE":[{"def":"A mineral relating to the zeolites, usually occurring in square prisms or octahedrons with pearly luster on the cleavage surface.","pos":""}],"APOPHYSIS":[{"def":"A marked prominence or process on any part of a bone.","pos":""},{"def":"An enlargement at the top of a pedicel or stem, as seen in certain mosses.","pos":""}],"APOPLECTIC":[{"def":"One liable to, or affected with, apoplexy.","pos":""},{"def":"Resembling apoplexy.","pos":""}],"APOPLEXED":[{"def":"Affected with apoplexy.","pos":""}],"APOPLEXY":[{"def":"Sudden diminution or loss of consciousness, sensation, and voluntary motion, usually caused by pressure on the brain.","pos":""}],"APORETICAL":[{"def":"Doubting; skeptical.","pos":""}],"APORIA":[{"def":"A figure in which the speaker professes to be at a loss what course to pursue, where to begin to end, what to say, etc.","pos":""}],"APOROSA":[{"def":"A group of corals in which the coral is not porous; -- opposed to Perforata.","pos":""}],"APORT":[{"def":"On or towards the port or left side; -- said of the helm.","pos":""}],"APOSEMATIC":[{"def":"Having or designating conspicuous or warning colors or structures indicative of special means of defense against enemies, as in the skunk.","pos":""}],"APOSIOPESIS":[{"def":"A figure of speech in which the speaker breaks off suddenly, as if unwilling or unable to state what was in his mind; as, \"I declare to you that his conduct -- but I can not speak of that, here.","pos":""}],"APOSITIC":[{"def":"Destroying the appetite, or suspending hunger.","pos":""}],"APOSTASY":[{"def":"An abandonment of what one has voluntarily professed; a total desertion of departure from one's faith, principles, or party; esp.","pos":""}],"APOSTATE":[{"def":"One who, after having received sacred orders, renounces his clerical profession.","pos":""}],"APOSTATICAL":[{"def":"An heretical and apostatical church.","pos":""}],"APOSTATIZE":[{"def":"To renounce totally a religious belief once professed; to forsake one's church, the faith or principles once held, or the party to which one has previously adhered.","pos":""}],"APOSTEMATE":[{"def":"To form an abscess; to swell and fill with pus.","pos":""}],"APOSTEMATION":[{"def":"The formation of an aposteme; the process of suppuration.","pos":""}],"APOSTEMATOUS":[{"def":"Pertaining to, or partaking of the nature of, an aposteme.","pos":""}],"APOSTEME":[{"def":"An abscess; a swelling filled with purulent matter.","pos":""}],"APOSTLE":[{"def":"A brief letter dimissory sent by a court appealed from to the superior court, stating the case, etc.","pos":""}],"APOSTLESHIP":[{"def":"The office or dignity of an apostle.","pos":""}],"APOSTOLATE":[{"def":"The dignity, office, or mission, of an apostle; apostleship.","pos":""},{"def":"The dignity or office of the pope, as the holder of the apostolic see.","pos":""}],"APOSTOLIC":[{"def":"A member of one of certain ascetic sects which at various times professed to imitate the practice of the apostles.","pos":""}],"APOSTOLIC DELEGATE":[{"def":"The diplomatic agent of the pope highest in grade, superior to a nuncio.","pos":""},{"def":"The state or quality of being apostolical.","pos":""}],"APOSTOLICALLY":[{"def":"In an apostolic manner.","pos":""}],"APOSTOLICALNESS":[{"def":"Ap`os*tol\"ic*al*ness, n.","pos":""}],"APOSTROPHE":[{"def":"A figure of speech by which the orator or writer suddenly breaks off from the previous method of his discourse, and addresses, in the second person, some person or thing, absent or present; as, Milton's apostrophe to Light at the beginning of the third book of \"Paradise Lost.","pos":""},{"def":"The contraction of a word by the omission of a letter or letters, which omission is marked by the character ['] placed where the letter or letters would have been; as, call'd for called.","pos":""}],"APOSTROPHIC":[{"def":"Pertaining to an apostrophe, grammatical or rhetorical.","pos":""}],"APOSTROPHIZE":[{"def":"To address by apostrophe.","pos":""},{"def":"To contract by omitting a letter or letters; also, to mark with an apostrophe (') or apostrophes.","pos":""}],"APOTACTITE":[{"def":"One of a sect of ancient Christians, who, in supposed imitation of the first believers, renounced all their possessions.","pos":""}],"APOTELESM":[{"def":"The calculation and explanation of a nativity.","pos":""}],"APOTELESMATIC":[{"def":"Relating to the casting of horoscopes.","pos":""},{"def":"Relating to an issue of fulfillment.","pos":""}],"APOTHECARY":[{"def":"One who prepares and sells drugs or compounds for medicinal purposes.","pos":""}],"APOTHECIUM":[{"def":"The ascigerous fructification of lichens, forming masses of various shapes.","pos":""},{"def":"A short, pithy, and instructive saying; a terse remark, conveying some important truth; a sententious precept or maxim.","pos":""}],"APOTHEGMATIST":[{"def":"A collector or maker of apothegms.","pos":""}],"APOTHEGMATIZE":[{"def":"To utter apothegms, or short and sententious sayings.","pos":""}],"APOTHEM":[{"def":"The perpendicular from the center to one of the sides of a regular polygon.","pos":""}],"APOTHEOSIS":[{"def":"The act of elevating a mortal to the rank of, and placing him among, \"the gods;\" deification.","pos":""},{"def":"Glorification; exaltation.","pos":""}],"APOTHEOSIZE":[{"def":"To exalt to the dignity of a deity; to declare to be a god; to deify; to glorify.","pos":""}],"APOTOME":[{"def":"The difference between two quantities commensurable only in power, as between sq.","pos":""},{"def":"The remaining part of a whole tone after a smaller semitone has been deducted from it; a major semitone.","pos":""}],"APOZEM":[{"def":"A decoction or infusion.","pos":""}],"APOZEMICAL":[{"def":"Pertaining to, or resembling, a decoction.","pos":""}]}