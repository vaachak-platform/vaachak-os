{"PONCELET":[{"def":"A unit of power, being the power obtained from an expenditure of one hundred kilogram-meters of energy per second.","pos":""}],"PONCHO":[{"def":"A kind of cloak worn by the Spanish Americans, having the form of a blanket, with a slit in the middle for the head to pass through.","pos":""},{"def":"A trade name for camlets, or stout worsteds.","pos":""}],"POND":[{"def":"A body of water, naturally or artificially confined, and usually of less extent than a lake.","pos":""}],"PONDER":[{"def":"To weigh in the mind; to view with deliberation; to examine carefully; to consider attentively.","pos":""}],"PONDERABILITY":[{"def":"The quality or state of being ponderable.","pos":""}],"PONDERABLE":[{"def":"Capable of being weighed; having appreciable weight.","pos":""}],"PONDERAL":[{"def":"Estimated or ascertained by weight; -- distinguished from numeral; as, a ponderal drachma.","pos":""}],"PONDERANCE":[{"def":"Weight; gravity.","pos":""}],"PONDERARY":[{"def":"Of or pertaining to weight; as, a ponderary system.","pos":""}],"PONDERATE":[{"def":"To consider; to ponder.","pos":""}],"PONDERATION":[{"def":"The act of weighing.","pos":""}],"PONDERER":[{"def":"One who ponders.","pos":""}],"PONDEROSITY":[{"def":"The quality or state of being ponderous; weight; gravity; heaviness, ponderousness; as, the ponderosity of gold.","pos":""}],"PONDEROUS":[{"def":"Very heavy; weighty; as, a ponderous shield; a ponderous load; the ponderous elephant.","pos":""},{"def":"Important; momentous; forcible.","pos":""}],"PONDEROUSLY":[{"def":"In a ponderous manner.","pos":""}],"PONDEROUSNESS":[{"def":"The quality or state of being ponderous; ponderosity.","pos":""}],"PONDFISH":[{"def":"Any one of numerous species of American fresh-water fishes belonging to the family Centrarchidæ; -- called also pond perch, and sunfish.","pos":""}],"PONDWEED":[{"def":"Any aquatic plant of the genus Potamogeton, of which many species are found in ponds or slow-moving rivers.","pos":""}],"PONE":[{"def":"A kind of johnnycake.","pos":""}],"PONENT":[{"def":"Western; occidental.","pos":""}],"PONGEE":[{"def":"A fabric of undyed silk from India and China.","pos":""}],"PONGHEE":[{"def":"A Buddhist priest of the higher orders in Burmah.","pos":""}],"PONGO":[{"def":"Any large ape; especially, the chimpanzee and the orang-outang.","pos":""}],"PONIARD":[{"def":"A kind of dagger, -- usually a slender one with a triangular or square blade.","pos":""}],"PONIBILITY":[{"def":"The capability of being placed or located.","pos":""}],"PONS":[{"def":"A bridge; -- applied to several parts which connect others, but especially to the pons Varolii, a prominent band of nervous tissue situated on the ventral side of the medulla oblongata and connected at each side with the hemispheres of the cerebellum; the mesocephalon.","pos":""}],"PONTAGE":[{"def":"A duty or tax paid for repairing bridges.","pos":""}],"PONTEE":[{"def":"An iron rod used by glass makers for manipulating the hot glass; -- called also, puntil, puntel, punty, and ponty.","pos":""}],"PONTIC":[{"def":"Of or pertaining to the Pontus, Euxine, or Black Sea.","pos":""}],"PONTIFEX":[{"def":"A high priest; a pontiff.","pos":""}],"PONTIFIC":[{"def":"Relating to, or consisting of, pontiffs or priests.","pos":""},{"def":"Of or pertaining to the pope; papal.","pos":""}],"PONTIFICAL":[{"def":"Of or pertaining to a pontiff, or high priest; as, pontifical authority; hence, belonging to the pope; papal.","pos":""},{"def":"Of or pertaining to the building of bridges.","pos":""}],"PONTIFICALITY":[{"def":"The state and government of the pope; the papacy.","pos":""}],"PONTIFICALLY":[{"def":"In a pontifical manner.","pos":""}],"PONTIFICATE":[{"def":"The state or dignity of a high priest; specifically, the office of the pope.","pos":""},{"def":"The term of office of a pontiff.","pos":""}],"PONTIFICE":[{"def":"Bridgework; structure or edifice of a bridge.","pos":""}],"PONTIFICIAL":[{"def":"Papal; pontifical.","pos":""}],"PONTIFICIAN":[{"def":"Of or pertaining to the pontiff or pope.","pos":""}],"PONTILE":[{"def":"Of or pertaining to the pons Varolii.","pos":""}],"PONTINE":[{"def":"Of or pertaining to an extensive marshy district between Rome and Naples.","pos":""}],"PONTLEVIS":[{"def":"The action of a horse in rearing repeatedly and dangerously.","pos":""}],"PONTOON":[{"def":"A wooden flat-bottomed boat, a metallic cylinder, or a frame covered with canvas, India rubber, etc.","pos":""},{"def":"A low, flat vessel, resembling a barge, furnished with cranes, capstans, and other machinery, used in careening ships, raising weights, drawing piles, etc.","pos":""}],"PONTOONING":[{"def":"The act, art, or process of constructing pontoon bridges.","pos":""}],"PONTVOLANT":[{"def":"A kind of light bridge, used in sieges, for surprising a post or outwork which has but a narrow moat; a flying bridge.","pos":""}],"PONY":[{"def":"Twenty-five pounds sterling.","pos":""}]}