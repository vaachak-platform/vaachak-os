{"CONVOCATE":[{"def":"To convoke; to call together.","pos":""}],"CONVOCATION":[{"def":"An assembly of the clergy, by their representatives, to consult on ecclesiastical affairs.","pos":""},{"def":"An academical assembly, in which the business of the university is transacted.","pos":""}],"CONVOCATIONAL":[{"def":"Of or pertaining to a convocation.","pos":""}],"CONVOCATIONIST":[{"def":"An advocate or defender of convocation.","pos":""}],"CONVOKE":[{"def":"To call together; to summon to meet; to assemble by summons.","pos":""}],"CONVOLUTE":[{"def":"Rolled or wound together, one part upon another; -- said of the leaves of plants in æstivation.","pos":""}],"CONVOLUTED":[{"def":"Having convolutions.","pos":""},{"def":"Folded in tortuous windings.","pos":""}],"CONVOLUTION":[{"def":"An irregular, tortuous folding of an organ or part; as, the convolutions of the intestines; the cerebral convolutions.","pos":""}],"CONVOLVE":[{"def":"To roll or wind together; to roll or twist one part on another.","pos":""}],"CONVOLVULACEOUS":[{"def":"Of, pertaining to, or resembling, the family of plants of which the bindweed and the morning-glory are common examples.","pos":""}],"CONVOLVULIN":[{"def":"A glucoside occurring in jalap (the root of a convolvulaceous plant), and extracted as a colorless, tasteless, gummy mass of powerful purgative properties.","pos":""}],"CONVOLVULUS":[{"def":"A large genus of plants having monopetalous flowers, including the common bindweed (C.","pos":""}],"CONVOY":[{"def":"To accompany for protection, either by sea or land; to attend for protection; to escort; as, a frigate convoys a merchantman.","pos":""}]}