{"MARONE":[{"def":"See Maroon, the color.","pos":""}],"MARONITE":[{"def":"One of a body of nominal Christians, who speak the Arabic language, and reside on Mount Lebanon and in different parts of Syria.","pos":""}],"MAROON":[{"def":"In the West Indies and Guiana, a fugitive slave, or a free negro, living in the mountains.","pos":""}]}