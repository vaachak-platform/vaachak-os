{"SIR":[{"def":"A man of social authority and dignity; a lord; a master; a gentleman; -- in this sense usually spelled sire.","pos":""},{"def":"A title prefixed to the Christian name of a knight or a baronet.","pos":""}],"SIRASKIERATE":[{"def":"See Seraskierate.","pos":""}],"SIRCAR":[{"def":"A Hindoo clerk or accountant.","pos":""},{"def":"A district or province; a circar.","pos":""}],"SIRDAR":[{"def":"A native chief in Hindostan; a headman.","pos":""}],"SIRE":[{"def":"A lord, master, or other person in authority.","pos":""},{"def":"A tittle of respect formerly used in speaking to elders and superiors, but now only in addressing a sovereign.","pos":""}],"SIREDON":[{"def":"The larval form of any salamander while it still has external gills; especially, one of those which, like the axolotl (Amblystoma Mexicanum), sometimes lay eggs while in this larval state, but which under more favorable conditions lose their gills and become normal salamanders.","pos":""}],"SIREN":[{"def":"One of three sea nymphs, -- or, according to some writers, of two, -- said to frequent an island near the coast of Italy, and to sing with such sweetness that they lured mariners to destruction.","pos":""},{"def":"Any long, slender amphibian of the genus Siren or family Sirenidæ, destitute of hind legs and pelvis, and having permanent external gills as well as lungs.","pos":""}],"SIRENIA":[{"def":"An order of large aquatic herbivorous mammals, including the manatee, dugong, rytina, and several fossil genera.","pos":""}],"SIRENIAN":[{"def":"Any species of Sirenia.","pos":""}],"SIRENICAL":[{"def":"Like, or appropriate to, a siren; fascinating; deceptive.","pos":""}],"SIRENIZE":[{"def":"To use the enticements of a siren; to act as a siren; to fascinate.","pos":""}],"SIRKEER":[{"def":"Any one of several species of Asiatic cuckoos of the genus Taccocua, as the Bengal sirkeer (T.","pos":""}],"SIRLOIN":[{"def":"A loin of beef, or a part of a loin.","pos":""}],"SIROCCO":[{"def":"An oppressive, relaxing wind from the Libyan deserts, chiefly experienced in Italy, Malta, and Sicily.","pos":""}],"SIRRAH":[{"def":"A term of address implying inferiority and used in anger, contempt, reproach, or disrespectful familiarity, addressed to a man or boy, but sometimes to a woman.","pos":""}],"SIRT":[{"def":"Moistened, covered, or sweetened with sirup, or sweet juice.","pos":""}],"SIRVENTE":[{"def":"A peculiar species of poetry, for the most part devoted to moral and religious topics, and commonly satirical, -- often used by the troubadours of the Middle Ages.","pos":""}]}