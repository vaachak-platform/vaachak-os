{"FRA":[{"def":"Brother; -- a title of a monk of friar; as, Fra Angelo.","pos":""}],"FRAB":[{"def":"To scold; to nag.","pos":""}],"FRABBIT":[{"def":"Crabbed; peevish.","pos":""}],"FRACAS":[{"def":"An uproar; a noisy quarrel; a disturbance; a brawl.","pos":""}],"FRACHO":[{"def":"A shallow iron pan to hold glass ware while being annealed.","pos":""}],"FRACID":[{"def":"Rotten from being too ripe; overripe.","pos":""}],"FRACT":[{"def":"To break; to violate.","pos":""}],"FRACTED":[{"def":"Having a part displaced, as if broken; -- said of an ordinary.","pos":""}],"FRACTION":[{"def":"One or more aliquot parts of a unit or whole number; an expression for a definite portion of a unit or magnitude.","pos":""}],"FRACTIONAL":[{"def":"Of or pertaining to fractions or a fraction; constituting a fraction; as, fractional numbers.","pos":""},{"def":"Relatively small; inconsiderable; insignificant; as, a fractional part of the population.","pos":""}],"FRACTIONALLY":[{"def":"By fractions or separate portions; as, to distill a liquid fractionally, that is, so as to separate different portions.","pos":""}],"FRACTIONATE":[{"def":"To separate into different portions or fractions, as in the distillation of liquids.","pos":""}],"FRACTIOUS":[{"def":"Apt to break out into a passion; apt to scold; cross; snappish; ugly; unruly; as, a fractious man; a fractious horse.","pos":""}],"FRACTURAL":[{"def":"Pertaining to, or consequent on, a fracture.","pos":""}],"FRACTURE":[{"def":"The breaking of a bone.","pos":""},{"def":"The texture of a freshly broken surface; as, a compact fracture; an even, hackly, or conchoidal fracture.","pos":""}],"FRAENULUM":[{"def":"A connecting fold of membrane serving to support or restrain any part; as, the frænum of the tongue.","pos":""}],"FRAGILE":[{"def":"Easily broken; brittle; frail; delicate; easily destroyed.","pos":""}],"FRAGILITY":[{"def":"The condition or quality of being fragile; brittleness; frangibility.","pos":""},{"def":"Weakness; feebleness.","pos":""}],"FRAGMENT":[{"def":"A part broken off; a small, detached portion; an imperfect part; as, a fragment of an ancient writing.","pos":""}],"FRAGMENTAL":[{"def":"Consisting of the pulverized or fragmentary material of rock, as conglomerate, shale, etc.","pos":""}],"FRAGMENTARILY":[{"def":"In a fragmentary manner; piecemeal.","pos":""}],"FRAGMENTARINESS":[{"def":"The quality or property of being in fragnebts, or broken pieces, incompleteness; want of continuity.","pos":""}],"FRAGMENTARY":[{"def":"Composed of the fragments of other rocks.","pos":""}],"FRAGMENTED":[{"def":"Broken into fragments.","pos":""}],"FRAGMENTIST":[{"def":"A writer of fragments; as, the fragmentist of Wolfenbüttel.","pos":""}],"FRAGOR":[{"def":"A strong or sweet scent.","pos":""},{"def":"The quality of being fragrant; sweetness of smell; a sweet smell; a pleasing odor; perfume.","pos":""}],"FRAGRANT":[{"def":"Fragrant the fertile earth After soft showers.","pos":""}],"FRAIGHT":[{"def":"Same as Fraught.","pos":""}],"FRAIL":[{"def":"A basket made of rushes, used chiefly for containing figs and raisins.","pos":""}],"FRAILLY":[{"def":"Weakly; infirmly.","pos":""}],"FRAILTY":[{"def":"The condition quality of being frail, physically, mentally, or morally, frailness; infirmity; weakness of resolution; liableness to be deceived or seduced.","pos":""},{"def":"A fault proceeding from weakness; foible; sin of infirmity.","pos":""}],"FRAISCHEUR":[{"def":"Freshness; coolness.","pos":""}],"FRAISE":[{"def":"A large and thick pancake, with slices of bacon in it.","pos":""}],"FRAISED":[{"def":"Fortified with a fraise.","pos":""}],"FRAKEN":[{"def":"A few fraknes in his face.","pos":""}],"FRAMABLE":[{"def":"Capable of being framed.","pos":""}],"FRAME":[{"def":"To construct by fitting and uniting the several parts of the skeleton of any structure; specifically, in woodwork, to put together by cutting parts of one member to fit parts of another.","pos":""}],"FRAME-UP":[{"def":"A conspiracy or plot, esp.","pos":""}],"FRAMER":[{"def":"One who frames; as, the framer of a building; the framers of the Constitution.","pos":""}],"FRAMEWORK":[{"def":"The work of framing, or the completed work; the frame or constructional part of anything; as, the framework of society.","pos":""},{"def":"Work done in, or by means of, a frame or loom.","pos":""}],"FRAMING":[{"def":"A framework, or a sy Framing chisel (Carp.","pos":""},{"def":"Peevish; cross; vexatious; quarrelsome.","pos":""}],"FRANC":[{"def":"A silver coin of France, and since 1795 the unit of the French monetary system.","pos":""}],"FRANC-TIREUR":[{"def":"A French partisan soldier, or one belonging to a corps of detached light troops engaged in forays, skirmishes, scouting, etc.","pos":""}],"FRANCHISE":[{"def":"A particular privilege conferred by grant from a sovereign or a government, and vested in individuals; an imunity or exemption from ordinary jurisdiction; a constitutional or statutory right or privilege, esp.","pos":""}],"FRANCHISEMENT":[{"def":"Release; deliverance; freedom.","pos":""}],"FRANCIC":[{"def":"Pertaining to the Franks, or their language; Frankish.","pos":""}],"FRANCISCAN":[{"def":"Belonging to the Order of St.","pos":""}],"FRANCOLIN":[{"def":"A spurred partidge of the genus Francolinus and allied genera, of Asia and Africa.","pos":""}],"FRANCOLITE":[{"def":"A variety of apatite from Wheal Franco in Devonshire.","pos":""}],"FRANGENT":[{"def":"Causing fracture; breaking.","pos":""}],"FRANGIBILITY":[{"def":"The state or quality of being frangible.","pos":""}],"FRANGIBLE":[{"def":"Capable of being broken; brittle; fragile; easily broken.","pos":""}],"FRANGIPANE":[{"def":"A perfume derived from, or imitating the odor of, the flower of the red jasmine, a West Indian tree of the genus Plumeria.","pos":""},{"def":"Pertaining to, or drived from, frangulin, or a species (Rhamnus Frangula) of the buckthorn.","pos":""}],"FRANGULIN":[{"def":"A yellow crystalline dyestuff, regarded as a glucoside, extracted from a species (Rhamnus Frangula) of the buckthorn; -- called also rhamnoxanthin.","pos":""}],"FRANION":[{"def":"A paramour; a loose woman; also, a gay, idle fellow.","pos":""}],"FRANK":[{"def":"To shut up in a frank or sty; to pen up; hence, to cram; to fatten.","pos":""}],"FRANK-CHASE":[{"def":"The liberty or franchise of having a chase; free chase.","pos":""}],"FRANK-FEE":[{"def":"A species of tenure in fee simple, being the opposite of ancient demesne, or copyhold.","pos":""}],"FRANK-LAW":[{"def":"The liberty of being sworn in courts, as a juror or witness; one of the ancient privileges of a freeman; free and common law; -- an obsolete expression signifying substantially the same as the American expression civil rights.","pos":""}],"FRANK-MARRIAGE":[{"def":"A certain tenure in tail special; an estate of inheritance given to a man his wife (the wife being of the blood of the donor), and descendible to the heirs of their two bodies begotten.","pos":""}],"FRANKALMOIGNE":[{"def":"A tenure by which a religious corporation holds lands given to them and their successors forever, usually on condition of praying for the soul of the donor and his heirs; -- called also tenure by free alms.","pos":""}],"FRANKFORT BLACK":[{"def":"Frank\"fort black` Defn: .","pos":""}],"FRANKINCENSE":[{"def":"A fragrant, aromatic resin, or gum resin, burned as an incense in religious rites or for medicinal fumigation.","pos":""}],"FRANKING":[{"def":"A method of forming a joint at the intersection of window-sash bars, by cutting away only enough wood to show a miter.","pos":""}],"FRANKISH":[{"def":"Like, or pertaining to, the Franks.","pos":""}],"FRANKLIN":[{"def":"An English freeholder, or substantial householder.","pos":""}],"FRANKLIN STOVE":[{"def":"Frank\"lin stove` Defn: .","pos":""}],"FRANKLINIC":[{"def":"Of or pertaining to Benjamin Franklin.","pos":""}],"FRANKLINITE":[{"def":"A kind of mineral of the spinel group.","pos":""}],"FRANKLY":[{"def":"In a frank manner; freely.","pos":""}],"FRANKNESS":[{"def":"The quality of being frank; candor; openess; ingenuousness; fairness; liberality.","pos":""}],"FRANKPLEDGE":[{"def":"The servants of the crown were not, as now, bound in frankpledge for each other.","pos":""}],"FRANTIC":[{"def":"Mad; raving; furious; violent; wild and disorderly; distracted.","pos":""}],"FRAP":[{"def":"To draw together; to bind with a view to secure and strengthen, as a vessel by passing cables around it; to tighten; as a tackle by drawing the lines together.","pos":""}],"FRAPE":[{"def":"A crowd, a rabble.","pos":""}],"FRAPLER":[{"def":"A blusterer; a rowdy.","pos":""}],"FRAPPE":[{"def":"Iced; frozen; artificially cooled; as, wine frappé.","pos":""},{"def":"A frappé mixture or beverage, as a water ice, variously flavored, frozen soft, and served in glasses.","pos":""}],"FRAPPING":[{"def":"A lashing binding a thing tightly or binding things together.","pos":""}],"FRATER":[{"def":"A monk; also, a frater house.","pos":""}],"FRATERNAL":[{"def":"Pf, pertaining to, or involving, brethren; becoming to brothers; brotherly; as, fraternal affection; a fraternal embrace.","pos":""}],"FRATERNATE":[{"def":"To fraternize; to hold fellowship.","pos":""}],"FRATERNITY":[{"def":"The state or quality of being fraternal or brotherly; brotherhood.","pos":""},{"def":"A body of men associated for their common interest, business, or pleasure; a company; a brotherhood; a society; in the Roman Catholic Chucrch, an association for special religious purposes, for relieving the sick and destitute, etc.","pos":""}],"FRATERNIZATION":[{"def":"The act of fraternizing or uniting as brothers.","pos":""}],"FRATERNIZE":[{"def":"To associate or hold fellowship as brothers, or as men of like occupation or character; to have brotherly feelings.","pos":""}],"FRATERNIZER":[{"def":"One who fraternizes.","pos":""}],"FRATRAGE":[{"def":"A sharing among brothers, or brothers' kin.","pos":""}],"FRATRICIDAL":[{"def":"Of or pertaining to fratricide; of the nature of fratricide.","pos":""}],"FRATRICIDE":[{"def":"One who murders or kills his own brother.","pos":""}],"FRAU":[{"def":"In Germany, a woman; a married woman; a wife; -- as a title, equivalent to Mrs.","pos":""}],"FRAUD":[{"def":"An intentional perversion of truth for the purpose of obtaining some valuable thing or promise from another.","pos":""}],"FRAUDFUL":[{"def":"Full of fraud, deceit, or treachery; trickish; treacherous; fraudulent; -- applied to persons or things.","pos":""}],"FRAUDLESS":[{"def":"Free from fraud.","pos":""},{"def":"The quality of being fraudulent; deliberate deceit; trickishness.","pos":""}],"FRAUDULENT":[{"def":"Using fraud; trickly; deceitful; dishonest.","pos":""},{"def":"Characterized by,, founded on, or proceeding from, fraund; as, a fraudulent bargain.","pos":""}],"FRAUDULENTLY":[{"def":"In a fraudulent manner.","pos":""}],"FRAUGHT":[{"def":"A freight; a cargo.","pos":""}],"FRAUGHTAGE":[{"def":"Freight; loading; cargo.","pos":""}],"FRAUGHTING":[{"def":"Constituting the freight or cargo.","pos":""}],"FRAULEIN":[{"def":"In Germany, a young lady; an unmarried woman; -- as a title, equivalent to Miss.","pos":"noun"}],"FRAUNHOFER LINES":[{"def":"The lines of the spectrun; especially and properly, the dark lines of the solar spectrum, so called because first accurately observed and interpreted by Fraunhofer, a German physicist.","pos":""}],"FRAXIN":[{"def":"A colorless crystalline substance, regarded as a glucoside, and found in the bark of the ash (Fraxinus) and along with esculin in the bark of the horse-chestnut.","pos":""}],"FRAXINUS":[{"def":"A genus of deciduous forest trees, found in the north temperate zone, and including the true ash trees.","pos":""}],"FRAY":[{"def":"Affray; broil; contest; combat.","pos":""}],"FRAYING":[{"def":"The skin which a deer frays from his horns.","pos":""}],"FRAZZLE":[{"def":"To fray; to wear or pull into tatters or tag ends; to tatter; - -used literally and figuratively.","pos":""}]}