{"AULARIAN":[{"def":"Relating to a hall.","pos":""}],"AULD":[{"def":"Old; as, Auld Reekie (old smoky), i.","pos":""}],"AULD LANG SYNE":[{"def":"A Scottish phrase used in recalling recollections of times long since past.","pos":""}],"AULETIC":[{"def":"Of or pertaining to a pipe (flute) or piper.","pos":""}],"AULIC":[{"def":"Pertaining to a royal court.","pos":""}],"AULN":[{"def":"See Alnage and Alnager.","pos":""}]}