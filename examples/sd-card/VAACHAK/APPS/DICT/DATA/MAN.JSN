{"MAN":[{"def":"A human being; -- opposed tobeast.","pos":""},{"def":"Especially: An adult male person; a grown-up male person, as distinguished from a woman or a child.","pos":""}],"MAN-EATER":[{"def":"One who, or that which, has an appetite for human flesh; specifically, one of certain large sharks (esp.","pos":""}],"MAN-OF-WAR":[{"def":"A government vessel employed for the purposes of war, esp.","pos":""}]}