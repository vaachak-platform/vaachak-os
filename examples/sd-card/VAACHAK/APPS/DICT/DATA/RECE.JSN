{"RECEDE":[{"def":"To move back; to retreat; to withdraw.","pos":""},{"def":"To withdraw a claim or pretension; to desist; to relinquish what had been proposed or asserted; as, to recede from a demand or proposition.","pos":""}],"RECEIPT":[{"def":"The act of receiving; reception.","pos":""},{"def":"Reception, as an act of hospitality.","pos":""}],"RECEIPTMENT":[{"def":"The receiving or harboring a felon knowingly, after the commission of a felony.","pos":""}],"RECEIPTOR":[{"def":"One who receipts; specifically (Law), one who receipts for property which has been taken by the sheriff.","pos":""}],"RECEIVABILITY":[{"def":"The quality of being receivable; receivableness.","pos":""}],"RECEIVABLE":[{"def":"Capable of being received.","pos":""}],"RECEIVE":[{"def":"To bat back (the ball) when served.","pos":""}],"RECEIVEDNESS":[{"def":"The state or quality of being received, accepted, or current; as, the receivedness of an opinion.","pos":""}],"RECEIVER":[{"def":"The glass vessel in which the vacuum is produced, and the objects of experiment are put, in experiments with an air pump.","pos":""}],"RECEIVER'S CERTIFICATE":[{"def":"An acknowledgement of indebtedness made by a receiver under order of court to obtain funds for the preservation of the assets held by him, as for operating a railroad.","pos":""}],"RECEIVERSHIP":[{"def":"The state or office of a receiver.","pos":""}],"RECELEBRATE":[{"def":"To celebrate again, or anew.","pos":""}],"RECENCY":[{"def":"The state or quality of being recent; newness; new state; late origin; lateness in time; freshness; as, the recency of a transaction, of a wound, etc.","pos":""}],"RECENSE":[{"def":"To review; to revise.","pos":""}],"RECENSION":[{"def":"The act of reviewing or revising; review; examination; enumeration.","pos":""},{"def":"Specifically, the review of a text (as of an ancient author) by an editor; critical revisal and establishment.","pos":""}],"RECENSIONIST":[{"def":"One who makes recensions; specifically, a critical editor.","pos":""}],"RECENT":[{"def":"Of or pertaining to the present or existing epoch; as, recent shells.","pos":""}],"RECENTER":[{"def":"To center again; to restore to the center.","pos":""}],"RECENTLY":[{"def":"Newly; lately; freshly; not long since; as, advices recently received.","pos":""}],"RECENTNESS":[{"def":"Quality or state of being recent.","pos":""}],"RECEPTACLE":[{"def":"That which serves, or is used, fro receiving and containing something, as a basket, a vase, a bag, a reservoir; a repository.","pos":""}],"RECEPTACULAR":[{"def":"Pertaining to the receptacle, or growing on it; as, the receptacular chaff or scales in the sunflower.","pos":""}],"RECEPTACULUM":[{"def":"A receptacle; as, the receptaculum of the chyle.","pos":""}],"RECEPTARY":[{"def":"Generally or popularly admitted or received.","pos":""}],"RECEPTIBILITY":[{"def":"The quality or state of being receptible; receivableness.","pos":""},{"def":"A receptible thing.","pos":""}],"RECEPTIBLE":[{"def":"Such as may be received; receivable.","pos":""}],"RECEPTION":[{"def":"The act of receiving; receipt; admission; as, the reception of food into the stomach; the reception of a letter; the reception of sensation or ideas; reception of evidence.","pos":""},{"def":"The state of being received.","pos":""}],"RECEPTIVE":[{"def":"Having the quality of receiving; able or inclined to take in, absorb, hold, or contain; receiving or containing; as, a receptive mind.","pos":""}],"RECEPTIVENESS":[{"def":"The quality of being receptive.","pos":""}],"RECEPTIVITY":[{"def":"The power or capacity of receiving impressions, as those of the external senses.","pos":""}],"RECESS":[{"def":"A withdrawing or retiring; a moving back; retreat; as, the recess of the tides.","pos":""},{"def":"The state of being withdrawn; seclusion; privacy.","pos":""}],"RECESSED":[{"def":"Having a recess or recesses; as, a recessed arch or wall.","pos":""},{"def":"Withdrawn; secluded.","pos":""}],"RECESSION":[{"def":"The act of receding or withdrawing, as from a place, a claim, or a demand.","pos":""}],"RECESSIONAL":[{"def":"Of or pertaining to recession or withdrawal.","pos":""}],"RECESSIVE":[{"def":"Going back; receding.","pos":""}]}