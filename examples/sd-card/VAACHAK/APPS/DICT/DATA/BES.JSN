{"BES-ANTLER":[{"def":"Same as Bez-antler.","pos":""}],"BESAINT":[{"def":"To make a saint of.","pos":""}],"BESCATTER":[{"def":"To scatter over.","pos":""},{"def":"To cover sparsely by scattering (something); to strew.","pos":""}],"BESCORN":[{"def":"To treat with scorn.","pos":""}],"BESCRATCH":[{"def":"To tear with the nails; to cover with scratches.","pos":""}],"BESCRAWL":[{"def":"To cover with scrawls; to scribble over.","pos":""}],"BESCREEN":[{"def":"To cover with a screen, or as with a screen; to shelter; to conceal.","pos":""}],"BESCRIBBLE":[{"def":"To scribble over.","pos":""},{"def":"To discharge ordure or dung upon.","pos":""}],"BESEE":[{"def":"To see; to look; to mind.","pos":""}],"BESEECH":[{"def":"To ask or entreat with urgency; to supplicate; to implore.","pos":""}],"BESEECHER":[{"def":"One who beseeches.","pos":""}],"BESEECHING":[{"def":"Entreating urgently; imploring; as, a beseeching look.","pos":""}],"BESEECHMENT":[{"def":"The act of beseeching or entreating earnestly.","pos":""}],"BESEEM":[{"def":"Literally: To appear or seem (well, ill, best, etc.","pos":""}],"BESEEMING":[{"def":"Appearance; look; garb.","pos":""}],"BESEEMLY":[{"def":"Fit; suitable; becoming.","pos":""}],"BESEEN":[{"def":"Seen; appearing.","pos":""},{"def":"Decked or adorned; clad.","pos":""}],"BESET":[{"def":"To set or stud (anything) with ornaments or prominent objects.","pos":""},{"def":"To hem in; to waylay; to surround; to besiege; to blockade.","pos":""}],"BESETMENT":[{"def":"The act of besetting, or the state of being beset; also, that which besets one, as a sin.","pos":""}],"BESETTER":[{"def":"One who, or that which, besets.","pos":""}],"BESETTING":[{"def":"Habitually attacking, harassing, or pressing upon or about; as, a besetting sin.","pos":""}],"BESHINE":[{"def":"To shine upon; to ullumine.","pos":""}],"BESHOW":[{"def":"A large food fish (Anoplopoma fimbria) of the north Pacific coast; -- called also candlefish.","pos":""}],"BESHREW":[{"def":"To curse; to execrate.","pos":""}],"BESHROUD":[{"def":"To cover with, or as with, a shroud; to screen.","pos":""}],"BESHUT":[{"def":"To shut up or out.","pos":""}],"BESIDE":[{"def":"At the side of; on one side of.","pos":""},{"def":"Aside from; out of the regular course or order of; in a state of deviation from; out of.","pos":""}],"BESIDES":[{"def":"Over and above; separate or distinct from; in addition to; other than; else than.","pos":""}],"BESIEGE":[{"def":"To beset or surround with armed forces, for the purpose of compelling to surrender; to lay siege to; to beleaguer; to beset.","pos":""}],"BESIEGEMENT":[{"def":"The act of besieging, or the state of being besieged.","pos":""}],"BESIEGER":[{"def":"One who besieges; -- opposed to the besieged.","pos":""}],"BESIEGING":[{"def":"That besieges; laying siege to.","pos":""}],"BESIT":[{"def":"To suit; to fit; to become.","pos":""}],"BESLAVER":[{"def":"To defile with slaver; to beslobber.","pos":""}],"BESLIME":[{"def":"To daub with slime; to soil.","pos":""}],"BESLOBBER":[{"def":"To slobber on; to smear with spittle running from the mouth.","pos":""}],"BESMEAR":[{"def":"To smear with any viscous, glutinous matter; to bedaub; to soil.","pos":""}],"BESMEARER":[{"def":"One that besmears.","pos":""}],"BESMIRCH":[{"def":"To smirch or soil; to discolor; to obscure.","pos":""}],"BESMOKE":[{"def":"To foul with smoke.","pos":""},{"def":"To harden or dry in smoke.","pos":""}],"BESMUT":[{"def":"To blacken with smut; to foul with soot.","pos":""}],"BESNOW":[{"def":"To scatter like snow; to cover thick, as with snow flakes.","pos":""},{"def":"To cover with snow; to whiten with snow, or as with snow.","pos":""}],"BESNUFF":[{"def":"To befoul with snuff.","pos":""}],"BESOGNE":[{"def":"A worthless fellow; a bezonian.","pos":""}],"BESOM":[{"def":"A brush of twigs for sweeping; a broom; anything which sweeps away or destroys.","pos":""}],"BESOMER":[{"def":"One who uses a besom.","pos":""}],"BESORT":[{"def":"To assort or be congruous with; to fit, or become.","pos":""}],"BESOT":[{"def":"To make sottish; to make dull or stupid; to stupefy; to infatuate.","pos":""}],"BESOTTED":[{"def":"Made sottish, senseless, or infatuated; characterized by drunken stupidity, or by infatuation; stupefied.","pos":""}],"BESOTTINGLY":[{"def":"In a besotting manner.","pos":""}],"BESPANGLE":[{"def":"To adorn with spangles; to dot or sprinkle with something brilliant or glittering.","pos":""}],"BESPATTER":[{"def":"To soil by spattering; to sprinkle, esp.","pos":""},{"def":"To asperse with calumny or reproach.","pos":""}],"BESPAWL":[{"def":"To daub, soil, or make foul with spawl or spittle.","pos":""}],"BESPEAK":[{"def":"To speak or arrange for beforehand; to order or engage against a future time; as, to bespeak goods, a right, or a favor.","pos":""},{"def":"To show beforehand; to foretell; to indicate.","pos":""}],"BESPEAKER":[{"def":"One who bespeaks.","pos":""}],"BESPECKLE":[{"def":"To mark with speckles or spots.","pos":""}],"BESPEW":[{"def":"To soil or daub with spew; to vomit on.","pos":""}],"BESPICE":[{"def":"To season with spice, or with some spicy drug.","pos":""}],"BESPIRT":[{"def":"Same as Bespurt.","pos":""}],"BESPIT":[{"def":"To daub or soil with spittle.","pos":""}],"BESPOKE":[{"def":"Be*spoke\", Defn: imp.","pos":""}],"BESPOT":[{"def":"To mark with spots, or as with spots.","pos":""}],"BESPREAD":[{"def":"To spread or cover over.","pos":""}],"BESPRENT":[{"def":"Sprinkled over; strewed.","pos":""}],"BESPRINKLE":[{"def":"To sprinkle over; to scatter over.","pos":""}],"BESPRINKLER":[{"def":"One who, or that which, besprinkles.","pos":""}],"BESPRINKLING":[{"def":"The act of sprinkling anything; a sprinkling over.","pos":""}],"BESPURT":[{"def":"To spurt on or over; to asperse.","pos":""}],"BESSEMER STEEL":[{"def":"Steel made directly from cast iron, by burning out a portion of the carbon and other impurities that the latter contains, through the agency of a blast of air which is forced through the molten metal; -- so called from Sir Henry Bessemer, an English engineer, the inventor of the process.","pos":""}],"BEST":[{"def":"Having good qualities in the highest degree; most good, kind, desirable, suitable, etc.","pos":""},{"def":"Most advanced; most correct or complete; as, the best scholar; the best view of a subject.","pos":""}],"BESTAD":[{"def":"Beset; put in peril.","pos":""}],"BESTAR":[{"def":"To sprinkle with, or as with, stars; to decorate with, or as with, stars; to bestud.","pos":""}],"BESTEAD":[{"def":"To put in a certain situation or condition; to circumstance; to place.","pos":""},{"def":"To put in peril; to beset.","pos":""}],"BESTIAL":[{"def":"Belonging to a beast, or to the class of beasts.","pos":""},{"def":"Having the qualities of a beast; brutal; below the dignity of reason or humanity; irrational; carnal; beastly; sensual.","pos":""}],"BESTIALITY":[{"def":"The state or quality of being bestial.","pos":""},{"def":"Unnatural connection with a beast.","pos":""}],"BESTIALIZE":[{"def":"To make bestial, or like a beast; to degrade; to brutalize.","pos":""}],"BESTIALLY":[{"def":"In a bestial manner.","pos":""}],"BESTIARY":[{"def":"A treatise on beasts; esp.","pos":""}],"BESTICK":[{"def":"To stick over, as with sharp points pressed in; to mark by infixing points or spots here and there; to pierce.","pos":""}],"BESTIR":[{"def":"To put into brisk or vigorous action; to move with life and vigor; -- usually with the reciprocal pronoun.","pos":""}],"BESTOW":[{"def":"To lay up in store; to deposit for safe keeping; to stow; to place; to put.","pos":""},{"def":"To use; to apply; to devote, as time or strength in some occupation.","pos":""}],"BESTOWAL":[{"def":"The act of bestowing; disposal.","pos":""}],"BESTOWER":[{"def":"One that bestows.","pos":""}],"BESTOWMENT":[{"def":"The act of giving or bestowing; a conferring or bestowal.","pos":""},{"def":"That which is given or bestowed.","pos":""}],"BESTRAUGHT":[{"def":"Out of one's senses; distracted; mad.","pos":""}],"BESTREW":[{"def":"To strew or scatter over; to besprinkle.","pos":""}],"BESTRIDE":[{"def":"To stand or sit with anything between the legs, or with the legs astride; to stand over That horse that thou so often hast bestrid.","pos":""},{"def":"To step over; to stride over or across; as, to bestride a threshold.","pos":""}],"BESTRODE":[{"def":"Be*strode\", Defn: imp.","pos":""}],"BESTROWN":[{"def":"Be*strown\", Defn: p.","pos":""}],"BESTUCK":[{"def":"Be*stuck\", Defn: imp.","pos":""}],"BESTUD":[{"def":"To set or adorn, as with studs or bosses; to set thickly; to stud; as, to bestud with stars.","pos":""}],"BESWIKE":[{"def":"To lure; to cheat.","pos":""}]}