{"REE":[{"def":"To riddle; to sift; to separate or throw off.","pos":""}],"REEBOK":[{"def":"To echo back; to reverberate again; as, the hills reëcho the roar of cannon.","pos":""}],"REECHO":[{"def":"To give echoes; to return back, or be reverberated, as an echo; to resound; to be resonant.","pos":""}],"REECHY":[{"def":"Smoky; reeky; hence, begrimed with dirt.","pos":""}],"REED":[{"def":"The fourth stomach of a ruminant; rennet.","pos":""}],"REED-MACE":[{"def":"Reed\"-mace` (-ms`), n.","pos":""}],"REEDBIRD":[{"def":"Reed\"bird` (rd\"brd`), n.","pos":""}],"REEDED":[{"def":"Civered with reeds; reedy.","pos":""},{"def":"Formed with channels and ridges like reeds.","pos":""}],"REEDEN":[{"def":"Consisting of a reed or reeds.","pos":""}],"REEDIFICATION":[{"def":"The act reëdifying; the state of being reëdified.","pos":""}],"REEDIFY":[{"def":"To edify anew; to build again after destruction.","pos":""}],"REEDING":[{"def":"A small convex molding; a reed (see Illust.","pos":""}],"REEDLESS":[{"def":"Destitute of reeds; as, reedless banks.","pos":""}],"REEDLING":[{"def":"The European bearded titmouse (Panurus biarmicus); -- called also reed bunting, bearded pinnock, and lesser butcher bird.","pos":""}],"REEDWORK":[{"def":"A collective name for the reed stops of an organ.","pos":""}],"REEDY":[{"def":"Abounding with reeds; covered with reeds.","pos":""}],"REEF":[{"def":"A large vein of auriferous quartz; -- so called in Australia.","pos":""}],"REEF-BAND":[{"def":"A piece of canvas sewed across a sail to strengthen it in the part where the eyelet holes for reefing are made.","pos":""}],"REEFER":[{"def":"One who reefs; -- a name often given to midshipmen.","pos":""}],"REEFING":[{"def":"The process of taking in a reef.","pos":""}],"REEFY":[{"def":"Full of reefs or rocks.","pos":""}],"REEK":[{"def":"Vapor; steam; smoke; fume.","pos":""}],"REEKY":[{"def":"Soiled with smoke or steam; smoky; foul.","pos":""}],"REEL":[{"def":"A lively dance of the Highlanders of Scotland; also, the music to the dance; -- often called Scotch reel.","pos":""}],"REELECT":[{"def":"To elect again; as, to reëlect the former governor.","pos":""}],"REELECTION":[{"def":"Election a second time, or anew; as, the reëlection of a former chief.","pos":""}],"REELER":[{"def":"The grasshopper warbler; -- so called from its note.","pos":""}],"REELIGIBLE":[{"def":"Eligble again; capable of reëlection; as, reëligible to the same office.","pos":""}],"REEM":[{"def":"The Hebrew name of a horned wild animal, probably the Urus.","pos":""}],"REEMBARK":[{"def":"To put, or go, on board a vessel again; to embark again.","pos":""}],"REEMBARKATION":[{"def":"A putting, or going, on board a vessel again.","pos":""}],"REEMBODY":[{"def":"To embody again.","pos":""}],"REEMBRACE":[{"def":"To embrace again.","pos":""}],"REEMERGE":[{"def":"To emerge again.","pos":""}],"REEMERGENCE":[{"def":"Re`ë*mer\"gence (-mr\"jens), n.","pos":""}],"REENACT":[{"def":"Re`ën*act\" (r`n*kt\") v.","pos":""}],"REENACTION":[{"def":"Re`ën*ac\"tion (-k\"shn), n.","pos":""}],"REENACTMENT":[{"def":"The enacting or passing of a law a second time; the renewal of a law.","pos":""}],"REENCOURAGE":[{"def":"To encourage again.","pos":""}],"REENDOW":[{"def":"Re`ën*dow\" (-dou\"), v.","pos":""}],"REENFORCE":[{"def":"To strengthen with new force, assistance, material, or support; as, to reënforce an argument; to reënforce a garment; especially, to strengthen with additional troops, as an army or a fort, or with additional ships, as a fleet.","pos":""}],"REENFORCED CONCRETE":[{"def":"Concrete having within its mass a system of strengthening iron or steel supports.","pos":""}],"REENFORCEMENT":[{"def":"The act of reënforcing, or the state of being reënforced.","pos":""},{"def":"That which reënforces; additional force; especially, additional troops or force to augment the strength of any army, or ships to strengthen a navy or fleet.","pos":""}],"REENGAGE":[{"def":"To engage a second time or again.","pos":""}],"REENGAGEMENT":[{"def":"A renewed or repeated engagement.","pos":""}],"REENGRAVE":[{"def":"To engrave anew.","pos":""}],"REENJOY":[{"def":"Re`ën*joy\" (-joi\"), v.","pos":""}],"REENJOYMENT":[{"def":"Renewed enjoiment.","pos":""}],"REENKINDLE":[{"def":"To enkindle again.","pos":""}],"REENLIST":[{"def":"To enlist again.","pos":""}],"REENLISTMENT":[{"def":"A renewed enlistment.","pos":""}],"REENSLAVE":[{"def":"To enslave again.","pos":""}],"REENTER":[{"def":"To cut deeper, as engraved lines on a plate of metal, when the engraving has not been deep enough, or the plate has become worn in printing.","pos":""}],"REENTERING":[{"def":"The process of applying additional colors, by applications of printing blocks, to patterns already partly colored.","pos":""}],"REENTHRONE":[{"def":"To enthrone again; to replace on a throne.","pos":""}],"REENTHRONEMENT":[{"def":"A second enthroning.","pos":""}],"REENTRANCE":[{"def":"The act entereing again; re Hooker.","pos":""}],"REENTRANT":[{"def":"Reëntering; pointing or directed inwardds; as, a re angle.","pos":""}],"REENTRY":[{"def":"A resuming or retaking possession of what one has lately foregone; -- applied especially to land; the entry by a lessor upon the premises leased, on failure of the tenant to pay rent or perform the covenants in the lease.","pos":""}],"REERECT":[{"def":"Re`ë*rect\" (r`*rkt\"), v.","pos":""}],"REERMOUSE":[{"def":"Reer\"mouse` (rr\"mous`), n.","pos":""}],"REESTABLISH":[{"def":"To establish anew; to fix or confirm again; to restore; as, to reëstablish a covenant; to reëstablish health.","pos":""}],"REESTABLISHER":[{"def":"One who establishes again.","pos":""}],"REESTABLISHMENT":[{"def":"The act reëstablishing; the state of being reëstablished.","pos":""}],"REEVE":[{"def":"The female of the ruff.","pos":""}],"REEXAMINABLE":[{"def":"Admitting of being reëxamined or reconsidered.","pos":""}],"REEXAMINATION":[{"def":"A repeated examination.","pos":""}],"REEXAMINE":[{"def":"To examine anew.","pos":""}],"REEXCHANGE":[{"def":"To exchange anew; to reverse (a previous exchange).","pos":""}],"REEXHIBIT":[{"def":"To exhibit again.","pos":""}],"REEXPEL":[{"def":"Re`ëx*pel\" (r`ks*pl\"), v.","pos":""}],"REEXPERIENCE":[{"def":"A renewed or repeated experience.","pos":""}],"REEXPORT":[{"def":"To export again, as what has been imported.","pos":""}],"REEXPORTATION":[{"def":"The act of reëxporting, or of exporting an import.","pos":""}],"REEXPULSION":[{"def":"Renewed or repeated expulsion.","pos":""}],"REEZED":[{"def":"Grown rank; rancid; rusty.","pos":""}]}