{"LURCATION":[{"def":"Gluttony; gormandizing.","pos":""}],"LURCH":[{"def":"To swallow or eat greedily; to devour; hence, to swallow up.","pos":""}],"LURCHER":[{"def":"One of a mongrel breed of dogs said to have been a cross between the sheep dog, greyhound, and spaniel.","pos":""}],"LURCHLINE":[{"def":"The line by which a fowling net was pulled over so as to inclose the birds.","pos":""}],"LURDAN":[{"def":"Stupid; blockish.","pos":""}],"LURE":[{"def":"A velvet smoothing brush.","pos":""}],"LURG":[{"def":"A large marine annelid (Nephthys cæca), inhabiting the sandy shores of Europe and America.","pos":""}],"LURID":[{"def":"Having a brown color tonged with red, as of flame seen through smoke.","pos":""},{"def":"Of a color tinged with purple, yellow, and gray.","pos":""}],"LURK":[{"def":"To lie hid; to lie in wait.","pos":""},{"def":"To keep out of sight.","pos":""}],"LURKER":[{"def":"A small fishing boat.","pos":""}],"LURRY":[{"def":"A confused heap; a throng, as of persons; a jumble, as of sounds.","pos":""}]}