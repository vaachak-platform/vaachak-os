{"SWAB":[{"def":"To clean with a mop or swab; to wipe when very wet, as after washing; as, to swab the desk of a ship.","pos":""}],"SWABBER":[{"def":"Formerly, an interior officer on board of British ships of war, whose business it was to see that the ship was kept clean.","pos":""}],"SWAD":[{"def":"A thin layer of refuse at the bottom of a seam.","pos":""}],"SWADDLE":[{"def":"Anything used to swaddle with, as a cloth or band; a swaddling band.","pos":""}],"SWADDLER":[{"def":"A term of contempt for an Irish Methodist.","pos":""}],"SWADDLING":[{"def":"from Swaddle, v.","pos":""}],"SWAG":[{"def":"To hang or move, as something loose and heavy; to sway; to swing.","pos":""},{"def":"To sink down by its weight; to sag.","pos":""}],"SWAG-BELLIED":[{"def":"Having a prominent, overhanging belly.","pos":""}],"SWAGBELLY":[{"def":"Any large tumor developed in the abdomen, and neither fluctuating nor sonorous.","pos":""}],"SWAGE":[{"def":"A tool, variously shaped or grooved on the end or face, used by blacksmiths and other workers in metals, for shaping their work, whether sheet metal or forging, by holding the swage upon the work, or the work upon the swage, and striking with a sledge.","pos":""}],"SWAGGER":[{"def":"To walk with a swaying motion; hence, to walk and act in a pompous, consequential manner.","pos":""},{"def":"To boast or brag noisily; to be ostentatiously proud or vainglorious; to bluster; to bully.","pos":""}],"SWAGGERER":[{"def":"One who swaggers; a blusterer; a bully; a boastful, noisy fellow.","pos":""}],"SWAGGY":[{"def":"Inclined to swag; sinking, hanging, or leaning by its weight.","pos":""}],"SWAGMAN":[{"def":"A bushman carrying a swag and traveling on foot; -- called also swagsman, swagger, and swaggie.","pos":""}],"SWAIN":[{"def":"A young man dwelling in the country; a rustic; esp.","pos":""}],"SWAINISH":[{"def":"Pertaining to, or resembling, a swain; rustic; ignorant.","pos":""}],"SWAINMOTE":[{"def":"A court held before the verders of the forest as judges, by the steward of the court, thrice every year, the swains, or freeholders, within the forest composing the jury.","pos":""}],"SWAINSHIP":[{"def":"The condition of a swain.","pos":""}],"SWAIP":[{"def":"To walk proudly; to sweep along.","pos":""}],"SWALE":[{"def":"A valley or low place; a tract of low, and usually wet, land; a moor; a fen.","pos":""}],"SWALLET":[{"def":"Water breaking in upon the miners at their work; -- so called among tin miners.","pos":""}],"SWALLOW":[{"def":"Any one of numerous species of passerine birds of the family Hirundinidæ, especially one of those species in which the tail is deeply forked.","pos":""},{"def":"Any one of numerous species of swifts which resemble the true swallows in form and habits, as the common American chimney swallow, or swift.","pos":""}],"SWALLOW-TAILED":[{"def":"United by dovetailing; dovetailed.","pos":""}],"SWALLOWER":[{"def":"One who swallows; also, a glutton.","pos":""}],"SWALLOWFISH":[{"def":"The European sapphirine gurnard (Trigla hirundo).","pos":""}],"SWALLOWTAIL":[{"def":"A kind of tenon or tongue used in making joints.","pos":""},{"def":"A species of willow.","pos":""}],"SWAMP":[{"def":"Wet, spongy land; soft, low ground saturated with water, but not usually covered with it; marshy ground away from the seashore.","pos":""}],"SWAMPY":[{"def":"Consisting of swamp; like a swamp; low, wet, and spongy; as, swampy land.","pos":""}],"SWAN":[{"def":"Any one of numerous species of large aquatic birds belonging to Cygnus, Olor, and allied genera of the subfamily Cygninæ.","pos":""},{"def":"The constellation Cygnus.","pos":""}],"SWAN-HOPPING":[{"def":"A corruption of Swan-upping.","pos":""}],"SWAN-UPPING":[{"def":"A yearly expedition on the Thames to take up young swans and mark them, as by Companies of Dyers and Vintners; -- called also swan-hopping.","pos":""}],"SWANHERD":[{"def":"One who tends or marks swans; as, the royal swanherd of England.","pos":""}],"SWANIMOTE":[{"def":"An active and clever young fellow.","pos":""}],"SWANLIKE":[{"def":"Resembling a swan.","pos":""}],"SWANMARK":[{"def":"A mark of ownership cut on the bill or swan.","pos":""}],"SWANNERY":[{"def":"A place where swans are bred.","pos":""}],"SWANNY":[{"def":"Swanlike; as, a swanny glossiness of the neck.","pos":""}],"SWANPAN":[{"def":"The Chinese abacus; a schwanpan.","pos":""}],"SWANSKIN":[{"def":"The act of a swan with the down or the feathers on.","pos":""},{"def":"A species of soft flannel, thick and warm.","pos":""}],"SWAP":[{"def":"To strike; -- with off.","pos":""},{"def":"To exchange (usually two things of the same kind); to swop.","pos":""}],"SWARD":[{"def":"The grassy surface of land; that part of the soil which is filled with the roots of grass; turf.","pos":""}],"SWARDED":[{"def":"Covered with sward.","pos":""}],"SWARDY":[{"def":"Covered with sward or grass.","pos":""}],"SWARE":[{"def":"Cophetua sware a royal oath.","pos":""}],"SWARF":[{"def":"To grow languid; to faint.","pos":""}],"SWARM":[{"def":"To climb a tree, pole, or the like, by embracing it with the arms and legs alternately.","pos":""}],"SWARMSPORE":[{"def":"One of innumerable minute, motile, reproductive bodies, produced asexually by certain algæ and fungi; a zoöspore.","pos":""},{"def":"One of the minute flagellate germs produced by the sporulation of a protozoan; -- called also zoöspore.","pos":""}],"SWART":[{"def":"Of a dark hue; moderately black; swarthy; tawny.","pos":""},{"def":"Gloomy; malignant.","pos":""}],"SWARTBACK":[{"def":"The black-backed gull (Larus marinus); -- called also swarbie.","pos":""}],"SWARTH":[{"def":"An apparition of a person about to die; a wraith.","pos":""}],"SWARTHILY":[{"def":"In a swarthy manner; with a tawny hue; duskily.","pos":""}],"SWARTHINESS":[{"def":"The quality or state of being swarthy; a dusky or dark complexion; tawniness.","pos":""}],"SWARTHY":[{"def":"Being of a dark hue or dusky complexion; tawny; swart; as, swarthy faces.","pos":""}],"SWARTISH":[{"def":"Somewhat swart, dark, or tawny.","pos":""}],"SWARTNESS":[{"def":"The quality or state of being swart.","pos":""}],"SWASH":[{"def":"An oval figure, whose moldings are oblique to the axis of the work.","pos":""}],"SWASHBUCKLER":[{"def":"A bully or braggadocio; a swaggering, boastful fellow; a swaggerer.","pos":""}],"SWASHER":[{"def":"One who makes a blustering show of valor or force of arms.","pos":""}],"SWASHING":[{"def":"Swaggering; hectoring.","pos":""},{"def":"Resounding; crushing.","pos":""}],"SWASHWAY":[{"def":"Same as 4th Swash, 2.","pos":""}],"SWASHY":[{"def":"Soft, like fruit that is too ripe; quashy; swash.","pos":""},{"def":"A symbol or ornament in the form of a Greek cross with the ends of the arms at right angles all in the same direction, and each prolonged to the height of the parallel arm of the cross.","pos":""}],"SWATCH":[{"def":"A piece, pattern, or sample, generally of cloth.","pos":""}],"SWATH":[{"def":"A line of grass or grain cut and thrown together by the scythe in mowing or cradling.","pos":""},{"def":"The whole sweep of a scythe, or the whole breadth from which grass or grain is cut by a scythe or a machine, in mowing or cradling; as, to cut a wide swath.","pos":""}],"SWATHE":[{"def":"To bind with a swathe, band, bandage, or rollers.","pos":""}],"SWATHER":[{"def":"A device attached to a mowing machine for raising the uncut fallen grain and marking the limit of the swath.","pos":""}],"SWAY":[{"def":"To hoist; as, to sway up the yards.","pos":""}],"SWAY-BACKED":[{"def":"Having the back hollow or sagged, whether naturally or as the result of injury or weakness; -- said of horses and other animals.","pos":""}],"SWAY-BRACING":[{"def":"The horizontal bracing of a bridge, which prevents its swaying.","pos":""}],"SWAYED":[{"def":"Bent down, and hollow in the back; sway-backed; -- said of a horse.","pos":""}],"SWAYING":[{"def":"An injury caused by violent strains or by overloading; -- said of the backs of horses.","pos":""}]}