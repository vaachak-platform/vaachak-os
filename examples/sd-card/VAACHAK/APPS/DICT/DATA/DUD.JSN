{"DUDDER":[{"def":"To confuse or confound with noise.","pos":""}],"DUDDERY":[{"def":"A place where rags are bought and kept for sale.","pos":""}],"DUDE":[{"def":"A kind of dandy; especially, one characterized by an ultrafashionable style of dress and other affectations.","pos":""}],"DUDEEN":[{"def":"A short tobacco pipe.","pos":""}],"DUDGEON":[{"def":"The root of the box tree, of which hafts for daggers were made.","pos":""},{"def":"The haft of a dagger.","pos":""}],"DUDISH":[{"def":"Like, or characterized of, a dude.","pos":""}],"DUDS":[{"def":"Old or inferior clothes; tattered garments.","pos":""},{"def":"Effects, in general.","pos":""}]}