{"MIST":[{"def":"Visible watery vapor suspended in the atmosphere, at or near the surface of the earth; fog.","pos":""},{"def":"Coarse, watery vapor, floating or falling in visible particles, approaching the form of rain; as, Scotch mist.","pos":""}],"MISTAKABLE":[{"def":"Liable to be mistaken; capable of being misconceived.","pos":""}],"MISTAKE":[{"def":"To take or choose wrongly.","pos":""},{"def":"To take in a wrong sense; to misunderstand misapprehend, or misconceive; as, to mistake a remark; to mistake one's meaning.","pos":""}],"MISTAKEN":[{"def":"Being in error; judging wrongly; having a wrong opinion or a misconception; as, a mistaken man; he is mistaken.","pos":""},{"def":"Erroneous; wrong; as, a mistaken notion.","pos":""}],"MISTAKER":[{"def":"One who mistakes.","pos":""}],"MISTAKING":[{"def":"An error; a mistake.","pos":""}],"MISTAUGHT":[{"def":"Wrongly taught; as, a mistaught youth.","pos":""}],"MISTEACH":[{"def":"To teach wrongly; to instruct erroneously.","pos":""}],"MISTELL":[{"def":"To tell erroneously.","pos":""}],"MISTEMPER":[{"def":"To temper ill; to disorder; as, to mistemper one's head.","pos":""}],"MISTER":[{"def":"A title of courtesy prefixed to the name of a man or youth.","pos":""}],"MISTERM":[{"def":"To call by a wrong name; to miscall.","pos":""}],"MISTERY":[{"def":"See Mystery, a trade.","pos":""}],"MISTFUL":[{"def":"Clouded with, or as with, mist.","pos":""}],"MISTHINK":[{"def":"To think wrongly.","pos":""}],"MISTHOUGHT":[{"def":"Erroneous thought; mistaken opinion; error.","pos":""}],"MISTHRIVE":[{"def":"To thrive poorly; to be not thrifty or prosperous.","pos":""}],"MISTHROW":[{"def":"To throw wrongly.","pos":""},{"def":"A kind of small sailing vessel used in the Mediterranean.","pos":""}],"MISTIDE":[{"def":"To happen or come to pass unfortunately; also, to suffer evil fortune.","pos":""},{"def":"A variety of the game of poker in which the joker is used, and called mistigris or mistigri.","pos":""}],"MISTILY":[{"def":"With mist; darkly; obscurely.","pos":""}],"MISTIME":[{"def":"To time wrongly; not to adapt to the time.","pos":""}],"MISTINESS":[{"def":"State of being misty.","pos":""}],"MISTITLE":[{"def":"To call by a wrong title.","pos":""}],"MISTLE":[{"def":"To fall in very fine drops, as rain.","pos":""}],"MISTLETOE":[{"def":"A parasitic evergreen plant of Europe (Viscum album), bearing a glutinous fruit.","pos":""}],"MISTONUSK":[{"def":"The American badger.","pos":""}],"MISTRADITION":[{"def":"A wrong tradition.","pos":""}],"MISTRAL":[{"def":"A violent and cold northwest wind experienced in the Mediterranean provinces of France, etc.","pos":""}],"MISTRANSLATE":[{"def":"To translate erroneously.","pos":""}],"MISTRANSLATION":[{"def":"Wrong translation.","pos":""}],"MISTRANSPORT":[{"def":"To carry away or mislead wrongfully, as by passion.","pos":""}],"MISTREADING":[{"def":"Misstep; misbehavior.","pos":""}],"MISTREAT":[{"def":"To treat amiss; to abuse.","pos":""}],"MISTREATMENT":[{"def":"Wrong treatment.","pos":""}],"MISTRESS":[{"def":"A woman having power, authority, or ownership; a woman who exercises authority, is chief, etc.","pos":""},{"def":"A woman well skilled in anything, or having the mastery over it.","pos":""}],"MISTRESSSHIP":[{"def":"Female rule or dominion.","pos":""},{"def":"Ladyship, a style of address; -- with the personal pronoun.","pos":""}],"MISTRIAL":[{"def":"A false or erroneous trial; a trial which has no result.","pos":""}],"MISTROW":[{"def":"To think wrongly.","pos":""}],"MISTRUST":[{"def":"Want of confidence or trust; suspicion; distrust.","pos":""}],"MISTRUSTER":[{"def":"One who mistrusts.","pos":""}],"MISTRUSTFUL":[{"def":"Having or causing mistrust, suspicions, or forebodings.","pos":""}],"MISTRUSTINGLY":[{"def":"With distrust or suspicion.","pos":""}],"MISTRUSTLESS":[{"def":"Having no mistrust or suspicion.","pos":""}],"MISTUNE":[{"def":"To tune wrongly.","pos":""}],"MISTURN":[{"def":"To turn amiss; to pervert.","pos":""}],"MISTUTOR":[{"def":"To instruct amiss.","pos":""}],"MISTY":[{"def":"Accompained with mist; characterized by the presence of mist; obscured by, or overspread with, mist; as, misty weather; misty mountains; a misty atmosphere.","pos":""},{"def":"Obscured as if by mist; dim; obscure; clouded; as, misty sight.","pos":""}]}