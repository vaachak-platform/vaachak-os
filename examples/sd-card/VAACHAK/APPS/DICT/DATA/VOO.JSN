{"VOODOO":[{"def":"One who practices voodooism; a negro sorcerer.","pos":""}],"VOODOOISM":[{"def":"A degraded form of superstition and sorcery, said to include human sacrifices and cannibalism in some of its rites.","pos":""}],"VOORTREKER":[{"def":"One who treks before or first; a pioneer.","pos":""}]}