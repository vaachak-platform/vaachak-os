{"VOMERINE":[{"def":"Of or pertaining to the vomer.","pos":""}],"VOMIC NUT":[{"def":"Same as Nux vomica.","pos":""}],"VOMIT":[{"def":"To eject the contents of the stomach by the mouth; to puke; to spew.","pos":""}],"VOMITING":[{"def":"The spasmodic ejection of matter from the stomach through the mouth.","pos":""}],"VOMITION":[{"def":"The act or power of vomiting.","pos":""}],"VOMITIVE":[{"def":"Causing the ejection of matter from the stomach; emetic.","pos":""}],"VOMITO":[{"def":"The yellow fever in its worst form, when it is usually attended with black vomit.","pos":""}],"VOMITORY":[{"def":"Causing vomiting; emetic; vomitive.","pos":""}]}