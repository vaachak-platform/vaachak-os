{"TIP":[{"def":"A piece of stiffened lining pasted on the inside of a hat crown.","pos":""}],"TIP-UP":[{"def":"The spotted sandpiper; -- called also teeter-tail.","pos":""}],"TIPCART":[{"def":"A cart so constructed that the body can be easily tipped, in order to dump the load.","pos":""}],"TIPCAT":[{"def":"A game in which a small piece of wood pointed at both ends, called a cat, is tipped, or struck with a stick or bat, so as to fly into the air.","pos":""}],"TIPPER":[{"def":"A kind of ale brewed with brackish water obtained from a particular well; -- so called from the first brewer of it, one Thomas Tipper.","pos":""}],"TIPPET":[{"def":"A cape, or scarflike garment for covering the neck, or the neck and shoulders, -- usually made of fur, cloth, or other warm material.","pos":""},{"def":"A length of twisted hair or gut in a fish line.","pos":""}],"TIPPING":[{"def":"A distinct articulation given in playing quick notes on the flute, by striking the tongue against the roof of the mouth; double- tonguing.","pos":""}],"TIPPLE":[{"def":"To drink spirituous or strong liquors habitually; to indulge in the frequent and improper used of spirituous liquors; especially, to drink frequently in small quantities, but without absolute drunkeness.","pos":""}],"TIPPLED":[{"def":"Intoxicated; inebriated; tipsy; drunk.","pos":""}],"TIPPLER":[{"def":"One who keeps a tippling-house.","pos":""},{"def":"One who habitually indulges in the excessive use of spirituous liquors, whether he becomes intoxicated or not.","pos":""}],"TIPPLING-HOUSE":[{"def":"A house in which liquors are sold in drams or small quantities, to be drunk on the premises.","pos":""}],"TIPSILY":[{"def":"In a tipsy manner; like one tipsy.","pos":""}],"TIPSINESS":[{"def":"The state of being tipsy.","pos":""}],"TIPSTAFF":[{"def":"A staff tipped with metal.","pos":""},{"def":"An officer who bears a staff tipped with metal; a constable.","pos":""}],"TIPSTER":[{"def":"One who makes a practice of giving or selling tips, or private hints or information, esp.","pos":""}],"TIPSTOCK":[{"def":"The detachable or movable fore part of a gunstock, lying beneath the barrel or barrels, and forming a hold for the left hand.","pos":""}],"TIPSY":[{"def":"Being under the influence of strong drink; rendered weak or foolish by liquor, but not absolutely or completely drunk; fuddled; intoxicated.","pos":""},{"def":"Staggering, as if from intoxication; reeling.","pos":""}],"TIPTOE":[{"def":"The end, or tip, of the toe.","pos":""}],"TIPTOP":[{"def":"The highest or utmost degree; the best of anything.","pos":""}],"TIPULA":[{"def":"Any one of many species of long-legged dipterous insects belonging to Tipula and allied genera.","pos":""}],"TIPULARY":[{"def":"Of or pertaining to the tipulas.","pos":""}]}