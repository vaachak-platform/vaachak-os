{"CHIC":[{"def":"Good form; style.","pos":""}],"CHICA":[{"def":"A red coloring matter.","pos":""}],"CHICALOTE":[{"def":"A Mexican prickly poppy (Argemone platyceras), which has migrated into California.","pos":""}],"CHICANE":[{"def":"The use of artful subterfuge, designed to draw away attention from the merits of a case or question; -- specifically applied to legal proceedings; trickery; chicanery; caviling; sophistry.","pos":""}],"CHICANER":[{"def":"One who uses chicanery.","pos":""}],"CHICANERY":[{"def":"Mean or unfair artifice to perplex a cause and obscure the truth; stratagem; sharp practice; sophistry.","pos":""}],"CHICHEVACHE":[{"def":"A fabulous cow of enormous size, whose food was patient wives, and which was therefore in very lean condition.","pos":""},{"def":"A leguminous plant (Lathyrus sativus), with broad flattened seeds which are sometimes used for food.","pos":""}],"CHICK":[{"def":"To sprout, as seed in the ground; to vegetate.","pos":""}],"CHICK-PEA":[{"def":"A Small leguminous plant (Cicer arietinum) of Asia, Africa, and the sounth of Europe; the chick; the dwarf pea; the gram.","pos":""}],"CHICKABIDDY":[{"def":"A chicken; a fowl; also, a trivial term of endearment for a child.","pos":""}],"CHICKADEE":[{"def":"A small bird, the blackcap titmouse (Parus atricapillus), of North America; -- named from its note.","pos":""}],"CHICKAREE":[{"def":"The American red squirrel (Sciurus Hudsonius); -- so called from its cry.","pos":""}],"CHICKASAWS":[{"def":"A trible of North American Indians (Southern Appalachian) allied to the Choctaws.","pos":""}],"CHICKEN":[{"def":"A young bird or fowl, esp.","pos":""},{"def":"A young person; a child; esp.","pos":""}],"CHICKEN POX":[{"def":"A mild, eruptive disease, generally attacking children only; varicella.","pos":""}],"CHICKEN-BREASTED":[{"def":"Having a narrow, projecting chest, caused by forward curvature of the vertebral column.","pos":""}],"CHICKEN-HEARTED":[{"def":"Timid; fearful; cowardly.","pos":""}],"CHICKLING":[{"def":"A small chick or chicken.","pos":""}],"CHICKWEED":[{"def":"The name of several caryophyllaseous weeds, especially Stellaria media, the seeds and flower buds of which are a favorite food of small birds.","pos":""}],"CHICKY":[{"def":"A chicken; -- used as a diminutive or pet name, especially in calling fowls.","pos":""},{"def":"A gumlike substance obtained from the bully tree (Mimusops globosa) and sometimes also from the naseberry or sapodilla (Sapota zapotilla).","pos":""}],"CHICO":[{"def":"The common greasewood of the western United States (Sarcobatus vermiculatus).","pos":""}],"CHICORY":[{"def":"A branching perennial plant (Cichorium Intybus) with bright blue flowers, growing wild in Europe, Asia, and America; also cultivated for its roots and as a salad plant; succory; wild endive.","pos":""}]}