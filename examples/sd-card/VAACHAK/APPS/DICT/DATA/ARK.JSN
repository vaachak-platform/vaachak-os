{"ARK":[{"def":"The oblong chest of acacia wood, overlaid with gold, which supported the mercy seat with its golden cherubs, and occupied the most sacred place in the sanctuary.","pos":""}],"ARK SHELL":[{"def":"A marine bivalve shell belonging to the genus Arca and its allies.","pos":""}],"ARKITE":[{"def":"Belonging to the ark.","pos":""}],"ARKOSE":[{"def":"A sandstone derived from the disintegration of granite or gneiss, and characterized by feldspar fragments.","pos":""}]}