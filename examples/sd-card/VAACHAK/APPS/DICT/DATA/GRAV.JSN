{"GRAVAMEN":[{"def":"The grievance complained of; the substantial cause of the action; also, in general, the ground or essence of a complaint.","pos":""},{"def":"A final syllable signifying a ruler, as in landgrave, margrave.","pos":""}],"GRAVE":[{"def":"Of great weight; heavy; ponderous.","pos":""},{"def":"Of importance; momentous; weighty; influential; sedate; serious; - - said of character, relations, etc.","pos":""}],"GRAVECLOTHES":[{"def":"The clothes or dress in which the dead are interred.","pos":""}],"GRAVEDIGGER":[{"def":"See Burying beetle, under Bury, v.","pos":""}],"GRAVEL":[{"def":"A deposit of small calculous concretions in the kidneys and the urinary or gall bladder; also, the disease of which they are a symptom.","pos":""}],"GRAVEL-STONE":[{"def":"A pebble, or small fragment of stone; a calculus.","pos":""}],"GRAVELESS":[{"def":"Without a grave; unburied.","pos":""},{"def":"A salmon one or two years old, before it has gone to sea.","pos":""}],"GRAVELLINESS":[{"def":"State of being gravelly.","pos":""}],"GRAVELLY":[{"def":"Abounding with gravel; consisting of gravel; as, a gravelly soil.","pos":""}],"GRAVELY":[{"def":"In a grave manner.","pos":""}],"GRAVENESS":[{"def":"The quality of being grave.","pos":""}],"GRAVENSTEIN":[{"def":"A kind of fall apple, marked with streaks of deep red and orange, and of excellent flavor and quality.","pos":""}],"GRAVEOLENCE":[{"def":"A strong and offensive smell; rancidity.","pos":""}],"GRAVEOLENT":[{"def":"Having a rank smell.","pos":""}],"GRAVER":[{"def":"One who graves; an engraver or a sculptor; one whose occupation is te cut letters or figures in stone or other hard material.","pos":""},{"def":"An ergraving or cutting tool; a burin.","pos":""}],"GRAVERY":[{"def":"The act, process, or art, of graving or carving; engraving.","pos":""}],"GRAVES":[{"def":"The sediment of melted tallow.","pos":""}],"GRAVES' DISEASE":[{"def":"Same as Basedow's disease.","pos":""}],"GRAVESTONE":[{"def":"A stone laid over, or erected near, a grave, usually with an inscription, to preserve the memory of the dead; a tombstone.","pos":""}],"GRAVEYARD":[{"def":"A yard or inclosure for the interment of the dead; a cemetery.","pos":""}],"GRAVIC":[{"def":"Pertaining to, or causing, gravitation; as, gravic forces; gravic attraction.","pos":""}],"GRAVID":[{"def":"Being with child; heavy with young; pregnant; fruitful; as, a gravid uterus; gravid piety.","pos":""}],"GRAVIDATED":[{"def":"Made pregnant; big.","pos":""}],"GRAVIDITY":[{"def":"The state of being gravidated; pregnancy.","pos":""}],"GRAVIGRADE":[{"def":"One of the pachyderms.","pos":""}],"GRAVIMETER":[{"def":"(Physics) An instrument for ascertaining the specific gravity of bodies.","pos":""}],"GRAVIMETRIC":[{"def":"Of or pertaining to measurement by weight; measured by weight.","pos":""}],"GRAVING":[{"def":"The act of cleaning a ship's bottom.","pos":""}],"GRAVITATE":[{"def":"To obey the law of gravitation; to exert a force Or pressure, or tend to move, under the influence of gravitation; to tend in any direction or toward any object.","pos":""}],"GRAVITATION":[{"def":"The act of gravitating.","pos":""}],"GRAVITATIONAL":[{"def":"Of or pertaining to the force of gravity; as, gravitational units.","pos":""}],"GRAVITATIVE":[{"def":"Causing to gravitate; tending to a center.","pos":""}],"GRAVITY":[{"def":"The tendency of a mass of matter toward a center of attraction; esp.","pos":""},{"def":"Lowness of tone; -- opposed to acuteness.","pos":""}],"GRAVY":[{"def":"The juice or other liquid matter that drips from flesh in cooking, made into a dressing for the food when served up.","pos":""},{"def":"Liquid dressing for meat, fish, vegetables, etc.","pos":""}]}