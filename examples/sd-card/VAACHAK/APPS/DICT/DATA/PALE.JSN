{"PALE":[{"def":"Wanting in color; not ruddy; dusky white; pallid; wan; as, a pale face; a pale red; a pale blue.","pos":""},{"def":"Not bright or brilliant; of a faint luster or hue; dim; as, the pale light of the moon.","pos":""}],"PALEA":[{"def":"A pendulous process of the skin on the throat of a bird, as in the turkey; a dewlap.","pos":""}],"PALEACEOUS":[{"def":"Chaffy; resembling or consisting of paleæ, or chaff; furnished with chaff; as, a paleaceous receptacle.","pos":""}],"PALEARCTIC":[{"def":"Belonging to a region of the earth's surface which includes all Europe to the Azores, Iceland, and all temperate Asia.","pos":""}],"PALED":[{"def":"Inclosed with a paling.","pos":""}],"PALEECHINOIDEA":[{"def":"An extinct order of sea urchins found in the Paleozoic rocks.","pos":""}],"PALEFACE":[{"def":"A white person; -- an appellation supposed to have been applied to the whites by the American Indians.","pos":""}],"PALEICHTHYES":[{"def":"A comprehensive division of fishes which includes the elasmobranchs and ganoids.","pos":""}],"PALELY":[{"def":"In a pale manner; dimly; wanly; not freshly or ruddily.","pos":""}],"PALEMPORE":[{"def":"A superior kind of dimity made in India, -- used for bed coverings.","pos":""}],"PALENESS":[{"def":"The quality or condition of being pale; want of freshness or ruddiness; a sickly whiteness; lack of color or luster; wanness.","pos":""}],"PALENQUE":[{"def":"A collective name for the Indians of Nicaragua and Honduras.","pos":""}],"PALEO-":[{"def":"A combining form meaning old, ancient; as, palearctic, paleontology, paleothere, paleography.","pos":""}],"PALEOBOTANIST":[{"def":"One versed in paleobotany.","pos":""}],"PALEOBOTANY":[{"def":"That branch of paleontology which treats of fossil plants.","pos":""}],"PALEOCARIDA":[{"def":"Same as Merostomata.","pos":""}],"PALEOCRINOIDEA":[{"def":"A suborder of Crinoidea found chiefly in the Paleozoic rocks.","pos":""}],"PALEOCRYSTIC":[{"def":"Of, pertaining to, or derived from, a former glacial formation.","pos":""}],"PALEOGAEAN":[{"def":"Of or pertaining to the Eastern hemisphere.","pos":""}],"PALEOGRAPH":[{"def":"An ancient manuscript.","pos":""}],"PALEOGRAPHER":[{"def":"One skilled in paleography; a paleographist.","pos":""},{"def":"Of or pertaining to paleography.","pos":""}],"PALEOGRAPHIST":[{"def":"One versed in paleography; a paleographer.","pos":""}],"PALEOGRAPHY":[{"def":"An ancient manner of writing; ancient writings, collectively; as, Punic paleography.","pos":""},{"def":"The study of ancient inscriptions and modes of writing; the art or science of deciphering ancient writings, and determining their origin, period, etc.","pos":""}],"PALEOLA":[{"def":"A diminutive or secondary palea; a lodicule.","pos":""}],"PALEOLITH":[{"def":"A relic of the Paleolithic era.","pos":""}],"PALEOLITHIC":[{"def":"Of or pertaining to an era marked by early stone implements.","pos":""}],"PALEOLOGIST":[{"def":"One versed in paleology; a student of antiquity.","pos":""}],"PALEOLOGY":[{"def":"The study or knowledge of antiquities, esp.","pos":""}],"PALEONTOGRAPHICAL":[{"def":"Of or pertaining to the description of fossil remains.","pos":""}],"PALEONTOGRAPHY":[{"def":"The description of fossil remains.","pos":""}],"PALEONTOLOGICAL":[{"def":"Of or pertaining to paleontology.","pos":""}],"PALEONTOLOGIST":[{"def":"One versed in paleontology.","pos":""}],"PALEONTOLOGY":[{"def":"The science which treats of the ancient life of the earth, or of fossils which are the remains of such life.","pos":""}],"PALEOPHYTOLOGIST":[{"def":"A paleobotanist.","pos":""}],"PALEOPHYTOLOGY":[{"def":"Pa`le*o*phy*tol\"o*gy, n.","pos":""}],"PALEORNITHOLOGY":[{"def":"The branch of paleontology which treats of fossil birds.","pos":""}],"PALEOSAURUS":[{"def":"A genus of fossil saurians found in the Permian formation.","pos":"noun"}],"PALEOTECHNIC":[{"def":"Belonging to, or connected with, ancient art.","pos":""}],"PALEOTHERE":[{"def":"Any species of Paleotherium.","pos":""}],"PALEOTHERIAN":[{"def":"Of or pertaining to Paleotherium.","pos":""}],"PALEOTHERIUM":[{"def":"An extinct genus of herbivorous Tertiary mammals, once supposed to have resembled the tapir in form, but now known to have had a more slender form, with a long neck like that of a llama.","pos":""}],"PALEOTHEROID":[{"def":"Resembling Paleotherium.","pos":""},{"def":"An animal resembling, or allied to, the paleothere.","pos":""}],"PALEOUS":[{"def":"Chaffy; like chaff; paleaceous.","pos":""}],"PALEOZOIC":[{"def":"Of or pertaining to, or designating, the older division of geological time during which life is known to have existed, including the Silurian, Devonian, and Carboniferous ages, and also to the life or rocks of those ages.","pos":""}],"PALEOZOIC ERA":[{"def":"The Paleozoic time or strata.","pos":""},{"def":"The science of extinct animals, a branch of paleontology.","pos":""}],"PALESTRA":[{"def":"Of or pertaining to the palestra, or to wrestling.","pos":""}],"PALET":[{"def":"A perpendicular band upon an escutcheon, one half the breadth of the pale.","pos":""}],"PALETTE":[{"def":"A thin, oval or square board, or tablet, with a thumb hole at one end for holding it, on which a painter lays and mixes his pigments.","pos":""},{"def":"One of the plates covering the points of junction at the bend of the shoulders and elbows.","pos":""}],"PALEWISE":[{"def":"In the manner of a pale or pales; by perpendicular lines or divisions; as, to divide an escutcheon palewise.","pos":""}]}