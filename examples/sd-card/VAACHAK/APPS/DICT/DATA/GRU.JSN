{"GRUB":[{"def":"To dig in or under the ground, generally for an object that is difficult to reach or extricate; to be occupied in digging.","pos":""},{"def":"To drudge; to do menial work.","pos":""}],"GRUBBER":[{"def":"One who, or that which, grubs; especially, a machine or tool of the nature of a grub ax, .","pos":""}],"GRUBBLE":[{"def":"To feel or grope in the dark.","pos":""}],"GRUBBY":[{"def":"The grubby game of marbles.","pos":""}],"GRUBWORM":[{"def":"And gnats and grubworms crowded on his view.","pos":""}],"GRUCCHE":[{"def":"To murmur; to grumble.","pos":""}],"GRUDGE":[{"def":"To look upon with desire to possess or to appropriate; to envy (one) the possession of; to begrudge; to covet; to give with reluctance; to desire to get back again; -- followed by the direct object only, or by both the direct and indirect objects.","pos":""},{"def":"To hold or harbor with malicioua disposition or purpose; to cherish enviously.","pos":""}],"GRUDGEFUL":[{"def":"Full of grudge; envious.","pos":""}],"GRUDGER":[{"def":"One who grudges.","pos":""}],"GRUDGINGLY":[{"def":"In a grudging manner.","pos":""}],"GRUDGINGNESS":[{"def":"The state or quality of grudging, or of being full of grudge or unwillingness.","pos":""}],"GRUEL":[{"def":"A light, liquid food, made by boiling meal of maize, oatmeal, or fiour in water or milk; thin porridge.","pos":""}],"GRUELLY":[{"def":"Like gruel; of the consistence of gruel.","pos":""}],"GRUESOME":[{"def":"Same as Grewsome.","pos":""}],"GRUF":[{"def":"Forwards; with one's face to the ground.","pos":""}],"GRUFF":[{"def":"Of a rough or stern manner, voice, or countenance; sour; surly; severe; harsh.","pos":""}],"GRUGRU PALM":[{"def":"A West Indian name for several kinds of palm.","pos":""}],"GRUGRU WORM":[{"def":"The larva or grub of a large South American beetle (Calandra palmarum), which lives in the pith of palm trees and sugar cane.","pos":""}],"GRUM":[{"def":"Morose; severe of countenance; sour; surly; glum; grim.","pos":""}],"GRUMBLE":[{"def":"To murmur or mutter with discontent; to make ill-natured complaints in a low voice and a surly manner.","pos":""},{"def":"To growl; to snarl in deep tones; as, a lion grumbling over his prey.","pos":""}],"GRUMBLER":[{"def":"One who grumbles.","pos":""}],"GRUMBLINGLY":[{"def":"In a grumbling manner.","pos":""}],"GRUME":[{"def":"A thick, viscid fluid; a clot, as of blood.","pos":""}],"GRUMLY":[{"def":"In a grum manner.","pos":""}],"GRUMOSE":[{"def":"Clustered in grains at intervals; grumous.","pos":""}],"GRUMOUS":[{"def":"Resembling or containing grume; thick; concreted; clotted; as, grumous blood.","pos":""}],"GRUMOUSNESS":[{"def":"The state of being grumous.","pos":""}],"GRUMPILY":[{"def":"In a surly manner; sullenly.","pos":""}],"GRUMPY":[{"def":"Surly; dissatisfied; grouty.","pos":""}],"GRUNDEL":[{"def":"A groundling (fish).","pos":""}],"GRUNDYISM":[{"def":"Narrow and unintelligent conventionalism.","pos":""}],"GRUNT":[{"def":"To make a deep, short noise, as a hog; to utter a short groan or a deep guttural sound.","pos":""}],"GRUNTER":[{"def":"One of several American marine fishes.","pos":""},{"def":"A hook used in lifting a crucible.","pos":""}],"GRUNTINGLY":[{"def":"In a grunting manner.","pos":""}],"GRUNTLE":[{"def":"To grunt; to grunt repeatedly.","pos":""}],"GRUYERE CHEESE":[{"def":"'' (Gruyère, Switzerland.","pos":""}]}