{"INMACY":[{"def":"The state of being an inmate.","pos":""}],"INMATE":[{"def":"One who lives in the same house or apartment with another; a fellow lodger; esp.","pos":""}],"INMEATS":[{"def":"The edible viscera of animals, as the heart, liver, etc.","pos":"noun"}],"INMESH":[{"def":"To bring within meshes, as of a net; to enmesh.","pos":""}],"INMEW":[{"def":"To inclose, as in a mew or cage.","pos":""}],"INMOST":[{"def":"Deepest within; farthest from the surface or external part; innermost.","pos":""}]}