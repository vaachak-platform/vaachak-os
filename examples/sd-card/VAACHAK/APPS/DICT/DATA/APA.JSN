{"APACE":[{"def":"With a quick pace; quick; fast; speedily.","pos":""}],"APACHES":[{"def":"A group of nomadic North American Indians including several tribes native of Arizona, New Mexico, etc.","pos":""}],"APAGOGE":[{"def":"An indirect argument which proves a thing by showing the impossibility or absurdity of the contrary.","pos":""},{"def":"Proving indirectly, by showing the absurdity, or impossibility of the contrary.","pos":""}],"APAIR":[{"def":"To impair or become impaired; to injure.","pos":""}],"APALACHIAN":[{"def":"See Appalachian.","pos":""}],"APANAGE":[{"def":"Same as Appanage.","pos":""}],"APANTHROPY":[{"def":"An aversion to the company of men; a love of solitude.","pos":""}],"APAREJO":[{"def":"A kind of pack saddle used in the American military service and among the Spanish Americans.","pos":""}],"APARITHMESIS":[{"def":"Enumeration of parts or particulars.","pos":""}],"APART":[{"def":"Separately, in regard to space or company; in a state of separation as to place; aside.","pos":""},{"def":"In a state of separation, of exclusion, or of distinction, as to purpose, use, or character, or as a matter of thought; separately; independently; as, consider the two propositions apart.","pos":""}],"APARTMENT":[{"def":"A room in a building; a division in a house, separated from others by partitions.","pos":""},{"def":"A set or suite of rooms.","pos":""}],"APARTMENT HOUSE":[{"def":"A building comprising a number of suites designed for separate housekeeping tenements, but having conveniences, such as heat, light, elevator service, etc.","pos":""}],"APARTNESS":[{"def":"The quality of standing apart.","pos":""}],"APASTRON":[{"def":"That point in the orbit of a double star where the smaller star is farthest from its primary.","pos":""},{"def":"Void of feeling; not susceptible of deep emotion; passionless; indifferent.","pos":""}],"APATHETICALLY":[{"def":"In an apathetic manner.","pos":""}],"APATHIST":[{"def":"One who is destitute of feeling.","pos":""}],"APATHISTICAL":[{"def":"Apathetic; une motional.","pos":""}],"APATHY":[{"def":"Want of feeling; privation of passion, emotion, or excitement; dispassion; -- applied either to the body or the mind.","pos":""}],"APATITE":[{"def":"Native phosphate of lime, occurring usually in six-sided prisms, color often pale green, transparent or translucent.","pos":""}]}