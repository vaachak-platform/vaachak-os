{"PENT":[{"def":"Penned or shut up; confined; -- often with up.","pos":""}],"PENTA-":[{"def":"Denoting the degree of five, either as regards quality, property, or composition; as, pentasulphide; pentoxide, etc.","pos":""}],"PENTABASIC":[{"def":"Capable of uniting with five molecules of a monacid base; having five acid hydrogen atoms capable of substitution by a basic radical; -- said of certain acids.","pos":""}],"PENTACAPSULAR":[{"def":"Having five capsules.","pos":""}],"PENTACHENIUM":[{"def":"A dry fruit composed of five carpels, which are covered by an epigynous calyx and separate at maturity.","pos":""}],"PENTACHLORIDE":[{"def":"A chloride having five atoms of chlorine in each molecule.","pos":""}],"PENTACHORD":[{"def":"An ancient instrument of music with five strings.","pos":""},{"def":"An order or system of five sounds.","pos":""}],"PENTACID":[{"def":"Capable of neutralizing, or combining with, five molecules of a monobasic acid; having five hydrogen atoms capable of substitution by acid residues; -- said of certain complex bases.","pos":""}],"PENTACLE":[{"def":"A figure composed of two equilateral triangles intersecting so as to form a six-pointed star, -- used in early ornamental art, and also with superstitious import by the astrologers and mystics of the Middle Ages.","pos":""}],"PENTACOCCOUS":[{"def":"Composed of five united carpels with one seed in each, as certain fruits.","pos":""}],"PENTACONTER":[{"def":"See Penteconter.","pos":""}],"PENTACRININ":[{"def":"A red and purple pigment found in certain crinoids of the genus Pentacrinus.","pos":""}],"PENTACRINITE":[{"def":"Any species of Pentacrinus.","pos":""}],"PENTACRINOID":[{"def":"An immature comatula when it is still attached by a stem, and thus resembles a Pentacrinus.","pos":""}],"PENTACRINUS":[{"def":"A genus of large, stalked crinoids, of which several species occur in deep water among the West Indies and elsewhere.","pos":""}],"PENTACRON":[{"def":"A solid having five summits or angular points.","pos":""}],"PENTACROSTIC":[{"def":"A set of verses so disposed that the name forming the subject of the acrostic occurs five times -- the whole set of verses being divided into five different parts from top to bottom.","pos":""}],"PENTAD":[{"def":"Any element, atom, or radical, having a valence of five, or which can be combined with, substituted for, or compared with, five atoms of hydrogen or other monad; as, nitrogen is a pentad in the ammonium compounds.","pos":""}],"PENTADACTYLOID":[{"def":"Having the form of, or a structure modified from, a pentadactyl limb.","pos":""}],"PENTADECANE":[{"def":"A hydrocarbon of the paraffin series, (C15H32) found in petroleum, tar oil, etc.","pos":""}],"PENTADECATOIC":[{"def":"Of, pertaining to, or derived from, pentadecane, or designating an acid related to it.","pos":""}],"PENTADECYLIC":[{"def":"Same as Quindecylic.","pos":""}],"PENTADELPHOUS":[{"def":"Having the stamens arranged in five clusters, those of each cluster having their filaments more or less united, as the flowers of the linden.","pos":""}],"PENTAFID":[{"def":"Divided or cleft into five parts.","pos":""}],"PENTAGLOT":[{"def":"A work in five different tongues.","pos":""}],"PENTAGON":[{"def":"A plane figure having five angles, and, consequently, five sides; any figure having five angles.","pos":""}],"PENTAGONAL":[{"def":"Having five corners or angles.","pos":""}],"PENTAGONALLY":[{"def":"In the form of a pentagon; with five angles.","pos":""}],"PENTAGRAM":[{"def":"A pentacle or a pentalpha.","pos":""}],"PENTAGYNIA":[{"def":"A Linnæan order of plants, having five styles or pistils.","pos":""},{"def":"Of or pertaining to plants of the order Pentagyna; having five styles.","pos":""}],"PENTAHEDRAL":[{"def":"Having five sides; as, a pentahedral figure.","pos":""}],"PENTAHEDRON":[{"def":"A solid figure having five sides.","pos":""}],"PENTAIL":[{"def":"A peculiar insectivore (Ptilocercus Lowii) of Borneo; -- so called from its very long, quill-shaped tail, which is scaly at the base and plumose at the tip.","pos":""}],"PENTALPHA":[{"def":"A five-pointed star, resembling five alphas joined at their bases; -- used as a symbol.","pos":""}],"PENTAMERA":[{"def":"An extensive division of Coleoptera, including those that normally have five-jointed tarsi.","pos":""}],"PENTAMERAN":[{"def":"One of the Pentamera.","pos":""}],"PENTAMEROUS":[{"def":"Divided into, or consisting of, five parts; also, arranged in sets, with five parts in each set, as a flower with five sepals, five petals, five, or twice five, stamens, and five pistils.","pos":""},{"def":"Belonging to the Pentamera.","pos":""}],"PENTAMERUS":[{"def":"A genus of extinct Paleozoic brachiopods, often very abundant in the Upper Silurian.","pos":""}],"PENTAMETER":[{"def":"A verse of five feet.","pos":""}],"PENTAMETHYLENE":[{"def":"A hypothetical hydrocarbon, C5H10, metameric with the amylenes, and the nucleus of a large number of derivatives; -- so named because regarded as composed of five methylene residues.","pos":""}],"PENTANDRIA":[{"def":"A Linnæan class of plants having five separate stamens.","pos":""},{"def":"Of or pertaining to the class Pentadria; having five stamens.","pos":""}],"PENTANE":[{"def":"Any one of the three metameric hydrocarbons, C5H12, of the methane or paraffin series.","pos":""}],"PENTANGULAR":[{"def":"Having five corners or angles.","pos":""}],"PENTAPETALOUS":[{"def":"Having five petals, or flower leaves.","pos":""}],"PENTAPHYLLOUS":[{"def":"Having five leaves or leaflets.","pos":""}],"PENTAPODY":[{"def":"A measure or series consisting of five feet.","pos":""}],"PENTAPTOTE":[{"def":"A noun having five cases.","pos":""}],"PENTAPTYCH":[{"def":"A picture, or combination of pictures, consisting of a centerpiece and double folding doors or wings, as for an altarpiece.","pos":""}],"PENTARCHY":[{"def":"A government in the hands of five persons; five joint rulers.","pos":""}],"PENTASPAST":[{"def":"A purchase with five pulleys.","pos":""}],"PENTASPERMOUS":[{"def":"Containing five seeds.","pos":""}],"PENTASTICH":[{"def":"A composition consisting of five verses.","pos":""}],"PENTASTICHOUS":[{"def":"Having, or arranged in, five vertical ranks, as the leaves of an apple tree or a cherry tree.","pos":""}],"PENTASTOMIDA":[{"def":"Same as Linguatulina.","pos":""}],"PENTASTYLE":[{"def":"Having five columns in front; -- said of a temple or portico in classical architecture.","pos":""},{"def":"A portico having five columns.","pos":""}],"PENTATEUCH":[{"def":"The first five books of the Old Testament, collectively; -- called also the Law of Moses, Book of the Law of Moses, etc.","pos":""}],"PENTATEUCHAL":[{"def":"Of or pertaining to the Pentateuch.","pos":""}],"PENTATHIONIC":[{"def":"Pertaining to, or designating, an acid of sulphur obtained by leading hydrogen sulphide into a solution of sulphur dioxide; -- so called because it contains five atoms of sulphur.","pos":""}],"PENTATHLON":[{"def":"A fivefold athletic performance peculiar to the great national games of the Greeks, including leaping, foot racing, wrestling, throwing the discus, and throwing the spear.","pos":""}],"PENTAVALENT":[{"def":"Having a valence of five; -- said of certain atoms and radicals.","pos":""}],"PENTECONTER":[{"def":"A Grecian vessel with fifty oars.","pos":""}],"PENTECOST":[{"def":"A solemn festival of the Jews; -- so called because celebrated on the fiftieth day (seven weeks) after the second day of the Passover (which fell on the sixteenth of the Jewish month Nisan); -- hence called, also, the Feast of Weeks.","pos":""},{"def":"A festival of the Roman Catholic and other churches in commemoration of the descent of the Holy Spirit on the apostles; which occurred on the day of Pentecost; -- called also Whitsunday.","pos":""}],"PENTECOSTAL":[{"def":"Of or pertaining to Pentecost or to Whitsuntide.","pos":""}],"PENTECOSTALS":[{"def":"Offerings formerly made to the parish priest, or to the mother church, at Pentecost.","pos":""}],"PENTECOSTER":[{"def":"An officer in the Spartan army commanding fifty men.","pos":""}],"PENTECOSTY":[{"def":"A troop of fifty soldiers in the Spartan army; -- called also pentecostys.","pos":""},{"def":"Of or pertaining to Mount Pentelicus, near Athens, famous for its fine white marble quarries; obtained from Mount Pentelicus; as, the Pentelic marble of which the Parthenon is built.","pos":""}],"PENTENE":[{"def":"Same as Amylene.","pos":""}],"PENTHOUSE":[{"def":"A shed or roof sloping from the main wall or building, as over a door or window; a lean-to.","pos":""}],"PENTINE":[{"def":"An unsaturated hydrocarbon, C5H8, of the acetylene series.","pos":""}],"PENTOIC":[{"def":"Pertaining to, or desingating, an acid (called also valeric acid) derived from pentane.","pos":""}],"PENTONE":[{"def":"Same as Valylene.","pos":""},{"def":"One of a class of substances (complex carbohydrates widely distributed in plants, as in fruits, gums, woods, hay, etc.","pos":""}],"PENTOSE":[{"def":"Any of a group of sugars of the formula C5H10O5, as arabinose; -- so called from the five carbon atoms in the molecule.","pos":""}],"PENTOXIDE":[{"def":"An oxide containing five atoms of oxygen in each molecule; as, phosphorus pentoxide, P2O5.","pos":""}],"PENTREMITE":[{"def":"Any species of Pentremites.","pos":""}],"PENTREMITES":[{"def":"A genus of crinoids belonging to the Blastoidea.","pos":""}],"PENTYL":[{"def":"The hypothetical radical, C5H11, of pentane and certain of its derivatives.","pos":""}],"PENTYLIC":[{"def":"Pertaining to, derived from, or containing, pentyl; as, pentylic alcohol PENUCHLE; PINOCLE Pe\"nu*chle, Pin\"o*cle, n.","pos":""},{"def":"A game at cards, played with forty-eight cards, being all the cards above the eight spots in two packs.","pos":""}]}