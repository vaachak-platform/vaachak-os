{"ELECT":[{"def":"Chosen as the object of mercy or divine favor; set apart to eternal life.","pos":""}],"ELECTANT":[{"def":"One who has the power of choosing; an elector.","pos":""}],"ELECTICISM":[{"def":"See Eclecticism.","pos":""}],"ELECTION":[{"def":"Divine choice; predestination of individuals as objects of mercy and salvation; -- one of the \"five points\" of Calvinism.","pos":""},{"def":"The choice, made by a party, of two alternatives, by taking one of which, the chooser is excluded from the other.","pos":""}],"ELECTIONEER":[{"def":"To make interest for a candidate at an election; to use arts for securing the election of a candidate.","pos":""}],"ELECTIONEERER":[{"def":"One who electioneers.","pos":""}],"ELECTIVE":[{"def":"Exerting the power of choice; selecting; as, an elective act.","pos":""},{"def":"Pertaining to, or consisting in, choice, or right of choosing; electoral.","pos":""}],"ELECTIVELY":[{"def":"In an elective manner; by choice.","pos":""}],"ELECTOR":[{"def":"One who elects, or has the right of choice; a person who is entitled to take part in an election, or to give his vote in favor of a candidate for office.","pos":""},{"def":"Hence, specifically, in any country, a person legally qualified to vote.","pos":""}],"ELECTORALITY":[{"def":"The territory or dignity of an elector; electorate.","pos":""}],"ELECTORATE":[{"def":"The territory, jurisdiction, or dignity of an elector, as in the old German empire.","pos":""},{"def":"The whole body of persons in a nation or state who are entitled to vote in an election, or any distinct class or division of them.","pos":""}],"ELECTORSHIP":[{"def":"The office or status of an elector.","pos":""}],"ELECTREPETER":[{"def":"An instrument used to change the direction of electric currents; a commutator.","pos":""}],"ELECTRESS":[{"def":"The wife or widow of an elector in the old German empire.","pos":""}],"ELECTRIC":[{"def":"A nonconductor of electricity, as amber, glass, resin, etc.","pos":""}],"ELECTRICALLY":[{"def":"In the manner of electricity, or by means of it; thrillingly.","pos":""}],"ELECTRICALNESS":[{"def":"The state or quality of being electrical.","pos":""}],"ELECTRICIAN":[{"def":"An investigator of electricity; one versed in the science of electricity.","pos":""}],"ELECTRICITY":[{"def":"The science which unfolds the phenomena and laws of electricity; electrical science.","pos":""}],"ELECTRIFIABLE":[{"def":"Capable of receiving electricity, or of being charged with it.","pos":""}],"ELECTRIFICATION":[{"def":"The act of electrifying, or the state of being charged with electricity.","pos":""}],"ELECTRIFY":[{"def":"To communicate electricity to; to charge with electricity; as, to electrify a jar.","pos":""},{"def":"To cause electricity to pass through; to affect by electricity; to give an electric shock to; as, to electrify a limb, or the body.","pos":""}],"ELECTRINE":[{"def":"Belonging to, or made of, amber.","pos":""},{"def":"Made of electrum, an alloy used by the ancients.","pos":""}],"ELECTRITION":[{"def":"The recognition by an animal body of the electrical condition of external objects.","pos":""}],"ELECTRIZATION":[{"def":"The act of electrizing; electrification.","pos":""}],"ELECTRIZER":[{"def":"One who, or that which, electrizes.","pos":""}],"ELECTRO-":[{"def":"A prefix or combining form signifying pertaining to electricity, produced by electricity, producing or employing electricity, etc.","pos":""}],"ELECTRO-BALLISTIC":[{"def":"Pertaining to electro-ballistics.","pos":""}],"ELECTRO-BALLISTICS":[{"def":"The art or science of measuring the force or velocity of projectiles by means of electricity.","pos":""}],"ELECTRO-BIOLOGIST":[{"def":"One versed in electro-biology.","pos":""}],"ELECTRO-BIOLOGY":[{"def":"That branch of biology which treats of the electrical phenomena of living organisms.","pos":""},{"def":"That phase of mesmerism or animal magnetism, the phenomena of which are supposed to be produced by a form of electricity.","pos":""}],"ELECTRO-BIOSCOPY":[{"def":"A method of determining the presence or absence of life in an animal organism with a current of electricity, by noting the presence or absence of muscular contraction.","pos":""}],"ELECTRO-CAPILLARITY":[{"def":"The occurrence or production of certain capillary effects by the action of an electrical current or charge.","pos":""}],"ELECTRO-CAPILLARY":[{"def":"E*lec`tro-cap\"il*la*ry, a.","pos":""}],"ELECTRO-CHEMICAL":[{"def":"Of or pertaining to electro-chemistry.","pos":""}],"ELECTRO-CHEMISTRY":[{"def":"That branch of science which treats of the relation of electricity to chemical changes.","pos":""}],"ELECTRO-CHRONOGRAPH":[{"def":"An instrument for obtaining an accurate record of the time at which any observed phenomenon occurs, or of its duration.","pos":""}],"ELECTRO-CHRONOGRAPHIC":[{"def":"Belonging to the electro-chronograph, or recorded by the aid of it.","pos":""}],"ELECTRO-DYNAMICS":[{"def":"The phenomena of electricity in motion.","pos":""},{"def":"The branch of science which treats of the properties of electric currents; dynamical electricity.","pos":""}],"ELECTRO-DYNAMOMETER":[{"def":"An instrument for measuring the strength of electro-dynamic currents.","pos":""}],"ELECTRO-ENGRAVING":[{"def":"The art or process of engraving by means of electricity.","pos":""}],"ELECTRO-ETCHING":[{"def":"A mode of etching upon metals by electrolytic action.","pos":""}],"ELECTRO-GILDING":[{"def":"The art or process of gilding copper, iron, etc.","pos":""}],"ELECTRO-GILT":[{"def":"Gilded by means of voltaic electricity.","pos":""}],"ELECTRO-KINETIC":[{"def":"Of or pertaining to electro-kinetics.","pos":""}],"ELECTRO-KINETICS":[{"def":"That branch of electrical science which treats of electricity in motion.","pos":""}],"ELECTRO-MAGNET":[{"def":"A mass, usually of soft iron, but sometimes of some other magnetic metal, as nickel or cobalt, rendered temporarily magnetic by being placed within a coil of wire through which a current of electricity is passing.","pos":""}],"ELECTRO-MAGNETIC":[{"def":"Of, Pertaining to, or produced by, magnetism which is developed by the passage of an electric current.","pos":""}],"ELECTRO-MAGNETISM":[{"def":"The magnetism developed by a current of electricity; the science which treats of the development of magnetism by means of voltaic electricity, and of the properties or actions of the currents evolved.","pos":""}],"ELECTRO-METALLURGY":[{"def":"The act or art precipitating a metal electro-chemical action, by which a coating is deposited, on a prepared surface, as in electroplating and electrotyping; galvanoplasty.","pos":""}],"ELECTRO-MOTION":[{"def":"The motion of electricity or its passage from one metal to another in a voltaic circuit; mechanical action produced by means of electricity.","pos":""}],"ELECTRO-MOTIVE":[{"def":"Producing electro-motion; producing, or tending to produce, electricity or an electric current; causing electrical action or effects.","pos":""}],"ELECTRO-MUSCULAR":[{"def":"Pertaining the reaction (contraction) of the muscles under electricity, or their sensibility to it.","pos":""}],"ELECTRO-NEGATIVE":[{"def":"E*lec`tro-neg\"a*tive, a.","pos":""}],"ELECTRO-PHYSIOLOGICAL":[{"def":"Pertaining to electrical results produced through physiological agencies, or by change of action in a living organism.","pos":""}],"ELECTRO-PHYSIOLOGY":[{"def":"That branch of physiology which treats of electric phenomena produced through physiological agencies.","pos":""}],"ELECTRO-POLAR":[{"def":"Possessing electrical polarity; positively electrified at one end, or on one surface, and negatively at the other; -- said of a conductor.","pos":""}],"ELECTRO-POSITIVE":[{"def":"Of such a nature relatively to some other associated body or bodies, as to tend to the negative pole of a voltaic battery, in electrolysis, while the associated body tends to the positive pole; - - the converse or correlative of electro-negative.","pos":""},{"def":"Hence: Positive; metallic; basic; -- distinguished from negative, nonmetallic, or acid.","pos":""}],"ELECTRO-PUNCTURE":[{"def":"An operation that consists in inserting needless in the part affected, and connecting them with the poles of a galvanic apparatus.","pos":""}],"ELECTRO-STEREOTYPE":[{"def":"Same as Electrotype.","pos":""}],"ELECTRO-TELEGRAPHIC":[{"def":"Pertaining to the electric telegraph, or by means of it.","pos":""}],"ELECTRO-TELEGRAPHY":[{"def":"The art or science of constructing or using the electric telegraph; the transmission of messages by means of the electric telegraph.","pos":""}],"ELECTRO-THERAPEUTICS":[{"def":"The branch of medical science which treats of the applications agent.","pos":""}],"ELECTRO-THERMANCY":[{"def":"That branch of electrical science which treats of the effect of an electric current upon the temperature of a conductor, or a part of a circuit composed of two different metals.","pos":""}],"ELECTRO-TINT":[{"def":"A style of engraving in relief by means of voltaic electricity.","pos":""}],"ELECTRO-VITAL":[{"def":"Derived from, or dependent upon, vital processes; -- said of certain electric currents supposed by some physiologists to circulate in the nerves of animals.","pos":""}],"ELECTRO-VITALISM":[{"def":"The theory that the functions of living organisms are dependent upon electricity or a kindred force.","pos":""}],"ELECTROCUTE":[{"def":"To execute or put to death by electricity.","pos":""}],"ELECTRODE":[{"def":"The path by which electricity is conveyed into or from a solution or other conducting medium; esp.","pos":""},{"def":"Pertaining to the movements or force of electric or galvanic currents; dependent on electric force.","pos":""}],"ELECTROGENESIS":[{"def":"Same as Electrogeny.","pos":""}],"ELECTROGENIC":[{"def":"Of or pertaining to electrogenesis; as, an electrogenic condition.","pos":""}],"ELECTROGENY":[{"def":"A term sometimes applied to the effects (tetanus) produced in the muscles of the limbs, when a current of electricity is passed along the spinal cord or nerves.","pos":""}],"ELECTROGRAPH":[{"def":"A mark, record, or tracing, made by the action of electricity.","pos":""}],"ELECTROGRAPHIC":[{"def":"Of or pertaining to an electrograph or electrography.","pos":""}],"ELECTROGRAPHY":[{"def":"The art or process of making electrographs or using an electrograph.","pos":""}],"ELECTROLIER":[{"def":"A branching frame, often of ornamental design, to support electric illuminating lamps.","pos":""}],"ELECTROLOGY":[{"def":"That branch of physical science which treats of the phenomena of electricity and its properties.","pos":""}],"ELECTROLYSIS":[{"def":"The act or process of chemical decomposition, by the action of electricity; as, the electrolysis of silver or nickel for plating; the electrolysis of water.","pos":""}],"ELECTROLYTE":[{"def":"A compound decomposable, or subjected to decomposition, by an electric current.","pos":""},{"def":"Pertaining to electrolysis; as, electrolytic action.","pos":""}],"ELECTROLYZABLE":[{"def":"Capable of being electrolyzed, or decomposed by electricity.","pos":""}],"ELECTROLYZATION":[{"def":"The act or the process of electrolyzing.","pos":""}],"ELECTROLYZE":[{"def":"To decompose by the direct action of electricity.","pos":""}],"ELECTROMETER":[{"def":"An instrument for measuring the quantity or intensity of electricity; also, sometimes, and less properly, applied to an instrument which indicates the presence of electricity (usually called an electroscope).","pos":""},{"def":"Pertaining to electrometry; made by means of electrometer; as, an electrometrical experiment.","pos":""}],"ELECTROMETRY":[{"def":"The art or process of making electrical measurements.","pos":""}],"ELECTROMOTOR":[{"def":"A mover or exciter of electricity; as apparatus for generating a current of electricity.","pos":""},{"def":"An apparatus or machine for producing motion and mechanical effects by the action of electricity; an electro-magnetic engine.","pos":""}],"ELECTRON":[{"def":"Amber; also, the alloy of gold and silver, called electrum.","pos":""}],"ELECTRONIC":[{"def":"Of or pertaining to an electron or electrons.","pos":""}],"ELECTROPATHY":[{"def":"The treatment of disease by electricity.","pos":""}],"ELECTROPHONE":[{"def":"An instrument for producing sound by means of electric currents.","pos":""}],"ELECTROPHORUS":[{"def":"An instrument for exciting electricity, and repeating the charge indefinitely by induction, consisting of a flat cake of resin, shelllac, or ebonite, upon which is placed a plate of metal.","pos":""}],"ELECTROPLATE":[{"def":"To plate or cover with a coating of metal, usually silver, nickel, or gold, by means of electrolysis.","pos":""}],"ELECTROPLATER":[{"def":"One who electroplates.","pos":""}],"ELECTROPLATING":[{"def":"The art or process of depositing a coating (commonly) of silver, gold, or nickel on an inferior metal, by means of electricity.","pos":""},{"def":"An exciting and depolarizing acid solution used in certain cells or batteries, as the Grenet battery.","pos":""}],"ELECTROSCOPE":[{"def":"An instrument for detecting the presence of electricity, or changes in the electric state of bodies, or the species of electricity present, as by means of pith balls, and the like.","pos":""}],"ELECTROSCOPIC":[{"def":"Relating to, or made by means of, the electroscope.","pos":""}],"ELECTROSTATIC":[{"def":"Pertaining to electrostatics.","pos":""}],"ELECTROSTATICS":[{"def":"That branch of science which treats of statical electricity or electric force in a state of rest.","pos":""}],"ELECTROTONIC":[{"def":"Of or pertaining to electrical tension; -- said of a supposed peculiar condition of a conducting circuit during its exposure to the action of another conducting circuit traversed by a uniform electric current when both circuits remain stationary.","pos":""},{"def":"Relating to electrotonus; as, the electrotonic condition of a nerve.","pos":""}],"ELECTROTONIZE":[{"def":"To cause or produce electrotonus.","pos":""}],"ELECTROTONUS":[{"def":"The modified condition of a nerve, when a constant current of electricity passes through any part of it.","pos":""}],"ELECTROTYPE":[{"def":"A facsimile plate made by electrotypy for use in printing; also, an impression or print from such plate.","pos":""}],"ELECTROTYPER":[{"def":"One who electrotypes.","pos":""}]}