{"ZA":[{"def":"An old solfeggio name for B flat; the seventh harmonic, as heard in the or æolian string; -- so called by Tartini.","pos":""}],"ZACHUN":[{"def":"An oil pressed by the Arabs from the fruit of a small thorny tree (Balanites Ægyptiaca), and sold to piligrims for a healing ointment.","pos":""}],"ZAFFER":[{"def":"A pigment obtained, usually by roasting cobalt glance with sand or quartz, as a dark earthy powder.","pos":""}],"ZAIM":[{"def":"A Turkish chief who supports a mounted militia bearing the same name.","pos":""}],"ZAIMET":[{"def":"A district from which a Zaim draws his revenue.","pos":""}],"ZAIN":[{"def":"A horse of a dark color, neither gray nor white, and having no spots.","pos":""}],"ZALAMBDODONT":[{"def":"Of or pertaining to a tribe (Zalambdodonta) of Insectivora in which the molar teeth have but one V-shaped ridge.","pos":""}],"ZAMANG":[{"def":"An immense leguminous tree (Pithecolobium Saman) of Venezuela.","pos":""}],"ZAMBO":[{"def":"The child of a mulatto and a negro; also, the child of an Indian and a negro; colloquially or humorously, a negro; a sambo.","pos":""}],"ZAMIA":[{"def":"A genus of cycadaceous plants, having the appearance of low palms, but with exogenous wood.","pos":""}],"ZAMINDAR":[{"def":"A landowner; also, a collector of land revenue; now, usually, a kind of feudatory recognized as an actual proprietor so long as he pays to the government a certain fixed revenue.","pos":""},{"def":"The jurisdiction of a zamindar; the land possessed by a zamindar.","pos":""}],"ZAMITE":[{"def":"A fossil cycad of the genus Zamia.","pos":""}],"ZAMOUSE":[{"def":"A West African buffalo (Bubalus brachyceros) having short horns depressed at the base, and large ears fringed internally with three rows of long hairs.","pos":""}],"ZAMPOGNA":[{"def":"A sort of bagpipe formerly in use among Italian peasants.","pos":""}],"ZANDER":[{"def":"A European pike perch (Stizostedion lucioperca) allied to the wall-eye; -- called also sandari, sander, sannat, schill, and zant.","pos":""}],"ZANTE CURRANT":[{"def":"A kind of seedless grape or raisin; -- so called from Zante, one of the Ionian Islands.","pos":""}],"ZANTEWOOD":[{"def":"See Fustet, and the Note under Fustic.","pos":""}],"ZANTIOT":[{"def":"A native or inhabitant of Zante, one of the Ionian Islands.","pos":""}],"ZANY":[{"def":"A merry-andrew; a buffoon.","pos":""}],"ZANYISM":[{"def":"State or character of a zany; buffoonery.","pos":""}],"ZAPAS":[{"def":"See Army organization, above.","pos":""}],"ZAPATERA":[{"def":"A cured olive which has spoiled or is on the verge of decomposition; loosely, an olive defective because of bruises, wormholes, or the like.","pos":""}],"ZAPHRENTIS":[{"def":"An extinct genus of cyathophylloid corals common in the Paleozoic formations.","pos":""}],"ZAPTIAH":[{"def":"A Turkish policeman.","pos":""},{"def":"Of or pertaining to Zarathustra, or Zoroaster; Zoroastrian.","pos":""}],"ZARATHUSTRISM":[{"def":"See Zoroastrianism.","pos":""}],"ZARATITE":[{"def":"A hydrous carbonate of nickel occurring as an emerald-green incrustation on chromite; -- called also emerald nickel.","pos":""}],"ZAREBA":[{"def":"An improvised stockade; especially, one made of thorn bushes, etc.","pos":""}],"ZARF":[{"def":"A metallic cuplike stand used for holding a finjan.","pos":""}],"ZARNICH":[{"def":"Native sulphide of arsenic, including sandarach, or realgar, and orpiment.","pos":""},{"def":"A European bream (Abramis vimba).","pos":""}],"ZASTRUGI":[{"def":"Grooves or furrows formed in snow by the action of the wind, and running parallel with the direction of the wind.","pos":""}],"ZATI":[{"def":"A species of macaque (Macacus pileatus) native of India and Ceylon.","pos":""}],"ZAUSCHNERIA":[{"def":"A genus of flowering plants.","pos":""}],"ZAX":[{"def":"A tool for trimming and puncturing roofing states.","pos":""}],"ZAYAT":[{"def":"A public shed, or portico, for travelers, worshipers, etc.","pos":""}]}