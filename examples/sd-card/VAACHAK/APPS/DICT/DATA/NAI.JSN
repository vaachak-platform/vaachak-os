{"NAIAD":[{"def":"A water nymph; one of the lower female divinities, fabled to preside over some body of fresh water, as a lake, river, brook, or fountain.","pos":""},{"def":"Any species of a tribe (Naiades) of freshwater bivalves, including Unio, Anodonta, and numerous allied genera; a river mussel.","pos":""}],"NAID":[{"def":"Any one of numerous species of small, fresh-water, chætopod annelids of the tribe Naidina.","pos":""}],"NAIF":[{"def":"Having a true natural luster without being cut; -- applied by jewelers to a precious stone.","pos":""},{"def":"Naïve; as, a naïf remark.","pos":""}],"NAIK":[{"def":"A chief; a leader; a Sepoy corporal.","pos":""}],"NAIL":[{"def":"the horny scale of plate of epidermis at the end of the fingers and toes of man and many apes.","pos":""}],"NAIL-HEADED":[{"def":"Having a head like that of a nail; formed so as to resemble the head of a nail.","pos":""}],"NAILBRUSH":[{"def":"A brush for cleaning the nails.","pos":""}],"NAILER":[{"def":"One whose occupation is to make nails; a nail maker.","pos":""},{"def":"One who fastens with, or drives, nails.","pos":""}],"NAILERESS":[{"def":"A women who makes nailes.","pos":""}],"NAILERY":[{"def":"A manufactory where nails are made.","pos":""}],"NAILLESS":[{"def":"Without nails; having no nails.","pos":""}],"NAINSOOK":[{"def":"A thick sort of jaconet muslin, plain or striped, formerly made in India.","pos":""}],"NAISSANT":[{"def":"Same as Jessant.","pos":""}],"NAIVE":[{"def":"Having native or unaffected simplicity; ingenuous; artless; frank; as, naïve manners; a naïve person; naïve and unsophisticated remarks.","pos":""}],"NAIVELY":[{"def":"In a naïve manner.","pos":""}],"NAIVETE":[{"def":"Native simplicity; unaffected plainness or ingenuousness; artlessness.","pos":""}],"NAIVETY":[{"def":"Na\"ïve`ty Defn: , n.","pos":""}]}