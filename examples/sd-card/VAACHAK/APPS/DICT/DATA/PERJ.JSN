{"PERJURE":[{"def":"To cause to violate an oath or a vow; to cause to make oath knowingly to what is untrue; to make guilty of perjury; to forswear; to corrupt; -- often used reflexively; as, he perjured himself.","pos":""},{"def":"To make a false oath to; to deceive by oaths and protestations.","pos":""}],"PERJURED":[{"def":"Guilty of perjury; having sworn falsely; forsworn.","pos":""}],"PERJURER":[{"def":"One who is guilty of perjury; one who perjures or forswears, in any sense.","pos":""},{"def":"Guilty of perjury; containing perjury.","pos":""}],"PERJURY":[{"def":"At common law, a willfully false statement in a fact material to the issue, made by a witness under oath in a competent judicial proceeding.","pos":""}]}