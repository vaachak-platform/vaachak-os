{"RAJAH":[{"def":"A native prince or king; also, a landholder or person of importance in the agricultural districts.","pos":""}],"RAJAHSHIP":[{"def":"The office or dignity of a rajah.","pos":""},{"def":"A Hindoo of the second, or royal and military, caste; a Kshatriya; especially, an inhabitant of the country of Rajpootana, in northern central India.","pos":""}]}