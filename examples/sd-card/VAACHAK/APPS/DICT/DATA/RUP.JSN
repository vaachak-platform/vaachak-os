{"RUPEE":[{"def":"A silver coin, and money of account, in the East Indies.","pos":""}],"RUPERT'S DROP":[{"def":"A kind of glass drop with a long tail, made by dropping melted glass into water.","pos":""}],"RUPIA":[{"def":"An eruption upon the skin, consisting of vesicles with inflamed base and filled with serous, purulent, or bloody fluid, which dries up, forming a blackish crust.","pos":""}],"RUPIAL":[{"def":"Of or pertaining to rupia.","pos":""}],"RUPICOLA":[{"def":"A genus of beautiful South American passerine birds, including the cock of the rock.","pos":""}],"RUPICOLINE":[{"def":"Rock-inhabiting.","pos":""}],"RUPTION":[{"def":"A breaking or bursting open; breach; rupture.","pos":""}],"RUPTUARY":[{"def":"One not of noble blood; a plebeian; a roturier.","pos":""}],"RUPTURE":[{"def":"The act of breaking apart, or separating; the state of being asunder; as, the rupture of the skin; the rupture of a vessel or fiber; the rupture of a lutestring.","pos":""},{"def":"Breach of peace or concord between individuals; open hostility or war between nations; interruption of friendly relations; as, the parties came to a rupture.","pos":""}],"RUPTURED":[{"def":"Having a rupture, or hernia.","pos":""}]}