{"ISIAC":[{"def":"Pertaining to the goddess Isis; as, Isiac mysteries.","pos":""}],"ISIDORIAN":[{"def":"Pertaining, or ascribed, to Isidore; as, the Isidorian decretals, a spurious collection of decretals published in the ninth century.","pos":""}],"ISINGLASS":[{"def":"A popular name for mica, especially when in thin sheets.","pos":""}],"ISIS":[{"def":"The principal goddess worshiped by the Egyptians.","pos":""},{"def":"Any coral of the genus Isis, or family Isidæ, composed of joints of white, stony coral, alternating with flexible, horny joints.","pos":""}]}