{"AROINT":[{"def":"Stand off, or begone.","pos":""}],"AROLLA":[{"def":"The stone pine (Pinus Cembra).","pos":""}],"AROMA":[{"def":"Pertaining to, or containing, aroma; fragrant; spicy; strong- scented; odoriferous; as, aromatic balsam.","pos":""}],"AROMATIC":[{"def":"A plant, drug, or medicine, characterized by a fragrant smell, and usually by a warm, pungent taste, as ginger, cinnamon spices.","pos":""}],"AROMATIZATION":[{"def":"The act of impregnating or secting with aroma.","pos":""}],"AROMATIZE":[{"def":"To impregnate with aroma; to render aromatic; to give a spicy scent or taste to; to perfume.","pos":""}],"AROMATIZER":[{"def":"One who, or that which, aromatizes or renders aromatic.","pos":""}],"AROPH":[{"def":"A barbarous word used by the old chemists to designate various medical remedies.","pos":""}],"AROSE":[{"def":"The past or preterit tense of Arise.","pos":""}],"AROUND":[{"def":"In a circle; circularly; on every side; round.","pos":""},{"def":"In a circuit; here and there within the surrounding space; all about; as, to travel around from town to town.","pos":""}],"AROUSAL":[{"def":"The act of arousing, or the state of being aroused.","pos":""}],"AROUSE":[{"def":"To excite to action from a state of rest; to stir, or put in motion or exertion; to rouse; to excite; as, to arouse one from sleep; to arouse the dormant faculties.","pos":""}],"AROW":[{"def":"In a row, line, or rank; successively; in order.","pos":""}]}