{"CORK":[{"def":"The outer layer of the bark of the cork tree (Quercus Suber), of which stoppers for bottles and casks are made.","pos":""},{"def":"A stopper for a bottle or cask, cut out of cork.","pos":""}],"CORK FOSSIL":[{"def":"A variety of amianthus which is very light, like cork.","pos":""}],"CORKAGE":[{"def":"The charge made by innkeepers for drawing the cork and taking care of bottles of wine bought elsewhere by a guest.","pos":""}],"CORKED":[{"def":"having acquired an unpleasant taste from the cork; as, a bottle of wine is corked.","pos":""}],"CORKINESS":[{"def":"The quality of being corky.","pos":""}],"CORKING PIN":[{"def":"A pin of a large size, formerly used attaching a woman's headdress to a cork mold.","pos":""}],"CORKSCREW":[{"def":"An instrument with a screw or a steel spiral for drawing corks from bottles.","pos":""}],"CORKWING":[{"def":"A fish; the goldsinny.","pos":""}],"CORKWOOD":[{"def":"The tree producing the aligator apple.","pos":""}],"CORKY":[{"def":"Consisting of, or like, cork; dry shriveled up.","pos":""},{"def":"Tasting of cork.","pos":""}]}