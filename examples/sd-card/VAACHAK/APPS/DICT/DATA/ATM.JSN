{"ATMIATRY":[{"def":"Treatment of disease by vapors or gases, as by inhalation.","pos":""}],"ATMIDOMETER":[{"def":"An instrument for measuring the evaporation from water, ice, or snow.","pos":""}],"ATMO":[{"def":"The standard atmospheric pressure used in certain physical measurements calculations; conventionally, that pressure under which the barometer stands at 760 millimeters, at a temperature of 0º Centigrade, at the level of the sea, and in the latitude of Paris.","pos":""},{"def":"Of or pertaining to atmology.","pos":""}],"ATMOLOGIST":[{"def":"One who is versed in atmology.","pos":""}],"ATMOLOGY":[{"def":"That branch of science which treats of the laws and phenomena of aqueous vapor.","pos":""}],"ATMOLYSIS":[{"def":"The act or process of separating mingled gases of unequal diffusibility by transmission through porous substances.","pos":""}],"ATMOLYZATION":[{"def":"Separation by atmolysis.","pos":""}],"ATMOLYZE":[{"def":"To subject to atmolysis; to separate by atmolysis.","pos":""}],"ATMOLYZER":[{"def":"An apparatus for effecting atmolysis.","pos":""}],"ATMOMETER":[{"def":"An instrument for measuring the rate of evaporation from a moist surface; an evaporometer.","pos":""}],"ATMOSPHERE":[{"def":"A supposed medium around various bodies; as, electrical atmosphere, a medium formerly supposed to surround electrical bodies.","pos":""},{"def":"The pressure or weight of the air at the sea level, on a unit of surface, or about 14.","pos":""}],"ATMOSPHERICALLY":[{"def":"In relation to the atmosphere.","pos":""}],"ATMOSPHEROLOGY":[{"def":"The science or a treatise on the atmosphere.","pos":""}]}