{"EST":[{"def":"A suffix used to form the superlative of adjectives and adverbs; as, smoothest; earl(y)iest.","pos":""}],"ESTABLISH":[{"def":"To make stable or firm; to fix immovably or firmly; to set (a thing) in a place and make it stable there; to settle; to confirm.","pos":""},{"def":"To appoint or constitute for permanence, as officers, laws, regulations, etc.","pos":""}],"ESTABLISHED SUIT":[{"def":"A plain suit in which a player (or side) could, except for trumping, take tricks with all his remaining cards.","pos":""}],"ESTABLISHER":[{"def":"One who establishes.","pos":""}],"ESTABLISHMENT":[{"def":"The act of establishing; a ratifying or ordaining; settlement; confirmation.","pos":""},{"def":"The state of being established, founded, and the like; fixed state.","pos":""}],"ESTABLISHMENTARIAN":[{"def":"One who regards the Church primarily as an establishment formed by the State, and overlooks its intrinsic spiritual character.","pos":""}],"ESTACADE":[{"def":"A dike of piles in the sea, a river, etc.","pos":""},{"def":"A courier who conveys messages to another courier; a military courier sent from one part of an army to another.","pos":""}],"ESTAMINET":[{"def":"A café, or room in a café, in which smoking is allowed.","pos":""}],"ESTANCIA":[{"def":"A grazing; a country house.","pos":""}],"ESTATE":[{"def":"The great classes or orders of a community or state (as the clergy, the nobility, and the commonalty of England) or their representatives who administer the government; as, the estates of the realm (England), which are (1) the lords spiritual, (2) the lords temporal, (3) the commons.","pos":""},{"def":"The degree, quality, nature, and extent of one's interest in, or ownership of, lands, tenements, etc.","pos":""}],"ESTEEM":[{"def":"To set a value on; to appreciate the worth of; to estimate; to value; to reckon.","pos":""},{"def":"To set a high value on; to prize; to regard with reverence, respect, or friendship.","pos":""}],"ESTEEMABLE":[{"def":"Worthy of esteem; estimable.","pos":""}],"ESTEEMER":[{"def":"One who esteems; one who sets a high value on any thing.","pos":""}],"ESTER":[{"def":"An ethereal salt, or compound ether, consisting of an organic radical united with the residue of any oxygen acid, organic or inorganic; thus the natural fats are esters of glycerin and the fatty acids, oleic, etc.","pos":""}],"ESTHESIOMETER":[{"def":"Same as Æsthesiometer.","pos":""},{"def":"Same as Æsthete, Æsthetic, Æsthetical, Æsthetics, etc.","pos":""}],"ESTIMABLE":[{"def":"Capable of being estimated or valued; as, estimable damage.","pos":""},{"def":"Valuable; worth a great price.","pos":""}],"ESTIMABLENESS":[{"def":"The quality of deserving esteem or regard.","pos":""}],"ESTIMABLY":[{"def":"In an estimable manner.","pos":""}],"ESTIMATE":[{"def":"To judge and form an opinion of the value of, from imperfect data, -- either the extrinsic (money), or intrinsic (moral), value; to fix the worth of roughly or in a general way; as, to estimate the value of goods or land; to estimate the worth or talents of a person.","pos":""},{"def":"To from an opinion of, as to amount,, number, etc.","pos":""}],"ESTIMATION":[{"def":"The act of estimating.","pos":""},{"def":"An opinion or judgment of the worth, extent, or quantity of anything, formed without using precise data; valuation; as, estimations of distance, magnitude, amount, or moral qualities.","pos":""}],"ESTIMATIVE":[{"def":"Inclined, or able, to estimate; serving for, or capable of being used in, estimating.","pos":""},{"def":"Pertaining to an estimate.","pos":""}],"ESTIMATOR":[{"def":"One who estimates or values; a valuer.","pos":""},{"def":"Same as Æstival, Æstivate, etc.","pos":""}],"ESTOILE":[{"def":"A six-pointed star whose rays are wavy, instead of straight like those of a mullet.","pos":""}],"ESTOP":[{"def":"To impede or bar by estoppel.","pos":""}],"ESTOVERS":[{"def":"Necessaries or supples; an allowance to a person out of an estate or other thing for support; as of wood to a tenant for life, etc.","pos":""}],"ESTRADE":[{"def":"A portion of the floor of a room raised above the general level, as a place for a bed or a throne; a platform; a dais.","pos":""}],"ESTRAMACON":[{"def":"A straight, heavy sword with two edges, used in the 16th and 17th centuries.","pos":""},{"def":"A blow with edge of a sword.","pos":""}],"ESTRANGE":[{"def":"To withdraw; to withhold; hence, reflexively, to keep at a distance; to cease to be familiar and friendly with.","pos":""},{"def":"To divert from its original use or purpose, or from its former possessor; to alienate.","pos":""}],"ESTRANGEDNESS":[{"def":"State of being estranged; estrangement.","pos":""}],"ESTRANGEMENT":[{"def":"The act of estranging, or the state of being estranged; alienation.","pos":""}],"ESTRANGER":[{"def":"One who estranges.","pos":""}],"ESTRAPADE":[{"def":"The action of a horse, when, to get rid of his rider, he rears, plunges, and kicks furiously.","pos":""}],"ESTRAY":[{"def":"Any valuable animal, not wild, found wandering from its owner; a stray.","pos":""}],"ESTRE":[{"def":"The inward part of a building; the interior.","pos":""}],"ESTREAT":[{"def":"A true copy, duplicate, or extract of an original writing or record, esp.","pos":""}],"ESTREPE":[{"def":"To strip or lay bare, as land of wood, houses, etc.","pos":""}],"ESTREPEMENT":[{"def":"A destructive kind of waste, committed by a tenant for life, in lands, woods, or houses.","pos":""}],"ESTRICH":[{"def":"The down of the ostrich.","pos":""}],"ESTUARINE":[{"def":"Pertaining to an estuary; estuary.","pos":""}],"ESTUARY":[{"def":"A place where water boils up; a spring that wells forth.","pos":""},{"def":"A passage, as the mouth of a river or lake, where the tide meets the current; an arm of the sea; a frith.","pos":""}],"ESTUATE":[{"def":"To boil up; to swell and rage; to be agitated.","pos":""}],"ESTUATION":[{"def":"The act of estuating; commotion, as of a fluid; agitation.","pos":""}],"ESTUFA":[{"def":"An assembly room in dwelling of the Pueblo Indians.","pos":""}]}