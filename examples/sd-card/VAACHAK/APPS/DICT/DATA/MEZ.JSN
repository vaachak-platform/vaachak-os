{"MEZEREON":[{"def":"A small European shrub (Daphne Mezereum), whose acrid bark is used in medicine.","pos":""}],"MEZUZOTH":[{"def":"A piece of parchment bearing the Decalogue and attached to the doorpost; -- in use among orthodox Hebrews.","pos":""}],"MEZZA MAJOLICA":[{"def":"Italian pottery of the epoch and general character of majolica, but less brilliantly decorated, esp.","pos":""}],"MEZZA VOCE":[{"def":"With a medium fullness of sound.","pos":""}],"MEZZO":[{"def":"Mean; not extreme.","pos":""}],"MEZZO-SOPRANO":[{"def":"Having a medium compass between the soprano and contralto; -- said of the voice of a female singer.","pos":""}],"MEZZOTINT":[{"def":"A manner of engraving on copper or steel by drawing upon a surface previously roughened, and then removing the roughness in places by scraping, burnishing, etc.","pos":""}],"MEZZOTINTER":[{"def":"One who engraves in mezzotint.","pos":""}],"MEZZOTINTO":[{"def":"To engrave in mezzotint; to represent by mezzotint.","pos":""}]}