{"VENAL":[{"def":"Of or pertaining to veins; venous; as, venal blood.","pos":""}],"VENALITY":[{"def":"The quality or state of being venal, or purchasable; mercenariness; prostitution of talents, offices, or services, for money or reward; as, the venality of a corrupt court; the venality of an official.","pos":""}],"VENALLY":[{"def":"In a venal manner.","pos":""}],"VENANTES":[{"def":"The hunting spiders, which run after, or leap upon, their prey.","pos":""}],"VENARY":[{"def":"Of or, pertaining to hunting.","pos":""},{"def":"Of or pertaining to hunting; used in hunting.","pos":""}],"VENATION":[{"def":"The arrangement or system of veins, as in the wing of an insect, or in the leaves of a plant.","pos":""}],"VENATORIAL":[{"def":"Or or pertaining to hunting; venatic.","pos":""}],"VEND":[{"def":"To transfer to another person for a pecuniary equivalent; to make an object of trade; to dispose of by sale; to sell; as, to vend goods; to vend vegetables.","pos":""}],"VENDACE":[{"def":"A European lake whitefish (Coregonus Willughbii, or C.","pos":""}],"VENDEE":[{"def":"The person to whom a thing is vended, or sold; -- the correlative of vendor.","pos":""}],"VENDEMIAIRE":[{"def":"The first month of the French republican calendar, dating from September 22, 1792.","pos":""}],"VENDER":[{"def":"One who vends; one who transfers the exclusive right of possessing a thing, either his own, or that of another as his agent, for a price or pecuniary equivalent; a seller; a vendor.","pos":""}],"VENDETTA":[{"def":"A blood feud; private revenge for the murder of a kinsman.","pos":""}],"VENDIBILITY":[{"def":"The quality or state of being vendible, or salable.","pos":""}],"VENDIBLE":[{"def":"Capable of being vended, or sold; that may be sold; salable.","pos":""}],"VENDITATION":[{"def":"The act of setting forth ostentatiously; a boastful display.","pos":""}],"VENDITION":[{"def":"The act of vending, or selling; sale.","pos":""}],"VENDOR":[{"def":"A vender; a seller; the correlative of vendee.","pos":""}],"VENDOR'S LIEN":[{"def":"An implied lien (that is, one not created by mortgage or other express agreement) given in equity to a vendor of lands for the unpaid purchase money.","pos":""}],"VENDUE":[{"def":"A public sale of anything, by outcry, to the highest bidder; an auction.","pos":""}],"VENEER":[{"def":"To overlay or plate with a thin layer of wood or other material for outer finish or decoration; as, to veneer a piece of furniture with mahogany.","pos":""}],"VENEERING":[{"def":"The act or art of one who veneers.","pos":""},{"def":"Thin wood or other material used as a veneer.","pos":""}],"VENEFICE":[{"def":"The act or practice of poisoning.","pos":""},{"def":"Acting by poison; used in poisoning or in sorcery.","pos":""}],"VENENATE":[{"def":"To poison; to infect with poison.","pos":""}],"VENENATION":[{"def":"The act of poisoning.","pos":""}],"VENENE":[{"def":"Poisonous; venomous.","pos":""}],"VENERABILITY":[{"def":"The quality or state of being venerable; venerableness.","pos":""}],"VENERABLE":[{"def":"Capable of being venerated; worthy of veneration or reverence; deserving of honor and respect; -- generally implying an advanced age; as, a venerable magistrate; a venerable parent.","pos":""},{"def":"Rendered sacred by religious or other associations; that should be regarded with awe and treated with reverence; as, the venerable walls of a temple or a church.","pos":""}],"VENERACEA":[{"def":"An extensive tribe of bivalve mollusks of which the genus Venus is the type.","pos":""}],"VENERATE":[{"def":"To regard with reverential respect; to honor with mingled respect and awe; to reverence; to revere; as, we venerate parents and elders.","pos":""}],"VENERATION":[{"def":"We find a secret awe and veneration for one who moves about us in regular and illustrious course of virtue.","pos":""}],"VENERATOR":[{"def":"One who venerates.","pos":""}],"VENEREAL":[{"def":"Of or pertaining to venery, or sexual love; relating to sexual intercourse.","pos":""},{"def":"Adapted to excite venereal desire; aphrodisiac.","pos":""}],"VENEREAN":[{"def":"Devoted to the offices of Venus, or love; venereal.","pos":""}],"VENEREOUS":[{"def":"Venereal; exciting lust; aphrodisiac.","pos":""},{"def":"Lustful; lascivious; libidinous.","pos":""}],"VENERY":[{"def":"Sexual love; sexual intercourse; coition.","pos":""}],"VENESECTION":[{"def":"The act or operation of opening a vein for letting blood; bloodletting; phlebotomy.","pos":""}],"VENETIAN":[{"def":"Of or pertaining to Venice in Italy.","pos":""}],"VENEW":[{"def":"A bout, or turn, as at fencing; a thrust; a hit; a veney.","pos":""}],"VENEY":[{"def":"A bout; a thrust; a venew.","pos":""}],"VENGE":[{"def":"To avenge; to punish; to revenge.","pos":""}],"VENGEABLE":[{"def":"Revengeful; deserving revenge.","pos":""}],"VENGEANCE":[{"def":"Punishment inflicted in return for an injury or an offense; retribution; -- often, in a bad sense, passionate or unrestrained revenge.","pos":""}],"VENGEANCELY":[{"def":"Extremely; excessively.","pos":""}],"VENGEFUL":[{"def":"Vindictive; retributive; revengeful.","pos":""}],"VENGEMENT":[{"def":"Avengement; penal retribution; vengeance.","pos":""}],"VENIABLE":[{"def":"Venial; pardonable.","pos":""}],"VENIAL":[{"def":"Capable of being forgiven; not heinous; excusable; pardonable; as, a venial fault or transgression.","pos":""},{"def":"Allowed; permitted.","pos":""}],"VENIALITY":[{"def":"The quality or state of being venial; venialness.","pos":""}],"VENIN":[{"def":"A toxic substance contained in the venom of poisonous snakes; also, a (supposedly identical) toxic substance obtained by the cleavage of an albumose.","pos":""}],"VENISON":[{"def":"Beasts of the chase.","pos":""},{"def":"Formerly, the flesh of any of the edible beasts of the chase, also of game birds; now, the flesh of animals of the deer kind exclusively.","pos":""}],"VENITE":[{"def":"The 95th Psalm, which is said or sung regularly in the public worship of many churches.","pos":""}],"VENOM":[{"def":"Matter fatal or injurious to life; poison; particularly, the poisonous, the poisonous matter which certain animals, such as serpents, scorpions, bees, etc.","pos":""},{"def":"Spite; malice; malignity; evil quality.","pos":""}],"VENOMOUS":[{"def":"Having a poison gland or glands for the secretion of venom, as certain serpents and insects.","pos":""}],"VENOSE":[{"def":"Having numerous or conspicuous veins; veiny; as, a venose frond.","pos":""}],"VENOSITY":[{"def":"A condition in which the circulation is retarded, and the entire mass of blood is less oxygenated than it normally is.","pos":""}],"VENOUS":[{"def":"Of or pertaining to a vein or veins; as, the venous circulation of the blood.","pos":""}],"VENT":[{"def":"Sale; opportunity to sell; market.","pos":""}],"VENTAGE":[{"def":"A small hole, as the stop in a flute; a vent.","pos":""}],"VENTAIL":[{"def":"That part of a helmet which is intended for the admission of air, -- sometimes in the visor.","pos":""}],"VENTER":[{"def":"One who vents; one who utters, reports, or publishes.","pos":""}],"VENTHOLE":[{"def":"A touchhole; a vent.","pos":""}],"VENTIDUCT":[{"def":"A passage for wind or air; a passage or pipe for ventilating apartments.","pos":""}],"VENTILATE":[{"def":"To open and expose to the free passage of air; to supply with fresh air, and remove impure air from; to air; as, to ventilate a room; to ventilate a cellar; to ventilate a mine.","pos":""},{"def":"To provide with a vent, or escape, for air, gas, etc.","pos":""}],"VENTILATION":[{"def":"The act of ventilating, or the state of being ventilated; the art or process of replacing foul air by that which is pure, in any inclosed place, as a house, a church, a mine, etc.","pos":""},{"def":"The act of refrigerating, or cooling; refrigeration; as, ventilation of the blood.","pos":""}],"VENTILATIVE":[{"def":"Of or pertaining to ventilation; adapted to secure ventilation; ventilating; as, ventilative apparatus.","pos":""}],"VENTILATOR":[{"def":"A contrivance for effecting ventilation; especially, a contrivance or machine for drawing off or expelling foul or stagnant air from any place or apartment, or for introducing that which is fresh and pure.","pos":""}],"VENTOSE":[{"def":"Windy; flatulent.","pos":""}],"VENTOSITY":[{"def":"Quality or state of being ventose; windiness; hence, vainglory; pride.","pos":""}],"VENTOUSE":[{"def":"A cupping glass.","pos":""}],"VENTRAD":[{"def":"Toward the ventral side; on the ventral side; ventrally; -- opposed to dorsad.","pos":""}],"VENTRAL":[{"def":"Of, pertaining to, or situated near, the belly, or ventral side, of an animal or of one of its parts; hemal; abdominal; as, the ventral fin of a fish; the ventral root of a spinal nerve; -- opposed to Ant: dorsal.","pos":""}],"VENTRICLE":[{"def":"A cavity, or one of the cavities, of an organ, as of the larynx or the brain; specifically, the posterior chamber, or one of the two posterior chambers, of the heart, which receives the blood from the auricle and forces it out from the heart.","pos":""},{"def":"Swelling out on one side or unequally; bellied; ventricular; as, a ventricose corolla.","pos":""}],"VENTRICULAR":[{"def":"Of or pertaining to a ventricle; bellied.","pos":""}],"VENTRICULITE":[{"def":"Any one of numerous species of siliceous fossil sponges belonging to Ventriculites and allied genera, characteristic of the Cretaceous period.","pos":""}],"VENTRICULOUS":[{"def":"Somewhat distended in the middle; ventricular.","pos":""}],"VENTRILOCUTION":[{"def":"Ven`tri*lo*cu\"tion, n.","pos":""}],"VENTRILOQUISM":[{"def":"The act, art, or practice of speaking in such a manner that the voice appears to come, not from the person speaking, but from some other source, as from the opposite side of the room, from the cellar, etc.","pos":""}],"VENTRILOQUIST":[{"def":"One who practices, or is skilled in, ventriloquism.","pos":""}],"VENTRILOQUIZE":[{"def":"To practice ventriloquism; to speak like a ventriloquist.","pos":""}],"VENTRILOQUOUS":[{"def":"Of or pertaining to a ventriloquist or ventriloquism.","pos":""}],"VENTRILOQUY":[{"def":"Same as Ventriloquism.","pos":""}],"VENTRO-":[{"def":"A combining form used in anatomy to indicate connection with, or relation to, the abdomen; also, connection with, relation to, or direction toward, the ventral side; as, ventrolateral; ventro- inguinal.","pos":""}],"VENTRO-INGUINAL":[{"def":"Pertaining both to the abdomen and groin, or to the abdomen and inguinal canal; as, ventro-inguinal hernia.","pos":""}],"VENTURE":[{"def":"An undertaking of chance or danger; the risking of something upon an event which can not be foreseen with certainty; a hazard; a risk; a speculation.","pos":""},{"def":"An event that is not, or can not be, foreseen; an accident; chance; hap; contingency; luck.","pos":""}],"VENTURER":[{"def":"One who ventures, or puts to hazard; an adventurer.","pos":""},{"def":"A strumpet; a prostitute.","pos":""}],"VENTURESOME":[{"def":"Inclined to venture; not loth to run risk or danger; venturous; bold; daring; adventurous; as, a venturesome boy or act.","pos":""}],"VENTURINE":[{"def":"Gold powder for covering varnished surfaces.","pos":""}],"VENTUROUS":[{"def":"Daring; bold; hardy; fearless; venturesome; adveturous; as, a venturous soldier.","pos":""}],"VENUE":[{"def":"A neighborhood or near place; the place or county in which anything is alleged to have happened; also, the place where an action is laid.","pos":""}],"VENULE":[{"def":"A small vein; a veinlet; specifically (Zoöl.","pos":""}],"VENULOSE":[{"def":"Full of venules, or small veins.","pos":""}],"VENUS":[{"def":"The goddess of beauty and love, that is, beauty or love deified.","pos":""},{"def":"One of the planets, the second in order from the sun, its orbit lying between that of Mercury and that of the Earth, at a mean distance from the sun of about 67,000,000 miles.","pos":""}]}