{"LIBANT":[{"def":"Sipping; touching lightly.","pos":""}],"LIBATION":[{"def":"The act of pouring a liquid or liquor, usually wine, either on the ground or on a victim in sacrifice, in honor of some deity; also, the wine or liquid thus poured out.","pos":""}],"LIBATORY":[{"def":"Pertaining to libation.","pos":""}],"LIBBARD'S BANE":[{"def":"Lib\"bard's bane` Defn: .","pos":""}],"LIBEL":[{"def":"A malicious publication expressed either in print or in writing, or by pictures, effigies, or other signs, tending to expose another to public hatred, contempt, or ridicule.","pos":""},{"def":"The crime of issuing a malicious defamatory publication.","pos":""}],"LIBELANT":[{"def":"One who libels; one who institutes a suit in an ecclesiastical or admiralty court.","pos":""}],"LIBELOUS":[{"def":"Containing or involving a libel; defamatory; containing that which exposes some person to public hatred, contempt, or ridicule; as, a libelous pamphlet.","pos":""}],"LIBER":[{"def":"The inner bark of plants, lying next to the wood.","pos":""}],"LIBERAL":[{"def":"Free by birth; hence, befitting a freeman or gentleman; refined; noble; independent; free; not servile or mean; as, a liberal ancestry; a liberal spirit; liberal arts or studies.","pos":""},{"def":"Bestowing in a large and noble way, as a freeman; generous; bounteous; open-handed; as, a liberal giver.","pos":""}],"LIBERALISM":[{"def":"Liberal principles; the principles and methods of the liberals in politics or religion; specifically, the principles of the Liberal party.","pos":""}],"LIBERALISTIC":[{"def":"Pertaining to, or characterized by, liberalism; as, liberalistic opinions.","pos":""}],"LIBERALITY":[{"def":"The quality or state of being liberal; liberal disposition or practice; freedom from narrowness or prejudice; generosity; candor; charity.","pos":""},{"def":"A gift; a gratuity; -- sometimes in the plural; as, a prudent man is not impoverished by his liberalities.","pos":""}],"LIBERALIZATION":[{"def":"The act of liberalizing.","pos":""}],"LIBERALIZE":[{"def":"To make liberal; to free from narrow views or prejudices.","pos":""}],"LIBERALIZER":[{"def":"One who, or that which, liberalizes.","pos":""}],"LIBERALLY":[{"def":"In a liberal manner.","pos":""}],"LIBERATE":[{"def":"To release from restraint or bondage; to set at liberty; to free; to manumit; to disengage; as, to liberate a slave or prisoner; to liberate the mind from prejudice; to liberate gases.","pos":""}],"LIBERATION":[{"def":"The act of liberating or the state of being liberated.","pos":""}],"LIBERATOR":[{"def":"One who, or that which, liberates; a deliverer.","pos":""}],"LIBERATORY":[{"def":"Tending, or serving, to liberate.","pos":""}],"LIBERTARIAN":[{"def":"Pertaining to liberty, or to the doctrine of free will, as opposed to the doctrine of necessity.","pos":""}],"LIBERTARIANISM":[{"def":"Libertarian principles or doctrines.","pos":""}],"LIBERTICIDE":[{"def":"The destruction of civil liberty.","pos":""},{"def":"A destroyer of civil liberty.","pos":""}],"LIBERTINAGE":[{"def":"Libertinism; license.","pos":""}],"LIBERTINE":[{"def":"A manumitted slave; a freedman; also, the son of a freedman.","pos":""},{"def":"One of a sect of Anabaptists, in the fifteenth and early part of the sixteenth century, who rejected many of the customs and decencies of life, and advocated a community of goods and of women.","pos":""}],"LIBERTINISM":[{"def":"The state of a libertine or freedman.","pos":""},{"def":"Licentious conduct; debauchery; lewdness.","pos":""}],"LIBERTY":[{"def":"A curve or arch in a bit to afford room for the tongue of the horse.","pos":""},{"def":"Leave of absence; permission to go on shore.","pos":""}],"LIBETHENITE":[{"def":"A mineral of an olive-green color, commonly in orthorhombic crystals.","pos":""}],"LIBIDINIST":[{"def":"One given to lewdness.","pos":""}],"LIBIDINOSITY":[{"def":"The state or quality of being libidinous; libidinousness.","pos":""}],"LIBIDINOUS":[{"def":"Having lustful desires; characterized by lewdness; sensual; lascivious.","pos":""},{"def":"A house or lodging.","pos":""}],"LIBRAL":[{"def":"Of a pound weight.","pos":""}],"LIBRARIAN":[{"def":"One who has the care or charge of a library.","pos":""},{"def":"One who copies manuscript books.","pos":""}],"LIBRARIANSHIP":[{"def":"The office of a librarian.","pos":""}],"LIBRARY":[{"def":"A considerable collection of books kept for use, and not as merchandise; as, a private library; a public library.","pos":""},{"def":"A building or apartment appropriated for holding such a collection of books.","pos":""}],"LIBRATE":[{"def":"To vibrate as a balance does before resting in equilibrium; hence, to be poised.","pos":""}],"LIBRATION":[{"def":"A real or apparent libratory motion, like that of a balance before coming to rest.","pos":""}],"LIBRATORY":[{"def":"Balancing; moving like a balance, as it tends to an equipoise or level.","pos":""}],"LIBRETTIST":[{"def":"One who makes a libretto.","pos":""}],"LIBRIFORM":[{"def":"Having the form of liber, or resembling liber.","pos":""}],"LIBYAN":[{"def":"Of or pertaining to Libya, the ancient name of that part of Africa between Egypt and the Atlantic Ocean, or of Africa as a whole.","pos":""}]}