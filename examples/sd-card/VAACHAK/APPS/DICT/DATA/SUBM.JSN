{"SUBMAMMARY":[{"def":"Situated under the mammæ; as, submammary inflammation.","pos":""}],"SUBMARINE":[{"def":"Being, acting, or growing, under water in the sea; as, submarine navigators; submarine plants.","pos":""}],"SUBMARSHAL":[{"def":"An under or deputy marshal.","pos":""}],"SUBMEDIAL":[{"def":"Lying under the middle.","pos":""}],"SUBMEDIAN":[{"def":"Next to the median (on either side); as, the submedian teeth of mollusks.","pos":""}],"SUBMEDIANT":[{"def":"The sixth tone of the scale; the under mediant, or third below the keynote; the superdominant.","pos":""}],"SUBMENTAL":[{"def":"Situated under the chin; as, the submental artery.","pos":""}],"SUBMENTUM":[{"def":"The basal part of the labium of insects.","pos":""}],"SUBMERGE":[{"def":"To put under water; to plunge.","pos":""},{"def":"To cover or overflow with water; to inundate; to flood; to drown.","pos":""}],"SUBMERGENCE":[{"def":"The act of submerging, or the state of being submerged; submersion.","pos":""}],"SUBMERSED":[{"def":"Being or growing under water, as the leaves of aquatic plants.","pos":""}],"SUBMERSION":[{"def":"The act of submerging, or putting under water or other fluid, or of causing to be overflowed; the act of plunging under water, or of drowning.","pos":""},{"def":"The state of being put under water or other fluid, or of being overflowed or drowned.","pos":""}],"SUBMETALLIC":[{"def":"Imperfectly metallic; as, a submetallic luster.","pos":""}],"SUBMINISTER":[{"def":"To supply; to afford.","pos":""}],"SUBMINISTRANT":[{"def":"Subordinate; subservient.","pos":""}],"SUBMINISTRATE":[{"def":"To supply; to afford; to subminister.","pos":""}],"SUBMINISTRATION":[{"def":"The act of subministering.","pos":""}],"SUBMISS":[{"def":"Submissive; humble; obsequious.","pos":""},{"def":"Gentle; soft; calm; as, submiss voices.","pos":""}],"SUBMISSION":[{"def":"An agreement by which parties engage to submit any matter of controversy between them to the decision of arbitrators.","pos":""}],"SUBMISSIVE":[{"def":"Inclined or ready to submit; acknowledging one's inferiority; yielding; obedient; humble.","pos":""},{"def":"Showing a readiness to submit; expressing submission; as, a submissive demeanor.","pos":""}],"SUBMISSLY":[{"def":"In a submissive manner; with a submission.","pos":""}],"SUBMIT":[{"def":"To let down; to lower.","pos":""},{"def":"To put or place under.","pos":""}],"SUBMITTER":[{"def":"One who submits.","pos":""}],"SUBMONISH":[{"def":"To suggest; to prompt.","pos":""}],"SUBMONITION":[{"def":"Suggestion; prompting.","pos":""}],"SUBMUCOUS":[{"def":"Situated under a mucous membrane.","pos":""}],"SUBMULTIPLE":[{"def":"A number or quality which is contained in another an exact number of times, or is an aliquot part of it; thus, 7 is the submultiple of 56, being contained in it eight times.","pos":""}],"SUBMUSCULAR":[{"def":"Situated underneath a muscle or muscles.","pos":""}]}