{"EUGANOIDEI":[{"def":"A group which includes the bony ganoids, as the gar pikes.","pos":""}],"EUGENESIS":[{"def":"The quality or condition of having strong reproductive powers; generation with full fertility between different species or races, specif.","pos":""}],"EUGENIA":[{"def":"A genus of mytraceous plants, mostly of tropical countries, and including several aromatic trees and shrubs, among which are the trees which produce allspice and cloves of commerce.","pos":""}],"EUGENIC":[{"def":"Pertaining to, or derived from, cloves; as, eugenic acid.","pos":""}],"EUGENICS":[{"def":"The science of improving stock, whether human or animal.","pos":""}],"EUGENIN":[{"def":"A colorless, crystalline substance extracted from oil of cloves; -- called also clove camphor.","pos":""}],"EUGENOL":[{"def":"A colorless, aromatic, liquid hydrocarbon, C10H12O2 resembling the phenols, and hence also called eugenic acid.","pos":""}],"EUGENY":[{"def":"Nobleness of birth.","pos":""},{"def":"Pertaining to, or derived from, eugenol; as, eugetic acid.","pos":""}],"EUGH":[{"def":"Of or pertaining to the ancient town of Eugubium (now Gubbio); as, the Eugubine tablets, or tables, or inscriptions.","pos":""}]}