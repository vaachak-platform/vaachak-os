{"SEABEACH":[{"def":"A beach lying along the sea.","pos":""}],"SEABEARD":[{"def":"A green seaweed (Cladophora rupestris) growing in dense tufts.","pos":""}],"SEABOARD":[{"def":"The seashore; seacoast.","pos":""}],"SEABOAT":[{"def":"A boat or vessel adapted to the open sea; hence, a vessel considered with reference to her power of resisting a storm, or maintaining herself in a heavy sea; as, a good sea boat.","pos":""}],"SEABOUND":[{"def":"Bounded by the sea.","pos":""}]}