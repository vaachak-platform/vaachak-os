{"BROKE":[{"def":"To transact business for another.","pos":""},{"def":"To act as procurer in love matters; to pimp.","pos":""}],"BROKEN":[{"def":"Separated into parts or pieces by violence; divided into fragments; as, a broken chain or rope; a broken dish.","pos":""},{"def":"Disconnected; not continuous; also, rough; uneven; as, a broken surface.","pos":""}],"BROKEN BREAST":[{"def":"Abscess of the mammary gland.","pos":""}],"BROKEN-BACKED":[{"def":"Hogged; so weakened in the frame as to droop at each end; -- said of a ship.","pos":""}],"BROKEN-BELLIED":[{"def":"Having a ruptured belly.","pos":""}],"BROKEN-HEARTED":[{"def":"Having the spirits depressed or crushed by grief or despair.","pos":""}],"BROKEN-WINDED":[{"def":"Having short breath or disordered respiration, as a horse.","pos":""}],"BROKENLY":[{"def":"In a broken, interrupted manner; in a broken state; in broken language.","pos":""}],"BROKENNESS":[{"def":"The state or quality of being broken; unevenness.","pos":""},{"def":"Contrition; as, brokenness of heart.","pos":""}],"BROKER":[{"def":"An agent employed to effect bargains and contracts, as a middleman or negotiator, between other persons, for a compensation commonly called brokerage.","pos":""}],"BROKERAGE":[{"def":"The business or employment of a broker.","pos":""},{"def":"The fee, reward, or commission, given or changed for transacting business as a broker.","pos":""}],"BROKERY":[{"def":"The business of a broker.","pos":""}],"BROKING":[{"def":"Of or pertaining to a broker or brokers, or to brokerage.","pos":""}]}