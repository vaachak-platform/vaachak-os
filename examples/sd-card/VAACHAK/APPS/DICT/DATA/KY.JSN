{"KYACK":[{"def":"A pack sack to be swung on either side of a packsaddle.","pos":""}],"KYANIZE":[{"def":"To render (wood) proof against decay by saturating with a solution of corrosive sublimate in open tanks, or under pressure.","pos":""}],"KYANOPHYLL":[{"def":"Same as Cyanophyll.","pos":""}],"KYAR":[{"def":"Cocoanut fiber, or the cordage made from it.","pos":""}],"KYDDE":[{"def":"Kyd\"de (, Defn: imp.","pos":""}],"KYKE":[{"def":"To look steadfastly; to gaze.","pos":""}],"KYLEY":[{"def":"A variety of the boomerang.","pos":""}],"KYLOES":[{"def":"The cattle of the Hebrides, or of the Highlands.","pos":""}],"KYMOGRAPH":[{"def":"An instrument for measuring, and recording graphically, the pressure of the blood in any of the blood vessels of a living animal; -- called also kymographion.","pos":""}],"KYMOGRAPHIC":[{"def":"Of or pertaining to a kymograph; as, a kymographic tracing.","pos":""}],"KYNURENIC":[{"def":"Pertaining to, or designating, an acid obtained from the urine of dogs.","pos":""}],"KYRIE":[{"def":"See Kyrie eleison.","pos":""}],"KYRIE ELEISON":[{"def":"Greek words, meaning \"Lord, have mercy upon us,\" used in the Mass, the breviary offices, the litany of the saints, etc.","pos":""}],"KYRIELLE":[{"def":"A litany beginning with the words.","pos":""},{"def":"The use of literal or simple expressions, as distinguished from the use of figurative or obscure ones.","pos":""}],"KYRIOLOGICAL":[{"def":"Serving to denote objects by conventional signs or alphabetical characters; as, the original Greek alphabet of sixteen letters was called kyriologic, because it represented the pure elementary sounds.","pos":""},{"def":"To make known; to manifest; to show; to declare.","pos":""}],"KYTHE":[{"def":"To come into view; to appear.","pos":""}],"KYTOPLASMA":[{"def":"See Karyoplasma.","pos":"noun"},{"def":"A short right-angled pipe fitting, used in connecting two pipes at right angles.","pos":"noun"}]}