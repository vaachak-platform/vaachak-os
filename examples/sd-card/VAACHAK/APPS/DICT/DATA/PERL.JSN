{"PERLACEOUS":[{"def":"Pearly; resembling pearl.","pos":""}],"PERLID":[{"def":"Any insect of the genus Perla, or family Perlidæ.","pos":""}],"PERLITE":[{"def":"Same as Pearlite.","pos":""}],"PERLITIC":[{"def":"Relating to or resembling perlite, or pearlstone; as, the perlitic structure of certain rocks.","pos":""}],"PERLUSTRATION":[{"def":"The act of viewing all over.","pos":""}]}