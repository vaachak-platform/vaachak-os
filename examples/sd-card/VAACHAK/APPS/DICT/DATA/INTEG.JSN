{"INTEGER":[{"def":"A complete entity; a whole number, in contradistinction to a fraction or a mixed number.","pos":""}],"INTEGRABILITY":[{"def":"The quality of being integrable.","pos":""}],"INTEGRABLE":[{"def":"Capable of being integrated.","pos":""}],"INTEGRAL":[{"def":"Lacking nothing of completeness; complete; perfect; uninjured; whole; entire.","pos":""},{"def":"Essential to completeness; constituent, as a part; pertaining to, or serving to form, an integer; integrant.","pos":""}],"INTEGRALLY":[{"def":"In an integral manner; wholly; completely; also, by integration.","pos":""}],"INTEGRANT":[{"def":"Making part of a whole; necessary to constitute an entire thing; integral.","pos":""}],"INTEGRATE":[{"def":"To subject to the operation of integration; to find the integral of.","pos":""}],"INTEGRATION":[{"def":"The operation of finding the primitive function which has a given function for its differential coefficient.","pos":""}],"INTEGRATOR":[{"def":"That which integrates; esp.","pos":""}],"INTEGRITY":[{"def":"The state or quality of being entire or complete; wholeness; entireness; unbroken state; as, the integrity of an empire or territory.","pos":""},{"def":"Moral soundness; honesty; freedom from corrupting influence or motive; -- used especially with reference to the fulfillment of contracts, the discharge of agencies, trusts, and the like; uprightness; rectitude.","pos":""}],"INTEGROPALLIAL":[{"def":"Having the pallial line entire, or without a sinus, as certain bivalve shells.","pos":""}],"INTEGUMATION":[{"def":"That part of physiology which treats of the integuments of animals and plants.","pos":""}],"INTEGUMENT":[{"def":"That which naturally invests or covers another thing, as the testa or the tegmen of a seed; specifically (Anat.","pos":""}],"INTEGUMENTARY":[{"def":"Belonging to, or composed of, integuments.","pos":""}],"INTEGUMENTATION":[{"def":"The act or process of covering with integuments; the state or manner of being thus covered.","pos":""}]}