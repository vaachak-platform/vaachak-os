{"AGRAFFE":[{"def":"A hook or clasp.","pos":""},{"def":"A hook, eyelet, or other device by which a piano wire is so held as to limit the vibration.","pos":""}],"AGRAMMATIST":[{"def":"A illiterate person.","pos":""}],"AGRAPHIA":[{"def":"The absence or loss of the power of expressing ideas by written signs.","pos":""}],"AGRAPHIC":[{"def":"Characterized by agraphia.","pos":""}],"AGRAPPES":[{"def":"Hooks and eyes for armor, etc.","pos":""}],"AGRARIAN":[{"def":"Wild; -- said of plants growing in the fields.","pos":""}],"AGRARIANISM":[{"def":"An equal or equitable division of landed property; the principles or acts of those who favor a redistribution of land.","pos":""}],"AGRARIANIZE":[{"def":"To distribute according to, or to imbue with, the principles of agrarianism.","pos":""},{"def":"In good part; kindly.","pos":""}],"AGREE":[{"def":"To correspond in gender, number, case, or person.","pos":""}],"AGREEABILITY":[{"def":"Easiness of disposition.","pos":""},{"def":"The quality of being, or making one's self, agreeable; agreeableness.","pos":""}],"AGREEABLE":[{"def":"Pleasing, either to the mind or senses; pleasant; grateful; as, agreeable manners or remarks; an agreeable person; fruit agreeable to the taste.","pos":""},{"def":"Willing; ready to agree or consent.","pos":""}],"AGREEABLENESS":[{"def":"The quality of being agreeable or pleasing; that quality which gives satisfaction or moderate pleasure to the mind or senses.","pos":""},{"def":"The quality of being agreeable or suitable; suitableness or conformity; consistency.","pos":""}],"AGREEABLY":[{"def":"In an agreeably manner; in a manner to give pleasure; pleasingly.","pos":""},{"def":"In accordance; suitably; consistently; conformably; -- followed by to and rarely by with.","pos":""}],"AGREEINGLY":[{"def":"In an agreeing manner (to); correspondingly; agreeably.","pos":""}],"AGREEMENT":[{"def":"Concord or correspondence of one word with another in gender, number, case, or person.","pos":""}],"AGRESTIC":[{"def":"Pertaining to fields or the country, in opposition to the city; rural; rustic; unpolished; uncouth.","pos":""}],"AGRICOLIST":[{"def":"A cultivator of the soil; an agriculturist.","pos":""}],"AGRICULTOR":[{"def":"An agriculturist; a farmer.","pos":""}],"AGRICULTURAL":[{"def":"Of or pertaining to agriculture; connected with, or engaged in, tillage; as, the agricultural class; agricultural implements, wages, etc.","pos":""}],"AGRICULTURALIST":[{"def":"An agriculturist (which is the preferred form.","pos":""}],"AGRICULTURE":[{"def":"The art or science of cultivating the ground, including the harvesting of crops, and the rearing and management of live stock; tillage; husbandry; farming.","pos":""}],"AGRICULTURIST":[{"def":"One engaged or skilled in agriculture; a husbandman.","pos":""}],"AGRIEF":[{"def":"In grief; amiss.","pos":""}],"AGRIMONY":[{"def":"Note: The Agrimonia eupatoria, or common agrimony, a perennial herb with a spike of yellow flowers, was once esteemed as a medical remedy, but is now seldom used.","pos":""}],"AGRIN":[{"def":"In the act of grinning.","pos":""}],"AGRIOLOGIST":[{"def":"One versed or engaged in agriology.","pos":""}],"AGRIOLOGY":[{"def":"Description or comparative study of the customs of savage or uncivilized tribes.","pos":""}],"AGRISE":[{"def":"To shudder with terror; to tremble with fear.","pos":""}],"AGROM":[{"def":"A disease occurring in Bengal and other parts of the East Indies, in which the tongue chaps and cleaves.","pos":""},{"def":"Pertaining to agronomy, of the management of farms.","pos":""}],"AGRONOMICS":[{"def":"The science of the distribution and management of land.","pos":""}],"AGRONOMIST":[{"def":"One versed in agronomy; a student of agronomy.","pos":""}],"AGRONOMY":[{"def":"The management of land; rural economy; agriculture.","pos":""}],"AGROPE":[{"def":"In the act of groping.","pos":""}],"AGROSTIS":[{"def":"A genus of grasses, including species called in common language bent grass.","pos":""},{"def":"Pertaining to agrostography.","pos":""}],"AGROSTOGRAPHY":[{"def":"A description of the grasses.","pos":""},{"def":"Pertaining to agrostology.","pos":""}],"AGROSTOLOGIST":[{"def":"One skilled in agrostology.","pos":""}],"AGROSTOLOGY":[{"def":"That part of botany which treats of the grasses.","pos":""}],"AGROTECHNY":[{"def":"That branch of agriculture dealing with the methods of conversion of agricultural products into manufactured articles; agricultural technology.","pos":""}],"AGROUND":[{"def":"On the ground; stranded; -- a nautical term applied to a ship when its bottom lodges on the ground.","pos":""}],"AGROUPMENT":[{"def":"See Aggroupment.","pos":""}],"AGRYPNOTIC":[{"def":"Anything which prevents sleep, or produces wakefulness, as strong tea or coffee.","pos":""}]}