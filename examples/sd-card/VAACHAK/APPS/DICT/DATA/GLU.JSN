{"GLUCIC":[{"def":"Pertaining to, or obtained from, sugar; as, glucic acid.","pos":""}],"GLUCINA":[{"def":"A white or gray tasteless powder, the oxide of the element glucinum; -- formerly called glucine.","pos":""}],"GLUCINIC":[{"def":"Pertaining to, derived from, or containing, glucinum; as, glucinic oxide.","pos":""}],"GLUCINUM":[{"def":"A rare metallic element, of a silver white color, and low specific gravity (2.","pos":""}],"GLUCONIC":[{"def":"Pertaining to, or derived from, glucose.","pos":""}],"GLUCOSE":[{"def":"Any one of a large class of sugars, isometric with glucose proper, and including levulose, galactose, etc.","pos":""}],"GLUCOSIDE":[{"def":"One of a large series of amorphous or crystalline substances, occurring very widely distributed in plants, rarely in animals, and regarded as influental agents in the formation and disposition of the sugars.","pos":""}],"GLUCOSURIA":[{"def":"A condition in which glucose is discharged in the urine; diabetes mellitus.","pos":""}],"GLUE":[{"def":"A hard brittle brownish gelatin, obtained by boiling to a jelly the skins, hoofs, etc.","pos":""}],"GLUEPOT":[{"def":"A utensil for melting glue, consisting of an inner pot holding the glue, immersed in an outer one containing water which is heated to soften the glue.","pos":""}],"GLUER":[{"def":"One who cements with glue.","pos":""}],"GLUEY":[{"def":"Viscous; glutinous; of the nature of, or like, glue.","pos":""}],"GLUM":[{"def":"Moody; silent; sullen.","pos":""}],"GLUMACEOUS":[{"def":"Having glumes; consisting of glumes.","pos":""}],"GLUMAL":[{"def":"Characterized by a glume, or having the nature of a glume.","pos":""}],"GLUME":[{"def":"The bracteal covering of the flowers or seeds of grain and grasses; esp.","pos":""},{"def":"One of the pelets or inner chaffy scales of the flowers or spikelets of grasses.","pos":""}],"GLUMLY":[{"def":"In a glum manner; sullenly; moodily.","pos":""}],"GLUMMY":[{"def":"dark; gloomy; dismal.","pos":""}],"GLUMNESS":[{"def":"Moodiness; sullenness.","pos":""}],"GLUMP":[{"def":"To manifest sullenness; to sulk.","pos":""}],"GLUMPY":[{"def":"Glum; sullen; sulky.","pos":""}],"GLUNCH":[{"def":"Frowning; sulky; sullen.","pos":""},{"def":"A sullen, angry look; a look of disdain or dislike.","pos":""}],"GLUT":[{"def":"To swallow, or to swallow greedlly; to gorge.","pos":""},{"def":"To fill to satiety; to satisfy fully the desire or craving of; to satiate; to sate; to cloy.","pos":""}],"GLUTACONIC":[{"def":"Pertaining to, or derived from, an acid intermediate between glutaric and aconitic acids.","pos":""}],"GLUTAEUS":[{"def":"The great muscle of the buttock in man and most mammals, and the corresponding muscle in many lower animals.","pos":""}],"GLUTAMIC":[{"def":"Of or pertaining to gluten.","pos":""}],"GLUTARIC":[{"def":"Of, pertaining to, or designating, an acid so called; as, glutaric ethers.","pos":""}],"GLUTAZINE":[{"def":"A nitrogenous substance, forming a heavy, sandy powder, white or nearly so.","pos":""}],"GLUTEAL":[{"def":"Pertaining to, or in the region of, the glutæus.","pos":""}],"GLUTEN":[{"def":"The viscid, tenacious substance which gives adhesiveness to dough.","pos":""}],"GLUTEUS":[{"def":"Same as Glutæus.","pos":""}],"GLUTIN":[{"def":"Same as Gliadin.","pos":""},{"def":"Sometimes synonymous with Gelatin.","pos":""}],"GLUTINATE":[{"def":"To unite with glue; to cement; to stick together.","pos":""}],"GLUTINATION":[{"def":"The act of uniting with glue; sticking together.","pos":""}],"GLUTINATIVE":[{"def":"Having the quality of cementing; tenacious; viscous; glutinous.","pos":""}],"GLUTINOSITY":[{"def":"The quality of being glutinous; viscousness.","pos":""}],"GLUTINOUS":[{"def":"Havig a moist and adhesive or sticky surface, as a leaf or gland.","pos":""}],"GLUTINOUSNESS":[{"def":"The quality of being glutinous.","pos":""}],"GLUTTON":[{"def":"A carnivorous mammal (Gulo luscus), of the family Mustelidæ, about the size of a large badger.","pos":""}],"GLUTTONISH":[{"def":"Gluttonous; greedy.","pos":""}],"GLUTTONIZE":[{"def":"To eat to excess; to eat voraciously; to gormandize.","pos":""}],"GLUTTONOUS":[{"def":"Given to gluttony; eating to excess; indulging the appetite; voracious; as, a gluttonous age.","pos":""}],"GLUTTONY":[{"def":"Excess in eating; extravagant indulgence of the appetite for food; voracity.","pos":""}]}