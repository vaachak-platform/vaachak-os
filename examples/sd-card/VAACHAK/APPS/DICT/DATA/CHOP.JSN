{"CHOP":[{"def":"To cut by striking repeatedly with a sharp instrument; to cut into pieces; to mince; -- often with up.","pos":""},{"def":"To sever or separate by one more blows of a sharp instrument; to divide; -- usually with off or down.","pos":""}],"CHOP-LOGIC":[{"def":"One who bandies words or is very argunentative.","pos":""}],"CHOPBOAT":[{"def":"A licensed lighter employed in the transportation of goods to and from vessels.","pos":""}],"CHOPCHURCH":[{"def":"An exchanger or an exchange of benefices.","pos":""}],"CHOPFALLEN":[{"def":"Having the lower chop or jaw depressed; hence, crestfallen; dejected; dispirited;downcast.","pos":""}],"CHOPHOUSE":[{"def":"A house where chops, etc.","pos":""}],"CHOPIN":[{"def":"A liquid measure formerly used in France and Great Britain, varying from half a pint to a wine quart.","pos":""}],"CHOPINE":[{"def":"A clog, or patten, having a very thick sole, or in some cases raised upon a stilt to a height of a foot or more.","pos":""}],"CHOPNESS":[{"def":"A kind of spade.","pos":""}],"CHOPPER":[{"def":"One who, or that which, chops.","pos":""}],"CHOPPING":[{"def":"Stout or plump; large.","pos":""}],"CHOPPY":[{"def":"Rough, with short, tumultuous waves; as, a choppy sea.","pos":""}],"CHOPS":[{"def":"The jaws; also, the fleshy parts about the mouth.","pos":""},{"def":"The sides or capes at the mouth of a river, channel, harbor, or bay; as, the chops of the English Channel.","pos":""}],"CHOPSTICK":[{"def":"One of two small sticks of wood, ivory, etc.","pos":""},{"def":"A mélange served in Chinese restaurants to be eaten with rice, noodles, etc.","pos":""}]}