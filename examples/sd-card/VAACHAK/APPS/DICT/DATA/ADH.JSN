{"ADHAMANT":[{"def":"Clinging, as by hooks.","pos":""}],"ADHERE":[{"def":"To stick fast or cleave, as a glutinous substance does; to become joined or united; as, wax to the finger; the lungs sometimes adhere to the pleura.","pos":""},{"def":"To hold, be attached, or devoted; to remain fixed, either by personal union or conformity of faith, principle, or opinion; as, men adhere to a party, a cause, a leader, a church.","pos":""}],"ADHERENCE":[{"def":"The quality or state of adhering.","pos":""},{"def":"The state of being fixed in attachment; fidelity; steady attachment; adhesion; as, adherence to a party or to opinions.","pos":""}],"ADHERENCY":[{"def":"The state or quality of being adherent; adherence.","pos":""},{"def":"That which adheres.","pos":""}],"ADHERENT":[{"def":"Congenitally united with an organ of another kind, as calyx with ovary, or stamens with petals.","pos":""}],"ADHERENTLY":[{"def":"In an adherent manner.","pos":""}],"ADHERER":[{"def":"One who adheres; an adherent.","pos":""}],"ADHESION":[{"def":"The molecular attraction exerted between bodies in contact.","pos":""},{"def":"Union of surface, normally separate, by the formation of new tissue resulting from an inflammatory process.","pos":""}],"ADHESIVE":[{"def":"Sticky; tenacious, as glutinous substances.","pos":""},{"def":"Apt or tending to adhere; clinging.","pos":""}],"ADHESIVELY":[{"def":"In an adhesive manner.","pos":""}],"ADHESIVENESS":[{"def":"Propensity to form and maintain attachments to persons, and to promote social intercourse.","pos":""}],"ADHIBIT":[{"def":"To admit, as a person or thing; to take in.","pos":""},{"def":"To use or apply; to administer.","pos":""}],"ADHIBITION":[{"def":"The act of adhibiting; application; use.","pos":""}],"ADHORT":[{"def":"To exhort; to advise.","pos":""}],"ADHORTATION":[{"def":"Advice; exhortation.","pos":""}],"ADHORTATORY":[{"def":"Containing counsel or warning; hortatory; advisory.","pos":""}]}