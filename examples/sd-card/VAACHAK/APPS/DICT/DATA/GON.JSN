{"GONAD":[{"def":"One of the masses of generative tissue primitively alike in both sexes, but giving rise to either an ovary or a testis; a generative gland; a germ gland.","pos":""}],"GONAKIE":[{"def":"An African timber tree (Acacia Adansonii).","pos":""}],"GONDOLA":[{"def":"A long, narrow boat with a high prow and stern, used in the canals of Venice.","pos":""},{"def":"A flat-bottomed boat for freight.","pos":""}],"GONDOLET":[{"def":"A small gondola.","pos":""}],"GONDOLIER":[{"def":"A man who rows a gondola.","pos":""}],"GONENESS":[{"def":"A state of exhaustion; faintness, especially as resulting from hunger.","pos":""}],"GONFALONIER":[{"def":"He who bears the gonfalon; a standard bearer; as: (a) An officer at Rome who bears the standard of the Church.","pos":""}],"GONG":[{"def":"A privy or jakes.","pos":""}],"GONGORISM":[{"def":"An affected elegance or euphuism of style, for which the Spanish poet Gongora y Argote (1561-1627), among others of his time, was noted.","pos":""}],"GONIATITE":[{"def":"One of an extinct genus of fossil cephalopods, allied to the Ammonites.","pos":""}],"GONIDIAL":[{"def":"Pertaining to, or containing, gonidia.","pos":""}],"GONIDIUM":[{"def":"A special groove or furrow at one or both angles of the mouth of many Anthozoa.","pos":""}],"GONIMIA":[{"def":"Bluish green granules which occur in certain lichens, as Collema, Peltigera, etc.","pos":""}],"GONIMOUS":[{"def":"Pertaining to, or containing, gonidia or gonimia, as that part of a lichen which contains the green or chlorophyll-bearing cells.","pos":""}],"GONIOMETER":[{"def":"An instrument for measuring angles, especially the angles of crystals, or the inclination of planes.","pos":""},{"def":"Pertaining to, or determined by means of, a goniometer; trigonometric.","pos":""}],"GONIOMETRY":[{"def":"The art of measuring angles; trigonometry.","pos":""}],"GONOBLASTID":[{"def":"A reproductive bud of a hydroid; a simple gonophore.","pos":""}],"GONOBLASTIDIUM":[{"def":"Gon`o*blas*tid\"i*um, n.","pos":""}],"GONOCALYX":[{"def":"The bell of a sessile gonozooid.","pos":""}],"GONOCOCCUS":[{"def":"A vegetable microörganism of the genus Micrococcus, occurring in the secretion in gonorrhea.","pos":""}],"GONOPH":[{"def":"A pickpocket or thief.","pos":""}],"GONOPHORE":[{"def":"A sexual zooid produced as a medusoid bud upon a hydroid, sometimes becoming a free hydromedusa, sometimes remaining attached.","pos":""},{"def":"A lengthened receptacle, bearing the stamens and carpels in a conspicuous manner.","pos":""}],"GONOSOME":[{"def":"The reproductive zooids of a hydroid colony, collectively.","pos":""}],"GONOTHECA":[{"def":"A capsule developed on certain hydroids (Thecaphora), inclosing the blastostyle upon which the medusoid buds or gonophores are developed; -- called also gonangium, and teleophore.","pos":""}],"GONOZOOID":[{"def":"A sexual zooid, or medusoid bud of a hydroid; a gonophore.","pos":""}],"GONYDIAL":[{"def":"Pertaining to the gonys of a bird's beak.","pos":""}],"GONYS":[{"def":"The keel or lower outline of a bird's bill, so far as the mandibular rami are united.","pos":""}]}