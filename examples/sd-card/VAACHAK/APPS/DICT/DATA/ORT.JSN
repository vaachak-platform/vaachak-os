{"ORT":[{"def":"A morsel left at a meal; a fragment; refuse; -- commonly used in the plural.","pos":""}],"ORTALIDIAN":[{"def":"Any one of numerous small two-winged flies of the family Ortalidæ.","pos":""}],"ORTHID":[{"def":"A brachiopod shell of the genus Orthis, and allied genera, of the family Orthidæ.","pos":""}],"ORTHIS":[{"def":"An extinct genus of Brachiopoda, abundant in the Paleozoic rocks.","pos":""}],"ORTHITE":[{"def":"A variety of allanite occurring in slender prismatic crystals.","pos":""}],"ORTHO-":[{"def":"A combining form (also used adjectively), designating: (a) (Inorganic Chem.","pos":""},{"def":"Connection with, or affinity to, one variety of isomerism, characteristic of the benzene compounds; -- contrasted with meta- or para-; as, the ortho position; hence, designating any substance showing such isomerism; as, an ortho compound.","pos":""}],"ORTHOCARBONIC":[{"def":"Designating a complex ether, C.","pos":""}],"ORTHOCENTER":[{"def":"That point in which the three perpendiculars let fall from the angles of a triangle upon the opposite sides, or the sides produced, mutually intersect.","pos":""}],"ORTHOCERAS":[{"def":"An extinct genus of Paleozoic Cephalopoda, having a long, straight, conical shell.","pos":""}],"ORTHOCERATITE":[{"def":"An orthoceras; also, any fossil shell allied to Orthoceras.","pos":""}],"ORTHOCLASE":[{"def":"Common or potash feldspar crystallizing in the monoclinic system and having two cleavages at right angles to each other.","pos":""}],"ORTHOCLASTIC":[{"def":"Breaking in directions at right angles to each other; -- said of the monoclinic feldspars.","pos":""}],"ORTHODIAGONAL":[{"def":"The diagonal or lateral axis in a monoclinic crystal which is at right angles with the vertical axis.","pos":""}],"ORTHODOME":[{"def":"See the Note under Dome, 4.","pos":""}],"ORTHODOX":[{"def":"Sound in opinion or doctrine, especially in religious doctrine; hence, holding the Christian faith; believing the doctrines taught in the Scriptures; -- opposed to Ant: heretical and Ant: heterodox; as, an orthodox Christian.","pos":""},{"def":"According or congruous with the doctrines of Scripture, the creed of a church, the decree of a council, or the like; as, an orthodox opinion, book, etc.","pos":""}],"ORTHODOXAL":[{"def":"Pertaining to, or evincing, orthodoxy; orthodox.","pos":""}],"ORTHODOXALITY":[{"def":"Or`tho*dox*al\"i*ty, n.","pos":""}],"ORTHODOXALLY":[{"def":"Or\"tho*dox`al*ly, adv.","pos":""}],"ORTHODOXASTICAL":[{"def":"Or`tho*dox*as\"tic*al, a.","pos":""}],"ORTHODOXICAL":[{"def":"Pertaining to, or evincing, orthodoxy; orthodox.","pos":""}],"ORTHODOXLY":[{"def":"In an orthodox manner; with soundness of faith.","pos":""}],"ORTHODOXNESS":[{"def":"The quality or state of being orthodox; orthodoxy.","pos":""}],"ORTHODOXY":[{"def":"Soundness of faith; a belief in the doctrines taught in the Scriptures, or in some established standard of faith; -- opposed to heterodoxy or to heresy.","pos":""},{"def":"Consonance to genuine Scriptural doctrines; -- said of moral doctrines and beliefs; as, the orthodoxy of a creed.","pos":""}],"ORTHODROMIC":[{"def":"Of or pertaining to orthodromy.","pos":""}],"ORTHODROMICS":[{"def":"The art of sailing in a direct course, or on the arc of a great circle, which is the shortest distance between any two points on the surface of the globe; great-circle sailing; orthodromy.","pos":""}],"ORTHODROMY":[{"def":"The act or art of sailing on a great circle.","pos":""},{"def":"Of or pertaining to orthoëpy, or correct pronunciation.","pos":""}],"ORTHOEPIST":[{"def":"One who is skilled in orthoëpy.","pos":""}],"ORTHOEPY":[{"def":"The art of uttering words corectly; a correct pronunciation of words; also, mode of pronunciation.","pos":""}],"ORTHOGAMY":[{"def":"Direct fertilization in plants, as when the pollen fertilizing the ovules comes from the stamens of the same blossom; -- opposed to heterogamy.","pos":""}],"ORTHOGNATHISM":[{"def":"The quality or state of being orthognathous.","pos":""}],"ORTHOGNATHOUS":[{"def":"Having the front of the head, or the skull, nearly perpendicular, not retreating backwards above the jaws; -- opposed to Ant: prognathous.","pos":""}],"ORTHOGON":[{"def":"A rectangular figure.","pos":""}],"ORTHOGONAL":[{"def":"Right-angled; rectangular; as, an orthogonal intersection of one curve with another.","pos":""}],"ORTHOGONALLY":[{"def":"Perpendicularly; at right angles; as, a curve cuts a set of curves orthogonally.","pos":""}],"ORTHOGRAPH":[{"def":"An orthographic projection, sometimes partly in section, esp.","pos":""}],"ORTHOGRAPHER":[{"def":"One versed in orthography; one who spells words correctly.","pos":""},{"def":"Of or pertaining to right lines or angles.","pos":""}],"ORTHOGRAPHICALLY":[{"def":"In an orthographical manner: (a) according to the rules of proper spelling; (b) according to orthographic projection.","pos":""}],"ORTHOGRAPHIST":[{"def":"One who spells words correctly; an orthographer.","pos":""}],"ORTHOGRAPHIZE":[{"def":"To spell correctly or according to usage; to correct in regard to spelling.","pos":""}],"ORTHOGRAPHY":[{"def":"The art or practice of writing words with the proper letters, according to standard usage; conventionally correct spelling; also, mode of spelling; as, his orthography is vicious.","pos":""},{"def":"The part of grammar which treats of the letters, and of the art of spelling words correctly.","pos":""}],"ORTHOLOGY":[{"def":"The right description of things.","pos":""}],"ORTHOMETRIC":[{"def":"Having the axes at right angles to one another; -- said of crystals or crystalline forms.","pos":""}],"ORTHOMETRY":[{"def":"The art or practice of constructing verses correctly; the laws of correct versification.","pos":""}],"ORTHOMORPHIC":[{"def":"Having the right form.","pos":""},{"def":"Pertaining to, or employed in, orthopedy; relating to the prevention or cure of deformities of children, or, in general, of the human body at any age; as, orthopedic surgery; an orthopedic hospital.","pos":""}],"ORTHOPEDIST":[{"def":"One who prevents, cures, or remedies deformities, esp.","pos":""}],"ORTHOPEDY":[{"def":"The art or practice of curing the deformities of children, or, by extension, any deformities of the human body.","pos":""}],"ORTHOPHONY":[{"def":"The art of correct articulation; voice training.","pos":""}],"ORTHOPINACOID":[{"def":"A name given to the two planes in the monoclinic system which are parallel to the vertical and orthodiagonal axes.","pos":""},{"def":"Specifically, a morbid condition in which respiration can be performed only in an erect posture; by extension, any difficulty of breathing.","pos":""}],"ORTHOPODA":[{"def":"An extinct order of reptiles which stood erect on the hind legs, and resembled birds in the structure of the feet, pelvis, and other parts.","pos":""}],"ORTHOPRAXY":[{"def":"The treatment of deformities in the human body by mechanical appliances.","pos":""}],"ORTHOPTERA":[{"def":"An order of mandibulate insects including grasshoppers, locusts, cockroaches, etc.","pos":""}],"ORTHOPTERAN":[{"def":"One of the Orthoptera.","pos":""}],"ORTHOPTEROUS":[{"def":"Of or pertaining to the Orthoptera.","pos":""}],"ORTHORHOMBIC":[{"def":"Noting the system of crystallization which has three unequal axes at right angles to each other; trimetric.","pos":""}],"ORTHOSCOPE":[{"def":"An instrument designed to show the condition of the superficial portions of the eye.","pos":""}],"ORTHOSCOPIC":[{"def":"Giving an image in correct or normal proportions; giving a flat field of view; as, an orthoscopic eyepiece.","pos":""}],"ORTHOSILICIC":[{"def":"Designating the form of silicic acid having the normal or highest number of hydroxyl groups.","pos":""}],"ORTHOSPERMOUS":[{"def":"Having the seeds straight, as in the fruits of some umbelliferous plants; -- opposed to coelospermous.","pos":""}],"ORTHOSTADE":[{"def":"A chiton, or loose, ungirded tunic, falling in straight folds.","pos":""}],"ORTHOSTICHY":[{"def":"A longitudinal rank, or row, of leaves along a stem.","pos":""}],"ORTHOTOMIC":[{"def":"Cutting at right angles.","pos":""}],"ORTHOTOMOUS":[{"def":"Having two cleavages at right angles with one another.","pos":""}],"ORTHOTOMY":[{"def":"The property of cutting at right angles.","pos":""}],"ORTHOTONE":[{"def":"Retaining the accent; not enclitic; -- said of certain indefinite pronouns and adverbs when used interrogatively, which, when not so used, are ordinarilly enclitic.","pos":""},{"def":"Having the axis of an ovule or seed straight from the hilum and chalaza to the orifice or the micropyle; atropous.","pos":""}],"ORTHOTROPIC":[{"def":"Having the longer axis vertical; -- said of erect stems.","pos":""}],"ORTHOXYLENE":[{"def":"That variety of xylene in which the two methyl groups are in the ortho position; a colorless, liquid, combustible hydrocarbon resembling benzene.","pos":""}],"ORTIVE":[{"def":"Of or relating to the time or act of rising; eastern; as, the ortive amplitude of a planet.","pos":""}],"ORTYGAN":[{"def":"One of several species of East Indian birds of the genera Ortygis and Hemipodius.","pos":""}]}