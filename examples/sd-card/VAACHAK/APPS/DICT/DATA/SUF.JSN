{"SUF-":[{"def":"A form of the prefix Sub-.","pos":""}],"SUFFER":[{"def":"To feel, or endure, with pain, annoyance, etc.","pos":""},{"def":"To endure or undergo without sinking; to support; to sustain; to bear up under.","pos":""}],"SUFFERABLE":[{"def":"Able to suffer or endure; patient.","pos":""},{"def":"That may be suffered, tolerated, or permitted; allowable; tolerable.","pos":""}],"SUFFERANCE":[{"def":"The state of suffering; the bearing of pain; endurance.","pos":""},{"def":"Pain endured; misery; suffering; distress.","pos":""}],"SUFFERER":[{"def":"One who suffers; one who endures or undergoes suffering; one who sustains inconvenience or loss; as, sufferers by poverty or sickness; men are sufferers by fire or by losses at sea.","pos":""},{"def":"One who permits or allows.","pos":""}],"SUFFERING":[{"def":"The bearing of pain, inconvenience, or loss; pain endured; distress, loss, or injury incurred; as, sufferings by pain or sorrow; sufferings by want or by wrongs.","pos":""}],"SUFFICE":[{"def":"To be enough, or sufficient; to meet the need (of anything); to be equal to the end proposed; to be adequate.","pos":""}],"SUFFICIENCY":[{"def":"The quality or state of being sufficient, or adequate to the end proposed; adequacy.","pos":""},{"def":"Qualification for any purpose; ability; capacity.","pos":""}],"SUFFICIENT":[{"def":"Equal to the end proposed; adequate to wants; enough; ample; competent; as, provision sufficient for the family; an army sufficient to defend the country.","pos":""},{"def":"Possessing adequate talents or accomplishments; of competent power or ability; qualified; fit.","pos":""}],"SUFFICIENTLY":[{"def":"To a sufficient degree; to a degree that answers the purpose, or gives content; enough; as, we are sufficiently supplied with food; a man sufficiently qualified for the discharge of his official duties.","pos":""}],"SUFFICING":[{"def":"Affording enough; satisfying.","pos":""}],"SUFFISANCE":[{"def":"Sufficiency; plenty; abundance; contentment.","pos":""}],"SUFFIX":[{"def":"A subscript mark, number, or letter.","pos":""}],"SUFFIXION":[{"def":"The act of suffixing, or the state of being suffixed.","pos":""}],"SUFFLAMINATE":[{"def":"To retard the motion of, as a carriage, by preventing one or more of its wheels from revolving, either by means of a chain or otherwise.","pos":""},{"def":"Hence, to stop; to impede.","pos":""}],"SUFFLATE":[{"def":"To blow up; to inflate; to inspire.","pos":""}],"SUFFLATION":[{"def":"The act of blowing up or inflating.","pos":""}],"SUFFOCATE":[{"def":"Suffocated; choked.","pos":""}],"SUFFOCATING":[{"def":"from Suffocate, v.","pos":""}],"SUFFOCATION":[{"def":"The act of suffocating, or the state of being suffocated; death caused by smothering or choking.","pos":""}],"SUFFOCATIVE":[{"def":"Tending or able to choke or stifle.","pos":""}],"SUFFOSSION":[{"def":"A digging under; an undermining.","pos":""}],"SUFFRAGAN":[{"def":"Assisting; assistant; as, a suffragan bishop.","pos":""}],"SUFFRAGANSHIP":[{"def":"The office of a suffragan.","pos":""}],"SUFFRAGATE":[{"def":"To vote or vote with.","pos":""}],"SUFFRAGATOR":[{"def":"One who assists or favors by his vote.","pos":""}],"SUFFRAGE":[{"def":"The right to vote; franchise.","pos":""}],"SUFFRAGETTE":[{"def":"A woman who advocates the right to vote for women; a woman suffragist.","pos":""}],"SUFFRAGINOUS":[{"def":"Of or pertaining to the hock of a beast.","pos":""}],"SUFFRAGIST":[{"def":"One who possesses or exercises the political right of suffrage; a voter.","pos":""},{"def":"One who has certain opinions or desires about the political right of suffrage; as, a woman suffragist.","pos":""}],"SUFFRUTESCENT":[{"def":"Slightly woody at the base.","pos":""}],"SUFFRUTICOSE":[{"def":"Woody in the lower part of the stem, but with the yearly branches herbaceous, as sage, thyme, hyssop, and the like.","pos":""}],"SUFFUMIGATE":[{"def":"To apply fumes or smoke to the parts of, as to the body in medicine; to fumigate in part.","pos":""}],"SUFFUMIGATION":[{"def":"The operation of suffumigating.","pos":""}],"SUFFUSE":[{"def":"To overspread, as with a fluid or tincture; to fill or cover, as with something fluid; as, eyes suffused with tears; cheeks suffused with blushes.","pos":""}],"SUFFUSION":[{"def":"A blending of one color into another; the spreading of one color over another, as on the feathers of birds.","pos":""}],"SUFI":[{"def":"A title or surname of the king of Persia.","pos":""}],"SUFISM":[{"def":"A refined mysticism among certain classes of Mohammedans, particularly in Persia, who hold to a kind of pantheism and practice extreme asceticism in their lives.","pos":""}]}