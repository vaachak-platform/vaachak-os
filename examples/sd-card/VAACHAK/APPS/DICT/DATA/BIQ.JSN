{"BIQUADRATE":[{"def":"The fourth power, or the square of the square.","pos":""}],"BIQUADRATIC":[{"def":"Of or pertaining to the biquadrate, or fourth power.","pos":""}],"BIQUINTILE":[{"def":"An aspect of the planets when they are distant from each other by twice the fifth part of a great circle -- that is, twice 72 degrees.","pos":""},{"def":"Having two rays; as, a biradiate fin.","pos":""}]}