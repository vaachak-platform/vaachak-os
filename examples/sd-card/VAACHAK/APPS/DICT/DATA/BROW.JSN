{"BROW":[{"def":"The prominent ridge over the eye, with the hair that covers it, forming an arch above the orbit.","pos":""},{"def":"The hair that covers the brow (ridge over the eyes); the eyebrow.","pos":""}],"BROWBEAT":[{"def":"To depress or bear down with haughty, stern looks, or with arrogant speech and dogmatic assertions; to abash or disconcert by impudent or abusive words or looks; to bully; as, to browbeat witnesses.","pos":""}],"BROWBEATING":[{"def":"The act of bearing down, abashing, or disconcerting, with stern looks, suspercilious manners, or confident assertions.","pos":""}],"BROWBOUND":[{"def":"Crowned; having the head encircled as with a diadem.","pos":""}],"BROWDYNG":[{"def":"Of goldsmithrye, of browdying, and of steel.","pos":""}],"BROWED":[{"def":"Having (such) a brow; -- used in composition; as, dark-browed, stern-browed.","pos":""}],"BROWN":[{"def":"Of a dark color, of various shades between black and red or yellow.","pos":""}],"BROWN BILL":[{"def":"A bill or halberd of the 16th and 17th centuries.","pos":""}],"BROWN RACE":[{"def":"The Malay or Polynesian race; -- loosely so called.","pos":""}],"BROWN THRUSH":[{"def":"A common American singing bird (Harporhynchus rufus), allied to the mocking bird; -- also called brown thrasher.","pos":""}],"BROWNBACK":[{"def":"The dowitcher or red-breasted snipe.","pos":""}],"BROWNIAN":[{"def":"Pertaining to Dr.","pos":""}],"BROWNIE":[{"def":"An imaginary good-natured spirit, who was supposed often to perform important services around the house by night, such as thrashing, churning, sweeping.","pos":""}],"BROWNING":[{"def":"A smooth coat of brown mortar, usually the second coat, and the preparation for the finishing coat of plaster.","pos":""}],"BROWNISM":[{"def":"The views or teachings of Robert Brown of the Brownists.","pos":""}],"BROWNIST":[{"def":"A follower of Robert Brown, of England, in the 16th century, who taught that every church is complete and independent in itself when organized, and consists of members meeting in one place, having full power to elect and depose its officers.","pos":""}],"BROWNNESS":[{"def":"The quality or state of being brown.","pos":""}],"BROWNSTONE":[{"def":"A dark variety of sandstone, much used for building purposes.","pos":""}],"BROWNWORT":[{"def":"A species of figwort or Scrophularia (S.","pos":""}],"BROWNY":[{"def":"Brown or, somewhat brown.","pos":""}],"BROWPOST":[{"def":"A beam that goes across a building.","pos":""}],"BROWSE":[{"def":"The tender branches or twigs of trees and shrubs, fit for the food of cattle and other animals; green food.","pos":""}],"BROWSER":[{"def":"An animal that browses.","pos":""}],"BROWSEWOOD":[{"def":"Srubs and bushes upon which animals browse.","pos":""}],"BROWSING":[{"def":"Browse; also, a place abounding with shrubs where animals may browse.","pos":""}],"BROWSPOT":[{"def":"A rounded organ between the eyes of the frog; the interocular gland.","pos":""}]}