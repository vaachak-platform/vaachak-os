{"SOLICIT":[{"def":"To ask from with earnestness; to make petition to; to apply to for obtaining something; as, to solicit person for alms.","pos":""},{"def":"To endeavor to obtain; to seek; to plead for; as, to solicit an office; to solicit a favor.","pos":""}],"SOLICITANT":[{"def":"One who solicits.","pos":"noun"}],"SOLICITATION":[{"def":"The act of soliciting; earnest request; persistent asking; importunity.","pos":""},{"def":"Excitement; invitation; as, the solicitation of the senses.","pos":""}],"SOLICITOR":[{"def":"One who solicits.","pos":""}],"SOLICITOR-GENERAL":[{"def":"The second law officer in the government of Great Britain; also, a similar officer under the United States government, who is associated with the attorney-general; also, the chief law officer of some of the States.","pos":""}],"SOLICITOUS":[{"def":"Disposed to solicit; eager to obtain something desirable, or to avoid anything evil; concerned; anxious; careful.","pos":""}],"SOLICITRESS":[{"def":"A woman who solicits.","pos":""}],"SOLICITUDE":[{"def":"The state of being solicitous; uneasiness of mind occasioned by fear of evil or desire good; anxiety.","pos":""}],"SOLID":[{"def":"Having all the geometrical dimensions; cubic; as, a solid foot contains 1,728 solid inches.","pos":""},{"def":"Of a fleshy, uniform, undivided substance, as a bulb or root; not spongy or hollow within, as a stem.","pos":""}],"SOLID-DRAWN":[{"def":"Drawn out from a heated solid bar, as by a process of spiral rolling which first hollows the bar and then expands the cavity by forcing the bar over a pointed mandrel fixed in front of the rolls; - - said of a weldless tube.","pos":""}],"SOLIDAGO":[{"def":"A genus of yellow-flowered composite perennial herbs; golden- rod.","pos":""}],"SOLIDARE":[{"def":"A small piece of money.","pos":""}],"SOLIDARITY":[{"def":"An entire union or consolidation of interests and responsibilities; fellowship; community.","pos":""}],"SOLIDARY":[{"def":"Having community of interests and responsibilities.","pos":""}],"SOLIDATE":[{"def":"To make solid or firm.","pos":""}],"SOLIDIFIABLE":[{"def":"Capable of being solidified.","pos":""}],"SOLIDIFICATION":[{"def":"Act of solidifying, or state of being solidified.","pos":""}],"SOLIDIFY":[{"def":"To make solid or compact.","pos":""}],"SOLIDISM":[{"def":"The doctrine that refers all diseases to morbid changes of the solid parts of the body.","pos":""}],"SOLIDIST":[{"def":"An advocate of, or believer in, solidism.","pos":""}],"SOLIDITY":[{"def":"The solid contents of a body; volume; amount of inclosed space.","pos":""}],"SOLIDLY":[{"def":"In a solid manner; densely; compactly; firmly; truly.","pos":""}],"SOLIDNESS":[{"def":"State or quality of being solid; firmness; compactness; solidity, as of material bodies.","pos":""},{"def":"Soundness; strength; truth; validity, as of arguments, reasons, principles, and the like.","pos":""}],"SOLIDUNGULA":[{"def":"A tribe of ungulates which includes the horse, ass, and related species, constituting the family Equidæ.","pos":""}],"SOLIDUNGULATE":[{"def":"Same as Soliped.","pos":""}],"SOLIFIDIAN":[{"def":"One who maintains that faith alone, without works, is sufficient for justification; -- opposed to nullifidian.","pos":""}],"SOLIFIDIANISM":[{"def":"The state of Solifidians.","pos":""}],"SOLIFORM":[{"def":"Like the sun in form, appearance, or nature; resembling the sun.","pos":""}],"SOLIFUGAE":[{"def":"A division of arachnids having large, powerful fangs and a segmented abdomen; -- called also Solpugidea, and Solpugides.","pos":""}],"SOLILOQUIZE":[{"def":"To utter a soliloquy; to talk to one's self.","pos":""}],"SOLILOQUY":[{"def":"The act of talking to one's self; a discourse made by one in solitude to one's self; monologue.","pos":""},{"def":"A written composition, reciting what it is supposed a person says to himself.","pos":""}],"SOLIPED":[{"def":"A mammal having a single hoof on each foot, as the horses and asses; a solidungulate.","pos":""}],"SOLIPEDOUS":[{"def":"Having single hoofs.","pos":""}],"SOLISEQUIOUS":[{"def":"Following the course of the sun; as, solisequious plants.","pos":""}],"SOLITAIRE":[{"def":"A person who lives in solitude; a recluse; a hermit.","pos":""},{"def":"A single diamond in a setting; also, sometimes, a precious stone of any kind set alone.","pos":""}],"SOLITARIAN":[{"def":"A hermit; a solitary.","pos":""}],"SOLITARIETY":[{"def":"The state of being solitary; solitariness.","pos":""}],"SOLITARILY":[{"def":"In a solitary manner; in solitude; alone.","pos":""}],"SOLITARINESS":[{"def":"Condition of being solitary.","pos":""}],"SOLITARY":[{"def":"Not associated with others of the same kind.","pos":""}],"SOLITUDE":[{"def":"Remoteness from society; destitution of company; seclusion; -- said of places; as, the solitude of a wood.","pos":""}],"SOLIVAGANT":[{"def":"Wandering alone.","pos":""}]}