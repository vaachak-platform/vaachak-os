{"CYTHEREAN":[{"def":"Pertaining to the goddess Venus.","pos":""}],"CYTOBLAST":[{"def":"The nucleus of a cell; the germinal or active spot of a cellule, through or in which cell development takes place.","pos":""}],"CYTOBLASTEMA":[{"def":"Cy`to*blas*te\"ma (-bls-t\"m), n.","pos":""}],"CYTOCOCCUS":[{"def":"The nucleus of the cytula or parent cell.","pos":""}],"CYTODE":[{"def":"A nonnucleated mass of protoplasm, the supposed simplest form of independent life differing from the amoeba, in which nuclei are present.","pos":""}],"CYTOGENESIS":[{"def":"Development of cells in animal and vegetable organisms.","pos":""},{"def":"Of or pertaining to cytogenesis or cell development.","pos":""}],"CYTOGENOUS":[{"def":"Producing cells; -- applied esp.","pos":""}],"CYTOGENY":[{"def":"Cell production or development; cytogenesis.","pos":""}],"CYTOID":[{"def":"Cell-like; -- applied to the corpuscles of lymph, blood, chyle, etc.","pos":""}],"CYTOPLASM":[{"def":"The substance of the body of a cell, as distinguished from the karyoplasma, or substance of the nucleus.","pos":""}],"CYTULA":[{"def":"The fertilized egg cell or parent cell, from the development of which the child or other organism is formed.","pos":""}]}