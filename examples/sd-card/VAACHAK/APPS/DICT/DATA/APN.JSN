{"APNEUMATIC":[{"def":"Devoid of air; free from air; as, an apneumatic lung; also, effected by or with exclusion of air; as, an apneumatic operation.","pos":""}],"APNEUMONA":[{"def":"An order of holothurians in which the internal respiratory organs are wanting; -- called also Apoda or Apodes.","pos":""},{"def":"Partial privation or suspension of breath; suffocation.","pos":""}]}