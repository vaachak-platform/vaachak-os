{"VELAR":[{"def":"Having the place of articulation on the soft palate; guttural; as, the velar consonants, such as k and hard q.","pos":""}],"VELARIUM":[{"def":"The marginal membrane of certain medusæ belonging to the Discophora.","pos":""}],"VELATE":[{"def":"Having a veil; veiled.","pos":""}],"VELDT":[{"def":"A region or tract of land; esp.","pos":""}],"VELDT SORE":[{"def":"An infective sore mostly on the hands and feet, often contracted in walking on the veldt and apparently due to a specific microörganism.","pos":""}],"VELELLA":[{"def":"Any species of oceanic Siphonophora belonging to the genus Velella.","pos":""}],"VELIFEROUS":[{"def":"Carrying or bearing sails.","pos":""}],"VELIGER":[{"def":"Any larval gastropod or bivalve mollusk in the state when it is furnished with one or two ciliated membranes for swimming.","pos":""}],"VELITATION":[{"def":"A dispute or contest; a slight contest; a skirmish.","pos":""}],"VELIVOLANT":[{"def":"Flying with sails; passing under full sail.","pos":""}],"VELL":[{"def":"The salted stomach of a calf, used in making cheese; a rennet bag.","pos":""}],"VELLEITY":[{"def":"The lowest degree of desire; imperfect or incomplete volition.","pos":""}],"VELLICATE":[{"def":"To twitch; to cause to twitch convulsively.","pos":""}],"VELLICATION":[{"def":"A local twitching, or convulsive motion, of a muscular fiber, especially of the face.","pos":""}],"VELLICATIVE":[{"def":"Having the power of vellicating, plucking, or twitching; causing vellication.","pos":""}],"VELLON":[{"def":"A word occurring in the phrase real vellon.","pos":""}],"VELLUM":[{"def":"A fine kind of parchment, usually made from calfskin, and rendered clear and white, -- used as for writing upon, and for binding books.","pos":""}],"VELLUMY":[{"def":"Resembling vellum.","pos":""}],"VELOCIMETER":[{"def":"An apparatus for measuring speed, as of machinery or vessels, but especially of projectiles.","pos":""}],"VELOCIPEDE":[{"def":"A light road carriage propelled by the feet of the rider.","pos":""}],"VELOCIPEDIST":[{"def":"One who rides on a velocipede.","pos":""}],"VELOCITY":[{"def":"Rate of motion; the relation of motion to time, measured by the number of units of space passed over by a moving body or point in a unit of time, usually the number of feet passed over in a second.","pos":""}],"VELOURS":[{"def":"One of many textile fabrics having a pile like that of velvet.","pos":""},{"def":"A white sauce or stock made by boiling down ham, veal, beef, fowl, bouillon, etc.","pos":""}],"VELUM":[{"def":"Curtain or covering; -- applied to various membranous partitions, especially to the soft palate.","pos":""},{"def":"A veil-like organ or part.","pos":""}],"VELUTINA":[{"def":"Any one of several species of marine gastropods belonging to Velutina and allied genera.","pos":""}],"VELUTINOUS":[{"def":"Having the surface covered with a fine and dense silky pubescence; velvety; as, a velutinous leaf.","pos":""}],"VELVERET":[{"def":"A kind of velvet having cotton back.","pos":""}],"VELVET":[{"def":"A silk fabric, having a short, close nap of erect threads.","pos":""},{"def":"The soft and highly vascular deciduous skin which envelops and nourishes the antlers of deer during their rapid growth.","pos":""}],"VELVETEEN":[{"def":"A kind of cloth, usually cotton, made in imitation of velvet; cotton velvet.","pos":""}],"VELVETING":[{"def":"The fine shag or nap of velvet; a piece of velvet; velvet goods.","pos":""}],"VELVETLEAF":[{"def":"A name given to several plants which have soft, velvety leaves, as the Abutilon Avicennæ, the Cissampelos Pareira, and the Lavatera arborea, and even the common mullein.","pos":""}],"VELVETY":[{"def":"Made of velvet, or like velvet; soft; smooth; delicate.","pos":""}]}