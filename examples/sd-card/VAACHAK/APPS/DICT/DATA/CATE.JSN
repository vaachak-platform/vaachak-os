{"CATE":[{"def":"Relating to or consisting in, asking questions and receiving answers, according to the ancient manner of teaching.","pos":""}],"CATECHETICALLY":[{"def":"In a catechetical manner; by question and answer.","pos":""}],"CATECHETICS":[{"def":"The science or practice of instructing by questions and answers.","pos":""}],"CATECHIN":[{"def":"One of the tannic acids, extracted from catechu as a white, crystaline substance; -- called also catechuic acid, and catechuin.","pos":""}],"CATECHISATION":[{"def":"The act of catechising.","pos":""}],"CATECHISE":[{"def":"To instruct by asking questions, receiving answeres, and offering explanations and corrections, -- esp.","pos":""},{"def":"To question or interrogate; to examine or try by questions; -- sometimes with a view to reproof, by eliciting from a person answers which condemn his own conduct.","pos":""}],"CATECHISER":[{"def":"One who catechises.","pos":""}],"CATECHISM":[{"def":"A form of instruction by means of questions answers.","pos":""},{"def":"A book containing a summary of principles, especially of religious doctrine, reduced to the form of questions and answers.","pos":""}],"CATECHISMAL":[{"def":"Of or pertaining to a catechism, having the form of questions and answers; catechical.","pos":""}],"CATECHIST":[{"def":"One who instructs by question and answer, especially in religions matters.","pos":""},{"def":"Of or pertaining to a catechist or to a catechism.","pos":""}],"CATECHU":[{"def":"A dry, brown, astringent extract, obtained by decoction and evaporation from the Acacia catechu, and several other plants growing in India.","pos":""}],"CATECHUIC":[{"def":"Of or pertaining to catechu or its derivatives.","pos":""}],"CATECHUMEN":[{"def":"One who is receiving rudimentary instruction in the doctrines of Christianity; a neophyte; in the primitive church, one officially recognized as a Christian, and admitted to instruction preliminary to admission to full membership in the church.","pos":""}],"CATECHUMENATE":[{"def":"The state or condition of a catechumen or the time during which one is a catechumen.","pos":""}],"CATECHUMENICAL":[{"def":"Of or pertaining to catechumens; as, catechumenical instructions.","pos":""}],"CATEGOREMATIC":[{"def":"Capable of being employed by itself as a term; -- said of a word.","pos":""}],"CATEGORICAL":[{"def":"Of or pertaining to a category.","pos":""},{"def":"Not hypothetical or relative; admitting no conditions or exceptions; declarative; absolute; positive; express; as, a categorical proposition, or answer.","pos":""}],"CATEGORICALLY":[{"def":"Absolutely; directly; expressly; positively; as, to affirm categorically.","pos":""}],"CATEGORICALNESS":[{"def":"The quality of being categorical, positive, or absolute.","pos":""}],"CATEGORIST":[{"def":"One who inserts in a category or list; one who classifies.","pos":""}],"CATEGORIZE":[{"def":"To insert in a category or list; to class; to catalogue.","pos":""}],"CATEGORY":[{"def":"One of the highest classes to which the objects of knowledge or thought can be reduced, and by which they can be arranged in a system; an ultimate or undecomposable conception; a predicament.","pos":""}],"CATEL":[{"def":"Property; -- often used by Chaucer in contrast with rent, or income.","pos":""}],"CATELECTRODE":[{"def":"The negative electrode or pole of a voltaic battery.","pos":""}],"CATELECTROTONIC":[{"def":"Relating to, or characterized by, catelectrotonus.","pos":""}],"CATELECTROTONUS":[{"def":"The condition of increased irritability of a nerve in the region of the cathode or negative electrode, on the passage of a current of electricity through it.","pos":""}],"CATENA":[{"def":"A chain or series of things connected with each other.","pos":""},{"def":"Relating to a chain; like a chain; as, a catenary curve.","pos":""}],"CATENARY":[{"def":"The curve formed by a rope or chain of uniform density and perfect flexibility, hanging freely between two points of suspension, not in the same vertical line.","pos":""}],"CATENATE":[{"def":"To connect, in a series of links or ties; to chain.","pos":""}],"CATENATION":[{"def":"Connection of links or union of parts, as in a chain; a regular or connected series.","pos":""}],"CATENULATE":[{"def":"Chainlike; -- said both or color marks and of indentations when arranged like the links of a chain, as on shells, etc.","pos":""}],"CATER":[{"def":"A provider; a purveyor; a caterer.","pos":""}],"CATER-COUSIN":[{"def":"A remote relation.","pos":""}],"CATERAN":[{"def":"A Highland robber: a kind of irregular soldier.","pos":""}],"CATERER":[{"def":"The little fowls in the air have God for Their provider and caterer.","pos":""}],"CATERESS":[{"def":"A woman who caters.","pos":""}],"CATERPILLAR":[{"def":"The larval state of a butterfly or any lepidopterous insect; sometimes, but less commonly, the larval state of other insects, as the sawflies, which are also called false caterpillars.","pos":""},{"def":"A plant of the genus Scorpiurus, with pods resembling caterpillars.","pos":""}],"CATERWAUL":[{"def":"To cry as cats in rutting time; to make a harsh, offensive noise.","pos":""}],"CATERWAULING":[{"def":"The cry of cats; a harsh, disagreeable noise or cry like the cry of cats.","pos":""}],"CATERY":[{"def":"The place where provisions are deposited.","pos":""}],"CATES":[{"def":"Provisions; food; viands; especially, luxurious food; delicacies; dainties.","pos":""}]}