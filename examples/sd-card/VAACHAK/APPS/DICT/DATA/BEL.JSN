{"BEL":[{"def":"The Babylonian name of the god known among the Hebrews as Baal.","pos":""}],"BEL-ACCOYLE":[{"def":"A kind or favorable reception or salutation.","pos":""}],"BEL-ESPRIT":[{"def":"A fine genius, or man of wit.","pos":""}],"BELABOR":[{"def":"To ply diligently; to work carefully upon.","pos":""},{"def":"To beat soundly; to cudgel.","pos":""}],"BELACE":[{"def":"To fasten, as with a lace or cord.","pos":""},{"def":"To cover or adorn with lace.","pos":""}],"BELAM":[{"def":"To beat or bang.","pos":""}],"BELAMOUR":[{"def":"A flower, but of what kind is unknown.","pos":""}],"BELAMY":[{"def":"Good friend; dear friend.","pos":""}],"BELATE":[{"def":"To retard or make too late.","pos":""}],"BELATED":[{"def":"Delayed beyond the usual time; too late; overtaken by night; benighted.","pos":""}],"BELAUD":[{"def":"To laud or praise greatly.","pos":""}],"BELAY":[{"def":"To make fast, as a rope, by taking several turns with it round a pin, cleat, or kevel.","pos":""}],"BELAYING PIN":[{"def":"A strong pin in the side of a vessel, or by the mast, round which ropes are wound when they are fastened or belayed.","pos":""}],"BELCH":[{"def":"To eject or throw up from the stomach with violence; to eruct.","pos":""},{"def":"To eject violently from within; to cast forth; to emit; to give vent to; to vent.","pos":""}],"BELCHER":[{"def":"One who, or that which, belches.","pos":""}],"BELEAGUER":[{"def":"To surround with an army so as to preclude escape; to besiege; to blockade.","pos":""}],"BELEAGUERER":[{"def":"One who beleaguers.","pos":""}],"BELEAVE":[{"def":"To leave or to be left.","pos":""}],"BELECTURE":[{"def":"To vex with lectures; to lecture frequently.","pos":""}],"BELEE":[{"def":"To place under the lee, or unfavorably to the wind.","pos":""}],"BELEMNITE":[{"def":"A conical calcareous fossil, tapering to a point at the lower extremity, with a conical cavity at the other end, where it is ordinarily broken; but when perfect it contains a small chambered cone, called the phragmocone, prolonged, on one side, into a delicate concave blade; the thunderstone.","pos":""}],"BELEPER":[{"def":"To infect with leprosy.","pos":""}],"BELFRY":[{"def":"A movable tower erected by besiegers for purposes of attack and defense.","pos":""},{"def":"The framing on which a bell is suspended.","pos":""}],"BELGARD":[{"def":"A sweet or loving look.","pos":""}],"BELGIAN":[{"def":"Of or pertaining to Belgium.","pos":""},{"def":"A native or inhabitant of Belgium.","pos":""}],"BELGIAN BLOCK":[{"def":"A nearly cubical block of some tough stone, esp.","pos":""}],"BELGIC":[{"def":"Of or pertaining to the Belgæ, a German tribe who anciently possessed the country between the Rhine, the Seine, and the ocean.","pos":""},{"def":"Of or pertaining to the Netherlands or to Belgium.","pos":""}],"BELGRAVIAN":[{"def":"Belonging to Belgravia (a fashionable quarter of London, around Pimlico), or to fashionable life; aristocratic.","pos":""}],"BELIAL":[{"def":"An evil spirit; a wicked and unprincipled person; the personification of evil.","pos":""}],"BELIBEL":[{"def":"To libel or traduce; to calumniate.","pos":""}],"BELIE":[{"def":"To show to be false; to convict of, or charge with, falsehood.","pos":""},{"def":"To give a false representation or account of.","pos":""}],"BELIEF":[{"def":"A persuasion of the truths of religion; faith.","pos":""}],"BELIEFFUL":[{"def":"Having belief or faith.","pos":""}],"BELIEVABLE":[{"def":"Capable of being believed; credible.","pos":""}],"BELIEVE":[{"def":"Our conqueror (whom I now Of force believe almighty).","pos":""}],"BELIEVER":[{"def":"One who gives credit to the truth of the Scriptures, as a revelation from God; a Christian; -- in a more restricted sense, one who receives Christ as his Savior, and accepts the way of salvation unfolded in the gospel.","pos":""},{"def":"One who was admitted to all the rights of divine worship and instructed in all the mysteries of the Christian religion, in distinction from a catechumen, or one yet under instruction.","pos":""}],"BELIEVING":[{"def":"That believes; having belief.","pos":""}],"BELIKE":[{"def":"It is likely or probably; perhaps.","pos":""}],"BELIME":[{"def":"To besmear or insnare with birdlime.","pos":""}],"BELITTLE":[{"def":"To make little or less in a moral sense; to speak of in a depreciatory or contemptuous way.","pos":""}],"BELIVE":[{"def":"Forthwith; speedily; quickly.","pos":""}],"BELL":[{"def":"That part of the capital of a column included between the abacus and neck molding; also used for the naked core of nearly cylindrical shape, assumed to exist within the leafage of a capital.","pos":""},{"def":"The strikes of the bell which mark the time; or the time so designated.","pos":""}],"BELL ANIMALCULE":[{"def":"An infusorian of the family Vorticellidæ, common in fresh-water ponds.","pos":""}],"BELL BEARER":[{"def":"A Brazilian leaf hopper (Bocydium tintinnabuliferum), remarkable for the four bell-shaped appendages of its thorax.","pos":""}],"BELL CRANK":[{"def":"A lever whose two arms form a right angle, or nearly a right angle, having its fulcrum at the apex of the angle.","pos":""}],"BELL JAR":[{"def":"A glass vessel, varying in size, open at the bottom and closed at the top like a bell, and having a knob or handle at the top for lifting it.","pos":""}],"BELL METAL":[{"def":"A hard alloy or bronze, consisting usually of about three parts of copper to one of tin; -- used for making bells.","pos":""}],"BELL PEPPER":[{"def":"A species of Capsicum, or Guinea pepper (C.","pos":""}],"BELL PROCESS":[{"def":"The process of washing molten pig iron by adding iron oxide, proposed by I.","pos":""}],"BELL SYSTEM OF CONTROL":[{"def":"Bell system of control.","pos":""}],"BELL'S PALSY":[{"def":"Paralysis of the facial nerve, producing distortion of one side of the face.","pos":""}],"BELL-FACED":[{"def":"Having the striking surface convex; -- said of hammers.","pos":""}],"BELL-MOUTHED":[{"def":"Expanding at the mouth; as, a bell-mouthed gun.","pos":""}],"BELL-SHAPED":[{"def":"Having the shape of a widemouthed bell; campanulate.","pos":""}],"BELLARMINE":[{"def":"A stoneware jug of a pattern originated in the neighborhood of Cologne, Germany, in the 16th century.","pos":""}],"BELLBIRD":[{"def":"Cotingidæ, of several species; the campanero.","pos":""}],"BELLE":[{"def":"A young lady of superior beauty and attractions; a handsome lady, or one who attracts notice in society; a fair lady.","pos":""}],"BELLE-LETTRIST":[{"def":"One versed in belleslettres.","pos":""}],"BELLED":[{"def":"Hung with a bell or bells.","pos":""}],"BELLEEK WARE":[{"def":"A porcelainlike kind of decorative pottery with a high gloss, which is sometimes iridescent.","pos":""}],"BELLEROPHON":[{"def":"A genus of fossil univalve shells, believed to belong to the Heteropoda, peculiar to the Paleozoic age.","pos":""}],"BELLES-LETTRES":[{"def":"Polite or elegant literature; the humanities; -- used somewhat vaguely for literary works in which imagination and taste are predominant.","pos":""},{"def":"Occupied with, or pertaining to, belles-lettres.","pos":""}],"BELLFLOWER":[{"def":"A plant of the genus Campanula; -- so named from its bell- shaped flowers.","pos":""}],"BELLIBONE":[{"def":"A woman excelling both in beauty and goodness; a fair maid.","pos":""},{"def":"Of or pertaining to war; warlike; martial.","pos":""}],"BELLICOSE":[{"def":"Inclined to war or contention; warlike; pugnacious.","pos":""}],"BELLICOSELY":[{"def":"In a bellicose manner.","pos":""}],"BELLIED":[{"def":"The quality of being belligerent; act or state of making war; warfare.","pos":""}],"BELLIGERENT":[{"def":"Waging war; carrying on war.","pos":""},{"def":"Pertaining, or tending, to war; of or relating to belligerents; as, a belligerent tone; belligerent rights.","pos":""}],"BELLIGERENTLY":[{"def":"In a belligerent manner; hostilely.","pos":""}],"BELLING":[{"def":"A bellowing, as of a deer in rutting time.","pos":""}],"BELLIPOTENT":[{"def":"Mighty in war; armipotent.","pos":""}],"BELLMAN":[{"def":"A man who rings a bell, especially to give notice of anything in the streets.","pos":""}],"BELLONA":[{"def":"The goddess of war.","pos":""}],"BELLOW":[{"def":"To make a hollow, loud noise, as an enraged bull.","pos":""},{"def":"To bowl; to vociferate; to clamor.","pos":""}],"BELLOWER":[{"def":"One who, or that which, bellows.","pos":""}],"BELLOWS":[{"def":"An instrument, utensil, or machine, which, by alternate expansion and contraction, or by rise and fall of the top, draws in air through a valve and expels it through a tube for various purposes, as blowing fires, ventilating mines, or filling the pipes of an organ with wind.","pos":""}],"BELLOWS FISH":[{"def":"A European fish (Centriscus scolopax), distinguished by a long tubular snout, like the pipe of a bellows; -- called also trumpet fish, and snipe fish.","pos":""}],"BELLUINE":[{"def":"Pertaining to, or like, a beast; brutal.","pos":""}],"BELLWETHER":[{"def":"A wether, or sheep, which leads the flock, with a bell on his neck.","pos":""},{"def":"Hence: A leader.","pos":""}],"BELLWORT":[{"def":"A genus of plants (Uvularia) with yellowish bell-shaped flowers.","pos":""}],"BELLY":[{"def":"The hollow part of a curved or bent timber, the convex part of which is the back.","pos":""}],"BELLY-GOD":[{"def":"One whose great pleasure it is to gratify his appetite; a glutton; an epicure.","pos":""}],"BELLY-PINCHED":[{"def":"Pinched with hunger; starved.","pos":""}],"BELLYACHE":[{"def":"Pain in the bowels; colic.","pos":""}],"BELLYBAND":[{"def":"A band of canvas, to strengthen a sail.","pos":""}],"BELLYBOUND":[{"def":"Costive; constipated.","pos":""}],"BELLYCHEAT":[{"def":"An apron or covering for the front of the person.","pos":""}],"BELLYCHEER":[{"def":"Good cheer; viands.","pos":""}],"BELLYFUL":[{"def":"As much as satisfies the appetite.","pos":""}],"BELOCK":[{"def":"To lock, or fasten as with a lock.","pos":""}],"BELOMANCY":[{"def":"A kind of divination anciently practiced by means of marked arrows drawn at random from a bag or quiver, the marks on the arrows drawn being supposed to foreshow the future.","pos":""}],"BELONG":[{"def":"To be the property of; as, Jamaica belongs to Great Britain.","pos":""},{"def":"To be a part of, or connected with; to be appendant or related; to owe allegiance or service.","pos":""}],"BELONGING":[{"def":"That which belongs to one; that which pertains to one; hence, goods or effects.","pos":""},{"def":"That which is connected with a principal or greater thing; an appendage; an appurtenance.","pos":""}],"BELONITE":[{"def":"Minute acicular or dendritic crystalline forms sometimes observed in glassy volcanic rocks.","pos":""},{"def":"Of or pertaining to Beloochistan, or to its inhabitants.","pos":""}],"BELORD":[{"def":"To act the lord over.","pos":""},{"def":"To address by the title of \"lord\".","pos":""}],"BELOVED":[{"def":"Greatly loved; dear to the heart.","pos":""}],"BELOW":[{"def":"Under, or lower in place; beneath not so high; as, below the moon; below the knee.","pos":""},{"def":"Inferior to in rank, excellence, dignity, value, amount, price, etc.","pos":""}],"BELOWT":[{"def":"To treat as a lout; to talk abusively to.","pos":""}],"BELSIRE":[{"def":"A grandfather, or ancestor.","pos":""}],"BELSWAGGER":[{"def":"A lewd man; also, a bully.","pos":""}],"BELT":[{"def":"Same as Band, n.","pos":""},{"def":"One of certain girdles or zones on the surface of the planets Jupiter and Saturn, supposed to be of the nature of clouds.","pos":""}],"BELTANE":[{"def":"The first day of May (Old Style).","pos":""},{"def":"A festival of the heathen Celts on the first day of May, in the observance of which great bonfires were kindled.","pos":""}],"BELTED":[{"def":"Encircled by, or secured with, a belt; as, a belted plaid; girt with a belt, as an honorary distinction; as, a belted knight; a belted earl.","pos":""},{"def":"Marked with a band or circle; as, a belted stalk.","pos":""}],"BELTING":[{"def":"The material of which belts for machinery are made; also, belts, taken collectively.","pos":""}],"BELUGA":[{"def":"A cetacean allied to the dolphins.","pos":""}],"BELUTE":[{"def":"To bespatter, as with mud.","pos":""}],"BELVEDERE":[{"def":"A small building, or a part of a building, more or less open, constructed in a place commanding a fine prospect.","pos":""}],"BELZEBUTH":[{"def":"A spider monkey (Ateles belzebuth) of Brazil.","pos":""}]}