{"UNQUALIFY":[{"def":"To disqualify; to unfit.","pos":""}],"UNQUALITIED":[{"def":"Deprived of the usual faculties.","pos":""}],"UNQUEEN":[{"def":"To divest of the rank or authority of queen.","pos":""}],"UNQUESTIONABLE":[{"def":"Not questionable; as, an unquestionable title.","pos":""},{"def":"Not inviting questions or conversation.","pos":""}],"UNQUESTIONED":[{"def":"Not called in question; not doubted.","pos":""},{"def":"Not interrogated; having no questions asked; not examined or examined into.","pos":""}],"UNQUIET":[{"def":"Not quiet; restless; uneasy; agitated; disturbed.","pos":""}],"UNQUIETUDE":[{"def":"Uneasiness; inquietude.","pos":""}]}