{"HEAL":[{"def":"To cover, as a roof, with tiles, slate, lead, or the like.","pos":""}],"HEALABLE":[{"def":"Capable of being healed.","pos":""}],"HEALALL":[{"def":"A common herb of the Mint family (Brunela vulgaris), destitute of active properties, but anciently thought a panacea.","pos":""}],"HEALER":[{"def":"One who, or that which, heals.","pos":""}],"HEALFUL":[{"def":"Tending or serving to heal; healing.","pos":""}],"HEALING":[{"def":"Tending to cure; soothing; mollifying; as, the healing art; a healing salve; healing words.","pos":""}],"HEALINGLY":[{"def":"So as to heal or cure.","pos":""}],"HEALTH":[{"def":"The state of being hale, sound, or whole, in body, mind, or soul; especially, the state of being free from physical disease or pain.","pos":""},{"def":"A wish of health and happiness, as in pledging a person in a toast.","pos":""}],"HEALTHFUL":[{"def":"Full of health; free from illness or disease; well; whole; sound; healthy; as, a healthful body or mind; a healthful plant.","pos":""},{"def":"Serving to promote health of body or mind; wholesome; salubrious; salutary; as, a healthful air, diet.","pos":""}],"HEALTHFULLY":[{"def":"In health; wholesomely.","pos":""}],"HEALTHFULNESS":[{"def":"The state of being healthful.","pos":""}],"HEALTHILY":[{"def":"In a healthy manner.","pos":""}],"HEALTHINESS":[{"def":"The state of being healthy or healthful; freedom from disease.","pos":""}],"HEALTHLESS":[{"def":"Without health, whether of body or mind; in firm.","pos":""},{"def":"Not conducive to health; unwholesome.","pos":""}],"HEALTHSOME":[{"def":"Wholesome; salubrious.","pos":""}],"HEALTHWARD":[{"def":"In the direction of health; as, a healthward tendency.","pos":""}],"HEALTHY":[{"def":"Being in a state of health; enjoying health; hale; sound; free from disease; as, a healthy chid; a healthy plant.","pos":""},{"def":"Evincing health; as, a healthy pulse; a healthy complexion.","pos":""}]}