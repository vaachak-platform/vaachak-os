{"TRISACRAMENTARIAN":[{"def":"One who recognizes three sacraments, and no more; -- namely, baptism, the Lord's Supper, and penance.","pos":""}],"TRISAGION":[{"def":"An ancient anthem, -- usually known by its Latin name tersanctus.","pos":""}],"TRISECT":[{"def":"To cut or divide into three equal parts.","pos":""}],"TRISECTED":[{"def":"Divided into three parts or segments by incisions extending to the midrib or to the base; -- said of leaves.","pos":""}],"TRISECTION":[{"def":"The division of a thing into three parts, Specifically: (Geom.","pos":""}],"TRISERALOUS":[{"def":"Having three sepals, or calyx leaves.","pos":""},{"def":"Arranged in three vertical or spiral rows.","pos":""}],"TRISNITRATE":[{"def":"A nitrate formed from three molecules of nitric acid; also, less properly, applied to certain basic nitrates; as, trisnitrate of bismuth.","pos":""}],"TRISOCTAHEDRON":[{"def":"A solid of the isometric system bounded by twenty-four equal faces, three corresponding to each face of an octahedron.","pos":""},{"def":"A machine with three pulleys which act together for raising great weights.","pos":""}],"TRISPERMOUS":[{"def":"Containing three seeds; three-seeded; as, a trispermous capsule.","pos":""}],"TRISPLANCHNIC":[{"def":"Of or pertaining to the three great splanchnic cavities, namely, that of the head, the chest, and the abdomen; -- applied to the sympathetic nervous system.","pos":""}],"TRIST":[{"def":"A post, or station, in hunting.","pos":""}],"TRISTFUL":[{"def":"Sad; sorrowful; gloomy.","pos":""}],"TRISTFULLY":[{"def":"In a tristful manner; sadly.","pos":""}],"TRISTICHOUS":[{"def":"Arranged in three vertical rows.","pos":""},{"def":"Having, or consisting of, three stigmas.","pos":""}],"TRISTOMA":[{"def":"Any one of numerous species of trematode worms belonging to Tristoma and allied genera having a large posterior sucker and two small anterior ones.","pos":""}],"TRISULC":[{"def":"Something having three forks or prongs, as a trident.","pos":""}],"TRISULCATE":[{"def":"Having three furrows, forks, or prongs; having three grooves or sulci; three-grooved.","pos":""}],"TRISULPHIDE":[{"def":"A sulphide containing three atoms of sulphur.","pos":""},{"def":"Of or pertaining to a trisyllable; consisting of three syllables; as, \"syllable\" is a trisyllabic word.","pos":""}],"TRISYLLABLE":[{"def":"A word consisting of three syllables only; as, a-ven-ger.","pos":""}]}