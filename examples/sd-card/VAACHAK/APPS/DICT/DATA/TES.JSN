{"TESSELAR":[{"def":"Formed of tesseræ, as a mosaic.","pos":""}],"TESSELLATA":[{"def":"A division of Crinoidea including numerous fossil species in which the body is covered with tessellated plates.","pos":""}],"TESSELLATE":[{"def":"To form into squares or checkers; to lay with checkered work.","pos":""}],"TESSELLATED":[{"def":"Marked like a checkerboard; as, a tessellated leaf.","pos":""}],"TESSELLATION":[{"def":"The act of tessellating; also, the mosaic work so formed.","pos":""}],"TESSERA":[{"def":"A small piece of marble, glass, earthenware, or the like, having a square, or nearly square, face, used by the ancients for mosaic, as for making pavements, for ornamenting walls, and like purposes; also, a similar piece of ivory, bone, wood, etc.","pos":""}],"TESSERAIC":[{"def":"Diversified by squares; done in mosaic; tessellated.","pos":""}],"TESSERAL":[{"def":"Of, pertaining to, or containing, tesseræ.","pos":""}],"TEST":[{"def":"A cupel or cupelling hearth in which precious metals are melted for trial and refinement.","pos":""}],"TESTABLE":[{"def":"Capable of being tested or proved.","pos":""},{"def":"Capable of being devised, or given by will.","pos":""}],"TESTACEA":[{"def":"Invertebrate animals covered with shells, especially mollusks; shellfish.","pos":""}],"TESTACEAN":[{"def":"Onr of the Testacea.","pos":""}],"TESTACEOGRAPHY":[{"def":"The science which treats of testaceans, or shellfish; the description of shellfish.","pos":""}],"TESTACEOLOGY":[{"def":"The science of testaceous mollusks; conchology.","pos":""}],"TESTACEOUS":[{"def":"Having a dull red brick color or a brownish yellow color.","pos":""}],"TESTACY":[{"def":"The state or circumstance of being testate, or of leaving a valid will, or testament, at death.","pos":""}],"TESTAMENT":[{"def":"A solemn, authentic instrument in writing, by which a person declares his will as to disposal of his estate and effects after his death.","pos":""}],"TESTAMENTAL":[{"def":"Of or pertaining to a testament; testamentary.","pos":""}],"TESTAMENTARY":[{"def":"Of or pertaining to a will, or testament; as, letters testamentary.","pos":""},{"def":"Bequeathed by will; given by testament.","pos":""}],"TESTAMENTATION":[{"def":"The act or power of giving by testament, or will.","pos":""}],"TESTAMUR":[{"def":"A certificate of merit or proficiency; -- so called from the Latin words, Ita testamur, with which it commences.","pos":""}],"TESTATE":[{"def":"Having made and left a will; as, a person is said to die testate.","pos":""}],"TESTATION":[{"def":"A witnessing or witness.","pos":""}],"TESTATOR":[{"def":"A man who makes and leaves a will, or testament, at death.","pos":""}],"TESTATRIX":[{"def":"A woman who makes and leaves a will at death; a female testator.","pos":""}],"TESTER":[{"def":"A headpiece; a helmet.","pos":""},{"def":"A flat canopy, as over a pulpit or tomb.","pos":""}],"TESTERN":[{"def":"A sixpence; a tester.","pos":""}],"TESTICARDINES":[{"def":"A division of brachiopods including those which have a calcareous shell furnished with a hinge and hinge teeth.","pos":""}],"TESTICLE":[{"def":"One of the essential male genital glands which secrete the semen.","pos":""}],"TESTICOND":[{"def":"Having the testicles naturally concealed, as in the case of the cetaceans.","pos":""}],"TESTICULAR":[{"def":"Of or pertaining to the testicle.","pos":""}],"TESTIERE":[{"def":"A piece of plate armor for the head of a war horse; a tester.","pos":""}],"TESTIF":[{"def":"Testy; headstrong; obstinate.","pos":""}],"TESTIFICATION":[{"def":"The act of testifying, or giving testimony or evidence; as, a direct testification of our homage to God.","pos":""}],"TESTIFIER":[{"def":"One who testifies; one who gives testimony, or bears witness to prove anything; a witness.","pos":""}],"TESTIFY":[{"def":"To make a solemn declaration under oath or affirmation, for the purpose of establishing, or making proof of, some fact to a court; to give testimony in a cause depending before a tribunal.","pos":""}],"TESTIMONIAL":[{"def":"A writing or certificate which bears testimony in favor of one's character, good conduct, ability, etc.","pos":""},{"def":"Something, as money or plate, presented to a preson as a token of respect, or of obligation for services rendered.","pos":""}],"TESTIMONY":[{"def":"The two tables of the law.","pos":""}],"TESTINESS":[{"def":"The quality or state of being testy; fretfulness; petulance.","pos":""}],"TESTING":[{"def":"The operation of refining gold or silver in a test, or cupel; cupellation.","pos":""}],"TESTON":[{"def":"A tester; a sixpence.","pos":""}],"TESTONE":[{"def":"A silver coin of Portugal, worth about sixpence sterling, or about eleven cents.","pos":""}],"TESTOON":[{"def":"An Italian silver coin.","pos":""}],"TESTUDINAL":[{"def":"Of, pertaining to, or resembling, a tortoise.","pos":""}],"TESTUDINARIOUS":[{"def":"Of or pertaining to the shell of a tortoise; resembling a tortoise shell; having the color or markings of a tortoise shell.","pos":""}],"TESTUDINATA":[{"def":"An order of reptiles which includes the turtles and tortoises.","pos":""},{"def":"Resembling a tortoise shell in appearance or structure; roofed; arched; vaulted.","pos":""}],"TESTUDINEOUS":[{"def":"Resembling the shell of a tortoise.","pos":""}],"TESTUDO":[{"def":"A genus of tortoises which formerly included a large number of diverse forms, but is now restricted to certain terrestrial species, such as the European land tortoise (Testudo Græca) and the gopher of the Southern United States.","pos":""},{"def":"A cover or screen which a body of troops formed with their shields or targets, by holding them over their heads when standing close to each other.","pos":""}],"TESTY":[{"def":"Fretful; peevish; petulant; easily irritated.","pos":""}]}