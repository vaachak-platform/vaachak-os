{"ECHAUGUETTE":[{"def":"A small chamber or place of protection for a sentinel, usually in the form of a projecting turret, or the like.","pos":""}],"ECHELON":[{"def":"An arrangement of a body of troops when its divisions are drawn up in parallel lines each to the right or the left of the one in advance of it, like the steps of a ladder in position for climbing.","pos":""},{"def":"An arrangement of a fleet in a wedge or Encyc.","pos":""}],"ECHIDNA":[{"def":"A monster, half maid and half serpent.","pos":""},{"def":"A genus of Monotremata found in Australia, Tasmania, and New Guinea.","pos":""}],"ECHIDNINE":[{"def":"The clear, viscid fluid secreted by the poison glands of certain serpents; also, a nitrogenous base contained in this, and supposed to be the active poisonous principle of the virus.","pos":""},{"def":"Set with prickles; prickly, like a hedgehog; bristled; as, an echinated pericarp.","pos":""}],"ECHINID":[{"def":"Same as Echinoid.","pos":""}],"ECHINIDAN":[{"def":"One the Echinoidea.","pos":""}],"ECHINITAL":[{"def":"Of, or like, an echinite.","pos":""}],"ECHINITE":[{"def":"A fossil echinoid.","pos":""}],"ECHINOCOCCUS":[{"def":"A parasite of man and of many domestic and wild animals, forming compound cysts or tumors (called hydatid cysts) in various organs, but especially in the liver and lungs, which often cause death.","pos":""}],"ECHINODERM":[{"def":"One of the Echinodermata.","pos":""}],"ECHINODERMAL":[{"def":"Relating or belonging to the echinoderms.","pos":""}],"ECHINODERMATA":[{"def":"One of the grand divisions of the animal kingdom.","pos":""}],"ECHINODERMATOUS":[{"def":"Relating to Echinodermata; echinodermal.","pos":""}],"ECHINOID":[{"def":"Of or pertaining to the Echinoidea.","pos":""},{"def":"One of the Echinoidea.","pos":""}],"ECHINOIDEA":[{"def":"The class Echinodermata which includes the sea urchins.","pos":""}],"ECHINOZOA":[{"def":"The Echinodermata.","pos":""}],"ECHINULATE":[{"def":"Set with small spines or prickles.","pos":""}],"ECHINUS":[{"def":"A genus of echinoderms, including the common edible sea urchin of Europe.","pos":""}],"ECHIUROIDEA":[{"def":"A division of Annelida which includes the genus Echiurus and allies.","pos":""}],"ECHO":[{"def":"A nymph, the daughter of Air and Earth, who, for love of Narcissus, pined away until nothing was left of her but her voice.","pos":""}],"ECHOER":[{"def":"One who, or that which, echoes.","pos":""}],"ECHOLESS":[{"def":"Without echo or response.","pos":""}],"ECHOMETER":[{"def":"A graduated scale for measuring the duration of sounds, and determining their different, and the relation of their intervals.","pos":""}],"ECHOMETRY":[{"def":"The art of measuring the duration of sounds or echoes.","pos":""},{"def":"The art of constructing vaults to produce echoes.","pos":""}],"ECHOPATHY":[{"def":"A morbid condition characterized by automatic and purposeless repetition of words or imitation of actions.","pos":""}],"ECHOSCOPE":[{"def":"An instrument for intensifying sounds produced by percussion of the thorax.","pos":""}]}