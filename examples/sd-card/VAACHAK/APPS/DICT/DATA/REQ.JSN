{"REQUERE":[{"def":"Re*quere\" (r--kwr\"), v.","pos":""}],"REQUEST":[{"def":"The act of asking for anything desired; expression of desire or demand; solicitation; prayer; petition; entreaty.","pos":""},{"def":"That which is asked for or requested.","pos":""}],"REQUESTER":[{"def":"One who requests; a petitioner.","pos":""}],"REQUICKEN":[{"def":"To quicken anew; to reanimate; to give new life to.","pos":""}],"REQUIEM":[{"def":"A mass said or sung for the repose of a departed soul.","pos":""}],"REQUIETORY":[{"def":"Re*qui\"e*to*ry (r-kw\"-t-r), n.","pos":""}],"REQUIN":[{"def":"The man-eater, or white shark (Carcharodon carcharias); -- so called on account of its causing requiems to be sung.","pos":""}],"REQUIRABLE":[{"def":"Capable of being required; proper to be required.","pos":""}],"REQUIRE":[{"def":"To demand; to insist upon having; to claim as by right and authority; to exact; as, to require the surrender of property.","pos":""},{"def":"To demand or exact as indispensable; to need.","pos":""}],"REQUIREMENT":[{"def":"The act of requiring; demand; requisition.","pos":""},{"def":"That which is required; an imperative or authoritative command; an essential condition; something needed or necessary; a need.","pos":""}],"REQUIRER":[{"def":"One who requires.","pos":""}],"REQUISITE":[{"def":"That which is required, or is necessary; something indispensable.","pos":""}],"REQUISITION":[{"def":"A formal demand made by one state or government upon another for the surrender or extradition of a fugitive from justice.","pos":"noun"}],"REQUISITIONIST":[{"def":"One who makes or signs a requisition.","pos":""}],"REQUISITIVE":[{"def":"Expressing or implying demand.","pos":""}],"REQUISITOR":[{"def":"One who makes reqisition; esp.","pos":""}],"REQUISITORY":[{"def":"Sought for; demanded.","pos":""}],"REQUITABLE":[{"def":"That may be requited.","pos":""}],"REQUITAL":[{"def":"The act of requiting; also, that which requites; return, good or bad, for anything done; in a good sense, compensation; recompense; as, the requital of services; in a bad sense, retaliation, or punishment; as, the requital of evil deeds.","pos":""}],"REQUITE":[{"def":"To repay; in a good sense, to recompense; to return (an equivalent) in good; to reward; in a bad sense, to retaliate; to return (evil) for evil; to punish.","pos":""}],"REQUITEMENT":[{"def":"Re*quite\"ment (-ment), n.","pos":""}],"REQUITER":[{"def":"One who requites.","pos":""}]}