{"ANACAMPTIC":[{"def":"Reflecting of reflected; as, an anacamptic sound (and echo).","pos":""}],"ANACAMPTICALLY":[{"def":"By reflection; as, echoes are sound produced anacamptically.","pos":""}],"ANACAMPTICS":[{"def":"A group of teleostean fishes destitute of spiny fin-rays, as the cod.","pos":""}],"ANACANTHOUS":[{"def":"Spineless, as certain fishes.","pos":""}],"ANACARDIACEOUS":[{"def":"Belonging to, or resembling, a family, or order, of plants of which the cashew tree is the type, and the species of sumac are well known examples.","pos":""}],"ANACARDIC":[{"def":"Pertaining to, or derived from, the cashew nut; as, anacardic acid.","pos":""}],"ANACARDIUM":[{"def":"A genus of plants including the cashew tree.","pos":""}],"ANACATHARTIC":[{"def":"Producing vomiting or expectoration.","pos":""},{"def":"An anacatharic medicine; an expectorant or an emetic.","pos":""}],"ANACHARIS":[{"def":"A fresh-water weed of the frog's-bit family (Hydrocharidaceæ), native to America.","pos":""},{"def":"See Anchoret, Anchoretic.","pos":""}],"ANACHORISM":[{"def":"An error in regard to the place of an event or a thing; a referring something to a wrong place.","pos":""},{"def":"Characterized by, or involving, anachronism; anachronistic.","pos":""}],"ANACHRONISM":[{"def":"A misplacing or error in the order of time; an error in chronology by which events are misplaced in regard to each other, esp.","pos":""}],"ANACHRONISTIC":[{"def":"Erroneous in date; containing an anachronism.","pos":""}],"ANACHRONIZE":[{"def":"To refer to, or put into, a wrong time.","pos":""}],"ANACHRONOUS":[{"def":"Containing an anachronism; anachronistic.","pos":""}],"ANACLASTIC":[{"def":"Produced by the refraction of light, as seen through water; as, anaclastic curves.","pos":""}],"ANACLASTICS":[{"def":"That part of optics which treats of the refraction of light; -- commonly called dioptrics.","pos":""}],"ANACOENOSIS":[{"def":"A figure by which a speaker appeals to his hearers or opponents for their opinion on the point in debate.","pos":""}],"ANACOLUTHIC":[{"def":"Lacking grammatical sequence.","pos":""}],"ANACOLUTHON":[{"def":"A want of grammatical sequence or coherence in a sentence; an instance of a change of construction in a sentence so that the latter part does not syntactically correspond with the first part.","pos":""}],"ANACONDA":[{"def":"A large South American snake of the Boa family (Eunectes murinus), which lives near rivers, and preys on birds and small mammals.","pos":""}],"ANACREONTIC":[{"def":"Pertaining to, after the manner of, or in the meter of, the Greek poet Anacreon; amatory and convivial.","pos":""}],"ANACROTIC":[{"def":"Pertaining to anachronism.","pos":""}],"ANACROTISM":[{"def":"A secondary notch in the pulse curve, obtained in a sphygmographic tracing.","pos":""}],"ANACRUSIS":[{"def":"A prefix of one or two unaccented syllables to a verse properly beginning with an accented syllable.","pos":""}]}