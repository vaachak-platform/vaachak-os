{"PENCEL":[{"def":"A small, narrow flag or streamer borne at the top of a lance; - - called also pennoncel.","pos":""}],"PENCHANT":[{"def":"Inclination; decided taste; bias; as, a penchant for art.","pos":""}],"PENCIL":[{"def":"An aggregate or collection of rays of light, especially when diverging from, or converging to, a point.","pos":""},{"def":"A number of lines that intersect in one point, the point of intersection being called the pencil point.","pos":""}],"PENCILED":[{"def":"Marked with parallel or radiating lines.","pos":""}],"PENCILING":[{"def":"Lines of white or black paint drawn along a mortar joint in a brick wall.","pos":""},{"def":"Shaped like a pencil; penicillate.","pos":""}],"PENCRAFT":[{"def":"Penmanship; skill in writing; chirography.","pos":""},{"def":"The art of composing or writing; authorship.","pos":""}]}