{"CARCAJOU":[{"def":"The wolverence; -- also applied, but erroneously, to the Canada lynx, and sometimes to the American badger.","pos":""}],"CARCANET":[{"def":"A jeweled chain, necklace, or collar.","pos":""}],"CARCASS":[{"def":"A hollow case or shell, filled with combustibles, to be thrown from a mortar or howitzer, to set fire to buldings, ships, etc.","pos":""}],"CARCEL LAMP":[{"def":"A French mechanical lamp, for lighthouses, in which a superbundance of oil is pumped to the wick tube by clockwork.","pos":""}],"CARCERAL":[{"def":"Belonging a prison.","pos":""}],"CARCINOLOGICAL":[{"def":"Of or pertaining to carcinology.","pos":""}],"CARCINOLOGY":[{"def":"The depertment of zoölogy which treats of the Crustacea (lobsters, crabs, etc.","pos":""}],"CARCINOMATOUS":[{"def":"Of or pertaining to carcinoma.","pos":""}],"CARCINOSYS":[{"def":"The affection of the system with cancer.","pos":""}]}