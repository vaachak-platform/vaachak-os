{"BLICKEY":[{"def":"A tin dinner pail.","pos":""}],"BLIGHT":[{"def":"To affect with blight; to blast; to prevent the growth and fertility of.","pos":""},{"def":"Hence: To destroy the happiness of; to ruin; to mar essentially; to frustrate; as, to blight one's prospects.","pos":""}],"BLIGHTINGLY":[{"def":"So as to cause blight.","pos":""},{"def":"See Bilimbi, etc.","pos":""}],"BLIN":[{"def":"To stop; to cease; to desist.","pos":""}],"BLIND":[{"def":"Abortive; failing to produce flowers or fruit; as, blind buds; blind flowers.","pos":""}],"BLIND READER":[{"def":"A post-office clerk whose duty is to decipher obscure addresses.","pos":""}],"BLINDAGE":[{"def":"A cover or protection for an advanced trench or approach, formed of fascines and earth supported by a framework.","pos":""}],"BLINDER":[{"def":"One of the leather screens on a bridle, to hinder a horse from seeing objects at the side; a blinker.","pos":""}],"BLINDFISH":[{"def":"A small fish (Amblyopsis spelæus) destitute of eyes, found in the waters of the Mammoth Cave, in Kentucky.","pos":""}],"BLINDFOLD":[{"def":"To cover the eyes of, as with a bandage; to hinder from seeing.","pos":""}],"BLINDING":[{"def":"Making blind or as if blind; depriving of sight or of understanding; obscuring; as, blinding tears; blinding snow.","pos":""}],"BLINDLY":[{"def":"Without sight, discernment, or understanding; without thought, investigation, knowledge, or purpose of one's own.","pos":""}],"BLINDMAN'S BUFF":[{"def":"A play in which one person is blindfolded, and tries to catch some one of the company and tell who it is.","pos":""}],"BLINDMAN'S HOLIDAY":[{"def":"The time between daylight and candle light.","pos":""}],"BLINDNESS":[{"def":"State or condition of being blind, literally or figuratively.","pos":""}],"BLINDSTORY":[{"def":"The triforium as opposed to the clearstory.","pos":""}],"BLINDWORM":[{"def":"A small, burrowing, snakelike, limbless lizard (Anguis fragilis), with minute eyes, popularly believed to be blind; the slowworm; -- formerly a name for the adder.","pos":""}],"BLINK":[{"def":"To wink; to twinkle with, or as with, the eye.","pos":""},{"def":"To see with the eyes half shut, or indistinctly and with frequent winking, as a person with weak eyes.","pos":""}],"BLINK BEER":[{"def":"Beer kept unbroached until it is sharp.","pos":""}],"BLINK-EYED":[{"def":"Habitually winking.","pos":""}],"BLINKARD":[{"def":"One who blinks with, or as with, weak eyes.","pos":""},{"def":"That which twinkles or glances, as a dim star, which appears and disappears.","pos":""}],"BLINKER":[{"def":"A kind of goggles, used to protect the eyes form glare, etc.","pos":""}],"BLIRT":[{"def":"A gust of wind and rain.","pos":""}],"BLISS":[{"def":"An then at last our bliss Full and perfect is.","pos":""}],"BLISSFUL":[{"def":"Full of, characterized by, or causing, joy and felicity; happy in the highest degree.","pos":""}],"BLISSLESS":[{"def":"Destitute of bliss.","pos":""}],"BLISSOM":[{"def":"To be lustful; to be lascivious.","pos":""}],"BLISTER":[{"def":"A vesicle of the skin, containing watery matter or serum, whether occasioned by a burn or other injury, or by a vesicatory; a collection of serous fluid causing a bladderlike elevation of the cuticle.","pos":""},{"def":"Any elevation made by the separation of the film or skin, as on plants; or by the swelling of the substance at the surface, as on steel.","pos":""}],"BLISTERY":[{"def":"Full of blisters.","pos":""}],"BLITE":[{"def":"A genus of herbs (Blitum) with a fleshy calyx.","pos":""}],"BLITHE":[{"def":"Gay; merry; sprightly; joyous; glad; cheerful; as, a blithe spirit.","pos":""}],"BLITHEFUL":[{"def":"Gay; full of gayety; joyous.","pos":""}],"BLITHELY":[{"def":"In a blithe manner.","pos":""}],"BLITHENESS":[{"def":"The state of being blithe.","pos":""}],"BLITHESOME":[{"def":"Cheery; gay; merry.","pos":""}],"BLIVE":[{"def":"Quickly; forthwith.","pos":""}],"BLIZZARD":[{"def":"A gale of piercingly cold wind, usually accompanied with fine and blinding snow; a furious blast.","pos":""}]}