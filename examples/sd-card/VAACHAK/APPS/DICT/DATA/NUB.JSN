{"NUB":[{"def":"To push; to nudge; also, to beckon.","pos":""}],"NUBBIN":[{"def":"A small or imperfect ear of maize.","pos":""}],"NUBBLE":[{"def":"To beat or bruise with the fist.","pos":""}],"NUBECULA":[{"def":"Specifically, the Magellanic clouds.","pos":""}],"NUBIA":[{"def":"A light fabric of wool, worn on the head by women; a cloud.","pos":""}],"NUBIAN":[{"def":"Of or pertaining to Nubia in Eastern Africa.","pos":""},{"def":"A native of Nubia.","pos":""}],"NUBIFEROUS":[{"def":"Bringing, or producing, clouds.","pos":""}],"NUBIGENOUS":[{"def":"Born of, or produced from, clouds.","pos":""}],"NUBILE":[{"def":"Of an age suitable for marriage; marriageable.","pos":""}],"NUBILITY":[{"def":"The state of being marriageable.","pos":""}]}