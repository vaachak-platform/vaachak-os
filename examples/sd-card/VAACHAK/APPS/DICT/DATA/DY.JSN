{"DYAD":[{"def":"An element, atom, or radical having a valence or combining power of two.","pos":""}],"DYADIC":[{"def":"Pertaining to the number two; of two parts or elements.","pos":""}],"DYAS":[{"def":"A name applied in Germany to the Permian formation, there consisting of two principal groups.","pos":""}],"DYE":[{"def":"To stain; to color; to give a new and permanent color to, as by the application of dyestuffs.","pos":""}],"DYEHOUSE":[{"def":"A building in which dyeing is carried on.","pos":""}],"DYEING":[{"def":"The process or art of fixing coloring matters permanently and uniformly in the fibers of wool, cotton, etc.","pos":""}],"DYER":[{"def":"One whose occupation is to dye cloth and the like.","pos":""}],"DYESTUFF":[{"def":"A material used for dyeing.","pos":""}],"DYEWOOD":[{"def":"Any wood from which coloring matter is extracted for dyeing.","pos":""}],"DYING":[{"def":"In the act of dying; destined to death; mortal; perishable; as, dying bodies.","pos":""},{"def":"Of or pertaining to dying or death; as, dying bed; dying day; dying words; also, simulating a dying state.","pos":""}],"DYINGLY":[{"def":"In a dying manner; as if at the point of death.","pos":""}],"DYINGNESS":[{"def":"The state of dying or the stimulation of such a state; extreme languor; languishment.","pos":""}],"DYNACTINOMETER":[{"def":"An instrument for measuring the intensity of the photogenic (light-producing) rays, and computing the power of object glasses.","pos":""}],"DYNAM":[{"def":"A unit of measure for dynamical effect or work; a foot pound.","pos":""}],"DYNAMETRICAL":[{"def":"Pertaining to a dynameter.","pos":""}],"DYNAMICALLY":[{"def":"In accordance with the principles of dynamics or moving forces.","pos":""}],"DYNAMICS":[{"def":"That department of musical science which relates to, or treats of, the power of tones.","pos":""}],"DYNAMISM":[{"def":"The doctrine of Leibnitz, that all substance involves force.","pos":""}],"DYNAMIST":[{"def":"One who accounts for material phenomena by a theory of dynamics.","pos":""}],"DYNAMITARD":[{"def":"A political dynamiter.","pos":""}],"DYNAMITE":[{"def":"An explosive substance consisting of nitroglycerin absorbed by some inert, porous solid, as infusorial earth, sawdust, etc.","pos":""}],"DYNAMITER":[{"def":"One who uses dynamite; esp.","pos":""}],"DYNAMITING":[{"def":"Destroying by dynamite, for political ends.","pos":""}],"DYNAMITISM":[{"def":"The work of dynamiters.","pos":""}],"DYNAMIZATION":[{"def":"The act of setting free the dynamic powers of a medicine, as by shaking the bottle containing it.","pos":""}],"DYNAMO":[{"def":"A dynamo-electric machine.","pos":""}],"DYNAMO-ELECTRIC":[{"def":"Pertaining to the development of electricity, especially electrical currents, by power; producing electricity or electrical currents by mechanical power.","pos":""}],"DYNAMOGRAPH":[{"def":"A dynamometer to which is attached a device for automatically registering muscular power.","pos":""}],"DYNAMOMETER":[{"def":"An apparatus for measuring force or power; especially, muscular effort of men or animals, or the power developed by a motor, or that required to operate machinery.","pos":""},{"def":"Relating to a dynamometer, or to the measurement of force doing work; as, dynamometrical instruments.","pos":""}],"DYNAMOMETRY":[{"def":"The art or process of measuring forces doing work.","pos":""}],"DYNAST":[{"def":"A ruler; a governor; a prince.","pos":""},{"def":"A dynasty; a government.","pos":""}],"DYNASTIC":[{"def":"Of or relating to a dynasty or line of kings.","pos":""}],"DYNASTIDAN":[{"def":"One of a group of gigantic, horned beetles, including Dynastus Neptunus, and the Hercules beetle (D.","pos":""}],"DYNASTY":[{"def":"Sovereignty; lordship; dominion.","pos":""},{"def":"A race or succession of kings, of the same line or family; the continued lordship of a race of rulers.","pos":""}],"DYNE":[{"def":"The unit of force, in the C.","pos":""}],"DYS-":[{"def":"An inseparable prefix, fr.","pos":""}],"DYSAESTHESIA":[{"def":"Impairment of any of the senses, esp.","pos":""}],"DYSCRASIA":[{"def":"An ill habit or state of the constitution; -- formerly regarded as dependent on a morbid condition of the blood and humors.","pos":""}],"DYSCRASITE":[{"def":"A mineral consisting of antimony and silver.","pos":""}],"DYSCRASY":[{"def":"Of or pertaining to dysentery; having dysentery; as, a dysenteric patient.","pos":""}],"DYSENTERY":[{"def":"A disease attended with inflammation and ulceration of the colon and rectum, and characterized by griping pains, constant desire to evacuate the bowels, and the discharge of mucus and blood.","pos":""}],"DYSGENESIC":[{"def":"Not procreating or breeding freely; as, one race may be dysgenesic with respect to another.","pos":""}],"DYSGENESIS":[{"def":"A condition of not generating or breeding freely; infertility; a form homogenesis in which the hybrids are sterile among themselves, but are fertile with members of either parent race.","pos":""}],"DYSLOGISTIC":[{"def":"Unfavorable; not commendatory; -- opposed to eulogistic.","pos":""}],"DYSLUITE":[{"def":"A variety of the zinc spinel or gahnite.","pos":""}],"DYSLYSIN":[{"def":"A resinous substance formed in the decomposition of cholic acid of bile; -- so called because it is difficult to solve.","pos":""}],"DYSMENORRHEA":[{"def":"Difficult and painful menstruation.","pos":""}],"DYSNOMY":[{"def":"Bad legislation; the enactment of bad laws.","pos":""}],"DYSODILE":[{"def":"An impure earthy or coaly bitumen, which emits a highly fetid odor when burning.","pos":""},{"def":"A kind of indigestion; a state of the stomach in which its functions are disturbed, without the presence of other diseases, or, if others are present, they are of minor importance.","pos":""}],"DYSPEPTIC":[{"def":"A person afflicted with dyspepsia.","pos":""}],"DYSPEPTONE":[{"def":"An insoluble albuminous body formed from casein and other proteid substances by the action of gastric juice.","pos":""},{"def":"Difficulty in swallowing.","pos":""}],"DYSPHORIA":[{"def":"Impatience under affliction; morbid restlessness; dissatisfaction; the fidgets.","pos":""},{"def":"Difficulty of breathing.","pos":""}],"DYSPROSIUM":[{"def":"An element of the rare earth-group.","pos":""}],"DYSTELEOLOGY":[{"def":"The doctrine of purposelessness; a term applied by Haeckel to that branch of physiology which treats of rudimentary organs, in view of their being useless to the life of the organism.","pos":""}],"DYSTOCIA":[{"def":"Difficult delivery pr parturition.","pos":""}],"DYSTOME":[{"def":"Cleaving with difficulty.","pos":""},{"def":"Difficult or painful discharge of urine.","pos":""}],"DYSURIC":[{"def":"Pertaining to, or afflicted with, dysury.","pos":""},{"def":"The Chinese yellow antelope (Procapra gutturosa), a remarkably swift-footed animal, inhabiting the deserts of Central Asia, Thibet, and China.","pos":""}]}