{"EPULARY":[{"def":"Of or pertaining to a feast or banquet.","pos":""}],"EPULATION":[{"def":"A feasting or feast; banquet.","pos":""}],"EPULIS":[{"def":"A hard tumor developed from the gums.","pos":""}],"EPULOSE":[{"def":"Feasting to excess.","pos":""}],"EPULOSITY":[{"def":"A feasting to excess.","pos":""}],"EPULOTIC":[{"def":"Promoting the skinning over or healing of sores; as, an epulotic ointment.","pos":""},{"def":"An epulotic agent.","pos":""}],"EPURE":[{"def":"A draught or model from which to build; especially, one of the full size of the work to be done; a detailed drawing.","pos":""}]}