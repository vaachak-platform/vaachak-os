{"JUVENESCENCE":[{"def":"A growing young.","pos":""}],"JUVENESCENT":[{"def":"Growing or becoming young.","pos":""}],"JUVENILE":[{"def":"Young; youthful; as, a juvenile appearance.","pos":""},{"def":"Of or pertaining to youth; as, juvenile sports.","pos":""}],"JUVENILENESS":[{"def":"The state or quality of being juvenile; juvenility.","pos":""}],"JUVENILITY":[{"def":"Youthfulness; adolescence.","pos":""},{"def":"The manners or character of youth; immaturity.","pos":""}],"JUVIA":[{"def":"A Brazilian name for the lofty myrtaceous tree (Bertholetia excelsa) which produces the large seeds known as Brazil nuts.","pos":""}]}