{"RUM":[{"def":"A kind of intoxicating liquor distilled from cane juice, or from the scumming of the boiled juice, or from treacle or molasses, or from the lees of former distillations.","pos":""}],"RUMBLE":[{"def":"To make a low, heavy, continued sound; as, the thunder rumbles at a distance.","pos":""},{"def":"To murmur; to ripple.","pos":""}],"RUMBLER":[{"def":"One who, or that which, rumbles.","pos":""}],"RUMBLING":[{"def":"Rum\"bling, Defn: a.","pos":""}],"RUMBLINGLY":[{"def":"In a rumbling manner.","pos":""}],"RUMBOWLINE":[{"def":"Same as Rombowline.","pos":""}],"RUMEN":[{"def":"The first stomach of ruminants; the paunch; the fardingbag.","pos":""}],"RUMICIN":[{"def":"A yellow crystalline substance found in the root of yellow dock (Rumex crispus) and identical with chrysophanic acid.","pos":""}],"RUMINAL":[{"def":"Ruminant; ruminating.","pos":""}],"RUMINANT":[{"def":"Chewing the cud; characterized by chewing again what has been swallowed; of or pertaining to the Ruminantia.","pos":""}],"RUMINANTIA":[{"def":"A division of Artiodactyla having four stomachs.","pos":""}],"RUMINANTLY":[{"def":"In a ruminant manner; by ruminating, or chewing the cud.","pos":""}],"RUMINATE":[{"def":"To chew the cud; to chew again what has been slightly chewed and swallowed.","pos":""}],"RUMINATION":[{"def":"The regurgitation of food from the stomach after it has been swallowed, -- occasionally oberved as a morbid phenomenon in man.","pos":""}],"RUMINATIVE":[{"def":"Inclined to, or engaged in, rumination or meditation.","pos":""}],"RUMINATOR":[{"def":"One who ruminates or muses; a meditator.","pos":""}],"RUMKIN":[{"def":"A popular or jocular name for a drinking vessel.","pos":""}],"RUMMAGE":[{"def":"A place or room for the stowage of cargo in a ship; also, the act of stowing cargo; the pulling and moving about of packages incident to close stowage; -- formerly written romage.","pos":""}],"RUMMAGER":[{"def":"A person on shipboard whose business was to take charge of stowing the cargo; -- formerly written roomager, and romager.","pos":""}],"RUMMER":[{"def":"A large and tall glass, or drinking cup.","pos":""}],"RUMMY":[{"def":"Of or pertaining to rum; characteristic of rum; as a rummy flavor.","pos":""}],"RUMNEY":[{"def":"A sort of Spanish wine.","pos":""}],"RUMOR":[{"def":"A flying or popular report; the common talk; hence, public fame; notoriety.","pos":""},{"def":"A current story passing from one person to another, without any known authority for its truth; -- in this sense often personified.","pos":""}],"RUMORER":[{"def":"A teller of news; especially, one who spreads false reports.","pos":""}],"RUMOROUS":[{"def":"Of or pertaining to a rumor; of the nature of rumors.","pos":""},{"def":"Famous; notorious.","pos":""}],"RUMP":[{"def":"The end of the backbone of an animal, with the parts adjacent; the buttock or buttoks.","pos":""},{"def":"Among butchers, the piece of beef betwen the sirloin and the aitchbone piece.","pos":""}],"RUMP-FED":[{"def":"A Shakespearean word of uncertain meaning.","pos":""}],"RUMPER":[{"def":"A member or a supporter of the Rump Parliament.","pos":""}],"RUMPLE":[{"def":"To make uneven; to form into irregular inequalities; to wrinkle; to crumple; as, to rumple an apron or a cravat.","pos":""}],"RUMPLED":[{"def":"Wrinkled; crumpled.","pos":""}],"RUMPLESS":[{"def":"Destitute of a rump.","pos":""}],"RUMPUS":[{"def":"A disturbance; noise and confusion; a quarrel.","pos":""}],"RUMSELLER":[{"def":"One who sells rum; one who deals in intoxicating liquors; especially, one who sells spirituous beverages at retail.","pos":""}]}