{"PRIE":[{"def":"The plant privet.","pos":""}],"PRIEDIEU":[{"def":"A kneeling desk for prayers.","pos":""}],"PRIER":[{"def":"One who pries; one who inquires narrowly and searches, or is inquisitive.","pos":""}],"PRIEST":[{"def":"A presbyter elder; a minister; specifically: (a) (R.","pos":""},{"def":"A presbyter; one who belongs to the intermediate order between bishop and deacon.","pos":""}],"PRIEST-RIDDEN":[{"def":"Controlled or oppressed by priests; as, a priest-ridden people.","pos":""}],"PRIESTCAP":[{"def":"A form of redan, so named from its shape; -- called also swallowtail.","pos":""}],"PRIESTCRAFT":[{"def":"Priestly policy; the policy of a priesthood; esp.","pos":""}],"PRIESTERY":[{"def":"Priests, collectively; the priesthood; -- so called in contempt.","pos":""}],"PRIESTESS":[{"def":"A woman who officiated in sacred rites among pagans.","pos":""}],"PRIESTHOOD":[{"def":"The office or character of a priest; the priestly function.","pos":""},{"def":"Priests, taken collectively; the order of men set apart for sacred offices; the order of priests.","pos":""}],"PRIESTING":[{"def":"The office of a priest.","pos":""}],"PRIESTISM":[{"def":"The influence, doctrines, principles, etc.","pos":""}],"PRIESTLESS":[{"def":"Without a priest.","pos":""}],"PRIESTLINESS":[{"def":"The quality or state of being priestly.","pos":""}],"PRIESTLY":[{"def":"Of or pertaining to a priest or the priesthood; sacerdotal; befitting or becoming a priest; as, the priestly office; a priestly farewell.","pos":""}]}