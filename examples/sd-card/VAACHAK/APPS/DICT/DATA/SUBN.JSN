{"SUBNARCOTIC":[{"def":"Moderately narcotic.","pos":""}],"SUBNASAL":[{"def":"Situated under the nose; as, the subnasal point, or the middle point of the inferior border of the anterior nasal aperture.","pos":""}],"SUBNASCENT":[{"def":"Growing underneath.","pos":""}],"SUBNECT":[{"def":"To tie or fasten beneath; to join beneath.","pos":""}],"SUBNEX":[{"def":"To subjoin; to subnect.","pos":""}],"SUBNORMAL":[{"def":"That part of the axis of a curved line which is intercepted between the ordinate and the normal.","pos":""}],"SUBNOTOCHORDAL":[{"def":"Situated on the ventral side of the notochord; as, the subnotochordal rod.","pos":""}],"SUBNUVOLAR":[{"def":"Under the clouds; attended or partly covered or obscured by clouds; somewhat cloudy.","pos":""}]}