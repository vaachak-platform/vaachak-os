{"SYM-":[{"def":"SYMAR; SYMARR Sy*mar\", Sy\"marr, n.","pos":""}],"SYMBIOSIS":[{"def":"The living together in more or less imitative association or even close union of two dissimilar organisms.","pos":""}],"SYMBIOTIC":[{"def":"Pertaining to, or characterized by, or living in, a state of symbiosis.","pos":""}],"SYMBOL":[{"def":"Any character used to represent a quantity, an operation, a relation, or an abbreviation.","pos":""},{"def":"An abstract or compendium of faith or doctrine; a creed, or a summary of the articles of religion.","pos":""}],"SYMBOLIC":[{"def":"Of or pertaining to a symbol or symbols; of the nature of a symbol; exhibiting or expressing by resemblance or signs; representative; as, the figure of an eye is symbolic of sight and knowledge.","pos":""}],"SYMBOLICS":[{"def":"The study of ancient symbols; esp.","pos":""},{"def":"that branch of historic theology which treats of creeds and confessions of faith; symbolism; -- called also symbolic.","pos":""}],"SYMBOLISM":[{"def":"The science of creeds; symbolics.","pos":""}],"SYMBOLIST":[{"def":"One who employs symbols.","pos":""},{"def":"Characterized by the use of symbols; as, symbolistic poetry.","pos":""}],"SYMBOLIZATION":[{"def":"The act of symbolizing; symbolical representation.","pos":""}],"SYMBOLIZE":[{"def":"To have a resemblance of qualities or properties; to correspond; to harmonize.","pos":""},{"def":"To hold the same faith; to agree.","pos":""}],"SYMBOLIZER":[{"def":"One who symbolizes.","pos":""}],"SYMBOLOGICAL":[{"def":"Pertaining to a symbology; versed in, or characterized by, symbology.","pos":""}],"SYMBOLOGIST":[{"def":"One who practices, or who is versed in, symbology.","pos":""}],"SYMBOLOGY":[{"def":"The art of expressing by symbols.","pos":""}],"SYMBRANCHII":[{"def":"An order of slender eel-like fishes having the gill openings confluent beneath the neck.","pos":""}],"SYMMETRAL":[{"def":"Commensurable; symmetrical.","pos":""}],"SYMMETRIAN":[{"def":"One eminently studious of symmetry of parts.","pos":""}],"SYMMETRICAL":[{"def":"Having the organs or parts of one side correspponding with those of the other; having the parts in two or more series of organs the same in number; exhibiting a symmetry.","pos":""},{"def":"Having a common measure; commensurable.","pos":""}],"SYMMETRICIAN":[{"def":"Same as Symmetrian.","pos":""}],"SYMMETRIST":[{"def":"One eminently studious of symmetry of parts.","pos":""}],"SYMMETRIZE":[{"def":"To make proportional in its parts; to reduce to symmetry.","pos":""}],"SYMMETRY":[{"def":"The law of likeness; similarity of structure; regularity in form and arrangement; orderly and similar distribution of parts, such that an animal may be divided into parts which are structurally symmetrical.","pos":""}],"SYMPATHETIC":[{"def":"Inclined to sympathy; sympathizing.","pos":""},{"def":"Produced by, or expressive of, sympathy.","pos":""}],"SYMPATHETICALLY":[{"def":"In a sympathetic manner.","pos":""}],"SYMPATHIST":[{"def":"One who sympathizes; a sympathizer.","pos":""}],"SYMPATHIZE":[{"def":"To have a common feeling, as of bodily pleasure or pain.","pos":""},{"def":"To feel in consequence of what another feels; to be affected by feelings similar to those of another, in consequence of knowing the person to be thus affected.","pos":""}],"SYMPATHIZER":[{"def":"One who sympathizes.","pos":""}],"SYMPATHY":[{"def":"Feeling corresponding to that which another feels; the quality of being affected by the affection of another, with feelings correspondent in kind, if not in degree; fellow-feeling.","pos":""},{"def":"An agreement of affections or inclinations, or a conformity of natural temperament, which causes persons to be pleased, or in accord, with one another; as, there is perfect sympathy between them.","pos":""}],"SYMPETALOUS":[{"def":"Having the petals united; gamopetalous.","pos":""}],"SYMPHONIC":[{"def":"Relating to, or in the manner of, symphony; as, the symphonic form or style of composition.","pos":""}],"SYMPHONIOUS":[{"def":"Agreeing in sound; accordant; harmonious.","pos":""}],"SYMPHONIST":[{"def":"A composer of symphonies.","pos":""}],"SYMPHONIZE":[{"def":"To agree; to be in harmony.","pos":""}],"SYMPHONY":[{"def":"A consonance or harmony of sounds, agreeable to the ear, whether the sounds are vocal or instrumental, or both.","pos":""},{"def":"A stringed instrument formerly in use, somewhat resembling the virginal.","pos":""}],"SYMPHYLA":[{"def":"An order of small apterous insects having an elongated body, with three pairs of thoracic and about nine pairs of abdominal legs.","pos":""}],"SYMPHYSEAL":[{"def":"Of or pertaining to to symphysis.","pos":""}],"SYMPHYSEOTOMY":[{"def":"The operation of dividing the symphysis pubis for the purpose of facilitating labor; -- formerly called the Sigualtian section.","pos":""}],"SYMPHYTISM":[{"def":"Coalescence; a growing into one with another word.","pos":""}],"SYMPIESOMETER":[{"def":"A sensitive kind of barometer, in which the pressure of the atmosphere, acting upon a liquid, as oil, in the lower portion of the instrument, compresses an elastic gas in the upper part.","pos":""}],"SYMPLECTIC":[{"def":"Plaiting or joining together; -- said of a bone next above the quadrate in the mandibular suspensorium of many fishes, which unites together the other bones of the suspensorium.","pos":""},{"def":"The symplectic bone.","pos":""}],"SYMPLOCE":[{"def":"The repetition of a word or phrase at the beginning and another at the end of successive clauses; as, Justice came down from heaven to view the earth; Justice returned to heaven, and left the earth.","pos":""}],"SYMPODIAL":[{"def":"Composed of superposed branches in such a way as to imitate a simple axis; as, a sympodial stem.","pos":""}],"SYMPODIUM":[{"def":"An axis or stem produced by dichotomous branching in which one of the branches is regularly developed at the expense of the other, as in the grapevine.","pos":""}],"SYMPOSIAC":[{"def":"Of or pertaining to compotations and merrymaking; happening where company is drinking together; as, symposiac meetings.","pos":""}],"SYMPOSIARCH":[{"def":"The master of a feast.","pos":""}],"SYMPOSIAST":[{"def":"One engaged with others at a banquet or merrymaking.","pos":""}],"SYMPOSION":[{"def":"A drinking together; a symposium.","pos":""}],"SYMPOSIUM":[{"def":"A drinking together; a merry feast.","pos":""},{"def":"A collection of short essays by different authors on a common topic; -- so called from the appellation given to the philosophical dialogue by the Greeks.","pos":""}],"SYMPTOM":[{"def":"Any affection which accompanies disease; a perceptible change in the body or its functions, which indicates disease, or the kind or phases of disease; as, the causes of disease often lie beyond our sight, but we learn their nature by the symptoms exhibited.","pos":""}],"SYMPTOMATOLOGY":[{"def":"The doctrine of symptoms; that part of the science of medicine which treats of the symptoms of diseases; semeiology.","pos":""}]}