{"OUTBABBLE":[{"def":"To utter foolishly or excessively; to surpass in babbling.","pos":""}],"OUTBALANCE":[{"def":"To outweight; to exceed in weight or effect.","pos":""}],"OUTBEG":[{"def":"To surpass in begging.","pos":""}],"OUTBID":[{"def":"To exceed or surpass in bidding.","pos":""}],"OUTBIDDER":[{"def":"One who outbids.","pos":""}],"OUTBLEAT":[{"def":"To surpass in bleating.","pos":""}],"OUTBLOWN":[{"def":"Inflated with wind.","pos":""}],"OUTBLUSH":[{"def":"To exceed in blushing; to surpass in rosy color.","pos":""}],"OUTBOARD":[{"def":"Beyond or outside of the lines of a vessel's bulwarks or hull; in a direction from the hull or from the keel; -- opposed to inboard; as, outboard rigging; swing the davits outboard.","pos":""}],"OUTBORN":[{"def":"Foreign; not native.","pos":""}],"OUTBOUNDS":[{"def":"The farthest or exterior bounds; extreme limits; boundaries.","pos":""}],"OUTBOW":[{"def":"To excel in bowing.","pos":""}],"OUTBOWED":[{"def":"Convex; curved outward.","pos":""}],"OUTBRAG":[{"def":"To surpass in bragging; hence, to make appear inferior.","pos":""}],"OUTBRAVE":[{"def":"To excel in bravery o 2.","pos":""}],"OUTBRAY":[{"def":"To exceed in braying.","pos":""},{"def":"To emit with great noise.","pos":""}],"OUTBRAZEN":[{"def":"To bear down with a brazen face; to surpass in impudence.","pos":""}],"OUTBREAK":[{"def":"A bursting forth; eruption; insurrection.","pos":""}],"OUTBREAKING":[{"def":"The act of breaking out.","pos":""},{"def":"That which bursts forth.","pos":""}],"OUTBREAST":[{"def":"To surpass in singing.","pos":""}],"OUTBREATHE":[{"def":"To breathe forth.","pos":""},{"def":"To cause to be out of breath; to exhaust.","pos":""}],"OUTBRIBE":[{"def":"To surpass in bribing.","pos":""}],"OUTBRING":[{"def":"To bring or bear out.","pos":""}],"OUTBUILD":[{"def":"To exceed in building, or in durability of building.","pos":""}],"OUTBUILDING":[{"def":"A building separate from, and subordinate to, the main house; an outhouse.","pos":""}],"OUTBURN":[{"def":"To exceed in burning.","pos":""},{"def":"To burn entirely; to be consumed.","pos":""}],"OUTBURST":[{"def":"A bursting forth.","pos":""}]}