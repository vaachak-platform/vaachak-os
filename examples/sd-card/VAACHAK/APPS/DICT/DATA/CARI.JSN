{"CARIAMA":[{"def":"A large, long-legged South American bird (Dicholophus cristatus) which preys upon snakes, etc.","pos":""}],"CARIB":[{"def":"A native of the Caribbee islands or the coaste of the Caribbean sea; esp.","pos":""},{"def":"Of or pertaining to the Caribs, to their islands (the eastern and southern West Indies), or to the sea (called the Caribbean sa) lying between those islands and Central America.","pos":""}],"CARIBE":[{"def":"A south American fresh water fish of the genus Serrasalmo of many species, remakable for its voracity.","pos":""}],"CARIBOU":[{"def":"The American reindeer, especially the common or woodland species (Rangifer Caribou).","pos":""}],"CARICATURE":[{"def":"An exaggeration, or distortion by exaggeration, of parts or characteristics, as in a picture.","pos":""},{"def":"A picture or other figure or description in which the peculiarities of a person or thing are so exaggerated as to appear ridiculous; a burlesque; a parody.","pos":""}],"CARICATURIST":[{"def":"One who caricatures.","pos":""}],"CARICOUS":[{"def":"Of the shape of a fig; as, a caricous tumor.","pos":""}],"CARIES":[{"def":"Ulceration of bone; a process in which bone disintegrates and is carried away piecemeal, as distinguished from necrosis, in which it dies in masses.","pos":"noun"}],"CARILLON":[{"def":"A chime of bells diatonically tuned, played by clockwork or by finger keys.","pos":""}],"CARINA":[{"def":"The keel of the breastbone of birds.","pos":""}],"CARINARIA":[{"def":"A genus of oceanic heteropod Mollusca, having a thin, glassy, bonnet-shaped shell, which covers only the nucleus and gills.","pos":""}],"CARINATAE":[{"def":"A grand division of birds, including all existing flying birds; -- So called from the carina or keel on the breastbone.","pos":""},{"def":"Shaped like the keel or prow of a ship; having a carina or keel; as, a carinate calyx or leaf; a carinate sternum (of a bird).","pos":""}],"CARIOUS":[{"def":"Affected with caries; decaying; as, a carious tooth.","pos":""}]}