{"EXACERBATE":[{"def":"To render more violent or bitter; to irriate; to exasperate; to imbitter, as passions or disease.","pos":""}],"EXACERBATION":[{"def":"A periodical increase of violence in a disease, as in remittent or continious fever; an increased energy of diseased and painful action.","pos":""}],"EXACERBESCENCE":[{"def":"Increase of irritation or violence, particularly the increase of a fever or disease.","pos":""}],"EXACERVATION":[{"def":"The act of heaping up.","pos":""}],"EXACINATE":[{"def":"To remove the kernel form.","pos":""}],"EXACINATION":[{"def":"Removal of the kernel.","pos":""}],"EXACT":[{"def":"Precisely agreeing with a standard, a fact, or the truth; perfectly conforming; neither exceeding nor falling short in any respect; true; correct; precise; as, the clock keeps exact time; he paid the exact debt; an exact copy of a letter; exact accounts.","pos":""},{"def":"Habitually careful to agree with a standard, a rule, or a promise; accurate; methodical; punctual; as, a man exact in observing an appointment; in my doings I was exact.","pos":""}],"EXACTING":[{"def":"Oppressive or unreasonably severe in making demands or requiring the exact fulfillment of obligations; harsh; severe.","pos":""}],"EXACTION":[{"def":"The act of demanding with authority, and compelling to pay or yield; compulsion to give or furnish; a levying by force; a driving to compliance; as, the exaction to tribute or of obedience; hence, extortion.","pos":""},{"def":"That which is exacted; a severe tribute; a fee, reward, or contribution, demanded or levied with severity or injustice.","pos":""}],"EXACTITUDE":[{"def":"The quality of being exact; exactness.","pos":""}],"EXACTLY":[{"def":"In an exact manner; precisely according to a rule, standard, or fact; accurately; strictly; correctly; nicely.","pos":""}],"EXACTNESS":[{"def":"The condition of being exact; accuracy; nicety; precision; regularity; as, exactness of jurgement or deportment.","pos":""},{"def":"Careful observance of method and conformity to truth; as, exactness in accounts or business.","pos":""}],"EXACTOR":[{"def":"One who exacts or demands by authority or right; hence, an extortioner; also, one unreasonably severe in injunctions or demands.","pos":""}],"EXACTRESS":[{"def":"A woman who is an exactor.","pos":""}],"EXACUATE":[{"def":"To whet or sharpen.","pos":""}],"EXAERESIS":[{"def":"In old writers, the operations concerned in the removal of parts of the body.","pos":""}],"EXAGGERATE":[{"def":"To heap up; to accumulate.","pos":""},{"def":"To amplify; to magnify; to enlarge beyond bounds or the truth ; to delineate extravagantly ; to overstate the truth concerning.","pos":""}],"EXAGGERATED":[{"def":"Enlarged beyond bounds or the truth.","pos":""}],"EXAGGERATING":[{"def":"That exaggerates; enlarging beyond bounds.","pos":""}],"EXAGGERATION":[{"def":"A representation of things beyond natural life, in expression, beauty, power, vigor.","pos":""}],"EXAGGERATIVE":[{"def":"Tending to exaggerate; involving exaggeration.","pos":""}],"EXAGGERATOR":[{"def":"One who exaggerates; one addicted to exaggeration.","pos":""}],"EXAGGERATORY":[{"def":"Containing, or tending to, exaggeration; exaggerative.","pos":""}],"EXAGITATE":[{"def":"To stir up; to agitate.","pos":""},{"def":"To satirize; to censure severely.","pos":""}],"EXALBUMINOUS":[{"def":"Having no albumen about the embryo; -- said of certain seeds.","pos":""}],"EXALT":[{"def":"To render pure or refined; to intensify or concentrate; as, to exalt the juices of bodies.","pos":""}],"EXALTATE":[{"def":"Exercising its highest influence; -- said of a planet.","pos":""}],"EXALTATION":[{"def":"The refinement or subtilization of a body, or the increasing of its virtue or principal property.","pos":""},{"def":"That place of a planet in the zodiac in which it was supposed to exert its strongest influence.","pos":""}],"EXALTED":[{"def":"Raised to lofty height; elevated; extolled; refined; dignified; sublime.","pos":""}],"EXALTER":[{"def":"One who exalts or raises to dignity.","pos":""}],"EXAMEN":[{"def":"Examination; inquiry.","pos":""}],"EXAMINABLE":[{"def":"Capable of being examined or inquired into.","pos":""}],"EXAMINANT":[{"def":"One who examines; an examiner.","pos":""},{"def":"One who is to be examined.","pos":""}],"EXAMINATE":[{"def":"A person subjected to examination.","pos":""}],"EXAMINATION":[{"def":"The act of examining, or state of being examined; a careful search, investigation, or inquiry; scrutiny by study or experiment.","pos":""},{"def":"A process prescribed or assigned for testing qualification; as, the examination of a student, or of a candidate for admission to the bar or the ministry.","pos":""}],"EXAMINE":[{"def":"To interrogate as in a judicial proceeding; to try or test by question; as, to examine a witness in order to elicit testimony, a student to test his qualifications, a bankrupt touching the state of his property, etc.","pos":""}],"EXAMINEE":[{"def":"A person examined.","pos":""}],"EXAMINER":[{"def":"One who examines, tries, or inspects; one who interrogates; an officer or person charged with the duty of making an examination; as, an examiner of students for a degree; an examiner in chancery, in the patent office, etc.","pos":""}],"EXAMINERSHIP":[{"def":"The office or rank of an examiner.","pos":""}],"EXAMINING":[{"def":"Having power to examine; appointed to examine; as, an examining committee.","pos":""}],"EXAMPLARY":[{"def":"Serving for example or pattern; exemplary.","pos":""}],"EXAMPLE":[{"def":"One or a portion taken to show the character or quality of the whole; a sample; a specimen.","pos":""},{"def":"That which is to be followed or imitated as a model; a pattern or copy.","pos":""}],"EXAMPLELESS":[{"def":"Without or above example.","pos":""}],"EXAMPLER":[{"def":"A pattern; an exemplar.","pos":""}],"EXANGULOUS":[{"def":"Having no corners; without angles.","pos":""}],"EXANIMATE":[{"def":"Destitute of animation; spiritless; disheartened.","pos":""}],"EXANIMATION":[{"def":"Deprivation of life or of spirits.","pos":"noun"}],"EXANNULATE":[{"def":"Having the sporangium destitute of a ring; -- said of certain genera of ferns.","pos":""}],"EXANTHEM":[{"def":"Same as Exanthema.","pos":""}],"EXANTHEMA":[{"def":"An efflorescence or discoloration of the skin; an eruption or breaking out, as in measles, smallpox, scarlatina, and the like diseases; -- sometimes limited to eruptions attended with fever.","pos":""},{"def":"Of, relating to, or characterized by, exanthema; efflorescent; as, an exanthematous eruption.","pos":""}],"EXANTHESIS":[{"def":"An eruption of the skin; cutaneous efflorescence.","pos":""}],"EXANTLATE":[{"def":"To exhaust or wear out.","pos":""}],"EXANTLATION":[{"def":"Act of drawing out ; exhaustion.","pos":""}],"EXARATE":[{"def":"To plow up; also, to engrave; to write.","pos":""}],"EXARATION":[{"def":"Act of plowing; also, act of writing.","pos":""}],"EXARCH":[{"def":"A viceroy; in Ravenna, the title of the viceroys of the Byzantine emperors; in the Eastern Church, the superior over several monasteries; in the modern Greek Church, a deputy of the patriarch , who visits the clergy, investigates ecclesiastical cases, etc.","pos":""}],"EXARCHATE":[{"def":"The office or the province of an exarch.","pos":""}],"EXARILLATE":[{"def":"Having no aril; -- said of certain seeds, or of the plants producing them.","pos":""}],"EXARTICULATE":[{"def":"Having but one joint; -- said of certain insects.","pos":""}],"EXARTICULATION":[{"def":"Luxation; the dislocation of a joint.","pos":""}],"EXASPERATE":[{"def":"Exasperated; imbittered.","pos":""}],"EXASPERATER":[{"def":"One who exasperates or inflames anger, enmity, or violence.","pos":""}],"EXASPERATION":[{"def":"The act of exasperating or the state of being exasperated; irritation; keen or bitter anger.","pos":""},{"def":"Increase of violence or malignity; aggravation; exacerbation.","pos":""}],"EXAUCTORATE":[{"def":"See Exauthorate.","pos":""}],"EXAUCTORATION":[{"def":"See Exauthoration.","pos":""}],"EXAUGURATE":[{"def":"To annul the consecration of; to secularize; to unhellow.","pos":""}],"EXAUGURATION":[{"def":"The act of exaugurating; desecration.","pos":""}],"EXAUTHORATE":[{"def":"To deprive of authority or office; to depose; to discharge.","pos":""}],"EXAUTHORATION":[{"def":"Deprivation of authority or dignity; degration.","pos":""}],"EXAUTHORIZE":[{"def":"To deprive of uthority.","pos":""}]}