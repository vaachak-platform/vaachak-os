{"OAF":[{"def":"Originally, an elf's child; a changeling left by fairies or goblins; hence, a deformed or foolish child; a simpleton; an idiot.","pos":""}],"OAFISH":[{"def":"Like an oaf; simple.","pos":""}],"OAK":[{"def":"Any tree or shrub of the genus Quercus.","pos":""}],"OAKEN":[{"def":"Made or consisting of oaks or of the wood of oaks.","pos":""}],"OAKUM":[{"def":"The material obtained by untwisting and picking into loose fiber old hemp ropes; -- used for calking the seams of ships, stopping leaks, etc.","pos":""},{"def":"The coarse portion separated from flax or hemp in nackling.","pos":""}],"OAKY":[{"def":"Resembling oak; strong.","pos":""}],"OAR":[{"def":"An oarlike swimming organ of various invertebrates.","pos":""}],"OAR-FOOTED":[{"def":"Having feet adapted for swimming.","pos":""}],"OARED":[{"def":"Furnished with oars; -- chiefly used in composition; as, a four- oared boat.","pos":""}],"OARFISH":[{"def":"The ribbon fish.","pos":""}],"OARFOOT":[{"def":"Any crustacean of the genus Remipes.","pos":""}],"OARLOCK":[{"def":"The notch, fork, or other device on the gunwale of a boat, in which the oar rests in rowing.","pos":""}],"OARSMAN":[{"def":"One who uses, or is skilled in the use of, an oar; a rower.","pos":""}],"OARSWEED":[{"def":"Any large seaweed of the genus Laminaria; tangle; kelp.","pos":""}],"OARY":[{"def":"Having the form or the use of an oar; as, the swan's oary feet.","pos":""}],"OASIS":[{"def":"A fertile or green spot in a waste or desert, esp.","pos":""}],"OAST":[{"def":"A kiln to dry hops or malt; a cockle.","pos":""}],"OATCAKE":[{"def":"A cake made of oatmeal.","pos":""}],"OATEN":[{"def":"Consisting of an oat straw or stem; as, an oaten pipe.","pos":""},{"def":"Made of oatmeal; as, oaten cakes.","pos":""}],"OATH":[{"def":"An appeal (in verification of a statement made) to a superior sanction, in such a form as exposes the party making the appeal to an indictment for perjury if the statement be false.","pos":""}],"OATHABLE":[{"def":"Capable of having an oath administered to.","pos":""}],"OATHBREAKING":[{"def":"The violation of an oath; perjury.","pos":""}],"OATMEAL":[{"def":"A plant of the genus Panicum; panic grass.","pos":""}]}