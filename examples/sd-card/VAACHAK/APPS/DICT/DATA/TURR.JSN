{"TURREL":[{"def":"A certain tool used by coopers.","pos":""}],"TURRET":[{"def":"A little tower, frequently a merely ornamental structure at one of the angles of a larger structure.","pos":""},{"def":"A movable building, of a square form, consisting of ten or even twenty stories and sometimes one hundred and twenty cubits high, usually moved on wheels, and employed in approaching a fortified place, for carrying soldiers, engines, ladders, casting bridges, and other necessaries.","pos":""}],"TURRET DECK":[{"def":"A narrow superstructure running from stem to stern on the upper deck of a steam cargo vessel having a rounded gunwale and sides curved inward convexly.","pos":""}],"TURRET STEAMER":[{"def":"A whaleback steamer with a hatch coaming, usually about seven feet high, extending almost continuously fore and aft.","pos":""}],"TURRETED":[{"def":"Furnished with a turret or turrets; specifically (Zoöl.","pos":""},{"def":"Formed like a tower; as, a turreted lamp.","pos":""}],"TURRIBANT":[{"def":"With hundred turrets like a turribant.","pos":""}],"TURRICAL":[{"def":"Of or pertaining to a turret, or tower; resembling a tower.","pos":""},{"def":"Furnished with, or formed like, a small turret or turrets; somewhat turreted.","pos":""}],"TURRILITE":[{"def":"Any fossil ammonite of the genus Turrilites.","pos":""}],"TURRITELLA":[{"def":"Any spiral marine gastropod belonging to Turritella and allied genera.","pos":""}],"TURRITELLOID":[{"def":"Of, pertaining to, or resembling, the turritellas.","pos":""}]}