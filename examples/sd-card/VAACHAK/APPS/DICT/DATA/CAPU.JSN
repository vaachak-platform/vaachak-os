{"CAPUCCIO":[{"def":"A capoch or hood.","pos":""}],"CAPUCHED":[{"def":"Cover with, or as with, a hood.","pos":""}],"CAPUCHIN":[{"def":"A Franciscan monk of the austere branch established in 1526 by Matteo di Baschi, distinguished by wearing the long pointed cowl or capoch of St.","pos":""}],"CAPUCINE":[{"def":"See Capuchin, 3.","pos":""}],"CAPULET":[{"def":"Same as Capellet.","pos":""}],"CAPULIN":[{"def":"The Mexican chery (Prunus Capollin).","pos":""}],"CAPUT":[{"def":"The head; also, a knoblike protuberance or capitulum.","pos":""},{"def":"The council or ruling body of the University of Cambridge prior to the constitution of 1856.","pos":""}]}