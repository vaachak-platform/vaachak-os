{"CRATAEGUS":[{"def":"A genus of small, hardy trees, including the hawthorn, much used for ornamental purposes.","pos":""}],"CRATCH":[{"def":"A manger or open frame for hay; a crib; a rack.","pos":""}],"CRATE":[{"def":"A large basket or hamper of wickerwork, used for the transportation of china, crockery, and similar wares.","pos":""},{"def":"A box or case whose sides are of wooden slats with interspaces, -- used especially for transporting fruit.","pos":""}],"CRATER":[{"def":"The pit left by the explosion of a mine.","pos":""},{"def":"A constellation of the southen hemisphere; -- called also the Cup.","pos":""}],"CRATERIFORM":[{"def":"Having the form of a shallow bowl; -- said of a corolla.","pos":""}],"CRATEROUS":[{"def":"Pertaining to, or resembling, a crater.","pos":""}]}