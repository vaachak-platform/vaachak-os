{"INTEMERATENESS":[{"def":"The state of being unpolluted; purity.","pos":""}],"INTEMPERAMENT":[{"def":"A bad state; as, the intemperament of an ulcerated part.","pos":""}],"INTEMPERANCE":[{"def":"The act of becoming, or state of being, intemperate; excess in any kind of action or indulgence; any immoderate indulgence of the appetites or passions.","pos":""},{"def":"Specifically: Habitual or excessive indulgence in alcoholic liquors.","pos":""}],"INTEMPERANT":[{"def":"Such as be intemperant, that is, followers of their naughty appetites and lusts.","pos":""}],"INTEMPERATE":[{"def":"Indulging any appetite or passion to excess; immoderate to enjoyments or exertion.","pos":""},{"def":"Specifically, addicted to an excessive or habitual use of alcoholic liquors.","pos":""}],"INTEMPERATELY":[{"def":"In an intemperate manner; immoderately; excessively; without restraint.","pos":""}],"INTEMPERATENESS":[{"def":"The state of being intemperate; excessive indulgence of any appetite or passion; as, intemperateness in eating or drinking.","pos":""},{"def":"Severity of weather; inclemency.","pos":""}],"INTEMPERATURE":[{"def":"Intemperateness.","pos":""}],"INTEMPESTIVE":[{"def":"Out of season; untimely.","pos":""}],"INTEMPESTIVELY":[{"def":"In`tem*pes\"tive*ly, adv.","pos":""}],"INTEMPESTIVITY":[{"def":"Unseasonableness; untimeliness.","pos":""}]}