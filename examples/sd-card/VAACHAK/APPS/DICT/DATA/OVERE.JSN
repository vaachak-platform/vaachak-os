{"OVEREAGER":[{"def":"Too eager; too impatient.","pos":""}],"OVEREAT":[{"def":"To gnaw all over, or on all sides.","pos":""},{"def":"To eat to excess; -- often with a reflexive.","pos":""}],"OVEREMPTY":[{"def":"To make too empty; to exhaust.","pos":""}],"OVEREST":[{"def":"Uppermost; outermost.","pos":""}],"OVERESTIMATE":[{"def":"To estimate too highly; to overvalue.","pos":""}],"OVEREXCITE":[{"def":"To excite too much.","pos":""}],"OVEREXCITEMENT":[{"def":"Excess of excitement; the state of being overexcited.","pos":""}],"OVEREXERT":[{"def":"To exert too much.","pos":""}],"OVEREXERTION":[{"def":"Excessive exertion.","pos":""}],"OVEREXPOSE":[{"def":"To expose excessively; specif.","pos":""},{"def":"to subject (a plate or film) too long to the actinic action of the light used in producing a picture.","pos":""}],"OVEREXQUISITE":[{"def":"Too exquisite; too exact or nice; too careful.","pos":""}],"OVEREYE":[{"def":"To superintend; to oversee; to inspect.","pos":""},{"def":"To see; to observe.","pos":""}]}