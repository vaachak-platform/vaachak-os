{"PROTHALLIUM":[{"def":"Same as Prothallus.","pos":""}],"PROTHALLUS":[{"def":"The minute primary growth from the spore of ferns and other Pteridophyta, which bears the true sexual organs; the oöphoric generation of ferns, etc.","pos":""}],"PROTHESIS":[{"def":"A credence table; -- so called by the Eastern or Greek Church.","pos":""}],"PROTHETIC":[{"def":"Of or pertaining to prothesis; as, a prothetic apparatus.","pos":""},{"def":"Formerly, one who had the charge of writing the acts of the martyrs, and the circumstances of their death; now, one of twelve persons, constituting a college in the Roman Curia, whose office is to register pontifical acts and to make and preserve the official record of beatifications.","pos":""}],"PROTHONOTARYSHIP":[{"def":"Office of a prothonotary.","pos":""}],"PROTHORACIC":[{"def":"Of or pertaining to the prothorax.","pos":""}],"PROTHORAX":[{"def":"The first or anterior segment of the thorax in insects.","pos":""}],"PROTHYALOSOME":[{"def":"Same as Prothyalosoma.","pos":""}]}