{"CASS":[{"def":"To render useless or void; to annul; to reject; to send away.","pos":""}],"CASSAREEP":[{"def":"A condiment made from the sap of the bitter cassava (Manihot utilissima) deprived of its poisonous qualities, concentrated by boiling, and flavored with aromatics.","pos":""}],"CASSATE":[{"def":"To render void or useless; to vacate or annul.","pos":""}],"CASSATION":[{"def":"The act of annulling.","pos":""}],"CASSAVA":[{"def":"A shrubby euphorbiaceous plant of the genus Manihot, with fleshy rootstocks yielding an edible starch; -- called also manioc.","pos":""}],"CASSAVA WOOD":[{"def":"A West Indian tree (Turpinia occidentalis) of the family Staphyleaceæ.","pos":""},{"def":"A brown pigment of varying permanence, consisting of impure lignite.","pos":""}],"CASSE PAPER":[{"def":"Broken paper; the outside quires of a ream.","pos":""}],"CASSE-TETE":[{"def":"A small war club, esp.","pos":""}],"CASSEROLE":[{"def":"A small round dish with a handle, usually of porcelain.","pos":""},{"def":"A mold (in the shape of a hollow vessel or incasement) of boiled rice, mashed potato or paste, baked, and afterwards filled with vegetables or meat.","pos":""}],"CASSIA":[{"def":"A genus of leguminous plants (herbs, shrubs, or trees) of many species, most of which have purgative qualities.","pos":""}],"CASSICAN":[{"def":"An American bird of the genus Cassicus, allied to the starlings and orioles, remarkable for its skillfully constructed and suspended nest; the crested oriole.","pos":""}],"CASSIDEOUS":[{"def":"Helmet-shaped; -- applied to a corolla having a broad, helmet- shaped upper petal, as in aconite.","pos":""}],"CASSIMERE":[{"def":"A thin, twilled, woolen cloth, used for men's garments.","pos":""}],"CASSINETTE":[{"def":"A cloth with a cotton wart, and a woof of very fine wool, or wool and silk.","pos":""}],"CASSINO":[{"def":"A game at cards, played by two or more persons, usually for twenty-one points.","pos":""}],"CASSIOBERRY":[{"def":"The fruit of the Viburnum obovatum, a shrub which grows from Virginia to Florida.","pos":""}],"CASSIOPEIA":[{"def":"A constellation of the northern hemisphere, situated between Capheus and Perseus; -- so called in honor of the wife of Cepheus, a fabuolous king of Ethiopia.","pos":""}],"CASSITERITE":[{"def":"Native tin dioxide; tin stone; a mineral occurring in tetragonal crystals of reddish brown color, and brilliant adamantine luster; also massive, sometimes in compact forms with concentric fibrous structure resembling wood (wood tin), also in rolled fragments or pebbly (Stream tin).","pos":""}],"CASSIUS":[{"def":"A brownish purple pigment, obtained by the action of some compounds of tin upon certain salts of gold.","pos":""}],"CASSOCK":[{"def":"A garment resembling a long frock coat worn by the clergy of certain churches when officiating, and by others as the usually outer garment.","pos":""}],"CASSOCKED":[{"def":"Clothed with a cassock.","pos":""}],"CASSOLETTE":[{"def":"a box, or vase with a perforated cover to emit perfumes.","pos":""}],"CASSONADE":[{"def":"Raw sugar; sugar not refined.","pos":""}],"CASSOWARY":[{"def":"A large bird, of the genus Casuarius, found in the east Indies.","pos":""},{"def":"A pungent, bitter, aromatic, gingerlike root, obtained from the East Indies.","pos":""}]}