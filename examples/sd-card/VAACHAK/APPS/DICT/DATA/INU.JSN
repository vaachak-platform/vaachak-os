{"INULIN":[{"def":"A substance of very wide occurrence.","pos":""}],"INULOID":[{"def":"A substance resembling inulin, found in the unripe bulbs of the dahila.","pos":""}],"INUMBRATE":[{"def":"To shade; to darken.","pos":""}],"INUNCTION":[{"def":"The act of anointing, or the state of being anointed; unction; specifically (Med.","pos":""}],"INUNCTUOSITY":[{"def":"The want of unctuosity; freedom from greasiness or oiliness; as, the inunctuosity of porcelain clay.","pos":""}],"INUNDATE":[{"def":"To cover with a flood; to overflow; to deluge; to flood; as, the river inundated the town.","pos":""},{"def":"To fill with an overflowing abundance or superfluity; as, the country was inundated with bills of credit.","pos":""}],"INUNDATION":[{"def":"The act of inundating, or the state of being inundated; an overflow; a flood; a rising and spreading of water over grounds.","pos":""},{"def":"An overspreading of any kind; overflowing or superfluous abundance; a flood; a great influx; as, an inundation of tourists.","pos":""}],"INUNDERSTANDING":[{"def":"Void of understanding.","pos":""}],"INURBANE":[{"def":"Uncivil; unpolished; rude.","pos":""}],"INURBANITY":[{"def":"Want of urbanity or courtesy; unpolished manners or deportment; inurbaneness; rudeness.","pos":""}],"INURE":[{"def":"To apply in use; to train; to discipline; to use or accustom till use gives little or no pain or inconvenience; to harden; to habituate; to practice habitually.","pos":""}],"INUREMENT":[{"def":"Use; practice; discipline; habit; custom.","pos":""}],"INURN":[{"def":"To put in an urn, as the ashes of the dead; hence, to bury; to intomb.","pos":""}],"INUSITATION":[{"def":"Want of use; disuse.","pos":""}],"INUSTION":[{"def":"The act of burning or branding.","pos":""}],"INUTILE":[{"def":"Useless; unprofitable.","pos":""}],"INUTILITY":[{"def":"Uselessness; the quality of being unprofitable; unprofitableness; as, the inutility of vain speculations and visionary projects.","pos":""}],"INUTTERABLE":[{"def":"Unutterable; inexpressible.","pos":""}]}