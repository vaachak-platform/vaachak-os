{"CONTRA":[{"def":"A Latin adverb and preposition, signifying against, contrary, in opposition, etc.","pos":""}],"CONTRABAND":[{"def":"Illegal or prohobited traffic.","pos":""},{"def":"Goods or merchandise the importation or exportation of which is forbidden.","pos":""}],"CONTRABANDISM":[{"def":"Traffic in contraband gods; smuggling.","pos":""}],"CONTRABANDIST":[{"def":"One who traffic illegaly; a smuggler.","pos":""}],"CONTRABASS":[{"def":"Con`tra*bass\" Defn: , n.","pos":""}],"CONTRABASSO":[{"def":"The largest kind of bass viol.","pos":""}],"CONTRACT":[{"def":"To shorten by omitting a letter or letters or by reducing two or more vowels or syllables to one.","pos":""}],"CONTRACT SYSTEM":[{"def":"The sweating system.","pos":""},{"def":"The system of employing convicts by selling their labor (to be performed inside the prison) at a fixed price per day to contractors who are allowed to have agents in the prison to superintend the work.","pos":""}],"CONTRACT TABLET":[{"def":"A clay tablet on which was inscribed a contract, for safe keeping.","pos":""}],"CONTRACTED":[{"def":"Drawn together; shrunken; wrinkled; narrow; as, a contracted brow; a contracted noun.","pos":""},{"def":"Narrow; illiberal; selfish; as, a contracted mind; contracted views.","pos":""}],"CONTRACTEDNESS":[{"def":"The state of being contracted; narrowness; meannes; selfishness.","pos":""}],"CONTRACTIBILITY":[{"def":"Capability of being contracted; quality of being contractible; as, the contractibiliy and dilatability of air.","pos":""}],"CONTRACTIBLE":[{"def":"Capable of contraction.","pos":""}],"CONTRACTIBLENESS":[{"def":"Contractibility.","pos":""}],"CONTRACTILE":[{"def":"tending to contract; having the power or property of contracting, or of shrinking into shorter or smaller dimensions; as, the contractile tissues.","pos":""}],"CONTRACTILITY":[{"def":"The power possessed by the fibers of living muscle of contracting or shortening.","pos":""}],"CONTRACTION":[{"def":"The process of shortening an operation.","pos":""},{"def":"The shortening of a word, or of two words, by the omission of a letter or letters, or by reducing two or more vowels or syllables to one; as, ne'er for never; can't for can not; don't for do not; it's for it is.","pos":""}],"CONTRACTIVE":[{"def":"Tending to contract; having the property or power or power of contracting.","pos":""}],"CONTRACTOR":[{"def":"One who contracts; one of the parties to a bargain; one who covenants to do anything for another; specifically, one who contracts to perform work on a rather large scale, at a certain price or rate, as in building houses or making a railroad.","pos":""}],"CONTRACTURE":[{"def":"A state of permanent rigidity or contraction of the muscles, generally of the flexor muscles.","pos":""}],"CONTRADANCE":[{"def":"A dance in which the partners are arranged face to face, or in opposite lines.","pos":""}],"CONTRADICT":[{"def":"To assert the contrary of; to oppose in words; to take issue with; to gainsay; to deny the truth of, as of a statement or a speaker; to impugn.","pos":""},{"def":"To be contrary to; to oppose; to resist.","pos":""}],"CONTRADICTABLE":[{"def":"Capable of being contradicting.","pos":""}],"CONTRADICTER":[{"def":"one who contradicts.","pos":""}],"CONTRADICTION":[{"def":"An assertion of the contrary to what has been said or affirmed; denial of the truth of a statement or assertion; contrary declaration; gainsaying.","pos":""},{"def":"Direct opposition or repugnancy; inconsistency; incongruity or contrariety; one who, or that which, is inconsistent.","pos":""}],"CONTRADICTIONAL":[{"def":"Contradictory; inconsistent; opposing.","pos":""}],"CONTRADICTIOUS":[{"def":"Filled with contradictions; inconsistent.","pos":""},{"def":"Inclined to contradict or cavil [Obs.","pos":""}],"CONTRADICTIVE":[{"def":"Contradictory; inconsistent.","pos":""}],"CONTRADICTORILY":[{"def":"In a contradictory manner.","pos":""}],"CONTRADICTORINESS":[{"def":"The quality of being contradictory; opposition; inconsistency.","pos":""}],"CONTRADICTORY":[{"def":"Affirming the contrary; implying a denial of what has been asserted; also, mutually contradicting; inconsistent.","pos":""},{"def":"Opposing or opposed; repugnant.","pos":""}],"CONTRADISTINCT":[{"def":"Distinguished by opposite qualities.","pos":""}],"CONTRADISTINCTION":[{"def":"Distinction by contrast.","pos":""}],"CONTRADISTINCTIVE":[{"def":"having the quality of contradistinction; distinguishing by contrast.","pos":""}],"CONTRADISTINGUISH":[{"def":"To distinguish by a contrast of opposite qualities.","pos":""}],"CONTRAFAGETTO":[{"def":"The double bassoon, an octave deeper than the bassoon.","pos":""}],"CONTRAFISSURE":[{"def":"A fissure or fracture on the side opposite to that which received the blow, or at some distance from it.","pos":""}],"CONTRAHENT":[{"def":"Entering into covenant; contracting; as, contrahent parties.","pos":""}],"CONTRAINDICANT":[{"def":"Something, as a symptom, indicating that the usual mode of treatment is not to be followed.","pos":""}],"CONTRAINDICATE":[{"def":"To indicate, as by a symptom, some method of treatment contrary to that which the general tenor of the case would seem to require.","pos":""}],"CONTRAINDICATION":[{"def":"An indication or symptom which forbids the method of treatment usual in such cases.","pos":""}],"CONTRALTO":[{"def":"Note: The usual range of the contralto voice is from G, below middle C, to the C above that; though exceptionally it embraces two octaves.","pos":""}],"CONTRANATURAL":[{"def":"Opposed to or against nature; unnatural.","pos":""}],"CONTRAPLEX":[{"def":"Pertaining to the sending of two messages in opposite directions at the same time.","pos":""}],"CONTRAPOSITION":[{"def":"A so-called immediate inference which consists in denying the original subject of the contradictory predicate; e.","pos":""}],"CONTRAPTION":[{"def":"A contrivance; a new-fangled device; -- used scornfully.","pos":""}],"CONTRAPUNTAL":[{"def":"Pertaining to, or according to the rules of, counterpoint.","pos":""}],"CONTRAPUNTIST":[{"def":"One skilled in counterpoint.","pos":""}],"CONTRAREMONSTRANT":[{"def":"One who remonstrates in opposition or answer to a remonstraint.","pos":""}],"CONTRARIANT":[{"def":"Contrary; opposed; antagonistic; inconsistent; contradictory.","pos":""}],"CONTRARIANTLY":[{"def":"Con*tra\"ri*ant*ly, adv.","pos":""}],"CONTRARIES":[{"def":"Propositions which directly and destructively contradict each other, but of which the falsehood of one does not establish the truth of the other.","pos":""}],"CONTRARIETY":[{"def":"The state or quality of being contrary; opposition; repugnance; disagreement; antagonism.","pos":""},{"def":"Something which is contrary to, or inconsistent with, something else; an inconsistency.","pos":""}],"CONTRARILY":[{"def":"Con\"tra*ri*ly or Defn: (adv.","pos":""}],"CONTRARINESS":[{"def":"state or quality of being contrary; opposition; inconsistency; contrariety; perverseness; obstinancy.","pos":""}],"CONTRARIOUS":[{"def":"Showing contrariety; repugnant; perverse.","pos":""}],"CONTRARIOUSLY":[{"def":"Contrarily; oppositely.","pos":""}],"CONTRARIWISE":[{"def":"On the contrary; oppositely; on the other hand.","pos":""},{"def":"In a contrary order; conversely.","pos":""}],"CONTRAROTATION":[{"def":"Circular motion in a direction contrary to some other circular motion.","pos":""}],"CONTRARY":[{"def":"Affirming the opposite; so opposed as to destroy each other; as, contrary propositions.","pos":""}],"CONTRAST":[{"def":"To stand in opposition; to exhibit difference, unlikeness, or opposition of qualities.","pos":""}],"CONTRASTIMULANT":[{"def":"Counteracting the effects of stimulants; relating to a course of medical treatment based on a theory of contrastimulants.","pos":""},{"def":"An agent which counteracts the effect of a stimulant.","pos":""}],"CONTRATE":[{"def":"Having cogs or teeth projecting parallel to the axis, instead of radiating from it.","pos":""}],"CONTRATENOR":[{"def":"Counter tenor; contralto.","pos":""}],"CONTRAVALLATION":[{"def":"A trench guarded with a parapet, constructed by besiegers, to secure themselves and check sallies of the besieged.","pos":""}],"CONTRAVENE":[{"def":"To meet in the way of opposition; to come into conflict with; to oppose; to contradict; to obstruct the operation of; to defeat.","pos":""},{"def":"To violate; to nullify; to be inconsistent with; as, to contravene a law.","pos":""}],"CONTRAVENER":[{"def":"One who contravenes.","pos":""}],"CONTRAVENTION":[{"def":"The act of contravening; opposition; obstruction; transgression; violation.","pos":""}],"CONTRAVERSION":[{"def":"A turning to the opposite side; antistrophe.","pos":""}],"CONTRAYERVA":[{"def":"A species of Dorstenia (D.","pos":""}],"CONTRECOUP":[{"def":"A concussion or shock produced by a blow or other injury, in a part or region opposite to that at which the blow is received, often causing rupture or disorganisation of the parts affected.","pos":""}],"CONTRETEMPS":[{"def":"An unexpected and untoward accident; something inopportune or embarassing; a hitch.","pos":""}],"CONTRIBUTABLE":[{"def":"Capable of being contributed.","pos":""}],"CONTRIBUTARY":[{"def":"Tributary; contributing.","pos":""}],"CONTRIBUTE":[{"def":"To give or grant i common with others; to give to a common stock or for a common purpose; to furnish or suply in part; to give (money or other aid) for a specified object; as, to contribute food or fuel for the poor.","pos":""}],"CONTRIBUTION":[{"def":"An irregular and arbitrary imposition or tax leved on the people of a town or country.","pos":""},{"def":"Payment, by each of several jointly liable, of a share in a loss suffered or an amount paid by one of their number for the common benefit.","pos":""}],"CONTRIBUTION PLAN":[{"def":"A plan of distributing surplus by giving to each policy the excess of premiums and interest earned thereon over the expenses of management, cost of insurance, and the policy value at the date of computation.","pos":""}],"CONTRIBUTIONAL":[{"def":"Pertaining to, or furnishing, a contribution.","pos":""}],"CONTRIBUTIVE":[{"def":"Contributing, or tending to contribute.","pos":""}],"CONTRIBUTOR":[{"def":"One who, or that which, contributes; specifically, one who writes articles for a newspaper or magazine.","pos":""}],"CONTRIBUTORY":[{"def":"Contributing to the same stock or purpose; promoting the same end; bringing assistance to some joint design, or increase to some common stock; contributive.","pos":""}],"CONTRIST":[{"def":"To deject and contrist myself.","pos":""}],"CONTRISTATE":[{"def":"To make sorrowful.","pos":""}],"CONTRITE":[{"def":"Thoroughly bruised or broken.","pos":""},{"def":"Broken down with grief and penitence; deeply sorrowful for sin because it is displeasing to God; humbly and thoroughly penitent.","pos":""}],"CONTRITENESS":[{"def":"Deep sorrow and penitence for sin; contrition.","pos":""}],"CONTRITION":[{"def":"The act of grinding or ribbing to powder; attrition; friction; rubbing.","pos":""},{"def":"The state of being contrite; deep sorrow and repentance for sin, because sin is displeasing to God; humble penitence; through repentance.","pos":""}],"CONTRITURATE":[{"def":"To triturate; to pulverize.","pos":""}],"CONTRIVABLE":[{"def":"Capable of being contrived, planned, invented, or devised.","pos":""}],"CONTRIVANCE":[{"def":"The act or faculty of contriving, inventing, devising, or planning.","pos":""},{"def":"The thing contrived, invented, or planned; disposition of parts or causes by design; a scheme; plan; atrifice; arrangement.","pos":""}],"CONTRIVE":[{"def":"To form by an exercise of ingenuity; to devise; to invent; to design; to plan.","pos":""}],"CONTRIVEMENT":[{"def":"Contrivance; invention; arrangement; design; plan.","pos":""}],"CONTRIVER":[{"def":"One who contrives, devises, plans, or schemas.","pos":""}],"CONTROL":[{"def":"A duplicate book, register, or account, kept to correct or check another account or register; a counter register.","pos":""},{"def":"That which serves to check, restrain, or hinder; restraint.","pos":""}],"CONTROLLABILITY":[{"def":"Capability of being controlled; controllableness.","pos":""}],"CONTROLLABLE":[{"def":"Capable of being controlled, checked, or restrained; amenable to command.","pos":""}],"CONTROLLABLENESS":[{"def":"Capability of being controlled.","pos":""}],"CONTROLLER":[{"def":"An iron block, usually bolted to a ship's deck, for controlling the running out of a chain cable.","pos":"verb"}],"CONTROLLERSHIP":[{"def":"The office of a controller.","pos":""}],"CONTROLMENT":[{"def":"The power or act of controlling; the state of being rstrained; control; restraint; regulation; superintendence.","pos":""},{"def":"Opposition; resistance; hostility.","pos":""}],"CONTROVERSAL":[{"def":"Turning or looking opposite ways.","pos":""}],"CONTROVERSE":[{"def":"To dispute; to controvert.","pos":""}],"CONTROVERSIAL":[{"def":"Relating to, or consisting of, controversy; disputatious; polemical; as, controversial divinity.","pos":""}],"CONTROVERSIALIST":[{"def":"One who carries on a controversy; a disputant.","pos":""}],"CONTROVERSIALLY":[{"def":"In a controversial manner.","pos":""}],"CONTROVERSION":[{"def":"Act of controverting; controversy.","pos":""}],"CONTROVERSY":[{"def":"Contention; dispute; debate; discussion; agitation of contrary opinions.","pos":""},{"def":"Quarrel; strife; cause of variance; difference.","pos":""}],"CONTROVERT":[{"def":"To make matter of controversy; to dispute or oppose by reasoning; to contend against in words or writings; to contest; to debate.","pos":""}],"CONTROVERTER":[{"def":"One who controverts; a controversial writer; a controversialist.","pos":""}],"CONTROVERTIBLE":[{"def":"Capable of being controverted; disputable; admitting of question.","pos":""}],"CONTROVERTIST":[{"def":"One skilled in or given to controversy; a controversialist.","pos":""},{"def":"Living or messing together; familiar; in companionship.","pos":""}]}