{"BEPAINT":[{"def":"To paint; to cover or color with, or as with, paint.","pos":""}],"BEPELT":[{"def":"To pelt roundly.","pos":""}],"BEPINCH":[{"def":"To pinch, or mark with pinches.","pos":""}],"BEPLASTER":[{"def":"To plaster over; to cover or smear thickly; to bedaub.","pos":""}],"BEPLUMED":[{"def":"Decked with feathers.","pos":""}],"BEPOMMEL":[{"def":"To pommel; to beat, as with a stick; figuratively, to assail or criticise in conversation, or in writing.","pos":""}],"BEPOWDER":[{"def":"To sprinkle or cover with powder; to powder.","pos":""}],"BEPRAISE":[{"def":"To praise greatly or extravagantly.","pos":""}],"BEPROSE":[{"def":"To reduce to prose.","pos":""}],"BEPUFFED":[{"def":"Puffed; praised.","pos":""}],"BEPURPLE":[{"def":"To tinge or dye with a purple color.","pos":""}]}