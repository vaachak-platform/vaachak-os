{"JAR":[{"def":"A deep, broad-mouthed vessel of earthenware or glass, for holding fruit, preserves, etc.","pos":""},{"def":"The measure of what is contained in a jar; as, a jar of oil; a jar of preserves.","pos":""}],"JARARACA":[{"def":"A poisonous serpent of Brazil (Bothrops jararaca), about eighteen inches long, and of a dusky, brownish color, variegated with red and black spots.","pos":""}],"JARBLE":[{"def":"To wet; to bemire.","pos":""}],"JARDINIERE":[{"def":"An ornamental stand or receptacle for plants, flowers, etc.","pos":""}],"JARDS":[{"def":"A callous tumor on the leg of a horse, below the hock.","pos":""}],"JARGLE":[{"def":"To emit a harsh or discordant sound.","pos":""}],"JARGON":[{"def":"Confused, unintelligible language; gibberish; hence, an artificial idiom or dialect; cant language; slang.","pos":""}],"JARGONELLE":[{"def":"A variety of pear which ripens early.","pos":""}],"JARGONIC":[{"def":"Of or pertaining to the mineral jargon.","pos":""}],"JARGONIST":[{"def":"One addicted to jargon; one who uses cant or slang.","pos":""}],"JARL":[{"def":"A chief; an earl; in English history, one of the leaders in the Danish and Norse invasions.","pos":""}],"JAROSITE":[{"def":"An ocher-yellow mineral occurring on minute rhombohedral crystals.","pos":""}],"JARRAH":[{"def":"The mahoganylike wood of the Australian Eucalyptus marginata.","pos":""}],"JARRING":[{"def":"Shaking; disturbing; discordant.","pos":""}],"JARRINGLY":[{"def":"In a jarring or discordant manner.","pos":""}]}