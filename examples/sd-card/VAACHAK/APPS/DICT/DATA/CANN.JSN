{"CANNA":[{"def":"A measure of length in Italy, varying from six to seven feet.","pos":""}],"CANNABENE":[{"def":"A colorless oil obtained from hemp dy distillation, and possessing its intoxicating properties.","pos":""}],"CANNABIN":[{"def":"A pisonous resin extracted from hemp (Cannabis sativa, variety Indica).","pos":""}],"CANNABINE":[{"def":"Pertaining to hemp; hempen.","pos":""}],"CANNABIS":[{"def":"A genus of a single species belonging to the order Uricaceæ; hemp.","pos":""}],"CANNEL COAL":[{"def":"A kind of mineral coal of a black color, sufficiently hard and solid to be cut and polished.","pos":""}],"CANNELE":[{"def":"A style of interweaving giving to fabrics a channeled or fluted effect; also, a fabric woven so as to have this effect; a rep.","pos":""}],"CANNELURE":[{"def":"A groove in any cylinder; specif.","pos":""}],"CANNERY":[{"def":"A place where the business of canning fruit, meat, etc.","pos":""}],"CANNIBAL":[{"def":"A human being that eats human flesh; hence, any that devours its own kind.","pos":""}],"CANNIBALISM":[{"def":"The act or practice of eating human flesh by mankind.","pos":""}],"CANNIBALLY":[{"def":"In the manner of cannibal.","pos":""}],"CANNIKIN":[{"def":"A small can or drinking vessel.","pos":""}],"CANNILY":[{"def":"In a canny manner.","pos":""}],"CANNINESS":[{"def":"Caution; crafty management.","pos":""}],"CANNON":[{"def":"A hollow cylindrical piece carried by a revolving shaft, on which it may, however, revolve independently.","pos":""}],"CANNONADE":[{"def":"The act of discharging cannon and throwing ball, shell, etc.","pos":""}],"CANNONED":[{"def":"Furnished with cannon.","pos":""},{"def":"A man who manages, or fires, cannon.","pos":""}],"CANNONERING":[{"def":"The use of cannon.","pos":""}],"CANNONRY":[{"def":"Cannon, collectively; artillery.","pos":""}],"CANNOT":[{"def":"Am, is, or are, not able; -- written either as one word or two.","pos":""}],"CANNULA":[{"def":"A small tube of metal, wood, or India rubber, used for various purposes, esp.","pos":""}],"CANNULAR":[{"def":"Having the form of a tube; tubular.","pos":""}],"CANNULATED":[{"def":"Hollow; affording a passage through its interior length for wire, thread, etc.","pos":""}]}