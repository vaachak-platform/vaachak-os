{"GAN":[{"def":"Began; commenced.","pos":""}],"GANANCIAL":[{"def":"Designating, pertaining to, or held under, the Spanish system of law (called ganancial system) which controls the title and disposition of the property acquired during marriage by the husband or wife.","pos":""}],"GANCH":[{"def":"To drop from a high place upon sharp stakes or hooks, as the Turks dropped malefactors, by way of punishment.","pos":""}],"GANDER":[{"def":"The male of any species of goose.","pos":""}],"GANE":[{"def":"To yawn; to gape.","pos":""}],"GANESA":[{"def":"The Hindoo god of wisdom or prudence.","pos":""}],"GANG":[{"def":"Note: Obsolete in English literature, but still used in the North of England, and also in Scotland.","pos":""}],"GANG-FLOWER":[{"def":"The common English milkwort (Polygala vulgaris), so called from blossoming in gang week.","pos":""}],"GANGE":[{"def":"To protect (the part of a line next a fishhook, or the hook itself) by winding it with wire.","pos":""},{"def":"To attach (a fishhook) to a line or snell, as by knotting the line around the shank of the hook.","pos":""}],"GANGER":[{"def":"One who oversees a gang of workmen.","pos":""}],"GANGETIC":[{"def":"Pertaining to, or inhabiting, the Ganges; as, the Gangetic shark.","pos":""}],"GANGION":[{"def":"A short line attached to a trawl.","pos":""},{"def":"Relating to a ganglion; ganglionic.","pos":""}],"GANGLION":[{"def":"A globular, hard, indolent tumor, situated somewhere on a tendon, and commonly formed by the effusion of a viscid fluid into it; -- called also weeping sinew.","pos":""}],"GANGLIONIC":[{"def":"Pertaining to, containing, or consisting of, ganglia or ganglion cells; as, a ganglionic artery; the ganglionic columns of the spinal cord.","pos":""}],"GANGREL":[{"def":"Wandering; vagrant.","pos":""}],"GANGRENE":[{"def":"A term formerly restricted to mortification of the soft tissues which has not advanced so far as to produce complete loss of vitality; but now applied to mortification of the soft parts in any stage.","pos":""}],"GANGRENESCENT":[{"def":"Tending to mortification or gangrene.","pos":""}],"GANGRENOUS":[{"def":"Affected by, or produced by, gangrene; of the nature of gangrene.","pos":""}],"GANGUE":[{"def":"The mineral or earthy substance associated with metallic ore.","pos":""}],"GANGWAY":[{"def":"The opening through the bulwarks of a vessel by which persons enter or leave it.","pos":""},{"def":"That part of the spar deck of a vessel on each side of the booms, from the quarter-deck to the forecastle; -- more properly termed the waist.","pos":""}],"GANIL":[{"def":"A kind of brittle limestone.","pos":""},{"def":"A refractory material consisting of crushed or ground siliceous stone, mixed with fire clay; -- used for lining Bessemer converters; also used for macadamizing roads.","pos":""}],"GANJA":[{"def":"The dried hemp plant, used in India for smoking.","pos":""}],"GANNET":[{"def":"One of several species of sea birds of the genus Sula, allied to the pelicans.","pos":""}],"GANOCEPHALA":[{"def":"A group of fossil amphibians allied to the labyrinthodonts, having the head defended by bony, sculptured plates, as in some ganoid fishes.","pos":""}],"GANOCEPHALOUS":[{"def":"Of or pertaining to the Ganocephala.","pos":""}],"GANOID":[{"def":"Of or pertaining to Ganoidei.","pos":""}],"GANOIDEI":[{"def":"One of the subclasses of fishes.","pos":""}],"GANOINE":[{"def":"A peculiar bony tissue beneath the enamel of a ganoid scale.","pos":""}],"GANTLET":[{"def":"A military punishment formerly in use, wherein the offender was made to run between two files of men facing one another, who struck him as he passed.","pos":""}],"GANTLINE":[{"def":"A line rigged to a mast; -- used in hoisting rigging; a girtline.","pos":""}],"GANZ SYSTEM":[{"def":"A haulage system for canal boats, in which an electric locomotive running on a monorail has its adhesion materially increased by the pull of the tow rope on a series of inclined gripping wheels.","pos":""}],"GANZA":[{"def":"A kind of wild goose, by a flock of which a virtuoso was fabled to be carried to the lunar world.","pos":""}]}