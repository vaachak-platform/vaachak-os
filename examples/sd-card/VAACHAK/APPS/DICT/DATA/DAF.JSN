{"DAFF":[{"def":"To cast aside; to put off; to doff.","pos":""}],"DAFFODIL":[{"def":"With damasc roses and daffadowndillies set.","pos":""}],"DAFT":[{"def":"Stupid; folish; idiotic; also, delirious; insance; as, he has gone daft.","pos":""},{"def":"Gay; playful; frolicsome.","pos":""}],"DAFTNESS":[{"def":"The quality of being daft.","pos":""}]}