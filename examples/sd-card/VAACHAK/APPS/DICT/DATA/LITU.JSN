{"LITUATE":[{"def":"Forked, with the points slightly curved outward.","pos":""}],"LITUIFORM":[{"def":"Having the form of a lituus; like a lituite.","pos":""}],"LITUITE":[{"def":"Any species of ammonites of the genus Lituites.","pos":""}],"LITURATE":[{"def":"Having indistinct spots, paler at their margins.","pos":""},{"def":"Spotted, as if from abrasions of the surface.","pos":""}],"LITURGICALLY":[{"def":"In the manner of a liturgy.","pos":""}],"LITURGICS":[{"def":"The science of worship; history, doctrine, and interpretation of liturgies.","pos":""}],"LITURGIOLOGIST":[{"def":"One versed in liturgiology.","pos":""}],"LITURGIOLOGY":[{"def":"The science treating of liturgical matters; a treatise on, or description of, liturgies.","pos":""}],"LITURGIST":[{"def":"One who favors or adheres strictly to a liturgy.","pos":""}],"LITURGY":[{"def":"An established formula for public worship, or the entire ritual for public worship in a church which uses prescribed forms; a formulary for public prayer or devotion.","pos":""}],"LITUUS":[{"def":"A spiral whose polar equation is r2th = a; that is, a curve the square of whose radius vector varies inversely as the angle which the radius vector makes with a given line.","pos":""}]}