{"PAP":[{"def":"A nipple; a mammilla; a teat.","pos":""}],"PAPA":[{"def":"A child's word for father.","pos":""},{"def":"A parish priest in the Greek Church.","pos":""}],"PAPABOTE":[{"def":"The upland plover.","pos":""}],"PAPACY":[{"def":"The office and dignity of the pope, or pontiff, of Rome; papal jurisdiction.","pos":""},{"def":"The popes, collectively; the succession of popes.","pos":""}],"PAPAGAY":[{"def":"See Popinjay, 1 (b).","pos":""}],"PAPAIN":[{"def":"A proteolytic ferment, like trypsin, present in the juice of the green fruit of the papaw (Carica Papaya) of tropical America.","pos":""}],"PAPAL":[{"def":"Of or pertaining to the pope of Rome; proceeding from the pope; ordered or pronounced by the pope; as, papal jurisdiction; a papal edict; the papal benediction.","pos":""},{"def":"Of or pertaining to the Roman Catholic Church.","pos":""}],"PAPALIZE":[{"def":"To conform to popery.","pos":""}],"PAPAPHOBIA":[{"def":"Intense fear or dread of the pope, or of the Roman Catholic Church.","pos":""}],"PAPARCHY":[{"def":"Government by a pope; papal rule.","pos":""}],"PAPAVER":[{"def":"A genus of plants, including the poppy.","pos":""}],"PAPAVERACEOUS":[{"def":"Of, pertaining to, or resembling, a natural order of plants (Papaveraceæ) of which the poppy, the celandine, and the bloodroot are well-known examples.","pos":""}],"PAPAVERINE":[{"def":"An alkaloid found in opium.","pos":""}],"PAPAVEROUS":[{"def":"Of or pertaining to the poppy; of the nature of the poppy.","pos":""}],"PAPAW":[{"def":"A tree (Carica Papaya) of tropical America, belonging to the order Passifloreæ.","pos":""},{"def":"A tree of the genus Asimina (A.","pos":""}],"PAPBOAT":[{"def":"A large spiral East Indian marine shell (Turbinella rapha); -- so called because used by native priests to hold the oil for anointing.","pos":""}],"PAPE":[{"def":"A spiritual father; specifically, the pope.","pos":""}],"PAPER":[{"def":"A substance in the form of thin sheets or leaves intended to be written or printed on, or to be used in wrapping.","pos":""},{"def":"A sheet, leaf, or piece of such substance.","pos":""}],"PAPERWEIGHT":[{"def":"See under Paper, n.","pos":""}],"PAPERY":[{"def":"Like paper; having the thinness or consistence of paper.","pos":""}],"PAPESCENT":[{"def":"Containing or producing pap; like pap.","pos":""}],"PAPESS":[{"def":"A female pope; i.","pos":""}],"PAPETERIE":[{"def":"A case or box containing paper and materials for writing.","pos":""}],"PAPHIAN":[{"def":"Of or pertaining to Paphos, an ancient city of Cyprus, having a celebrated temple of Venus; hence, pertaining to Venus, or her rites.","pos":""}],"PAPIER-MACHE":[{"def":"A hard and strong substance made of a pulp from paper, mixed with sise or glue, etc.","pos":""}],"PAPILIO":[{"def":"A genus of butterflies.","pos":""}],"PAPILIONACEOUS":[{"def":"Resembling the butterfly.","pos":""}],"PAPILIONES":[{"def":"The division of Lepidoptera which includes the butterflies.","pos":""}],"PAPILIONIDES":[{"def":"The typical butterflies.","pos":""}],"PAPILLA":[{"def":"Any minute nipplelike projection; as, the papillæ of the tongue.","pos":""}],"PAPILLAR":[{"def":"Same as Papillose.","pos":""}],"PAPILLARY":[{"def":"Of, pertaining to, or resembling, a papilla or papillæ; bearing, or covered with, papillæ; papillose.","pos":""}],"PAPILLATE":[{"def":"To cover with papillæ; to take the form of a papilla, or of papillæ.","pos":""}],"PAPILLIFORM":[{"def":"Shaped like a papilla; mammilliform.","pos":""}],"PAPILLOMA":[{"def":"A tumor formed by hypertrophy of the papillæ of the skin or mucous membrane, as a corn or a wart.","pos":""}],"PAPILLOMATOUS":[{"def":"Of, pertaining to, or consisting of, papillomata.","pos":""}],"PAPILLOSE":[{"def":"Covered with, or bearing, papillæ; resembling papillæ; papillate; papillar; papillary.","pos":""}],"PAPILLOTE":[{"def":"a small piece of paper on which women roll up their hair to make it curl; a curl paper.","pos":""}],"PAPILLOUS":[{"def":"Papillary; papillose.","pos":""}],"PAPILLULATE":[{"def":"Having a minute papilla in the center of a larger elevation or depression.","pos":""}],"PAPION":[{"def":"A West African baboon (Cynocephalus sphinx), allied to the chacma.","pos":""}],"PAPISM":[{"def":"Popery; -- an offensive term.","pos":""}],"PAPIST":[{"def":"A Roman catholic; one who adheres to the Church of Rome and the authority of the pope; -- an offensive designation applied to Roman Catholics by their opponents.","pos":""},{"def":"Of or pertaining to the Church of Rome and its doctrines and ceremonies; pertaining to popery; popish; -- used disparagingly.","pos":""}],"PAPISTRY":[{"def":"The doctrine and ceremonies of the Church of Rome; popery.","pos":""}],"PAPIZED":[{"def":"Conformed to popery.","pos":""}],"PAPOOSE":[{"def":"A babe or young child of Indian parentage in North America.","pos":""}],"PAPPIFORM":[{"def":"Resembling the pappus of composite plants.","pos":""}],"PAPPOOSE":[{"def":"Same as Papoose.","pos":""}],"PAPPOSE":[{"def":"Furnished with a pappus; downy.","pos":""}],"PAPPUS":[{"def":"The hairy or feathery appendage of the achenes of thistles, dandelions, and most other plants of the order Compositæ; also, the scales, awns, or bristles which represent the calyx in other plants of the same order.","pos":""}],"PAPPY":[{"def":"Like pap; soft; succulent; tender.","pos":""},{"def":"The dried ripened fruit of Capsicum annuum or various other species of pepper; also, the mildly pungent condiment prepared from it.","pos":""}],"PAPUAN":[{"def":"Of or pertaining to Papua.","pos":""}],"PAPUARS":[{"def":"The native black race of Papua or New Guinea, and the adjacent islands.","pos":""}],"PAPULA":[{"def":"A pimple; a small, usually conical, elevation of the cuticle, produced by congestion, accumulated secretion, or hypertrophy of tissue; a papule.","pos":""},{"def":"One of the numerous small hollow processes of the integument between the plates of starfishes.","pos":""}],"PAPULAR":[{"def":"Consisting of papules; characterized by the presence of papules; as, a papular eruption.","pos":""}],"PAPULOSE":[{"def":"Having papulæ; papillose; as, a papulose leaf.","pos":""}],"PAPULOUS":[{"def":"Covered with, or characterized by, papulæ; papulose.","pos":""}],"PAPYRACEOUS":[{"def":"Made of papyrus; of the consistency of paper; papery.","pos":""}],"PAPYREAN":[{"def":"Of or pertaining to papyrus, or to paper; papyraceous.","pos":""}],"PAPYRINE":[{"def":"Imitation parchment, made by soaking unsized paper in dilute sulphuric acid.","pos":""}],"PAPYROGRAPH":[{"def":"An apparatus for multiplying writings, drawings, etc.","pos":""}],"PAPYROGRAPHY":[{"def":"The process of multiplying copies of writings, etc.","pos":""}],"PAPYRUS":[{"def":"A tall rushlike plant (Cyperus Papyrus) of the Sedge family, formerly growing in Egypt, and now found in Abyssinia, Syria, Sicily, etc.","pos":""}]}