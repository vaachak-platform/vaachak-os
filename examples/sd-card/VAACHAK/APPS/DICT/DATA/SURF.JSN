{"SURF":[{"def":"The swell of the sea which breaks upon the shore, esp.","pos":""}],"SURFACE":[{"def":"A magnitude that has length and breadth without thickness; superficies; as, a plane surface; a spherical surface.","pos":""},{"def":"That part of the side which is terminated by the flank prolonged, and the angle of the nearest bastion.","pos":""}],"SURFACE LOADING":[{"def":"The weight supported per square unit of surface; the quotient obtained by dividing the gross weight, in pounds, of a fully loaded flying machine, by the total area, in square feet, of its supporting surface.","pos":""}],"SURFACE TENSION":[{"def":"That property, due to molecular forces, which exists in the surface film of all liquids and tends to bring the contained volume into a form having the least superficial area.","pos":""}],"SURFACER":[{"def":"A form of machine for dressing the surface of wood, metal, stone, etc.","pos":""}],"SURFBOAT":[{"def":"A boat intended for use in heavy surf.","pos":""}],"SURFEIT":[{"def":"Excess in eating and drinking.","pos":""},{"def":"Fullness and oppression of the system, occasioned often by excessive eating and drinking.","pos":""}],"SURFEIT-WATER":[{"def":"Water for the cure of surfeits.","pos":""},{"def":"To wash, as the face, with a cosmetic water, said by some to be prepared from the sulphur.","pos":""}],"SURFEITER":[{"def":"One who surfeits.","pos":""}],"SURFMAN":[{"def":"One who serves in a surfboat in the life-saving service.","pos":""}],"SURFOOT":[{"def":"Tired or sore of foot from travel; lamed.","pos":""}],"SURFY":[{"def":"Consisting of, abounding in, or resembling, surf; as, a surfy shore.","pos":""}]}