{"NONPAREIL":[{"def":"A size of type next smaller than minion and next larger than agate (or ruby).","pos":""}],"NONPAYMENT":[{"def":"Neglect or failure to pay.","pos":""}],"NONPERFORMANCE":[{"def":"Neglect or failure to perform.","pos":""}],"NONPHOTOBIOTIC":[{"def":"Capable of living without light; as, nonphotobiotic plant cells, or cells which habitually live in darkness.","pos":""}],"NONPLANE":[{"def":"Not lying in one plane; -- said of certain curves.","pos":""}],"NONPLUS":[{"def":"A state or condition which daffles reason or confounds judgment; insuperable difficalty; inability to proceed or decide; puzzle; quandary.","pos":""}],"NONPREPARATION":[{"def":"Neglect or failure to prepare; want of preparation.","pos":""}],"NONPRESENTATION":[{"def":"Neglect or failure to present; state of not being presented.","pos":""}],"NONPRODUCTION":[{"def":"A failure to produce or exhibit.","pos":""}],"NONPROFESSIONAL":[{"def":"Not belonging to a profession; not done by, or proceeding from, professional men; contrary to professional usage.","pos":""}],"NONPROFICIENCY":[{"def":"Want of proficiency; failure to make progress.","pos":""}],"NONPROFICIENT":[{"def":"One who has failed to become proficient.","pos":""},{"def":"An abbreviation of Non prosequitur.","pos":""}]}