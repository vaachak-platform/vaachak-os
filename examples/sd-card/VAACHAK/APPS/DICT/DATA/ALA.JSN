{"ALA":[{"def":"A winglike organ, or part.","pos":""}],"ALABAMA PERIOD":[{"def":"A period in the American eocene, the lowest in the tertiary age except the lignitic.","pos":""}],"ALABASTER":[{"def":"A box or vessel for holding odoriferous ointments, etc.","pos":""}],"ALABASTRINE":[{"def":"Of, pertaining to, or like, alabaster; as alabastrine limbs.","pos":""}],"ALACK":[{"def":"An exclamation expressive of sorrow.","pos":""}],"ALACKADAY":[{"def":"An exclamation expressing sorrow.","pos":""}],"ALACRIFY":[{"def":"To rouse to action; to inspirit.","pos":""}],"ALACRIOUS":[{"def":"Brisk; joyously active; lively.","pos":""}],"ALACRIOUSLY":[{"def":"With alacrity; briskly.","pos":""}],"ALACRITY":[{"def":"A cheerful readiness, willingness, or promptitude; joyous activity; briskness; sprightliness; as, the soldiers advanced with alacrity to meet the enemy.","pos":""}],"ALADINIST":[{"def":"One of a sect of freethinkers among the Mohammedans.","pos":""}],"ALALIA":[{"def":"Inability to utter articulate sounds, due either to paralysis of the larynx or to that form of aphasia, called motor, or ataxis, aphasia, due to loss of control of the muscles of speech.","pos":""}],"ALAMIRE":[{"def":"The lowest note but one in Guido Aretino's scale of music.","pos":""}],"ALAMODALITY":[{"def":"The quality of being à la mode; conformity to the mode or fashion; fashionableness.","pos":""}],"ALAMODE":[{"def":"According to the fashion or prevailing mode.","pos":""}],"ALAMORT":[{"def":"To the death; mortally.","pos":""}],"ALAND":[{"def":"On land; to the land; ashore.","pos":""}],"ALANINE":[{"def":"A white crystalline base, C3H7NO2, derived from aldehyde ammonia.","pos":""}],"ALAR":[{"def":"Axillary; in the fork or axil.","pos":""}],"ALARM":[{"def":"A summons to arms, as on the approach of an enemy.","pos":""},{"def":"Any sound or information intended to give notice of approaching danger; a warming sound to arouse attention; a warning of danger.","pos":""}],"ALARMABLE":[{"def":"Easily alarmed or disturbed.","pos":""}],"ALARMED":[{"def":"Aroused to vigilance; excited by fear of approaching danger; agitated; disturbed; as, an alarmed neighborhood; an alarmed modesty.","pos":""}],"ALARMEDLY":[{"def":"In an alarmed manner.","pos":""}],"ALARMING":[{"def":"Exciting, or calculated to excite, alarm; causing apprehension of danger; as, an alarming crisis or report.","pos":""}],"ALARMIST":[{"def":"One prone to sound or excite alarms, especially, needless alarms.","pos":""}],"ALARUM":[{"def":"Note: The variant form alarum is now commonly restricted to an alarm signal or the mechanism to sound an alarm (as in an alarm clock.","pos":""}],"ALARY":[{"def":"Of or pertaining to wings; also, wing-shaped.","pos":""}],"ALAS":[{"def":"An exclamation expressive of sorrow, pity, or apprehension of evil; -- in old writers, sometimes followed by day or white; alas the day, like alack a day, or alas the white.","pos":""}],"ALATE":[{"def":"Lately; of late.","pos":""},{"def":"Winged; having wings, or side appendages like wings.","pos":""}],"ALATION":[{"def":"The state of being winged.","pos":""}]}