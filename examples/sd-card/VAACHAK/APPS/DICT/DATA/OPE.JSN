{"OPE":[{"def":"On Sunday heaven's gate stands ope.","pos":""}],"OPEIDOSCOPE":[{"def":"An instrument, consisting of a tube having one end open and the other end covered with a thin flexible membrance to the center of which is attached a small mirror.","pos":""}],"OPELET":[{"def":"A bright-colored European actinian (Anemonia, or Anthea, sulcata); -- so called because it does not retract its tentacles.","pos":""}],"OPEN":[{"def":"Free of access; not shut up; not closed; affording unobstructed ingress or egress; not impeding or preventing passage; not locked up or covered over; -- applied to passageways; as, an open door, window, road, etc.","pos":""},{"def":"Free to be used, enjoyed, visited, or the like; not private; public; unrestricted in use; as, an open library, museum, court, or other assembly; liable to the approach, trespass, or attack of any one; unprotected; exposed.","pos":""}],"OPEN DOOR":[{"def":"She of the open soul and open door, With room about her hearth for all mankind.","pos":""}],"OPEN SEA":[{"def":"A sea open to all nations.","pos":""}],"OPEN VERDICT":[{"def":"A verdict on a preliminary investigation, finding the fact of a crime but not stating the criminal, or finding the fact of a violent death without disclosing the cause.","pos":""}],"OPEN-AIR":[{"def":"Taking place in the open air; outdoor; as, an open-air game or meeting.","pos":""}],"OPEN-EYED":[{"def":"With eyes widely open; watchful; vigilant.","pos":""}],"OPEN-HANDED":[{"def":"Generous; liberal; munificent.","pos":""}],"OPEN-HEARTED":[{"def":"Candid; frank; generous.","pos":""}],"OPEN-MOUTHED":[{"def":"Having the mouth open; gaping; hence, greedy; clamorous.","pos":""}],"OPENBILL":[{"def":"A bird of the genus Anastomus, allied to the stork; -- so called because the two parts of the bill touch only at the base and tip.","pos":""}],"OPENER":[{"def":"One who, or that which, opens.","pos":""}],"OPENING":[{"def":"The act or process of opening; a beginning; commencement; first appearance; as, the opening of a speech.","pos":""},{"def":"A place which is open; a breach; an aperture; a gap; cleft, or hole.","pos":""}],"OPENLY":[{"def":"In an open manner; publicly; not in private; without secrecy.","pos":""},{"def":"Without reserve or disguise; plainly; evidently.","pos":""}],"OPENNESS":[{"def":"The quality or state of being open.","pos":""}],"OPENWORK":[{"def":"A quarry; an open cut.","pos":""}],"OPERA":[{"def":"A drama, either tragic or comic, of which music forms an essential part; a drama wholly or mostly sung, consisting of recitative, arials, choruses, duets, trios, etc.","pos":""},{"def":"The score of a musical drama, either written or in print; a play set to music.","pos":""}],"OPERAMETER":[{"def":"An instrument or machine for measuring work done, especially for ascertaining the number of rotations made by a machine or wheel in manufacturing cloth; a counter.","pos":""},{"def":"The act of operating or working; operation.","pos":""}],"OPERAND":[{"def":"The symbol, quantity, or thing upon which a mathematical operation is performed; -- called also faciend.","pos":""}],"OPERANT":[{"def":"An operative person or thing.","pos":""}],"OPERATE":[{"def":"To perform some manual act upon a human body in a methodical manner, and usually with instruments, with a view to restore soundness or health, as in amputation, lithotomy, etc.","pos":""}],"OPERATION":[{"def":"Something to be done; some transformation to be made upon quantities, the transformation being indicated either by rules or symbols.","pos":""},{"def":"Any methodical action of the hand, or of the hand with instruments, on the human body, to produce a curative or remedial effect, as in amputation, etc.","pos":""}],"OPERATIVE":[{"def":"Based upon, or consisting of, an operation or operations; as, operative surgery.","pos":""}],"OPERATIVELY":[{"def":"In an operative manner.","pos":""}],"OPERATOR":[{"def":"One who performs some act upon the human body by means of the hand, or with instruments.","pos":""},{"def":"The symbol that expresses the operation to be performed; -- called also facient.","pos":""}],"OPERCLE":[{"def":"Any one of the bony plates which support the gill covers of fishes; an opercular bone.","pos":""}],"OPERCULAR":[{"def":"Of, pertaining to, or like, an operculum.","pos":""}],"OPERCULIFEROUS":[{"def":"Bearing an operculum.","pos":""}],"OPERCULIFORM":[{"def":"Having the form of a lid or cover.","pos":""}],"OPERCULIGENOUS":[{"def":"Producing an operculum; -- said of the foot, or part of the foot, of certain mollusks.","pos":""}],"OPERETTA":[{"def":"A short, light, musical drama.","pos":""}],"OPEROSE":[{"def":"Wrought with labor; requiring labor; hence, tedious; wearisome.","pos":""}],"OPERTANEOUS":[{"def":"Concealed; private.","pos":""}],"OPETIDE":[{"def":"Open time; -- applied to different things: (a) The early spring, or the time when flowers begin opening.","pos":""}]}