{"SIMAR":[{"def":"A woman's long dress or robe; also light covering; a scarf.","pos":""}],"SIMBLOT":[{"def":"The harness of a drawloom.","pos":""}],"SIMIA":[{"def":"A Linnæan genus of Quadrumana which included the types of numerous modern genera.","pos":""}],"SIMIAL":[{"def":"Simian; apelike.","pos":""}],"SIMIAN":[{"def":"Of or pertaining to the family Simiadæ, which, in its widest sense, includes all the Old World apes and monkeys; also, apelike.","pos":""},{"def":"Any Old World monkey or ape.","pos":""}],"SIMILAR":[{"def":"Exactly corresponding; resembling in all respects; precisely like.","pos":""},{"def":"Nearly corresponding; resembling in many respects; somewhat like; having a general likeness.","pos":""}],"SIMILARITY":[{"def":"The quality or state of being similar; likeness; resemblance; as, a similarity of features.","pos":""}],"SIMILARLY":[{"def":"In a similar manner.","pos":""}],"SIMILARY":[{"def":"Rhyming cadences of similarly words.","pos":""}],"SIMILATIVE":[{"def":"Implying or indicating likeness or resemblance.","pos":""}],"SIMILE":[{"def":"A word or phrase by which anything is likened, in one or more of its aspects, to something else; a similitude; a poetical or imaginative comparison.","pos":""}],"SIMILITER":[{"def":"The technical name of the form by which either party, in pleading, accepts the issue tendered by his opponent; -- called sometimes a joinder in issue.","pos":""}],"SIMILITUDE":[{"def":"The quality or state of being similar or like; resemblance; likeness; similarity; as, similitude of substance.","pos":""},{"def":"The act of likening, or that which likens, one thing to another; fanciful or imaginative comparison; a simile.","pos":""}],"SIMILITUDINARY":[{"def":"Involving or expressing similitude.","pos":""}],"SIMILIZE":[{"def":"To liken; to compare; as, to similize a person, thing, or act.","pos":""}],"SIMILOR":[{"def":"An alloy of copper and zinc, resembling brass, but of a golden color.","pos":""}],"SIMIOUS":[{"def":"Of or pertaining to the Simian.","pos":""}],"SIMMER":[{"def":"To boil gently, or with a gentle hissing; to begin to boil.","pos":""}],"SIMNEL":[{"def":"A kind of cake made of fine flour; a cracknel.","pos":""},{"def":"A kind of rich plum cake, eaten especially on Mid-Lent Sunday.","pos":""}],"SIMON-PURE":[{"def":"Genuine; true; real; authentic; -- a term alluding to the comedy character Simon Pure, who is impersonated by another and is obliged to prove himself to be the \"real Simon Pure.","pos":""}],"SIMONIAC":[{"def":"One who practices simony, or who buys or sells preferment in the church.","pos":""}],"SIMONIACAL":[{"def":"Of or pertaining to simony; guilty of simony; consisting of simony.","pos":""}],"SIMONIAN":[{"def":"One of the followers of Simon Magus; also, an adherent of certain heretical sects in the early Christian church.","pos":"noun"}],"SIMONIST":[{"def":"One who practices simony.","pos":""}],"SIMONY":[{"def":"The crime of buying or selling ecclesiastical preferment; the corrupt presentation of any one to an ecclesiastical benefice for money or reward.","pos":""},{"def":"A hot, dry, suffocating, dust-laden wind, that blows occasionally in Arabia, Syria, and neighboring countries, generated by the extreme heat of the parched deserts or sandy plains.","pos":""}],"SIMOUS":[{"def":"Having a very flat or snub nose, with the end turned up.","pos":""}],"SIMPAI":[{"def":"A long-tailed monkey (Semnopitchecus melalophus) native of Sumatra.","pos":"noun"}],"SIMPER":[{"def":"To smile in a silly, affected, or conceited manner.","pos":""},{"def":"To glimmer; to twinkle.","pos":""}],"SIMPERER":[{"def":"One who simpers.","pos":""}],"SIMPERINGLY":[{"def":"In a simpering manner.","pos":""}],"SIMPLE":[{"def":"Without subdivisions; entire; as, a simple stem; a simple leaf.","pos":""},{"def":"Not capable of being decomposed into anything more simple or ultimate by any means at present known; elementary; thus, atoms are regarded as simple bodies.","pos":""}],"SIMPLE-HEARTED":[{"def":"Sincere; inguenuous; guileless.","pos":""}],"SIMPLE-MINDED":[{"def":"Artless; guileless; simple-hearted; undesigning; unsuspecting; devoid of duplicity.","pos":""}],"SIMPLENESS":[{"def":"The quality or state of being simple; simplicity.","pos":""}],"SIMPLER":[{"def":"One who collects simples, or medicinal plants; a herbalist; a simplist.","pos":""}],"SIMPLESS":[{"def":"Simplicity; silliness.","pos":""}],"SIMPLETON":[{"def":"A person of weak intellect; a silly person.","pos":""}],"SIMPLICIAN":[{"def":"One who is simple.","pos":""}],"SIMPLICITY":[{"def":"The quality or state of being simple, unmixed, or uncompounded; as, the simplicity of metals or of earths.","pos":""},{"def":"The quality or state of being not complex, or of consisting of few parts; as, the simplicity of a machine.","pos":""}],"SIMPLIFICATION":[{"def":"The act of simplifying.","pos":""}],"SIMPLIFY":[{"def":"To make simple; to make less complex; to make clear by giving the explanation for; to show an easier or shorter process for doing or making.","pos":""}],"SIMPLIST":[{"def":"One skilled in simples, or medicinal plants; a simpler.","pos":""}],"SIMPLISTIC":[{"def":"Of or pertaining to simples, or a simplist.","pos":""}],"SIMPLY":[{"def":"In a simple manner or state; considered in or by itself; without addition; along; merely; solely; barely.","pos":""},{"def":"Plainly; without art or subtlety.","pos":""}],"SIMULACRUM":[{"def":"A likeness; a semblance; a mock appearance; a sham; -- now usually in a derogatory sense.","pos":""}],"SIMULAR":[{"def":"One who pretends to be what he is not; one who, or that which, simulates or counterfeits something; a pretender.","pos":""}],"SIMULATE":[{"def":"Feigned; pretended.","pos":""}],"SIMULATION":[{"def":"The act of simulating, or assuming an appearance which is feigned, or not true; -- distinguished from dissimulation, which disguises or conceals what is true.","pos":""}],"SIMULATOR":[{"def":"One who simulates, or feigns.","pos":""}],"SIMULATORY":[{"def":"Simulated, or capable of being simulated.","pos":""}],"SIMULTANEITY":[{"def":"The quality or state of being simultaneous; simultaneousness.","pos":""}],"SIMULTANEOUS":[{"def":"Existing, happening, or done, at the same time; as, simultaneous events.","pos":""}],"SIMULTY":[{"def":"Private grudge or quarrel; as, domestic simulties.","pos":""}]}