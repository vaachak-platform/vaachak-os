{"CONSPECIFIC":[{"def":"Of the same species.","pos":""}],"CONSPECTUITY":[{"def":"The faculty of seeing; sight; eye.","pos":""}],"CONSPECTUS":[{"def":"A general sketch or outline of a subject; a synopsis; an epitome.","pos":""}],"CONSPERSION":[{"def":"The act of sprinkling.","pos":""}],"CONSPICUITY":[{"def":"The state or quality of being clear or bright; brightness; conspicuosness.","pos":""}],"CONSPICUOUS":[{"def":"Open to the view; obvious to the eye; easy to be seen; plainly visible; manifest; attracting the eye.","pos":""},{"def":"Obvious to the mental eye; easily recognized; clearly defined; notable; prominent; eminent; distinguished; as, a conspicuous exellence, or fault.","pos":""}],"CONSPIRACY":[{"def":"An agreement, manifesting itself in words or deeds, by which two or more persons confederate to do an unlawful act, or to use unlawful to do an act which is lawful; confederacy.","pos":""}],"CONSPIRANT":[{"def":"Engaging in a plot to commit a crime; conspiring.","pos":""}],"CONSPIRATION":[{"def":"Agreement or concurrence for some end or purpose; conspiracy.","pos":""}],"CONSPIRATOR":[{"def":"One who engages in a conspiracy; a plotter.","pos":""}],"CONSPIRE":[{"def":"To make an agreement, esp.","pos":""},{"def":"To concur to one end; to agree.","pos":""}],"CONSPIRER":[{"def":"One who conspires; a conspirator.","pos":""}],"CONSPIRINGLY":[{"def":"In the manner of a conspirator; by conspiracy.","pos":""}],"CONSPISSATION":[{"def":"A making thick or viscous; thickness; inspissation.","pos":""}],"CONSPURCATE":[{"def":"To pollute; to defile.","pos":""}],"CONSPURCATION":[{"def":"This act of defiling; defilement; pollution.","pos":""}]}