{"DEUCE":[{"def":"Two; a card or a die with two spots; as, the deuce of hearts.","pos":""},{"def":"A condition of the score beginning whendeuce, which decides the game.","pos":""}],"DEUCED":[{"def":"Devilish; excessive; extreme.","pos":""},{"def":"See Deuce, Deuced.","pos":""}],"DEUTEROCANONICAL":[{"def":"Pertaining to a second canon, or ecclesiastical writing of inferior authority; -- said of the Apocrypha, certain Epistles, etc.","pos":""}],"DEUTEROGAMIST":[{"def":"One who marries the second time.","pos":""}],"DEUTEROGAMY":[{"def":"A second marriage, after the death of the first husband of wife; -- in distinction from bigamy, as defined in the old canon law.","pos":""}],"DEUTEROGENIC":[{"def":"Of secondary origin; -- said of certain rocks whose material has been derived from older rocks.","pos":""}],"DEUTERONOMIST":[{"def":"The writer of Deuteronomy.","pos":""}],"DEUTERONOMY":[{"def":"The fifth book of the Pentateuch, containing the second giving of the law by Moses.","pos":""},{"def":"A sympathetic affection of any part of the body, as headache from an overloaded stomach.","pos":""}],"DEUTEROPATHIC":[{"def":"Pertaining to deuteropathy; of the nature of deuteropathy.","pos":""}],"DEUTEROSCOPY":[{"def":"That which is seen at a second view; a meaning beyond the literal sense; the second intention; a hidden signification.","pos":""}],"DEUTEROZOOID":[{"def":"One of the secondary, and usually sexual, zooids produced by budding or fission from the primary zooids, in animals having alternate generations.","pos":""}],"DEUTHYDROGURET":[{"def":"Same as Deutohydroguret.","pos":""},{"def":"A prefix which formerly properly indicated the second in a regular series of compound in the series, and not to its composition, but which is now generally employed in the same sense as bi- or di-, although little used.","pos":""}],"DEUTOHYDROGURET":[{"def":"A compound containing in the molecule two atoms of hydrogen united with some other element or radical.","pos":""}],"DEUTOPLASM":[{"def":"The lifeless food matter in the cytoplasm of an ovum or a cell, as distinguished from the active or true protoplasm; yolk substance; yolk.","pos":""}],"DEUTOPLASTIC":[{"def":"Pertaining to, or composed of, deutoplasm.","pos":""}],"DEUTOSULPHURET":[{"def":"Deu`to*sul\"phu*ret, n.","pos":""}],"DEUTOXIDE":[{"def":"A compound containing in the molecule two atoms of oxygen united with some other element or radical; -- usually called dioxide, or less frequently, binoxide.","pos":""}],"DEUTZIA":[{"def":"A genus of shrubs with pretty white flowers, much cultivated.","pos":""},{"def":"A god; a deity; a divine being; an idol; a king.","pos":""}]}