{"VERD":[{"def":"Greenness; freshness.","pos":""}],"VERDANCY":[{"def":"The quality or state of being verdant.","pos":""}],"VERDANT":[{"def":"Covered with growing plants or grass; green; fresh; flourishing; as, verdant fields; a verdant lawn.","pos":""},{"def":"Unripe in knowledge or judgment; unsophisticated; raw; green; as, a verdant youth.","pos":""}],"VERDANTLY":[{"def":"In a verdant manner.","pos":""},{"def":"An officer who has the charge of the king's forest, to preserve the vert and venison, keep the assizes, view, receive, and enroll attachments and presentments of all manner of trespasses.","pos":""}],"VERDICT":[{"def":"The answer of a jury given to the court concerning any matter of fact in any cause, civil or criminal, committed to their examination and determination; the finding or decision of a jury on the matter legally submitted to them in the course of the trial of a cause.","pos":""}],"VERDIGRIS":[{"def":"A green poisonous substance used as a pigment and drug, obtained by the action of acetic acid on copper, and consisting essentially of a complex mixture of several basic copper acetates.","pos":""}],"VERDIN":[{"def":"A small yellow-headed bird (Auriparus flaviceps) of Lower California, allied to the titmice; -- called also goldtit.","pos":""}],"VERDINE":[{"def":"A commercial name for green aniline dye.","pos":""}],"VERDINGALE":[{"def":"See Farthingale.","pos":""}],"VERDITURE":[{"def":"The faintest and palest green.","pos":""}],"VERDOY":[{"def":"Charged with leaves, fruits, flowers, etc.","pos":""}],"VERDURE":[{"def":"Green; greenness; freshness of vegetation; as, the verdure of the meadows in June.","pos":""}],"VERDURED":[{"def":"Covered with verdure.","pos":""}],"VERDURELESS":[{"def":"Destitute of verdure.","pos":""}],"VERDUROUS":[{"def":"Covered with verdure; clothed with the fresh green of vegetation; verdured; verdant; as, verdurous pastures.","pos":""}]}