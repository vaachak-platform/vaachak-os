{"MORPHEAN":[{"def":"Of or relating to Morpheus, to dreams, or to sleep.","pos":""}],"MORPHEUS":[{"def":"The god of dreams.","pos":""}],"MORPHEW":[{"def":"A scurfy eruption.","pos":""}],"MORPHINE":[{"def":"A bitter white crystalline alkaloid found in opium, possessing strong narcotic properties, and much used as an anodyne; -- called also morphia, and morphina.","pos":""}],"MORPHINISM":[{"def":"A morbid condition produced by the excessive or prolonged use of morphine.","pos":""}],"MORPHO":[{"def":"Any one of numerous species of large, handsome, tropical American butterflies, of the genus Morpho.","pos":""}],"MORPHOGENY":[{"def":"History of the evolution of forms; that part of ontogeny that deals with the germ history of forms; -- distinguished from physiogeny.","pos":""},{"def":"Of, pertaining to, or according to, the principles of morphology.","pos":""}],"MORPHOLOGIST":[{"def":"One who is versed in the science of morphology.","pos":""}],"MORPHOLOGY":[{"def":"That branch of biology which deals with the structure of animals and plants, treating of the forms of organs and describing their varieties, homologies, and metamorphoses.","pos":""}],"MORPHON":[{"def":"A morphological individual, characterized by definiteness of form bion, a physiological individual.","pos":""}],"MORPHONOMY":[{"def":"The laws of organic formation.","pos":""}],"MORPHOPHYLY":[{"def":"The tribal history of forms; that part of phylogeny which treats of the tribal history of forms, in distinction from the tribal history of functions.","pos":""}],"MORPHOSIS":[{"def":"The order or mode of development of an organ or part.","pos":""}],"MORPHOTIC":[{"def":"Connected with, or becoming an integral part of, a living unit or of the morphological framework; as, morphotic, or tissue, proteids.","pos":""},{"def":"A combining form denoting form, shape; as, isomorphous.","pos":""}]}