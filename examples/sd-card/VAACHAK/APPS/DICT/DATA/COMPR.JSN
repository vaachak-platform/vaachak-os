{"COMPRADOR":[{"def":"A kind of steward or agent.","pos":""}],"COMPRECATION":[{"def":"A praying together.","pos":""}],"COMPREHEND":[{"def":"To contain; to embrace; to include; as, the states comprehended in the Austrian Empire.","pos":""},{"def":"To take in or include by construction or implication; to comprise; to imply.","pos":""}],"COMPREHENSIBILITY":[{"def":"The quality or state of being comprehensible; capability of being understood.","pos":""}],"COMPREHENSIBLE":[{"def":"Capable of being comprehended, included, or comprised.","pos":""},{"def":"Capable of being understood; intelligible; conceivable by the mind.","pos":""}],"COMPREHENSIBLENESS":[{"def":"The quality of being comprehensible; comprehensibility.","pos":""}],"COMPREHENSIBLY":[{"def":"With great extent of signification; comprehensively.","pos":""},{"def":"Intelligibly; in a manner to be comprehended or understood.","pos":""}],"COMPREHENSION":[{"def":"The complement of attributes which make up the notion signified by a general term.","pos":""},{"def":"A figure by which the name of a whole is put for a part, or that of a part for a whole, or a definite number for an indefinite.","pos":""}],"COMPREHENSIVE":[{"def":"Possessing peculiarities that are characteristic of several diverse groups.","pos":""}],"COMPREHENSIVELY":[{"def":"In a comprehensive manner; with great extent of scope.","pos":""}],"COMPREHENSIVENESS":[{"def":"The quality of being comprehensive; extensiveness of scope.","pos":""}],"COMPREHENSOR":[{"def":"One who comprehends; one who has attained to a full knowledge.","pos":""}],"COMPRESS":[{"def":"To press or squeeze together; to force into a narrower compass; to reduce the volume of by pressure; to compact; to condense; as, to compress air or water.","pos":""},{"def":"To embrace sexually.","pos":""}],"COMPRESSED":[{"def":"Flattened lengthwise.","pos":""}],"COMPRESSED YEAST":[{"def":"A cake yeast made by filtering the cells from the liquid in which they are grown, subjecting to heavy pressure, and mixing with starch or flour.","pos":""}],"COMPRESSIBILITY":[{"def":"The quality of being compressible of being compressible; as, the compressibility of elastic fluids.","pos":""}],"COMPRESSIBLE":[{"def":"Capable of being pressed together or forced into a narrower compass, as an elastic or spongy substance.","pos":""}],"COMPRESSIBLENESS":[{"def":"The quality of being compressible; compressibility.","pos":""}],"COMPRESSION":[{"def":"The act of compressing, or state of being compressed.","pos":""}],"COMPRESSION PROJECTILE":[{"def":"A projectile constructed so as to take the grooves of a rifle by means of a soft copper band firmly attached near its base or, formerly, by means of an envelope of soft metal.","pos":""}],"COMPRESSIVE":[{"def":"Compressing, or having power or tendency to compress; as, a compressive force.","pos":""}],"COMPRESSOR":[{"def":"Anything which serves to compress; as: (a) (Anat.","pos":""}],"COMPRINT":[{"def":"To print surreptitiously a work belonging to another.","pos":""}],"COMPRISAL":[{"def":"The act of comprising or comprehending; a compendium or epitome.","pos":""}],"COMPRISE":[{"def":"To comprehend; to include.","pos":""}],"COMPROBATE":[{"def":"To agree; to concur.","pos":""}],"COMPROBATION":[{"def":"Joint attestation; proof.","pos":""}],"COMPROMISE":[{"def":"A mutual agreement to refer matters in dispute to the decision of arbitrators.","pos":""},{"def":"A settlement by arbitration or by mutual consent reached by concession on both sides; a reciprocal abatement of extreme demands or rights, resulting in an agreement.","pos":""}],"COMPROMISER":[{"def":"One who compromises.","pos":""}],"COMPROMISSORIAL":[{"def":"Relating to compromise.","pos":""}],"COMPROMIT":[{"def":"To pledge by some act or declaration; to promise.","pos":""},{"def":"To put to hazard, by some indiscretion; to endanger; to compromise; as, to compromit the honor or the safety of a nation.","pos":""}],"COMPROVINCIAL":[{"def":"Belonging to, or associated in, the same province.","pos":""},{"def":"One who belongs to the same province.","pos":""}]}