{"VIGESIMAL":[{"def":"Twentieth; divided into, or consisting of, twenties or twenty parts.","pos":""}],"VIGESIMATION":[{"def":"The act of putting to death every twentieth man.","pos":""}],"VIGESIMO-QUARTO":[{"def":"Having twenty-four leaves to a sheet; as, a vigesimo-quarto form, book, leaf, size, etc.","pos":""}],"VIGIL":[{"def":"Abstinence from sleep, whether at a time when sleep is customary or not; the act of keeping awake, or the state of being awake, or the state of being awake; sleeplessness; wakefulness; watch.","pos":""},{"def":"Hence, devotional watching; waking for prayer, or other religious exercises.","pos":""}],"VIGILANCE":[{"def":"The quality or state of being vigilant; forbearance of sleep; wakefulness.","pos":""},{"def":"Watchfulness in respect of danger; care; caution; circumspection.","pos":""}],"VIGILANT":[{"def":"Attentive to discover and avoid danger, or to provide for safety; wakeful; watchful; circumspect; wary.","pos":""}],"VIGILANTLY":[{"def":"In a vigilant manner.","pos":""}],"VIGINTIVIRATE":[{"def":"The office of the vigintiviri, a body of officers of government consisting of twenty men; also, the vigintiviri.","pos":""}],"VIGNETTE":[{"def":"A running ornament consisting of leaves and tendrils, used in Gothic architecture.","pos":""}],"VIGNETTER":[{"def":"A device used by photographers in printing vignettes, consisting of a screen of paper or glass with a central aperture the edges of which become opaque by intensible gradations.","pos":""},{"def":"A maker of vignettes.","pos":""}],"VIGONIA":[{"def":"Of or pertaining to the vicuña; characterizing the vicuña; -- said of the wool of that animal, used in felting hats, and for other purposes.","pos":""}],"VIGOR":[{"def":"Active strength or force of body or mind; capacity for exertion, physically, intellectually, or morally; force; energy.","pos":""},{"def":"Strength or force in animal or force in animal or vegetable nature or action; as, a plant grows with vigor.","pos":""}],"VIGORITE":[{"def":"An explosive containing nitroglycerin.","pos":""}],"VIGOROSO":[{"def":"Vigorous; energetic; with energy; -- a direction to perform a passage with energy and force.","pos":""}],"VIGOROUS":[{"def":"Possessing vigor; full of physical or mental strength or active force; strong; lusty; robust; as, a vigorous youth; a vigorous plant.","pos":""},{"def":"Exhibiting strength, either of body or mind; powerful; strong; forcible; energetic; as, vigorous exertions; a vigorous prosecution of a war.","pos":""}]}