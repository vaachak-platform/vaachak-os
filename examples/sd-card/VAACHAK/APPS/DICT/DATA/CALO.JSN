{"CALORESCENCE":[{"def":"The conversion of obscure radiant heat info kight; the transmutation of rays of heat into others of higher refrangibility.","pos":""}],"CALORIC":[{"def":"The principle of heat, or the agent to which the phenomena of heat and combustion were formerly ascribed; -- not now used in scientific nomenclature, but sometimes used as a general term for heat.","pos":""}],"CALORICITY":[{"def":"A faculty in animals of developing and preserving the heat nesessary to life, that is, the animal heat.","pos":""}],"CALORIDUCT":[{"def":"A tube or duct for conducting heat; a caliduct.","pos":""}],"CALORIE":[{"def":"The unit of heat according to the Frensc standard; the amount of heat requires to raise the temperature of one kilogram (sometimes, one gram) of water one degree centigrade, or from 0Foot pound.","pos":""}],"CALORIFACIENT":[{"def":"See Calorificient.","pos":""}],"CALORIFERE":[{"def":"An apparatus for conveying and distributing heat, especially by means of hot water circulating in tubes.","pos":""}],"CALORIFIANT":[{"def":"See Calorificient.","pos":""}],"CALORIFIC":[{"def":"Possessing the quality of producing heat; heating.","pos":""}],"CALORIFICATION":[{"def":"Production of heat, esp.","pos":""}],"CALORIFICIENT":[{"def":"Having, or relating to the power of producing heat; -- applied to foods which, being rich in carbon, as the fats, are supposed to give rise to heat in the animal body by oxidation.","pos":""}],"CALORIMETER":[{"def":"An apparatus for measuring the amount of heat contained in bodies or developed by some mechanical or chemical process, as friction, chemical combination, combustion, etc.","pos":""},{"def":"An apparatus for measuring the proportion of unevaporated water contained in steam.","pos":""}],"CALORIMETRIC":[{"def":"Of or pertaining to process of using the calorimeter.","pos":""}],"CALORIMETRY":[{"def":"Measurement of the quantities of heat in bodies.","pos":""}],"CALORIMOTOR":[{"def":"A voltaic battery, having a large surface of plate, and producing powerful heating effects.","pos":""}],"CALORISATOR":[{"def":"An apparatus used in beet-sugar factories to heat the juice in order to aid the diffusion.","pos":""},{"def":"A close cap without visor or brim.","pos":""}],"CALOTYPE":[{"def":"A method of taking photographic pictures, on paper sensitized with iodide of silver; -- also called Talbotype, from the inventor, Mr.","pos":""}],"CALOYER":[{"def":"A monk of the Greek Church; a cenobite, anchoret, or recluse of the rule of St.","pos":""}]}