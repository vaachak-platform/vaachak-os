{"CANT":[{"def":"A segment forming a side piece in the head of a cask.","pos":""},{"def":"A segment of he rim of a wooden cogwheel.","pos":""}],"CANT HOOK":[{"def":"A wooden lever with a movable iron hook.","pos":""}],"CANTABILE":[{"def":"In a melodious, flowing style; in a singing style, as opposed to bravura, recitativo, or parlando.","pos":""}],"CANTABRIAN":[{"def":"Of or pertaining to Cantabria on the Bay of Biscay in Spain.","pos":""}],"CANTABRIGIAN":[{"def":"A native or resident of Cambridge; esp.","pos":""}],"CANTALEVER":[{"def":"A bracket to support a balcony, a cornice, or the like.","pos":""},{"def":"A projecting beam, truss, or bridge unsupported at the outer end; one which overhangs.","pos":""}],"CANTALOUPE":[{"def":"A muskmelon of several varieties, having when mature, a yellowish skin, and flesh of a reddish orange color.","pos":""}],"CANTANKEROUS":[{"def":"Perverse; contentious; ugly; malicious.","pos":""}],"CANTATA":[{"def":"A poem set to music; a musical composition comprising choruses, solos, interludes, etc.","pos":""}],"CANTATORY":[{"def":"Caontaining cant or affectation; whining; singing.","pos":""}],"CANTATRICE":[{"def":"A female professional singer.","pos":""}],"CANTED":[{"def":"Having angles; as, a six canted bolt head; a canted window.","pos":""},{"def":"Inclined at an angle to something else; tipped; sloping.","pos":""}],"CANTEEN":[{"def":"A vessel used by soldiers for carrying water, liquor, or other drink.","pos":""},{"def":"The sulter's shop in a garrison; also, a chest containing culinary and other vessels for officers.","pos":""}],"CANTER":[{"def":"A moderate and easy gallop adapted to pleasure riding.","pos":""},{"def":"A rapid or easy passing over.","pos":""}],"CANTERBURY":[{"def":"A city in England, giving its name various articles.","pos":""},{"def":"A stand with divisions in it for holding music, loose papers, etc.","pos":""}],"CANTHARIDAL":[{"def":"Of or pertaining to cantharides or made of cantharides; as, cantharidal plaster.","pos":""}],"CANTHARIDIN":[{"def":"The active principe of the cantharis, or Spanish fly, a volatile, acrid, bitter solid, crystallizing in four-sided prisms.","pos":""}],"CANTHARIS":[{"def":"A beetle (Lytta, or Cantharis, vesicatoria), having an elongated cylindrical body of a brilliant green color, and a nauseous odor; the blister fly or blister beetle, of the apothecary; -- also called Spanish fly.","pos":""}],"CANTHOPLASTY":[{"def":"The operation of forming a new canthus, when one has been destroyed by injury or disease.","pos":""}],"CANTHUS":[{"def":"The corner where the upper and under eyelids meet on each side of the eye.","pos":""}],"CANTICLE":[{"def":"The Song of Songs or Song of Solomon, one of the books of the Old Testament.","pos":""}],"CANTICOY":[{"def":"A social gathering; usually, one for dancing.","pos":""}],"CANTILE":[{"def":"Same as Cantle, v.","pos":""}],"CANTILEVER":[{"def":"Same as Cantalever.","pos":""}],"CANTILLATE":[{"def":"To chant; to recite with musical tones.","pos":""}],"CANTILLATION":[{"def":"A chanting; recitation or reading with musical modulations.","pos":""}],"CANTING":[{"def":"Speaking in a whining tone of voice; using technical or religious terms affectedly; affectedly pious; as, a canting rogue; a canting tone.","pos":""}],"CANTINIERE":[{"def":"A woman who carries a canteen for soldiers; a vivandière.","pos":""}],"CANTION":[{"def":"A song or verses.","pos":""}],"CANTLE":[{"def":"A corner or edge of anything; a piece; a fragment; a part.","pos":""},{"def":"The upwardly projecting rear part of saddle, opposite to the pommel.","pos":""}],"CANTLET":[{"def":"A piece; a fragment; a corner.","pos":""}],"CANTO":[{"def":"The highest vocal part; the air or melody in choral music; anciently the tenor, now the soprano.","pos":""}],"CANTON":[{"def":"A song or canto [Obs.","pos":""}],"CANTON CRAPE":[{"def":"A soft, white or colored silk fabric, of a gauzy texture and wavy appearance, used for ladies' scarfs, shawls, bonnet trimmings, etc.","pos":""}],"CANTON FLANNEL":[{"def":"See Cotton flannel.","pos":""}],"CANTONAL":[{"def":"Of or pertaining to a canton or cantons; of the nature of a canton.","pos":""}],"CANTONED":[{"def":"Having a charge in each of the four corners; -- said of a cross on a shield, and also of the shield itself.","pos":""},{"def":"Having the angles marked by, or decorated with, projecting moldings or small columns; as, a cantoned pier or pilaster.","pos":""}],"CANTONIZE":[{"def":"To divide into cantons or small districts.","pos":""}],"CANTONMENT":[{"def":"A town or village, or part of a town or village, assigned to a body of troops for quarters; temporary shelter or place of rest for an army; quarters.","pos":""}],"CANTOON":[{"def":"A cotton stuff showing a fine cord on one side and a satiny surface on the other.","pos":""}],"CANTOR":[{"def":"The cantor of the church intones the Te Deum.","pos":""}],"CANTORAL":[{"def":"Of or belonging to a cantor.","pos":""}],"CANTORIS":[{"def":"Of or pertaining to a cantor; as, the cantoris side of a choir; a cantoris stall.","pos":""},{"def":"A charm; an incantation; a shell; a trick; adroit mischief.","pos":""}],"CANTY":[{"def":"Cheerful; sprightly; lively; merry.","pos":""}]}