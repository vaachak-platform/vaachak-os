{"SIP":[{"def":"To drink or imbibe in small quantities; especially, to take in with the lips in small quantities, as a liquid; as, to sip tea.","pos":""},{"def":"To draw into the mouth; to suck up; as, a bee sips nectar from the flowers.","pos":""}],"SIPHOID":[{"def":"A siphon bottle.","pos":""}],"SIPHON":[{"def":"A siphon bottle.","pos":""}],"SIPHONAGE":[{"def":"The action of a siphon.","pos":""}],"SIPHONAL":[{"def":"Of or pertaining to a siphon; resembling a siphon.","pos":""}],"SIPHONARID":[{"def":"Any one of numerous species of limpet-shaped pulmonate gastropods of the genus Siphonaria.","pos":""}],"SIPHONATA":[{"def":"A tribe of bivalve mollusks in which the posterior mantle border is prolonged into two tubes or siphons.","pos":""}],"SIPHONATE":[{"def":"Belonging to the Siphonata.","pos":""}],"SIPHONET":[{"def":"One of the two dorsal tubular organs on the hinder part of the abdomen of aphids.","pos":""}],"SIPHONIA":[{"def":"A former name for a euphorbiaceous genus (Hevea) of South American trees, the principal source of caoutchouc.","pos":""}],"SIPHONIATA":[{"def":"Same as Siphonata.","pos":""}],"SIPHONIC":[{"def":"Of or pertaining to a siphon.","pos":""}],"SIPHONIFER":[{"def":"Any cephalopod having a siphonate shell.","pos":""}],"SIPHONIFEROUS":[{"def":"Siphon-bearing, as the shell of the nautilus and other cephalopods.","pos":""}],"SIPHONIUM":[{"def":"A bony tube which, in some birds, connects the tympanium with the air chambers of the articular piece of the mandible.","pos":""}],"SIPHONOBRANCHIATA":[{"def":"A tribe of gastropods having the mantle border, on one or both sides, prolonged in the form of a spout through which water enters the gill cavity.","pos":""}],"SIPHONOBRANCHIATE":[{"def":"Having a siphon, or siphons, to convey water to the gills; belonging or pertaining to the Siphonobranchiata.","pos":""},{"def":"One of the Siphonobranchiata.","pos":""}],"SIPHONOPHORA":[{"def":"An order of pelagic Hydrozoa including species which form complex free-swimming communities composed of numerous zooids of various kinds, some of which act as floats or as swimming organs, others as feeding or nutritive zooids, and others as reproductive zooids.","pos":""}],"SIPHONOPHORAN":[{"def":"Belonging to the Siphonophora.","pos":""},{"def":"One of the Siphonophora.","pos":""}],"SIPHONOPHORE":[{"def":"One of the Siphonophora.","pos":""}],"SIPHONOPODA":[{"def":"A division of Scaphopoda including those in which the foot terminates in a circular disk.","pos":""}],"SIPHONOSTOMATA":[{"def":"Si`pho*no*stom\"a*ta, n.","pos":""}],"SIPHONOSTOMATOUS":[{"def":"Si`pho*no*stom\"a*tous, a.","pos":""}],"SIPHORHINAL":[{"def":"Having tubular nostrils, as the petrels.","pos":""}],"SIPHORHINIAN":[{"def":"A siphorhinal bird.","pos":""}],"SIPHUNCLE":[{"def":"The tube which runs through the partitions of chambered cephalopod shells.","pos":""}],"SIPHUNCLED":[{"def":"Having a siphuncle; siphunculated.","pos":""}],"SIPHUNCULAR":[{"def":"Of or pertaining to the siphuncle.","pos":""}],"SIPHUNCULATED":[{"def":"Having a siphuncle.","pos":""}],"SIPID":[{"def":"Having a taste or flavorl savory; sapid.","pos":""}],"SIPPET":[{"def":"A small sop; a small, thin piece of toasted bread soaked in milk, broth, or the like; a small piece of toasted or fried bread cut into some special shape and used for garnishing.","pos":""}],"SIPUNCULACEA":[{"def":"A suborder of Gephyrea, including those which have the body unarmed and the intestine opening anteriorly.","pos":""}],"SIPUNCULOID":[{"def":"Pertaining to the Sipunculoidea.","pos":""},{"def":"One of the Sipunculoidea.","pos":""}],"SIPUNCULOIDEA":[{"def":"Si*pun`cu*loi\"de*a, n.","pos":""}]}