{"JUB":[{"def":"A vessel for holding ale or wine; a jug.","pos":""}],"JUBA":[{"def":"The mane of an animal.","pos":""},{"def":"A loose panicle, the axis of which falls to pieces, as in certain grasses.","pos":""}],"JUBATE":[{"def":"Fringed with long, pendent hair.","pos":""},{"def":"A long outer garment worn by both sexes of Mohammedans of the better class.","pos":""}],"JUBILANT":[{"def":"Uttering songs of triumph; shouting with joy; triumphant; exulting.","pos":""}],"JUBILANTLY":[{"def":"In a jubilant manner.","pos":""}],"JUBILAR":[{"def":"Pertaining to, or having the character of, a jubilee.","pos":""}],"JUBILATE":[{"def":"The third Sunday after Easter; -- so called because the introit is the 66th Psalm, which, in the Latin version, begins with the words, \"Jubilate Deo.","pos":""},{"def":"A name of the 100th Psalm; -- so called from its opening word in the Latin version.","pos":""}],"JUBILATION":[{"def":"A triumphant shouting; rejoicing; exultation.","pos":""}],"JUBILEE":[{"def":"Every fiftieth year, being the year following the completion of each seventh sabbath of years, at which time all the slaves of Hebrew blood were liberated, and all lands which had been alienated during the whole period reverted to their former owners.","pos":""},{"def":"A church solemnity or ceremony celebrated at Rome, at stated intervals, originally of one hundred years, but latterly of twenty- five; a plenary and extraordinary indulgence grated by the sovereign pontiff to the universal church.","pos":""}]}