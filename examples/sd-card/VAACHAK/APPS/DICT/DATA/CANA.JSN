{"CANAANITE":[{"def":"A descendant of Canaan, the son of Ham, and grandson of Noah.","pos":""},{"def":"A Native or inbabitant of the land of Canaan, esp.","pos":""}],"CANAANITISH":[{"def":"Of or pertaining to Canaan or the Canaanites.","pos":""},{"def":"A small cañon; a narrow valley or glen; also, but less frequently, an open valley.","pos":""}],"CANADA":[{"def":"A British province in North America, giving its name to various plants and animals.","pos":""}],"CANADIAN":[{"def":"Of or pertaining to Canada.","pos":""},{"def":"A native or inhabitant of Canada.","pos":""}],"CANAILLE":[{"def":"The lowest class of people; the rabble; the vulgar.","pos":""},{"def":"Shorts or inferior flour.","pos":""}],"CANAKIN":[{"def":"A little can or cup.","pos":""}],"CANAL":[{"def":"A tube or duct; as, the alimentary canal; the semicircular canals of the ear.","pos":""}],"CANAL COAL":[{"def":"See Cannel coal.","pos":""},{"def":"Having a channel or groove, as in the leafstalks of most palms.","pos":""}],"CANALIZATION":[{"def":"Construction of, or furnishing with, a canal or canals.","pos":""}],"CANAPE":[{"def":"A sofa or divan.","pos":""}],"CANAPE CONFIDENT":[{"def":"A sofa having a seat at each end at right angles to the main seats.","pos":""}],"CANARD":[{"def":"An extravagant or absurd report or story; a fabricated sensational report or statement; esp.","pos":""}],"CANARESE":[{"def":"Pertaining to Canara, a district of British India.","pos":""}],"CANARY":[{"def":"Of or pertaining to the Canary Islands; as, canary wine; canary birds.","pos":""},{"def":"Of a pale yellowish color; as, Canary stone.","pos":""}],"CANARY BIRD":[{"def":"A small singing bird of the Finch family (Serinus Canarius), a native of the Canary Islands.","pos":""}],"CANASTER":[{"def":"A kind of tobacco for smoking, made of the dried leaves, coarsely broken; -- so called from the rush baskets in which it is packed in South America.","pos":""}]}