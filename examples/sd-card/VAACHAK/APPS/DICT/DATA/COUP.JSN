{"COUP":[{"def":"A sudden stroke; an unexpected device or stratagem; -- a term used in various ways to convey the idea of promptness and force.","pos":""}],"COUPE":[{"def":"The front compartment of a French diligence; also, the front compartment (usually for three persons) of a car or carriage on British railways.","pos":""},{"def":"A four-wheeled close carriage for two persons inside, with an outside seat for the driver; -- so called because giving the appearance of a larger carriage cut off.","pos":""}],"COUPE-GORGE":[{"def":"Any position giving the enemy such advantage that the troops occupying it must either surrender or be cut to pieces.","pos":""}],"COUPED":[{"def":"Cut off smoothly, as distinguished from erased; -- used especially for the head or limb of an animal.","pos":""}],"COUPEE":[{"def":"A motion in dancing, when one leg is a little bent, and raised from the floor, and with the other a forward motion is made.","pos":""}],"COUPLE":[{"def":"See Couple-close.","pos":""},{"def":"One of the pairs of plates of two metals which compose a voltaic battery; -- called a voltaic couple or galvanic couple.","pos":""}],"COUPLE-BEGGAR":[{"def":"One who makes it his business to marry beggars to each other.","pos":""}],"COUPLE-CLOSE":[{"def":"A diminutive of the chevron, containing one fourth of its surface.","pos":""},{"def":"A pair of rafters framed together with a tie fixed at their feet, or with a collar beam.","pos":""}],"COUPLEMENT":[{"def":"Union; combination; a coupling; a pair.","pos":""}],"COUPLER":[{"def":"One who couples; that which couples, as a link, ring, or shackle, to connect cars.","pos":""}],"COUPLET":[{"def":"Two taken together; a pair or couple; especially two lines of verse that rhyme with each other.","pos":""}],"COUPLING":[{"def":"A device or contrivance which serves to couple or connect adjacent parts or objects; as, a belt coupling, which connects the ends of a belt; a car coupling, which connects the cars in a train; a shaft coupling, which connects the ends of shafts.","pos":""}],"COUPON":[{"def":"A certificate of interest due, printed at the bottom of transferable bonds (state, railroad, etc.","pos":""}],"COUPSTICK":[{"def":"A stick or switch used among some American Indians in making or counting a coup.","pos":""}],"COUPURE":[{"def":"A passage cut through the glacis to facilitate sallies by the besieged.","pos":""}]}