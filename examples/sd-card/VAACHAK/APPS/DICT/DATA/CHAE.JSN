{"CHAETETES":[{"def":"A genus of fossil corals, common in the lower Silurian limestones.","pos":""}],"CHAETODONT":[{"def":"A marine fish of the family Chætodontidæ.","pos":""}],"CHAETOGNATH":[{"def":"Of or pertaining to the Chætognatha.","pos":""}],"CHAETOGNATHA":[{"def":"An order of free-swimming marine worms, of which the genus Sagitta is the type.","pos":""}],"CHAETOPOD":[{"def":"Pertaining to the Chætopoda.","pos":""},{"def":"One of the Chætopoda.","pos":""}],"CHAETOPODA":[{"def":"A very extensive order of Annelida, characterized by the presence of lateral setæ, or spines, on most or all of the segments.","pos":""}],"CHAETOTAXY":[{"def":"The arrangement of bristles on an insect.","pos":""}]}