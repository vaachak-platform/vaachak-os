{"UNCULPABLE":[{"def":"Inculpable; not blameworthy.","pos":""}],"UNCULT":[{"def":"Not cultivated; rude; illiterate.","pos":""}],"UNCULTURE":[{"def":"Want of culture.","pos":""}],"UNCUNNING":[{"def":"I am young and uncunning, as thou wost [knowest].","pos":""}],"UNCURABLY":[{"def":"In an uncurable manner.","pos":""}],"UNCURBABLE":[{"def":"Not capable of being curbed.","pos":""}],"UNCURL":[{"def":"To loose from curls, or ringlets; to straighten out, as anything curled or curly.","pos":""}],"UNCURSE":[{"def":"To free from a curse or an execration.","pos":""}],"UNCURTAIN":[{"def":"To remove a curtain from; to reveal.","pos":""}],"UNCUSTOMABLE":[{"def":"Not customable, or subject to custom duties.","pos":""}],"UNCUSTOMED":[{"def":"Uncustomable; also, not having paid duty or customs.","pos":""}],"UNCUT":[{"def":"Not cut; not separated or divided by cutting or otherwise; -- said especially of books, periodicals, and the like, when the leaves have not been separated by trimming in binding.","pos":""},{"def":"Not ground, or otherwise cut, into a certain shape; as, an uncut diamond.","pos":""}],"UNCUT VELVET":[{"def":"A fabric woven like velvet, but with the loops of the warp threads uncut.","pos":""}],"UNCUTH":[{"def":"Unknown; strange.","pos":""}]}