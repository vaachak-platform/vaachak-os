{"TRICA":[{"def":"An apothecium in certain lichens, having a spherical surface marked with spiral or concentric ridges and furrows.","pos":""}],"TRICARBALLYLIC":[{"def":"Of, pertaining to, or designating, a complex tribasic organic acid, C3H5.","pos":""}],"TRICARBIMIDE":[{"def":"See under Cyanuric.","pos":""}],"TRICE":[{"def":"To haul and tie up by means of a rope.","pos":""}],"TRICENNARIOUS":[{"def":"Of or pertaining to thirty years; tricennial.","pos":""}],"TRICENNIAL":[{"def":"Of or pertaining to thirty years; consisting of thirty years; occurring once in every thirty years.","pos":""}],"TRICENTENARY":[{"def":"Including, or relating to, the interval of three hundred years; tercentenary.","pos":""},{"def":"A period of three centuries, or three hundred years, also, the three-hundredth anniversary of any event; a tercentenary.","pos":""}],"TRICEPS":[{"def":"A muscle having three heads; specif.","pos":""}],"TRICHIASIS":[{"def":"A disease of the eye, in which the eyelashes, being turned in upon the eyeball, produce constant irritation by the motion of the lids.","pos":""}],"TRICHINA":[{"def":"A small, slender nematoid worm (Trichina spiralis) which, in the larval state, is parasitic, often in immense numbers, in the voluntary muscles of man, the hog, and many other animals.","pos":""}],"TRICHINIZE":[{"def":"To render trichinous; to affect with trichinæ; -- chiefly used in the past participle; as, trichinized pork.","pos":""}],"TRICHINOSCOPE":[{"def":"An apparatus for the detection of trichinæ in the flesh of animals, as of swine.","pos":""}],"TRICHINOSIS":[{"def":"The disease produced by the presence of trichinæ in the muscles and intestinal track.","pos":""}],"TRICHINOUS":[{"def":"Of or pertaining to trichinæ or trichinosis; affected with, or containing, trichinæ; as, trichinous meat.","pos":""}],"TRICHITE":[{"def":"A kind of crystallite resembling a bunch of hairs, common in obsidian.","pos":""},{"def":"A delicate, hairlike siliceous spicule, found in certain sponges.","pos":""}],"TRICHIURIFORM":[{"def":"Like or pertaining to the genus Trichiurus or family Trichiuridæ, comprising the scabbard fishes and hairtails.","pos":""}],"TRICHIUROID":[{"def":"Of, like, or pertaining to, Trichiurus.","pos":""}],"TRICHIURUS":[{"def":"A genus of fishes comprising the hairtails.","pos":""}],"TRICHLORIDE":[{"def":"A chloride having three atoms of chlorine in the molecule.","pos":""}],"TRICHOBRANCHIA":[{"def":"The gill of a crustacean in which the branchial filaments are slender and cylindrical, as in the crawfishes.","pos":""}],"TRICHOGYNE":[{"def":"The slender, hairlike cell which receives the fertilizing particles, or antherozoids, in red seaweeds.","pos":""}],"TRICHOMANES":[{"def":"Any fern of the genus Trichomanes.","pos":""}],"TRICHOMATOSE":[{"def":"Affected with a disease which causes agglutination and matting together; -- said of the hair when affected with plica.","pos":""}],"TRICHOME":[{"def":"A hair on the surface of leaf or stem, or any modification of a hair, as a minute scale, or star, or gland.","pos":""}],"TRICHOPHORE":[{"def":"The special cell in red algæ which produces or bears a trichogyne.","pos":""},{"def":"One of the saclike organs from which the setæ of annelids arise.","pos":""}],"TRICHOPTER":[{"def":"One of the Trichoptera.","pos":""}],"TRICHOPTERA":[{"def":"A suborder of Neuroptera usually having the wings covered with minute hairs.","pos":""}],"TRICHOPTERAN":[{"def":"One of the Trichoptera.","pos":""}],"TRICHOPTEROUS":[{"def":"Of, pertaining to, or characterizing, the Trichoptera.","pos":""}],"TRICHORD":[{"def":"An instrument, as a lyre or harp, having three strings.","pos":""}],"TRICHOSCOLICES":[{"def":"An extensive group of wormlike animals characterized by being more or less covered with cilia.","pos":""}],"TRICHOTOMOUS":[{"def":"Divided into three parts, or into threes; three-forked; as, a trichotomous stem.","pos":""}],"TRICHOTOMY":[{"def":"Division into three parts.","pos":""}],"TRICHROIC":[{"def":"Exhibiting trichroism; pleochroic; pleochroism.","pos":""}],"TRICHROISM":[{"def":"The quality possessed by some crystals of presenting different colors in three different directions.","pos":""}],"TRICHROMATIC":[{"def":"Having or existing in three different phases of color; having three distinct color varieties; -- said of certain birds and insects.","pos":""}],"TRICHROMATISM":[{"def":"The quality, state, or phenomenon of being trichromatic.","pos":""}],"TRICHROMIC":[{"def":"If, pertaining to, or consisting of, three colors or color sensations.","pos":""}],"TRICIPITAL":[{"def":"Having three heads, or three origins; as, a tricipital muscle.","pos":""}],"TRICK":[{"def":"The whole number of cards played in one round, and consisting of as many cards as there are players.","pos":""},{"def":"A turn; specifically, the spell of a sailor at the helm, -- usually two hours.","pos":""}],"TRICKER":[{"def":"One who tricks; a trickster.","pos":""}],"TRICKERY":[{"def":"The art of dressing up; artifice; stratagem; fraud; imposture.","pos":""}],"TRICKINESS":[{"def":"The quality of being tricky.","pos":""}],"TRICKING":[{"def":"Given to tricks; tricky.","pos":""}],"TRICKISH":[{"def":"Given to tricks; artful in making bargains; given to deception and cheating; knavish.","pos":""}],"TRICKLE":[{"def":"To flow in a small, gentle stream; to run in drops.","pos":""}],"TRICKSINESS":[{"def":"The quality or state of being tricksy; trickiness.","pos":""}],"TRICKSTER":[{"def":"One who tricks; a deceiver; a tricker; a cheat.","pos":""}],"TRICKSY":[{"def":"Exhibiting artfulness; trickish.","pos":""}],"TRICKTRACK":[{"def":"An old game resembling backgammon.","pos":""}],"TRICKY":[{"def":"Given to tricks; practicing deception; trickish; knavish.","pos":""}],"TRICLINIARY":[{"def":"Of or pertaining to a triclinium, or to the ancient mode of reclining at table.","pos":""}],"TRICLINIC":[{"def":"Having, or characterized by, three unequal axes intersecting at oblique angles.","pos":""}],"TRICOCCOUS":[{"def":"Having three cocci, or roundish carpels.","pos":""}],"TRICOLOR":[{"def":"The national French banner, of three colors, blue, white, and red, adopted at the first revolution.","pos":""},{"def":"Hence, any three-colored flag.","pos":""}],"TRICOLORED":[{"def":"Having three colors.","pos":""}],"TRICORNIGEROUS":[{"def":"Having three horns.","pos":""},{"def":"Represented with three bodies conjoined to one head, as a lion.","pos":""}],"TRICOSTATE":[{"def":"Three-ribbed; having three ribs from the base.","pos":""}],"TRICOT":[{"def":"A fabric of woolen, silk, or cotton knitted, or women to resemble knitted work.","pos":""}],"TRICROTIC":[{"def":"Of or pertaining to tricrotism; characterized by tricrotism.","pos":""}],"TRICROTISM":[{"def":"That condition of the arterial pulse in which there is a triple beat.","pos":""}],"TRICURVATE":[{"def":"Curved in three directions; as, a tricurvate spicule (see Illust.","pos":""}],"TRICUSPID":[{"def":"Of or pertaining to the tricuspid valves; as, tricuspid obstruction.","pos":""}],"TRICUSPIDATE":[{"def":"Three-pointed; ending in three points; as, a tricuspidate leaf.","pos":""}],"TRICYCLE":[{"def":"A three-wheeled velocipede.","pos":""}]}