{"SHOE":[{"def":"A covering for the human foot, usually made of leather, having a thick and somewhat stiff sole and a lighter top.","pos":""},{"def":"Anything resembling a shoe in form, position, or use.","pos":""}],"SHOEBILL":[{"def":"A large African wading bird (Balæniceps rex) allied to the storks and herons, and remarkable for its enormous broad swollen bill.","pos":""}],"SHOEBLACK":[{"def":"One who polishes shoes.","pos":""}],"SHOEFLY":[{"def":"A curved piece of polished horn, wood, or metal used to facilitate the entrance of the foot into a shoe.","pos":""},{"def":"Figuratively: (a) Anything by which a transaction is facilitated; a medium; -- by way of contempt.","pos":""}],"SHOELESS":[{"def":"Destitute of shoes.","pos":""}],"SHOEMAKER":[{"def":"One whose occupation it is to make shoes and boots.","pos":""}],"SHOEMAKING":[{"def":"The business of a shoemaker.","pos":""}],"SHOER":[{"def":"One who fits shoes to the feet; one who furnishes or puts on shoes; as, a shoer of horses.","pos":""}]}