{"PIG":[{"def":"Any wild species of the genus Sus and related genera.","pos":""},{"def":"An oblong mass of cast iron, lead, or other metal.","pos":""}],"PIG-EYED":[{"def":"Having small, deep-set eyes.","pos":""}],"PIG-HEADED":[{"def":"Having a head like a pig; hence, figuratively: stupidity obstinate; perverse; stubborn.","pos":""}],"PIG-JAWED":[{"def":"Having the upper jaw projecting beyond the lower, with the upper incisors in advance of the lower; -- said of dogs.","pos":""}],"PIG-STICKING":[{"def":"Boar hunting; -- so called by Anglo-Indians.","pos":""}],"PIGEON":[{"def":"Any bird of the order Columbæ, of which numerous species occur in nearly all parts of the world.","pos":""}],"PIGEON-BREASTED":[{"def":"Having a breast like a pigeon, -- the sternum being so prominent as to constitute a deformity; chicken-breasted.","pos":""}],"PIGEON-HEARTED":[{"def":"Timid; easily frightened; chicken-hearted.","pos":""}],"PIGEONFOOT":[{"def":"The dove's-foot geranium (Geranium molle).","pos":""}],"PIGEONHOLE":[{"def":"A small compartment in a desk or case for the keeping of letters, documents, etc.","pos":""}],"PIGEONRY":[{"def":"A place for pigeons; a dovecote.","pos":""}],"PIGEONTOED":[{"def":"Having the toes turned in.","pos":""}],"PIGEONWING":[{"def":"A wing of a pigeon, or a wing like it.","pos":""},{"def":"An old mode of dressing men's side hair in a form likened to a pigeon's wings; also, a wig similarly shaped.","pos":""}],"PIGFOOT":[{"def":"A marine fish (Scorpæna porcus), native of Europe.","pos":""}],"PIGGERY":[{"def":"A place where swine are kept.","pos":""}],"PIGGIN":[{"def":"A small wooden pail or tub with an upright stave for a handle, -- often used as a dipper.","pos":""}],"PIGGISH":[{"def":"Relating to, or like, a pig; greedy.","pos":""}],"PIGHT":[{"def":"Pitched; fixed; determined.","pos":""}],"PIGHTEL":[{"def":"A small inclosure.","pos":""}],"PIGMENT":[{"def":"Any one of the colored substances found in animal and vegetable tissues and fluids, as bilirubin, urobilin, chlorophyll, etc.","pos":""},{"def":"Of or pertaining to pigments; furnished with pigments.","pos":""}],"PIGMENTATION":[{"def":"A deposition, esp.","pos":""}],"PIGMENTED":[{"def":"Colored; specifically (Biol.","pos":""}],"PIGNERATE":[{"def":"To pledge or pawn.","pos":""}],"PIGNORATION":[{"def":"The taking of cattle doing damage, by way of pledge, till satisfaction is made.","pos":""}],"PIGNORATIVE":[{"def":"Pledging, pawning.","pos":""}],"PIGNUS":[{"def":"A pledge or pawn.","pos":""}],"PIGPEN":[{"def":"A pen, or sty, for pigs.","pos":""}],"PIGSKIN":[{"def":"The skin of a pig, -- used chiefly for making saddles; hence, a colloquial or slang term for a saddle.","pos":""}],"PIGSNEY":[{"def":"A word of endearment for a girl or woman.","pos":""}],"PIGTAIL":[{"def":"A cue, or queue.","pos":""}],"PIGTAILED":[{"def":"Having a tail like a pig's; as, the pigtailed baboon.","pos":""}],"PIGWEED":[{"def":"A name of several annual weeds.","pos":""}],"PIGWIDGEON":[{"def":"A cant word for anything petty or small.","pos":""}]}