{"FUR":[{"def":"Articles of clothing made of fur; as, a set of furs for a lady (a collar, tippet, or cape, muff, etc.","pos":""},{"def":"One of several patterns or diapers used as tinctures.","pos":""}],"FURACIOUS":[{"def":"Given to theft; thievish.","pos":""}],"FURACITY":[{"def":"Addictedness to theft; thievishness.","pos":""}],"FURBELOW":[{"def":"A plaited or gathered flounce on a woman's garment.","pos":""}],"FURBISH":[{"def":"To rub or scour to brightness; to clean; to burnish; as, to furbish a sword or spear.","pos":""}],"FURBISHABLE":[{"def":"Capable of being furbished.","pos":""}],"FURBISHER":[{"def":"One who furbishes; esp.","pos":""},{"def":"Forked; branching like a fork; as, furcate twigs.","pos":""}],"FURCATION":[{"def":"A branching like a.","pos":""}],"FURCIFEROUS":[{"def":"Rascally; scandalous.","pos":""}],"FURCULA":[{"def":"A forked process; the wishbone or furculum.","pos":""}],"FURCULAR":[{"def":"Shaped like a fork; furcate.","pos":""}],"FURCULUM":[{"def":"The wishbone or merrythought of birds, formed by the united clavicles.","pos":""}],"FURDLE":[{"def":"To draw up into a bundle; to roll up.","pos":""}],"FURFUR":[{"def":"Scurf; dandruff.","pos":""}],"FURFURACEOUS":[{"def":"Made of bran; like bran; scurfy.","pos":""}],"FURFURAN":[{"def":"A colorless, oily substance, C4H4O, obtained by distilling certain organic substances, as pine wood, salts of pyromucic acid, etc.","pos":""}],"FURFURATION":[{"def":"Falling of scurf from the head; desquamation.","pos":""}],"FURFURINE":[{"def":"A white, crystalline base, obtained indirectly from furfurol.","pos":""}],"FURFUROL":[{"def":"A colorless oily liquid, C4H3O.","pos":""}],"FURFUROUS":[{"def":"Made of bran; furfuraceous.","pos":""}],"FURIAL":[{"def":"Furious; raging; tormenting.","pos":""}],"FURILE":[{"def":"A yellow, crystalline substance, (C4H3O)2.","pos":""}],"FURILIC":[{"def":"Pertaining to, or derived from, furile; as, furilic acid.","pos":""}],"FURIOSO":[{"def":"With great force or vigor; vehemently.","pos":""}],"FURIOUS":[{"def":"Transported with passion or fury; raging; violent; as, a furious animal.","pos":""},{"def":"Rushing with impetuosity; moving with violence; as, a furious stream; a furious wind or storm.","pos":""}],"FURL":[{"def":"To draw up or gather into close compass; to wrap or roll, as a sail, close to the yard, stay, or mast, or, as a flag, close to or around its staff, securing it there by a gasket or line.","pos":""}],"FURLONG":[{"def":"A measure of length; the eighth part of a mile; forty rods; two hundred and twenty yards.","pos":""}],"FURLOUGH":[{"def":"Leave of abserice; especially, leave given to an offcer or soldier to be absent from service for a certain time; also, the document granting leave of absence.","pos":""}],"FURNACE":[{"def":"An inclosed place in which heat is produced by the combustion of fuel, as for reducing ores or melting metals, for warming a house, for baking pottery, etc.","pos":""},{"def":"A place or time of punishment, affiction, or great trial; severe experience or discipline.","pos":""}],"FURNISH":[{"def":"To offer for use; to provide (something); to give (something); to afford; as, to furnish food to the hungry: to furnish arms for defense.","pos":""}],"FURNISHER":[{"def":"One who supplies or fits out.","pos":""}],"FURNISHMENT":[{"def":"The act of furnishing, or of supplying furniture; also, furniture.","pos":""}],"FURNITURE":[{"def":"A mixed or compound stop in an organ; -- sometimes called mixture.","pos":""}],"FUROIN":[{"def":"A colorless, crystalline substance, C10H8O4, from furfurol.","pos":""}],"FURORE":[{"def":"Excitement; commotion; enthusiasm.","pos":""}],"FURRIER":[{"def":"A dealer in furs; one who makes or sells fur goods.","pos":""}],"FURRIERY":[{"def":"Furs, in general.","pos":""},{"def":"The business of a furrier; trade in furs.","pos":""}],"FURRING":[{"def":"Double planking of a ship's side.","pos":""}],"FURROW":[{"def":"A trench in the earth made by, or as by, a plow.","pos":""},{"def":"Any trench, channel, or groove, as in wood or metal; a wrinkle on the face; as, the furrows of age.","pos":""}],"FURRY":[{"def":"Covered with fur; dressed in fur.","pos":""},{"def":"Consisting of fur; as, furry spoils.","pos":""}],"FURTHER":[{"def":"To a greater distance; in addition; moreover.","pos":""}],"FURTHERANCE":[{"def":"The act of furthering or helping forward; promotion; advancement; progress.","pos":""}],"FURTHERER":[{"def":"One who furthers.","pos":""}],"FURTHERMOST":[{"def":"Most remote; furthest.","pos":""}],"FURTHERSOME":[{"def":"Tending to further, advance, or promote; helpful; advantageous.","pos":""}],"FURTHEST":[{"def":"At the greatest distance; farthest.","pos":""}],"FURTIVE":[{"def":"Stolen; obtained or characterized by stealth; sly; secret; stealthy; as, a furtive look.","pos":""}],"FURTIVELY":[{"def":"Stealthily by theft.","pos":""}],"FURUNCLE":[{"def":"A superficial, inflammatory tumor, suppurating with a central core; a boil.","pos":""}],"FURUNCULAR":[{"def":"Of or pertaining to a furuncle; marked by the presence of furuncles.","pos":""}],"FURY":[{"def":"Have an eye to your plate, for there be furies.","pos":""}],"FURZE":[{"def":"A thorny evergreen shrub (Ulex Europæus), with beautiful yellow flowers, very common upon the plains and hills of Great Britain; -- called also gorse, and whin.","pos":""}],"FURZECHAT":[{"def":"The whinchat; -- called also furzechuck.","pos":""}],"FURZELING":[{"def":"An English warbler (Melizophilus provincialis); -- called also furze wren, and Dartford warbler.","pos":""}],"FURZY":[{"def":"bounding in, or overgrown with, furze; characterized by furze.","pos":""}]}