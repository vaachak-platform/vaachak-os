{"DISBAND":[{"def":"To loose the bands of; to set free; to disunite; to scatter; to disperse; to break up the organization of; especially, to dismiss from military service; as, to disband an army.","pos":""}],"DISBANDMENT":[{"def":"The act of disbanding.","pos":""}],"DISBAR":[{"def":"To expel from the bar, or the legal profession; to deprive (an attorney, barrister, or counselor) of his status and privileges as such.","pos":""}],"DISBARK":[{"def":"To strip of bark; to bark.","pos":""}],"DISBARMENT":[{"def":"Act of disbarring.","pos":""}],"DISBASE":[{"def":"To debase or degrade.","pos":""}],"DISBELIEF":[{"def":"The act of disbelieving;; a state of the mind in which one is fully persuaded that an opinion, assertion, or doctrine is not true; refusal of assent, credit, or credence; denial of belief.","pos":""}],"DISBELIEVE":[{"def":"Not to believe; to refuse belief or credence to; to hold not to be true or actual.","pos":""}],"DISBELIEVER":[{"def":"One who disbelieves, or refuses belief; an unbeliever.","pos":""}],"DISBENCH":[{"def":"To deprive (a bencher) of his privileges.","pos":""}],"DISBIND":[{"def":"To unbind; to loosen.","pos":""}],"DISBLAME":[{"def":"To clear from blame.","pos":""}],"DISBOSCATION":[{"def":"Converting forest land into cleared or arable land; removal of a forest.","pos":""}],"DISBRANCH":[{"def":"To divest of a branch or branches; to tear off.","pos":""}],"DISBUD":[{"def":"To deprive of buds or shoots, as for training, or economizing the vital strength of a tree.","pos":""}],"DISBURDEN":[{"def":"To rid of a burden; to free from a load borne or from something oppressive; to unload; to disencumber; to relieve.","pos":""}],"DISBURGEON":[{"def":"To strip of burgeons or buds; to disbud.","pos":""}],"DISBURSE":[{"def":"To pay out; to expend; -- usually from a public fund or treasury.","pos":""}],"DISBURSEMENT":[{"def":"The act of disbursing or paying out.","pos":""},{"def":"That which is disbursed or paid out; as, the annual disbursements exceed the income.","pos":""}],"DISBURSER":[{"def":"One who disburses money.","pos":""}],"DISBURTHEN":[{"def":"To disburden; to relieve of a load.","pos":""}]}