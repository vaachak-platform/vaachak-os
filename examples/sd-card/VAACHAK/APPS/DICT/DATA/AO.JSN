{"AONIAN":[{"def":"Pertaining to Aonia, Boeotia, or to the Muses, who were supposed to dwell there.","pos":""}],"AORIST":[{"def":"A tense in the Greek language, which expresses an action as completed in past time, but leaves it, in other respects, wholly indeterminate.","pos":""}],"AORISTIC":[{"def":"Indefinite; pertaining to the aorist tense.","pos":""}],"AORTA":[{"def":"The great artery which carries the blood from the heart to all parts of the body except the lungs; the main trunk of the arterial system.","pos":""}],"AORTIC":[{"def":"Of or pertaining to the aorta.","pos":""}],"AORTITIS":[{"def":"Inflammation of the aorta.","pos":""}],"AOUDAD":[{"def":"An African sheeplike quadruped (the Ammotragus tragelaphus) having a long mane on the breast and fore legs.","pos":""}]}