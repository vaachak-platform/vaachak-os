{"CHESS":[{"def":"A game played on a chessboard, by two persons, with two differently colored sets of men, sixteen in each set.","pos":""}],"CHESS-APPLE":[{"def":"The wild service of Europe (Purus torminalis).","pos":""}],"CHESSBOARD":[{"def":"The board used in the game of chess, having eight rows of alternate light and dark squares, eight in each row.","pos":""}],"CHESSEL":[{"def":"The wooden mold in which cheese is pressed.","pos":""}],"CHESSES":[{"def":"The platforms, consisting of two or more planks doweled together, for the flooring of a temporary military bridge.","pos":""}],"CHESSIL":[{"def":"Gravel or pebbles.","pos":""}],"CHESSMAN":[{"def":"A piece used in the game of chess.","pos":""}],"CHESSOM":[{"def":"Mellow earth; mold.","pos":""}],"CHESSTREE":[{"def":"A piece of oak bolted perpendicularly on the side of a vessel, to aid in drawing down and securing the clew of the mainsail.","pos":""}],"CHESSY COPPER":[{"def":"The mineral azurite, found in fine crystallization at Chessy, near Lyons; called also chessylite.","pos":""}],"CHEST":[{"def":"A case in which certain goods, as tea, opium, etc.","pos":""},{"def":"A tight receptacle or box, usually for holding gas, steam, liguids, etc.","pos":""}],"CHEST FOUNDER":[{"def":"A rheumatic affection of the muscles of the breast and fore legs of a horse, affecting motion and respiration.","pos":""}],"CHESTED":[{"def":"Having (such) a chest; -- in composition; as, broad-chested; narrow-chested.","pos":""}],"CHESTERLITE":[{"def":"A variety of feldspar found in crystals in the county of Chester, Pennsylvania.","pos":""}],"CHESTEYN":[{"def":"The chestnut tree.","pos":""}],"CHESTNUT":[{"def":"The edible nut of a forest tree (Castanea vesce) of Europe and America.","pos":""}]}