{"GURGE":[{"def":"The plain, wherein a black bituminous gurge Boils out from under ground.","pos":""}],"GURGLE":[{"def":"To run or flow in a broken, irregular, noisy current, as water from a bottle, or a small stream among pebbles or stones.","pos":""}],"GURGLET":[{"def":"A porous earthen jar for cooling water by evaporation.","pos":""}],"GURGLINGLY":[{"def":"In a gurgling manner.","pos":""}],"GURJUN":[{"def":"A thin balsam or wood oil derived from the Diptcrocarpus lævis, an East Indian tree.","pos":""}],"GURL":[{"def":"A young person of either sex.","pos":""}],"GURLET":[{"def":"A pickax with one sharp point and one cutting edge.","pos":""}],"GURMY":[{"def":"A level; a working.","pos":""},{"def":"One ofseveral European marine fishes, of the genus Trigla and allied genera, having a large and spiny head, with mailed cheeks.","pos":""}],"GURRY":[{"def":"An alvine evacuation; also, refuse matter.","pos":""}],"GURT":[{"def":"A gutter or channel for water, hewn out of the bottom of a working drift.","pos":""}]}