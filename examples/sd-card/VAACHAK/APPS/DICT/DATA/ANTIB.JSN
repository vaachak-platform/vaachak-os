{"ANTIBACCHIUS":[{"def":"A foot of three syllables, the first two long, and the last short.","pos":""}],"ANTIBACTERIAL":[{"def":"An`ti*bac*te\"ri*al, a.","pos":""}],"ANTIBILLOUS":[{"def":"Counteractive of bilious complaints; tending to relieve biliousness.","pos":""}],"ANTIBODY":[{"def":"Any of various bodies or substances in the blood which act in antagonism to harmful foreign bodies, as toxins or the bacteria producing the toxins.","pos":""}],"ANTIBRACHIAL":[{"def":"Of or pertaining to the antibrachium, or forearm.","pos":""}],"ANTIBRACHIUM":[{"def":"That part of the fore limb between the brachium and the carpus; the forearm.","pos":""}],"ANTIBROMIC":[{"def":"An agent that destroys offensive smells; a deodorizer.","pos":""}],"ANTIBUBONIC":[{"def":"Good or used against bubonic plague; as, antibubonic serum, obtained from immunized horses; antibubonic vaccine, a sterilized bouillon culture of the plague bacillus; antibubonic measures.","pos":""}],"ANTIBURGHER":[{"def":"One who seceded from the Burghers (1747), deeming it improper to take the Burgess oath.","pos":""}]}