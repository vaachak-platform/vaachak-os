{"BRAN":[{"def":"The European carrion crow.","pos":""}],"BRANCARD":[{"def":"A litter on which a person may be carried.","pos":""}],"BRANCH":[{"def":"A shoot or secondary stem growing from the main stem, or from a principal limb or bough of a tree or other plant.","pos":""},{"def":"One of the portions of a curve that extends outwards to an indefinitely great distance; as, the branches of an hyperbola.","pos":""}],"BRANCH PILOT":[{"def":"A pilot who has a branch or commission, as from Trinity House, England, for special navigation.","pos":""}],"BRANCHER":[{"def":"A young hawk when it begins to leave the nest and take to the branches.","pos":""}],"BRANCHERY":[{"def":"A system of branches.","pos":""}],"BRANCHIA":[{"def":"A gill; a respiratory organ for breathing the air contained in water, such as many aquatic and semiaquatic animals have.","pos":""}],"BRANCHIAL":[{"def":"Of or pertaining to branchiæ or gills.","pos":""}],"BRANCHIATE":[{"def":"Furnished with branchiæ; as, branchiate segments.","pos":""}],"BRANCHIFEROUS":[{"def":"Having gills; branchiate; as, branchiferous gastropods.","pos":""}],"BRANCHINESS":[{"def":"Fullness of branches.","pos":""}],"BRANCHING":[{"def":"Furnished with branches; shooting our branches; extending in a branch or branches.","pos":""}],"BRANCHIOGASTROPODA":[{"def":"Those Gastropoda that breathe by branchiæ, including the Prosobranchiata and Opisthobranchiata.","pos":""}],"BRANCHIOMERISM":[{"def":"The state of being made up of branchiate segments.","pos":""}],"BRANCHIOPOD":[{"def":"One of the Branchiopoda.","pos":""}],"BRANCHIOPODA":[{"def":"An order of Entomostraca; -- so named from the feet of branchiopods having been supposed to perform the function of gills.","pos":""}],"BRANCHIOSTEGAL":[{"def":"Pertaining to the membrane covering the gills of fishes.","pos":""},{"def":"A branchiostegal ray.","pos":""}],"BRANCHIOSTEGE":[{"def":"The branchiostegal membrane.","pos":""}],"BRANCHIOSTEGOUS":[{"def":"Bran`chi*os\"te*gous, a.","pos":""}],"BRANCHIURA":[{"def":"A group of Entomostraca, with suctorial mouths, including species parasitic on fishes, as the carp lice (Argulus).","pos":""}],"BRANCHLESS":[{"def":"Destitude of branches or shoots; without any valuable product; barren; naked.","pos":""}],"BRANCHLET":[{"def":"A little branch; a twig.","pos":""}],"BRANCHY":[{"def":"Full of branches; having wide-spreading branches; consisting of branches.","pos":""}],"BRAND":[{"def":"Any minute fungus which produces a burnt appearance in plants.","pos":""}],"BRAND GOOSE":[{"def":"A species of wild goose (Branta bernicla) usually called in America brant.","pos":""}],"BRAND IRON":[{"def":"A branding iron.","pos":""},{"def":"A trivet to set a pot on.","pos":""}],"BRAND SPORE":[{"def":"One of several spores growing in a series or chain, and produced by one of the fungi called brand.","pos":""}],"BRAND-NEW":[{"def":"Quite new; bright as if fresh from the forge.","pos":""}],"BRANDENBURG":[{"def":"A kind of decoration for the breast of a coat, sometimes only a frog with a loop, but in some military uniforms enlarged into a broad horizontal stripe.","pos":""}],"BRANDER":[{"def":"One who, or that which, brands; a branding iron.","pos":""}],"BRANDIED":[{"def":"Mingled with brandy; made stronger by the addition of brandy; flavored or treated with brandy; as, brandied peaches.","pos":""}],"BRANDING IRON":[{"def":"An iron to brand with.","pos":""}],"BRANDISH":[{"def":"To move or wave, as a weapon; to raise and move in various directions; to shake or flourish.","pos":""},{"def":"To play with; to flourish; as, to brandish syllogisms.","pos":""}],"BRANDISHER":[{"def":"One who brandishes.","pos":""}],"BRANDLE":[{"def":"To shake; to totter.","pos":""},{"def":"Same as Branlin, fish and worm.","pos":""}],"BRANDY":[{"def":"A strong alcoholic liquor distilled from wine.","pos":""}],"BRANGLE":[{"def":"A wrangle; a squabble; a noisy contest or dispute.","pos":""}],"BRANGLEMENT":[{"def":"Wrangle; brangle.","pos":""}],"BRANGLER":[{"def":"A quarrelsome person.","pos":""}],"BRANK":[{"def":"A sort of bridle with wooden side pieces.","pos":""},{"def":"A scolding bridle, an instrument formerly used for correcting scolding women.","pos":""}],"BRANKURSINE":[{"def":"Bear's-breech, or Acanthus.","pos":""}],"BRANLIN":[{"def":"A young salmon or parr, in the stage in which it has transverse black bands, as if burned by a gridiron.","pos":""}],"BRANNY":[{"def":"Having the appearance of bran; consisting of or containing bran.","pos":""}],"BRANSLE":[{"def":"A brawl or dance.","pos":""}],"BRANT":[{"def":"A species of wild goose (Branta bernicla) -- called also brent and brand goose.","pos":""}],"BRANT-FOX":[{"def":"A kind of fox found in Sweden (Vulpes alopex), smaller than the common fox (V.","pos":""}],"BRANTAIL":[{"def":"The European redstart; -- so called from the red color of its tail.","pos":""}],"BRANULAR":[{"def":"Relating to the brain; cerebral.","pos":""}]}