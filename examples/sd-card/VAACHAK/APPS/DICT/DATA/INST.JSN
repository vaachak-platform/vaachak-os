{"INSTABILITY":[{"def":"The quality or condition of being unstable; want of stability, firmness, or steadiness; liability to give way or to fail; insecurity; precariousness; as, the instability of a building.","pos":""},{"def":"Lack of determination of fixedness; inconstancy; fickleness; mutability; changeableness; as, instability of character, temper, custom, etc.","pos":""}],"INSTABLE":[{"def":"Not stable; not standing fast or firm; unstable; prone to change or recede from a purpose; mutable; inconstant.","pos":""}],"INSTABLENESS":[{"def":"Instability; unstableness.","pos":""}],"INSTALL":[{"def":"To set in a seat; to give a place to; establish (one) in a place.","pos":""},{"def":"To place in an office, rank, or order; to invest with any charge by the usual ceremonies; to instate; to induct; as, to install an ordained minister as pastor of a church; to install a college president.","pos":""}],"INSTALLATION":[{"def":"The whole of a system of machines, apparatus, and accessories, when set up and arranged for practical working, as in electric lighting, transmission of power, etc.","pos":""}],"INSTALLMENT":[{"def":"The act of installing; installation.","pos":""},{"def":"The seat in which one is placed.","pos":""}],"INSTANCE":[{"def":"The act or quality of being instant or pressing; urgency; solicitation; application; suggestion; motion.","pos":""},{"def":"That which is instant or urgent; motive.","pos":""}],"INSTANCY":[{"def":"Instance; urgency.","pos":""}],"INSTANT":[{"def":"Pressing; urgent; importunate; earnest.","pos":""},{"def":"Closely pressing or impending in respect to time; not deferred; immediate; without delay.","pos":""}],"INSTANTANEITY":[{"def":"Quality of being instantaneous.","pos":""}],"INSTANTANEOUS":[{"def":"Done or occurring in an instant, or without any perceptible duration of time; as, the passage of electricity appears to be instantaneous.","pos":""},{"def":"At or during a given instant; as, instantaneous acceleration, velocity, etc.","pos":""}],"INSTANTER":[{"def":"Immediately; instantly; at once; as, he left instanter.","pos":""}],"INSTANTLY":[{"def":"Without the least delay or interval; at once; immediately.","pos":""},{"def":"With urgency or importunity; earnestly; pressingly.","pos":""}],"INSTAR":[{"def":"To stud as with stars.","pos":""}],"INSTATE":[{"def":"To set, place, or establish, as in a rank, office, or condition; to install; to invest; as, to instate a person in greatness or in favor.","pos":""}],"INSTAURATE":[{"def":"To renew or renovate.","pos":""}],"INSTAURATION":[{"def":"Restoration after decay, lapse, or dilapidation; renewal; repair; renovation; renaissance.","pos":""}],"INSTAURATOR":[{"def":"One who renews or restores to a former condition.","pos":""}],"INSTAURE":[{"def":"To renew or renovate; to instaurate.","pos":""}],"INSTEAD":[{"def":"In the place or room; -- usually followed by of.","pos":""},{"def":"Equivalent; equal to; -- usually with of.","pos":""}],"INSTEEP":[{"def":"To steep or soak; to drench.","pos":""}],"INSTEP":[{"def":"The arched middle portion of the human foot next in front of the ankle joint.","pos":""},{"def":"That part of the hind leg of the horse and allied animals, between the hock, or ham, and the pastern joint.","pos":""}],"INSTIGATE":[{"def":"To goad or urge forward; to set on; to provoke; to incite; -- used chiefly with reference to evil actions; as to instigate one to a crime.","pos":""}],"INSTIGATINGLY":[{"def":"Incitingly; temptingly.","pos":""}],"INSTIGATION":[{"def":"The act of instigating, or the state of being instigated; incitement; esp.","pos":""}],"INSTIGATOR":[{"def":"One who instigates or incites.","pos":""}],"INSTILL":[{"def":"To drop in; to pour in drop by drop; hence, to impart gradually; to infuse slowly; to cause to be imbibed.","pos":""}],"INSTILLATION":[{"def":"The of instilling; also, that which is instilled.","pos":""}],"INSTILLATORY":[{"def":"Belonging to instillation.","pos":""}],"INSTILLER":[{"def":"One who instills.","pos":""}],"INSTILLMENT":[{"def":"The act of instilling; also, that which is instilled.","pos":""}],"INSTIMULATE":[{"def":"Not to stimulate; to soothe; to quiet.","pos":""}],"INSTINCT":[{"def":"Urged or sas, birds instinct with life.","pos":""}],"INSTINCTION":[{"def":"Instinct; incitement; inspiration.","pos":""}],"INSTINCTIVE":[{"def":"Of or pertaining to instinct; derived from, or prompted by, instinct; of the nature of instinct; determined by natural impulse or propensity; acting or produced without reasoning, deliberation, instruction, or experience; spontaneous.","pos":""}],"INSTINCTIVELY":[{"def":"In an instinctive manner; by force of instinct; by natural impulse.","pos":""}],"INSTINCTIVITY":[{"def":"The quality of being instinctive, or prompted by instinct.","pos":""}],"INSTIPULATE":[{"def":"See Exstipulate.","pos":""}],"INSTITUTE":[{"def":"Established; organized; founded.","pos":""}],"INSTITUTION":[{"def":"The act or process of instituting; as: (a) Establishment; foundation; enactment; as, the institution of a school.","pos":""},{"def":"That which instituted or established; as: (a) Established order, method, or custom; enactment; ordinance; permanent form of law or polity.","pos":""}],"INSTITUTIONAL":[{"def":"Pertaining to, or treating of, institutions; as, institutional legends.","pos":""},{"def":"Instituted by authority.","pos":""}],"INSTITUTIONARY":[{"def":"Relating to an institution, or institutions.","pos":""},{"def":"Containing the first principles or doctrines; elemental; rudimentary.","pos":""}],"INSTITUTIST":[{"def":"A writer or compiler of, or a commentator on, institutes.","pos":""}],"INSTITUTIVE":[{"def":"Tending or intended to institute; having the power to establish.","pos":""},{"def":"Established; depending on, or characterized by, institution or order.","pos":""}],"INSTITUTIVELY":[{"def":"In conformity with an institution.","pos":""}],"INSTITUTOR":[{"def":"A presbyter appointed by the bishop to institute a rector or assistant minister over a parish church.","pos":""}],"INSTOP":[{"def":"To stop; to close; to make fast; as, to instop the seams.","pos":""}],"INSTORE":[{"def":"To store up; to inclose; to contain.","pos":""}],"INSTRATIFIED":[{"def":"Interstratified.","pos":""}],"INSTROKE":[{"def":"An inward stroke; specif.","pos":""}],"INSTRUCT":[{"def":"Arranged; furnished; provided.","pos":""},{"def":"Instructed; taught; enlightened.","pos":""}],"INSTRUCTIBLE":[{"def":"Capable of being instructed; teachable; docible.","pos":""}],"INSTRUCTION":[{"def":"The act of instructing, teaching, or furnishing with knowledge; information.","pos":""},{"def":"That which instructs, or with which one is instructed; the intelligence or information imparted; as: (a) Precept; information; teachings.","pos":""}],"INSTRUCTIONAL":[{"def":"Pertaining to, or promoting, instruction; educational.","pos":""}],"INSTRUCTIVE":[{"def":"Conveying knowledge; serving to instruct or inform; as, experience furnishes very instructive lessons.","pos":""}],"INSTRUCTOR":[{"def":"One who instructs; one who imparts knowledge to another; a teacher.","pos":""}],"INSTRUCTRESS":[{"def":"A woman who instructs; a preceptress; a governess.","pos":""}],"INSTRUMENT":[{"def":"A writing, as the means of giving formal expression to some act; a writing expressive of some act, contract, process, as a deed, contract, writ, etc.","pos":""}],"INSTRUMENTAL":[{"def":"Pertaining to, made by, or prepared for, an instrument, esp.","pos":""},{"def":"Applied to a case expressing means or agency; as, the instrumental case.","pos":""}],"INSTRUMENTALISM":[{"def":"The view that the sanction of truth is its utility, or that truth is genuine only in so far as it is a valuable instrument.","pos":""}],"INSTRUMENTALIST":[{"def":"One who plays upon an instrument of music, as distinguished from a vocalist.","pos":""}],"INSTRUMENTALITY":[{"def":"The quality or condition of being instrumental; that which is instrumental; anything used as a means; medium; agency.","pos":""}],"INSTRUMENTALLY":[{"def":"By means of an instrument or agency; as means to an end.","pos":""},{"def":"With instruments of music; as, a song instrumentally accompanied.","pos":""}],"INSTRUMENTALNESS":[{"def":"Usefulness or agency, as means to an end; instrumentality.","pos":""}],"INSTRUMENTATION":[{"def":"The act of using or adapting as an instrument; a series or combination of instruments; means; agency.","pos":""}],"INSTRUMENTIST":[{"def":"A performer on a musical instrument; an instrumentalist.","pos":""}]}