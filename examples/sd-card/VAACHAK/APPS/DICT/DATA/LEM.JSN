{"LEMAN":[{"def":"A sweetheart, of either sex; a gallant, or a mistress; -- usually in a bad sense.","pos":""}],"LEME":[{"def":"A ray or glimmer of light; a gleam.","pos":""}],"LEMMA":[{"def":"A preliminary or auxiliary proposition demonstrated or accepted for immediate use in the demonstration of some other proposition, as in mathematics or logic.","pos":""}],"LEMMING":[{"def":"Any one of several species of small arctic rodents of the genera Myodes and Cuniculus, resembling the meadow mice in form.","pos":""}],"LEMNIAN":[{"def":"Of or pertaining to the isle of Lemnos.","pos":""},{"def":"A curve in the form of the figure 8, with both parts symmetrical, generated by the point in which a tangent to an equilateral hyperbola meets the perpendicular on it drawn from the center.","pos":""}],"LEMNISCUS":[{"def":"One of two oval bodies hanging from the interior walls of the body in the Acanthocephala.","pos":""}],"LEMON":[{"def":"An oval or roundish fruit resembling the orange, and containing a pulp usually intensely acid.","pos":""}],"LEMONADE":[{"def":"A beverage consisting of lemon juice mixed with water and sweetened.","pos":""}],"LEMUR":[{"def":"One of a family (Lemuridæ) of nocturnal mammals allied to the monkeys, but of small size, and having a sharp and foxlike muzzle, and large eyes.","pos":""}],"LEMURES":[{"def":"Spirits or ghosts of the departed; specters.","pos":""}],"LEMURIA":[{"def":"A hypothetical land, or continent, supposed by some to have existed formerly in the Indian Ocean, of which Madagascar is a remnant.","pos":""}],"LEMURID":[{"def":"Same as Lemuroid.","pos":""}],"LEMUROID":[{"def":"Like or pertaining to the lemurs or the Lemuroidea.","pos":""},{"def":"One of the Lemuroidea.","pos":""}],"LEMUROIDEA":[{"def":"A suborder of primates, including the lemurs, the aye-aye, and allied species.","pos":""}]}