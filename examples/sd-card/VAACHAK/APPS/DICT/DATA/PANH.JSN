{"PANHANDLE":[{"def":"The handle of a pan; hence, fig.","pos":""}],"PANHANDLE STATE":[{"def":"West Virginia; -- a nickname.","pos":""}],"PANHELLENIC":[{"def":"Of or pertaining to all Greece, or to Panhellenism; including all Greece, or all the Greeks.","pos":""}],"PANHELLENISM":[{"def":"A scheme to unite all the Greeks in one political body.","pos":""}],"PANHELLENIST":[{"def":"An advocate of Panhellenism.","pos":""}],"PANHELLENIUM":[{"def":"An assembly or association of Greeks from all the states of Greece.","pos":""}]}