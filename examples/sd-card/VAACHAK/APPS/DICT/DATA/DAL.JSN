{"DAL":[{"def":"Split pulse, esp.","pos":""}],"DAL SEGNO":[{"def":"A direction to go back to the sign Segno.","pos":""}],"DALE":[{"def":"A low place between hills; a vle or valley.","pos":""},{"def":"A trough or spout to carry off water, as from a pump.","pos":""}],"DALESMAN":[{"def":"One living in a dale; -- a term applied particularly to the inhabitants of the valleys in the north of England, Norway, etc.","pos":""}],"DALLES":[{"def":"The place below, where the compressed river wound like a silver thread among the flat black rocks, was the far-famed Dalles of the Columbia.","pos":""}],"DALLIANCE":[{"def":"The act of dallying, trifling, or fondling; interchange of caresses; wanton play.","pos":""},{"def":"Delay or procrastination.","pos":""}],"DALLIER":[{"def":"One Who fondles; a trifler; as, dalliers with pleasant words.","pos":""}],"DALLOP":[{"def":"A tuft or clump.","pos":""}],"DALLY":[{"def":"To waste time in effeminate or voluptuous pleasures, or in idleness; to fool away time; to delay unnecessarily; to tarry; to trifle.","pos":""},{"def":"To interchange caresses, especially with one of the opposite sex; to use fondling; to wanton; to sport.","pos":""}],"DALMANIA":[{"def":"A genus of trilobites, of many species, common in the Upper Silurian and Devonian rocks.","pos":""}],"DALMANITES":[{"def":"Same as Dalmania.","pos":""}],"DALMATIAN":[{"def":"Of or pertaining to Dalmatia.","pos":""},{"def":"A vestment with wide sleeves, and with two stripes, worn at Mass by deacons, and by bishops at pontifical Mass; -- imitated from a dress originally worn in Dalmatia.","pos":""}],"DALTONIAN":[{"def":"One afflicted with color blindness.","pos":""}],"DALTONISM":[{"def":"Inability to perceive or distinguish certain colors, esp.","pos":""}]}