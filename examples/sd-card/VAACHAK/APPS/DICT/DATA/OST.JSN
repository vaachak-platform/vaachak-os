{"OSTEITIS":[{"def":"Inflammation of bone.","pos":""}],"OSTELER":[{"def":"Same as Hosteler.","pos":""}],"OSTEND":[{"def":"To exhibit; to manifest.","pos":""}],"OSTENSIBILITY":[{"def":"The quality or state of being ostensible.","pos":""}],"OSTENSIBLE":[{"def":"Capable of being shown; proper or intended to be shown.","pos":""},{"def":"Shown; exhibited; declared; avowed; professed; apparent; -- often used as opposed to real or actual; as, an ostensible reason, motive, or aim.","pos":""}],"OSTENSIBLY":[{"def":"In an ostensible manner; avowedly; professedly; apparently.","pos":""}],"OSTENSION":[{"def":"The showing of the sacrament on the altar in order that it may receive the adoration of the communicants.","pos":""}],"OSTENSIVE":[{"def":"Showing; exhibiting.","pos":""}],"OSTENSIVELY":[{"def":"In an ostensive manner.","pos":""},{"def":"Same as Monstrance.","pos":""}],"OSTENT":[{"def":"Appearance; air; mien.","pos":""},{"def":"Manifestation; token; portent.","pos":""}],"OSTENTATE":[{"def":"To make an ambitious display of; to show or exhibit boastingly.","pos":""}],"OSTENTATION":[{"def":"The act of ostentating or of making an ambitious display; unnecessary show; pretentious parade; -- usually in a detractive sense.","pos":""},{"def":"A show or spectacle.","pos":""}],"OSTENTATIOUS":[{"def":"Fond of, or evincing, ostentation; unduly conspicuous; pretentious; boastful.","pos":""}],"OSTENTATOR":[{"def":"One fond of display; a boaster.","pos":""}],"OSTEO-":[{"def":"A combining form of Gr.","pos":""}],"OSTEOBLAST":[{"def":"One of the protoplasmic cells which occur in the osteogenetic layer of the periosteum, and from or around which the matrix of the bone is developed; an osteoplast.","pos":""}],"OSTEOCLASIS":[{"def":"The operation of breaking a bone in order to correct deformity.","pos":""}],"OSTEOCLAST":[{"def":"An instrument for performing osteoclasis.","pos":""}],"OSTEOCOLLA":[{"def":"A kind of glue obtained from bones.","pos":""},{"def":"A cellular calc tufa, which in some places forms incrustations on the stems of plants, -- formerly supposed to have the quality of uniting fractured bones.","pos":""}],"OSTEOCOMMA":[{"def":"A metamere of the vertebrate skeleton; an osteomere; a vertebra.","pos":""}],"OSTEOCOPE":[{"def":"Pain in the bones; a violent fixed pain in any part of a bone.","pos":""}],"OSTEOCRANIUM":[{"def":"The bony cranium, as distinguished from the cartilaginous cranium.","pos":""}],"OSTEODENTINE":[{"def":"A hard substance, somewhat like bone, which is sometimes deposited within the pulp cavity of teeth.","pos":""}],"OSTEOGEN":[{"def":"The soft tissue, or substance, which, in developing bone, ultimately undergoes ossification.","pos":""},{"def":"The formation or growth of bone.","pos":""}],"OSTEOGENETIC":[{"def":"Connected with osteogenesis, or the formation of bone; producing bone; as, osteogenetic tissue; the osteogenetic layer of the periosteum.","pos":""}],"OSTEOGRAPHY":[{"def":"The description of bones; osteology.","pos":""}],"OSTEOID":[{"def":"Resembling bone; bonelike.","pos":""}],"OSTEOLITE":[{"def":"A massive impure apatite, or calcium phosphate.","pos":""}],"OSTEOLOGER":[{"def":"One versed in osteology; an osteologist.","pos":""},{"def":"Of or pertaining to osteology.","pos":""}],"OSTEOLOGIST":[{"def":"One who is skilled in osteology; an osteologer.","pos":""}],"OSTEOLOGY":[{"def":"The science which treats of the bones of the vertebrate skeleton.","pos":""}],"OSTEOLYSIS":[{"def":"Softening and absorption of bone.","pos":""}],"OSTEOMA":[{"def":"A tumor composed mainly of bone; a tumor of a bone.","pos":""}],"OSTEOMALACIA":[{"def":"A disease of the bones, in which they lose their earthy material, and become soft, flexible, and distorted.","pos":""}],"OSTEOMANTY":[{"def":"Divination by means of bones.","pos":""}],"OSTEOPATH":[{"def":"A practitioner of osteopathy.","pos":""}],"OSTEOPATHIC":[{"def":"Of or pertaining to osteopathy.","pos":""}],"OSTEOPATHIST":[{"def":"One who practices osteopathy; an osteopath.","pos":""}],"OSTEOPERIOSTITIS":[{"def":"Inflammation of a bone and its periosteum.","pos":""}],"OSTEOPHONE":[{"def":"An instrument for transmission of auditory vibrations through the bones of the head, so as to be appreciated as sounds by persons deaf from causes other than those affecting the nervous apparatus of hearing.","pos":""}],"OSTEOPLASTIC":[{"def":"Producing bone; as, osteoplastic cells.","pos":""},{"def":"Of or pertaining to the replacement of bone; as, an osteoplastic operation.","pos":""}],"OSTEOPLASTY":[{"def":"An operation or process by which the total or partial loss of a bone is remedied.","pos":""}],"OSTEOPOROSIS":[{"def":"An absorption of bone so that the tissue becomes unusually porous.","pos":""}],"OSTEOPTERYGIOUS":[{"def":"Having bones in the fins, as certain fishes.","pos":""}],"OSTEOSARCOMA":[{"def":"A tumor having the structure of a sacroma in which there is a deposit of bone; sarcoma connected with bone.","pos":""}],"OSTEOSCLEROSIS":[{"def":"Abnormal hardness and density of bone.","pos":""}],"OSTEOTOME":[{"def":"Strong nippers or a chisel for dividing bone.","pos":""}],"OSTEOTOMIST":[{"def":"One skilled in osteotomy.","pos":""}],"OSTEOTOMY":[{"def":"The operation of dividing a bone or of cutting a piece out of it, -- done to remedy deformity, etc.","pos":""}],"OSTEOZOA":[{"def":"Same as Vertebrata.","pos":""}],"OSTIARY":[{"def":"The mouth of a river; an estuary.","pos":""},{"def":"One who keeps the door, especially the door of a church; a porter.","pos":""}],"OSTIC":[{"def":"Pertaining to, or applied to, the language of the Tuscaroras, Iroquois, Wyandots, Winnebagoes, and a part of the Sioux Indians.","pos":""}],"OSTIUM":[{"def":"An opening; a passage.","pos":""}],"OSTLERESS":[{"def":"A female ostler.","pos":""}],"OSTMEN":[{"def":"East men; Danish settlers in Ireland, formerly so called.","pos":""}],"OSTOSIS":[{"def":"Bone formation; ossification.","pos":""}],"OSTRACEA":[{"def":"A division of bivalve mollusks including the oysters and allied shells.","pos":""}],"OSTRACEAN":[{"def":"Any one of a family of bivalves, of which the oyster is the type.","pos":""}],"OSTRACION":[{"def":"A genus of plectognath fishes having the body covered with solid, immovable, bony plates.","pos":""}],"OSTRACIONT":[{"def":"A fish of the genus Ostracion and allied genera.","pos":""}],"OSTRACISM":[{"def":"Banishment by popular vote, -- a means adopted at Athens to rid the city of a person whose talent and influence gave umbrage.","pos":""}],"OSTRACITE":[{"def":"A fossil oyster.","pos":""}],"OSTRACIZE":[{"def":"To exile by ostracism; to banish by a popular vote, as at Athens.","pos":""}],"OSTRACODERMI":[{"def":"A suborder of fishes of which Ostracion is the type.","pos":""}],"OSTRACOID":[{"def":"Of or pertaining to the Ostracoidea.","pos":""},{"def":"One of the Ostracoidea.","pos":""}],"OSTRACOIDEA":[{"def":"An order of Entomostraca possessing hard bivalve shells.","pos":""}],"OSTREA":[{"def":"A genus of bivalve Mollusca which includes the true oysters.","pos":""}],"OSTREACEOUS":[{"def":"Of or pertaining to an oyster, or to a shell; shelly.","pos":""}],"OSTREACULTURE":[{"def":"The artificial cultivation of oysters.","pos":""}],"OSTREOPHAGIST":[{"def":"One who feeds on oysters.","pos":""}],"OSTRICH":[{"def":"A large bird of the genus Struthio, of which Struthio camelus of Africa is the best known species.","pos":""}],"OSTRIFEROUS":[{"def":"Producing oysters; containing oysters.","pos":""}],"OSTROGOTH":[{"def":"One of the Eastern Goths.","pos":""}],"OSTROGOTHIC":[{"def":"Of or pertaining to the Ostrogoths.","pos":""}]}