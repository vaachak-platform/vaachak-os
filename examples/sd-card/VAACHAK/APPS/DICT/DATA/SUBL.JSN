{"SUBLAPSARIAN":[{"def":"Same as Infralapsarian.","pos":""}],"SUBLAPSARIANISM":[{"def":"Infralapsarianism.","pos":""}],"SUBLATE":[{"def":"To take or carry away; to remove.","pos":""}],"SUBLATION":[{"def":"The act of taking or carrying away; removal.","pos":""}],"SUBLATIVE":[{"def":"Having power, or tending, to take away.","pos":""}],"SUBLEASE":[{"def":"A lease by a tenant or lessee to another person; an underlease.","pos":""}],"SUBLESSEE":[{"def":"A holder of a sublease.","pos":""}],"SUBLET":[{"def":"To underlet; to lease, as when a lessee leases to another person.","pos":""}],"SUBLEVATION":[{"def":"The act of raising on high; elevation.","pos":""},{"def":"An uprising; an insurrection.","pos":""}],"SUBLIBRARIAN":[{"def":"An under or assistant librarian.","pos":""}],"SUBLIEUTENANT":[{"def":"An inferior or second lieutenant; in the British service, a commissioned officer of the lowest rank.","pos":""}],"SUBLIGATION":[{"def":"The act of binding underneath.","pos":""}],"SUBLIMABLE":[{"def":"Capable of being sublimed or sublimated.","pos":""}],"SUBLIMATE":[{"def":"To bring by heat into the state of vapor, which, on cooling, returns again to the solid state; as, to sublimate sulphur or camphor.","pos":""},{"def":"To refine and exalt; to heighten; to elevate.","pos":""}],"SUBLIMATED":[{"def":"Refined by, or as by, sublimation; exalted; purified.","pos":""}],"SUBLIMATION":[{"def":"The act or process of subliming, or the state or result of being sublimed.","pos":""}],"SUBLIMATORY":[{"def":"Used for sublimation; as, sublimatory vessels.","pos":""}],"SUBLIME":[{"def":"Lifted up; high in place; exalted aloft; uplifted; lofty.","pos":""},{"def":"Distinguished by lofty or noble traits; eminent; -- said of persons.","pos":""}],"SUBLIMED":[{"def":"Having been subjected to the process of sublimation; hence, also, purified.","pos":""}],"SUBLIMELY":[{"def":"In a sublime manner.","pos":""}],"SUBLIMENESS":[{"def":"The quality or state of being sublime; sublimity.","pos":""}],"SUBLIMIFICATION":[{"def":"The act of making sublime, or state of being made sublime.","pos":""}],"SUBLIMINAL":[{"def":"Existing in the mind, but below the surface or threshold of consciousness; that is, existing as feeling rather than as clear ideas.","pos":""}],"SUBLIMITY":[{"def":"The quality or state of being sublime (in any sense of the adjective).","pos":""},{"def":"That which is sublime; as, the sublimities of nature.","pos":""}],"SUBLINEATION":[{"def":"A mark of a line or lines under a word in a sentence, or under another line; underlining.","pos":""}],"SUBLINGUA":[{"def":"A process or fold below the tongue in some animals.","pos":""}],"SUBLITION":[{"def":"The act or process of laying the ground in a painting.","pos":""}],"SUBLITTORAL":[{"def":"Under the shore.","pos":""}],"SUBLOBULAR":[{"def":"Situated under, or at the bases of, the lobules of the liver.","pos":""}],"SUBLUMBAR":[{"def":"Situated under, or on the ventral side of, the lumbar region of the vertebral column.","pos":""},{"def":"Situated beneath the moon; hence, of or pertaining to this world; terrestrial; earthly.","pos":""}],"SUBLUNARY":[{"def":"Any worldly thing.","pos":""}],"SUBLUXATION":[{"def":"An incomplete or partial dislocation.","pos":""}]}