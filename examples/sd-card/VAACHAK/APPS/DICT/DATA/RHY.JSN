{"RHYME":[{"def":"Correspondence of sound in the terminating words or syllables of two or more verses, one succeeding another immediately or at no great distance.","pos":""}],"RHYMELESS":[{"def":"Destitute of rhyme.","pos":""}],"RHYMER":[{"def":"One who makes rhymes; a versifier; -- generally in contempt; a poor poet; a poetaster.","pos":""}],"RHYMERY":[{"def":"The art or habit of making rhymes; rhyming; -- in contempt.","pos":""}],"RHYMESTER":[{"def":"A rhymer; a maker of poor poetry.","pos":""}],"RHYMIC":[{"def":"Pertaining to rhyme.","pos":""}],"RHYMIST":[{"def":"A rhymer; a rhymester.","pos":""}],"RHYNCHOBDELLEA":[{"def":"A suborder of leeches including those that have a protractile proboscis, without jaws.","pos":""}],"RHYNCHOCEPHALA":[{"def":"An order of reptiles having biconcave vertebræ, immovable quadrate bones, and many other peculiar osteological characters.","pos":""}],"RHYNCHOCOELA":[{"def":"Same as Nemertina.","pos":""}],"RHYNCHOLITE":[{"def":"A fossil cephalopod beak.","pos":""}],"RHYNCHONELLA":[{"def":"A genus of brachiopods of which some species are still living, while many are found fossil.","pos":""}],"RHYNCHOPHORA":[{"def":"A group of Coleoptera having a snoutlike head; the snout beetles, curculios, or weevils.","pos":""}],"RHYNCHOPHORE":[{"def":"One of the Rhynchophora.","pos":""}],"RHYNCHOTA":[{"def":"Same as Hemiptera.","pos":""}],"RHYOLITE":[{"def":"A quartzose trachyte, an igneous rock often showing a fluidal structure.","pos":""}],"RHYPAROGRAPHY":[{"def":"In ancient art, the painting of genre or still-life pictures.","pos":""}],"RHYSIMETER":[{"def":"An instrument, acting on the principle of Pitot's tube, for measuring the velocity of a fluid current, the speed of a ship, etc.","pos":""}],"RHYTHM":[{"def":"Movement in musical time, with periodical recurrence of accent; the measured beat or pulse which marks the character and expression of the music; symmetry of movement and accent.","pos":""}],"RHYTHMER":[{"def":"One who writes in rhythm, esp.","pos":""},{"def":"Pertaining to, or of the nature of, rhythm DAy and night I worked my rhythmic thought.","pos":""}],"RHYTHMICALLY":[{"def":"In a rhythmical manner.","pos":""}],"RHYTHMICS":[{"def":"The department of musical science which treats of the length of sounds.","pos":""}],"RHYTHMING":[{"def":"Writing rhythm; verse making.","pos":""}],"RHYTHMLESS":[{"def":"Being without rhythm.","pos":""}],"RHYTHMOMETER":[{"def":"An instrument for marking time in musical movements.","pos":""}]}