{"ABHAL":[{"def":"The berries of a species of cypress in the East Indies.","pos":""}],"ABHOMINABLE":[{"def":"Note: [A false orthography anciently used; h was foisted into various words; hence abholish, for abolish, etc.","pos":""}],"ABHOR":[{"def":"To protest against; to reject solemnly.","pos":""}],"ABHORRENCE":[{"def":"Extreme hatred or detestation; the feeling of utter dislike.","pos":""}],"ABHORRENT":[{"def":"Abhorring; detesting; having or showing abhorrence; loathing; hence, strongly opposed to; as, abhorrent thoughts.","pos":""},{"def":"Contrary or repugnant; discordant; inconsistent; -- followed by to.","pos":""}],"ABHORRENTLY":[{"def":"With abhorrence.","pos":""}],"ABHORRING":[{"def":"Object of abhorrence.","pos":""}]}