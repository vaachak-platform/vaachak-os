{"DODDART":[{"def":"A game much like hockey, played in an open field; also, the, bent stick for playing the game.","pos":""}],"DODDED":[{"def":"Without horns; as, dodded cattle; without beards; as, dodded corn.","pos":""}],"DODDER":[{"def":"A plant of the genus Cuscuta.","pos":""}],"DODDERED":[{"def":"Shattered; infirm.","pos":""}],"DODECAGON":[{"def":"A figure or polygon bounded by twelve sides and containing twelve angles.","pos":""}],"DODECAGYNIA":[{"def":"A Linnæan order of plants having twelve styles.","pos":""},{"def":"Of or pertaining to the Dodecagynia; having twelve styles.","pos":""}],"DODECAHEDRAL":[{"def":"Pertaining to, or like, a dodecahedion; consisting of twelve equal sides.","pos":""}],"DODECAHEDRON":[{"def":"A solid having twelve faces.","pos":""}],"DODECANDRIA":[{"def":"A Linnæan class of plants including all that have any number of stamens between twelve and nineteen.","pos":""},{"def":"Of or pertaining to the Dodecandria; having twelve stamens, or from twelve to nineteen.","pos":""}],"DODECANE":[{"def":"Any one of a group of thick oily hydrocarbons, C12H26, of the paraffin series.","pos":""}],"DODECASTYLE":[{"def":"Having twelve columns in front.","pos":""},{"def":"A dodecastyle portico, or building.","pos":""}],"DODECASYLLABIC":[{"def":"Having twelve syllables.","pos":""}],"DODECASYLLABLE":[{"def":"A word consisting of twelve syllables.","pos":""}],"DODECATEMORY":[{"def":"A tern applied to the twelve houses, or parts, of the zodiac of the primum mobile, to distinguish them from the twelve signs; also, any one of the twelve signs of the zodiac.","pos":""}],"DODGE":[{"def":"To start suddenly aside, as to avoid a blow or a missile; to shift place by a sudden start.","pos":""},{"def":"To evade a duty by low craft; to practice mean shifts; to use tricky devices; to play fast and loose; to quibble.","pos":""}],"DODGER":[{"def":"One who dodges or evades; one who plays fast and loose, or uses tricky devices.","pos":""},{"def":"A small handbill.","pos":""}],"DODGERY":[{"def":"trickery; artifice.","pos":""},{"def":"A stupid person; a fool; a blockhead.","pos":""}],"DODKIN":[{"def":"A doit; a small coin.","pos":""}],"DODMAN":[{"def":"Any shellfish which casts its shell, as a lobster.","pos":""}],"DODO":[{"def":"A large, extinct bird (Didus ineptus), formerly inhabiting the Island of Mauritius.","pos":""}]}