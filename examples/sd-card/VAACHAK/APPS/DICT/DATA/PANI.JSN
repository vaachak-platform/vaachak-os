{"PANIC":[{"def":"A plant of the genus Panicum; panic grass; also, the edible grain of some species of panic grass.","pos":""}],"PANICLE":[{"def":"A pyramidal form of inflorescence, in which the cluster is loosely branched below and gradually simpler toward the end.","pos":""}],"PANICLED":[{"def":"Furnished with panicles; arranged in, or like, panicles; paniculate.","pos":""},{"def":"Struck with a panic, or sudden fear.","pos":""}],"PANICUM":[{"def":"A genus of grasses, including several hundred species, some of which are valuable; panic grass.","pos":""}],"PANIDIOMORPHIC":[{"def":"Having a completely idiomorphic structure; -- said of certain rocks.","pos":""}],"PANIFICATION":[{"def":"The act or process of making bread.","pos":""}],"PANISLAMISM":[{"def":"A desire or plan for the union of all Mohammedan nations for the conquest of the world.","pos":""}],"PANIVOROUS":[{"def":"Eating bread; subsisting on bread.","pos":""}]}