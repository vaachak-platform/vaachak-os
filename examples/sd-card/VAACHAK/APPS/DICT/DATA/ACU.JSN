{"ACUATE":[{"def":"To sharpen; to make pungent; to quicken.","pos":""}],"ACUATION":[{"def":"Act of sharpening.","pos":""}],"ACUITION":[{"def":"The act of sharpening.","pos":""}],"ACUITY":[{"def":"Sharpness or acuteness, as of a needle, wit, etc.","pos":""}],"ACULEATE":[{"def":"Having a sting; covered with prickles; sharp like a prickle.","pos":""},{"def":"Having prickles, or sharp points; beset with prickles.","pos":""}],"ACULEATED":[{"def":"Having a sharp point; armed with prickles; prickly; aculeate.","pos":""}],"ACULEOLATE":[{"def":"Having small prickles or sharp points.","pos":""}],"ACULEUS":[{"def":"A prickle growing on the bark, as in some brambles and roses.","pos":""}],"ACUMEN":[{"def":"Quickness of perception or discernment; penetration of mind; the faculty of nice discrimination.","pos":""}],"ACUMINATE":[{"def":"Tapering to a point; pointed; as, acuminate leaves, teeth, etc.","pos":""}],"ACUMINATION":[{"def":"A sharpening; termination in a sharp point; a tapering point.","pos":""}],"ACUMINOSE":[{"def":"Terminating in a flat, narrow end.","pos":""}],"ACUMINOUS":[{"def":"Characterized by acumen; keen.","pos":""}],"ACUPRESSURE":[{"def":"A mode of arresting hemorrhage resulting from wounds or surgical operations, by passing under the divided vessel a needle, the ends of which are left exposed externally on the cutaneous surface.","pos":""}],"ACUPUNCTURATION":[{"def":"See Acupuncture.","pos":""}],"ACUPUNCTURE":[{"def":"Pricking with a needle; a needle prick.","pos":""},{"def":"The insertion of needles into the living tissues for remedial purposes.","pos":""}],"ACUSTUMAUNCE":[{"def":"See Accustomance.","pos":""}],"ACUTE":[{"def":"Attended with symptoms of some degree of severity, and coming speedily to a crisis; -- opposed to chronic; as, an acute disease.","pos":""}],"ACUTE-ANGLED":[{"def":"Having acute angles; as, an acute-angled triangle, a triangle with every one of its angles less than a right angle.","pos":""}],"ACUTELY":[{"def":"In an acute manner; sharply; keenly; with nice discrimination.","pos":""}],"ACUTENESS":[{"def":"Violence of a disease, which brings it speedily to a crisis.","pos":""}],"ACUTIFOLIATE":[{"def":"Having sharp-pointed leaves.","pos":""}],"ACUTILOBATE":[{"def":"Having acute lobes, as some leaves.","pos":""}],"ACUTORSION":[{"def":"The twisting of an artery with a needle to arrest hemorrhage.","pos":""}]}