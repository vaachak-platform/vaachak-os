{"TURBAN":[{"def":"The whole set of whorls of a spiral shell.","pos":""}],"TURBAN-SHELL":[{"def":"A sea urchin when deprived of its spines; -- popularly so called from a fancied resemblance to a turban.","pos":""}],"TURBAN-TOP":[{"def":"A kind of fungus with an irregularly wrinkled, somewhat globular pileus (Helvella, or Gyromitra, esculenta.","pos":""}],"TURBANED":[{"def":"Wearing a turban.","pos":""}],"TURBANT":[{"def":"I see the Turk nodding with his turbant.","pos":""}],"TURBARY":[{"def":"A right of digging turf on another man's land; also, the ground where turf is dug.","pos":""}],"TURBELLARIA":[{"def":"An extensive group of worms which have the body covered externally with vibrating cilia.","pos":""}],"TURBELLARIAN":[{"def":"One of the Turbellaria.","pos":""}],"TURBID":[{"def":"Having the lees or sediment disturbed; roiled; muddy; thick; not clear; -- used of liquids of any kind; as, turbid water; turbid wine.","pos":""},{"def":"Disturbed; confused; disordered.","pos":""}],"TURBIDLY":[{"def":"In a turbid manner; with muddiness or confusion.","pos":""},{"def":"Proudly; haughtily.","pos":""}],"TURBIDNESS":[{"def":"The quality or state of being turbid; muddiness; foulness.","pos":""}],"TURBILLION":[{"def":"A whirl; a vortex.","pos":""}],"TURBINACEOUS":[{"def":"Of or pertaining to peat, or turf; of the nature of peat, or turf; peaty; turfy.","pos":""}],"TURBINAL":[{"def":"Rolled in a spiral; scroll-like; turbinate; -- applied to the thin, plicated, bony or cartilaginous plates which support the olfactory and mucous membranes of the nasal chambers.","pos":""}],"TURBINATE":[{"def":"To revolve or spin like a top; to whirl.","pos":""},{"def":"Shaped like a top, or inverted cone; narrow at the base, and broad at the apex; as, a turbinated ovary, pericarp, or root.","pos":""}],"TURBINATION":[{"def":"The act of spinning or whirling, as a top.","pos":""}],"TURBINE":[{"def":"A water wheel, commonly horizontal, variously constructed, but usually having a series of curved floats or buckets, against which the water acts by its impulse or reaction in flowing either outward from a central chamber, inward from an external casing, or from above downward, etc.","pos":""}],"TURBINELLA":[{"def":"A genus of large marine gastropods having a thick heavy shell with conspicuous folds on the columella.","pos":""}],"TURBINITE":[{"def":"A petrified shell resembling the genus Turbo.","pos":""}],"TURBINOID":[{"def":"Like or pertaining to Turbo or the family Turbinidæ.","pos":""}],"TURBIT":[{"def":"A variety of the domestic pigeon, remarkable for its short beak.","pos":""}],"TURBO":[{"def":"Any one of numerous marine gastropods of the genus Turbo or family Turbinidæ, usually having a turbinate shell, pearly on the inside, and a calcareous operculum.","pos":""}],"TURBOGENERATOR":[{"def":"An electric generator or dynamo which is combined on one frame with a turbomotor, by which it is driven.","pos":""}],"TURBOT":[{"def":"Flounder), the halibut, and the diamond flounder (Hypsopsetta guttulata) of California.","pos":""}],"TURBULENCE":[{"def":"The quality or state of being turbulent; a disturbed state; tumult; disorder; agitation.","pos":""}],"TURBULENCY":[{"def":"What a tale of terror now its turbulency tells! Poe.","pos":""}],"TURBULENT":[{"def":"Disturbed; agitated; tumultuous; roused to violent commotion; as, the turbulent ocean.","pos":""},{"def":"Disposed to insubordination and disorder; restless; unquiet; refractory; as, turbulent spirits.","pos":""}],"TURBULENTLY":[{"def":"In a turbulent manner.","pos":""}]}