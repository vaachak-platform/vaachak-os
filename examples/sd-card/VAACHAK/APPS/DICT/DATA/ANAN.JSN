{"ANAN":[{"def":"An expression equivalent to What did you say Sir Eh [Obs.","pos":""}],"ANANAS":[{"def":"The pineapple (Ananassa sativa).","pos":""}],"ANANGULAR":[{"def":"Containing no angle.","pos":""}],"ANANTHEROUS":[{"def":"Destitute of anthers.","pos":""}],"ANANTHOUS":[{"def":"Destitute of flowers; flowerless.","pos":""},{"def":"Same as Anapest, Anapestic.","pos":""}]}