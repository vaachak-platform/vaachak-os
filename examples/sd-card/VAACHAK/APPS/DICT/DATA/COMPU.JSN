{"COMPULSATIVELY":[{"def":"Com*pul\"sa*tive*ly, adv.","pos":""}],"COMPULSATORY":[{"def":"Operating with force; compelling; forcing; constraininig; resulting from, or enforced by, compulsion.","pos":""}],"COMPULSION":[{"def":"The act of compelling, or the state of being compelled; the act of driving or urging by force or by physical or moral constraint; subjection to force.","pos":""}],"COMPULSIVE":[{"def":"Having power to compel; exercising or applying compulsion.","pos":""}],"COMPULSIVELY":[{"def":"By compulsion; by force.","pos":""}],"COMPULSORILY":[{"def":"; by force or constraint.","pos":""}],"COMPULSORY":[{"def":"Having the power of compulsion; constraining.","pos":""},{"def":"Obligatory; enjoined by authority; necessary; due to complusion.","pos":""}],"COMPUNCT":[{"def":"Affected with compunction; conscience-stricken.","pos":""}],"COMPUNCTION":[{"def":"A pricking; stimulation.","pos":""},{"def":"A picking of heart; poignant grief proceeding from a sense of guilt or consciousness of causing pain; the sting of conscience.","pos":""}],"COMPUNCTIONLESS":[{"def":"Without compunction.","pos":""}],"COMPUNCTIOUS":[{"def":"Of the nature of compunction; caused by conscience; attended with, or causing, compunction.","pos":""}],"COMPUNCTIOUSLY":[{"def":"With compunction.","pos":""}],"COMPUNCTIVE":[{"def":"Sensitive in respect of wrongdoing; conscientious.","pos":""}],"COMPURGATION":[{"def":"The act or practice of justifying or confirming a man's veracity by the oath of others; -- called also wager of law.","pos":""}],"COMPURGATOR":[{"def":"One who bears testimony or swears to the veracity or innocence of another.","pos":""}],"COMPURGATORIAL":[{"def":"Relating to a compurgator or to compurgation.","pos":""}],"COMPUTABLE":[{"def":"Capable of being computed, numbered, or reckoned.","pos":""}],"COMPUTATION":[{"def":"The act or process of computing; calculation; reckoning.","pos":""},{"def":"The result of computation; the amount computed.","pos":""}],"COMPUTE":[{"def":"To determine calculation; to reckon; to count.","pos":""}],"COMPUTER":[{"def":"One who computes.","pos":""}]}