{"BORABLE":[{"def":"Capable of being bored.","pos":""}],"BORACHTE":[{"def":"A large leather bottle for liquors, etc.","pos":""}],"BORACIC":[{"def":"Pertaining to, or produced from, borax; containing boron; boric; as, boracic acid.","pos":""}],"BORACITE":[{"def":"A mineral of a white or gray color occurring massive and in isometric crystals; in composition it is a magnesium borate with magnesium chloride.","pos":""}],"BORACOUS":[{"def":"Relating to, or obtained from, borax; containing borax.","pos":""}],"BORAGE":[{"def":"A mucilaginous plant of the genus Borago (B.","pos":""}],"BORAGEWORT":[{"def":"Plant of the Borage family.","pos":""}],"BORAGINACEOUS":[{"def":"Of, pertaining to, or resembling, a family of plants (Boraginaceæ) which includes the borage, heliotrope, beggar's lice, and many pestiferous plants.","pos":""}],"BORAGINEOUS":[{"def":"Relating to the Borage tribe; boraginaceous.","pos":""}],"BORATE":[{"def":"A salt formed by the combination of boric acid with a base or positive radical.","pos":""}],"BORAX":[{"def":"A white or gray crystalline salt, with a slight alkaline taste, used as a flux, in soldering metals, making enamels, fixing colors on porcelain, and as a soap.","pos":""}],"BORBORYGM":[{"def":"A rumbling or gurgling noise produced by wind in the bowels.","pos":""}],"BORD":[{"def":"The face of coal parallel to the natural fissures.","pos":""}],"BORD SERVICE":[{"def":"Service due from a bordar; bordage.","pos":""}],"BORDAGE":[{"def":"The base or servile tenure by which a bordar held his cottage.","pos":""}],"BORDAR":[{"def":"A villein who rendered menial service for his cottage; a cottier.","pos":""}],"BORDEAUX":[{"def":"Pertaining to Bordeaux in the south of France.","pos":""},{"def":"A claret wine from Bordeaux.","pos":""}],"BORDEAUX MIXTURE":[{"def":"A fungicidal mixture composed of blue vitriol, lime, and water.","pos":""},{"def":"A brothel; a bawdyhouse; a house devoted to prostitution.","pos":""}],"BORDELAIS":[{"def":"Of or pertaining to Bordeaux, in France, or to the district around Bordeaux.","pos":""}],"BORDELLER":[{"def":"A keeper or a frequenter of a brothel.","pos":""}],"BORDER":[{"def":"The outer part or edge of anything, as of a garment, a garden, etc.","pos":""},{"def":"A boundary; a frontier of a state or of the settled part of a country; a frontier district.","pos":""}],"BORDEREAU":[{"def":"A note or memorandum, esp.","pos":""}],"BORDERER":[{"def":"One who dwells on a border, or at the extreme part or confines of a country, region, or tract of land; one who dwells near to a place or region.","pos":""}],"BORDLAND":[{"def":"Either land held by a bordar, or the land which a lord kept for the maintenance of his board, or table.","pos":""}],"BORDLODE":[{"def":"The service formerly required of a tenant, to carry timber from the woods to the lord's house.","pos":""}],"BORDMAN":[{"def":"A bordar; a tenant in bordage.","pos":""},{"def":"An incursion upon the borders of a country; a raid.","pos":""}],"BORDURE":[{"def":"A border one fifth the width of the shield, surrounding the field.","pos":""}],"BORE":[{"def":"To perforate or penetrate, as a solid body, by turning an auger, gimlet, drill, or other instrument; to make a round hole in or through; to pierce; as, to bore a plank.","pos":""},{"def":"To form or enlarge by means of a boring instrument or apparatus; as, to bore a steam cylinder or a gun barrel; to bore a hole.","pos":""}],"BOREAL":[{"def":"Northern; pertaining to the north, or to the north wind; as, a boreal bird; a boreal blast.","pos":""}],"BOREAS":[{"def":"The north wind; -- usually a personification.","pos":""}],"BORECOLE":[{"def":"A brassicaceous plant of many varieties, cultivated for its leaves, which are not formed into a compact head like the cabbage, but are loose, and are generally curled or wrinkled; kale.","pos":""}],"BOREDOM":[{"def":"The state of being bored, or pestered; a state of ennui.","pos":""},{"def":"The realm of bores; bores, collectively.","pos":""}],"BOREE":[{"def":"Same as BourrÉ\\'82.","pos":""}],"BORELE":[{"def":"The smaller two-horned rhinoceros of South Africa (Atelodus bicornis).","pos":""}],"BORER":[{"def":"One that bores; an instrument for boring.","pos":""}],"BORIC":[{"def":"Of, pertaining to, or containing, boron.","pos":""}],"BORIDE":[{"def":"A binary compound of boron with a more positive or basic element or radical; -- formerly called boruret.","pos":""}],"BORING":[{"def":"The chips or fragments made by boring.","pos":""}],"BORN":[{"def":"Brought forth, as an animal; brought into life; introduced by birth.","pos":""},{"def":"Having from birth a certain character; by or from birth; by nature; innate; as, a born liar.","pos":""}],"BORNE":[{"def":"Carried; conveyed; supported; defrayed.","pos":""}],"BORNEOL":[{"def":"A rare variety of camphor, C10H17.","pos":""}],"BORNITE":[{"def":"A valuable ore of copper, containing copper, iron, and sulphur; -- also called purple copper ore (or erubescite), in allusion to the colors shown upon the slightly tarnished surface.","pos":""}],"BOROFLUORIDE":[{"def":"A double fluoride of boron and hydrogen, or some other positive element, or radical; -- called also fluoboride, and formerly fluoborate.","pos":""}],"BOROGLYCERIDE":[{"def":"A compound of boric acid and glycerin, used as an antiseptic.","pos":""}],"BORON":[{"def":"A nonmetallic element occurring abundantly in borax.","pos":""}],"BOROSILICATE":[{"def":"A double salt of boric and silicic acids, as in the natural minerals tourmaline, datolite, etc.","pos":""}],"BOROUGH":[{"def":"The collective body of citizens or inhabitants of a borough; as, the borough voted to lay a tax.","pos":""}],"BOROUGH-ENGLISH":[{"def":"A custom, as in some ancient boroughs, by which lands and tenements descend to the youngest son, instead of the eldest; or, if the owner have no issue, to the youngest brother.","pos":""}],"BOROUGHHEAD":[{"def":"See Headborough.","pos":""}],"BOROUGHHOLDER":[{"def":"A headborough; a borsholder.","pos":""}],"BOROUGHMASTER":[{"def":"The mayor, governor, or bailiff of a borough.","pos":""}],"BOROUGHMONGER":[{"def":"One who buys or sells the parliamentary seats of boroughs.","pos":""},{"def":"The practices of a boroughmonger.","pos":""}],"BORRACHO":[{"def":"BORRAGE; BORRAGINACEOUS Bor\"rage, n.","pos":""}],"BORREL":[{"def":"Coarse woolen cloth; hence, coarse clothing; a garment.","pos":""},{"def":"A kind of light stuff, of silk and wool.","pos":""}],"BORROW":[{"def":"To take (one or more) from the next higher denomination in order to add it to the next lower; -- a term of subtraction when the figure of the subtrahend is larger than the corresponding one of the minuend.","pos":""}],"BORROWER":[{"def":"One who borrows.","pos":""}],"BORSHOLDER":[{"def":"The head or chief of a tithing, or borough (see 2d Borough); the headborough; a parish constable.","pos":""}],"BORT":[{"def":"Imperfectly crystallized or coarse diamonds, or fragments made in cutting good diamonds which are reduced to powder and used in lapidary work.","pos":""}]}