{"BIMACULATE":[{"def":"Having, or marked with, two spots.","pos":""}],"BIMANA":[{"def":"Animals having two hands; -- a term applied by Cuvier to man as a special order of Mammalia.","pos":""}],"BIMANOUS":[{"def":"Having two hands; two-handed.","pos":""}],"BIMARGINATE":[{"def":"Having a double margin, as certain shells.","pos":""}],"BIMASTISM":[{"def":"The condition of having two mammæ or teats.","pos":""}],"BIMEDIAL":[{"def":"Applied to a line which is the sum of two lines commensurable only in power (as the side and diagonal of a square).","pos":""}],"BIMEMBRAL":[{"def":"Having two members; as, a bimembral sentence.","pos":""}],"BIMENSAL":[{"def":"See Bimonthly, a.","pos":""}],"BIMESTRIAL":[{"def":"Continuing two months.","pos":""}],"BIMETALLIC":[{"def":"Of or relating to, or using, a double metallic standard (as gold and silver) for a system of coins or currency.","pos":""}],"BIMETALLISM":[{"def":"The legalized use of two metals (as gold and silver) in the currency of a country, at a fixed relative value; -- in opposition to monometallism.","pos":""}],"BIMETALLIST":[{"def":"An advocate of bimetallism.","pos":""}],"BIMOLECULAR":[{"def":"Pertaining to, or formed from, two molecules; as, a bimolecular reaction (a reaction between two molecules).","pos":""}],"BIMONTHLY":[{"def":"Occurring, done, or coming, once in two months; as, bimonthly visits; bimonthly publications.","pos":""},{"def":"A bimonthly publication.","pos":""}],"BIMUSCULAR":[{"def":"Having two adductor muscles, as a bivalve mollusk.","pos":""}]}