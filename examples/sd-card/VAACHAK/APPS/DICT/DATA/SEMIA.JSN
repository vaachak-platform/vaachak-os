{"SEMIACID":[{"def":"Slightly acid; subacid.","pos":""}],"SEMIACIDIFIED":[{"def":"Sem`i*a*cid\"i*fied, a.","pos":""}],"SEMIADHERENT":[{"def":"Adherent part way.","pos":""}],"SEMIAMPLEXICAUL":[{"def":"Partially amplexicaul; embracing the stem half round, as a leaf.","pos":""}],"SEMIANGLE":[{"def":"The half of a given, or measuring, angle.","pos":""}],"SEMIANNUALLY":[{"def":"Every half year.","pos":""}],"SEMIANNULAR":[{"def":"Having the figure of a half circle; forming a semicircle.","pos":""}]}