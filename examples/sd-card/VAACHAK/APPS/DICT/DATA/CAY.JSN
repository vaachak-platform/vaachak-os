{"CAY":[{"def":"See Key, a ledge.","pos":""}],"CAYENNE":[{"def":"A very pungent spice made by drying and grinding the fruits or seeds of several species of the genus Capsicum, esp.","pos":""}],"CAYMAN":[{"def":"The south America alligator.","pos":""}],"CAYO":[{"def":"A small island or ledge of rock in the water; a key.","pos":""}],"CAYUSE":[{"def":"A chief or petty king among some tribes of Indians in America.","pos":""}]}