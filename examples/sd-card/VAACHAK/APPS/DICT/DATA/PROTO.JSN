{"PROTO-":[{"def":"A combining form prefix signifying first, primary, primordial; as, protomartyr, the first martyr; protomorphic, primitive in form; protoplast, a primordial organism; prototype, protozoan.","pos":""}],"PROTO-DORIC":[{"def":"Pertaining to, or designating, architecture, in which the beginnings of the Doric style are supposed to be found.","pos":""}],"PROTOCANONICAL":[{"def":"Of or pertaining to the first canon, or that which contains the authorized collection of the books of Scripture; -- opposed to deutero-canonical.","pos":""}],"PROTOCATECHUIC":[{"def":"Pertaining to, derived from, or designating, an organic acid which is obtained as a white crystalline substance from catechin, asafetida, oil of cloves, etc.","pos":""}],"PROTOCERCAL":[{"def":"Having a caudal fin extending around the end of the vertebral column, like that which is first formed in the embryo of fishes; diphycercal.","pos":""}],"PROTOCOCCUS":[{"def":"A genus of minute unicellular algæ including the red snow plant (Protococcus nivalis).","pos":""}],"PROTOCOL":[{"def":"The original copy of any writing, as of a deed, treaty, dispatch, or other instrument.","pos":""},{"def":"The minutes, or rough draught, of an instrument or transaction.","pos":""}],"PROTOCOLIST":[{"def":"One who draughts protocols.","pos":""}],"PROTOCONCH":[{"def":"The embryonic shell, or first chamber, of ammonites and other cephalopods.","pos":""}],"PROTOGINE":[{"def":"A kind of granite or gneiss containing a silvery talcose mineral.","pos":""}],"PROTOGYNOUS":[{"def":"Same as Proterogynous.","pos":""}],"PROTOHIPPUS":[{"def":"A genus of fossil horses from the Lower Pliocene.","pos":""}],"PROTOMARTYR":[{"def":"The first martyr; the first who suffers, or is sacrificed, in any cause; -- applied esp.","pos":""}],"PROTOMERITE":[{"def":"The second segment of one of the Gregarinæ.","pos":""}],"PROTOMETALS":[{"def":"Pro`to*me*tal\"ic (#), a.","pos":""}],"PROTOMORPHIC":[{"def":"Having the most primitive character; in the earliest form; as, a protomorphic layer of tissue.","pos":""}],"PROTONEMA":[{"def":"The primary growth from the spore of a moss, usually consisting of branching confervoid filaments, on any part of which stem and leaf buds may be developed.","pos":""}],"PROTONOTARY":[{"def":"Same as Prothonotary.","pos":""},{"def":"An organism whose nature is so difficult to determine that it might be referred to either the animal or the vegetable kingdom.","pos":""}],"PROTOPHYTE":[{"def":"Any unicellular plant, or plant forming only a plasmodium, having reproduction only by fission, gemmation, or cell division.","pos":""}],"PROTOPHYTOLOGY":[{"def":"Pro`to*phy*tol\"o*gy, n.","pos":""}],"PROTOPINE":[{"def":"An alkaloid found in opium in small quantities, and extracted as a white crystalline substance.","pos":""}],"PROTOPLASM":[{"def":"The viscid and more or less granular material of vegetable and animal cells, possessed of vital properties by which the processes of nutrition, secretion, and growth go forward; the so-called \" physical basis of life;\" the original cell substance, cytoplasm, cytoblastema, bioplasm sarcode, etc.","pos":""}],"PROTOPLASMATIC":[{"def":"Pro`to*plas*mat\"ic, a.","pos":""}],"PROTOPLASMIC":[{"def":"Of or pertaining to protoplasm; consisting of, or resembling, protoplasm.","pos":""}],"PROTOPLAST":[{"def":"A first-formed organized body; the first individual, or pair of individuals, of a species.","pos":""}],"PROTOPLASTA":[{"def":"A division of fresh-water rhizopods including those that have a soft body and delicate branched pseudopodia.","pos":""}],"PROTOPODITE":[{"def":"The basal portion, or two proximal and more or less consolidated segments, of an appendage of a crustacean.","pos":""}],"PROTOPOPE":[{"def":"One of the clergy of first rank in the lower order of secular clergy; an archpriest; -- called also protopapas.","pos":""}],"PROTOSALT":[{"def":"A salt derived from a protoxide base.","pos":""}],"PROTOSILICATE":[{"def":"A silicate formed with the lowest proportion of silicic acid, or having but one atom of silicon in the molecule.","pos":""}],"PROTOSOMITE":[{"def":"One of the primitive segments, or metameres, of an animal.","pos":""}],"PROTOSULPHIDE":[{"def":"That one of a series of sulphides of any element which has the lowest proportion of sulphur; a sulphide with but one atom of sulphur in the molecule.","pos":""}],"PROTOSULPHURET":[{"def":"A protosulphide.","pos":""}],"PROTOTHERIA":[{"def":"Same as Monotremata.","pos":""}],"PROTOTRACHEATA":[{"def":"Same as Malacopoda.","pos":""}],"PROTOTYPE":[{"def":"An original or model after which anything is copied; the pattern of anything to be engraved, or otherwise copied, cast, or the like; a primary form; exemplar; archetype.","pos":""}],"PROTOVERTEBRA":[{"def":"One of the primitive masses, or segments, into which the mesoblast of the vertebrate embryo breaks up on either side of the anterior part of the notochord; a mesoblastic, or protovertebral, somite.","pos":""}],"PROTOVERTEBRAL":[{"def":"Of or pertaining to the protovertebræ.","pos":""}],"PROTOXIDE":[{"def":"That one of a series of oxides having the lowest proportion of oxygen.","pos":""}],"PROTOXIDIZE":[{"def":"To combine with oxygen, as any elementary substance, in such proportion as to form a protoxide.","pos":""}],"PROTOZOA":[{"def":"The lowest of the grand divisions of the animal kingdom.","pos":""}],"PROTOZOAN":[{"def":"Of or pertaining to the Protozoa.","pos":""},{"def":"One of the Protozoa.","pos":""}],"PROTOZOIC":[{"def":"Of or pertaining to the Protozoa.","pos":""},{"def":"Containing remains of the earliest discovered life of the globe, which included mollusks, radiates and protozoans.","pos":""}]}