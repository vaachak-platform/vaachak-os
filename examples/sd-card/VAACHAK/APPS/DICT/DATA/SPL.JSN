{"SPLANCHNAPOPHYSIS":[{"def":"Any element of the skeleton in relation with the alimentary canal, as the jaws and hyoidean apparatus.","pos":""}],"SPLANCHNIC":[{"def":"Of or pertaining to the viscera; visceral.","pos":""}],"SPLANCHNO-SKELETON":[{"def":"That part of the skeleton connected with the sense organs and the viscera.","pos":""}],"SPLANCHNOGRAPHY":[{"def":"Splanch*nog\"ra*phy, n.","pos":""}],"SPLANCHNOLOGY":[{"def":"That part of anatomy which treats of the viscera; also, a treatise on the viscera.","pos":""}],"SPLANCHNOPLEURE":[{"def":"The inner, or visceral, one of the two lamellæ into which the vertebrate blastoderm divides on either side of the notochord, and from which the walls of the enteric canal and the umbilical vesicle are developed.","pos":""}],"SPLANCHNOTOMY":[{"def":"The dissection, or anatomy, of the viscera.","pos":""}],"SPLASH":[{"def":"To strike and dash about, as water, mud, etc.","pos":""},{"def":"To spatter water, mud, etc.","pos":""}],"SPLASHBOARD":[{"def":"A guard in the front part of vehicle, to prevent splashing by a mud or water from the horse's heels; -- in the United States commonly called dashboard.","pos":""}],"SPLASHER":[{"def":"One who, or that which, splashes.","pos":""},{"def":"One of the guarde over the wheels, as of a carriage, locomotive, etc.","pos":""}],"SPLASHY":[{"def":"Full of dirty water; wet and muddy, so as be easily splashed about; slushy.","pos":""}],"SPLATTER":[{"def":"To spatter; to splash.","pos":""}],"SPLAY":[{"def":"To display; to spread.","pos":""},{"def":"To dislocate, as a shoulder bone.","pos":""}],"SPLAYFOOT":[{"def":"A foot that is abnormally flattened and spread out; flat foot.","pos":""},{"def":"Having a splayfoot or splayfeet.","pos":""}],"SPLAYMOUTH":[{"def":"A wide mouth; a mouth stretched in derision.","pos":""}],"SPLAYMOUTHED":[{"def":"Having a splaymouth.","pos":""}],"SPLEEN":[{"def":"A peculiar glandlike but ductless organ found near the stomach or intestine of most vertebrates and connected with the vascular system; the milt.","pos":""}],"SPLEENED":[{"def":"Deprived of the spleen.","pos":""},{"def":"Angered; annoyed.","pos":""}],"SPLEENFUL":[{"def":"Displaying, or affected with, spleen; angry; fretful; melancholy.","pos":""}],"SPLEENISH":[{"def":"Spleeny; affected with spleen; fretful.","pos":""}],"SPLEENLESS":[{"def":"Having no spleen; hence, kind; gentle; mild.","pos":""}],"SPLEENWORT":[{"def":"Any fern of the genus Asplenium, some species of which were anciently used as remedies for disorders of the spleen.","pos":""}],"SPLEENY":[{"def":"Irritable; peevish; fretful.","pos":""},{"def":"Affected with nervous complaints; melancholy.","pos":""}],"SPLEGET":[{"def":"A cloth dipped in a liquid for washing a sore.","pos":""}],"SPLENALGIA":[{"def":"Pain over the region of the spleen.","pos":""}],"SPLENDENT":[{"def":"Shining; glossy; beaming with light; lustrous; as, splendent planets; splendent metals.","pos":""},{"def":"Very conspicuous; illustrious.","pos":""}],"SPLENDID":[{"def":"Possessing or displaying splendor; shining; very bright; as, a splendid sun.","pos":""},{"def":"Showy; magnificent; sumptuous; pompous; as, a splendid palace; a splendid procession or pageant.","pos":""}],"SPLENDIDLY":[{"def":"In a splendid manner; magnificently.","pos":""}],"SPLENDIDNESS":[{"def":"The quality of being splendid.","pos":""}],"SPLENDIFEROUS":[{"def":"Splendor-bearing; splendid.","pos":""}],"SPLENDOR":[{"def":"Great brightness; brilliant luster; brilliancy; as, the splendor ot the sun.","pos":"noun"},{"def":"Magnifience; pomp; parade; as, the splendor of equipage, ceremonies, processions, and the like.","pos":"noun"}],"SPLENETIC":[{"def":"Affected with spleen; malicious; spiteful; peevish; fretful.","pos":""}],"SPLENETICALLY":[{"def":"In a splenetical manner.","pos":""}],"SPLENIAL":[{"def":"The splenial bone.","pos":""}],"SPLENIC":[{"def":"Of or pertaining to the spleen; lienal; as, the splenic vein.","pos":""}],"SPLENITIS":[{"def":"Inflammation of the spleen.","pos":"noun"}],"SPLENITIVE":[{"def":"Even and smooth as seemed the temperament of the nonchalant, languid Virginian -- not splenitive or rash.","pos":""}],"SPLENIUM":[{"def":"The thickened posterior border of the corpus callosum; -- so called in allusion to its shape.","pos":"noun"}],"SPLENIUS":[{"def":"A flat muscle of the back of the neck.","pos":""}],"SPLENIZATION":[{"def":"A morbid state of the lung produced by inflammation, in which its tissue resembles that of the spleen.","pos":""}],"SPLENOCELE":[{"def":"Hernia formed by the spleen.","pos":""}],"SPLENOGRAPHY":[{"def":"A description of the spleen.","pos":""}],"SPLENOID":[{"def":"Resembling the spleen; spleenlike.","pos":""}],"SPLENOLOGY":[{"def":"The branch of science which treats of the spleen.","pos":""}],"SPLENT":[{"def":"See Splent coal, below.","pos":""}],"SPLEUCHAN":[{"def":"A pouch, as for tobacco.","pos":""}],"SPLICE":[{"def":"To unite, as two ropes, or parts of a rope, by a particular manner of interweaving the strands, -- the union being between two ends, or between an end and the body of a rope.","pos":""},{"def":"To unite, as spars, timbers, rails, etc.","pos":""}],"SPLINE":[{"def":"A rectangular piece fitting grooves like key seats in a hub and a shaft, so that while the one may slide endwise on the other, both must revolve together; a feather; also, sometimes, a groove to receive such a rectangular piece.","pos":""},{"def":"A long, flexble piece of wood sometimes used as a ruler.","pos":""}],"SPLINING":[{"def":"Of or pertaining to a spline.","pos":""}],"SPLINT":[{"def":"A thin piece of wood, or other substance, used to keep in place, or protect, an injured part, especially a broken bone when set.","pos":""}],"SPLINTER":[{"def":"To split or rend into long, thin pieces; to shiver; as, the lightning splinters a tree.","pos":""},{"def":"To fasten or confine with splinters, or splints, as a broken limb.","pos":""}],"SPLINTERPROOF":[{"def":"Proof against the splinters, or fragments, of bursting shells.","pos":""}],"SPLINTERY":[{"def":"Consisting of splinters; resembling splinters; as, the splintery fracture of a mineral.","pos":""}],"SPLIT":[{"def":"To divide or separate into components; -- often used with up; as, to split up sugar into alcohol and carbonic acid.","pos":""}],"SPLIT DYNAMOMETER":[{"def":"An electric dynamometer having two coils so arranged that one carries the primary current, and the other the secondary current, of a transformer.","pos":""}],"SPLIT INFINITIVE":[{"def":"A simple infinitive with to, having a modifier between the verb and the to; as in, to largely decrease.","pos":""}],"SPLIT KEY":[{"def":"A key split at one end like a split pin, for the same purpose.","pos":""},{"def":"In croquet, etc.","pos":""}],"SPLIT STITCH":[{"def":"A stitch used in stem work to produce a fine line, much used in old church embroidery to work the hands and faces of figures.","pos":""}],"SPLIT STUFF":[{"def":"Timber sawn into lengths and then split.","pos":""}],"SPLIT-TONGUED":[{"def":"Having a forked tongue, as that of snakes and some lizards.","pos":""}],"SPLITTER":[{"def":"One who, or that which, splits.","pos":""}],"SPLOTCH":[{"def":"A spot; a stain; a daub.","pos":""}],"SPLOTCHY":[{"def":"Covered or marked with splotches.","pos":""}],"SPLURGE":[{"def":"A blustering demonstration, or great effort; a great display.","pos":""}],"SPLUTTER":[{"def":"To speak hastily and confusedly; to sputter.","pos":""}],"SPLUTTERER":[{"def":"One who splutters.","pos":""}]}