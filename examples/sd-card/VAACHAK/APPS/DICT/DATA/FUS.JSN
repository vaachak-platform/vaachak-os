{"FUSAROLE":[{"def":"A molding generally placed under the echinus or quarter round of capitals in the Doric, Ionic, and Corinthian orders of architecture.","pos":""}],"FUSCATION":[{"def":"A darkening; obscurity; obfuscation.","pos":""}],"FUSCIN":[{"def":"A brown, nitrogenous pigment contained in the retinal epithelium; a variety of melanin.","pos":""}],"FUSCINE":[{"def":"A dark-colored substance obtained from empyreumatic animal oil.","pos":""}],"FUSCOUS":[{"def":"Brown or grayish black; darkish.","pos":""}],"FUSE":[{"def":"To liquefy by heat; to render fiuid; to dissolve; to melt.","pos":""},{"def":"To unite or blend, as if melted together.","pos":""}],"FUSEE":[{"def":"A small packet of explosive material with wire appendages allowing it to be conveniently attached to a railroad track.","pos":""}],"FUSELAGE":[{"def":"An elongated body or frame of an aëroplane or flying machine; sometimes, erroneously, any kind of frame or body.","pos":""},{"def":"A plug fitted to the fuse hole of a shell to hold the fuse.","pos":""}],"FUSIBILITY":[{"def":"The quality of being fusible.","pos":""}],"FUSIBLE":[{"def":"CapabIe of being melted or liquefied.","pos":""}],"FUSIFORM":[{"def":"Shaped like a spindle; tapering at each end; as, a fusiform root; a fusiform cell.","pos":""}],"FUSIL":[{"def":"Capable of being melted or rendered fluid by heat; fusible.","pos":""},{"def":"Running or flowing, as a liquid.","pos":""}],"FUSILE":[{"def":"Same as Fusil, a.","pos":""}],"FUSILLADE":[{"def":"A simultaneous discharge of firearms.","pos":""}],"FUSION":[{"def":"The union, or binding together, of adjacent parts or tissues.","pos":""}],"FUSOME":[{"def":"Handy; reat; handsome; notable.","pos":""}],"FUSS":[{"def":"A tumult; a bustle; unnecessary or annoying ado about trifles.","pos":""},{"def":"One who is unduly anxious about trifles.","pos":""}],"FUSSILY":[{"def":"In a fussy manner.","pos":""}],"FUSSINESS":[{"def":"The quality of being fussy.","pos":""}],"FUSSY":[{"def":"Making a fuss; disposed to make an unnecessary ado about trifles; overnice; fidgety.","pos":""}],"FUST":[{"def":"The shaft of a column, or trunk of pilaster.","pos":""}],"FUSTED":[{"def":"Moldy; ill-smelling.","pos":""}],"FUSTERIC":[{"def":"The coloring matter of fustet.","pos":""}],"FUSTET":[{"def":"The wood of the Rhus Cptinus or Venice sumach, a shrub of Southern Europe, which yields a fine orange color, which, however, is not durable without a mordant.","pos":""}],"FUSTIAN":[{"def":"A kind of coarse twilled cotton or cotton and linen stuff, including corduroy, velveteen, etc.","pos":""},{"def":"An inflated style of writing; a kind of writing in which high- sounding words are used,' above the dignity of the thoughts or subject; bombast.","pos":""}],"FUSTIANIST":[{"def":"A writer of fustian.","pos":""}],"FUSTIC":[{"def":"The wood of the Maclura tinctoria, a tree growing in the West Indies, used in dyeing yellow; -- called also old fustic.","pos":""}],"FUSTIGATION":[{"def":"A punishment by beating with a stick or club; cudgeling.","pos":""}],"FUSTILARIAN":[{"def":"A low fellow; a stinkard; a scoundrel.","pos":""},{"def":"A gross, fat, unwieldy person.","pos":""}],"FUSTINESS":[{"def":"A fusty state or quality; moldiness; mustiness; an ill smell from moldiness.","pos":""}],"FUSTY":[{"def":"Moldy; musty; ill-smelling; rank.","pos":""}],"FUSURE":[{"def":"Act of fusing; fusion.","pos":""}]}