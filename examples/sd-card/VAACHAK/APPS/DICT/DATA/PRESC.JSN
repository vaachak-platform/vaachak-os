{"PRESCAPULA":[{"def":"The part of the scapula in front of, or above, the spine, or mesoscapula.","pos":""}],"PRESCIENCE":[{"def":"Knowledge of events before they take place; foresight.","pos":""}],"PRESCIENT":[{"def":"Having knowledge of coming events; foreseeing; conscious beforehand.","pos":""}],"PRESCIENTLY":[{"def":"With presciense or foresight.","pos":""}],"PRESCIND":[{"def":"To consider by a separate act of attention or analysis.","pos":""}],"PRESCINDENT":[{"def":"Cutting off; abstracting.","pos":""}],"PRESCIOUS":[{"def":"Foreknowing; having foreknowledge; as, prescious of ills.","pos":""}],"PRESCRIBE":[{"def":"To direct, as a remedy to be used by a patient; as, the doctor prescribed quinine.","pos":""}],"PRESCRIBER":[{"def":"One who prescribes.","pos":""}],"PRESCRIPT":[{"def":"Directed; prescribed.","pos":""}],"PRESCRIPTIBILITY":[{"def":", The quality or state of being prescriptible.","pos":""}],"PRESCRIPTIBLE":[{"def":"Depending on, or derived from, prescription; proper to be prescribed.","pos":""}],"PRESCRIPTION":[{"def":"A direction of a remedy or of remedies for a disease, and the manner of using them; a medical recipe; also, a prescribed remedy.","pos":""},{"def":"A prescribing for title; the claim of title to a thing by virtue immemorial use and enjoyment; the right or title acquired by possession had during the time and in the manner fixed by law.","pos":""}],"PRESCRIPTIVE":[{"def":"Consisting in, or acquired by, immemorial or long-continued use and enjoyment; as, a prescriptive right of title; pleading the continuance and authority of long custom.","pos":""}],"PRESCRIPTIVELY":[{"def":"By prescription.","pos":""}],"PRESCUTUM":[{"def":"The first of the four pieces composing the dorsal part, or tergum, of a thoracic segment of an insect.","pos":""}]}