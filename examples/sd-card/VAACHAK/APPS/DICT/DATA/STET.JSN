{"STET":[{"def":"Let it stand; -- a word used by proof readers to signify that something once erased, or marked for omission, is to remain.","pos":""}],"STETHAL":[{"def":"One of the higher alcohols of the methane series, homologous with ethal, and found in small quantities as an ethereal salt of stearic acid in spermaceti.","pos":""}],"STETHOGRAPH":[{"def":"See Pneumatograph.","pos":""}],"STETHOMETER":[{"def":"An apparatus for measuring the external movements of a given point of the chest wall, during respiration; -- also called thoracometer.","pos":""}],"STETHOSCOPE":[{"def":"An instrument used in auscultation for examining the organs of the chest, as the heart and lungs, by conveying to the ear of the examiner the sounds produced in the thorax.","pos":""}],"STETHOSCOPIST":[{"def":"One skilled in the use of the stethoscope.","pos":""}],"STETHOSCOPY":[{"def":"The art or process of examination by the stethoscope.","pos":""}]}