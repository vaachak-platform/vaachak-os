{"SYPHERING":[{"def":"The lapping of chamfered edges of planks to make a smooth surface, as for a bulkhead.","pos":""}],"SYPHILIDE":[{"def":"A cutaneous eruption due to syphilis.","pos":""}],"SYPHILIS":[{"def":"The pox, or venereal disease; a chronic, specific, infectious disease, usually communicated by sexual intercourse or by hereditary transmission, and occurring in three stages known as primary, secondary, and tertiary syphilis.","pos":""}],"SYPHILITIC":[{"def":"Of or pertaining to syphilis; of the nature of syphilis; affected with syphilis.","pos":""},{"def":"A syphilitic patient.","pos":""}],"SYPHILITICALLY":[{"def":"In a syphilitic manner; with venereal disease.","pos":""}],"SYPHILIZATION":[{"def":"Inoculation with the syphilitic virus, especially when employed as a preventive measure, like vaccination.","pos":""}],"SYPHILIZE":[{"def":"To inoculate with syphilis.","pos":""}],"SYPHILODERM":[{"def":"A cutaneous affection due to syphilis.","pos":""}],"SYPHILODERMATOUS":[{"def":"Of or pertaining to the cutaneous manifestations of syphilis.","pos":""}],"SYPHILOID":[{"def":"Resembling syphilis.","pos":""}],"SYPHILOLOGIST":[{"def":"One skilled in syphilology.","pos":""}],"SYPHILOLOGY":[{"def":"That branch of medicine which treats of syphilis.","pos":""}]}