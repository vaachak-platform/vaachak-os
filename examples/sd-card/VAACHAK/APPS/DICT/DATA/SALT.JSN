{"SALT":[{"def":"The neutral compound formed by the union of an acid base; thus, sulphuric acid and iron form the salt sulphate of iron or green vitriol.","pos":""},{"def":"Any mineral salt used as an aperient or cathartic, especially Epsom salts, Rochelle salt, or Glauber's salt.","pos":""}],"SALT RHEUM":[{"def":"A popular name, esp.","pos":""}],"SALT-GREEN":[{"def":"Sea-green in color.","pos":""}],"SALTANT":[{"def":"In a leaping position; springing forward; -- applied especially to the squirrel, weasel, and rat, also to the cat, greyhound, monkey, etc.","pos":""}],"SALTARELLO":[{"def":"A popular Italian dance in quick 3-4 or 6-8 time, running mostly in triplets, but with a hop step at the beginning of each measure.","pos":""}],"SALTATE":[{"def":"To leap or dance.","pos":""}],"SALTATION":[{"def":"An abrupt and marked variation in the condition or appearance of a species; a sudden modification which may give rise to new races.","pos":""}],"SALTATORIA":[{"def":"A division of Orthoptera including grasshoppers, locusts, and crickets.","pos":""}],"SALTATORIAL":[{"def":"Relating to leaping; saltatory; as, saltatorial exercises.","pos":""}],"SALTATORIOUS":[{"def":"Capable of leaping; formed for leaping; saltatory; as, a saltatorious insect or leg.","pos":""}],"SALTATORY":[{"def":"Leaping or dancing; having the power of, or used in, leaping or dancing.","pos":""}],"SALTBUSH":[{"def":"An Australian plant (Atriplex nummularia) of the Goosefoot family.","pos":""}],"SALTCAT":[{"def":"A mixture of salt, coarse meal lime, etc.","pos":""}],"SALTCELLAR":[{"def":"Formerly a large vessel, now a small vessel of glass or other material, used for holding salt on the table.","pos":""}],"SALTER":[{"def":"One who makes, sells, or applies salt; one who salts meat or fish.","pos":""}],"SALTERN":[{"def":"A building or place where salt is made by boiling or by evaporation; salt works.","pos":""}],"SALTFOOT":[{"def":"A large saltcellar formerly placed near the center of the table.","pos":""}],"SALTIE":[{"def":"The European dab.","pos":""}],"SALTIGRADAE":[{"def":"A tribe of spiders including those which lie in wait and leap upon their prey; the leaping spiders.","pos":""}],"SALTIGRADE":[{"def":"Having feet or legs formed for leaping.","pos":""}],"SALTIMBANCO":[{"def":"A mountebank; a quack.","pos":""}],"SALTING":[{"def":"The act of sprinkling, impregnating, or furnishing, with salt.","pos":""}],"SALTIREWISE":[{"def":"In the manner of a saltire; -- said especially of the blazoning of a shield divided by two lines drawn in the direction of a bend and a bend sinister, and crossing at the center.","pos":""}],"SALTLESS":[{"def":"Destitute of salt; insipid.","pos":""}],"SALTLY":[{"def":"With taste of salt; in a salt manner.","pos":""}],"SALTMOUTH":[{"def":"A wide-mouthed bottle with glass stopper for holding chemicals, especially crystallized salts.","pos":""}],"SALTNESS":[{"def":"The quality or state of being salt, or state of being salt, or impregnated with salt; salt taste; as, the saltness of sea water.","pos":""},{"def":"Potassium nitrate; niter, a white crystalline substance, KNO3, having a cooling saline taste, obtained by leaching from certain soils in which it is produced by the process of nitrification (see Nitrification, 2).","pos":""}],"SALTPETROUS":[{"def":"Pertaining to saltpeter, or partaking of its qualities; impregnated with saltpeter.","pos":""}],"SALTWORT":[{"def":"A name given to several plants which grow on the seashore, as the Batis maritima, and the glasswort.","pos":""}],"SALTY":[{"def":"Somewhat salt; saltish.","pos":""}]}