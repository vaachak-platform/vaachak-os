{"COY":[{"def":"Shrinking from approach or familiarity; reserved; bashful; shy; modest; -- usually applied to women, sometimes with an implication of coquetry.","pos":""}],"COYISH":[{"def":"Somewhat coy or reserved.","pos":""}],"COYLY":[{"def":"In a coy manner; with reserve.","pos":""}],"COYNESS":[{"def":"The quality of being coy; feigned o When the kind nymph would coyness feign, And hides but to be found again.","pos":""}],"COYOTE":[{"def":"A carnivorous animal (Canis latrans), allied to the dog, found in the western part of North America; -- called also prairie wolf.","pos":""}],"COYOTE STATE":[{"def":"South Dakota; -- a nickname.","pos":""}],"COYOTILLO":[{"def":"A low rhamnaceous shrub (Karwinskia humboldtiana) of the southwestern United States and Mexico.","pos":""}],"COYPU":[{"def":"A South American rodent (Myopotamus coypus), allied to the beaver.","pos":""}],"COYSTREL":[{"def":"Same as Coistril.","pos":""}]}