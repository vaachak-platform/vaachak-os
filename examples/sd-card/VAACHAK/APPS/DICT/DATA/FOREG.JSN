{"FOREGAME":[{"def":"A first game; first plan.","pos":""}],"FOREGANGER":[{"def":"A short rope grafted on a harpoon, to which a longer lin Totten.","pos":""}],"FOREGATHER":[{"def":"Same as Forgather.","pos":""}],"FOREGLEAM":[{"def":"An antecedent or premonitory gleam; a dawning light.","pos":""}],"FOREGO":[{"def":"To quit; to relinquish; to leave.","pos":""},{"def":"To relinquish the enjoyment or advantage of; to give up; to resign; to renounce; -- said of a thing already enjoyed, or of one within reach, or anticipated.","pos":""}],"FOREGOER":[{"def":"One who goes before another; a predecessor; hence, an ancestor' a progenitor.","pos":""},{"def":"A purveyor of the king; -- so called, formerly, from going before to provide for his household.","pos":""}],"FOREGROUND":[{"def":"On a painting, and sometimes in a bas-relief, mosaic picture, or the like, that part of the scene represented, which is nearest to the spectator, and therefore occupies the lowest part of the work of art itself.","pos":""}]}