{"INFOLD":[{"def":"To wrap up or cover with folds; to envelop; to inwrap; to inclose; to involve.","pos":""},{"def":"To clasp with the arms; to embrace.","pos":""}],"INFOLDMENT":[{"def":"The act of infolding; the state of being infolded.","pos":""}],"INFOLIATE":[{"def":"To cover or overspread with, or as with, leaves.","pos":""}],"INFORM":[{"def":"Without regular form; shapeless; ugly; deformed.","pos":""}],"INFORMAL":[{"def":"Not in the regular, usual, or established form; not according to official, conventional, prescribed, or customary forms or rules; irregular; hence, without ceremony; as, an informal writting, proceeding, or visit.","pos":""},{"def":"Deranged in mind; out of one's senses.","pos":""}],"INFORMALITY":[{"def":"The state of being informal; want of regular, prescribed, or customary form; as, the informality of legal proceedings.","pos":""},{"def":"An informal, unconventional, or unofficial act or proceeding; something which is not in proper or prescribed form or does not conform to the established rule.","pos":""}],"INFORMALLY":[{"def":"In an informal manner.","pos":""}],"INFORMANT":[{"def":"One who, or that which, informs, animates, or vivifies.","pos":""},{"def":"One who imparts information or instruction.","pos":""}],"INFORMATION":[{"def":"A proceeding in the nature of a prosecution for some offens against the government, instituted and prosecuted, really or nominally, by some authorized public officer on behalt of the government.","pos":""}],"INFORMATIVE":[{"def":"Having power to inform, animate, or vivify.","pos":""}],"INFORMATORY":[{"def":"Full of, or conveying, information; instructive.","pos":""}],"INFORMED":[{"def":"Unformed or ill-formed; deformed; shapeless.","pos":""}],"INFORMER":[{"def":"One who informs a magistrate of violations of law; one who informs against another for violation of some law or penal statute.","pos":""}],"INFORMIDABLE":[{"def":"Not formidable; not to be feared or dreaded.","pos":""}],"INFORMITY":[{"def":"Want of regular form; shapelessness.","pos":""}],"INFORMOUS":[{"def":"Of irregular form; shapeless.","pos":""}],"INFORTUNATE":[{"def":"Unlucky; unfortunate.","pos":""}],"INFORTUNED":[{"def":"I, woeful wretch and infortuned wight.","pos":""}],"INFOUND":[{"def":"To pour in; to infuse.","pos":""}]}