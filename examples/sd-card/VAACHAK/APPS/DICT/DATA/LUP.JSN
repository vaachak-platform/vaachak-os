{"LUPERCAL":[{"def":"Of or pertaining to the Lupercalia.","pos":""}],"LUPERCALIA":[{"def":"A feast of the Romans in honor of Lupercus, or Pan.","pos":""}],"LUPINE":[{"def":"A leguminous plant of the genus Lupinus, especially L.","pos":""}],"LUPININ":[{"def":"A glucoside found in the seeds of several species of lupine, and extracted as a yellowish white crystalline substance.","pos":""}],"LUPININE":[{"def":"An alkaloid found in several species of lupine (Lupinus luteus, L.","pos":""}],"LUPULIN":[{"def":"A bitter principle extracted from hops.","pos":""}],"LUPULINE":[{"def":"An alkaloid extracted from hops as a colorless volatile liquid.","pos":""}],"LUPULINIC":[{"def":"Pertaining to, or obtained from, hops; specifically, designating an acid obtained by the decomposition of lupulin.","pos":""}],"LUPUS":[{"def":"A cutaneous disease occurring under two distinct forms.","pos":""},{"def":"The Wolf, a constellation situated south of Scorpio.","pos":""}]}