{"ADYNAMIA":[{"def":"Considerable debility of the vital powers, as in typhoid fever.","pos":""}],"ADYNAMIC":[{"def":"Pertaining to, or characterized by, debility of the vital powers; weak.","pos":""},{"def":"Characterized by the absence of power or force.","pos":""}],"ADYTUM":[{"def":"The innermost sanctuary or shrine in ancient temples, whence oracles were given.","pos":""}]}