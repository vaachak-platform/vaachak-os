{"RICE":[{"def":"A well-known cereal grass (Oryza sativa) and its seed.","pos":""}],"RICE-SHELL":[{"def":"Any one of numerous species of small white polished marine shells of the genus Olivella.","pos":""}],"RICH":[{"def":"Having an abundance of material possessions; possessed of a large amount of property; well supplied with land, goods, or money; wealthy; opulent; affluent; -- opposed to Ant: poor.","pos":""},{"def":"Hence, in general, well supplied; abounding; abundant; copious; bountiful; as, a rich treasury; a rich entertainment; a rich crop.","pos":""}],"RICHES":[{"def":"That which makes one rich; an abundance of land, goods, money, or other property; wealth; opulence; affluence.","pos":""},{"def":"That which appears rich, sumptuous, precious, or the like.","pos":""}],"RICHESSE":[{"def":"Some man desireth for to have richesse.","pos":""}],"RICHLY":[{"def":"In a rich manner.","pos":""}],"RICHNESS":[{"def":"The quality or state of being rich (in any sense of the adjective).","pos":""}],"RICHWEED":[{"def":"An herb (Pilea pumila) of the Nettle family, having a smooth, juicy, pellucid stem; -- called also clearweed.","pos":""}],"RICINELAIDIC":[{"def":"Pertaining to, or designating, an isomeric modification of ricinoleic acid obtained as a white crystalline solid.","pos":""}],"RICINELAIDIN":[{"def":"The glycerin salt of ricinelaidic acid, obtained as a white crystalline waxy substance by treating castor oil with nitrous acid.","pos":""}],"RICINIC":[{"def":"Pertaining to, or derived from, castor oil; formerly, designating an acid now called ricinoleic acid.","pos":""}],"RICININE":[{"def":"A bitter white crystalline alkaloid extracted from the seeds of the castor-oil plant.","pos":""}],"RICINOLEATE":[{"def":"A salt of ricinoleic acid; -- formerly called palmate.","pos":""}],"RICINOLEIC":[{"def":"Pertaining to, or designating, a fatty acid analogous to oleic acid, obtained from castor oil as an oily substance, Cricinolic.","pos":""}],"RICINOLEIN":[{"def":"The glycerin salt of ricinoleic acid, occuring as a characteristic constituent of castor oil; -- formerly called palmin.","pos":""}],"RICINUS":[{"def":"A genus of plants of the Spurge family, containing but one species (R.","pos":""}],"RICK":[{"def":"A stack or pile, as of grain, straw, or hay, in the open air, usually protected from wet with thatching.","pos":""}],"RICKER":[{"def":"A stout pole for use in making a rick, or for a spar to a boat.","pos":""}],"RICKETS":[{"def":"A disease which affects children, and which is characterized by a bulky head, crooked spine and limbs, depressed ribs, enlarged and spongy articular epiphyses, tumid abdomen, and short stature, together with clear and often premature mental faculties.","pos":""}],"RICKETY":[{"def":"Affected with rickets.","pos":""},{"def":"Feeble in the joints; imperfect; weak; shaky.","pos":""}],"RICKRACK":[{"def":"A kind of openwork edging made of serpentine braid.","pos":""}],"RICKSTAND":[{"def":"A flooring or framework on which a rick is made.","pos":""}],"RICOCHET":[{"def":"A rebound or skipping, as of a ball along the ground when a gun is fired at a low angle of elevation, or of a fiat stone thrown along the surface of water.","pos":""}],"RICTAL":[{"def":"Of or pertaining to the rictus; as, rictal bristles.","pos":""}],"RICTUS":[{"def":"The gape of the mouth, as of birds; -- often resricted to the corners of the mouth.","pos":""}]}