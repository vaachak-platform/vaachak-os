{"UNSWADDLE":[{"def":"To take a swaddle from; to unswathe.","pos":""}],"UNSWATHE":[{"def":"To take a swathe from; to relieve from a bandage; to unswaddle.","pos":""}],"UNSWAYABLE":[{"def":"Not capable of being swayed.","pos":""}],"UNSWEAR":[{"def":"To recant or recall, as an oath; to recall after having sworn; to abjure.","pos":""}],"UNSWEAT":[{"def":"To relieve from perspiration; to ease or cool after exercise or toil.","pos":""}],"UNSWELL":[{"def":"To sink from a swollen state; to subside.","pos":""}]}