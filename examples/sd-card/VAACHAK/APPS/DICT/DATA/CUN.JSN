{"CUN":[{"def":"To con (a ship).","pos":""}],"CUNABULA":[{"def":"The extant copies of the first or earliest printed books, or of such as were printed in the 15th century.","pos":""}],"CUNCTATION":[{"def":"Delay; procrastination.","pos":""}],"CUNCTATIVE":[{"def":"Slow; tardy; dilatory; causing delay.","pos":""}],"CUNCTATOR":[{"def":"One who delays or lingers.","pos":""}],"CUNCTIPOTENT":[{"def":"All-powerful; omnipotent.","pos":""}],"CUND":[{"def":"To con (a ship).","pos":""}],"CUNDURANGO":[{"def":"The bark of a South American vine (Gonolobus Condurango) of the Milkweed family.","pos":""}],"CUNEAL":[{"def":"Relating to a wedge; wedge-shaped.","pos":""},{"def":"Wedge-shaped; (Bot.","pos":""}],"CUNEATIC":[{"def":"Wedge-shaped; as, a cuneiform bone; -- especially applied to the wedge-shaped or arrowheaded characters of ancient Persian and Assyrian inscriptions.","pos":""},{"def":"Pertaining to, or versed in, the ancient wedge-shaped characters, or the inscriptions in them.","pos":""}],"CUNETTE":[{"def":"A drain trench, in a ditch or moat; -- called also cuvette.","pos":""}],"CUNNING":[{"def":"Knowing; skillfull; dexterous.","pos":""},{"def":"Wrought with, or exibiting, skill or ingenuity; ingenious; curious; as, cunning work.","pos":""}],"CUNNINGLY":[{"def":"In a cunning manner; with cunning.","pos":""}],"CUNNINGMAN":[{"def":"A fortune teller; one who pretends to reveal mysteries.","pos":""}],"CUNNINGNESS":[{"def":"Quality of being cunning; craft.","pos":""}]}