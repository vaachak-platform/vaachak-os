{"INCELEBRITY":[{"def":"Want of celebrity or distinction; obscurity.","pos":""}],"INCEND":[{"def":"To inflame; to excite.","pos":""}],"INCENDIARISM":[{"def":"The act or practice of maliciously setting fires; arson.","pos":""}],"INCENDIARY":[{"def":"Any person who maliciously sets fire to a building or other valuable or other valuable property.","pos":""},{"def":"A person who excites or inflames factions, and promotes quarrels or sedition; an agitator; an exciter.","pos":""}],"INCENDIOUS":[{"def":"Promoting faction or contention; seditious; inflammatory.","pos":""}],"INCENSANT":[{"def":"A modern term applied to animals (as a boar) when borne as raging, or with furious aspect.","pos":""}],"INCENSATION":[{"def":"The offering of incense.","pos":""}],"INCENSE":[{"def":"To set on fire; to inflame; to kindle; to burn.","pos":""},{"def":"To inflame with anger; to endkindle; to fire; to incite; to provoke; to heat; to madden.","pos":""}],"INCENSED":[{"def":"Represented as enraged, as any wild creature depicted with fire issuing from mouth and eyes.","pos":""}],"INCENSEMENT":[{"def":"Fury; rage; heat; exasperation; as, implacable incensement.","pos":""}],"INCENSER":[{"def":"One who instigates or incites.","pos":""}],"INCENSION":[{"def":"The act of kindling, or the state of being kindled or on fire.","pos":""}],"INCENSIVE":[{"def":"Tending to excite or provoke; inflammatory.","pos":""}],"INCENSOR":[{"def":"A kindler of anger or enmity; an inciter.","pos":""}],"INCENSORY":[{"def":"The vessel in which incense is burned and offered; a censer; a thurible.","pos":""}],"INCENTER":[{"def":"The center of the circle inscribed in a triangle.","pos":""}],"INCENTIVE":[{"def":"Inciting; encouraging or moving; rousing to action; stimulative.","pos":""},{"def":"Serving to kindle or set on fire.","pos":""}],"INCENTIVELY":[{"def":"Incitingly; encouragingly.","pos":""}],"INCEPTION":[{"def":"Beginning; commencement; initiation.","pos":""},{"def":"Reception; a taking in.","pos":""}],"INCEPTIVE":[{"def":"Beginning; expressing or indicating beginning; as, an inceptive proposition; an inceptive verb, which expresses the beginning of action; -- called also inchoative.","pos":""}],"INCEPTOR":[{"def":"A beginner; one in the rudiments.","pos":""},{"def":"One who is on the point of taking the degree of master of arts at an English university.","pos":""}],"INCERATION":[{"def":"The act of smearing or covering with wax.","pos":""}],"INCERATIVE":[{"def":"Cleaving or sticking like wax.","pos":""}],"INCERTAIN":[{"def":"Uncertain; doubtful; unsteady.","pos":""}],"INCERTITUDE":[{"def":"Uncertainty; doubtfulness; doubt.","pos":""}],"INCERTUM":[{"def":"Doubtful; not of definite form.","pos":""}],"INCESSABLE":[{"def":"Unceasing; continual.","pos":""}],"INCESSANCY":[{"def":"The quality of being incessant; unintermitted continuance; unceasingness.","pos":""}],"INCESSANT":[{"def":"Continuing or following without interruption; unceasing; unitermitted; uninterrupted; continual; as, incessant clamors; incessant pain, etc.","pos":""}],"INCESSANTLY":[{"def":"Unceasingly; continually.","pos":""}],"INCESSION":[{"def":"Motion on foot; progress in walking.","pos":""}],"INCEST":[{"def":"The crime of cohabitation or sexual commerce between persons related within the degrees wherein marriage is prohibited by law.","pos":""}],"INCESTTUOUS":[{"def":"Guilty of incest; involving, or pertaining to, the crime of incest; as, an incestuous person or connection.","pos":""}]}