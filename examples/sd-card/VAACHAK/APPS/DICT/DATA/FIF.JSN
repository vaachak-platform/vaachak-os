{"FIFE":[{"def":"A small shrill pipe, resembling the piccolo flute, used chiefly to accompany the drum in military music.","pos":""}],"FIFER":[{"def":"One who plays on a fife.","pos":""}],"FIFTEEN":[{"def":"Five and ten; one more than fourteen.","pos":""}],"FIFTEENTH":[{"def":"Next in order after the fourteenth; -- the ordinal of fifteen.","pos":""},{"def":"Consisting of one of fifteen equal parts or divisions of a thing.","pos":""}],"FIFTH":[{"def":"Next in order after the fourth; -- the ordinal of five.","pos":""},{"def":"Consisting of one of five equal divisions of a thing.","pos":""}],"FIFTHLY":[{"def":"In the fifth place; as the fifth in order.","pos":""}],"FIFTIETH":[{"def":"Next in order after the forty-ninth; -- the ordinal of fifty.","pos":""},{"def":"Consisting of one of fifty equal parts or divisions.","pos":""}],"FIFTY":[{"def":"Five times ten; as, fifty men.","pos":""}]}