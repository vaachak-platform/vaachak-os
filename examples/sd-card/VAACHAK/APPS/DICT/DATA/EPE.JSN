{"EPEIRA":[{"def":"A genus of spiders, including the common garden spider (E.","pos":""}],"EPEN":[{"def":"See Epencephalon.","pos":""}],"EPENCEPHALON":[{"def":"The segment of the brain next behind the midbrain, including the cerebellum and pons; the hindbrain.","pos":""}],"EPENDYMA":[{"def":"The epithelial lining of the ventricles of the brain and the canal of the spinal cord; endyma; ependymis.","pos":""}],"EPENETIC":[{"def":"Bestowing praise; eulogistic; laudatory.","pos":""}],"EPENTHESIS":[{"def":"The insertion of a letter or a sound in the body of a word; as, the b in \"nimble\" from AS.","pos":""}],"EPENTHETIC":[{"def":"Inserted in the body of a word; as, an epenthetic letter or sound.","pos":""}],"EPERGNE":[{"def":"A centerpiece for table decoration, usually consisting of several dishes or receptacles of different sizes grouped together in an ornamental design.","pos":""}],"EPERLAN":[{"def":"The European smelt (Osmerus eperlanus).","pos":""}],"EPEXEGESIS":[{"def":"A full or additional explanation; exegesis.","pos":""}],"EPEXEGETICAL":[{"def":"Relating to epexegesis; explanatory; exegetical.","pos":""},{"def":"A Hebrew dry measure, supposed to be equal to two pecks and five quarts.","pos":""}]}