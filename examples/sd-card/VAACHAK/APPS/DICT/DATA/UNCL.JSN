{"UNCLASP":[{"def":"To loose the clasp of; to open, as something that is fastened, or as with, a clasp; as, to unclasp a book; to unclasp one's heart.","pos":""}],"UNCLE":[{"def":"The brother of one's father or mother; also applied to an aunt's husband; -- the correlative of aunt in sex, and of nephew and niece in relationship.","pos":""}],"UNCLEAN":[{"def":"Not clean; foul; dirty; filthy.","pos":""},{"def":"Ceremonially impure; needing ritual cleansing.","pos":""}],"UNCLEANSABLE":[{"def":"Incapable of being cleansed or cleaned.","pos":""}],"UNCLENCH":[{"def":"Same as Unclinch.","pos":""}],"UNCLESHIP":[{"def":"The office or position of an uncle.","pos":""}],"UNCLEW":[{"def":"To unwind, unfold, or untie; hence, to undo; to ruin.","pos":""}],"UNCLINCH":[{"def":"To cause to be no longer clinched; to open; as, to unclinch the fist.","pos":""}],"UNCLING":[{"def":"To cease from clinging or adhering.","pos":""}],"UNCLOAK":[{"def":"To remove a cloak or cover from; to deprive of a cloak or cover; to unmask; to reveal.","pos":""}],"UNCLOG":[{"def":"To disencumber of a clog, or of difficulties and obstructions; to free from encumbrances; to set at liberty.","pos":""}],"UNCLOISTER":[{"def":"To release from a cloister, or from confinement or seclusion; to set free; to liberate.","pos":""}],"UNCLOSE":[{"def":"To open; to separate the parts of; as, to unclose a letter; to unclose one's eyes.","pos":""},{"def":"To disclose; to lay open; to reveal.","pos":""}],"UNCLOSED":[{"def":"Not separated by inclosures; open.","pos":""},{"def":"Not finished; not concluded.","pos":""}],"UNCLOTHE":[{"def":"To strip of clothes or covering; to make naked.","pos":""}],"UNCLOTHED":[{"def":"Divested or stripped of clothing.","pos":""},{"def":"Not yet clothed; wanting clothes; naked.","pos":""}],"UNCLOUD":[{"def":"To free from clouds; to unvail; to clear from obscurity, gloom, sorrow, or the like.","pos":""}],"UNCLUE":[{"def":"To unwind; to untangle.","pos":""}],"UNCLUTCH":[{"def":"To disengage, as a clutch.","pos":""}]}