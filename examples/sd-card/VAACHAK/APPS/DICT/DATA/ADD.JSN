{"ADD":[{"def":"To give by way of increased possession (to any one); to bestow (on).","pos":""},{"def":"To join or unite, as one thing to another, or as several particulars, so as to increase the number, augment the quantity, enlarge the magnitude, or so as to form into one aggregate.","pos":""}],"ADDAX":[{"def":"One of the largest African antelopes (Hippotragus, or Oryx, nasomaculatus).","pos":""}],"ADDEEM":[{"def":"To award; to adjudge.","pos":""}],"ADDENDUM":[{"def":"A thing to be added; an appendix or addition.","pos":""}],"ADDER":[{"def":"One who, or that which, adds; esp.","pos":""}],"ADDERWORT":[{"def":"The common bistort or snakeweed (Polygonum bistorta).","pos":""}],"ADDIBILITY":[{"def":"The quantity of being addible; capability of addition.","pos":""}],"ADDIBLE":[{"def":"Capable of being added.","pos":""}],"ADDICT":[{"def":"Addicted; devoted.","pos":""}],"ADDICTEDNESS":[{"def":"The quality or state of being addicted; attachment.","pos":""}],"ADDICTION":[{"def":"The state of being addicted; devotion; inclination.","pos":""}],"ADDISON'S DISEASE":[{"def":"A morbid condition causing a peculiar brownish discoloration of the skin, and thought, at one time, to be due to disease of the suprarenal capsules (two flat triangular bodies covering the upper part of the kidneys), but now known not to be dependent upon this causes exclusively.","pos":""}],"ADDITAMENT":[{"def":"An addition, or a thing added.","pos":""}],"ADDITION":[{"def":"That part of arithmetic which treats of adding numbers.","pos":""},{"def":"A dot at the right side of a note as an indication that its sound is to be lengthened one half.","pos":""}],"ADDITIONAL":[{"def":"Added; supplemental; in the way of an addition.","pos":""}],"ADDITIONALLY":[{"def":"By way of addition.","pos":""}],"ADDITIVE":[{"def":"Proper to be added; positive; -- opposed to subtractive.","pos":""}],"ADDITORY":[{"def":"Tending to add; making some addition.","pos":""}],"ADDLE":[{"def":"Liquid filth; mire.","pos":""}],"ADDLE-PATEDNESS":[{"def":"Ad\"dle-pa`ted*ness, n.","pos":""}],"ADDORSED":[{"def":"Set or turned back to back.","pos":""}],"ADDRESS":[{"def":"To consign or intrust to the care of another, as agent or factor; as, the ship was addressed to a merchant in Baltimore.","pos":""}],"ADDRESSEE":[{"def":"One to whom anything is addressed.","pos":""}],"ADDRESSION":[{"def":"The act of addressing or directing one's course.","pos":""}],"ADDUCE":[{"def":"To bring forward or offer, as an argument, passage, or consideration which bears on a statement or case; to cite; to allege.","pos":""}],"ADDUCENT":[{"def":"Bringing together or towards a given point; -- a word applied to those muscles of the body which pull one part towards another.","pos":""}],"ADDUCER":[{"def":"One who adduces.","pos":""}],"ADDUCIBLE":[{"def":"Capable of being adduced.","pos":""}],"ADDUCT":[{"def":"To draw towards a common center or a middle line.","pos":""}],"ADDUCTION":[{"def":"The action by which the parts of the body are drawn towards its axis]; -- opposed to abduction.","pos":""}],"ADDUCTIVE":[{"def":"Adducing, or bringing towards or to something.","pos":""}],"ADDUCTOR":[{"def":"A muscle which draws a limb or part of the body toward the middle line of the body, or closes extended parts of the body; -- opposed to abductor; as, the adductor of the eye, which turns the eye toward the nose.","pos":""}],"ADDULCE":[{"def":"To sweeten; to soothe.","pos":""}]}