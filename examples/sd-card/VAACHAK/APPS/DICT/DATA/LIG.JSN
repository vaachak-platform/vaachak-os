{"LIG":[{"def":"To recline; to lie still.","pos":""}],"LIGAMENT":[{"def":"Composing a ligament; of the nature of a ligament; binding; as, a strong ligamentous membrane.","pos":""}],"LIGAN":[{"def":"Goods sunk in the sea, with a buoy attached in order that they may be found again.","pos":"noun"}],"LIGATE":[{"def":"To tie with a ligature; to bind around; to bandage.","pos":""}],"LIGATION":[{"def":"The act of binding, or the state of being bound.","pos":""},{"def":"That which binds; bond; connection.","pos":""}],"LIGATOR":[{"def":"An instrument for ligating, or for placing and fastening a ligature.","pos":""}],"LIGATURE":[{"def":"A curve or line connecting notes; a slur.","pos":""},{"def":"A double character, or a type consisting of two or more letters or characters united, as æ, fi, ffl.","pos":""}],"LIGE":[{"def":"To lie; to tell lies.","pos":""}],"LIGEANCE":[{"def":"The connection between sovereign and subject by which they were mutually bound, the former to protection and the securing of justice, the latter to faithful service; allegiance.","pos":""}],"LIGGE":[{"def":"To lie or recline.","pos":""}],"LIGGER":[{"def":"A baited line attached to a float, for night fishing.","pos":""}],"LIGHT":[{"def":"The manner in which the light strikes upon a picture; that part of a picture which represents those objects upon which the light is supposed to fall; the more illuminated part of a landscape or other scene; -- opposed to shade.","pos":""},{"def":"A firework made by filling a case with a substance which burns brilliantly with a white or colored flame; as, a Bengal light.","pos":""}],"LIGHT SIGNALS":[{"def":"A system of signaling in which balls of red and green fire are fired from a pistol, the arrangement in groups denoting numbers having a code significance.","pos":""}],"LIGHT YEAR":[{"def":"The distance over which light can travel in a year's time; -- used as a unit in expressing stellar distances.","pos":""}],"LIGHT-ARMED":[{"def":"Armed with light weapons or accouterments.","pos":""}],"LIGHT-FINGERED":[{"def":"Dexterous in taking and conveying away; thievish; pilfering; addicted to petty thefts.","pos":""},{"def":"Having a light, springy step; nimble in running or dancing; active; as, light-foot Iris.","pos":""}],"LIGHT-HANDED":[{"def":"Not having a full complement of men; as, a vessel light-handed.","pos":""}],"LIGHT-HEADED":[{"def":"Disordered in the head; dilirious.","pos":""},{"def":"Thoughtless; heedless; volatile; unsteady; fickle; loose.","pos":""}],"LIGHT-HEARTED":[{"def":"Free from grief or anxiety; gay; cheerful; merry.","pos":""}],"LIGHT-HEELED":[{"def":"Lively in walking or running; brisk; light-footed.","pos":""}],"LIGHT-HORSEMAN":[{"def":"A West Indian fish of the genus Ephippus, remarkable for its high dorsal fin and brilliant colors.","pos":""}],"LIGHT-LEGGED":[{"def":"Nimble; swift of foot.","pos":""}],"LIGHT-MINDED":[{"def":"Unsettled; unsteady; volatile; not considerate.","pos":""}],"LIGHT-O'-LOVE":[{"def":"An old tune of a dance, the name of which made it a proverbial expression of levity, especially in love matters.","pos":""},{"def":"Hence: A light or wanton woman.","pos":""}],"LIGHT-SHIP":[{"def":"A vessel carrying at the masthead a brilliant light, and moored off a shoal or place of dangerous navigation as a guide for mariners.","pos":""}],"LIGHT-WINGED":[{"def":"Having light and active wings; volatile; fleeting.","pos":""}],"LIGHTABLE":[{"def":"Such as can be lighted.","pos":""}],"LIGHTE":[{"def":"of Light, to alight.","pos":""}],"LIGHTEN":[{"def":"To descend; to light.","pos":""}],"LIGHTER":[{"def":"One who, or that which, lights; as, a lighter of lamps.","pos":""}],"LIGHTERAGE":[{"def":"The price paid for conveyance of goods on a lighter.","pos":""},{"def":"The act of unloading into a lighter, or of conveying by a lighter.","pos":""}],"LIGHTERMAN":[{"def":"A person employed on, or who manages, a lighter.","pos":""}],"LIGHTFUL":[{"def":"Full of light; bright.","pos":""}],"LIGHTHOUSE":[{"def":"A tower or other building with a powerful light at top, erected at the entrance of a port, or at some important point on a coast, to serve as a guide to mariners at night; a pharos.","pos":""}],"LIGHTING":[{"def":"A name sometimes applied to the process of annealing metals.","pos":""}],"LIGHTLESS":[{"def":"Destitute of light; dark.","pos":""}],"LIGHTLY":[{"def":"With little weight; with little force; as, to tread lightly; to press lightly.","pos":""},{"def":"Swiftly; nimbly; with agility.","pos":""}],"LIGHTMAN":[{"def":"A man who carries or takes care of a light.","pos":""}],"LIGHTNESS":[{"def":"The state, condition, or quality, of being light or not heavy; buoyancy; levity; fickleness; delicacy; grace.","pos":""}],"LIGHTNING":[{"def":"A discharge of atmospheric electricity, accompanied by a vivid flash of light, commonly from one cloud to another, sometimes from a cloud to the earth.","pos":""},{"def":"The act of making bright, or the state of being made bright; enlightenment; brightening, as of the mental powers.","pos":""}],"LIGHTROOM":[{"def":"A small room from which the magazine of a naval vessel is lighted, being separated from the magazine by heavy glass windows.","pos":""}],"LIGHTS":[{"def":"The lungs of an animal or bird; -- sometimes coarsely applied to the lungs of a human being.","pos":""}],"LIGHTSOME":[{"def":"Having light; lighted; not dark or gloomy; bright.","pos":""},{"def":"Gay; airy; cheering; exhilarating.","pos":""}],"LIGHTSTRUCK":[{"def":"Damaged by accidental exposure to light; light-fogged; -- said of plates or films.","pos":""}],"LIGHTWEIGHT":[{"def":"Light in weight, as a coin; specif.","pos":""}],"LIGHTWOOD":[{"def":"Pine wood abounding in pitch, used for torches in the Southern United States; pine knots, dry sticks, and the like, for kindling a fire quickly or making a blaze.","pos":""}],"LIGN-ALOES":[{"def":"Aloes wood, or agallochum.","pos":""},{"def":"A fragrant tree mentioned in the Bible.","pos":""}],"LIGNEOUS":[{"def":"Made of wood; consisting of wood; of the nature of, or resembling, wood; woody.","pos":""}],"LIGNIFEROUS":[{"def":"Yielding or producing wood.","pos":""}],"LIGNIFICATION":[{"def":"A change in the character of a cell wall, by which it becomes harder.","pos":""}],"LIGNIFY":[{"def":"To convert into wood or into a ligneous substance.","pos":""}],"LIGNIN":[{"def":"A substance characterizing wood cells and differing from cellulose in its conduct with certain chemical reagents.","pos":""}],"LIGNIPERDOUS":[{"def":"Wood-destroying; -- said of certain insects.","pos":""}],"LIGNITE":[{"def":"Mineral coal retaining the texture of the wood from which it was formed, and burning with an empyreumatic odor.","pos":""}],"LIGNITIC":[{"def":"Containing lignite; resembling, or of the nature of, lignite; as, lignitic clay.","pos":""}],"LIGNITIFEROUS":[{"def":"Producing or containing lignite; lignitic.","pos":""}],"LIGNOCERIC":[{"def":"Pertaining to, or designating, an acid of the formic acid series, found in the tar, wax, or paraffine obtained by distilling certain kinds of wood, as the beech.","pos":""}],"LIGNONE":[{"def":"LIGNOSE; LIGNOUS Lig*nose`, Lig\"nous, a.","pos":""}],"LIGNOSE":[{"def":"An explosive compound of wood fiber and nitroglycerin.","pos":""}],"LIGNUM RHODIUM":[{"def":"The fragrant wood of several shrubs and trees, especially of species of Rhodorhiza from the Canary Islands, and of the West Indian Amyris balsamifera.","pos":""}],"LIGNUM-VITAE":[{"def":"A tree (Guaiacum officinale) found in the warm latitudes of America, from which the guaiacum of medicine is procured.","pos":""}],"LIGROIN":[{"def":"A trade name applied somewhat indefinitely to some of the volatile products obtained in refining crude petroleum.","pos":""}],"LIGULA":[{"def":"Like a bandage, or strap; strap-shaped.","pos":""}],"LIGULE":[{"def":"A band of white matter in the wall of fourth ventricle of the brain.","pos":""}],"LIGULIFLOROUS":[{"def":"Bearing only ligulate flowers; -- said of a large suborder of composite plants, such as the dandelion, hawkweed, etc.","pos":""}],"LIGURE":[{"def":"A kind of precious stone.","pos":""}],"LIGUSTRIN":[{"def":"A bitter principle found in the bark of the privet (Ligustrum vulgare), and extracted as a white crystalline substance with a warm, bitter taste; -- called also ligustron.","pos":""}]}