{"UNJOINTED":[{"def":"Having no joint or articulation; as, an unjointed stem.","pos":""}],"UNJUST":[{"def":"Acting contrary to the standard of right; not animated or controlled by justice; false; dishonest; as, an unjust man or judge.","pos":""},{"def":"Contrary to justice and right; prompted by a spirit of injustice; wrongful; as, an unjust sentence; an unjust demand; an unjust accusation.","pos":""}],"UNJUSTICE":[{"def":"Want of justice; injustice.","pos":""}]}