{"CHIT":[{"def":"The embryo or the growing bud of a plant; a shoot; a sprout; as, the chits of Indian corn or of potatoes.","pos":""},{"def":"A child or babe; as, a forward chit; also, a young, small, or insignificant person or animal.","pos":""}],"CHITCHAT":[{"def":"Familiar or trifling talk; prattle.","pos":""}],"CHITIN":[{"def":"A white amorphous horny substance forming the harder part of the outer integument of insects, crustacea, and various other invertebrates; entomolin.","pos":""}],"CHITINIZATION":[{"def":"The process of becoming chitinous.","pos":""}],"CHITINOUS":[{"def":"Having the nature of chitin; consisting of, or containing, chitin.","pos":""}],"CHITON":[{"def":"One of a group of gastropod mollusks, with a shell composed of eight movable dorsal plates.","pos":""}],"CHITTER":[{"def":"To chirp in a tremulous manner, as a bird.","pos":""},{"def":"To shiver or chatter with cold.","pos":""}],"CHITTERLING":[{"def":"The frill to the breast of a shirt, which when ironed out resembled the small entrails.","pos":""}],"CHITTERLINGS":[{"def":"The smaller intestines of swine, etc.","pos":""}],"CHITTRA":[{"def":"The axis deer of India.","pos":""}],"CHITTY":[{"def":"Full of chits or sprouts.","pos":""},{"def":"Childish; like a babe.","pos":""}]}