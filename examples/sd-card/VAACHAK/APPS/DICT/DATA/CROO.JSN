{"CROODLE":[{"def":"To cower or cuddle together, as from fear or cold; to lie close and snug together, as pigs in straw.","pos":""},{"def":"To fawn or coax.","pos":""}],"CROOK":[{"def":"A small tube, usually curved, applied to a trumpet, horn, etc.","pos":""}],"CROOKBACK":[{"def":"A crooked back; one who has a crooked or deformed back; a hunchback.","pos":""}],"CROOKBILL":[{"def":"A New Zealand plover (Anarhynchus frontalis), remarkable for having the end of the beak abruptly bent to the right.","pos":""}],"CROOKED":[{"def":"Characterized by a crook or curve; not straight; turning; bent; twisted; deformed.","pos":""},{"def":"Not straightforward; deviating from rectitude; distorted from the right.","pos":""}],"CROOKEDLY":[{"def":"In a curved or crooked manner; in a perverse or untoward manner.","pos":""}],"CROOKEDNESS":[{"def":"The condition or quality of being crooked; hence, deformity of body or of mind; deviation from moral rectitude; perverseness.","pos":""}],"CROOKEN":[{"def":"To make crooked.","pos":""}],"CROOKES SPACE":[{"def":"The dark space within the negative-pole glow at the cathode of a vacuum tube, observed only when the pressure is low enough to give a striated discharge; -- called also Crookes layer.","pos":""}],"CROOKES TUBE":[{"def":"A vacuum tube in which the exhaustion is carried to a very high degree, with the production of a distinct class of effects; -- so called from W.","pos":""}],"CROOKNECK":[{"def":"Either of two varieties of squash, distinguished by their tapering, recurved necks.","pos":""}],"CROON":[{"def":"To make a continuous hollow moan, as cattle do when in pain.","pos":""},{"def":"To hum or sing in a low tone; to murmur softly.","pos":""}]}