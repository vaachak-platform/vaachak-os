{"CONCEAL":[{"def":"To hide or withdraw from observation; to cover; to cover or keep from sight; to prevent the discovery of; to withhold knowledge of.","pos":""}],"CONCEALABLE":[{"def":"Capable of being concealed.","pos":""}],"CONCEALED":[{"def":"Hidden; kept from sight; secreted.","pos":""}],"CONCEALER":[{"def":"One who conceals.","pos":""}],"CONCEALMENT":[{"def":"Suppression of such facts and circumstances as in justice ought to be made known.","pos":""}],"CONCEDE":[{"def":"To yield or suffer; to surrender; to grant; as.","pos":""},{"def":"To grant, as a right or privilege; to make concession of.","pos":""}],"CONCEIT":[{"def":"That which is conceived, imagined, or formed in the mind; idea; thought; image; conception.","pos":""},{"def":"Faculty of conceiving ideas; mental faculty; apprehension; as, a man of quick conceit.","pos":""}],"CONCEITED":[{"def":"Endowed with fancy or imagination.","pos":""},{"def":"Entertaining a flattering opinion of one's self; vain.","pos":""}],"CONCEITEDLY":[{"def":"In an egotistical manner.","pos":""},{"def":"Fancifully; whimsically.","pos":""}],"CONCEITEDNESS":[{"def":"The state of being conceited; conceit; vanity.","pos":""}],"CONCEITLESS":[{"def":"Without wit; stupid.","pos":""}],"CONCEIVABLE":[{"def":"Capable of being conceived, imagined, or understood.","pos":""}],"CONCEIVE":[{"def":"To receive into the womb and begin to breed; to begin the formation of the embryo of.","pos":""},{"def":"To form in the mind; to plan; to devise; to generate; to originate; as, to conceive a purpose, plan, hope.","pos":""}],"CONCEIVER":[{"def":"One who conceives.","pos":""}],"CONCELEBRATE":[{"def":"To celebrate together.","pos":""}],"CONCENT":[{"def":"To come to one point; to meet in, or converge toward, a common center; to have a common center.","pos":""},{"def":"To draw or direct to a common center; to bring together at a focus or point, as two or more lines; to concentrate.","pos":""}],"CONCENTRATE":[{"def":"To bring to, or direct toward, a common center; to unite more closely; to gather into one body, mass, or force; to fix; as, to concentrate rays of light into a focus; to concentrate the attention.","pos":""},{"def":"To increase the strength and diminish the bulk of, as of a liquid or an ore; to intensify, by getting rid of useless material; to condense; as, to concentrate acid by evaporation; to concentrate by washing; -- opposed to Ant: dilute.","pos":""}],"CONCENTRATION":[{"def":"The act or process of removing the dress of ore and of reducing the valuable part to smaller compass, as by currents of air or water.","pos":""}],"CONCENTRATIVE":[{"def":"Serving or tending to concentrate; characterized by concentration.","pos":""}],"CONCENTRATIVENESS":[{"def":"The faculty or propensity which has to do with concentrating the intellectual the intellectual powers.","pos":""}],"CONCENTRATOR":[{"def":"An apparatus for the separation of dry comminuted ore, by exposing it to intermittent puffs of air.","pos":""},{"def":"Having a common center, as circles of different size, one within another.","pos":""}],"CONCENTRIC":[{"def":"That which has a common center with something else.","pos":""}],"CONCENTRICALLY":[{"def":"In a concentric manner.","pos":""}],"CONCENTRICITY":[{"def":"The state of being concentric.","pos":""}],"CONCENTUAL":[{"def":"Possesing harmony; accordant.","pos":""}],"CONCEPT":[{"def":"An abstract general conception; a notion; a universal.","pos":""}],"CONCEPTACLE":[{"def":"That in which anything is contained; a vessel; a receiver or receptacle.","pos":""}],"CONCEPTIBILITY":[{"def":"The quality of being conceivable; conceivableness.","pos":""}],"CONCEPTIBLE":[{"def":"Capable of being conceived; conceivable.","pos":""}],"CONCEPTION":[{"def":"The act of conceiving in the womb; the initiation of an embryonic animal life.","pos":""},{"def":"The state of being conceived; beginning.","pos":""}],"CONCEPTIONAL":[{"def":"Pertaining to conception.","pos":""}],"CONCEPTIONALIST":[{"def":"A conceptualist.","pos":""}],"CONCEPTIOUS":[{"def":"Apt to conceive; fruitful.","pos":""}],"CONCEPTIVE":[{"def":"Capable of conceiving.","pos":""}],"CONCEPTUAL":[{"def":"Pertaining to conception.","pos":""}],"CONCEPTUALISM":[{"def":"A theory, intermediate between realism and nominalism, that the mind has the power of forming for itself general conceptions of individual or single objects.","pos":""}],"CONCEPTUALIST":[{"def":"One who maintains the theory of conceptualism.","pos":""}],"CONCERN":[{"def":"To relate or belong to; to have reference to or connection with; to affect the interest of; to be of importance to.","pos":""},{"def":"To engage by feeling or sentiment; to interest; as, a good prince concerns himself in the happiness of his subjects.","pos":""}],"CONCERNED":[{"def":"Disturbed; troubled; solicitous; as, to be much concerned for the safety of a friend.","pos":""}],"CONCERNEDLY":[{"def":"In a concerned manner; solicitously; sympathetically.","pos":""}],"CONCERNING":[{"def":"Pertaining to; regarding; having relation to; respecting; as regards.","pos":""}],"CONCERT":[{"def":"To plan together; to settle or adjust by conference, agreement, or consultation.","pos":""},{"def":"To plan; to devise; to arrange.","pos":""}],"CONCERT OF THE POWERS":[{"def":"An agreement or understanding between the chief European powers, the United States, and Japan in 1900 to take only joint action in the Chinese aspect of the Eastern Question.","pos":""}],"CONCERTANTE":[{"def":"A concert for two or more principal instruments, with orchestral accompaniment.","pos":""}],"CONCERTATION":[{"def":"Strife; contention.","pos":""}],"CONCERTATIVE":[{"def":"Contentious; quarrelsome.","pos":""}],"CONCERTED":[{"def":"Mutually contrived or planned; agreed on; as, concerted schemes, signals.","pos":""}],"CONCERTINA":[{"def":"A small musical imstrument on the principle of the accordion.","pos":""}],"CONCERTINO":[{"def":"A piece for one or more solo instruments with orchestra; -- more concise than the concerto.","pos":""}],"CONCERTION":[{"def":"Act of concerting; adjustment.","pos":""}],"CONCERTMEISTER":[{"def":"The head violinist or leader of the strings in an orchestra; the sub-leader of the orchestra; concert master.","pos":""}],"CONCERTO":[{"def":"A composition (usually in symphonic form with three movements) in which one instrument (or two or three) stands out in bold relief against the orchestra, or accompaniment, so as to display its qualities or the performer's skill.","pos":""},{"def":"An agreement or understanding between the chief European powers to take only joint action in the (European) Eastern Question.","pos":""}],"CONCESSION":[{"def":"The beneficiary of a concession or grant.","pos":""}],"CONCESSIONARY":[{"def":"Of or pertaining to a concession.","pos":""},{"def":"A concessionaire.","pos":""}],"CONCESSIONIST":[{"def":"One who favors concession.","pos":""}],"CONCESSIVE":[{"def":"Implying concession; as, a concessive conjunction.","pos":""}],"CONCESSIVELY":[{"def":"By way of concession.","pos":""}],"CONCESSORY":[{"def":"Conceding; permissive.","pos":""}],"CONCETTISM":[{"def":"The use of concetti or affected conceits.","pos":""}],"CONCETTO":[{"def":"Affected wit; a conceit.","pos":""}]}