{"CREVALLE":[{"def":"Cre`val*le\" (kr`vl-l\"), n.","pos":""}],"CREVASSE":[{"def":"A deep crevice or fissure, as in embankment; one of the clefts or fissure by which the mass of a glacier is divided.","pos":""},{"def":"A breach in the levee or embankment of a river, caused by the pressure of the water, as on the lower Mississippi.","pos":""}],"CREVET":[{"def":"A crucible or melting pot; a cruset.","pos":""}],"CREVICE":[{"def":"A narrow opening resulting from a split or crack or the separation of a junction; a cleft; a fissure; a rent.","pos":""}],"CREVICED":[{"def":"Having a crevice or crevices; as, a creviced structure for storing ears of corn.","pos":""}]}