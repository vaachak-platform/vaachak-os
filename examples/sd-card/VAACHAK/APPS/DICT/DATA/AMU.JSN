{"AMUCK":[{"def":"In a frenzied and reckless.","pos":""}],"AMULET":[{"def":"An ornament, gem, or scroll, or a package containing a relic, etc.","pos":""}],"AMULETIC":[{"def":"Of or pertaining to an amulet; operating as a charm.","pos":""}],"AMURCOUS":[{"def":"Full off dregs; foul.","pos":""}],"AMUSABLE":[{"def":"Capable of being amused.","pos":""}],"AMUSE":[{"def":"To occupy or engage the attention of; to lose in deep thought; to absorb; also, to distract; to bewilder.","pos":""},{"def":"To entertain or occupy in a pleasant manner; to stir with pleasing or mirthful emotions; to divert.","pos":""}],"AMUSED":[{"def":"Expressing amusement; as, an amused look.","pos":""}],"AMUSEMENT":[{"def":"Deep thought; muse.","pos":""},{"def":"The state of being amused; pleasurable excitement; that which amuses; diversion.","pos":""}],"AMUSETTE":[{"def":"A light field cannon, or stocked gun mounted on a swivel.","pos":""}],"AMUSING":[{"def":"Giving amusement; diverting; as, an amusing story.","pos":""}],"AMUSIVE":[{"def":"Having power to amuse or entertain the mind; fitted to excite mirth.","pos":""}]}