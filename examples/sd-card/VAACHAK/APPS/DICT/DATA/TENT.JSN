{"TENT":[{"def":"A kind of wine of a deep red color, chiefly from Galicia or Malaga in Spain; -- called also tent wine, and tinta.","pos":""}],"TENTACLE":[{"def":"A more or less elongated process or organ, simple or branched, proceeding from the head or cephalic region of invertebrate animals, being either an organ of sense, prehension, or motion.","pos":""}],"TENTACLED":[{"def":"Having tentacles.","pos":""}],"TENTACULAR":[{"def":"Of or pertaining to a tentacle or tentacles.","pos":""}],"TENTACULATA":[{"def":"A division of Ctenophora including those which have two long tentacles.","pos":""},{"def":"Having tentacles, or organs like tentacles; tentacled.","pos":""}],"TENTACULIFERA":[{"def":"Same as Suctoria, 1.","pos":""}],"TENTACULIFEROUS":[{"def":"Producing or bearing tentacles.","pos":""}],"TENTACULIFORM":[{"def":"Shaped like a tentacle.","pos":""}],"TENTACULITE":[{"def":"Any one of numerous species of small, conical fossil shells found in Paleozoic rocks.","pos":""}],"TENTACULOCYST":[{"def":"One of the auditory organs of certain medusæ; -- called also auditory tentacle.","pos":""}],"TENTACULUM":[{"def":"One of the stiff hairs situated about the mouth, or on the face, of many animals, and supposed to be tactile organs; a tactile hair.","pos":""}],"TENTAGE":[{"def":"A collection of tents; an encampment.","pos":""}],"TENTATION":[{"def":"A mode of adjusting or operating by repeated trials or experiments.","pos":""}],"TENTATIVE":[{"def":"Of or pertaining to a trial or trials; essaying; experimental.","pos":""}],"TENTED":[{"def":"Covered with tents.","pos":""}],"TENTER":[{"def":"A kind of governor.","pos":""}],"TENTFUL":[{"def":"As much, or as many, as a tent will hold.","pos":""}],"TENTH":[{"def":"Next in order after the ninth; coming after nine others.","pos":""},{"def":"Constituting or being one of ten equal parts into which anything is divided.","pos":""}],"TENTHLY":[{"def":"In a tenth manner.","pos":""},{"def":"A unit for the measurement of many small lengths, such that 1010 of these units make one meter; the ten millionth part of a millimeter.","pos":""}],"TENTHREDINIDES":[{"def":"A group of Hymneoptera comprising the sawflies.","pos":""}],"TENTIGINOUS":[{"def":"Stiff; stretched; strained.","pos":""},{"def":"Lustful, or pertaining to lust.","pos":""}],"TENTMAKER":[{"def":"One whose occupation it is to make tents.","pos":""}],"TENTORIUM":[{"def":"A fold of the dura mater which separates the cerebellum from the cerebrum and often incloses a process or plate of the skull called the bony tentorium.","pos":""}],"TENTORY":[{"def":"The awning or covering of a tent.","pos":""}],"TENTWORT":[{"def":"A kind of small fern, the wall rue.","pos":""}]}