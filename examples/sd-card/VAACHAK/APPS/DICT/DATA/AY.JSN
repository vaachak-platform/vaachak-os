{"AY":[{"def":"Ah! alas! \"Ay me! I fondly dream `Had ye been there.","pos":""}],"AYAH":[{"def":"A native nurse for children; also, a lady's maid.","pos":""},{"def":"Yes; yea; -- a word expressing assent, or an affirmative answer to a question.","pos":""}],"AYE":[{"def":"An affirmative vote; one who votes in the affirmative; as, \"To call for the ayes and noes;\" \"The ayes have it.","pos":""},{"def":"Always; ever; continually; for an indefinite time.","pos":""}],"AYE-AYE":[{"def":"A singular nocturnal quadruped, allied to the lemurs, found in Madagascar (Cheiromys Madagascariensis), remarkable for its long fingers, sharp nails, and rodent-like incisor teeth.","pos":""}],"AYEGREEN":[{"def":"The houseleek (Sempervivum tectorum).","pos":""},{"def":"Again; back against.","pos":""}],"AYME":[{"def":"The utterance of the ejaculation \"Ay me !\" [Obs.","pos":""}],"AYONT":[{"def":"AYRIE; AYRY A\"y*rie, A\"y*ry, n.","pos":""}],"AYRSHIRE":[{"def":"One of a superior breed of cattle from Ayrshire, Scotland.","pos":""}],"AYUNTAMIENTO":[{"def":"In Spain and Spanish America, a corporation or body of magistrates in cities and towns, corresponding to mayor and aldermen.","pos":""}]}