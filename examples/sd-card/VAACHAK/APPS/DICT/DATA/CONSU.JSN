{"CONSUBSTANTIAL":[{"def":"Of the same kind or nature; having the same substance or essence; coessential.","pos":""}],"CONSUBSTANTIALISM":[{"def":"The doctrine of consubstantiation.","pos":""}],"CONSUBSTANTIALIST":[{"def":"One who believes in consubstantiation.","pos":""}],"CONSUBSTANTIALITY":[{"def":"Participation of the same nature; coexistence in the same substance.","pos":""}],"CONSUBSTANTIALLY":[{"def":"In a consubstantial manner; with identity of substance or nature.","pos":""}],"CONSUBSTANTIATE":[{"def":"To cause to unite, or to regard as united, in one common substance or nature.","pos":""}],"CONSUBSTANTIATION":[{"def":"The actual, substantial presence of the body of Christ with the bread and wine of the sacrament of the Lord's Supper; impanation; -- opposed to transubstantiation.","pos":""}],"CONSUETUDE":[{"def":"Custom, habit; usage.","pos":""}],"CONSUETUDINAL":[{"def":"According to custom; customary; usual.","pos":""}],"CONSUETUDINARY":[{"def":"Con`sue*tu\"di*na\"ry, a.","pos":""}],"CONSUL":[{"def":"One of the two chief magistrates of the republic.","pos":""},{"def":"One of the three chief magistrates of France from 1799 to 1804, who were called, respectively, first, second, and third consul.","pos":""}],"CONSULAGE":[{"def":"A duty or tax paid by merchants for the protection of their connerce by means of a consul in a foreign place.","pos":""}],"CONSULAR":[{"def":"Of or pertaining to a consul; performing the duties of a consul; as, consular power; consular dignity; consular officers.","pos":""}],"CONSULATE":[{"def":"The office of a consul.","pos":""},{"def":"The jurisdiction or residence of a consul.","pos":""}],"CONSULSHIP":[{"def":"The office of a consul; consulate.","pos":""},{"def":"The term of office of a consul.","pos":""}],"CONSULT":[{"def":"To seek the opinion or advice of another; to take consel; to deliberate together; to confer.","pos":""}],"CONSULTARY":[{"def":"Formed by consultation; resulting from conference.","pos":""}],"CONSULTATION":[{"def":"The act of consulting or conferring; deliberation of two or more persons on some matter, with a view to a decision.","pos":""},{"def":"A council or conference, as of physicians, held to consider a special case, or of lawyers restained in a cause.","pos":""}],"CONSULTATIVE":[{"def":"Pertaining to consultation; having the privilege or right of conference.","pos":""}],"CONSULTATORY":[{"def":"Formed by, or resulting from, consultation; advisory.","pos":""}],"CONSULTER":[{"def":"One who consults, or asks counsel or information.","pos":""}],"CONSULTIVE":[{"def":"Determined by, or pertaining to, consultation; deliberate; consultative.","pos":""}],"CONSUMABLE":[{"def":"Capable of being consumed; that may be destroyed, dissipated, wasted, or spent.","pos":""}],"CONSUME":[{"def":"To destroy, as by decomposition, dissipation, waste, or fire; to use up; to expend; to waste; to burn up; to eat up; to devour.","pos":""}],"CONSUMEDLY":[{"def":"He's so consumedly pround of it.","pos":""}],"CONSUMER":[{"def":"One who, or that which, consumes; as, the consumer of food.","pos":""}],"CONSUMER'S GOODS":[{"def":"Economic goods that directly satisfy human wants or desires, such as food, clothes, pictures, etc.","pos":""}],"CONSUMER'S SURPLUS":[{"def":"The excess that a purchaser would be willing to pay for a commodity over that he does pay, rather than go without the commodity; -- called also consumer's rent.","pos":""}],"CONSUMINGLY":[{"def":"In a consuming manner.","pos":""}],"CONSUMMATE":[{"def":"Carried to the utmost extent or degree; of the highest quality; complete; perfect.","pos":""}],"CONSUMMATELY":[{"def":"In a consummate manner; completely.","pos":""}],"CONSUMMATION":[{"def":"The act of consummating, or the state of being consummated; completed; completion; perfection; termination; end (as of the world or of life).","pos":""}],"CONSUMMATIVE":[{"def":"Serving to consummate; completing.","pos":""}],"CONSUMPTION":[{"def":"A progressive wasting away of the body; esp.","pos":""}],"CONSUMPTIVE":[{"def":"Affected with, or inclined to, consumption.","pos":""}],"CONSUMPTIVELY":[{"def":"In a way tending to or indication consumption.","pos":""}],"CONSUMPTIVENESS":[{"def":"A state of being consumptive, or a tendency to a consumption.","pos":""}]}