{"SKADDON":[{"def":"The larva of a bee.","pos":""}],"SKAG":[{"def":"An additional piece fastened to the keel of a boat to prevent lateral motion.","pos":""}],"SKAINSMATE":[{"def":"A messmate; a companion.","pos":""}],"SKALL":[{"def":"To scale; to mount.","pos":""},{"def":"Wild; timid; shy.","pos":""}],"SKAT":[{"def":"A three-handed card game played with 32 cards, of which two constitute the skat (sense 2), or widow.","pos":""}],"SKATE":[{"def":"A metallic runner with a frame shaped to fit the sole of a shoe, -- made to be fastened under the foot, and used for moving rapidly on ice.","pos":""}],"SKATER":[{"def":"Any one of numerous species of hemipterous insects belonging to Gerris, Pyrrhocoris, Prostemma, and allied genera.","pos":""}],"SKATOL":[{"def":"A constituent of human fæces formed in the small intestines as a product of the putrefaction of albuminous matter.","pos":""}],"SKEAN":[{"def":"A knife or short dagger, esp.","pos":""}],"SKEDADDLE":[{"def":"To betake one's self to flight, as if in a panic; to flee; to run away.","pos":""}],"SKEE":[{"def":"A long strip of wood, curved upwards in front, used on the foot for sliding.","pos":""}],"SKEEL":[{"def":"A shallow wooden vessel for holding milk or cream.","pos":""},{"def":"The common European sheldrake.","pos":""}],"SKEET":[{"def":"A scoop with a long handle, used to wash the sides of a vessel, and formerly to wet the sails or deck.","pos":""}],"SKEG":[{"def":"The after part of the keel of a vessel, to which the rudder is attached.","pos":""}],"SKEIN":[{"def":"A metallic strengthening band or thimble on the wooden arm of an axle.","pos":""}],"SKELDER":[{"def":"To deceive; to cheat; to trick.","pos":""}],"SKELETAL":[{"def":"Pertaining to the skeleton.","pos":""}],"SKELETOGENOUS":[{"def":"Forming or producing parts of the skeleton.","pos":""}],"SKELETOLOGY":[{"def":"That part of anatomy which treats of the skeleton; also, a treatise on the skeleton.","pos":""}],"SKELETON":[{"def":"Hence, figuratively: (a) A very thin or lean person.","pos":""}],"SKELETONIZE":[{"def":"To prepare a skeleton of; also, to reduce, as a leaf, to its skeleton.","pos":""}],"SKELETONIZER":[{"def":"Any small moth whose larva eats the parenchyma of leaves, leaving the skeleton; as, the apple-leaf skeletonizer.","pos":""}],"SKELP":[{"def":"A blow; a smart stroke.","pos":""},{"def":"A squall; also, a heavy fall of rain.","pos":""}],"SKELTER":[{"def":"To run off helter-skelter; to hurry; to scurry; -- with away or off.","pos":""}],"SKEP":[{"def":"A coarse round farm basket.","pos":""}],"SKEPTIC":[{"def":"A doubter as to whether any fact or truth can be certainly known; a universal doubter; a Pyrrhonist; hence, in modern usage, occasionally, a person who questions whether any truth or fact can be established on philosophical grounds; sometimes, a critical inquirer, in opposition to a dogmatist.","pos":""},{"def":"A person who doubts the existence and perfections of God, or the truth of revelation; one who disbelieves the divine origin of the Christian religion.","pos":""}],"SKEPTICISM":[{"def":"A doubting of the truth of revelation, or a denial of the divine origin of the Christian religion, or of the being, perfections, or truth of God.","pos":""}],"SKEPTICIZE":[{"def":"To doubt; to pretend to doubt of everything.","pos":""}],"SKERRY":[{"def":"A rocky isle; an insulated rock.","pos":""}],"SKETCH":[{"def":"An outline or general delineation of anything; a first rough or incomplete draught or plan of any design; especially, in the fine arts, such a representation of an object or scene as serves the artist's purpose by recording its chief features; also, a preliminary study for an original work.","pos":""}],"SKETCHBOOK":[{"def":"A book of sketches or for sketches.","pos":""}],"SKETCHER":[{"def":"One who sketches.","pos":""}],"SKETCHILY":[{"def":"In a sketchy or incomplete manner.","pos":""}],"SKETCHINESS":[{"def":"The quality or state of being sketchy; lack of finish; incompleteness.","pos":""}],"SKETCHY":[{"def":"Containing only an outline or rough form; being in the manner of a sketch; incomplete.","pos":""}],"SKEW":[{"def":"Awry; obliquely; askew.","pos":""}],"SKEWBALD":[{"def":"Marked with spots and patches of white and some color other than black; -- usually distinguished from piebald, in which the colors are properly white and black.","pos":""}],"SKEWER":[{"def":"A pin of wood or metal for fastening meat to a spit, or for keeping it in form while roasting.","pos":""}],"SKI":[{"def":"See Sciagraph, Sciagraphy, etc.","pos":""}],"SKID":[{"def":"Large fenders hung over a vessel's side to protect it in handling a cargo.","pos":""}],"SKIDDAW":[{"def":"The black guillemot.","pos":""}],"SKIFF":[{"def":"A small, light boat.","pos":""}],"SKIFFLING":[{"def":"Rough dressing by knocking off knobs or projections; knobbing.","pos":""}],"SKILDER":[{"def":"To beg; to pilfer; to skelder.","pos":""}],"SKILL":[{"def":"Discrimination; judgment; propriety; reason; cause.","pos":""},{"def":"Knowledge; understanding.","pos":""}],"SKILLED":[{"def":"Having familiar knowledge united with readiness and dexterity in its application; familiarly acquainted with; expert; skillful; -- often followed by in; as, a person skilled in drawing or geometry.","pos":""}],"SKILLET":[{"def":"A small vessel of iron, copper, or other metal, with a handle, used for culinary purpose, as for stewing meat.","pos":""}],"SKILLFUL":[{"def":"Discerning; reasonable; judicious; cunning.","pos":""},{"def":"Possessed of, or displaying, skill; knowing and ready; expert; well-versed; able in management; as, a skillful mechanic; -- often followed by at, in, or of; as, skillful at the organ; skillful in drawing.","pos":""}],"SKILLIGALEE":[{"def":"A kind of thin, weak broth or oatmeal porridge, served out to prisoners and paupers in England; also, a drink made of oatmeal, sugar, and water, sometimes used in the English navy or army.","pos":""}],"SKILLING":[{"def":"A bay of a barn; also, a slight addition to a cottage.","pos":""}],"SKILTS":[{"def":"A kind of large, coarse, short trousers formerly worn.","pos":""}],"SKIM":[{"def":"To clear (a liquid) from scum or substance floating or lying thereon, by means of a utensil that passes just beneath the surface; as, to skim milk; to skim broth.","pos":""},{"def":"To take off by skimming; as, to skim cream.","pos":""}],"SKIMBLE-SCAMBLE":[{"def":"Rambling; disorderly; unconnected.","pos":""}],"SKIMITRY":[{"def":"See Skimmington.","pos":""}],"SKIMMER":[{"def":"Any species of longwinged marine birds of the genus Rhynchops, allied to the terns, but having the lower mandible compressed and much longer than the upper one.","pos":""},{"def":"Any one of several large bivalve shells, sometimes used for skimming milk, as the sea clams, and large scallops.","pos":""}],"SKIMMERTON":[{"def":"See Skimmington.","pos":""}],"SKIMMING":[{"def":"The act of one who skims.","pos":""},{"def":"That which is skimmed from the surface of a liquid; -- chiefly used in the plural; as, the skimmings of broth.","pos":""}],"SKIMMINGLY":[{"def":"In a skimming manner.","pos":""}],"SKIMMINGTON":[{"def":"A word employed in the phrase, To ride Skimmington; that is to ride on a horse with a woman, but behind her, facing backward, carrying a distaff, and accompanied by a procession of jeering neighbors making mock music; a cavalcade in ridicule of a henpecked man.","pos":""}],"SKIMP":[{"def":"To slight; to do carelessly; to scamp.","pos":""},{"def":"To make insufficient allowance for; to scant; to scrimp.","pos":""}],"SKIN":[{"def":"The external membranous integument of an animal.","pos":""}],"SKIN-DEEP":[{"def":"Not deeper than the skin; hence, superficial.","pos":""}],"SKINBOUND":[{"def":"Having the skin adhering closely and rigidly to the flesh; hidebound.","pos":""}],"SKINCH":[{"def":"To give scant measure; to squeeze or pinch in order to effect a saving.","pos":""}],"SKINFLINT":[{"def":"A penurious person; a miser; a niggard.","pos":""}],"SKINFUL":[{"def":"As much as a skin can hold.","pos":""}],"SKINK":[{"def":"Any one of numerous species of regularly scaled harmless lizards of the family Scincidæ, common in the warmer parts of all the continents.","pos":""}],"SKINKER":[{"def":"One who serves liquor; a tapster.","pos":""}],"SKINLESS":[{"def":"Having no skin, or a very thin skin; as, skinless fruit.","pos":""}],"SKINNER":[{"def":"One who deals in skins, pelts, or hides.","pos":""}],"SKINNINESS":[{"def":"Quality of being skinny.","pos":""}],"SKINNY":[{"def":"Consisting, or chiefly consisting, of skin; wanting flesh.","pos":""}],"SKIP":[{"def":"An iron bucket, which slides between guides, for hoisting mineral and rock.","pos":""},{"def":"A charge of sirup in the pans.","pos":""}],"SKIPJACK":[{"def":"An elater; a snap bug, or snapping beetle.","pos":""},{"def":"A name given to several kinds of a fish, as the common bluefish, the alewife, the bonito, the butterfish, the cutlass fish, the jurel, the leather jacket, the runner, the saurel, the saury, the threadfish, etc.","pos":""}],"SKIPPER":[{"def":"The saury (Scomberesox saurus).","pos":""},{"def":"Any one of numerous species of small butterflies of the family Hesperiadæ; -- so called from their peculiar short, jerking flight.","pos":""}],"SKIPPET":[{"def":"A small boat; a skiff.","pos":""},{"def":"A small round box for keeping records.","pos":""}],"SKIPPINGLY":[{"def":"In a skipping manner; by skips, or light leaps.","pos":""}],"SKIRL":[{"def":"To utter in a shrill tone; to scream.","pos":""}],"SKIRLCOCK":[{"def":"The missel thrush; -- so called from its harsh alarm note.","pos":""}],"SKIRLING":[{"def":"A shrill cry or sound; a crying shrilly; a skirl.","pos":""}],"SKIRMISH":[{"def":"To fight slightly or in small parties; to engage in a skirmish or skirmishes; to act as skirmishers.","pos":""}],"SKIRMISHER":[{"def":"One who skirmishes.","pos":""},{"def":"Soldiers deployed in loose order, to cover the front or flanks of an advancing army or a marching column.","pos":""}],"SKIRR":[{"def":"To ramble over in order to clear; to scour.","pos":""}],"SKIRRET":[{"def":"An umbelliferous plant (Sium, or Pimpinella, Sisarum).","pos":""}],"SKIRT":[{"def":"The lower and loose part of a coat, dress, or other like garment; the part below the waist; as, the skirt of a coat, a dress, or a mantle.","pos":""},{"def":"A loose edging to any part of a dress.","pos":""}],"SKIRTING":[{"def":"A skirting board.","pos":""}],"SKIT":[{"def":"To cast reflections on; to asperse.","pos":"verb"}],"SKITTER":[{"def":"To move or pass (something) over a surface quickly so that it touches only at intervals; to skip.","pos":""}],"SKITTISH":[{"def":"Easily frightened; timorous; shy; untrustworthy; as, a skittish colt.","pos":""},{"def":"Wanton; restive; freakish; volatile; changeable; fickle.","pos":""}],"SKITTLE":[{"def":"Pertaining to the game of skittles.","pos":""}],"SKITTLE-DOG":[{"def":"The piked dogfish.","pos":""}],"SKITTLES":[{"def":"An English game resembling ninepins, but played by throwing wooden disks, instead of rolling balls, at the pins.","pos":""}],"SKITTY":[{"def":"A rail; as, the water rail (called also skitty cock, and skitty coot); the spotted crake (Porzana maruetta), and the moor hen.","pos":""}],"SKIVE":[{"def":"The iron lap used by diamond polishers in finishing the facets of the gem.","pos":""}],"SKIVER":[{"def":"An inferior quality of leather, made of split sheepskin, tanned by immersion in sumac, and dyed.","pos":""},{"def":"The cutting tool or machine used in splitting leather or skins, as sheepskins.","pos":""}],"SKIVING":[{"def":"The act of paring or splitting leather or skins.","pos":""},{"def":"A piece made in paring or splitting leather; specifically, the part from the inner, or flesh, side.","pos":""}],"SKLERE":[{"def":"To shelter; to cover.","pos":""}],"SKOWITZ":[{"def":"The silver salmon.","pos":""}],"SKRIKE":[{"def":"The missel thrush.","pos":""}],"SKUA":[{"def":"Any jager gull; especially, the Megalestris skua; -- called also boatswain.","pos":""}],"SKULK":[{"def":"To hide, or get out of the way, in a sneaking manner; to lie close, or to move in a furtive way; to lurk.","pos":""}],"SKULKINGLY":[{"def":"In a skulking manner.","pos":""}],"SKULL":[{"def":"A school, company, or shoal.","pos":""}],"SKULLCAP":[{"def":"Any plant of the labiate genus Scutellaria, the calyx of whose flower appears, when inverted, like a helmet with the visor raised.","pos":""}],"SKULLFISH":[{"def":"A whaler's name for a whale more than two years old.","pos":""}],"SKUNK":[{"def":"Any one of several species of American musteline carnivores of the genus Mephitis and allied genera.","pos":""}],"SKUNKHEAD":[{"def":"Atlantic coast of New England.","pos":""}],"SKUNKISH":[{"def":"Like the skunk, especially in odor.","pos":""}],"SKUTE":[{"def":"A boat; a small vessel.","pos":"verb"}],"SKUTTERUDITE":[{"def":"A mineral of a bright metallic luster and tin-white to pale lead-gray color.","pos":""}],"SKY":[{"def":"Hence, a shadow.","pos":""}],"SKY PILOT":[{"def":"A person licensed as a pilot.","pos":""}],"SKY-BLUE":[{"def":"Having the blue color of the sky; azure; as, a sky-blue stone.","pos":""}],"SKY-HIGH":[{"def":"Sky\"-high` Defn: , adv.","pos":""}],"SKYED":[{"def":"Surrounded by sky.","pos":""}],"SKYEY":[{"def":"Like the sky; ethereal; being in the sky.","pos":""}],"SKYISH":[{"def":"Like the sky, or approaching the sky; lofty; ethereal.","pos":""}],"SKYLARK":[{"def":"A lark that mounts and sings as it files, especially the common species (Alauda arvensis) found in Europe and in some parts of Asia, and celebrated for its melodious song; -- called also sky laverock.","pos":""}],"SKYLARKING":[{"def":"The act of running about the rigging of a vessel in sport; hence, frolicking; scuffing; sporting; carousing.","pos":""}],"SKYLIGHT":[{"def":"A window placed in the roof of a building, in the ceiling of a room, or in the deck of a ship, for the admission of light from above.","pos":""}],"SKYROCKET":[{"def":"A rocket that ascends high and burns as it flies; a species of fireworks.","pos":""}],"SKYSAIL":[{"def":"The sail set next above the royal.","pos":""}],"SKYSCRAPER":[{"def":"A name for the one of the fancy sails alleged to have been sometimes set above the skysail.","pos":""}]}