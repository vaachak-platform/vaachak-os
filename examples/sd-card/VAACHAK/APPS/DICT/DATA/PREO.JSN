{"PREOBLONGATA":[{"def":"The anterior part of the medulla oblongata.","pos":""}],"PREOBTAIN":[{"def":"To obtain beforehand.","pos":""}],"PREOCCUPANCY":[{"def":"The act or right of taking possession before another; as, the preoccupancy of wild land.","pos":""}],"PREOCCUPATE":[{"def":"To anticipate; to take before.","pos":""},{"def":"To prepossess; to prejudice.","pos":""}],"PREOCCUPATION":[{"def":"The act of preoccupying, or taking possession of beforehand; the state of being preoccupied; prepossession.","pos":""},{"def":"Anticipation of objections.","pos":""}],"PREOCCUPY":[{"def":"To take possession of before another; as, to preoccupy a country not before held.","pos":""},{"def":"To prepossess; to engage, occupy, or engross the attention of, beforehand; hence, to prejudice.","pos":""}],"PREOCULAR":[{"def":"Placed just in front of the eyes, as the antennæ of certain insects.","pos":""},{"def":"One of the scales just in front of the eye of a reptile or fish.","pos":""}],"PREOMINATE":[{"def":"To ominate beforehand; to portend.","pos":""}],"PREOPERCULAR":[{"def":"Situated in front of the operculum; pertaining to the preoperculum.","pos":""},{"def":"The preoperculum.","pos":""}],"PREOPERCULUM":[{"def":"The anterior opercular bone in fishes.","pos":""}],"PREOPINION":[{"def":"Opinion previously formed; prepossession; prejudice.","pos":""}],"PREOPTION":[{"def":"Right of first choice.","pos":""}],"PREORAL":[{"def":"Situated in front of, or anterior to, the mouth; as, preoral bands.","pos":""}],"PREORBITAL":[{"def":"Pre*or\"bit*al Defn: a.","pos":""}],"PREORDAIN":[{"def":"To ordain or appoint beforehand: to predetermine: to foreordain.","pos":""}],"PREORDER":[{"def":"To order to arrange beforehand; to foreordain.","pos":""}],"PREORDINANCE":[{"def":"Antecedent decree or determination.","pos":""}],"PREORDINATION":[{"def":"The act of foreordaining: previous determination.","pos":""}]}