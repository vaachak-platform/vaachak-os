{"FOVEA":[{"def":"A slight depression or pit; a fossa.","pos":""}],"FOVEATE":[{"def":"Having pits or depressions; pitted.","pos":""}],"FOVEOLA":[{"def":"A small depression or pit; a fovea.","pos":""}],"FOVEOLATE":[{"def":"Having small pits or depression, as the receptacle in some composite flowers.","pos":""}],"FOVILLA":[{"def":"One of the fine granules contained in the protoplasm of a pollen grain.","pos":""}]}