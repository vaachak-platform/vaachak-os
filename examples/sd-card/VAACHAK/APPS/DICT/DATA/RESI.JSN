{"RESIANCE":[{"def":"Residence; abode.","pos":""}],"RESIANT":[{"def":"Resident; present in a place.","pos":""}],"RESIDE":[{"def":"To dwell permanently or for a considerable time; to have a settled abode for a time; to abide continuosly; to have one's domicile of home; to remain for a long time.","pos":""},{"def":"To have a seat or fixed position; to inhere; to lie or be as in attribute or element.","pos":""}],"RESIDENCE":[{"def":"The residing of an incumbent on his benefice; -- opposed to nonresidence.","pos":""}],"RESIDENCIA":[{"def":"In Spanish countries, a court or trial held, sometimes as long as six months, by a newly elected official, as the governor of a province, to examine into the conduct of a predecessor.","pos":""}],"RESIDENCY":[{"def":"A political agency at a native court in British India, held by an officer styled the Residentl: also, a Dutch commercial colony or province in the East Indies.","pos":""}],"RESIDENT":[{"def":"Dwelling, or having an abode, in a place for a continued length of time; residing on one's own estate; -- opposed to nonresident; as, resident in the city or in the country.","pos":""},{"def":"Fixed; stable; certain.","pos":""}],"RESIDENTER":[{"def":"Res\"i*dent*er (-$r), n.","pos":""}],"RESIDENTIAL":[{"def":"Of or pertaining to a residence or residents; as, residential trade.","pos":""},{"def":"Residing; residentiary.","pos":""}],"RESIDENTIARY":[{"def":"Having residence; as, a canon residentary; a residentiary guardian.","pos":""}],"RESIDENTIARYSHIP":[{"def":"The office or condition of a residentiary.","pos":""}],"RESIDENTSHIP":[{"def":"The office or condition of a resident.","pos":""}],"RESIDER":[{"def":"One who resides in a place.","pos":""}],"RESIDUAL":[{"def":"Pertaining to a residue; remaining after a part is taken.","pos":""}],"RESIDUARY":[{"def":"Consisting of residue; as, residuary matter; pertaining to the residue, or part remaining; as, the residuary advantage of an estate.","pos":""}],"RESIDUE":[{"def":"That part of a testeator's estate wwhich is not disposed of in his will by particular and special legacies and devises, and which remains after payment of debts and legacies.","pos":""},{"def":"That which remains of a molecule after the removal of a portion of its constituents; hence, an atom or group regarded as a portion of a molecule; -- used as nearly equivalent to radical, but in a more general sense.","pos":""}],"RESIDUOUS":[{"def":"Remaining; residual.","pos":""}],"RESIDUUM":[{"def":"That which is left after any process of separation or purification; that which remains after certain specified deductions are made; residue.","pos":""}],"RESIEGE":[{"def":"To seat again; to reinstate.","pos":""}],"RESIGN":[{"def":"To sign back; to return by a formal act; to yield to another; to surrender; -- said especially of office or emolument.","pos":""},{"def":"To relinquish; to abandon.","pos":""}],"RESIGNATION":[{"def":"The act of resigning or giving up, as a claim, possession, office, or the like; surrender; as, the resignation of a crown or comission.","pos":""},{"def":"The state of being resigned or submissive; quiet or patient submission; unresisting acquiescence; as, resignation to the will and providence of God.","pos":""}],"RESIGNED":[{"def":"Submissive; yielding; not disposed to resist or murmur.","pos":""}],"RESIGNEDLY":[{"def":"With submission.","pos":""}],"RESIGNEE":[{"def":"One to whom anything is resigned, or in whose favor a resignation is made.","pos":""}],"RESIGNER":[{"def":"One who resigns.","pos":""}],"RESIGNMENT":[{"def":"The act of resigning.","pos":""}],"RESILE":[{"def":"To start back; to recoil; to recede from a purpose.","pos":""},{"def":"The mechanical work required to strain an elastic body, as a deflected beam, stretched spring, etc.","pos":""}],"RESILIENT":[{"def":"Leaping back; rebounding; recoling.","pos":""}],"RESILITION":[{"def":"Res`i*li\"tion (rz`-lsh\"n), n.","pos":""}],"RESIN":[{"def":"Any one of a class of yellowish brown solid inflammable substances, of vegetable origin, which are nonconductors of electricity, have a vitreous fracture, and are soluble in ether, alcohol, and essential oils, but not in water; specif.","pos":""}],"RESINACEOUS":[{"def":"Having the quality of resin; resinous.","pos":""}],"RESINATE":[{"def":"Any one of the salts the resinic acids.","pos":""}],"RESINIC":[{"def":"Pertaining to, or obtained from, resin; as, the resinic acids.","pos":""}],"RESINIFEROUS":[{"def":"Yielding resin; as, a resiniferous tree or vessel.","pos":""}],"RESINIFORM":[{"def":"Having the form of resin.","pos":""}],"RESINO-ELECTRIC":[{"def":"Containing or exhibiting resinous electricity.","pos":""}],"RESINOID":[{"def":"Somewhat like resin.","pos":""}],"RESINOUS":[{"def":"Of or pertaining to resin; of the nature of resin; resembling or obtained from resin.","pos":""}],"RESINOUSLY":[{"def":"By means, or in the manner, of resin.","pos":""}],"RESINOUSNESS":[{"def":"The quality of being resinous.","pos":""}],"RESINY":[{"def":"Like resin; resinous.","pos":""}],"RESIPISCENCE":[{"def":"Wisdom derived from severe experience; hence, repentance.","pos":""}],"RESIST":[{"def":"To stand against; to withstand; to obstruct.","pos":""},{"def":"To strive against; to endeavor to counteract, defeat, or frustrate; to act in opposition to; to oppose.","pos":""}],"RESISTANCE":[{"def":"The quality of not yielding to force or external pressure; that power of a body which acts in opposition to the impulse or pressure of another, or which prevents the effect of another power; as, the resistance of the air to a body passing through it; the resistance of a target to projectiles.","pos":""},{"def":"A certain hindrance or opposition to the passage of an electrical current or discharge offered by conducting bodies.","pos":""}],"RESISTANCE FRAME":[{"def":"A rheostat consisting of an open frame on which are stretched spirals of wire.","pos":""}],"RESISTANT":[{"def":"Making resistance; resisting.","pos":""},{"def":"One who, or that which, resists.","pos":""}],"RESISTER":[{"def":"One who resists.","pos":""}],"RESISTFUL":[{"def":"Making much resistance.","pos":""}],"RESISTIBILITY":[{"def":"The quality of being resistible; resistibleness.","pos":""},{"def":"The quality of being resistant; resitstance.","pos":""}],"RESISTIBLE":[{"def":"Capable of being resisted; as, a resistible force.","pos":""}],"RESISTING":[{"def":"Making resistance; opposing; as, a resisting medium.","pos":""}],"RESISTIVE":[{"def":"Serving to resist.","pos":""}],"RESISTLESS":[{"def":"Having no power to resist; making no opposition.","pos":""},{"def":"Incapable of being resisted; irresistible.","pos":""}]}