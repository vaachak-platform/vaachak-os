{"PANOISTIC":[{"def":"Producing ova only; -- said of the ovaries of certain insects which do not produce vitelligenous cells.","pos":""}],"PANOMPHEAN":[{"def":"Uttering ominous or prophetic voices; divining.","pos":""}],"PANOPLIED":[{"def":"Dressed in panoply.","pos":""}],"PANOPLY":[{"def":"Defensive armor in general; a full suit of defensive armor.","pos":""}],"PANOPTICON":[{"def":"A prison so contructed that the inspector can see each of the prisoners at all times, without being seen.","pos":""},{"def":"A room for the exhibition of novelties.","pos":""}],"PANORAMA":[{"def":"Of, pertaining to, or like, a panorama.","pos":""}],"PANORPIAN":[{"def":"Like, or pertaining to, the genus Panorpa.","pos":""},{"def":"Same as Panorpid.","pos":""}],"PANORPID":[{"def":"Any neuropterous insect of the genus Panorpa, and allied genera.","pos":""}]}