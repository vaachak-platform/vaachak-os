{"HERO":[{"def":"An illustrious man, supposed to be exalted, after death, to a place among the gods; a demigod, as Hercules.","pos":""}],"HERODIAN":[{"def":"One of a party among the Jews, composed of partisans of Herod of Galilee.","pos":""}],"HERODIONES":[{"def":"A division of wading birds, including the herons, storks, and allied forms.","pos":""}],"HEROIC":[{"def":"Larger than life size, but smaller than colossal; -- said of the representation of a human figure.","pos":""}],"HEROICNESS":[{"def":"Combining the heroic and the ludicrous; denoting high burlesque; as, a heroicomic poem.","pos":""}],"HEROINE":[{"def":"A woman of an heroic spirit.","pos":""},{"def":"The principal female person who figures in a remarkable action, or as the subject of a poem or story.","pos":""}],"HEROISM":[{"def":"The qualities characteristic of a hero, as courage, bravery, fortitude, unselfishness, etc.","pos":""},{"def":"One who treats of heroes.","pos":""}],"HERON":[{"def":"Any wading bird of the genus Ardea and allied genera, of the family Ardeidæ.","pos":""}],"HERONER":[{"def":"A hawk used in hunting the heron.","pos":""}],"HERONRY":[{"def":"A place where herons breed.","pos":""}],"HEROSHIP":[{"def":"The character or personality of a hero.","pos":""}]}