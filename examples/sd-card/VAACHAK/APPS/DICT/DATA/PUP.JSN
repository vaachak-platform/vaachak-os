{"PUP":[{"def":"To bring forth whelps or young, as the female of the canine species.","pos":""}],"PUPA":[{"def":"Any insect in that stage of its metamorphosis which usually immediately precedes the adult, or imago, stage.","pos":""},{"def":"A genus of air-breathing land snails having an elongated spiral shell.","pos":""}],"PUPAL":[{"def":"Of or pertaining to a pupa, or the condition of a pupa.","pos":""}],"PUPATE":[{"def":"To become a pupa.","pos":""}],"PUPATION":[{"def":"the act of becoming a pupa.","pos":""}],"PUPIGEROUS":[{"def":"Bearing or containing a pupa; -- said of dipterous larvæ which do not molt when the pupa is formed within them.","pos":""}],"PUPIL":[{"def":"The aperture in the iris; the sight, apple, or black of the eye.","pos":""}],"PUPILAGE":[{"def":"The state of being a pupil.","pos":""}],"PUPILLARITY":[{"def":"The period before puberty, or from birth to fourteen in males, and twelve in females.","pos":""}],"PUPILLARY":[{"def":"Of or pertaining to the pupil of the eye.","pos":""}],"PUPILLOMETER":[{"def":"An instrument for measuring the size of the pupil of the pupil of the eye.","pos":""}],"PUPIPARA":[{"def":"A division of Diptera in which the young are born in a stage like the pupa.","pos":""}],"PUPIVORA":[{"def":"A group of parasitic Hymenoptera, including the ichneumon flies, which destroy the larvæ and pupæ of insects.","pos":""}],"PUPIVOROUS":[{"def":"Feeding on the pupæ of insects.","pos":""}],"PUPPET":[{"def":"The upright support for the bearing of the spindle in a lathe.","pos":""}],"PUPPETISH":[{"def":"Resembling a puppet in appearance or action; of the nature of a puppet.","pos":""}],"PUPPETMAN":[{"def":"A master of a puppet show.","pos":""}],"PUPPETRY":[{"def":"Action or appearance resembling that of a puppet, or puppet show; hence, mere form or show; affectation.","pos":""}],"PUPPY":[{"def":"The young of a canine animal, esp.","pos":""}],"PUPPYHOOD":[{"def":"The time or state of being a puppy; the time of being young and undisciplined.","pos":""}],"PUPPYISM":[{"def":"Extreme meanness, affectation, conceit, or impudence.","pos":""}]}