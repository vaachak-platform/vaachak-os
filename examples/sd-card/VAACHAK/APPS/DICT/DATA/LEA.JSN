{"LEA":[{"def":"A meadow or sward land; a grassy field.","pos":""}],"LEACH":[{"def":"A quantity of wood ashes, through which water passes, and thus imbibes the alkali.","pos":""},{"def":"A tub or vat for leaching ashes, bark, etc.","pos":""}],"LEACHY":[{"def":"Permitting liquids to pass by percolation; not capable of retaining water; porous; pervious; -- said of gravelly or sandy soils, and the like.","pos":""}],"LEAD":[{"def":"One of the elements, a heavy, pliable, inelastic metal, having a bright, bluish color, but easily tarnished.","pos":""}],"LEADED":[{"def":"Separated by leads, as the lines of a page.","pos":""}],"LEADEN":[{"def":"Made of lead; of the nature of lead; as, a leaden ball.","pos":""},{"def":"Like lead in color, etc.","pos":""}],"LEADER":[{"def":"A net for leading fish into a pound, weir, etc.","pos":""},{"def":"a row of dots, periods, or hyphens, used in tables of contents, etc.","pos":""}],"LEADERSHIP":[{"def":"The office of a leader.","pos":""}],"LEADHILLITE":[{"def":"A mineral of a yellowish or greenish white color, consisting of the sulphate and carbonate of lead; -- so called from having been first found at Leadhills, Scotland.","pos":""}],"LEADING":[{"def":"Guiding; directing; controlling; foremost; as, a leading motive; a leading man; a leading example.","pos":""}],"LEADING EDGE":[{"def":"same as Advancing edge, above.","pos":""}],"LEADMAN":[{"def":"One who leads a dance.","pos":""}],"LEADSMAN":[{"def":"The man who heaves the lead.","pos":""}],"LEADWORT":[{"def":"A genus of maritime herbs (Plumbago).","pos":""}],"LEADY":[{"def":"Resembling lead.","pos":""}],"LEAF":[{"def":"A colored, usually green, expansion growing from the side of a stem or rootstock, in which the sap for the use of the plant is elaborated under the influence of light; one of the parts of a plant which collectively constitute its foliage.","pos":""},{"def":"A special organ of vegetation in the form of a lateral outgrowth from the stem, whether appearing as a part of the foliage, or as a cotyledon, a scale, a bract, a spine, or a tendril.","pos":""}],"LEAF-FOOTED":[{"def":"Having leaflike expansions on the legs; -- said of certain insects; as, the leaf-footed bug (Leptoglossus phyllopus).","pos":""}],"LEAF-NOSED":[{"def":"Having a leaflike membrane on the nose; -- said of certain bats, esp.","pos":""}],"LEAFAGE":[{"def":"Leaves, collectively; foliage.","pos":""}],"LEAFCUP":[{"def":"A coarse American composite weed (Polymnia Uvedalia).","pos":""}],"LEAFED":[{"def":"Having (such) a leaf or (so many) leaves; -- used in composition; as, broad-leafed; four-leafed.","pos":""}],"LEAFINESS":[{"def":"The state of being leafy.","pos":""}],"LEAFLESS":[{"def":"Having no leaves or foliage; bearing no foliage.","pos":""}],"LEAFLET":[{"def":"One of the divisions of a compound leaf; a foliole.","pos":""},{"def":"A leaflike organ or part; as, a leaflet of the gills of fishes.","pos":""}],"LEAFSTALK":[{"def":"The stalk or petiole which supports a leaf.","pos":""}],"LEAFY":[{"def":"Full of leaves; abounding in leaves; as, the leafy forest.","pos":""},{"def":"Consisting of leaves.","pos":""}],"LEAGUE":[{"def":"A measure of length or distance, varying in different countries from about 2.","pos":""},{"def":"A stone erected near a public road to mark the distance of a league.","pos":""}],"LEAGUER":[{"def":"The camp of a besieging army; a camp in general.","pos":""},{"def":"A siege or beleaguering.","pos":""}],"LEAK":[{"def":"A crack, crevice, fissure, or hole which admits water or other fluid, or lets it escape; as, a leak in a roof; a leak in a boat; a leak in a gas pipe.","pos":""},{"def":"The entrance or escape of a fluid through a crack, fissure, or other aperture; as, the leak gained on the ship's pumps.","pos":""}],"LEAKAGE":[{"def":"An allowance of a certain rate per cent for the leaking of casks, or waste of liquors by leaking.","pos":""}],"LEAKINESS":[{"def":"The quality of being leaky.","pos":""}],"LEAKY":[{"def":"Permitting water or other fluid to leak in or out; as, a leaky roof or cask.","pos":""},{"def":"Apt to disclose secrets; tattling; not close.","pos":""}],"LEAL":[{"def":"Faithful; loyal; true.","pos":""}],"LEAM":[{"def":"A cord or strap for leading a dog.","pos":""}],"LEAMER":[{"def":"A dog held by a leam.","pos":""}],"LEAN":[{"def":"To incline, deviate, or bend, from a vertical position; to be in a position thus inclining or deviating; as, she leaned out at the window; a leaning column.","pos":""},{"def":"To incline in opinion or desire; to conform in conduct; -- with to, toward, etc.","pos":""}],"LEAN-FACED":[{"def":"slender or narrow; -- said of type the letters of which have thin lines, or are unusually narrow in proportion to their height.","pos":""}],"LEAN-TO":[{"def":"Having only one slope or pitch; -- said of a roof.","pos":""},{"def":"A shed or slight building placed against the wall of a larger structure and having a single-pitched roof; -- called also penthouse, and to-fall.","pos":""}],"LEAN-WITTED":[{"def":"Having but little sense or shrewdness.","pos":""}],"LEANING":[{"def":"The act, or state, of inclining; inclination; tendency; as, a leaning towards Calvinism.","pos":""}],"LEANLY":[{"def":"Meagerly; without fat or plumpness.","pos":""}],"LEANNESS":[{"def":"The condition or quality of being lean.","pos":""}],"LEAP":[{"def":"A weel or wicker trap for fish.","pos":""}],"LEAP YEAR":[{"def":"Leap\" year` Defn: .","pos":""}],"LEAPER":[{"def":"One who, or that which, leaps.","pos":""}],"LEAPFROG":[{"def":"A play among boys, in which one stoops down and another leaps over him by placing his hands on the shoulders of the former.","pos":""}],"LEAPING":[{"def":"from Leap, to jump.","pos":""}],"LEAR":[{"def":"An annealing oven.","pos":""}],"LEARN":[{"def":"To communicate knowledge to; to teach.","pos":""}],"LEARNABLE":[{"def":"Such as can be learned.","pos":""}],"LEARNED":[{"def":"Of or pertaining to learning; possessing, or characterized by, learning, esp.","pos":""}],"LEARNER":[{"def":"One who learns; a scholar.","pos":""}],"LEARNING":[{"def":"The acquisition of knowledge or skill; as, the learning of languages; the learning of telegraphy.","pos":""},{"def":"The knowledge or skill received by instruction or study; acquired knowledge or ideas in any branch of science or literature; erudition; literature; science; as, he is a man of great learning.","pos":""}],"LEASABLE":[{"def":"Such as can be leased.","pos":""}],"LEASE":[{"def":"To gather what harvesters have left behind; to glean.","pos":""}],"LEASEHOLD":[{"def":"A tenure by lease; specifically, land held as personalty under a lease for years.","pos":""}],"LEASEHOLDER":[{"def":"A tenant under a lease.","pos":""}],"LEASER":[{"def":"One who leases or gleans.","pos":""}],"LEASH":[{"def":"A brace and a half; a tierce; three; three creatures of any kind, especially greyhounds, foxes, bucks, and hares; hence, the number three in general.","pos":""},{"def":"A string with a loop at the end for lifting warp threads, in a loom.","pos":""}],"LEASING":[{"def":"The act of lying; falsehood; a lie or lies.","pos":""}],"LEAST":[{"def":"Smallest, either in size or degree; shortest; lowest; most unimportant; as, the least insect; the least mercy; the least space.","pos":""}],"LEASY":[{"def":"Flimsy; vague; deceptive.","pos":""}],"LEAT":[{"def":"An artificial water trench, esp.","pos":""}],"LEATHER":[{"def":"The skin of an animal, or some part of such skin, tanned, tawed, or otherwise dressed for use; also, dressed hides, collectively.","pos":""}],"LEATHERBACK":[{"def":"A large sea turtle (Sphargis coriacea), having no bony shell on its back.","pos":""},{"def":"An imitation of leather, made of paper and cloth.","pos":""}],"LEATHERN":[{"def":"Made of leather; consisting of.","pos":""}],"LEATHERNECK":[{"def":"The sordid friar bird of Australia (Tropidorhynchus sordidus).","pos":""}],"LEATHERWOOD":[{"def":"A small branching shrub (Dirca palustris), with a white, soft wood, and a tough, leathery bark, common in damp woods in the Northern United States; -- called also moosewood, and wicopy.","pos":""}],"LEATHERY":[{"def":"Resembling leather in appearance or consistence; tough.","pos":""}],"LEAVE":[{"def":"To send out leaves; to leaf; -- often with out.","pos":""}],"LEAVE-TAKING":[{"def":"Taking of leave; parting compliments.","pos":""}],"LEAVED":[{"def":"Bearing, or having, a leaf or leaves; having folds; -- used in combination; as, a four-leaved clover; a two-leaved gate; long- leaved.","pos":""}],"LEAVEN":[{"def":"Any substance that produces, or is designed to produce, fermentation, as in dough or liquids; esp.","pos":""},{"def":"Anything which makes a general assimilating (especially a corrupting) change in the mass.","pos":""}],"LEAVENING":[{"def":"The act of making light, or causing to ferment, by means of leaven.","pos":""},{"def":"That which leavens or makes light.","pos":""}],"LEAVENOUS":[{"def":"Containing leaven.","pos":""}],"LEAVER":[{"def":"One who leaves, or withdraws.","pos":""}],"LEAVINGS":[{"def":"Things left; remnants; relics.","pos":""}],"LEAVY":[{"def":"Coagulated sour milk diluted with water; -- a common beverage among the Arabs.","pos":""}]}