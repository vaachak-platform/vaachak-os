{"COME":[{"def":"To move hitherward; to draw near; to approach the speaker, or some place or person indicated; -- opposed to go.","pos":""},{"def":"To complete a movement toward a place; to arrive.","pos":""}],"COME-ALONG":[{"def":"A gripping device, as for stretching wire, etc.","pos":""}],"COME-OUTER":[{"def":"One who comes out or withdraws from a religious or other organization; a radical reformer.","pos":""}],"COMEDIAN":[{"def":"An actor or player in comedy.","pos":""},{"def":"A writer of comedy.","pos":""}],"COMEDIENNE":[{"def":"A women who plays in comedy.","pos":""}],"COMEDIETTA":[{"def":"A dramatic sketch; a brief comedy.","pos":""}],"COMEDO":[{"def":"A small nodule or cystic tumor, common on the nose, etc.","pos":""}],"COMEDOWN":[{"def":"A downfall; an humillation.","pos":""}],"COMEDY":[{"def":"A dramatic composition, or representation of a bright and amusing character, based upon the foibles of individuals, the manners of society, or the ludicrous events or accidents of life; a play in which mirth predominates and the termination of the plot is happy; -- opposed to tragedy.","pos":""}],"COMELILY":[{"def":"In a suitable or becoming manner.","pos":""}],"COMELINESS":[{"def":"The quality or state of being comely.","pos":""}],"COMELY":[{"def":"Pleasing or agreeable to the sight; well-proportioned; good- looking; handsome.","pos":""},{"def":"Suitable or becoming; proper; agreeable.","pos":""}],"COMER":[{"def":"One who comes, or who has come; one who has arrived, and is present.","pos":""}],"COMES":[{"def":"The answer to the theme (dux) in a fugue.","pos":""}],"COMESSATION":[{"def":"A reveling; a rioting.","pos":""}],"COMESTIBLE":[{"def":"Suitable to be eaten; eatable; esculent.","pos":""}],"COMET":[{"def":"A member of the solar system which usually moves in an elongated orbit, approaching very near to the sun in its perihelion, and receding to a very great distance from it at its aphelion.","pos":""}],"COMETARIUM":[{"def":"An instrument, intended to represent the revolution of a comet round the sun.","pos":""}],"COMETARY":[{"def":"Pertaining to, or resembling, a comet.","pos":""},{"def":"A telescope of low power, having a large field of view, used for finding comets.","pos":""}],"COMETHER":[{"def":"Defn: Matter; affair.","pos":""},{"def":"Friendly communication or association.","pos":""}],"COMETIC":[{"def":"Relating to a comet.","pos":""}],"COMETOGRAPHER":[{"def":"One who describes or writes about comets.","pos":""}],"COMETOGRAPHY":[{"def":"A description of, or a treatise concerning, comets.","pos":""}],"COMETOLOGY":[{"def":"The department of astronomy relating to comets.","pos":""}]}