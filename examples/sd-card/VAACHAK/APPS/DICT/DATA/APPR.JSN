{"APPRAISABLE":[{"def":"Capable of being appraised.","pos":""}],"APPRAISAL":[{"def":"A valuation by an authorized person; an appraisement.","pos":""}],"APPRAISE":[{"def":"To set a value; to estimate the worth of, particularly by persons appointed for the purpose; as, to appraise goods and chattels.","pos":""},{"def":"To estimate; to conjecture.","pos":""}],"APPRAISEMENT":[{"def":"The act of setting the value; valuation by an appraiser; estimation of worth.","pos":""}],"APPRAISER":[{"def":"One who appraises; esp.","pos":""}],"APPRECATION":[{"def":"Earnest prayer; devout wish.","pos":""}],"APPRECATORY":[{"def":"Praying or wishing good.","pos":""}],"APPRECIABLE":[{"def":"Capable of being appreciated or estimated; large enough to be estimated; perceptible; as, an appreciable quantity.","pos":""}],"APPRECIATE":[{"def":"To set a price or value on; to estimate justly; to value.","pos":""},{"def":"To raise the value of; to increase the market price of; -- opposed to depreciate.","pos":""}],"APPRECIATINGLY":[{"def":"In an appreciating manner; with appreciation.","pos":""}],"APPRECIATION":[{"def":"A just valuation or estimate of merit, worth, weight, etc.","pos":""},{"def":"Accurate perception; true estimation; as, an appreciation of the difficulties before us; an appreciation of colors.","pos":""}],"APPRECIATIVE":[{"def":"Having or showing a just or ready appreciation or perception; as, an appreciative audience.","pos":""}],"APPRECIATIVENESS":[{"def":"The quality of being appreciative; quick recognition of excellence.","pos":""}],"APPRECIATOR":[{"def":"One who appreciates.","pos":""}],"APPRECIATORY":[{"def":"Showing appreciation; appreciative; as, appreciatory commendation.","pos":""}],"APPREHEND":[{"def":"To take or seize; to take hold of.","pos":""},{"def":"Hence: To take or seize (a person) by legal process; to arrest; as, to apprehend a criminal.","pos":""}],"APPREHENDER":[{"def":"One who apprehends.","pos":""}],"APPREHENSIBIITY":[{"def":"The quality of being apprehensible.","pos":""}],"APPREHENSIBLE":[{"def":"Capable of being apprehended or conceived.","pos":""}],"APPREHENSION":[{"def":"The act of seizing or taking hold of; seizure; as, the hand is an organ of apprehension.","pos":""},{"def":"The act of seizing or taking by legal process; arrest; as, the felon, after his apprehension, escaped.","pos":""}],"APPREHENSIVE":[{"def":"Capable of apprehending, or quick to do so; apt; discerning.","pos":""},{"def":"Knowing; conscious; cognizant.","pos":""}],"APPREHENSIVELY":[{"def":"In an apprehensive manner; with apprehension of danger.","pos":""}],"APPREHENSIVENESS":[{"def":"The quality or state of being apprehensive.","pos":""}],"APPRENTICE":[{"def":"A barrister, considered a learner of law till of sixteen years' standing, when he might be called to the rank of serjeant.","pos":""}],"APPRENTICESHIP":[{"def":"Pressed close to, or lying against, something for its whole length, as against a stem, Gray.","pos":""}],"APPRISE":[{"def":"To give notice, verbal or written; to inform; -- followed by of; as, we will apprise the general of an intended attack; he apprised the commander of what he had done.","pos":""}],"APPRIZE":[{"def":"To appraise; to value; to appreciate.","pos":""}],"APPRIZER":[{"def":"A creditor for whom an appraisal is made.","pos":""}],"APPROACH":[{"def":"To come or go near, in place or time; to draw nigh; to advance nearer.","pos":""},{"def":"To draw near, in a figurative sense; to make advances; to approximate; as, he approaches to the character of the ablest statesman.","pos":""}],"APPROACHABILITY":[{"def":"The quality of being approachable; approachableness.","pos":""}],"APPROACHABLE":[{"def":"Capable of being approached; accessible; as, approachable virtue.","pos":""}],"APPROACHABLENESS":[{"def":"The quality or state of being approachable; accessibility.","pos":""}],"APPROACHER":[{"def":"One who approaches.","pos":""}],"APPROACHING":[{"def":"The act of ingrafting a sprig or shoot of one tree into another, without cutting it from the parent stock; -- called, also, inarching and grafting by approach.","pos":""}],"APPROACHLESS":[{"def":"Impossible to be approached.","pos":""}],"APPROBATE":[{"def":"To express approbation of; to approve; to sanction officially.","pos":""}],"APPROBATION":[{"def":"Proof; attestation.","pos":""},{"def":"The act of approving; an assenting to the propriety of a thing with some degree of pleasure or satisfaction; approval; sanction; commendation.","pos":""}],"APPROBATIVE":[{"def":"Approving, or implying approbation.","pos":""}],"APPROBATIVENESS":[{"def":"Love of approbation.","pos":""}],"APPROBATOR":[{"def":"One who approves.","pos":""}],"APPROBATORY":[{"def":"Containing or expressing approbation; commendatory.","pos":""}],"APPROMT":[{"def":"To quicken; to prompt.","pos":""}],"APPROOF":[{"def":"Approval; commendation.","pos":""}],"APPROPINQUATION":[{"def":"A drawing nigh; approach.","pos":""}],"APPROPINQUITY":[{"def":"Nearness; propinquity.","pos":""}],"APPROPRIABLE":[{"def":"Capable of being appropriated, set apart, sequestered, or assigned exclusively to a particular use.","pos":""}],"APPROPRIAMENT":[{"def":"What is peculiarly one's own; peculiar qualification.","pos":""}],"APPROPRIATE":[{"def":"Set apart for a particular use or person.","pos":""}],"APPROPRIATELY":[{"def":"In an appropriate or proper manner; fitly; properly.","pos":""}],"APPROPRIATENESS":[{"def":"The state or quality of being appropriate; peculiar fitness.","pos":""}],"APPROPRIATION":[{"def":"The act of setting apart or assigning to a particular use or person, or of taking to one's self, in exclusion of all others; application to a special use or purpose, as of a piece of ground for a park, or of money to carry out some object.","pos":""},{"def":"Anything, especially money, thus set apart.","pos":""}],"APPROPRIATIVE":[{"def":"Appropriating; making, or tending to, appropriation; as, an appropriative act.","pos":""}],"APPROPRIATOR":[{"def":"A spiritual corporation possessed of an appropriated benefice; also, an impropriator.","pos":""}],"APPROVABLE":[{"def":"Worthy of being approved; meritorious.","pos":""}],"APPROVAL":[{"def":"Approbation; sanction.","pos":""}],"APPROVE":[{"def":"To show to be real or true; to prove.","pos":""},{"def":"To make proof of; to demonstrate; to prove or show practically.","pos":""}],"APPROVEDLY":[{"def":"So as to secure approbation; in an approved manner.","pos":""}],"APPROVEMENT":[{"def":"a confession of guilt by a prisoner charged with treason or felony, together with an accusation of his accomplish and a giving evidence against them in order to obtain his own pardon.","pos":""}],"APPROVER":[{"def":"One who confesses a crime and accuses another.","pos":""}],"APPROVING":[{"def":"Expressing approbation; commending; as, an approving smile.","pos":""}],"APPROXIMATE":[{"def":"Approaching; proximate; nearly resembling.","pos":""},{"def":"Near correctness; nearly exact; not perfectly accurate; as, approximate results or values.","pos":""}],"APPROXIMATELY":[{"def":"With approximation; so as to approximate; nearly.","pos":""}],"APPROXIMATION":[{"def":"The act of approximating; a drawing, advancing or being near; approach; also, the result of approximating.","pos":""},{"def":"An approach to a correct estimate, calculation, or conception, or to a given quantity, quality, etc.","pos":""}],"APPROXIMATIVE":[{"def":"Approaching; approximate.","pos":""}],"APPROXIMATOR":[{"def":"One who, or that which, approximates.","pos":""}]}