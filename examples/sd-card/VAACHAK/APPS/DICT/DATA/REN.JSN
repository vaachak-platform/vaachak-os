{"RENABLE":[{"def":"Reasonable; also, loquacious.","pos":""}],"RENAISSANCE":[{"def":"A new birth, or revival.","pos":""}],"RENAISSANT":[{"def":"Of or pertaining to the Renaissance.","pos":""}],"RENAL":[{"def":"Of or pertaining to the kidneys; in the region of the kidneys.","pos":""}],"RENAL-PORTAL":[{"def":"Both renal and portal.","pos":""}],"RENAME":[{"def":"To give a new name to.","pos":""}],"RENARD":[{"def":"A fox; -- so called in fables or familiar tales, and in poetry.","pos":""}],"RENARDINE":[{"def":"Of or pertaining to Renard, the fox, or the tales in which Renard is mentioned.","pos":""}],"RENASCENCE":[{"def":"The state of being renascent.","pos":""},{"def":"Same as Renaissance.","pos":""}],"RENASCENCY":[{"def":"State of being renascent.","pos":""}],"RENASCENT":[{"def":"Springing or rising again into being; being born again, or reproduced.","pos":""}],"RENASCIBLE":[{"def":"Capable of being reproduced; ablle to spring again into being.","pos":""}],"RENATE":[{"def":"Born again; regenerate; renewed.","pos":""}],"RENAVIGATE":[{"def":"To navigate again.","pos":""}],"RENAY":[{"def":"To deny; to disown.","pos":""}],"RENCONTRE":[{"def":"Same as Rencounter, n.","pos":""}],"RENCOUNTER":[{"def":"To meet unexpectedly; to encounter.","pos":""},{"def":"To attack hand to hand.","pos":""}],"REND":[{"def":"To separate into parts with force or sudden violence; to tear asunder; to split; to burst; as, powder rends a rock in blasting; lightning rends an oak.","pos":""},{"def":"To part or tear off forcibly; to take away by force.","pos":""}],"RENDER":[{"def":"To return; to pay back; to restore.","pos":""},{"def":"To inflict, as a retribution; to requite.","pos":""}],"RENDERABLE":[{"def":"Capable of being rendered.","pos":""}],"RENDERER":[{"def":"One who renders.","pos":""},{"def":"A vessel in which lard or tallow, etc.","pos":""}],"RENDERING":[{"def":"The act of one who renders, or that which is rendered.","pos":""}],"RENDEZVOUS":[{"def":"A place appointed for a meeting, or at which persons customarily meet.","pos":""},{"def":"Especially, the appointed place for troops, or for the ships of a fleet, to assemble; also, a place for enlistment.","pos":""}],"RENDIBLE":[{"def":"Capable of being rent or torn.","pos":""}],"RENDITION":[{"def":"The act of rendering; especially, the act of surrender, as of fugitives from justice, at the claim of a foreign government; also, surrender in war.","pos":""},{"def":"Translation; rendering; version.","pos":""}],"RENDROCK":[{"def":"A kind of dynamite used in blasting.","pos":""}],"RENEGADE":[{"def":"One faithless to principle or party.","pos":""}],"RENEGADO":[{"def":"Ren`e*ga\"do (rn`-g\"d), n.","pos":""}],"RENEGAT":[{"def":"Ren\"e*gat (rn\"-gt), n.","pos":""}],"RENEGATION":[{"def":"Ren`e*ga\"tion (rn`-ga\"shn), n.","pos":""}],"RENEGE":[{"def":"To deny; to disown.","pos":""}],"RENERVE":[{"def":"To nerve again; to give new vigor to; to reinvigorate.","pos":""}],"RENEW":[{"def":"To make new spiritually; to regenerate.","pos":""}],"RENEWABILITY":[{"def":"The quality or state of being renewable.","pos":""}],"RENEWABLE":[{"def":"Capable of being renewed; as, a lease renewable at pleasure.","pos":""}],"RENEWAL":[{"def":"The act of renewing, or the state of being renewed; as, the renewal of a treaty.","pos":""}],"RENEWEDLY":[{"def":"Again; once more.","pos":""}],"RENEWEDNESS":[{"def":"The state of being renewed.","pos":""}],"RENEWER":[{"def":"One who, or that which, renews.","pos":""}],"RENEYE":[{"def":"To deney; to reject; to renounce.","pos":""}],"RENG":[{"def":"A rung or round of a ladder.","pos":""}],"RENIDIFICATION":[{"def":"The act of rebuilding a nest.","pos":""}],"RENIFORM":[{"def":"Having the form or shape of a kidney; as, a reniform mineral; a reniform leaf.","pos":""},{"def":"The state or quality of being renitent; resistance; reluctance.","pos":""}],"RENITENT":[{"def":"Resisting pressure or the effect of it; acting against impluse by elastic force.","pos":""},{"def":"Persistently opposed.","pos":""}],"RENNE":[{"def":"To plunder; -- only in the phrase \"to rape and renne.","pos":""}],"RENNET":[{"def":"A name of many different kinds of apples.","pos":""}],"RENNETED":[{"def":"Provided or treated with rennet.","pos":""}],"RENNETING":[{"def":"Same as 1st Rennet.","pos":""}],"RENNING":[{"def":"Asses' milk is holden for to be thickest, and therefore they use it instead of renning, to turn milk.","pos":""}],"RENOMEE":[{"def":"Re`no*mee\" (r`n-m\"), n.","pos":""}],"RENOUNCE":[{"def":"To disclaim having a card of (the suit led) by playing a card of another suit.","pos":""}],"RENOUNCEMENT":[{"def":"The act of disclaiming or rejecting; renunciation.","pos":""}],"RENOUNCER":[{"def":"One who renounces.","pos":""}],"RENOVATE":[{"def":"To make over again; to restore to freshness or vigor; to renew.","pos":""}],"RENOVATION":[{"def":"The act or process of renovating; the state of being renovated or renewed.","pos":""}],"RENOVATOR":[{"def":"One who, or that which, renovates.","pos":""}],"RENOVEL":[{"def":"To renew; to renovate.","pos":""}],"RENOVELANCE":[{"def":"Re*nov\"el*ance (-ans), n.","pos":""}],"RENOWME":[{"def":"Re*nowme\" (r-noum\"), n.","pos":""}],"RENOWMED":[{"def":"Re*nowmed\" (r-noumd\"), a.","pos":""}],"RENOWN":[{"def":"The state of being much known and talked of; exalted reputation derived from the extensive praise of great achievements or accomplishments; fame; celebrity; -- always in a good sense.","pos":""},{"def":"Report of nobleness or exploits; praise.","pos":""}],"RENOWNED":[{"def":"Famous; celebrated for great achievements, for distinguished qualities, or for grandeur; eminent; as, a renowned king.","pos":""}],"RENOWNEDLY":[{"def":"Re*nown\"ed*ly (r-noun\"d-l), adv.","pos":""}],"RENOWNER":[{"def":"One who gives renown.","pos":""}],"RENOWNFUL":[{"def":"Having great renown; famous.","pos":""}],"RENOWNLESS":[{"def":"Without renown; inglorius.","pos":""}],"RENSSELAERITE":[{"def":"A soft, compact variety of talc,, being an altered pyroxene.","pos":""}],"RENT":[{"def":"An opening made by rending; a break or breach made by force; a tear.","pos":""},{"def":"Figuratively, a schim; a rupture of harmony; a separation; as, a rent in the church.","pos":""}],"RENTABLE":[{"def":"Capable of being rented, or suitable for renting.","pos":""}],"RENTAL":[{"def":"A schedule, account, or list of rents, with the names of the tenants, etc.","pos":""},{"def":"A sum total of rents; as, an estate that yields a rental of ten thousand dollars a year.","pos":""}],"RENTE":[{"def":"In France, interest payable by government on indebtedness; the bonds, shares, stocks, etc.","pos":""}],"RENTER":[{"def":"One who rents or leases an estate; -- usually said of a lessee or tenant.","pos":""}],"RENTERER":[{"def":"One who renters.","pos":""}],"RENTIER":[{"def":"One who has a fixed income, as from lands, stocks, or the like.","pos":""}],"RENUMERATE":[{"def":"Re*nu\"mer*ate (r-n\"mr-t), v.","pos":""}],"RENUNCIATION":[{"def":"Formal declination to take out letters of administration, or to assume an office, privilege, or right.","pos":""}],"RENUNCIATORY":[{"def":"Pertaining to renunciation; containing or declaring a renunciation; as, renunciatory vows.","pos":""}],"RENVERSE":[{"def":"Reversed; set with the head downward; turned contrary to the natural position.","pos":""}],"RENVERSEMENT":[{"def":"Ren*verse\"ment (-ment), n.","pos":""}]}