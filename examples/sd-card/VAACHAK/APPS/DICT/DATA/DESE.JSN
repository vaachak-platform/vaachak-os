{"DESECATE":[{"def":"To cut, as with a scythe; to mow.","pos":""}],"DESECRATE":[{"def":"To divest of a sacred character or office; to divert from a sacred purpose; to violate the sanctity of; to profane; to put to an unworthy use; -- the opposite of consecrate.","pos":""}],"DESECRATER":[{"def":"One who desecrates; a profaner.","pos":""}],"DESECRATION":[{"def":"The act of desecrating; profanation; condition of anything desecrated.","pos":""}],"DESECRATOR":[{"def":"One who desecrates.","pos":""}],"DESEGMENTATION":[{"def":"The loss or obliteration of division into segments; as, a desegmentation of the body.","pos":""}],"DESERT":[{"def":"That which is deserved; the reward or the punishment justly due; claim to recompense, usually in a good sense; right to reward; merit.","pos":""}],"DESERTER":[{"def":"One who forsakes a duty, a cause or a party, a friend, or any one to whom he owes service; especially, a soldier or a seaman who abandons the service without leave; one guilty of desertion.","pos":""}],"DESERTION":[{"def":"The act of deserting or forsaking; abandonment of a service, a cause, a party, a friend, or any post of duty; the quitting of one's duties willfully and without right; esp.","pos":""},{"def":"The state of being forsaken; desolation; as, the king in his desertion.","pos":""}],"DESERTNESS":[{"def":"A deserted condition.","pos":""},{"def":"A feminine deserter.","pos":""}],"DESERVE":[{"def":"To earn by service; to be worthy of (something due, either good or evil); to merit; to be entitled to; as, the laborer deserves his wages; a work of value deserves praise.","pos":""},{"def":"To serve; to treat; to benefit.","pos":""}],"DESERVEDLY":[{"def":"According to desert (whether good or evil); justly.","pos":""}],"DESERVEDNESS":[{"def":"Meritoriousness.","pos":""}],"DESERVER":[{"def":"One who deserves.","pos":""}],"DESERVING":[{"def":"A person of great deservings from the republic.","pos":""}]}