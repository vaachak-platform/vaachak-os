{"COSCINOMANCY":[{"def":"Divination by means of a suspended sieve.","pos":""}],"COSCOROBA":[{"def":"A large, white, South American duck, of the genus Cascoroba, resembling a swan.","pos":""}],"COSECANT":[{"def":"The secant of the complement of an arc or angle.","pos":""}],"COSENAGE":[{"def":"Cos\"en*age (kz\"'n-j), n.","pos":""}],"COSENING":[{"def":"Anything done deceitfully, and which could not be properly designated by any special name, whether belonging to contracts or not.","pos":""}],"COSENTIENT":[{"def":"Perceiving together.","pos":""}],"COSHER":[{"def":"To levy certain exactions or tribute upon; to lodge and eat at the expense of.","pos":""}],"COSHERER":[{"def":"One who coshers.","pos":""}],"COSHERING":[{"def":"A feudal prerogative of the lord of the soil entitling him to lodging and food at his tenant's house.","pos":""}],"COSIER":[{"def":"A tailor who botches his work.","pos":""}],"COSIGNIFICATIVE":[{"def":"Having the same signification.","pos":""}],"COSIGNITARY":[{"def":"Signing some important public document with another or with others; as, a treaty violated by one of the cosignitary powers.","pos":""}],"COSILY":[{"def":"Co\"si*ly (k\"z-l), adv.","pos":""}],"COSINAGE":[{"def":"Cos\"in*age (ks\"'n-j), n.","pos":""}],"COSINE":[{"def":"The sine of the complement of an arc or angle.","pos":""},{"def":"Imparting or improving beauty, particularly the beauty of the complexion; as, a cosmetical preparation.","pos":""}],"COSMETIC":[{"def":"Any external application intended to beautify and improve the complexion.","pos":""},{"def":"Rising or setting with the sun; -- the opposite of acronycal.","pos":""}],"COSMICALLY":[{"def":"Belonging to cosmogony.","pos":""}],"COSMOGONIST":[{"def":"One who treats of the origin of the universe; one versed in cosmogony.","pos":""}],"COSMOGONY":[{"def":"The creation of the world or universe; a theory or account of such creation; as, the poetical cosmogony of Hesoid; the cosmogonies of Thales, Anaxagoras, and Plato.","pos":""}],"COSMOGRAPHER":[{"def":"One who describes the world or universe, including the heavens and the earth.","pos":""},{"def":"Of or pertaining to cosmography.","pos":""}],"COSMOGRAPHICALLY":[{"def":"In a cosmographic manner; in accordance with cosmography.","pos":""}],"COSMOGRAPHY":[{"def":"A description of the world or of the universe; or the science which teaches the constitution of the whole system of worlds, or the figure, disposition, and relation of all its parts.","pos":""}],"COSMOLABE":[{"def":"An instrument resembling the astrolabe, formerly used for measuring the angles between heavenly bodies; -- called also pantacosm.","pos":""}],"COSMOLATRY":[{"def":"Worship paid to the world.","pos":""}],"COSMOLINE":[{"def":"A substance obtained from the residues of the distillation of petroleum, essentially the same as vaseline, but of somewhat stiffer consistency, and consisting of a mixture of the higher paraffines; a kind of petroleum jelly.","pos":""}],"COSMOLOGICAL":[{"def":"Of or pertaining to cosmology.","pos":""}],"COSMOLOGIST":[{"def":"One who describes the universe; one skilled in cosmology.","pos":""}],"COSMOLOGY":[{"def":"The science of the world or universe; or a treatise relating to the structure and parts of the system of creation, the elements of bodies, the modifications of material things, the laws of motion, and the order and course of nature.","pos":""}],"COSMOMETRY":[{"def":"The art of measuring the world or the universe.","pos":""}],"COSMOPLASTIC":[{"def":"Pertaining to a plastic force as operative in the formation of the world independently of God; world-forming.","pos":""},{"def":"One who has no fixed residence, or who is at home in every place; a citizen of the world.","pos":""}],"COSMOPOLITANISM":[{"def":"The quality of being cosmopolitan; cosmopolitism.","pos":""}],"COSMOPOLITE":[{"def":"See Cosmopolitan.","pos":""}],"COSMOPOLITICAL":[{"def":"Having the character of a cosmopolite.","pos":""}],"COSMOPOLITISM":[{"def":"The condition or character of a cosmopolite; disregard of national or local peculiarities and prejudices.","pos":""}],"COSMORAMA":[{"def":"An exhibition in which a series of views in various parts of the world is seen reflected by mirrors through a series of lenses, with such illumination, etc.","pos":""}],"COSMORAMIC":[{"def":"Of or pertaining to a cosmorama.","pos":""}],"COSMOS":[{"def":"The universe or universality of created things; -- so called from the order and harmony displayed in it.","pos":""},{"def":"The theory or description of the universe, as a system displaying order and harmony.","pos":""}],"COSMOSPHERE":[{"def":"An apparattus for showing the position of the earth, at any given time, with respect to the fixed stars.","pos":""}],"COSMOTHEISM":[{"def":"Same as Pantheism.","pos":""}],"COSMOTHETIC":[{"def":"Assuming or positing the actual existence or reality of the physical or external world.","pos":""}],"COSOVEREIGN":[{"def":"A joint sovereign.","pos":""}],"COSS":[{"def":"A Hindoo measure of distance, varying from one and a half to two English miles.","pos":""}],"COSSACK":[{"def":"One of a warlike, pastoral people, skillful as horsemen, inhabiting different parts of the Russian empire and furnishing valuable contingents of irregular cavalry to its armies, those of Little Russia and those of the Don forming the principal divisions.","pos":""}],"COSSACK POST":[{"def":"An outpost consisting of four men, forming one of a single line of posts substituted for the more formal line of sentinels and line of pickets.","pos":""}],"COSSAS":[{"def":"Plain India muslin, of various qualities and widths.","pos":""}],"COSSET":[{"def":"A lamb reared without the aid of the dam.","pos":""}],"COSSETTE":[{"def":"One of the small chips or slices into which beets are cut in sugar making.","pos":""},{"def":"Of or relating to algebra; as, cossic numbers, or the cossic art.","pos":""}],"COST":[{"def":"A rib; a side; a region or coast.","pos":""}],"COSTA":[{"def":"A rib of an animal or a human being.","pos":""},{"def":"A rib or vein of a leaf, especially the midrib.","pos":""}],"COSTAGE":[{"def":"Cost\"age (kst\"j; 115), n.","pos":""}],"COSTAL":[{"def":"Pertaining to the ribs or the sides of the body; as, costal nerves.","pos":""},{"def":"Relating to a costa, or rib.","pos":""}],"COSTAL-NERVED":[{"def":"Having the nerves spring from the midrib.","pos":""}],"COSTARD":[{"def":"An apple, large and round like the head.","pos":""},{"def":"The head; -- used contemptuously.","pos":""}],"COSTARDMONGER":[{"def":"Having ribs, or the appearance of ribs; (Bot.","pos":""}],"COSTEAN":[{"def":"To search after lodes.","pos":""}],"COSTEANING":[{"def":"The process by which miners seek to discover metallic lodes.","pos":""}],"COSTELLATE":[{"def":"Finely ribbed or costated.","pos":""}],"COSTER":[{"def":"One who hawks about fruit, green vegetables, fish, etc.","pos":"noun"}],"COSTERMONGER":[{"def":"An apple seller; a hawker of, or dealer in, any kind of fruit or vegetables; a fruiterer.","pos":""}],"COSTIFEROUS":[{"def":"Rib-bearing, as the dorsal vertebræ.","pos":""}],"COSTIVE":[{"def":"Retaining fecal matter in the bowels; having too slow a motion of the bowels; constipated.","pos":""},{"def":"Reserved; formal; close; cold.","pos":""}],"COSTIVELY":[{"def":"In a costive manner.","pos":""}],"COSTIVENESS":[{"def":"An unnatural retention of the fecal matter of the bowels; constipation.","pos":""},{"def":"Inability to express one's self; stiffness.","pos":""}],"COSTLESS":[{"def":"Costing nothing.","pos":""}],"COSTLINESS":[{"def":"The quality of being costy; expensiveness; sumptuousness.","pos":""}],"COSTLY":[{"def":"Of great cost; expensive; dear.","pos":""},{"def":"Gorgeous; sumptuous.","pos":""}],"COSTMARY":[{"def":"A garden plant (Chrysanthemum Balsamita) having a strong balsamic smell, and nearly allied to tansy.","pos":""}],"COSTON LIGHTS":[{"def":"Signals made by burning lights of different colors and used by vessels at sea, and in the life-saving service; -- named after their inventor.","pos":""}],"COSTOTOME":[{"def":"An instrument (chisel or shears) to cut the ribs and open the thoracic cavity, in post-mortem examinations and dissections.","pos":""}],"COSTREL":[{"def":"A bottle of leather, earthenware, or wood, having ears by which it was suspended at the side.","pos":""}],"COSTUME":[{"def":"Dress in general; esp.","pos":""},{"def":"Such an arrangement of accessories, as in a picture, statue, poem, or play, as is appropriate to the time, place, or other circumstances represented or described.","pos":""}],"COSTUMER":[{"def":"One who makes or deals in costumes, as for theaters, fancy balls, etc.","pos":""}],"COSUPREME":[{"def":"A partaker of supremacy; one jointly supreme.","pos":""}],"COSURETY":[{"def":"One who is surety with another.","pos":""}]}