{"PROBABILIORISM":[{"def":"The doctrine of the probabiliorists.","pos":""}],"PROBABILIORIST":[{"def":"One who holds, in opposition to the probabilists, that a man is bound to do that which is most probably right.","pos":""}],"PROBABILISM":[{"def":"The doctrine of the probabilists.","pos":""}],"PROBABILIST":[{"def":"One who maintains that a man may do that which has a probability of being right, or which is inculcated by teachers of authority, although other opinions may seem to him still more probable.","pos":""}],"PROBABILITY":[{"def":"Likelihood of the occurrence of any event in the doctrine of chances, or the ratio of the number of favorable chances to the whole number of chances, favorable and unfavorable.","pos":""}],"PROBABLE":[{"def":"Capable of being proved.","pos":""},{"def":"Having more evidence for than against; supported by evidence which inclines the mind to believe, but leaves some room for doubt; likely.","pos":""}],"PROBABLY":[{"def":"In a probable manner; in likelihood.","pos":""}],"PROBAL":[{"def":"Approved; probable.","pos":""}],"PROBANG":[{"def":"A slender elastic rod, as of whalebone, with a sponge on the end, for removing obstructions from the esophagus, etc.","pos":""}],"PROBATE":[{"def":"Of or belonging to a probate, or court of probate; as, a probate record.","pos":""}],"PROBATION":[{"def":"The act of proving; also, that which proves anything; proof.","pos":""},{"def":"Any proceeding designed to ascertain truth, to determine character, qualification, etc.","pos":""}],"PROBATIONARY":[{"def":"Of or pertaining to probation; serving for trial.","pos":""}],"PROBATIONER":[{"def":"One who is undergoing probation; one who is on trial; a novice.","pos":""},{"def":"A student in divinity, who, having received certificates of good morals and qualifications from his university, is admitted to several trials by a presbytery, and, on acquitting himself well, is licensed to preach.","pos":""}],"PROBATIONERSHIP":[{"def":"The state of being a probationer; novitiate.","pos":""}],"PROBATIONSHIP":[{"def":"A state of probation.","pos":""}],"PROBATIVE":[{"def":"Serving for trial or proof; probationary; as, probative judgments; probative evidence.","pos":""}],"PROBATOR":[{"def":"One who, when indicted for crime, confessed it, and accused others, his accomplices, in order to obtain pardon; a state's evidence.","pos":""}],"PROBATORY":[{"def":"Serving for trial; probationary.","pos":""},{"def":"Pertaining to, or serving for, proof.","pos":""}],"PROBE":[{"def":"To examine, as a wound, an ulcer, or some cavity of the body, with a probe.","pos":""}],"PROBE-POINTED":[{"def":"Having a blunt or button-shaped extremity; -- said of cutting instruments.","pos":""}],"PROBITY":[{"def":"Tried virtue or integrity; approved moral excellence; honesty; rectitude; uprightness.","pos":""}],"PROBLEM":[{"def":"Anything which is required to be done; as, in geometry, to bisect a line, to draw a perpendicular; or, in algebra, to find an unknown quantity.","pos":""},{"def":"Having the nature of a problem; not shown in fact; questionable; uncertain; unsettled; doubtful.","pos":""}],"PROBLEMATIST":[{"def":"One who proposes problems.","pos":""}],"PROBLEMATIZE":[{"def":"To propose problems.","pos":""}],"PROBOSCIDATE":[{"def":"Having a proboscis; proboscidial.","pos":""}],"PROBOSCIDIAN":[{"def":"Pertaining to the Proboscidea.","pos":""},{"def":"One of the Proboscidea.","pos":""}],"PROBOSCIDIFERA":[{"def":"An extensive division of pectinibranchiate gastropods, including those that have a long retractile proboscis, with the mouth at the end, as the cones, whelks, tritons, and cowries.","pos":""},{"def":"A subdivision of the tænioglossate gastropods, including the fig-shells (Pyrula), the helmet shells (Cassis), the tritons, and allied genera.","pos":""}],"PROBOSCIDIFORM":[{"def":"Having the form or uses of a proboscis; as, a proboscidiform mouth.","pos":""}],"PROBOSCIS":[{"def":"A hollow organ or tube attached to the head, or connected with the mouth, of various animals, and generally used in taking food or drink; a snout; a trunk.","pos":""},{"def":"By extension, applied to various tubelike mouth organs of the lower animals that can be everted or protruded.","pos":""}]}