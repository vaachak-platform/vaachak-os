{"GUN":[{"def":"A piece of heavy ordnance; in a restricted sense, a cannon.","pos":""},{"def":"Violent blasts of wind.","pos":""}],"GUNA":[{"def":"In Sanskrit grammar, a lengthening of the simple vowels a, i, e, by prefixing an a element.","pos":""}],"GUNBOAT":[{"def":"A vessel of light draught, carrying one or more guns.","pos":""}],"GUNFLINT":[{"def":"A sharpened flint for the lock of a gun, to ignite the charge.","pos":""}],"GUNLOCK":[{"def":"The lock of a gun, for producing the discharge.","pos":""}],"GUNNAGE":[{"def":"The number of guns carried by a ship of war.","pos":""}],"GUNNEL":[{"def":"A small, eel-shaped, marine fish of the genus Murænoides; esp.","pos":""}],"GUNNER":[{"def":"One who works a gun, whether on land or sea; a cannoneer.","pos":""},{"def":"A warrant officer in the navy having charge of the ordnance on a vessel.","pos":""}],"GUNNERY":[{"def":"That branch of military science which comprehends the theory of projectiles, and the manner of constructing and using ordnance.","pos":""}],"GUNNIE":[{"def":"Space left by the removal of ore.","pos":""}],"GUNNING":[{"def":"The act or practice of hunting or shooting game with a gun.","pos":""},{"def":"A strong, coarse kind of sacking, made from the fibers (called jute) of two plants of the genus Corchorus (C.","pos":""}],"GUNPOWDER":[{"def":"A black, granular, explosive substance, consisting of an intimate mechanical mixture of niter, charcoal, and sulphur.","pos":""}],"GUNREACH":[{"def":"The reach or distance to which a gun will shoot; gunshot.","pos":""}],"GUNROOM":[{"def":"An apartment on the after end of the lower gun deck of a ship of war, usually occupied as a messroom by the commissioned officers, except the captain; -- called wardroom in the United States navy.","pos":""}],"GUNSHOT":[{"def":"Act of firing a gun; a shot.","pos":""},{"def":"The distance to which shot can be thrown from a gun, so as to be effective; the reach or range of a gun.","pos":""}],"GUNSMITH":[{"def":"One whose occupation is to make or repair small firearms; an armorer.","pos":""},{"def":"The art or business of a gunsmith.","pos":""}],"GUNSTICK":[{"def":"A stick to ram down the charge of a musket, etc.","pos":""}],"GUNSTOCK":[{"def":"The stock or wood to which the barrel of a hand gun is fastened.","pos":""}],"GUNSTOME":[{"def":"A cannon ball; -- so called because originally made of stone.","pos":""}],"GUNTER RIG":[{"def":"A topmast arranged with metal bands so that it will readily slide up and down the lower mast.","pos":""}],"GUNTER'S CHAIN":[{"def":"The chain ordinarily used in measuring land.","pos":""}],"GUNTER'S LINE":[{"def":"A logarithmic line on Gunter's scale, used for performing the multiplication and division of numbers mechanically by the dividers; -- called also line of lines, and line of numbers.","pos":""}],"GUNTER'S QUADRANT":[{"def":"A thin quadrant, made of brass, wood, etc.","pos":""}],"GUNTER'S SCALE":[{"def":"A scale invented by the Rev.","pos":""}],"GUNWALE":[{"def":"The upper edge of a vessel's or boat's side; the uppermost wale of a ship (not including the bulwarks); or that piece of timber which reaches on either side from the quarter-deck to the forecastle, being the uppermost bend, which finishes the upper works of the hull.","pos":""}]}