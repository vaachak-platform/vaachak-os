{"EMBODIER":[{"def":"One who embodies.","pos":""}],"EMBODIMENT":[{"def":"The act of embodying; the state of being embodied.","pos":""},{"def":"That which embodies or is embodied; representation in a physical body; a completely organized system, like the body; as, the embodiment of courage, or of courtesy; the embodiment of true piety.","pos":""}],"EMBODY":[{"def":"To form into a body; to invest with a body; to collect into a body, a united mass, or a whole; to incorporate; as, to embody one's ideas in a treatise.","pos":""}],"EMBOGUE":[{"def":"To disembogue; to discharge, as a river, its waters into the sea or another river.","pos":""}],"EMBOGUING":[{"def":"The mouth of a river, or place where its waters are discharged.","pos":""}],"EMBOIL":[{"def":"To boil with anger; to effervesce.","pos":""}],"EMBOITEMENT":[{"def":"The hypothesis that all living things proceed from preëxisting germs, and that these encase the germs of all future living things, inclosed one within another.","pos":""}],"EMBOLDEN":[{"def":"To give boldness or courage to; to encourage.","pos":""}],"EMBOLDENER":[{"def":"One who emboldens.","pos":""}],"EMBOLIC":[{"def":"Pertaining to an embolism; produced by an embolism; as, an embolic abscess.","pos":""},{"def":"Pushing or growing in; -- said of a kind of invagination.","pos":""}],"EMBOLISM":[{"def":"The occlusion of a blood vessel by an embolus.","pos":""}],"EMBOLISMAL":[{"def":"Pertaining to embolism; intercalary; as, embolismal months.","pos":""}],"EMBOLITE":[{"def":"A mineral consisting of both the chloride and the bromide of silver.","pos":""}],"EMBOLUS":[{"def":"A plug of some substance lodged in a blood vessel, being brought thither by the blood current.","pos":""}],"EMBOLY":[{"def":"Embolic invagination.","pos":""}],"EMBONPOINT":[{"def":"Plumpness of person; -- said especially of persons somewhat corpulent.","pos":""}],"EMBORDER":[{"def":"To furnish or adorn with a border; to imborder.","pos":""}],"EMBOSOM":[{"def":"To take into, or place in, the bosom; to cherish; to foster.","pos":""},{"def":"To inclose or surround; to shelter closely; to place in the midst of something.","pos":""}],"EMBOSS":[{"def":"To arise the surface of into bosses or protuberances; particularly, to ornament with raised work.","pos":""},{"def":"To raise in relief from a surface, as an ornament, a head on a coin, or the like.","pos":""}],"EMBOSSED":[{"def":"Formed or covered with bosses or raised figures.","pos":""},{"def":"Having a part projecting like the boss of a shield.","pos":""}],"EMBOSSER":[{"def":"One who embosses.","pos":""}],"EMBOSSMENT":[{"def":"The act of forming bosses or raised figures, or the state of being so formed.","pos":""},{"def":"A bosslike prominence; figure in relief; raised work; jut; protuberance; esp.","pos":""}],"EMBOUCHURE":[{"def":"The mouth of a river; also, the mouth of a cannon.","pos":""}],"EMBOW":[{"def":"To bend like a bow; to curve.","pos":""}],"EMBOWEL":[{"def":"To imbed; to hide in the inward parts; to bury.","pos":""}],"EMBOWELER":[{"def":"One who takes out the bowels.","pos":""}],"EMBOWER":[{"def":"To cover with a bower; to shelter with trees.","pos":""},{"def":"To lodge or rest in a bower.","pos":""}],"EMBOWL":[{"def":"To form like a bowl; to give a globular shape to.","pos":""}],"EMBOX":[{"def":"To inclose, as in a box; to imbox.","pos":""}]}