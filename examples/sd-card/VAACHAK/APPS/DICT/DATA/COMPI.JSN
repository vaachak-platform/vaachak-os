{"COMPILATION":[{"def":"The act or process of compiling or gathering together from various sources.","pos":""},{"def":"That which is compiled; especially, a book or document composed of materials gathering from other books or documents.","pos":""}],"COMPILE":[{"def":"To put together; to construct; to build.","pos":""},{"def":"To contain or comprise.","pos":""}],"COMPILER":[{"def":"One who compiles; esp.","pos":""}],"COMPINGE":[{"def":"To compress; to shut up.","pos":""}]}