{"PION":[{"def":"Parryana, cembroides, edulis, and monophylla, the nut pines of Western North America.","pos":""}],"PIONED":[{"def":"A Shakespearean word of disputed meaning; perh.","pos":""}],"PIONEER":[{"def":"A soldier detailed or employed to form roads, dig trenches, and make bridges, as an army advances.","pos":""}],"PIONEERS' DAY":[{"def":"In Utah, a legal holiday, July 24, commemorated the arrival, in 1847, of Brigham Young and his followers at the present site of Salt Lake City.","pos":""}],"PIOUS":[{"def":"Of or pertaining to piety; exhibiting piety; reverential; dutiful; religious; devout; godly.","pos":""},{"def":"Practiced under the pretext of religion; prompted by mistaken piety; as, pious errors; pious frauds.","pos":""}],"PIOUSLY":[{"def":"In a pious manner.","pos":""}]}