{"CRAZE":[{"def":"To break into pieces; to crush; to grind to powder.","pos":""},{"def":"To weaken; to impair; to render decrepit.","pos":""}],"CRAZEDNESS":[{"def":"A broken state; decrepitude; an impaired state of the intellect.","pos":""},{"def":"A mill for grinding tin ore.","pos":""}],"CRAZILY":[{"def":"In a crazy manner.","pos":""}],"CRAZINESS":[{"def":"The state of being broken down or weakened; as, the craziness of a ship, or of the limbs.","pos":""},{"def":"The state of being broken in mind; imbecility or weakness of intellect; derangement.","pos":""}],"CRAZY":[{"def":"Characterized by weakness or feeblness; decrepit; broken; falling to decay; shaky; unsafe.","pos":""},{"def":"Broken, weakened, or dissordered in intellect; shattered; demented; deranged.","pos":""}]}