{"UNTACK":[{"def":"To separate, as what is tacked; to disjoin; to release.","pos":""}],"UNTACKLE":[{"def":"To unbitch; to unharness.","pos":""}],"UNTALKED":[{"def":"Not talked; not mentioned; -- often with of.","pos":""}],"UNTANGIBILITY":[{"def":"Un*tan`gi*bil\"i*ty, n.","pos":""}],"UNTANGLE":[{"def":"To loose from tangles or intricacy; to disentangle; to resolve; as, to untangle thread.","pos":""}],"UNTAPPICE":[{"def":"to come out of concealment.","pos":""}],"UNTASTE":[{"def":"To deprive of a taste for a thing.","pos":""}],"UNTEACH":[{"def":"To cause to forget, or to lose from memory, or to disbelieve what has been taught.","pos":""},{"def":"To cause to be forgotten; as, to unteach what has been learned.","pos":""}],"UNTEAM":[{"def":"To unyoke a team from.","pos":""}],"UNTEMPER":[{"def":"To deprive of temper, or of the proper degree of temper; to make soft.","pos":""}],"UNTEMPERATELY":[{"def":"Un*tem\"per*ate*ly, adv.","pos":""}],"UNTEMPTER":[{"def":"One who does not tempt, or is not a tempter.","pos":""}],"UNTENANT":[{"def":"To remove a tenant from.","pos":""}],"UNTENT":[{"def":"To bring out of a tent.","pos":""}],"UNTENTED":[{"def":"Having no tent or tents, as a soldier or a field.","pos":""}],"UNTHANK":[{"def":"No thanks; ill will; misfortune.","pos":""}],"UNTHINK":[{"def":"To recall or take back, as something thought.","pos":""}],"UNTHINKER":[{"def":"A person who does not think, or does not think wisely.","pos":""}],"UNTHINKING":[{"def":"Not thinking; not heedful; thoughtless; inconsiderate; as, unthinking youth.","pos":""},{"def":"Not indicating thought or reflection; thoughtless.","pos":""}],"UNTHREAD":[{"def":"To draw or take out a thread from; as, to unthread a needle.","pos":""},{"def":"To deprive of ligaments; to loose the ligaments of.","pos":""}],"UNTHRIFT":[{"def":"Want of thrift; untriftiness; prodigality.","pos":""}],"UNTHRIFTFULLY":[{"def":"Un*thrift\"ful*ly, adv.","pos":""}],"UNTHRIFTILY":[{"def":"Improperly; unbecomingly.","pos":""}],"UNTHRIFTINESS":[{"def":"The quality or state or being unthrifty; profuseness; lavishness.","pos":""}],"UNTHRIFTY":[{"def":"Not thrifty; profuse.","pos":""}],"UNTHRONE":[{"def":"To remove from, or as from, a throne; to dethrone.","pos":""}],"UNTIDY":[{"def":"Unseasonable; untimely.","pos":""},{"def":"Not tidy or neat; slovenly.","pos":""}],"UNTIE":[{"def":"To loosen, as something interlaced or knotted; to disengage the parts of; as, to untie a knot.","pos":""},{"def":"To free from fastening or from restraint; to let loose; to unbind.","pos":""}],"UNTIGHTEN":[{"def":"To make less tight or tense; to loosen.","pos":""}],"UNTIL":[{"def":"To; unto; towards; -- used of material objects.","pos":""},{"def":"To; up to; till; before; -- used of time; as, he staid until evening; he will not come back until the end of the month.","pos":""}],"UNTILE":[{"def":"To take the tiles from; to uncover by removing the tiles.","pos":""}],"UNTIME":[{"def":"An unseasonable time.","pos":""}],"UNTIMELINESS":[{"def":"Unseasonableness.","pos":""}],"UNTIMELY":[{"def":"Not timely; done or happening at an unnatural, unusual, or improper time; unseasonable; premature; inopportune; as, untimely frosts; untimely remarks; an untimely death.","pos":""}],"UNTIMEOUSLY":[{"def":"Untimely; unseasonably.","pos":""}],"UNTITHED":[{"def":"Not subjected tithes.","pos":""}],"UNTITLED":[{"def":"Not titled; having no title, or appellation of dignity or distinction.","pos":""},{"def":"Being without title or right; not entitled.","pos":""}],"UNTO":[{"def":"To; -- now used only in antiquated, formal, or scriptural style.","pos":""}],"UNTOLD":[{"def":"Not told; not related; not revealed; as, untold secrets.","pos":""},{"def":"Not numbered or counted; as, untold money.","pos":""}],"UNTOMB":[{"def":"To take from the tomb; to exhume; to disinter.","pos":""}],"UNTONGUE":[{"def":"To deprive of a tongue, or of voice.","pos":""}],"UNTOOTH":[{"def":"To take out the teeth of.","pos":""}],"UNTOWARD":[{"def":"Froward; perverse.","pos":""},{"def":"Awkward; ungraceful.","pos":""}],"UNTOWARDLY":[{"def":"Perverse; froward; untoward.","pos":""}],"UNTRADED":[{"def":"Not dealt with in trade; not visited for purposes of trade.","pos":""},{"def":"Unpracticed; inexperienced.","pos":""}],"UNTRAINED":[{"def":"Not trainable; indocile.","pos":""}],"UNTRAMMELED":[{"def":"Not hampered or impeded; free.","pos":""}],"UNTRAVELED":[{"def":"Not traveled; not trodden by passengers; as, an untraveled forest.","pos":""},{"def":"Having never visited foreign countries; not having gained knowledge or experience by travel; as, an untraveled Englishman.","pos":""}],"UNTREAD":[{"def":"To tread back; to retrace.","pos":""}],"UNTREASURE":[{"def":"To bring forth or give up, as things previously treasured.","pos":""}],"UNTREASURED":[{"def":"Deprived of treasure.","pos":""},{"def":"Not treasured; not kept as treasure.","pos":""}],"UNTREATABLE":[{"def":"Incapable of being treated; not practicable.","pos":""}],"UNTRENCHED":[{"def":"Being without trenches; whole; intact.","pos":""}],"UNTRESSED":[{"def":"Not tied up in tresses; unarranged; -- said of the hair.","pos":""}],"UNTRUE":[{"def":"Not true; false; contrary to the fact; as, the story is untrue.","pos":""},{"def":"Not faithful; inconstant; false; disloyal.","pos":""}],"UNTRUISM":[{"def":"Something not true; a false statement.","pos":""}],"UNTRUNKED":[{"def":"Separated from its trunk or stock.","pos":""}],"UNTRUSS":[{"def":"To loose from a truss, or as from a truss; to untie or unfasten; to let out; to undress.","pos":""},{"def":"One who untrussed persons for the purpose of flogging them; a public whipper.","pos":""}],"UNTRUSTFUL":[{"def":"Not trustful or trusting.","pos":""},{"def":"Not to be trusted; not trusty.","pos":""}],"UNTRUTH":[{"def":"The quality of being untrue; contrariety to truth; want of veracity; also, treachery; faithlessness; disloyalty.","pos":""},{"def":"That which is untrue; a false assertion; a falsehood; a lie; also, an act of treachery or disloyalty.","pos":""}],"UNTRUTHFUL":[{"def":"Not truthful; unveracious; contrary to the truth or the fact.","pos":""}],"UNTUCK":[{"def":"To unfold or undo, as a tuck; to release from a tuck or fold.","pos":""}],"UNTUNE":[{"def":"To make incapable of harmony, or of harmonious action; to put out of tune.","pos":""}],"UNTURN":[{"def":"To turn in a reserve way, especially so as to open something; as, to unturn a key.","pos":""}],"UNTURNED":[{"def":"Not turned; not revolved or reversed.","pos":""}],"UNTWAIN":[{"def":"To rend in twain; to tear in two.","pos":""}],"UNTWINE":[{"def":"To untwist; to separate, as that which is twined or twisted; to disentangle; to untie.","pos":""}],"UNTWIRL":[{"def":"To untwist; to undo.","pos":""}],"UNTWIST":[{"def":"To separate and open, as twisted threads; to turn back, as that which is twisted; to untwine.","pos":""},{"def":"To untie; to open; to disentangle.","pos":""}]}