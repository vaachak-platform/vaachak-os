{"LIN":[{"def":"To yield; to stop; to cease.","pos":""}],"LINARITE":[{"def":"A hydrous sulphate of lead and copper occurring in bright blue monoclinic crystals.","pos":""}],"LINCH":[{"def":"A ledge; a right-angled projection.","pos":""}],"LINCHI":[{"def":"An esculent swallow.","pos":""}],"LINCHPIN":[{"def":"A pin used to prevent the wheel of a vehicle from sliding off the axletree.","pos":""}],"LINCOLN GREEN":[{"def":"Medicine taken by licking with the tongue.","pos":""}],"LINDIA":[{"def":"A peculiar genus of rotifers, remarkable for the absence of ciliated disks.","pos":""}],"LINDIFORM":[{"def":"Resembling the genus Lindia; -- said of certain apodous insect larvæ.","pos":""}],"LINE":[{"def":"The longer and fiber of flax.","pos":""}],"LINEAGE":[{"def":"Descent in a line from a common progenitor; progeny; race; descending line of offspring or ascending line of parentage.","pos":""}],"LINEAL":[{"def":"Descending in a direct line from an ancestor; hereditary; derived from ancestors; -- opposed to collateral; as, a lineal descent or a lineal descendant.","pos":""},{"def":"Inheriting by direct descent; having the right by direct descent to succeed (to).","pos":""}],"LINEALLY":[{"def":"In a lineal manner; as, the prince is lineally descended from the Conqueror.","pos":""}],"LINEAMENT":[{"def":"One of the outlines, exterior features, or distinctive marks, of a body or figure, particularly of the face; feature; form; mark; - - usually in the plural.","pos":""}],"LINEAR":[{"def":"Like a line; narrow; of the same breadth throughout, except at the extremities; as, a linear leaf.","pos":""}],"LINEAR-SHAPED":[{"def":"Of a linear shape.","pos":""}],"LINEARENSATE":[{"def":"Having the form of a sword, but very long and narrow.","pos":""}],"LINEARLY":[{"def":"In a linear manner; with lines.","pos":""}],"LINEARY":[{"def":"Marked with lines.","pos":""}],"LINEATION":[{"def":"Delineation; a line or lines.","pos":""}],"LINEATURE":[{"def":"Anything having outline.","pos":""}],"LINEMAN":[{"def":"One who carried the line in surveying, etc.","pos":""},{"def":"A man employed to examine the rails of a railroad to see if they are in good condition; also, a man employed to repair telegraph lines.","pos":""}],"LINEN":[{"def":"Made of linen; as, linen cloth; a linen stocking.","pos":""}],"LINENER":[{"def":"A dealer in linen; a linen draper.","pos":""}],"LINEOLATE":[{"def":"Marked with little lines.","pos":""},{"def":"Marked longitudinally with fine lines.","pos":""}],"LINER":[{"def":"A thin piece placed between two parts to hold or adjust them, fill a space, etc.","pos":""},{"def":"A lining within the cylinder, in which the piston works and between which and the outer shell of the cylinder a space is left to form a steam jacket.","pos":""}],"LING":[{"def":"Heather (Calluna vulgaris).","pos":""},{"def":"The phallic symbol under which Siva is principally worshiped in his character of the creative and reproductive power.","pos":""}],"LING-BIRD":[{"def":"The European meadow pipit; -- called also titling.","pos":""}],"LINGEL":[{"def":"A shoemaker's thread.","pos":""},{"def":"A little tongue or thong of leather; a lacing for belts.","pos":""}],"LINGER":[{"def":"To delay; to loiter; to remain or wait long; to be slow or reluctant in parting or moving; to be slow in deciding; to be in suspense; to hesitate.","pos":""}],"LINGERER":[{"def":"One who lingers.","pos":""}],"LINGERIE":[{"def":"Linen goods collectively; linen underwear, esp.","pos":""}],"LINGERING":[{"def":"Drawn out in time; remaining long; protracted; as, a lingering disease.","pos":""}],"LINGERINGLY":[{"def":"With delay; slowly; tediously.","pos":""}],"LINGISM":[{"def":"A mode of treating certain diseases, as obesity, by gymnastics; -- proposed by Pehr Henrik Ling, a Swede.","pos":""}],"LINGO":[{"def":"Language; speech; dialect.","pos":""}],"LINGOA WOOD":[{"def":"Lin*go\"a wood` Defn: .","pos":""}],"LINGOT":[{"def":"A linget or ingot; also, a mold for casting metals.","pos":""}],"LINGUA FRANCA":[{"def":"The commercial language of the Levant, -- a mixture of the language of the people of the region and foreign traders.","pos":""}],"LINGUACIOUS":[{"def":"Given to the use of the tongue; loquacious.","pos":""}],"LINGUADENTAL":[{"def":"Formed or uttered by the joint use of the tongue and teeth, or rather that part of the gum just above the front teeth; dentolingual, as the letters d and t.","pos":""}],"LINGUAL":[{"def":"Of or pertaining to the tongue; uttered by the aid of the tongue; glossal; as, the lingual nerves; a lingual letter.","pos":""}],"LINGUALITY":[{"def":"The quality of being lingual.","pos":""}],"LINGUATULIDA":[{"def":"Same as Linguatulina.","pos":""}],"LINGUATULINA":[{"def":"An order of wormlike, degraded, parasitic arachnids.","pos":""}],"LINGUIFORM":[{"def":"Having the form of the tongue; tongue-shaped.","pos":""}],"LINGUIST":[{"def":"Of or pertaining to language; relating to linguistics, or to the affinities of languages.","pos":""}],"LINGUISTICALLY":[{"def":"In a linguistic manner; from the point of view of a linguist.","pos":""}],"LINGUISTICS":[{"def":"The science of languages, or of the origin, signification, and application of words; glossology.","pos":""}],"LINGULA":[{"def":"A tonguelike process or part.","pos":""},{"def":"Any one of numerous species of brachiopod shells belonging to the genus Lingula, and related genera.","pos":""}],"LINGULATE":[{"def":"Shaped like the tongue or a strap; ligulate.","pos":""}],"LINIGEROUS":[{"def":"Bearing flax; producing linen.","pos":""}],"LINIMENT":[{"def":"A liquid or semiliquid preparation of a consistence thinner than an ointment, applied to the skin by friction, esp.","pos":""}],"LINING":[{"def":"The act of one who lines; the act or process of making lines, or of inserting a lining.","pos":""},{"def":"That which covers the inner surface of anything, as of a garment or a box; also, the contents of anything.","pos":""}],"LINK":[{"def":"A torch made of tow and pitch, or the like.","pos":""}],"LINK MOTION":[{"def":"A valve gear, consisting of two eccentrics with their rods, giving motion to a slide valve by an adjustable connecting bar, called the link, in such a way that the motion of the engine can be reversed, or the cut-off varied, at will; -- used very generally in locomotives and marine engines.","pos":""}],"LINKAGE":[{"def":"Manner of linking or of being linked; -- said of the union of atoms or radicals in the molecule.","pos":""},{"def":"A system of straight lines or bars, fastened together by joins, and having certain of their points fixed in a plane.","pos":""}],"LINKS":[{"def":"A tract of ground laid out for the game of golf; a golfing green.","pos":""}],"LINKWORK":[{"def":"A fabric consisting of links made of metal or other material fastened together; also, a chain.","pos":""},{"def":"Mechanism in which links, or intermediate connecting pieces, are employed to transmit motion from one part to another.","pos":""}],"LINNAEA BOREALIS":[{"def":"The twin flower which grows in cold northern climates.","pos":""},{"def":"Of or pertaining to Linnæus, the celebrated Swedish botanist.","pos":""}],"LINNAEITE":[{"def":"A mineral of pale steel-gray color and metallic luster, occurring in isometric crystals, and also massive.","pos":""}],"LINNET":[{"def":"Any one of several species of fringilline birds of the genera Linota, Acanthis, and allied genera, esp.","pos":""}],"LINOLEATE":[{"def":"A salt of linoleic acid.","pos":""}],"LINOLEIC":[{"def":"Pertaining to, or derived from, linoleum, or linseed oil; specifically (Chem.","pos":""}],"LINOLEUM":[{"def":"Linseed oil brought to various degrees of hardness by some oxidizing process, as by exposure to heated air, or by treatment with chloride of sulphur.","pos":""},{"def":"A kind of floor cloth made by laying hardened linseed oil mixed with ground cork on a canvas backing.","pos":""}],"LINOXIN":[{"def":"A resinous substance obtained as an oxidation product of linoleic acid.","pos":""}],"LINSANG":[{"def":"Any viverrine mammal of the genus Prionodon, inhabiting the East Indies and Southern Asia.","pos":""}],"LINSEED":[{"def":"The seeds of flax, from which linseed oil is obtained.","pos":""}],"LINSEY-WOOLSEY":[{"def":"Cloth made of linen and wool, mixed.","pos":""}],"LINSTOCK":[{"def":"A pointed forked staff, shod with iron at the foot, to hold a lighted match for firing cannon.","pos":""}],"LINT":[{"def":"Linen scraped or otherwise made into a soft, downy or fleecy substance for dressing wounds and sores; also, fine ravelings, down, fluff, or loose short fibers from yarn or fabrics.","pos":""}],"LINTEL":[{"def":"A horizontal member spanning an opening, and carrying the superincumbent weight by means of its strength in resisting crosswise fracture.","pos":""}],"LINUM":[{"def":"A genus of herbaceous plants including the flax (Linum usitatissimum).","pos":""}]}