{"FAR":[{"def":"A young pig, or a litter of pigs.","pos":""}],"FAR-ABOUT":[{"def":"A going out of the way; a digression.","pos":""}],"FAR-OFF":[{"def":"Remote; as, the far-off distance.","pos":""}],"FAR-STRETCHED":[{"def":"Stretched beyond ordinary limits.","pos":""}],"FARADIC":[{"def":"Of or pertaining to Michael Faraday, the distinguished electrician; -- applied especially to induced currents of electricity, as produced by certain forms of inductive apparatus, on account of Faraday's investigations of their laws.","pos":""},{"def":"The treatment with faradic or induced currents of electricity for remedial purposes.","pos":""}],"FARADIZE":[{"def":"To stimulate with, or subject to, faradic, or inducted, electric currents.","pos":""}],"FARANDAMS":[{"def":"A fabrik made of silk and wool or hair.","pos":""}],"FARANDOLE":[{"def":"A rapid dance in six-eight time in which a large number join hands and dance in various figures, sometimes moving from room to room.","pos":""}],"FARANTLY":[{"def":"Orderly; comely; respectable.","pos":""}],"FARCE":[{"def":"To stuff with forcemeat; hence, to fill with mingled ingredients; to fill full; to stuff.","pos":""}],"FARCEMENT":[{"def":"Stuffing; forcemeat.","pos":""}],"FARCICAL":[{"def":"Pertaining to farce; appropriated to farce; ludicrous; unnatural; unreal.","pos":""}],"FARCILITE":[{"def":"FARCIMEN; FARCIN Far\"ci*men, Far\"cin, n.","pos":""}],"FARCING":[{"def":"Stuffing; forcemeat.","pos":""}],"FARCTATE":[{"def":"Stuffed; filled solid; as, a farctate leaf, stem, or pericarp; -- opposed to tubular or hollow.","pos":""}],"FARCY":[{"def":"A contagious disease of horses, associated with painful ulcerating enlargements, esp.","pos":""}],"FARD":[{"def":"Paint used on the face.","pos":""}],"FARDEL":[{"def":"A bundle or little pack; hence, a burden.","pos":""}],"FARDING-BAG":[{"def":"The upper stomach of a cow, or other ruminant animal; the rumen.","pos":""}],"FARDINGDEAL":[{"def":"The fourth part of an acre of land.","pos":""}],"FARE":[{"def":"To go; to pass; to journey; to travel.","pos":""},{"def":"To be in any state, or pass through any experience, good or bad; to be attended with any circummstances or train of events, fortunate or unfortunate; as, he fared well, or ill.","pos":""}],"FAREWELL":[{"def":"Go well; good-by; adieu; -- originally applied to a person departing, but by custom now applied both to those who depart and those who remain.","pos":""}],"FARFET":[{"def":"York with his farfet policy.","pos":""}],"FARFETCH":[{"def":"To bring from far; to seek out studiously.","pos":""}],"FARFETCHED":[{"def":"Brought from far, or from a remote place.","pos":""},{"def":"Studiously sought; not easily or naturally deduced or introduced; forced; strained.","pos":""}],"FARINA":[{"def":"A fine flour or meal made from cereal grains or from the starch or fecula of vegetables, extracted by various processes, and used in cookery.","pos":""}],"FARINACEOUS":[{"def":"Consisting or made of meal or flour; as, a farinaceous diet.","pos":""},{"def":"Yielding farina or flour; as, ffarinaceous seeds.","pos":""}],"FARINOSE":[{"def":"Civered with a sort of white, mealy powder, as the leaves of some poplars, and the body of certain insects; mealy.","pos":""}],"FARLIE":[{"def":"An unusual or unexpected thing; a wonder.","pos":""}],"FARM":[{"def":"A lease of the imposts on particular goods; as, the sugar farm, the silk farm.","pos":""}],"FARMABLE":[{"def":"Capable of being farmed.","pos":""}],"FARMER":[{"def":"One who farms; as: (a) One who hires and cultivates a farm; a cultivator of leased ground; a tenant.","pos":""}],"FARMERESS":[{"def":"A woman who farms.","pos":""}],"FARMERSHIP":[{"def":"Skill in farming.","pos":""}],"FARMERY":[{"def":"The buildings and yards necessary for the business of a farm; a homestead.","pos":""}],"FARMHOUSE":[{"def":"A dwelling house on a farm; a farmer's residence.","pos":""}],"FARMING":[{"def":"Pertaining to agriculture; devoted to, adapted to, or engaged in, farming; as, farming tools; farming land; a farming community.","pos":""}],"FARMOST":[{"def":"Most distant; farthest.","pos":""}],"FARMSTEAD":[{"def":"A farm with the building upon it; a homestead on a farm.","pos":""}],"FARMYARD":[{"def":"The yard or inclosure attached to a barn, or the space inclosed by the farm buildings.","pos":""}],"FARNESS":[{"def":"The state of being far off; distance; remoteness.","pos":""}],"FARO":[{"def":"A gambling game at cardds, in whiich all the other players play against the dealer or banker, staking their money upon the order in which the cards will lie and be dealt from the pack.","pos":""}],"FAROESE":[{"def":"An inhabitant, or, collectively, inhabitants, of the Faroe islands.","pos":""}],"FARRAGINOUS":[{"def":"Formed of various materials; mixed; as, a farraginous mountain.","pos":""}],"FARRAGO":[{"def":"A mass ccomposed of various materials confusedly mixed; a medley; a mixture.","pos":""}],"FARRAND":[{"def":"Manner; custom; fashion; humor.","pos":""}],"FARREATION":[{"def":"Same as Confarreation.","pos":""}],"FARRIER":[{"def":"A shoer of horses Defn: 2.","pos":""}],"FARRIERY":[{"def":"The art of shoeing horses.","pos":""},{"def":"The art of preventing, curing, or mitigating diseases of horses and cattle; the veterinary art.","pos":""}],"FARROW":[{"def":"A little of pigs.","pos":""}],"FARSE":[{"def":"An addition to, or a paraphrase of, some part of the Latin service in the vernacular; -- common in English before the Reformation.","pos":""}],"FARSEEING":[{"def":"Able to see to a great distance; farsighted.","pos":""},{"def":"Having foresight as regards the future.","pos":""}],"FARSIGHTED":[{"def":"Seeing to great distance; hence, of good judgment regarding the remote effects of actions; sagacious.","pos":""}],"FARSIGHTEDNESS":[{"def":"Stretched beyond ordinary limits.","pos":""}],"FARTHER":[{"def":"More remote; more distant than something else.","pos":""},{"def":"Tending to a greater distance; beyond a certain point; additional; further.","pos":""}],"FARTHERANCE":[{"def":"See Furtherence.","pos":""}],"FARTHERMORE":[{"def":"See Furthermore.","pos":""}],"FARTHERMOST":[{"def":"Most distant or remote; as, the farthest degree.","pos":""}],"FARTHEST":[{"def":"Most distant or remote; as, the farthest degree.","pos":""}],"FARTHING":[{"def":"The fourth of a penny; a small copper coin of Great Britain, being a cent in United States currency.","pos":""},{"def":"A very small quantity or value.","pos":""}],"FARTHINGALE":[{"def":"A hoop skirt or hoop petticoat, or other light, elastic material, used to extend the petticoat.","pos":""}]}