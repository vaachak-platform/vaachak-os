{"ROIL":[{"def":"To render turbid by stirring up the dregs or sediment of; as, to roil wine, cider, etc.","pos":""},{"def":"To disturb, as the temper; to ruffle the temper of; to rouse the passion of resentment in; to perplex.","pos":""}],"ROILY":[{"def":"Turbid; as, roily water.","pos":""}],"ROIN":[{"def":"A scab; a scurf, or scurfy spot.","pos":""}],"ROISTER":[{"def":"To bluster; to swagger; to bully; to be bold, noisy, vaunting, or turbulent.","pos":""}],"ROISTERER":[{"def":"A blustering, turbulent fellow.","pos":""}],"ROISTERLY":[{"def":"Blustering; violent.","pos":""}]}