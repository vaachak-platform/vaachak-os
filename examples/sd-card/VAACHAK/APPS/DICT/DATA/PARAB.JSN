{"PARABANIC":[{"def":"Pertaining to, or designating, a nitrogenous acid which is obtained by the oxidation of uric acid, as a white crystalline substance (C3N2H2O3); -- also called oxalyl urea.","pos":""}],"PARABLAST":[{"def":"A portion of the mesoblast (of peripheral origin) of the developing embryo, the cells of which are especially concerned in forming the first blood and blood vessels.","pos":""}],"PARABLASTIC":[{"def":"Of or pertaining to the parablast; as, the parablastic cells.","pos":""}],"PARABLE":[{"def":"A comparison; a similitude; specifically, a short fictitious narrative of something which might really occur in life or nature, by means of which a moral is drawn; as, the parables of Christ.","pos":""}],"PARABOLE":[{"def":"Similitude; comparison.","pos":""}],"PARABOLICALLY":[{"def":"By way of parable; in a parabolic manner.","pos":""},{"def":"In the form of a parabola.","pos":""}],"PARABOLIFORM":[{"def":"Resembling a parabola in form.","pos":""}],"PARABOLISM":[{"def":"The division of the terms of an equation by a known quantity that is involved in the first term.","pos":""}],"PARABOLIST":[{"def":"A narrator of parables.","pos":""}],"PARABOLOID":[{"def":"The solid generated by the rotation of a parabola about its axis; any surface of the second order whose sections by planes parallel to a given line are parabolas.","pos":""}],"PARABOLOIDAL":[{"def":"Of, pertaining to, or resembling, a paraboloid.","pos":""}],"PARABRONCHIUM":[{"def":"One of the branches of an ectobronchium or entobronchium.","pos":""}]}