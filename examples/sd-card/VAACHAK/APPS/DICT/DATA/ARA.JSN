{"ARA":[{"def":"The Altar; a southern constellation, south of the tail of the Scorpion.","pos":""}],"ARAB":[{"def":"One of a swarthy race occupying Arabia, and numerous in Syria, Northern Africa, etc.","pos":""}],"ARABA":[{"def":"A wagon or cart, usually heavy and without springs, and often covered.","pos":""}],"ARABESQUE":[{"def":"A style of ornamentation either painted, inlaid, or carved in low relief.","pos":""}],"ARABESQUED":[{"def":"Ornamented in the style of arabesques.","pos":""}],"ARABIAN":[{"def":"Of or pertaining to Arabia or its inhabitants.","pos":""}],"ARABIC":[{"def":"Of or pertaining to Arabia or the Arabians.","pos":""}],"ARABICAL":[{"def":"Relating to Arabia; Arabic.","pos":""}],"ARABIN":[{"def":"A carbohydrate, isomeric with cane sugar, contained in gum arabic, from which it is extracted as a white, amorphous substance.","pos":""}],"ARABINOSE":[{"def":"A sugar of the composition C5H10O5, obtained from cherry gum by boiling it with dilute sulphuric acid.","pos":""}],"ARABISM":[{"def":"An Arabic idiom peculiarly of language.","pos":""}],"ARABIST":[{"def":"One well versed in the Arabic language or literature; also, formerly, one who followed the Arabic system of surgery.","pos":""}],"ARABLE":[{"def":"Fit for plowing or tillage; -- hence, often applied to land which has been plowed or tilled.","pos":""}],"ARABY":[{"def":"The country of Arabia.","pos":""}],"ARACANESE":[{"def":"Of or pertaining to Aracan, a province of British Burmah.","pos":""},{"def":"A native or natives of Aracan.","pos":""}],"ARACARI":[{"def":"A South American bird, of the genus Pleroglossius, allied to the toucans.","pos":""}],"ARACE":[{"def":"To tear up by the roots; to draw away.","pos":""}],"ARACEOUS":[{"def":"Of or pertaining to an order of plants, of which the genus Arum is the type.","pos":""}],"ARACHNIDA":[{"def":"One of the classes of Arthropoda.","pos":""}],"ARACHNIDAN":[{"def":"One of the Arachnida.","pos":""}],"ARACHNIDIUM":[{"def":"The glandular organ in which the material for the web of spiders is secreted.","pos":""}],"ARACHNITIS":[{"def":"Inflammation of the arachnoid membrane.","pos":""}],"ARACHNOID":[{"def":"Pertaining to a thin membrane of the brain and spinal cord, between the dura mater and pia mater.","pos":""},{"def":"Covered with, or composed of, soft, loose hairs or fibers, so as to resemble a cobweb; cobwebby.","pos":""}],"ARACHNOIDAL":[{"def":"Pertaining to the arachnoid membrane; arachnoid.","pos":""}],"ARACHNOIDEA":[{"def":"Same as Arachnida.","pos":""}],"ARACHNOLOGICAL":[{"def":"Of or pertaining to arachnology.","pos":""}],"ARACHNOLOGIST":[{"def":"One who is versed in, or studies, arachnology.","pos":""}],"ARACHNOLOGY":[{"def":"The department of zoölogy which treats of spiders and other Arachnida.","pos":""}],"ARAEOSTYLE":[{"def":"See Intercolumniation.","pos":""}],"ARAEOSYSTYLE":[{"def":"See Intercolumniation.","pos":""}],"ARAGONESE":[{"def":"Of or pertaining to Aragon, in Spain, or to its inhabitants.","pos":""},{"def":"A native or natives of Aragon, in Spain.","pos":""}],"ARAGONITE":[{"def":"A mineral identical in composition with calcite or carbonate of lime, but differing from it in its crystalline form and some of its physical characters.","pos":""}],"ARAGUATO":[{"def":"A South American monkey, the ursine howler (Mycetes ursinus).","pos":""}],"ARAK":[{"def":"Of or pertaining to the Syrians and Chaldeans, or to their language; Aramaic.","pos":""}],"ARAMAIC":[{"def":"Pertaining to Aram, or to the territory, inhabitants, language, or literature of Syria and Mesopotamia; Aramæan; -- specifically applied to the northern branch of the Semitic family of languages, including Syriac and Chaldee.","pos":""},{"def":"The Aramaic language.","pos":""}],"ARAMAISM":[{"def":"An idiom of the Aramaic.","pos":""}],"ARANEIDAN":[{"def":"Of or pertaining to the Araneina or spiders.","pos":""},{"def":"One of the Araneina; a spider.","pos":""}],"ARANEIFORM":[{"def":"Having the form of a spider.","pos":""}],"ARANEINA":[{"def":"The order of Arachnida that includes the spiders.","pos":""}],"ARANEOSE":[{"def":"Of the aspect of a spider's web; arachnoid.","pos":""}],"ARANEOUS":[{"def":"Cobweblike; extremely thin and delicate, like a cobweb; as, the araneous membrane of the eye.","pos":""}],"ARANGO":[{"def":"A bead of rough carnelian.","pos":""}],"ARAPAIMA":[{"def":"A large fresh-water food fish of South America.","pos":""}],"ARARA":[{"def":"The palm (or great black) cockatoo, of Australia (Microglossus aterrimus).","pos":""}],"ARAROBA":[{"def":"A fabaceous tree of Brazil (Centrolobium robustum) having handsomely striped wood; --called also zebrawood.","pos":""}],"ARATION":[{"def":"Plowing; tillage.","pos":""}],"ARATORY":[{"def":"Contributing to tillage.","pos":""}],"ARAUCARIA":[{"def":"A genus of tall conifers of the pine family.","pos":""}],"ARAUCARIAN":[{"def":"Relating to, or of the nature of, the Araucaria.","pos":""},{"def":"A crossbow, consisting of a steel bow set in a shaft of wood, furnished with a string and a trigger, and a mechanical device for bending the bow.","pos":""}]}