{"DIN":[{"def":"Loud, confused, harsh noise; a loud, continuous, rattling or clanging sound; clamor; roar.","pos":""}],"DINAPHTHYL":[{"def":"A colorless, crystalline hydrocarbon, C20H14, obtained from naphthylene, and consisting of a doubled naphthylene radical.","pos":""}],"DINAR":[{"def":"A petty money of accounts of Persia.","pos":""},{"def":"An ancient gold coin of the East.","pos":""}],"DINE":[{"def":"To eat the principal regular meal of the day; to take dinner.","pos":""}],"DINER-OUT":[{"def":"One who often takes his dinner away from home, or in company.","pos":""}],"DINETICAL":[{"def":"Revolving on an axis.","pos":""}],"DING":[{"def":"To dash; to throw violently.","pos":""},{"def":"To cause to sound or ring.","pos":""}],"DINGDONG":[{"def":"An attachment to a clock by which the quarter hours are struck upon bells of different tones.","pos":""}],"DINGDONG THEORY":[{"def":"A kind of boat used in the East Indies.","pos":""},{"def":"A ship's smallest boat.","pos":""}],"DINGILY":[{"def":"In a dingy manner.","pos":""}],"DINGINESS":[{"def":"Quality of being dingy; a dusky hue.","pos":""}],"DINGLE":[{"def":"A narrow dale; a small dell; a small, secluded, and embowered valley.","pos":""}],"DINGLE-DANGLE":[{"def":"In a dangling manner.","pos":""}],"DINGO":[{"def":"A wild dog found in Australia, but supposed to have introduced at a very early period.","pos":""}],"DINGTHRIFT":[{"def":"Wilt thou, therefore, a drunkard be, A dingthrift and a knave Drant.","pos":""}],"DINGY":[{"def":"Soiled; sullied; of a dark or dusky color; dark brown; dirty.","pos":""}],"DINICHTHYS":[{"def":"A genus of large extinct Devonian ganoid fishes.","pos":""}],"DINING":[{"def":"Note: Used either adjectively or as the first part of a compound; as, dining hall or dining-hall, dining room, dining table, etc.","pos":""}],"DINK":[{"def":"To deck; -- often with out or up.","pos":""}],"DINMONT":[{"def":"A wether sheep between one and two years old.","pos":""}],"DINNER":[{"def":"The principal meal of the day, eaten by most people about midday, but by many (especially in cities) at a later hour.","pos":""},{"def":"An entertainment; a feast.","pos":""}],"DINNERLESS":[{"def":"Having no dinner.","pos":""}],"DINNERLY":[{"def":"Of or pertaining to dinner.","pos":""}],"DINOCERAS":[{"def":"A genus of large extinct Eocene mammals from Wyoming; -- called also Uintatherium.","pos":""}],"DINORNIS":[{"def":"A genus of extinct, ostrichlike birds of gigantic size, which formerly inhabited New Zealand.","pos":""},{"def":"One of the Dinosauria.","pos":""}],"DINOSAURIA":[{"def":"An order of extinct mesozoic reptiles, mostly of large size (whence the name).","pos":""},{"def":"A large extinct proboscidean mammal from the miocene beds of Europe and Asia.","pos":""}],"DINOXIDE":[{"def":"Same as Dioxide.","pos":""}],"DINT":[{"def":"A blow; a stroke.","pos":""},{"def":"The mark left by a blow; an indentation or impression made by violence; a dent.","pos":""}]}