{"FOREWARD":[{"def":"The van; the front.","pos":""}],"FOREWARN":[{"def":"To warn beforehand; to give previous warning, admonition, information, or notice to; to caution in advance.","pos":""}],"FOREWISH":[{"def":"To wish beforehand.","pos":""}],"FOREWIT":[{"def":"A leader, or would-be leader, in matters of knowledge or taste.","pos":""},{"def":"Foresight; prudence.","pos":""}],"FOREWOMAN":[{"def":"A woman who is chief; a woman who has charge of the work or workers in a shop or other place; a head woman.","pos":""}],"FOREWORN":[{"def":"Worn out; wasted; used up.","pos":""}],"FOREWOT":[{"def":", 1st & 3d pers.","pos":""}]}