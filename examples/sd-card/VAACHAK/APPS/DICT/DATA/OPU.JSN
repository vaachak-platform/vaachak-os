{"OPULENCE":[{"def":"Wealth; riches; affluence.","pos":""}],"OPULENT":[{"def":"Having a large estate or property; wealthy; rich; affluent; as, an opulent city; an opulent citizen.","pos":""}],"OPUNTIA":[{"def":"A genus of cactaceous plants; the prickly pear, or Indian fig.","pos":""}],"OPUS":[{"def":"A small or petty work.","pos":""}]}