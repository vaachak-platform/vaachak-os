{"ANTITHEISM":[{"def":"The doctrine of antitheists.","pos":""}],"ANTITHEIST":[{"def":"A disbeliever in the existence of God.","pos":""}],"ANTITHESIS":[{"def":"An opposition or contrast of words or sentiments occurring in the same sentence; as, \"The prodigal robs his heir; the miser robs himself.","pos":""}],"ANTITHET":[{"def":"An antithetic or contrasted statement.","pos":""},{"def":"Pertaining to antithesis, or opposition of words and sentiments; containing, or of the nature of, antithesis; contrasted.","pos":""}],"ANTITHETICALLY":[{"def":"By way antithesis.","pos":""},{"def":"A substance (sometimes the product of a specific micro-organism and sometimes naturally present in the blood or tissues of an animal), capable of producing immunity from certain diseases, or of counteracting the poisonous effects of pathogenic bacteria.","pos":""}],"ANTITRAGUS":[{"def":"A prominence on the lower posterior portion of the concha of the external ear, opposite the tragus.","pos":""}],"ANTITROCHANTER":[{"def":"An articular surface on the ilium of birds against which the great trochanter of the femur plays.","pos":""},{"def":"At the extremity most remote from the hilum, as the embryo, or inverted with respect to the seed, as the radicle.","pos":""}],"ANTITYPE":[{"def":"That of which the type pattern or representation; that which is represented by the type or symbol.","pos":""}],"ANTITYPICAL":[{"def":"Of or pertaining to an antitype; explaining the type.","pos":""}],"ANTITYPOUS":[{"def":"Resisting blows; hard.","pos":""}],"ANTITYPY":[{"def":"Opposition or resistance of matter to force.","pos":""}]}