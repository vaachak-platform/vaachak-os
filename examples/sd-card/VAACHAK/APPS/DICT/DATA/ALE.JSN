{"ALE":[{"def":"An intoxicating liquor made from an infusion of malt by fermentation and the addition of a bitter, usually hops.","pos":""},{"def":"A festival in English country places, so called from the liquor drunk.","pos":""}],"ALE SILVER":[{"def":"A duty payable to the lord mayor of London by the sellers of ale within the city.","pos":""}],"ALE-KNIGHT":[{"def":"A pot companion.","pos":""}],"ALEAK":[{"def":"In a leaking condition.","pos":""}],"ALEATORY":[{"def":"Depending on some uncertain contingency; as, an aleatory contract.","pos":""}],"ALEBENCH":[{"def":"A bench in or before an alehouse.","pos":""}],"ALEBERRY":[{"def":"A beverage, formerly made by boiling ale with spice, sugar, and sops of bread.","pos":""}],"ALECITHAL":[{"def":"Applied to those ova which segment uniformly, and which have little or no food yelk embedded in their protoplasm.","pos":""}],"ALECOST":[{"def":"The plant costmary, which was formerly much used for flavoring ale.","pos":""}],"ALECTORIDES":[{"def":"A group of birds including the common fowl and the pheasants.","pos":""}],"ALECTOROMACHY":[{"def":"A*lec`to*rom\"a*chy, n.","pos":""}],"ALECTOROMANCY":[{"def":"See Alectryomancy.","pos":""}],"ALECTRYOMANCY":[{"def":"Divination by means of a cock and grains of corn placed on the letters of the alphabet, the letters being put together in the order in which the grains were eaten.","pos":""}],"ALEE":[{"def":"On or toward the lee, or the side away from the wind; the opposite of aweather.","pos":""}],"ALEGAR":[{"def":"Sour ale; vinegar made of ale.","pos":""}],"ALEGER":[{"def":"Gay; cheerful; sprightly.","pos":""}],"ALEGGE":[{"def":"To allay or alleviate; to lighten.","pos":""}],"ALEHOOF":[{"def":"Ground ivy (Nepeta Glechoma).","pos":""}],"ALEHOUSE":[{"def":"A house where ale is retailed; hence, a tippling house.","pos":""}],"ALEM":[{"def":"The imperial standard of the Turkish Empire.","pos":""}],"ALEMANNIC":[{"def":"Belonging to the Alemanni, a confederacy of warlike German tribes.","pos":""}],"ALEMBIC":[{"def":"An apparatus formerly used in distillation, usually made of glass or metal.","pos":""}],"ALEMBROTH":[{"def":"The salt of wisdom of the alchemists, a double salt composed of the chlorides of ammonium and mercury.","pos":""}],"ALENGTH":[{"def":"At full length; lenghtwise.","pos":""}],"ALEPIDOTE":[{"def":"Not having scales.","pos":""},{"def":"A fish without scales.","pos":""}],"ALEPOLE":[{"def":"A pole set up as the sign of an alehouse.","pos":""},{"def":"A chronic skin affection terminating in an ulcer, most commonly of the face.","pos":""}],"ALEPPO GRASS":[{"def":"One of the cultivated forms of Andropogon Halepensis (syn.","pos":""}],"ALERT":[{"def":"Watchful; vigilant; active in vigilance.","pos":""},{"def":"Brisk; nimble; moving with celerity.","pos":""}],"ALERTLY":[{"def":"In an alert manner; nimbly.","pos":""}],"ALERTNESS":[{"def":"The quality of being alert or on the alert; briskness; nimbleness; activity.","pos":""}],"ALESTAKE":[{"def":"A stake or pole projecting from, or set up before, an alehouse, as a sign; an alepole.","pos":""}],"ALETHIOLOGY":[{"def":"The science which treats of the nature of truth and evidence.","pos":""}],"ALETHOSCOPE":[{"def":"An instrument for viewing pictures by means of a lens, so as to present them in their natural proportions and relations.","pos":""}],"ALEUROMANCY":[{"def":"Divination by means of flour.","pos":""}],"ALEUROMETER":[{"def":"An instrument for determining the expansive properties, or quality, of gluten in flour.","pos":""}],"ALEURONAT":[{"def":"Flour made of aleurone, used as a substitute for ordinary flour in preparing bread for diabetic persons.","pos":""}],"ALEURONE":[{"def":"An albuminoid substance which occurs in minute grains (\"protein granules\") in maturing seeds and tubers; -- supposed to be a modification of protoplasm.","pos":""}],"ALEURONIC":[{"def":"Having the nature of aleurone.","pos":""},{"def":"Of or pertaining to a chain of islands between Alaska and Kamtchatka; also, designating these islands.","pos":""}],"ALEVIN":[{"def":"Young fish; fry.","pos":""}],"ALEWIFE":[{"def":"A woman who keeps an alehouse.","pos":""}],"ALEXANDRIAN":[{"def":"Of or pertaining to Alexandria in Egypt; as, the Alexandrian library.","pos":""},{"def":"Applied to a kind of heroic verse.","pos":""}],"ALEXANDRINE":[{"def":"Belonging to Alexandria; Alexandrian.","pos":""}],"ALEXIA":[{"def":"ALEXIPHARMAC; ALEXIPHARMACAL A*lex`i*phar\"mac, A*lex`i*phar\"ma*cal, a.","pos":""}],"ALEXIPHARMIC":[{"def":"An antidote against poison or infection; a counterpoison.","pos":""},{"def":"Expelling or counteracting poison; antidotal.","pos":""}],"ALEXIPYRETIC":[{"def":"Serving to drive off fever; antifebrile.","pos":""}],"ALEXITERIC":[{"def":"A preservative against contagious and infectious diseases, and the effects of poison in general.","pos":""},{"def":"Resisting poison; obviating the effects of venom; alexipharmic.","pos":""}]}