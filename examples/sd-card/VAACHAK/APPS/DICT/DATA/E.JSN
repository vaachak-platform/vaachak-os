{"E'EN":[{"def":"A contraction for even.","pos":""}],"E'ER":[{"def":"A contraction for ever.","pos":""}],"E-":[{"def":"A Latin prefix meaning out, out of, from; also, without.","pos":""}],"E-LA":[{"def":"Originally, the highest note in the scale of Guido; hence, proverbially, any extravagant saying.","pos":""}]}