{"STRIA":[{"def":"A fillet between the flutes of columns, pilasters, or the like.","pos":""}],"STRIATE":[{"def":"To mark with striaæ.","pos":""},{"def":"Marked with striaæ, or fine grooves, or lines of color; showing narrow structural bands or lines; as, a striated crystal; striated muscular fiber.","pos":""}],"STRIATION":[{"def":"The quality or condition of being striated.","pos":""},{"def":"A stria; as, the striations on a shell.","pos":""}],"STRIATUM":[{"def":"The corpus striatum.","pos":""}],"STRICK":[{"def":"A bunch of hackled flax prepared for drawing into slivers.","pos":""}],"STRICKEN":[{"def":"Struck; smitten; wounded; as, the stricken deer.","pos":""},{"def":"Worn out; far gone; advanced.","pos":""}],"STRICKLE":[{"def":"An instrument used for smoothing the surface of a core.","pos":""},{"def":"A templet; a pattern.","pos":""}],"STRICT":[{"def":"Upright, or straight and narrow; -- said of the shape of the plants or their flower clusters.","pos":""}],"STRICTION":[{"def":"The act of constricting, or the state of being constricted.","pos":""}],"STRICTLY":[{"def":"In a strict manner; closely; precisely.","pos":""}],"STRICTNESS":[{"def":"Quality or state of being strict.","pos":""}],"STRICTURE":[{"def":"A localized morbid contraction of any passage of the body.","pos":""}],"STRICTURED":[{"def":"Affected with a stricture; as, a strictured duct.","pos":""}],"STRID":[{"def":"A narrow passage between precipitous rocks or banks, which looks as if it might be crossed at a stride.","pos":""}],"STRIDE":[{"def":"To walk with long steps, especially in a measured or pompous manner.","pos":""},{"def":"To stand with the legs wide apart; to straddle.","pos":""}],"STRIDENT":[{"def":"Characterized by harshness; grating; shrill.","pos":""}],"STRIDOR":[{"def":"A harsh, shrill, or creaking noise.","pos":""}],"STRIDULATE":[{"def":"To make a shrill, creaking noise; specifically (Zoöl.","pos":""},{"def":"to make a shrill or musical sound, such as is made by the males of many insects.","pos":""}],"STRIDULATION":[{"def":"The act of stridulating.","pos":""}],"STRIDULATOR":[{"def":"That which stridulates.","pos":""}],"STRIDULATORY":[{"def":"Stridulous; able to stridulate; used in stridulating; adapted for stridulation.","pos":""}],"STRIDULOUS":[{"def":"Making a shrill, creaking sound.","pos":""}],"STRIFE":[{"def":"The act of striving; earnest endeavor.","pos":""},{"def":"Exertion or contention for superiority; contest of emulation, either by intellectual or physical efforts.","pos":""}],"STRIFEFUL":[{"def":"Contentious; discordant.","pos":""}],"STRIGATE":[{"def":"Having transverse bands of color.","pos":""}],"STRIGES":[{"def":"The tribe of birds which comprises the owls.","pos":""}],"STRIGIL":[{"def":"An instrument of metal, ivory, etc.","pos":""}],"STRIGILLOSE":[{"def":"Set with stiff, slender bristles.","pos":""}],"STRIGINE":[{"def":"Of or pertaining to owls; owl-like.","pos":""}],"STRIGMENT":[{"def":"Scraping; that which is scraped off.","pos":""}],"STRIGOSE":[{"def":"Set with stiff, straight bristles; hispid; as, a strigose leaf.","pos":""}],"STRIKE":[{"def":"To cut off, as a mortar joint, even with the face of the wall, or inward at a slight angle.","pos":""}],"STRIKER":[{"def":"One who, or that which, strikes; specifically, a blacksmith's helper who wieds the sledge.","pos":""},{"def":"A harpoon; also, a harpooner.","pos":""}],"STRIKING":[{"def":"Strik\"ing, Defn: a.","pos":""}],"STRING":[{"def":"An inside range of ceiling planks, corresponding to the sheer strake on the outside and bolted to it.","pos":""},{"def":"The tough fibrous substance that unites the valves of the pericap of leguminous plants, and which is readily pulled off; as, the strings of beans.","pos":""}],"STRINGBOARD":[{"def":"Same as Stringpiece.","pos":""}],"STRINGCOURSE":[{"def":"A horizontal band in a building, forming a part of the design, whether molded, projecting, or carved, or in any way distinguished from the rest of the work.","pos":""}],"STRINGED":[{"def":"Having strings; as, a stringed instrument.","pos":""},{"def":"Produced by strings.","pos":""}],"STRINGENCY":[{"def":"The quality or state of being stringent.","pos":""}],"STRINGENDO":[{"def":"Urging or hastening the time, as to a climax.","pos":""}],"STRINGENT":[{"def":"Binding strongly; making strict requirements; restrictive; rigid; severe; as, stringent rules.","pos":""}],"STRINGER":[{"def":"A longitudinal sleeper.","pos":""},{"def":"A streak of planking carried round the inside of a vessel on the under side of the beams.","pos":""}],"STRINGHALT":[{"def":"An habitual sudden twitching of the hinder leg of a horse, or an involuntary or convulsive contraction of the muscles that raise the hock.","pos":""}],"STRINGINESS":[{"def":"Quality of being stringy.","pos":""}],"STRINGLESS":[{"def":"Having no strings.","pos":""}],"STRINGY":[{"def":"Consisting of strings, or small threads; fibrous; filamentous; as, a stringy root.","pos":""},{"def":"Capable of being drawn into a string, as a glutinous substance; ropy; viscid; gluely.","pos":""}],"STRIP":[{"def":"To dismantle; as, to strip a ship of rigging, spars, etc.","pos":""},{"def":"To pare off the surface of, as land, in strips.","pos":""}],"STRIP-LEAF":[{"def":"Tobacco which has been stripped of its stalks before packing.","pos":""}],"STRIPE":[{"def":"A pattern produced by arranging the warp threads in sets of alternating colors, or in sets presenting some other contrast of appearance.","pos":""},{"def":"The chevron on the coat of a noncommissioned officer.","pos":""}],"STRIPED":[{"def":"Having stripes of different colors; streaked.","pos":""}],"STRIPLING":[{"def":"A youth in the state of adolescence, or just passing from boyhood to manhood; a lad.","pos":""}],"STRIPPER":[{"def":"One who, or that which, strips; specifically, a machine for stripping cards.","pos":""}],"STRIPPING":[{"def":"The last milk drawn from a cow at a milking.","pos":""}],"STRISORES":[{"def":"A division of passerine birds including the humming birds, swifts, and goatsuckers.","pos":""}],"STRIVE":[{"def":"To make efforts; to use exertions; to endeavor with earnestness; to labor hard.","pos":""},{"def":"To struggle in opposition; to be in contention or dispute; to contend; to contest; -- followed by against or with before the person or thing opposed; as, strive against temptation; strive for the truth.","pos":""}],"STRIVED":[{"def":"Yea, so have I strived to preach the gospel.","pos":""}],"STRIVER":[{"def":"One who strives.","pos":""}],"STRIX":[{"def":"One of the flutings of a column.","pos":""}]}