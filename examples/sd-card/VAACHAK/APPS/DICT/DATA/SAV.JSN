{"SAVABLE":[{"def":"capable of, or admitting of, being saved.","pos":""}],"SAVABLENESS":[{"def":"Capability of being saved.","pos":""}],"SAVAGE":[{"def":"Of or pertaining to the forest; remote from human abodes and cultivation; in a state of nature; nature; wild; as, a savage wilderness.","pos":""},{"def":"Wild; untamed; uncultivated; as, savage beasts.","pos":""}],"SAVAGELY":[{"def":"In a savage manner.","pos":""}],"SAVAGENESS":[{"def":"The state or quality of being savage.","pos":""}],"SAVAGERY":[{"def":"The state of being savage; savageness; savagism.","pos":""},{"def":"An act of cruelty; barbarity.","pos":""}],"SAVAGISM":[{"def":"The state of being savage; the state of rude, uncivilized men, or of men in their native wildness and rudeness.","pos":""}],"SAVANNA":[{"def":"A tract of level land covered with the vegetable growth usually found in a damp soil and warm climate, -- as grass or reeds, -- but destitute of trees.","pos":""}],"SAVANT":[{"def":"A man of learning; one versed in literature or science; a person eminent for acquirements.","pos":""}],"SAVE":[{"def":"The herb sage, or salvia.","pos":""}],"SAVE-ALL":[{"def":"Anything which saves fragments, or prevents waste or loss.","pos":""}],"SAVELOY":[{"def":"A kind of dried sausage.","pos":""}],"SAVEMENT":[{"def":"The act of saving.","pos":""}],"SAVER":[{"def":"SAVIN; SAVINE Sav\"in, Sav\"ine, n.","pos":""}],"SAVING":[{"def":"Avoiding unnecessary expense or waste; frugal; not lavish or wasteful; economical; as, a saving cook.","pos":""},{"def":"Bringing back in returns or in receipts the sum expended; incurring no loss, though not gainful; as, a saving bargain; the ship has made a saving voyage.","pos":""}],"SAVINGLY":[{"def":"In a saving manner; with frugality or parsimony.","pos":""},{"def":"So as to be finally saved from eternal death.","pos":""}],"SAVINGNESS":[{"def":"The quality of being saving; carefulness not to expend money uselessly; frugality; parsimony.","pos":""},{"def":"Tendency to promote salvation.","pos":""}],"SAVIOR":[{"def":"One who saves, preserves, or delivers from destruction or danger.","pos":""},{"def":"Specifically: The (or our, your, etc.","pos":""}],"SAVIORESS":[{"def":"A female savior.","pos":""}],"SAVOR":[{"def":"That property of a thing which affects the organs of taste or smell; taste and odor; flavor; relish; scent; as, the savor of an orange or a rose; an ill savor.","pos":""},{"def":"Hence, specific flavor or quality; characteristic property; distinctive temper, tinge, taint, and the like.","pos":""}],"SAVORILY":[{"def":"In a savory manner.","pos":""}],"SAVORINESS":[{"def":"The quality of being savory.","pos":""}],"SAVORLESS":[{"def":"Having no savor; destitute of smell or of taste; insipid.","pos":""}],"SAVORLY":[{"def":"In a savory manner.","pos":""}],"SAVOROUS":[{"def":"Having a savor; savory.","pos":""}],"SAVORY":[{"def":"Pleasing to the organs of taste or smell.","pos":""},{"def":"An aromatic labiate plant (Satireia hortensis), much used in cooking; -- also called summer savory.","pos":""}],"SAVOY":[{"def":"A variety of the common cabbage (Brassica oleracea major), having curled leaves, -- much cultivated for winter use.","pos":""}],"SAVOYARD":[{"def":"A native or inhabitant of Savoy.","pos":""},{"def":"To understand; to comprehend; know.","pos":""}]}