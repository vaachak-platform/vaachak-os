{"LOXODROMIC":[{"def":"Pertaining to sailing on rhumb lines; as, loxodromic tables.","pos":""}],"LOXODROMICS":[{"def":"The art or method of sailing on the loxodromic or rhumb line.","pos":""}],"LOXODROMISM":[{"def":"The act or process of tracing a loxodromic curve; the act of moving as if in a loxodromic curve.","pos":""}],"LOXODROMY":[{"def":"The science of loxodromics.","pos":""}]}