{"SALP":[{"def":"Any species of Salpa, or of the family Salpidæ.","pos":""}],"SALPA":[{"def":"A genus of transparent, tubular, free-swimming oceanic tunicates found abundantly in all the warmer latitudes.","pos":""}],"SALPICON":[{"def":"Chopped meat, bread, etc.","pos":""}],"SALPINGITIS":[{"def":"Inflammation of the salpinx.","pos":""}],"SALPINX":[{"def":"The Eustachian tube, or the Fallopian tube.","pos":""}]}