{"CONIA":[{"def":"Having the form of, or resembling, a geometrical cone; round and tapering to a point, or gradually lessening in circumference; as, a conic or conical figure; a conical vessel.","pos":""},{"def":"Of or pertaining to a cone; as, conic sections.","pos":""}],"CONIC":[{"def":"A conic section.","pos":""}],"CONICALLY":[{"def":"In the form of a cone.","pos":""}],"CONICALNESS":[{"def":"State or quality of being conical.","pos":""}],"CONICO-":[{"def":"A combining form, meaning somewhat resembling a cone; as, conico-cylindrical, resembling a cone and a cylinder; conico- hemispherical; conico-subulate.","pos":""}],"CONICOID":[{"def":"Same as Conoidal.","pos":""}],"CONICS":[{"def":"That branch of geometry which treats of the cone and the curves which arise from its sections.","pos":""}],"CONIDIUM":[{"def":"A peculiar kind of reproductive cell found in certain fungi, and often containing zoöspores.","pos":""}],"CONIFER":[{"def":"A tree or shrub bearing cones; one of the order Coniferae, which includes the pine, cypress, and (according to some) the yew.","pos":""}],"CONIFERIN":[{"def":"A glucoside extracted from the cambium layer of coniferous trees as a white crystalline substance.","pos":""}],"CONIFORM":[{"def":"Cone-shaped; conical.","pos":""}],"CONIMENE":[{"def":"Same as Olibene.","pos":""}],"CONINE":[{"def":"A powerful and very poisonous vegetable alkaloid found in the hemlock (Conium maculatum) and extracted as a colorless oil, C8H17N, of strong repulsive odor and acrid taste.","pos":""}],"CONIROSTER":[{"def":"One of the Conirostres.","pos":""}],"CONIROSTRAL":[{"def":"Belonging to the Conirostres.","pos":""}],"CONIROSTRES":[{"def":"A tribe of perching birds, including those which have a strong conical bill, as the finches.","pos":""}],"CONISTRA":[{"def":"Originally, a part of the palestra, or gymnasium among the Greeks; either the place where sand was stored for use in sprinkling the wrestlers, or the wrestling ground itself.","pos":""}],"CONITE":[{"def":"A magnesian variety of dolomite.","pos":""}],"CONIUM":[{"def":"A genus of biennial, poisonous, white-flowered, umbelliferous plants, bearing ribbed fruit (\"seeds\") and decompound leaves.","pos":""},{"def":"The common hemlock (Conium maculatum, poison hemlock, spotted hemlock, poison parsley), a roadside weed of Europe, Asia, and America, cultivated in the United States for medicinal purpose.","pos":""}]}