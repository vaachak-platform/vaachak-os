{"MONILIALES":[{"def":"The largest of the three orders into which the Fungi Imperfecti are divided, including various forms.","pos":""}],"MONILIFORM":[{"def":"Joined or constricted, at regular intervals, so as to resemble a string of beads; as, a moniliform root; a moniliform antenna.","pos":""}],"MONIMENT":[{"def":"Something to preserve memory; a reminder; a monument; hence, a mark; an image; a superscription; a record.","pos":""}],"MONISH":[{"def":"To admonish; to warn.","pos":""}],"MONISHER":[{"def":"One who monishes; an admonisher.","pos":""}],"MONISM":[{"def":"That doctrine which refers all phenomena to a single ultimate constituent or agent; -- the opposite of dualism.","pos":""},{"def":"See Monogenesis, 1.","pos":""}],"MONIST":[{"def":"A believer in monism.","pos":""}],"MONISTIC":[{"def":"Of, pertaining to, or involving, monism.","pos":""}],"MONITION":[{"def":"A process in the nature of a summons to appear and answer.","pos":""},{"def":"An order monishing a party complained against to obey under pain of the law.","pos":""}],"MONITIVE":[{"def":"Conveying admonition; admonitory.","pos":""}],"MONITOR":[{"def":"Any large Old World lizard of the genus Varanus; esp.","pos":""},{"def":"An ironclad war vessel, very low in the water, and having one or more heavily-armored revolving turrets, carrying heavy guns.","pos":""}],"MONITOR NOZZLE":[{"def":"A nozzle capable of turning completely round in a horizontal plane and having a limited play in a vertical plane, used in hydraulic mining, fire-extinguishing apparatus, etc.","pos":""}],"MONITORIAL":[{"def":"Of or pertaining to a monitor or monitors.","pos":""},{"def":"Done or performed by a monitor; as, monitorial work; conducted or taught by monitors; as, a monitorial school; monitorial instruction.","pos":""}],"MONITORIALLY":[{"def":"In a monitorial manner.","pos":""}],"MONITORSHIP":[{"def":"The post or office of a monitor.","pos":""}],"MONITORY":[{"def":"Giving admonition; instructing by way of caution; warning.","pos":""}]}