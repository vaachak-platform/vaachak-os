{"FIN":[{"def":"To carve or cut up, as a chub.","pos":""}],"FIN KEEL":[{"def":"A projection downward from the keel of a yacht, resembling in shape the fin of a fish, though often with a cigar-shaped bulb of lead at the bottom, and generally made of metal.","pos":""}],"FIN-TOED":[{"def":"Having toes connected by a membrane; palmiped; palmated; also, lobate.","pos":""}],"FINABLE":[{"def":"Liable or subject to a fine; as, a finable person or offense.","pos":""}],"FINAL":[{"def":"Pertaining to the end or conclusion; last; terminating; ultimate; as, the final day of a school term.","pos":""},{"def":"Conclusive; decisive; as, a final judgment; the battle of Waterloo brought the contest to a final issue.","pos":""}],"FINALE":[{"def":"Close; termination; as: (a) (Mus.","pos":""}],"FINALIST":[{"def":"Any of the players who meet in the final round of a tournament in which the losers in any round do not play again.","pos":""}],"FINALITY":[{"def":"The state of being final, finished, or complete; a final or conclusive arrangement; a settlement.","pos":""},{"def":"The relation of end or purpose to its means.","pos":""}],"FINALLY":[{"def":"At the end or conclusion; ultimately; lastly; as, the contest was long, but the Romans finally conquered.","pos":""},{"def":"Completely; beyond recovery.","pos":""}],"FINANCE":[{"def":"The income of a ruler or of a state; revennue; public money; sometimes, the income of an individual; often used in the plural for funds; available money; resources.","pos":""},{"def":"The science of raising and expending the public revenue.","pos":""}],"FINANCIAL":[{"def":"Pertaining to finance.","pos":""}],"FINANCIALLY":[{"def":"In a dfinancial manner.","pos":""}],"FINANCIER":[{"def":"One charged with the administration of finance; an officer who administers the public revenue; a treasurer.","pos":""},{"def":"One skilled in financial operations; one acquainted with money matters.","pos":""}],"FINATIVE":[{"def":"Conclusive; decisive; definitive; final.","pos":""}],"FINBACK":[{"def":"Any whale of the genera Sibbaldius, Balænoptera, and allied genera, of the family Balænopteridæ, characterized by a prominent fin on the back.","pos":""}],"FINCH":[{"def":"A small singing bird of many genera and species, belonging to the family Fringillidæ.","pos":""}],"FINCHBACKED":[{"def":"Streaked or spotted on the back; -- said of cattle.","pos":""}],"FINCHED":[{"def":"Same as Finchbacked.","pos":""}],"FIND":[{"def":"To meet with, or light upon, accidentally; to gain the first sight or knowledge of, as of something new, or unknown; hence, to fall in with, as a person.","pos":""},{"def":"To learn by experience or trial; to perceive; to experience; to discover by the intellect or the feelings; to detect; to feel.","pos":""}],"FINDABLE":[{"def":"Capable of being found; discoverable.","pos":""}],"FINDER":[{"def":"One who, or that which, finds; specifically (Astron.","pos":""}],"FINDFAULT":[{"def":"A censurer or caviler.","pos":""}],"FINDFAULTING":[{"def":"Apt to censure or cavil; faultfinding; captious.","pos":""}],"FINDING":[{"def":"The result of a judicial examination or inquiry, especially into some matter of fact; a verdict; as, the finding of a jury.","pos":""}],"FINDY":[{"def":"Full; heavy; firm; solid; substemtial.","pos":""}],"FINE":[{"def":"Finished; brought to perfection; refined; hence, free from impurity; excellent; superior; elegant; worthy of admiration; accomplished; beautiful.","pos":""},{"def":"Aiming at show or effect; loaded with ornament; overdressed or overdecorated; showy.","pos":""}],"FINEDRAW":[{"def":"To sew up, so nicely that the seam is not perceived; to renter.","pos":""}],"FINEDRAWER":[{"def":"One who finedraws.","pos":""}],"FINEDRAWN":[{"def":"Drawn out with too much subtilty; overnice; as, finedrawn speculations.","pos":""}],"FINEER":[{"def":"To run in dept by getting goods made up in a way unsuitable for the use of others, and then threatening not to take them except on credit.","pos":""}],"FINELESS":[{"def":"Endless; boundless.","pos":""}],"FINELY":[{"def":"In a fine or finished manner.","pos":""}],"FINENESS":[{"def":"The quality or condition of being fine.","pos":""},{"def":"Freedom from foreign matter or alloy; clearness; purity; as, the fineness of liquor.","pos":""}],"FINER":[{"def":"One who fines or purifies.","pos":""}],"FINERY":[{"def":"A charcoal hearth or furnace for the conversion of cast iron into wrought iron, or into iron suitable for puddling.","pos":""}],"FINESPUN":[{"def":"Spun so as to be fine; drawn to a fine thread; attenuated; hence, unsubstantial; visionary; as, finespun theories.","pos":""}],"FINESSE":[{"def":"The act of finessing.","pos":""}],"FINESTILL":[{"def":"To distill, as spirit from molasses or some saccharine preparation.","pos":""}],"FINESTILLER":[{"def":"One who finestills.","pos":""}],"FINFOOT":[{"def":"A South American bird (heliornis fulica) allied to the grebes.","pos":""}],"FINGER":[{"def":"One of the five terminating members of the hand; a digit; esp.","pos":""},{"def":"Anything that does work of a finger; as, the pointer of a clock, watch, or other registering machine; especially (Mech.","pos":""}],"FINGERED":[{"def":"Having leaflets like fingers; digitate.","pos":""},{"def":"Marked with figures designating which finger should be used for each note.","pos":""}],"FINGERER":[{"def":"One who fingers; a pilferer.","pos":""}],"FINGERING":[{"def":"The act or process of handling or touching with the fingers.","pos":""},{"def":"The manner of using the fingers in playing or striking the keys of an instrument of music; movement or management of the fingers in playing on a musical instrument, in typewriting, etc.","pos":""}],"FINGRIGO":[{"def":"A prickly, climbing shrub of the genus Pisonia.","pos":""}],"FINIAL":[{"def":"The knot or bunch of foliage, or foliated ornament, that forms the upper extremity of a pinnacle in Gothic architecture; sometimes, the pinnacle itself.","pos":""}],"FINICAL":[{"def":"Affectedly fine; overnice; unduly particular; fastidious.","pos":""}],"FINICALITY":[{"def":"The quality of being finical; finicalness.","pos":""},{"def":"Finical; unduly particular.","pos":""}],"FINIFIC":[{"def":"A limiting element or quality.","pos":""}],"FINIFY":[{"def":"To make fine; to dress finically.","pos":""}],"FINIKIN":[{"def":"Precise in trifles; idly busy.","pos":""}],"FINING":[{"def":"The act of imposing a fin 2.","pos":""},{"def":"That which is used to refine; especially, a preparation of isinglass, gelatin, etc.","pos":""}],"FINIS":[{"def":"An end; conclusion.","pos":""}],"FINISH":[{"def":"To arrive at the end of; to bring to an end; to put an end to; to make an end of; to terminate.","pos":""},{"def":"To bestow the last required labor upon; to complete; to bestow the utmost possible labor upon; to perfect; to accomplish; to polish.","pos":""}],"FINISHED":[{"def":"Polished to the highest degree of excellence; complete; perfect; as, a finished poem; a finished education.","pos":""}],"FINISHER":[{"def":"One who finishes, puts an end to, completes, or perfects; esp.","pos":""},{"def":"Something that gives the finishing touch to, or settles, anything.","pos":""}],"FINISHING":[{"def":"The act or process of completing or perfecting; the final work upon or ornamentation of a thing.","pos":""}],"FINITE":[{"def":"Having a limit; limited in quantity, degree, or capacity; bounded; -- opposed to infinite; as, finite number; finite existence; a finite being; a finite mind; finite duration.","pos":""}],"FINITELESS":[{"def":"Fi\"nite*less, a Defn: Infinite.","pos":""}],"FINITELY":[{"def":"In a finite manner or degree.","pos":""}],"FINITENESS":[{"def":"The state of being finite.","pos":""}],"FINJAN":[{"def":"In the Levant, a small coffee cup without a handle, such as is held in a cup or stand called a zarf.","pos":""}],"FINLANDER":[{"def":"A native or inhabitant of Finland.","pos":""}],"FINLESS":[{"def":"destitute of fins.","pos":""}],"FINLET":[{"def":"A little fin; one of the parts of a divided fin.","pos":""}],"FINLIKE":[{"def":"Resembling a fin.","pos":""}],"FINN":[{"def":"A native of Finland; one of the FinnFinns.","pos":""}],"FINNAN HADDIE":[{"def":"Haddock cured in peat smoke, originally at Findon (pron.","pos":""}],"FINNED":[{"def":"Having a fin, or fins, or anything resembling a fin.","pos":""}],"FINNER":[{"def":"A finback whale.","pos":""}],"FINNIC":[{"def":"Of or pertaining to the Finns.","pos":""}],"FINNIKIN":[{"def":"A variety of pigeon, with a crest somewhat resembling the mane of a horse.","pos":""}],"FINNISH":[{"def":"Of or pertaining to Finland, to the Finns, or to their language.","pos":""},{"def":"A Northern Turanian group of languages; the language of the Finns.","pos":""}],"FINNS":[{"def":"Europe, including the Magyars, Bulgarians, Permians, Lapps, and Finlanders.","pos":""}],"FINNY":[{"def":"Having, or abounding in, fins, as fishes; pertaining to fishes.","pos":""}],"FINOCHIO":[{"def":"An umbelliferous plant (Foeniculum dulce) having a somewhat tuberous stem; sweet fennel.","pos":""}],"FINOS":[{"def":"Second best wool from Merino sheep.","pos":""}],"FINSEN LIGHT":[{"def":"Highly actinic light, derived from sunlight or from some form of electric lamp, used in the treatment of lupus and other cutaneous affections.","pos":""}],"FINT":[{"def":"Fint, Defn: 3d pers.","pos":""}]}