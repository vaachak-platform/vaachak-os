{"TRIRECTANGULAR":[{"def":"Having three right angles.","pos":""}],"TRIREME":[{"def":"An ancient galley or vessel with tree banks, or tiers, of oars.","pos":""}],"TRIRHOMBOIDAL":[{"def":"Having three rhombic faces or sides.","pos":""},{"def":"A complex sugar, as raffinose, yielding by hydrolysis three simple sugar molecules.","pos":""}]}