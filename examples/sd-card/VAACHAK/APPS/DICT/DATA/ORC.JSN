{"ORCADIAN":[{"def":"Of or pertaining to the Orkney Islands.","pos":""}],"ORCHANET":[{"def":"Same as Alkanet, 2.","pos":""}],"ORCHARD":[{"def":"An inclosure containing fruit trees; also, the fruit trees, collectively; -- used especially of apples, peaches, pears, cherries, plums, or the like, less frequently of nutbearing trees and of sugar maple trees.","pos":""}],"ORCHARDING":[{"def":"The cultivation of orchards.","pos":""},{"def":"Orchards, in general.","pos":""}],"ORCHARDIST":[{"def":"One who cultivates an orchard.","pos":""}],"ORCHESOGRAPHY":[{"def":"A treatise upon dancing.","pos":""}],"ORCHESTIAN":[{"def":"Any species of amphipod crustacean of the genus Orchestia, or family Orchestidæ.","pos":""}],"ORCHESTRA":[{"def":"The instruments employed by a full band, collectively; as, an orchestra of forty stringed instruments, with proper complement of wind instruments.","pos":""}],"ORCHESTRAL":[{"def":"Of or pertaining to an orchestra; suitable for, or performed in or by, an orchestra.","pos":""}],"ORCHESTRATION":[{"def":"The arrangement of music for an orchestra; orchestral treatment of a composition; -- called also instrumentation.","pos":""}],"ORCHESTRION":[{"def":"A large music box imitating a variety of orchestral instruments.","pos":""}],"ORCHID":[{"def":"Any plant of the order Orchidaceæ.","pos":""}],"ORCHIDACEOUS":[{"def":"Pertaining to, or resembling, a natural order (Orchidaceæ) of endogenous plants of which the genus Orchis is the type.","pos":""}],"ORCHIDEOUS":[{"def":"Same as Orchidaceous.","pos":""}],"ORCHIDOLOGIST":[{"def":"One versed in orchidology.","pos":""}],"ORCHIDOLOGY":[{"def":"The branch of botany which treats of orchids.","pos":""}],"ORCHILLA WEED":[{"def":"The lichen from which archil is obtained.","pos":""}],"ORCHIS":[{"def":"A genus of endogenous plants growing in the North Temperate zone, and consisting of about eighty species.","pos":""},{"def":"Any plant of the same family with the orchis; an orchid.","pos":""}],"ORCHITIS":[{"def":"Inflammation of the testicles.","pos":""}],"ORCHOTOMY":[{"def":"The operation of cutting out or removing a testicle by the knife; castration.","pos":""}],"ORCIN":[{"def":"A colorless crystalline substance, C6H3.","pos":""}]}