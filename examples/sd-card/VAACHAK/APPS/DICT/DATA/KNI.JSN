{"KNICKER":[{"def":"A small ball of clay, baked hard and oiled, used as a marble by boys in playing.","pos":""}],"KNICKERBOCKER":[{"def":"A linsey-woolsey fabric having a rough knotted surface on the right side; used for women's dresses.","pos":""}],"KNICKERBOCKERS":[{"def":"The name for a style of short breeches; smallclothes.","pos":""}],"KNICKKNACK":[{"def":"A trifle or toy; a bawble; a gewgaw.","pos":""}],"KNICKKNACKATORY":[{"def":"A collection of knickknacks.","pos":""}],"KNIFE":[{"def":"An instrument consisting of a thin blade, usually of steel and having a sharp edge for cutting, fastened to a handle, but of many different forms and names for different uses; as, table knife, drawing knife, putty knife, pallet knife, pocketknife, penknife, chopping knife, etc.","pos":""},{"def":"A sword or dagger.","pos":""}],"KNIFE SWITCH":[{"def":"A switch consisting of one or more knifelike pieces hinged at one end and making contact near the other with flat gripping springs.","pos":""}],"KNIFEBOARD":[{"def":"A board on which knives are cleaned or polished.","pos":""},{"def":"A piece of steel sharpened to an acute edge or angle, and resting on a smooth surface, serving as the axis of motion of a pendulum, scale beam, or other piece required to oscillate with the least possible friction.","pos":""}],"KNIGHT":[{"def":"A young servant or follower; a military attendant.","pos":""},{"def":"A piece used in the game of chess, usually bearing a horse's head.","pos":""}],"KNIGHT BACHELOR":[{"def":"A knight of the most ancient, but lowest, order of English knights, and not a member of any order of chivalry.","pos":""}],"KNIGHT BANNERET":[{"def":"A knight who carried a banner, who possessed fiefs to a greater amount than the knight bachelor, and who was obliged to serve in war with a greater number of attendants.","pos":""}],"KNIGHT MARSHAL":[{"def":"An officer in the household of the British sovereign, who has cognizance of transgressions within the royal household and verge, and of contracts made there, a member of the household being one of the parties.","pos":""}],"KNIGHT SERVICE":[{"def":"A tenure of lands held by knights on condition of performing military service.","pos":""}],"KNIGHT TEMPLAR":[{"def":"See Commandery, n.","pos":""}],"KNIGHT'S FEE":[{"def":"The fee of a knight; specif.","pos":""}],"KNIGHT-ER-RATIC":[{"def":"Pertaining to a knight-errant or to knight-errantry.","pos":""}],"KNIGHT-ERRANT":[{"def":"A wandering knight; a knight who traveled in search of adventures, for the purpose of exhibiting military skill, prowess, and generosity.","pos":""}],"KNIGHT-ERRANTRY":[{"def":"The character or actions of wandering knights; the practice of wandering in quest of adventures; chivalry; a quixotic or romantic adventure or scheme.","pos":""}],"KNIGHTAGE":[{"def":"To body of knights, taken collectively.","pos":""}],"KNIGHTHEAD":[{"def":"A bollard timber.","pos":""}],"KNIGHTHOOD":[{"def":"The character, dignity, or condition of a knight, or of knights as a class; hence, chivalry.","pos":""},{"def":"The whole body of knights.","pos":""}],"KNIGHTLESS":[{"def":"Unbecoming a knight.","pos":""}],"KNIGHTLINESS":[{"def":"The character or bearing suitable for a knight; chivalry.","pos":""}],"KNIGHTLY":[{"def":"Of or pertaining to a knight; becoming a knight; chivalrous; as, a knightly combat; a knightly spirit.","pos":""}],"KNIT":[{"def":"To form into a knot, or into knots; to tie together, as cord; to fasten by tying.","pos":""},{"def":"To form, as a textile fabric, by the interlacing of yarn or thread in a series of connected loops, by means of needles, either by hand or by machinery; as, to knit stockings.","pos":""}],"KNITBACK":[{"def":"The plant comfrey; -- so called from its use as a restorative.","pos":""},{"def":"A number of things tied or knit together; a bundle; a fagot.","pos":""}],"KNITS":[{"def":"Small particles of ore.","pos":""}],"KNITSTER":[{"def":"A woman who knits.","pos":""}],"KNITTER":[{"def":"One who, or that which, knits, joins, or unites; a knitting machine.","pos":""}],"KNITTING":[{"def":"The work of a knitter; the network formed by knitting.","pos":""},{"def":"Union formed by knitting, as of bones.","pos":""}],"KNITTLE":[{"def":"A string that draws together a purse or bag.","pos":""}]}