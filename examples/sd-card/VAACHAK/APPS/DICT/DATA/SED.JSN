{"SEDAN":[{"def":"A portable chair or covered vehicle for carrying a single person, -- usually borne on poles by two men.","pos":""}],"SEDATE":[{"def":"Undisturbed by passion or caprice; calm; tranquil; serene; not passionate or giddy; composed; staid; as, a sedate soul, mind, or temper.","pos":""}],"SEDATION":[{"def":"The act of calming, or the state of being calm.","pos":""}],"SEDATIVE":[{"def":"Tending to calm, moderate, or tranquilize; specifically (Med.","pos":""}],"SEDENT":[{"def":"Sitting; inactive; quiet.","pos":""}],"SEDENTARILY":[{"def":"In a sedentary manner.","pos":""}],"SEDENTARINESS":[{"def":"Quality of being sedentary.","pos":""}],"SEDENTARY":[{"def":"Remaining in one place, especially when firmly attached to some object; as, the oyster is a sedentary mollusk; the barnacles are sedentary crustaceans.","pos":""}],"SEDERUNT":[{"def":"A sitting, as of a court or other body.","pos":""}],"SEDGE":[{"def":"Any plant of the genus Carex, perennial, endogenous herbs, often growing in dense tufts in marshy places.","pos":""},{"def":"A flock of herons.","pos":""}],"SEDGED":[{"def":"Made or composed of sedge.","pos":""}],"SEDGY":[{"def":"Overgrown with sedge.","pos":""}],"SEDILIA":[{"def":"Seats in the chancel of a church near the altar for the officiating clergy during intervals of service.","pos":""}],"SEDIMENT":[{"def":"The material of which sedimentary rocks are formed.","pos":""}],"SEDIMENTARY":[{"def":"Of or pertaining to sediment; formed by sediment; containing matter that has subsided.","pos":""}],"SEDIMENTATION":[{"def":"The act of depositing a sediment; specifically (Geol.","pos":""}],"SEDITION":[{"def":"The raising of commotion in a state, not amounting to insurrection; conduct tending to treason, but without an overt act; excitement of discontent against the government, or of resistance to lawful authority.","pos":""},{"def":"Dissension; division; schism.","pos":""}],"SEDITIONARY":[{"def":"An inciter or promoter of sedition.","pos":""}],"SEDITIOUS":[{"def":"Of or pertaining to sedition; partaking of the nature of, or tending to excite, sedition; as, seditious behavior; seditious strife; seditious words.","pos":""},{"def":"Disposed to arouse, or take part in, violent opposition to lawful authority; turbulent; factious; guilty of sedition; as, seditious citizens.","pos":""}],"SEDLITZ":[{"def":"Same as Seidlitz.","pos":""}],"SEDUCE":[{"def":"To draw aside from the path of rectitude and duty in any manner; to entice to evil; to lead astray; to tempt and lead to iniquity; to corrupt.","pos":""},{"def":"Specifically, to induce to surrender chastity; to debauch by means of solicitation.","pos":""}],"SEDUCEMENT":[{"def":"The act of seducing.","pos":""},{"def":"The means employed to seduce, as flattery, promises, deception, etc.","pos":""}],"SEDUCER":[{"def":"One who, or that which, seduces; specifically, one who prevails over the chastity of a woman by enticements and persuasions.","pos":""}],"SEDUCIBLE":[{"def":"Capable of being seduced; corruptible.","pos":""}],"SEDUCTION":[{"def":"The act of seducing; enticement to wrong doing; specifically, the offense of inducing a woman to consent to unlawful sexual intercourse, by enticements which overcome her scruples; the wrong or crime of persuading a woman to surrender her chastity.","pos":""},{"def":"That which seduces, or is adapted to seduce; means of leading astray; as, the seductions of wealth.","pos":""}],"SEDUCTIVE":[{"def":"Tending to lead astray; apt to mislead by flattering appearances; tempting; alluring; as, a seductive offer.","pos":""}],"SEDUCTIVELY":[{"def":"In a seductive manner.","pos":""}],"SEDUCTRESS":[{"def":"A woman who seduces.","pos":""}],"SEDULITY":[{"def":"The quality or state of being sedulous; diligent and assiduous application; constant attention; unremitting industry; sedulousness.","pos":""}],"SEDULOUS":[{"def":"Diligent in application or pursuit; constant, steady, and persevering in business, or in endeavors to effect an object; steadily industrious; assiduous; as, the sedulous bee.","pos":""}],"SEDUM":[{"def":"A genus of plants, mostly perennial, having succulent leaves and cymose flowers; orpine; stonecrop.","pos":""}]}