{"POLACCA":[{"def":"A vessel with two or three masts, used in the Mediterranean.","pos":""}],"POLACRE":[{"def":"Same as Polacca, 1.","pos":""}],"POLANDER":[{"def":"A native or inhabitant of Poland; a Pole.","pos":""}],"POLAR":[{"def":"Pertaining to, reckoned from, or having a common radiating point; as, polar coördinates.","pos":""}],"POLARILY":[{"def":"In a polary manner; with polarity.","pos":""}],"POLARIMETER":[{"def":"An instrument for determining the amount of polarization of light, or the proportion of polarized light, in a partially polarized ray.","pos":""}],"POLARIMETRY":[{"def":"The art or process of measuring the polarization of light.","pos":""}],"POLARISCOPE":[{"def":"An instrument consisting essentially of a polarizer and an analyzer, used for polarizing light, and analyzing its properties.","pos":""}],"POLARISCOPIC":[{"def":"Of or pertaining to the polariscope; obtained by the use of a polariscope; as, polariscopic observations.","pos":""}],"POLARISCOPY":[{"def":"The art or rocess of making observations with the polariscope.","pos":""}],"POLARISTIC":[{"def":"Pertaining to, or exhibiting, poles; having a polar arrangement or disposition; arising from, or dependent upon, the possession of poles or polar characteristics; as, polaristic antagonism.","pos":""}],"POLARITY":[{"def":"A property of the conic sections by virtue of which a given point determines a corresponding right line and a given right line determines a corresponding point.","pos":""}],"POLARIZABLE":[{"def":"Susceptible of polarization.","pos":""}],"POLARIZATION":[{"def":"A peculiar affection or condition of the rays of light or heat, in consequence of which they exhibit different properties in different directions.","pos":""},{"def":"An effect produced upon the plates of a voltaic battery, or the electrodes in an electrolytic cell, by the deposition upon them of the gases liberated by the action of the current.","pos":""}],"POLARIZE":[{"def":"To communicate polarity to.","pos":""}],"POLARIZER":[{"def":"That which polarizes; especially, the part of a polariscope which receives and polarizes the light.","pos":""}],"POLARY":[{"def":"Tending to a pole; having a direction toward a pole.","pos":""}],"POLATOUCHE":[{"def":"A flying squirrel (Sciuropterus volans) native of Northern Europe and Siberia; -- called also minene.","pos":""}]}