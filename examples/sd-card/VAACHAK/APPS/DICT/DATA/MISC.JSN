{"MISCALCULATE":[{"def":"To calculate erroneously; to judge wrongly.","pos":""}],"MISCALL":[{"def":"To call by a wrong name; to name improperly.","pos":""},{"def":"To call by a bad name; to abuse.","pos":""}],"MISCARRIAGE":[{"def":"Unfortunate event or issue of an undertaking; failure to attain a desired result or reach a destination.","pos":""},{"def":"Ill conduct; evil or improper behavior; as, the failings and miscarriages of the righteous.","pos":""}],"MISCARRIAGEABLE":[{"def":"Capable of miscarrying; liable to fail.","pos":""}],"MISCARRY":[{"def":"To carry, or go, wrong; to fail of reaching a destination, or fail of the intended effect; to be unsuccessful; to suffer defeat.","pos":""},{"def":"To bring forth young before the proper time.","pos":""}],"MISCAST":[{"def":"To cast or reckon wrongly.","pos":""}],"MISCEGENATION":[{"def":"A mixing of races; amalgamation, as by intermarriage of black and white.","pos":""}],"MISCELLANARIAN":[{"def":"Of or pertaining to miscellanies.","pos":""},{"def":"A writer of miscellanies.","pos":""}],"MISCELLANE":[{"def":"A mixture of two or more sorts of grain; -- now called maslin and meslin.","pos":""}],"MISCELLANEA":[{"def":"A collection of miscellaneous matters; matters of various kinds.","pos":""}],"MISCELLANEOUS":[{"def":"Mixed; mingled; consisting of several things; of diverse sorts; promiscuous; heterogeneous; as, a miscellaneous collection.","pos":""}],"MISCELLANIST":[{"def":"A writer of miscellanies; miscellanarian.","pos":""}],"MISCELLANY":[{"def":"A mass or mixture of various things; a medley; esp.","pos":""}],"MISCENSURE":[{"def":"Erroneous judgment.","pos":""}],"MISCHANCE":[{"def":"Ill luck; ill fortune; mishap.","pos":""}],"MISCHARACTERIZE":[{"def":"To characterize falsely or erroneously; to give a wrong character to.","pos":""}],"MISCHARGE":[{"def":"To charge erroneously, as in account.","pos":""},{"def":"A mistake in charging.","pos":""}],"MISCHIEF":[{"def":"Harm; damage; esp.","pos":""},{"def":"Cause of trouble or vexation; trouble.","pos":""}],"MISCHIEF-MAKER":[{"def":"One who makes mischief; one who excites or instigates quarrels or enmity.","pos":""}],"MISCHIEF-MAKING":[{"def":"Causing harm; exciting enmity or quarrels.","pos":""},{"def":"The act or practice of making mischief, inciting quarrels, etc.","pos":""}],"MISCHIEVOUS":[{"def":"Causing mischief; harmful; hurtful; -- now often applied where the evil is done carelessly or in sport; as, a mischievous child.","pos":""}],"MISCHOOSE":[{"def":"To choose wrongly.","pos":""}],"MISCHRISTEN":[{"def":"To christen wrongly.","pos":""}],"MISCIBILITY":[{"def":"Capability of being mixed.","pos":""}],"MISCIBLE":[{"def":"Capable of being mixed; mixable; as, water and alcohol are miscible in all proportions.","pos":""}],"MISCITATION":[{"def":"Erroneous citation.","pos":""}],"MISCITE":[{"def":"To cite erroneously.","pos":""}],"MISCLAIM":[{"def":"A mistaken claim.","pos":""}],"MISCOGNIZANT":[{"def":"Not cognizant; ignorant; not knowing.","pos":""}],"MISCOGNIZE":[{"def":"To fail to apprehend; to misunderstand.","pos":""}],"MISCOLLOCATION":[{"def":"Wrong collocation.","pos":""}],"MISCOLOR":[{"def":"To give a wrong color to; figuratively, to set forth erroneously or unfairly; as, to miscolor facts.","pos":""}],"MISCOMPREHEND":[{"def":"To get a wrong idea of or about; to misunderstand.","pos":""}],"MISCOMPUTATION":[{"def":"Erroneous computation; false reckoning.","pos":""}],"MISCOMPUTE":[{"def":"To compute erroneously.","pos":""}],"MISCONCEIVE":[{"def":"To conceive wrongly; to interpret incorrectly; to receive a false notion of; to misjudge; to misapprehend.","pos":""}],"MISCONCEIVER":[{"def":"One who misconceives.","pos":""}],"MISCONCEPTION":[{"def":"Erroneous conception; false opinion; wrong understanding.","pos":""}],"MISCONCLUSION":[{"def":"An erroneous inference or conclusion.","pos":""}],"MISCONDUCT":[{"def":"Wrong conduct; bad behavior; mismanagement.","pos":""}],"MISCONFIDENT":[{"def":"Having a mistaken confidence; wrongly trusting.","pos":""}],"MISCONJECTURE":[{"def":"A wrong conjecture or guess.","pos":""}],"MISCONSECRATE":[{"def":"To consecrate amiss.","pos":""}],"MISCONSECRATION":[{"def":"Wrong consecration.","pos":""}],"MISCONSEQUENCE":[{"def":"A wrong consequence; a false deduction.","pos":""}],"MISCONSTRUABLE":[{"def":"Such as can be misconstrued, as language or conduct.","pos":""}],"MISCONSTRUCT":[{"def":"To construct wrongly; to construe or interpret erroneously.","pos":""}],"MISCONSTRUCTION":[{"def":"Erroneous construction; wrong interpretation.","pos":""}],"MISCONSTRUE":[{"def":"To construe wrongly; to interpret erroneously.","pos":""}],"MISCONSTRUER":[{"def":"One who misconstrues.","pos":""}],"MISCONTINUANCE":[{"def":"Discontinuance; also, continuance by undue process.","pos":""}],"MISCOPY":[{"def":"A mistake in copying.","pos":""}],"MISCORRECT":[{"def":"To fail or err in attempting to correct.","pos":""}],"MISCOUNSEL":[{"def":"To counsel or advise wrongly.","pos":""}],"MISCOUNT":[{"def":"To count erroneously.","pos":""}],"MISCOVET":[{"def":"To covet wrongfully.","pos":""},{"def":"The quality of being miscreant; adherence to a false religion; false faith.","pos":""}],"MISCREANT":[{"def":"One who holds a false religious faith; a misbeliever.","pos":""},{"def":"One not restrained by Christian principles; an unscrupulous villain; a while wretch.","pos":""}],"MISCREATE":[{"def":"Miscreated; illegitimate; forged; as, miscreate titles.","pos":""}],"MISCREATED":[{"def":"Formed unnaturally or illegitimately; deformed.","pos":""}],"MISCREDENT":[{"def":"A miscreant, or believer in a false religious doctrine.","pos":""}],"MISCREDULITY":[{"def":"Wrong credulity or belief; misbelief.","pos":""}],"MISCUE":[{"def":"A false stroke with a billiard cue, the cue slipping from the ball struck without impelling it as desired.","pos":""}]}