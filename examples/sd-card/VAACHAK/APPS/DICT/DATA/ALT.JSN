{"ALT":[{"def":"The higher part of the scale.","pos":""},{"def":"Of or pertaining to the Altai, a mountain chain in Central Asia.","pos":""}],"ALTAR":[{"def":"A raised structure (as a square or oblong erection of stone or wood) on which sacrifices are offered or incense burned to a deity.","pos":""},{"def":"In the Christian church, a construction of stone, wood, or other material for the celebration of the Holy Eucharist; the communion table.","pos":""}],"ALTARAGE":[{"def":"The offerings made upon the altar, or to a church.","pos":""},{"def":"The profit which accrues to the priest, by reason of the altar, from the small tithes.","pos":""}],"ALTARPIECE":[{"def":"The painting or piece of sculpture above and behind the altar; reredos.","pos":""}],"ALTARWISE":[{"def":"In the proper position of an altar, that is, at the east of a church with its ends towards the north and south.","pos":""}],"ALTAZIMUTH":[{"def":"An instrument for taking azimuths and altitudes simultaneously.","pos":""}],"ALTER":[{"def":"To make otherwise; to change in some respect, either partially or wholly; to vary; to modify.","pos":""},{"def":"To agitate; to affect mentally.","pos":""}],"ALTERABILITY":[{"def":"The quality of being alterable; alterableness.","pos":""}],"ALTERABLE":[{"def":"Capable of being altered.","pos":""}],"ALTERABLENESS":[{"def":"The quality of being alterable; variableness; alterability.","pos":""}],"ALTERABLY":[{"def":"In an alterable manner.","pos":""}],"ALTERANT":[{"def":"Altering; gradually changing.","pos":""}],"ALTERATION":[{"def":"The act of altering or making different.","pos":""},{"def":"The state of being altered; a change made in the form or nature of a thing; changed condition.","pos":""}],"ALTERATIVE":[{"def":"Causing ateration.","pos":""},{"def":"Gradually changing, or tending to change, a morbid state of the functions into one of health.","pos":""}],"ALTERCATE":[{"def":"The contend in words; to dispute with zeal, heat, or anger; to wrangle.","pos":""}],"ALTERCATION":[{"def":"Warm contention in words; dispute carried on with heat or anger; controversy; wrangle; wordy contest.","pos":""}],"ALTERCATIVE":[{"def":"Characterized by wrangling; scolding.","pos":""}],"ALTERITY":[{"def":"The state or quality of being other; a being otherwise.","pos":""}],"ALTERN":[{"def":"Acting by turns; alternate.","pos":""}],"ALTERNACY":[{"def":"Alternateness; alternation.","pos":""}],"ALTERNANT":[{"def":"Composed of alternate layers, as some rocks.","pos":""}],"ALTERNAT":[{"def":"A usage, among diplomats, of rotation in precedence among representatives of equal rank, sometimes determined by lot and at other times in regular order.","pos":""}],"ALTERNATE":[{"def":"Distributed, as leaves, singly at different heights of the stem, and at equal intervals as respects angular divergence.","pos":""}],"ALTERNATELY":[{"def":"By alternation; when, in a proportion, the antecedent term is compared with antecedent, and consequent.","pos":""}],"ALTERNATENESS":[{"def":"The quality of being alternate, or of following by turns.","pos":""}],"ALTERNATING CURRENT":[{"def":"A current which periodically changes or reverses its direction of flow.","pos":""}],"ALTERNATION":[{"def":"The reciprocal succession of things in time or place; the act of following and being followed by turns; alternate succession, performance, or occurrence; as, the alternation of day and night, cold and heat, summer and winter, hope and fear.","pos":""},{"def":"The response of the congregation speaking alternately with the minister.","pos":""}],"ALTERNATIVE":[{"def":"Offering a choice of two things.","pos":""},{"def":"Disjunctive; as, an alternative conjunction.","pos":""}],"ALTERNATIVELY":[{"def":"In the manner of alternatives, or that admits the choice of one out of two things.","pos":""}],"ALTERNATIVENESS":[{"def":"The quality of being alternative, or of offering a choice between two.","pos":""}],"ALTERNATOR":[{"def":"An electric generator or dynamo for producing alternating currents.","pos":""}],"ALTERNITY":[{"def":"Succession by turns; alternation.","pos":""}],"ALTHING":[{"def":"The national assembly or parliament of Iceland.","pos":""}],"ALTHO":[{"def":"An instrument of the saxhorn family, used exclusively in military music, often replacing the French horn.","pos":""}],"ALTHORN":[{"def":"An instrument of the saxhorn family, used exclusively in military music, often replacing the French horn.","pos":""}],"ALTHOUGH":[{"def":"Grant all this; be it that; supposing that; notwithstanding; though.","pos":""}],"ALTILOQUENCE":[{"def":"Lofty speech; pompous language.","pos":""}],"ALTILOQUENT":[{"def":"High-sounding; pompous in speech.","pos":""}],"ALTIMETER":[{"def":"An instrument for taking altitudes, as a quadrant, sextant, etc.","pos":""}],"ALTIMETRY":[{"def":"The art of measuring altitudes, or heights.","pos":""}],"ALTISCOPE":[{"def":"An arrangement of lenses and mirrors which enables a person to see an object in spite of intervening objects.","pos":""}],"ALTISONANT":[{"def":"High-sounding; lofty or pompous.","pos":""}],"ALTISSIMO":[{"def":"The part or notes situated above F in alt.","pos":""}],"ALTITUDE":[{"def":"The elevation of a point, or star, or other celestial object, above the horizon, measured by the arc of a vertical circle intercepted between such point and the horizon.","pos":""},{"def":"The perpendicular distance from the base of a figure to the summit, or to the side parallel to the base; as, the altitude of a triangle, pyramid, parallelogram, frustum, etc.","pos":""}],"ALTITUDINAL":[{"def":"Of or pertaining to height; as, altitudinal measurements.","pos":""}],"ALTITUDINARIAN":[{"def":"Lofty in doctrine, aims, etc.","pos":""}],"ALTO":[{"def":"Formerly the part sung by the highest male, or counter-tenor, voices; now the part sung by the lowest female, or contralto, voices, between in tenor and soprano.","pos":""}],"ALTO-CUMULUS":[{"def":"A fleecy cloud formation consisting of large whitish or grayish globular cloudlets with shaded portions, often grouped in flocks or rows.","pos":""}],"ALTO-RILIEVO":[{"def":"High relief; sculptured work in which the figures project more than half their thickness; as, this figure is an alto-rilievo or in alto-rilievo.","pos":""}],"ALTO-STRATUS":[{"def":"A cloud formation similar to cirro-stratus, but heavier and at a lower level.","pos":""}],"ALTOGETHER":[{"def":"All together; conjointly.","pos":""},{"def":"Without exception; wholly; completely.","pos":""}],"ALTRICAL":[{"def":"Like the articles.","pos":""}],"ALTRICES":[{"def":"Nursers, -- a term applied to those birds whose young are hatched in a very immature and helpless condition, so as to require the care of their parents for some time; -- opposed to præcoces.","pos":""}],"ALTRUISM":[{"def":"Regard for others, both natural and moral; devotion to the interests of others; brotherly kindness; -- opposed to egoism or selfishness.","pos":""}],"ALTRUIST":[{"def":"One imbued with altruism; -- opposed to egoist.","pos":""}],"ALTRUISTIC":[{"def":"Regardful of others; beneficent; unselfish; -- opposed to Ant: egoistic or Ant: selfish.","pos":""}]}