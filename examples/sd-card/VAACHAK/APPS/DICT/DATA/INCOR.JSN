{"INCORPORAL":[{"def":"Immaterial; incorporeal; spiritual.","pos":""}],"INCORPORALITY":[{"def":"In*cor`po*ral\"i*ty, n.","pos":""}],"INCORPORALLY":[{"def":"In*cor\"po*ral*ly, adv.","pos":""}],"INCORPORATE":[{"def":"Not consisting of matter; not having a material body; incorporeal; spiritual.","pos":""},{"def":"Not incorporated; not existing as a corporation; as, an incorporate banking association.","pos":""}],"INCORPORATED":[{"def":"United in one body; formed into a corporation; made a legal entity.","pos":""}],"INCORPORATION":[{"def":"The act of incorporating, or the state of being incorporated.","pos":""},{"def":"The union of different ingredients in one mass; mixture; combination; synthesis.","pos":""}],"INCORPORATIVE":[{"def":"Incorporating or tending to incorporate; as, the incorporative languages (as of the Basques, North American Indians, etc.","pos":""}],"INCORPORATOR":[{"def":"One of a number of persons who gets a company incorporated; one of the original members of a corporation.","pos":""}],"INCORPOREAL":[{"def":"Existing only in contemplation of law; not capable of actual visible seizin or possession; not being an object of sense; intangible; -- opposed to corporeal.","pos":""}],"INCORPOREALISM":[{"def":"Existence without a body or material form; immateriality.","pos":""}],"INCORPOREALIST":[{"def":"One who believes in incorporealism.","pos":""}],"INCORPOREALITY":[{"def":"The state or quality of being incorporeal or bodiless; immateriality; incorporealism.","pos":""}],"INCORPOREALLY":[{"def":"In an incorporeal manner.","pos":""}],"INCORPOREITY":[{"def":"The quality of being incorporeal; immateriality.","pos":""}],"INCORRECT":[{"def":"Not correct; not according to a copy or model, or to established rules; inaccurate; faulty.","pos":""},{"def":"Not in accordance with the truth; inaccurate; not exact; as, an incorrect statement or calculation.","pos":""}],"INCORRECTION":[{"def":"Want of correction, restraint, or discipline.","pos":""}],"INCORRECTLY":[{"def":"Not correctly; inaccurately; not exactly; as, a writing incorrectly copied; testimony incorrectly stated.","pos":""}],"INCORRECTNESS":[{"def":"The quality of being incorrect; want of conformity to truth or to a standard; inaccuracy; inexactness; as incorrectness may in defect or in redundance.","pos":""},{"def":"Want of correspondence; disagreement; disproportion.","pos":""}],"INCORRESPONDING":[{"def":"Not corresponding; disagreeing.","pos":""}],"INCORRIGIBILITY":[{"def":"The state or quality of being incorrigible.","pos":""}],"INCORRIGIBLE":[{"def":"Not corrigible; incapable of being corrected or amended; bad beyond correction; irreclaimable; as, incorrigible error.","pos":""}],"INCORRIGIBLENESS":[{"def":"Incorrigibility.","pos":""}],"INCORRIGIBLY":[{"def":"In an incorrigible manner.","pos":""}],"INCORRODIBLE":[{"def":"Incapable of being corroded, consumed, or eaten away.","pos":""}],"INCORRUPT":[{"def":"Not affected with corruption or decay; unimpaired; not marred or spoiled.","pos":""},{"def":"Not defiled or depraved; pure; sound; untainted; above the influence of bribes; upright; honest.","pos":""}],"INCORRUPTED":[{"def":"Breathed into their incorrupted breasts.","pos":""}],"INCORRUPTIBILITY":[{"def":"The quality of being incorruptible; incapability of corruption.","pos":""}],"INCORRUPTIBLE":[{"def":"Not corruptible; incapable of corruption, decay, or dissolution; as, gold is incorruptible.","pos":""},{"def":"Incapable of being bribed or morally corrupted; inflexibly just and upright.","pos":""}],"INCORRUPTIBLENESS":[{"def":"The quality or state of being incorruptible.","pos":""}],"INCORRUPTIBLY":[{"def":"In an incorruptible manner.","pos":""}],"INCORRUPTION":[{"def":"The condition or quality of being incorrupt or incorruptible; absence of, or exemption from, corruption.","pos":""}],"INCORRUPTIVE":[{"def":"Incorruptible; not liable to decay.","pos":""}],"INCORRUPTLY":[{"def":"Without corruption.","pos":""}],"INCORRUPTNESS":[{"def":"Freedom or exemption from decay or corruption.","pos":""},{"def":"Probity; integrity; honesty.","pos":""}]}