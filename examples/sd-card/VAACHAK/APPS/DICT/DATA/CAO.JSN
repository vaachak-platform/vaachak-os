{"CAONCITO":[{"def":"A narrow passage or lane through chaparral or a forest.","pos":""}],"CAOUTCHIN":[{"def":"An inflammable, volatile, oily, liquid hydrocarbon, obtained by the destructive distillation of caoutchouc.","pos":""}],"CAOUTCHOUC":[{"def":"A tenacious, elastic, gummy substance obtained from the milky sap of several plants of tropical South America (esp.","pos":""}]}