{"DEVANAGARI":[{"def":"The character in which Sanskrit is written.","pos":""}],"DEVAPORATION":[{"def":"The change of vapor into water, as in the formation of rain.","pos":""}],"DEVASTATE":[{"def":"To lay waste; to ravage; to desolate.","pos":""}],"DEVASTATION":[{"def":"Waste of the goods of the deceased by an executor or administrator.","pos":""}],"DEVASTATOR":[{"def":"One who, or that which, devastates.","pos":""}],"DEVASTAVIT":[{"def":"Waste or misapplication of the assets of a deceased person by an executor or an administrator.","pos":""}],"DEVATA":[{"def":"A deity; a divine being; a good spirit; an idol.","pos":""}],"DEVELIN":[{"def":"The European swift.","pos":""}],"DEVELOP":[{"def":"To change the form of, as of an algebraic expression, by executing certain indicated operations without changing the value.","pos":""},{"def":"To cause to become visible, as an invisible or latent image upon plate, by submitting it to chemical agents; to bring to view.","pos":""}],"DEVELOPABLE":[{"def":"Capable of being developed.","pos":""}],"DEVELOPER":[{"def":"A reagent by the action of which the latent image upon a photographic plate, after exposure in the camera, or otherwise, is developed and visible.","pos":""}],"DEVELOPMENT":[{"def":"The series of changes which animal and vegetable organisms undergo in their passage from the embryonic state to maturity, from a lower to a higher state of organization.","pos":""},{"def":"The elaboration of a theme or subject; the unfolding of a musical idea; the evolution of a whole piece or movement from a leading theme or motive.","pos":""}],"DEVELOPMENTAL":[{"def":"Pertaining to, or characteristic of, the process of development; as, the developmental power of a germ.","pos":""}],"DEVENUSTATE":[{"def":"To deprive of beauty or grace.","pos":""}],"DEVEST":[{"def":"To divest; to undress.","pos":""},{"def":"To take away, as an authority, title, etc.","pos":""}],"DEVEX":[{"def":"Bending down; sloping.","pos":""}],"DEVEXITY":[{"def":"A bending downward; a sloping; incurvation downward; declivity.","pos":""}],"DEVIATE":[{"def":"To go out of the way; to turn aside from a course or a method; to stray or go astray; to err; to digress; to diverge; to vary.","pos":""}],"DEVIATION":[{"def":"The voluntary and unnecessary departure of a ship from, or delay in, the regular and usual course of the specific voyage insured, thus releasing the underwriters from their responsibility.","pos":""}],"DEVIATOR":[{"def":"One who, or that which, deviates.","pos":""}],"DEVIATORY":[{"def":"Tending to deviate; devious; as, deviatory motion.","pos":""}],"DEVICE":[{"def":"That which is devised, or formed by design; a contrivance; an invention; a project; a scheme; often, a scheme to deceive; a stratagem; an artifice.","pos":""},{"def":"Power of devising; invention; contrivance.","pos":""}],"DEVICEFUL":[{"def":"Full of devices; inventive.","pos":""}],"DEVICEFULLY":[{"def":"In a deviceful manner.","pos":""}],"DEVIL":[{"def":"A dish, as a bone with the meat, broiled and excessively peppered; a grill with Cayenne pepper.","pos":""},{"def":"A machine for tearing or cutting rags, cotton, etc.","pos":""}],"DEVIL'S DARNING-NEEDLE":[{"def":"Dev\"il's darn\"ing-nee`dle.","pos":""}],"DEVILISH":[{"def":"Resembling, characteristic of, or pertaining to, the devil; diabolical; wicked in the extreme.","pos":""},{"def":"Extreme; excessive.","pos":""}],"DEVILISM":[{"def":"The state of the devil or of devils; doctrine of the devil or of devils.","pos":""}],"DEVILIZE":[{"def":"To make a devil of.","pos":""}],"DEVILKIN":[{"def":"A little devil; a devilet.","pos":""}],"DEVILRY":[{"def":"Conduct suitable to the devil; extreme wickedness; deviltry.","pos":""},{"def":"The whole body of evil spirits.","pos":""}],"DEVILSHIP":[{"def":"The character or person of a devil or the devil.","pos":""}],"DEVILTRY":[{"def":"Diabolical conduct; malignant mischief; devilry.","pos":""}],"DEVILWOOD":[{"def":"A kind of tree (Osmanthus Americanus), allied to the European olive.","pos":""}],"DEVIOUS":[{"def":"Out of a straight line; winding; varying from directness; as, a devious path or way.","pos":""},{"def":"Going out of the right or common course; going astray; erring; wandering; as, a devious step.","pos":""}],"DEVIRGINATE":[{"def":"Deprived of virginity.","pos":""}],"DEVISABLE":[{"def":"Capable of being devised, invented, or contrived.","pos":""},{"def":"Capable of being bequeathed, or given by will.","pos":""}],"DEVISE":[{"def":"To give by will; -- used of real estate; formerly, also, of chattels.","pos":""}],"DEVISEE":[{"def":"One to whom a devise is made, or real estate given by will.","pos":""}],"DEVISER":[{"def":"One who devises.","pos":""}],"DEVISOR":[{"def":"One who devises, or gives real estate by will; a testator; -- correlative to devisee.","pos":""}],"DEVITALIZE":[{"def":"To deprive of life or vitality.","pos":""}],"DEVITATION":[{"def":"An avoiding or escaping; also, a warning.","pos":""}],"DEVITRIFICATION":[{"def":"The act or process of devitrifying, or the state of being devitrified.","pos":""}],"DEVITRIFY":[{"def":"To deprive of glasslike character; to take away vitreous luster and transparency from.","pos":""}],"DEVOCALIZE":[{"def":"To make toneless; to deprive of vowel quality.","pos":""}],"DEVOCATION":[{"def":"A calling off or away.","pos":""}],"DEVOID":[{"def":"To empty out; to remove.","pos":""}],"DEVOIR":[{"def":"Duty; service owed; hence, due act of civility or respect; -- now usually in the plural; as, they paid their devoirs to the ladies.","pos":""}],"DEVOLUTION":[{"def":"The act of rolling down.","pos":""},{"def":"Transference from one person to another; a passing or devolving upon a successor.","pos":""}],"DEVOLVE":[{"def":"To roll onward or downward; to pass on.","pos":""},{"def":"To transfer from one person to another; to deliver over; to hand down; -- generally with upon, sometimes with to or into.","pos":""}],"DEVOLVEMENT":[{"def":"The act or process of devolving;; devolution.","pos":""}],"DEVON":[{"def":"One of a breed of hardy cattle originating in the country of Devon, England.","pos":""}],"DEVONIAN":[{"def":"Of or pertaining to Devon or Devonshire in England; as, the Devonian rocks, period, or system.","pos":""}],"DEVORATION":[{"def":"The act of devouring.","pos":""}],"DEVOTE":[{"def":"To appropriate by vow; to set apart or dedicate by a solemn act; to consecrate; also, to consign over; to doom; to evil; to devote one to destruction; the city was devoted to the flames.","pos":""},{"def":"To execrate; to curse.","pos":""}],"DEVOTED":[{"def":"Consecrated to a purpose; strongly attached; zealous; devout; as, a devoted admirer.","pos":""}],"DEVOTEE":[{"def":"One who is wholly devoted; esp.","pos":""}],"DEVOTEMENT":[{"def":"The state of being devoted, or set apart by a vow.","pos":""}],"DEVOTER":[{"def":"One who devotes; a worshiper.","pos":""}],"DEVOTION":[{"def":"The act of devoting; consecration.","pos":""},{"def":"The state of being devoted; addiction; eager inclination; strong attachment love or affection; zeal; especially, feelings toward God appropriately expressed by acts of worship; devoutness.","pos":""}],"DEVOTIONAL":[{"def":"Pertaining to, suited to, or used in, devotion; as, a devotional posture; devotional exercises; a devotional frame of mind.","pos":""},{"def":"One given to devotion, esp.","pos":""}],"DEVOTIONALITY":[{"def":"The practice of a devotionalist.","pos":""}],"DEVOTIONALLY":[{"def":"In a devotional manner; toward devotion.","pos":""}],"DEVOTOR":[{"def":"A worshiper; one given to devotion.","pos":""}],"DEVOUR":[{"def":"To eat up with greediness; to consume ravenously; to feast upon like a wild beast or a glutton; to prey upon.","pos":""},{"def":"To seize upon and destroy or appropriate greedily, selfishly, or wantonly; to consume; to swallow up; to use up; to waste; to annihilate.","pos":""}],"DEVOURABLE":[{"def":"That may be devoured.","pos":""}],"DEVOURER":[{"def":"One who, or that which, devours.","pos":""}],"DEVOURINGLY":[{"def":"In a devouring manner.","pos":""}],"DEVOUT":[{"def":"Devoted to religion or to religious feelings and duties; absorbed in religious exercises; given to devotion; pious; reverent; religious.","pos":""},{"def":"Expressing devotion or piety; as, eyes devout; sighs devout; a devout posture.","pos":""}],"DEVOUTFUL":[{"def":"Full of devotion.","pos":""}],"DEVOUTLESS":[{"def":"Destitute of devotion.","pos":""}],"DEVOUTLY":[{"def":"In a devout and reverent manner; with devout emotions; piously.","pos":""},{"def":"Sincerely; solemnly; earnestly.","pos":""}],"DEVOUTNESS":[{"def":"Quality or state of being devout.","pos":""}],"DEVOW":[{"def":"To disavow; to disclaim.","pos":""}],"DEVULGARIZE":[{"def":"To free from what is vulgar, common, or narrow.","pos":""}]}