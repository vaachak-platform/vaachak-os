{"ETACISM":[{"def":"The pronunciation of the Greek ê (eta) like the Italian e long, that is like a in the English word ate.","pos":""}],"ETACIST":[{"def":"One who favors etacism.","pos":""}],"ETAGERE":[{"def":"A piece of furniture having a number of uninclosed shelves or stages, one above another, for receiving articles of elegance or use.","pos":""}],"ETAMINE":[{"def":"A light textile fabric, like a fine bunting.","pos":""}],"ETAPE":[{"def":"A public storehouse.","pos":""},{"def":"the place where troops on the march halt over night; also, by extension, the distance marched during a day.","pos":""}],"ETAT MAJOR":[{"def":"The staff of an army, including all officers above the rank of colonel, also, all adjutants, inspectors, quartermasters, commissaries, engineers, ordnance officers, paymasters, physicians, signal officers, judge advocates; also, the noncommissioned assistants of the above officers.","pos":""},{"def":"Others of the like kind; and the rest; and so on; -- used to point out that other things which could be mentioned are to be understood.","pos":""}],"ETCH":[{"def":"A variant of Eddish.","pos":""}],"ETCHING":[{"def":"The act, art, or practice of engraving by means of acid which eats away lines or surfaces left unprotected in metal, glass, or the like.","pos":""},{"def":"A design carried out by means of the above process; a pattern on metal, glass, etc.","pos":""}],"ETEOSTIC":[{"def":"A kind of chronogram.","pos":""}],"ETERMINABLE":[{"def":"ETERN; ETERNE E*tern\" or E*terne\", a.","pos":""}],"ETERNAL":[{"def":"Without beginning or end of existence; always existing.","pos":""},{"def":"Without end of existence or duration; everlasting; endless; immortal.","pos":""}],"ETERNALIST":[{"def":"One who holds the existence of matter to be from eternity.","pos":""}],"ETERNALIZE":[{"def":"To make eternal.","pos":""}],"ETERNALLY":[{"def":"In an eternal manner.","pos":""}],"ETERNIFY":[{"def":"To make eternal.","pos":""}],"ETERNITY":[{"def":"Infinite duration, without beginning in the past or end in the future; also, duration without end in the future; endless time.","pos":""},{"def":"Condition which begins at death; immortality.","pos":""}],"ETERNIZATION":[{"def":"The act of eternizing; the act of rendering immortal or famous.","pos":""}],"ETERNIZE":[{"def":"To make eternal or endless.","pos":""},{"def":"To make forever famous; to immortalize; as, to eternize one's self, a name, exploits.","pos":""}],"ETESIAN":[{"def":"Periodical; annual; -- applied to winds which annually blow from the north over the Mediterranean, esp.","pos":""}],"ETHAL":[{"def":"A white waxy solid, C16H33.","pos":""}],"ETHANE":[{"def":"A gaseous hydrocarbon, C2H6, forming a constituent of ordinary illuminating gas.","pos":""}],"ETHENE":[{"def":"Ethylene; olefiant gas.","pos":""}],"ETHENIC":[{"def":"Pertaining to, derived from.","pos":""}],"ETHEOSTOMOID":[{"def":"Pertaining to, or like, the genus Etheostoma.","pos":""},{"def":"Any fish of the genus Etheostoma and related genera, allied to the perches; -- also called darter.","pos":""}],"ETHER":[{"def":"A medium of great elasticity and extreme tenuity, supposed to pervade all space, the interior of solid bodies not excepted, and to be the medium of transmission of light and heat; hence often called luminiferous ether.","pos":""}],"ETHEREAL":[{"def":"Pertaining to, derived from, or resembling, ether; as, ethereal salts.","pos":""}],"ETHEREALITY":[{"def":"The state of being ethereal; etherealness.","pos":""}],"ETHEREALIZATION":[{"def":"An ethereal or spiritlike state.","pos":""}],"ETHEREALIZE":[{"def":"To convert into ether, or into subtile fluid; to saturate with ether.","pos":""},{"def":"To render ethereal or spiritlike.","pos":""}],"ETHEREALLY":[{"def":"In an ethereal manner.","pos":""}],"ETHEREOUS":[{"def":"Pertaining to, or resembling, either.","pos":""}],"ETHERIFICATION":[{"def":"The act or process of making ether; specifically, the process by which a large quantity of alcohol is transformed into ether by the agency of a small amount of sulphuric, or ethyl sulphuric, acid.","pos":""}],"ETHERIFORM":[{"def":"Having the form of ether.","pos":""}],"ETHERIN":[{"def":"A white, crystalline hydrocarbon, regarded as a polymeric variety of ethylene, obtained in heavy oil of wine, the residue left after making ether; -- formerly called also concrete oil of wine.","pos":""}],"ETHERIZE":[{"def":"To convert into ether.","pos":""},{"def":"To render insensible by means of ether, as by inhalation; as, to etherize a patient.","pos":""}],"ETHEROL":[{"def":"An oily hydrocarbon regarded as a polymeric variety of ethylene, produced with etherin.","pos":""},{"def":"Of, or belonging to, morals; treating of the moral feelings or duties; containing percepts of morality; moral; as, ethic discourses or epistles; an ethical system; ethical philosophy.","pos":""}],"ETHICALLY":[{"def":"According to, in harmony with, moral principles or character.","pos":""}],"ETHICIST":[{"def":"One who is versed in ethics, or has written on ethics.","pos":""}],"ETHICS":[{"def":"The science of human duty; the body of rules of duty drawn from this science; a particular system of principles and rules concerting duty, whether true or false; rules of practice in respect to a single class of human actions; as, political or social ethics; medical ethics.","pos":""}],"ETHIDE":[{"def":"Any compound of ethyl of a binary type; as, potassium ethide.","pos":""}],"ETHIONIC":[{"def":"Pertaining to, derived from, or designating, an acid so called.","pos":""},{"def":"A native or inhabitant of Ethiopia; also, in a general sense, a negro or black man.","pos":""}],"ETHIOPIC":[{"def":"The language of ancient Ethiopia; the language of the ancient Abyssinian empire (in Ethiopia), now used only in the Abyssinian church.","pos":""}],"ETHIOPS":[{"def":"A black substance; -- formerly applied to various preparations of a black or very dark color.","pos":""}],"ETHMOID":[{"def":"The ethmoid bone.","pos":""}],"ETHMOTRUBINAL":[{"def":"An ethmoturbinal bone.","pos":""}],"ETHMOVOMERINE":[{"def":"Pertaining to the region of the vomer and the base of the ethmoid in the skull.","pos":""}],"ETHNARCH":[{"def":"The governor of a province or people.","pos":""}],"ETHNARCHY":[{"def":"The dominion of an ethnarch; principality and rule.","pos":""}],"ETHNIC":[{"def":"A heathen; a pagan.","pos":""}],"ETHNICALLY":[{"def":"In an ethnical manner.","pos":""}],"ETHNICISM":[{"def":"Heathenism; paganism; idolatry.","pos":""}],"ETHNOGRAPHER":[{"def":"One who investigates ethnography.","pos":""},{"def":"pertaining to ethnography.","pos":""}],"ETHNOGRAPHICALLY":[{"def":"In an ethnographical manner.","pos":""}],"ETHNOGRAPHY":[{"def":"That branch of knowledge which has for its subject the characteristics of the human family, developing the details with which ethnology as a comparative science deals; descriptive ethnology.","pos":""},{"def":"Of or pertaining to ethnology.","pos":""}],"ETHNOLOGICALLY":[{"def":"In an ethnological manner; by ethnological classification; as, one belonging ethnologically to an African race.","pos":""}],"ETHNOLOGIST":[{"def":"One versed in ethnology; a student of ethnology.","pos":""}],"ETHNOLOGY":[{"def":"The science which treats of the division of mankind into races, their origin, distribution, and relations, and the peculiarities which characterize them.","pos":""},{"def":"treating of, or pertaining to, ethnic or morality, or the science of character.","pos":""}],"ETHOLOGIST":[{"def":"One who studies or writes upon ethology.","pos":""}],"ETHOLOGY":[{"def":"A treatise on morality; ethics.","pos":""},{"def":"The science of the formation of character, national and collective as well as individual.","pos":""}],"ETHOPOETIC":[{"def":"Expressing character.","pos":""}],"ETHOS":[{"def":"The character, sentiment, or disposition of a community or people, considered as a natural endowment; the spirit which actuates manners and customs; also, the characteristic tone or genius of an institution or social organization.","pos":""}],"ETHULE":[{"def":"Eth\"ule Etym: [Ether + Gr.","pos":""}],"ETHYL":[{"def":"A monatomic, hydrocarbon radical, C2H5 of the paraffin series, forming the essential radical of ethane, and of common alcohol and ether.","pos":""}],"ETHYLAMINE":[{"def":"A colorless, mobile, inflammable liquid, C2H5.","pos":""}],"ETHYLATE":[{"def":"A compound derived from ethyl alcohol by the replacement of the hydroxyl hydrogen, after the manner of a hydrate; an ethyl alcoholate; as, potassium ethylate, C2H5.","pos":""}],"ETHYLENE":[{"def":"A colorless, gaseous hydrocarbon, C2H4, forming an important ingredient of illuminating gas, and also obtained by the action of concentrated sulphuric acid in alcohol.","pos":""}],"ETHYLIC":[{"def":"Pertaining to, derived from, or containing, ethyl; as, ethylic alcohol.","pos":""}],"ETHYLIDENE":[{"def":"An unsymmetrical, divalent, hydrocarbon radical, C2H4 metameric with ethylene but written thus, CH3.","pos":""}],"ETHYLIN":[{"def":"Any one of the several complex ethers of ethyl and glycerin.","pos":""}],"ETHYLSULPHURIC":[{"def":"Pertaining to, or containing, ethyl and sulphuric acid.","pos":""}],"ETIOLATE":[{"def":"To become pale through disease or absence of light.","pos":""}],"ETIOLATION":[{"def":"Paleness produced by absence of light, or by disease.","pos":""}],"ETIOLIN":[{"def":"A yellowish coloring matter found in plants grown in darkness, which is supposed to be an antecedent condition of chlorophyll.","pos":""}],"ETIOLOGICAL":[{"def":"Pertaining to, or inquiring into, causes; ætiological.","pos":""}],"ETIOLOGY":[{"def":"The science of causes.","pos":""}],"ETIQUETTE":[{"def":"The forms required by good breeding, or prescribed by authority, to be observed in social or official life; observance of the proprieties of rank and occasion; conventional decorum; ceremonial code of polite society.","pos":""}],"ETNA":[{"def":"A kind of small, portable, cooking apparatus for which heat is furnished by a spirit lamp.","pos":""}],"ETNEAN":[{"def":"Pertaining to Etna, a volcanic mountain in Sicily.","pos":""}],"ETRURIAN":[{"def":"Of or relating to ancient Etruria, in Italy.","pos":""},{"def":"A native or inhabitant of ancient Etruria.","pos":""}],"ETRUSCAN":[{"def":"Of or relating to Etruria.","pos":""},{"def":"A native or inhabitant of Etruria.","pos":""}],"ETTER PIKE":[{"def":"The stingfish, or lesser weever (Tranchinus vipera).","pos":""}],"ETUDE":[{"def":"A study; an exercise; a piece for practice of some special point of technical execution.","pos":""}],"ETUI":[{"def":"A case for one several small articles; esp.","pos":""}],"ETYMIC":[{"def":"Relating to the etymon; as, an etymic word.","pos":""}],"ETYMOLOGICAL":[{"def":"Pertaining to etymology, or the derivation of words.","pos":""}],"ETYMOLOGICON":[{"def":"an etymological dictionary or manual.","pos":""}],"ETYMOLOGIST":[{"def":"One who investigates the derivation of words.","pos":""}],"ETYMOLOGIZE":[{"def":"To give the etymology of; to trace to the root or primitive, as a word.","pos":""}],"ETYMOLOGY":[{"def":"That branch of philological science which treats of the history of words, tracing out their origin, primitive significance, and changes of from and meaning.","pos":""},{"def":"That pert of grammar which relates to the changes in the form of the words in a language; inflection.","pos":""}],"ETYMON":[{"def":"Original or fundamental signification.","pos":""}],"ETYPICAL":[{"def":"Diverging from, or lacking conformity to, a type.","pos":""}]}