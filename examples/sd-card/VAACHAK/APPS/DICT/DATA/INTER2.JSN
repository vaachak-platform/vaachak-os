{"INTERFUSE":[{"def":"To pour or spread between or among; to diffuse; to scatter.","pos":""},{"def":"To spread through; to permeate; to pervade.","pos":""}],"INTERFUSION":[{"def":"The act of interfusing, or the state of being interfused.","pos":""}],"INTERGANGLIONIC":[{"def":"Between and uniting the nervous ganglions; as, interganglionic cords.","pos":""}],"INTERGLOBULAR":[{"def":"Between globules; -- applied esp.","pos":""}],"INTERGRAVE":[{"def":"To grave or carve between; to engrave in the alternate sections.","pos":""},{"def":"Between the hemal arches or hemal spines.","pos":""}],"INTERHYAL":[{"def":"Of or pertaining to a segment sometimes present at the proximal end of the hyoidean arch.","pos":""},{"def":"An interhyal ligament or cartilage.","pos":""}],"INTERIM":[{"def":"A name given to each of three compromises made by the emperor Charles V.","pos":""}],"INTERIOR":[{"def":"Being within any limits, inclosure, or substance; inside; internal; inner; -- opposed to exterior, or superficial; as, the interior apartments of a house; the interior surface of a hollow ball.","pos":""},{"def":"Remote from the limits, frontier, or shore; inland; as, the interior parts of a region or country.","pos":""}],"INTERIORITY":[{"def":"State of being interior.","pos":""}],"INTERIORLY":[{"def":"Internally; inwardly.","pos":""},{"def":"The state of being between; a coming or lying between or among; intervention; also, that which lies between.","pos":""}],"INTERJACENT":[{"def":"Lying or being between or among; intervening; as, interjacent isles.","pos":""}],"INTERJACULATE":[{"def":"To ejaculate parenthetically.","pos":""}],"INTERJANGLE":[{"def":"To make a dissonant, discordant noise one with another; to talk or chatter noisily.","pos":""}],"INTERJECT":[{"def":"To throw in between; to insert; to interpose.","pos":""}],"INTERJECTION":[{"def":"A word or form of speech thrown in to express emotion or feeling, as O! Alas! Ha ha! Begone! etc.","pos":""}],"INTERJECTIONAL":[{"def":"Thrown in between other words or phrases; parenthetical; ejaculatory; as, an interjectional remark.","pos":""},{"def":"Pertaining to, or having the nature of, an interjection; consisting of natural and spontaneous exclamations.","pos":""}],"INTERJECTIONALIZE":[{"def":"To convert into, or to use as, an interjection.","pos":""}],"INTERJECTIONALLY":[{"def":"In an interjectional manner.","pos":""}],"INTERJECTIONARY":[{"def":"In`ter*jec\"tion*a*ry, a.","pos":""}],"INTERJOIN":[{"def":"To join mutually; to unite.","pos":""}],"INTERJOIST":[{"def":"The space or interval between two joists.","pos":""},{"def":"A middle joist or crossbeam.","pos":""}],"INTERJUNCTION":[{"def":"A mutual joining.","pos":""}],"INTERKNIT":[{"def":"To knit together; to unite closely; to intertwine.","pos":""}],"INTERKNOW":[{"def":"To know mutually.","pos":""}],"INTERKNOWLEDGE":[{"def":"Mutual knowledge or acquaintance.","pos":""}],"INTERLACE":[{"def":"To unite, as by lacing together; to insert or interpose one thing within another; to intertwine; to interweave.","pos":""}],"INTERLACEMENT":[{"def":"The act of interlacing, or the state of being interlaced; also, that which is interlaced.","pos":""},{"def":"Between lammellæ or laminæ; as, interlamellar spaces.","pos":""}],"INTERLAMINATED":[{"def":"Placed between, or containing, laminæ or plates.","pos":""}],"INTERLAMINATION":[{"def":"The state of being interlaminated.","pos":""}],"INTERLAPSE":[{"def":"The lapse or interval of time between two events.","pos":""}],"INTERLARD":[{"def":"To place lard or bacon amongst; to mix, as fat meat with lean.","pos":""},{"def":"Hence: To insert between; to mix or mingle; especially, to introduce that which is foreign or irrelevant; as, to interlard a conservation with oaths or allusions.","pos":""}],"INTERLAY":[{"def":"To lay or place among or between.","pos":""}],"INTERLEAF":[{"def":"A leaf inserted between other leaves; a blank leaf inserted, as in a book.","pos":""}],"INTERLEAVE":[{"def":"To insert a leaf or leaves in; to bind with blank leaves inserted between the others; as, to interleave a book.","pos":""}],"INTERLIBEL":[{"def":"To libel mutually.","pos":""}],"INTERLINE":[{"def":"Contained between lines; written or inserted between lines already written or printed; containing interlineations; as, an interlinear manuscript, translation, etc.","pos":""}],"INTERLINEARY":[{"def":"A book containing interlineations.","pos":""}],"INTERLINEATION":[{"def":"The act of interlining.","pos":""},{"def":"That which is interlined; a passage, word, or line inserted between lines already written or printed.","pos":""}],"INTERLINING":[{"def":"Correction or alteration by writing between the lines; interlineation.","pos":""}],"INTERLINK":[{"def":"To link together; to join, as one chain to another.","pos":""}],"INTERLOBAR":[{"def":"Between lobes; as, the interlobar notch of the liver; the interlobar ducts of a gland.","pos":""}],"INTERLOBULAR":[{"def":"Between lobules; as, the interlobular branches of the portal vein.","pos":""}],"INTERLOCATION":[{"def":"A placing or coming between; interposition.","pos":""}],"INTERLOCK":[{"def":"To unite, embrace, communicate with, or flow into, one another; to be connected in one system; to lock into one another; to interlace firmly.","pos":""}],"INTERLOCUTION":[{"def":"An intermediate act or decree before final decision.","pos":""}],"INTERLOCUTOR":[{"def":"An interlocutory judgment or sentence.","pos":""}],"INTERLOCUTORY":[{"def":"Intermediate; not final or definitive; made or done during the progress of an action.","pos":""}],"INTERLOCUTRICE":[{"def":"A female interlocutor.","pos":""}],"INTERLOPE":[{"def":"To run between parties and intercept without right the advantage that one should gain from the other; to traffic without a proper license; to intrude; to forestall others; to intermeddle.","pos":""}],"INTERLOPER":[{"def":"One who interlopes; one who interlopes; one who unlawfully intrudes upon a property, a station, or an office; one who interferes wrongfully or officiously.","pos":""}],"INTERLUCATE":[{"def":"To let in light upon, as by cutting away branches.","pos":""}],"INTERLUCATION":[{"def":"Act of thinning a wood to let in light.","pos":""}],"INTERLUCENT":[{"def":"Shining between.","pos":""}],"INTERLUDE":[{"def":"A short piece of instrumental music played between the parts of a song or cantata, or the acts of a drama; especially, in church music, a short passage played by the organist between the stanzas of a hymn, or in German chorals after each line.","pos":""}],"INTERLUDED":[{"def":"Inserted in the manner of an interlude; having or containing interludes.","pos":""}],"INTERLUDER":[{"def":"An actor who performs in an interlude.","pos":""}],"INTERLUENCY":[{"def":"A flowing between; intervening water.","pos":""},{"def":"Belonging or pertaining to the time when the moon, at or near its conjunction with the sun, is invisible.","pos":""}],"INTERMANDIBULAR":[{"def":"Between the mandibles; interramal; as, the intermandibular space.","pos":""}],"INTERMARRIAGE":[{"def":"Connection by marriage; reciprocal marriage; giving and taking in marriage, as between two families, tribes, castes, or nations.","pos":""}],"INTERMARRY":[{"def":"To become connected by marriage between their members; to give and take mutually in marriage; -- said of families, ranks, castes, etc.","pos":""}],"INTERMAXILLARY":[{"def":"An intermaxilla.","pos":""}],"INTERMEAN":[{"def":"Something done in the meantime; interlude.","pos":""}],"INTERMEATION":[{"def":"A flowing between.","pos":""}],"INTERMEDDLE":[{"def":"To meddle with the affairs of others; to meddle officiously; to interpose or interfere improperly; to mix or meddle with.","pos":""}],"INTERMEDDLER":[{"def":"One who meddles with, or intrudes into, the affairs of others.","pos":""}],"INTERMEDDLESOME":[{"def":"Inclined or disposed to intermeddle.","pos":""}],"INTERMEDDLING":[{"def":"The act of improperly interfering.","pos":""}],"INTERMEDE":[{"def":"A short musical dramatic piece, of a light and pleasing, sometimes a burlesque, character; an interlude introduced between the acts of a play or an opera.","pos":""}],"INTERMEDIACY":[{"def":"Interposition; intervention.","pos":""}],"INTERMEDIAE":[{"def":"The middle pair of tail feathers, or middle rectrices.","pos":""}],"INTERMEDIAL":[{"def":"Lying between; intervening; intermediate.","pos":""}],"INTERMEDIARY":[{"def":"Lying, coming, or done, between; intermediate; as, an intermediary project.","pos":""}],"INTERMEDIATE":[{"def":"Lying or being in the middle place or degree, or between two extremes; coming or done between; intervening; interposed; interjacent; as, an intermediate space or time; intermediate colors.","pos":""}],"INTERMEDIATELY":[{"def":"In an intermediate manner; by way of intervention.","pos":""}],"INTERMEDIATION":[{"def":"The act of coming between; intervention; interposition.","pos":""}],"INTERMEDIATOR":[{"def":"In`ter*me\"di*a`tor, n.","pos":""}],"INTERMEDIUM":[{"def":"The bone or cartilage between the radiale and ulnare in the carpus, and between the tibiale and fibulare in the tarsus.","pos":""}],"INTERMELL":[{"def":"To intermeddle; to intermix.","pos":""}],"INTERMEMBRAL":[{"def":"Between members or limbs; as, intermembral homology, the correspondence of the limbs with each other.","pos":""}],"INTERMEMBRANOUS":[{"def":"Within or beneath a membrane; as, intermembranous ossification.","pos":""}],"INTERMENT":[{"def":"The act or ceremony of depositing a dead body in the earth; burial; sepulture; inhumation.","pos":""}],"INTERMENTION":[{"def":"To mention among other things, or casually or incidentally.","pos":""}],"INTERMESENTERIC":[{"def":"Within the mesentery; as, the intermesenteric, or aortic, plexus.","pos":""}],"INTERMETACARPAL":[{"def":"Between the metacarpal bones.","pos":""}],"INTERMETATARSAL":[{"def":"Between the metatarsal bones.","pos":""}],"INTERMEZZO":[{"def":"An interlude; an intermede.","pos":""}],"INTERMICATE":[{"def":"To flash or shine between or among.","pos":""}],"INTERMICATION":[{"def":"A shining between or among.","pos":""}],"INTERMIGRATION":[{"def":"Reciprocal migration; interchange of dwelling place by migration.","pos":""}],"INTERMINABLE":[{"def":"Without termination; admitting no limit; boundless; endless; wearisomely protracted; as, interminable space or duration; interminable sufferings.","pos":""}],"INTERMINABLENESS":[{"def":"The state of being endless.","pos":""}],"INTERMINABLY":[{"def":"Without end or limit.","pos":""}],"INTERMINATE":[{"def":"Endless; as, interminate sleep.","pos":""}],"INTERMINATED":[{"def":"Interminable; interminate; endless; unending.","pos":""}],"INTERMINATION":[{"def":"A menace or threat.","pos":""}],"INTERMINE":[{"def":"To intersect or penetrate with mines.","pos":""}],"INTERMINGLE":[{"def":"To mingle or mix together; to intermix.","pos":""}],"INTERMISE":[{"def":"Interference; interposition.","pos":""}],"INTERMISSION":[{"def":"The temporary cessation or subsidence of a fever; the space of time between the paroxysms of a disease.","pos":""}],"INTERMISSIVE":[{"def":"Having temporary cessations; not continual; intermittent.","pos":""}],"INTERMIT":[{"def":"To cause to cease for a time, or at intervals; to interrupt; to suspend.","pos":""}],"INTERMITTENCE":[{"def":"Act or state of intermitting; intermission.","pos":""}],"INTERMITTENT":[{"def":"Coming and going at intervals; alternating; recurrent; periodic; as, an intermittent fever.","pos":""}],"INTERMITTENTLY":[{"def":"With intermissions; in an intermittent manner; intermittingly.","pos":""}],"INTERMITTINGLY":[{"def":"With intermissions; at intervals.","pos":""}],"INTERMIX":[{"def":"To mix together; to intermingle.","pos":""}],"INTERMIXEDLY":[{"def":"In a mixed manner.","pos":""}],"INTERMIXTURE":[{"def":"A mass formed by mixture; a mass of ingredients mixed.","pos":""},{"def":"Admixture; an additional ingredient.","pos":""}],"INTERMOBILITY":[{"def":"Capacity of things to move among each other; as, the intermobility of fluid particles.","pos":""}],"INTERMODILLION":[{"def":"The space between two modillions.","pos":""}],"INTERMONTANE":[{"def":"Between mountains; as, intermontane soil.","pos":""}],"INTERMUNDANE":[{"def":"Being, between worlds or orbs.","pos":""}],"INTERMURAL":[{"def":"Lying between walls; inclosed by walls.","pos":""}],"INTERMURE":[{"def":"To wall in; to inclose.","pos":""}],"INTERMUSCULAR":[{"def":"Between muscles; as, intermuscular septa.","pos":""}],"INTERMUTATION":[{"def":"Interchange; mutual or reciprocal change.","pos":""}],"INTERN":[{"def":"To put for safe keeping in the interior of a place or country; to confine to one locality; as, to intern troops which have fled for refuge to a neutral country.","pos":""}],"INTERNAL":[{"def":"Lying toward the mesial plane; mesial.","pos":""},{"def":"Designating, or pertaining to, any engine (called an Internal- combustion engine) in which the heat or pressure energy necessary to produce motion is developed in the engine cylinder, as by the explosion of a gas, and not in a separate chamber, as in a steam- engine boiler.","pos":""}],"INTERNALITY":[{"def":"The state of being internal or within; interiority.","pos":""}],"INTERNALLY":[{"def":"Inwardly; within the enveloping surface, or the boundary of a thing; within the body; beneath the surface.","pos":""},{"def":"Hence: Mentally; spiritually.","pos":""}],"INTERNASAL":[{"def":"Between the nasal cavities; as, the internasal cartilage.","pos":""}],"INTERNATIONAL":[{"def":"Between or among nations; pertaining to the intercourse of nations; participated in by two or more nations; common to, or affecting, two or more nations.","pos":""},{"def":"Of or concerning the association called the International.","pos":""}],"INTERNATIONALISM":[{"def":"The state or principles of international interests and intercourse.","pos":""},{"def":"The doctrines or organization of the International.","pos":""}],"INTERNATIONALIST":[{"def":"One who is versed in the principles of international law.","pos":""},{"def":"A member of the International; one who believes in, or advocates the doctrines of, the International.","pos":""}],"INTERNATIONALIZE":[{"def":"To make international; to cause to affect the mutual relations of two or more nations; as, to internationalize a principle of law, or a philanthropic enterprise.","pos":""}]}