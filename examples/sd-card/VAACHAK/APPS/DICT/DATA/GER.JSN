{"GERAH":[{"def":"A small coin and weight; 1-20th of a shekel.","pos":""}],"GERANIACEOUS":[{"def":"Of or pertaining to a natural order of pants (Geraniaceæ) which includes the genera Geranium, Pelargonium, and many others.","pos":""},{"def":"A valuable astringet obtained from the root of the Geranium maculatum or crane's-bill.","pos":""}],"GERANIUM":[{"def":"A genus of plants having a beaklike tours or receptacle, around which the seed capsules are arranged, and membranous projections, or stipules, at the joints.","pos":""},{"def":"A cultivated pelargonium.","pos":""}],"GERANT":[{"def":"The manager or acting partner of a company, joint-stock association, etc.","pos":""}],"GERBE":[{"def":"A kind of ornamental firework.","pos":""},{"def":"One of several species of small, jumping, murine rodents, of the genus Gerbillus.","pos":""}],"GERENT":[{"def":"Bearing; carrying.","pos":""}],"GERFUL":[{"def":"Changeable; capricious.","pos":""}],"GERLIND":[{"def":"A salmon returning from the sea the second time.","pos":""}],"GERM":[{"def":"That which is to develop a new individual; as, the germ of a fetus, of a plant or flower, and the like; the earliest form under which an organism appears.","pos":""}],"GERM CELL":[{"def":"A cell, of either sex, directly concerned in the production of a new organism.","pos":""}],"GERM PLASM":[{"def":"See Plasmogen, and Idioplasm.","pos":""}],"GERM THEORY":[{"def":"The theory that living organisms can be produced only by the development of living germs.","pos":""}],"GERMAN":[{"def":"Nearly related; closely akin.","pos":""}],"GERMANDER":[{"def":"A plant of the genus Teucrium (esp.","pos":""}],"GERMANE":[{"def":"Literally, near akin; hence, closely allied; appropriate or fitting; relevant.","pos":""}],"GERMANIC":[{"def":"Pertaining to, or containing, germanium.","pos":""}],"GERMANISM":[{"def":"An idiom of the German language.","pos":""},{"def":"A characteristic of the Germans; a characteristic German mode, doctrine, etc.","pos":""}],"GERMANIUM":[{"def":"A rare element, recently discovered (1885), in a silver ore (argyrodite) at Freiberg.","pos":""}],"GERMANIZATION":[{"def":"The act of Germanizing.","pos":""}],"GERMANIZE":[{"def":"To make German, or like what is distinctively German; as, to Germanize a province, a language, a society.","pos":""}],"GERMARIUM":[{"def":"An organ in which the ova are developed in certain Turbellaria.","pos":""}],"GERMICIDE":[{"def":"Destructive to germs; -- applied to any agent which has a destructive action upon living germs, particularly bacteria, or bacterial germs, which are considered the cause of many infectious diseases.","pos":""},{"def":"A germicide agent.","pos":""}],"GERMINAL":[{"def":"Pertaining or belonging to a germ; as, the germinal vesicle.","pos":""}],"GERMINANT":[{"def":"Sprouting; sending forth germs or buds.","pos":""}],"GERMINATE":[{"def":"To sprout; to bud; to shoot; to begin to vegetate, as a plant or its seed; to begin to develop, as a germ.","pos":""}],"GERMINATION":[{"def":"The process of germinating; the beginning of vegetation or growth in a seed or plant; the first development of germs, either animal or vegetable.","pos":""}],"GERMINATIVE":[{"def":"Pertaining to germination; having power to bud or develop.","pos":""}],"GERMIPARITY":[{"def":"Reproduction by means of germs.","pos":""}],"GERN":[{"def":"To grin or yawn.","pos":""}],"GEROCOMICAL":[{"def":"Pertaining to gerocomy.","pos":""}],"GEROCOMY":[{"def":"That part of medicine which treats of regimen for old people.","pos":""}],"GERONTES":[{"def":"Magistrates in Sparta, who with the ephori and kings, constituted the supreme civil authority.","pos":""}],"GERONTOCRACY":[{"def":"Government by old men.","pos":""}],"GEROPIGIA":[{"def":"A mixture composed of unfermented grape juice, brandy, sugar, etc.","pos":""},{"def":"A suffix signifying bearing, producing; as, calcigerous; dentigerous.","pos":""}],"GERRYMANDER":[{"def":"To divide (a State) into districts for the choice of representatives, in an unnatural and unfair way, with a view to give a political party an advantage over its opponent.","pos":""}],"GERUND":[{"def":"A verbal noun ending in -e, preceded by to and usually denoting purpose or end; -- called also the dative infinitive; as, \"Ic hæbbe mete tô etanne\" (I have meat to eat.","pos":""}],"GERUNDIAL":[{"def":"Pertaining to, or resembling, a gerund; as, a gerundial use.","pos":""}],"GERUNDIVE":[{"def":"Pertaining to, or partaking of, the nature of the gerund; gerundial.","pos":""},{"def":"The future passive participle; as, amandus, i.","pos":""}],"GERUNDIVELY":[{"def":"In the manner of a gerund; as, or in place of, a gerund.","pos":""}],"GERY":[{"def":"Changeable; fickle.","pos":""}]}