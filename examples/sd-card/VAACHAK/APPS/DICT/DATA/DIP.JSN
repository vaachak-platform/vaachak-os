{"DIP":[{"def":"To plunge or immerse; especially, to put for a moment into a liquid; to insert into a fluid and withdraw again.","pos":""},{"def":"To immerse for baptism; to baptize by immersion.","pos":""}],"DIPASCHAL":[{"def":"Including two passovers.","pos":""}],"DIPETALOUS":[{"def":"Having two petals; two-petaled.","pos":""}],"DIPHENYL":[{"def":"A white crystalline substance, C6H5.","pos":""}],"DIPHTHERIA":[{"def":"A very dangerous contagious disease in which the air passages, and especially the throat, become coated with a false membrane, produced by the solidification of an inflammatory exudation.","pos":""},{"def":"Relating to diphtheria; diphtheritic.","pos":""}],"DIPHTHERITIC":[{"def":"Pertaining to, or connected with, diphtheria.","pos":""},{"def":"Having characteristics resembling those of diphtheria; as, diphtheritic inflammation of the bladder.","pos":""}],"DIPHTHONG":[{"def":"Diph\"thong (; 115, 277), n.","pos":""}],"DIPHTHONGAL":[{"def":"Relating or belonging to a diphthong; having the nature of a diphthong.","pos":""}],"DIPHTHONGALIZE":[{"def":"To make into a diphthong; to pronounce as a diphthong.","pos":""}],"DIPHTHONGATION":[{"def":"See Diphthongization.","pos":""}],"DIPHTHONGIC":[{"def":"Of the nature of diphthong; diphthongal.","pos":""}],"DIPHTHONGIZATION":[{"def":"The act of changing into a diphthong.","pos":""}],"DIPHTHONGIZE":[{"def":"To change into a diphthong, as by affixing another vowel to a simple vowel.","pos":""}],"DIPHYCERCAL":[{"def":"Having the tail fin divided into two equal parts by the notochord, or end of the vertebral column; protocercal.","pos":""}],"DIPHYGENIC":[{"def":"Having two modes of embryonic development.","pos":""}],"DIPHYLLOUS":[{"def":"Having two leaves, as a calyx, etc.","pos":""}],"DIPHYODONT":[{"def":"Having two successive sets of teeth (deciduous and permanent), one succeeding the other; as, a diphyodont mammal; diphyodont dentition; -- opposed to monophyodont.","pos":""},{"def":"An animal having two successive sets of teeth.","pos":""}],"DIPHYOZOOID":[{"def":"One of the free-swimming sexual zooids of Siphonophora.","pos":""}],"DIPLANAR":[{"def":"Of or pertaining to two planes.","pos":""}],"DIPLEIDOSCOPE":[{"def":"An instrument for determining the time of apparent noon.","pos":""}],"DIPLEX":[{"def":"Pertaining to the sending of two messages in the same direction at the same time.","pos":""}],"DIPLOBLASTIC":[{"def":"Characterizing the ovum when it has two primary germinal layers.","pos":""}],"DIPLOCARDIAC":[{"def":"Having the heart completely divided or double, one side systemic, the other pulmonary.","pos":""}],"DIPLOCOCCUS":[{"def":"A form of micrococcus in which cocci are united in a binary manner.","pos":""}],"DIPLOE":[{"def":"The soft, spongy, or cancellated substance between the plates of the skull.","pos":""}],"DIPLOGENIC":[{"def":"Partaking of the nature of two bodies; producing two substances.","pos":""}],"DIPLOGRAPH":[{"def":"An instrument used for double writing, as one for producing embossed writing for the blind and ordinary writing at the same time.","pos":""}],"DIPLOIC":[{"def":"Of or pertaining to the diploë.","pos":""}],"DIPLOID":[{"def":"A solid bounded by twenty-four similar quadrilateral faces.","pos":""}],"DIPLOMA":[{"def":"A letter or writing, usually under seal, conferring some privilege, honor, or power; a document bearing record of a degree conferred by a literary society or educational institution.","pos":""}],"DIPLOMACY":[{"def":"The art and practice of conducting negotiations between nations (particularly in securing treaties), including the methods and forms usually employed.","pos":""},{"def":"Dexterity or skill in securing advantages; tact.","pos":""}],"DIPLOMATE":[{"def":"To invest with a title o [R.","pos":""}],"DIPLOMATIAL":[{"def":"Pertaining to diplomacy; relating to the foreign ministers at a court, who are called the diplomatic body.","pos":""},{"def":"Characterized by tact and shrewdness; dexterous; artful; as, diplomatic management.","pos":""}],"DIPLOMATIC":[{"def":"A minister, official agent, or envoy to a foreign court; a diplomatist.","pos":""}],"DIPLOMATICALLY":[{"def":"According to the rules of diplomacy; in the manner of a diplomatist; artfully.","pos":""}],"DIPLOMATICS":[{"def":"The science of diplomas, or the art of deciphering ancient writings, and determining their age, authenticity, etc.","pos":""}],"DIPLOMATIST":[{"def":"A person employed in, or skilled in, diplomacy; a diplomat.","pos":""},{"def":"The act or state of seeing double.","pos":""}],"DIPLOPOD":[{"def":"One of the Diplopoda.","pos":""}],"DIPLOPODA":[{"def":"An order of myriapods having two pairs of legs on each segment; the Chilognatha.","pos":""}],"DIPLOSTEMONOUS":[{"def":"Having twice as many stamens as petals, as the geranium.","pos":""}],"DIPLOSTEMONY":[{"def":"The condition of being diplostemonous.","pos":""}],"DIPNEUMONA":[{"def":"A group of spiders having only two lunglike organs.","pos":""}],"DIPNOI":[{"def":"A group of ganoid fishes, including the living genera Ceratodus and Lepidosiren, which present the closest approximation to the Amphibia.","pos":""}],"DIPODY":[{"def":"Two metrical feet taken together, or included in one measure.","pos":""}],"DIPOLAR":[{"def":"Having two poles, as a magnetic bar.","pos":""}],"DIPPEL'S OIL":[{"def":"See Bone oil, under Bone.","pos":""}],"DIPPER":[{"def":"One who, or that which, dips; especially, a vessel used to dip water or other liquid; a ladle.","pos":""}],"DIPPING":[{"def":"The act or process of immersing.","pos":""},{"def":"The act of inclining downward.","pos":""}],"DIPRISMATIC":[{"def":"Doubly prismatic.","pos":""}],"DIPROPARGYL":[{"def":"A pungent, mobile, volatile liquid, C6H6, produced artificially from certain allyl derivatives.","pos":""}],"DIPROPYL":[{"def":"One of the hexane paraffins, found in petroleum, consisting of two propyl radicals.","pos":""}],"DIPROTODON":[{"def":"An extinct Quaternary marsupial from Australia, about as large as the hippopotamus; -- so named because of its two large front teeth.","pos":""}],"DIPSAS":[{"def":"A genus of harmless colubrine snakes.","pos":""}],"DIPSETIC":[{"def":"Tending to produce thirst.","pos":""},{"def":"Deep-sea; as, a dipsey line; a dipsy lead.","pos":""}],"DIPSOMANIA":[{"def":"A morbid an uncontrollable craving (often periodic) for drink, esp.","pos":""}],"DIPSOMANIAC":[{"def":"One who has an irrepressible desire for alcoholic drinks.","pos":""}],"DIPSOMANIACAL":[{"def":"Of or pertaining to dipsomania.","pos":""}],"DIPSOSIS":[{"def":"Excessive thirst produced by disease.","pos":""}],"DIPTERA":[{"def":"An extensive order of insects having only two functional wings and two balancers, as the house fly, mosquito, etc.","pos":""}],"DIPTERAL":[{"def":"Having two wings only; belonging to the order Diptera.","pos":""},{"def":"Having a double row of columns on each on the flanks, as well as in front and rear; -- said of a temple.","pos":""}],"DIPTERAN":[{"def":"An insect of the order Diptera.","pos":""}],"DIPTEROCARPUS":[{"def":"A genus of trees found in the East Indies, some species of which produce a fragrant resin, other species wood oil.","pos":""}],"DIPTEROUS":[{"def":"Having two wings, as certain insects; belonging to the order Diptera.","pos":""},{"def":"Having two wings; two-winged.","pos":""}],"DIPTERYGIAN":[{"def":"Having two dorsal fins; -- said of certain fishes.","pos":""}],"DIPTOTE":[{"def":"A noun which has only two cases.","pos":""}],"DIPTYCH":[{"def":"Anything consisting of two leaves.","pos":""},{"def":"A double catalogue, containing in one part the names of living, and in the other of deceased, ecclesiastics and benefactors of the church; a catalogue of saints.","pos":""}],"DIPYRE":[{"def":"A mineral of the scapolite group; -- so called from the double effect of fire upon it, in fusing it, and rendering it phosphorescent.","pos":""}],"DIPYRENOUS":[{"def":"Containing two stones or nutlets.","pos":""}],"DIPYRIDINE":[{"def":"A polymeric form of pyridine, C10H10N2, obtained as a colorless oil by the action of sodium on pyridine.","pos":""}],"DIPYRIDYL":[{"def":"A crystalline nitrogenous base, C10H8N2, obtained by the reduction of pyridine.","pos":""}]}