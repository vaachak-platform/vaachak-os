{"CHEVAL":[{"def":"A horse; hence, a support or frame.","pos":""}],"CHEVAL-DE-FRISE":[{"def":"A piece of timber or an iron barrel traversed with iron-pointed spikes or spears, five or six feet long, used to defend a passage, stop a breach, or impede the advance of cavalry, etc.","pos":""}],"CHEVALIER":[{"def":"A horseman; a knight; a gallant young man.","pos":""},{"def":"A member of certain orders of knighthood.","pos":""}],"CHEVE":[{"def":"To come to an issue; to turn out; to succed; as, to cheve well in a enterprise.","pos":""}],"CHEVELURE":[{"def":"A hairlike envelope.","pos":""}],"CHEVEN":[{"def":"A river fish; the chub.","pos":""}],"CHEVENTEIN":[{"def":"A variant of Chieftain.","pos":""}],"CHEVERIL":[{"def":"Soft leather made of kid skin.","pos":""}],"CHEVERLIIZE":[{"def":"To make as pliable as kid leather.","pos":""}],"CHEVET":[{"def":"The extreme end of the chancel or choir; properly the round or polygonal part.","pos":""}],"CHEVIOT":[{"def":"A valuable breed of mountain sheep in Scotland, which takes its name from the Cheviot hills.","pos":""},{"def":"A woolen fabric, for men's clothing.","pos":""}],"CHEVISANCE":[{"def":"Achievement; deed; performance.","pos":""},{"def":"A bargain; profit; gain.","pos":""}],"CHEVRETTE":[{"def":"A machine for raising guns or mortar into their carriages.","pos":""}],"CHEVRON":[{"def":"One of the nine honorable ordinaries, consisting of two broad bands of the width of the bar, issuing, respectively from the dexter and sinister bases of the field and conjoined at its center.","pos":""},{"def":"A distinguishing mark, above the elow, on the sleeve of a noncommisioned officer's coat.","pos":""}],"CHEVRONED":[{"def":"Having a chevron; decorated with an ornamental figure of a zigzag from.","pos":""}],"CHEVRONEL":[{"def":"A bearing like a chevron, but of only half its width.","pos":""}],"CHEVRONWISE":[{"def":"In the manner of a chevron; as, the field may be divided chevronwise.","pos":""}],"CHEVROTAIN":[{"def":"A small ruminant of the family Tragulidæ a allied to the musk deer.","pos":""}],"CHEVY":[{"def":"One poor fellow was chevied about among the casks in the storm for ten minutes.","pos":""}]}