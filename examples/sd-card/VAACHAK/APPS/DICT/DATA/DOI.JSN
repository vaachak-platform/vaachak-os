{"DOILY":[{"def":"A kind of woolen stuff.","pos":""},{"def":"A small napkin, used at table with the fruit, etc.","pos":""}],"DOING":[{"def":"Anything done; a deed; an action good or bad; hence, in the plural, conduct; behavior.","pos":""}],"DOIT":[{"def":"A small Dutch coin, worth about half a farthing; also, a similar small coin once used in Scotland; hence, any small piece of money.","pos":""},{"def":"A thing of small value; as, I care not a doit.","pos":""}],"DOITKIN":[{"def":"A very small coin; a doit.","pos":""}]}