{"ASSIBILATE":[{"def":"To make sibilant; to change to a sibilant.","pos":""}],"ASSIBILATION":[{"def":"Change of a non-sibilant letter to a sibilant, as of -tion to - shun, duke to ditch.","pos":""}],"ASSIDEAN":[{"def":"One of a body of devoted Jews who opposed the Hellenistic Jews, and supported the Asmoneans.","pos":""}],"ASSIDENT":[{"def":"Usually attending a disease, but not always; as, assident signs, or symptoms.","pos":""}],"ASSIDUATE":[{"def":"Unremitting; assiduous.","pos":""}],"ASSIDUITY":[{"def":"Constant or close application or attention, particularly to some business or enterprise; diligence.","pos":""},{"def":"Studied and persevering attention to a person; -- usually in the plural.","pos":""}],"ASSIDUOUS":[{"def":"Constant in application or attention; devoted; attentive; unremitting.","pos":""},{"def":"Performed with constant diligence or attention; unremitting; persistent; as, assiduous labor.","pos":""}],"ASSIENTIST":[{"def":"A shareholder of the Assiento company; one of the parties to the Assiento contract.","pos":""}],"ASSIENTO":[{"def":"A contract or convention between Spain and other powers for furnishing negro slaves for the Spanish dominions in America, esp.","pos":""}],"ASSIGN":[{"def":"To transfer, or make over to another, esp.","pos":""}],"ASSIGNABILITY":[{"def":"The quality of being assignable.","pos":""}],"ASSIGNABLE":[{"def":"Capable of being assigned, allotted, specified, or designated; as, an assignable note or bill; an assignable reason; an assignable quantity.","pos":""}],"ASSIGNAT":[{"def":"One of the notes, bills, or bonds, issued as currency by the revolutionary government of France (1790-1796), and based on the security of the lands of the church and of nobles which had been appropriated by the state.","pos":""}],"ASSIGNATION":[{"def":"The act of assigning or allotting; apportionment.","pos":""},{"def":"An appointment of time and place for meeting or interview; -- used chiefly of love interviews, and now commonly in a bad sense.","pos":""}],"ASSIGNEE":[{"def":"In England, the persons appointed, under a commission of bankruptcy, to manage the estate of a bankrupt for the benefit of his creditors.","pos":""}],"ASSIGNER":[{"def":"One who assigns, appoints, allots, or apportions.","pos":""}],"ASSIGNMENT":[{"def":"An allotting or an appointment to a particular person or use; or for a particular time, as of a cause or causes in court.","pos":""}],"ASSIGNOR":[{"def":"An assigner; a person who assigns or transfers an interest; as, the assignor of a debt or other chose in action.","pos":""}],"ASSIMILABILITY":[{"def":"The quality of being assimilable.","pos":""}],"ASSIMILABLE":[{"def":"That may be assimilated; that may be likened, or appropriated and incorporated.","pos":""}],"ASSIMILATE":[{"def":"To bring to a likeness or to conformity; to cause a resemblance between.","pos":""},{"def":"To liken; to compa [R.","pos":""}],"ASSIMILATION":[{"def":"The conversion of nutriment into the fluid or solid substance of the body, by the processes of digestion and absorption, whether in plants or animals.","pos":""}],"ASSIMILATIVE":[{"def":"Tending to, or characterized by, assimilation; that assimilates or causes assimilation; as, an assimilative process or substance.","pos":""}],"ASSIMILATORY":[{"def":"Tending to assimilate, or produce assimilation; as, assimilatory organs.","pos":""}],"ASSIMULATE":[{"def":"To feign; to counterfeit; to simulate; to resemble.","pos":""}],"ASSISH":[{"def":"Resembling an ass; asinine; stupid or obstinate.","pos":""}],"ASSIST":[{"def":"To give support to in some undertaking or effort, or in time of distress; to help; to aid; to succor.","pos":""}],"ASSISTANCE":[{"def":"The act of assisting; help; aid; furtherance; succor; support.","pos":""},{"def":"An assistant or helper; a body of helpers.","pos":""}],"ASSISTANT":[{"def":"Of the second grade in the staff of the army; as, an assistant surgeon.","pos":""}],"ASSISTANTLY":[{"def":"In a manner to give aid.","pos":""}],"ASSISTER":[{"def":"An assistant; a helper.","pos":""}],"ASSISTIVE":[{"def":"Lending aid, helping.","pos":""}],"ASSISTLESS":[{"def":"Without aid or help.","pos":""}],"ASSIZE":[{"def":"An assembly of knights and other substantial men, with a bailiff or justice, in a certain place and at a certain time, for public business.","pos":""},{"def":"Measure; dimension; size.","pos":""}],"ASSIZER":[{"def":"An officer who has the care or inspection of weights and measures, etc.","pos":""}]}