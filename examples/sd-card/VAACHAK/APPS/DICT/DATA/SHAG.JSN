{"SHAG":[{"def":"A kind of prepared tobacco cut fine.","pos":""},{"def":"Any species of cormorant.","pos":""}],"SHAG-HAIRED":[{"def":"Having shaggy hair.","pos":""}],"SHAG-RAG":[{"def":"The unkempt and ragged part of the community.","pos":""}],"SHAGBARK":[{"def":"A rough-barked species of hickory (Carya alba), its nut.","pos":""}],"SHAGGINESS":[{"def":"The quality or state of being shaggy; roughness; shaggedness.","pos":""}],"SHAGGY":[{"def":"Rough with long hair or wool.","pos":""}],"SHAGREEN":[{"def":"Covered with rough scales or points like those on shagreen.","pos":""}]}