{"ERR":[{"def":"To wander; to roam; to stray.","pos":""},{"def":"To deviate from the true course; to miss the thing aimed at.","pos":""}],"ERRABLE":[{"def":"Liable to error; fallible.","pos":""}],"ERRABLENESS":[{"def":"Liability to error.","pos":""}],"ERRANCY":[{"def":"A wandering; state of being in error.","pos":""}],"ERRAND":[{"def":"A special business intrusted to a messenger; something to be told or done by one sent somewhere for the purpose; often, a verbal message; a commission; as, the servant was sent on an errand; to do an errand.","pos":""}],"ERRANT":[{"def":"Journeying; itinerant; -- formerly applied to judges who went on circuit and to bailiffs at large.","pos":""}],"ERRANTIA":[{"def":"A group of chætopod annelids, including those that are not confined to tubes.","pos":""}],"ERRANTRY":[{"def":"A wandering; a roving; esp.","pos":""},{"def":"The employment of a knight-errant.","pos":""}],"ERRATIC":[{"def":"Having no certain course; roving about without a fixed destination; wandering; moving; -- hence, applied to the planets as distinguished from the fixed stars.","pos":""},{"def":"Deviating from a wise of the common course in opinion or conduct; eccentric; strange; queer; as, erratic conduct.","pos":""}],"ERRATION":[{"def":"A wandering; a roving about.","pos":""}],"ERRATUM":[{"def":"An error or mistake in writing or printing.","pos":""}],"ERRHINE":[{"def":"A medicine designed to be snuffed up the nose, to promote discharges of mucus; a sternutatory.","pos":""},{"def":"Causing or increasing secretion of nasal mucus.","pos":""}],"ERRONEOUS":[{"def":"Wandering; straying; deviating from the right course; -- hence, irregular; unnatural.","pos":""},{"def":"Misleading; misled; mistaking.","pos":""}],"ERROR":[{"def":"The difference between the approximate result and the true result; -- used particularly in the rule of double position.","pos":""},{"def":"A mistake in the proceedings of a court of record in matters of law or of fact.","pos":""}],"ERRORFUL":[{"def":"Full of error; wrong.","pos":""}],"ERRORIST":[{"def":"One who encourages and propagates error; one who holds to error.","pos":""}]}