{"IO":[{"def":"An exclamation of joy or triumph; -- often interjectional.","pos":""}],"IO MOTH":[{"def":"A large and handsome American moth (Hyperchiria Io), having a large, bright-colored spot on each hind wing, resembling the spots on the tail of a peacock.","pos":""}],"IODAL":[{"def":"An oily liquid, Cl3.","pos":""}],"IODATE":[{"def":"A salt of iodic acid.","pos":""}],"IODHYDRIN":[{"def":"One of a series of compounds containing iodine, and analogous to the chlorhydrins.","pos":""}],"IODIC":[{"def":"to, or containing, iodine; specif.","pos":""}],"IODIDE":[{"def":"A binary compound of iodine, or one which may be regarded as binary; as, potassium iodide.","pos":""}],"IODINE":[{"def":"A nonmetallic element, of the halogen group, occurring always in combination, as in the iodides.","pos":""}],"IODISM":[{"def":"A morbid state produced by the use of iodine and its compounds, and characterized by palpitation, depression, and general emaciation, with a pustular eruption upon the skin.","pos":""}],"IODIZE":[{"def":"To treat or impregnate with iodine or its compounds; as, to iodize a plate for photography.","pos":""}],"IODIZER":[{"def":"One who, or that which, iodizes.","pos":""},{"def":"A prefix, or combining from, indicating iodine as an ingredient; as, iodoform.","pos":""}],"IODOCRESOL":[{"def":"Any of several isomeric iodine derivatives of the cresols, C6H3I(CH3)OH, esp.","pos":""}],"IODOFORM":[{"def":"A yellow, crystalline, volatile substance, CI3H, having an offensive odor and sweetish taste, and analogous to chloroform.","pos":""}],"IODOFORMOGEN":[{"def":"A light powder used as a substitute for iodoform.","pos":""}],"IODOL":[{"def":"A crystallized substance of the composition C4I4NH, technically tetra-iodo-pyrrol, used like iodoform.","pos":""}],"IODOQUININE":[{"def":"A iodide of quinine obtained as a brown substance,.","pos":""}],"IODOTHYRIN":[{"def":"A peculiar substance obtained from the thyroid gland, containing from nine to ten per cent of iodine.","pos":""}],"IODOUS":[{"def":"Pertaining to, or containing, iodine.","pos":""}],"IODYRITE":[{"def":"Silver iodide, a mineral of a yellowish color.","pos":""}],"IOLITE":[{"def":"A silicate of alumina, iron, and magnesia, having a bright blue color and vitreous luster; cordierite.","pos":""}],"ION":[{"def":"One of the elements which appear at the respective poles when a body is subjected to electro-chemical decomposition.","pos":""}],"IONIAN":[{"def":"Of or pertaining to Ionia or the Ionians; Ionic.","pos":""},{"def":"A native or citizen of Ionia.","pos":""}],"IONIC":[{"def":"Pertaining to the Ionic order of architecture, one of the three orders invented by the Greeks, and one of the five recognized by the Italian writers of the sixteenth century.","pos":""}],"IONIDIUM":[{"def":"A genus of violaceous plants, chiefly found in tropical America, some species of which are used as substitutes for ipecacuanha.","pos":""}],"IONIZE":[{"def":"To separate (a compound) into ions, esp.","pos":""}],"IOQUA SHELL":[{"def":"The shell of a large Dentalium (D.","pos":""}],"IOTA":[{"def":"The ninth letter of the Greek alphabet (i) corresponding with the English i.","pos":""},{"def":"A very small quantity or degree; a jot; a particle.","pos":""}],"IOTACISM":[{"def":"The frequent use of the sound of iota (that of English e in be), as among the modern Greeks; also, confusion from sounding Littré.","pos":""}]}