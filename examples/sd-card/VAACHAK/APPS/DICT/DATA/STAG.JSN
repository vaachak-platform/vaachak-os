{"STAG":[{"def":"The European wren.","pos":""}],"STAG-EVIL":[{"def":"A kind of palsy affecting the jaw of a horse.","pos":""}],"STAG-HORNED":[{"def":"Having the mandibles large and palmate, or branched somewhat like the antlers of a stag; -- said of certain beetles.","pos":""}],"STAGE":[{"def":"One of several marked phases or periods in the development and growth of many animals and plants; as, the larval stage; pupa stage; zoea stage.","pos":""}],"STAGE DIRECTOR":[{"def":"One who prepares a play for production.","pos":""}],"STAGE FRIGHT":[{"def":"Nervousness felt before an audience.","pos":""}],"STAGE MANAGER":[{"def":"One in control of the stage during the production of a play.","pos":""}],"STAGE-STRUCK":[{"def":"Fascinated by the stage; seized by a passionate desire to become an actor.","pos":""}],"STAGECOACH":[{"def":"A coach that runs regularly from one stage, station, or place to another, for the conveyance of passengers.","pos":""}],"STAGECOACHMAN":[{"def":"One who drives a stagecoach.","pos":""}],"STAGEHOUSE":[{"def":"A house where a stage regularly stops for passengers or a relay of horses.","pos":""}],"STAGELY":[{"def":"Pertaining to a stage; becoming the theater; theatrical.","pos":""}],"STAGEPLAY":[{"def":"A dramatic or theatrical entertainment.","pos":""}],"STAGEPLAYER":[{"def":"An actor on the stage; one whose occupation is to represent characters on the stage; as, Garrick was a celebrated stageplayer.","pos":""}],"STAGER":[{"def":"One who has long acted on the stage of life; a practitioner; a person of experience, or of skill derived from long experience.","pos":""}],"STAGERY":[{"def":"Exhibition on the stage.","pos":""}],"STAGGARD":[{"def":"The male red deer when four years old.","pos":""}],"STAGGER":[{"def":"To move to one side and the other, as if about to fall, in standing or walking; not to stand or walk with steadiness; to sway; to reel or totter.","pos":""},{"def":"To cease to stand firm; to begin to give way; to fail.","pos":""}],"STAGGERBUSH":[{"def":"An American shrub (Andromeda Mariana) having clusters of nodding white flowers.","pos":""}],"STAGGERINGLY":[{"def":"In a staggering manner.","pos":""}],"STAGGERWORT":[{"def":"A kind of ragwort (Senecio Jacobæa).","pos":""}],"STAGHOUND":[{"def":"A large and powerful hound formerly used in hunting the stag, the wolf, and other large animals.","pos":""}],"STAGING":[{"def":"A structure of posts and boards for supporting workmen, etc.","pos":""}],"STAGIRITE":[{"def":"A native of, or resident in, Stagira, in ancient Macedonia; especially, Aristotle.","pos":""}],"STAGNANCY":[{"def":"State of being stagnant.","pos":""}],"STAGNANT":[{"def":"That stagnates; not flowing; not running in a current or steam; motionless; hence, impure or foul from want of motion; as, a stagnant lake or pond; stagnant blood in the veins.","pos":""},{"def":"Not active or brisk; dull; as, business in stagnant.","pos":""}],"STAGNANTLY":[{"def":"In a stagnant manner.","pos":""}],"STAGNATE":[{"def":"To cease to flow; to be motionless; as, blood stagnates in the veins of an animal; hence, to become impure or foul by want of motion; as, air stagnates in a close room.","pos":""},{"def":"To cease to be brisk or active; to become dull or inactive; as, commerce stagnates; business stagnates.","pos":""}],"STAGNATION":[{"def":"The condition of being stagnant; cessation of flowing or circulation, as of a fluid; the state of being motionless; as, the stagnation of the blood; the stagnation of water or air; the stagnation of vapors.","pos":""},{"def":"The cessation of action, or of brisk action; the state of being dull; as, the stagnation of business.","pos":""}],"STAGWORM":[{"def":"The larve of any species of botfly which is parasitic upon the stag, as , which burrows beneath the skin, and Cephalomyia auribarbis, which lives in the nostrils.","pos":""}],"STAGY":[{"def":"Having an air or manner characteristic of the stage; theatrical; artificial; as, a stagy tone or bearing; --chiefly used depreciatively.","pos":""}]}