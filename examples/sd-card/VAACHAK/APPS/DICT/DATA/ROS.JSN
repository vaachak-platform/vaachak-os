{"ROSACEOUS":[{"def":"Of a pure purpish pink color.","pos":""}],"ROSACIC":[{"def":"Pertaining to, or designating, an acid (called also lithic acid) found in certain red precipitates of urine.","pos":""}],"ROSALIA":[{"def":"A form of melody in which a phrase or passage is successively repeated, each time a step or half step higher; a melodic sequence.","pos":""}],"ROSANILINE":[{"def":"A complex nitrogenous base, C20H21N3O, obtained by oxidizing a mixture of aniline and toluidine, as a colorless crystalline substance which forms red salts.","pos":""}],"ROSARIAN":[{"def":"A cultivator of roses.","pos":""}],"ROSARY":[{"def":"A series of prayers (see Note below) arranged to be recited in order, on beads; also, a string of beads by which the prayers are counted.","pos":""}],"ROSCID":[{"def":"Containing, or consisting of, dew; dewy.","pos":""}],"ROSCOELITE":[{"def":"A green micaceous mineral occurring in minute scales.","pos":""}],"ROSE":[{"def":"A flower and shrub of any species of the genus Rosa, of which there are many species, mostly found in the morthern hemispere Note: Roses are shrubs with pinnate leaves and usually prickly stems.","pos":""},{"def":"A knot of ribbon formed like a rose; a rose knot; a rosette, esp.","pos":""}],"ROSE WATER":[{"def":"Water tinctured with roses by distillation.","pos":""}],"ROSE-COLORED":[{"def":"Having the color of a pink rose; rose-pink; of a delicate pink color.","pos":""},{"def":"Uncommonly beautiful; hence, extravagantly fine or pleasing; alluring; as, rose-colored anticipations.","pos":""}],"ROSE-CUT":[{"def":"Cut flat on the reverse, and with a convex face formed of triangular facets in rows; -- said of diamonds and other precious stones.","pos":""}],"ROSE-PINK":[{"def":"Having a pink color like that of the rose, or like the pigment called rose pink.","pos":""},{"def":"Disposed to clothe everything with roseate hues; hence, sentimental.","pos":""}],"ROSE-RED":[{"def":"Red as a rose; specifically (Zoöl.","pos":""}],"ROSE-RIAL":[{"def":"A name of several English gold coins struck in different reigns and having having different values; a rose noble.","pos":""}],"ROSE-WATER":[{"def":"Having the odor of rose water; hence, affectedly nice or delicate; sentimental.","pos":""}],"ROSEAL":[{"def":"resembling a rose in smell or color.","pos":""}],"ROSEATE":[{"def":"Full of roses; rosy; as, roseate bowers.","pos":""}],"ROSEBAY":[{"def":"Europe and North America; -- called also great willow herb.","pos":""}],"ROSEBUD":[{"def":"The flower of a rose before it opens, or when but partially open.","pos":""}],"ROSEBUSH":[{"def":"The bush or shrub which bears roses.","pos":""}],"ROSEDROP":[{"def":"A ruddy eruption upon the nose caused by drinking ardent spirits; a grog blossom.","pos":""}],"ROSEFINCH":[{"def":"Any one of numerous species of Asiatic finches of the genera Carpodacus, and Propasser, and allied genera, in which the male is more or less colored with rose red.","pos":""}],"ROSEFISH":[{"def":"A large marine scorpænoid food fish (Sebastes marinus) found on the northern coasts of Europe and America.","pos":""}],"ROSEHEAD":[{"def":"A many-sided pyramidal head upon a nail; also a nail with such a head.","pos":""}],"ROSELITE":[{"def":"A hydrous arsenite of cobalt, occuring in small red crystals, allied to erythrite.","pos":""}],"ROSELLA":[{"def":"A beautiful Australian parrakeet (Platycercus eximius) often kept as a cage bird.","pos":""}],"ROSELLE":[{"def":"a malvaceous plant (Hibiscus Sabdariffa) cultivated in the east and West Indies for its fleshy calyxes, which are used for making tarts and jelly and an acid drink.","pos":""}],"ROSEMALOES":[{"def":"The liquid storax of the East Indian Liquidambar orientalis.","pos":""}],"ROSEMARY":[{"def":"A labiate shrub (Rosmarinus officinalis) with narrow grayish leaves, growing native in the southern part of France, Spain, and Italy, also in Asia Minor and in China.","pos":""}],"ROSEN":[{"def":"Consisting of roses; rosy.","pos":""},{"def":"[So named from its first describer, J.","pos":""}],"ROSEO-":[{"def":"A prefix (also used adjectively) signifying rose-red; specifically used to designate certain rose-red compounds (called roseo-cobaltic compounds) of cobalt with ammonia.","pos":""}],"ROSEOLA":[{"def":"A rose-colored efflorescence upon the skin, occurring in circumscribed patches of little or no elevation and often alternately fading and reviving; also, an acute specific disease which is characterized by an eruption of this character; -- called also rose rash.","pos":""}],"ROSER":[{"def":"A rosier; a rosebush.","pos":""}],"ROSEROOT":[{"def":"A fleshy-leaved herb (Rhodiola rosea); rosewort; -- so called because the roots have the odor of roses.","pos":""}],"ROSERY":[{"def":"A place where roses are cultivated; a nursery of roses.","pos":""}],"ROSET":[{"def":"A red color used by painters.","pos":""}],"ROSETTA STONE":[{"def":"A stone found at Rosetta, in Egypt, bearing a trilingual inscription, by aid of which, with other inscriptions, a key was obtained to the hieroglyphics of ancient Egypt.","pos":""}],"ROSETTA WOOD":[{"def":"An east Indian wood of a reddish orange color, handsomely veined with darker marks.","pos":""}],"ROSETTE":[{"def":"An ornament in the form of a rose or roundel, -much used in decoration.","pos":""}],"ROSEWOOD":[{"def":"A valuable cabinet wood of a dark red color, streaked and variegated with black, obtained from several tropical leguminous trees of the genera Dalbergia and Machærium.","pos":""}],"ROSEWORM":[{"def":"The larva of any one of several species of lepidopterous insects which feed upon the leaves, buds, or blossoms of the rose, especially Cacæcia rosaceana, which rolls up the leaves for a nest, and devours both the leaves and buds.","pos":""}],"ROSICRUCIAN":[{"def":"One who, in the 17th century and the early part of the 18th, claimed to belong to a secret society of philosophers deeply versed in the secrets of nature, -- the alleged society having existed, it was stated, several hundred years.","pos":""}],"ROSIED":[{"def":"Decorated with roses, or with the color of roses.","pos":""}],"ROSIER":[{"def":"A rosebush; roses, collectively.","pos":""}],"ROSILY":[{"def":"In a rosy manner.","pos":""}],"ROSIN":[{"def":"The hard, amber-colored resin left after distilling off the volatile oil of turpentine; colophony.","pos":""}],"ROSINESS":[{"def":"The quality of being rosy.","pos":""}],"ROSINY":[{"def":"like rosin, or having its qualities.","pos":""}],"ROSLAND":[{"def":"heathy land; land full of heather; moorish or watery land.","pos":""}],"ROSMARINE":[{"def":"Dew from the sea; sea dew.","pos":""}],"ROSOLIC":[{"def":"Pertaining to, or designating, a complex red dyestuff (called rosolic acid) which is analogous to rosaniline and aurin.","pos":""}],"ROSS":[{"def":"The rough, scaly matter on the surface of the bark of trees.","pos":""}],"ROSSEL":[{"def":"Light land; rosland.","pos":""}],"ROSSEL CURRENT":[{"def":"A portion of the southern equatorial current flowing westward from the Fiji Islands to New Guinea.","pos":""}],"ROSTEL":[{"def":"same as Rostellum.","pos":""}],"ROSTELLAR":[{"def":"Pertaining to a rostellum.","pos":""}],"ROSTELLATE":[{"def":"Having a rostellum, or small beak; terminating in a beak.","pos":""}],"ROSTELLIFORM":[{"def":"Having the form of a rostellum, or small beak.","pos":""}],"ROSTELLUM":[{"def":"A small beaklike process or extension of some part; a small rostrum; as, the rostellum of the stigma of violets, or of the operculum of many mosses; the rostellum on the head of a tapeworm.","pos":""}],"ROSTER":[{"def":"A register or roll showing the order in which officers, enlisted men, companies, or regiments are called on to serve.","pos":""}],"ROSTRAL":[{"def":"Of or pertaining to the beak or snout of an animal, or the beak of a ship; resembling a rostrum, esp.","pos":""}],"ROSTRIFERA":[{"def":"A division of pectinibranchiate gastropods, having the head prolonged into a snout which is not retractile.","pos":""}],"ROSTRIFORM":[{"def":"Having the form of a beak.","pos":""}],"ROSTRULUM":[{"def":"A little rostrum, or beak, as of an insect.","pos":""}],"ROSTRUM":[{"def":"The Beaks; the stage or platform in the forum where orations, pleadings, funeral harangues, etc.","pos":""},{"def":"Same as Rostellum.","pos":""}],"ROSULATE":[{"def":"Arranged in little roselike clusters; -- said of leaves and bracts.","pos":""}],"ROSY":[{"def":"Resembling a rose in color, form, or qualities; blooming; red; blushing; also, adorned with roses.","pos":""}]}