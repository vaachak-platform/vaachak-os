{"NARCEINE":[{"def":"An alkaloid found in small quantities in opium, and extracted as a white crystalline substance of a bitter astringent taste.","pos":""}],"NARCISSINE":[{"def":"Of or pertaining to Narcissus.","pos":""}],"NARCISSUS":[{"def":"A genus of endogenous bulbous plants with handsome flowers, having a cup-shaped crown within the six-lobed perianth, and comprising the daffodils and jonquils of several kinds.","pos":""},{"def":"A beautiful youth fabled to have been enamored of his own image as seen in a fountain, and to have been changed into the flower called Narcissus.","pos":""}],"NARCOSIS":[{"def":"Privation of sense or consciousness, due to a narcotic.","pos":""}],"NARCOTIC":[{"def":"Having the properties of a narcotic; operating as a narcotic.","pos":""}],"NARCOTINE":[{"def":"An alkaloid found in opium, and extracted as a white crystalline substance, tasteless and less poisonous than morphine; -- called also narcotia.","pos":""}],"NARCOTINIC":[{"def":"Pertaining to narcotine.","pos":""}],"NARCOTISM":[{"def":"Narcosis; the state of being narcotized.","pos":""}],"NARCOTIZE":[{"def":"To imbue with, or subject to the influence of, a narcotic; to put into a state of narcosis.","pos":""}],"NARD":[{"def":"An East Indian plant (Nardostachys Jatamansi) of the Valerian family, used from remote ages in Oriental perfumery.","pos":""},{"def":"A kind of grass (Nardus stricta) of little value, found in Europe and Asia.","pos":""}],"NARDINE":[{"def":"Of or pertaining to nard; having the qualities of nard.","pos":""}],"NARDOO":[{"def":"An Australian name for Marsilea Drummondii, a four-leaved cryptogamous plant, sometimes used for food.","pos":""}],"NARES":[{"def":"The nostrils or nasal openings, -- the anterior nares being the external or proper nostrils, and the posterior nares, the openings of the nasal cavities into the mouth or pharynx.","pos":""},{"def":"An apparatus for smoking tobacco.","pos":""}],"NARICA":[{"def":"The brown coati.","pos":""}],"NARIFORM":[{"def":"Formed like the nose.","pos":""}],"NARINE":[{"def":"Of or belonging to the nostrils.","pos":""}],"NARRABLE":[{"def":"Capable of being narrated or told.","pos":""}],"NARRAGANSETTS":[{"def":"A tribe of Indians who formerly inhabited the shores of Narragansett Bay.","pos":""}],"NARRATE":[{"def":"To tell, rehearse, or recite, as a story; to relate the particulars of; to go through with in detail, as an incident or transaction; to give an account of.","pos":""}],"NARRATION":[{"def":"That part of a discourse which recites the time, manner, or consequences of an action, or simply states the facts connected with the subject.","pos":""}],"NARRATIVE":[{"def":"Of or pertaining to narration; relating to the particulars of an event or transaction.","pos":""},{"def":"Apt or inclined to relate stories, or to tell particulars of events; story-telling; garrulous.","pos":""}],"NARRATIVELY":[{"def":"In the style of narration.","pos":""}],"NARRATOR":[{"def":"One who narrates; one who relates a series of events or transactions.","pos":""}],"NARRATORY":[{"def":"Giving an account of events; narrative; as, narratory letters.","pos":""}],"NARROW":[{"def":"Formed (as a vowel) by a close position of some part of the tongue in relation to the palate; or (according to Bell) by a tense condition of the pharynx; -- distinguished from wide; as e (eve) and oo (food), etc.","pos":""}],"NARROW-MINDED":[{"def":"Of narrow mental scope; illiberal; mean.","pos":""}],"NARROWER":[{"def":"One who, or that which, narrows or contracts.","pos":""}],"NARROWING":[{"def":"The act of contracting, or of making or becoming less in breadth or extent.","pos":""},{"def":"The part of a stocking which is narrowed.","pos":""}],"NARROWLY":[{"def":"With little breadth; in a narrow manner.","pos":""},{"def":"Without much extent; contractedly.","pos":""}],"NARROWNESS":[{"def":"The condition or quality of being narrow.","pos":""}],"NARTHEX":[{"def":"A tall umbelliferous plant (Ferula communis).","pos":""},{"def":"The portico in front of ancient churches; sometimes, the atrium or outer court surrounded by ambulatories; -- used, generally, for any vestibule, lobby, or outer porch, leading to the nave of a church.","pos":""}],"NARWHAL":[{"def":"An arctic cetacean (Monodon monocerous), about twenty feet long.","pos":""}]}