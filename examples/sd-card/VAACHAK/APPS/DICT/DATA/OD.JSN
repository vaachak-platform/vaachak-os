{"OD":[{"def":"An alleged force or natural power, supposed, by Reichenbach and others, to produce the phenomena of mesmerism, and to be developed by various agencies, as by magnets, heat, light, chemical or vital action, etc.","pos":""}],"ODAL":[{"def":"Among the early and medieval Teutonic peoples, esp.","pos":""}],"ODALISQUE":[{"def":"A female slave or concubine in the harem of the Turkish sultan.","pos":""},{"def":"A man or woman having odal, or able to share in it by inheritance.","pos":""}],"ODD":[{"def":"Not paired with another, or remaining over after a pairing; without a mate; unmatched; single; as, an odd shoe; an odd glove.","pos":""},{"def":"Not divisible by 2 without a remainder; not capable of being evenly paired, one unit with another; as, 1, 3, 7, 9, 11, etc.","pos":""}],"ODD FELLOW":[{"def":"A member of a secret order, or fraternity, styled the Independent Order of Odd Fellows, established for mutual aid and social enjoyment.","pos":""}],"ODDITY":[{"def":"The quality or state of being odd; singularity; queerness; peculiarity; as, oddity of dress, manners, and the like.","pos":""},{"def":"That which is odd; as, a collection of oddities.","pos":""}],"ODDLY":[{"def":"In a manner measured by an odd number.","pos":""}],"ODDMENT":[{"def":"An odd thing, or one that is left over, disconnected, fragmentary, or the like; something that is separated or disconnected from its fellows; esp.","pos":""},{"def":"the odds and ends.","pos":""}],"ODDNESS":[{"def":"The state of being odd, or not even.","pos":""},{"def":"Singularity; strangeness; eccentricity; irregularity; uncouthness; as, the oddness of dress or shape; the oddness of an event.","pos":""}],"ODDS":[{"def":"Difference in favor of one and against another; excess of one of two things or numbers over the other; inequality; advantage; superiority; hence, excess of chances; probability.","pos":""},{"def":"Quarrel; dispute; debate; strife; -- chiefly in the phraze at odds.","pos":""}],"ODE":[{"def":"A short poetical composition proper to be set to music or sung; a lyric poem; esp.","pos":""}],"ODELET":[{"def":"A little or short ode.","pos":""}],"ODELSTHING":[{"def":"The lower house of the Norwegian Storthing.","pos":""}],"ODEON":[{"def":"A kind of theater in ancient Greece, smaller than the dramatic theater and roofed over, in which poets and musicians submitted their works to the approval of the public, and contended for prizes; -- hence, in modern usage, the name of a hall for musical or dramatic performances.","pos":""}],"ODIBLE":[{"def":"Fitted to excite hatred; hateful.","pos":""}],"ODIC":[{"def":"Of or pertaining to od.","pos":""}],"ODIN":[{"def":"The supreme deity of the Scandinavians; -- the same as Woden, of the German tribes.","pos":""}],"ODINIC":[{"def":"Of or pertaining to Odin.","pos":""}],"ODINISM":[{"def":"Worship of Odin; broadly, the Teutonic heathenism.","pos":""}],"ODIOUS":[{"def":"Hateful; deserving or receiving hatred; as, an odious name, system, vice.","pos":""},{"def":"Causing or provoking hatred, repugnance, or disgust; offensive; disagreeable; repulsive; as, an odious sight; an odious smell.","pos":""}],"ODIST":[{"def":"A writer of an ode or odes.","pos":""}],"ODIUM":[{"def":"Hatred; dislike; as, his conduct brought him into odium, or, brought odium upon him.","pos":""},{"def":"The quality that provokes hatred; offensiveness.","pos":""}],"ODIZE":[{"def":"To charge with od.","pos":""}],"ODMYL":[{"def":"A volatile liquid obtained by boiling sulphur with linseed oil.","pos":""}],"ODOGRAPH":[{"def":"A machine for registering the distance traversed by a vehicle or pedestrain.","pos":""},{"def":"A device for recording the length and rapidity of stride and the number of steps taken by a walker.","pos":""}],"ODOMETER":[{"def":"An instrument attached to the wheel of a vehicle, to measure the distance traversed; also, a wheel used by surveyors, which registers the miles and rods traversed.","pos":""}],"ODOMETRICAL":[{"def":"Of or pertaining to the odometer, or to measurements made with it.","pos":""}],"ODOMETROUS":[{"def":"Serving to measure distance on a road.","pos":""}],"ODOMETRY":[{"def":"Measurement of distances by the odometer.","pos":""}],"ODONATA":[{"def":"The division of insects that includes the dragon flies.","pos":""}],"ODONTALGIC":[{"def":"Of or pertaining to odontalgia.","pos":""},{"def":"A remedy for the toothache.","pos":""}],"ODONTALGY":[{"def":"Same as Odontalgia.","pos":""}],"ODONTIASIS":[{"def":"Cutting of the teeth; dentition.","pos":""}],"ODONTO-":[{"def":"A combining form from Gr.","pos":""}],"ODONTOBLAST":[{"def":"One of the more or less columnar cells on the outer surface of the pulp of a tooth; an odontoplast.","pos":""},{"def":"One of the cells which secrete the chitinous teeth of Mollusca.","pos":""}],"ODONTOCETE":[{"def":"A subdivision of Cetacea, including the sperm whale, dolphins, etc.","pos":"noun"}],"ODONTOGENY":[{"def":"Generetion, or mode of development, of the teeth.","pos":""}],"ODONTOGRAPH":[{"def":"An instrument for marking or laying off the outlines of teeth of gear wheels.","pos":""}],"ODONTOGRAPHIC":[{"def":"Of or pertaining to odontography.","pos":""}],"ODONTOGRAPHY":[{"def":"A description of the teeth.","pos":""}],"ODONTOLCAE":[{"def":"An extinct order of ostrichlike aquatic birds having teeth, which are set in a groove in the jaw.","pos":""}],"ODONTOLITE":[{"def":"A fossil tooth colored a bright blue by phosphate of iron.","pos":""}],"ODONTOLOGY":[{"def":"The science which treats of the teeth, their structure and development.","pos":""}],"ODONTOPHORA":[{"def":"Same as Cephalophora.","pos":"noun"}],"ODONTOPHORE":[{"def":"A special structure found in the mouth of most mollusks, except bivalves.","pos":""}],"ODONTOPHOROUS":[{"def":"Having an odontophore.","pos":""}],"ODONTOPTERYX":[{"def":"An extinct Eocene bird having the jaws strongly serrated, or dentated, but destitute of true teeth.","pos":""}],"ODONTORNITHES":[{"def":"A group of Mesozoic birds having the jaws armed with teeth, as in most other vertebrates.","pos":""}],"ODONTOSTOMATOUS":[{"def":"Having toothlike mandibles; -- applied to certain insects.","pos":""}],"ODONTOTORMAE":[{"def":"An order of extinct toothed birds having the teeth in sockets, as in the genus Ichthyornis.","pos":"noun"}],"ODOR":[{"def":"Any smell, whether fragrant or offensive; scent; perfume.","pos":""}],"ODORAMENT":[{"def":"A perfume; a strong scent.","pos":""}],"ODORANT":[{"def":"Yielding odors; fragrant.","pos":""}],"ODORATING":[{"def":"Diffusing odor or scent; fragrant.","pos":""}],"ODORIFEROUS":[{"def":"Bearing or yielding an odor; perfumed; usually, sweet of scent; fragrant; as, odoriferous spices, particles, fumes, breezes.","pos":""}],"ODORINE":[{"def":"A pungent oily substance obtained by redistilling bone oil.","pos":""}],"ODOROUS":[{"def":"Having or emitting an odor or scent, esp.","pos":""}],"ODS":[{"def":"A corruption of God's; -- formerly used in oaths and ejaculatory phrases.","pos":""}],"ODYLIC":[{"def":"Of or pertaining to odyle; odic; as, odylic force.","pos":""}],"ODYSSEY":[{"def":"An epic poem attributed to Homer, which describes the return of Ulysses to Ithaca after the siege of Troy.","pos":""}]}