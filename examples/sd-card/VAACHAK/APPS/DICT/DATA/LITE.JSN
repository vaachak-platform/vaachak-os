{"LITE":[{"def":"A measure of capacity in the metric system, being a cubic decimeter, equal to 61.","pos":""}],"LITERACY":[{"def":"State of being literate.","pos":""}],"LITERAL":[{"def":"According to the letter or verbal expression; real; not figurative or metaphorical; as, the literal meaning of a phrase.","pos":""},{"def":"Following the letter or exact words; not free.","pos":""}],"LITERALISM":[{"def":"The tendency or disposition to represent objects faithfully, without abstraction, conventionalities, or idealization.","pos":""}],"LITERALIST":[{"def":"One who adheres to the letter or exact word; an interpreter according to the letter.","pos":""}],"LITERALITY":[{"def":"The state or quality of being literal.","pos":""}],"LITERALIZATION":[{"def":"The act of literalizing; reduction to a literal meaning.","pos":""}],"LITERALIZE":[{"def":"To make literal; to interpret or put in practice according to the strict meaning of the words; -- opposed to spiritualize; as, to literalize Scripture.","pos":""}],"LITERALLY":[{"def":"According to the primary and natural import of words; not figuratively; as, a man and his wife can not be literally one flesh.","pos":""},{"def":"With close adherence to words; word by word.","pos":""}],"LITERALNESS":[{"def":"The quality or state of being literal; literal import.","pos":""}],"LITERARY":[{"def":"Of or pertaining to letters or literature; pertaining to learning or learned men; as, literary fame; a literary history; literary conversation.","pos":""},{"def":"Versed in, or acquainted with, literature; occupied with literature as a profession; connected with literature or with men of letters; as, a literary man.","pos":""}],"LITERATE":[{"def":"Instructed in learning, science, or literature; learned; lettered.","pos":""}],"LITERATI":[{"def":"Learned or literary men.","pos":""}],"LITERATIM":[{"def":"Letter for letter.","pos":""}],"LITERATION":[{"def":"The act or process of representing by letters.","pos":""}],"LITERATOR":[{"def":"One who teaches the letters or elements of knowledge; a petty schoolmaster.","pos":""},{"def":"A person devoted to the study of literary trifles, esp.","pos":""}],"LITERATURE":[{"def":"Learning; acquaintance with letters or books.","pos":""}],"LITERATUS":[{"def":"A learned man; a man acquainted with literature; -- chiefly used in the plural.","pos":""},{"def":"Combining forms fr.","pos":""}]}