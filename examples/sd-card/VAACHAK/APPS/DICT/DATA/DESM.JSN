{"DESMAN":[{"def":"An amphibious, insectivorous mammal found in Russia (Myogale moschata).","pos":""},{"def":"A microscopic plant of the family Desmidiæ, a group of unicellular algæ in which the species have a greenish color, and the cells generally appear as if they consisted of two coalescing halves.","pos":""}],"DESMINE":[{"def":"Same as Stilbite.","pos":""}],"DESMOBACTERIA":[{"def":"See Microbacteria.","pos":""}],"DESMODONT":[{"def":"A member of a group of South American blood-sucking bats, of the genera Desmodus and Diphylla.","pos":""}],"DESMOGNATHOUS":[{"def":"Having the maxillo-palatine bones united; -- applied to a group of carinate birds (Desmognathæ), including various wading and swimming birds, as the ducks and herons, and also raptorial and other kinds.","pos":""}],"DESMOID":[{"def":"Resembling, or having the characteristics of, a ligament; ligamentous.","pos":""}],"DESMOLOGY":[{"def":"The science which treats of the ligaments.","pos":""}],"DESMOMYARIA":[{"def":"The division of Tunicata which includes the Salpæ.","pos":""}]}