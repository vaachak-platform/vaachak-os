{"LEIOTRICHAN":[{"def":"Of or pertaining to the Leiotrichi.","pos":""},{"def":"One of the Leiotrichi.","pos":""}],"LEIOTRICHI":[{"def":"The division of mankind which embraces the smooth-haired races.","pos":""}],"LEIOTRICHOUS":[{"def":"Having smooth, or nearly smooth, hair.","pos":""}],"LEIPOA":[{"def":"A genus of Australian gallinaceous birds including but a single species (Leipoa ocellata), about the size of a turkey.","pos":""}],"LEIPOTHYMIC":[{"def":"A spear armed with three or more prongs, for striking fish.","pos":""}],"LEISURABLE":[{"def":"Vacant of employment; not occupied; idle; leisure; as leisurable hours.","pos":""}],"LEISURE":[{"def":"Freedom from occupation or business; vacant time; time free from employment.","pos":""},{"def":"Time at one's command, free from engagement; convenient opportunity; hence, convenience; ease.","pos":""}],"LEISURELY":[{"def":"Characterized by leisure; taking abundant tome; not hurried; as, a leisurely manner; a leisurely walk.","pos":""}],"LEITMOTIF":[{"def":"See Leading motive, under Leading, a.","pos":""}]}