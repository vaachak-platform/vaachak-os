{"WAN":[{"def":"Having a pale or sickly hue; languid of look; pale; pallid.","pos":""}],"WAND":[{"def":"A small stick; a rod; a verge.","pos":""},{"def":"Specifically: (a) A staff of authority.","pos":""}],"WANDER":[{"def":"To ramble here and there without any certain course or with no definite object in view; to range about; to stroll; to rove; as, to wander over the fields.","pos":""},{"def":"To go away; to depart; to stray off; to deviate; to go astray; as, a writer wanders from his subject.","pos":""}],"WANDERER":[{"def":"One who wanders; a rambler; one who roves; hence, one who deviates from duty.","pos":""}],"WANDERING":[{"def":"Wan\"der*ing, Defn: a.","pos":""}],"WANDERINGLY":[{"def":"In a wandering manner.","pos":""}],"WANDERMENT":[{"def":"The act of wandering, or roaming.","pos":""}],"WANDEROO":[{"def":"A large monkey (Macacus silenus) native of Malabar.","pos":""}],"WANDY":[{"def":"Long and flexible, like a wand.","pos":""}],"WANE":[{"def":"To be diminished; to decrease; -- contrasted with wax, and especially applied to the illuminated part of the moon.","pos":""},{"def":"To decline; to fail; to sink.","pos":""}],"WANEY":[{"def":"A sharp or uneven edge on a board that is cut from a log not perfectly squared, or that is made in the process of squaring.","pos":""}],"WANG":[{"def":"The jaw, jawbone, or cheek bone.","pos":""}],"WANGAN":[{"def":"A boat for conveying provisions, tools, etc.","pos":""}],"WANGER":[{"def":"A pillow for the cheek; a pillow.","pos":""}],"WANGHEE":[{"def":"The Chinese name of one or two species of bamboo, or jointed cane, of the genus Phyllostachys.","pos":""}],"WANHOPE":[{"def":"Want of hope; despair; also, faint or delusive hope; delusion.","pos":""}],"WANHORN":[{"def":"An East Indian plant (Kæmpferia Galanga) of the Ginger family.","pos":""}],"WANIAND":[{"def":"The wane of the moon.","pos":""}],"WANING":[{"def":"The act or process of waning, or decreasing.","pos":""}],"WANION":[{"def":"A word of uncertain signification, used only in the phrase with a wanion, apparently equivalent to with a vengeance, with a plague, or with misfortune.","pos":""}],"WANKLE":[{"def":"Not to be depended on; weak; unstable.","pos":""}],"WANLY":[{"def":"In a wan, or pale, manner.","pos":""}],"WANNED":[{"def":"Made wan, or pale.","pos":""}],"WANNESS":[{"def":"The quality or state of being wan; a sallow, dead, pale color; paleness; pallor; as, the wanness of the cheeks after a fever.","pos":""}],"WANNISH":[{"def":"Somewhat wan; of a pale hue.","pos":""}],"WANT":[{"def":"A depression in coal strata, hollowed out before the subsequent deposition took place.","pos":""}],"WANTAGE":[{"def":"That which is wanting; deficiency.","pos":""}],"WANTING":[{"def":"Absent; lacking; missing; also, deficient; destitute; needy; as, one of the twelve is wanting; I shall not be wanting in exertion.","pos":""}],"WANTLESS":[{"def":"Having no want; abundant; fruitful.","pos":""}],"WANTON":[{"def":"Untrained; undisciplined; unrestrained; hence, loose; free; luxuriant; roving; sportive.","pos":""},{"def":"Wandering from moral rectitude; perverse; dissolute.","pos":""}],"WANTONIZE":[{"def":"To behave wantonly; to frolic; to wanton.","pos":""}],"WANTONLY":[{"def":"In a wanton manner; without regularity or restraint; loosely; sportively; gayly; playfully; recklessly; lasciviously.","pos":""},{"def":"Unintentionally; accidentally.","pos":""}],"WANTONNESS":[{"def":"The quality or state of being wanton; negligence of restraint; sportiveness; recklessness; lasciviousness.","pos":""}],"WANTRUST":[{"def":"Failing or diminishing trust; want of trust or confidence; distrust.","pos":""}],"WANTWIT":[{"def":"One destitute of wit or sense; a blockhead; a fool.","pos":""}],"WANTY":[{"def":"A surcingle, or strap of leather, used for binding a load upon the back of a beast; also, a leather tie; a short wagon rope.","pos":""}],"WANY":[{"def":"Waning or diminished in some parts; not of uniform size throughout; -- said especially of sawed boards or timber when tapering or uneven, from being cut too near the outside of the log.","pos":""},{"def":"Spoiled by wet; -- said of timber.","pos":""}],"WANZE":[{"def":"To wane; to wither.","pos":""}]}