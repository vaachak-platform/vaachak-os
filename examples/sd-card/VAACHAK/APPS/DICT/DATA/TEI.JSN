{"TEIL":[{"def":"The lime tree, or linden; -- called also teil tree.","pos":""}],"TEINLAND":[{"def":"Land granted by the crown to a thane or lord.","pos":""}],"TEINOSCOPE":[{"def":"An instrument formed by combining prisms so as to correct the chromatic aberration of the light while linear dimensions of objects seen through the prisms are increased or diminished; -- called also prism telescope.","pos":""}],"TEINT":[{"def":"Tint; color; tinge, See Tint.","pos":""}],"TEINTURE":[{"def":"Color; tinge; tincture.","pos":""}]}