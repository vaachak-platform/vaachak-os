{"REBANISH":[{"def":"To banish again.","pos":""},{"def":"A second baptism.","pos":""}],"REBAPTISM":[{"def":"A second baptism.","pos":""}],"REBAPTIZE":[{"def":"To baptize again or a second time.","pos":""}],"REBAPTIZER":[{"def":"One who rebaptizes.","pos":""}],"REBARBARIZE":[{"def":"To reduce again to barbarism.","pos":""}],"REBATE":[{"def":"To beat to obtuseness; to deprive of keenness; to blunt; to turn back the point of, as a lance used for exercise.","pos":""},{"def":"To deduct from; to make a discount from, as interest due, or customs duties.","pos":""}],"REBATEMENT":[{"def":"Same as 3d Rebate, v.","pos":""}],"REBEC":[{"def":"An instrument formerly used which somewhat resembled the violin, having three strings, and being played with a bow.","pos":""}],"REBEL":[{"def":"Pertaining to rebels or rebellion; acting in revolt; rebellious; as, rebel troops.","pos":""}],"REBELDOM":[{"def":"A region infested by rebels; rebels, considered collectively; also, conduct o Thackeray.","pos":""}],"REBELLER":[{"def":"One who rebels; a rebel.","pos":""}],"REBELLION":[{"def":"Open resistances to, or defiance of, lawful authority.","pos":""}],"REBELLIOUS":[{"def":"Engaged in rebellion; disposed to rebel of the nature of rebels or of rebellion; resisting government or lawful authority by force.","pos":""}],"REBELLOW":[{"def":"To bellow again; to repeat or echo a bellow.","pos":""}],"REBITING":[{"def":"The act or process of deepening worn lines in an etched plate by submitting it again to the action if acid.","pos":""}],"REBLOSSOM":[{"def":"To blossom again.","pos":""}],"REBOANT":[{"def":"Rebellowing; resounding loudly.","pos":""}],"REBOATION":[{"def":"Repetition of a bellow.","pos":""}],"REBOIL":[{"def":"To boil, or to cause to boil, again.","pos":""}],"REBOUND":[{"def":"To spring back; to start back; to be sent back or reverberated by elastic force on collision with another body; as, a rebounding echo.","pos":""},{"def":"To give back an echo.","pos":""}],"REBOZO":[{"def":"A kind of mantilla worn by women over the head and shoulders, and sometimes over part of the face.","pos":""}],"REBREATHE":[{"def":"To breathe again.","pos":""}],"REBUCOUS":[{"def":"She gave unto him many rebucous words.","pos":""}],"REBUFF":[{"def":"Repercussion, or beating back; a quick and sudden resistance.","pos":""},{"def":"Sudden check; unexpected repulse; defeat; refusal; repellence; rejection of solicitation.","pos":""}],"REBUILD":[{"def":"To build again, as something which has been demolished; to construct anew; as, to rebuild a house, a wall, a wharf, or a city.","pos":""}],"REBUILDER":[{"def":"One who rebuilds.","pos":""}],"REBUKABLE":[{"def":"Worthy of rebuke or reprehension; reprehensible.","pos":""}],"REBUKE":[{"def":"To check, silence, or put down, with reproof; to restrain by expression of disapprobation; to reprehend sharply and summarily; to chide; to reprove; to admonish.","pos":""}],"REBUKEFUL":[{"def":"Containing rebuke; of the nature of rebuke.","pos":""}],"REBUKER":[{"def":"One who rebukes.","pos":""}],"REBUKINGLY":[{"def":"By way of rebuke.","pos":""}],"REBULLITION":[{"def":"The act of boiling up or effervescing.","pos":""}],"REBUS":[{"def":"A pictorial suggestion on a coat of arms of the name of the person to whom it belongs.","pos":""}],"REBUT":[{"def":"To contradict, meet, or oppose by argument, plea, or countervailing proof.","pos":""}],"REBUTTABLE":[{"def":"Capable of being rebutted.","pos":""}],"REBUTTAL":[{"def":"The giving of evidence on the part of a plaintiff to destroy the effect of evidence introduced by the defendant in the same suit.","pos":""}],"REBUTTER":[{"def":"The answer of a defendant in matter of fact to a plaintiff's surrejoinder.","pos":""}]}