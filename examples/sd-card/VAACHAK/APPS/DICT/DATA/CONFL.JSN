{"CONFLAGRANT":[{"def":"Burning together in a common flame.","pos":""}],"CONFLAGRATION":[{"def":"A fire extending to many objects, or over a large space; a general burning.","pos":""}],"CONFLATE":[{"def":"To blow together; to bring together; to collect; to fuse together; to join or weld; to consolidate.","pos":""}],"CONFLATION":[{"def":"A blowing together, as of many instruments in a concert, or of many fires in a foundry.","pos":""}],"CONFLICT":[{"def":"A striking or dashing together; violent collision; as, a conflict of elements or waves.","pos":""},{"def":"A strife for the mastery; hostile contest; battle; struggle; fighting.","pos":""}],"CONFLICTING":[{"def":"Being in conflict or collision, or in opposition; contending; contradictory; incompatible; contrary; opposing.","pos":""}],"CONFLICTIVE":[{"def":"Tending to conflict; conflicting.","pos":""}],"CONFLUENCE":[{"def":"The act of flowing together; the meeting or junction of two or more streams; the place of meeting.","pos":""},{"def":"Any running together of separate streams or currents; the act of meeting and crowding in a place; hence, a crowd; a concourse; an assemblage.","pos":""}],"CONFLUENT":[{"def":"Flowing together; meeting in their course; running one into another.","pos":""}],"CONFLUX":[{"def":"A flowing together; a meeting of currents.","pos":""},{"def":"A large assemblage; a passing multitude.","pos":""}],"CONFLUXIBILITY":[{"def":"The tendency of fluids to run together.","pos":""}],"CONFLUXIBLE":[{"def":"Inclined to flow or run together.","pos":""}]}