{"LITH":[{"def":"A joint or limb; a division; a member; a part formed by growth, and articulated to, or symmetrical with, other parts.","pos":""}],"LITHAEMIA":[{"def":"A condition in which uric (lithic) acid is present in the blood.","pos":""}],"LITHAGOGUE":[{"def":"A medicine having, or supposed to have, the power of expelling calculous matter with the urine.","pos":""}],"LITHARGE":[{"def":"Lead monoxide; a yellowish red substance, obtained as an amorphous powder, or crystallized in fine scales, by heating lead moderately in a current of air or by calcining lead nitrate or carbonate.","pos":""}],"LITHARGYRUM":[{"def":"Crystallized litharge, obtained by fusion in the form of fine yellow scales.","pos":""}],"LITHATE":[{"def":"A salt of lithic or uric acid; a urate.","pos":""}],"LITHE":[{"def":"To listen or listen to; to hearken to.","pos":""}],"LITHELY":[{"def":"In a lithe, pliant, or flexible manner.","pos":""}],"LITHENESS":[{"def":"The quality or state of being lithe; flexibility; limberness.","pos":""}],"LITHER":[{"def":"Bad; wicked; false; worthless; slothful.","pos":""}],"LITHERLY":[{"def":"Crafty; cunning; mischievous; wicked; treacherous; lazy.","pos":""}],"LITHESOME":[{"def":"Pliant; limber; flexible; supple; nimble; lissom.","pos":""}],"LITHIA":[{"def":"The oxide of lithium; a strong alkaline caustic similar to potash and soda, but weaker.","pos":""}],"LITHIASIS":[{"def":"The formation of stony concretions or calculi in any part of the body, especially in the bladder and urinary passages.","pos":""}],"LITHIC":[{"def":"Pertaining to the formation of uric-acid concretions (stone) in the bladder and other parts of the body; as, lithic diathesis.","pos":""}],"LITHIOPHILITE":[{"def":"A phosphate of manganese and lithium; a variety of triphylite.","pos":""}],"LITHIUM":[{"def":"A metallic element of the alkaline group, occurring in several minerals, as petalite, spodumene, lepidolite, triphylite, etc.","pos":""}],"LITHO":[{"def":"A combining form from Gr.","pos":""}],"LITHOBILIC":[{"def":"Pertaining to or designating an organic acid of the tartaric acid series, distinct from lithofellic acid, but, like it, obtained from certain bile products, as bezoar stones.","pos":""}],"LITHOCARP":[{"def":"Fossil fruit; a fruit petrified; a carpolite.","pos":""}],"LITHOCHROMATICS":[{"def":"See Lithochromics.","pos":""}],"LITHOCHROMICS":[{"def":"The art of printing colored pictures on canvas from oil paintings on stone.","pos":""}],"LITHOCLAST":[{"def":"An instrument for crushing stones in the bladder.","pos":""}],"LITHOCYST":[{"def":"A sac containing small, calcareous concretions (otoliths).","pos":""}],"LITHODOME":[{"def":"Any one of several species of bivalves, which form holes in limestone, in which they live; esp.","pos":""}],"LITHODOMOUS":[{"def":"Like, or pertaining to, Lithodomus; lithophagous.","pos":""}],"LITHODOMUS":[{"def":"A genus of elongated bivalve shells, allied to the mussels, and remarkable for their ability to bore holes for shelter, in solid limestone, shells, etc.","pos":""}],"LITHOFELLIC":[{"def":"Pertaining to, or designating, a crystalline, organic acid, resembling cholic acid, found in the biliary intestinal concretions (bezoar stones) common in certain species of antelope.","pos":""}],"LITHOFRACTEUR":[{"def":"An explosive compound of nitroglycerin.","pos":""}],"LITHOGENESY":[{"def":"The doctrine or science of the origin of the minerals composing the globe.","pos":""}],"LITHOGENOUS":[{"def":"Stone-producing; -- said of polyps which form coral.","pos":""}],"LITHOGLYPH":[{"def":"An engraving on a gem.","pos":""}],"LITHOGLYPHER":[{"def":"One who curs or engraves precious stones.","pos":""}],"LITHOGLYPHIC":[{"def":"Of or pertaining to the art of cutting and engraving precious stones.","pos":""}],"LITHOGLYPTICS":[{"def":"The art of cutting and engraving gems.","pos":""}],"LITHOGRAPH":[{"def":"To trace on stone by the process of lithography so as to transfer the design to paper by printing; as, to lithograph a design; to lithograph a painting.","pos":""}],"LITHOGRAPHER":[{"def":"One who lithographs; one who practices lithography.","pos":""},{"def":"Of or pertaining to lithography; made by lithography; as, the lithographic art; a lithographic picture.","pos":""}],"LITHOGRAPHY":[{"def":"The art or process of putting designs or writing, with a greasy material, on stone, and of producing printed impressions therefrom.","pos":""},{"def":"Like a stone; having a stony structure.","pos":""}],"LITHOLATRY":[{"def":"The worship of a stone or stones.","pos":""},{"def":"Of or pertaining to the character of a rock, as derived from the nature and mode of aggregation of its mineral contents.","pos":""}],"LITHOLOGICALLY":[{"def":"From a lithological point of view; as, to consider a stratum lithologically.","pos":""}],"LITHOLOGIST":[{"def":"One who is skilled in lithology.","pos":""}],"LITHOLOGY":[{"def":"A treatise on stones found in the body.","pos":""}],"LITHOMANCY":[{"def":"Divination by means of stones.","pos":""}],"LITHOMARGE":[{"def":"A clay of a fine smooth texture, and very sectile.","pos":""},{"def":"Same as Lithontriptic.","pos":""}],"LITHONTRIPTIC":[{"def":"Having the quality of, or used for, dissolving or destroying stone in the bladder or kidneys; as, lithontriptic forcéps.","pos":""},{"def":"A lithontriptic remedy or agent, as distilled water.","pos":""}],"LITHONTRIPTIST":[{"def":"Same as Lithotriptist.","pos":""}],"LITHONTRIPTOR":[{"def":"See Lithotriptor.","pos":""}],"LITHOPHANE":[{"def":"Porcelain impressed with figures which are made distinct by transmitted light, -- as when hung in a window, or used as a lamp shade.","pos":""}],"LITHOPHOSPHOR":[{"def":"A stone that becomes phosphoric by heat.","pos":""}],"LITHOPHOSPHORIC":[{"def":"Pertaining to lithophosphor; becoming phosphoric by heat.","pos":""}],"LITHOPHOTOGRAPHY":[{"def":"Same as Photolithography.","pos":""}],"LITHOPHYLL":[{"def":"A fossil leaf or impression of a leaf.","pos":""}],"LITHOPHYSE":[{"def":"A spherulitic cavity often with concentric chambers, observed in some volcanic rocks, as in rhyolitic lavas.","pos":""}],"LITHOPHYTE":[{"def":"A hard, or stony, plantlike organism, as the gorgonians, corals, and corallines, esp.","pos":""}],"LITHOPHYTIC":[{"def":"Of or pertaining to lithophytes.","pos":""}],"LITHOSIAN":[{"def":"Any one of various species of moths belonging to the family Lithosidæ.","pos":""}],"LITHOTINT":[{"def":"A kind of lithography by which the effect of a tinted drawing is produced, as if made with India ink.","pos":""},{"def":"A picture produced by this process.","pos":""}],"LITHOTOME":[{"def":"An instrument used for cutting the bladder in operations for the stone.","pos":""},{"def":"Pertaining to, or performed by, lithotomy.","pos":""}],"LITHOTOMIST":[{"def":"One who performs the operation of cutting for stone in the bladder, or one who is skilled in the operation.","pos":""}],"LITHOTOMY":[{"def":"The operation, art, or practice of cutting for stone in the bladder.","pos":""}],"LITHOTRIPSY":[{"def":"The operation of crushing a stone in the bladder with an instrument called lithotriptor or lithotrite; lithotrity.","pos":""}],"LITHOTRIPTIC":[{"def":"Same as Lithontriptic.","pos":""}],"LITHOTRIPTIST":[{"def":"One skilled in breaking and extracting stone in the bladder.","pos":""}],"LITHOTRIPTOR":[{"def":"An instrument for triturating the stone in the bladder; a lithotrite.","pos":""}],"LITHOTRITIST":[{"def":"A lithotriptist.","pos":""}],"LITHOTRITY":[{"def":"The operation of breaking a stone in the bladder into small pieces capable of being voided.","pos":""}],"LITHOTYPE":[{"def":"A kind of stereotype plate made by lithotypy; also, that which in printed from it.","pos":""}],"LITHOTYPIC":[{"def":"Of, pertaining to, or produced by, lithotypy.","pos":""}],"LITHOTYPY":[{"def":"The art or process of making a kind of hard, stereotypeplate, by pressing into a mold, taken from a page of type or other matter, a composition of gum shell-lac and sand of a fine quality, together with a little tar and linseed oil, all in a heated state.","pos":""}],"LITHUANIAN":[{"def":"Of or pertaining to Lithuania (formerly a principality united with Poland, but now Russian and Prussian territory).","pos":""}],"LITHY":[{"def":"Easily bent; pliable.","pos":""}]}