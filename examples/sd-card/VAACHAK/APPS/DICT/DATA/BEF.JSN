{"BEFALL":[{"def":"I beseech your grace that I may know The worst that may befall me.","pos":""}],"BEFIT":[{"def":"To be suitable to; to suit; to become.","pos":""}],"BEFITTING":[{"def":"Suitable; proper; becoming; fitting.","pos":""}],"BEFITTINGLY":[{"def":"In a befitting manner; suitably.","pos":""}],"BEFLATTER":[{"def":"To flatter excessively.","pos":""}],"BEFLOWER":[{"def":"To besprinkle or scatter over with, or as with, flowers.","pos":""}],"BEFOG":[{"def":"To involve in a fog; -- mostly as a participle or part.","pos":""},{"def":"Hence: To confuse; to mystify.","pos":""}],"BEFOOL":[{"def":"To fool; to delude or lead into error; to infatuate; to deceive.","pos":""},{"def":"To cause to behave like a fool; to make foolish.","pos":""}],"BEFORE":[{"def":"In front of; preceding in space; ahead of; as, to stand before the fire; before the house.","pos":""},{"def":"Preceding in time; earlier than; previously to; anterior to the time when; -- sometimes with the additional idea of purpose; in order that.","pos":""}],"BEFOREHAND":[{"def":"In a state of anticipation ore preoccupation; in advance; -- often followed by with.","pos":""},{"def":"By way of preparation, or preliminary; previously; aforetime.","pos":""}],"BEFORETIME":[{"def":"Formerly; aforetime.","pos":""}],"BEFORTUNE":[{"def":"I wish all good befortune you.","pos":""}],"BEFOUL":[{"def":"To make foul; to soil.","pos":""},{"def":"To entangle or run against so as to impede motion.","pos":""}],"BEFRIEND":[{"def":"To act as a friend to; to favor; to aid, benefit, or countenance.","pos":""}],"BEFRIENDMENT":[{"def":"Act of befriending.","pos":""}],"BEFRILL":[{"def":"To furnish or deck with a frill.","pos":""}],"BEFRINGE":[{"def":"To furnish with a fringe; to form a fringe upon; to adorn as with fringe.","pos":""}],"BEFUDDLE":[{"def":"To becloud and confuse, as with liquor.","pos":""}]}