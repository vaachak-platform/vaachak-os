{"DISEASE":[{"def":"Lack of ease; uneasiness; trouble; vexation; disquiet.","pos":""}],"DISEASED":[{"def":"Afflicted with disease.","pos":""}],"DISEASEDNESS":[{"def":"The state of being diseased; a morbid state; sickness.","pos":""}],"DISEASEFUL":[{"def":"Causing uneasiness.","pos":""},{"def":"Abounding with disease; producing diseases; as, a diseaseful climate.","pos":""}],"DISEASEFULNESS":[{"def":"The quality of being diseaseful; trouble; trial.","pos":""}],"DISEASEMENT":[{"def":"Uneasiness; inconvenience.","pos":""}],"DISEDGE":[{"def":"To deprive of an edge; to blunt; to dull.","pos":""}],"DISEDIFY":[{"def":"To fail of edifying; to injure.","pos":""}],"DISELDER":[{"def":"To deprive of an elder or elders, or of the office of an elder.","pos":""}],"DISELENIDE":[{"def":"A selenide containing two atoms of selenium in each molecule.","pos":""}],"DISEMBARK":[{"def":"To remove from on board a vessel; to put on shore; to land; to debark; as, the general disembarked the troops.","pos":""}],"DISEMBARKATION":[{"def":"The act of disembarking.","pos":""}],"DISEMBARRASS":[{"def":"To free from embarrassment, or perplexity; to clear; to extricate.","pos":""}],"DISEMBARRASSMENT":[{"def":"Freedom or relief from impediment or perplexity.","pos":""}],"DISEMBAY":[{"def":"To clear from a bay.","pos":""}],"DISEMBELLISH":[{"def":"To deprive of embellishment; to disadorn.","pos":""}],"DISEMBODIED":[{"def":"Divested of a body; ceased to be corporal; incorporeal.","pos":""}],"DISEMBODIMENT":[{"def":"The act of disembodying, or the state of being disembodied.","pos":""}],"DISEMBODY":[{"def":"To disarm and disband, as a body of soldiers,-Wilhelm.","pos":""}],"DISEMBOGUE":[{"def":"To pour out or discharge at the mouth, as a stream; to vent; to discharge into an ocean, a lake, etc.","pos":""},{"def":"To eject; to cast forth.","pos":""}],"DISEMBOGUEMENT":[{"def":"The act of disemboguing; discharge.","pos":""}],"DISEMBOSSOM":[{"def":"To separate from the bosom.","pos":""}],"DISEMBOWEL":[{"def":"To take or let out the bowels or interior parts of; to eviscerate.","pos":""},{"def":"To take or draw from the body, as the web of a spider.","pos":""}],"DISEMBOWELMENT":[{"def":"The act of disemboweling, or state of being disemboweled; evisceration.","pos":""}],"DISEMBOWERED":[{"def":"Deprived of, or removed from, a bower.","pos":""}],"DISEMBRANGLE":[{"def":"To free from wrangling or litigation.","pos":""}],"DISEMBROIL":[{"def":"To disentangle; to free from perplexity; to extricate from confusion.","pos":""}],"DISEMPLOY":[{"def":"To throw out of employment.","pos":""}],"DISEMPLOYMENT":[{"def":"The state of being disemployed, or deprived of employment.","pos":""}],"DISEMPOWER":[{"def":"To deprive of power; to divest of strength.","pos":""}],"DISENABLE":[{"def":"To disable; to disqualify.","pos":""}],"DISENAMOR":[{"def":"To free from the captivity of love.","pos":""}],"DISENCHAINED":[{"def":"Freed from restraint; unrestrained.","pos":""}],"DISENCHANT":[{"def":"To free from enchantment; to deliver from the power of charms or spells; to free from fascination or delusion.","pos":""}],"DISENCHANTER":[{"def":"One who, or that which, disenchants.","pos":""}],"DISENCHANTMENT":[{"def":"The act of disenchanting, or state of being disenchanted.","pos":""}],"DISENCHARM":[{"def":"To free from the influence of a charm or spell; to disenchant.","pos":""}],"DISENCOURAGEMENT":[{"def":"Dis`en*cour\"age*ment, n.","pos":""}],"DISENCUMBER":[{"def":"To free from encumbrance, or from anything which clogs, impedes, or obstructs; to disburden.","pos":""}],"DISENCUMBRANCE":[{"def":"Freedom or deliverance from encumbrance, or anything burdensome or troublesome.","pos":""}],"DISENDOW":[{"def":"To deprive of an endowment, as a church.","pos":""}],"DISENDOWMENT":[{"def":"The act of depriving of an endowment or endowments.","pos":""}],"DISENFRANCHISE":[{"def":"To disfranchise; to deprive of the rights of a citizen.","pos":""}],"DISENGAGE":[{"def":"To disengage him and the kingdom, great sums were to be borrowed.","pos":""}],"DISENGAGED":[{"def":"Not engaged; free from engagement; at leisure; free from occupation or care; vacant.","pos":""}],"DISENGAGEMENT":[{"def":"The act of disengaging or setting free, or the state of being disengaged.","pos":""},{"def":"Freedom from engrossing occupation; leisure.","pos":""}],"DISENGAGING":[{"def":"Loosing; setting free; detaching.","pos":""}],"DISENNOBLE":[{"def":"To deprive of that which ennobles; to degrade.","pos":""}],"DISENROLL":[{"def":"To erase from a roll or list.","pos":""}],"DISENSANITY":[{"def":"Insanity; folly.","pos":""}],"DISENSHROUDED":[{"def":"Freed from a shroudlike covering; unveiled.","pos":""}],"DISENSLAVE":[{"def":"To free from bondage or slavery; to disenthrall.","pos":""}],"DISENTAIL":[{"def":"To free from entailment.","pos":""}],"DISENTANGLE":[{"def":"To free from entanglement; to release from a condition of being intricately and confusedly involved or interlaced; to reduce to orderly arrangement; to straighten out; as, to disentangle a skein of yarn.","pos":""},{"def":"To extricate from complication and perplexity; disengage from embarrassing connection or intermixture; to disembroil; to set free; to separate.","pos":""}],"DISENTANGLEMENT":[{"def":"The act of disentangling or clearing from difficulties.","pos":""}],"DISENTHRALL":[{"def":"To release from thralldom or slavery; to give freedom to; to disinthrall.","pos":""}],"DISENTHRALLMENT":[{"def":"Liberation from bondage; emancipation; disinthrallment.","pos":""}],"DISENTHRONE":[{"def":"To dethrone; to depose from sovereign authority.","pos":""}],"DISENTITLE":[{"def":"To deprive of title or claim.","pos":""}],"DISENTOMB":[{"def":"To take out from a tomb; a disinter.","pos":""}],"DISENTRAIL":[{"def":"To disembowel; to let out or draw forth, as the entrails.","pos":""}],"DISENTRANCE":[{"def":"To awaken from a trance or an enchantment.","pos":""}],"DISENTWINE":[{"def":"To free from being entwined or twisted.","pos":""}],"DISEPALOUS":[{"def":"Having two sepals; two-sepaled.","pos":""}],"DISERTY":[{"def":"Expressly; clearly; eloquently.","pos":""}],"DISESPOUSE":[{"def":"To release from espousal or plighted faith.","pos":""}],"DISESTABLISH":[{"def":"To unsettle; to break up (anything established); to deprive, as a church, of its connection with the state.","pos":""}],"DISESTABLISHMENT":[{"def":"The act or process of unsettling or breaking up that which has been established; specifically, the withdrawal of the support of the state from an established church; as, the disestablishment and disendowment of the Irish Church by Act of Parliament.","pos":""},{"def":"The condition of being disestablished.","pos":""}],"DISESTEEM":[{"def":"Want of esteem; low estimation, inclining to dislike; disfavor; disrepute.","pos":""}],"DISESTEEMER":[{"def":"One who disesteems.","pos":""}],"DISEXERCISE":[{"def":"To deprive of exercise; to leave untrained.","pos":""}]}