{"HYACINTH":[{"def":"A red variety of zircon, sometimes used as a gem.","pos":""}],"HYACINTHINE":[{"def":"Belonging to the hyacinth; resemblingthe hyacinth; in color like the hyacinth.","pos":""},{"def":"A cluster of five stars in the face of the constellation Taurus, supposed by the ancients to indicate the coming of rainy weather when they rose with the sun.","pos":""}],"HYALEA":[{"def":"A pteroid of the genus Cavolina.","pos":""}],"HYALESCENCE":[{"def":"The process of becoming, or the state of being, transparent like glass.","pos":""}],"HYALINE":[{"def":"Glassy; resembling glass; consisting of glass; transparent, like crystal.","pos":""}],"HYALITE":[{"def":"A pellucid variety of opal in globules looking like colorless gum or resin; -- called also Müller's glass.","pos":""}],"HYALOGRAPH":[{"def":"An instrument for tracing designs on glass.","pos":""}],"HYALOGRAPHY":[{"def":"Art of writing or engraving on glass.","pos":""}],"HYALOID":[{"def":"Resembling glass; vitriform; transparent; hyaline; as, the hyaloid membrane, a very delicate membrane inclosing the vitreous humor of the eye.","pos":""}],"HYALONEMA":[{"def":"A genus of hexactinelline sponges, having a long stem composed of very long, slender, transparent, siliceous fibres twisted together like the strands of a color.","pos":""}],"HYALOPHANE":[{"def":"A species of the feldspar group containing barium.","pos":""}],"HYALOSPONGIA":[{"def":"An order of vitreous sponges, having glassy six-rayed, siliceous spicules; -- called also Hexactinellinæ.","pos":""}],"HYALOTYPE":[{"def":"A photographic picture copied from the negative on glass; a photographic transparency.","pos":""},{"def":"See Hibernacle, Hibernate, Hibernation.","pos":""}]}