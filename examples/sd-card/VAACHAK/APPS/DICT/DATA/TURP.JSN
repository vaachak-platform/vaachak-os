{"TURPENTINE":[{"def":"A semifluid or fluid oleoresin, primarily the exudation of the terebinth, or turpentine, tree (Pistacia Terebinthus), a native of the Mediterranean region.","pos":""}],"TURPENTINE STATE":[{"def":"North Carolina; -- a nickname alluding to its extensive production of turpentine.","pos":""}],"TURPETH":[{"def":"The root of Ipomoea Turpethum, a plant of Ceylon, Malabar, and Australia, formerly used in medicine as a purgative; -- sometimes called vegetable turpeth.","pos":""},{"def":"A heavy yellow powder, Hg3O2SO4, which consists of a basic mercuric sulphate; -- called also turpeth mineral.","pos":""}],"TURPIN":[{"def":"A land tortoise.","pos":""}],"TURPITUDE":[{"def":"Inherent baseness or vileness of principle, words, or actions; shameful wickedness; depravity.","pos":""},{"def":"A hydrous phosphate of alumina containing a little copper; calaite.","pos":""}]}