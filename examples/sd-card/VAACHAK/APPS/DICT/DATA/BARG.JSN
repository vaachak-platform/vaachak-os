{"BARGAIN":[{"def":"An agreement between parties concerning the sale of property; or a contract by which one party binds himself to transfer the right to some property for a consideration, and the other party binds himself to receive the property and pay the consideration.","pos":""},{"def":"An agreement or stipulation; mutual pledge.","pos":""}],"BARGAINEE":[{"def":"The party to a contract who receives, or agrees to receive, the property sold.","pos":""}],"BARGAINER":[{"def":"One who makes a bargain; -- sometimes in the sense of bargainor.","pos":""}],"BARGAINOR":[{"def":"One who makes a bargain, or contracts with another; esp.","pos":""}],"BARGE":[{"def":"A pleasure boat; a vessel or boat of state, elegantly furnished and decorated.","pos":""},{"def":"A large, roomy boat for the conveyance of passengers or goods; as, a ship's barge; a charcoal barge.","pos":""}],"BARGECOURSE":[{"def":"A part of the tiling which projects beyond the principal rafters, in buildings where there is a gable.","pos":""}],"BARGEMAN":[{"def":"The man who manages a barge, or one of the crew of a barge.","pos":""}],"BARGEMASTTER":[{"def":"The proprietor or manager of a barge, or one of the crew of a barge.","pos":""}],"BARGER":[{"def":"The manager of a barge.","pos":""}],"BARGHEST":[{"def":"A goblin, in the shape of a large dog, portending misfortune.","pos":""}]}