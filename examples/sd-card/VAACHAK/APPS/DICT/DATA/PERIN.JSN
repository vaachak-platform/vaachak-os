{"PERINEAL":[{"def":"Of or pertaining to the perineum.","pos":""}],"PERINEOPLASTY":[{"def":"The act or process of restoring an injured perineum.","pos":""}],"PERINEORRHAPHY":[{"def":"The operation of sewing up a ruptured perineum.","pos":""}],"PERINEPHRITIS":[{"def":"Inflammation of the cellular tissue around the kidney.","pos":""}],"PERINEUM":[{"def":"The region which is included within the outlet of the pelvis, and is traversed by the urinogenital canal and the rectum.","pos":""}],"PERINEURIAL":[{"def":"Surrounding nerves or nerve fibers; of or pertaining to the perineurium.","pos":""}],"PERINEURIUM":[{"def":"The connective tissue sheath which surrounds a bundle of nerve fibers.","pos":""}],"PERINUCLEAR":[{"def":"Of or pertaining to a nucleus; situated around a nucleus; as, the perinuclear protoplasm.","pos":""}]}