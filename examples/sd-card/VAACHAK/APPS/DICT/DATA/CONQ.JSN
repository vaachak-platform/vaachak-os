{"CONQUADRATE":[{"def":"To bring into a square.","pos":""}],"CONQUASSATE":[{"def":"To shake; to agitate.","pos":""}],"CONQUER":[{"def":"To gain or acquire by force; to take possession of by violent means; to gain dominion over; to subdue by physical means; to reduce; to overcome by force of arms; to cause to yield; to vanquish.","pos":""},{"def":"To subdue or overcome by mental or moral power; to surmount; as, to conquer difficulties, temptatin, etc.","pos":""}],"CONQUERABLE":[{"def":"Capable of being conquered or subdued.","pos":""}],"CONQUERESS":[{"def":"A woman who conquers.","pos":""}],"CONQUEROR":[{"def":"One who conquers.","pos":""}],"CONQUEST":[{"def":"The acquiring of property by other means than by inheritance; acquisition.","pos":""}],"CONQUIAN":[{"def":"A game for two, played with 40 cards, in which each player tries to form three or four of a kind or sequences.","pos":""}]}