{"CRENATION":[{"def":"A rounded tooth on the edge of a leaf.","pos":""}],"CRENATURE":[{"def":"A rounded tooth or notch of a crenate leaf, or any part that is crenate; -- called also crenelle.","pos":""}],"CRENELATE":[{"def":"To furnish with crenelles.","pos":""},{"def":"To indent; to notch; as, a crenelated leaf.","pos":""}],"CRENELATION":[{"def":"The act of crenelating, or the state of being crenelated; an indentation or an embrasure.","pos":""},{"def":"Same as Crenature.","pos":""}],"CRENELLED":[{"def":"Same as Crenate.","pos":""}],"CRENULATION":[{"def":"A minute crenation.","pos":""},{"def":"The state of being minutely scalloped.","pos":""}]}