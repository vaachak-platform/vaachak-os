{"CAPABILITY":[{"def":"The quality of being capable; capacity; capableness; esp.","pos":""},{"def":"Capacity of being used or improved.","pos":""}],"CAPABLE":[{"def":"Possessing ability, qualification, or susceptibility; having capacity; of sufficient size or strength; as, a room capable of holding a large number; a castle capable of resisting a long assault.","pos":""},{"def":"Possessing adequate power; qualified; able; fully competent; as, a capable instructor; a capable judge; a mind capable of nice investigations.","pos":""}],"CAPABLENESS":[{"def":"The quality or state of being capable; capability; adequateness; competency.","pos":""}],"CAPACIFY":[{"def":"The benefice he is capacified and designed for.","pos":""}],"CAPACIOUS":[{"def":"Having capacity; able to contain much; large; roomy; spacious; extended; broad; as, a capacious vessel, room, bay, or harbor.","pos":""},{"def":"Able or qualified to make large views of things, as in obtaining knowledge or forming designs; comprehensive; liberal.","pos":""}],"CAPACIOUSLY":[{"def":"In a capacious manner or degree; comprehensively.","pos":""}],"CAPACIOUSNESS":[{"def":"The quality of being capacious, as of a vessel, a reservoir a bay, the mind, etc.","pos":""}],"CAPACITATE":[{"def":"To render capable; to enable; to qualify.","pos":""}],"CAPACITY":[{"def":"Legal or noral qualification, as of age, residence, character, etc.","pos":""}],"CAPAPIE":[{"def":"From head to foot; at all points.","pos":""}],"CAPARISON":[{"def":"An ornamental covering or housing for a horse; the harness or trappings of a horse, taken collectively, esp.","pos":""},{"def":"Gay or rich clothing.","pos":""}],"CAPARRO":[{"def":"A large South American monkey (Lagothrix Humboldtii), with prehensile tail.","pos":""}]}