{"SYNOCHAL":[{"def":"Of or pertaining to synocha; like synocha.","pos":""}],"SYNOCHUS":[{"def":"A continuous fever.","pos":""}],"SYNOCIL":[{"def":"A sense organ found in certain sponges.","pos":""}],"SYNOD":[{"def":"An ecclesiastic council or meeting to consult on church matters.","pos":""},{"def":"A conjunction of two or more of the heavenly bodies.","pos":""}],"SYNODAL":[{"def":"A tribute in money formerly paid to the bishop or archdeacon, at the time of his Easter visitation, by every parish priest, now made to the ecclesiastical commissioners; a procuration.","pos":""},{"def":"Of or pertaining to a synod; transacted in, or authorized by, a synod; as, synodical proceedings or forms.","pos":""}],"SYNODICALLY":[{"def":"In a synodical manner; in a synod; by the authority of a synod.","pos":""}],"SYNODIST":[{"def":"An adherent to a synod.","pos":""}],"SYNOECIOUS":[{"def":"Having stamens and pistil in the same head, or, in mosses, having antheridia and archegonia on the same receptacle.","pos":""}],"SYNOMOCY":[{"def":"Sworn brotherhood; a society in ancient Greece nearly resembling a modern political club.","pos":""}],"SYNONYM":[{"def":"One of two or more words (commonly words of the same language) which are equivalents of each other; one of two or more words which have very nearly the same signification, and therefore may often be used interchangeably.","pos":""}],"SYNONYME":[{"def":"Same as Synonym.","pos":""}],"SYNONYMIC":[{"def":"The science, or the scientific treatment, of synonymous words.","pos":""},{"def":"Of or pertaining to synonyms, or synonymic; synonymous.","pos":""}],"SYNONYMICON":[{"def":"A dictionary of synonyms.","pos":""}],"SYNONYMIST":[{"def":"One who collects or explains synonyms.","pos":""}],"SYNONYMIZE":[{"def":"To express by a synonym or synonyms; to give the synonym or synonyms corresponding to.","pos":""}],"SYNONYMOUS":[{"def":"Having the character of a synonym; expressing the same thing; conveying the same, or approximately the same, idea.","pos":""}],"SYNONYMY":[{"def":"A figure by which synonymous words are used to amplify a discourse.","pos":""}],"SYNOPSIS":[{"def":"A general view, or a collection of heads or parts so arranged as to exhibit a general view of the whole; an abstract or summary of a discourse; a syllabus; a conspectus.","pos":""},{"def":"Affording a general view of the whole, or of the principal parts of a thing; as, a synoptic table; a synoptical statement of an argument.","pos":""}],"SYNOPTIC":[{"def":"One of the first three Gospels of the New Testament.","pos":""}],"SYNOPTIST":[{"def":"Any one of the authors of the three synoptic Gospels, which give a history of our Lord's life and ministry, in distinction from the writer of John's Gospel, which gives a fuller record of his teachings.","pos":""}],"SYNOSTEOLOGY":[{"def":"That part of anatomy which treats of joints; arthrology.","pos":""}],"SYNOSTEOSIS":[{"def":"Union by means of bone; the complete closing up and obliteration of sutures.","pos":""}],"SYNOSTOSIS":[{"def":"Same as Synosteosis.","pos":""}],"SYNOVIA":[{"def":"A transparent, viscid, lubricating fluid which contains mucin and secreted by synovial membranes; synovial fluid.","pos":""}],"SYNOVIAL":[{"def":"Of or pertaining to synovia; secreting synovia.","pos":""}],"SYNOVITIS":[{"def":"Inflammation of the synovial membrane.","pos":""}]}