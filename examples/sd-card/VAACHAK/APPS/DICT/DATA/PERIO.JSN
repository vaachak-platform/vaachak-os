{"PERIOD":[{"def":"One of the great divisions of geological time; as, the Tertiary period; the Glacial period.","pos":""},{"def":"A complete sentence, from one full stop to another; esp.","pos":""}],"PERIODATE":[{"def":"A salt of periodic acid.","pos":""}],"PERIODIC":[{"def":"Pertaining to, derived from, or designating, the highest oxygen acid (HIO PERIODIC; PERIODICAL Pe`ri*od\"ic, Pe`ri*od\"ic*al, a.","pos":""},{"def":"Of or pertaining to a period; constituting a complete sentence.","pos":""}],"PERIODICAL":[{"def":"A magazine or other publication which appears at stated or regular intervals.","pos":""}],"PERIODICALIST":[{"def":"One who publishes, or writes for, a periodical.","pos":""}],"PERIODICALLY":[{"def":"In a periodical manner.","pos":""}],"PERIODICALNESS":[{"def":"Pe`ri*od\"ic*al*ness, n.","pos":""}],"PERIODICITY":[{"def":"The quality or state of being periodical, or regularly recurrent; as, the periodicity in the vital phenomena of plants.","pos":""}],"PERIODIDE":[{"def":"An iodide containing a higher proportion of iodine than any other iodide of the same substance or series.","pos":""}],"PERIODONTAL":[{"def":"Surrounding the teeth.","pos":""}],"PERIODOSCOPE":[{"def":"A table or other means for calculating the periodical functions of women.","pos":""},{"def":"Those who live on the same parallel of latitude but on opposite meridians, so that it is noon in one place when it is midnight in the other.","pos":""}],"PERIOPLE":[{"def":"The external smooth horny layer of the hoof of the horse and allied animals.","pos":""}],"PERIOPLIC":[{"def":"Of or pertaining to the periople; connected with the periople.","pos":""}],"PERIOSTEAL":[{"def":"Situated around bone; of or pertaining to the periosteum.","pos":""}],"PERIOSTEUM":[{"def":"The membrane of fibrous connective tissue which closely invests all bones except at the articular surfaces.","pos":""}],"PERIOSTITIS":[{"def":"Inflammation of the periosteum.","pos":""}],"PERIOSTRACUM":[{"def":"A chitinous membrane covering the exterior of many shells; -- called also epidermis.","pos":""}],"PERIOTIC":[{"def":"Surrounding, or pertaining to the region surrounding, the internal ear; as, the periotic capsule.","pos":""},{"def":"A periotic bone.","pos":""}]}