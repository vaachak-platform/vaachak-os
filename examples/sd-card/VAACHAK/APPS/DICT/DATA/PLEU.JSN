{"PLEURA":[{"def":"Same as Pleuron.","pos":""}],"PLEURAL":[{"def":"Of or pertaining to the pleura or pleuræ, or to the sides of the thorax.","pos":""}],"PLEURALGIA":[{"def":"Pain in the side or region of the ribs.","pos":""}],"PLEURAPOPHYSIS":[{"def":"One of the ventral processes of a vertebra, or the dorsal element in each half of a hemal arch, forming, or corresponding to, a vertebral rib.","pos":""}],"PLEURENCHYMA":[{"def":"A tissue consisting of long and slender tubular cells, of which wood is mainly composed.","pos":""}],"PLEURISY":[{"def":"An inflammation of the pleura, usually accompanied with fever, pain, difficult respiration, and cough, and with exudation into the pleural cavity.","pos":""}],"PLEURITE":[{"def":"Same as Pleuron.","pos":""}],"PLEURO-":[{"def":"A combining form denoting relation to a side; specif.","pos":""}],"PLEUROBRACHIA":[{"def":"A genus of ctenophores having an ovate body and two long plumose tentacles.","pos":""}],"PLEUROBRANCH":[{"def":"Any one of the gills of a crustacean that is attached to the side of the thorax.","pos":""}],"PLEUROBRANCHIA":[{"def":"Same as Pleurobranch.","pos":""}],"PLEUROCARP":[{"def":"Any pleurocarpic moss.","pos":""},{"def":"Side-fruited; -- said of those true mosses in which the pedicels or the capsules are from lateral archegonia; -- opposed to Ant: acrocarpous.","pos":""}],"PLEUROCENTRUM":[{"def":"One of the lateral elements in the centra of the vertebræ in some fossil batrachians.","pos":""}],"PLEURODERES":[{"def":"A group of fresh-water turtles in which the neck can not be retracted, but is bent to one side, for protection.","pos":""}],"PLEURODONT":[{"def":"Having the teeth consolidated with the inner edge of the jaw, as in some lizards.","pos":""}],"PLEURODYNIA":[{"def":"A painful affection of the side, simulating pleurisy, usually due to rheumatism.","pos":""}],"PLEURONECTOID":[{"def":"Pertaining to the Pleuronectidæ, or Flounder family.","pos":""}],"PLEUROPERICARDIAL":[{"def":"Of or pertaining to the pleura and pericardium.","pos":""}],"PLEUROPERIPNEUMONY":[{"def":"Pleuropneumonia.","pos":""}],"PLEUROPERITONEAL":[{"def":"Of or pertaining to the pleural and peritoneal membranes or cavities, or to the pleuroperitoneum.","pos":""}],"PLEUROPERITONEUM":[{"def":"The pleural and peritoneal membranes, or the membrane lining the body cavity and covering the surface of the inclosed viscera; the peritoneum; -- used especially in the case of those animals in which the body cavity is not divided.","pos":""}],"PLEUROPNEUMONIA":[{"def":"Inflammation of the pleura and lungs; a combination of pleurisy and pneumonia, esp.","pos":""}],"PLEUROPTERA":[{"def":"A group of Isectivora, including the colugo.","pos":""}],"PLEUROSIGMA":[{"def":"A genus of diatoms of elongated elliptical shape, but having the sides slightly curved in the form of a letter S.","pos":""}],"PLEUROSTEON":[{"def":"The antero-lateral piece which articulates the sternum of birds.","pos":""}],"PLEUROTHOTONUS":[{"def":"A species of tetanus, in which the body is curved laterally.","pos":""}],"PLEUROTOMA":[{"def":"Any marine gastropod belonging to Pleurotoma, and ether allied genera of the family Pleurotmidæ.","pos":""}]}