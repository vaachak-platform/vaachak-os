{"MARQUE":[{"def":"A license to pass the limits of a jurisdiction, or boundary of a country, for the purpose of making reprisals.","pos":""}],"MARQUEE":[{"def":"A large field tent; esp.","pos":""}],"MARQUETRY":[{"def":"Inlaid work; work inlaid with pieces of wood, shells, ivory, and the like, of several colors.","pos":""}],"MARQUIS":[{"def":"A nobleman in England, France, and Germany, of a rank next below that of duke.","pos":""}],"MARQUISATE":[{"def":"The seigniory, dignity, or lordship of a marquis; the territory governed by a marquis.","pos":""}],"MARQUISE":[{"def":"The wife of a marquis; a marchioness.","pos":""}]}