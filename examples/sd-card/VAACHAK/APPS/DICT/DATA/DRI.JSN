{"DRIB":[{"def":"To do by little and little; as: (a) To cut off by a little at a time; to crop.","pos":""}],"DRIBBER":[{"def":"One who dribs; one who shoots weakly or badly.","pos":""}],"DRIBBLE":[{"def":"To fall in drops or small drops, or in a quick succession of drops; as, water dribbles from the eaves.","pos":""},{"def":"To slaver, as a child or an idiot; to drivel.","pos":""}],"DRIBBLER":[{"def":"One who dribbles.","pos":""},{"def":"A small piece or part; a small sum; a small quantity of money in making up a sum; as, the money was paid in dribblets.","pos":""}],"DRIE":[{"def":"So causeless such drede for to drie.","pos":""}],"DRIER":[{"def":"Drying oil; a substance mingled with the oil used in oil painting to make it dry quickly.","pos":""}],"DRIFT":[{"def":"The horizontal thrust or pressure of an arch or vault upon the abutments.","pos":""},{"def":"A collection of loose earth and rocks, or boulders, which have been distributed over large portions of the earth's surface, especially in latitudes north of forty degrees, by the agency of ice.","pos":""}],"DRIFTAGE":[{"def":"Deviation from a ship's course due to leeway.","pos":""},{"def":"Anything that drifts.","pos":""}],"DRIFTBOLT":[{"def":"A bolt for driving out other bolts.","pos":""}],"DRIFTLESS":[{"def":"Having no drift or direction; without aim; purposeless.","pos":""}],"DRIFTPIECE":[{"def":"An upright or curved piece of timber connecting the plank sheer with the gunwale; also, a scroll terminating a rail.","pos":""}],"DRIFTWAY":[{"def":"Same as Drift, 11.","pos":""}],"DRIFTWEED":[{"def":"Seaweed drifted to the shore by the wind.","pos":""}],"DRIFTWIND":[{"def":"A driving wind; a wind that drives snow, sand, etc.","pos":""}],"DRIFTWOOD":[{"def":"Wood drifted or floated by water.","pos":""}],"DRIFTY":[{"def":"Full of drifts; tending to form drifts, as snow, and the like.","pos":""}],"DRILL":[{"def":"To pierce or bore with a drill, or a with a drill; to perforate; as, to drill a hole into a rock; to drill a piece of metal.","pos":""},{"def":"To train in the military art; to exercise diligently, as soldiers, in military evolutions and exercises; hence, to instruct thoroughly in the rudiments of any art or branch of knowledge; to discipline.","pos":""}],"DRILL PRESS":[{"def":"A machine for drilling holes in metal, the drill being pressed to the metal by the action of a screw.","pos":""}],"DRILLER":[{"def":"One who, or that which, drills.","pos":""}],"DRILLING":[{"def":"The act of piercing with a drill.","pos":""},{"def":"A training by repeated exercises.","pos":""}],"DRILLMASTER":[{"def":"One who teaches drill, especially in the way of gymnastics.","pos":""}],"DRILLSTOCK":[{"def":"A contrivance for holding and turning a drill.","pos":""}],"DRIMYS":[{"def":"A genus of magnoliaceous trees.","pos":""}],"DRINK":[{"def":"To swallow anything liquid, for quenching thirst or other purpose; to imbibe; to receive or partake of, as if in satisfaction of thirst; as, to drink from a spring.","pos":""},{"def":"To quaff exhilarating or intoxicating liquors, in merriment or feasting; to carouse; to revel; hence, to lake alcoholic liquors to excess; to be intemperate in the Pope.","pos":""}],"DRINKABLE":[{"def":"Capable of being drunk; suitable for drink; potable.","pos":""}],"DRINKABLENESS":[{"def":"State of being drinkable.","pos":""}],"DRINKER":[{"def":"One who drinks; as, the effects of tea on the drinker; also, one who drinks spirituous liquors to excess; a drunkard.","pos":""}],"DRINKING":[{"def":"The act of one who drinks; the act of imbibing.","pos":""},{"def":"The practice of partaking to excess of intoxicating liquors.","pos":""}],"DRINKLESS":[{"def":"Destitute of drink.","pos":""}],"DRIP":[{"def":"To fall in drops; as, water drips from the eaves.","pos":""},{"def":"To let fall drops of moisture or liquid; as, a wet garment drips.","pos":""}],"DRIPPING":[{"def":"A falling in drops, or the sound so made.","pos":""},{"def":"That which falls in drops, as fat from meat in roasting.","pos":""}],"DRIPSTONE":[{"def":"A drip, when made of stone.","pos":""}],"DRIVE":[{"def":"To dig Horizontally; to cut a horizontal gallery or tunnel.","pos":""}],"DRIVEBOLT":[{"def":"A drift; a tool for setting bolts home.","pos":""}],"DRIVEL":[{"def":"To be weak or foolish; to dote; as, a driveling hero; driveling love.","pos":""}],"DRIVELER":[{"def":"A slaverer; a slabberer; an idiot; a fool.","pos":""}],"DRIVEPIPE":[{"def":"A pipe for forcing into the earth.","pos":""}],"DRIVER":[{"def":"A part that transmits motion to another part by contact with it, or through an intermediate relatively movable part, as a gear which drives another, or a lever which moves another through a link, etc.","pos":""},{"def":"The after sail in a ship or bark, being a fore-and-aft sail attached to a gaff; a spanker.","pos":""}],"DRIVEWAY":[{"def":"A passage or way along or through which a carriage may be driven.","pos":""}],"DRIVING":[{"def":"Having great force of impulse; as, a driving wind or storm.","pos":""},{"def":"Communicating force; impelling; as, a driving shaft.","pos":""}],"DRIZZLE":[{"def":"To rain slightly in very small drops; to fall, as water from the clouds, slowly and in fine particles; as, it drizzles; drizzling drops or rain.","pos":""}],"DRIZZLY":[{"def":"Characterized by small rain, or snow; moist and disagreeable.","pos":""}]}