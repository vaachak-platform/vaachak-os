{"INSCIENCE":[{"def":"Want of knowledge; ignorance.","pos":""}],"INSCIENT":[{"def":"Having little or no knowledge; ignorant; stupid; silly.","pos":""}],"INSCRIBABLE":[{"def":"Capable of being inscribed, -- used specif.","pos":""}],"INSCRIBABLENESS":[{"def":"Quality of being inscribable.","pos":""}],"INSCRIBE":[{"def":"To draw within so as to meet yet not cut the boundaries.","pos":""}],"INSCRIBER":[{"def":"One who inscribes.","pos":""}],"INSCRIPTIBLE":[{"def":"Capable of being inscribed; inscribable.","pos":""}],"INSCRIPTION":[{"def":"A line of division or intersection; as, the tendinous inscriptions, or intersections, of a muscle.","pos":""}],"INSCRIPTIVE":[{"def":"Bearing inscription; of the character or nature of an inscription.","pos":""}],"INSCROLL":[{"def":"To write on a scroll; to record.","pos":""}],"INSCRUTABILITY":[{"def":"The quality or state of being inscrutable; inscrutableness.","pos":""}],"INSCRUTABLE":[{"def":"Unsearchable; incapable of being searched into and understood by inquiry or study; impossible or difficult to be explained or accounted for satisfactorily; obscure; incomprehensible; as, an inscrutable design or event.","pos":""}],"INSCRUTABLENESS":[{"def":"The quality or state of being inscrutable; inscrutability.","pos":""}],"INSCRUTABLY":[{"def":"In an inscrutable manner.","pos":""}],"INSCULP":[{"def":"To engrave; to carve; to sculpture.","pos":""}],"INSCULPTURE":[{"def":"An engraving, carving, or inscription.","pos":""}]}