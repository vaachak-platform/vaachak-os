{"FLABBERGAST":[{"def":"To astonish; to strike with wonder, esp.","pos":""}],"FLABBERGASTATION":[{"def":"The state of being flabbergasted.","pos":""}],"FLABBILY":[{"def":"In a flabby manner.","pos":""}],"FLABBINESS":[{"def":"Quality or state of being flabby.","pos":""}],"FLABBY":[{"def":"Yielding to the touch, and easily moved or shaken; hanging loose by its own weight; wanting firmness; flaccid; as, flabby flesh.","pos":""}],"FLABELLATION":[{"def":"The act of keeping fractured limbs cool by the use of a fan or some other contrivance.","pos":""}],"FLABELLIFORM":[{"def":"Having the form of a fan; fan-shaped; flabellate.","pos":""}],"FLABELLINERVED":[{"def":"Having many nerves diverging radiately from the base; -- said of a leaf.","pos":""}],"FLABELLUM":[{"def":"A fan; especially, the fan carried before the pope on state occasions, made in ostrich and peacock feathers.","pos":""}],"FLABILE":[{"def":"Liable to be blown about.","pos":""}]}