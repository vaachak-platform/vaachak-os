{"ZYGANTRUM":[{"def":"See under Zygosphene.","pos":""}],"ZYGAPOPHYSIS":[{"def":"One of the articular processes of a vertebra, of which there are usually four, two anterior and two posterior.","pos":""}],"ZYGENID":[{"def":"Any one of numerous species of moths of the family Zygænidæ, most of which are bright colored.","pos":""}],"ZYGOBRANCHIA":[{"def":"A division of marine gastropods in which the gills are developed on both sides of the body and the renal organs are also paired.","pos":""}],"ZYGOBRANCHIATE":[{"def":"Of or pertaining to the Zygobranchia.","pos":""},{"def":"Any zygodactylous bird.","pos":""}],"ZYGODACTYLAE":[{"def":"The zygodactylous birds.","pos":""}],"ZYGODACTYLI":[{"def":"Same as Scansores.","pos":""},{"def":"Yoke-footed; having the toes disposed in pairs; -- applied to birds which have two toes before and two behind, as the parrot, cuckoo, woodpecker, etc.","pos":""}],"ZYGOMATIC":[{"def":"Of, pertaining to, or in the region of, the zygoma.","pos":""},{"def":"Symmetrical bilaterally; -- said of organisms, or parts of organisms, capable of division into two symmetrical halves only in a single plane.","pos":""}],"ZYGOPHYTE":[{"def":"Any plant of a proposed class or grand division (Zygophytes, Zygophyta, or Zygosporeæ), in which reproduction consists in the union of two similar cells.","pos":""}],"ZYGOSIS":[{"def":"Same as Conjugation.","pos":""}],"ZYGOSPERM":[{"def":"A spore formed by the union of the contents of two similar cells, either of the same or of distinct individual plants.","pos":""}],"ZYGOSPHENE":[{"def":"A median process on the front part of the neural arch of the vertebræ of most snakes and some lizards, which fits into a fossa, called the zygantrum, on the back part of the arch in front.","pos":""}],"ZYMASE":[{"def":"A soluble ferment, or enzyme.","pos":""}],"ZYME":[{"def":"The morbific principle of a zymotic disease.","pos":""}],"ZYMIC":[{"def":"Pertaining to, or produced by, fermentation; -- formerly, by confusion, used to designate lactic acid.","pos":""}],"ZYMOGEN":[{"def":"A mother substance, or antecedent, of an enzyme or chemical ferment; -- applied to such substances as, not being themselves actual ferments, may by internal changes give rise to a ferment.","pos":""}],"ZYMOGENE":[{"def":"One of a physiological group of globular bacteria which produces fermentations of diverse nature; -- distinguished from pathogene.","pos":""}],"ZYMOGENIC":[{"def":"Of or pertaining to zymology.","pos":""}],"ZYMOLOGIST":[{"def":"One who is skilled in zymology, or in the fermentation of liquors.","pos":""}],"ZYMOLOGY":[{"def":"A treatise on the fermentation of liquors, or the doctrine of fermentation.","pos":""}],"ZYMOLYSIS":[{"def":"The action of enzymes; also, the changes produced by such action.","pos":""}],"ZYMOME":[{"def":"A glutinous substance, insoluble in alcohol, resembling legumin; -- now called vegetable fibrin, vegetable albumin, or gluten casein.","pos":""},{"def":"An instrument for ascertaining the degree of fermentation occasioned by the mixture of different liquids, and the degree of heat which they acquire in fermentation.","pos":""}],"ZYMOPHYTE":[{"def":"A bacteroid ferment.","pos":""}],"ZYMOTIC":[{"def":"Designating, or pertaining to, a certain class of diseases.","pos":""}],"ZYTHUM":[{"def":"A kind of ancient malt beverage; a liquor made from malt and wheat.","pos":""}]}