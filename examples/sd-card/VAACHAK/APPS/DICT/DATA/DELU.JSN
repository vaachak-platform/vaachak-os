{"DELUDABLE":[{"def":"Capable of being deluded; liable to be imposed on gullible.","pos":""}],"DELUDE":[{"def":"To lead from truth or into error; to mislead the mind or judgment of to beguile; to impose on; to dupe; to make a fool of.","pos":""},{"def":"To frustrate or disappoint.","pos":""}],"DELUDER":[{"def":"One who deludes; a deceiver; an impostor.","pos":""}],"DELUGE":[{"def":"A washing away; an overflowing of the land by water; an inundation; a flood; specifically, The Deluge, the great flood in the days of Noah (Gen.","pos":""}],"DELUNDUNG":[{"def":"An East Indian carnivorous mammal (Prionodon gracilis), resembling the civets, but without scent pouches.","pos":""}],"DELUSION":[{"def":"The act of deluding; deception; a misleading of the mind.","pos":""},{"def":"The state of being deluded or misled.","pos":""}],"DELUSIONAL":[{"def":"Of or pertaining to delusions; as, delusional monomania.","pos":""}],"DELUSIVE":[{"def":"Apt or fitted to delude; tending to mislead the mind; deceptive; beguiling; delusory; as, delusive arts; a delusive dream.","pos":""}],"DELUSORY":[{"def":"Delusive; fallacious.","pos":""}]}