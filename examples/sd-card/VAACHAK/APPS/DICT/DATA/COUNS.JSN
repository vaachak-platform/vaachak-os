{"COUNSEL":[{"def":"Interchange of opinions; mutual advising; consultation.","pos":""},{"def":"Examination of consequences; exercise of deliberate judgment; prudence.","pos":""}],"COUNSELABLE":[{"def":"Willing to receive counsel or follow advice.","pos":""},{"def":"Suitable to be advised; advisable, wise.","pos":""}],"COUNSELOR":[{"def":"One who counsels; an adviser.","pos":""},{"def":"A member of council; one appointed to advise a sovereign or chief magistrate.","pos":""}],"COUNSELORSHIP":[{"def":"The function and rank or office of a counselor.","pos":""}]}