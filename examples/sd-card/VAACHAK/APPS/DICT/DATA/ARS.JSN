{"ARSE":[{"def":"The buttocks, or hind part of an animal; the posteriors; the fundament; the bottom.","pos":""}],"ARSENAL":[{"def":"A public establishment for the storage, or for the manufacture and storage, of arms and all military equipments, whether for land or naval service.","pos":""}],"ARSENATE":[{"def":"A salt of arsenic acid.","pos":""}],"ARSENIC":[{"def":"One of the elements, a solid substance resembling a metal in its physical properties, but in its chemical relations ranking with the nonmetals.","pos":""},{"def":"Arsenious oxide or arsenious anhydride; -- called also arsenious acid, white arsenic, and ratsbane.","pos":""}],"ARSENICAL":[{"def":"Of or pertaining to, or containing, arsenic; as, arsenical vapor; arsenical wall papers.","pos":""}],"ARSENICATE":[{"def":"To combine with arsenic; to treat or impregnate with arsenic.","pos":""}],"ARSENICISM":[{"def":"A diseased condition produced by slow poisoning with arsenic.","pos":""}],"ARSENIDE":[{"def":"A compound of arsenic with a metal, or positive element or radical; -- formerly called arseniuret.","pos":""}],"ARSENIFEROUS":[{"def":"Containing or producing arsenic.","pos":""}],"ARSENIOUS":[{"def":"Pertaining to, or derived from, arsenic, when having an equivalence next lower than the highest; as, arsenious acid.","pos":""}],"ARSENITE":[{"def":"A salt formed by the union of arsenious acid with a base.","pos":""}],"ARSENIURETED":[{"def":"Combined with arsenic; -- said some elementary substances or radicals; as, arseniureted hydrogen.","pos":""}],"ARSENOPYRITE":[{"def":"A mineral of a tin-white color and metallic luster, containing arsenic, sulphur, and iron; -- also called arsenical pyrites and mispickel.","pos":""}],"ARSESMART":[{"def":"Smartweed; water pepper.","pos":""}],"ARSHINE":[{"def":"A Russian measure of length = 2 ft.","pos":""}],"ARSINE":[{"def":"A compound of arsenic and hydrogen, AsH3, a colorless and exceedingly poisonous gas, having and odor like garlic; arseniureted hydrogen.","pos":""}],"ARSIS":[{"def":"The elevation of the hand, or that part of the bar at which it is raised, in beating time; the weak or unaccented part of the bar; - - opposed to thesis.","pos":""}],"ARSON":[{"def":"The malicious burning of a dwelling house or outhouse of another man, which by the common law is felony; the malicious and voluntary firing of a building or ship.","pos":""}]}