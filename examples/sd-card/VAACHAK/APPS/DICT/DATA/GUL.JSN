{"GULA":[{"def":"A capping molding.","pos":""}],"GULAR":[{"def":"Pertaining to the gula or throat; as, gular plates.","pos":""}],"GULAUND":[{"def":"An arctic sea bird.","pos":""}],"GULCH":[{"def":"Act of gulching or gulping.","pos":""}],"GULE":[{"def":"To give the color of gules to.","pos":""}],"GULES":[{"def":"The tincture red, indicated in seals and engraved figures of escutcheons by parallel vertical lines.","pos":""}],"GULF":[{"def":"A portion of an ocean or sea extending into the land; a partially land-locked sea; as, the Gulf of Mexico.","pos":""},{"def":"A large deposit of ore in a lode.","pos":""}],"GULFY":[{"def":"Full of whirlpools or gulfs.","pos":""}],"GULGUL":[{"def":"A cement made in India from sea shells, pulverized and mixed with oil, and spread over a ship's bottom, to prevent the boring of worms.","pos":""}],"GULL":[{"def":"To deceive; to cheat; to mislead; to trick; to defraud.","pos":""}],"GULLAGE":[{"def":"Act of being gulled.","pos":""}],"GULLER":[{"def":"One who gulls; a deceiver.","pos":""}],"GULLERY":[{"def":"An act, or the practice, of gulling; trickery; fraud.","pos":""}],"GULLET":[{"def":"The tube by which food and drink are carried from the pharynx to the stomach; the esophagus.","pos":""}],"GULLETING":[{"def":"A system of excavating by means of gullets or channels.","pos":""}],"GULLIBLE":[{"def":"Easily gulled; that may be duped.","pos":""}],"GULLISH":[{"def":"Foolish; stupid.","pos":""}],"GULLY":[{"def":"A channel or hollow worn in the earth by a current of water; a short deep portion of a torrent's bed when dry.","pos":""},{"def":"A grooved iron rail or tram plate.","pos":""}],"GULOSITY":[{"def":"Excessive appetite; greediness; voracity.","pos":""}],"GULP":[{"def":"To swallow eagerly, or in large draughts; to swallow up; to take down at one swallow.","pos":""}],"GULY":[{"def":"Of or pertaining to gules; red.","pos":""}]}