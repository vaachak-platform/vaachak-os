{"OGDOAD":[{"def":"A thing made up of eight parts.","pos":""}],"OGDOASTICH":[{"def":"A poem of eight lines.","pos":""}],"OGEE":[{"def":"A molding, the section of which is the form of the letter S, with the convex part above; cyma reversa.","pos":""}],"OGGANITION":[{"def":"Snarling; grumbling.","pos":""}],"OGHAM":[{"def":"A particular kind of writing practiced by the ancient Irish, and found in inscriptions on stones, metals, etc.","pos":""}],"OGIVE":[{"def":"The arch or rib which crosses a Gothic vault diagonally.","pos":""}],"OGLE":[{"def":"To view or look at with side glances, as in fondness, or with a design to attract notice.","pos":""}],"OGRE":[{"def":"An imaginary monster, or hideous giant of fairy tales, who lived on human beings; hence, any frightful giant; a cruel monster.","pos":""}],"OGREISH":[{"def":"Resembling an ogre; having the character or appearance of an ogre; suitable for an ogre.","pos":""}],"OGRESS":[{"def":"The character or manners of an ogre.","pos":""}],"OGYGIAN":[{"def":"Of or pertaining to Ogyges, a mythical king of ancient Attica, or to a great deluge in Attica in his days; hence, primeval; of obscure antiquity.","pos":""}]}