{"MYDALEINE":[{"def":"A toxic alkaloid (ptomaine) obtained from putrid flesh and from herring brines.","pos":""}],"MYDATOXIN":[{"def":"A poisonous amido acid, C6H13NO2, separated by Brieger from decaying horseflesh.","pos":""}],"MYDRIASIS":[{"def":"A long-continued or excessive dilatation of the pupil of the eye.","pos":""}],"MYDRIATIC":[{"def":"Causing dilatation of the pupil.","pos":""},{"def":"A mydriatic medicine or agent, as belladonna.","pos":""}]}