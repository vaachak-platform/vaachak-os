{"ADACT":[{"def":"To compel; to drive.","pos":""}],"ADAGE":[{"def":"An old saying, which has obtained credit by long use; a proverb.","pos":""}],"ADAGIAL":[{"def":"Pertaining to an adage; proverbial.","pos":""}],"ADAGIO":[{"def":"Slow; slowly, leisurely, and gracefully.","pos":""}],"ADAM":[{"def":"\"Original sin;\" human frailty.","pos":""}],"ADAMANT":[{"def":"A stone imagined by some to be of impenetrable hardness; a name given to the diamond and other substance of extreme hardness; but in modern minerology it has no technical signification.","pos":""},{"def":"Lodestone; magnet.","pos":""}],"ADAMANTEAN":[{"def":"Of adamant; hard as adamant.","pos":""}],"ADAMANTINE":[{"def":"Like the diamond in hardness or luster.","pos":""}],"ADAMBULACRAL":[{"def":"Next to the ambulacra; as, the adambulacral ossicles of the starfish.","pos":""},{"def":"Of or pertaining to Adam, or resembling him.","pos":""}],"ADAMITE":[{"def":"One of a sect of visionaries, who, professing to imitate the state of Adam, discarded the use of dress in their assemblies.","pos":""}],"ADANSONIA":[{"def":"A genus of great trees related to the Bombax.","pos":""}],"ADAPT":[{"def":"To make suitable; to fit, or suit; to adjust; to alter so as to fit for a new use; -- sometimes followed by to or for.","pos":""},{"def":"The quality of being adaptable; suitableness.","pos":""}],"ADAPTABLE":[{"def":"Capable of being adapted.","pos":""}],"ADAPTATION":[{"def":"The act or process of adapting, or fitting; or the state of being adapted or fitted; fitness.","pos":""},{"def":"The result of adapting; an adapted form.","pos":""}],"ADAPTEDNESS":[{"def":"The state or quality of being adapted; suitableness; special fitness.","pos":""}],"ADAPTER":[{"def":"A connecting tube; an adopter.","pos":""}],"ADAPTIVE":[{"def":"Suited, given, or tending, to adaptation; characterized by adaptation; capable of adapting.","pos":""}],"ADAPTIVENESS":[{"def":"The quality of being adaptive; capacity to adapt.","pos":""}],"ADAPTLY":[{"def":"In a suitable manner.","pos":""}],"ADAR":[{"def":"The twelfth month of the Hebrew ecclesiastical year, and the sixth of the civil.","pos":""}],"ADARCE":[{"def":"A saltish concretion on reeds and grass in marshy grounds in Galatia.","pos":""}],"ADATIS":[{"def":"A fine cotton cloth of India.","pos":""}],"ADAUNT":[{"def":"To daunt; to subdue; to mitigate.","pos":""}],"ADAW":[{"def":"To subdue; to daunt.","pos":""}],"ADAYS":[{"def":"By day, or every day; in the daytime.","pos":""}]}