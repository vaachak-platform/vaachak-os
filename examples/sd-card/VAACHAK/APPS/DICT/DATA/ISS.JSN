{"ISSUABLE":[{"def":"Leading to, producing, or relating to, an issue; capable of being made an issue at law.","pos":""},{"def":"Lawful or suitable to be issued; as, a writ issuable on these grounds.","pos":""}],"ISSUABLY":[{"def":"In an issuable manner; by way of issue; as, to plead issuably.","pos":""}],"ISSUANCE":[{"def":"The act of issuing, or giving out; as, the issuance of an order; the issuance of rations, and the like.","pos":""}],"ISSUANT":[{"def":"Issuing or coming up; -- a term used to express a charge or bearing rising or coming out of another.","pos":""}],"ISSUE":[{"def":"An artificial ulcer, usually made in the fleshy part of the arm or leg, to produce the secretion and discharge of pus for the relief of some affected part.","pos":""},{"def":"In pleading, a single material point of law or fact depending in the suit, which, being affirmed on the one side and denied on the other, is presented for determination.","pos":""}],"ISSUELESS":[{"def":"Having no issue or progeny; childless.","pos":""}],"ISSUER":[{"def":"One who issues, emits, or publishes.","pos":""},{"def":"A noun suffix denoting an agent, or doer, one who practices, a believer in; as, theorist, one who theorizes; socialist, one who holds to socialism; sensualist, one given to sensuality.","pos":""}]}