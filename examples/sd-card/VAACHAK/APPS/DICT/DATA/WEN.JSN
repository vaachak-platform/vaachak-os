{"WEN":[{"def":"An indolent, encysted tumor of the skin; especially, a sebaceous cyst.","pos":""}],"WEN-LI":[{"def":"The higher literary idiom of Chinese, that of the canonical books and of all composition pretending to literary standing.","pos":""}],"WENCH":[{"def":"A young woman; a girl; a maiden.","pos":""},{"def":"A low, vicious young woman; a drab; a strumpet.","pos":""}],"WENCHER":[{"def":"One who wenches; a lewd man.","pos":""}],"WENCHLESS":[{"def":"Being without a wench.","pos":""}],"WEND":[{"def":"To go; to pass; to betake one's self.","pos":""}],"WENDE":[{"def":"Of or pertaining the Wends, or their language.","pos":""}],"WENDIC":[{"def":"The language of the Wends.","pos":""}],"WENDS":[{"def":"A Slavic tribe which once occupied the northern and eastern parts of Germany, of which a small remnant exists.","pos":""}],"WENLOCK GROUP":[{"def":"The middle subdivision of the Upper Silurian in Great Britain; -- so named from the typical locality in Shropshire.","pos":""}],"WENNEL":[{"def":"Having the nature of a wen; resembling a wen; as, a wennish excrescence.","pos":""}],"WENONA":[{"def":"A sand snake (Charina plumbea) of Western North America, of the family Erycidæ.","pos":""}],"WENT":[{"def":"To the church both be they went.","pos":""}],"WENTLETRAP":[{"def":"Any one of numerous species of elegant, usually white, marine shells of the genus Scalaria, especially Scalaria pretiosa, which was formerly highly valued; -- called also staircase shell.","pos":""}]}