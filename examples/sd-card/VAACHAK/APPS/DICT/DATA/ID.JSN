{"ID":[{"def":"A small fresh-water cyprinoid fish (Leuciscus idus or Idus idus) of Europe.","pos":""}],"IDALIAN":[{"def":"Of or pertaining to Idalium, a mountain city in Cyprus, or to Venus, to whom it was sacred.","pos":""}],"IDE":[{"def":"A suffix used to denote: (a) The nonmetallic, or negative, element or radical in a binary compound; as, oxide, sulphide, chloride.","pos":""}],"IDEA":[{"def":"The transcript, image, or picture of a visible object, that is formed by the mind; also, a similar image of any object whatever, whether sensible or spiritual.","pos":""},{"def":"A general notion, or a conception formed by generalization.","pos":""}],"IDEAL":[{"def":"Existing in idea or thought; conceptional; intellectual; mental; as, ideal knowledge.","pos":""},{"def":"Reaching an imaginary standard of excellence; fit for a model; faultless; as, ideal beauty.","pos":""}],"IDEALESS":[{"def":"Destitute of an idea.","pos":""}],"IDEALISM":[{"def":"The system or theory that denies the existence of material bodies, and teaches that we have no rational grounds to believe in the reality of anything but ideas and their relations.","pos":""}],"IDEALIST":[{"def":"One who idealizes; one who forms picturesque fancies; one given to romantic expectations.","pos":""},{"def":"One who holds the doctrine of idealism.","pos":""}],"IDEALISTIC":[{"def":"Of or pertaining to idealists or their theories.","pos":""}],"IDEALITY":[{"def":"The conceptive faculty.","pos":""}],"IDEALIZATION":[{"def":"The representation of natural objects, scenes, etc.","pos":""}],"IDEALIZE":[{"def":"To treat in an ideal manner.","pos":""}],"IDEALLY":[{"def":"In an ideal manner; by means of ideals; mentally.","pos":""}],"IDEALOGIC":[{"def":"Of or pertaining to an idealogue, or to idealization.","pos":""}],"IDEALOGUE":[{"def":"One given to fanciful ideas or theories; a theorist; a spectator.","pos":""},{"def":"The actual existence supposed to correspond with an idea; the correlate in real existence to the idea as a thought or existence.","pos":""}],"IDEATE":[{"def":"To form in idea; to fancy.","pos":""},{"def":"To apprehend in thought so as to fix and hold in the mind; to memorize.","pos":""}],"IDEATION":[{"def":"The faculty or capacity of the mind for forming ideas; the exercise of this capacity; the act of the mind by which objects of sense are apprehended and retained as objects of thought.","pos":""}],"IDEATIONAL":[{"def":"Pertaining to, or characterized by, ideation.","pos":""}],"IDEM":[{"def":"The same; the same as above; -- often abbreviated id.","pos":""}],"IDENTICAL":[{"def":"The same; the selfsame; the very same; not different; as, the identical person or thing.","pos":""},{"def":"Uttering sameness or the same truth; expressing in the predicate what is given, or obviously implied, in the subject; tautological.","pos":""}],"IDENTICALLY":[{"def":"In an identical manner; with respect to identity.","pos":""}],"IDENTICALNESS":[{"def":"The quality or state of being identical; sameness.","pos":""}],"IDENTIFIABLE":[{"def":"Capable of being identified.","pos":""}],"IDENTIFICATION":[{"def":"The act of identifying, or proving to be the same; also, the state of being identified.","pos":""}],"IDENTIFY":[{"def":"To make to be the same; to unite or combine in such a manner as to make one; to treat as being one or having the same purpose or effect; to consider as the same in any relation.","pos":""},{"def":"To establish the identity of; to prove to be the same with something described, claimed, or asserted; as, to identify stolen property.","pos":""}],"IDENTISM":[{"def":"The doctrine taught by Schelling, that matter and mind, and subject and object, are identical in the Absolute; -- called also the system or doctrine of identity.","pos":""}],"IDENTITY":[{"def":"An identical equation.","pos":""}],"IDEO-MOTION":[{"def":"An ideo-motor movement.","pos":""}],"IDEO-MOTOR":[{"def":"Applied to those actions, or muscular movements, which are automatic expressions of dominant ideas, rather than the result of distinct volitional efforts, as the act of expressing the thoughts in speech, or in writing, while the mind is occupied in the composition of the sentence.","pos":""}],"IDEOGENICAL":[{"def":"Of or relating to ideology.","pos":""}],"IDEOGENY":[{"def":"The science which treats of the origin of ideas.","pos":""}],"IDEOGRAM":[{"def":"An original, pictorial element of writing; a kind of hieroglyph expressing no sound, but only an idea.","pos":""},{"def":"A symbol used for convenience, or for abbreviation; as, 1, 2, 3, +, -, 3.","pos":""}],"IDEOGRAPH":[{"def":"Same as Ideogram.","pos":""},{"def":"Of or pertaining to an ideogram; representing ideas by symbols, independently of sounds; as, 9 represents not the word \"nine,\" but the idea of the number itself.","pos":""}],"IDEOGRAPHICS":[{"def":"The system of writing in ideographic characters; also, anything so written.","pos":""}],"IDEOGRAPHY":[{"def":"The representation of ideas independently of sounds, or in an ideographic manner, as sometimes is done in shorthand writing, etc.","pos":""}],"IDEOLOGICAL":[{"def":"Of or pertaining to ideology.","pos":""}],"IDEOLOGIST":[{"def":"One who treats of ideas; one who theorizes or idealizes; one versed in the science of ideas, or who advocates the doctrines of ideology.","pos":""}],"IDEOLOGY":[{"def":"A theory of the origin of ideas which derives them exclusively from sensation.","pos":""}],"IDES":[{"def":"The fifteenth day of March, May, July, and October, and the thirteenth day of the other months.","pos":""}],"IDIOBLAST":[{"def":"An individual cell, differing greatly from its neighbours in regard to size, structure, or contents.","pos":""}],"IDIOCRASY":[{"def":"Peculiarity of constitution; that temperament, or state of constitution, which is peculiar to a person; idiosyncrasy.","pos":""},{"def":"Peculiar in constitution or temperament; idiosyncratic.","pos":""}],"IDIOCY":[{"def":"The condition or quality of being an idiot; absence, or marked deficiency, of sense and intelligence.","pos":""}],"IDIOCYCLOPHANOUS":[{"def":"Same as Idiophanous.","pos":""}],"IDIOELECTRIC":[{"def":"Electric by virtue of its own peculiar properties; capable of becoming electrified by friction; -- opposed to anelectric.","pos":""},{"def":"An idioelectric substance.","pos":""}],"IDIOGRAPH":[{"def":"A mark or signature peculiar to an individual; a trade-mark.","pos":""},{"def":"Of or pertaining to an idiograph.","pos":""}],"IDIOLATRY":[{"def":"Self-worship; excessive self-esteem.","pos":""}],"IDIOM":[{"def":"Of or pertaining to, or conforming to, the mode of expression peculiar to a language; as, an idiomatic meaning; an idiomatic phrase.","pos":""}],"IDIOMORPHOUS":[{"def":"Apperaing in distinct crystals; -- said of the mineral constituents of a rock.","pos":""}],"IDIOMUSCULAR":[{"def":"Applied to a semipermanent contraction of a muscle, produced by a mechanical irritant.","pos":""}],"IDIOPATHETIC":[{"def":"Pertaining to idiopathy; characterizing a disease arising primarily, and not in consequence of some other disease or injury; -- opposed to symptomatic, sympathetic, and traumatic.","pos":""}],"IDIOPATHY":[{"def":"A morbid state or condition not preceded or occasioned by any other disease; a primary disease.","pos":""}],"IDIOPHANOUS":[{"def":"Exhibiting interference figures without the aid of a polariscope, as certain crystals.","pos":""}],"IDIOPLASM":[{"def":"Same as Idioplasma.","pos":""}],"IDIOPLASMA":[{"def":"That portion of the cell protoplasm which is the seat of all active changes, and which carries on the function of hereditary transmission; -- distinguished from the other portion, which is termed nutritive plasma.","pos":""}],"IDIOREPULSIVE":[{"def":"Repulsive by itself; as, the idiorepulsive power of heat.","pos":""}],"IDIOSYNCRASY":[{"def":"A peculiarity of physical or mental constitution or temperament; a characteristic belonging to, and distinguishing, an individual; characteristic susceptibility; idiocrasy; eccentricity.","pos":""},{"def":"Of peculiar temper or disposition; belonging to one's peculiar and individual character.","pos":""}],"IDIOT":[{"def":"A man in private station, as distinguished from one holding a public office.","pos":""},{"def":"An unlearned, ignorant, or simple person, as distinguished from the educated; an ignoramus.","pos":""}],"IDIOTED":[{"def":"Rendered idiotic; befooled.","pos":""}],"IDIOTHERMIC":[{"def":"Self-heating; warmed, as the body of animal, by process going on within itself.","pos":""}],"IDIOTICALLY":[{"def":"In a idiotic manner.","pos":""}],"IDIOTICON":[{"def":"A dictionary of a peculiar dialect, or of the words and phrases peculiar to one part of a country; a glossary.","pos":""}],"IDIOTISH":[{"def":"Like an idiot; foolish.","pos":""}],"IDIOTISM":[{"def":"An idiom; a form, mode of expression, or signification, peculiar to a language.","pos":""},{"def":"Lack of knowledge or mental capacity; idiocy; foolishness.","pos":""}],"IDIOTIZE":[{"def":"To become stupid.","pos":""}],"IDLE":[{"def":"Of no account; useless; vain; trifling; unprofitable; thoughtless; silly; barren.","pos":""},{"def":"Not called into active service; not turned to appropriate use; unemployed; as, idle hours.","pos":""}],"IDLE-HEADED":[{"def":"Foolish; stupid.","pos":""},{"def":"Delirious; infatuated.","pos":""}],"IDLE-PATED":[{"def":"Idle-headed; stupid.","pos":""}],"IDLENESS":[{"def":"The condition or quality of being idle (in the various senses of that word); uselessness; fruitlessness; triviality; inactivity; laziness.","pos":""}],"IDLER":[{"def":"One who has constant day duties on board ship, and keeps no regular watch.","pos":""},{"def":"An idle wheel or pulley.","pos":""}],"IDLY":[{"def":"In a idle manner; ineffectually; vainly; lazily; carelessly; (Obs.","pos":""}],"IDO":[{"def":"An artificial international language, selected by the \"Delegation for the Adoption of an Auxillary International Language\" (founded at Paris in 1901), made public in 1907, and subsequently greatly revised and extended by a permanent committee or \"Academy.","pos":""}],"IDOCRASE":[{"def":"Same as Vesuvianite.","pos":""}],"IDOL":[{"def":"An image or representation of anything.","pos":""},{"def":"An image of a divinity; a representation or symbol of a deity or any other being or thing, made or used as an object of worship; a similitude of a false god.","pos":""}],"IDOLATER":[{"def":"A worshiper of idols; one who pays divine honors to images, statues, or representations of anything made by hands; one who worships as a deity that which is not God; a pagan.","pos":""},{"def":"An adorer; a great admirer.","pos":""}],"IDOLATRESS":[{"def":"A female worshiper of idols.","pos":""}],"IDOLATRIZE":[{"def":"To worship idols; to pay idolatrous worship.","pos":""}],"IDOLATROUS":[{"def":"Of or pertaining to idolatry; partaking of the nature of idolatry; given to idolatry or the worship of false gods; as, idolatrous sacrifices.","pos":""},{"def":"Consisting in, or partaking of, an excessive attachment or reverence; as, an idolatrous veneration for antiquity.","pos":""}],"IDOLATROUSLY":[{"def":"In a idolatrous manner.","pos":""}],"IDOLATRY":[{"def":"The worship of idols, images, or anything which is not God; the worship of false gods.","pos":""},{"def":"Excessive attachment or veneration for anything; respect or love which borders on adoration.","pos":""}],"IDOLISM":[{"def":"The worship of idols.","pos":""}],"IDOLIST":[{"def":"A worshiper of idols.","pos":""}],"IDOLIZE":[{"def":"To make an idol of; to pay idolatrous worship to; as, to idolize the sacred bull in Egypt.","pos":""},{"def":"To love to excess; to love or reverence to adoration; as, to idolize gold, children, a hero.","pos":""}],"IDOLIZER":[{"def":"One who idolizes or loves to the point of reverence; an idolater.","pos":""}],"IDOLOCLAST":[{"def":"A breaker of idols; an iconoclast.","pos":""}],"IDOLOGRAPHICAL":[{"def":"Descriptive of idols.","pos":""}],"IDOLOUS":[{"def":"Appearance or image; a phantasm; a spectral image; also, a mental image or idea.","pos":""}],"IDONEOUS":[{"def":"Appropriate; suitable; proper; fit; adequate.","pos":""}],"IDORGAN":[{"def":"A morphological unit, consisting of two or more plastids, which does not possess the positive character of the person or stock, in distinction from the physiological organ or biorgan.","pos":""},{"def":"A bituminous substance obtained from the mercury mines of Idria, where it occurs mixed with cinnabar.","pos":""}],"IDUMEAN":[{"def":"Of or pertaining to ancient Idumea, or Edom, in Western Asia.","pos":""},{"def":"An inhabitant of Idumea, an Edomite.","pos":""}],"IDYL":[{"def":"Wordsworth's solemn-thoughted idyl.","pos":""}],"IDYLLIC":[{"def":"Of or belonging to idyls.","pos":""},{"def":"Abbreviation of Latin id est, that is.","pos":""}]}