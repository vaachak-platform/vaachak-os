{"THEOBROMA":[{"def":"A genus of small trees.","pos":""}],"THEOBROMIC":[{"def":"Of, pertaining to, or designating, an acid extracted from cacao butter (from the Theobroma Cacao), peanut oil (from Arachis hypogæa), etc.","pos":""}],"THEOBROMINE":[{"def":"An alkaloidal ureide, C7H8N4O2, homologous with and resembling caffeine, produced artificially, and also extracted from cacao and chocolate (from Theobroma Cacao) as a bitter white crystalline substance; -- called also dimethyl xanthine.","pos":""}],"THEOCHRISTIC":[{"def":"Anointed by God.","pos":""}],"THEOCRACY":[{"def":"Government of a state by the immediate direction or administration of God; hence, the exercise of political authority by priests as representing the Deity.","pos":""},{"def":"The state thus governed, as the Hebrew commonwealth before it became a kingdom.","pos":""}],"THEOCRASY":[{"def":"An intimate union of the soul with God in contemplation, -- an ideal of the Neoplatonists and of some Oriental mystics.","pos":""}],"THEOCRAT":[{"def":"One who lives under a theocratic form of government; one who in civil affairs conforms to divine law.","pos":""},{"def":"Of or pertaining to a theocracy; administred by the immediate direction of God; as, the theocratical state of the Israelites.","pos":""}],"THEODICY":[{"def":"A vindication of the justice of God in ordaining or permitting natural and moral evil.","pos":""},{"def":"That department of philosophy which treats of the being, perfections, and government of God, and the immortality of the soul.","pos":""}],"THEODOLITE":[{"def":"An instrument used, especially in trigonometrical surveying, for the accurate measurement of horizontal angles, and also usually of vertical angles.","pos":""}],"THEODOLITIC":[{"def":"Of or pertaining to a theodolite; made by means of a theodolite; as, theodolitic observations.","pos":""}],"THEOGONIC":[{"def":"Of or relating to theogony.","pos":""}],"THEOGONIST":[{"def":"A writer on theogony.","pos":""}],"THEOGONY":[{"def":"The generation or genealogy of the gods; that branch of heathen theology which deals with the origin and descent of the deities; also, a poem treating of such genealogies; as, the Theogony of Hesiod.","pos":""}],"THEOLOGASTER":[{"def":"A pretender or quack in theology.","pos":""}],"THEOLOGIAN":[{"def":"A person well versed in theology; a professor of theology or divinity; a divine.","pos":""}],"THEOLOGICAL":[{"def":"Of or pertaining to theology, or the science of God and of divine things; as, a theological treatise.","pos":""}],"THEOLOGIZE":[{"def":"To render theological; to apply to divinity; to reduce to a system of theology.","pos":""}],"THEOLOGIZER":[{"def":"One who theologizes; a theologian.","pos":""}],"THEOLOGUE":[{"def":"A student in a theological seminary.","pos":""}],"THEOLOGY":[{"def":"See Theism, and Logic.","pos":""}],"THEOMACHIST":[{"def":"One who fights against the gods; one who resists God of the divine will.","pos":""}],"THEOMACHY":[{"def":"A fighting against the gods, as the battle of the gaints with the gods.","pos":""},{"def":"A battle or strife among the gods.","pos":""}],"THEOMANCY":[{"def":"A kind of divination drawn from the responses of oracles among heathen nations.","pos":""},{"def":"Of or pertaining to a theopathy.","pos":""}],"THEOPATHY":[{"def":"Capacity for religious affections or worship.","pos":""}],"THEOPHANIC":[{"def":"Of or pertaining to a theopany; appearing to man, as a god.","pos":""}],"THEOPHANY":[{"def":"A manifestation of God to man by actual appearance, usually as an incarnation.","pos":""}],"THEOPHILANTHROPIC":[{"def":"Pertaining to theophilanthropy or the theophilanthropists.","pos":""}],"THEOPHILANTHROPISM":[{"def":"The doctrine of the theophilanthropists; theophilanthropy.","pos":""}],"THEOPHILANTHROPIST":[{"def":"A member of a deistical society established at Paris during the French revolution.","pos":""}],"THEOPHILANTHROPY":[{"def":"Theophilanthropism.","pos":""}],"THEOPHILOSOPHIC":[{"def":"Combining theism and philosophy, or pertaining to the combination of theism and philosophy.","pos":""}],"THEOPNEUSTED":[{"def":"Divinely inspired; theopneustic.","pos":""}],"THEOPNEUSTIC":[{"def":"Given by the inspiration of the Spirit of God.","pos":""}],"THEOPNEUSTY":[{"def":"Divine inspiration; the supernatural influence of the Divine Spirit in qualifying men to receive and communicate revealed truth.","pos":""}],"THEORBIST":[{"def":"One who plays on a theorbo.","pos":""}],"THEORBO":[{"def":"An instrument made like large lute, but having two necks, with two sets of pegs, the lower set holding the strings governed by frets, while to the upper set were attached the long bass strings used as open notes.","pos":""}],"THEOREM":[{"def":"A statement of a principle to be demonstrated.","pos":""}],"THEOREMATIST":[{"def":"One who constructs theorems.","pos":""}],"THEOREMIC":[{"def":"Pertaining to theory; depending on, or confined to, theory or speculation; speculative; terminating in theory or speculation: not practical; as, theoretical learning; theoretic sciences.","pos":""}],"THEORETICS":[{"def":"The speculative part of a science; speculation.","pos":""}],"THEORIC":[{"def":"Relating to, or skilled in, theory; theoretically skilled.","pos":""}],"THEORICA":[{"def":"Public moneys expended at Athens on festivals, sacrifices, and public entertainments (especially theatrical performances), and in gifts to the people; -- also called theoric fund.","pos":""}],"THEORICALLY":[{"def":"In a theoretic manner.","pos":""}],"THEORIST":[{"def":"One who forms theories; one given to theory and speculation; a speculatist.","pos":""}],"THEORIZATION":[{"def":"The act or product of theorizing; the formation of a theory or theories; speculation.","pos":""}],"THEORIZE":[{"def":"To form a theory or theories; to form opinions solely by theory; to speculate.","pos":""}],"THEORIZER":[{"def":"One who theorizes or speculates; a theorist.","pos":""}],"THEORY":[{"def":"Of or pertaining to theosophy.","pos":""}],"THEOSOPHISM":[{"def":"Belief in theosophy.","pos":""}],"THEOSOPHIST":[{"def":"One addicted to theosophy.","pos":""}],"THEOSOPHISTICAL":[{"def":"Of or pertaining to theosophy; theosophical.","pos":""}],"THEOSOPHIZE":[{"def":"To practice theosophy.","pos":""}]}