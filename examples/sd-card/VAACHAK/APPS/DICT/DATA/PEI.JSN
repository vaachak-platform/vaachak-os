{"PEIGNOIR":[{"def":"A woman's loose dressing sack; hence, a loose morning gown or wrapper.","pos":""}],"PEIRAMETER":[{"def":"A dynamometer for measuring the force required to draw wheel carriages on roads of different constructions.","pos":""}],"PEIRASTIC":[{"def":"Fitted for trail or test; experimental; tentative; treating of attempts.","pos":""}],"PEISE":[{"def":"A weight; a poise.","pos":""}]}