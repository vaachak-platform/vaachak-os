{"CATCALL":[{"def":"A sound like the cry of a cat, such as is made in playhouses to express dissatisfaction with a play; also, a small shrill instrument for making such a noise.","pos":""}],"CATCH":[{"def":"To lay hold on; to seize, especially with the hand; to grasp (anything) in motion, with the effect of holding; as, to catch a ball.","pos":""},{"def":"To seize after pursuing; to arrest; as, to catch a thief.","pos":""}],"CATCH CROP":[{"def":"Any crop grown between the rows of another crop or intermediate between two crops in ordinary rotation in point of time.","pos":""}],"CATCH TITLE":[{"def":"A short expressive title used for abbreviated book lists, etc.","pos":""},{"def":"A table sauce made from mushrooms, tomatoes, walnuts, etc.","pos":""}],"CATCH-BASIN":[{"def":"A cistern or vault at the point where a street gutter discharges into a sewer, to oatch bulky matters which would not pass readly throught the sewer.","pos":""}],"CATCH-MEADOW":[{"def":"meadow irrigated by water from a spring or rivulet on the side of hill.","pos":""}],"CATCHABLE":[{"def":"Capable of being caught.","pos":""}],"CATCHDRAIN":[{"def":"A dich or drain along the side of a hill to catch the surface water; also, a ditch at the side of a canal to catch the surplus water.","pos":""}],"CATCHER":[{"def":"The player who stands behind the batsman to catch the ball.","pos":""}],"CATCHFLY":[{"def":"A plant with the joints of the stem, and sometimes other parts, covered with a viscid secretion to which small insects adhere.","pos":""}],"CATCHING":[{"def":"Infections; contagious.","pos":""},{"def":"Captavating; alluring.","pos":""}],"CATCHMENT":[{"def":"A surface of ground on which water may be caught and collected into a reservoir.","pos":""}],"CATCHPENNY":[{"def":"Made or contrived for getting small sums of money from the ignorant or unwary; as, a catchpenny book; a catchpenny show.","pos":""},{"def":"Some worthless catchpenny thing.","pos":""}],"CATCHPOLL":[{"def":"A bailiff's assistant.","pos":""}],"CATCHWATER":[{"def":"A ditch or drain for catching water.","pos":""}],"CATCHWEIGHT":[{"def":"Without any additional weight; without being handicapped; as, to ride catchweight.","pos":""}],"CATCHWORD":[{"def":"The first word of any page of a book after the first, inserted at the right hand bottom corner of the preceding page for the assistance of the reader.","pos":""}],"CATCHWORK":[{"def":"A work or artificial watercourse for throwing water on lands that lie on the slopes of hills; a catchdrain.","pos":""}],"CATCHY":[{"def":"Apt or tending to catch the fancy or attention; catching; taking; as, catchy music.","pos":""},{"def":"Tending to catch or insnare; entangling; -- usually used fig.","pos":""}]}