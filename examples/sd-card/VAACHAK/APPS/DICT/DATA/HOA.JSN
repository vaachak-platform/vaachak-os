{"HOAR":[{"def":"White, or grayish white: as, hoar frost; hoar cliffs.","pos":""},{"def":"Gray or white with age; hoary.","pos":""}],"HOARD":[{"def":"See Hoarding, 2.","pos":""}],"HOARDING":[{"def":"A screen of boards inclosing a house and materials while builders are at work.","pos":""}],"HOARFROST":[{"def":"The white particles formed by the congelation of dew; white frost.","pos":""}],"HOARHOUND":[{"def":"Same as Horehound.","pos":""}],"HOARINESS":[{"def":"The state of being hoary.","pos":""}],"HOARSE":[{"def":"Having a harsh, rough, grating voice or sound, as when affected with a cold; making a rough, harsh cry or sound; as, the hoarse raven.","pos":""},{"def":"Harsh; grating; discordant; -- said of any sound.","pos":""}],"HOARSELY":[{"def":"With a harsh, grating sound or voice.","pos":""}],"HOARSEN":[{"def":"I shall be obliged to hoarsen my voice.","pos":""}],"HOARSENESS":[{"def":"Harshness or roughness of voice or sound, due to mucus collected on the vocal cords, or to swelling or looseness of the cords.","pos":""}],"HOARSTONE":[{"def":"A stone designating the Halliwell.","pos":""}],"HOARY":[{"def":"Of a pale silvery gray.","pos":""},{"def":"Covered with short, dense, grayish white hairs; canescent.","pos":""}],"HOAX":[{"def":"A deception for mockery or mischief; a deceptive trick or story; a practical joke.","pos":""}],"HOAZIN":[{"def":"A remarkable South American bird (Opisthocomus cristatus); the crested touraco.","pos":""}]}