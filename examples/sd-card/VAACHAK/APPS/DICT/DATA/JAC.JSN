{"JACAL":[{"def":"In Mexico and the southwestern United States, a kind of plastered house or hut, usually made by planting poles or timber in the ground, filling in between them with screen work or wickerwork, and daubing one or both sides with mud or adobe mortar; also, this method of construction.","pos":""}],"JACAMAR":[{"def":"Any one of numerous species of tropical American birds of the genus Galbula and allied genera.","pos":""}],"JACANA":[{"def":"Any of several wading birds belonging to the genus Jacana and several allied genera, all of which have spurs on the wings.","pos":""}],"JACCHUS":[{"def":"The common marmoset (Hapale vulgaris).","pos":""}],"JACENT":[{"def":"Lying at length; as, the jacent posture.","pos":""}],"JACK":[{"def":"A large tree, the Artocarpus integrifolia, common in the East Indies, closely allied to the breadfruit, from which it differs in having its leaves entire.","pos":""}],"JACK KETCH":[{"def":"A public executioner, or hangman.","pos":""}],"JACK-'-LANTERN":[{"def":"See Jack-with-a-lantern, under 2d Jack.","pos":""}],"JACK-A-DANDY":[{"def":"A little dandy; a little, foppish, impertinent fellow.","pos":""}],"JACK-A-LENT":[{"def":"A small stuffed puppet to be pelted in Lent; hence, a simple fellow.","pos":""}],"JACK-O'-LANTERN":[{"def":"See Jack-with-a-lantern, under 2d Jack.","pos":""}],"JACKAL":[{"def":"Any one of several species of carnivorous animals inhabiting Africa and Asia, related to the dog and wolf.","pos":""}],"JACKANAPES":[{"def":"A young man living as an apprentice on a sheep station, or otherwise engaged in acquainting himself with colonial life.","pos":""}],"JACKAROO":[{"def":"To be a jackaroo; to pass one's time as a jackaroo.","pos":""}],"JACKASS":[{"def":"The male ass; a donkey.","pos":""},{"def":"A conceited dolt; a perverse blockhead.","pos":""}],"JACKEEN":[{"def":"A drunken, dissolute fellow.","pos":""}],"JACKET":[{"def":"In ordnance, a strengthening band surrounding and reënforcing the tube in which the charge is fired.","pos":""}],"JACKETED":[{"def":"Wearing, or furnished with, a jacket.","pos":""}],"JACKETING":[{"def":"The material of a jacket; as, nonconducting jacketing.","pos":""}],"JACKKNIFE":[{"def":"A large, strong clasp knife for the pocket; a pocket knife.","pos":""}],"JACKMAN":[{"def":"One wearing a jack; a horse soldier; a retainer.","pos":""}],"JACKPUDDING":[{"def":"A merry-andrew; a buffoon.","pos":""}],"JACKSCREW":[{"def":"A jack in which a screw is used for lifting, or exerting pressure.","pos":""}],"JACKSLAVE":[{"def":"A low servant; a mean fellow.","pos":""}],"JACKSMITH":[{"def":"A smith who makes jacks.","pos":""}],"JACKSTAY":[{"def":"A rail of wood or iron stretching along a yard of a vessel, to which the sails are fastened.","pos":""}],"JACKSTRAW":[{"def":"An effigy stuffed with straw; a scarecrow; hence, a man without property or influence.","pos":""},{"def":"One of a set of straws of strips of ivory, bone, wood, etc.","pos":""}],"JACKWOOD":[{"def":"Wood of the jack (Artocarpus integrifolia), used in cabinetwork.","pos":""}],"JACOB":[{"def":"A Hebrew patriarch (son of Isaac, and ancestor of the Jews), who in a vision saw a ladder reaching up to heaven (Gen.","pos":""}],"JACOBAEAN LILY":[{"def":"A bulbous plant (Amaryllis, or Sprekelia, formosissima) from Mexico.","pos":""},{"def":"Of or pertaining to a style of architecture and decoration in the time of James the First, of England.","pos":""}],"JACOBIN":[{"def":"A Dominican friar; -- so named because, before the French Revolution, that order had a convent in the Rue St.","pos":""},{"def":"A fancy pigeon, in which the feathers of the neck form a hood, -- whence the name.","pos":""}],"JACOBINE":[{"def":"Of or pertaining to the Jacobins of France; revolutionary; of the nature of, or characterized by, Jacobinism.","pos":""}],"JACOBINISM":[{"def":"The principles of the Jacobins; violent and factious opposition to legitimate government.","pos":""}],"JACOBINIZE":[{"def":"To taint with, or convert to, Jacobinism.","pos":""}],"JACOBITE":[{"def":"A partisan or adherent of James the Second, after his abdication, or of his descendants, an opposer of the revolution in 1688 in favor of William and Mary.","pos":""},{"def":"One of the sect of Syrian Monophysites.","pos":""}],"JACOBITISM":[{"def":"The principles of the Jacobites.","pos":""}],"JACOBUS":[{"def":"An English gold coin, of the value of twenty-five shillings sterling, struck in the reign of James I.","pos":""}],"JACONET":[{"def":"A thin cotton fabric, between and muslin, used for dresses, neckcloths, etc.","pos":""}],"JACQUARD":[{"def":"Pertaining to, or invented by, Jacquard, a French mechanician, who died in 1834.","pos":""}],"JACQUEMINOT":[{"def":"A half-hardy, deep crimson rose of the remontant class; -- so named after General Jacqueminot, of France.","pos":""}],"JACQUERIE":[{"def":"The name given to a revolt of French peasants against the nobles in 1358, the leader assuming the contemptuous title, Jacques Bonhomme, given by the nobles to the peasantry.","pos":""}],"JACTANCY":[{"def":"A boasting; a bragging.","pos":""}],"JACTATION":[{"def":"A throwing or tossing of the body; a shaking or agitation.","pos":""}],"JACTITATION":[{"def":"Vain boasting or assertions repeated to the prejudice of another's right; false claim.","pos":""},{"def":"A frequent tossing or moving of the body; restlessness, as in delirium.","pos":""}],"JACULABLE":[{"def":"Fit for throwing.","pos":""}],"JACULATE":[{"def":"To throw or cast, as a dart; to throw out; to emit.","pos":""}],"JACULATION":[{"def":"The act of tossing, throwing, or hurling, as spears.","pos":""}],"JACULATOR":[{"def":"The archer fish (Toxotes jaculator).","pos":""}],"JACULATORY":[{"def":"Darting or throwing out suddenly; also, suddenly thrown out; uttered in short sentences; ejaculatory; as, jaculatory prayers.","pos":""}]}