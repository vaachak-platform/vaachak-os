{"CUINAGE":[{"def":"The stamping of pigs of tin, by the proper officer, with the arms of the duchy of Cornwall.","pos":"noun"}],"CUIR BOUILLI":[{"def":"In decorative art, boiled leather, fitted by the process to receive impressed patterns, like those produced by chasing metal, and to retain the impression permanently.","pos":""}],"CUIRASS":[{"def":"An armor of bony plates, somewhat resembling a cuirass.","pos":""}],"CUIRASSED":[{"def":"Having a covering of bony plates, resembling a cuirass;- said of certain fishes.","pos":""}],"CUIRASSIER":[{"def":"A soldier armed with a cuirass.","pos":""}],"CUISH":[{"def":"Defensive armor for the thighs.","pos":""}],"CUISINE":[{"def":"The kitchen or cooking department.","pos":""},{"def":"Manner or style of cooking.","pos":""}]}