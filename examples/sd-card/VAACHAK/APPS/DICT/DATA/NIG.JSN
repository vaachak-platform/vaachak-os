{"NIGGARD":[{"def":"A person meanly close and covetous; one who spends grudgingly; a stingy, parsimonous fellow; a miser.","pos":""}],"NIGGARDISH":[{"def":"Somewhat niggard.","pos":""}],"NIGGARDLINESS":[{"def":"The quality or state of being niggard; meanness in giving or spending; parsimony; stinginess.","pos":""}],"NIGGARDLY":[{"def":"Meanly covetous or avarcious in dealing with others; stingy; niggard.","pos":""}],"NIGGARDOUS":[{"def":"Covetous gathering and niggardous keeping.","pos":""}],"NIGGED":[{"def":"Hammer-dressed; -- said of building stone.","pos":""}],"NIGGER":[{"def":"A negro; -- in vulgar derision or depreciation.","pos":""}],"NIGGERHEAD":[{"def":"A strong black chewing tobacco, usually in twisted plug form; negro head.","pos":""}],"NIGGLE":[{"def":"To trifle with; to deceive; to mock.","pos":""}],"NIGGLER":[{"def":"One who niggles.","pos":""}],"NIGGLING":[{"def":"Finicky or pottering work; specif.","pos":""},{"def":"minute and very careful workmanship in drawing, painting, or the like, esp.","pos":""}],"NIGH":[{"def":"Not distant or remote in place or time; near.","pos":""},{"def":"Not remote in degree, kindred, circumstances, etc.","pos":""}],"NIGHLY":[{"def":"In a near relation in place, time, degree, etc.","pos":""}],"NIGHNESS":[{"def":"The quality or state of being nigh.","pos":""}],"NIGHT":[{"def":"That part of the natural day when the sun is beneath the horizon, or the time from sunset to sunrise; esp.","pos":""},{"def":"Hence: (a) Darkness; obscurity; concealment.","pos":""}],"NIGHT TERRORS":[{"def":"A sudden awkening associated with a sensation of terror, occurring in children, esp.","pos":""}],"NIGHT-BLOOMING":[{"def":"Blooming in the night.","pos":""}],"NIGHT-EYED":[{"def":"Capable of seeing at night; sharp-eyed.","pos":""}],"NIGHT-FARING":[{"def":"Going or traveling in the night.","pos":""}],"NIGHTCAP":[{"def":"A cap worn in bed to protect the head, or in undress.","pos":""},{"def":"A potion of spirit drank at bedtime.","pos":""}],"NIGHTED":[{"def":"Darkness; clouded.","pos":""},{"def":"Overtaken by night; belated.","pos":""}],"NIGHTERTALE":[{"def":"period of night; nighttime.","pos":""}],"NIGHTFALL":[{"def":"The close of the day.","pos":""}],"NIGHTGOWN":[{"def":"A loose gown used for undress; also, a gown used for a sleeping garnment.","pos":""}],"NIGHTINGALE":[{"def":"A small, plain, brown and gray European song bird (Luscinia luscinia).","pos":""},{"def":"A larger species (Lucinia philomela), of Eastern Europe, having similar habits; the thrush nightingale.","pos":""}],"NIGHTISH":[{"def":"Of or pertaining to night.","pos":""}],"NIGHTJAR":[{"def":"A goatsucker, esp.","pos":""}],"NIGHTLESS":[{"def":"Having no night.","pos":""},{"def":"See Letter, above.","pos":""}],"NIGHTLONG":[{"def":"Lasting all night.","pos":""}],"NIGHTLY":[{"def":"Of or pertaining to the night, or to every night; happening or done by night, or every night; as, nightly shades; he kept nightly vigils.","pos":""}],"NIGHTMAN":[{"def":"One whose business is emptying privies by night.","pos":""}],"NIGHTMARE":[{"def":"A fiend or incubus formerly supposed to cause trouble in sleep.","pos":""},{"def":"A condition in sleep usually caused by improper eating or by digestive or nervous troubles, and characterized by a sense of extreme uneasiness or discomfort (as of weight on the chest or stomach, impossibility of motion or speech, etc.","pos":""}],"NIGHTSHADE":[{"def":"A common name of many species of the genus Solanum, given esp.","pos":""}],"NIGHTSHIRT":[{"def":"A kind of nightgown for men.","pos":""}],"NIGHTTIME":[{"def":"The time from dusk to dawn; -- opposed to Ant: daytime.","pos":""}],"NIGHTWARD":[{"def":"Approaching toward night.","pos":""}],"NIGRANILINE":[{"def":"The complex, nitrogenous, organic base and dyestuff called also aniline black.","pos":""}],"NIGRESCENT":[{"def":"Growing black; changing to a black color; approaching to blackness.","pos":""}],"NIGRIFICATION":[{"def":"The act or process of making black.","pos":""}],"NIGRINE":[{"def":"A ferruginous variety of rutile.","pos":""}],"NIGRITIC":[{"def":"Pertaining to, or having the characteristics of, negroes, or of the Negritos, Papuans, and the Melanesian races; negritic.","pos":""}],"NIGRITUDE":[{"def":"Blackness; the state of being black.","pos":""}],"NIGROMANCIEN":[{"def":"These false enchanters or nigromanciens.","pos":""}],"NIGROSINE":[{"def":"A dark blue dyestuff, of the induline group; -- called also azodiphenyl blue.","pos":""}]}