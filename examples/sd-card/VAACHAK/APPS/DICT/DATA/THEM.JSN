{"THEM":[{"def":"The objective case of they.","pos":""}],"THEMATIC":[{"def":"Of or pertaining to the theme of a word.","pos":""},{"def":"Of or pertaining to a theme, or subject.","pos":""}],"THEME":[{"def":"A noun or verb, not modified by inflections; also, that part of a noun or verb which remains unchanged (except by euphonic variations) in declension or conjugation; stem.","pos":""},{"def":"The leading subject of a composition or a movement.","pos":""}],"THEMIS":[{"def":"The goddess of law and order; the patroness of existing rights.","pos":""}],"THEMSELVES":[{"def":"The plural of himself, herself, and itself.","pos":""}]}