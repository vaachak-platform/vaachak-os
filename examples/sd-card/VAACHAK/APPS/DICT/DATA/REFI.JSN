{"REFIGURE":[{"def":"To figure again.","pos":""}],"REFILL":[{"def":"To fill, or become full, again.","pos":""}],"REFIND":[{"def":"To find again; to get or experience again.","pos":""}],"REFINE":[{"def":"To reduce to a fine, unmixed, or pure state; to free from impurities; to free from dross or alloy; to separate from extraneous matter; to purify; to defecate; as, to refine gold or silver; to refine iron; to refine wine or sugar.","pos":""},{"def":"To purify from what is gross, coarse, vulgar, inelegant, low, and the like; to make elegant or exellent; to polish; as, to refine the manners, the language, the style, the taste, the intellect, or the moral feelings.","pos":""}],"REFINED":[{"def":"Freed from impurities or alloy; purifed; polished; cultured; delicate; as; refined gold; refined language; refined sentiments.","pos":""}],"REFINEMENT":[{"def":"The act of refining, or the state of being refined; as, the refinement or metals; refinement of ideas.","pos":""},{"def":"That which is refined, elaborated, or polished to excess; an affected subtilty; as, refinements of logic.","pos":""}],"REFINER":[{"def":"One who, or that which, refines.","pos":""}],"REFINERY":[{"def":"The building and apparatus for refining or purifying, esp.","pos":""},{"def":"A furnace in which cast iron is refined by the action of a blast on the molten metal.","pos":""}],"REFIT":[{"def":"To fit or prepare for use again; to repair; to restore after damage or decay; as, to refit a garment; to refit ships of war.","pos":""},{"def":"To fit out or supply a second time.","pos":""}],"REFITMENT":[{"def":"The act of refitting, or the state of being refitted.","pos":""}],"REFIX":[{"def":"To fix again or anew; to establish anew.","pos":""}]}