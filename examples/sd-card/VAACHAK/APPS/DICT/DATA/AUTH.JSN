{"AUTHENTIC":[{"def":"Vested with all due formalities, and legally attested.","pos":""},{"def":"Having as immediate relation to the tonic, in distinction from plagal, which has a correspondent relation to the dominant in the octave below the tonic.","pos":""}],"AUTHENTICALLY":[{"def":"In an authentic manner; with the requisite or genuine authority.","pos":""}],"AUTHENTICALNESS":[{"def":"The quality of being authentic; authenticity.","pos":""}],"AUTHENTICATE":[{"def":"To render authentic; to give authority to, by the proof, attestation, or formalities required by law, or sufficient to entitle to credit.","pos":""},{"def":"To prove authentic; to determine as real and true; as, to authenticate a portrait.","pos":""}],"AUTHENTICITY":[{"def":"The quality of being authentic or of established authority for truth and correctness.","pos":""},{"def":"Genuineness; the quality of being genuine or not corrupted from the original.","pos":""}],"AUTHENTICNESS":[{"def":"The quality of being authentic; authenticity.","pos":""}],"AUTHENTICS":[{"def":"A collection of the Novels or New Constitutions of Justinian, by an anonymous author; -- so called on account of its authencity.","pos":""}],"AUTHOR":[{"def":"The beginner, former, or first mover of anything; hence, the efficient cause of a thing; a creator; an originator.","pos":""},{"def":"One who composes or writers a book; a composer, as distinguished from an editor, translator, or compiler.","pos":""}],"AUTHORESS":[{"def":"A female author.","pos":""}],"AUTHORIAL":[{"def":"Of or pertaining to an author.","pos":""}],"AUTHORITATIVE":[{"def":"Having, or proceeding from, due authority; entitled to obedience, credit, or acceptance; determinate; commanding.","pos":""},{"def":"Having an air of authority; positive; dictatorial; peremptory; as, an authoritative tone.","pos":""}],"AUTHORITY":[{"def":"Legal or rightful power; a right to command or to act; power exercised buy a person in virtue of his office or trust; dominion; jurisdiction; authorization; as, the authority of a prince over subjects, and of parents over children; the authority of a court.","pos":""},{"def":"Government; the persons or the body exercising power or command; as, the local authorities of the States; the military authorities.","pos":""}],"AUTHORIZABLE":[{"def":"Capable of being authorized.","pos":""}],"AUTHORIZATION":[{"def":"The act of giving authority or legal power; establishment by authority; sanction or warrant.","pos":""}],"AUTHORIZE":[{"def":"To clothe with authority, warrant, or legal power; to give a right to act; to empower; as, to authorize commissioners to settle a boundary.","pos":""},{"def":"To make legal; to give legal sanction to; to legalize; as, to authorize a marriage.","pos":""}],"AUTHORIZE ONE'S SELF":[{"def":", to rely for authority.","pos":""}],"AUTHORIZED":[{"def":"Possessed of or endowed with authority; as, an authorized agent.","pos":""},{"def":"Sanctioned by authority.","pos":""}],"AUTHORIZER":[{"def":"One who authorizes.","pos":""}],"AUTHORLESS":[{"def":"Without an author; without authority; anonymous.","pos":""}],"AUTHORSHIP":[{"def":"The quality or state of being an author; function or dignity of an author.","pos":""},{"def":"Source; origin; origination; as, the authorship of a book or review, or of an act, or state of affairs.","pos":""}],"AUTHOTYPE":[{"def":"A type or block containing a facsimile of an autograph.","pos":""}]}