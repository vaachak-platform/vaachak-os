{"PIKA":[{"def":"Any one of several species of rodents of the genus Lagomys, resembling small tailless rabbits.","pos":""}],"PIKE":[{"def":"A foot soldier's weapon, consisting of a long wooden shaft or staff, with a pointed steel head.","pos":""},{"def":"A large fresh-water fish (Esox lucius), found in Europe and America, highly valued as a food fish; -- called also pickerel, gedd, luce, and jack.","pos":""}],"PIKE-DEVANT":[{"def":"A pointed beard.","pos":""},{"def":"A light, thin cake or muffin.","pos":""}],"PIKED":[{"def":"Furnished with a pike; ending in a point; peaked; pointed.","pos":""}],"PIKEMAN":[{"def":"A soldier armed with a pike.","pos":""},{"def":"A miner who works with a pick.","pos":""}],"PIKESTAFF":[{"def":"The staff, or shaft, of a pike.","pos":""},{"def":"A staff with a spike in the lower end, to guard against slipping.","pos":""}]}