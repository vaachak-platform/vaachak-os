{"LED":[{"def":"Language; speech; voice; cry.","pos":""}],"LEDGE":[{"def":"A lode; a limited mass of rock bearing valuable mineral.","pos":""},{"def":"A piece of timber to support the deck, placed athwartship between beams.","pos":""}],"LEDGER":[{"def":"A book in which a summary of accounts is laid up or preserved; the final book of record in business transactions, in which all debits and credits from the journal, etc.","pos":""}],"LEDGY":[{"def":"Abounding in ledges; consisting of a ledge or reef; as, a ledgy island.","pos":""}]}