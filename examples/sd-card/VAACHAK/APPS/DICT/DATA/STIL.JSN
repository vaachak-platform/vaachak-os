{"STILAR":[{"def":"Of or pertaining to the style of a dial.","pos":""}],"STILBENE":[{"def":"A hydrocarbon, C14H12, produced artificially in large, fine crystals; -- called also diphenyl ethylene, toluylene, etc.","pos":""}],"STILBITE":[{"def":"A common mineral of the zeolite family, a hydrous silicate of alumina and lime, usually occurring in sheaflike aggregations of crystals, also in radiated masses.","pos":""}],"STILE":[{"def":"A pin set on the face of a dial, to cast a shadow; a style.","pos":""},{"def":"Mode of composition.","pos":""}],"STILETTO":[{"def":"A kind of dagger with a slender, rounded, and pointed blade.","pos":""},{"def":"A pointed instrument for making eyelet holes in embroidery.","pos":""}],"STILL":[{"def":"Motionless; at rest; quiet; as, to stand still; to lie or sit still.","pos":""},{"def":"Uttering no sound; silent; as, the audience is still; the animals are still.","pos":""}],"STILL-BURN":[{"def":"To burn in the process of distillation; as, to still-burn brandy.","pos":""}],"STILL-HUNT":[{"def":"A hunting for game in a quiet and cautious manner, or under cover; stalking; hence, colloquially, the pursuit of any object quietly and cautiously.","pos":""}],"STILLAGE":[{"def":"A low stool to keep the goods from touching the floor.","pos":""}],"STILLATITIOUS":[{"def":"Falling in drops; drawn by a still.","pos":""}],"STILLATORY":[{"def":"An alembic; a vessel for distillation.","pos":""},{"def":"A laboratory; a place or room in which distillation is performed.","pos":""}],"STILLBIRTH":[{"def":"The birth of a dead fetus.","pos":""}],"STILLBORN":[{"def":"Dead at the birth; as, a stillborn child.","pos":""}],"STILLER":[{"def":"One who stills, or quiets.","pos":""}],"STILLHOUSE":[{"def":"A house in which distillation is carried on; a distillery.","pos":""}],"STILLICIDE":[{"def":"A continual falling or succession of drops; rain water falling from the eaves.","pos":""}],"STILLICIDIOUS":[{"def":"Falling in drops.","pos":""}],"STILLIFORM":[{"def":"Having the form of a drop.","pos":""}],"STILLION":[{"def":"A stand, as for casks or vats in a brewery, or for pottery while drying.","pos":""}],"STILLNESS":[{"def":"The quality or state of being still; quietness; silence; calmness; inactivity.","pos":""},{"def":"Habitual silence or quiet; taciturnity.","pos":""}],"STILLROOM":[{"def":"A room for distilling.","pos":""},{"def":"An apartment in a house where liquors, preserves, and the like, are kept.","pos":""}],"STILLSON WRENCH":[{"def":"A pipe wrench having an adjustable L-shaped jaw piece sliding in a sleeve that is pivoted to, and loosely embraces, the handle.","pos":""}],"STILLY":[{"def":"Still; quiet; calm.","pos":""}],"STILPNOMELANE":[{"def":"A black or greenish black mineral occurring in foliated flates, also in velvety bronze-colored incrustations.","pos":""}],"STILT":[{"def":"Any species of limicoline birds belonging to Himantopus and allied genera, in which the legs are remarkably long and slender.","pos":""}],"STILTED":[{"def":"Elevated as if on stilts; hence, pompous; bombastic; as, a stilted style; stilted declamation.","pos":""}],"STILTIFY":[{"def":"To raise upon stilts, or as upon stilts; to stilt.","pos":""},{"def":"A peculiarly flavored unpressed cheese made from milk with cream added; -- so called from the village or parish of Stilton, England, where it was originally made.","pos":""}],"STILTY":[{"def":"Unreasonably elevated; pompous; stilted; as, a stilty style.","pos":""}]}