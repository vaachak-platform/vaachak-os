{"RIOT":[{"def":"The tumultuous disturbance of the public peace by an unlawful assembly of three or more persons in the execution of some private object.","pos":""}],"RIOTER":[{"def":"One who engages in a riot.","pos":""}],"RIOTISE":[{"def":"Excess; tumult; revelry.","pos":""}],"RIOTOUS":[{"def":"Involving, or engaging in, riot; wanton; unrestrained; luxurious.","pos":""},{"def":"Partaking of the nature of an unlawful assembly or its acts; seditious.","pos":""}],"RIOTRY":[{"def":"The act or practice of rioting; riot.","pos":""}]}