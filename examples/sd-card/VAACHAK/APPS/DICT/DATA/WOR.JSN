{"WORD":[{"def":"Talk; discourse; speech; language.","pos":""},{"def":"Verbal contention; dispute.","pos":""}],"WORD METHOD":[{"def":"A method of teaching reading in which words are first taken as single ideograms and later analyzed into their phonetic and alphabetic elements; -- contrasted with the alphabet and sentence methods.","pos":""}],"WORD-CATCHER":[{"def":"One who cavils at words.","pos":""}],"WORDBOOK":[{"def":"A collection of words; a vocabulary; a dictionary; a lexicon.","pos":""}],"WORDILY":[{"def":"In a wordy manner.","pos":""}],"WORDINESS":[{"def":"The quality or state of being wordy, or abounding with words; verboseness.","pos":""}],"WORDING":[{"def":"The act or manner of expressing in words; style of expression; phrasing.","pos":""}],"WORDISH":[{"def":"Respecting words; full of words; wordy.","pos":""}],"WORDLE":[{"def":"One of several pivoted pieces forming the throat of an adjustable die used in drawing wire, lead pipe, etc.","pos":""}],"WORDLESS":[{"def":"Not using words; not speaking; silent; speechless.","pos":""}],"WORDPLAY":[{"def":"A more or less subtle playing upon the meaning of words.","pos":""}],"WORDSMAN":[{"def":"One who deals in words, or in mere words; a verbalist.","pos":""}],"WORDY":[{"def":"Of or pertaining to words; consisting of words; verbal; as, a wordy war.","pos":""},{"def":"Using many words; verbose; as, a wordy speaker.","pos":""}],"WORK":[{"def":"Structures in civil, military, or naval engineering, as docks, bridges, embankments, trenches, fortifications, and the like; also, the structures and grounds of a manufacturing establishment; as, iron works; locomotive works; gas works.","pos":""},{"def":"The moving parts of a mechanism; as, the works of a watch.","pos":""}],"WORKABLE":[{"def":"Capable of being worked, or worth working; as, a workable mine; workable clay.","pos":""}],"WORKBAG":[{"def":"A bag for holding implements or materials for work; especially, a reticule, or bag for holding needlework, and the like.","pos":""}],"WORKBASKET":[{"def":"A basket for holding materials for needlework, or the like.","pos":""}],"WORKBENCH":[{"def":"A bench on which work is performed, as in a carpenter's shop.","pos":""}],"WORKBOX":[{"def":"A box for holding instruments or materials for work.","pos":""}],"WORKDAY":[{"def":"A day on which work is performed, as distinguished from Sunday, festivals, etc.","pos":""}],"WORKER":[{"def":"One of the neuter, or sterile, individuals of the social ants, bees, and white ants.","pos":""}],"WORKFELLOW":[{"def":"One engaged in the same work with another; a companion in work.","pos":""}],"WORKFOLK":[{"def":"People that labor.","pos":""}],"WORKFUL":[{"def":"Full of work; diligent.","pos":""}],"WORKHOUSE":[{"def":"A house where any manufacture is carried on; a workshop.","pos":""},{"def":"A house in which idle and vicious persons are confined to labor.","pos":""}],"WORKING":[{"def":"Work\"ing, Defn: a & n.","pos":""}],"WORKING-DAY":[{"def":"Pertaining to, or characteristic of, working days, or workdays; everyday; hence, plodding; hard-working.","pos":""}],"WORKINGMAN":[{"def":"A laboring man; a man who earns his daily support by manual labor.","pos":""}],"WORKLESS":[{"def":"Without work; not laboring; as, many people were still workless.","pos":""},{"def":"Not carried out in practice; not exemplified in fact; as, workless faith.","pos":""}],"WORKMAN":[{"def":"A man employed in labor, whether in tillage or manufactures; a worker.","pos":""},{"def":"Hence, especially, a skillful artificer or laborer.","pos":""}],"WORKMANLIKE":[{"def":"Becoming a workman, especially a skillful one; skillful; well performed.","pos":""}],"WORKMANLY":[{"def":"Becoming a skillful workman; skillful; well performed; workmanlike.","pos":""}],"WORKMANSHIP":[{"def":"The art or skill of a workman; the execution or manner of making anything.","pos":""},{"def":"That which is effected, made, or produced; manufacture, something made by manual labor.","pos":""}],"WORKMASTER":[{"def":"The performer of any work; a master workman.","pos":""}],"WORKMEN'S COMPENSATION ACT":[{"def":"A statute fixing the compensation that a workman may recover from an employer in case of accident, esp.","pos":""}],"WORKROOM":[{"def":"Any room or apartment used especially for labor.","pos":""}],"WORKSHOP":[{"def":"A shop where any manufacture or handiwork is carried on.","pos":""}],"WORKTABLE":[{"def":"A table for holding working materials and implements; esp.","pos":""},{"def":"In a working position or manner; as, a T rail placed workwise, i.","pos":""}],"WORKWOMAN":[{"def":"A woman who performs any work; especially, a woman skilled in needlework.","pos":""}],"WORKYDAY":[{"def":"A week day or working day, as distinguished from Sunday or a holiday.","pos":""}],"WORLD":[{"def":"The earth and the surrounding heavens; the creation; the system of created things; existent creation; the universe.","pos":""},{"def":"Any planet or heavenly body, especially when considered as inhabited, and as the scene of interests analogous with human interests; as, a plurality of worlds.","pos":""}],"WORLD-WIDE":[{"def":"Extended throughout the world; as, world-wide fame.","pos":""}],"WORLDLINESS":[{"def":"The quality of being worldly; a predominant passion for obtaining the good things of this life; covetousness; addictedness to gain and temporal enjoyments; worldly-mindedness.","pos":""}],"WORLDLING":[{"def":"A person whose soul is set upon gaining temporal possessions; one devoted to this world and its enjoyments.","pos":""}],"WORLDLY":[{"def":"Relating to the world; human; common; as, worldly maxims; worldly actions.","pos":""},{"def":"Pertaining to this world or life, in contradistinction from the life to come; secular; temporal; devoted to this life and its enjoyments; bent on gain; as, worldly pleasures, affections, honor, lusts, men.","pos":""}],"WORLDLY-MINDED":[{"def":"Devoted to worldly interests; mindful of the affairs of the present life, and forgetful of those of the future; loving and pursuing this world's goods, to the exclusion of piety and attention to spiritual concerns.","pos":""},{"def":"Wise in regard to things of this world.","pos":""}],"WORM":[{"def":"A creeping or a crawling animal of any kind or size, as a serpent, caterpillar, snail, or the like.","pos":""},{"def":"Any small creeping animal or reptile, either entirely without feet, or with very short ones, including a great variety of animals; as, an earthworm; the blindworm.","pos":""}],"WORM-EATEN":[{"def":"Eaten, or eaten into, by a worm or by worms; as, worm-eaten timber.","pos":""},{"def":"Worn-out; old; worthless.","pos":""}],"WORM-SHAPED":[{"def":"Shaped like a worm; as, a worm-shaped root.","pos":""}],"WORM-SHELL":[{"def":"Any species of Vermetus.","pos":""}],"WORMED":[{"def":"Penetrated by worms; injured by worms; worm-eaten; as, wormed timber.","pos":""}],"WORMHOLE":[{"def":"A burrow made by a worm.","pos":""}],"WORMIAN":[{"def":"Discovered or described by Olanus Wormius, a Danish anatomist.","pos":""}],"WORMIL":[{"def":"Any botfly larva which burrows in or beneath the skin of domestic and wild animals, thus producing sores.","pos":""},{"def":"See 1st Warble, 1 (b).","pos":""}],"WORMLING":[{"def":"O dusty wormling! dost thou strive and stand With heaven's high monarch Sylvester.","pos":""}],"WORMSEED":[{"def":"Any one of several plants, as Artemisia santonica, and Chenopodium anthelminticum, whose seeds have the property of expelling worms from the stomach and intestines.","pos":""}],"WORMWOOD":[{"def":"A composite plant (Artemisia Absinthium), having a bitter and slightly aromatic taste, formerly used as a tonic and a vermifuge, and to protect woolen garments from moths.","pos":""}],"WORMY":[{"def":"Containing a worm; abounding with worms.","pos":""},{"def":"Like or pertaining to a worm; earthy; groveling.","pos":""}],"WORN-OUT":[{"def":"Consumed, or rendered useless, by wearing; as, worn-out garments.","pos":""},{"def":"An Egyptian fork-tongued lizard, about four feet long when full grown.","pos":""}],"WORRIER":[{"def":"One who worries.","pos":""}],"WORRIMENT":[{"def":"Trouble; anxiety; worry.","pos":""}],"WORRISOME":[{"def":"Inclined to worry or fret; also, causing worry or annoyance.","pos":""}],"WORRIT":[{"def":"To worry; to annoy.","pos":""}],"WORRY":[{"def":"To harass by pursuit and barking; to attack repeatedly; also, to tear or mangle with the teeth.","pos":""},{"def":"To harass or beset with importunity, or with care an anxiety; to vex; to annoy; to torment; to tease; to fret; to trouble; to plague.","pos":""}],"WORRYINGLY":[{"def":"In a worrying manner.","pos":""}],"WORSE":[{"def":"Bad, ill, evil, or corrupt, in a greater degree; more bad or evil; less good; specifically, in poorer health; more sick; -- used both in a physical and moral sense.","pos":""}],"WORSEN":[{"def":"To make worse; to deteriorate; to impair.","pos":""},{"def":"To get the better of; to worst.","pos":""}],"WORSER":[{"def":"Thou dost deserve a worser end.","pos":""}],"WORSHIP":[{"def":"Excellence of character; dignity; worth; worthiness.","pos":""},{"def":"Honor; respect; civil deference.","pos":""}],"WORSHIPABILITY":[{"def":"The quality of being worthy to be worshiped.","pos":""}],"WORSHIPABLE":[{"def":"Capable of being worshiped; worthy of worship.","pos":""}],"WORSHIPER":[{"def":"One who worships; one who pays divine honors to any being or thing; one who adores.","pos":""}],"WORSHIPFUL":[{"def":"Entitled to worship, reverence, or high respect; claiming respect; worthy of honor; -- often used as a term of respect, sometimes ironically.","pos":""}],"WORST":[{"def":"Bad, evil, or pernicious, in the highest degree, whether in a physical or moral sense.","pos":""}],"WORSTED":[{"def":"Well-twisted yarn spun of long-staple wool which has been combed to lay the fibers parallel, used for carpets, cloth, hosiery, gloves, and the like.","pos":""},{"def":"Fine and soft woolen yarn, untwisted or lightly twisted, used in knitting and embroidery.","pos":""}],"WORT":[{"def":"A plant of any kind.","pos":""}],"WORTH":[{"def":"To be; to become; to betide; -- now used only in the phrases, woe worth the day, woe worth the man, etc.","pos":""}],"WORTHFUL":[{"def":"Full of worth; worthy; deserving.","pos":""}],"WORTHILY":[{"def":"In a worthy manner; excellently; deservedly; according to merit; justly; suitably; becomingly.","pos":""}],"WORTHINESS":[{"def":"The quality or state of being worthy; desert; merit; excellence; dignity; virtue; worth.","pos":""}],"WORTHLESS":[{"def":"Destitute of worth; having no value, virtue, excellence, dignity, or the like; undeserving; valueless; useless; vile; mean; as, a worthless garment; a worthless ship; a worthless man or woman; a worthless magistrate.","pos":""}],"WORTHWHILE":[{"def":"Worth the time or effort spent.","pos":""}],"WORTHY":[{"def":"Having worth or excellence; possessing merit; valuable; deserving; estimable; excellent; virtuous.","pos":""}]}