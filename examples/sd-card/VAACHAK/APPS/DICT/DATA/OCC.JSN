{"OCCAMY":[{"def":"An alloy imitating gold or silver.","pos":""}],"OCCASION":[{"def":"A falling out, happening, or coming to pass; hence, that which falls out or happens; occurrence; incident.","pos":""},{"def":"A favorable opportunity; a convenient or timely chance; convenience.","pos":""}],"OCCASIONABLE":[{"def":"Capable of being occasioned or caused.","pos":""}],"OCCASIONAL":[{"def":"Of or pertaining to an occasion or to occasions; occuring at times, but not constant, regular, or systematic; made or happening as opportunity requires or admits; casual; incidental; as, occasional remarks, or efforts.","pos":""},{"def":"Produced by accident; as, the occasional origin of a thing.","pos":""}],"OCCASIONALISM":[{"def":"The system of occasional causes; -- a name given to certain theories of the Cartesian school of philosophers, as to the intervention of the First Cause, by which they account for the apparent reciprocal action of the soul and the body.","pos":""}],"OCCASIONALITY":[{"def":"Quality or state of being occasional; occasional occurrence.","pos":""}],"OCCASIONALLY":[{"def":"In an occasional manner; on occasion; at times, as convenience requires or opportunity offers; not regularly.","pos":""}],"OCCASIONATE":[{"def":"The lowest may occasionate much ill.","pos":""}],"OCCASIONER":[{"def":"One who, or that which, occasions, causes, or produces.","pos":""}],"OCCASIVE":[{"def":"Of or pertaining to the setting sun; falling; descending; western.","pos":""}],"OCCECATION":[{"def":"The act of making blind, or the state of being blind.","pos":""}],"OCCIDENT":[{"def":"The part of the horizon where the sun last appears in the evening; that part of the earth towards the sunset; the west; -- opposed to orient.","pos":""}],"OCCIDENTAL":[{"def":"Of, pertaining to, or situated in, the occident, or west; western; -- opposed to oriental; as, occidental climates, or customs; an occidental planet.","pos":""},{"def":"Possessing inferior hardness, brilliancy, or beauty; -- used of inferior precious stones and gems, because those found in the Orient are generally superior.","pos":""}],"OCCIDENTALS":[{"def":"Western Christians of the Latin rite.","pos":"noun"}],"OCCIDUOUS":[{"def":"Western; occidental.","pos":""}],"OCCIPITAL":[{"def":"Of or pertaining to the occiput, or back part of the head, or to the occipital bone.","pos":""}],"OCCIPITO-":[{"def":"A combining form denoting relation to, or situation near, the occiput; as, occipito-axial; occipito-mastoid.","pos":""}],"OCCIPITOAXIAL":[{"def":"Of or pertaining to the occipital bone and second vertebra, or axis.","pos":""}],"OCCIPUT":[{"def":"The back, or posterior, part of the head or skull; the region of the occipital bone.","pos":""},{"def":"A plate which forms the back part of the head of insects.","pos":""}],"OCCISION":[{"def":"A killing; the act of killing.","pos":""}],"OCCLUDE":[{"def":"To take in and retain; to absorb; -- said especially with respect to gases; as iron, platinum, and palladium occlude large volumes of hydrogen.","pos":""}],"OCCLUDENT":[{"def":"Serving to close; shutting up.","pos":""},{"def":"That which closes or shuts up.","pos":""}],"OCCLUSION":[{"def":"The transient approximation of the edges of a natural opening; imperforation.","pos":""}],"OCCRUSTATE":[{"def":"To incrust; to harden.","pos":""}],"OCCULT":[{"def":"Hidden from the eye or the understanding; inviable; secret; concealed; unknown.","pos":""}],"OCCULTATION":[{"def":"The hiding of a heavenly body from sight by the intervention of some other of the heavenly bodies; -- applied especially to eclipses of stars and planets by the moon, and to the eclipses of satellites of planets by their primaries.","pos":""}],"OCCULTED":[{"def":"Concealed by the intervention of some other heavenly body, as a star by the moon.","pos":""}],"OCCULTING":[{"def":"Same as Occultation.","pos":""}],"OCCULTISM":[{"def":"A certain Oriental system of theosophy.","pos":""}],"OCCULTIST":[{"def":"An adherent of occultism.","pos":""}],"OCCULTLY":[{"def":"In an occult manner.","pos":""}],"OCCULTNESS":[{"def":"State or quality of being occult.","pos":""}],"OCCUPANCY":[{"def":"The act of taking or holding possession; possession; occupation.","pos":""}],"OCCUPANT":[{"def":"One who occupies, or takes possession; one who has the actual use or possession, or is in possession, of a thing.","pos":""}],"OCCUPATION":[{"def":"The act or process of occupying or taking possession; actual possession and control; the state of being occupied; a holding or keeping; tenure; use; as, the occupation of lands by a tenant.","pos":""},{"def":"That which occupies or engages the time and attention; the principal business of one's life; vocation; employment; calling; trade.","pos":""}],"OCCUPIER":[{"def":"One who occupies, or has possession.","pos":""},{"def":"One who follows an employment; hence, a tradesman.","pos":""}],"OCCUPY":[{"def":"To take or hold possession of; to hold or keep for use; to possess.","pos":""},{"def":"To hold, or fill, the dimensions of; to take up the room or space of; to cover or fill; as, the camp occupies five acres of ground.","pos":""}],"OCCUR":[{"def":"To meet; to clash.","pos":""},{"def":"To go in order to meet; to make reply.","pos":""}],"OCCURRENCE":[{"def":"A coming or happening; as, the occurence of a railway collision.","pos":""},{"def":"Any incident or event; esp.","pos":""}],"OCCURRENT":[{"def":"Occurring or happening; hence, incidental; accidental.","pos":""}],"OCCURSE":[{"def":"Same as Occursion.","pos":""}],"OCCURSION":[{"def":"A meeting; a clash; a collision.","pos":""}]}