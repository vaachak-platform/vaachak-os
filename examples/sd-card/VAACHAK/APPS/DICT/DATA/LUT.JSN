{"LUTANIST":[{"def":"A person that plays on the lute.","pos":""}],"LUTARIOUS":[{"def":"Of, pertaining to, or like, mud; living in mud.","pos":""}],"LUTATION":[{"def":"The act or method of luting vessels.","pos":""}],"LUTE":[{"def":"A cement of clay or other tenacious infusible substance for sealing joints in apparatus, or the mouths of vessels or tubes, or for coating the bodies of retorts, etc.","pos":""},{"def":"A straight-edged piece of wood for striking off superfluous clay from mold.","pos":""}],"LUTE-BACKED":[{"def":"Having a curved spine.","pos":""}],"LUTECIUM":[{"def":"A metallic element separated from ytterbium in 1907, by Urbain in Paris and by von Welsbach in Vienna.","pos":""}],"LUTEIN":[{"def":"A substance of a strongly marked yellow color, extracted from the yelk of eggs, and from the tissue of the corpus luteum.","pos":""}],"LUTENIST":[{"def":"Same as Lutanist.","pos":""}],"LUTEO-":[{"def":"A combining form signifying orange yellow or brownish yellow.","pos":""}],"LUTEOCOBALTIC":[{"def":"Pertaining to, or designating, certain compounds of cobalt having a yellow color.","pos":""}],"LUTEOLIN":[{"def":"A yellow dyestuff obtained from the foliage of the dyer's broom (Reseda luteola).","pos":""}],"LUTEOUS":[{"def":"Yellowish; more or less like buff.","pos":""}],"LUTER":[{"def":"One who plays on a lute.","pos":""}],"LUTESCENT":[{"def":"Of a yellowish color.","pos":""}],"LUTESTRING":[{"def":"A plain, stout, lustrous silk, used for ladies' dresses and for ribbon.","pos":""}],"LUTH":[{"def":"The leatherback.","pos":""}],"LUTHERAN":[{"def":"Of or pertaining to Luther; adhering to the doctrines of Luther or the Lutheran Church.","pos":""}],"LUTHERN":[{"def":"A dormer window.","pos":""}],"LUTIDINE":[{"def":"Any one of several metameric alkaloids, C5H3N.","pos":""}],"LUTING":[{"def":"See Lute, a cement.","pos":""}],"LUTIST":[{"def":"One who plays on a lute.","pos":""}],"LUTOSE":[{"def":"Covered with clay; miry.","pos":""}],"LUTULENCE":[{"def":"The state or quality of being lutulent.","pos":""}],"LUTULENT":[{"def":"Muddy; turbid; thick.","pos":""}]}