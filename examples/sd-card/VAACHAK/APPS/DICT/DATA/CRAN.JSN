{"CRANAGE":[{"def":"The liberty of using a crane, as for loading and unloading vessels.","pos":""},{"def":"The money or price paid for the use of a crane.","pos":""}],"CRANBERRY":[{"def":"A red, acid berry, much used for making sauce, etc.","pos":""}],"CRANDALL":[{"def":"A kind of hammer having a head formed of a group of pointed steel bars, used for dressing ashlar, etc.","pos":""},{"def":"To dress with a crandall.","pos":""}],"CRANE":[{"def":"A wading bird of the genus Grus, and allied genera, of various species, having a long, straight bill, and long legs and neck.","pos":""},{"def":"A forked post or projecting bracket to support spars, etc.","pos":""}],"CRANE'S-BILL":[{"def":"The geranium; -- so named from the long axis of the fruit, which resembles the beak of a crane.","pos":""},{"def":"A pair of long-beaked forceps.","pos":""}],"CRANIA":[{"def":"A genus of living Brachiopoda; -- so called from its fancied resemblance to the cranium or skull.","pos":""}],"CRANIAL":[{"def":"Of or pertaining to the cranium.","pos":""}],"CRANIOCLASM":[{"def":"The crushing of a child's head, as with the cranioclast or craniotomy forceps in cases of very difficult delivery.","pos":""}],"CRANIOCLAST":[{"def":"An instrument for crushing the head of a fetus, to facilitate delivery in difficult eases.","pos":""}],"CRANIOFACIAL":[{"def":"Of or pertaining to the cranium and face; as, the craniofacial angle.","pos":""}],"CRANIOGNOMY":[{"def":"The science of the form and characteristics of the skull.","pos":""}],"CRANIOLOGICAL":[{"def":"Of or pertaining to craniology.","pos":""}],"CRANIOLOGIST":[{"def":"One proficient in craniology; a phrenologist.","pos":""}],"CRANIOLOGY":[{"def":"The department of science (as of ethnology or archæology) which deals with the shape, size, proportions, indications, etc.","pos":""}],"CRANIOMETER":[{"def":"An instrument for measuring the size of skulls.","pos":""},{"def":"Pertaining to craniometry.","pos":""}],"CRANIOMETRY":[{"def":"The art or act of measuring skulls.","pos":""}],"CRANIOSCOPIST":[{"def":"One skilled in, or who practices, cranioscopy.","pos":""}],"CRANIOSCOPY":[{"def":"Scientific examination of the cranium.","pos":""}],"CRANIOTA":[{"def":"A comprehensive division of the Vertebrata, including all those that have a skull.","pos":""}],"CRANIOTOMY":[{"def":"The operation of opening the fetal head, in order to effect delivery.","pos":""}],"CRANIUM":[{"def":"The skull of an animal; especially, that part of the skull, either cartilaginous or bony, which immediately incloses the brain; the brain case or brainpan.","pos":""}],"CRANK":[{"def":"A bent portion of an axle, or shaft, or an arm keyed at right angles to the end of a shaft, by which motion is imparted to or received from it; also used to change circular into reciprocating motion, or reciprocating into circular motion.","pos":""}],"CRANKBIRD":[{"def":"A small European woodpecker (Picus minor).","pos":""}],"CRANKED":[{"def":"Formed with, or having, a bend or crank; as, a cranked axle.","pos":""}],"CRANKINESS":[{"def":"Crank\"i*ness (krnk\"-ns), n.","pos":""}],"CRANKLE":[{"def":"To break into bends, turns, or angles; to crinkle.","pos":""}],"CRANKNESS":[{"def":"Liability to be overset; -- said of a ship or other vessel.","pos":""}],"CRANKY":[{"def":"Full of spirit; crank.","pos":""},{"def":"Addicted to crotchets and whims; unreasonable in opinions; crotchety.","pos":""}],"CRANNIED":[{"def":"Having crannies, chinks, or fissures; as, a crannied wall.","pos":""},{"def":"One of the stockaded islands in Scotland and Ireland which in ancient times were numerous in the lakes of both countries.","pos":""}],"CRANNY":[{"def":"A tool for forming the necks of bottles, etc.","pos":""}],"CRANTARA":[{"def":"The fiery cross, used as a rallying signal in the Highlands of Scotland.","pos":""}],"CRANTS":[{"def":"A garland carried before the bier of a maiden.","pos":""}]}