{"SALOL":[{"def":"A white crystalline substance consisting of phenol salicylate.","pos":""}],"SALON":[{"def":"An apartment for the reception of company; hence, in the plural, faschionable parties; circles of fashionable society.","pos":""}],"SALOON":[{"def":"A spacious and elegant apartment for the reception of company or for works of art; a hall of reception, esp.","pos":""},{"def":"Popularly, a public room for specific uses; esp.","pos":""}],"SALOOP":[{"def":"An aromatic drink prepared from sassafras bark and other ingredients, at one time much used in London.","pos":""}]}