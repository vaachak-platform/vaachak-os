{"FLAW":[{"def":"A crack or breach; a gap or fissure; a defect of continuity or cohesion; as, a flaw in a knife or a vase.","pos":""},{"def":"A defect; a fault; as, a flaw in reputation; a flaw in a will, in a deed, or in a statute.","pos":""}],"FLAWLESS":[{"def":"Free from flaws.","pos":""}],"FLAWN":[{"def":"A sort of flat custard or pie.","pos":""}],"FLAWTER":[{"def":"To scrape o [Obs.","pos":""}],"FLAWY":[{"def":"Full of flaws or cracks; broken; defective; faulty.","pos":""},{"def":"Subject to sudden flaws or gusts of wind.","pos":""}]}