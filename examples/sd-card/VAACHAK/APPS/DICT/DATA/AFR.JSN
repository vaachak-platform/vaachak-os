{"AFRAID":[{"def":"Impressed with fear or apprehension; in fear; apprehensive.","pos":""}],"AFRESH":[{"def":"Anew; again; once more; newly.","pos":""}],"AFRICAN":[{"def":"Of or pertaining to Africa.","pos":""}],"AFRICANDER":[{"def":"One born in Africa, the offspring of a white father and a \"colored\" mother.","pos":""}],"AFRICANISM":[{"def":"A word, phrase, idiom, or custom peculiar to Africa or Africans.","pos":""}],"AFRICANIZE":[{"def":"To place under the domination of Africans or negroes.","pos":""},{"def":"A powerful evil jinnee, demon, or monstrous giant.","pos":""}],"AFRONT":[{"def":"In front; face to face.","pos":""}]}