{"BAD":[{"def":"Wanting good qualities, whether physical or moral; injurious, hurtful, inconvenient, offensive, painful, unfavorable, or defective, either physically or morally; evil; vicious; wicked; -- the opposite of good; as a bad man; bad conduct; bad habits; bad soil; bad health; bad crop; bad news.","pos":""}],"BAD LANDS":[{"def":"Mauvaises Terres (bad lands).","pos":""}],"BADAUD":[{"def":"A person given to idle observation of everything, with wonder or astonishment; a credulous or gossipy idler.","pos":""}],"BADDER":[{"def":"Bad\"der, Defn: compar.","pos":""}],"BADDERLOCKS":[{"def":"A large black seaweed (Alaria esculenta) sometimes eaten in Europe; -- also called murlins, honeyware, and henware.","pos":""}],"BADDISH":[{"def":"Somewhat bad; inferior.","pos":""}],"BADE":[{"def":"A form of the pat tense of Bid.","pos":""}],"BADGE":[{"def":"A carved ornament on the stern of a vessel, containing a window or the representation of one.","pos":""}],"BADGELESS":[{"def":"Having no badge.","pos":""}],"BADGER":[{"def":"An itinerant licensed dealer in commodities used for food; a hawker; a huckster; -- formerly applied especially to one who bought grain in one place and sold it in another.","pos":""}],"BADGER GAME":[{"def":"The method of blackmailing by decoying a person into a compromising situation and extorting money by threats of exposure.","pos":""}],"BADGER STATE":[{"def":"Wisconsin; -- a nickname.","pos":""}],"BADGER-LEGGED":[{"def":"Having legs of unequal length, as the badger was thought to have.","pos":""}],"BADGERER":[{"def":"One who badgers.","pos":""},{"def":"A kind of dog used in badger baiting.","pos":""}],"BADGERING":[{"def":"The act of one who badgers.","pos":""},{"def":"The practice of buying wheat and other kinds of food in one place and selling them in another for a profit.","pos":""}],"BADIAGA":[{"def":"A fresh-water sponge (Spongilla), common in the north of Europe, the powder of which is used to take away the livid marks of bruises.","pos":""}],"BADIAN":[{"def":"An evergreen Chinese shrub of the Magnolia family (Illicium anisatum), and its aromatic seeds; Chinese anise; star anise.","pos":""}],"BADIGEON":[{"def":"A cement or paste (as of plaster and freestone, or of sawdust and glue or lime) used by sculptors, builders, and workers in wood or stone, to fill holes, cover defects, or finish a surface.","pos":""}],"BADINAGE":[{"def":"Playful raillery; banter.","pos":""}],"BADLY":[{"def":"In a bad manner; poorly; not well; unskillfully; imperfectly; unfortunately; grievously; so as to cause harm; disagreeably; seriously.","pos":""}],"BADMINTON":[{"def":"A game, similar to lawn tennis, played with shuttlecocks.","pos":""},{"def":"A preparation of claret, spiced and sweetened.","pos":""}],"BADNESS":[{"def":"The state of being bad.","pos":""}]}