{"CAPPADINE":[{"def":"A floss or waste obtained from the cocoon after the silk has been reeled off, used for shag.","pos":""}],"CAPPAPER":[{"def":"Cap\"pa`per, Defn: See cap, n.","pos":""}],"CAPPEAK":[{"def":"The front piece of a cap; -- now more commonly called visor.","pos":""}],"CAPPELINE":[{"def":"A hood-shaped bandage for the head, the shoulder, or the stump of an amputated limb.","pos":""}],"CAPPER":[{"def":"One whose business is to make or sell caps.","pos":""},{"def":"A by-bidder; a decoy for gamblers [Slang, U.","pos":""}],"CAPPING PLANE":[{"def":"A plane used for working the upper surface of staircase rails.","pos":""}]}