{"SEMPERVIRENT":[{"def":"Always fresh; evergreen.","pos":""}],"SEMPERVIVUM":[{"def":"A genus of fleshy-leaved plants, of which the houseleek (Sempervivum tectorum) is the commonest species.","pos":""}],"SEMPITERNAL":[{"def":"Of neverending duration; everlasting; endless; having beginning, but no end.","pos":""},{"def":"Without beginning or end; eternal.","pos":""}],"SEMPITERNITY":[{"def":"Future duration without end; the relation or state of being sempiternal.","pos":""}],"SEMPRE":[{"def":"Always; throughout; as, sempre piano, always soft.","pos":""}],"SEMPSTRESS":[{"def":"Two hundred sepstress were employed to make me shirts.","pos":""}]}