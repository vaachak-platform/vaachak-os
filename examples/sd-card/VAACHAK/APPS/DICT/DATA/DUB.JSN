{"DUB":[{"def":"To confer knight.","pos":""},{"def":"To invest with any dignity or new character; to entitle; to call.","pos":""}],"DUBB":[{"def":"The Syrian bear.","pos":""}],"DUBBER":[{"def":"One who, or that which, dubs.","pos":""}],"DUBBING":[{"def":"The act of dubbing, as a knight, etc.","pos":""},{"def":"The act of rubbing, smoothing, or dressing; a dressing off smooth with an adz.","pos":""}],"DUBIETY":[{"def":"Doubtfulness; uncertainty; doubt.","pos":""}],"DUBIOSITY":[{"def":"The state of being doubtful; a doubtful statement or thing.","pos":""}],"DUBIOUS":[{"def":"Doubtful or not settled in opinion; being in doubt; wavering or fluctuating; undetermined.","pos":""},{"def":"Occasioning doubt; not clear, or obvious; equivocal; questionable; doubtful; as, a dubious answer.","pos":""}],"DUBIOUSLY":[{"def":"In a dubious manner.","pos":""}],"DUBIOUSNESS":[{"def":"State of being dubious.","pos":""}],"DUBITABLE":[{"def":"Liable to be doubted; uncertain.","pos":""}],"DUBITANCY":[{"def":"Doubt; uncertainty.","pos":""}],"DUBITATION":[{"def":"Act of doubting; doubt.","pos":""}],"DUBITATIVE":[{"def":"Tending to doubt; doubtful.","pos":""}],"DUBOISIA":[{"def":"Same as Duboisine.","pos":""}],"DUBOISINE":[{"def":"An alkaloid obtained from the leaves of an Australian tree (Duboisia myoporoides), and regarded as identical with hyoscyamine.","pos":""}]}