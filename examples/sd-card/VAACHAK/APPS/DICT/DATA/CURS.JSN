{"CURSE":[{"def":"To call upon divine or supernatural power to send injury upon; to imprecate evil upon; to execrate.","pos":""},{"def":"To bring great evil upon; to be the cause of serious harm or unhappiness to; to furnish with that which will be a cause of deep trouble; to afflict or injure grievously; to harass or torment.","pos":""}],"CURSED":[{"def":"Deserving a curse; execrable; hateful; detestable; abominable.","pos":""}],"CURSEDLY":[{"def":"In a cursed manner; miserably; in a manner to be detested; enormously.","pos":""}],"CURSEDNESS":[{"def":"The state of being under a curse or of being doomed to execration or to evil.","pos":""},{"def":"Wickedness; sin; cursing.","pos":""}],"CURSHIP":[{"def":"The state of being a cur; one who is currish.","pos":""}],"CURSITATING":[{"def":"Moving about slightly.","pos":""}],"CURSITOR":[{"def":"An officer in the Court of Chancery, whose business is to make out original writs.","pos":""}],"CURSIVE":[{"def":"Running; flowing.","pos":""}],"CURSOR":[{"def":"Any part of a mathematical instrument that moves or slides backward and forward upon another part.","pos":""}],"CURSORARY":[{"def":"Cur\"so*ra*ry (-s-r-r), a.","pos":""}],"CURSORES":[{"def":"Cur*so\"res (kr-s\"rEz), n.","pos":""}],"CURSORIAL":[{"def":"Cur*so\"ri*al (kr-s\"r-al), a.","pos":""}],"CURSORILY":[{"def":"In a running or hasty manner; carelessly.","pos":""}],"CURSORINESS":[{"def":"The quality of being cursory; superficial performance; as, cursoriness of view.","pos":""}],"CURSORY":[{"def":"Running about; not stationary.","pos":""},{"def":"Characterized by haste; hastily or superficially performed; slight; superficial; careless.","pos":""}],"CURST":[{"def":"Curst (krst), Defn: imp.","pos":""}],"CURSTFULLY":[{"def":"Peevishly; vexatiously; detestably.","pos":""}],"CURSTNESS":[{"def":"Peevishness; malignity; frowardness; crabbedness; surliness.","pos":""}]}