{"GECARCINIAN":[{"def":"A land crab of the genus Gecarcinus, or of allied genera.","pos":""}],"GECK":[{"def":"Scorn, derision, or contempt.","pos":""},{"def":"An object of scorn; a dupe; a gull.","pos":""}],"GECKO":[{"def":"Any lizard of the family Geckonidæ.","pos":""}],"GECKOTIAN":[{"def":"The European pike.","pos":""}]}