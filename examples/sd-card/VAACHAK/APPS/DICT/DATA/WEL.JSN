{"WEL-BEGONE":[{"def":"Surrounded with happiness or prosperity.","pos":""}],"WELAWAY":[{"def":"Then welaway, for she undone was clean.","pos":""}],"WELCOME":[{"def":"Received with gladness; admitted willingly to the house, entertainment, or company; as, a welcome visitor.","pos":""},{"def":"Producing gladness; grateful; as, a welcome present; welcome news.","pos":""}],"WELCOMELY":[{"def":"In a welcome manner.","pos":""}],"WELCOMENESS":[{"def":"The quality or state of being welcome; gratefulness; agreeableness; kind reception.","pos":""}],"WELCOMER":[{"def":"One who welcomes; one who salutes, or receives kindly, a newcomer.","pos":""}],"WELD":[{"def":"An herb (Reseda luteola) related to mignonette, growing in Europe, and to some extent in America; dyer's broom; dyer's rocket; dyer's weed; wild woad.","pos":""}],"WELD STEEL":[{"def":"A compound of iron, such as puddled steel, made without complete fusion.","pos":""}],"WELDABLE":[{"def":"Capable of being welded.","pos":""}],"WELDER":[{"def":"One who welds, or unites pieces of iron, etc.","pos":""}],"WELDON'S PROCESS":[{"def":"A process for the recovery or regeneration of manganese dioxide in the manufacture of chlorine, by means of milk of lime and the oxygen of the air; -- so called after the inventor.","pos":""}],"WELE":[{"def":"Prosperity; happiness; well-being; weal.","pos":""}],"WELEFUL":[{"def":"Producing prosperity or happiness; blessed.","pos":""}],"WELEW":[{"def":"To welk, or wither.","pos":""}],"WELFARE":[{"def":"Well-doing or well-being in any respect; the enjoyment of health and the common blessings of life; exemption from any evil or calamity; prosperity; happiness.","pos":""}],"WELFARING":[{"def":"Faring well; prosperous; thriving.","pos":""}],"WELK":[{"def":"To wither; to fade; also, to decay; to decline; to wane.","pos":""}],"WELKIN":[{"def":"The visible regions of the air; the vault of heaven; the sky.","pos":""}],"WELL":[{"def":"A hole or excavation in the earth, in mining, from which run branches or galleries.","pos":""},{"def":"An opening through the floors of a building, as for a staircase or an elevator; a wellhole.","pos":""}],"WELL-BEING":[{"def":"The state or condition of being well; welfare; happiness; prosperity; as, virtue is essential to the well-being of men or of society.","pos":""}],"WELL-BORN":[{"def":"Born of a noble or respect able family; not of mean birth.","pos":""}],"WELL-BRED":[{"def":"Having good breeding; refined in manners; polite; cultivated.","pos":""}],"WELL-FAVORED":[{"def":"Handsome; wellformed; beautiful; pleasing to the eye.","pos":""}],"WELL-INFORMED":[{"def":"Correctly informed; provided with information; well furnished with authentic knowledge; intelligent.","pos":""}],"WELL-INTENTIONED":[{"def":"Having upright intentions or honorable purposes.","pos":""}],"WELL-KNOWN":[{"def":"Fully known; generally known or acknowledged.","pos":""}],"WELL-LIKING":[{"def":"Being in good condition.","pos":""}],"WELL-MANNERED":[{"def":"Polite; well-bred; complaisant; courteous.","pos":""}],"WELL-MEANER":[{"def":"One whose intention is good.","pos":""}],"WELL-MEANING":[{"def":"Having a good intention.","pos":""}],"WELL-NATURED":[{"def":"Good-natured; kind.","pos":""}],"WELL-PLIGHTED":[{"def":"Being well folded.","pos":""}],"WELL-READ":[{"def":"Of extensive reading; deeply versed; -- often followed by in.","pos":""}],"WELL-SEEN":[{"def":"Having seen much; hence, accomplished; experienced.","pos":""}],"WELL-SET":[{"def":"Properly or firmly set.","pos":""},{"def":"Well put together; having symmetry of parts.","pos":""}],"WELL-SPED":[{"def":"Having good success.","pos":""}],"WELL-SPOKEN":[{"def":"Speaking well; speaking with fitness or grace; speaking kindly.","pos":""},{"def":"Spoken with propriety; as, well-spoken words.","pos":""}],"WELL-WILLER":[{"def":"One who wishes well, or means kindly.","pos":""}],"WELL-WISH":[{"def":"A wish of happiness.","pos":""}],"WELLADAY":[{"def":"Alas! Welaway! Shak.","pos":""}],"WELLAT":[{"def":"The king parrakeet See under King.","pos":""}],"WELLDOER":[{"def":"One who does well; one who does good to another; a benefactor.","pos":""}],"WELLDOING":[{"def":"A doing well; right performance of duties.","pos":""}],"WELLDRAIN":[{"def":"To drain, as land; by means of wells, or pits, which receive the water, and from which it is discharged by machinery.","pos":""}],"WELLHEAD":[{"def":"A source, spring, or fountain.","pos":""}],"WELLHOLE":[{"def":"A cavity which receives a counterbalancing weight in certain mechanical contrivances, and is adapted also for other purposes.","pos":""}],"WELLINGTON BOOT":[{"def":"A riding boot for men, the front of which came above the knee; also, a similar shorter boot worn under the trousers.","pos":""}],"WELLINGTONIA":[{"def":"A name given to the \"big trees\" (Sequoia gigantea) of California, and still used in England.","pos":""}],"WELLINGTONS":[{"def":"A kind of long boots for men.","pos":""}],"WELLSPRING":[{"def":"A fountain; a spring; a source of continual supply.","pos":""}],"WELLWISHER":[{"def":"One who wishes another well; one who is benevolently or friendlily inclined.","pos":""}],"WELS":[{"def":"The sheatfish; -- called also waller.","pos":""}],"WELSBACH":[{"def":"Of or pertaining to Auer von Welsbach or the incandescent gas burner invented by him.","pos":""}],"WELSH":[{"def":"Of or pertaining to Wales, or its inhabitants.","pos":""}],"WELSHER":[{"def":"One who cheats at a horse race; one who bets, without a chance of being able to pay; one who receives money to back certain horses and absconds with it.","pos":""}],"WELSHMAN":[{"def":"A native or inhabitant of Wales; one of the Welsh.","pos":""}],"WELSOME":[{"def":"Prosperous; well.","pos":""}],"WELT":[{"def":"A narrow border, as of an ordinary, but not extending around the ends.","pos":""}],"WELTER":[{"def":"To roll, as the body of an animal; to tumble about, especially in anything foul or defiling; to wallow.","pos":""},{"def":"To rise and fall, as waves; to tumble over, as billows.","pos":""}],"WELTERWEIGHT":[{"def":"A boxer or wrestler whose weight is intermediate between that of a lightweight and that of a middleweight.","pos":""}],"WELTSCHMERTZ":[{"def":"Sorrow or sadness over the present or future evils or woes of the world in general; sentimental pessimism.","pos":""}],"WELWITSCHIA":[{"def":"An African plant (Welwitschia mirabilis) belonging to the order Gnetaceæ.","pos":""}]}