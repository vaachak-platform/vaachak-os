{"INVOCATE":[{"def":"To invoke; to call on, or for, in supplication; to implore.","pos":""}],"INVOCATION":[{"def":"A call or summons; especially, a judicial call, demand, or order; as, the invocation of papers or evidence into court.","pos":""}],"INVOCATORY":[{"def":"Making or containing invocation; invoking.","pos":""}],"INVOICE":[{"def":"A written account of the particulars of merchandise shipped or sent to a purchaser, consignee, factor, etc.","pos":""}],"INVOKE":[{"def":"To call on for aid or protection; to invite earnestly or solemnly; to summon; to address in prayer; to solicit or demand by invocation; to implore; as, to invoke the Supreme Being, or to invoke His and blessing.","pos":""}],"INVOLUCEL":[{"def":"A partial, secondary, or small involucre.","pos":""}],"INVOLUCELLATE":[{"def":"Furnished with involucels.","pos":""}],"INVOLUCRAL":[{"def":"Pertaining to, possessing, or like, an involucrum.","pos":""},{"def":"Having an involucre; involucred.","pos":""}],"INVOLUCRED":[{"def":"Having an involucre, as umbels, heads, etc.","pos":""}],"INVOLUCRUM":[{"def":"A sheath which surrounds the base of the lasso cells in the Siphonophora.","pos":""}],"INVOLUNTARILY":[{"def":"In an involuntary manner; not voluntarily; not intentionally or willingly.","pos":""}],"INVOLUNTARINESS":[{"def":"The quality or state of being involuntary; unwillingness; automatism.","pos":""}],"INVOLUNTARY":[{"def":"Rolled inward from the edges; -- said of leaves in vernation, or of the petals of flowers in æstivation.","pos":""}],"INVOLUTE":[{"def":"A curve traced by the end of a string wound upon another curve, or unwound from it; -- called also evolvent.","pos":""}],"INVOLUTION":[{"def":"The insertion of one or more clauses between the subject and the verb, in a way that involves or complicates the construction.","pos":""},{"def":"The act or process of raising a quantity to any power assigned; the multiplication of a quantity into itself a given number of times; -- the reverse of evolution.","pos":""}],"INVOLVE":[{"def":"To raise to any assigned power; to multiply, as a quantity, into itself a given number of times; as, a quantity involved to the third or fourth power.","pos":""}],"INVOLVED":[{"def":"Same as Involute.","pos":""}],"INVOLVEDNESS":[{"def":"The state of being involved.","pos":""}],"INVOLVEMENT":[{"def":"The act of involving, or the state of being involved.","pos":""}]}