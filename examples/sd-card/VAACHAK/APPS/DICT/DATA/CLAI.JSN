{"CLAIM":[{"def":"To ask for, or seek to obtain, by virtue of authority, right, or supposed right; to challenge as a right; to demand as due.","pos":""}],"CLAIMABLE":[{"def":"Capable of being claimed.","pos":""}],"CLAIMANT":[{"def":"One who claims; one who asserts a right or title; a claimer.","pos":""}],"CLAIMER":[{"def":"One who claims; a claimant.","pos":""}],"CLAIMLESS":[{"def":"Having no claim.","pos":""}],"CLAIR-OBSCUR":[{"def":"See Chiaroscuro.","pos":""}],"CLAIRAUDIENCE":[{"def":"Act of hearing, or the ability to hear, sounds not normally audible; -- usually claimed as a special faculty of spiritualistic mediums, or the like.","pos":""}],"CLAIRAUDIENT":[{"def":"Pertaining to, or characterized by, clairaudience.","pos":""}],"CLAIRE":[{"def":"A small inclosed pond used for gathering and greening oysters.","pos":""}],"CLAIRVOYANCE":[{"def":"A power, attributed to some persons while in a mesmeric state, of discering objects not perceptible by the senses in their normal condition.","pos":""}],"CLAIRVOYANT":[{"def":"Pertaining to clairvoyance; discerning objects while in a mesmeric state which are not present to the senses.","pos":""}]}