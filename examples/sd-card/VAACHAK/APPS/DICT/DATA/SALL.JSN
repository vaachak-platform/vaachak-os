{"SALLENDERS":[{"def":"An eruption on the hind leg of a horse.","pos":""}],"SALLET":[{"def":"A light kind of helmet, with or without a visor, introduced during the 15th century.","pos":""}],"SALLOW":[{"def":"A name given to certain species of willow, especially those which do not have flexible shoots, as Salix caprea, S.","pos":""}],"SALLOWISH":[{"def":"Somewhat sallow.","pos":""}],"SALLOWNESS":[{"def":"The quality or condition of being sallow.","pos":""}],"SALLY":[{"def":"To leap or rush out; to burst forth; to issue suddenly; as a body of troops from a fortified place to attack besiegers; to make a sally.","pos":""}],"SALLY LUNN":[{"def":"A tea cake slighty sweetened, and raised with yeast, baked in the form of biscuits or in a thin loaf, and eaten hot with butter.","pos":""}],"SALLYMAN":[{"def":"The velella; -- called also saleeman.","pos":""}]}