{"BOA":[{"def":"A genus of large American serpents, including the boa constrictor, the emperor boa of Mexico (B.","pos":""}],"BOA CONSTRICTOR":[{"def":"A large and powerful serpent of tropical America, sometimes twenty or thirty feet long.","pos":""}],"BOANERGES":[{"def":"Any declamatory and vociferous preacher or orator.","pos":""}],"BOAR":[{"def":"The uncastrated male of swine; specifically, the wild hog.","pos":""}],"BOARD":[{"def":"The stage in a theater; as, to go upon the boards, to enter upon the theatrical profession.","pos":""},{"def":"The border or side of anything.","pos":""}],"BOARDABLE":[{"def":"That can be boarded, as a ship.","pos":""}],"BOARDER":[{"def":"One who boards a ship; one selected to board an enemy's ship.","pos":""}],"BOARDING":[{"def":"The act of entering a ship, whether with a hostile or a friendly purpose.","pos":""}],"BOARISH":[{"def":"Swinish; brutal; cruel.","pos":""}],"BOAST":[{"def":"To vaunt one's self; to brag; to say or tell things which are intended to give others a high opinion of one's self or of things belonging to one's self; as, to boast of one's exploits courage, descent, wealth.","pos":""},{"def":"To speak in exulting language of another; to glory; to exult.","pos":""}],"BOASTER":[{"def":"One who boasts; a braggart.","pos":""}],"BOASTFUL":[{"def":"Given to, or full of, boasting; inclined to boast; vaunting; vainglorious; self-praising.","pos":""}],"BOASTING":[{"def":"The act of glorying or vaunting; vainglorious speaking; ostentatious display.","pos":""}],"BOASTINGLY":[{"def":"Boastfully; with boasting.","pos":""}],"BOASTLESS":[{"def":"Without boasting or ostentation.","pos":""}],"BOAT":[{"def":"A small open vessel, or water craft, usually moved by cars or paddles, but often by a sail.","pos":""},{"def":"Hence, any vessel; usually with some epithet descriptive of its use or mode of propulsion; as, pilot boat, packet boat, passage boat, advice boat, etc.","pos":""}],"BOAT BUG":[{"def":"An aquatic hemipterous insect of the genus Notonecta; -- so called from swimming on its back, which gives it the appearance of a little boat.","pos":""}],"BOAT-TAIL":[{"def":"A large grackle or blackbird (Quiscalus major), found in the Southern United States.","pos":""}],"BOATABLE":[{"def":"Such as can be transported in a boat.","pos":""},{"def":"Navigable for boats, or small river craft.","pos":""}],"BOATAGE":[{"def":"Conveyance by boat; also, a charge for such conveyance.","pos":""}],"BOATBILL":[{"def":"A wading bird (Cancroma cochlearia) of the tropical parts of South America.","pos":""},{"def":"A perching bird of India, of the genus Eurylaimus.","pos":""}],"BOATFUL":[{"def":"The quantity or amount that fills a boat.","pos":""}],"BOATHOUSE":[{"def":"A house for sheltering boats.","pos":""}],"BOATING":[{"def":"The act or practice of rowing or sailing, esp.","pos":""},{"def":"In Persia, a punishment of capital offenders, by laying them on the back in a covered boat, where they are left to perish.","pos":""}],"BOATION":[{"def":"A crying out; a roaring; a bellowing; reverberation.","pos":""}],"BOATMAN":[{"def":"A man who manages a boat; a rower of a boat.","pos":""}],"BOATMANSHIP":[{"def":"The art of managing a boat.","pos":""}],"BOATSWAIN":[{"def":"An officer who has charge of the boats, sails, rigging, colors, anchors, cables, cordage, etc.","pos":""}],"BOATWOMAN":[{"def":"A woman who manages a boat.","pos":""}]}