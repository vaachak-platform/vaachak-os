{"GIALLOLINO":[{"def":"A term variously employed by early writers on art, though commonly designating the yellow oxide of lead, or massicot.","pos":""}],"GIAMBEUX":[{"def":"Greaves; armor for the legs.","pos":""}],"GIANT":[{"def":"A man of extraordinari bulk and stature.","pos":""},{"def":"A person of extraordinary strength or powers, bodily or intellectual.","pos":""}],"GIANTESS":[{"def":"A woman of extraordinary size.","pos":""}],"GIANTIZE":[{"def":"To play the giant.","pos":""}],"GIANTLY":[{"def":"Appropriate to a giant.","pos":""}],"GIANTRY":[{"def":"The race of giants.","pos":""}],"GIANTSHIP":[{"def":"The state, personality, or character, of a giant; -- a compellation for a giant.","pos":""}],"GIAOUR":[{"def":"An infidel; -- a term applied by Turks to disbelievers in the Mohammedan religion, especially Christrians.","pos":""}],"GIB":[{"def":"A male cat; a tomcat.","pos":""}],"GIB-CAT":[{"def":"A male cat, esp.","pos":""}],"GIBARO":[{"def":"The offspring of a Spaniard and an Indian; a Spanish-Indian mestizo.","pos":""}],"GIBBARTAS":[{"def":"One of several finback whales of the North Atlantic; -- called also Jupiter whale.","pos":""}],"GIBBER":[{"def":"To speak rapidly and inarticulately.","pos":""}],"GIBBERISH":[{"def":"Rapid and inarticulate talk; unintelligible language; unmeaning words; jargon.","pos":""}],"GIBBET":[{"def":"A kind of gallows; an upright post with an arm projecting from the top, on which, formerly, malefactors were hanged in chains, and their bodies allowed to remain asa warning.","pos":""},{"def":"The projecting arm of a crane, from which the load is suspended; the jib.","pos":""}],"GIBBIER":[{"def":"Wild fowl; game.","pos":""}],"GIBBON":[{"def":"Any arboreal ape of the genus Hylobates, of which many species and varieties inhabit the East Indies and Southern Asia.","pos":""}],"GIBBOSE":[{"def":"Humped; protuberant; -- said of a surface which presents one or more large elevations.","pos":""}],"GIBBOSTITY":[{"def":"The state of being gibbous or gibbose; gibbousness.","pos":""}],"GIBBOUS":[{"def":"Swelling by a regular curve or surface; protuberant; convex; as, the moon is gibbous between the half-moon and the full moon.","pos":""},{"def":"Hunched; hump-backed.","pos":""}],"GIBBSITE":[{"def":"A hydrate of alumina.","pos":""}],"GIBE":[{"def":"To cast reproaches and sneering expressions; to rail; to utter taunting, sarcastic words; to flout; to fleer; to scoff.","pos":""}],"GIBEL":[{"def":"A kind of carp (Cyprinus gibelio); -- called also Prussian carp.","pos":""}],"GIBER":[{"def":"One who utters gibes.","pos":""}],"GIBFISH":[{"def":"The male of the salmon.","pos":""}],"GIBINGLY":[{"def":"In a gibing manner; scornfully.","pos":""}],"GIBLET":[{"def":"Made of giblets; as, a giblet pie.","pos":""}],"GIBLETS":[{"def":"The inmeats, or edible viscera (heart, gizzard, liver, etc.","pos":""}],"GIBRALTAR":[{"def":"A strongly fortified town on the south coast of Spain, held by the British since 1704; hence, an impregnable stronghold.","pos":""},{"def":"A kind of candy sweetmeat, or a piece of it; -- called, in full, Gibraltar rock.","pos":""}],"GIBSTAFF":[{"def":"A staff to guage water, or to push a boat.","pos":""},{"def":"A staff formerly used in fighting beasts on the stage.","pos":""}],"GID":[{"def":"A disease of sheep, characterized by vertigo; the staggers.","pos":""}],"GIDDILY":[{"def":"In a giddy manner.","pos":""}],"GIDDINESS":[{"def":"The quality or state of being giddy.","pos":""}],"GIDDY":[{"def":"Having in the head a sensation of whirling or reeling about; having lost the power of preserving the balance of the body, and therefore wavering and inclined to fall; lightheaded; dizzy.","pos":""},{"def":"Promoting or inducing giddiness; as, a giddy height; a giddy precipice.","pos":""}],"GIDDY-HEAD":[{"def":"A person without thought fulness, prudence, or judgment.","pos":""}],"GIDDY-HEADED":[{"def":"Thoughtless; unsteady.","pos":""}],"GIDDY-PACED":[{"def":"Moving irregularly; flighty; fickle.","pos":""}],"GIER-EAGLE":[{"def":"A bird referred to in the Bible (Lev.","pos":""}],"GIESECKITE":[{"def":"A mineral occurring in greenish gray six-sided prisms, having a greasy luster.","pos":""}],"GIF":[{"def":"Note: Gif is the old form of if, and frequently occurs in the earlier English writers.","pos":""}],"GIFFARD INJECTOR":[{"def":"See under Injector.","pos":""}],"GIFFGAFF":[{"def":"Mutial accommodation; mutual giving.","pos":""}],"GIFT":[{"def":"A voluntary transfer of real or personal property, without any consideration.","pos":""}],"GIFTEDNESS":[{"def":"The state of being gifted.","pos":""}],"GIG":[{"def":"A kind of spear or harpoon.","pos":""}],"GIGANTEAN":[{"def":"Like a giant; mighty; gigantic.","pos":""}],"GIGANTESQUE":[{"def":"Befitting a giant; bombastic; magniloquent.","pos":""}],"GIGANTIC":[{"def":"Of extraordinary size; like a giant.","pos":""},{"def":"Such as a giant might use, make, or cause; immense; tremendous; extraordinarly; as, gigantic deeds; gigantic wickedness.","pos":""}],"GIGANTICIDE":[{"def":"The act of killing, or one who kills, a giant.","pos":""}],"GIGANTOLOGY":[{"def":"An account or description of giants.","pos":""}],"GIGANTOMACHY":[{"def":"A war of giants; especially, the fabulous war of the giants against heaven.","pos":""},{"def":"The leather strap by which the shield of a knight was slung across the shoulder, or across the neck and shoulder.","pos":""}],"GIGERIUM":[{"def":"The muscular stomach, or gizzard, of birds.","pos":""}],"GIGGET":[{"def":"Cut the slaves to giggets.","pos":""}],"GIGGLE":[{"def":"To laugh with short catches of the breath or voice; to laugh in a light, affected, or silly manner; to titter with childish levity.","pos":""}],"GIGGLER":[{"def":"One who giggles or titters.","pos":""}],"GIGGLY":[{"def":"Prone to giggling.","pos":""}],"GIGGYNG":[{"def":"The act of fastending the gige or leather strap to the shield.","pos":""},{"def":"A wanton; a lascivious or light, giddy girl.","pos":""}],"GIGLOT":[{"def":"Giddi; light; inconstant; wanton.","pos":""}],"GIGUE":[{"def":"A piece of lively dance music, in two strains which are repeated; also, the dance.","pos":""}],"GILA MONSTER":[{"def":"A large tuberculated lizard (Heloderma suspectum) native of the dry plains of Arizona, New Mexico, etc.","pos":""}],"GILD":[{"def":"To overlay with a thin covering of gold; to cover with a golden color; to cause to look like gold.","pos":""},{"def":"To make attractive; to adorn; to brighten.","pos":""}],"GILDALE":[{"def":"A drinking bout in which every one pays an equal share.","pos":""}],"GILDER":[{"def":"One who gilds; one whose occupation is to overlay with gold.","pos":""}],"GILDING":[{"def":"The art or practice of overlaying or covering with gold leaf; also, a thin coating or wash of gold, or of that which resembles gold.","pos":""},{"def":"Gold in leaf, powder, or liquid, for application to any surface.","pos":""}],"GILL":[{"def":"An organ for aquatic respiration; a branchia.","pos":""},{"def":"The radiating, gill-shaped plates forming the under surface of a mushroom.","pos":""}],"GILL-FLIRT":[{"def":"A thoughtless, giddy girl; a flirt-gill.","pos":""}],"GILLHOUSE":[{"def":"A shop where gill is sold.","pos":""}],"GILLIAN":[{"def":"A boy or young man; a manservant; a male attendant, in the Scottish Highlands.","pos":""}],"GILLYFLOWER":[{"def":"A name given by old writers to the clove pink (Dianthus Caryophyllus) but now to the common stock (Matthiola incana), a cruciferous plant with showy and fragrant blossoms, usually purplish, but often pink or white.","pos":""},{"def":"A kind of apple, of a roundish conical shape, purplish red color, and having a large core.","pos":""}],"GILOUR":[{"def":"A guiler; deceiver.","pos":""}],"GILT":[{"def":"A female pig, when young.","pos":""}],"GILTTAIL":[{"def":"A yellow-tailed worm or larva.","pos":""}],"GIM":[{"def":"A contrivance for permitting a body to incline freely in all directions, or for suspending anything, as a barometer, ship's compass, chronometer, etc.","pos":""}],"GIMCRACK":[{"def":"A trivial mechanism; a device; a toy; a pretty thing.","pos":""}],"GIMLET":[{"def":"A small tool for boring holes.","pos":""}],"GIMMAL":[{"def":"Joined work whose parts move within each other; a pair or series of interlocked rings.","pos":""},{"def":"A quaint piece of machinery; a gimmer.","pos":""}],"GIMP":[{"def":"Smart; spruce; trim; nice.","pos":""}],"GIN":[{"def":"Against; near by; towards; as, gin night.","pos":""}],"GING":[{"def":"Same as Gang, n.","pos":""}],"GINGER":[{"def":"A plant of the genus Zingiber, of the East and West Indies.","pos":""}],"GINGERBREAD":[{"def":"A kind of plain sweet cake seasoned with ginger, and sometimes made in fanciful shapes.","pos":""}],"GINGERLY":[{"def":"Cautiously; timidly; fastidiously; daintily.","pos":""}],"GINGERNESS":[{"def":"Cautiousness; tenderness.","pos":""}],"GINGHAM":[{"def":"A kind of cotton or linen cloth, usually in stripes or checks, the yarn of which is dyed before it is woven; -- distinguished from printed cotton or prints.","pos":""}],"GINGING":[{"def":"The lining of a mine shaft with stones or bricks to prevent caving.","pos":""}],"GINGIVAL":[{"def":"Of or pertaining to the gums.","pos":""}],"GINGLYMODI":[{"def":"An order of ganoid fishes, including the modern gar pikes and many allied fossil forms.","pos":""},{"def":"Pertaining to, or resembling, a ginglymus, or hinge joint; ginglyform.","pos":""}],"GINGLYMUS":[{"def":"A hinge joint; an articulation, admitting of flexion and extension, or motion in two directions only, as the elbow and the ankle.","pos":""}],"GINHOUSE":[{"def":"A building where cotton is ginned.","pos":""}],"GINKGO":[{"def":"A large ornamental tree (Ginkgo biloba) from China and Japan, belonging to the Yew suborder of Coniferæ.","pos":""}],"GINNET":[{"def":"See Genet, a horse.","pos":""}],"GINNY-CARRIAGE":[{"def":"A small, strong carriage for conveying materials on a railroad.","pos":""}],"GINSENG":[{"def":"A plant of the genus Aralia, the root of which is highly valued as a medicine among the Chinese.","pos":""}],"GINSHOP":[{"def":"A shop or barroom where gin is sold as a beverage.","pos":""}],"GIP":[{"def":"To take out the entrails of (herrings).","pos":""}],"GIPOUN":[{"def":"A short cassock.","pos":""},{"def":"A kind of pouch formerly worn at the girdle.","pos":""}],"GIRAFFE":[{"def":"An African ruminant (Camelopardalis giraffa) related to the deers and antelopes, but placed in a family by itself; the camelopard.","pos":""}],"GIRANDOLE":[{"def":"A kind of revolving firework.","pos":""},{"def":"A series of chambers in defensive mines.","pos":""}],"GIRD":[{"def":"A stroke with a rod or switch; a severe spasm; a twinge; a pang.","pos":""},{"def":"A cut; a sarcastic remark; a gibe; a sneer.","pos":""}],"GIRDER":[{"def":"One who girds; a satirist.","pos":""}],"GIRDING":[{"def":"That with which one is girded; a girdle.","pos":""}],"GIRDLE":[{"def":"The line ofgreatest circumference of a brilliant-cut diamond, at which it is grasped by the setting.","pos":""},{"def":"A thin bed or stratum of stone.","pos":""}],"GIRDLER":[{"def":"An American longicorn beetle (Oncideres cingulatus) which lays its eggs in the twigs of the hickory, and then girdles each branch by gnawing a groove around it, thus killing it to provide suitable food for the larvæ.","pos":""}],"GIRDLESTEAD":[{"def":"That part of the body where the girdle is worn.","pos":""}],"GIRL":[{"def":"A roebuck two years old.","pos":""}],"GIRLHOOD":[{"def":"State or time of being a girl.","pos":""}],"GIRLISH":[{"def":"Like, or characteristic of, a girl; of or pertaining to girlhood; innocent; artless; immature; weak; as, girlish ways; girlish grief.","pos":""}],"GIRLOND":[{"def":"A garland; a prize.","pos":""}],"GIRONDIST":[{"def":"A member of the moderate republican party formed in the French legislative assembly in 1791.","pos":""}],"GIRT":[{"def":"To gird; to encircle; to invest by means of a girdle; to measure the girth of; as, to girt a tree.","pos":""}],"GIRTH":[{"def":"A band or strap which encircles the body; especially, one by which a saddle is fastened upon the back of a horse.","pos":""},{"def":"The measure round the body, as at the waist or belly; the circumference of anything.","pos":""}],"GISARM":[{"def":"A weapon with a scythe-shaped blade, and a separate long sharp point, mounted on a long staff and carried by foot soldiers.","pos":""}],"GISE":[{"def":"To feed or pasture.","pos":""}],"GISLE":[{"def":"A native hydrated silicate of alumina, lime, and potash, first noticed near Rome.","pos":""}],"GIST":[{"def":"A resting place.","pos":""},{"def":"The main point, as of a question; the point on which an action rests; the pith of a matter; as, the gist of a question.","pos":""}],"GIT":[{"def":"A Spanish gypsy.","pos":""}],"GITE":[{"def":"She came often in a gite of red.","pos":""}],"GITH":[{"def":"The corn cockle; also anciently applied to the Nigella, or fennel flower.","pos":""}],"GITTERN":[{"def":"An instrument like a guitar.","pos":""}],"GITTITH":[{"def":"A musical instrument, of unknown character, supposed by some to have been used by the people of Gath, and thence obtained by David.","pos":""}],"GIUSTO":[{"def":"In just, correct, or suitable time.","pos":""}],"GIVE":[{"def":"To set forth as a known quantity or a known relation, or as a premise from which to reason; -- used principally in the passive form given.","pos":""}],"GIVEN":[{"def":"Granted; assumed; supposed to be known; set forth as a known quantity, relation, or premise.","pos":""}],"GIVER":[{"def":"One who gives; a donor; a bestower; a grantor; one who imparts or distributes.","pos":""}],"GIVING":[{"def":"The act of bestowing as a gift; a conferring or imparting.","pos":""},{"def":"A gift; a benefaction.","pos":""}],"GIZZARD":[{"def":"The second, or true, muscular stomach of birds, in which the food is crushed and ground, after being softened in the glandular stomach (crop), or lower part of the esophagus; the gigerium.","pos":""}]}