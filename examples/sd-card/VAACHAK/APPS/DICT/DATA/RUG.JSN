{"RUG":[{"def":"A kind of coarse, heavy frieze, formerly used for garments.","pos":""},{"def":"A piece of thick, nappy fabric, commonly made of wool, -- used for various purposes, as for covering and ornamenting part of a bare floor, for hanging in a doorway as a potière, for protecting a portion of carpet, for a wrap to protect the legs from cold, etc.","pos":""}],"RUG-GOWNED":[{"def":"Wearing a coarse gown or shaggy garment made of rug.","pos":""}],"RUG-HEADED":[{"def":"Having shaggy hair; shock-headed.","pos":""}],"RUGA":[{"def":"A wrinkle; a fold; as, the rugæ of the stomach.","pos":""}],"RUGATE":[{"def":"Having alternate ridges and depressions; wrinkled.","pos":""}],"RUGGED":[{"def":"Full of asperities on the surface; broken into sharp or irregular points, or otherwise uneven; not smooth; rough; as, a rugged mountain; a rugged road.","pos":""},{"def":"Not neat or regular; uneven.","pos":""}],"RUGGING":[{"def":"A coarse kind of woolen cloth, used for wrapping, blanketing, etc.","pos":""}],"RUGINE":[{"def":"An instrument for scraping the periosteum from bones; a raspatory.","pos":""}],"RUGOSA":[{"def":"An extinct tribe of fossil corals, including numerous species, many of them of large size.","pos":""}],"RUGOSE":[{"def":"Wrinkled; full of wrinkles; specifically (Bot.","pos":""}],"RUGOSITY":[{"def":"The quality or state of being rugose.","pos":""}],"RUGOUS":[{"def":"Wrinkled; rugose.","pos":""}],"RUGULOSE":[{"def":"Somewhat rugose.","pos":""}]}