{"POM-POM":[{"def":"A Vickers-Maxim one-pounder automatic machine cannon using metallic ammunition fed from a lopped belt attached to the gun; -- popularly so called from its peculiar drumming sound in action.","pos":""}],"POMACE":[{"def":"The substance of apples, or of similar fruit, crushed by grinding.","pos":""}],"POMACENTROID":[{"def":"Pertaining to the Pomacentridæ, a family of bright-colored tropical fishes having spiny opercula; -- often called coral fishes.","pos":""}],"POMADE":[{"def":"Perfumed ointment; esp.","pos":""}],"POMARINE":[{"def":"Having the nostril covered with a scale.","pos":""}],"POMATUM":[{"def":"A perfumed unguent or composition, chiefly used in dressing the hair; pomade.","pos":""}],"POME":[{"def":"A fruit composed of several cartilaginous or bony carpels inclosed in an adherent fleshy mass, which is partly receptacle and partly calyx, as an apple, quince, or pear.","pos":""},{"def":"A ball of silver or other metal, which is filled with hot water, and used by the priest in cold weather to warm his hands during the service.","pos":""}],"POMEGRANATE":[{"def":"The fruit of the tree Punica Granatum; also, the tree itself (see Balaustine), which is native in the Orient, but is successfully cultivated in many warm countries, and as a house plant in colder climates.","pos":""}],"POMELO":[{"def":"A variety of shaddock, called also grape fruit.","pos":""}],"POMERANIAN":[{"def":"Of or pertaining to Pomerania, a province of Prussia on the Baltic Sea.","pos":""},{"def":"A native or inhabitant of Pomerania.","pos":""}],"POMEWATER":[{"def":"A kind of sweet, juicy apple.","pos":""}],"POMEY":[{"def":"A figure supposed to resemble an apple; a roundel, -- always of a green color.","pos":""}],"POMICULTURE":[{"def":"The culture of fruit; pomology as an art.","pos":""}],"POMME":[{"def":"Having the ends terminating in rounded protuberances or single balls; -- said of a cross.","pos":""}],"POMME BLANCHE":[{"def":"The prairie turnip.","pos":""}],"POMMEL":[{"def":"A knob or ball; an object resembling a ball in form; as: (a) The knob on the hilt of a sword.","pos":""}],"POMMELION":[{"def":"The cascabel, or hindmost knob, of a cannon.","pos":""}],"POMMETTE":[{"def":"Having two balls or protuberances at each end; -- said of a cross.","pos":""}],"POMOLOGICAL":[{"def":"Of or pertaining to pomology.","pos":""}],"POMOLOGIST":[{"def":"One versed in pomology; one who culticvates fruit trees.","pos":""}],"POMOLOGY":[{"def":"The science of fruits; a treatise on fruits; the cultivation of fruits and fruit trees.","pos":""}],"POMONA":[{"def":"The goddess of fruits and fruit trees.","pos":""}],"POMP":[{"def":"A procession distinguished by ostentation and splendor; a pageant.","pos":""},{"def":"Show of magnificence; parade; display; power.","pos":""}],"POMPADOUR":[{"def":"A crimson or pink color; also, a style of dress cut low and square in the neck; also, a mode of dressing the hair by drawing it straight back from the forehead over a roll; -- so called after the Marchioness de Pompadour of France.","pos":""}],"POMPANO":[{"def":"Any one of several species of marine fishes of the genus Trachynotus, of which four species are found on the Atlantic coast of the United States; -- called also palometa.","pos":""},{"def":"A California harvest fish (Stromateus simillimus), highly valued as a food fish.","pos":""}],"POMPEIAN":[{"def":"Of, pertaining to, or characteristic of, Pompeii, an ancient city of Italy, buried by an eruption of Vesuvius in 79 a.","pos":""}],"POMPEIAN RED":[{"def":"A brownish red approaching maroon, supposed to be imitated from the color of the wall panels of houses in Pompeii, which were decorated during the last age of the Republic.","pos":""}],"POMPELMOUS":[{"def":"A shaddock, esp.","pos":""}],"POMPET":[{"def":"The ball formerly used to ink the type.","pos":""}],"POMPHOLYX":[{"def":"Impure zinc oxide.","pos":""},{"def":"A skin disease in which there is an eruption of bullæ, without inflammation or fever.","pos":""}],"POMPILLION":[{"def":"An ointment or pomatum made of black poplar buds.","pos":""}],"POMPON":[{"def":"A tuft or ball of wool, or the like, sometimes worn by soldiers on the front of the hat, instead of a feather.","pos":""}],"POMPOSITY":[{"def":"The quality or state of being pompous; pompousness.","pos":""}],"POMPOSO":[{"def":"Grand and dignified; in grand style.","pos":""}],"POMPOUS":[{"def":"Displaying pomp; stately; showy with grandeur; magnificent; as, a pompous procession.","pos":""},{"def":"Ostentatious; pretentious; boastful; vainlorious; as, pompous manners; a pompous style.","pos":""}],"POMWATER":[{"def":"Same as Pomewater.","pos":""}]}