{"PLASH":[{"def":"A small pool of standing water; a puddle.","pos":""},{"def":"A dash of water; a splash.","pos":""}],"PLASHET":[{"def":"A small pond or pool; a puddle.","pos":""}],"PLASHING":[{"def":"The cutting or bending and intertwining the branches of small trees, as in hedges.","pos":""},{"def":"The dashing or sprinkling of coloring matter on the walls of buildings, to imitate granite, etc.","pos":""}],"PLASHOOT":[{"def":"A hedge or fence formed of branches of trees interlaced, or plashed.","pos":""}],"PLASHY":[{"def":"Watery; abounding with puddles; splashy.","pos":""},{"def":"Specked, as if plashed with color.","pos":""}],"PLASM":[{"def":"A mold or matrix in which anything is cast or formed to a particular shape.","pos":""}],"PLASMA":[{"def":"A variety of quartz, of a color between grass green and leek green, which is found associated with common chalcedony.","pos":""},{"def":"The viscous material of an animal or vegetable cell, out of which the various tissues are formed by a process of differentiation; protoplasm.","pos":""}],"PLASMATION":[{"def":"The act of forming or molding.","pos":""}],"PLASMATOR":[{"def":"A former; a fashioner.","pos":""}],"PLASMIC":[{"def":"Of, pertaining to, or connected with, plasma; plasmatic.","pos":""},{"def":"A piece of DNA, usually circular, functioning as part of the genetic material of a cell, not integrated with the chromosome and replicating independently of the chromosome, but transferred, like the chromosome, to subsequent generations.","pos":""}],"PLASMIN":[{"def":"A proteid body, separated by some physiologists from blood plasma.","pos":""}],"PLASMODIAL":[{"def":"Of or pertaining to, or like, a plasmodium; as, the plasmodial form of a life cycle.","pos":""}],"PLASMODIUM":[{"def":"A jellylike mass of free protoplasm, without any union of amoeboid cells, and endowed with life and power of motion.","pos":""},{"def":"A naked mobile mass of protoplasm, formed by the union of several amoebalike young, and constituting one of the stages in the life cycle of Mycetozoa and other low organisms.","pos":""}],"PLASMOGEN":[{"def":"The important living portion of protoplasm, considered a chemical substance of the highest elaboration.","pos":""},{"def":"A flourlike food preparation made from skim milk, and consisting essentially of the unaltered proteid of milk.","pos":""}],"PLASSON":[{"def":"The albuminous material composing the body of a cytode.","pos":""}],"PLASTER":[{"def":"An external application of a consistency harder than ointment, prepared for use by spreading it on linen, leather, silk, or other material.","pos":""}],"PLASTERER":[{"def":"One who applies plaster or mortar.","pos":""},{"def":"One who makes plaster casts.","pos":""}],"PLASTERING":[{"def":"Same as Plaster, n.","pos":""},{"def":"The act or process of overlaying with plaster.","pos":""}],"PLASTERLY":[{"def":"Resembling plaster of Paris.","pos":""}],"PLASTERWORK":[{"def":"Plastering used to finish architectural constructions, exterior or interior, especially that used for the lining of rooms.","pos":""}],"PLASTERY":[{"def":"Of the nature of plaster.","pos":""},{"def":"A combining form signifying developing, forming, growing; as, heteroplastic, monoplastic, polyplastic.","pos":""}],"PLASTIC":[{"def":"a substance composed predominantly of a synthetic organic high polymer capable of being cast or molded; many varieties of plastic are used to produce articles of commerce (after 1900).","pos":""}],"PLASTICALLY":[{"def":"In a plastic manner.","pos":""}],"PLASTICITY":[{"def":"A formative particle of albuminous matter; a monad; a cytode.","pos":""}],"PLASTIDOZOA":[{"def":"Same as Protoza.","pos":""}],"PLASTIDULE":[{"def":"One of the small particles or organic molecules of protoplasm.","pos":""}],"PLASTIN":[{"def":"A substance associated with nuclein in cell nuclei, and by some considered as the fundamental substance of the nucleus.","pos":""}],"PLASTOGRAPHY":[{"def":"The art of forming figures in any plastic material.","pos":""},{"def":"Imitation of handwriting; forgery.","pos":""}],"PLASTRON":[{"def":"An iron breastplate, worn under the hauberk.","pos":""},{"def":"The ventral shield or shell of tortoises and turtles.","pos":""}]}