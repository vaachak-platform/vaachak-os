{"CHOW":[{"def":"A prefecture or district of the second rank in China, or the chief city of such a district; -- often part of the name of a city, as in Foochow.","pos":""}],"CHOWCHOW":[{"def":"Consisting of several kinds mingled together; mixed; as, chowchow sweetmeats (preserved fruits put together).","pos":""}],"CHOWDER":[{"def":"A dish made of fresh fish or clams, biscuit, onions, etc.","pos":""}],"CHOWRY":[{"def":"A whisk to keep off files, used in the East Indies.","pos":""}],"CHOWTER":[{"def":"To grumble or mutter like a froward child.","pos":""}]}