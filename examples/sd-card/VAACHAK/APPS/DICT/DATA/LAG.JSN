{"LAG":[{"def":"Coming tardily after or behind; slow; tardy.","pos":""},{"def":"Last; long-delayed; -- obsolete, except in the phrase lag end.","pos":""}],"LAGENA":[{"def":"The terminal part of the cochlea in birds and most reptiles; an appendage of the sacculus, corresponding to the cochlea, in fishes and amphibians.","pos":""}],"LAGENIAN":[{"def":"Like, or pertaining to, Lagena, a genus of Foraminifera having a straight, chambered shell.","pos":""}],"LAGENIFORM":[{"def":"Shaped like a bottle or flask; flag-shaped.","pos":""}],"LAGER BEER":[{"def":"Originally a German beer, but now also made in immense quantities in the United States; -- so called from its being laid up or stored for some months before use.","pos":""}],"LAGER WINE":[{"def":"La\"ger wine` Defn: .","pos":""}],"LAGGARD":[{"def":"Slow; sluggish; backward.","pos":""}],"LAGGING":[{"def":"The clothing (esp.","pos":""}],"LAGGINGLY":[{"def":"In a lagging manner; loiteringly.","pos":""}],"LAGLY":[{"def":"In Louisiana, a trifling present given to customers by tradesmen; a gratuity.","pos":""}],"LAGOMORPH":[{"def":"One of the Lagomorpha.","pos":""}],"LAGOMORPHA":[{"def":"A group of rodents, including the hares.","pos":""}],"LAGOON":[{"def":"A morbid condition in which the eye stands wide open, giving a peculiar staring appearance.","pos":""}],"LAGOPOUS":[{"def":"Having a dense covering of long hair, like the foot of a hare.","pos":""}],"LAGTHING":[{"def":"See Legislatature, below.","pos":""}],"LAGUNE":[{"def":"Of or pertaining to a layman or the laity.","pos":""}]}