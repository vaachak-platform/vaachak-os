{"INOBEDIENT":[{"def":"Not obedient; disobedient.","pos":""}],"INOBSERVABLE":[{"def":"See In- not, and Observable.","pos":""}],"INOBSERVANCE":[{"def":"Want or neglect of observance.","pos":""}],"INOBSERVANT":[{"def":"Not observant; regardless; heedless.","pos":""}],"INOBSERVATION":[{"def":"Neglect or want of observation.","pos":""}],"INOBTRUSIVE":[{"def":"Not obtrusive; unobtrusive.","pos":""}],"INOCARPIN":[{"def":"A red, gummy, coloring matter, extracted from the colorless juice of the Otaheite chestnut (Inocarpus edulis).","pos":""}],"INOCCUPATION":[{"def":"Want of occupation.","pos":""}],"INOCERAMUS":[{"def":"An extinct genus of large, fossil, bivalve shells,allied to the mussels.","pos":""}],"INOCULABILITY":[{"def":"The qual ity or state of being inoculable.","pos":""}],"INOCULABLE":[{"def":"Capable of being inoculated; capable of communicating disease, or of being communicated, by inoculation.","pos":""}],"INOCULATE":[{"def":"To communicate a disease to ( a person ) by inserting infectious matter in the skin or flesh; as, to inoculate a person with the virus of smallpox,rabies, etc.","pos":""}],"INOCULATION":[{"def":"The act or practice of communicating a disease to a person in health, by inserting contagious matter in his skin or flesh.","pos":""}],"INOCULATOR":[{"def":"One who inoculates; one who propagates plants or diseases by inoculation.","pos":""}],"INODIATE":[{"def":"To make odious or hateful.","pos":""}],"INODOROUS":[{"def":"Emitting no odor; wthout smell; scentless; odorless.","pos":""}],"INOFFENSIVE":[{"def":"Giving no offense, or provocation; causing no uneasiness, annoyance, or disturbance; as, an inoffensive man, answer, appearance.","pos":""},{"def":"Harmless; doing no injury or mischief.","pos":""}],"INOFFICIAL":[{"def":"Not official; not having official sanction or authoriy; not according to the forms or ceremony of official business; as, inofficial intelligence.","pos":""}],"INOFFICIALLY":[{"def":"Without the usual forms, or not in the official character.","pos":""}],"INOFFICIOUS":[{"def":"Regardless of natural obligation; contrary to natural duty; unkind; -- commonly said of a testament made without regard to natural obligation, or by which a child is unjustly deprived of inheritance.","pos":""}],"INOFFICIOUSLY":[{"def":"Not-officiously.","pos":""}],"INOGEN":[{"def":"A complex nitrogenous substance, which, by Hermann's hypothesis, is continually decomposed and reproduced in the muscles, during their life.","pos":""}],"INOPERATION":[{"def":"Agency; influence; production of effects.","pos":""}],"INOPERATIVE":[{"def":"Not operative; not active; producing no effects; as, laws renderd inoperative by neglect; inoperative remedies or processes.","pos":""},{"def":"Having no operculum; -- said of certain gastropod shells.","pos":""}],"INOPINABLE":[{"def":"Not to be expected; inconceivable.","pos":""}],"INOPINATE":[{"def":"Not expected or looked for.","pos":""}],"INOPPORTUNE":[{"def":"Not opportune; inconvenient; unseasonable; as, an inopportune occurrence, remark, etc.","pos":""}],"INOPPORTUNELY":[{"def":"Not opportunely; unseasonably; inconveniently.","pos":""}],"INOPPORTUNITY":[{"def":"Want of opportunity; unseasonableness; inconvenience.","pos":""}],"INOPPRESSIVE":[{"def":"Not oppressive or burdensome.","pos":""}],"INOPULENT":[{"def":"Not opulent; not affluent or rich.","pos":""}],"INORDINACY":[{"def":"The state or quality of being inordinate; excessiveness; immoderateness; as, the inordinacy of love or desire.","pos":""}],"INORDINATE":[{"def":"Not limited to rules prescribed, or to usual bounds; irregular; excessive; immoderate; as, an inordinate love of the world.","pos":""}],"INORDINATION":[{"def":"Deviation from custom, rule, or right; irregularity; inordinacy.","pos":""}],"INORGANIC":[{"def":"Not organic; without the organs necessary for life; devoid of an organized structure; unorganized; lifeness; inanimate; as, all chemical compounds are inorganic substances.","pos":""}],"INORGANICALLY":[{"def":"In an inorganic manner.","pos":""}],"INORGANITY":[{"def":"Quality of being inorganic.","pos":""}],"INORGANIZATION":[{"def":"The state of being without organization.","pos":""}],"INORGANIZED":[{"def":"Not having organic structure; devoid of organs; inorganic.","pos":""}],"INORTHOGRAPHY":[{"def":"Deviation from correct orthography; bad spelling.","pos":""}],"INOSCULATE":[{"def":"To unite by apposition or contact, as two tubular vessels at their extremities; to anastomose.","pos":""},{"def":"To intercommunicate; to interjoin.","pos":""}],"INOSCULATION":[{"def":"The junction or connection of vessels, channels, or passages, so that their contents pass from one to the other; union by mouths or ducts; anastomosis; intercommunication; as, inosculation of veins, etc.","pos":""}],"INOSINIC":[{"def":"Pertaining to, or derived from, inosite; as, inosinic acid.","pos":""}],"INOSITE":[{"def":"A white crystalline substance with a sweet taste, found in certain animal tissues and fluids, particularly in the muscles of the heart and lungs, also in some plants, as in unripe pease, beans, potato sprouts, etc.","pos":""}],"INOXIDIZABLE":[{"def":"Incapable of being oxidized; as, gold and platinum are inoxidizable in the air.","pos":""}],"INOXIDIZE":[{"def":"To prevent or hinder oxidation, rust, or decay; as, inoxidizing oils or varnishes.","pos":""}]}