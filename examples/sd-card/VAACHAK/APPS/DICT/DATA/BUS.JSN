{"BUSBY":[{"def":"A military headdress or cap, used in the British army.","pos":""}],"BUSCON":[{"def":"One who searches for ores; a prospector.","pos":""}],"BUSH":[{"def":"The tail, or brush, of a fox.","pos":""}],"BUSHEL":[{"def":"A dry measure, containing four pecks, eight gallons, or thirty-two quarts.","pos":""},{"def":"A vessel of the capacity of a bushel, used in measuring; a bushel measure.","pos":""}],"BUSHELAGE":[{"def":"A duty payable on commodities by the bushel.","pos":""}],"BUSHELMAN":[{"def":"A tailor's assistant for repairing garments; -- called also busheler.","pos":""}],"BUSHFIGHTER":[{"def":"One accustomed to bushfighting.","pos":""}],"BUSHFIGHTING":[{"def":"Fighting in the bush, or from behind bushes, trees, or thickets.","pos":""}],"BUSHHAMMER":[{"def":"A hammer with a head formed of a bundle of square bars, with pyramidal points, arranged in rows, or a solid head with a face cut into a number of rows of such points; -- used for dressing stone.","pos":""}],"BUSHIDO":[{"def":"The unwritten code of moral principles regulating the actions of the Japanese knighthood, or Samurai; the chivalry of Japan.","pos":""}],"BUSHINESS":[{"def":"The condition or quality of being bushy.","pos":""}],"BUSHING":[{"def":"A bush or lining; -- sometimes called .","pos":""}],"BUSHLESS":[{"def":"Free from bushes; bare.","pos":""}],"BUSHMAN":[{"def":"One of a race of South African nomads, living principally in the deserts, and not classified as allied in race or language to any other people.","pos":""}],"BUSHMENT":[{"def":"A thicket; a cluster of bushes.","pos":""}],"BUSHRANGER":[{"def":"One who roams, or hides, among the bushes; especially, in Australia, an escaped criminal living in the bush.","pos":""}],"BUSHWHACKER":[{"def":"One accustomed to beat about, or travel through, bushes.","pos":""},{"def":"A guerrilla; a marauding assassin; one who pretends to be a peaceful citizen, but secretly harasses a hostile force or its sympathizers.","pos":""}],"BUSHWHACKING":[{"def":"Traveling, or working a way, through bushes; pulling by the bushes, as in hauling a boat along the bushy margin of a stream.","pos":""},{"def":"The crimes or warfare of bushwhackers.","pos":""}],"BUSHY":[{"def":"Thick and spreading, like a bush.","pos":""},{"def":"Full of bushes; overgrowing with shrubs.","pos":""}],"BUSILY":[{"def":"In a busy manner.","pos":""}],"BUSINESS":[{"def":"The position, distribution, and order of persons and properties on the stage of a theater, as determined by the stage manager in rehearsal.","pos":""}],"BUSINESSLIKE":[{"def":"In the manner of one transacting business wisely and by right methods.","pos":""}],"BUSK":[{"def":"A thin, elastic strip of metal, whalebone, wood, or other material, worn in the front of a corset.","pos":""}],"BUSKET":[{"def":"A small bush; also, a sprig or bouquet.","pos":""},{"def":"A part of a garden devoted to shrubs.","pos":""}],"BUSKIN":[{"def":"A strong, protecting covering for the foot, coming some distance up the leg.","pos":""},{"def":"A similar covering for the foot and leg, made with very thick soles, to give an appearance of elevation to the stature; -- worn by tragic actors in ancient Greece and Rome.","pos":""}],"BUSKINED":[{"def":"Wearing buskins.","pos":""},{"def":"Trodden by buskins; pertaining to tragedy.","pos":""}],"BUSKY":[{"def":"See Bosky, and 1st Bush, n.","pos":""}],"BUSS":[{"def":"A kiss; a rude or playful kiss; a smack.","pos":""}],"BUST":[{"def":"A piece of sculpture representing the upper part of the human figure, including the head, shoulders, and breast.","pos":""},{"def":"The portion of the human figure included between the head and waist, whether in statuary or in the person; the chest or thorax; the upper part of the trunk of the body.","pos":""}],"BUSTARD":[{"def":"A bird of the genus Otis.","pos":""}],"BUSTER":[{"def":"Something huge; a roistering blade; also, a spree.","pos":""}],"BUSTLE":[{"def":"To move noisily; to be rudely active; to move in a way to cause agitation or disturbance; as, to bustle through a crowd.","pos":""}],"BUSTLER":[{"def":"An active, stirring person.","pos":""}],"BUSTLING":[{"def":"Agitated; noisy; tumultuous; characterized by confused activity; as, a bustling crowd.","pos":""}],"BUSTO":[{"def":"A bust; a statue.","pos":""}],"BUSY":[{"def":"Engaged in some business; hard at work (either habitually or only for the time being); occupied with serious affairs; not idle nor at leisure; as, a busy merchant.","pos":""},{"def":"Constantly at work; diligent; active.","pos":""}],"BUSYBODY":[{"def":"One who officiously concerns himself with the affairs of others; a meddling person.","pos":""}]}