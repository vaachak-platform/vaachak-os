{"INJECT":[{"def":"To fill (a vessel, cavity, or tissue) with a fluid or other substance; as, to inject the blood vessels.","pos":""}],"INJECTION":[{"def":"The act of injecting or throwing in; -- applied particularly to the forcible throwing in of a liquid, or aëriform body, by means of a syringe, pump, etc.","pos":""},{"def":"That which is injected; especially, a liquid medicine thrown into a cavity of the body by a syringe or pipe; a clyster; an enema.","pos":""}],"INJECTOR":[{"def":"A contrivance for forcing feed water into a steam boiler by the direct action of the steam upon the water.","pos":""}],"INJELLY":[{"def":"To place in jelly.","pos":""}],"INJOINT":[{"def":"To join; to unite.","pos":""}],"INJUCUNDITY":[{"def":"Unpleassantness; disagreeableness.","pos":""}],"INJUDICABLE":[{"def":"Not cognizable by a judge.","pos":""}],"INJUDICIAL":[{"def":"Not according to the forms of law; not judicial.","pos":""}],"INJUDICIOUS":[{"def":"Not judicious; wanting in sound judgment; undiscerning; indiscreet; unwise; as, an injudicious adviser.","pos":""},{"def":"Not according to sound judgment or discretion; unwise; as, an injudicious measure.","pos":""}],"INJUDICIOUSLY":[{"def":"In an injudicious manner.","pos":""}],"INJUDICIOUSNESS":[{"def":"The quality of being injudicious; want of sound judgment; indiscretion.","pos":""}],"INJUNCTION":[{"def":"A writ or process, granted by a court of equity, and, insome cases, under statutes, by a court of law,whereby a party is required to do or to refrain from doing certain acts, according to the exigency of the writ.","pos":""}],"INJURE":[{"def":"To do harm to; to impair the excellence and value of; to hurt; to damage; -- used in a variety of senses; as: (a) To hurt or wound, as the person; to impair soundness, as of health.","pos":""}],"INJURER":[{"def":"One who injures or wrongs.","pos":""}],"INJURIA":[{"def":"Injury; invasion of another's rights.","pos":""}],"INJURIOUS":[{"def":"Not just; wrongful; iniquitous; culpable.","pos":""},{"def":"Causing injury or harm; hurtful; harmful; detrimental; mischievous; as, acts injurious to health, credit, reputation, property, etc.","pos":""}],"INJURIOUSLY":[{"def":"In an injurious or hurtful manner; wrongfully; hurtfully; mischievously.","pos":""}],"INJURIOUSNESS":[{"def":"The quality of being injurious or hurtful; harmfulness; injury.","pos":""}],"INJURY":[{"def":"For he that doeth injury shall receve that he did evil.","pos":""}],"INJUSTICE":[{"def":"Want of justice and equity; violation of the rights of another or others; iniquity; wrong; unfairness; imposition.","pos":""},{"def":"An unjust act or deed; a sin; a crime; a wrong.","pos":""}]}