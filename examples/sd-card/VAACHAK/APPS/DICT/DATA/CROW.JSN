{"CROW":[{"def":"To make the shrill sound characteristic of a cock, either in joy, gayety, or defiance.","pos":""},{"def":"To shout in exultation or defiance; to brag.","pos":""}],"CROW'S-FOOT":[{"def":"The wrinkles that appear, as the effect of age or dissipation, under and around the outer corners of the eyes.","pos":""}],"CROW'S-NEST":[{"def":"A box or perch near the top of a mast, esp.","pos":""}],"CROW-QUILL":[{"def":"A quill of the crow, or a very fine pen made from such a quill.","pos":""}],"CROW-SILK":[{"def":"A filamentous fresh-water alga (Conferva rivularis of Linnaeus, Rhizoclonium rivulare of Kutzing).","pos":""}],"CROW-TRODDEN":[{"def":"Marked with crow's-feet, or wrinkles, about the eyes.","pos":""}],"CROWBAR":[{"def":"A bar of iron sharpened at one end, and used as a lever.","pos":""}],"CROWBERRY":[{"def":"A heathlike plant of the genus Empetrum, and its fruit, a black, scarcely edible berry; -- also called crakeberry.","pos":""}],"CROWD":[{"def":"To push, to press, to shove.","pos":""},{"def":"To press or drive together; to mass together.","pos":""}],"CROWDER":[{"def":"One who plays on a crowd; a fiddler.","pos":""}],"CROWDY":[{"def":"A thick gruel of oatmeal and milk or water; food of the porridge kind.","pos":""}],"CROWFLOWER":[{"def":"A kind of campion; according to Gerarde, the Lychnis Flos- cuculi.","pos":""}],"CROWFOOT":[{"def":"The genus Ranunculus, of many species; some are common weeds, others are flowering plants of considerable beauty.","pos":""},{"def":"A number of small cords rove through a long block, or euphroe, to suspend an awning by.","pos":""}],"CROWKEEPER":[{"def":"A person employed to scare off crows; hence, a scarecrow.","pos":""}],"CROWN":[{"def":"Crown (krn), Defn: p.","pos":""}],"CROWN COLONY":[{"def":"A colony of the British Empire not having an elective magistracy or a parliament, but governed by a chief magistrate (called Governor) appointed by the Crown, with executive councilors nominated by him and not elected by the people.","pos":""}],"CROWN OFFICE":[{"def":"The criminal branch of the Court of King's or Queen's Bench, commonly called the crown side of the court, which takes cognizance of all criminal cases.","pos":""}],"CROWN SIDE":[{"def":"See Crown office.","pos":""}],"CROWN WHEEL":[{"def":"A wheel with cogs or teeth set at right angles to its plane; -- called also a contrate wheel or face wheel.","pos":""}],"CROWN-IMPERIAL":[{"def":"A spring-blooming plant (Fritillaria imperialis) of the Lily family, having at the top of the stalk a cluster of pendent bell- shaped flowers surmounted with a tuft of green leaves.","pos":""}],"CROWN-POST":[{"def":"Same as King-post.","pos":""}],"CROWN-SAW":[{"def":"A saw in the form of a hollow cylinder, with teeth on the end or edge, and operated by a rotative motion.","pos":""}],"CROWNED":[{"def":"Having or wearing a crown; surmounted, invested, or adorned, with a crown, wreath, garland, etc.","pos":""},{"def":"Great; excessive; supreme.","pos":""}],"CROWNER":[{"def":"One who, or that which, crowns.","pos":""}],"CROWNET":[{"def":"The ultimate end and result of an undertaking; a chief end.","pos":""}],"CROWNLAND":[{"def":"In Austria-Hungary, one of the provinces, or largest administrative divisions of the monarchy; as, the crownland of Lower Austria.","pos":""}],"CROWNLESS":[{"def":"Without a crown.","pos":""}],"CROWNPIECE":[{"def":"Crown\"piece` (-ps`), n.","pos":""}],"CROWNWORK":[{"def":"A work consisting of two or more bastioned fronts, with their outworks, covering an enceinte, a bridgehead, etc.","pos":""}],"CROWS":[{"def":"A tribe of Indians of the Dakota stock, living in Montana; -- also called Upsarokas.","pos":""}],"CROWSTEP":[{"def":"Crow\"step` (kr\"stp`), n.","pos":""}],"CROWSTONE":[{"def":"The top stone of the gable end of a house.","pos":""}],"CROWTH":[{"def":"An ancient musical instrument.","pos":""}],"CROWTOE":[{"def":"The Lotus corniculatus.","pos":""},{"def":"An unidentified plant, probably the crowfoot.","pos":""}]}