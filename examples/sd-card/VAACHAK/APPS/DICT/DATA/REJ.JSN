{"REJECT":[{"def":"To cast from one; to throw away; to discard.","pos":""},{"def":"To refuse to receive or to acknowledge; to decline haughtily or harshly; to repudiate.","pos":""}],"REJECTABLE":[{"def":"Capable of being, or that ought to be, rejected.","pos":""}],"REJECTAMENTA":[{"def":"Things thrown out or away; especially, things excreted by a living organism.","pos":"noun"}],"REJECTANEOUS":[{"def":"Not chosen orr received; rejected.","pos":""}],"REJECTER":[{"def":"One who rejects.","pos":""}],"REJECTION":[{"def":"Act of rejecting, or state of being rejected.","pos":""}],"REJECTITIOUS":[{"def":"Implying or requiring rejection; rejectable.","pos":""}],"REJECTIVE":[{"def":"Rejecting, or tending to reject.","pos":""}],"REJECTMENT":[{"def":"Act of rejecting; matter rejected, or thrown away.","pos":""}],"REJOICE":[{"def":"To feel joy; to experience gladness in a high degree; to have pleasurable satisfaction; to be delighted.","pos":""}],"REJOICEMENT":[{"def":"Re*joice\"ment (-ment), n.","pos":""}],"REJOICER":[{"def":"One who rejoices.","pos":""}],"REJOICING":[{"def":"Joy; gladness; delight.","pos":""},{"def":"The expression of joy or gladness.","pos":""}],"REJOICINGLY":[{"def":"With joi or exultation.","pos":""}],"REJOIN":[{"def":"To join again; to unite after separation.","pos":""},{"def":"To come, or go, again into the presence of; to join the company of again.","pos":""}],"REJOINDER":[{"def":"The defendant's answer to the plaintiff's replication.","pos":""}],"REJOINDURE":[{"def":"Act of joining again.","pos":""}],"REJOINT":[{"def":"To reunite the joints of; to joint anew.","pos":""},{"def":"Specifically (Arch.","pos":""}],"REJOLT":[{"def":"A reacting jolt or shock; a rebound or recoil.","pos":""}],"REJOURN":[{"def":"To adjourn; to put off.","pos":""}],"REJOURNMENT":[{"def":"Re*journ\"ment (-ment), n.","pos":""}],"REJUDGE":[{"def":"To judge again; to re Rejudge his acts, and dignify disgrace.","pos":""}],"REJUVENATE":[{"def":"To render young again.","pos":""}],"REJUVENATED":[{"def":"Rendered young again; as, rejuvenated life.","pos":""}],"REJUVENATION":[{"def":"Re*ju`ve*na\"tion (-n\"shn), n.","pos":""}],"REJUVENESCENCE":[{"def":"A method of cell formation in which the entire protoplasm of an old cell escapes by rupture of the cell wall, and then develops a new cell wall.","pos":""}],"REJUVENESCENCY":[{"def":"Re*ju`ve*nes\"cen*cy (-sen-s), n.","pos":""}],"REJUVENESCENT":[{"def":"Becoming, or causing to become, rejuvenated; rejuvenating.","pos":""}],"REJUVENIZE":[{"def":"Re*ju`ve*nize (r-j\"v-nz), v.","pos":""}]}