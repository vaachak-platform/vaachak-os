{"BROACH":[{"def":"A broad chisel for stonecutting.","pos":""},{"def":"A spire rising from a tower.","pos":""}],"BROACHER":[{"def":"A spit; a broach.","pos":""},{"def":"One who broaches, opens, or utters; a first publisher or promoter.","pos":""}],"BROAD":[{"def":"Characterized by breadth.","pos":""}],"BROAD CHURCH":[{"def":"A portion of the Church of England, consisting of persons who claim to hold a position, in respect to doctrine and fellowship, intermediate between the High Church party and the Low Church, or evangelical, party.","pos":""}],"BROAD GAUGE":[{"def":"A wider distance between the rails than the \"standard\" gauge of four feet eight inches and a half.","pos":""}],"BROAD SEAL":[{"def":"The great seal of England; the public seal of a country or state.","pos":""}],"BROAD-BRIMMED":[{"def":"Having a broad brim.","pos":""}],"BROAD-HORNED":[{"def":"Having horns spreading widely.","pos":""}],"BROADBILL":[{"def":"A wild duck (Aythya, or Fuligula, marila), which appears in large numbers on the eastern coast of the United States, in autumn; - - called also bluebill, blackhead, raft duck, and scaup duck.","pos":""}],"BROADBRIM":[{"def":"A hat with a very broad brim, like those worn by men of the society of Friends.","pos":""},{"def":"A member of the society of Friends; a Quaker.","pos":""}],"BROADCAST":[{"def":"A casting or throwing seed in all directions, as from the hand in sowing.","pos":""}],"BROADCLOTH":[{"def":"A fine smooth-faced woolen cloth for men's garments, usually of double width (i.","pos":""}],"BROADEN":[{"def":"To grow broad; to become broader or wider.","pos":""}],"BROADISH":[{"def":"Rather broad; moderately broad.","pos":""}],"BROADLEAF":[{"def":"A tree (Terminalia latifolia) of Jamaica, the wood of which is used for boards, scantling, shingles, etc; -- sometimes called the almond tree, from the shape of its fruit.","pos":""},{"def":"Having broad, or relatively broad, leaves.","pos":""}],"BROADLY":[{"def":"In a broad manner.","pos":""}],"BROADMOUTH":[{"def":"One of the Eurylaimidæ, a family of East Indian passerine birds.","pos":""}],"BROADNESS":[{"def":"The condition or quality of being broad; breadth; coarseness; grossness.","pos":""}],"BROADPIECE":[{"def":"An old English gold coin, broader than a guinea, as a Carolus or Jacobus.","pos":""}],"BROADSEAL":[{"def":"To stamp with the broad seal; to make sure; to guarantee or warrant.","pos":""}],"BROADSIDE":[{"def":"The side of a ship above the water line, from the bow to the quarter.","pos":""},{"def":"A sheet of paper containing one large page, or printed on one side only; -- called also broadsheet.","pos":""}],"BROADSPREADING":[{"def":"Spreading widely.","pos":""}],"BROADSWORD":[{"def":"A sword with a broad blade and a cutting edge; a claymore.","pos":""}]}