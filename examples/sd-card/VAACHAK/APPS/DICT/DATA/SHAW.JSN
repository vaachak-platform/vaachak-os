{"SHAW":[{"def":"The leaves and tops of vegetables, as of potatoes, turnips, etc.","pos":""}],"SHAWFOWL":[{"def":"The representation or image of a fowl made by fowlers to shoot at.","pos":""}],"SHAWL":[{"def":"A square or oblong cloth of wool, cotton, silk, or other textile or netted fabric, used, especially by women, as a loose covering for the neck and shoulders.","pos":""}],"SHAWM":[{"def":"A wind instrument of music, formerly in use, supposed to have resembled either the clarinet or the hautboy in form.","pos":""}],"SHAWNEES":[{"def":"A tribe of North American Indians who occupied Western New York and part of Ohio, but were driven away and widely dispersed by the Iroquois.","pos":""}]}