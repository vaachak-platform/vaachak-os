{"ENRACE":[{"def":"To enroot; to implant.","pos":""}],"ENRAGE":[{"def":"To fill with rage; to provoke to frenzy or madness; to make furious.","pos":""}],"ENRAGEMENT":[{"def":"Act of enraging or state of being enraged; excitement.","pos":""}],"ENRANGE":[{"def":"To range in order; to put in rank; to arrange.","pos":""},{"def":"To rove over; to range.","pos":""}],"ENRANK":[{"def":"To place in ranks or in order.","pos":""}],"ENRAPT":[{"def":"Thrown into ecstasy; transported; enraptured.","pos":""}],"ENRAPTURE":[{"def":"To transport with pleasure; to delight beyond measure; to enravish.","pos":""}],"ENRAVISH":[{"def":"To transport with delight; to enrapture; to fascinate.","pos":""}],"ENRAVISHINGLY":[{"def":"So as to throw into ecstasy.","pos":""}],"ENRAVISHMENT":[{"def":"The state of being enravished or enraptured; ecstasy; rapture.","pos":""}],"ENREGISTER":[{"def":"To register; to enroll or record; to inregister.","pos":""}],"ENRHEUM":[{"def":"To contract a rheum.","pos":""}],"ENRICH":[{"def":"To make rich with any kind of wealth; to render opulent; to increase the possessions of; as, to enrich the understanding with knowledge.","pos":""},{"def":"To supply with ornament; to adorn; as, to enrich a ceiling by frescoes.","pos":""}],"ENRICHER":[{"def":"One who enriches.","pos":""}],"ENRICHMENT":[{"def":"The act of making rich, or that which enriches; increase of value by improvements, embellishment, etc.","pos":""}],"ENRIDGE":[{"def":"To form into ridges.","pos":""}],"ENRING":[{"def":"The Muses and the Graces, grouped in threes, Enringed a billowing fountain in the midst.","pos":""}],"ENRIVE":[{"def":"To rive; to cleave.","pos":""}],"ENROBE":[{"def":"To invest or adorn with a robe; to attire.","pos":""}],"ENROCKMENT":[{"def":"A mass of large stones thrown into water at random to form bases of piers, breakwaters, etc.","pos":""}],"ENROLL":[{"def":"To insert in a roil; to register or enter in a list or catalogue or on rolls of court; hence, to record; to insert in records; to leave in writing; as, to enroll men for service; to enroll a decree or a law; also, reflexively, to enlist.","pos":""},{"def":"To envelop; to inwrap; to involve.","pos":""}],"ENROLLER":[{"def":"One who enrolls or registers.","pos":""}],"ENROLLMENT":[{"def":"The act of enrolling; registration.","pos":""},{"def":"A writing in which anything is enrolled; a register; a record.","pos":""}],"ENROOT":[{"def":"To fix by the root; to fix fast; to implant deep.","pos":""}]}