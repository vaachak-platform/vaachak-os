{"MARIAN":[{"def":"Pertaining to the Virgin Mary, or sometimes to Mary, Queen of England, daughter of Henry VIII.","pos":""}],"MARIET":[{"def":"A kind of bellflower, Companula Trachelium, once called Viola Mariana; but it is not a violet.","pos":""}],"MARIGENOUS":[{"def":"Produced in or by the sea.","pos":""}],"MARIGOLD":[{"def":"A name for several plants with golden yellow blossoms, especially the Calendula officinalis (see Calendula), and the cultivated species of Tagetes.","pos":""}],"MARIKINA":[{"def":"A small marmoset (Midas rosalia); the silky tamarin.","pos":""}],"MARIMBA":[{"def":"A musical istrument of percussion, consisting of bars yielding musical tones when struck.","pos":""}],"MARIMONDA":[{"def":"A spider monkey (Ateles belzebuth) of Central and South America.","pos":""}],"MARINADE":[{"def":"A brine or pickle containing wine and spices, for enriching the flavor of meat and fish.","pos":""}],"MARINATE":[{"def":"To salt or pickle, as fish, and then preserve in oil or vinegar; to prepare by the use of marinade.","pos":""}],"MARINE":[{"def":"Formed by the action of the currents or waves of the sea; as, marine deposits.","pos":""}],"MARINED":[{"def":"Having the lower part of the body like a fish.","pos":""}],"MARINER":[{"def":"One whose occupation is to assist in navigating ships; a seaman or sailor.","pos":""}],"MARINISM":[{"def":"A bombastic literary style marked by the use of metaphors and antitheses characteristic of the Italian poet Giambattista Marini (1569-1625).","pos":""}],"MARINORAMA":[{"def":"A representation of a sea view.","pos":""}],"MARIOLATER":[{"def":"One who worships the Virgin Mary.","pos":""}],"MARIOLATRY":[{"def":"The worship of the Virgin Mary.","pos":""}],"MARIONETTE":[{"def":"The buffel duck.","pos":""}],"MARIOTTE'S LAW":[{"def":"See Boyle's law, under Law.","pos":""}],"MARIPOSA LILY":[{"def":"One of a genus (Calochortus) of tuliplike bulbous herbs with large, and often gaycolored, blossoms.","pos":""}],"MARIPUT":[{"def":"A species of civet; the zoril.","pos":""}],"MARISH":[{"def":"Low, wet ground; a marsh; a fen; a bog; a moor.","pos":""}],"MARITAL":[{"def":"Of or pertaining to a husband; as, marital rights, duties, authority.","pos":""}],"MARITATED":[{"def":"Having a husband; married.","pos":""}],"MARITIME":[{"def":"Bordering on, or situated near, the ocean; connected with the sea by site, interest, or power; having shipping and commerce or a navy; as, maritime states.","pos":""},{"def":"Of or pertaining to the ocean; marine; pertaining to navigation and naval affairs, or to shipping and commerce by sea.","pos":""}]}