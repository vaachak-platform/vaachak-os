{"PERIPATETIC":[{"def":"Walking about; itinerant.","pos":""},{"def":"Of or pertaining to the philosophy taught by Aristotle (who gave his instructions while walking in the Lyceum at Athens), or to his followers.","pos":""}],"PERIPATETICAL":[{"def":"Per`i*pa*tet\"ic*al, a.","pos":""}],"PERIPATETICISM":[{"def":"The doctrines or philosophical system of the peripatetics.","pos":""}],"PERIPATUS":[{"def":"A genus of lowly organized arthropods, found in South Africa, Australia, and tropical America.","pos":""}],"PERIPETALOUS":[{"def":"Surrounding, or situated about, the petals.","pos":""}],"PERIPHERAL":[{"def":"External; away from the center; as, the peripheral portion of the nervous system.","pos":""}],"PERIPHERY":[{"def":"The circumference of a circle, ellipse, or other figure.","pos":""}],"PERIPHRASE":[{"def":"The use of more words than are necessary to express the idea; a roundabout, or indirect, way of speaking; circumlocution.","pos":""}],"PERIPHRASIS":[{"def":"Expressing, or expressed, in more words than are necessary; characterized by periphrase; circumlocutory.","pos":""}],"PERIPHRASTICALLY":[{"def":"With circumlocution.","pos":""}],"PERIPLAST":[{"def":"Same as Periblast.","pos":""}],"PERIPNEUMONIC":[{"def":"Of or pertaining to peripneumonia.","pos":""}],"PERIPROCT":[{"def":"The region surrounding the anus, particularly of echinoderms.","pos":""}],"PERIPROCTITIS":[{"def":"Inflammation of the tissues about the rectum.","pos":""}],"PERIPTERAL":[{"def":"Having columns on all sides; -- said of an edifice.","pos":""}],"PERIPTEROUS":[{"def":"Feathered all around.","pos":""}],"PERIPTERY":[{"def":"The region surrounding a moving body, such as the wing of a bird or a gliding aëroplane, within which cyclic or vortical motion of the air occur.","pos":""}]}