{"CRAFT":[{"def":"A vessel; vessels of any kind; -- generally used in a collective sense.","pos":""}],"CRAFTER":[{"def":"a creator of great skill in the manual arts.","pos":""}],"CRAFTILY":[{"def":"With craft; artfully; cunningly.","pos":""}],"CRAFTINESS":[{"def":"Dexterity in devising and effecting a purpose; cunning; artifice; stratagem.","pos":""}],"CRAFTLESS":[{"def":"Without craft or cunning.","pos":""}],"CRAFTSMAN":[{"def":"One skilled in some trade or manual occupation; an artificer; a mechanic.","pos":""}],"CRAFTSMANSHIP":[{"def":"The work of a craftsman.","pos":""}],"CRAFTSMASTER":[{"def":"One skilled in his craft or trade; one of superior cunning.","pos":""}],"CRAFTY":[{"def":"Relating to, or characterized by, craft or skill; dexterous.","pos":""},{"def":"Possessing dexterity; skilled; skillful.","pos":""}]}