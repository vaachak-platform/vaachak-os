{"PAH":[{"def":"An exclamation expressing disgust or contempt.","pos":""}],"PAHI":[{"def":"A large war canoe of the Society Islands.","pos":""}],"PAHLEVI":[{"def":"Same as Pehlevi.","pos":""}],"PAHOEHOE":[{"def":"A name given in the Sandwich Islands to lava having a relatively smooth surface, in distinction from the rough-surfaced lava, called a-a.","pos":""}]}