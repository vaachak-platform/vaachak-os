{"DIARCHY":[{"def":"A form of government in which the supreme power is vested in two persons.","pos":""},{"def":"Pertaining to a diary; daily.","pos":""}],"DIARIST":[{"def":"One who keeps a diary.","pos":""},{"def":"A morbidly frequent and profuse discharge of loose or fluid evacuations from the intestines, without tenesmus; a purging or looseness of the bowels; a flux.","pos":""}],"DIARTHRODIAL":[{"def":"Relating to diarthrosis, or movable articulations.","pos":""}],"DIARTHROSIS":[{"def":"A form of articulation which admits of considerable motion; a complete joint; abarticulation.","pos":""}],"DIARY":[{"def":"A register of daily events or transactions; a daily record; a journal; a blank book dated for the record of daily memoranda; as, a diary of the weather; a physician's diary.","pos":""}]}