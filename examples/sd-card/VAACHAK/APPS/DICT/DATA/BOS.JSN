{"BOS":[{"def":"A genus of ruminant quadrupeds, including the wild and domestic cattle, distinguished by a stout body, hollow horns, and a large fold of skin hanging from the neck.","pos":""}],"BOSA":[{"def":"A drink, used in the East.","pos":""}],"BOSCAGE":[{"def":"Food or sustenance for cattle, obtained from bushes and trees; also, a tax on wood.","pos":""}],"BOSH":[{"def":"Figure; outline; show.","pos":""}],"BOSHBOK":[{"def":"A kind of antelope.","pos":""}],"BOSK":[{"def":"A thicket; a small wood.","pos":""}],"BOSKAGE":[{"def":"Same as Boscage.","pos":""},{"def":"A grove; a thicket; shrubbery; an inclosure formed by branches of trees, regularly or irregularly disposed.","pos":""}],"BOSKINESS":[{"def":"Boscage; also, the state or quality of being bosky.","pos":""}],"BOSKY":[{"def":"Woody or bushy; covered with boscage or thickets.","pos":""},{"def":"Caused by boscage.","pos":""}],"BOSOM":[{"def":"The breast of a human being; the part, between the arms, to which anything is pressed when embraced by them.","pos":""},{"def":"The breast, considered as the seat of the passions, affections, and operations of the mind; consciousness; se Tut, I am in their bosoms, and I know Wherefore they do it.","pos":""}],"BOSOMED":[{"def":"Having, or resembling, bosom; kept in the bosom; hidden.","pos":""}],"BOSOMY":[{"def":"Characterized by recesses or sheltered hollows.","pos":""}],"BOSPORIAN":[{"def":"Of or pertaining to the Thracian or the Cimmerian Bosporus.","pos":""}],"BOSPORUS":[{"def":"A strait or narrow sea between two seas, or a lake and a seas; as, the Bosporus (formerly the Thracian Bosporus) or Strait of Constantinople, between the Black Sea and Sea of Marmora; the Cimmerian Bosporus, between the Black Sea and Sea of Azof.","pos":""}],"BOSS":[{"def":"A projecting ornament placed at the intersection of the ribs of ceilings, whether vaulted or flat, and in other situations.","pos":""},{"def":"A wooden vessel for the mortar used in tiling or masonry, hung by a hook from the laths, or from the rounds of a ladder.","pos":""}],"BOSSAGE":[{"def":"A stone in a building, left rough and projecting, to be afterward carved into shape.","pos":""},{"def":"Rustic work, consisting of stones which seem to advance beyond the level of the building, by reason of indentures or channels left in the joinings.","pos":""}],"BOSSED":[{"def":"Embossed; also, bossy.","pos":""}],"BOSSET":[{"def":"A rudimental antler of a young male of the red deer.","pos":""}],"BOSSISM":[{"def":"The rule or practices of bosses, esp.","pos":""}],"BOSSY":[{"def":"Ornamented with bosses; studded.","pos":""}],"BOSTON":[{"def":"A game at cards, played by four persons, with two packs of fifty-two cards each; -- said to be so called from Boston, Massachusetts, and to have been invented by officers of the French army in America during the Revolutionary war.","pos":""}],"BOSTRYX":[{"def":"A form of cymose inflorescence with all the flowers on one side of the rachis, usually causing it to curl; -- called also a uniparous helicoid cyme.","pos":""}],"BOSWELLIAN":[{"def":"Relating to, or characteristic of, Boswell, the biographer of Dr.","pos":""}],"BOSWELLISM":[{"def":"The style of Boswell.","pos":""}]}