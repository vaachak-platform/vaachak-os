{"PERVADE":[{"def":"To pass or flow through, as an aperture, pore, or interstice; to permeate.","pos":""},{"def":"To pass or spread through the whole extent of; to be diffused throughout.","pos":""}],"PERVASION":[{"def":"The act of pervading, passing, or spreading through the whole extent of a thing.","pos":""}],"PERVASIVE":[{"def":"Tending to pervade, or having power to spread throughout; of a pervading quality.","pos":""}],"PERVERSE":[{"def":"Turned aside; hence, specifically, turned away from the right; willfully erring; wicked; perverted.","pos":""},{"def":"Obstinate in the wrong; stubborn; intractable; hence, wayward; vexing; contrary.","pos":""}],"PERVERSELY":[{"def":"In a perverse manner.","pos":""}],"PERVERSENESS":[{"def":"The quality or state of being perverse.","pos":""}],"PERVERSION":[{"def":"The act of perverting, or the state of being perverted; a turning from truth or right; a diverting from the true intent or object; a change to something worse; a turning or applying to a wrong end or use.","pos":""}],"PERVERSITY":[{"def":"The quality or state of being perverse; perverseness.","pos":""}],"PERVERSIVE":[{"def":"Tending to pervert.","pos":""}],"PERVERT":[{"def":"To turnanother way; to divert.","pos":""},{"def":"To turn from truth, rectitude, or propriety; to divert from a right use, end, or way; to lead astray; to corrupt; also, to misapply; to misinterpret designedly; as, to pervert one's words.","pos":""}],"PERVERTER":[{"def":"One who perverts (a person or thing).","pos":""}],"PERVERTIBLE":[{"def":"Capable of being perverted.","pos":""}],"PERVESTIGATE":[{"def":"To investigate thoroughly.","pos":""}],"PERVESTIGATION":[{"def":"Thorough investigation.","pos":""}],"PERVICACIOUS":[{"def":"Obstinate; willful; refractory.","pos":""}],"PERVICACITY":[{"def":"Obstinacy; pervicaciousness.","pos":""}],"PERVIGILATION":[{"def":"Careful watching.","pos":""}],"PERVIOUS":[{"def":"Open; -- used synonymously with perforate, as applied to the nostrils or birds.","pos":""}],"PERVIOUSNESS":[{"def":"The quality or state of being pervious; as, the perviousness of glass.","pos":""}]}