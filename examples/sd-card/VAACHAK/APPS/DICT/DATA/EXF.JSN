{"EXFETATION":[{"def":"Imperfect fetation in some organ exterior to the uterus; extra- uterine fetation.","pos":""}],"EXFOLIATE":[{"def":"To split into scales, especially to become converted into scales at the result of heat or decomposition.","pos":""}],"EXFOLIATION":[{"def":"The scaling off of a bone, a rock, or a mineral, etc.","pos":""}],"EXFOLIATIVE":[{"def":"Having the power of causing exfoliation.","pos":""},{"def":"An exfoliative agent.","pos":""}]}