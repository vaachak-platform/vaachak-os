{"TEA":[{"def":"The prepared leaves of a shrub, or small tree (Thea, or Camellia, Chinensis).","pos":""},{"def":"A decoction or infusion of tea leaves in boiling water; as, tea is a common beverage.","pos":""}],"TEA-SAUCER":[{"def":"A small saucer in which a teacup is set.","pos":""}],"TEABERRY":[{"def":"The checkerberry.","pos":""}],"TEACH":[{"def":"To impart the knowledge of; to give intelligence concerning; to impart, as knowledge before unknown, or rules for practice; to inculcate as true or important; to exhibit impressively; as, to teach arithmetic, dancing, music, or the like; to teach morals.","pos":""},{"def":"To direct, as an instructor; to manage, as a preceptor; to guide the studies of; to instruct; to inform; to conduct through a course of studies; as, to teach a child or a class.","pos":""}],"TEACHABLE":[{"def":"Capable of being taught; apt to learn; also, willing to receive instruction; docile.","pos":""}],"TEACHABLENESS":[{"def":"Willingness to be taught.","pos":""}],"TEACHE":[{"def":"One of the series of boilers in which the cane juice is treated in making sugar; especially, the last boiler of the series.","pos":""}],"TEACHER":[{"def":"One who teaches or instructs; one whose business or occupation is to instruct others; an instructor; a tutor.","pos":""},{"def":"One who instructs others in religion; a preacher; a minister of the gospel; sometimes, one who preaches without regular ordination.","pos":""}],"TEACHING":[{"def":"The act or business of instructing; also, that which is taught; instruction.","pos":""}],"TEACUP":[{"def":"A small cup from which to drink tea.","pos":""}],"TEACUPFUL":[{"def":"As much as a teacup can hold; enough to fill a teacup.","pos":""}],"TEAGLE":[{"def":"A hoisting apparatus; an elevator; a crane; a lift.","pos":""}],"TEAGUE":[{"def":"An Irishman; -- a term used in contempt.","pos":""}],"TEAK":[{"def":"A tree of East Indies (Tectona grandis) which furnishes an extremely strong and durable timber highly valued for shipbuilding and other purposes; also, the timber of the tree.","pos":""}],"TEAKETTLE":[{"def":"A kettle in which water is boiled for making tea, coffee, etc.","pos":""}],"TEAL":[{"def":"Any one of several species of small fresh-water ducks of the genus Anas and the subgenera Querquedula and Nettion.","pos":""}],"TEAM":[{"def":"A flock of wild ducks.","pos":""},{"def":"A royalty or privilege granted by royal charter to a lord of a manor, of having, keeping, and judging in his court, his bondmen, neifes, and villains, and their offspring, or suit, that is, goods and chattels, and appurtenances thereto.","pos":""}],"TEAMED":[{"def":"Yoked in, or as in, a team.","pos":""}],"TEAMING":[{"def":"The act or occupation of driving a team, or of hauling or carrying, as logs, goods, or the like, with a team.","pos":""}],"TEAMSTER":[{"def":"One who drives a team.","pos":""}],"TEAMWORK":[{"def":"Work done by a team, as distinguished from that done by personal labor.","pos":""}],"TEAPOT":[{"def":"A vessel with a spout, in which tea is made, and from which it is poured into teacups.","pos":""}],"TEAPOY":[{"def":"An ornamental stand, usually with three legs, having caddies for holding tea.","pos":""}],"TEAR":[{"def":"A drop of the limpid, saline fluid secreted, normally in small amount, by the lachrymal gland, and diffused between the eye and the eyelids to moisten the parts and facilitate their motion.","pos":""}],"TEAR-FALLING":[{"def":"Shedding tears; tender.","pos":""}],"TEAR-THUMB":[{"def":"A name given to several species of plants of the genus Polygonum, having angular stems beset with minute reflexed prickles.","pos":""}],"TEARER":[{"def":"One who tears or rends anything; also, one who rages or raves with violence.","pos":""}],"TEARFUL":[{"def":"Abounding with tears; weeping; shedding tears; as, tearful eyes.","pos":""}],"TEARLESS":[{"def":"Shedding no tears; free from tears; unfeeling.","pos":""}],"TEARPIT":[{"def":"A cavity or pouch beneath the lower eyelid of most deer and antelope; the lachrymal sinus; larmier.","pos":""}],"TEARY":[{"def":"Wet with tears; tearful.","pos":""},{"def":"Consisting of tears, or drops like tears.","pos":""}],"TEASE":[{"def":"To tear or separate into minute shreds, as with needles or similar instruments.","pos":""}],"TEASEL":[{"def":"A plant of the genus Dipsacus, of which one species (D.","pos":""}],"TEASELER":[{"def":"One who uses teasels for raising a nap on cloth.","pos":""}],"TEASELING":[{"def":"The cutting and gathering of teasels; the use of teasels.","pos":""}],"TEASER":[{"def":"One who teases or vexes.","pos":""}],"TEASPOON":[{"def":"A small spoon used in stirring and sipping tea, coffee, etc.","pos":""}],"TEASPOONFUL":[{"def":"As much as teaspoon will hold; enough to fill a teaspoon; -- usually reckoned at a fluid dram or one quarter of a tablespoonful.","pos":""}],"TEAT":[{"def":"A small protuberance or nozzle resembling the teat of an animal.","pos":""}],"TEATED":[{"def":"Having protuberances resembling the teat of an animal.","pos":""}],"TEATISH":[{"def":"Peevish; tettish; fretful; -- said of a child.","pos":""}],"TEAZE-HOLE":[{"def":"The opening in the furnaces through which fuel is introduced.","pos":""}],"TEAZER":[{"def":"The stoker or fireman of a furnace, as in glass works.","pos":""}]}