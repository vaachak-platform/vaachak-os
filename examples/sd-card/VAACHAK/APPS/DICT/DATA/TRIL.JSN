{"TRILATERAL":[{"def":"Having three sides; being three-sided; as, a trilateral triangle.","pos":""}],"TRILEMMA":[{"def":"A syllogism with three conditional propositions, the major premises of which are disjunctively affirmed in the minor.","pos":""}],"TRILINEAR":[{"def":"Of, pertaining to, or included by, three lines; as, trilinear coördinates.","pos":""}],"TRILINGUAL":[{"def":"Containing, or consisting of, three languages; expressed in three languages.","pos":""}],"TRILITERAL":[{"def":"Consisting of three letters; trigrammic; as, a triliteral root or word.","pos":""},{"def":"A triliteral word.","pos":""}],"TRILITERALISM":[{"def":"Same as Triliterality.","pos":""},{"def":"The quality of being triliteral; as, the triliterality of Hebrew roots.","pos":""}],"TRILITH":[{"def":"Same as Trilithon.","pos":""}],"TRILITHIC":[{"def":"Pertaining to a trilith.","pos":""}],"TRILITHON":[{"def":"A monument consisting of three stones; especially, such a monument forming a kind of doorway, as among the ancient Celts.","pos":""}],"TRILL":[{"def":"To flow in a small stream, or in drops rapidly succeeding each other; to trickle.","pos":""}],"TRILLACHAN":[{"def":"The oyster catcher.","pos":""}],"TRILLING":[{"def":"A compound crystal, consisting of three individuals.","pos":""}],"TRILLIUM":[{"def":"A genus of liliaceous plants; the three-leaved nightshade; -- so called because all the parts of the plant are in threes.","pos":""}],"TRILLO":[{"def":"A trill or shake.","pos":""}],"TRILOBATE":[{"def":"Having three lobes.","pos":""}],"TRILOBATION":[{"def":"The state of being trilobate.","pos":""}],"TRILOBED":[{"def":"Same as Trilobate.","pos":""}],"TRILOBITA":[{"def":"An extinct order of arthropods comprising the trilobites.","pos":""}],"TRILOBITE":[{"def":"Any one of numerous species of extinct arthropods belonging to the order Trilobita.","pos":""}],"TRILOBITIC":[{"def":"Of, pertaining to or containing, trilobites; as, trilobitic rocks.","pos":""}],"TRILOCULAR":[{"def":"Having three cells or cavities; as, a trilocular capsule; a trilocular heart.","pos":""}],"TRILOGY":[{"def":"A series of three dramas which, although each of them is in one sense complete, have a close mutual relation, and form one historical and poetical picture.","pos":""},{"def":"Having three lights [R.","pos":""}]}