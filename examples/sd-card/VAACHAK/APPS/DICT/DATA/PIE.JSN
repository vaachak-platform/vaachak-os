{"PIE":[{"def":"An article of food consisting of paste baked with something in it or under it; as, chicken pie; venison pie; mince pie; apple pie; pumpkin pie.","pos":""}],"PIEBALD":[{"def":"Having spots and patches of black and white, or other colors; mottled; pied.","pos":""}],"PIECE":[{"def":"One of the superior men, distinguished from a pawn.","pos":""}],"PIECELESS":[{"def":"Not made of pieces; whole; entire.","pos":""}],"PIECELY":[{"def":"In pieces; piecemeal.","pos":""}],"PIECEMEAL":[{"def":"In pieces; in parts or fragments.","pos":""},{"def":"Piece by piece; by little and little in succession.","pos":""}],"PIECEMEALED":[{"def":"Divided into pieces.","pos":""}],"PIECENER":[{"def":"One who supplies rolls of wool to the slubbing machine in woolen mills.","pos":""},{"def":"Same as Piecer, 2.","pos":""}],"PIECER":[{"def":"One who pieces; a patcher.","pos":""},{"def":"A child employed in spinning mill to tie together broken threads.","pos":""}],"PIECEWORK":[{"def":"Work done by the piece or job; work paid for at a rate based on the amount of work done, rather than on the time employed.","pos":""}],"PIED":[{"def":"Variegated with spots of different colors; party-colored; spotted; piebald.","pos":""}],"PIEDMONT":[{"def":"Noting the region of foothills near the base of a mountain chain.","pos":""}],"PIEDMONTITE":[{"def":"A manganesian kind of epidote, from Piedmont.","pos":""}],"PIEDNESS":[{"def":"The state of being pied.","pos":""}],"PIEDOUCHE":[{"def":"A pedestal of small size, used to support small objects, as busts, vases, and the like.","pos":""}],"PIEMAN":[{"def":"A man who makes or sells pies.","pos":""}],"PIENO":[{"def":"Full; having all the instruments.","pos":""}],"PIEPLANT":[{"def":"A plant (Rheum Rhaponticum) the leafstalks of which are acid, and are used in making pies; the garden rhubarb.","pos":""},{"def":"An ancient court of record in England, formerly incident to every fair and market, of which the steward of him who owned or had the toll was the judge.","pos":""}],"PIER":[{"def":"A projecting wharf or landing place.","pos":""}],"PIERAGE":[{"def":"Same as Wharfage.","pos":""}],"PIERCE":[{"def":"To thrust into, penetrate, or transfix, with a pointed instrument.","pos":""},{"def":"To penetrate; to enter; to force a way into or through; to pass into or through; as, to pierce the enemy's line; a shot pierced the ship.","pos":""}],"PIERCEABLE":[{"def":"That may be pierced.","pos":""}],"PIERCED":[{"def":"Penetrated; entered; perforated.","pos":""}],"PIERCEL":[{"def":"A kind of gimlet for making vents in casks; -- called also piercer.","pos":""}],"PIERCER":[{"def":"One who, or that which, pierces or perforates; specifically: (a) An instrument used in forming eyelets; a stiletto.","pos":""}],"PIERCING":[{"def":"Forcibly entering, or adapted to enter, at or by a point; perforating; penetrating; keen; -- used also figuratively; as, a piercing instrument, or thrust.","pos":""}],"PIERIAN":[{"def":"Of or pertaining to Pierides or Muses.","pos":""}],"PIERID":[{"def":"Any butterfly of the genus Pieris and related genera.","pos":""}],"PIERRE-PERDU":[{"def":"Blocks of stone or concrete heaped loosely in the water to make a foundation (as for a sea wall), a mole, etc.","pos":""}],"PIETA":[{"def":"A representation of the dead Christ, attended by the Virgin Mary or by holy women and angels.","pos":""}],"PIETISM":[{"def":"The principle or practice of the Pietists.","pos":""},{"def":"Strict devotion; also, affectation of devotion.","pos":""}],"PIETIST":[{"def":"One of a class of religious reformers in Germany in the 17th century who sought to revive declining piety in the Protestant churches; -- often applied as a term of reproach to those who make a display of religious feeling.","pos":""},{"def":"Of or pertaining to the Pietists; hence, in contempt, affectedly or demonstratively religious.","pos":""}],"PIETRA DURA":[{"def":"Hard and fine stones in general, such as are used for inlay and the like, as distinguished from the softer stones used in building; thus, a Florentine mosaic is a familiar instance of work in pietra dura, though the ground may be soft marble.","pos":""}],"PIETY":[{"def":"Veneration or reverence of the Supreme Being, and love of his character; loving obedience to the will of God, and earnest devotion to his service.","pos":""},{"def":"Duty; dutifulness; filial reverence and devotion; affectionate reverence and service shown toward parents, relatives, benefactors, country, etc.","pos":""}],"PIEWIPE":[{"def":"The lapwing, or pewit.","pos":""}],"PIEZOMETER":[{"def":"An instrument for measuring the compressibility of liquids.","pos":""},{"def":"A gauge connected with a water main to show the pressure at that point.","pos":""}]}