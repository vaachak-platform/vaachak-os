{"IMIDE":[{"def":"A compound with, or derivative of, the imido group; specif.","pos":""}],"IMIDO":[{"def":"Pertaining to, containing, or combined with, the radical NH, which is called the imido group.","pos":""}],"IMITABILITY":[{"def":"The quality of being imitable.","pos":""}],"IMITABLE":[{"def":"Capble of being imitated or copied.","pos":""},{"def":"Worthy of imitation; as, imitable character or qualities.","pos":""}],"IMITABLENESS":[{"def":"The state or quality of being imitable; worthness of imitation.","pos":""}],"IMITANCY":[{"def":"Tendency to imitation.","pos":""}],"IMITATE":[{"def":"To follow as a pattern, model, or example; to copy or strive to copy, in acts, manners etc.","pos":""},{"def":"To produce a semblance or likeness of, in form, character, color, qualities, conduct, manners, and the like; to counterfeit; to copy.","pos":""}],"IMITATION":[{"def":"One of the principal means of securing unity and consistency in polyphonic composition; the repetition of essentially the same melodic theme, phrase, or motive, on different degrees of pitch, by one or more of the other parts of voises.","pos":""},{"def":"The act of condition of imitating another species of animal, or a plant, or unanimate object.","pos":""}],"IMITATIONAL":[{"def":"Pertaining to, or employed in, imitation; as, imitational propensities.","pos":""}],"IMITATIVE":[{"def":"Designed to imitate another species of animal, or a plant, or inanimate object, for some useful purpose, such as protection from enemies; having resamblance to something else; as, imitative colors; imitative habits; dendritic and mammillary forms of minerals are imitative.","pos":""}],"IMITATOR":[{"def":"One who imitates.","pos":""}],"IMITATORSHIP":[{"def":"The state or office of an imitator.","pos":""}],"IMITATRESS":[{"def":"A woman who is an imitator.","pos":""}]}