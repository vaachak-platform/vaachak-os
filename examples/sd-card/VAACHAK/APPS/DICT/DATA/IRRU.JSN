{"IRRUBRICAL":[{"def":"Contrary to the rubric; not rubrical.","pos":""}],"IRRUPTED":[{"def":"Broken with violence.","pos":""}],"IRRUPTION":[{"def":"A bursting in; a sudden, violent rushing into a place; as, irruptions of the sea.","pos":""},{"def":"A sudden and violent inroad, or entrance of invaders; as, the irruptions of the Goths into Italy.","pos":""}],"IRRUPTIVE":[{"def":"Rushing in or upon.","pos":""}]}