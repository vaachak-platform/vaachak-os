{"SUBIMAGO":[{"def":"A stage in the development of certain insects, such as the May flies, intermediate between the pupa and imago.","pos":""}],"SUBINCUSATION":[{"def":"A slight charge or accusation.","pos":""}],"SUBINDEX":[{"def":"A number or mark placed opposite the lower part of a letter or symbol to distinguish the symbol; thus, a0, b1, c2, xn, have 0, 1, 2, and n as subindices.","pos":""}],"SUBINDICATE":[{"def":"To indicate by signs or hints; to indicate imperfectly.","pos":""}],"SUBINDICATION":[{"def":"The act of indicating by signs; a slight indication.","pos":""}],"SUBINDIVIDUAL":[{"def":"A division of that which is individual.","pos":""}],"SUBINDUCE":[{"def":"To insinuate; to offer indirectly.","pos":""}],"SUBINFER":[{"def":"To infer from an inference already made.","pos":""}],"SUBINFEUDATION":[{"def":"Sub*in`feu*da\"tion, n.","pos":""}],"SUBINGRESSION":[{"def":"Secret entrance.","pos":""}],"SUBINTESTINAL":[{"def":"Situated under, or on the ventral side of, the intestine.","pos":""}],"SUBINVOLUTION":[{"def":"Partial or incomplete involution; as, subinvolution of the uterus.","pos":""}],"SUBITANY":[{"def":"Subitaneous; sudden; hasty.","pos":""}],"SUBITO":[{"def":"In haste; quickly; rapidly.","pos":""}]}