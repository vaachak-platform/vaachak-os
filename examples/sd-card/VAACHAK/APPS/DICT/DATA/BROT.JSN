{"BROTH":[{"def":"Liquid in which flesh (and sometimes other substances, as barley or rice) has been boiled; thin or simple soup.","pos":""}],"BROTHEL":[{"def":"A house of lewdness or ill fame; a house frequented by prostitutes; a bawdyhouse.","pos":""}],"BROTHELER":[{"def":"One who frequents brothels.","pos":""}],"BROTHELRY":[{"def":"Lewdness; obscenity; a brothel.","pos":""}],"BROTHER":[{"def":"A male person who has the same father and mother with another person, or who has one of them only.","pos":""},{"def":"One related or closely united to another by some common tie or interest, as of rank, profession, membership in a society, toil, suffering, etc.","pos":""}],"BROTHER GERMAN":[{"def":"A brother by both the father's and mother's side, in contradistinction to a uterine brother, one by the mother only.","pos":""}],"BROTHER-IN-LAW":[{"def":"The brother of one's husband or wife; also, the husband of one's sister; sometimes, the husband of one's wife's sister.","pos":""}],"BROTHERHOOD":[{"def":"The state of being brothers or a brother.","pos":""},{"def":"An association for any purpose, as a society of monks; a fraternity.","pos":""}],"BROTHERLINESS":[{"def":"The state or quality of being brotherly.","pos":""}],"BROTHERLY":[{"def":"Of or pertaining to brothers; such as is natural for brothers; becoming to brothers; kind; affectionate; as, brotherly love.","pos":""}]}