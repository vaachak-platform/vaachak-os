{"MELACONITE":[{"def":"An earthy black oxide of copper, arising from the decomposition of other ores.","pos":""},{"def":"A mixture of sugar and molasses; crude sugar as it comes from the pans without being drained.","pos":""}],"MELAENA":[{"def":"A discharge from the bowels of black matter, consisting of altered blood.","pos":""}],"MELAIN":[{"def":"The dark coloring matter of the liquid of the cuttlefish.","pos":""}],"MELAMINE":[{"def":"A strong nitrogenous base, C3H6N6, produced from several cyanogen compounds, and obtained as a white crystalline substance, -- formerly supposed to be produced by the decomposition of melam.","pos":""}],"MELAMPODE":[{"def":"The black hellebore.","pos":""},{"def":"The saccharine substance dulcite; -- so called because found in the leaves of cowwheat (Melampyrum).","pos":""}],"MELANAEMIA":[{"def":"A morbid condition in which the blood contains black pigment either floating freely or imbedded in the white blood corpuscles.","pos":""}],"MELANAGOGUE":[{"def":"A medicine supposed to expel black bile or choler.","pos":""}],"MELANCHOLIA":[{"def":"A kind of mental unsoundness characterized by extreme depression of spirits, ill-grounded fears, delusions, and brooding over one particular subject or train of ideas.","pos":""}],"MELANCHOLIAN":[{"def":"A person affected with melancholy; a melancholic.","pos":""}],"MELANCHOLIC":[{"def":"Given to melancholy; depressed; melancholy; dejected; unhappy.","pos":""}],"MELANCHOLILY":[{"def":"In a melancholy manner.","pos":""}],"MELANCHOLINESS":[{"def":"The state or quality of being melancholy.","pos":""}],"MELANCHOLIST":[{"def":"One affected with melancholy or dejection.","pos":""}],"MELANCHOLIZE":[{"def":"To become gloomy or dejected in mind.","pos":""}],"MELANCHOLY":[{"def":"Depression of spirits; a gloomy state continuing a considerable time; deep dejection; gloominess.","pos":""},{"def":"Great and continued depression of spirits, amounting to mental unsoundness; melancholia.","pos":""}],"MELANCONIACEAE":[{"def":"A family of fungi constituting the order Melanconiales.","pos":""}],"MELANCONIALES":[{"def":"The smallest of the three orders of Fungi Imperfecti, including those with no asci nor pycnidia, but as a rule having the spores in cavities without special walls.","pos":""}],"MELANESIAN":[{"def":"Of or pertaining to Melanesia.","pos":""}],"MELANGE":[{"def":"A mixture; a medley.","pos":""}],"MELANIAN":[{"def":"One of a family of fresh-water pectinibranchiate mollusks, having a turret-shaped shell.","pos":""}],"MELANIC":[{"def":"Of or pertaining to the black-haired races.","pos":""}],"MELANILINE":[{"def":"A complex nitrogenous hydrocarbon obtained artificially (as by the action of cyanogen chloride on aniline) as a white, crystalline substance; -- called also diphenyl guanidin.","pos":""}],"MELANIN":[{"def":"A black pigment found in the pigment-bearing cells of the skin (particularly in the skin of the negro), in the epithelial cells of the external layer of the retina (then called fuscin), in the outer layer of the choroid, and elsewhere.","pos":""}],"MELANISM":[{"def":"A disease; black jaundice.","pos":""}],"MELANISTIC":[{"def":"Affected with melanism; of the nature of melanism.","pos":""}],"MELANITE":[{"def":"A black variety of garnet.","pos":""}],"MELANOCHROI":[{"def":"A group of the human race, including the dark whites.","pos":""}],"MELANOCHROIC":[{"def":"Having a dark complexion; of or pertaining to the Melanochroi.","pos":""}],"MELANOCHROITE":[{"def":"A mineral of a red, or brownish or yellowish red color.","pos":""}],"MELANOCOMOUS":[{"def":"Having very dark or black hair; black-haired.","pos":""}],"MELANORRHOEA":[{"def":"An East Indian genus of large trees.","pos":""}],"MELANOSCOPE":[{"def":"An instrument containing a combination of colored glasses such that they transmit only red light, so that objects of other colors, as green leaves, appear black when seen through it.","pos":""}],"MELANOSIS":[{"def":"The morbid deposition of black matter, often of a malignant character, causing pigmented tumors.","pos":""}],"MELANOSPERM":[{"def":"An alga of any kind that produces blackish spores, or seed dust.","pos":""}],"MELANOTIC":[{"def":"Mel`a*not\"ic Defn: , Melanistic.","pos":""}],"MELANOTYPE":[{"def":"A positive picture produced with sensitized collodion on a smooth surface of black varnish, coating a thin plate of iron; also, the process of making such a picture.","pos":""}],"MELANTERITE":[{"def":"A hydrous sulphate of iron of a green color and vitreous luster; iron vitriol.","pos":""}],"MELANURE":[{"def":"A small fish of the Mediterranean; a gilthead.","pos":""}],"MELANURIC":[{"def":"Pertaining to, or designating, a complex nitrogenous acid obtained by decomposition of melam, or of urea, as a white crystalline powder; -- called also melanurenic acid.","pos":""}],"MELAPHYRE":[{"def":"Any one of several dark-colored augitic, eruptive rocks allied to basalt.","pos":""}],"MELASMA":[{"def":"A dark discoloration of the skin, usually local; as, Addison's melasma, or Addison's disease.","pos":""}],"MELASSIC":[{"def":"Pertaining to, or designating, an acid obtained from molasses or glucose, and probably identical with saccharic acid.","pos":""}],"MELASTOMA":[{"def":"A genus of evergreen tropical shrubs; -- so called from the black berries of some species, which stain the mouth.","pos":""}],"MELASTOMACEOUS":[{"def":"Belonging to the order of which Melastoma is the type.","pos":""}],"MELCHITE":[{"def":"One of a sect, chiefly in Syria and Egypt, which acknowledges the authority of the pope, but adheres to the liturgy and ceremonies of the Eastern Church.","pos":""}],"MELD":[{"def":"In the game of pinochle, to declare or announce for a score; as, to meld a sequence.","pos":""}],"MELEAGRINE":[{"def":"Of or pertaining to the genus Meleagris.","pos":""}],"MELEAGRIS":[{"def":"A genus of American gallinaceous birds, including the common and the wild turkeys.","pos":""}],"MELENE":[{"def":"An unsaturated hydrocarbon, C30H60, of the ethylene series, obtained from beeswax as a white, scaly, crystalline wax; -- called also melissene, and melissylene.","pos":""}],"MELENITE":[{"def":"An explosive of great destructive power; -- so called from its color, which resembles honey.","pos":""}],"MELEZITOSE":[{"def":"A variety of sugar, isomeric with sucrose, extracted from the manna of the larch (Larix).","pos":""}],"MELIACEOUS":[{"def":"Pertaining to a natural order (Meliacæ) of plants of which the genus Melia is the type.","pos":""},{"def":"Alternately responsive, as verses.","pos":""}],"MELIC":[{"def":"Of or pertaining to song; lyric; tuneful.","pos":""}],"MELIC GRASS":[{"def":"A genus of grasses (Melica) of little agricultural importance.","pos":""}],"MELICEROUS":[{"def":"Consisting of or containing matter like honey; -- said of certain encysted tumors.","pos":""}],"MELICRATORY":[{"def":"A meadlike drink.","pos":""}],"MELILITE":[{"def":"A mineral occurring in small yellow crystals, found in the lavas (melilite basalt) of Vesuvius, and elsewhere.","pos":""}],"MELILOT":[{"def":"Any species of Melilotus, a genus of leguminous herbs having a vanillalike odor; sweet clover; hart's clover.","pos":""}],"MELILOTIC":[{"def":"Of, pertaining to, or obtained from, sweet clover or meliot; specifically, designating an acid of the aromatic series, obtained from melilot as a white crystalline substance.","pos":""}],"MELINITE":[{"def":"A high explosive similar to lyddite, consisting principally of picric acid, used in the French military service.","pos":""}],"MELIORATE":[{"def":"To make better; to improve; to ameliorate; to soften; to make more tolerable.","pos":""}],"MELIORATER":[{"def":"Same as Meliorator.","pos":""}],"MELIORATION":[{"def":"The act or operation of meliorating, or the state of being meliorated; improvement.","pos":""}],"MELIORATOR":[{"def":"One who meliorates.","pos":""}],"MELIORISM":[{"def":"The doctrine that there is a tendency throughout nature toward improvement.","pos":""}],"MELIORITY":[{"def":"The state or quality of being better; melioration.","pos":""}],"MELIPHAGAN":[{"def":"Belonging to the genus Meliphaga.","pos":""}],"MELIPHAGOUS":[{"def":"Eating, or feeding upon, honey.","pos":""}],"MELISSA":[{"def":"A genus of labiate herbs, including the balm, or bee balm (Melissa officinalis).","pos":""}],"MELISSIC":[{"def":"Pertaining to, or derived from, beeswax; specif.","pos":""}],"MELITOSE":[{"def":"A variety of sugar isomeric with sucrose, extracted from cotton seeds and from the so-called Australian manna (a secretion of certain species of Eucalyptus).","pos":""}],"MELL":[{"def":"To mix; to meddle.","pos":""}],"MELLAY":[{"def":"A mêlée; a conflict.","pos":""}],"MELLIFEROUS":[{"def":"Producing honey.","pos":""}],"MELLIFIC":[{"def":"Producing honey.","pos":""}],"MELLIFICATION":[{"def":"The making or production of honey.","pos":""}],"MELLIFLUENCE":[{"def":"A flow of sweetness, or a sweet, smooth flow.","pos":""}],"MELLIFLUENT":[{"def":"Flowing as with honey; smooth; mellifluous.","pos":""}],"MELLIFLUENTLY":[{"def":"In a mellifluent manner.","pos":""}],"MELLIFLUOUS":[{"def":"Flowing as with honey; smooth; flowing sweetly or smoothly; as, a mellifluous voice.","pos":""}],"MELLIGENOUS":[{"def":"Having the qualities of honey.","pos":""}],"MELLILOQUENT":[{"def":"Speaking sweetly or harmoniously.","pos":""}],"MELLIPHAGOUS":[{"def":"See Meliphagous.","pos":""}],"MELLITATE":[{"def":"A salt of mellitic acid.","pos":""}],"MELLITE":[{"def":"A mineral of a honey color, found in brown coal, and partly the result of vegetable decomposition; honeystone.","pos":""}],"MELLONE":[{"def":"A yellow powder, C6H3N9, obtained from certain sulphocyanates.","pos":""}],"MELLOW":[{"def":"Soft or tender by reason of ripeness; having a tender pulp; as, a mellow apple.","pos":""},{"def":"Hence: (a) Easily worked or penetrated; not hard or rigid; as, a mellow soil.","pos":""}],"MELLOWLY":[{"def":"In a mellow manner.","pos":""}],"MELLOWNESS":[{"def":"Quality or state of being mellow.","pos":""}],"MELLUCO":[{"def":"A climbing plant (Ullucus officinalis) of the Andes, having tuberous roots which are used as a substitute for potatoes.","pos":""}],"MELNE":[{"def":"MELOCOTON; MELOCOTOON Mel`o*co*ton\", Mel`o*co*toon\", n.","pos":""}],"MELODEON":[{"def":"A kind of small reed organ; -- a portable form of the seraphine.","pos":""}],"MELODIC":[{"def":"Of the nature of melody; relating to, containing, or made up of, melody; melodious.","pos":""}],"MELODICS":[{"def":"The department of musical science which treats of the pitch of tones, and of the laws of melody.","pos":""}],"MELODIOGRAPH":[{"def":"A contrivance for preserving a record of music, by recording the action of the keys of a musical instrument when played upon.","pos":""}],"MELODIOUS":[{"def":"Containing, or producing, melody; musical; agreeable to the ear by a sweet succession of sounds; as, a melodious voice.","pos":""}],"MELODIST":[{"def":"A composer or singer of melodies.","pos":""}],"MELODIZE":[{"def":"To make melodious; to form into, or set to, melody.","pos":""}],"MELODRAMA":[{"def":"Formerly, a kind of drama having a musical accompaniment to intensify the effect of certain scenes.","pos":""}],"MELODRAMATIC":[{"def":"Of or pertaining to melodrama; like or suitable to a melodrama; unnatural in situation or action.","pos":""}],"MELODRAMATIST":[{"def":"One who acts in, or writes, melodramas.","pos":""}],"MELODY":[{"def":"A rhythmical succession of single tones, ranging for the most part within a given key, and so related together as to form a musical whole, having the unity of what is technically called a musical thought, at once pleasing to the ear and characteristic in expression.","pos":""}],"MELOE":[{"def":"A genus of beetles without wings, but having short oval elytra; the oil beetles.","pos":""}],"MELOGRAPH":[{"def":"Same as Melodiograph.","pos":""}],"MELOLONTHIDIAN":[{"def":"A beetle of the genus Melolontha, and allied genera.","pos":""}],"MELON":[{"def":"The juicy fruit of certain cucurbitaceous plants, as the muskmelon, watermelon, and citron melon; also, the plant that produces the fruit.","pos":""},{"def":"A large, ornamental, marine, univalve shell of the genus Melo.","pos":""}],"MELOPIANO":[{"def":"A piano having a mechanical attachment which enables the player to prolong the notes at will.","pos":""}],"MELOPLASTIC":[{"def":"Of or pertaining to meloplasty, or the artificial formation of a new cheek.","pos":""}],"MELOPLASTY":[{"def":"The process of restoring a cheek which has been destroyed wholly or in part.","pos":""}],"MELOPOEIA":[{"def":"The art of forming melody; melody; -- now often used for a melodic passage, rather than a complete melody.","pos":""}],"MELOTYPE":[{"def":"A picture produced by a process in which development after exposure may be deferred indefinitely, so as to permit transportation of exposed plates; also, the process itself.","pos":""}],"MELPOMENE":[{"def":"The Muse of tragedy.","pos":""},{"def":"The eighteenth asteroid.","pos":""}],"MELT":[{"def":"To reduce from a solid to a liquid state, as by heat; to liquefy; as, to mell wax, tallow, or lead; to melt ice or snow.","pos":""},{"def":"Hence: To soften, as by a warming or kindly influence; to relax; to render gentle or susceptible to mild influences; sometimes, in a bad sense, to take away the firmness of; to weaken.","pos":""}],"MELTABLE":[{"def":"Capable of being melted.","pos":""}],"MELTER":[{"def":", One who, or that which, melts.","pos":""}],"MELTING":[{"def":"Liquefaction; the act of causing (something) to melt, or the process of becoming melted.","pos":""}],"MELTON":[{"def":"A kind of stout woolen cloth with unfinished face and without raised nap.","pos":""}],"MELUNGEON":[{"def":"One of a mixed white and Indian people living in parts of Tennessee and the Carolinas.","pos":""}]}