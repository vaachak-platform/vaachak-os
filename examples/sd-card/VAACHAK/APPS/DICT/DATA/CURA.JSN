{"CURABILITY":[{"def":"The state of being curable; curableness.","pos":""}],"CURABLE":[{"def":"Capable of being cured; admitting remedy.","pos":""},{"def":"A liqueur, or cordial, flavored with orange peel, cinnamon, and mace; -- first made at the island of Curaçcao.","pos":""}],"CURACY":[{"def":"The office or employment of a curate.","pos":""},{"def":"A black resinoid extract prepared by the South American Indians from the bark of several species of Strychnos (S.","pos":""}],"CURARINE":[{"def":"A deadly alkaloid extracted from the curare poison and from the Strychnos toxifera.","pos":""}],"CURARIZE":[{"def":"To poison with curare.","pos":""}],"CURASSOW":[{"def":"A large gallinaceous bird of the American genera Crax, Ourax, etc.","pos":""}],"CURAT":[{"def":"A cuirass or breastplate.","pos":""}],"CURATE":[{"def":"One who has the cure souls; originally, any clergyman, but now usually limited to one who assist a rector or vicar Hook.","pos":""}],"CURATION":[{"def":"Cu*ra\"tion (k-r\"shn), n.","pos":""}],"CURATIVE":[{"def":"Relating to, or employed in, the cure of diseases; tending to cure.","pos":""}],"CURATOR":[{"def":"One who has the care and superintendence of anything, as of a museum; a custodian; a keeper.","pos":""},{"def":"One appointed to act as guardian of the estate of a person not legally competent to manage it, or of an absentee; a trustee; a guardian.","pos":""}],"CURATORSHIP":[{"def":"The office of a curator.","pos":""}],"CURATRIX":[{"def":"A woman who cures.","pos":""},{"def":"A woman who is a guardian or custodian.","pos":""}]}