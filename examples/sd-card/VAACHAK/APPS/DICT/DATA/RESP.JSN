{"RESPEAK":[{"def":"To speak or utter again.","pos":""},{"def":"To answer; to echo.","pos":""}],"RESPECT":[{"def":"To take notice of; to regard with special attention; to regard as worthy of special consideration; hence, to care for; to heed.","pos":""},{"def":"To consider worthy of esteem; to regard with honor.","pos":""}],"RESPECTABILITY":[{"def":"The state or quality of being respectable; the state or quality which deserves or commands respect.","pos":""}],"RESPECTABLE":[{"def":"Worthy of respect; fitted to awaken esteem; deserving regard; hence, of good repute; not mean; as, a respectable citizen.","pos":""},{"def":"Moderate in degree of excellence or in number; as, a respectable performance; a respectable audience.","pos":""}],"RESPECTANT":[{"def":"Placed so as to face one another; -- said of animals.","pos":""}],"RESPECTER":[{"def":"One who respects.","pos":""}],"RESPECTFUL":[{"def":"Marked or characterized by respect; as, respectful deportment.","pos":""}],"RESPECTING":[{"def":"With regard or relation to; regarding; concerning; as, respecting his conduct there is but one opinion.","pos":""}],"RESPECTION":[{"def":"The act of respecting; respect; regard.","pos":""}],"RESPECTIVE":[{"def":"Noticing with attention; hence, careful; wary; considerate.","pos":""},{"def":"Looking towardl having reference to; relative, not absolute; as, the respective connections of society.","pos":""}],"RESPECTIVELY":[{"def":"As relating to each; particularly; as each belongs to each; as each refers to each in order; as, let each man respectively perform his duty.","pos":""},{"def":"Relatively; not absolutely.","pos":""}],"RESPECTLESS":[{"def":"Having no respect; without regard; regardless.","pos":""}],"RESPECTUOUS":[{"def":"Respectful; as, a respectuous silence.","pos":""}],"RESPELL":[{"def":"Re*spell\" (r*spl\"), v.","pos":""}],"RESPERSE":[{"def":"To sprinkle; to scatter.","pos":""}],"RESPERSION":[{"def":"The act of sprinkling or scattering.","pos":""}],"RESPIRABILITY":[{"def":"The quality or state of being respirable; respirableness.","pos":""}],"RESPIRABLE":[{"def":"Suitable for being breathed; adapted for respiration.","pos":""}],"RESPIRATION":[{"def":"The act of resping or breathing; the act of taking in and giving out air; the aggregate of those processes bu which oxygen is introduced into the system, and carbon dioxide, or carbonic acid, removed.","pos":""}],"RESPIRATIONAL":[{"def":"Of or pertaining to respiration; as, respirational difficulties.","pos":""}],"RESPIRATIVE":[{"def":"Of or pertaining to respiration; as, respirative organs.","pos":""}],"RESPIRATOR":[{"def":"A divice of gauze or wire, covering the mouth or nose, to prevent the inhalation of noxious substances, as dust or smoke.","pos":""}],"RESPIRATORY":[{"def":"Of or pertaining to respiration; serving for respiration; as, the respiratory organs; respiratory nerves; the respiratory function; respiratory changes.","pos":""}],"RESPIRE":[{"def":"To breathe; to inhale air into the lungs, and exhale it from them, successively, for the purpose of maintaining the vitality of the blood.","pos":""}],"RESPITE":[{"def":"A putting off of that which was appointed; a postponement or delay.","pos":""},{"def":"Temporary intermission of labor, or of any process or operation; interval of rest; pause; delay.","pos":""}],"RESPITELESS":[{"def":"Without respite.","pos":""},{"def":"The quality or state of being resplendent; brilliant luster; vivid brightness; splendor.","pos":""}],"RESPLENDENT":[{"def":"Shining with brilliant luster; very bright.","pos":""}],"RESPLENDISHANT":[{"def":"Resplendent; brilliant.","pos":""}],"RESPLIT":[{"def":"Re*split\" (r*splt\"), v.","pos":""}],"RESPOND":[{"def":"To say somethin in return; to answer; to reply; as, to respond to a question or an argument.","pos":""},{"def":"To show some effect in return to a force; to act in response; to accord; to correspond; to suit.","pos":""}],"RESPONDENT":[{"def":"Disposed or expected to respond; answering; according; corresponding.","pos":""}],"RESPONDENTIA":[{"def":"A loan upon goods laden on board a ship.","pos":""}],"RESPONSAL":[{"def":"Re*spon\"sal (r*spn\"sal), a.","pos":""}],"RESPONSE":[{"def":"The act of responding.","pos":""},{"def":"An answer or reply.","pos":""}],"RESPONSELESS":[{"def":"Giving no response.","pos":""}],"RESPONSIBILITY":[{"def":"The state of being responsible, accountable, or answerable, as for a trust, debt, or obligation.","pos":""},{"def":"That for which anyone is responsible or accountable; as, the resonsibilities of power.","pos":""}],"RESPONSIBLE":[{"def":"Liable to respond; likely to be called upon to answer; accountable; answerable; amenable; as, a guardian is responsible to the court for his conduct in the office.","pos":""},{"def":"Able to respond or answer for one's conduct and obligations; trustworthy, financially or otherwise; as, to have a responsible man for surety.","pos":""}],"RESPONSION":[{"def":"The first university examination; -- called also little go.","pos":""}],"RESPONSIVE":[{"def":"That responds; ready or inclined to respond.","pos":""},{"def":"Suited to something else; correspondent.","pos":""}],"RESPONSORIAL":[{"def":"Responsory; antiphonal.","pos":""}],"RESPONSORY":[{"def":"Containing or making answer; answering.","pos":""}]}