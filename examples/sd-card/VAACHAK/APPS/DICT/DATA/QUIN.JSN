{"QUIN":[{"def":"A European scallop (Pecten opercularis), used as food.","pos":""}],"QUINALDINE":[{"def":"A colorless liquid of a slightly pungent odor, C9H6N.","pos":""}],"QUINARY":[{"def":"Consisting of five; arranged by fives.","pos":""}],"QUINATE":[{"def":"Growing in sets of five; -- said especially of leaves composed of five leaflets set at the end of a common petiole.","pos":""}],"QUINAZOL":[{"def":"A complex nitrogenous base related to cinnoline.","pos":""}],"QUINCE":[{"def":"a quince tree or shrub.","pos":""}],"QUINCH":[{"def":"To stir; to wince.","pos":""}],"QUINCUNCIAL":[{"def":"Having the leaves of a pentamerous calyx or corolla so imbricated that two are exterior, two are interior, and the other has one edge exterior and one interior; as, quincuncial æstivation.","pos":""}],"QUINCUNCIALLY":[{"def":"In the manner or order of a quincunx.","pos":""}],"QUINCUNX":[{"def":"The position of planets when distant from each other five signs, or 150º.","pos":""},{"def":"A quincuncial arrangement, as of the parts of a flower in æstivation.","pos":""}],"QUINDECAGON":[{"def":"A plane figure with fifteen angles, and consequently fifteen sides.","pos":""}],"QUINDECEMVIR":[{"def":"One of a sacerdotal college of fifteen men whose chief duty was to take care of the Sibylline books.","pos":""}],"QUINDECEMVIRATE":[{"def":"The body or office of the quindecemviri.","pos":""}],"QUINDECONE":[{"def":"An unsaturated hydrocarbon, C15H26, of the valylene series, produced artificially as an oily liquid.","pos":""}],"QUINDECYLIC":[{"def":"Pertaining to, or designating, an acid of the fatty acid series, containing fifteen atoms of carbon; called also pentadecylic acid.","pos":""}],"QUINDEM":[{"def":"A fifteenth part.","pos":""}],"QUINHYDRONE":[{"def":"A green crystalline substance formed by the union of quinone with hydroquinone, or as an intermediate product in the oxidation of hydroquinone or the reduction of quinone.","pos":""}],"QUINIBLE":[{"def":"An interval of a fifth; also, a part sung with such intervals.","pos":""}],"QUINIC":[{"def":"Pertaining to, derived from, or connected with, quinine and related compounds; specifically, designating a nonnitrogenous acid obtained from cinchona bark, coffee, beans, etc.","pos":""}],"QUINICINE":[{"def":"An uncrystallizable alkaloid obtained by the action of heat from quinine, with which it is isomeric.","pos":""}],"QUINIDINE":[{"def":"An alkaloid isomeric with, and resembling, quinine, found in certain species of cinchona, from which it is extracted as a bitter white crystalline substance; conchinine.","pos":""}],"QUININE":[{"def":"An alkaloid extracted from the bark of several species of cinchona (esp.","pos":""}],"QUININIC":[{"def":"Pertaining to, or designating, a nitrogenous acid obtained as a yellow crystalline substance by the oxidation of quinine.","pos":""}],"QUINIZARIN":[{"def":"A yellow crystalline substance produced artificially.","pos":""}],"QUINIZINE":[{"def":"any one of a series of nitrogenous bases, certain of which are used as antipyretics.","pos":""}],"QUINNAT":[{"def":"The California salmon (Oncorhynchus choicha); -- called also chouicha, king salmon, chinnook salmon, and Sacramento salmon.","pos":""}],"QUINOA":[{"def":"The seeds of a kind of goosewort (Chenopodium Quinoa), used in Chili and Peru for making porridge or cakes; also, food thus made.","pos":""}],"QUINOGEN":[{"def":"A hypothetical radical of quinine and related alkaloids.","pos":""}],"QUINOIDINE":[{"def":"A brownish resinous substance obtained as a by-product in the treatment of cinchona bark.","pos":""}],"QUINOLINE":[{"def":"A nitrogenous base, C9H7N obtained as a pungent colorless liquid by the distillation of alkaloids, bones, coal tar, etc.","pos":""}],"QUINOLOGIST":[{"def":"One who is versed in quinology.","pos":""}],"QUINOLOGY":[{"def":"The science which treats of the cultivation of the cinchona, and of its use in medicine.","pos":""}],"QUINONE":[{"def":"A crystalline substance, C6H4O2 (called also benzoketone), first obtained by the oxidation of quinic acid and regarded as a double ketone; also, by extension, any one of the series of which quinone proper is the type.","pos":""}],"QUINOVIC":[{"def":"Pertaining to, or designating, a crystalline acid obtained from some varieties of cinchona bark.","pos":""}],"QUINOVIN":[{"def":"An amorphous bitter glucoside derived from cinchona and other barks.","pos":""}],"QUINOXALINE":[{"def":"Any one of a series of complex nitrogenous bases obtained by the union of certain aniline derivatives with glyoxal or with certain ketones.","pos":""}],"QUINOXYL":[{"def":"The hypothetical radical of certain quinone derivatives related to rhodizonic acid.","pos":""}],"QUINOYL":[{"def":"A radical of which quinone is the hydride, analogous to phenyl.","pos":""}],"QUINQUANGULAR":[{"def":"Having five angles or corners.","pos":""}],"QUINQUARTICULAR":[{"def":"Relating to the five articles or points; as, the quinquarticular controversy between Arminians and Calvinists.","pos":""}],"QUINQUE FOLIOLATE":[{"def":"Having five leaflets.","pos":""}],"QUINQUE-":[{"def":"A combining form meaning five, five times, fivefold; as, quinquefid, five-cleft; quinquedentate, five-toothed.","pos":""}],"QUINQUEANGLED":[{"def":"Having five angles; quinquangular.","pos":""},{"def":"Five-toothed; as, a quinquedentate leaf.","pos":""}],"QUINQUEFARIOUS":[{"def":"Arranged in five vertical rows; pentastichous.","pos":""}],"QUINQUEFID":[{"def":"Sharply cut about halfway to the middle or base into five segments; as, a quinquefid leaf or corolla.","pos":""},{"def":"Having five leaves or leaflets.","pos":""}],"QUINQUELITERAL":[{"def":"Consisting of five letters.","pos":""},{"def":"Cut less than halfway into portions, usually somewhat rounded; five-lobed; as, a quinquelobate leaf or corolla.","pos":""}],"QUINQUELOBED":[{"def":"Same as Quinquelobate.","pos":""}],"QUINQUELOCULAR":[{"def":"Having five cells or loculi; five-celled; as, a quinquelocular pericarp.","pos":""}],"QUINQUENERVED":[{"def":"Having five nerves; -- said of a leaf with five nearly equal nerves or ribs rising from the end of the petiole.","pos":""}],"QUINQUENNALIA":[{"def":"Public games celebrated every five years.","pos":""}],"QUINQUENNIAL":[{"def":"Occurring once in five years, or at the end of every five years; also, lasting five years.","pos":""}],"QUINQUENNIUM":[{"def":"Space of five years.","pos":""}],"QUINQUEPARTITE":[{"def":"Divided into five parts almost to the base.","pos":""}],"QUINQUEREME":[{"def":"A galley having five benches or banks of oars; as, an Athenian quinquereme.","pos":""}],"QUINQUESYLLABLE":[{"def":"A word of five syllables.","pos":""},{"def":"Having five valves, as a pericarp.","pos":""}],"QUINQUEVIR":[{"def":"One of five commissioners appointed for some special object.","pos":""}],"QUINQUIVALENT":[{"def":"Same as Pentavalent.","pos":""}],"QUINSY":[{"def":"An inflammation of the throat, or parts adjacent, especially of the fauces or tonsils, attended by considerable swelling, painful and impeded deglutition, and accompanied by inflammatory fever.","pos":""}],"QUINT":[{"def":"The interval of a fifth.","pos":""}],"QUINTAIN":[{"def":"An object to be tilted at; -- called also quintel.","pos":""}],"QUINTAL":[{"def":"A hundredweight, either 112 or 100 pounds, according to the scale used.","pos":""},{"def":"A metric measure of weight, being 100,000 grams, or 100 kilograms, equal to 220.","pos":""}],"QUINTAN":[{"def":"Occurring as the fifth, after four others also, occurring every fifth day, reckoning inclusively; as, a quintan fever.","pos":""},{"def":"An intermittent fever which returns every fifth day, reckoning inclusively, or in which the intermission lasts three days.","pos":""}],"QUINTESSENCE":[{"def":"The fifth or last and highest essence or power in a natural body.","pos":""},{"def":"Hence: An extract from anything, containing its rarest virtue, or most subtle and essential constituent in a small quantity; pure or concentrated essence.","pos":""}],"QUINTESSENTIAL":[{"def":"Of the nature of a quintessence; purest.","pos":""},{"def":"A composition for five voices or instruments; also, the set of five persons who sing or play five-part music.","pos":""}],"QUINTIC":[{"def":"Of the fifth degree or order.","pos":""},{"def":"A quantic of the fifth degree.","pos":""}],"QUINTILE":[{"def":"The aspect of planets when separated the fifth part of the zodiac, or 72º.","pos":""}],"QUINTILLLION":[{"def":"According to the French notation, which is used on the Continent and in America, the cube of a million, or a unit with eighteen ciphers annexed; according to the English notation, a number produced by involving a million to the fifth power, or a unit with thirty ciphers annexed.","pos":""}],"QUINTINE":[{"def":"The embryonic sac of an ovule, sometimes regarded as an innermost fifth integument.","pos":""}],"QUINTOLE":[{"def":"A group of five notes to be played or sung in the time of four of the same species.","pos":""}],"QUINTROON":[{"def":"The off-spring of an octoroon and a white person.","pos":""}],"QUINTUPLE":[{"def":"Multiplied by five; increased to five times the amount; fivefold.","pos":""}],"QUINTUPLET":[{"def":"A collection or combination of five of a kind.","pos":""},{"def":"A cycle having five crank shafts and adapted for five riders, all of whom can assist in the propulsion.","pos":""}],"QUINZAINE":[{"def":"The fifteenth day after a feast day, including both in the reckoning.","pos":""}],"QUINZE":[{"def":"A game at cards in which the object is to make fifteen points.","pos":""}]}