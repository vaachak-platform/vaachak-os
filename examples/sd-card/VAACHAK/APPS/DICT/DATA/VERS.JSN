{"VERS":[{"def":"A verse or verses.","pos":""}],"VERS DE SOCIETE":[{"def":"See Society verses, under Society.","pos":""}],"VERSABILITY":[{"def":"The quality or state of being versable.","pos":""}],"VERSABLE":[{"def":"Capable of being turned.","pos":""}],"VERSANT":[{"def":"Familiar; conversant.","pos":""}],"VERSATILE":[{"def":"Capable of turning; freely movable; as, a versatile anther, which is fixed at one point to the filament, and hence is very easily turned around; a versatile toe of a bird.","pos":""}],"VERSATILITY":[{"def":"The quality or state of being versatile; versatileness.","pos":""}],"VERSE":[{"def":"A line consisting of a certain number of metrical feet (see Foot, n.","pos":""},{"def":"Metrical arrangement and language; that which is composed in metrical form; versification; poetry.","pos":""}],"VERSED":[{"def":"Acquainted or familiar, as the result of experience, study, practice, etc.","pos":""}],"VERSEMAN":[{"def":"Same as Versemonger.","pos":""}],"VERSEMONGER":[{"def":"A writer of verses; especially, a writer of commonplace poetry; a poetaster; a rhymer; -- used humorously or in contempt.","pos":""}],"VERSICLE":[{"def":"A little verse; especially, a short verse or text said or sung in public worship by the priest or minister, and followed by a response from the people.","pos":""},{"def":"Having various colors; changeable in color.","pos":""}],"VERSICULAR":[{"def":"Of or pertaining to verses; designating distinct divisions of a writing.","pos":""}],"VERSIFICATION":[{"def":"The act, art, or practice, of versifying, or making verses; the construction of poetry; metrical composition.","pos":""}],"VERSIFIER":[{"def":"One who versifies, or makes verses; as, not every versifier is a poet.","pos":""},{"def":"One who converts into verse; one who expresses in verse the ideas of another written in prose; as, Dr.","pos":""}],"VERSIFY":[{"def":"I'll versify in spite, and do my best.","pos":""}],"VERSION":[{"def":"A condition of the uterus in which its axis is deflected from its normal position without being bent upon itself.","pos":""}],"VERSIONIST":[{"def":"One who makes or favors a version; a translator.","pos":""}],"VERSO":[{"def":"The reverse, or left-hand, page of a book or a folded sheet of paper; -- opposed to recto.","pos":""}],"VERSOR":[{"def":"The turning factor of a quaternion.","pos":""}],"VERST":[{"def":"A Russian measure of length containing 3,500 English feet.","pos":""}],"VERSUAL":[{"def":"Of or pertaining to a verse.","pos":""}],"VERSUS":[{"def":"Against; as, John Doe versus Richard Roe; -- chiefly used in legal language, and abbreviated to v.","pos":""}],"VERSUTE":[{"def":"Crafty; wily; cunning; artful.","pos":""}]}