{"ANTHELION":[{"def":"A halo opposite the sun, consisting of a colored ring or rings around the shadow of the spectator's own head, as projected on a cloud or on an opposite fog bank.","pos":""}],"ANTHELIX":[{"def":"Same as Antihelix.","pos":""}],"ANTHELMINTIC":[{"def":"Good against intestinal worms.","pos":""}],"ANTHEM":[{"def":"Formerly, a hymn sung in alternate parts, in present usage, a selection from the Psalms, or other parts of the Scriptures or the liturgy, set to sacred music.","pos":""},{"def":"A song or hymn of praise.","pos":""}],"ANTHEMION":[{"def":"A floral ornament.","pos":""}],"ANTHEMIS":[{"def":"Chamomile; a genus of composite, herbaceous plants.","pos":""}],"ANTHER":[{"def":"That part of the stamen containing the pollen, or fertilizing dust, which, when mature, is emitted for the impregnation of the ovary.","pos":""}],"ANTHERIDIUM":[{"def":"The male reproductive apparatus in the lower, consisting of a cell or other cavity in which spermatozoids are produced; -- called also spermary.","pos":""}],"ANTHERIFORM":[{"def":"Shaped like an anther; anther-shaped.","pos":""}],"ANTHEROGENOUS":[{"def":"Transformed from anthers, as the petals of a double flower.","pos":""}],"ANTHEROID":[{"def":"Resembling an anther.","pos":""},{"def":"One of the mobile male reproductive bodies in the antheridia of cryptogams.","pos":""}],"ANTHESIS":[{"def":"The period or state of full expansion in a flower.","pos":""}],"ANTHOBIAN":[{"def":"A beetle which feeds on flowers.","pos":""}],"ANTHOBRANCHIA":[{"def":"A division of nudibranchiate Mollusca, in which the gills form a wreath or cluster upon the posterior part of the back.","pos":""}],"ANTHOCARPOUS":[{"def":"Having some portion of the floral envelopes attached to the pericarp to form the fruit, as in the checkerberry, the mulberry, and the pineapple.","pos":""}],"ANTHOCYANIN":[{"def":"Same as Anthokyan.","pos":""}],"ANTHODIUM":[{"def":"The inflorescence of a compound flower in which many florets are gathered into a involucrate head.","pos":""}],"ANTHOGRAPHY":[{"def":"A description of flowers.","pos":""}],"ANTHOID":[{"def":"Resembling a flower; flowerlike.","pos":""}],"ANTHOKYAN":[{"def":"The blue coloring matter of certain flowers.","pos":""}],"ANTHOLITE":[{"def":"A fossil plant, like a petrified flower.","pos":""}],"ANTHOLOGICAL":[{"def":"Pertaining to anthology; consisting of beautiful extracts from different authors, especially the poets.","pos":""}],"ANTHOLOGIST":[{"def":"One who compiles an anthology.","pos":""}],"ANTHOLOGY":[{"def":"A service book containing a selection of pieces for the festival services.","pos":""}],"ANTHOMANIA":[{"def":"A extravagant fondness for flowers.","pos":""}],"ANTHONY'S FIRE":[{"def":"See Saint Anthony's Fire, under Saint.","pos":""}],"ANTHOPHAGOUS":[{"def":"Eating flowers; -- said of certain insects.","pos":""}],"ANTHOPHORE":[{"def":"The stipe when developed into an internode between calyx and corolla, as in the Pink family.","pos":""}],"ANTHOPHOROUS":[{"def":"Flower bearing; supporting the flower.","pos":""}],"ANTHOPHYLLITE":[{"def":"A mineral of the hornblende group, of a yellowish gray or clove brown color.","pos":""}],"ANTHORISM":[{"def":"A description or definition contrary to that which is given by the adverse party.","pos":""}],"ANTHOTAXY":[{"def":"The arrangement of flowers in a cluster; the science of the relative position of flowers; inflorescence.","pos":""}],"ANTHOZOA":[{"def":"The class of the Coelenterata which includes the corals and sea anemones.","pos":""}],"ANTHOZOAN":[{"def":"Pertaining to the Anthozoa.","pos":""},{"def":"One of the Anthozoa.","pos":""}],"ANTHOZOIC":[{"def":"Of or pertaining to the Anthozoa.","pos":""}],"ANTHRACENE":[{"def":"A solid hydrocarbon, C6H4.","pos":""}],"ANTHRACENE OIL":[{"def":"A heavy green oil (partially solidifying on cooling), which distills over from coal tar at a temperature above 270º.","pos":""}],"ANTHRACIC":[{"def":"Of or relating to anthrax; as, anthracic blood.","pos":""}],"ANTHRACIFEROUS":[{"def":"Yielding anthracite; as, anthraciferous strata.","pos":""}],"ANTHRACITE":[{"def":"A hard, compact variety of mineral coal, of high luster, differing from bituminous coal in containing little or no bitumen, in consequence of which it burns with a nearly non luminous flame.","pos":""}],"ANTHRACITIC":[{"def":"Of, pertaining to, or like, anthracite; as, anthracitic formations.","pos":""}],"ANTHRACNOSE":[{"def":"Any one of several fungus diseases, caused by parasitic species of the series Melanconiales, attacking the bean, grape, melon, cotton, and other plants.","pos":""}],"ANTHRACOID":[{"def":"Resembling anthrax in action; of the nature of anthrax; as, an anthracoid microbe.","pos":""}],"ANTHRACOMANCY":[{"def":"Divination by inspecting a burning coal.","pos":""}],"ANTHRACOMETER":[{"def":"An instrument for measuring the amount of carbonic acid in a mixture.","pos":""}],"ANTHRACOMETRIC":[{"def":"Of or pertaining to an anthracometer.","pos":""}],"ANTHRACONITE":[{"def":"A coal-black marble, usually emitting a fetid smell when rubbed; -- called also stinkstone and swinestone.","pos":""}],"ANTHRACOSIS":[{"def":"A chronic lung disease, common among coal miners, due to the inhalation of coal dust; -- called also collier's lung and miner's phthisis.","pos":""}],"ANTHRAQUINONE":[{"def":"A hydrocarbon, C6H4.","pos":""}],"ANTHRAX":[{"def":"A microscopic, bacterial organism (Bacillus anthracis), resembling transparent rods.","pos":""}],"ANTHRAX VACCINE":[{"def":"A fluid vaccine obtained by growing a bacterium (Bacterium anthracis) in beef broth.","pos":""}],"ANTHRENUS":[{"def":"A genus of small beetles, several of which, in the larval state, are very destructive to woolen goods, fur, etc.","pos":""},{"def":"Like or related to man; human.","pos":""}],"ANTHROPIDAE":[{"def":"The group that includes man only.","pos":""}],"ANTHROPOCENTRIC":[{"def":"Assuming man as the center or ultimate end; -- applied to theories of the universe or of any part of it, as the solar system.","pos":""}],"ANTHROPOGENIC":[{"def":"Of or pertaining to anthropogeny.","pos":""}],"ANTHROPOGENY":[{"def":"The science or study of human generation, or the origin and development of man.","pos":""}],"ANTHROPOGEOGRAPHY":[{"def":"The science of the human species as to geographical distribution and environment.","pos":""}],"ANTHROPOGLOT":[{"def":"An animal which has a tongue resembling that of man, as the parrot.","pos":""}],"ANTHROPOGRAPHY":[{"def":"An`thro*pog\"ra*phy, n.","pos":""}],"ANTHROPOID":[{"def":"Resembling man; -- applied especially to certain apes, as the ourang or gorilla.","pos":""},{"def":"An anthropoid ape.","pos":""}],"ANTHROPOIDEA":[{"def":"The suborder of primates which includes the monkeys, apes, and man.","pos":""}],"ANTHROPOLITE":[{"def":"A petrifaction of the human body, or of any portion of it.","pos":""},{"def":"Pertaining to anthropology; belonging to the nature of man.","pos":""}],"ANTHROPOLOGIST":[{"def":"One who is versed in anthropology.","pos":""}],"ANTHROPOLOGY":[{"def":"The science of the structure and functions of the human body.","pos":""},{"def":"The science of man; -- sometimes used in a limited sense to mean the study of man as an object of natural history, or as an animal.","pos":""}],"ANTHROPOMANCY":[{"def":"Divination by the entrails of human being.","pos":""},{"def":"Pertaining to anthropometry.","pos":""}],"ANTHROPOMETRY":[{"def":"Measurement of the height and other dimensions of human beings, especially at different ages, or in different races, occupations, etc.","pos":""}],"ANTHROPOMORPHA":[{"def":"The manlike, or anthropoid, apes.","pos":""}],"ANTHROPOMORPHIC":[{"def":"Of or pertaining to anthromorphism.","pos":""}],"ANTHROPOMORPHISM":[{"def":"The representation of the Deity, or of a polytheistic deity, under a human form, or with human attributes and affections.","pos":""},{"def":"The ascription of human characteristics to things not human.","pos":""}],"ANTHROPOMORPHIST":[{"def":"One who attributes the human form or other human attributes to the Deity or to anything not human.","pos":""}],"ANTHROPOMORPHITE":[{"def":"One who ascribes a human form or human attributes to the Deity or to a polytheistic deity.","pos":""}],"ANTHROPOMORPHITIC":[{"def":"to anthropomorphism.","pos":""}],"ANTHROPOMORPHITISM":[{"def":"Anthropomorphism.","pos":""}],"ANTHROPOMORPHIZE":[{"def":"To attribute a human form or personality to.","pos":""}],"ANTHROPOMORPHOLOGY":[{"def":"The application to God of terms descriptive of human beings.","pos":""}],"ANTHROPOMORPHOSIS":[{"def":"Transformation into the form of a human being.","pos":""}],"ANTHROPOMORPHOUS":[{"def":"Having the figure of, or resemblance to, a man; as, an anthromorphous plant.","pos":""},{"def":"The science of the laws of the development of the human organism in relation to other organisms and to environment.","pos":""}],"ANTHROPOPATHITE":[{"def":"One who ascribes human feelings to deity.","pos":""}],"ANTHROPOPHAGI":[{"def":"Man eaters; cannibals.","pos":""},{"def":"Relating to cannibalism or anthropophagy.","pos":""}],"ANTHROPOPHAGINIAN":[{"def":"One who east human flesh.","pos":""}],"ANTHROPOPHAGITE":[{"def":"An`thro*poph\"a*gite, n.","pos":""}],"ANTHROPOPHAGOUS":[{"def":"Feeding on human flesh; cannibal.","pos":""}],"ANTHROPOPHAGY":[{"def":"The eating of human flesh; cannibalism.","pos":""}],"ANTHROPOPHUISM":[{"def":"An\"thro*poph\"u*ism, n.","pos":""}],"ANTHROPOSCOPY":[{"def":"The art of discovering or judging of a man's character, passions.","pos":""}],"ANTHROPOSOPHY":[{"def":"Knowledge of the nature of man; hence, human wisdom.","pos":""}],"ANTHROPOTOMICAL":[{"def":"Pertaining to anthropotomy, or the dissection of human bodies.","pos":""}],"ANTHROPOTOMIST":[{"def":"One who is versed in anthropotomy, or human anatomy.","pos":""}],"ANTHROPOTOMY":[{"def":"The anatomy or dissection of the human body; androtomy.","pos":""}],"ANTHYPNOTIC":[{"def":"See Antihypnotic.","pos":""}],"ANTHYPOCHONDRIAC":[{"def":"See Antihypochondriac.","pos":""}],"ANTHYSTERIC":[{"def":"See Antihysteric.","pos":""}]}