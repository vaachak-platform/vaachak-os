{"PARAGE":[{"def":"Equality of condition, blood, or dignity; also, equality in the partition of an inheritance.","pos":""},{"def":"Equality of condition between persons holding unequal portions of a fee.","pos":""}],"PARAGENESIS":[{"def":"The science which treats of minerals with special reference to their origin.","pos":""}],"PARAGENIC":[{"def":"Originating in the character of the germ, or at the first commencement of an individual; -- said of peculiarities of structure, character, etc.","pos":""}],"PARAGLOBULIN":[{"def":"An albuminous body in blood serum, belonging to the group of globulins.","pos":""}],"PARAGLOSSA":[{"def":"One of a pair of small appendages of the lingua or labium of certain insects.","pos":""}],"PARAGNATH":[{"def":"Same as Paragnathus.","pos":""}],"PARAGNATHOUS":[{"def":"Having both mandibles of equal length, the tips meeting, as in certain birds.","pos":""}],"PARAGOGE":[{"def":"The addition of a letter or syllable to the end of a word, as withouten for without.","pos":""}],"PARAGON":[{"def":"A size of type between great primer and double pica.","pos":""}],"PARAGONITE":[{"def":"A kind of mica related to muscovite, but containing soda instead of potash.","pos":""}],"PARAGRAM":[{"def":"Puns, which he calls paragrams.","pos":""}],"PARAGRAMMATIST":[{"def":"Par`a*gram\"ma*tist, n.","pos":""}],"PARAGRANDINE":[{"def":"An instrument to avert the occurrence of hailstorms.","pos":""}],"PARAGRAPH":[{"def":"Originally, a marginal mark or note, set in the margin to call attention to something in the text, e.","pos":""},{"def":"A distinct part of a discourse or writing; any section or subdivision of a writing or chapter which relates to a particular point, whether consisting of one or many sentences.","pos":""}],"PARAGRAPHER":[{"def":"A writer of paragraphs; a paragraphist.","pos":""},{"def":"Pertaining to, or consisting of, a paragraph or paragraphs.","pos":""}],"PARAGRAPHISTICAL":[{"def":"Of or relating to a paragraphist.","pos":""}],"PARAGRELE":[{"def":"A lightning conductor erected, as in a vineyard, for drawing off the electricity in the atmosphere in order to prevent hailstorms.","pos":""}],"PARAGUAY TEA":[{"def":"See Mate, the leaf of the Brazilian holly.","pos":""}],"PARAGUAYAN":[{"def":"Of or pertaining to Paraguay.","pos":""},{"def":"A native or inhabitant of Paraguay.","pos":""}]}