{"RESE":[{"def":"To shake; to quake; to tremble.","pos":""}],"RESEARCH":[{"def":"Diligent inquiry or examination in seeking facts or principles; laborius or continued search after truth; as, researches of human wisdom.","pos":""}],"RESEARCHER":[{"def":"One who researches.","pos":""}],"RESEARCHFUL":[{"def":"Making researches; inquisitive.","pos":""}],"RESEAT":[{"def":"To seat or set again, as on a chair, throne, etc.","pos":""},{"def":"To put a new seat, or new seats, in; as, to reseat a theater; to reseat a chair or trousers.","pos":""}],"RESEAU":[{"def":"A system of lines forming small squares of standard size, which is photographed, by a separate exposure, on the same plate with star images to facilitate measurements, detect changes of the film, etc.","pos":""}],"RESECT":[{"def":"To cut or pare off; to remove by cutting.","pos":""}],"RESECTION":[{"def":"The removal of the articular extremity of a bone, or of the ends of the bones in a false articulation.","pos":""}],"RESEDA":[{"def":"A genus of plants, the type of which is mignonette.","pos":""}],"RESEIZE":[{"def":"To take possession of, as lands and tenements which have been disseized.","pos":""}],"RESEIZER":[{"def":"The taking of lands into the hands of the king where a general livery, or oustre le main, was formerly mis-sued, contrary to the form and order of law.","pos":""}],"RESEIZURE":[{"def":"A second seizure; the act of seizing again.","pos":""}],"RESELL":[{"def":"To sell again; to sell what has been bought or sold; to retail.","pos":""}],"RESEMBLABLE":[{"def":"Admitting of being compared; like.","pos":""}],"RESEMBLANCE":[{"def":"The quality or state of resembling; likeness; similitude; similarity.","pos":""},{"def":"That which resembles, or is similar; a representation; a likeness.","pos":""}],"RESEMBLANT":[{"def":"Having or exhibiting resemblance; resembling.","pos":""}],"RESEMBLE":[{"def":"To be like or similar to; to bear the similitude of, either in appearance or qualities; as, these brothers resemble each other.","pos":""},{"def":"To liken; to compare; to represent as like.","pos":""}],"RESEMBLER":[{"def":"One who resembles.","pos":""}],"RESEMBLINGLY":[{"def":"So as to resemble; with resemblance or likeness.","pos":""}],"RESEMINATE":[{"def":"To produce again by means of seed.","pos":""}],"RESEND":[{"def":"To send on from an intermediate station by means of a repeater.","pos":""}],"RESENT":[{"def":"To be sensible of; to feel; as: (a) In a good sense, to take well; to receive with satisfaction.","pos":""},{"def":"To express or exhibit displeasure or indignation at, as by words or acts.","pos":""}],"RESENTER":[{"def":"One who resents.","pos":""}],"RESENTFUL":[{"def":"Inclined to resent; easily provoked to anger; irritable.","pos":""}],"RESENTIMENT":[{"def":"Re*sent\"i*ment (--ment), n.","pos":""}],"RESENTINGLY":[{"def":"With deep sense or strong perception.","pos":""},{"def":"With a sense of wrong or affront; with resentment.","pos":""}],"RESENTMENT":[{"def":"The act of resenting.","pos":""},{"def":"The state of holding something in the mind as a subject of contemplation, or of being inclined to reflect upon something; a state consciousness; conviction; feeling; impression.","pos":""}],"RESERATE":[{"def":"To unlock; to open.","pos":""}],"RESERVANCE":[{"def":"Re*serv\"ance (r-zrv\"ans), n.","pos":""}],"RESERVATION":[{"def":"The act of reserving, or keeping back; concealment, or withholding from disclosure; reserve.","pos":""},{"def":"Something withheld, either not expressed or disclosed, or not given up or brought forward.","pos":""}],"RESERVATIVE":[{"def":"Tending to reserve or keep; keeping; reserving.","pos":""}],"RESERVATORY":[{"def":"A place in which things are reserved or kept.","pos":""}],"RESERVE":[{"def":"To keep back; to retain; not to deliver, make over, or disclose.","pos":""},{"def":"Hence, to keep in store for future or special use; to withhold from present use for another purpose or time; to keep; to retain.","pos":""}],"RESERVE CITY":[{"def":"In the national banking system of the United States, any of certain cities in which the national banks are required (U.","pos":""}],"RESERVED":[{"def":"Kept for future or special use, or for an exigency; as, reserved troops; a reserved seat in a theater.","pos":""},{"def":"Restrained from freedom in words or actions; backward, or cautious, in communicating one's thoughts and feelings; not free or frank.","pos":""}],"RESERVEE":[{"def":"One to, or for, whom anything is reserved; -- contrasted with reservor.","pos":""}],"RESERVER":[{"def":"One who reserves.","pos":""}],"RESERVIST":[{"def":"A member of a reserve force of soldiers or militia.","pos":""}],"RESERVOIR":[{"def":"A small intercellular space, often containing Receiving reservoir (Water Works), a principal reservoir into which an aqueduct or rising main delivers water, and from which a distributing reservoir draws its supply.","pos":""}],"RESERVOR":[{"def":"One who reserves; a reserver.","pos":""}],"RESET":[{"def":"To set again; as, to reset type; to reset copy; to reset a diamond.","pos":""}],"RESETTER":[{"def":"One who receives or conceals, as stolen goods or criminal.","pos":""}],"RESETTLE":[{"def":"To settle again.","pos":""}],"RESETTLEMENT":[{"def":"Act of settling again, or state of being settled again; as, the resettlement of lees.","pos":""}]}