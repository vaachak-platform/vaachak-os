{"RETUND":[{"def":"To blunt; to turn, as an edge; figuratively, to cause to be obtuse or dull; as, to retund confidence.","pos":""}],"RETURN":[{"def":"To turn back; to go or come again to the same place or condition.","pos":""},{"def":"To come back, or begin again, after an interval, regular or irregular; to appear again.","pos":""}],"RETURNABLE":[{"def":"Legally required to be returned, delivered, given, or rendered; as, a writ or precept returnable at a certain day; a verdict returnable to the court.","pos":""}],"RETURNER":[{"def":"One who returns.","pos":""}],"RETURNLESS":[{"def":"Admitting no return.","pos":""}],"RETUSE":[{"def":"Having the end rounded and slightly indented; as, a retuse leaf.","pos":""}]}