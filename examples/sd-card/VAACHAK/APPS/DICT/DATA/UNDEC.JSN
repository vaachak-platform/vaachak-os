{"UNDECAGON":[{"def":"A figure having eleven angles and eleven sides.","pos":""}],"UNDECANE":[{"def":"A liquid hydrocarbon, C11H24, of the methane series, found in petroleum; -- so called from its containing eleven carbon atoms in the molecule.","pos":""}],"UNDECEIVE":[{"def":"To cause to be no longer deceived; to free from deception, fraud, fallacy, or mistake.","pos":""}],"UNDECENNARY":[{"def":"Occurring once in every period of eleven years; undecennial.","pos":""}],"UNDECENNIAL":[{"def":"Occurring or observed every eleventh year; belonging to, or continuing, a period of eleven years; undecennary; as, an undecennial festival.","pos":""}],"UNDECIDE":[{"def":"To reverse or recant, as a previous decision.","pos":""}],"UNDECK":[{"def":"To divest of ornaments.","pos":""}],"UNDECKED":[{"def":"Not decked; unadorned.","pos":""},{"def":"Not having a deck; as, an undecked vessel.","pos":""}],"UNDECOLIC":[{"def":"Pertaining to, or designating, an acid, C11H18O2, of the propiolic acid series, obtained indirectly from undecylenic acid as a white crystalline substance.","pos":""}],"UNDECREED":[{"def":"Reversed or nullified by decree, as something previously decreed.","pos":""}],"UNDECYL":[{"def":"The radical regarded as characteristic of undecylic acid.","pos":""}],"UNDECYLENIC":[{"def":"Pertaining to, or designating, an acid C11H20O2, homologous with acrylic acid, and obtained as a white crystalline substance by the distillation of castor oil.","pos":""}],"UNDECYLIC":[{"def":"Related to, derived from, or containing, undecyl; specifically, designating that member of the fatty acids which corresponds to undecane, and is obtained as a white crystalline substance, C11H22O2.","pos":""}]}