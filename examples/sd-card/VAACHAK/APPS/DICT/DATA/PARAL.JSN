{"PARALACTIC":[{"def":"Designating an acid called paralactic acid.","pos":""}],"PARALBUMIN":[{"def":"A proteidlike body found in the fluid from ovarian cysts and elsewhere.","pos":""}],"PARALDEHYDE":[{"def":"A polymeric modification of aldehyde obtained as a white crystalline substance.","pos":""}],"PARALEIPSIS":[{"def":"A pretended or apparent omission; a figure by which a speaker artfully pretends to pass by what he really mentions; as, for example, if an orator should say, \"I do not speak of my adversary's scandalous venality and rapacity, his brutal conduct, his treachery and malice.","pos":""}],"PARALEPSIS":[{"def":"See Paraleipsis.","pos":""}],"PARALGESIA":[{"def":"Disordered sensibility to pain, including absence of sensibility to pain, excessive sensibility to pain, and abnormal painful results of stimuli.","pos":""}],"PARALIAN":[{"def":"A dweller by the sea.","pos":""}],"PARALIPOMENON":[{"def":"A title given in the Douay Bible to the Books of Chronicles.","pos":""}],"PARALIPSIS":[{"def":"See Paraleipsis.","pos":""},{"def":"Of or pertaining to a parallax.","pos":""}],"PARALLAX":[{"def":"The apparent difference in position of a body (as the sun, or a star) as seen from some point on the earth's surface, and as seen from some other conventional point, as the earth's center or the sun.","pos":""}],"PARALLEL":[{"def":"Extended in the same direction, and in all parts equally distant; as, parallel lines; parallel planes.","pos":""}],"PARALLEL STANDARDS":[{"def":"Two or more metals coined without any attempt by the government to regulate their values.","pos":""}],"PARALLEL SULCUS":[{"def":"A sulcus parallel to, but some distance below, the horizontal limb of the fissure of Sylvius.","pos":""}],"PARALLEL TRANSFORMER":[{"def":"A transformer connected in parallel.","pos":""}],"PARALLEL VISE":[{"def":"A vise with jaws so guided as to remain parallel.","pos":""}],"PARALLELABLE":[{"def":"Capable of being paralleled, or equaled.","pos":""}],"PARALLELISM":[{"def":"The quality or state of being parallel.","pos":""},{"def":"Resemblance; correspondence; similarity.","pos":""}],"PARALLELISTIC":[{"def":"Of the nature of a parallelism; involving parallelism.","pos":""}],"PARALLELIZE":[{"def":"To render parallel.","pos":""}],"PARALLELLY":[{"def":"In a parallel manner; with parallelism.","pos":""}],"PARALLELOGRAM":[{"def":"A right-lined quadrilateral figure, whose opposite sides are parallel, and consequently equal; -- sometimes restricted in popular usage to a rectangle, or quadrilateral figure which is longer than it is broad, and with right angles.","pos":""}],"PARALLELOGRAMMATIC":[{"def":"Of or pertaining to a parallelogram; parallelogrammic.","pos":""},{"def":"Having the properties of a parallelogram.","pos":""}],"PARALLELOPIPED":[{"def":"A solid, the faces of which are six parallelograms, the opposite pairs being parallel, and equal to each other; a prism whose base is a parallelogram.","pos":""}],"PARALLELOPIPEDON":[{"def":"A parallelopiped.","pos":""}],"PARALOGICAL":[{"def":"Containing paralogism; illogical.","pos":""}],"PARALOGISM":[{"def":"A reasoning which is false in point of form, that is, which is contrary to logical rules or formulæ; a formal fallacy, or pseudo- syllogism, in which the conclusion does not follow from the premises.","pos":""}],"PARALOGIZE":[{"def":"To reason falsely; to draw conclusions not warranted by the premises.","pos":""}],"PARALOGY":[{"def":"False reasoning; paralogism.","pos":""}],"PARALYSE":[{"def":"Same as Paralyze.","pos":""}],"PARALYSIS":[{"def":"Abolition of function, whether complete or partial; esp.","pos":""}],"PARALYTIC":[{"def":"Of or pertaining to paralysis; resembling paralysis.","pos":""},{"def":"Affected with paralysis, or palsy.","pos":""}],"PARALYZATION":[{"def":"The act or process of paralyzing, or the state of being paralyzed.","pos":""}],"PARALYZE":[{"def":"To affect or strike with paralysis or palsy.","pos":""}]}