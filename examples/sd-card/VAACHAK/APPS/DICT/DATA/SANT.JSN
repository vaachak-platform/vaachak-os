{"SANTAL":[{"def":"A colorless crystalline substance, isomeric with piperonal, but having weak acid properties.","pos":""}],"SANTALACEOUS":[{"def":"Of or pertaining to a natural order of plants (Santalaceæ), of which the genus Santalum is the type, and which includes the buffalo nut and a few other North American plants, and many peculiar plants of the southern hemisphere.","pos":""}],"SANTALIC":[{"def":"Of, pertaining to, or obtained from, sandalwood (Santalum); -- used specifically to designate an acid obtained as a resinous or red crystalline dyestuff, which is called also santalin.","pos":""}],"SANTALUM":[{"def":"A genus of trees with entire opposite leaves and small apetalous flowers.","pos":""}],"SANTEES":[{"def":"One of the seven confederated tribes of Indians belonging to the Sioux, or Dakotas.","pos":""}],"SANTON":[{"def":"A Turkish saint; a kind of dervish, regarded by the people as a saint: also, a hermit.","pos":""}],"SANTONATE":[{"def":"A salt of santonic acid.","pos":""}],"SANTONIC":[{"def":"Of, pertaining to, or designating, an acid (distinct from santoninic acid) obtained from santonin as a white crystalline substance.","pos":""}],"SANTONIN":[{"def":"A white crystalline substance having a bitter taste, extracted from the buds of levant wormseed and used as an anthelmintic.","pos":""}],"SANTONINATE":[{"def":"A salt of santoninic acid.","pos":""}],"SANTONINIC":[{"def":"Of or pertaining to santonin; -- used specifically to designate an acid not known in the free state, but obtained in its salts.","pos":""}]}