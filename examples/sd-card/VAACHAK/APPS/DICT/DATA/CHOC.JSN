{"CHOCK":[{"def":"To stop or fasten, as with a wedge, or block; to scotch; as, to chock a wheel or cask.","pos":""}],"CHOCK-FULL":[{"def":"Quite full; choke-full.","pos":""}],"CHOCKABLOCK":[{"def":"Hoisted as high as the tackle will admit; brought close together, as the two blocks of a tackle in hoisting.","pos":""}],"CHOCOLATE":[{"def":"A paste or cake composed of the roasted seeds of the Theobroma Cacao ground and mixed with other ingredients, usually sugar, and cinnamon or vanilla.","pos":""},{"def":"The beverage made by dissolving a portion of the paste or cake in boiling water or milk.","pos":""}]}