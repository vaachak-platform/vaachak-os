fn phase38i_is_epub_or_epu_name(name: &[u8]) -> bool {
    if name.len() >= 5
        && name[name.len() - 5] == b'.'
        && name[name.len() - 4..].eq_ignore_ascii_case(b"EPUB")
    {
        return true;
    }

    name.len() >= 4
        && name[name.len() - 4] == b'.'
        && name[name.len() - 3..].eq_ignore_ascii_case(b"EPU")
}
